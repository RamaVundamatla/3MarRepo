    <JadeMethod name="customScheduleTime" id="2203f265-40b0-4b67-a61c-2fe1e017a1aa">
        <source>customScheduleTime(pNextDate : Date output; pNextTime: Time output):Boolean protected;
// Reimplement on the task as required, return true in the re-implementation.
begin
	return false;
end;</source>
        <access>protected</access>
        <Parameter name="pNextDate" type="Date" usage="output"/>
        <Parameter name="pNextTime" type="Time" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTask" id="04a71f25-b8d8-4ca3-b684-b1e59a889cdb">
        <updating/>
        <source>doTask():Boolean updating;

// Re-implement at a lower level.

begin
	self.notifyStartOfTask();
	
	// Action here.
	
	// Finish here.
	self.notifyFinishOfTask(true);
	
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getIdentification" id="66ec43ad-6acb-4d23-a513-61954276c53a">
        <source>getIdentification():String;

vars
	retValue : String;
	
begin
	if self.taskComment = null then
		retValue	:=	self.taskName;
	else
		retValue	:=	self.taskName &amp; " [" &amp; self.taskComment &amp; "]";
	endif;
	
	if self.completedTimeStamp.isValid then
		retValue	:=	retValue &amp; " - " &amp; self.completedTimeStamp.date.shortFormat() &amp; ", " &amp; self.completedTimeStamp.time.String;
	else
		retValue	:=	retValue &amp; " - " &amp; self.scheduleTimeStamp.date.shortFormat() &amp; ", " &amp; self.scheduleTimeStamp.time.String;
	endif;
	
	return retValue;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextScheduleTime" id="3e220d87-981c-41db-9bc9-41d34640ca8d">
        <source>getNextScheduleTime():TimeStamp;

vars
	now				: TimeStamp;
	nextRunTime		: TimeStamp;
	nowDate			: Date;
	nextDate 		: Date;
	nowTime 		: Time;
	nextTime 		: Time;
	nowDayOfWeek	: Integer;
	nextDayArray	: BooleanArray;
	pos				: Integer;
	inXDays			: Integer;
	minutesAfterMid	: Integer;
	
begin
	if self.isOneTimeOnly then
		nextDate		:=	null;
		nextTime		:=	null;
	else
		now				:=	app.actualTimeServer();// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		nowDate			:=	now.Date;
		nowTime			:=	now.Time;
		nowDayOfWeek	:=	now.Date.dayOfWeek();
		
		if self.isCustomSchedule then
	
			if customScheduleTime(nextDate,nextTime) then
		
				//values been updated in the reimplementation..
			else
				// selected custom but no values returned.
				nextDate := null;
				nextTime := null;
			endif;	
		
		elseif self.daysToExecute &lt;&gt; self.WEEK_INACTIVE then	// execution dependant upon day of the week, at a pre-determined time.

			create nextDayArray transient;
				
			nextDayArray.add(self.daysToExecute[1:1] = self.DAY_ACTIVE); //monday
			nextDayArray.add(self.daysToExecute[2:1] = self.DAY_ACTIVE); //tuesday
			nextDayArray.add(self.daysToExecute[3:1] = self.DAY_ACTIVE); //wednesday
			nextDayArray.add(self.daysToExecute[4:1] = self.DAY_ACTIVE); //thursday
			nextDayArray.add(self.daysToExecute[5:1] = self.DAY_ACTIVE); //friday
			nextDayArray.add(self.daysToExecute[6:1] = self.DAY_ACTIVE); //saturday
			nextDayArray.add(self.daysToExecute[7:1] = self.DAY_ACTIVE); //sunday
			nextDayArray.add(self.daysToExecute[1:1] = self.DAY_ACTIVE); //monday
			nextDayArray.add(self.daysToExecute[2:1] = self.DAY_ACTIVE); //tuesday
			nextDayArray.add(self.daysToExecute[3:1] = self.DAY_ACTIVE); //wednesday
			nextDayArray.add(self.daysToExecute[4:1] = self.DAY_ACTIVE); //thursday
			nextDayArray.add(self.daysToExecute[5:1] = self.DAY_ACTIVE); //friday
			nextDayArray.add(self.daysToExecute[6:1] = self.DAY_ACTIVE); //saturday
			nextDayArray.add(self.daysToExecute[7:1] = self.DAY_ACTIVE); //sunday
			
			//find next day required
			foreach pos in nowDayOfWeek + 1 to 14 do
				if nextDayArray[pos] then
					inXDays := pos - nowDayOfWeek; // number of days forward till next run. 
					nextDate := ( nowDate + inXDays ).Date;
					break;
				endif; 
			endforeach; 
			
			nextTime := self.daysToExecuteTime;
						
		elseif self.minsBetweenExecution &lt;&gt; 0 then // execute every 'n' mins. (every day)
		
			minutesAfterMid := getMinutesAfterMidnight(nowTime) + self.minsBetweenExecution; 
			if minutesAfterMid &gt;= 1440 then // next execute at or after midnight
				nextDate := ( nowDate + 1 ).Date;
				minutesAfterMid := minutesAfterMid - 1440; 
			else // next execute still today
				nextDate := nowDate;
			endif;
			nextTime := getTimeFromMinsAfterMidnight(minutesAfterMid);
			  
		endif;
				
	endif;
	
	nextRunTime.setDate(nextDate);
	nextRunTime.setTime(nextTime);
			
epilog
	delete nextDayArray;
	
	return nextRunTime;	
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getSecondsBeforeExecution" id="19efb530-623b-4d30-a00f-d6e95878c4ff">
        <source>getSecondsBeforeExecution();

	//Only works if called from the same process....

vars
	option			: Integer; 
	timeRemaining	: Integer;
	
begin
	option := Timer_OneShot;	
//	write self.getTimerStatus(DO_TASK, option, timeRemaining);	
//	write timeRemaining;
end;</source>
    </JadeMethod>
    <JadeMethod name="getStatusColour" id="81162eb1-0adb-4059-990e-37b33608c68f">
        <source>getStatusColour(): Integer;

vars
	now : Date;
	
begin
	if self.isRunning then
		return self.myManager.getColorActive();
		
	elseif self.isScheduled then
		return self.myManager.getColorQueued();
		
	elseif self.completedTimeStamp.isValid then
		if self.isFailed then
			return self.myManager.getColorFailed();
		else
			return self.myManager.getColorCompleted();
		endif;
	endif;
	
	now := app.actualTimeServer().Date;// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	if now &lt; self.scheduleTimeStamp.Date then
		return self.myManager.getColorPrequeued();	//will be scheduled some day in the future
	else
		return self.myManager.getColorPrequeuedReady();
	endif;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initializeMe" id="654292e5-72b9-4070-a0df-358e2db9dcf1">
        <updating/>
        <source>initializeMe(	pTaskName : String;
				pStartTime : TimeStamp;
				pIsOneTimeOnly : Boolean;
				pIsRescheduleDaily:Boolean;
				pIsRunEveryNMinutes:Boolean;
				pIsRestartOnFailure : Boolean;
				pDaysToExecute : String;
				pDaysToExecuteTime : Time;
				pMinsBetweenExecution : Integer;
				pUseCustomSchedule : Boolean;
				pManagerObj : CnEcBackShedManager) updating;
// -----------------------------------------------------------------------------
// Created:		17 June 2003 by cnwdad1
//
// Purpose:		Initializes the receiver's properties.
//
// Parameters:	Matching property parameters.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 17/06/2003	cnwdad1		Added the isRescheduleDaily and isRunEveryNMinutes
//							attributes.
// -----------------------------------------------------------------------------
begin
	self.scheduleTimeStamp		:=	pStartTime;
	self.isOneTimeOnly			:=	pIsOneTimeOnly;
	self.isRescheduleDaily		:=	pIsRescheduleDaily;
	self.isRunEveryNMinutes		:=	pIsRunEveryNMinutes;
	self.isRestartOnFailure		:=	pIsRestartOnFailure;
	self.daysToExecute			:=	pDaysToExecute;
	self.daysToExecuteTime		:=	pDaysToExecuteTime;
	self.minsBetweenExecution	:=	pMinsBetweenExecution;
	self.isCustomSchedule 		:=	pUseCustomSchedule;
	
	self.taskName				:=	pTaskName;
	
	self.myManager				:=	pManagerObj;		
end;</source>
        <Parameter name="pTaskName" type="String"/>
        <Parameter name="pStartTime" type="TimeStamp"/>
        <Parameter name="pIsOneTimeOnly" type="Boolean"/>
        <Parameter name="pIsRescheduleDaily" type="Boolean"/>
        <Parameter name="pIsRunEveryNMinutes" type="Boolean"/>
        <Parameter name="pIsRestartOnFailure" type="Boolean"/>
        <Parameter name="pDaysToExecute" type="String"/>
        <Parameter name="pDaysToExecuteTime" type="Time"/>
        <Parameter name="pMinsBetweenExecution" type="Integer"/>
        <Parameter name="pUseCustomSchedule" type="Boolean"/>
        <Parameter name="pManagerObj" type="CnEcBackShedManager"/>
    </JadeMethod>
    <JadeMethod name="isRunFriday" id="2240d2b8-3fe2-4aff-b0a4-8473fba35d24">
        <source>isRunFriday():Boolean;
// -----------------------------------------------------------------------------
// Created:		15 December 2001 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the task runs on a Friday.
//
// Parameters:	None
//
// Returns:		True if the task runs on a Friday, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	return (self.daysToExecute[5:1] = self.DAY_ACTIVE);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
