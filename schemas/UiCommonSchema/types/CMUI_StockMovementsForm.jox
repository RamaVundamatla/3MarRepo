    <JadeMethod name="loadTermAreas" id="79dc2281-6cd2-4a4f-8710-1088e24fa422">
        <updating/>
        <source>loadTermAreas() updating;
// ---------------------------------------------------------------------------
// Created:     30 July 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ta					: CM_TerminalArea;
	count				: Integer;
	idx					: Integer;
begin
	cmbLocation.clear;
	
	foreach ta in self.myTerminal.allTerminalAreas where ta.isStockControlled do
		count := count + 1;
		idx := cmbLocation.addItem(self.displayEntryLocation(ta));
		cmbLocation.itemObject[idx] := ta;
			
		if count = 1 then
			if self.myFiltTA = null then
				self.myFiltTA := ta;
			endif;
		endif;
	endforeach;
	
	if count &gt; 0 then
		cmbLocation.listObject := self.myFiltTA;
		tblEntQuery.setValueByName(ETRow_Location, self.myFiltTA.id);
	else
		tblEntQuery.setValueByName(ETRow_Location, null);		
	endif;
end;</source>
