    <JadeMethod name="getMyParent" id="9d4e6d22-d746-40cf-a8e2-3c205e14dd8d">
        <source>getMyParent() : CM_HSCodeSection;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
09 December 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars

begin
	if self.myHSSection &lt;&gt; null and self.myHSSection.isTransient and not self.myHSSection.pxyIsProxy then
		return app.myRoot.allHSSections[self.myHSSection.id];
	endif;
	
	return self.myHSSection;

epilog

end;</source>
        <ReturnType type="CM_HSCodeSection"/>
    </JadeMethod>
