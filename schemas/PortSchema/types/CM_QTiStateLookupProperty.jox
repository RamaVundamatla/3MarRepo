    <JadeMethod name="create" id="0cfddd75-5bd4-4ae9-98ab-aa3f01ac98b1">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     06 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	oper : CM_QueryOperator;

begin
	if self.isTransient then 
		return;
	endif;
		
	create oper as CM_QIntegerLookupEqual persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QIntegerLookupNotEqual persistent;
	self.allAllowedOperators.add(oper);

	create oper as CM_QIntegerIsOneOf persistent;
	self.allAllowedOperators.add(oper);

end;</source>
    </JadeMethod>
    <JadeMethod name="doesIncludeState" id="a1fa084c-2a30-4fc5-8c79-e574f530fc92">
        <source>doesIncludeState(_state : Integer; _operator : CM_QIntegerIsOneOf) : String protected;
// ---------------------------------------------------------------------------
// Created:     05 November 2003	cnwth2:b
//
// Purpose:     Returns checkbox value
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _operator &lt;&gt; null and _operator.allSelectionValues.includes(_state) then
		return '1';
	endif;
	
	return '0';

end;</source>
        <access>protected</access>
        <Parameter name="_state" type="Integer"/>
        <Parameter name="_operator" type="CM_QIntegerIsOneOf"/>
        <ReturnType type="String"/>
    </JadeMethod>
