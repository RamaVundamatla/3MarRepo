    <JadeMethod name="setDisabledItems" id="0c11cecf-aff5-4021-a433-048b70dc3e4d">
        <updating/>
        <source>setDisabledItems(_disabledRows : ObjectArray) updating;
// --------------------------------------------------------------------------------
// Created:		12 August 2010 by cnwjo3
//
// Purpose:		Disable rows and make them look disabled
//
// Changed On	By			Reason
// ----------	--------	----------------------------------------------------------
// 05/11/2020	jlgdap1		TFS 50136 POL Prenote Picker Disables Wrong Rows - changed signature from IntegerArray to ObjectArray
vars

	theRow,
	idx		: Integer;
	e : Boolean;
	rows : Integer;
	obj : Object;				// TFS 50136
begin
	rows := self.tblList.rows;
	
	//foreach idx in _disabledRows do
	foreach obj in _disabledRows do
		idx := self.tblList.cnEcFindObjectRowNo(obj);			// TFS 50136
		if idx &lt;&gt; null then										// TFS 50136
			tblList.accessRow(idx).enabled := false;
			tblList.accessRow(idx).backColor := #E9E9E9;
			tblList.accessRow(idx).foreColor := Gray;
		endif;													// TFS 50136
	endforeach;
	
	//need to reselect top row since it may now be disabled
	self.defaultSelectRow();
end;</source>
