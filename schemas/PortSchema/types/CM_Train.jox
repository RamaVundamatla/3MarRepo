    <JadeMethod name="setToDoTaskComplete" id="0a251b4c-68a8-48cd-b5ba-0645b39430b2">
        <updating/>
        <source>setToDoTaskComplete(taskCode : Integer; _passport : CM_Passport input; _resourceUsageProxys : CM_ResourceTypeUsageSet; _wodtl: CM_WorkOrderToDoDtl) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
30 November 2022	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen
19 May 2023			navhl20	ChangeRequest 56631:[56185] EUP - Transport Mode change - UI Changes
*/

vars
	task 				: CM_ToDoTask;
	found 				: Boolean;
	wod 				: CM_WodToDoTrain;
	eventType			: Integer;
	event, trans		: CM_Transaction;
	resourceUsageProxys	: CM_ResourceTypeUsageSet;
	tasksComplete		: Boolean;
	transType : CM_TransactionType;
begin
	tasksComplete := true;

	foreach task in self.allToDoTasksToDo where (task.toDoTaskDescCode = taskCode and _wodtl.allToDoTasks.includes(task)) do
		found := true;
		break;
	endforeach;
	
	create resourceUsageProxys transient;
	if _resourceUsageProxys &lt;&gt; null then
		_resourceUsageProxys.copy(resourceUsageProxys);
	endif;
	
	if found then
		wod := task.myWODetailToDo.CM_WodToDoTrain;
		task.setToDoTaskComplete(_passport, resourceUsageProxys);
		task.CM_TrainToDoTask.updateTrainComplete();
		trans := wod.createWOTransaction(wod.TRANS_COMPLETED, resourceUsageProxys, task);	 // ### JIRA 23013 16OCT2024 NAVAB1
		
		// ### JIRA 14793 24OCT2024 NAVAB1
		transType := task.toDoTaskDesc.myTransactionType;
		if transType &lt;&gt; null and transType.isForWorkOrder()    then // WO Trans Type
			trans := wod.createWOTransactionUserDefined(transType.trxType, resourceUsageProxys, task);
		
		else
			eventType := task.getToDoTaskCompleteEventInt;	
			if eventType &lt;&gt; null then
				event := self.createTransaction(eventType, app.actualTime, resourceUsageProxys, task, wod); // ### TFS CR 57927 TASK 54268 22MAY2023 NAVAB1
				/* // ### TFS CR 57927 TASK 54268 22MAY2023 NAVAB1
				if event &lt;&gt; null then															//19.5.2023 navhl20 #56631[56185]
					event.addResourcesFromProxys(resourceUsageProxys);
				endif;
				*/
			endif;
		endif;
		
		foreach task in self.allToDoTasksToDo do
			if task.myWODetailToDo = wod and task.status = STATUS_TODO then
				tasksComplete := false;	
			endif;
		endforeach;
		if tasksComplete then		
			wod.allTrainsActioned.remove(self);
			wod.allTrainsCompleted.add(self);
		endif;
		self.updateObjectEdition(self);
	endif;

epilog
	delete resourceUsageProxys;
end;</source>
        <Parameter name="taskCode" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_resourceUsageProxys" type="CM_ResourceTypeUsageSet"/>
        <Parameter name="_wodtl" type="CM_WorkOrderToDoDtl"/>
    </JadeMethod>
    <JadeMethod name="setupBGPRequest" id="dd1e36d4-e7d3-43a1-befc-19c627e8a159">
        <updating/>
        <source>setupBGPRequest(_eventTransaction : CMEVT_TrainTransaction) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Feb 2019	jlgsl4	TFS 40360 - NXL - KiwiRail EDI message

*/

vars
	trainTerminal : CM_Terminal;
	proxyBGPRequest : BGP_KiwiRailWSRequest;
	bgpRequest : BGP_ExternalWSRequest;
begin
	if _eventTransaction.getMappedWSDef() &lt;&gt; null then // if valid event-to-webservice mapping exists
		create proxyBGPRequest transient; // then set up BGP request to call webservice
		proxyBGPRequest.setMyEventTransaction(_eventTransaction);
		trainTerminal := self.myTerminalDeparted;
		if trainTerminal = null then
			trainTerminal := self.myTerminal;
		endif;
		proxyBGPRequest.setTerminal(trainTerminal);
		if process.isInTransactionState then
			app.myUtilityCA.utlCreateBGPRequestExtWS(proxyBGPRequest, bgpRequest, app.myPassport);
		else
			app.myTrxCA.trxCreateBGPRequestExtWS(proxyBGPRequest, bgpRequest, app.myPassport);
		endif;
	endif;
epilog
	delete proxyBGPRequest;
end;</source>
        <Parameter name="_eventTransaction" type="CMEVT_TrainTransaction"/>
    </JadeMethod>
    <JadeMethod name="validateDepartureProcess" id="a6361eb2-4df7-462e-b265-19dba421ab77">
        <source>validateDepartureProcess();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22/08/2023	navkc1	CR 59610 Task 59611: Jade - Stop Prevention
21 Oct 2024	navbs1  Story MTN-14791: EUP | 53856 - New Scanning App - Unpack mode issue

*/

vars
	ti				: CM_TrackedItem;
	
begin
	
	foreach ti in self.allAssignedTIs discreteLock do
		app.myPassport.setContext(Context_Pass_CUST_FullyCleared); // ### TFS CR 60424 TASK 60549 16OCT2023 NAVAB1		//21.10.2024  navbs1  #14791
		ti.checkStopsToBePrevented(StopPreventTrainDeparture, null, true);
		app.myPassport.setContext(Context_Pass_Null); // ### TFS CR 60424 TASK 60549 17OCT2023 NAVAB1					//21.10.2024  navbs1  #14791
	endforeach;
	
epilog
	app.myPassport.setContext(Context_Pass_Null); // ### TFS CR 60424 TASK 60549 17OCT2023 NAVAB1						//21.10.2024  navbs1  #14791
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="1f4ee9b5-2622-4381-80fd-5cb6792f8cec">
        <source>validateForCreate();
/*
----------   ----------  --------------------------------------------------
Created:	06 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	
begin

	if self.myTerminal.allTrainsOnTerminal[self.code, self.scheduledArrivalDT] &lt;&gt; null then
// PAR 19710		app.raiseCMException1(Full_Replacement_Message, 'The train code "' &amp; self.code &amp; '" has already been used, it must be unique.', null,  self);
//		app.raiseCMException1(Train_code_alrea_been_used_mu, self.getCodeDateString(), null,  self); //+ cnwmd1, CCMS 1067, Par 20009
		
	endif;
	
	self.validateForUpdate();
end;


</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="cc2590f7-af9e-4081-96f9-3626f218d870">
        <source>validateForDelete();
/*
----------   ----------  --------------------------------------------------
Created:	07 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	wagon		: CM_Wagon;
	
begin
	if app.isUnitTestGarbageCollect then
		return;
	endif;
	
	if self.myTerminalDeparted &lt;&gt; null then // PAR 20607
		app.raiseCMException1(Train_cannot_delete_becaus_dep, self.code, null, self); // PAR 20607
	endif;
	if self.code = NULL_TRAIN_CODE and not app.isJMTUnitTest then
		app.raiseCMException(Cannot_delete_null_train, ETRow_Code, self);
	endif;
	
	foreach wagon in self.allWagonsByIdInward do
		wagon.validateForDelete(false);
		/*
		if wagon.confirmed then
			//app.raiseCMWarning1(Full_Replacement_Message, 'Warning: This train currently has confirmed wagons in the rail area. These will be disassociated from this train.', null, null,self); //- cnwmd1, CCMS 1067, Par 19710
			app.raiseCMWarning(Warni_this_train_curre_confi_w, null, null,self); //+ cnwmd1, CCMS 1067, Par 20009
			break;
		endif;
		*/
	endforeach;
	
	foreach wagon in self.allWagonsByIdOutward do
		wagon.validateForDelete(false);
	endforeach;
	
	if not self.allWagonsByIdInward.isEmpty() then
		app.raiseCMException2(Train_canno_delet_becau_inwar_, self.code,self.allWagonsByIdInward.size.String, null, self); // PAR 20607
	endif;
	if not self.allWagonsByIdOutward.isEmpty() then
		app.raiseCMException2(Train_canno_delet_becau_outwa_, self.code,self.allWagonsByIdOutward.size.String, null, self); // PAR 20607
	endif;
end;


</source>
    </JadeMethod>
    <JadeMethod name="validateForTrainConsistDelete" id="270def8b-49f0-4cce-836e-39163d920937">
        <source>validateForTrainConsistDelete(_allWagonsToDelete : CM_WagonSet);
// --------------------------------------------------------------------------------
// Created:		19 February 2010 by cnwdad1
//
// Purpose:		This method is a replacement of the self.validateForDelete method,
//				explicity for EDI Train Consist processing.
//
// Parameters:	_allWagonsToDelete - A set of all of the Wagons that will be deleted.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	wagonObj	: CM_Wagon;
	
begin
	if self.myTerminalDeparted &lt;&gt; null then
		app.raiseCMException1(Train_cannot_delete_becaus_dep, self.code, null, self);
	endif;
	
	if self.code = NULL_TRAIN_CODE then
		app.raiseCMException(Cannot_delete_null_train, ETRow_Code, self);
	endif;
	
	foreach wagonObj in self.allWagonsByIdInward do
		wagonObj.validateForDelete(true);
		
//		if _allWagonsToDelete &lt;&gt; null and not _allWagonsToDelete.includes(wagonObj) then
//			app.raiseCMException2(	Train_canno_delet_becau_inwar_,
//									self.code,
//									self.allWagonsByIdInward.size().String,
//									null,
//									self);
//		endif;
	endforeach;
	
	foreach wagonObj in self.allWagonsByIdOutward do
		wagonObj.validateForDelete(true);
		
//		if _allWagonsToDelete &lt;&gt; null and not _allWagonsToDelete.includes(wagonObj) then
//			app.raiseCMException2(	Train_canno_delet_becau_outwa_,
//									self.code,
//									self.allWagonsByIdOutward.size().String,
//									null,
//									self);
//		endif;
	endforeach;
end;</source>
        <Parameter name="_allWagonsToDelete" type="CM_WagonSet"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="9c9237b6-8061-4b6d-b7b5-3c0baeb174c6">
        <source>validateForUpdate();
/*
----------   ----------  --------------------------------------------------
Created:	06 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
29/08/2018	JLGNS1	Bug 40008: PEN - Restrict Operator Issue - removed TFS2749	
22/08/2023	navkc1	CR 59610 Task 59611: Jade - Stop Prevention
30/06/2025  navma1  MTN-34090  MTN | Dead lock (1081) on CM_TIByIdCargoTypeRelseDictRev
----------   ----------  --------------------------------------------------
*/
vars
	existingTrain,
	realTrain				: CM_Train;
	release					: CM_BulkRelease;
	carrier					: CM_Carrier;
	operator				: CM_Operator;
	dac						: CM_DataAccessController;
	terminal 				: CM_Terminal;
	wagon					: CM_Wagon;
	now						: TimeStamp;
begin
	
	realTrain		:= self.pxyGetRealObject();
	now				:= app.actualTimeServer();			//30.06.2025 navma1 #MTN-34090
	
	if self.code = null then
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Code), ETRow_Code, null); // cnwdb2	PAR 35364
	endif;
	
	if self.code = NULL_TRAIN_CODE then
		app.raiseCMException2(CodeInvalid, self.code, app.getErrorString(Cannot_this_train_code), ETRow_Code, self);
	endif;
	
	// cnwrl1 13/10/2009 PAR 21049 - start of coding
	// must be upper case only.
	if self.code &lt;&gt; self.code.toUpper then
		app.raiseCMException1( Name_Must_Be_Upper_Case_Only, self.code, ETRow_Code, self );
	endif;

	if self.departureDT.isValid and self.departureDT &lt; now then												//30.06.2025 navma1 #MTN-34090
		
		if self.myDestinationPort = null then
			app.raiseCMWarning1(Train_been_depar_desti_been_sp, self.code, ETRow_DestPort, null, self);		//+ cnwmd1, CCMS 1067, Par 20009
		endif;
		
		if (not self.allWagonsByIdInward.isEmpty) then
			app.raiseCMException(Canno_this_train_depar_becau_s, null, null); 								//+ cnwmd1, CCMS 1067, Par 20009
		endif;
		
		if self.arrivalDT.isValid and self.departureDT &lt; self.arrivalDT then
			app.raiseCMException(Depar_date_time_canno_befor_ar, null, null); 								//+ cnwmd1, CCMS 1067, Par 20009
		endif;
	elseif self.departureDT = null and self.myTerminal = null then
		app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(Null_terminal_reference)); //+ cnwmd1, CCMS 1067, Par 19710
	endif;
	
	
	//validate duplicate train if not departed
	if self.departureDT = null then
		existingTrain	:= self.myTerminal.allTrainsOnTerminal[self.code, self.scheduledArrivalDT];
		
		if existingTrain &lt;&gt; null and
		   (realTrain = null or //in which case we are trying add a new one that is duplicate
		   existingTrain &lt;&gt; realTrain) //in which case we are trying update one to be same as another
		   then
			app.raiseCMException1(Train_code_alrea_been_used_mu, self.getCodeDateString(), null,  self); //+ cnwmd1, CCMS 1067, Par 20009
		endif;	
	endif;
	
	//cnwrd1 par 19710 20.5.09 -  ccms 1067
	//Validate shunter dates
	if self.shunterInDT.isValid and self.shunterOutDT.isValid then
		if self.shunterOutDT &lt; self.shunterInDT then
		app.raiseCMException(Shunt_date_time_canno_befor_sh, null, null);	//+ cnwmd1, CCMS 1067, Par 20009
		endif;
	endif;
	
	if not self.scheduledArrivalDT.isValid() then
		app.raiseCMException1(Valid_sched_arriv_date_time_tr, self.code, null, null);
	endif;
	
	if self.arrivalDT.isValid and self.arrivalDT &gt; now then								//30.06.2025 navma1 #MTN-34090
		app.raiseCMException1(Train_actua_arriv_date_canno_f, self.code, null, null);
	endif;

	// 9/1/18 MAP TFS6638	check for carrier/operator incompatibility
	carrier := self.myCarrier;
	if realTrain &lt;&gt; null and carrier &lt;&gt; null then
		foreach release in realTrain.allBulkReleases discreteLock do
			operator := release.myOperator;
			if operator &lt;&gt; null and not carrier.canCarrierAccessForOperator(operator, dac, true) then
				app.raiseCMException4(Train_assig_relea_reque_whose_, self.code, release.code, operator.description, carrier.description, null, null);
			endif;
		endforeach;
	endif;

	//navsp1 25MAY2022 TFS#53619
	if self.myTerminal&lt;&gt;null then		
		terminal	:= self.myTerminal;
	else
		terminal	:= self.myTerminalDeparted;
	endif;
	//31 May 2021	NDL	TFS 51199
	if self.cargoExchangeEndTS.isValid and  terminal.getConfig(RailRetroDefault).Boolean  then	//30.06.2025 navma1 #MTN-34090
			if self.cargoExchangeEndTS &gt; now then												//30.06.2025 navma1 #MTN-34090
				app.raiseCMWarning1( Termi_confi_rail_retro_defau_c, self.cargoExchangeEndTS.asStringJMT, null, null, null );
			endif;
		endif;
		
		if app.myPassport.isOpsViewEnabled(terminal) then 	// ### TFS 51855 17MAY2022 NAVAB1
			if self.myCarrier = null then 					// ### TFS 51855 17MAY2022 NAVAB1
				app.raiseCMException2(Termi_confi_navis_smart_opsvi_, terminal.code, self.code,null,self); // ### TFS 51855 17MAY2022 NAVAB1
			endif;		
	endif;
	
	//22/08/2023 navkc1	CR 59610 Task 59611
	if self.status = TrainStatus_Departed then
		if realTrain.allTransactions.getFirstOfType(EVT_TrainDepart) = null then
			realTrain.validateDepartureProcess();
			foreach wagon in realTrain.allWagonsByIdOutward discreteLock do
				wagon.validateDepartureProcess();
			endforeach;
		endif;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateTIsForConfirm" id="b394aafb-1575-4ac9-8abe-005f1201e210">
        <source>validateTIsForConfirm(_passport : CM_Passport input) : Boolean;
/*
----------   ----------  --------------------------------------------------
Created:	14 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	wagon 	: CM_Wagon;
begin
	if not self.canBeConfirmed() then // PAR 20062
		app.raiseCMException1(Train_canno_confi_been_fully_m,  self.code, null, self);
		return false;
	endif;
	
	foreach wagon in self.allWagonsByIdInward discreteLock do
		wagon.validateTIsForConfirm(_passport);
	endforeach;

	return _passport.noErrors();


end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateUsingGaugeClearance" id="7abc171e-00ec-477d-a515-0f734dcaeb16">
        <source>validateUsingGaugeClearance(_moveMode : Integer);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 July 2009	cnwndl1	Initial creation

*/

vars

	iter : Iterator;
	wagon : CM_Wagon;
	asError : Boolean;
	
begin

	if myTrackClearance &lt;&gt; null then
		iter := self.allWagonsByIdOutward.createIterator();
		while iter.next( wagon ) do
			asError := self.myTerminal.getConfig(RailTrackClearErr).Boolean;
			wagon.validateUsingTrackClearance(null, myTrackClearance, _moveMode, true, asError);
		endwhile;
	endif;
	
epilog

	delete iter;

end;</source>
        <Parameter name="_moveMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateUsingTrackClearance" id="c9a068cd-6c48-4756-b427-33a70e49fb6d">
        <source>validateUsingTrackClearance();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 March 2010	cnwas3	par 23112

*/

vars

	iter : Iterator;
	wagon : CM_Wagon;
	trainTotWeight, wagonWeight, wagonWidth, wagonHeight : Decimal [12,4];
begin

	if myTrackClearance &lt;&gt; null then
		iter := self.allWagonsByIdOutward.createIterator();
		while iter.next( wagon ) do
		
			wagon.validateTIsTrackClearance(myTrackClearance, true, false);
			
			if self.myTrackClearance.maxWeight &lt;&gt; 0 then // PAR 23176
				wagon.getTotalWeightWidthHeight(wagonWeight, wagonWidth, wagonHeight); // PAR 23176
				trainTotWeight := trainTotWeight + wagonWeight; // PAR 23176
			endif;
		endwhile;
		
		
		if self.maxWeight &lt;&gt; 0 and self.maxWeight &lt; trainTotWeight then // PAR 23176
			app.raiseCMWarning4(Track_clear_error_total_weight, self.code, trainTotWeight.asStringWeightJMT(), self.myTrackClearance.code, self.maxWeight.asStringJMT(), null, null, self); // PAR 23176
		endif;
	endif;
	
epilog

	delete iter;

end;</source>
    </JadeMethod>
</Class>
