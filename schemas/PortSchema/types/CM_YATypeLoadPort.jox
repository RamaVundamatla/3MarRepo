    <JadeMethod name="getObjects" id="c471cee3-1771-4157-b86e-6d92d5c6065d">
        <source>getObjects(objects: ObjectLongNameDict input);
//05 August 2008	cnwdw1	
// Return a dict of objects for this criteria type
vars
	port: CM_Port;
begin
	foreach port in app.myRoot.allActivePorts do
		objects[port.getYAIdentifier] := port;
	endforeach;
end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
