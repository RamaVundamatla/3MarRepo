    <JadeMethod name="getDisplayStringForAttribute" id="7b824a75-8196-42fe-8cd0-833c060e4291">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Date		    Who			Reason
02 May 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars

begin
	if _attrName = ETRow_Code or _attrName = ETRow_DeckItemCode then
		return self.code;
	elseif _attrName = ETRow_DeckCode then
		return self.myDeck.code;
	elseif _attrName = ETRow_Description then
		return self.description;
	elseif _attrName = ETRow_Remarks then
		return self.remarks;
	elseif _attrName = ETRow_DeckItemType then
		return self.typeName();
	else	
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtremePoints" id="50ee5766-e66b-43ea-b0ce-43e95a285582">
        <source>getExtremePoints(_x1, _y1, _x2, _y2 : Integer io);
/*

Purpose:		get the extreme points of all the VISIBLE deck layer graphics	

Parameters:			

Return Value:		


Date		Who		Reason
28 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	iter : Iterator;
	deckLayout : CM_DeckLayerLayout;
begin
	iter :=self.allDeckLayerLayouts.createIterator;
	
	while iter.next(deckLayout) do 
		if not deckLayout.isVisible then
			continue;
		endif;
		deckLayout.getExtremePoints(_x1, _y1, _x2, _y2);
	endwhile;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_x1" type="Integer" usage="io"/>
        <Parameter name="_y1" type="Integer" usage="io"/>
        <Parameter name="_x2" type="Integer" usage="io"/>
        <Parameter name="_y2" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getGCLayer" id="2147331e-f82b-4b33-bc85-00e4c8e4bd64">
        <source>getGCLayer() : CM_DeckLayerLayout;
/*
Purpose:			
Date		Who		Reason
13 June 2011	cnwab1	Initial creation
*/

vars
	pxyGC, realGC : CM_DeckLayerLayout;
	found : Boolean;
begin
	foreach realGC in self.allDeckLayerLayouts discreteLock where realGC.type = ROROLayerType_GC do
		return realGC;
	endforeach;

	create pxyGC transient;
	pxyGC.setProxy("General Cargo", "", "", self,true,ROROLayerType_GC);
	
 // PAR 28330	app.myUtilityCA.utlCreateDeckLayerLayout(pxyGC, realGC, false, app.myPassport);  
	if process.isInTransactionState then // PAR 28330
		app.myUtilityCA.utlCreateDeckLayerLayout(pxyGC, realGC, true, app.myPassport); // PAR 28330
	else
		app.myTrxCA.trxCreateDeckLayerLayout(pxyGC, realGC, true, app.myPassport); // PAR 28330
	endif;
	if (app.myPassport.hasWarnings and not app.myPassport.warningsAcknowledged) 
	or app.myPassport.hasErrors() then
		return null;
	endif;
	
 // PAR 28330	self.moveLayerToTop(realGC); // make it draw as the top layer
 // PAR 28330	self.moveCCLayersToTop();
	
	return realGC;
epilog
	delete pxyGC;
end;</source>
        <ReturnType type="CM_DeckLayerLayout"/>
    </JadeMethod>
