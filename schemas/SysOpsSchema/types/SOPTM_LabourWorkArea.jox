<Class name="SOPTM_LabourWorkArea" id="0e86e01a-de9e-4a6c-a961-3229229a7c56">
    <superclass name="SOP_TableMaintItem"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="sysops"/>
    <JadeMethod name="clearThumbnailData" id="bdd3cfba-c1ac-4380-8d8d-6ef7c3add628">
        <updating/>
        <source>clearThumbnailData() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2014	cnwndl1	Initial creation	Par 33995

*/

vars

	theForm : SOP_TableMaintForm;
	labourWorkArea :CM_LabourWorkArea;

begin
  
	theForm := self.myForm;
	theForm.tblInput1.clearValues();
	
	labourWorkArea := self.getSelectedLabourWorkArea();
	
	if labourWorkArea &lt;&gt; null then
		theForm.tblInput1.setValueByName(ETRow_Code, labourWorkArea.code);
		theForm.tblInput1.setValueByName(ETRow_Description, labourWorkArea.description);
		theForm.tblInput1.setValueByName(ETRow_NotAvailable, labourWorkArea.notAvailableForEntry.String);
		theForm.tblInput1.setValueByName(ETRow_TermAreas, labourWorkArea.getTerminalAreasString);
		theForm.tblInput1.setValueByName(ETRow_SubAreas, labourWorkArea.getSubAreasString);
		theForm.tblInput1.setValueByName(ETRow_SubSubAreas, labourWorkArea.getSubSubAreasString);
	endif;
  
end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="df89b827-f233-40ef-8b59-8d11fe49d131">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2014	cnwndl1	Initial creation	Par 33995

*/

vars

begin

	self.name := SOP_TableMaintForm.Table_LabourWorkArea;
	self.permissionView	 := PmAdmLabourAreaView;
	self.permissionMaint := PmAdmLabourAreaMaint;
	self.myDataClass := CM_LabourWorkArea;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="9fb9798d-22f7-4ae4-a9f2-0ad0aa4bdca4">
        <updating/>
        <source>doDelete(pObj: Object io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2014	cnwndl1	Initial creation

*/

vars

begin

	app.myTrxDA.trxDeleteCMObject( pObj.CM_Object, app.myPassport );

epilog

end;</source>
        <Parameter name="pObj" type="Object" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doEnableControls" id="9ae83069-ef16-49e1-9356-2b5a9d83a4b9">
        <source>doEnableControls( _enable : Boolean );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2014	cnwndl1	Initial creation	Par 33995

*/

vars

	theForm : SOP_TableMaintForm;
	
begin

	theForm := self.myForm;	
	
	theForm.btnNewWc.enabled := _enable;
	theForm.btnEditWc.enabled := _enable;
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(theForm.myTerminal, self.permissionMaint) then
		theForm.btnNewWc.enabled:= false;
		theForm.btnEditWc.enabled:= false;
	endif;

	
epilog

end;</source>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
