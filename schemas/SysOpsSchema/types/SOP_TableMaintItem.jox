    <JadeMethod name="doSaveDrawingAttributePxy" id="acd5092e-f13b-4f34-9585-a5c67b4eed72">
        <source>doSaveDrawingAttributePxy(_pxyDraw : CM_DrawingAttribute input) : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 13/05/2015	cnwdap1		Initial creation PAR #36206 Grpahic Representation of Hazard Class and Special Stow
// 06/08/2015	cnwdap1		PAR #36421 Hazardous Materials Handling
//
vars
	code, 
	abbr,
	drawFont	: String;
	character	: Integer;
	drawColour	: Integer;
	table		: CM_EntryTable;

begin
	table := self.myForm.tblInput1;
	abbr := table.getValueByName(ETRow_Code).String;
	drawFont := table.getValueByName(ETRow_Font).String;
	character := table.getValueByName(ETRow_CharacterNumber).Integer;
	drawColour := table.getValueByName(ETRow_Colour).Integer;
	
	if drawFont = null then					// PAR #36421
		return false;						// PAR #36421
	endif;									// PAR #36421
	
	if character = null then
		if abbr.length &gt; 0 then
			character := abbr[1:1].getWeightedAsciiValue();
		endif;
	endif;
	if drawFont = null then
		drawFont := "Arial";
	endif;
	
	if self.myForm.myCurrentTableItem.isKindOf(SOPTM_HazardClass) then
		code := "HazardClass_";
	elseif self.myForm.myCurrentTableItem.isKindOf(SOPTM_SpecialStow) then
		code := "SpecialStow_";
	endif;
	
	_pxyDraw.setProxy(	code &amp; abbr,//abbreviation cannot be duplicate, so OK to use for code attr (key)
						drawFont,
						character,
						drawColour,
						app.myRoot	);
	
	return true;
epilog

end;</source>
        <Parameter name="_pxyDraw" type="CM_DrawingAttribute" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
