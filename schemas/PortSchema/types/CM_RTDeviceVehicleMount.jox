    </JadeMethod>
    <JadeMethod name="startDebugAppFor" id="a2006738-3689-4b16-ab70-422116b15b3e">
        <source>startDebugAppFor();

vars
	param		: CM_ViewObjectColour;
begin
	//	app.startApplicationWithParameter('MobileUISchema', 'VehicleMountedWithDevice', self);

