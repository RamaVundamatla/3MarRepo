    <JadeMethod name="getMatchingAllocations" id="ddc5a8ce-48df-49d7-89e2-e0ab440ae50e">
        <source>getMatchingAllocations(_criteria : CM_YACriteria; _terminal : CM_Terminal; _allocationDict : CM_YardAllocationSet input);
// -------------------------------------------
// Created 10 May 2005 by cnwdvb1
// -------------------------------------------
vars

	criteria : CM_YACriteria;

begin

	// Just make sure we are looking at matching types
	if _criteria.myYACriteriaType &lt;&gt; self then
		return;
	endif;
	
	// Haven't cleared dict because we are probably going to call this
	// method multiple times.
	
	foreach criteria in self.allYACriteria discreteLock where criteria.myYardAllocation &lt;&gt; null do	//cnwas3 par 26767- in some cases we're checking CM_YACargoCheckCriteria which has no myYardAllocation references
		self.sharedLock(criteria);
		criteria.getMatchingAllocations(_criteria, _terminal, _allocationDict);
		self.unlock(criteria);
	endforeach;

epilog

	if criteria &lt;&gt; null then
		self.unlock(criteria);
	endif;
end;</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_allocationDict" type="CM_YardAllocationSet" usage="input"/>
    </JadeMethod>
