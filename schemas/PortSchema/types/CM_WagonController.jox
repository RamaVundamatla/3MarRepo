    <JadeMethod name="getRowColumn" id="b08f1deb-79ca-4ae2-8d22-59b1cd99596c">
        <source>getRowColumn(_row: Integer output; _column: Integer output; _flippedH, _flippedV : Boolean);
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Changed On   Changed By  Reason
