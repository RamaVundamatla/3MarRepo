    <JadeMethod name="isDamageParty_Match" id="588e5a03-cda9-4f43-b942-149bc63768bf">
        <source>isDamageParty_Match(_yaData: CM_YADataObjects): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
12 July 2022	navsj20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars
	damInstance : CM_DamageInstance;

begin
	if _yaData.isEmpty() then
		return true;
	endif;

	// if any of the damage instances match return true
	foreach damInstance in self.myTrackedItem.allDamageInstances discreteLock do
		if _yaData.matches(damInstance.myDamageParty) then
			return true;
		endif;
	
	endforeach;

	return false;
epilog

end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
