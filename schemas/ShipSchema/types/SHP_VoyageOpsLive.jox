    <JadeMethod name="getXMLSettingsForSave" id="00b0f2d7-4e8e-46b6-a22b-ac4b576beea7">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*
Purpose:			

Date		Who		Reason
01 Mar 2023	navab1	TFS CR 56806 TASK 56807
01 Dec 2023	jlika1	TFS 61592 CUX | FLP Priority Quick Filters
07 Dec 2023	jlizm1	TFS 61426 CUX FLP Screen Enhancements
17 Jan 2024 navra1	CR 62045/Task 62047 - 17th January 2024CUX | Modifications to Confirm to Location for Voyage Ops Live
08 Feb 2024 jlier1 TFS 62363
10 Dec 2025	navah1	MTN-36400: CUX - If the user adjusts the bar at the bottom in the Voyage Operations Live screen the change doesnt remain if the screen is closed and reopened
*/

vars
	theXML : String;
begin

	theXML := inheritMethod();
	theXML := theXML &amp; self.tblAllCargoBottom.getXmlStrForColumns(true); 
	theXML := theXML &amp; self.tblAllCargoTop.getXmlStrForColumns(true);
	theXML := theXML &amp; self.tblHazardousBottom.getXmlStrForColumns(true);
	theXML := theXML &amp; self.tblHazardousTop.getXmlStrForColumns(true);
	theXML := theXML &amp; self.tblMAFIBottom.getXmlStrForColumns(true);
	theXML := theXML &amp; self.tblMAFITop.getXmlStrForColumns(true);
	theXML := theXML &amp; self.tblBookingBottom.getXmlStrForColumns(true);
	theXML := theXML &amp; self.tblBookingTop.getXmlStrForColumns(true);
	theXML := theXML &amp; self.tblReefersBottom.getXmlStrForColumns(true);
	theXML := theXML &amp; self.tblReefersTop.getXmlStrForColumns(true);
	theXML := theXML &amp; self.tblTrailersBottom.getXmlStrForColumns(true);
	theXML := theXML &amp; self.tblTrailersTop.getXmlStrForColumns(true);

	theXML := theXML &amp; global.formatAsXML(self.XML_TagShowFilter,chkShowFilters.value.Integer.String);
	theXML := theXML &amp; global.formatAsXML(self.XML_TagShowCargo,chkShowCargo.value.Integer.String);
	theXML := theXML &amp; global.formatAsXML(self.XML_TagShowLocation,chkShowLocationFuns.value.Integer.String);			//navra1 - CR 62045/Task 62047 - 17th January 2024
	theXML := theXML &amp; global.formatAsXML(self.XML_TagColourCells,chkColourCells.value.Integer.String);
	
	if self.myCustomerPriority1 &lt;&gt; null then
		theXML := theXML &amp; global.formatAsXML(self.XML_TagCustomerPriority1, self.myCustomerPriority1.getOidAsString());
	endif;
	if self.myCustomerPriority2 &lt;&gt; null then
		theXML := theXML &amp; global.formatAsXML(self.XML_TagCustomerPriority2, self.myCustomerPriority2.getOidAsString());
	endif;
	if self.myCustomerPriority3 &lt;&gt; null then
		theXML := theXML &amp; global.formatAsXML(self.XML_TagCustomerPriority3, self.myCustomerPriority3.getOidAsString());
	endif;
	
	theXML := theXML &amp; self.getXMLStrForTablePositions(); //10.12.2025 navah1 #MTN-36400 
	return theXML;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="e7c5f320-a44a-42ac-a69e-aea9223e747b">
        <updating/>
        <source>getXMLSettingsForSetup() updating;
/*
Purpose:			

Date		Who		Reason
01 Mar 2023	navab1	TFS CR 56806 TASK 56807
01 Dec 2023	jlika1	TFS 61592 CUX | FLP Priority Quick Filters
17 Jan 2024 navra1	CR 62045/Task 62047 - 17th January 2024CUX | Modifications to Confirm to Location for Voyage Ops Live
*/

vars

	userWindow			: CM_UserWindow;
	theXML, 
	theXMLValue 		: String;
	useParam 			: Boolean;
	customerPriority	: CM_CustomerPriority;
begin

	userWindow := app.getUserWindow(self.name, false);
	
	if userWindow = null then
		return;
	endif;
	theXML := userWindow.xmlInfo;
	
	//navra1 - CR 62045/Task 62047 - 17th January 2024 - start
	// ### XML_TagShowLocation
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_TagShowLocation);
 	useParam := false;
 	if theXMLValue &lt;&gt; null then
 		useParam := theXMLValue.Integer.Boolean;
 	endif;
 	self.chkShowLocationFuns.value := useParam;
	self.chkShowLocationFuns.click(self.chkShowLocationFuns);
	//navra1 - CR 62045/Task 62047 - 17th January 2024 - end
	
	// ### XML_TagShowFilter
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_TagShowFilter);
 	useParam := false;
 	if theXMLValue &lt;&gt; null then
 		useParam := theXMLValue.Integer.Boolean;
 	endif;
 	self.chkShowFilters.value := useParam;
	self.chkShowFilters.click(self.chkShowFilters);
	
	// ### XML_TagShowCargo
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_TagShowCargo);
 	useParam := false;
 	if theXMLValue &lt;&gt; null then
 		useParam := theXMLValue.Integer.Boolean;
 	endif;
 	self.chkShowCargo.value := useParam;
	self.chkShowCargo.click(self.chkShowCargo);
	
	// ### XML_TagColourCells
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_TagColourCells);
 	useParam := false;
 	if theXMLValue &lt;&gt; null then
 		useParam := theXMLValue.Integer.Boolean;
 	endif;
 	self.chkColourCells.value := useParam;
	self.chkColourCells.click(self.chkColourCells);
	
	// ### XML_TagCustomerPriority1
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_TagCustomerPriority1);
 	if theXMLValue &lt;&gt; null then
		customerPriority := theXMLValue.asOid.CM_CustomerPriority;
		if customerPriority &lt;&gt; null then
			self.myCustomerPriority1 := customerPriority;
		endif;
 	endif;
	
	// ### XML_TagCustomerPriority2
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_TagCustomerPriority2);
 	if theXMLValue &lt;&gt; null then
		customerPriority := theXMLValue.asOid.CM_CustomerPriority;
		if customerPriority &lt;&gt; null then
			self.myCustomerPriority2 := customerPriority;
		endif;
 	endif;
	
	// ### XML_TagCustomerPriority3
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_TagCustomerPriority3);
 	if theXMLValue &lt;&gt; null then
		customerPriority := theXMLValue.asOid.CM_CustomerPriority;
		if customerPriority &lt;&gt; null then
			self.myCustomerPriority3 := customerPriority;
		endif;
 	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getXMLStrForTablePositions" id="f4565244-3da8-423f-af20-0e06449914ee">
        <source>getXMLStrForTablePositions(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Dec 2025	navah1	Initial creation
15 Dec 2025	navah1	MTN-36400: CUX - If the user adjusts the bar at the bottom in the Voyage Operations Live screen the change doesnt remain if the screen is closed and reopened
*/
 
vars
	xmlStr : String;

begin 
	xmlStr := self.splAllCargo.getXMLStrForTablePositions();
	xmlStr &amp;= self.splBooking.getXMLStrForTablePositions();
	xmlStr &amp;= self.splHazardous.getXMLStrForTablePositions();
	xmlStr &amp;= self.splMAFI.getXMLStrForTablePositions();
	xmlStr &amp;= self.splReefers.getXMLStrForTablePositions();
	xmlStr &amp;= self.splTrailers.getXMLStrForTablePositions();
	return xmlStr;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleNewItem" id="a9a72582-4c10-4114-a239-d36732c3f3c1">
        <updating/>
        <source>handleNewItem(_ti : CM_TrackedItem) updating;
/*
Purpose:			

Date		Who		Reason
14 Mar 2023	navab1	TFS CR 56806 TASK 56807
06 Dec 2023	jlizm1	TFS 61426 CUX FLP Screen Enhancements
04 Mar 2024	jlika1	TFS 62716 CUX | FR 60847 | Ticket 62714 - Prenotes duplicated on Booking List in VoyOpsLive
19 Mar 2024	jlizm1	TFS 62763 Table auto updates
19 Jul 2024 jlier1  TFS 65275 table sorting and row coloring
*/

vars
	ti 				: CM_TrackedItem;

begin
	ti := _ti;
	
	self.addCargoToCollection(ti,true);
	if self.allCargoBooked.includes(ti) then
		if not self.isCargoInTable(ti, self.tblBookingTop) then
			self.addCargoToTable(ti, self.tblBookingTop, self.shtBookingList);
			self.tblBookingTop.resort;
			self.colourTableRows(self.tblBookingTop); //jlier1 TFS 65275 19/7/24
		endif;
		
		self.doSheetCaption(self.shtBookingList, self.tblBookingTop);
	endif;
	
	if self.allHazardous.includes(ti) then
		if not self.isCargoInTable(ti, self.tblHazardousTop) then
			self.addCargoToTable(ti, self.tblHazardousTop, self.shtHazardous);
			self.tblHazardousTop.resort;
			self.colourTableRows(self.tblHazardousTop); //jlier1 TFS 65275 19/7/24
		endif;
		
		self.doSheetCaption(self.shtHazardous, self.tblHazardousTop);
		
	endif;
	
	if self.allMAFI.includes(ti) then
		if not self.isCargoInTable(ti, self.tblMAFITop) then
			self.addCargoToTable(ti, self.tblMAFITop, self.shtMAFI);
			self.tblMAFITop.resort;
			self.colourTableRows(self.tblMAFITop); //jlier1 TFS 65275 19/7/24
		endif;
		
		self.doSheetCaption(self.shtMAFI, self.tblMAFITop);
		
	endif;
	
	if self.allCargoToBeWorked.includes(ti) then
		if not self.isCargoInTable(ti, self.tblAllCargoTop) then
			self.addCargoToTable(ti, self.tblAllCargoTop, self.shtAllCargo);
			self.tblAllCargoTop.resort;
			self.colourTableRows(self.tblAllCargoTop); //jlier1 TFS 65275 19/7/24
		endif;
		
		self.doSheetCaption(self.shtAllCargo, self.tblAllCargoTop);
		
	endif;
	
	if self.allReefers.includes(ti) then
		if not self.isCargoInTable(ti, self.tblReefersTop) then
			self.addCargoToTable(ti, self.tblReefersTop, self.shtReefers);
			self.tblReefersTop.resort;
			self.colourTableRows(self.tblReefersTop); //jlier1 TFS 65275 19/7/24
		endif;
		self.doSheetCaption(self.shtReefers, self.tblReefersTop);
		
	endif;
	
	if self.allTrailer.includes(ti) then
		if not self.isCargoInTable(ti, self.tblTrailersTop) then
			self.addCargoToTable(ti, self.tblTrailersTop, self.shtTrailers);
			self.tblTrailersTop.resort;
			self.colourTableRows(self.tblTrailersTop); //jlier1 TFS 65275 19/7/24
		endif;
		self.doSheetCaption(self.shtTrailers, self.tblTrailersTop);
	
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="handleRemoveItem" id="a6444362-e319-4ef1-b9bb-5fd1db3c49e6">
        <updating/>
        <source>handleRemoveItem(_ti : CM_TrackedItem) updating;
/*
Purpose:			

Date				Who		Reason
14 March 2023		navab1	TFS CR 56806 TASK 56807
06 December 2023	jlizm1	TFS 61426 CUX FLP Screen Enhancements
19 March 2024		jlizm1	TFS 62763 Table auto updates
*/

vars
	ti : CM_TrackedItem;
begin
	ti := _ti;
	
	if self.allCargoBooked.includes(ti) then
		self.removeCargoFromTable(ti, self.tblBookingTop, self.shtBookingList);
		self.allCargoBooked.remove(ti);
	endif;
	
	if self.allCargoToBeWorked.includes(ti) then
		self.removeCargoFromTable(ti, self.tblAllCargoTop, self.shtAllCargo);
		self.allCargoToBeWorked.remove(ti);
	endif;
	
	if self.allHazardous.includes(ti) then
		self.removeCargoFromTable(ti, self.tblHazardousTop, self.shtHazardous);
		self.allHazardous.remove(ti);
	endif;
	
	if self.allMAFI.includes(ti) then
		self.removeCargoFromTable(ti, self.tblMAFITop, self.shtMAFI);
		self.allMAFI.remove(ti);
	endif;
	
	if self.allReefers.includes(ti) then
		self.removeCargoFromTable(ti, self.tblReefersTop, self.shtReefers);
		self.allReefers.remove(ti);
	endif;
	
	if self.allTrailer.includes(ti) then
		self.removeCargoFromTable(ti, self.tblTrailersTop, self.shtTrailers);
		self.allTrailer.remove(ti);
	endif;			

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="handleSystemNotifications" id="3c9bad4b-0cb1-4327-9d63-4e4daa513e21">
        <updating/>
        <source>handleSystemNotifications(_event : Integer; _theObject : CM_Object) updating;
/*
Purpose:			

Date		Who		Reason
01MAR2023	NAVAB1	CR 56806 TASK 56807
19/03/2024	jlizm1	TFS 62763 Table auto updates
24/06/2024	jlizm1	TFS 64766 VOL child cargo should not display as row
12/09/2024  navma1	Bug 66079: CUX - Error 4s at Voyage Operation live
*/

vars
	idx		: Integer;
	ti		: CM_TrackedItem;
	tilc 	: CM_TILC;
	invalid : Boolean;
	edition : Integer;
begin

	on Exception do app.handleDeletedObject(exception, _theObject, invalid);
	
	if _event = Object_Update_Event then
		if _theObject.isKindOf(CM_TrackedItem) and self.myCurrentVoyage &lt;&gt; null then
			ti := _theObject.CM_TrackedItem;
			
			edition := _theObject.edition;  // 12.10.2019 cnwma1 #66079
	
			if invalid then
				return;
			endif;
			
			if ti.myVoyage = self.myCurrentVoyage then
				if self.allCargoBooked.includes(ti) then
					self.updateCargoToTable(ti, self.tblBookingTop, self.shtBookingList);
				
					self.tblAllCargoTop.findObjectInRow(ti,idx); // ### TFS BUG 57053 27MAR2023 NAVAB1
					if idx &gt; 0 then 							 // ### TFS BUG 57053 27MAR2023 NAVAB1
						// All cargo list is all cargo that is left to be worked, checked and confirmed.
						if self.includeObject(ti, true)
						and not ti.isOnTrailer then
							self.updateCargoToTable(ti, self.tblAllCargoTop, self.shtAllCargo);
						else
							self.removeCargoFromTable(ti, self.tblAllCargoTop, self.shtAllCargo);
						endif;
					elseif not ti.isOnTrailer then // 'child' just unloaded from trailer  	 // ### TFS BUG 57053 27MAR2023 NAVAB1
						if self.includeObject(ti,true) then 								 // ### TFS BUG 57053 27MAR2023 NAVAB1
							self.addCargoToTable(ti, self.tblAllCargoTop, self.shtAllCargo); // ### TFS BUG 57053 27MAR2023 NAVAB1
							self.tblAllCargoTop.resort;
							self.colourTableRows(self.tblAllCargoTop); //jlier1 TFS 65275 19/7/24
							self.doSheetCaption(self.shtAllCargo, self.tblAllCargoTop);
						endif;
					endif;
				else
					if ti.isTranshipItem then // a trans ship we do not know about.
						self.handleNewItem(ti);
						return;
					endif;
				endif;
				
				self.handleUpdateItem(ti); // ### TFS CR 57043 TASK 57454 04APR2023 NAVAB1
	
				// ### TFS CR 57043 TASK 57454 04APR2023 NAVAB1
				tilc := ti.getCurrentTrailer();
				if tilc &lt;&gt; null then
					if self.allCargoBooked.includes(tilc) then
						self.updateCargoToTable(tilc, self.tblBookingTop, self.shtBookingList);
						self.handleUpdateItem(tilc);
					endif;
				endif;
				
			else
				self.handleRemoveItem(ti);
			endif;			

		endif;
	elseif _event = Object_Delete_Event then
		if _theObject.isKindOf(CM_TrackedItem) then
			ti := _theObject.CM_TrackedItem;
			self.handleRemoveItem(ti);
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_event" type="Integer"/>
        <Parameter name="_theObject" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="handleUpdateItem" id="dd099699-55d9-448e-9d6b-fe078be3d57d">
        <updating/>
        <source>handleUpdateItem(ti : CM_TrackedItem) updating;
/*
Purpose:			

Date				Who		Reason
04 April 2023	 			// ### TFS CR 57043 TASK 57454 04APR2023 NAVAB1
07 December 2023	jlizm1	TFS 61426 CUX FLP Screen Enhancements
19 March 2024		jlizm1	TFS 62763 Table auto updates
24 June 2024		jlizm1	TFS 64766 VOL child cargo should not display as row
*/

vars
	wasCargo	: Boolean;
	wasHaz 		: Boolean;
	wasMafi 	: Boolean;
	wasReefer 	: Boolean;
	wasTrailer	: Boolean;
	
begin
	
	wasCargo	:= self.allCargoToBeWorked.includes(ti);
	wasHaz 		:= self.allHazardous.includes(ti);
	wasMafi 	:= self.allMAFI.includes(ti);
	wasReefer 	:= self.allReefers.includes(ti);
	wasTrailer 	:= self.allTrailer.includes(ti);
	
	if self.includeObject(ti, true) then
		// refresh collections
		self.removeCargoFromCollections(ti);
		self.addCargoToCollection(ti, true);
		
		if self.allCargoToBeWorked.includes(ti) then
			self.updateCargoToTable(ti, self.tblAllCargoTop, self.shtAllCargo);
		elseif wasCargo then
			self.removeCargoFromTable(ti, self.tblAllCargoTop, self.shtAllCargo);
		endif;
		
		if self.allHazardous.includes(ti) then
			self.updateCargoToTable(ti, self.tblHazardousTop, self.shtHazardous);
		elseif wasHaz then
			self.removeCargoFromTable(ti, self.tblHazardousTop, self.shtHazardous);
		endif;
		
		if self.allMAFI.includes(ti) then
			self.updateCargoToTable(ti, self.tblMAFITop, self.shtMAFI);
		elseif wasMafi then
			self.removeCargoFromTable(ti, self.tblMAFITop, self.shtMAFI);
		endif;
		
		if self.allReefers.includes(ti) then
			self.updateCargoToTable(ti, self.tblReefersTop, self.shtReefers);
		elseif wasReefer then
			self.removeCargoFromTable(ti, self.tblReefersTop, self.shtReefers);
		endif;
		
		if self.allTrailer.includes(ti) then
			self.updateCargoToTable(ti, self.tblTrailersTop, self.shtTrailers);
		elseif wasTrailer then
			self.removeCargoFromTable(ti, self.tblTrailersTop, self.shtTrailers);
		endif;
		
	else
		// dont want to include, so delete from all tables and collections
		if wasCargo then
			self.removeCargoFromTable(ti, self.tblAllCargoTop, self.shtAllCargo);
			self.allCargoToBeWorked.remove(ti);
		endif;
		
		if wasHaz then
			self.removeCargoFromTable(ti, self.tblHazardousTop, self.shtHazardous);
			self.allHazardous.remove(ti);
		endif;
		
		if wasMafi then
			self.removeCargoFromTable(ti, self.tblMAFITop, self.shtMAFI);
			self.allMAFI.remove(ti);
		endif;
		
		if wasReefer then
			self.removeCargoFromTable(ti, self.tblReefersTop, self.shtReefers);
			self.allReefers.remove(ti);
		endif;
		
		if wasTrailer then
			self.removeCargoFromTable(ti, self.tblTrailersTop, self.shtTrailers);
			self.allTrailer.remove(ti);
		endif;
	endif;

epilog

end;</source>
        <Parameter name="ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="handleUserNotifications" id="05a5e9b4-785f-49eb-93eb-ef9bd2418b98">
        <updating/>
        <source>handleUserNotifications(_event : Integer; _theObject, _userObject : CM_Object) updating;
/*
Purpose:			

Date		Who		Reason
01MAR2023	NAVAB1	CR 56806 TASK 56807 
19/03/2024	jlizm1	TFS 62763 Table auto updates
02/07/2024	jlizm1	TFS 64940 VOL Cargo table not updating with mafi voyage update
12/09/2024  navma1	Bug 66079: CUX - Error 4s at Voyage Operation live
*/

vars
	termEvent : Integer;
	ti		  : CM_TrackedItem;
	invalid   : Boolean;
	edition   : Integer;
begin
	on Exception do app.handleDeletedObject(exception, _theObject, invalid);
	
	if self.myTerminal &lt;&gt; null then
		termEvent := self.myTerminal.getEventFromTerminalEvent(_event);
	endif;
	
	
	if termEvent = TIEvent_PreNote_Add 	or termEvent = EVENT_TI_Voyage_Chg then
		if _theObject.isKindOf(CM_TrackedItem) 	and self.myCurrentVoyage &lt;&gt; null then
			ti := _theObject.CM_TrackedItem;
			
			edition := _theObject.edition;  // 12.10.2019 cnwma1 #66079
	
			if invalid then
				return;
			endif;
			
			if ti.myVoyage = self.myCurrentVoyage then
				if self.isCargoInCollection(ti) then
					self.handleUpdateItem(ti);
				else
					self.handleNewItem(ti);
				endif;
			endif;
		endif;
		
	elseif termEvent = Voyage_Update_Event then
		if self.myCurrentVoyage = _theObject.CM_Voyage then
			self.setStartOpsButton();
		endif;
		
	elseif termEvent = TIEvent_Transit_Status_Update then
		if self.myCurrentVoyage = _theObject.CM_Voyage then
			if _userObject.isKindOf(CM_TrackedItem) then
				ti := _userObject.CM_TrackedItem;
				if self.isCargoInCollection(ti) then
					self.handleUpdateItem(ti);
				else
					self.handleNewItem(ti);
				endif;
			endif;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_event" type="Integer"/>
        <Parameter name="_theObject" type="CM_Object"/>
        <Parameter name="_userObject" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="hasFilters" id="7d40f211-fa4c-418c-a03a-f5f0bebbdcfc">
        <source>hasFilters() : Boolean;
/*
Purpose:			

Date				Who		Reason
01 March 2023		navab1	TFS CR 56806 TASK 56807
17 October 2023		jlizm1	TFS 60659 CUX Filtered Indicator not always showing correctly
01 Dec 2023	jlika1	TFS 61592 CUX | FLP Priority Quick Filters
*/

vars

begin
		
	if self.txtCargoId.text &lt;&gt; null then
		return true;
	endif;
	
	
	if self.cmbCargoType.listIndex &gt; 1 then
		return true;
	endif;
	if self.cmbCargoTypeOnBoard.listIndex &gt; 1 then
		return true;
	endif;
	if self.cmbCargoSubType.listIndex &gt; 1 then
		return true;
	endif;
	if self.cmbCargoSubTypeOnBoard.listIndex &gt; 1 then
		return true;
	endif;
	if self.cmbIMEX.listIndex &gt; 1 then
		return true;
	endif;
	if self.cmbSite.listIndex &gt; 1 then
		return true;
	endif;
	
	
	if self.chkConfirmed.value then
		return true;
	endif;	
	if self.chkHasStops.value then
		return true;
	endif;		
	if self.chkOnboardCargo.value then
		return true;
	endif;		
	if self.chkChecked.value then
		return true;
	endif;
	
	
	if self.btnImports.value then
		return true;
	endif;
	if self.btnExports.value then
		return true;
	endif;
	if self.btnRTL.value then
		return true;
	endif;
	if self.btnCustomerPri1.value then
		return true;
	endif;
	if self.btnCustomerPri2.value then
		return true;
	endif;
	if self.btnCustomerPri3.value then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hideShowFilters" id="46e7dd8b-12cf-4555-b841-fc678c47880e">
        <source>hideShowFilters();
/*
Purpose:			

Date		Who		Reason
27 February 2023	navab1	TFS CR 56806 TASK 56807
16 January  2024	navra1	CR 62045/Task 62047 - UI - Location Confirmation Configuration
*/

vars

	cargoFuncHeight : Decimal[23,4];
begin
	self.frmCargoFunctions.visible := self.frmCreateCargoAndMove.visible or self.frmConfirmLcnAndQ.visible;
	
	if not self.frmFilter.visible then
		self.frmCargoFunctions.top := self.frmFilter.top;
	else
		self.frmCargoFunctions.top := self.frmTop.top + self.frmTop.height + self.frmFilter.height;
	endif;

	if not self.frmCargoFunctions.visible then
		cargoFuncHeight := 0;
	else
		cargoFuncHeight := self.frmCargoFunctions.height;
	endif;
	
	//navra1 - CR 62045/Task 62047 - 17th January 2024 - start
	if self.frmCreateCargoAndMove.visible then
		self.frmConfirmLcnAndQ.left := 477;
	else
		self.frmConfirmLcnAndQ.left := 10;
	endif;
	//navra1 - CR 62045/Task 62047 - 17th January 2024 - end
	
	self.frmForeman.top := self.frmCargoFunctions.top + cargoFuncHeight;
	self.fldMain.top := self.frmForeman.top + self.frmForeman.height;
	self.fldMain.height := self.clientHeight - self.fldMain.top + 20;
	self.splAllCargo.repositionAfterResize();


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="includeObject" id="7ec9a91c-de47-45cc-ac3b-b17ef4b1929b">
        <source>includeObject(_ti : CM_TrackedItem; _checkRelRec : Boolean) : Boolean;
/*
Purpose:			

Date		Who		Reason
03 Mar 2023	navab1	TFS CR 56806 TASK 56807
01 Dec 2023	jlika1	TFS 61592 CUX | FLP Priority Quick Filters
06 Dec 2023	jlika1	TFS 61600 61695 CUX | Implement Imports &amp; Exports Quick Filters
21 Dec 2023	jlika1	TFS 61601 61847 CUX | FLP Implement RTL Quick Filter
24 Jun 2024	jlizm1	TFS 64766 VOL child cargo should not display as row
27 Jun 2024	jlizm1	TFS 64880 Cargo loaded then unloaded doesn't show for loading again
06 Aug 2024	jlizm1	TFS 65494 Discharged MAFI not showing for reload with new cargo
12 Sep 2024 navma1	Bug 66079: CUX - Error 4s at Voyage Operation live
*/

vars
	imex 				: CM_IMEXStatus;
	site 				: Integer;
	cargoType			: CM_CargoType;
	subType				: CM_Product;
	trackedItem			: CM_TrackedItem;
	customerPriority 	: CM_CustomerPriority;
	isMatch 			: Boolean;
	invalid				: Boolean;
	edition				: Integer;
begin

	on Exception do app.handleDeletedObject(exception, _ti, invalid);
	
	if _ti = null then
		return false;
	endif;
	
	edition := _ti.edition;  // 12.10.2019 navma1 #46965
	
	if invalid then			 // 12.10.2019 navma1 #46965
		return false;
	endif;
	
	trackedItem := _ti;
	
	if _checkRelRec then
		// release/receival to/from ship no longer enough to confirm ti is where it's supposed to be. Need to check other details too
		if trackedItem.hasBeenReleasedToShip() then
			if trackedItem.isOnShip // just to confirm ti hasn't been unloaded again for some reason
			and trackedItem.myPrimaryActualLocation &lt;&gt; self.myCurrentVoyage.myShipBlockStack then // CUX will move loads to the ship block stack first, then they will confirm and move to actual location
				return false;
			endif;
		else
			if trackedItem.isMAFI() then
				if self.excludeMAFI(trackedItem.CM_TILC) then
					return false;
				endif;
			else
				if trackedItem.isOnSite
				and trackedItem.hasBeenReceivedFromVoyage(self.myCurrentVoyage) then
					return false;
				endif;
			endif;
		endif;
	endif;
	//jlier1 TFS 65274 19/7/24
	if trackedItem.isOffSite then
		return false;
	endif;
	
	if trackedItem.isChild then
		return false;
	endif;
	
	imex := self.cmbIMEX.listObject.CM_IMEXStatus;
	if imex &lt;&gt; null then
		if imex &lt;&gt; trackedItem.getImExStatusObject() then
			if self.btnImports.value and not trackedItem.isImport then			
				return false;
			elseif self.btnExports.value  and not trackedItem.isExport then			
				return false;
			elseif not self.btnImports.value and not self.btnExports.value then
				return false;
			endif;
		endif;
	endif;
	
	if self.btnImports.value and self.btnExports.value then				
		if not trackedItem.isImport then
			if not trackedItem.isExport then
				return false;
			endif;
		elseif not trackedItem.isExport then
			if not trackedItem.isImport then
				return false;
			endif;
		endif;
	else
		if imex = null then
			if self.btnImports.value then
			if not trackedItem.isImport 
				and not trackedItem.isTranshipItem then
					return false;
				endif;
			endif;
			
			if self.btnExports.value then
				if not trackedItem.isExport 
				and not trackedItem.isTranshipItem then
					return false;
				endif;
			endif;			
		endif;
	endif;	
	
	if self.btnRTL.value and not trackedItem.readyToLoad then
		return false;
	endif;
	
	if self.cmbSite.listIndex &gt; 1 then
		site := self.cmbSite.listData;
		if site &lt;&gt; trackedItem.site then
			return false;
		endif;
	endif;
	

	if self.txtCargoId.text &lt;&gt; null then
		if trackedItem.id.pos(self.txtCargoId.text,1) = 0 then
			return false;
		endif;
	endif;
	
	cargoType := self.cmbCargoType.listObject.CM_CargoType;
	if cargoType &lt;&gt; null then
		if cargoType &lt;&gt; trackedItem.myCargoType then
			return false;
		endif;
	
	endif;
	
	subType := self.cmbCargoSubType.listObject.CM_Product;
	if subType &lt;&gt; null then
		if subType &lt;&gt; trackedItem.myProduct then
			return false;
		endif;
	
	endif;
	
	cargoType := self.cmbCargoTypeOnBoard.listObject.CM_CargoType;
	if cargoType &lt;&gt; null then
		subType := self.cmbCargoSubTypeOnBoard.listObject.CM_Product;
		return trackedItem.includesCargoTypeOnboard(cargoType,subType);
	else
		subType := self.cmbCargoSubTypeOnBoard.listObject.CM_Product;
		if subType &lt;&gt; null then
			return trackedItem.includesCargoTypeOnboard(null,subType);
		endif;
	endif;
	
	if self.chkHasStops.value then
		if not trackedItem.hasStops then
			return false;
		endif;
	endif;
	
	if self.btnCustomerPri1.value = false 
	and self.btnCustomerPri2.value = false 
	and self.btnCustomerPri3.value = false then
		return true;
	
	else
		customerPriority := trackedItem.getCustomerPriority();
		
		if self.btnCustomerPri1.value = true then
			if self.myCustomerPriority1 &lt;&gt; null then
				if customerPriority = self.myCustomerPriority1 then
					isMatch := true;
				endif;
			endif;
		endif;
		if not isMatch 
		and self.btnCustomerPri2.value = true then
			if self.myCustomerPriority2 &lt;&gt; null then
				if customerPriority = self.myCustomerPriority2 then
					isMatch := true;
				endif;
			endif;
		endif;
		if not isMatch 
		and self.btnCustomerPri3.value = true then
			if self.myCustomerPriority3 &lt;&gt; null then
				if customerPriority = self.myCustomerPriority3 then
					isMatch := true;
				endif;
			endif;
		endif;
		
		//Just in Case it was click without setting any of the button mapped value.
		if not isMatch and self.myCustomerPriority1 = null 
		and self.myCustomerPriority2 = null 
		and self.myCustomerPriority3 = null then
			isMatch := true;
		endif;
		
		return isMatch;
	endif;
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_checkRelRec" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initCargoTable" id="d3384d1b-b250-485e-9dbd-b44df187af95">
        <source>initCargoTable(_table : CM_DataTable);
/*
Purpose:			

Date		Who		Reason
27 February 2023	navab1	TFS CR 56806 TASK 56807
*/

vars

	theTable : CM_DataTable;
	entTableDef : EntTableDef;
begin

	theTable := _table; 
	theTable.userInputEnabled := false;
	theTable.allowDragSelect := false;
	theTable.selectMode := CM_EntryTable.SelectMode_FixedRow;
	theTable.selectionType := CM_EntryTable.SelectionType_Row;
	theTable.rows := theTable.fixedRows;
	theTable.cnEcResizeContents();
	
	entTableDef := app.myController.getEntTableDef(ETDef_LlHeadings);
	theTable.setTblDataEntRowsFromDef(entTableDef);
	
	theTable.readOnly := false;	
	theTable.fixedColumns := 0;
	theTable.show3D := Table.Show3D_Not3D;
	theTable.multiSelect := CM_BaseTable.MultiSelect_Simple;


epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="initSplitterAndTables" id="76e051b9-e8e1-4367-b077-561c16106129">
        <updating/>
        <source>initSplitterAndTables(_spl : CMUI_SplitContainer input; _top, _bott : CM_DataTable input) updating;
/*
Purpose:			

Date				Who		Reason
27 February 2023	navab1	TFS CR 56806 TASK 56807
07 December 2023	jlizm1	TFS 61426 CUX FLP Screen Enhancements
*/

vars

begin
	_spl.setupChildControlsLeftRight(_top,_bott);
	_spl.cnEcResizeContents();
	_spl.setLeftToRightRatio(80);
	_spl.setSplitDirection(true);
	_spl.stretchHeight := true;
	_spl.stretchWidth := true;
	_spl.setDistanceFromBottom(18);
	
	self.initCargoTable(_top);
	self.initCargoTable(_bott);
	

epilog

end;</source>
        <Parameter name="_spl" type="CMUI_SplitContainer" usage="input"/>
        <Parameter name="_top" type="CM_DataTable" usage="input"/>
        <Parameter name="_bott" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initVoyageOpsSummaryTable" id="7bf80e82-dfbd-4de0-ba61-6e97472f26e2">
        <source>initVoyageOpsSummaryTable(_table : Table input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2024	jlier1	Initial creation 62270

*/

vars

begin

	_table.clear;
	_table.clearGraphics;
	_table.columns:= 7;
	_table.rows:=0;
	_table.autoRedraw:=true;
	_table.gridLines:=true;
epilog

end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="isCargoInCollection" id="cb50565b-2f93-43d2-a9d6-f6e95a1109ee">
        <source>isCargoInCollection(_ti : CM_TrackedItem) : Boolean;
/*

Purpose:			Search all collection to determine if cargo has already been added

Parameters:			

Return Value:		

Date				Who		Reason
19 March 2024		jlizm1	Initial creation TFS 62763 Table auto updates

*/

vars
	idx : Integer;
	
begin
	if _ti = null then
		return false;
	endif;
	
	if self.allCargoBooked.includes(_ti) then
		return true;
	
	elseif self.allCargoToBeWorked.includes(_ti) then
		return true;
	
	endif;
	
	return false;
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isCargoInTable" id="d4b13e13-a758-4a94-ac2b-7bfbd61298bb">
        <source>isCargoInTable(_ti : CM_TrackedItem; _table : CM_DataTable) : Boolean;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 04 March 2024
TFS#		: 62716
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	rowIdx 		: Integer;
	rows		: Integer;
	trackedItem : CM_TrackedItem;
	tbl 		: CM_DataTable;
begin
	tbl := _table;
	rows := _table.rows;
	
	//CHECK EACH ROW IN TABLE FOR TI
	foreach rowIdx in 2 to rows do
		trackedItem := tbl.accessRow(rowIdx).itemObject.CM_TrackedItem;	
		if _ti = trackedItem then
			return true;
		endif;
	endforeach;
	
	return false;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_table" type="CM_DataTable"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="960b0fad-dc31-4cd9-90a8-b023b4d76e56">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
27 November 2024		jlizm1	Initial creation MTN 33144 Voyage ops live search with enter key

*/

vars
	theActiveControl	: Control;
	
begin
	inheritMethod(keyCode, shift);	// ### JIRA: MTN-34390 24Mar2025 NAVPW1
	
	if keyCode = J_key_Enter then
		theActiveControl := app.activeControl;
		if theActiveControl.parent = frmFilter
		and not theActiveControl = self.btnClear then
			self.doQuery(false);
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
