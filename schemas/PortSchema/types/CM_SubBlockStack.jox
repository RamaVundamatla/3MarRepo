    <JadeMethod name="createDeckingOptions" id="856d7717-0c11-43de-86b1-f23a8d56af33">
        <source>createDeckingOptions();
//----------------------------------------------------------------
//	Created:	08 November 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	pxyDO,
	theDO		: CM_YADeckingOptionsTA;
	yardLocn	: CM_BlockController;
	locnCtrl	: CM_LocationsController;
	areaIndex	: Integer;
begin

	if self.myYADeckingOptions = null then
		create pxyDO transient;
		pxyDO.setProxy(false, true, self);
		pxyDO.setProxyRules(DeckingRule_Default, DeckingRule_Default);
	
		create theDO persistent;
		theDO.setForCreate(pxyDO);
	else
		theDO := self.myYADeckingOptions;
	endif;
	
	if self.allLocationsControllers.size &lt;&gt; 1 then
		app.raiseUnexpectedProgramError(class.name, method.name, 'invalid number of locations in sub block stack');
		return;
	else
		locnCtrl := self.allLocationsControllers.first;
		if CM_BlockController.hasInstance(locnCtrl) then
			yardLocn := locnCtrl.CM_BlockController;
			areaIndex := 0;
			yardLocn.setForDeckingIn(1, 1, theDO.allYALocationCellsIn, areaIndex);
			areaIndex := 0;
			yardLocn.setForDeckingOut(1, 1, theDO.allYALocationCellsOut, areaIndex);
		endif;
		
	endif;

epilog

	delete pxyDO;										// 07/02/2014

end;</source>
    </JadeMethod>
    <JadeMethod name="erase" id="d36d5497-9448-4562-8213-6c56f2d7189a">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aTA : CM_TerminalArea;
begin
	aTA := self.myParent;
	
	inheritMethod(_eraseLevel);

epilog
	if aTA &lt;&gt; null then
		aTA.causeEvent(aTA.myTerminal.getTerminalEvent(EVENT_REFRESH_GRID_AREA),false,aTA); //epr 11/6/08  par 16956 
	endif;
	
end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getColumns" id="ac73c27f-f730-4568-98bb-4ec76eec470c">
        <source>getColumns(_forDrawing: Boolean): Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 August 2011	cnwndl1	Initial creation	Par 28076

*/

vars

	iter : Iterator;
	gridCont : CM_GridController;
	gridColumnDict : CM_GridColumnDict;

begin

	if self.allByPassedControllers.isEmpty then
		return inheritMethod(_forDrawing);
		
	else
		create gridColumnDict transient;
		iter := self.allByPassedControllers.createIterator;
		while iter.next( gridCont ) do
			if not gridColumnDict.includes( gridCont.myGridColumn ) then
				gridColumnDict.add( gridCont.myGridColumn );
			endif;
		endwhile;
		return gridColumnDict.size;
	endif;

epilog

	delete iter;
	delete gridColumnDict;
	
end;</source>
        <Parameter name="_forDrawing" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getName" id="2704bf76-a6e0-4dac-bec3-fb2008432b3d">
        <source>getName(): String;
// ---------------------------------------------------------------------------
// Created:		08 May 2008 By Andrew Bishop cnwab1
//
// Purpose:		PAR 16705
//
// ---------------------------------------------------------------------------
vars
	tmp : String;
begin
	tmp := inheritMethod();

	if self.myParent &lt;&gt; null then
		tmp := tmp &amp; " '" &amp; self.myParent.id &amp; "'";
	endif;
		
	
	return tmp;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRows" id="197df4b8-c08a-4caa-bdac-69901b44ed61">
        <source>getRows(_forDrawing: Boolean): Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 August 2011	cnwndl1	Initial creation	Par 28076

*/

vars

	iter : Iterator;
	gridCont : CM_GridController;
	gridRowDict : CM_GridRowDict;

begin

	if self.allByPassedControllers.isEmpty then
		return inheritMethod(_forDrawing);
		
	else
		create gridRowDict transient;
		iter := self.allByPassedControllers.createIterator;
		while iter.next( gridCont ) do
			if not gridRowDict.includes( gridCont.myGridRow ) then
				gridRowDict.add( gridCont.myGridRow );
			endif;
		endwhile;
		return gridRowDict.size;
	endif;

epilog

	delete iter;
	delete gridRowDict;
	
end;</source>
        <Parameter name="_forDrawing" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initForSubBlockStack" id="6268aec1-cc30-4d55-a35c-23056b1bd351">
        <updating/>
        <source>initForSubBlockStack(_grid : CMIF_GridTARegion; _parent : CM_GridArea) updating;
// ---------------------------------------------------------------------------
// Created:     05 March 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.id := _grid.id;
	
	self.setMyParent(_parent);	//Inverse
	self.type 	:= TA_TYPE_SUBBLOCK_STACK ;
	self.myType := app.myRoot.allTerminalAreaTypes[TA_TYPE_SUBBLOCK_STACK];
	self.autoRestrictionsEnabled := _parent.autoRestrictionsEnabled;
	self.isEmpty := true;
	//-----------------
	//Create the individual LocationsController
	//-----------------
	self.createLC();
	self.setMyLayoutGraphic(null);
	self.myLayoutGraphic.setColour(_grid.colour);
	self.myTerminal := _parent.myTerminal;
	//------------------
	//check swapstack exists
	//------------------
	self.createSwapStack();

end;</source>
        <Parameter name="_grid" type="CMIF_GridTARegion"/>
        <Parameter name="_parent" type="CM_GridArea"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="3944c80a-5582-4f97-b0d9-63fa987fd659">
        <updating/>
        <source>setForCreate(_proxy :CM_BlockStack input; _passport : CM_Passport input) updating;
//setForCreate(pProxyBlockStack: CM_BlockStack; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		December  2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lController	: CM_GridController;
begin
	inheritMethod(_proxy, _passport);

	self.setForUpdate(_proxy);	
end;</source>
        <Parameter name="_proxy" type="CM_BlockStack" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="94e2f680-4f13-4e4b-9daa-c6b3574385e6">
        <updating/>
        <source>setForUpdate(_proxy :CM_BlockStack) updating;
//setForUpdate(pProxyBlockStack: CM_BlockStack) updating;
// ---------------------------------------------------------------------------
// Created:		December  2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	lProxyController, 
	lRealController	: CM_LocationsController;
begin
	inheritMethod(_proxy);
	
	// if we are creating this will be empty, if we are updating then we will break the existing links, and then recreate them below, incase the 'shape' has changed
	foreach lRealController in self.allByPassedControllers do
		lRealController.CM_GridController.setMySubBlockStack(null); 
	endforeach;
	
	foreach lProxyController in _proxy.allByPassedControllers do
		lRealController := lProxyController.pxyGetRealObject;
		lRealController.CM_GridController.setMySubBlockStack(self); 
	endforeach;

end;</source>
        <Parameter name="_proxy" type="CM_BlockStack"/>
    </JadeMethod>
    <JadeMethod name="setMyParent" id="39405651-a94c-4b23-ab21-6b65c5e65346">
        <updating/>
        <source>setMyParent(_value : CM_GridArea) updating;
// ---------------------------------------------------------------------------
// Created:		November  2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	exclusiveLock(self);
	
	if self.myParent &lt;&gt; _value then
		self.myParent := _value;
	endif;

end;</source>
        <Parameter name="_value" type="CM_GridArea"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="d7bdbbf2-00d6-4f78-98a4-adab02f5a60c">
        <updating/>
        <source>setProxy(pID, pComment : String; 
		 pType : Integer;
		 pHeight : Integer;
		 pRows : Integer;	//29 Aug 2011	NDL	Par 28076
		 pColumns : Integer;	//29 Aug 2011	NDL	Par 28076
		 pEnforceMaxCapacity : Boolean;	//29 Aug 2011	NDL	Par 28076
		 pTypeString : String;
		 pMax : Integer;
		 pRel : Boolean;
		 pControllers: CM_LCArray;
		 pTerm : CM_Terminal;
		 _autoRestrictionEnabled,
		 pAutoPlanEnabled,
		 _stockControlled, _isOverlapped : Boolean;
		 _hideFromOverView : Boolean;
		 _allInterchangeAreas	:CM_InterchangeAreaArray;	// par 24292
		_defaultInterchangeArea: CM_InterchangeArea;
		_doCreateLogicalDelTrx : Boolean //03 Aug NDL	TFS 5679
		) updating;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		NOTE pControllers should be an array with proxy copies of the real controllers in it
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26/05/2010		cnwcs5	par 24292 - change _allInterchangeAreas parameter from set to array
vars
	i : Integer;
	lLabels : String;
	lController	: CM_LocationsController;
	lGridArea	: CM_GridArea;
begin
	inheritMethod(pID, pComment, pType, pHeight, pRows, pColumns, pEnforceMaxCapacity, pTypeString, pMax, pRel, pControllers, pTerm,_autoRestrictionEnabled, pAutoPlanEnabled, _stockControlled, _isOverlapped, _hideFromOverView, _allInterchangeAreas,_defaultInterchangeArea,_doCreateLogicalDelTrx);
	
	foreach lController in pControllers do
		lController.CM_GridController.setMySubBlockStack(self); // this is effectively converting from a Grid Area to a sub block stack
		if lGridArea = null then
			lGridArea := lController.myTerminalArea.CM_GridArea;
		endif;
	endforeach;
	self.setMyParent(lGridArea);
end;</source>
        <Parameter name="pID" type="String"/>
        <Parameter name="pComment" type="String"/>
        <Parameter name="pType" type="Integer"/>
        <Parameter name="pHeight" type="Integer"/>
        <Parameter name="pRows" type="Integer"/>
        <Parameter name="pColumns" type="Integer"/>
        <Parameter name="pEnforceMaxCapacity" type="Boolean"/>
        <Parameter name="pTypeString" type="String"/>
        <Parameter name="pMax" type="Integer"/>
        <Parameter name="pRel" type="Boolean"/>
        <Parameter name="pControllers" type="CM_LCArray"/>
        <Parameter name="pTerm" type="CM_Terminal"/>
        <Parameter name="_autoRestrictionEnabled" type="Boolean"/>
        <Parameter name="pAutoPlanEnabled" type="Boolean"/>
        <Parameter name="_stockControlled" type="Boolean"/>
        <Parameter name="_isOverlapped" type="Boolean"/>
        <Parameter name="_hideFromOverView" type="Boolean"/>
        <Parameter name="_allInterchangeAreas" type="CM_InterchangeAreaArray"/>
        <Parameter name="_defaultInterchangeArea" type="CM_InterchangeArea"/>
        <Parameter name="_doCreateLogicalDelTrx" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validate" id="69f1f862-527b-4f97-a167-e2b253d31cfd">
        <source>validate() protected;
// ---------------------------------------------------------------------------
// Created:		December  2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lControllerArray	: CM_LCArray;
	lController	: CM_LocationsController;

begin
	inheritMethod();

	create lControllerArray transient;
	
	foreach lController in self.allByPassedControllers do
		lControllerArray.add(lController);
	endforeach;
	
	self.myParent.validateConvertToSubBlock(lControllerArray);

epilog
	delete lControllerArray;
end;</source>
        <access>protected</access>
    </JadeMethod>
