    <JadeMethod name="ma111219" id="5b17a34a-0ba2-47a8-ba62-4bae258e56dc">
        <source>ma111219();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2019	jlgma1	Initial creation

*/

vars
	reference     : Integer;
	yearStr,
	voyageCode    : String;
	now 		  : Date;
	voyageGrpCode : String;
begin
	voyageCode :="12345";
	write voyageCode.length;
	
	
	reference := HookType_VoyageGroupCode; // here to provide some sort of reference....
									      // doesn't do anything, just makes it easier to find.
	
	if voyageCode.length &gt;= 5 then
		voyageGrpCode := voyageCode[1:5];
	endif;
	
	write voyageGrpCode;
epilog

end;</source>
