    <JadeMethod name="validateInvLineDescUsedTranMap" id="fa646f44-e5e9-47db-8cb8-02bed76a9788">
        <source>validateInvLineDescUsedTranMap(_invLineDesc : CM_InvoiceLineDesc) : Boolean;
/*
Purpose:	TFS 39236		
Date				Who			Reason
JUNE 2018		CNWAB1		Initial creation
*/
vars
	tis : CM_WorkOrderServiceBroker;
begin
	foreach tis in self.allWorkOrderSBs discreteLock do
		if tis.validateInvLineDescUsedTranMap(_invLineDesc) then
			return true;
		endif;
	endforeach;
	
	return false;
end;</source>
        <Parameter name="_invLineDesc" type="CM_InvoiceLineDesc"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
