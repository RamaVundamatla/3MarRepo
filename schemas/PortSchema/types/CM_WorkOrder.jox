    <JadeMethod name="setForCreate" id="df636a69-f056-4fea-879c-15bad84ab9ca">
        <updating/>
        <source>setForCreate( _proxyWO: CM_WorkOrder) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23/07/2009	cnwrd1	Initial creation
08/05/2018	jlgdap1	TFS 38501 PEL1 Work Order Changes
15 Oct 2021 jlier1	TFS 52195 
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
*/

vars
	proxyWOD,
	realWoDTL 	: CM_WorkOrderDtl;
	createPin,								// TFS 38501
	approved	: Boolean;					// TFS 38501
	pinNo 		: CM_PinNo;					// TFS 38501
	error		: String;					// TFS 38501
	term        : CM_Terminal;
begin
	term             := _proxyWO.myTerminal;	//12.01.2023 navma1 #56141 Task#56147
	approved 		 := self.taskStatus &lt;&gt; WO_STATUS_APPROVED and _proxyWO.taskStatus = WO_STATUS_APPROVED;		// TFS 38501
	createPin 		 := false;	
	
	
	if _proxyWO.id.trimBlanks = null then
		if _proxyWO.isVoyageWorkOrder then
			self.id	:= term.generateNextVoyWorkOrderId( _proxyWO.CM_WorkOrderVoyage.myVoyage,  _proxyWO.CM_WorkOrderVoyage );
		else
			self.id	:= term.generateNextCargoWorkOrderId();						//12 Jun 2018	NDL	TFS 39142
		endif;
	else
		self.id := _proxyWO.id;
	endif;
	
	self.myTerminal	 := term; // NAVAB1 UT fixing; move setting this to after setting the ID 					// TFS 41539

	foreach proxyWOD in _proxyWO.allWoDtls do
		create realWoDTL as proxyWOD.class persistent;
		
		realWoDTL.setForCreate( proxyWOD, self);
		
		if realWoDTL.isWorkOrderForRelease or realWoDTL.isWorkOrderForReceival 			// TFS 38501
		or realWoDTL.isWorkOrderForExportReturn then									// TFS 38501
			createPin := true;															// TFS 38501
		endif;																			// TFS 38501
	endforeach;
	
	if createPin and approved and self.myPinNo = null then								// TFS 38501
		app.generatePinNo(pinNo, error, term);											// TFS 38501
		if pinNo &lt;&gt; null then															// TFS 38501
			self.myPinNo := pinNo;														// TFS 38501
		endif;																			// TFS 38501
	endif;																				// TFS 38501
	
	//jlier1 29/5/25 MTN-34591 
	self.causeTerminalEvent(Event_WorkOrder_Create);
	
	self.setForUpdate ( _proxyWO ,false);
epilog

end;</source>
        <Parameter name="_proxyWO" type="CM_WorkOrder"/>
    </JadeMethod>
    <JadeMethod name="setForCreateShipMani" id="3e749226-6a76-43d8-950e-638b0fdc62c0">
        <updating/>
        <source>setForCreateShipMani( _proxyWO: CM_WorkOrder) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15/11/2023	navcs2	ChangeRequest 60866: EUP | Manifest - Single Work Order per transport
*/

vars
	proxyWOD,
	realWoDTL 	: CM_WorkOrderDtl;
	createPin,								
	approved	: Boolean;					
	pinNo 		: CM_PinNo;					
	error		: String;					
	term        : CM_Terminal;
begin
	term             := _proxyWO.myTerminal;	
	self.myTerminal	 := term; 					
	approved 		 := self.taskStatus &lt;&gt; WO_STATUS_APPROVED and _proxyWO.taskStatus = WO_STATUS_APPROVED;
	createPin 		 := false;	
	
	
	if _proxyWO.id.trimBlanks = null then
		if _proxyWO.isVoyageWorkOrder then
			self.id	:= term.generateNextVoyWorkOrderId( _proxyWO.CM_WorkOrderVoyage.myVoyage,  _proxyWO.CM_WorkOrderVoyage );
		else
			self.id	:= term.generateNextCargoWorkOrderId();					
		endif;
	else
		self.id := _proxyWO.id;
	endif;
	
	foreach proxyWOD in _proxyWO.allWoDtls do
		create realWoDTL as proxyWOD.class persistent;
		
		realWoDTL.setForCreate( proxyWOD, self);
		
		if realWoDTL.isWorkOrderForRelease or realWoDTL.isWorkOrderForReceival 		
		or realWoDTL.isWorkOrderForExportReturn then								
			createPin := true;															
		endif;																			
	endforeach;
	
	if createPin and approved and self.myPinNo = null then								
		app.generatePinNo(pinNo, error, term);								
		if pinNo &lt;&gt; null then														
			self.myPinNo := pinNo;													
		endif;															
	endif;
	
	//jlier1 29/5/25 MTN-34591 
	self.causeTerminalEvent(Event_WorkOrder_Create);
	
	self.setForUpdateShipMani( _proxyWO ,false);
epilog

end;</source>
        <Parameter name="_proxyWO" type="CM_WorkOrder"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="e2b58532-a27a-4ce7-aa9f-4795b686beb2">
        <updating/>
        <source>setForUpdate( _proxyWO: CM_WorkOrder; _updateTasks: Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24/07/2009	cnwrd1	Initial creation
08/05/2018	jlgdap1	TFS 38501 PEL1 Work Order Changes
15/10/2021 	jlier1	TFS 52195
19 Apr 2022	navcs2	ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
16 Dec 2022 navma1	Bug 54234: MTN - Work Order Maintenance - Work Order tasks are duplicated when adding a todo task to the Receive Cargo
*/

vars
	email 				: CM_EmailEntity;
	approved			: Boolean;					
	workOrdersToDelete  : ObjectSet;
	pxyWorkOrderDtl, 
	newRealWorkOrderDtl : CM_WorkOrderDtl;
	obj 				: Object;
begin
	approved := self.taskStatus &lt;&gt; WO_STATUS_APPROVED and _proxyWO.taskStatus = WO_STATUS_APPROVED;		// TFS 38501
	
	self.allEmailAddresses.clear();
	foreach email in _proxyWO.allEmailAddresses do
		self.allEmailAddresses.add(email);
	endforeach;
	
	self.approvalExpiryTS   := _proxyWO.approvalExpiryTS;	// 11 Jun 2018	NDL	TFS 38795
	self.approvedBy 		:= _proxyWO.approvedBy;
	self.approvedByDT 		:= _proxyWO.approvedByDT;
	self.archived 			:= _proxyWO.archived;
	self.completedDT 		:= _proxyWO.completedDT;
	self.customerReference  := _proxyWO.customerReference;
	self.emailNotification  := _proxyWO.emailNotification;
	self.myTerminal			:= _proxyWO.myTerminal;
	self.userCode 			:= _proxyWO.userCode;
	self.enteredByDT 		:= _proxyWO.enteredByDT;
	self.myOrganisation		:= _proxyWO.myOrganisation;
	self.remarks			:= _proxyWO.remarks;
	self.requiredByDT		:= _proxyWO.requiredByDT;
	self.startAtDT			:= _proxyWO.startAtDT;
	self.notApprovedBy 		:= _proxyWO.notApprovedBy;		//14 Jun 2018	NDL	TFS 39167	
	self.notApprovedByDT 	:= _proxyWO.notApprovedByDT;	//14 Jun 2018	NDL	TFS 39167
	
	//15/10/2021 	jlier1	TFS 52195 - need to update all the tasks before the status change code that sends emails
	if _updateTasks then
		create workOrdersToDelete transient;
		self.allWoDtls.copy(workOrdersToDelete); 
		
		foreach pxyWorkOrderDtl in _proxyWO.allWoDtls discreteLock do
			
			newRealWorkOrderDtl := app.myProxyManager.getRealObject(pxyWorkOrderDtl).CM_WorkOrderDtl;
			
			if newRealWorkOrderDtl = null then
				app.myUtilityCA.utlCreateWorkOrderTask(pxyWorkOrderDtl, newRealWorkOrderDtl, self, app.myPassport);
			else
				workOrdersToDelete.remove(pxyWorkOrderDtl.pxyGetRealObject);
				app.myUtilityUA.utlUpdateWorkOrderTask(pxyWorkOrderDtl,  app.myPassport);
				newRealWorkOrderDtl.setTaskID(pxyWorkOrderDtl.taskID);						//12.01.2023 navma1 #56141 Task#56147
			endif;
			
			if  app.myPassport.hasErrors() then
				return;
			endif;
		
		endforeach;	
	
		foreach obj in workOrdersToDelete do 					//16.12.2022 navma1 #54234
			obj.CM_WorkOrderDtl.erase(NORMAL_ERASE);
		endforeach;
		//workOrdersToDelete.purge;								//16.12.2022 navma1 #54234	
	endif;
	
	self.setTaskStatus( _proxyWO.taskStatus );
	self.updateTaskOrderPosition(_proxyWO);					//12.01.2023 navma1 #56141 Task#56147
	
	//jlier1 29/5/25 MTN-34591 
	self.causeTerminalEvent(Event_WorkOrder_Update);
epilog
	delete workOrdersToDelete;
end;</source>
        <Parameter name="_proxyWO" type="CM_WorkOrder"/>
        <Parameter name="_updateTasks" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateCompleted" id="4e40e0bb-7acb-44af-890b-dbda4fca6ac7">
        <updating/>
        <source>setForUpdateCompleted(_pxyWO : CM_WorkOrder) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13/11/2024	navkc1 JIRA Story MTN-33012: EUP | WO Transaction Billing Change of Debtor

*/

vars
	pxyWorkOrderDtl : CM_WorkOrderDtl;
	email 			: CM_EmailEntity;
begin
	
	self.allEmailAddresses.clear();
	foreach email in _pxyWO.allEmailAddresses do
		self.allEmailAddresses.add(email);
	endforeach;
	
	self.approvalExpiryTS   := _pxyWO.approvalExpiryTS;
	self.approvedBy 		:= _pxyWO.approvedBy;
	self.approvedByDT 		:= _pxyWO.approvedByDT;
	self.archived 			:= _pxyWO.archived;
	self.completedDT 		:= _pxyWO.completedDT;
	self.customerReference  := _pxyWO.customerReference;
	self.emailNotification  := _pxyWO.emailNotification;
	self.myTerminal			:= _pxyWO.myTerminal;
	self.userCode 			:= _pxyWO.userCode;
	self.enteredByDT 		:= _pxyWO.enteredByDT;
	self.myOrganisation		:= _pxyWO.myOrganisation;
	self.remarks			:= _pxyWO.remarks;
	self.requiredByDT		:= _pxyWO.requiredByDT;
	self.startAtDT			:= _pxyWO.startAtDT;
	self.notApprovedBy 		:= _pxyWO.notApprovedBy;
	self.notApprovedByDT 	:= _pxyWO.notApprovedByDT;
	
	// Update work order details
	foreach pxyWorkOrderDtl in _pxyWO.allWoDtls discreteLock do
		app.myUtilityUA.utlUpdateCompletedWOTask(pxyWorkOrderDtl,  app.myPassport);
	endforeach;
	
	self.doResyncAllTransactions();
	
	//jlier1 29/5/25 MTN-34591 
	self.causeTerminalEvent(Event_WorkOrder_Update);
	
epilog

end;</source>
        <Parameter name="_pxyWO" type="CM_WorkOrder"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateShipMani" id="eb33958b-2f71-4b58-85ce-4a44f85a7018">
        <updating/>
        <source>setForUpdateShipMani( _proxyWO: CM_WorkOrder; _updateTasks: Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15/11/2023	navcs2	ChangeRequest 60866: EUP | Manifest - Single Work Order per transport
24/06/2025	navcs2	MTN-35058 MTN - Error 1301 When Loading Ship Manifest


*/

vars
	email 				: CM_EmailEntity;
	approved			: Boolean;					
	workOrdersToDelete  : ObjectSet;
	pxyWorkOrderDtl, 
	newRealWorkOrderDtl : CM_WorkOrderDtl;
	obj 				: Object;
begin
	approved := self.taskStatus &lt;&gt; WO_STATUS_APPROVED and _proxyWO.taskStatus = WO_STATUS_APPROVED;		
	
	self.allEmailAddresses.clear();
	foreach email in _proxyWO.allEmailAddresses do
		self.allEmailAddresses.add(email);
	endforeach;
	
	self.approvalExpiryTS   := _proxyWO.approvalExpiryTS;	
	self.approvedBy 		:= _proxyWO.approvedBy;
	self.approvedByDT 		:= _proxyWO.approvedByDT;
	self.archived 			:= _proxyWO.archived;
	self.completedDT 		:= _proxyWO.completedDT;
	self.customerReference  := _proxyWO.customerReference;
	self.emailNotification  := _proxyWO.emailNotification;
	self.myTerminal			:= _proxyWO.myTerminal;
	self.userCode 			:= _proxyWO.userCode;
	self.enteredByDT 		:= _proxyWO.enteredByDT;
	self.myOrganisation		:= _proxyWO.myOrganisation;
	self.remarks			:= _proxyWO.remarks;
	self.requiredByDT		:= _proxyWO.requiredByDT;
	self.startAtDT			:= _proxyWO.startAtDT;
	self.notApprovedBy 		:= _proxyWO.notApprovedBy;			
	self.notApprovedByDT 	:= _proxyWO.notApprovedByDT;
	
	if _updateTasks then
		create workOrdersToDelete transient;
		self.allWoDtls.copy(workOrdersToDelete); 
		
		foreach pxyWorkOrderDtl in _proxyWO.allWoDtls discreteLock do
			
			newRealWorkOrderDtl := app.myProxyManager.getRealObject(pxyWorkOrderDtl).CM_WorkOrderDtl;
			
			if newRealWorkOrderDtl = null then
				app.myUtilityCA.utlCreateWorkOrderTask(pxyWorkOrderDtl, newRealWorkOrderDtl, self, app.myPassport);
			else
				workOrdersToDelete.tryRemoveIfNotNull(pxyWorkOrderDtl.pxyGetRealObject);				// 24/06/2025	navcs2	MTN-35058
				app.myUtilityUA.utlUpdateWorkOrderTask(pxyWorkOrderDtl,  app.myPassport);
			endif;
			
			if  app.myPassport.hasErrors() then
				return;
			endif;
		
		endforeach;	
	
		foreach obj in workOrdersToDelete do 					
			obj.CM_WorkOrderDtl.erase(NORMAL_ERASE);
		endforeach;
	endif;
	
	self.setTaskStatus( _proxyWO.taskStatus );
	

epilog
	delete workOrdersToDelete;
end;</source>
        <Parameter name="_proxyWO" type="CM_WorkOrder"/>
        <Parameter name="_updateTasks" type="Boolean"/>
    </JadeMethod>
