    <JadeMethod name="cmbProcess_click" id="fe77a246-fd89-49de-badd-804ec4b22650">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbProcess_click(combobox: ComboBox input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
/*

Date		Name	TFS#		Description
============================================================================
15/03/2018	jlgdap1	TFS 37427 	PEL1 Voyage Status Enhancements Initial creation 
16/03/2018	jlgdap1	TFS 37540 	PEL1 Voyage Statuses Pelindo 1
24/04/2018	jlgdap1	TFS 38214 	PEL1 Voyage Status Changes
09/08/2019	jlgka1 	TFS 45921	PEL1 - Cannot make IMSR after Completing WO Permit Request - Manual Etmal IMSR
============================================================================*/
vars
	voyageProcess : CM_VoyageProcess;
	currentStatus : Integer;	
begin
	self.cmbStatus.clear;
	voyageProcess := self.cmbProcess.listObject.CM_VoyageProcess;
	if voyageProcess &lt;&gt; null then
		if self.myCurrentVoyage &lt;&gt; null then
			currentStatus := self.myCurrentVoyage.status;
		endif;
		//epr TFS 41523 2/11/18
		self.initComboVoyageStatus(voyageProcess,currentStatus);
		
		self.checkandsetCmbStatus(voyageProcess, currentStatus); //jlgka1 TFS 45921
	endif;
epilog
	
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbProcess_displayEntry" id="40713df4-cfd5-44a3-a209-34dc2ced0a14">
