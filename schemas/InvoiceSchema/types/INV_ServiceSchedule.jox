    <JadeMethod name="doPropertiesDClick" id="b820fbc6-e969-45af-9468-c031b862a681">
        <updating/>
        <source>doPropertiesDClick(_table: CM_EntryTable input) updating;
// 24024 CCMS 1151 Aug 2010 cnwjre1 user hook code for invoice quantity and rate
// 31451 May 2013 no edit of calc type hook code here - just view
vars
	rowInTable	: Integer;
begin
	rowInTable := _table.getRowByName(ETRow_RateHookCode);
