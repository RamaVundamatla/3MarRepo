    <JadeMethod name="doSearchYATemplates" id="f3bd5159-f180-4528-a6c6-3c1010816511">
        <updating/>
        <source>doSearchYATemplates() updating, protected;

/*

Purpose:		Search the Yard Allocation Templates based upon the YA Criteria that
				the user has created.  If no Criteria are entered, then all Yard
				Allocations Templates will be listed.

Parameters:			

Return Value:	self.allYATemplates - loaded with templates matching search criteria

Date			Who		Reason
13 August 2008	consw1	Initial creation

*/
begin
	self.showSearchParameters();
	self.allYATemplates.clear();
	self.mySearchParameters.search(self.allYATemplates, self.myTerminal.allYATemplates);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doShowSearch" id="f677f365-8e6d-40e7-a65c-9f1bb2566e2d">
        <updating/>
        <source>doShowSearch( _useYACriteria : Boolean ) updating, protected;

/*

Purpose:			Show search form and initiate search

Parameters:			

Return Value:		


Date				Who		Reason
09 September 2008	consw1	Initial creation

*/

vars
	theForm : CMUI_YACriteriaSearchForm;
	yardAlloc : CM_YardAllocation;
	
begin
	theForm := app.loadForm(CMUI_YACriteriaSearchForm, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_YACriteriaSearchForm;
	if theForm = null then
		return;
	endif;

	theForm.set( self.mySearchParameters );

	if _useYACriteria then
		if self.myCurrentObject &lt;&gt; null and global.isValidObject( self.myCurrentObject ) then
			yardAlloc := self.myCurrentObject.CM_YATemplate.myYardAllocation;
		endif;
		theForm.populateYACriteria( yardAlloc );
	endif;
	
	theForm.setParentForm(self);
	theForm.showModal();
	
	if theForm.modalResult = IDOK then
		self.doSearchYATemplates();
		self.doRefresh();
	endif;

epilog
	delete theForm;
end;</source>
        <access>protected</access>
        <Parameter name="_useYACriteria" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUserNotes" id="3415d3a0-e574-483b-8449-a2b9ddacb7da">
        <updating/>
        <source>doUserNotes(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
//30 July 2008	cnwdw1	
//
vars
	event: Integer;
	idx: Integer;
	breakOut: Boolean;
begin
	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	if event = Event_YATemplateCreate then
		if self.mySearchParameters.isMatchingYA( userInfo.CM_YATemplate.myYardAllocation ) then
			self.addObjectToTable(userInfo.CM_YATemplate, idx, breakOut);
			self.tblData.colourRows(self.colorRow1, self.colorRow2);
		endif;
	elseif event = Event_YATemplateUpdate then
	
	elseif event = Event_YATemplateDelete then
		self.tblData.colourRows(self.colorRow1, self.colorRow2);
	endif;

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
