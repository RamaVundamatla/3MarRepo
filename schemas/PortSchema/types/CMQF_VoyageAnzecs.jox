<Class name="CMQF_VoyageAnzecs" id="d952309d-3313-4637-a145-0451502d2dc0">
    <superclass name="CMQF_VoyageSummary"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <Constant name="LoadedOption_NZ" id="4a6adfb4-25a8-4783-87ba-94e0fa76fc61">
        <source>'New Zealand'</source>
        <type name="String"/>
    </Constant>
    <Constant name="LoadedOption_ThisPort" id="ea572cec-7c8e-42b7-a1f8-93718136c676">
        <source>'This port'</source>
        <type name="String"/>
    </Constant>
    <PrimAttribute name="loadedOption" id="5b585a55-7a57-4af3-891d-62a361fc5c80">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="filterObjects" id="358771bf-2aed-4955-a6c4-2b746d68c352">
        <updating/>
        <source>filterObjects(_voySummaryDict : CMIF_VoyageSummaryByValueDict input; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     10 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	voyage			: CM_Voyage;
	terminal		: CM_Terminal;
	iter			: Iterator;
	tiDict			: CM_TIByCargoTypeIdDict;
	ti				: CM_TrackedItem;
	disPort			: CM_Port;
	portDict		: CM_PortByCodeDict;
	disGroupCode	: String;
	summaryObj		: CMIF_VoyageSummary;
	breakOut		: Boolean;
	str				: String;
	querySelf		: CMQF_VoyageAnzecs;
begin
	querySelf := self;
	voyage := querySelf.getMyVoyage;
	
	if voyage = null then
		return;
	endif;
	self.initFields();

	//portDict := app.myRoot.allPorts;	
	portDict := app.myRoot.allPorts;	
	tiDict := voyage.allOnshipTIsByCargoTypeId;
	iter := tiDict.createIterator;
	tiDict.startKeyGeq(TI_CargoType_Container, null, iter);

	while iter.next(ti) do
		if ti.cargoType &lt;&gt; TI_CargoType_Container then
			break;
		endif;
		
		if not querySelf.checkStatusIncludesObject(ti, _passport, breakOut) then
//		if (not querySelf.includesObject(ti, _passport, breakOut)) then
//			if breakOut then
//				break;
//			endif;
			continue;
		endif;
	
//		if breakOut then
//			break;
//		endif;

		disPort := portDict[ti.dischargePort.trimBlanks];
		if disPort &lt;&gt; null and disPort.myPortGroup &lt;&gt; null then
			disGroupCode := disPort.myPortGroup.code;
		endif;
		
		summaryObj := querySelf.getSummaryObjectForOrder(_voySummaryDict, ti, null, null);		
		summaryObj.totalSelfForAnzecs(ti.CM_Container, disGroupCode);
		
		summaryObj := querySelf.getSummaryObjectForOrder(_voySummaryDict, ti, querySelf.TOTALS_ID, null);
		summaryObj.totalSelfForAnzecs(ti.CM_Container, disGroupCode);
		
	endwhile;
	
epilog
	delete iter;

end;</source>
        <Parameter name="_voySummaryDict" type="CMIF_VoyageSummaryByValueDict" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="8d83faa2-c5d9-4dc7-aa77-963d08341878">
        <updating/>
        <source>includesObject(_ti: CM_TrackedItem; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     10 December 2003	cnwth2
//
// Purpose:     No filtering done - just updates the monitor
//			 
// ----------   ----------  --------------------------------------------------
vars
	querySelf			: CMQF_VoyageSummary;
begin
	querySelf := self;
	querySelf.numSearched := querySelf.numSearched + 1;
	
	if (not self.allFilterLoadPorts.includes(_ti.loadPort.trimBlanks)) then
		return false;
	endif;
		
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initFields" id="5e6ee11e-07ab-4e25-862e-c3562d6799c4">
        <updating/>
        <source>initFields() updating;
// ---------------------------------------------------------------------------
// Created:     12 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	loadGroup		: CM_PortGroup;
	port			: CM_Port;
begin
	if self.loadedOption = null then
		self.loadedOption := self.LoadedOption_ThisPort;
	endif;
	
	if self.loadedOption = self.LoadedOption_NZ then
		loadGroup := app.myRoot.allPortGroups['NZ'];
		if loadGroup &lt;&gt; null then
			foreach port in loadGroup.allPorts discreteLock do
				self.allFilterLoadPorts.add(port.code.trimBlanks);		
			endforeach;
		endif;
	else
		self.allFilterLoadPorts.add(self.allTerminals.first.getConfig(PortDestCode).String);	
	endif;

end;</source>
    </JadeMethod>
</Class>
