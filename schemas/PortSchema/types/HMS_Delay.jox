    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="3d97bf7d-f6fb-4931-85b5-47881b129619">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------------
//
// Created by: cnwsh3 
//
// Date: 15 July 2003
//
//----------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxy	:	HMS_Delay;
	completedOK		: Boolean;
	
begin
	proxy := inheritMethod();
	proxy.myRoot := self.myRoot;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="edd625b4-59c6-4e8e-8175-92e6b93e1b42">
        <updating/>
        <source>setForUpdate(_pxyDelay: HMS_Delay; _passport: CM_Passport input) updating;
//--------------------------------------------------------
//
// Created by: cnwsh3 
//
// Date: 14 July 2003
//
//----------------------------------------------------------

vars

begin
	inheritMethod(_pxyDelay, _passport);
	
	self.code 			:= _pxyDelay.code.toUpper.trimBlanks;
	self.description	:= _pxyDelay.description;
	self.isChargeable	:= _pxyDelay.isChargeable;
	self.myRoot			:= _pxyDelay.myRoot;
	 
end;</source>
        <Parameter name="_pxyDelay" type="HMS_Delay"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="de1f5151-9c7f-4ca0-8b40-438034c236f2">
        <updating/>
        <source>setProxy(_root	:	CM_Root) updating;
//--------------------------------------------------------
//
// Created by: cnwsh3 
//
// Date: 15 July 2003
//
//----------------------------------------------------------

vars

begin
	self.raiseExceptionIfNotTransient(method);
	self.myRoot := _root;
	
epilog


end;</source>
        <Parameter name="_root" type="CM_Root"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="dc417a82-ab0b-412d-99f1-c4a4c74e7a35">
