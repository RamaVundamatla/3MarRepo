    <JadeMethod name="create" id="0746de7c-934a-4c8a-bd55-93bde10d69a7">
        <updating/>
        <source>create(_name, 
		_desc, 
		_methodSource	: String;
		_reason			: Integer;
		_class			: DEV_Class) ::super(_name) updating;
/*

Purpose:			Constructor for DEV_Method class

Parameters:			_name:			The name of the method
					_desc:			The description on the method
					_methodSource:	The source of the method
					_class:			The class object the method belongs to

Return Value:		

Date		Who		Reason
27 October 2021	navpw1	Initial creation TFS: 52202

*/

begin
	self.name 			:= _name;
	self.desc 			:= _desc;
	self.methodSource 	:= _methodSource;
	self.reason			:= _reason;
	
	//Set References
	self.myClass		:= _class;
	
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_desc" type="String"/>
        <Parameter name="_methodSource" type="String"/>
        <Parameter name="_reason" type="Integer"/>
        <Parameter name="_class" type="DEV_Class"/>
    </JadeMethod>
    <JadeMethod name="update" id="c6714467-a89f-4c9e-9d00-283ad70dbb70">
        <updating/>
        <source>update(_methodSignature, 
		_miscData,
		_desc, 
		_methodSource,
		_documentationTextData : String) updating;
/*

Purpose:			Update method for DEV_Method class (Sets optional attributes)

Parameters:			_methodSignature:		The signature of the method (The method anme and parameters of the method/first line)
					_miscData:				
					_modifiedTimestamp:		When the method was last modified
					_desc:					The description/body of the method (May need renaming to source)
					_methodSource:			The source of the method (JadeMetrodSource, External Method etc)
					_documentationTextData:	The documentation text on the method

Return Value:		

Date		Who		Reason
10 November 2021	navpw1	Initial creation TFS: 52202

*/

begin
	self.miscData 				:= _miscData;
	self.desc 					:= _desc;
	self.methodSource 			:= _methodSource;
	self.methodSignature 		:= _methodSignature;
	self.setDocumentationText(_documentationTextData);
	
end;</source>
        <Parameter name="_methodSignature" type="String"/>
        <Parameter name="_miscData" type="String"/>
        <Parameter name="_desc" type="String"/>
        <Parameter name="_methodSource" type="String"/>
        <Parameter name="_documentationTextData" type="String"/>
    </JadeMethod>
</Class>
