    <JadeMethod name="getCargoType" id="46519b0f-d168-49d8-a329-fb9bb8bcbeae">
        <source>getCargoType():CM_CargoType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	cargoTypeObj : CM_CargoType;
	ti : CM_TrackedItem;
	
begin

	if self.myCargoType &lt;&gt; null then
		return self.myCargoType;
	endif;

	if self.cargoType &lt;&gt; null then
		cargoTypeObj :=  app.myRoot.allCargoTypesById[ self.cargoType ];
		if cargoTypeObj &lt;&gt; null then
			return cargoTypeObj;
		endif;
	endif;
	
	ti := self.getTrackedItem;
	if ti &lt;&gt; null then
		cargoTypeObj := ti.myCargoType;
		if cargoTypeObj &lt;&gt; null then
			return cargoTypeObj;
		endif;
	endif;
	
	return null;

epilog

end;</source>
