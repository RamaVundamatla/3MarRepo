    <JadeMethod name="setDefaultBankCashInvoiceType" id="04ec7f1d-11f2-4c94-a751-eff039a1a035">
        <source>setDefaultBankCashInvoiceType( _cashInvType : CM_InvoiceDesc ):Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 January 2019	jlgndl1	Initial creation	TFS 40010

*/

vars

	bank : CM_Bank;
	oldSetting: Any;

begin

//	self.setTerminalConfig(CashInvoiceType, _cashInvType);
	bank := self.getTerminal.getDefaultCompanyBank;
	if bank &lt;&gt; null then
		oldSetting := bank.getConfig(CashInvoiceType);
		beginTransaction;
		bank.setConfig( CashInvoiceType, _cashInvType );
		commitTransaction;
	endif;
	
	return oldSetting;

epilog
	
	abortTransaction;

end;</source>
