	tabOrder 					:= tabOrder + 1;
	self.cmbCargoTypes.tabIndex 	:= tabOrder;
	return tabOrder;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_startTab" type="Integer"/>
        <ReturnType type="Integer"/>
