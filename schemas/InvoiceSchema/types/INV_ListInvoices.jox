        <source>doBtnStatusVoidClick() updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	
begin
	app.mousePointer := MP_HOURGLASS;
	//epr par 36958 24/9/15
	// TFS 39618 PATCH 1 if not app.myCurrentUserCan(self.myTerminal, PmAdmInvoiceStatusVoid) then
	if not self.myCurrentBank.userCanSet(CM_Invoice.INVOICE_VOID) then  // TFS 39618 PATCH 1 

