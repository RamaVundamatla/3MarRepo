    <JadeMethod name="getDensity" id="03c0a847-254f-4f59-a8e9-00862bb9d644">
        <source>getDensity(): Decimal;
/*

Date		Who		Reason
19 June 2014	cnwer1	Initial creation PAR 34406
// ### TFS BUG 60216 04SEP2023 NAVAB1 return 1 if the density is zero

*/

vars
	density : Decimal [23,4];
begin
	density := self.getDensitySelection();
	
	if density = 0 then
		return 1;
	endif;

epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getDensitySelection" id="1956251a-d0b4-44c2-999c-6855272516dd">
        <source>getDensitySelection(): Decimal;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
========================================================
10 February 2010		cnwcs5	CCMS 1925/PAR 22295 Release Summaries (Initial creation)
20 March 2014			cnwdap1 PAR #33606 CCMS SFW 1366 Bulk - density changed to Decimal, but this method
								is only used in data extract, so OK to cast as an Integer to return
10 March 2016			cnwdap1	PAR #37581 densitySelection is now Decimal as well, so change this too
*/

vars
	ti	:CM_TrackedItem;
begin
	ti := self.getTI;
	
	if ti &lt;&gt; null then
		//return ti.getDensity.Integer;					// PAR #33606		// PAR #37581
		return ti.getDensity;							// PAR #33606		// PAR #37581
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getDescription" id="8ebd1778-41f8-4e78-b776-77a81ba02c3b">
        <source>getDescription(): String;
/*
----------   ----------  --------------------------------------------------
Created:	07 May 2007 By cnwth2

Purpose:	

Changed On	Changed By	Reason
----------	----------	---------------------------------------------------
24/09/2009	consw1		SFW1035 - Changed CM_ReserveTI methods to use getTI for consistency.
---------------------------------------------------------------------------
*/
vars
	ti			: CM_TrackedItem;
	cargoType	: CM_CargoType;
begin
	
	ti := getTI();
	
	if ti = null then
		if app.isSpecial then
			return null;
			app.raiseUnexpectedProgramError(class.name, method.name, self.String &amp; ' has an allTrackedItems size of &gt; 1');
		endif;
		
		return 'No item assigned';
	endif;
	//th2 should only ever be a single ti in this collection when self is a CM_ReserveTI
	
	cargoType := ti.myCargoType;
	
	if cargoType.isBreakBulkMulti or cargoType.isBulkMulti then
		return self.getTotalRequestedDisplay() &amp; ' x ' &amp; ti.id;
	else
		return ti.id;
	endif;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDescriptionForSummary" id="834df1cb-243b-4e4d-8276-6b40b1c8b035">
        <source>getDescriptionForSummary(): String;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
========================================================
11 February 2010		cnwcs5	CCMS 1925/PAR 22295 Release Summaries (Initial creation)
*/

vars
	ti	: CM_TrackedItem;
	str	: String;
begin
	ti := self.getTI;
	
	if ti = null then
		return null;
	endif;
	
	str := ti.description;
	
	if str.length &gt; 30 then
		str := str[1:30];
	endif;
	
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="32377a86-bb60-4fc0-9cf6-dc10fc01993d">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
/* Changes

Date		Name	TFS#			Description
============================================================================
24/09/2009	consw1	SFW1035  		Changed CM_ReserveTI methods to use getTI for consistency.
25/8/2010	cnwjo3	PAR25538 		removed ETRow_AllocatedItems
05/05/2014	cnwdap1	PAR #34058 		Cater for Bulk Weight and Volume
24/01/2019	jlgka1	41708			Add the following fields ETRow_BillOfLading, 
									ETRow_TotalRequestedAllowed and ETRow_BolItems
									for us to be able to have a validation of BOL
									of each container vs the release request.
27/07/2022 navtnr20 ChangeRequest 54279: EUP - Extra Fields in the Road Gate Picker Screen
14 Mar 2023 navma1  Defect 57169: MTN - Invalid property error while creating release cargo work order using MTN
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
15/11/2023  navma1	MTN - Add JMTTestEnvironment Initialisation Flag
18 Dec 2024 navbs1	Bug MTN-33650: CUX - Missing Additional Remarks pop up When Gated in Booking Item without reviewing cargo individually
//19/03/2025 navrv30 JIRA 34360 MTN - Cargo Review causing Invalid Property error to occur
20 Aug 2025	navnk30	JIRA 35619: FR [35043].011: Add "Is Hazardous" as an available email field
============================================================================*/


vars
	tmpTI 		: CM_TrackedItem;
	measure		: CM_MeasurementType;								// PAR #34058
	volume		: Decimal [22,10];									// PAR #34058
	rowName,														// PAR #34058
	type		: String;											// PAR #34058
	totalWeight : Decimal[14,0];
	ti		    : CM_TrackedItem;
	bolDtl		: CM_BOLDtl;
	allTis		: CM_TISet; 
begin
	
	if _attrName = ETRow_AllSpecialLifts											//start 27-07-2022 navtnr20 54279		
	or _attrName = ETRow_AllTIHazards
	or _attrName = ETRow_AllTiHazards
	or _attrName = ETRow_IsHazardous		//20AUG2025 navnk30 JIRA-35619
	or _attrName = ETRow_CargoGroup
	or _attrName = ETRow_ClientRef
	or _attrName = ETRow_Commodity
	or _attrName = ETRow_Destination
	or _attrName = ETRow_Diameter
	or _attrName = ETRow_DischargePort
	or _attrName = ETRow_Grade
	or _attrName = ETRow_Grammage
	or _attrName = ETRow_Height
	or _attrName = ETRow_ImexStatusString
	or _attrName = ETRow_Length
	or _attrName = ETRow_PurchaseOrder
	or _attrName = ETRow_RollingLength
	or _attrName = ETRow_ServiceOrder
	or _attrName = ETRow_SpecialStow
	or _attrName = ETRow_CargoTypeEntry 
	or _attrName = ETRow_TopID
	or _attrName = ETRow_PickerId													//17.03.2023 navma1 #57169
	or _attrName = ETRow_CargoId 		
	or _attrName = ETRow_ImexStatusString
	or _attrName = ETRow_Colour
	or _attrName = ETRow_Mark
	or _attrName = ETRow_MarkNumber 
	or _attrName = ETRow_PickerCargoRemarks1 										//18.12.2024 navbs1 #33650
	or _attrName = ETRow_PickerCargoRemarks2										//18.12.2024 navbs1 #33650
	//19/03/2025 navrv30 JIRA 34360
	or _attrName = ETRow_SortingMethod
	or _attrName = ETRow_Consignor
	or _attrName = ETRow_IMEXStatus
	or _attrName = ETRow_ImexStatus
	or _attrName = ETRow_ReceiptTransportMode
	or _attrName = ETRow_ReceivedDT
	or _attrName = ETRow_ReleasedTransportMode
	or _attrName = ETRow_Site
	or _attrName = ETRow_Vessel
	or _attrName = ETRow_TranshipDischargePort
	or _attrName = ETRow_IntendedReleaseMode
	or _attrName = ETRow_VoyageInbound
	or _attrName = ETRow_VoyageOutbound
	or _attrName = ETRow_BookingRef
	or _attrName = ETRow_Stevedore
	or _attrName = ETRow_WeightRange
	or _attrName = ETRow_ShippingLine
	or _attrName = ETRow_AllHazardClasses
	or _attrName = ETRow_AllIMDGCodes
	or _attrName = ETRow_ContainerNumberText then
		tmpTI := self.getTI();
		if tmpTI &lt;&gt; null then														//end 27-07-2022 navtnr20 54279
			return tmpTI.getDisplayStringForAttribute(_attrName, _short);
		endif;
		return null;
	elseif _attrName = ETRow_EmptyReleaseItemDescr or
		   _attrName = ETRow_Id then												//15 Mar 2017	NDL	TFS 3758
		tmpTI := self.getTI();
		if tmpTI &lt;&gt; null then
			return tmpTI.id;
		endif;
		return null;
	elseif _attrName = ETRow_IsoType then
		return null;
	elseif _attrName = ETRow_TotalWeight then												// PAR #34058
		measure := app.getDefaultMeasurementForType(Type_Weight);							// PAR #34058
		return app.convertMeasurementForDisplay(measure.shortName, self.weightRequested);	// PAR #34058
	elseif _attrName = ETRow_TotalVolume then												// PAR #34058
		tmpTI := self.getTI();
		if tmpTI &lt;&gt; null and tmpTI.getDensity &lt;&gt; null then									// PAR #34058
			measure := app.getDefaultMeasurementForType(Type_Volume);						// PAR #34058
			volume := self.weightRequested / tmpTI.getDensity;								// PAR #34058
			return app.convertMeasurementForDisplay(measure.shortName, volume);				// PAR #34058
		endif;																				// PAR #34058
		return null;																		// PAR #34058
		
	elseif _attrName = ETRow_Weight then
		create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
		self.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
		//foreach ti in self.allTrackedItems do
		foreach ti in allTis do //23/06/2023	navkc1	CR 58406 Task 58408
			totalWeight := totalWeight + ti.totalWeight;
		endforeach;
		return totalWeight.String;
		
	//jlgka1 TFS 41708 --&gt;	
	elseif _attrName = ETRow_BillOfLading or	
			_attrName = ETRow_BillOfLadingCmb then	
		if self.myBOLIn &lt;&gt; null then
			return self.myBOLIn.number;			
		endif;		
		return null;
		
	elseif _attrName = ETRow_TotalRequestedAllowed  then	
		if self.anyAmtAnyIdAllowedAmount &lt;&gt; null then
			return self.anyAmtAnyIdAllowedAmount.asStringJMT;
		endif;			
		return null;
	elseif _attrName = ETRow_BolItems  then	
		   bolDtl := self.myBOLDtl;
		if bolDtl &lt;&gt; null then
			return bolDtl.cargoTypeDescr &amp; Tab &amp; bolDtl.commodity &amp; Tab &amp; bolDtl.quantity.asStringJMT;
		endif;	
		return null;
	//jlgka1 TFS 41708 &lt;--	
	elseif _attrName = ETRow_ExtraCriteriaDisp then											//15.11.2023 navma1 #61117
		return null;
	elseif _attrName = ETRow_CargoGroup   //19/03/2025 navrv30 JIRA 34360
	or _attrName = ETRow_CargoGroupId then
		if self.myCargoGroup &lt;&gt; null then 
			return self.myCargoGroup.id;
		endif;
		return null;
	elseif _attrName.isMeasurementType then													// PAR #34058
		_attrName.getRowNameMeasureType(rowName, type);										// PAR #34058
		return self.getMeasurementStringForAttrib(rowName, type, _short);					// PAR #34058
	
	endif;

	return inheritMethod(_attrName, _short);
epilog
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFirstAvailabilityGrade" id="1da3c387-ddc7-4652-843b-6c11380e9246">
        <source>getFirstAvailabilityGrade(): CM_MTGrade;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
========================================================
09 February 2010		cnwcs5	CCMS 1925/PAR 22295 Release Summaries (Initial creation)
*/

vars
	ti	: CM_TrackedItem;
begin
	ti := self.getTI();
	
	if CM_Container.hasInstance(ti) then
		return app.myRoot.allAvailabilityGrades[ti.CM_Container.availabilityGrade];
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_MTGrade"/>
    </JadeMethod>
    <JadeMethod name="getFirstLocationByAmount" id="a57b3551-e072-40c1-befc-68edee01b60a">
        <source>getFirstLocationByAmount(_amount: Decimal output; _location: CM_LocationsController output; _request : CM_Request input);
/*
Purpose:			

Date		Who		Reason
28 December 2023	navab1	CR 58499 TASK 61455
*/

vars
	resAmt, topAmt : Decimal[23,4];
	resLC, topLC : CM_LocationsController;
	ti : CM_TrackedItem;
begin
	ti := self.allTrackedItems.first; // there is only one.
	if ti &lt;&gt; null then
		resLC := ti.myPrimaryActualLocation;
		resAmt := ti.totalQuantity;
		
		if ti.myCargoType.isBulkByQuantity then
			resAmt += ti.totalQuantity;
		else
			resAmt += ti.totalWeight;
		endif;
	
		if resAmt &gt; topAmt then
			topAmt := resAmt;
			topLC := resLC;
		endif;
		
	endif;
	
	_amount := topAmt;
	_location := topLC;

epilog

end;</source>
        <Parameter name="_amount" type="Decimal" usage="output"/>
        <Parameter name="_location" type="CM_LocationsController" usage="output"/>
        <Parameter name="_request" type="CM_Request" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getHeavyRated" id="70675ed9-772a-44fb-b6fa-9d7d92ccc31d">
