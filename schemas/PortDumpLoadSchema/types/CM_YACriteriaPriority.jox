<Class name="CM_YACriteriaPriority">
    <JadeMethod name="exportPDXMLMyReferences" id="9cd7ed44-cec9-43f4-b07c-51b9f466c73b">
        <source>exportPDXMLMyReferences(_file: File; _objArray: ObjectArray io; _property: Property; _object: Object);

vars

begin
	if _property.getName() = CM_YACriteriaPriority::myYAData.name then
		_file.writeLine("&lt;"&amp;_property.getName&amp;"&gt;");
		self.myYAData.exportPDXML(_file, _objArray, true, true);
		_file.writeLine("&lt;/"&amp;_property.getName&amp;"&gt;");
	else
		inheritMethod(_file, _objArray, _property, _object);
	endif;
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLReference" id="dbbab97f-b0e4-4edc-8eb6-c52dcc1b034a">
        <updating/>
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object updating;

vars
	objectBlock: String;
	newObj: CM_YAData;
begin
	if _name = CM_YACriteriaPriority::myYAData.name then
		objectBlock := _referencesBlock.cnEcGetTagValueOfName(_name);
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;objectBlock;
		if objectBlock.cnEcGetTagValueOfName(CM_YADataBoolean.name) &lt;&gt; null then
			create newObj as CM_YADataBoolean transient;
			newObj.importPLXML(CM_YADataBoolean.name, objectBlock);
			newObj.setPropertyValue(CM_YAData::myYAParent.name, self); 
			return newObj;
		elseif objectBlock.cnEcGetTagValueOfName(CM_YADataInteger.name) &lt;&gt; null then
			create newObj as CM_YADataInteger transient;
			newObj.importPLXML(CM_YADataInteger.name, objectBlock);
			newObj.setPropertyValue(CM_YAData::myYAParent.name, self); 
			return newObj;
		elseif objectBlock.cnEcGetTagValueOfName(CM_YADataObjects.name) &lt;&gt; null then
			create newObj as CM_YADataObjects transient;
			newObj.importPLXML(CM_YADataObjects.name, objectBlock);
			newObj.setPropertyValue(CM_YAData::myYAParent.name, self); 
			return newObj;
		endif;
	elseif _name = CM_YACriteriaPriority::myYACriteriaType.name then
		return app.myRoot.allYACriteriaTypes[_theCode.Integer];
//		return app.getMyTerminal().allYardAllocatonsByCode[_theCode];
	else
		return inheritMethod(_name, _theCode, _referencesBlock);
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</Class>
