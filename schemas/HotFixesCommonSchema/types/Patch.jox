    <JadeMethod name="addOrderedSchema" id="5c64b117-0f74-4390-868c-00a532f8f42b">
        <source>addOrderedSchema(_scm : SchemaInPatch);
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 10 June 2019
TFS#		: 41865
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	sortOrder		 : Integer;
	schemaCollection : SchemaColl;
begin
	create schemaCollection transient;	
	self.createListOfSchema(schemaCollection);	
	
	sortOrder := self.getSchemaOrder(_scm.name, schemaCollection);
	
	self.allSchemasInPatchArray.atPut(sortOrder, _scm);
epilog
	delete schemaCollection;
end;
</source>
        <Parameter name="_scm" type="SchemaInPatch"/>
    </JadeMethod>
    <JadeMethod name="createBatchAndIni" id="cc97a12d-65fa-4184-8625-497095dd760e">
        <source>createBatchAndIni(_webPatch : Boolean);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 January 2014	cnwmc5	Initial creation

*/

vars
	lastPatch 		: Patch;
	batchFile 		: File;
	iniFile			: File;
	
	version			: String;
	patchDir 		: String;
	lastPatchNo		: String;
	skipOverride	: String;
	fileShare		: String;
	tagStr			: String;
	patchNoStr		: String;
	baseFolder		: String;
begin
	if _webPatch then
		return;
	endif;
	
	version := app.myRootHotFix.releaseVersionNo;
	patchDir := self.getPatchDirectory();
	
	skipOverride := "false";
	lastPatchNo := (self.patchNo.Integer - 1).String;
	lastPatch := self.myRootHotFixes.allPatchesByReleaseNoPatchNo[lastPatchNo, version];
	if lastPatch &lt;&gt; null 
	and lastPatch.allWebsInPatch.size &gt; 0 then
		skipOverride := "true";
	endif;
	
	// TFS 38497 jlgmd1 12/10/2018 START
	if self.tag &lt;&gt; null then
		tagStr := "_" &amp; self.tag;
	endif;
	
	if self.isTFSPatch then
		//patchType := "TFS";	// combine this with the parNo instead
		if self.parNo[1:1] = app.myRootHotFix.TFS_NUMBER_MASK then
			patchNoStr := "TFS" &amp; self.parNo[2:end];
		else
			patchNoStr := "TFS" &amp; self.parNo;
		endif;
	else
		//patchType := "Par";	// combine this with the parNo instead
		patchNoStr := "Par" &amp; self.parNo;
	endif;
	// TFS 38497 jlgmd1 12/10/2018 END

	create batchFile transient;
	create iniFile transient;
	
	batchFile.mode := File.Mode_Output; // 3/3/16  cnwns1 PAR 36286 unicode version
	iniFile.mode   := File.Mode_Output; // 3/3/16  cnwns1 PAR 36286 unicode version
	
	
	// Batch file 
	fileShare := app.myRootHotFix.DIR_FILE_SHARE;		// TFS 38497 jlgmd1 12/10/2018
	batchFile.fileName		:= patchDir &amp; "autoinstall.bat";
	batchFile.open;
	
	//batchFile.writeLine("Powershell.exe -executionpolicy remotesigned -File C:\AutoPatchInstall\MasterInstaller.ps1 " &amp; version &amp; " " &amp; self.patchNo &amp; " " &amp; self.parNo &amp; " false");
	batchFile.writeLine("pwsh.exe -executionpolicy bypass -File " &amp; fileShare &amp; "\Releases\Utilities\RemoteInstaller\RemotePatchAccess.ps1 " &amp; version &amp; " " &amp; self.patchNo &amp; " " &amp; patchNoStr &amp; " " &amp; skipOverride);
	batchFile.writeLine("pause");
	batchFile.writeLine("if exist " &amp; fileShare &amp; "\Releases\Utilities\RemoteInstaller\temp\JAPInstall.log notepad " &amp; fileShare &amp; "\Releases\Utilities\RemoteInstaller\temp\JAPInstall.log");
	//batchFile.writeLine("if exist " &amp; fileShare &amp; "\Releases\Utilities\RemoteInstaller\temp\JAPInstallLoader.log notepad " &amp; fileShare &amp; "\Releases\Utilities\RemoteInstaller\temp\JAPInstallLoader.log");
	batchFile.writeLine("pause");
	
	batchFile.commit;
	batchFile.close;
	
	// INI file
	iniFile.fileName		:= patchDir &amp; "JMTSetup.ini";
	iniFile.open;
	
	if self.readme_parTopic.cnContains("Priority A") then
		baseFolder := RootHotFixes.DIR_HOTFIXES_NAME;
	else
		baseFolder := RootHotFixes.DIR_PATCHES_NAME;
	endif;
	
	iniFile.writeLine("[JadeDB]");
	iniFile.writeLine("ini=e:\JMT" &amp; version &amp; "DevEnc\JMT" &amp; version &amp; "DevEnc.ini");
	iniFile.writeLine("path=e:\JMT" &amp; version &amp; "DevEnc\c_system");
	iniFile.writeLine("bin=e:\JMT" &amp; version &amp; "DevEnc\c_bin");
	iniFile.writeLine("");
	iniFile.writeLine("[Install]");
	//iniFile.writeLine("install=\\cnwchcm24\cnwpod$\Releases\" &amp; version &amp; "\Hotfixes-pending\" &amp; self.patchNo &amp; "_Par" &amp; self.parNo &amp; "\" &amp; self.patchNo);
	iniFile.writeLine("install=" &amp; fileShare &amp; "\Releases\" &amp; version &amp; "\" &amp; baseFolder &amp; "\" &amp; self.patchNo &amp; "_" &amp; patchNoStr &amp; tagStr &amp; "\" &amp; self.patchNo);		// TFS 38497 jlgmd1 12/10/2018
	iniFile.writeLine("replayableReorg=true");
	iniFile.writeLine("server=singleUser");
	
	batchFile.commit;
	batchFile.close;

epilog
	delete batchFile;
	delete iniFile;
end;</source>
        <Parameter name="_webPatch" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createFilesForPatch" id="6ca56110-9cbf-4914-a6ec-fc5239f9eb4c">
        <source>createFilesForPatch( _patchNo: String; _isSingleUser : Boolean; _isThinClient : Boolean; _webPatch: Boolean ) : Boolean;
// created by cnwvu1 on 11/03/2007
/* Changes

Date		Name	TFS#		Description
============================================================================
22 Mar 2010	cnwkpd1				Allow for Thin client patch creation
13 Jul 2017 cnwma1	TFS #4847	JMT - Change to HotFixesCommonSchema PatchCreateApp
05 Jun 2019	jlgka1	41865		JMT - Add Prefix in the filename based on the Schema Order.
28 Aug 2019 jlgmd1				Bail early if we hit an error
============================================================================*/

vars
	fC				: File;
	extrFile		: File;
	fLiveAppUpgrade  : File;   //13.07.2017 cnwma1 TFS #4847
	scm				: SchemaInPatch;
	web				: WebInPatch;
	pErrTxt 		: String;
	strResult 		: String;
	res				: Integer;
	failedExtract 	: Boolean;
	
	serverFile		: File;
	
	//cnwmc5 - 14 Jan 2014 - PAR 32864
	rptView			: ReportViewInPatch;
	rpt				: ReportInPatch;
	patchDirJade,
	patchDirClient 	: String;
	appl			: AppInSchema;
	//jlgka1 TFS 41865 --&gt;	
	sortOrder		: Integer;
	strSortOrder	: String;
	//jlgka1 TFS 41865 &lt;--
begin
	if _webPatch then
		foreach web in self.allWebsInPatch do
			app.writeLogMessage(' Copying web files: ' &amp; web.display );		
			if not web.copy() then
				return false;
			endif;
		endforeach;
	else
		create fC transient;
		create extrFile transient;
		create fLiveAppUpgrade transient;  // TFS 13.07.2017 #4847 cnwma1
		fC.mode := File.Mode_Output; // 3/3/16  cnwns1 PAR 36286 unicode version
		
		//cnwmc5 - 14 Jan 2014 - PAR 32864
		patchDirJade := self.getPatchDirJademasterSchemas();
		patchDirClient := self.getPatchDirClientSchemas();
		
		fC.fileName		:= self.getFileJMTInstall( _patchNo, false );
		fC.open;
		
		if _isSingleUser then
			fC.writeLine( app.myRootHotFix.JMT_INSTALL_STR_FIRST_SNGLUSER );
		else
			fC.writeLine( app.myRootHotFix.JMT_INSTALL_STR_FIRST );
		endif;
	
		// ----------------------------------------------------------------
		//                  creating UNL for each schema          
		// ----------------------------------------------------------------
		app.writeLogMessage(' Creating files UNL:');
		failedExtract := false;
		foreach scm in self.allSchemasInPatchArray do
			
			// Bail early if we encounter an error
			if failedExtract then
				break;
			endif;
			
			if scm &lt;&gt; null then // jlgka1 TFS 41865
				//jlgka1 TFS 41865 --&gt;
				sortOrder := sortOrder + 1;
				if sortOrder &gt; 9 then
					strSortOrder := (sortOrder * 10).String;
				else
					strSortOrder := "0" &amp; (sortOrder * 10).String;
				endif;
				//jlgka1 TFS 41865 &lt;--
				
				fC.writeString( app.myRootHotFix.JMT_INSTALL_STR_BEGIN );
				if self.extractOptionDDB then
					fC.writeString( app.myRootHotFix.JMT_INSTALL_STR_BEGIN_DDB );
				endif;
				fC.writeString( app.myRootHotFix.JMT_INSTALL_STR_SP &amp; strSortOrder &amp; scm.name &amp;'_'&amp; app.myRootHotFix.releaseVersionNo &amp;'_'&amp; self.patchNo ); //jlgka1 TFS 41865
				
				//cnwmc5 - 29 Nov 2013 - PAR 33105
				if scm.errorsOk then
					fC.writeLine( app.myRootHotFix.JMT_INSTALL_STR_END_ERRORSOK );
				else
					fC.writeLine( app.myRootHotFix.JMT_INSTALL_STR_END );
				endif;
		
				// UNL file for each schema
				scm.writeClassesToFileUNL( fC, strSortOrder ); //jlgka1 TFS 41865
				
				if not scm.extractMethodsByUNL( scm.DO_EXTRACT_BY_UNL_FILE, 
						scm.getFileNameUNL(strSortOrder), //jlgka1 TFS 41865
						scm.name,
						strSortOrder &amp; scm.name &amp;'_'&amp; app.myRootHotFix.releaseVersionNo &amp;'_'&amp; self.patchNo,	//schemaName //jlgka1 TFS 41865
						patchDirJade, 							//cnwmc5 - 14 Jan 2014 - PAR 32864
						patchDirClient,	//extractDirEncrypted		//cnwmc5 - 14 Jan 2014 - PAR 32864
						_isThinClient,
						strResult ) 
				then
					failedExtract := true;
				endif;
		
				// Check whether extracted schemas exist
				// JadeMaster
				extrFile.fileName:= patchDirJade &amp; strSortOrder &amp; scm.name &amp;'_'&amp; app.myRootHotFix.releaseVersionNo &amp;'_'&amp; self.patchNo &amp; '.scm';		//cnwmc5 - 14 Jan 2014 - PAR 32864 //jlgka1 TFS 41865
				if not extrFile.isAvailable() then
					failedExtract := true;
				endif;
				// Cient
				extrFile.fileName:= patchDirClient &amp; strSortOrder &amp; scm.name &amp;'_'&amp; app.myRootHotFix.releaseVersionNo &amp;'_'&amp; self.patchNo &amp; '.scm';		//cnwmc5 - 14 Jan 2014 - PAR 32864 //jlgka1 TFS 41865
				if  not extrFile.isAvailable() then
					failedExtract := true;
				endif;
		
				// delete *.ddb file, if the DDB option is not ticked
				if not self.extractOptionDDB then
					// JadeMaster
					extrFile.fileName:= patchDirJade &amp; strSortOrder &amp; scm.name &amp;'_'&amp; app.myRootHotFix.releaseVersionNo &amp;'_'&amp; self.patchNo &amp; '.' &amp; scm.EXTRACT_FILE_TYPE_DDB;		//cnwmc5 - 14 Jan 2014 - PAR 32864 //jlgka1 TFS 41865
					if extrFile.isAvailable() then
						extrFile.purge();
					endif;
					// Client
					extrFile.fileName:= patchDirClient &amp; strSortOrder &amp; scm.name &amp;'_'&amp; app.myRootHotFix.releaseVersionNo &amp;'_'&amp; self.patchNo &amp; '.' &amp; scm.EXTRACT_FILE_TYPE_DDB;		//cnwmc5 - 14 Jan 2014 - PAR 32864 //jlgka1 TFS 41865
					if extrFile.isAvailable() then
						extrFile.purge();
					endif;
				endif;
			endif;	// jlgka1 TFS 41865
		endforeach;
		
		//cnwmc5 - 14 Jan 2014 - PAR 32864 - must do Report Views before Reports, just incase the new Reports are dependant on the views..
		foreach rptView in self.allReportViewsInPatch do
			
			// Bail early if we encounter an error
			if failedExtract then
				break;
			endif;
			
			fC.writeLine(app.myRootHotFix.REPORT_VIEW_BEGIN &amp; rptView.getNameWithDetails() &amp; app.myRootHotFix.JMT_INSTALL_STR_END);
			
			
			rptView.extractReportView(patchDirJade, patchDirClient);
			
			// Check whether extracted report views exist
			// JadeMaster
			extrFile.fileName:= patchDirJade &amp; rptView.getNameWithDetails() &amp; '.rwv';
			if not extrFile.isAvailable() then
				failedExtract := true;
			endif;
			// Cient
			extrFile.fileName:= patchDirClient &amp; rptView.getNameWithDetails() &amp; '.rwv';
			if  not extrFile.isAvailable() then
				failedExtract := true;
			endif;
		endforeach;
		
		//cnwmc5 - 14 Jan 2014 - PAR 32864
		foreach rpt in self.allReportsInPatch do
			// Bail early if we encounter an error
			if failedExtract then
				break;
			endif;
		
			fC.writeLine(app.myRootHotFix.REPORT_BEGIN &amp; rpt.getNameWithDetails() &amp; app.myRootHotFix.JMT_INSTALL_STR_END);
			
			rpt.extractReport(patchDirJade, patchDirClient);
			
			// Check whether extracted report views exist
			// JadeMaster
			extrFile.fileName:= patchDirJade &amp; rpt.getNameWithDetails() &amp; '.rwr';
			if not extrFile.isAvailable() then
				failedExtract := true;
			endif;
			// Cient
			extrFile.fileName:= patchDirClient &amp; rpt.getNameWithDetails() &amp; '.rwr';
			if  not extrFile.isAvailable() then
				failedExtract := true;
			endif;
		endforeach;
		
		if scm.DO_EXTRACT_BY_UNL_FILE and failedExtract then
			//app.msgBox('Failed to extract schemas. Please extract manually. Check your JADE configuration, more details in Jade Interpeter output.', self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);	//trx state, can't show msgBoxes
			app.writeLogMessage('');
			app.writeLogMessage(' Failed to extract schemas... The problem can be:');
			app.writeLogMessage(' Your UNL file'); 
			app.writeLogMessage(' INI file - [JadeClient] ServerNodeSpecifications=...'); 
			app.writeLogMessage(' Try to renew files in your BIN directory');
			app.writeLogMessage('');
			return false;
		endif;
		
		//cnwmc5 - 27 Jan 2014 - PAR 32864
		fC.writeLine( RootHotFixes.JMT_INSTALL_SCMCHK );
		foreach scm in self.allSchemasInPatchArray do
			if scm &lt;&gt; null then // jlgka1 TFS 41865
				if not scm.allAppsInSchema.isEmpty then    //13.07.2017 cnwma1 TFS #4847;
					appl := scm.allAppsInSchema[SchemaInPatch.JMT_RELEASE,scm.name,scm.myPatch.parNo]; 
					if appl &lt;&gt; null then
						fC.writeLine(RootHotFixes.JMT_INSTALL_STR_JMTMAJOR &amp; app.myRootHotFix.releaseVersionNo &amp; RootHotFixes.JMT_INSTALL_STR_SP &amp; RootHotFixes.JMT_INSTALL_STR_NOERRORS); //13.07.2017 cnwma1 TFS #4847;
						// 13.07.2017 cnwma1 TFS #4847
						// --------------------------------------------------------------
						//                   live_app_upgrade.bat        
						// --------------------------------------------------------------
						
						self.writeToFileLiveAppUpgrade();
						
					endif;
				endif;
			endif; // jlgka1 TFS 41865
		endforeach;
		fC.writeLine( RootHotFixes.JMT_INSTALL_STR_LAST );
	
		// --------------------------------------------------------------
		//                   copying JMTInstall.txt          
		// --------------------------------------------------------------
		fC.commit;
		fC.close;
		app.writeLogMessage(' Creating install file:');
		app.writeLogMessage(' Created ' &amp; fC.fileName);
	
		if app.myRootHotFix.ZJade_Local_Mode_For_File_Copy then
			if not fC.cnCopyFile( self.getFileJMTInstall( _patchNo, true ), true, pErrTxt) then
				return false;
			endif;
		else
			if not app.myRootHotFix.copyFile( fC.fileName, self.getPatchDirectoryJademaster(), true ) then
				return false;
			endif;
		endif;
	
		app.writeLogMessage(' Copied  ' &amp; self.getFileJMTInstall( _patchNo, true ));
	endif;
	// --------------------------------------------------------------
	//                   creating readme.txt          
	// --------------------------------------------------------------
	self.writeToFileReadme( self.readme_parTopic, self.readme_parDescription, self.readme_closeDetail, self.readme_areasAffected );
	
	//cnwmc5 - 27 Jan 2014 - PAR 32864
	app.writeLogMessage(' Creating batch and ini files...');
	self.createBatchAndIni(_webPatch);
	app.writeLogMessage(' Created batch and ini.');
	
	return true;
	
epilog
	delete fC;
	delete extrFile;
	delete fLiveAppUpgrade;
end;
</source>
        <Parameter name="_patchNo" type="String"/>
        <Parameter name="_isSingleUser" type="Boolean"/>
        <Parameter name="_isThinClient" type="Boolean"/>
        <Parameter name="_webPatch" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createListOfSchema" id="fd2398d9-e498-45ed-bad0-4415468ea0d8">
        <source>createListOfSchema(schemaCollection : SchemaColl io);
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 05 June 2019
TFS#		: 41865
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars	
	schema 	: Schema;	
begin	
	schema := rootSchema.getSchema("PortSchema");	
	schemaCollection.add(schema);
	schema.allSubschemas(schemaCollection);
end;
</source>
        <Parameter name="schemaCollection" type="SchemaColl" usage="io"/>
    </JadeMethod>
    <JadeMethod name="createMySchema" id="fc848837-099a-48bf-83ab-0b74ee3f4418">
        <source>createMySchema( _name : String );
// created by cnwvu1 on 10/03/2007

vars
	sch : SchemaInPatch;
	
begin

	beginTransaction;
	create sch;
	sch.setForCreate( _name, self );
	commitTransaction;
	

end;
</source>
        <Parameter name="_name" type="String"/>
    </JadeMethod>
    <JadeMethod name="deletePatch" id="96f1c58b-c61b-47a6-ac33-8f617cacec25">
        <updating/>
        <source>deletePatch( deleteFull : Boolean ) updating;
/*--------------------------------------------------------------------
Created:	11 April 2007 By cnwvu1
Purpose:	deletes either patch or its children only: schemas, classes and methods
Parameter:	deleteFull = true - deletes the patch itself.
----------------------------------------------------------------------
*/

vars
	scm	: SchemaInPatch;
	cls	: ClassInSchema;
	mtd	: MethodInClass;
	appl: AppInSchema;
	rpt		: ReportInPatch;
	rptView : ReportViewInPatch;
	
begin

	foreach scm in self.allSchemasInPatch do
		foreach cls in scm.allClassesInSchema do
			foreach mtd in cls.allMethodsInClass do
				delete mtd;
			endforeach;
			delete cls;
		endforeach;
		foreach appl in scm.allAppsInSchema do
			delete appl;
		endforeach;
		self.allSchemasInPatchArray.remove(scm);	// jlgmd1 28/08/2019 missed from TFS 41865
		delete scm;
	endforeach;
	//cnwmc5 - 15 Jan 2014 - PAR 32864
	foreach rpt in self.allReportsInPatch do
		delete rpt;
	endforeach;
	//cnwmc5 - 15 Jan 2014 - PAR 32864
	foreach rptView in self.allReportViewsInPatch do
		delete rptView;
	endforeach;
	if deleteFull then
		delete self;
	endif;
	
end;
</source>
        <Parameter name="deleteFull" type="Boolean"/>
    </JadeMethod>
