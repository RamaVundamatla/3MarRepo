    <JadeMethod name="doMnuZoomClick" id="15a1bbdc-e26f-4abb-853a-5ff315abf0a8">
        <updating/>
        <source>doMnuZoomClick(theMenuItem : MenuItem) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
