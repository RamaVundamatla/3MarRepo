    <JadeMethod name="getColour" id="47a77d51-602b-4df5-b9f1-29e3b176b954">
        <source>getColour():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
9/10/2013	cnwjre1		Initial creation PAR #32751 additional reporting fields
*/

vars

	colour : String;
	
begin

	if self.myTrackedItem &lt;&gt; null then
		colour := self.myTrackedItem.getColour();
	elseif self.myBookingRef &lt;&gt; null then
		colour := null;
	elseif self.myBOL &lt;&gt; null then
		colour := null;
	elseif self.myGateReceival &lt;&gt; null then
		colour := self.myGateReceival.colour;
	elseif self.myGateReceivalByType &lt;&gt; null then
		colour := null;
	endif;
	
	return app.getErrorString(Colour) &amp; "  =  " &amp; colour;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCommodity" id="8ed27938-72f2-4ac3-9bf9-e4c332949b86">
        <source>getCommodity() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 January 2010	cnwndl1	Initial creation	CCMS MES 1004

*/

vars

	commodityCode : String;
	commodity : CM_Commodity;
	commodityDesc : String;
	
begin

	if self.myTrackedItem &lt;&gt; null then
		commodityCode := self.myTrackedItem.commodity;
	elseif self.myBookingRef &lt;&gt; null then
		commodityCode := self.myBookingRef.commodity;
	elseif self.myBOL &lt;&gt; null then
		// no commodity on a BOL.
	elseif self.myGateReceival &lt;&gt; null then
		commodityCode := self.myGateReceival.commodity;
	elseif self.myGateReceivalByType &lt;&gt; null then	// 10/12/2010 cnwmh5 #26556
		commodityCode := self.myGateReceivalByType.myReceivalInfo.commodity;
	endif;
	
	if commodityCode &lt;&gt; null then
		commodity := app.myRoot.allCommodities[commodityCode];
		if commodity &lt;&gt; null then
			commodityDesc := commodity.description;
			if commodityDesc &lt;&gt; null then
				return app.getErrorString(CM_Commodity_GC) &amp; " =  " &amp;commodityDesc;
			endif;
		endif;
	else
		commodityCode := " ";
	endif;
	
	return app.getErrorString(CM_Commodity_GC) &amp; " =  " &amp; commodityCode;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
