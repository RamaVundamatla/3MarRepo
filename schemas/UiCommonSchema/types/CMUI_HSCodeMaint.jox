    <JadeMethod name="cmbHeadingBuild" id="e6694934-3149-41a3-abd5-73c36466fe62">
        <source>cmbHeadingBuild();
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
08 December 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars
	obj : Object;
	chapter : CM_HSCodeChapter;
	heading : CM_HSCodeHeading;
	idx : Integer;
	str : String;
	iter : Iterator;
	section : CM_HSCodeSection;
begin
	self.cmbHeading.clear;
	self.cmbHeading.sorted := false;
	self.cmbHeading.addItem(app.getErrorString(All_Headings));
	self.cmbHeading.itemObject[self.cmbHeading.newIndex] := null;
	self.cmbHeading.listIndex := 1;
	
	obj := self.cmbChapter.listObject;
	
	if obj = null or not obj.isKindOf(CM_HSCodeChapter) then
		iter:=app.myRoot.allHSHeadings.createIterator;
		section:=self.cmbSection.listObject.CM_HSCodeSection;
	else
		chapter := obj.CM_HSCodeChapter;
		iter:=chapter.allHSCodeHeadings.createIterator;
	endif;
	
	while iter.next(heading) do
		if section &lt;&gt; null and heading.getMySection &lt;&gt; section then
			continue;
		endif;
		idx := self.cmbHeading.addItem(heading.getDisplayString);
		self.cmbHeading.itemObject[idx] := heading;
	endwhile;
	
	self.cmbHeading.listIndex := 1;
	
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="cmbSectionBuild" id="02e7bc0c-a5c7-405a-aeca-ddea6d6e63f7">
        <source>cmbSectionBuild();
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
08 December 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars
	section : CM_HSCodeSection;
	idx : Integer;
	str : String;
	
begin
	self.cmbSection.clear;
	self.cmbSection.sorted := false;
	self.cmbSection.addItem(app.getErrorString(All_Sections));
	self.cmbSection.itemObject[self.cmbSection.newIndex] := null;
	self.cmbSection.listIndex := 1;
	
	foreach section in app.myRoot.allHSSections do
		idx := self.cmbSection.addItem(section.getDisplayString);
		self.cmbSection.itemObject[idx] := section;
	endforeach;
	
	self.cmbSection.listIndex := 1;
	
epilog

end;</source>
    </JadeMethod>
