    <JadeMethod name="setMyReserveDetail" id="83fefefe-6d2f-492e-be09-3c7048a744ea">
        <updating/>
        <source>setMyReserveDetail(_rd : CM_ReserveDetail) updating;
// --------------------------------------------------------------------------------
// Created:		23 February 2009 by cnwjo3
//
// Purpose:		set the current myReserveDetails to be used on form
//
// Parameters:	
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
