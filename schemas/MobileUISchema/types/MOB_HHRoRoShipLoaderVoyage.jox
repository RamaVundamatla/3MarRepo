    <JadeMethod name="doResizeControls" id="b37a1735-faf9-4fe5-b0d6-33ede598c420">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	voyage : CM_Voyage;
	stdHeight : Real;

begin

	self.setResizeableMarginAndFontSize();
	stdHeight := self.getStdControlHeight;

	if _initialSetup then
		self.cmbVoyage.visible := true;
	endif;
	self.cmbVoyage.move( self.resizedMargin,
						 self.resizedMargin,
						 self.clientWidth - self.resizedMargin - self.resizedMargin,
						 stdHeight );
	
	if _initialSetup then
		self.populateVoyages();
	
		self.cmbArea.visible := true;
	endif;
	self.cmbArea.move( self.resizedMargin,
						 self.resizedMargin + self.cmbVoyage.height + self.cmbVoyage.top,
						 self.clientWidth - self.resizedMargin - self.resizedMargin,
						 stdHeight );
						 
						 
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="924c6176-82da-4fba-a913-947f91a627fb">
        <updating/>
        <source>handleBtnOne() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 July 2010	cnwndl1	Initial creation	CCMS MES 1077

*/

vars

	voyage : CM_Voyage;
	area : CM_CraneTransferArea;
	errMess : String;
	
begin
	// user clicked 'Next'
	
	voyage := cmbVoyage.listObject.CM_Voyage;
	if voyage = null then
		self.msgBox(app.getErrorString(PleaseSelectAVoyage) ,app.getErrorString(Error), MsgBox_OK_Only, true);
		return;
	endif;
	
	area := cmbArea.listObject.CM_CraneTransferArea;
	if area = null then
		self.msgBox(app.getErrorString(YoMustSelectATerminalArea) ,app.getErrorString(Error), MsgBox_OK_Only, true);
		return;
	endif;
	
	self.myMobileGenericAgent.setMyVoyage(voyage);
	self.myMobileGenericAgent.setMyCraneTransferArea(area);

	self.gotoForm( MOB_HHRoRoShipLoaderCargo, false );
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
