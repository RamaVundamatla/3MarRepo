    <JadeMethod name="zJMT_To_CICS_Events" id="0938bdae-8ae1-4df7-b29e-e873f32cca2f">
        <source>zJMT_To_CICS_Events(_protocol :String; _camGroup :CM_CamGroup; _start, _end :TimeStamp)protected;
/*
Date		Who		Reason
18 June 2012	cnwcs5	Initial creation - par 
*/
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
constants
	PREFIX 		= 'EV';
	JRWREPORT	= 'CM_TrainConsistOutward';
vars
	desc		:CM_CamProtocolDesc;
	eventColl	:CM_EventTypeByNameDict;
	filter		:CMQF_CamTransactionTemplate;
	protocol	:CM_CamProtocol;
	theLines : HugeStringArray;
	tempStr : String;
	runDateTime : TimeStamp;
	str : String;
	idx : Integer;
begin
	create theLines transient;
	self.deleteCamProtocol (_protocol);
	
	desc 	:= CM_CamUserDefRepEventDesc.firstInstance;
		
	create eventColl transient;
	
	eventColl.add (app.myRoot.allEventTypesByType [EVT_TrainArrive]);
	
	protocol := self.createCamProtocolEvent (_protocol, _camGroup, desc, PREFIX, JRWREPORT, eventColl);
	
	self.assertNotNullMsg (protocol, _protocol &amp; ' - CAM protocol not created');
	self.assertEqual (protocol.jrwReportName, JRWREPORT);
	self.assertEqual (protocol.allTrainEventTypes.size, 1);
	
	self.runCamsAdhoc (_start, _end, runDateTime, protocol);
	
	self.assertNotNullMsg (protocol.taskHistoryByProtocolSeq.last, protocol.code &amp; ' No history');
	protocol.taskHistoryByProtocolSeq.last.rawDataToHSA(theLines);
	self.assertNotEqualMsg(theLines.size, 0, protocol.code &amp; ' No history');
	
	foreach tempStr in theLines do
		idx := idx + 1;
//		char := tempStr[1:1].Character;
		str := tempStr[1:1].asHex;
		if tempStr.length &gt; 2 and
		   str = "FE" then
		   theLines[idx] := theLines[idx][2:end];
		endif;
	endforeach;
	// expect MT releases by road/rail - must have consignee, have no booking
	// visit number impossible to match so replace with a constant
	self.zReplaceFieldsDelim(theLines, 3, '&lt;date&gt;', ';', 'TRAIN', 0);
	
app.writeLog("jlirs1 "&amp;class.name&amp;'::'&amp;method.name&amp;' '&amp;self.String, 0);	
	self.zCheckOutput(protocol, theLines, self.zCICSEvents_output);
epilog
	delete eventColl;
//	delete output;
	delete theLines;
end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="String"/>
        <Parameter name="_camGroup" type="CM_CamGroup"/>
        <Parameter name="_start" type="TimeStamp"/>
        <Parameter name="_end" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="zReplaceFields" id="7dd85336-e7af-4306-8e59-aa0faf4575df">
        <source>zReplaceFields(_input :HugeStringArray input; _num :Integer; _token :String) :String;// protected;
/*
Date		Who		Reason
06 June 2012	cnwcs5	Initial creation - just so we don't have to do exact match on dates
*/
vars
	tokens				:HugeStringArray;
	temp, result, str	:String;
	int	, count			:Integer;
	heading				:Boolean;
begin
	// compare with what we expect
	create tokens transient;
			
	heading := true;
	
	foreach str in _input do
		count := count + 1;
		
		if heading then
			heading	:= false;
			continue;
		endif;
		
		temp := null;
		
		tokens.clear;
		
		//str.getTokensForDelimiter (',', tokens);
		str.getHugeTokensForDelimiter(",", tokens);
		
		foreach int in 1 to tokens.size do
			if int = _num then
				if int = 1 then
					temp := _token;
				else
					temp := temp &amp; ',' &amp; _token;
				endif;
			else
				if int = 1 then
					temp := tokens[int];
				else
					temp := temp &amp; ',' &amp; tokens[int];
				endif;
			endif;
		endforeach;
		
		_input[count] := temp;
	endforeach;
	
	return result;
epilog
	delete tokens;
end;</source>
        <Parameter name="_input" type="HugeStringArray" usage="input"/>
        <Parameter name="_num" type="Integer"/>
        <Parameter name="_token" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="zReplaceFieldsDelim" id="53b78c14-a000-4ccc-b983-39e487b46960">
        <source>zReplaceFieldsDelim(_input :HugeStringArray input; _num :Integer; _token :String; _delimiter : Character; _header : String; _skipLines : Integer) :String;// protected;
/*
Date		Who		Reason
06 June 2012	cnwcs5	Initial creation - just so we don't have to do exact match on dates
*/
vars
	tokens				:HugeStringArray;
	temp, result, str	:String;
	int	, count			:Integer;
//	heading				:Boolean;
begin
	// compare with what we expect
	create tokens transient;
			
//	heading := true;
	
	foreach str in _input do
		count := count + 1;
		if not (count &gt; _skipLines) then
			continue;
		endif;
//		if heading then
//			heading	:= false;
//			continue;
//		endif;
		
		temp := null;
		
		tokens.clear;
		
		//str.getTokensForDelimiter (',', tokens);
		str.getHugeTokensForDelimiter(_delimiter, tokens);
		if _header &lt;&gt; null then
			if tokens[1] &lt;&gt; _header then
				continue;
			endif;
		endif;
		
		foreach int in 1 to tokens.size do
			if int = _num then
				if int = 1 then
					temp := _token;
				else
					temp := temp &amp; _delimiter &amp; _token;
				endif;
			else
				if int = 1 then
					temp := tokens[int];
				else
					temp := temp &amp; _delimiter &amp; tokens[int];
				endif;
			endif;
		endforeach;
		
		_input[count] := temp;
	endforeach;
	
	return result;
epilog
	delete tokens;
end;</source>
        <Parameter name="_input" type="HugeStringArray" usage="input"/>
        <Parameter name="_num" type="Integer"/>
        <Parameter name="_token" type="String"/>
        <Parameter name="_delimiter" type="Character"/>
        <Parameter name="_header" type="String"/>
        <Parameter name="_skipLines" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
