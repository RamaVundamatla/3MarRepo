    <JadeMethod name="createCargoOnSitePrenote" id="f0efc0a5-a33a-414d-926c-a14973c77228">
        <updating/>
        <source>createCargoOnSitePrenote() updating;
/*
Purpose:			
Date		Who		Reason
20 October 2011	NAVAB1	Initial creation
27 Jul 2022 navsj20 TFS 53862	EUP - WMS - Damage Recording Extra Details*/

vars
	aPort : CM_Port;
	voy : CM_Voyage;
	op : CM_Operator;

	booking: CM_BookingRef;
	ti: CM_TrackedItem;
	aStop : CM_StopsTable;
	ct : CM_CargoType;
	didRemove : Boolean;
	bookingOversubscribe : Boolean;
	criteria, criteriaCargoType: CM_YACriteria;
	
begin

	self.setTerminalConfig(BookingOversubscribe, true);
	
	voy := self.getVoyage("UTBISH1");

	aPort := app.myRoot.allPorts["NZAKL"];
	op := app.myRoot.allOperators["UTOP"];

	deleteContainer("UTPN8899001");
	deleteContainer("UTPN8899002");
	deleteContainer("UTPN8899003");
	deleteContainer("UTPN8899004");
	self.deleteBooking("UT_PNBOOKING");
	
	booking := self.addBookingForContainer("UT_PNBOOKING", op, voy, "NZAKL", "2200", "GENL");
	assertNotNull(booking);
	
	ct := app.myRoot.allCargoTypesById[TI_CargoType_Container];
	aStop := app.myRoot.allStopsTable[TI_Stop_CustomsDocs];
	
	if aStop.myStopCriteria &lt;&gt; null then   																						// 27 Jul 2022 navsj20 TFS 53862
		foreach criteria in aStop.myStopCriteria.allCriteria where criteria.myYACriteriaType.type = YACriteriaType_CargoType do	// 27 Jul 2022 navsj20 TFS 53862
			//	if aStop.allCargoTypesNew.includes(ct) then
			if criteria.myYAData.CM_YADataObjects.allObjects.includes(ct) then													// 27 Jul 2022 navsj20 TFS 53862
				beginTransaction;
				//aStop.allCargoTypesNew.remove(ct); 																			// 27 Jul 2022 navsj20 TFS 53862
				criteria.myYAData.CM_YADataObjects.allObjects.remove(ct);														
				commitTransaction;
				didRemove := true;
			endif;
		endforeach;																												// 27 Jul 2022 navsj20 TFS 53862
	endif;
	
	ti := self.addPrenotedContainer(booking.allBookingRefItems.first,  "UTPN8899001");
	ti := self.addPrenotedContainer(booking.allBookingRefItems.first,  "UTPN8899002");
	ti := self.addPrenotedContainer(booking.allBookingRefItems.first,  "UTPN8899003");
	ti := self.addPrenotedContainer(booking.allBookingRefItems.first,  "UTPN8899004");
	assertNotNull(ti );
	
epilog

	// moved to correct spot
	if didRemove then
		beginTransaction;
		// START 03 Aug 2022 navsj20 TFS 53862
		//aStop.allCargoTypesNew.add(ct);
		if aStop.myStopCriteria &lt;&gt; null then
			foreach criteria in aStop.myStopCriteria.allCriteria where criteria.myYACriteriaType.type = YACriteriaType_CargoType do
				criteria.myYAData.CM_YADataObjects.allObjects.add(ct);
			endforeach;
		endif;
		// END 03 Aug 2022 navsj20 TFS 53862
		commitTransaction;
	endif;

end;</source>
    </JadeMethod>
