    <JadeMethod name="getLastDetailOfType" id="16061e51-10ce-4c24-a723-9cc385133fca">
        <source>getLastDetailOfType(_type : Integer) : CM_VehicleVisitRecordDetail;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
15 October 2024		jlizm1	Initial creation fixing failing unit test

*/

vars
	detail	: CM_VehicleVisitRecordDetail;
	
begin
	foreach detail in self.allVehicleVisitRecordDetails reversed do
