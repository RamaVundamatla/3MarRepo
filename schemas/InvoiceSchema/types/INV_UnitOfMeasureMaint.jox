    <JadeMethod name="doCmbTypeBuild" id="a37279db-a1f9-4e1c-8511-ba85dc1115ca">
        <source>doCmbTypeBuild(_type : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who			Reason
13 Feb 2023		navvt20		TFS CR 56132 Task 56399: UI - UOM Maintenance - Type

*/

vars
	cmb : CMUI_ComboBox;
	idx : Integer;
begin
	cmb := self.cmbType;
	cmb.clear;
	
	cmb.addItemAt(Invoice_UOM_Type_WeightStr,1);
	cmb.addItemAt(Invoice_UOM_Type_VolumeStr,2);
	cmb.addItemAt(Invoice_UOM_Type_QuantityStr,3);
	cmb.addItemAt(Invoice_UOM_Type_TEUStr,4);
	
	cmb.listIndex := cmb.findString(1,app.getUOMInttoStr(_type));
epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doDelete" id="71dae5df-4347-460a-97fe-6d8ef32931bc">
        <updating/>
        <source>doDelete(): Boolean updating;
// ---------------------------------------------------------------------------
// Date			Who			Reason
// 20 Dec 2022	navvt20		TFS CR 55621 Task 55695: UI - UOM Maint
// ---------------------------------------------------------------------------

vars
	theReturn : Integer;
begin
 
	while true do
 	app.myTrxDA.trxDeleteInvoiceUnitOfMeasure(self.myCurrentObject.CM_InvoiceUnitOfMeasure, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			return true;
		else
			theReturn := app.showErrorWarningDialog("Invoice Unit Of Measure", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
		endif;
		break;
	endwhile;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="28033e15-9012-4b10-96b1-67019a8f8210">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// 
//
// Date				Who		Reason
// 13 December 2022	navvt20	TFS CR 55621 Task 55695: UI - UOM Maint
// 13 February 2023	navvt20		TFS CR 56132 Task 56399: UI - UOM Maintenance - Type
// ---------------------------------------------------------------------------

vars
	pxyInvUOM					: CM_InvoiceUnitOfMeasure;
	theReturn					: Integer;
	table						: CM_EntryTable;
begin

	table := self.tblEntDetail;

	if self.mode = Mode_Add then
		create pxyInvUOM transient;
	elseif self.mode = Mode_Update then
		pxyInvUOM := self.myProxyObject.CM_InvoiceUnitOfMeasure;
	else
		return false;
	endif;
	
	
	pxyInvUOM.setProxy(		app.getUOMStrtoInt(self.tblEntDetail.getValueByName(ETRow_Type).String),	// 13 Feb 2023 navvt20 TFS 56399
							self.tblEntDetail.getValueByName(ETRow_Code).String,
							self.tblEntDetail.getValueByName(ETRow_Description).String);

	while true do
		if self.mode = Mode_Add then
			app.myTrxCA.trxCreateInvoiceUnitOfMeasure(pxyInvUOM,  self.myCurrentObject, app.myPassport);
		elseif self.mode = Mode_Update then
			app.myTrxUA.trxUpdateInvoiceUnitOfMeasure(pxyInvUOM, app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			return true;
		else
			theReturn := app.showErrorWarningDialog("Unit Of Measure", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
		endif;
		break;
	endwhile;
	
epilog
	if self.mode = Mode_Add then
		delete pxyInvUOM;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initDataTable" id="d0f9365c-9c2c-4bb7-b3ea-c13f7c1b6090">
        <updating/>
        <source>initDataTable() updating;
/*
	
Date				Who			Reason
14 Dec 2022 		navvt20		TFS CR 55621 Task 55695: UI - UOM Maint
*/

vars
	
begin

	self.setTblDataEntRows(ETDef_InvoiceUOMDetail);

	self.zClearSortColumns();
	self.zAddSortColumn(ETRow_Code, false);
	self.zAddSortColumn(ETRow_Description, false);

end;</source>
    </JadeMethod>
    <JadeMethod name="initForm" id="02d24a4a-3e89-4e14-a248-f287610ccdcf">
        <updating/>
        <source>initForm() updating;
/*

Date				Who			Reason
14 Dec 2022 		navvt20		TFS CR 55621 Task 55695: UI - UOM Maint
*/

vars
begin

	self.allowPrint		:= true;
	self.allowExportCSV	:= true;
	self.allowSearch	:= false;
	self.allowTblDataSearch := true;
	self.allowDelete := true;
	self.allowAdd := true;
	self.caption := "Invoice Unit Of Measure Maintenance";
	self.useTblThumb := true;
	self.frmDetailsBottom.visible := false;
	self.mnuTblVPrint.enabled	:= true;	
	self.mnuTblVExportCSV.enabled:= true;	
	
	self.initTblThumb();
	self.initTblEntDetail();
	self.clearErrorWarnings();

end;</source>
    </JadeMethod>
    <JadeMethod name="initTblEntDetail" id="2622d6b6-d943-48a5-b95d-f7e366f89615">
        <source>initTblEntDetail();
/*

Date				Who			Reason
14 Dec 2022			navvt20		TFS CR 55621 Task 55695: UI - UOM Maint
*/

vars
	entTableDef		: EntTableDef;
	theTable		: CM_EntryTable;
	
begin

	theTable := self.tblEntDetail;
	theTable.warningMethod := 'entTableWarning';

	theTable.stretchToParent := true;
	theTable.optimiseRowHeight := true;
	entTableDef := app.myController.getEntTableDef(ETDef_InvoiceUOMThumb);
	theTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	
	theTable.adjustHeight(200);	
	theTable.optimiseHeadingColumn();
	theTable.changeMode := theTable.ChangeMode_FirstOnly;
end;</source>
    </JadeMethod>
    <JadeMethod name="initTblThumb" id="70f6ed1a-5e18-4af5-ba97-15fa8a340862">
        <source>initTblThumb();
/*
	
Date				Who			Reason
12 Dec 2022 		navvvt20	TFS CR 55621 Task 55695: UI - UOM Maint
*/

vars

	theTable		: CM_ThumbnailTable;
begin
	theTable := self.tblThumb;
	theTable.clear;
	theTable.scrollBars := Table.ScrollBar_Horizontal;

end;</source>
    </JadeMethod>
    <JadeMethod name="populateEntDetailTable" id="d318891a-72b3-4f16-a830-c35da0d4b8c0">
        <source>populateEntDetailTable();
// ---------------------------------------------------------------------------
//
// Date		Who 	Reason
//13 December 2022	navvt20	TFS CR 55621 Task 55695: UI - UOM Maint
//07 March	2023	navmk20	Bug 56947: EUP - When Adding a Unit of Measure for the first time the type combo box is empty
// ---------------------------------------------------------------------------

vars
	entRow			: EntTableRow;
	invoiceUOM		: CM_InvoiceUnitOfMeasure;
	displayValue	: String;	
	entDef			: EntTableDef;
	type 			: Integer; //7.3.2023 navmk20 TFS 56947
begin
	entDef := app.myController.getEntTableDef(ETDef_InvoiceUOMDetail);

	invoiceUOM := self.myCurrentObject.CM_InvoiceUnitOfMeasure;
	// Start 7.3.2023 navmk20 TFS 56947
	if invoiceUOM &lt;&gt; null then
		type := invoiceUOM.type; 
	endif;
	self.doCmbTypeBuild(type);
	//End 7.3.2023 navmk20 TFS 56947
	if self.mode = Mode_Add then
		self.tblEntDetail.clearValues();
		return;
	endif;	
	if invoiceUOM = null then
		return;
	endif;
	
	foreach entRow in entDef.allEntTableRows do
		if invoiceUOM &lt;&gt; null then
			displayValue := invoiceUOM.getDisplayStringForAttribute(entRow.name, false).String;
		else
			displayValue := null;
		endif;
		
		tblEntDetail.setValueByName(entRow.name, displayValue);		
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="a64be391-ec7e-4bc5-bb0a-387342857fd1">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
/*
		
Date				Who			Reason
