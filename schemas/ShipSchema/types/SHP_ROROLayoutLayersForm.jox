        <updating/>
        <source>tblDimensions_click(table: Table input) updating;
/*
Purpose:			
Date		Who		Reason
06 May 2011	cnwab1	Initial creation
*/

vars

begin
	if table.row &lt;= table.fixedRows or table.row &gt; table.rows then
		return;
	endif;

	// PAR 27526
	if table.column &lt; 2 then
		table.column := 2; 
		table.accessCell(table.row,2);
	endif;

epilog

end;</source>
