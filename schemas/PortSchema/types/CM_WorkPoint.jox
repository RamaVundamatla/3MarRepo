    <JadeMethod name="releaseToShip" id="6c6abcff-1e15-4831-9ca2-494879da66ba">
        <source>releaseToShip(_ti : CM_TrackedItem; _wle : CM_WorkListEntry; _lcController : CM_LocationsController);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 July 2012	cnwndl1	Initial creation	Par 30039

*/

vars

	moveController	: CMIF_MoveController;
	startTime		: TimeStamp;
	lockKeeperStarted	: Boolean;

begin
	if _lcController = null then
		app.setContinueCMExceptions(false);
		app.raiseUnexpectedProgramError(class.name, method.name, 'To Location is null');
		return;
	endif;

	startTime := app.actualTimeServer();
	
	create moveController transient;
	
	moveController.isForcedMove		:= true;
	moveController.isSystemMove 	:= true;
	moveController.isRehandleMove 	:= _ti.isRehandle;
	moveController.setMyWorkListEntry(_wle);		
	moveController.setMoveMode(REAL_MODE);
	moveController.setMyTrackedItem(_ti);
	moveController.isOverstowMove := false;
	moveController.setMyToPrimaryLocation(_lcController);

	app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, app.myPassport);	

epilog
	delete moveController;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_lcController" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="replaceWPRatesWith" id="71c2d299-8cdd-4473-be21-a45cb070231c">
        <source>replaceWPRatesWith( _allTemplates : CM_WPRatesByCargoTypeProduct; _passport : CM_Passport input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2018	jlgndl1	Initial creation	TFS 41980

*/

vars

	localExistingWPCRs : CM_WPRatesByCargoTypeProduct;
	existingWPCR : CM_WorkPointCargoRates;

	templateWpcr : CM_WorkPointCargoRates;
	newRealWpcr : CM_WorkPointCargoRates;

begin
	
	//copy the existing wpcrs to a local collection.
	create localExistingWPCRs transient;
	self.allWorkPointRates.copy( localExistingWPCRs );
	
	//delink all of the existing wpcrs, to remove them from our real collection
	foreach existingWPCR in localExistingWPCRs do
		existingWPCR.setMyWorkPoint( null );
	endforeach;
	
	//purge the old de-linked wpcrs.
	if localExistingWPCRs &lt;&gt; null and not localExistingWPCRs.isEmpty then
		localExistingWPCRs.purge();
	endif;
	
	//create new persistent wpcrs from the templates
	foreach templateWpcr in _allTemplates do
		create newRealWpcr persistent;
		newRealWpcr.setForUpdate( templateWpcr, _passport );
		newRealWpcr.setMyWorkPoint( self );
	endforeach;

epilog

	delete localExistingWPCRs;

end;</source>
        <Parameter name="_allTemplates" type="CM_WPRatesByCargoTypeProduct"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
