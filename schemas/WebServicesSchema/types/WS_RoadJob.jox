    <JadeMethod name="delete" id="b0126cbc-6409-4704-9cc6-3178adc8c99b">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 November 2017	jlger1	Initial creation 7521

*/

vars

begin
	self.allLoadedCargo.purge;
	self.allUnloadedCargo.purge;
	self.allWLEsToLoad.purge;
	self.allWLEsToUnload.purge;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="hasCargoInWLEsToLoad" id="f784b694-c961-4558-9070-e1343df2dfdb">
        <source>hasCargoInWLEsToLoad(_cargo : CM_TrackedItem) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 January 2018	jlger1	Initial creation tfs 36534

*/

vars
	wsTI : WS_TrackedItem;
begin
	if _cargo = null then
		return false;
	endif;
	
	foreach wsTI in self.allLoadedCargo discreteLock do	
		if wsTI.idTextBox = _cargo.id then
			return true;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <Parameter name="_cargo" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setAnyIdLoadDetails" id="33263ffe-81c1-4c7a-8d75-b49ba7aaedd5">
        <updating/>
        <source>setAnyIdLoadDetails(_roadJob : CM_RoadJob) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Jul 2017	jlger1	Initial creation 5597
08 Jan 2026 navma1  MTN-36897 PEN - Transient File Growth in PEN Production Environment 
*/

vars
	wle 	 : CM_WorkListEntry;
	wsCargo  : WS_TrackedItem;
	wleArray : CM_WLEArray;
	req		 : CM_Request;
begin
	
	create wleArray transient;
	
	if _roadJob.workListEntries.isNotEmpty then
		_roadJob.workListEntries.copy(wleArray);	//08.01.2026 navma1 #MTN-36897
	endif;
	
	foreach wle in wleArray discreteLock do
		
		req := wle.myRequest;
		
		if req = null then
			continue;
		endif;
		
		if  wle.isReceipt then
			continue;
		endif;
		
		if (req.isAnyId() and req.isAnyAmount) then
			if wle.myTrackedItem &lt;&gt; null then
				create wsCargo transient;
				wsCargo.setProxyFromObject(wle.myTrackedItem);
				self.allLoadedCargo.add(wsCargo);
			endif;		
		endif;	
	endforeach;
	
epilog
	delete wleArray;
end;</source>
        <Parameter name="_roadJob" type="CM_RoadJob"/>
    </JadeMethod>
    <JadeMethod name="setLoadWLEDetails" id="3aaa6293-eb85-46bf-97a1-b5a600f1138e">
        <updating/>
        <source>setLoadWLEDetails(_roadJob : CM_RoadJob input; _includeLoadWLEs, _includeLoadedCargo : Boolean) updating;
/*

Date		Who		Reason
10 November 2015	cnwer1	Initial creation PAR
22 November 2018	jlgmd1	TFS 41068 - JMT - CardSchema monitoring for Web services
29 Nov      2019	cnwma1  Bug 47748: STWR - Remain on board trailer can be put in storage without warning
03 October	2023	navpw1	TFS: 59830 - PRP | TruckLoader Prevent Cargo List display on page load
*/

vars
	truck 			 : CM_Vehicle;
	wle 			 : CM_WorkListEntry;
	ti 				 : CM_TrackedItem;
	loadedTIs  	     : CM_TISet;
	wsTI 		 	 : WS_TrackedItem;
	wsRoadWLE 		 : WS_RoadWLE;
	wleArray		 : CM_WLEArray;
	allAnyIdCargo,
	allWLEAnyIdCargo : CM_TIArray;
	wleAdded		 : Boolean;
	anyIdDynaDict 	 : DynaDictionary;
	trailerTIs 		 : CM_TISet;
begin
	create loadedTIs transient;
	self.allLoadedCargo.purge;
	self.allWLEsToLoad.purge;
	truck:=_roadJob.myVehicle;
	
	create wleArray transient;
	truck.getAllWLEs(wleArray);
	create trailerTIs transient;
	
	foreach ti in truck.locationsController.allTrackedItems discreteLock do
		// must have been found and selected without an associated Wle.
		if ti.isPreNote then //jlier1 TFS 2/8/24
			continue;
		endif;
		if ti.isROB then               //29.11.2019 cnwma1 #47748
			continue;
		endif;
		if not loadedTIs.includes(ti) then
			loadedTIs.add(ti);
		endif;
		if ti.isKindOf(CM_TILC) then
			trailerTIs.clear;
			ti.CM_TILC.getAllOnboardTIs(trailerTIs);
			trailerTIs.copyNoDups(loadedTIs);
		endif;
	endforeach;
	
	create allAnyIdCargo transient;	
	create allWLEAnyIdCargo transient;
	
	//epr TFS 8325 any id cargo not showing to filter 15/12/17
	create anyIdDynaDict transient;
	anyIdDynaDict.setMembership(WS_RoadWLE);
	anyIdDynaDict.addExternalKey(String,30,true,true);
	anyIdDynaDict.endKeys(false);
	foreach wle in wleArray discreteLock do
	
		// Let JSA know we're still doing something
		app.sendHeartbeatIfRequired();
		
		if wle.isROB then                 //29.11.2019 cnwma1 #47748
			continue;
		endif;
		if wle.isReceipt and wle.status &lt;&gt; WLE_COMPLETED then
			ti := wle.myTrackedItem;
			if ti &lt;&gt; null then
				if ti.hasBeenMerged then
					continue;
				endif;
				if loadedTIs.includes(ti) then
					loadedTIs.remove(ti);
				endif;	
			endif;
			
		endif;
		
		// ### TFS 59830 (59831) 03Oct2023 NAVPW1
		if not _includeLoadWLEs then
			continue;
		endif;
		// ### TFS 59830 (59831) 03Oct2023 NAVPW1
		
		if not wle.isReceipt and wle.status &lt;&gt; WLE_COMPLETED then
			if wle.isAnyId then
				allWLEAnyIdCargo.clear;
				wle.getAllCargoForAnyIdSelection(allWLEAnyIdCargo);
				if allWLEAnyIdCargo.size &gt; 0 then
					wleAdded:=false;
					foreach ti in allWLEAnyIdCargo discreteLock do
						if not allAnyIdCargo.includes(ti) then
							wleAdded:=true;
							create wsRoadWLE transient;
							wsRoadWLE.setProxyFromObject(wle.CM_YardWLE);
							create wsRoadWLE.myTrackedItem transient;
							wsRoadWLE.myTrackedItem.setProxyFromObject(ti);
							allAnyIdCargo.add(ti);
							self.allWLEsToLoad.add(wsRoadWLE);	
							
							anyIdDynaDict.putAtKey(ti.getOidString,wsRoadWLE);
						endif;
					endforeach;
					if not wleAdded  and ti &lt;&gt; null then
						// have to find one of the other and id wles with the ti
						wsRoadWLE:=anyIdDynaDict.getAtKey(ti.getOidString).WS_RoadWLE;
						if wsRoadWLE &lt;&gt; null and self.allWLEsToLoad.includes(wsRoadWLE) then
							self.allWLEsToLoad.remove(wsRoadWLE);
							delete wsRoadWLE;
							create wsRoadWLE transient;
							wsRoadWLE.setProxyFromObject(wle.CM_YardWLE);
							create wsRoadWLE.myTrackedItem transient;
							wsRoadWLE.myTrackedItem.setProxyFromObject(ti);
							self.allWLEsToLoad.add(wsRoadWLE);
						endif;
					endif;
				
					continue;	
				endif;
			endif;
			
			//epr TFS 36605 22/1/18
			if wle.myTrackedItem &lt;&gt; null and wle.myTrackedItem.hasBeenMerged then
				continue;
			endif;
			create wsRoadWLE transient;
			wsRoadWLE.setProxyFromObject(wle.CM_YardWLE);
			self.allWLEsToLoad.add(wsRoadWLE);	
			
		endif;
	endforeach;
	
	if _includeLoadedCargo then					// ### TFS 59830 (59831) 03Oct2023 NAVPW1
		foreach ti in loadedTIs discreteLock do
			create wsTI transient;
			wsTI.setProxyFromObject(ti);
			self.allLoadedCargo.add(wsTI);
		endforeach;	
	endif;										// ### TFS 59830 (59831) 03Oct2023 NAVPW1
	
epilog
	delete loadedTIs;
	delete wleArray;
	delete allAnyIdCargo;
	delete allWLEAnyIdCargo;
	delete anyIdDynaDict;
	delete trailerTIs;
end;</source>
        <Parameter name="_roadJob" type="CM_RoadJob" usage="input"/>
        <Parameter name="_includeLoadWLEs" type="Boolean"/>
        <Parameter name="_includeLoadedCargo" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="432b8d29-1c1f-41a7-9356-08d460a261e8">
        <updating/>
        <source>setProxyFromObject(_roadJob: CM_RoadJob) updating;
/*

Date		Who		Reason
10 Nov 2015	cnwer1	Initial creation PAR
29 Nov 2019 cnwma1  Bug 47748: STWR - Remain on board trailer can be put in storage without warning 
*/

vars
	wle 			 : CM_WorkListEntry;
	totalWleOnJob    : Integer;
begin
	if _roadJob = null then
		return;
	endif;
	
	inheritMethod(_roadJob);
	
	self.carrier  :=_roadJob.carrierId;
	self.driverId :=_roadJob.driverId;
	self.truckReg :=_roadJob.regNumber;
	
	if _roadJob.myRFIDTag &lt;&gt; null then
		self.batNumber:=_roadJob.myRFIDTag.code;
	endif;
	
	if _roadJob.myVehicleVisit &lt;&gt; null then
		self.visitNumber :=_roadJob.myVehicleVisit.visitNumber;
	endif;
	
	foreach wle in _roadJob.workListEntries do
		
		if wle.isROB then                       //29.11.2019 cnwma1 #47748
			continue;
		endif;
		totalWleOnJob := totalWleOnJob + 1;
		
		if wle.status = WLE_COMPLETED then			
			self.totalCompleteWLEs := self.totalCompleteWLEs + 1;
			
		endif;
	endforeach;
	
	self.totalWLEs := totalWleOnJob;  			//29.11.2019 cnwma1 #47748
	self.showBolDetails := app.myPassport.myTerminal.getConfig( HhTruckLoadBolId ).Boolean;

epilog

end;</source>
        <Parameter name="_roadJob" type="CM_RoadJob"/>
    </JadeMethod>
    <JadeMethod name="setUnloadWLEDetails" id="d265f9c5-05e7-4518-a0e1-2c7bb51b3e25">
        <updating/>
        <source>setUnloadWLEDetails(_roadJob : CM_RoadJob input) updating;
/*

Date		Who		Reason
11 November 2015	cnwer1	Initial creation PAR
22 November 2018	jlgmd1	TFS 41068 - JMT - CardSchema monitoring for Web services
29 Nov      2019	cnwma1  Bug 47748: STWR - Remain on board trailer can be put in storage without warning 
20 Feb 2025 navma1	MTN-34072	TPT| Remove Cargo Once the Truck has been Completed via the Handheld
*/

vars
	truck 		: CM_Vehicle;
	wle 		: CM_WorkListEntry;
	ti 			: CM_TrackedItem;
	unloadedTIs : CM_TISet;
	wsTI 		: WS_TrackedItem;
	wsRoadWLE 	: WS_RoadWLE;
	wleArray	: CM_WLEArray;
	
begin
	create unloadedTIs transient;
	self.allUnloadedCargo.purge;
	self.allWLEsToUnload.purge;
	truck:=_roadJob.myVehicle;
	
	
	create wleArray transient;
	truck.getAllWLEs(wleArray);
	

	foreach wle in wleArray discreteLock do	
	
		// Let JSA know we're still doing something
		app.sendHeartbeatIfRequired();
	
		if not wle.isReceipt then
			continue;
		endif;
	
		ti := wle.myTrackedItem;		
		if ti &lt;&gt; null then
			if ti.hasBeenMerged then
				continue;
			endif;
			
			if ti.isROB then       //29.11.2019 cnwma1 #47748
				continue;
			endif;
		
			if not ti.isOnVehicle( truck ) then
				//add to all Loaded Cargo
				if not unloadedTIs.includes(ti) then
					unloadedTIs.add(ti);
					create wsTI transient;					
					wsTI.setProxyFromObject(ti);					
					self.allUnloadedCargo.add(wsTI);
				endif;		
			endif;
		endif;
		if  wle.status &lt;&gt; WLE_COMPLETED then
			create wsRoadWLE transient;
			wsRoadWLE.setProxyFromObject(wle.CM_YardWLE);
			// ### TFS 53155 03Aug2022 NAVPW1
			if wle.myTrackedItem &lt;&gt; null then
				wsRoadWLE.hasCargoChecks := wle.myTrackedItem.hasCargoChecksByContext(CARGO_CHECK_CONTEXT_TRUKUNLOAD);
			endif;
			// ### TFS 53155 03Aug2022 NAVPW1
			self.allWLEsToUnload.add(wsRoadWLE);

		endif;
	endforeach;


epilog
	delete unloadedTIs;
	delete wleArray;
	
end;</source>
        <Parameter name="_roadJob" type="CM_RoadJob" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setWeights" id="79de5bb0-72a1-442a-987f-399f41224a69">
        <updating/>
        <source>setWeights(_reserveDetail : CM_ReserveDetail; _targetLocation : CM_LocationsController) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 February 2024	navcs2	ChangeRequest 61550: EUP | Release Request by Weight - Truck Loader/Unloader 

*/

vars
	countLoaded, countToLoad : Integer;
	weightLoaded, weightToLoad : Decimal[16,4];
	measureType : CM_MeasurementType;	
	bulkRelease	: CM_BulkRelease;
begin
	if _reserveDetail = null  then
		return;
	else
		bulkRelease := _reserveDetail.myReserveHeader;
		self.byTypeByWeight := _reserveDetail.byTypeByWeight;
	endif;
	
	bulkRelease.getLoadedAmountsForTarget(_targetLocation,countLoaded,countToLoad,weightLoaded, weightToLoad);
	measureType := app.getDefaultMeasurementForType(Type_Weight);
	if measureType &lt;&gt; null then
		self.weightLoaded:=app.convertMeasurementForDisplay(measureType.shortName, weightLoaded)&amp; " " &amp; measureType.shortName;
		self.weightToLoad:=app.convertMeasurementForDisplay(measureType.shortName, weightToLoad)&amp; " " &amp; measureType.shortName;	
	else
		self.weightLoaded:= weightLoaded.asStringWeightJMT;
		self.weightToLoad:= weightToLoad.asStringWeightJMT;
	endif;
epilog

end;</source>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
        <Parameter name="_targetLocation" type="CM_LocationsController"/>
    </JadeMethod>
</Class>
