    <JadeMethod name="doResize" id="5924cfad-d53b-43ef-992c-2b326397b0d3">
        <updating/>
        <source>doResize() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 Oct 2009	cnwndl1	Initial creation Par 21325
04 Nov 2020 cnwma1 ChangeRequest 50112: ASPA - GCI Stevedores
24 Aug 2022 navsj20	ChangeRequest 54281: EUP - Wagon Track Planning

*/

vars

begin

	inheritMethod();

	self.frmTrainCmb.borderStyle := Frame.BorderStyle_None;
	self.frmTrainCmb.width       := frmToolbar.width;
	self.frmTrainCmb.top         := frmToolbar.height + 1; // JMT METRO AKB
	self.grpTrainDetails.caption := null;
	self.grpTrainDetails.top     := self.frmTrainCmb.top + self.frmTrainCmb.height + 1;
	
	if self.tblWarnings.visible then
		self.tblWarnings.top   := self.grpTrainDetails.top + self.grpTrainDetails.height + 2;
		self.tblWarnings.width := self.grpTrainDetails.width;
		if self.tblWarnings.rows &gt; 0 then
			self.tblWarnings.accessColumn(1).width := ( self.tblWarnings.width - 2 ).Integer;
		endif;
		self.chkAdvanced.top := self.tblWarnings.top + self.tblWarnings.height + 5;
	//	self.minimumHeight := ( 425 + ( self.chkAdvanced.top - self.tblWarnings.top) ).Integer;
	else
		self.chkAdvanced.top := self.grpTrainDetails.top + self.grpTrainDetails.height + 4;
	//	self.minimumHeight := 425;
	endif;
	
	
	self.fldAdvanced.top 	   := self.chkAdvanced.top + 22;
	self.fldAdvanced.height    := 205;           //02.10.2020 cnwma1 TFS #50112
	self.grpAdvancedOpt.height := 185;           //02.10.2020 cnwma1 TFS #50112
	self.tblWagons.top 		   := self.frmWagonToolbar.top + self.frmWagonToolbar.height + 5;
	self.tblWagons.height 	   := self.grpWagonDetails.height - self.tblWagons.top - 4;
	
	self.hideShowAdvanced( chkAdvanced.value );
	self.setupMoveModeCtrl(); //24 Aug 2022	navsj20	TFS 54281	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="9ca19816-5382-468b-95d6-7c13a86affe0">
        <updating/>
        <source>doSave():Boolean protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 August 2009	cnwndl1	Initial creation

*/

vars
	newTrain,
	pxyTrain			: CM_Train;
	ls					: Boolean;
	result				: Integer;
begin
	app.cmsBeginLoad(ls);
	if self.mode = self.Mode_Add then
		create pxyTrain transient;
	elseif self.mode = self.Mode_Update then
		pxyTrain := app.createUpdateProxy(self.mySelectedTrain).CM_Train;
	endif;
	
	self.setTrainPxy(pxyTrain);
	app.cmsEndLoad(ls);
	
	while true do
		if self.mode = self.Mode_Add then
			app.myTrxCA.trxCreateTrain(pxyTrain, newTrain, false, app.myPassport);
		elseif self.mode = self.Mode_Update then
			app.myTrxUA.trxUpdateTrain(pxyTrain, false, app.myPassport);
		endif;
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			self.initialLoadMode := self.Mode_View;
			if self.mySelectedTrain = null then
				self.mySelectedTrain := newTrain;
			endif;
			self.setControlsForView();
			return true;
		else
			//result := app.showErrorWarningDialog('Train Update', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings); //- cnwmd1, CCMS 1067, Par 19710
			result := app.showErrorWarningDialog(app.getErrorString(Train_update), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings); //+ cnwmd1, CCMS 1067, Par 19710
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		
		return false;
		
	endwhile;
	
epilog

	self.setMyCaption();

	delete pxyTrain;
	app.cmsEndLoad(ls);

	
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
