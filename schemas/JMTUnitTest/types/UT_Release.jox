    <JadeMethod name="xRoadReleaseByTypeTwoTrucks" id="132ee436-51cc-450d-887e-c4159612758b">
        <source>xRoadReleaseByTypeTwoTrucks();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 May 2013	cnwrd1	Initial creation
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

vars
	releaseRequest : CM_BulkRelease;
	ti, ti1 : CM_TrackedItem;
	bs : CM_BlockStack;
begin
	self.deleteReleaseRequest("UTRRRoad");
	self.deleteContainer("UUT00000001");
	self.deleteContainer("UUT00000002");
	self.deleteTerminalArea("UTBS1");
	
	bs := self.addBlockStack("UTBS1", 100, null);
	
	releaseRequest := addReleaseByTypeRequest("UTRRRoad", BR_TYPE_ROAD, TI_CargoType_Container, "2200");
	assertEqual(releaseRequest.status, BR_ACTIVE);
	
	ti := self.addContainer("UUT00000001", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.move(ti, bs);
	
	self.releaseAssignCargo(releaseRequest,null, ti);
	assertEqual(releaseRequest.allTrackedItemsAssigned.size, 1);
	assertEqual(releaseRequest.allReserveDetails.size, 1);
	//assertEqual(releaseRequest.allReserveDetails.first.CM_ReserveSelection.allTrackedItems.size, 1);
	assertEqual(releaseRequest.allReserveDetails.first.CM_ReserveSelection.getAllTrackedItemsSize(false), 1); //23/06/2023	navkc1	CR 58406 Task 58408
		
	ti1 := self.addContainer("UUT00000002", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.move(ti1, bs);
	self.releaseAssignCargo(releaseRequest,null, ti1);
	assertEqual(releaseRequest.allTrackedItemsAssigned.size, 2);
	assertEqual(releaseRequest.allReserveDetails.size, 1);
	//assertEqual(releaseRequest.allReserveDetails.first.CM_ReserveSelection.allTrackedItems.size, 2);
	assertEqual(releaseRequest.allReserveDetails.first.CM_ReserveSelection.getAllTrackedItemsSize(false), 2); //23/06/2023	navkc1	CR 58406 Task 58408
	assertEqual(releaseRequest.status, BR_ACTIVE);

epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="xUnplanLoadSlots" id="8be6a830-028d-44f3-a3fd-5947404712d7">
        <source>xUnplanLoadSlots(_voyage : CM_Voyage; _jobSet : CM_VoyageJobSet io);

/*

Purpose:		Unplan load slots

Date			Who		Reason
20/02/2014		cnwmh5	Initial creation
11 Mar 2025		navah1	Story 34324: MSL - Un Plan Cargo items Doesn't use Deferred Updates [With Jobs]
*/

vars

	moveController 				: CMIF_MoveController;
	theVWLE 					: CM_VoyageWLE;
	ti							: CM_TrackedItem;
	pxyJob						: CM_VoyageJob;
		
	wleSet 						: CM_WLESet;
	wleArray					: CM_WLEArray;
	
	ls							: Boolean;
	tiTrans,											//13.03.2025 navah1 #34324
	moveTrans					: CM_TITransaction;		//13.03.2025 navah1 #34324
begin
	
	create wleArray transient;
	create wleSet transient;
	_jobSet.first.getAllWLEs(wleArray);
	wleArray.copy(wleSet);
	
	// unplan TI using trxUpdateVoyageJobUnassignTI	
	
	ti := wleSet.first.myTrackedItem;
	theVWLE := ti.getVoyageWLEUnactioned(true);
	self.assertNotNull(theVWLE);
	
	create moveController transient;
	moveController.setForCreateUnplan(ti, theVWLE, theVWLE.myRequest, true);
	app.cmsBeginLoad(ls);
	pxyJob := theVWLE.myRequest.myJob.CM_VoyageJob.pxyCreateUpdateProxy();
	app.cmsEndLoad(ls);
	
	app.myTrxUA.trxUpdateVoyageJobUnassignTI(moveController, pxyJob, app.myPassport);	
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(ti.myPrimaryPlannedLocation, null);
	
	//13.03.2025 navah1 #34324 - Start
	// check move unplan transaction
	tiTrans := ti.allTransactions.last;
	assertTrueMsg(tiTrans.isKindOf(CM_Move),"CM_Move transaction is not generated for trackedIItem");
	assertTrue(tiTrans.CM_Move.unplan);
	
	//check for this transaction in CM_Terminal::allTITransactions
	moveTrans := self.getTerminal.allTITransactions[tiTrans.dateTime,tiTrans.type];
	assertNotNullMsg(moveTrans,"CM_Move transaction is not found in terminal TITransactions dictionary");
	assertTrueMsg(tiTrans = moveTrans ,"The CM_Move transaction is not the expected one");
	//13.03.2025 navah1 #34324 - End
	
	app.myTrxUA.trxUpdateWLEsUnassignTI(wleSet, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.unplanVoyageJobs(_jobSet);
	
epilog

	app.cmsEndLoad(ls);

	delete moveController;
	delete wleSet;
	delete wleArray;
	delete pxyJob; 
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_jobSet" type="CM_VoyageJobSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="xUpdateSlotAttributesDefn" id="ff4cad8f-afc7-4fb7-9e58-56691f2ed89b">
        <source>xUpdateSlotAttributesDefn(_voyage : CM_Voyage);

/*

Purpose:		Update Slot Attributes / Definition

Date			Who		Reason
19/02/2014		cnwmh5	Initial creation

*/

vars
	
	bay								: CM_Bay;
	slotDefn						: CM_SlotDefn;
	pxySlotDefn						: CM_SlotDefn;
	slotController					: CM_SlotController;
		
	theSlots						: CM_SlotControllerSet;
	
	loadState						: Boolean;
	
begin

	// get the slots
	create theSlots transient;
	
	bay := _voyage.myCellularVoyageStructure.allBayVoyagesById["01"];
	foreach slotDefn in bay.allSlotsOnDeck do
		theSlots.add(slotDefn.CM_SlotDefnVoyage.mySlotController);
	endforeach;
	self.assertNotEqual(theSlots.size, 0);	
	
	self.updateSlotAttributes(theSlots, CM_SlotRequest.Attribute_Heavy);
	
	foreach slotController in theSlots do
		slotDefn := slotController.mySlotDefnVoyage;
		if slotDefn &lt;&gt; null then
			self.assertEqual(slotDefn.heavy, true);
		endif;
	endforeach;

	// update slot defn
	bay := _voyage.myCellularVoyageStructure.allBayVoyagesById["03"];
	slotDefn := bay.allSlotsOnDeck.first.CM_SlotDefn;
	app.cmsBeginLoad(loadState);
	pxySlotDefn := slotDefn.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadState);
	
	// empty only
	pxySlotDefn.setPxyMTOnly(not pxySlotDefn.mtOnly);
	
	app.myTrxUA.trxUpdateSlotDefn(pxySlotDefn, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertEqual(slotDefn.mtOnly, true);
	
epilog

	app.cmsEndLoad(loadState);
	
	delete pxySlotDefn;
	delete theSlots;
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="xUpdateSlotOrdinals" id="c52e1075-74d5-4f42-87db-835df076e2ff">
        <source>xUpdateSlotOrdinals(_vessel : CM_Vessel);

/*

Purpose:		Update a voyages slot ordinals

Date			Who		Reason
19/02/2014		cnwmh5	Initial creation

*/

vars
	
	deck							: CM_Deck;
	
	allDecks						: CM_DeckVesselByOrdinalDIct;
	allDeckOrds						: IntegerArray;
	
	index							: Integer;
	
begin

	// copy decks
	create allDecks transient;
	_vessel.myROROVesselStructure.allDecks.copy(allDecks);
	
	// get the ordinals for the decks
	create allDeckOrds transient;
	foreach deck in allDecks do
		allDeckOrds.add(deck.ordinal);
	endforeach;	
	
	app.myTrxUA.trxUpdateROROVesselDecksOrd(allDecks, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	foreach index in 1 to allDecks.size step 1 do
		self.assertNotEqual(allDecks[index].ordinal, allDeckOrds[index]);
	endforeach;
	
epilog

	delete allDeckOrds;
	delete allDecks;

end;</source>
        <Parameter name="_vessel" type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="xreSequenceSlotRequests" id="eaf0e0b9-b82f-484e-a71e-054aca7fe954">
        <source>xreSequenceSlotRequests(_voyageJob : CM_VoyageJob);

/*

Purpose:		Change the jobs sequence

Date			Who		Reason
21/02/2014		cnwmh5	Initial creation

*/

vars

	theSequence 					: CMIF_CustomSequence;
	request							: CM_Request;

	theSeqNums 						: IntegerArray;
	origSeqNums						: IntegerArray;
	
	index							: Integer;
	currentSeqNumber				: Integer;

begin

	create theSeqNums transient;
	create origSeqNums transient;
	
	create theSequence transient;
	theSequence.isStarboardBerthed := _voyageJob.isStarboard;
	
	// get the original sequence numbers
	foreach request in _voyageJob.allRequests do
		if _voyageJob.isStarboard then
			origSeqNums.add(request.getNumSeqStarboardCustom());
		else
			origSeqNums.add(request.getNumSeqPortCustom());
		endif;
	endforeach;
	
	currentSeqNumber := 14;
	foreach index in currentSeqNumber to (currentSeqNumber + _voyageJob.allRequests.size) do
		theSeqNums.add(index);
	endforeach;
		
	_voyageJob.allRequests.copy(theSequence.allSlotRequests);
	theSeqNums.copy(theSequence.allSeqNumbers);
	
	app.myTrxUA.trxUpdateSlotRequestSeqNum(theSequence, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();	
	
	// Check new seq nums against original to make sure different
	index := 1;
	foreach request in _voyageJob.allRequests do
		if _voyageJob.isStarboard then
			currentSeqNumber := request.getNumSeqStarboardCustom();
		else
			currentSeqNumber := request.getNumSeqPortCustom();
		endif;
		self.assertNotEqual(currentSeqNumber, origSeqNums[index]);
	endforeach;

epilog

	delete theSequence;
	delete theSeqNums;
	delete origSeqNums;
	
end;</source>
        <Parameter name="_voyageJob" type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="zConsigneeValidationMTN33613" id="82878b42-b913-4068-8c1d-9f311bfbe483">
        <source>zConsigneeValidationMTN33613(_terminalUTHelper : UT_HelperAdmTerm io; _terminal : CM_Terminal; _operator : CM_Operator; _consignee1, _consignee2 : CM_ConsigneeConsignor; _blockStack : CM_BlockStack) protected;
/*

Purpose:			Tests Changes made for MTN-33613 to make sure they are working

Parameters:			NONE

Return Value:		NONE

Date				Who		Reason
07 November 2025	navpw1	Initial creation JIRA: MTN-36370
27 November 2025	navpw1	JIRA: MTN-36756 - Fixed app.isRT by setting it false

*/

constants
	REF							: String = "36370";
	UT_ReleaseRequest			: String = "UT_" &amp; REF &amp; "REL1";
	UT_TruckId					: String = "UTTrk" &amp; REF &amp; "1";
	UT_TotalRequested			: Integer = 1;
	UT_ContainerId1				: String = "UT_" &amp; REF &amp; "1";
	UT_ContainerId2				: String = "UT_" &amp; REF &amp; "2";
	UT_ContainerId3				: String = "UT_" &amp; REF &amp; "3";
	ForkliftName				: String = "FLT1";
	
vars
	cargoTypeCont				: CM_CargoType;
	gate						: CM_Gate;
	vvr							: CM_VehicleVisitRecord;
	releaseRequest				: CM_BulkRelease;
	pxyReserveSelection			: CM_ReserveSelection;
	reserveDetail				: CM_ReserveDetail;
	forklift					: CM_Machine;
	allTasksJSON,
	allTasks					: CM_RTQueueTaskArray;
	wle							: CM_WorkListEntry;
	ti,
	ti1, ti2, ti3				: CM_TrackedItem;
	faultQuestion				: CM_FaultQuestion;
	locations					: CM_LCArray;
	ta,
	yardAllocation				: CM_YardAllocation;
	ya 							: CM_YardAllocationsByCodeDict;
	yardAllArray				: CM_YardAllocationArray;
	yardAllocExclArray			: CM_YardAllocationArray;
	imex						: CM_IMEXStatus;
	task, expTask				: CM_RTQueueTask;
	allDirectorCargo			: CM_TIArray;
	tiSet						: CM_TISet;
	originalConsigneeConfig,
	idx							: Integer;
	driverName,
	vehicleName,
	testHeader,
	allTasksJSONStr				: String;
	taAreas						: StringArray;
	q1							: CM_SubQueue;
	
begin
	/*
	Steps To Reproduce: 
	1. Empty Release request created for Type = Road Cargo Type = ISO Container Consignee = DSV DSV POOL, Release Number = DFDUPH
	2. Perform the road gate – Enter the Registration field, Driver Code
	3. Under New Item enter the Release number = DFDUPH
	4. Hit tab
	5. Note the fields are populated as per screenshot below of the Release Empty Container form. The consignee field shows as DSV DSV POOL
	6. Hit save    A record is now available in the road gate form
	7. Hit save again in the road gate form
	8. Open Road Operations form
	9. Select the truck &gt; Right click &gt; Select proceed &gt; Select to UN_CHK_Lane 1
	10. Now select the truck again &gt; Right click &gt; select proceed &gt; To Yard
	-------------------------------------------
	11. Open the vehicle app
	12. Log into the RS
	13. Pick up the Cargo
	14. Click Accept
	15.In the screen that opens you have the source and target locations
	16. Click on the magnifier to search for all matching containers
	*/
	
	/*
	** Global Setup
	*/
	testHeader := "MTN-33613 - ";
	self.logMessagePw(testHeader &amp; "Starting setup", LogINFO);
	
	originalConsigneeConfig := self.getTerminalConfig(RelReqConsigneeValidate).Integer;
	
	self.setTerminalConfig(NoExportStops, true);
	
	cargoTypeCont := self.getCargoTypeByAbbrv("CONT");
	self.assertNotNullMsg(cargoTypeCont, "cargoTypeCont");
	
	self.deleteReleaseRequest(UT_ReleaseRequest);
	
	// Vehicle
	driverName := self.getDriverName();
	self.assertNotNullMsg(driverName, "driverName");
	
	vehicleName := UT_TruckId;
	// Delete Vehicle
	self.deleteVehicle(vehicleName);
	
	self.opts.purge();
	self.opts.addAssoc("YardInterchangeArea", "UTBS2" &amp; REF);
	
	// Get the gate
	gate := _terminal.getConfig(GateDefaultEntry).CM_Gate;
	self.assertNotNullMsg(gate, "Gate");
	
	/*
	** Pre Run
	*/
	
	self.deleteYA("UTPW1");
	
	create locations transient;
	locations.add(_blockStack.allLocationsControllers.first);
	
	imex := app.myRoot.allImexStatuses[TI_IMEX_STATUS_IMPORT];
	
	yardAllocation := self.addYA("UTPW1", YACriteriaType_CargoType, cargoTypeCont, YACriteriaType_ImexStatus, imex, null, null, locations, null);
	self.assertNotNullMsg(yardAllocation, "yardAllocation");
	
	create yardAllArray transient;
	create yardAllocExclArray transient;
	yardAllocExclArray.add(yardAllocation);
	
	self.disableAllYAExt(_terminal, yardAllArray, yardAllocExclArray);
	
	//Create TI
	ti1 := self.getTrackedItem(UT_ContainerId1);
	if ti1 &lt;&gt; null then
		self.deleteTrackedItem(ti1, true);
		self.assertIsDeletedMsg(ti1, "ti1");
	endif;
	
	ti2 := self.getTrackedItem(UT_ContainerId2);
	if ti2 &lt;&gt; null then
		self.deleteTrackedItem(ti2, true);
		self.assertIsDeletedMsg(ti2, "ti2");
	endif;
	
	ti3 := self.getTrackedItem(UT_ContainerId3);
	if ti3 &lt;&gt; null then
		self.deleteTrackedItem(ti3, true);
		self.assertIsDeletedMsg(ti3, "ti3");
	endif;
	
	create tiSet transient;
	
	self.opts.purge;
	self.opts.addAssoc(UTTI_Consignee, _consignee1.code);
	ti1 := self.addContainer(UT_ContainerId1, _operator, "2200", "GENL", TI_IMEX_STATUS_IMPORT);
	tiSet.add(ti1);
	
	self.opts.purge;
	self.opts.addAssoc(UTTI_Consignee, _consignee2.code);
	ti2 := self.addContainer(UT_ContainerId2, _operator, "2200", "GENL", TI_IMEX_STATUS_IMPORT);
	tiSet.add(ti2);
	
	self.opts.purge;
	ti3 := self.addContainer(UT_ContainerId3, _operator, "2200", "GENL", TI_IMEX_STATUS_IMPORT);
	tiSet.add(ti3);
	
	foreach ti in tiSet do
		self.move(ti, _blockStack);
	endforeach;
	
	self.opts.purge;
	
	// Create vehicle visit
	vvr := _terminalUTHelper.xCreateVehicleVisitRecord(vehicleName, driverName, driverName, null, _terminal, gate.name);
	self.assertNotNullMsg(vvr, "vvr");
	
	_terminalUTHelper.opts.purge;
	_terminalUTHelper.opts.addAssoc("CargoType", cargoTypeCont);
	_terminalUTHelper.opts.addAssoc(UTTI_Consignee, _consignee1.code);
	_terminalUTHelper.opts.addAssoc(UT_OPTS_FullRelease, true);
	_terminalUTHelper.opts.addAssoc(UT_OPTS_Commodity, app.myRoot.allCommodities["GENL"]);
	
	pxyReserveSelection := _terminalUTHelper.xCreateReserveSelection(cargoTypeCont, null, app.myRoot.allISOTypes["2200"], UT_TotalRequested, null, null);
	self.assertNotNullMsg(pxyReserveSelection, "pxyReserveSelection");
	
	releaseRequest := _terminalUTHelper.xCreateReleaseRequest(UT_ReleaseRequest, BR_TYPE_ROAD, true, _terminal, pxyReserveSelection);	// Create a release request/bulk release. Release by Type
	self.assertNotNullMsg(releaseRequest, "releaseRequest");
	
	reserveDetail := releaseRequest.allReserveDetails.first;
	self.assertNotNullMsg(reserveDetail, "reserveDetail");
	
	//get forklift
	create taAreas transient;
	taAreas.add(_blockStack.id);
	
	//Delete Machine
	forklift := self.getMachine(ForkliftName);
	if forklift &lt;&gt; null then
		self.deleteMachine(ForkliftName);
		self.assertIsDeletedMsg(forklift, "forklift");
	endif;
	
	q1 := self.addQueue("UT_Q", _blockStack, null, false);
	
	//Add machine
	forklift := self.addForkLift(ForkliftName, 151, taAreas, q1.id); //wle.queue.id
	self.assertNotNull(forklift);

	
	//Create VVR
	_terminalUTHelper.opts.purge;
	_terminalUTHelper.opts.addAssoc(UT_OPTS_Consignee, _consignee1.code);
	
	vvr := _terminalUTHelper.xCreateGateEntityOutRelease(vvr, null, null,1,releaseRequest);
	
	self.assertEqualMsg(vvr.vehicle.allRoadJobs.size, 1, "Expecting only 1 Road Job");
	_terminalUTHelper.opts.purge();
	
	//Move Vehicle to Lane
	self.moveVehicleToLane(vvr.vehicle, self.getPGate(gate.name), 1);
	self.assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(self.getPGate(gate.name), 1));
	
	_terminalUTHelper.xMoveVehicleToYard(vvr.vehicle);
	
	wle := vvr.myRoadJob.workListEntries.first;
	
	//login forklift
	app.isRTApp := true;
	self.machineLogon(forklift);
	
	idx := 1;
	while idx &lt;= forklift.allCurrentFaultQuestions.size do
		faultQuestion := forklift.allCurrentFaultQuestions[idx];
		app.myTrxUA.trxMachineUpdateFaultResponse(forklift, idx, "Yes", app.myPassport);
		idx += 1; 
	endwhile;
	
	//Assign to Queue
	self.machineAssignToQueue(forklift, q1);
	
	self.assertEqualMsg(forklift.queueId, q1.id, "forklift.queueId");
	
	//Get RT Queue Tasks Old
	create allTasks transient;
	forklift.getAllAvailableQueuesTasks(allTasks); //CM_RTQueueTaskArray
	
	self.assertNotNullMsg(allTasks, "allTasks");
	//self.assertEqualMsg(allTasks.size, 1, "allTasks");
	
	//Get RT Queue Tasks JSON
	create allTasksJSON transient;
	allTasksJSONStr := forklift.getTasksAsJSON(allTasksJSON);
	
	self.assertNotNullMsg(allTasksJSON, "allTasksJSON");
	//self.assertEqualMsg(allTasksJSON.size, 1, "allTasksJSON");
	self.assertNotNullMsg(allTasksJSONStr, "allTasksJSONStr");
	
	foreach task in allTasksJSON do
		if task.tiId = "UTOP 2200" and task.targetLocationId = "UTTrk363701 Road" then
			expTask := task;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg(expTask, "expTask");
	self.assertEqualMsg(expTask.tiId, "UTOP 2200", "Expected: 'UTOP 2200' | Actual: '" &amp; expTask.tiId &amp; "'");
	self.assertEqualMsg(task.targetLocationId, "UTTrk363701 Road", "Expected: 'UTTrk363701 Road' | Actual: '" &amp; expTask.targetLocationId &amp; "'");
	
	//Update Task States??
	//app.myTrxUA.trxMachineSetTaskStates(machine,allTasks,app.myPassport); //Maybe need this?
	
	//Disconnect Cargo if needed (only for reefers?)
	//self.doDisconnectCargo();
	
	//Accept Task
	self.machineAcceptSpecifiedTask(forklift, task.myEntry);
	
	create allDirectorCargo transient;
	
	self.logMessagePw(testHeader &amp; "Finished setup", LogINFO);
	
	/*
	**	Test 1 Start - No Match Consignee
	*/
	
	/*
	** Setup
	*/
	testHeader := "MTN-33613 - Test 1 - ";
	self.logMessagePw(testHeader &amp; "Starting Test", LogINFO);
	
	beginTransaction;
	_terminal.setConfig(RelReqConsigneeValidate, ConsigneeNoMatch);
	_terminal.setConfig(RelReqConsignorValidate, ConsigneeNoMatch);
	app.cmsCommitTransaction(app.myPassport);
	
	/*
	** Run
	*/
	
	//forklift.getDirectorCargoAsJSON(UT_ContainerId.asStringRESTFUL.trimBlanks, null, 1, 100); //Maybe use JSON so we verfiy this too in case the original changes.
	
	//Get Director Cargo should contain the cargo we want?
	forklift.getDirectorTaskCargo(null, null, allDirectorCargo);
	
	/*
	** Assert
	*/
	//Assert expected cargo is in list
	self.assertTrueMsg(allDirectorCargo.includes(ti1), "Test 1 - allDirectorCargo contains ti '" &amp; ti1.id &amp; "' Expected: 'true' | Actual: 'false'");
	
	//Assert all cargo is in list as we are not filtering by consignee
	self.assertTrueMsg(allDirectorCargo.includes(ti2), "Test 1 - allDirectorCargo contains ti '" &amp; ti2.id &amp; "' Expected: 'true' | Actual: 'false'");
	self.assertTrueMsg(allDirectorCargo.includes(ti3), "Test 1 - allDirectorCargo contains ti '" &amp; ti3.id &amp; "' Expected: 'true' | Actual: 'false'");
	
	self.logMessagePw(testHeader &amp; "Finished Test", LogINFO);
	
	/*
	**	Test 1 End - No Match Consignee
	*/
	
	/*
	**	Test 2 Start - Strict Match Consignee
	*/
	
	/*
	** Setup
	*/
	testHeader := "MTN-33613 - Test 2 - ";
	self.logMessagePw(testHeader &amp; "Starting Test", LogINFO);
	
	beginTransaction;
	_terminal.setConfig(RelReqConsigneeValidate, ConsigneeStrictMatch);
	_terminal.setConfig(RelReqConsignorValidate, ConsignorStrictMatch);
	app.cmsCommitTransaction(app.myPassport);
	
	/*
	** Run
	*/
	
	//forklift.getDirectorCargoAsJSON(UT_ContainerId.asStringRESTFUL.trimBlanks, null, 1, 100); //Maybe use JSON so we verfiy this too in case the original changes.
	
	//Get Director Cargo should contain the cargo we want?
	forklift.getDirectorTaskCargo(null, null, allDirectorCargo);
	
	/*
	** Assert
	*/
	//Assert expected cargo is in list
	self.assertTrueMsg(allDirectorCargo.includes(ti1), "Test 2 - allDirectorCargo contains ti '" &amp; ti1.id &amp; "' Expected: 'true' | Actual: 'false'");
	
	self.logMessagePw(testHeader &amp; "Finished Test", LogINFO);
	
	/*
	**	Test 2 End - Strict Match Consignee
	*/
	
	/*
	**	Test 3 Start - Empty Match Consignee
	*/
	
	/*
	** Setup
	*/
	testHeader := "MTN-33613 - Test 3 - ";
	self.logMessagePw(testHeader &amp; "Starting Test", LogINFO);
	
	beginTransaction;
	_terminal.setConfig(RelReqConsigneeValidate, ConsigneeEmptyOk);
	_terminal.setConfig(RelReqConsignorValidate, ConsigneeEmptyOk);
	app.cmsCommitTransaction(app.myPassport);
	
	/*
	** Run
	*/
	
	//forklift.getDirectorCargoAsJSON(UT_ContainerId.asStringRESTFUL.trimBlanks, null, 1, 100); //Maybe use JSON so we verfiy this too in case the original changes.
	
	//Get Director Cargo should contain the cargo we want?
	forklift.getDirectorTaskCargo(null, null, allDirectorCargo);
	
	/*
	** Assert
	*/
	//Assert expected cargo is in list
	//Assert all cargo is in list as we are not filtering by consignee
	
	foreach ti in tiSet do
		self.assertTrueMsg(allDirectorCargo.includes(ti1), "Test 3 - allDirectorCargo contains ti '" &amp; ti1.id &amp; "' Expected: 'true' | Actual: 'false'");
	endforeach;
	
	self.logMessagePw(testHeader &amp; "Finished Test", LogINFO);
	
	/*
	**	Test 3 End - Empty Match Consignee
	*/
	
	/*
	** Cleanup
	*/
	ti := self.getTrackedItem(UT_ContainerId1);
	if ti &lt;&gt; null then
		self.deleteTrackedItem(ti, true);
		self.assertIsDeletedMsg(ti, "ti");
	endif;
	
	self.deleteReleaseRequest(UT_ReleaseRequest);
	self.deleteVehicle(vehicleName);
	
	beginTransaction;
	foreach ta in yardAllArray do
		ta.setPropertyValue(CM_YardAllocation::isDisabled.name, false);
	endforeach;
	commitTransaction;
	
	self.deleteYA("UTPW1");
	
epilog
	app.isRTApp := false;
	if process.isInTransactionState then
		app.cmsAbortTransaction();
	endif;
	
	beginTransaction;
	_terminal.setConfig(RelReqConsigneeValidate, ConsigneeNoMatch);
	_terminal.setConfig(RelReqConsignorValidate, ConsigneeNoMatch);
	app.cmsCommitTransaction(app.myPassport);
	
	delete taAreas;
	delete locations;
	
	beginTransaction;
	foreach ta in yardAllArray do
		ta.setPropertyValue(CM_YardAllocation::isDisabled.name, false);
	endforeach;
	commitTransaction;
	delete yardAllArray;
	delete yardAllocExclArray;
	delete allDirectorCargo;
	delete allTasks;
	delete allTasksJSON;
	delete tiSet;
	
end;</source>
        <access>protected</access>
        <Parameter name="_terminalUTHelper" type="UT_HelperAdmTerm" usage="io"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_consignee1" type="CM_ConsigneeConsignor"/>
        <Parameter name="_consignee2" type="CM_ConsigneeConsignor"/>
        <Parameter name="_blockStack" type="CM_BlockStack"/>
    </JadeMethod>
    <JadeMethod name="zConsigneeValidationMTN35801" id="d25c5efd-ff10-4727-88b1-4d90b38a85d1">
        <source>zConsigneeValidationMTN35801(_terminalUTHelper : UT_HelperAdmTerm io; _terminal : CM_Terminal; _operator : CM_Operator; _consignee1, _consignee2 : CM_ConsigneeConsignor; _blockStack : CM_BlockStack) protected;
/*

Purpose:			

Parameters:			NONE

Return Value:		NONE

Date				Who		Reason
07 November 2025	navpw1	Initial creation JIRA: MTN-36370

*/

constants
	UT_YardAlloc			: String	= "UTPW2";
	REF						: String	= "35801";
	UT_ReleaseRequest		: String	= "UT_" &amp; REF &amp; "REL1";
	UT_ReleaseRequest2		: String	= "UT_" &amp; REF &amp; "REL2";
	UT_ReleaseRequest3		: String	= "UT_" &amp; REF &amp; "REL3";
	UT_ReleaseRequest4		: String	= "UT_" &amp; REF &amp; "REL4";
	UT_ReleaseRequest5		: String	= "UT_" &amp; REF &amp; "REL5";
	UT_TruckId				: String	= "UTTrk" &amp; REF &amp; "1";
	UT_TotalRequested		: Integer	= 1;
	UT_ContainerId1			: String	= "UT_" &amp; REF &amp; "1";
	VESSEL					: String	= 'UTVES' &amp; REF;
	VOYAGE					: String	= 'UT' &amp; REF;
	OperatorCode			: String	= "UTPW";
	
vars
	cargoTypeCont			: CM_CargoType;
	operator				: CM_Operator;
	gate					: CM_Gate;
	vvr						: CM_VehicleVisitRecord;
	pxyReserveSelection		: CM_ReserveSelection;
	releaseRequest			: CM_BulkRelease;
	reserveDetail			: CM_ReserveDetail;
	ti,
	ti1						: CM_TrackedItem;
	locations				: CM_LCArray;
	ta,
	yardAllocation			: CM_YardAllocation;
	ya 						: CM_YardAllocationsByCodeDict;
	yardAllArray			: CM_YardAllocationArray;
	imex					: CM_IMEXStatus;
	tiSet					: CM_TISet;
	driverName,
	vehicleName,
	testHeader				: String;
	originalConsigneeConfig	: Integer;
	
begin
	/*
	Steps to Reproduce Case
	----------------------------------
		
		1. Create an empty release with a specified consignee
		2. Have no empty onsite cargo items with the corresponding consignee 
		3. Tick "Best Pick" on the release.
		4. Use the road gate to collect the empty container
		5. Error 86022. No matching best-pick item found for XYZ ISO in area ABC.
		
		This happens regardless of the configuration set in Terminal Config.
		
		6. Remove the consignee from the release request.
		7. Clear the road gate and then enter details again.
		8. System does not throw an error.
	
	*/
	
	/*
	** Global Setup
	*/
	testHeader := "MTN-35801 - ";
	self.logMessagePw(testHeader &amp; "Starting setup", LogINFO);
	
	_terminalUTHelper.opts.purge;
	
	originalConsigneeConfig := self.getTerminalConfig(RelReqConsigneeValidate).Integer;
	
	self.setTerminalConfig(NoExportStops, true);
	
	cargoTypeCont := self.getCargoTypeByAbbrv("CONT");
	self.assertNotNullMsg(cargoTypeCont, "cargoTypeCont | " &amp; testHeader);
	
	self.deleteReleaseRequest(UT_ReleaseRequest);
	self.deleteReleaseRequest(UT_ReleaseRequest2);
	self.deleteReleaseRequest(UT_ReleaseRequest3);
	self.deleteReleaseRequest(UT_ReleaseRequest4);
	self.deleteReleaseRequest(UT_ReleaseRequest5);
	
	// Vehicle
	driverName := self.getDriverName();
	self.assertNotNullMsg(driverName, "driverName | " &amp; testHeader);
	
	vehicleName := UT_TruckId;
	// Delete Vehicle
	self.deleteVehicle(vehicleName);
	
	self.opts.purge();
	self.opts.addAssoc("YardInterchangeArea", "UTBS2" &amp; REF);
	
	// Get the gate
	gate := _terminal.getConfig(GateDefaultEntry).CM_Gate;
	self.assertNotNullMsg(gate, "Gate | " &amp; testHeader);
	
	self.deleteVoyage(VOYAGE);
	self.deleteVessel(VESSEL);
	self.deleteOperator(OperatorCode);
	
	//Create Operator
	operator := self.addOperator(OperatorCode, "UT_" &amp; OperatorCode &amp; " Desc", false, null, null, null, false, false, false, false, false, false, false, false, false, false, null, null, null, null, false, false, null, null, null, null, false, false);
	self.assertNotNullMsg(operator, "operator | " &amp; testHeader);
	
	/*
	** Pre Run
	*/
	self.deleteYA(UT_YardAlloc);
	
	create locations transient;
	locations.add(_blockStack.allLocationsControllers.first);
	
	imex := app.myRoot.allImexStatuses[TI_IMEX_STATUS_IMPORT];
	
	yardAllocation := self.addYA(UT_YardAlloc, YACriteriaType_CargoType, cargoTypeCont, YACriteriaType_ImexStatus, imex, null, null, locations, null);
	self.assertNotNullMsg(yardAllocation, "yardAllocation | " &amp; testHeader);
	
	create yardAllArray transient;
	ya := app.myPassport.myTerminal.allYardAllocatonsByCode;
	beginTransaction;
	foreach ta in ya discreteLock do 
		if ta.isDisabled = false and ta.code &lt;&gt; UT_YardAlloc then
			yardAllArray.add(ta);
			ta.setPropertyValue(CM_YardAllocation::isDisabled.name, true);
		endif;
	endforeach;
	commitTransaction;
	
	self.logMessagePw(testHeader &amp; "Finished setup", LogINFO);
	
	/*
	**	Test 1 Start - No Match Consignee
	*/
	testHeader := "MTN-35801 - Test 1 - ";
	self.logMessagePw(testHeader &amp; "Starting Test", LogINFO);
	
	/*
	** Setup
	*/
	if not originalConsigneeConfig = ConsigneeNoMatch then
		beginTransaction;
		_terminal.setConfig(RelReqConsigneeValidate, ConsigneeNoMatch);
		app.cmsCommitTransaction(app.myPassport);
	endif;
	
	/*
	** Run
	*/
	//Create TI
	ti1 := self.getTrackedItem(UT_ContainerId1);
	if ti1 &lt;&gt; null then
		self.deleteTrackedItem(ti1, true);
		self.assertIsDeletedMsg(ti1, "ti1 | " &amp; testHeader);
	endif;
	
	create tiSet transient;
	
	self.opts.purge;
	ti1 := self.addContainer(UT_ContainerId1, operator, "2200", "MT", TI_IMEX_STATUS_IMPORT);
	tiSet.add(ti1);
	
	foreach ti in tiSet do
		self.move(ti, _blockStack);
	endforeach;
	
	self.opts.purge;
	
	// Create vehicle visit
	vvr := _terminalUTHelper.xCreateVehicleVisitRecord(vehicleName, driverName, driverName, null, _terminal, gate.name);
	self.assertNotNullMsg(vvr, "vvr | " &amp; testHeader);
	
	_terminalUTHelper.opts.purge;
	_terminalUTHelper.opts.addAssoc("CargoType", cargoTypeCont);
	_terminalUTHelper.opts.addAssoc(UTTI_Consignee, _consignee1.code);
	_terminalUTHelper.opts.addAssoc(UT_OPTS_FullRelease, false);
	_terminalUTHelper.opts.addAssoc(UT_OPTS_BestPick, true);
	_terminalUTHelper.opts.addAssoc(UT_OPTS_Operator, operator);
	
	pxyReserveSelection := _terminalUTHelper.xCreateReserveSelection(cargoTypeCont, null, app.myRoot.allISOTypes["2200"], UT_TotalRequested, null, null);
	self.assertNotNullMsg(pxyReserveSelection, "pxyReserveSelection | " &amp; testHeader);
	
	releaseRequest := _terminalUTHelper.xCreateReleaseRequest(UT_ReleaseRequest, BR_TYPE_ROAD, true, _terminal, pxyReserveSelection);	// Create a release request/bulk release. Release by Type
	self.assertNotNullMsg(releaseRequest, "releaseRequest | " &amp; testHeader);
	
	reserveDetail := releaseRequest.allReserveDetails.first;
	self.assertNotNullMsg(reserveDetail, "reserveDetail | " &amp; testHeader);
	
	//Create VVR
	_terminalUTHelper.opts.purge;
	_terminalUTHelper.opts.addAssoc(UT_OPTS_Consignee, _consignee1.code);
	_terminalUTHelper.opts.addAssoc(UT_OPTS_IsMT, true);
	_terminalUTHelper.opts.addAssoc(UT_OPTS_AssertChecks, false);
	_terminalUTHelper.opts.addAssoc(UT_OPTS_IgnoreTrxWarning, false);
	_terminalUTHelper.opts.addAssoc(UT_OPTS_BestPick, true);
	
	vvr := _terminalUTHelper.xCreateGateEntityOutRelease(vvr, null, null,1,releaseRequest);
	
	/*
	** Assert
	*/
	self.assertNoTrxErrorsOrWarnings();
	
	/*
	** Cleanup
	*/
	self.deleteReleaseRequest(UT_ReleaseRequest);
	
	//Delete previous cargo
	
	vehicleName := UT_TruckId;
	// Delete Vehicle
	self.deleteVehicle(vehicleName);
	
	tiSet.clear;
	
	self.logMessagePw(testHeader &amp; "Finished Test", LogINFO);
	
	/*
	**	Test 1 End - No Match Consignee
	*/
	
	/*
	**	Test 2 Start - Strict Match Consignee - Cargo matches no error
	*/
	
	/*
	** Setup
	*/
	testHeader := "MTN-35801 - Test 2 - ";
	self.logMessagePw(testHeader &amp; "Starting Test", LogINFO);
	
	beginTransaction;
	_terminal.setConfig(RelReqConsigneeValidate, ConsigneeStrictMatch);
	app.cmsCommitTransaction(app.myPassport);
	
	//Create TI
	ti1 := self.getTrackedItem(UT_ContainerId1);
	if ti1 &lt;&gt; null then
		self.deleteTrackedItem(ti1, true);
		self.assertIsDeletedMsg(ti1, "ti1 | " &amp; testHeader);
	endif;
	
	self.opts.purge;
	self.opts.addAssoc(UTTI_Consignee, _consignee1.code);
	ti1 := self.addContainer(UT_ContainerId1, operator, "2200", "MT", TI_IMEX_STATUS_IMPORT);
	tiSet.add(ti1);
	
	foreach ti in tiSet do
		self.move(ti, _blockStack);
	endforeach;
	
	self.opts.purge;
	
	/*
	** Run
	*/
	// Create vehicle visit
	vvr := _terminalUTHelper.xCreateVehicleVisitRecord(vehicleName, driverName, driverName, null, _terminal, gate.name);
	self.assertNotNullMsg(vvr, "vvr | " &amp; testHeader);
	
	_terminalUTHelper.opts.purge;
	_terminalUTHelper.opts.addAssoc("CargoType", cargoTypeCont);
	_terminalUTHelper.opts.addAssoc(UTTI_Consignee, _consignee1.code);
	_terminalUTHelper.opts.addAssoc(UT_OPTS_FullRelease, false);
	_terminalUTHelper.opts.addAssoc(UT_OPTS_BestPick, true);
	_terminalUTHelper.opts.addAssoc(UT_OPTS_Operator, operator);
	
	pxyReserveSelection := _terminalUTHelper.xCreateReserveSelection(cargoTypeCont, null, app.myRoot.allISOTypes["2200"], UT_TotalRequested, null, null);
	self.assertNotNullMsg(pxyReserveSelection, "pxyReserveSelection | " &amp; testHeader);
	
	releaseRequest := _terminalUTHelper.xCreateReleaseRequest(UT_ReleaseRequest2, BR_TYPE_ROAD, true, _terminal, pxyReserveSelection);	// Create a release request/bulk release. Release by Type
	self.assertNotNullMsg(releaseRequest, "releaseRequest | " &amp; testHeader);
	
	reserveDetail := releaseRequest.allReserveDetails.first;
	self.assertNotNullMsg(reserveDetail, "reserveDetail | " &amp; testHeader);
	
	//Create VVR
	_terminalUTHelper.opts.purge;
	_terminalUTHelper.opts.addAssoc(UT_OPTS_Consignee, _consignee1.code);
	_terminalUTHelper.opts.addAssoc(UT_OPTS_IsMT, true);
	_terminalUTHelper.opts.addAssoc(UT_OPTS_AssertChecks, false);
	_terminalUTHelper.opts.addAssoc(UT_OPTS_IgnoreTrxWarning, false);
	_terminalUTHelper.opts.addAssoc(UT_OPTS_BestPick, true);
	
	vvr := _terminalUTHelper.xCreateGateEntityOutRelease(vvr, null, null,1,releaseRequest);
	
	/*
	** Assert
	*/
	self.assertNoTrxErrorsOrWarnings();
	
	/*
	** Cleanup
	*/
	self.deleteReleaseRequest(UT_ReleaseRequest2);
	
	//Delete previous cargo
	
	vehicleName := UT_TruckId;
	// Delete Vehicle
	self.deleteVehicle(vehicleName);
	
	tiSet.clear;
	
	self.logMessagePw(testHeader &amp; "Finished Test", LogINFO);
	
	/*
	**	Test 2 End - Strict Match Consignee - Cargo matches no error
	*/
	
	/*
	**	Test 3 Start - Strict Match Consignee - Cargo does not match error
	*/
	
	/*
	** Setup
	*/
	testHeader := "MTN-35801 - Test 3 - ";
	self.logMessagePw(testHeader &amp; "Starting Test", LogINFO);
	
	beginTransaction;
	_terminal.setConfig(RelReqConsigneeValidate, ConsigneeStrictMatch);
	app.cmsCommitTransaction(app.myPassport);
	
	vehicleName := UT_TruckId;
	// Delete Vehicle
	self.deleteVehicle(vehicleName);
	
	//Create TI
	ti1 := self.getTrackedItem(UT_ContainerId1);
	if ti1 &lt;&gt; null then
		self.deleteTrackedItem(ti1, true);
		self.assertIsDeletedMsg(ti1, "ti1 | " &amp; testHeader);
	endif;
	
	self.opts.purge;
