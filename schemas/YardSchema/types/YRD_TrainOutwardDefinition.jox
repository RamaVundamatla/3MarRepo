epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBubbleHelp" id="6620560d-4dae-4552-82c5-feb909a5974f">
        <updating/>
        <source>doBubbleHelp(textBox: TextBox input) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 August 2009	cnwndl1	Initial creation

*/

vars

	textString : String;
	intValue : Integer;
	pos : Integer;
	otherEndTextBox : TextBox;
	mess : String;
	
begin

	if textBox = null then
		return;
	endif;
	
	textString := textBox.text.trimBlanks;
	pos := textBox.index;
	if textBox.name = txtRakeLeft1.name then
		otherEndTextBox := self.txtRakeRight1.getControl(pos);
	elseif textBox.name = txtRakeRight1.name then
		otherEndTextBox := self.txtRakeLeft1.getControl(pos);
	endif;
	
	if textString = null then
	
		if clickInteger = 0 then
			
			if otherEndTextBox.text.trimBlanks &lt;&gt; null then
				mess := app.getErrorString1(Click_swap_this_end,otherEndTextBox.text.trimBlanks);
			else
				mess := app.getErrorString1(Click_enter_here,self.getFirstUnusedIntegerString);
			endif;
			
		elseif clickInteger &gt; 0 then
		
			mess := app.getErrorString1(Click_enter_here,self.clickInteger.String);
			
		endif;
		
	else
	
		mess := app.getErrorString1(Click_remove_from_here,textString);
		
	endif;
	
	textBox.bubbleHelp := mess;
	
epilog

end;

</source>
        <access>protected</access>
        <Parameter name="textBox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doKeyUpFromOrderValue" id="390865cc-9815-4bf6-aa86-58e5fee25bbd">
        <updating/>
        <source>doKeyUpFromOrderValue( textBox : TextBox input) protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2009	cnwndl1	Initial creation

*/

vars

	value : String;
	intValue : Integer;
	
begin

	value := textBox.text.trimBlanks;
	if value &lt;&gt; null then
		if value.isInteger then
			intValue := value.Integer;
			if intValue &lt; 1 then
				// must be one or greater.
				textBox.text := null;
				return;
			endif;
			//clear the opposite end of this rake.
			if textBox = self.txtRakeLeft1 then
				self.txtRakeRight1.text := null;
			elseif textBox = self.txtRakeRight1 then
				self.txtRakeLeft1.text := null;
			endif;
			//clear any other order using the same value
			clearSameValue(textBox);
		else
			// must be an integer.
			textBox.text := null;
			return;
		endif;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="textBox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doOK" id="9827f9f6-0ebc-41aa-8bfc-c3e0a1858158">
        <updating/>
        <source>doOK() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2009	cnwndl1	Initial creation

*/

vars
	wagonSequence : CM_WagonArray;
	wagonMoveController : CMIF_WagonMoveController;
	wagon : CM_Wagon;
	result : Integer;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	
begin
	create wagonSequence transient;
	if not validateDetails(wagonSequence) then
		return;
	endif;
	
	create wagonMoveController transient;
	wagonMoveController.myTargetTrain := myTrain;
	wagonMoveController.myTargetRailLine := null;
	wagonMoveController.isInwardTarget := false;
	wagonMoveController.targetPosition := 1;
	foreach wagon in wagonSequence do
		wagonMoveController.allWagons.add(wagon);
	endforeach;
	wagonMoveController.autoSetEffectiveTimeStamp();	//26 Feb 2021	NDL	TFS 50837
	
	app.myPassport.setWarningsIgnored(false);	//18 Dec 2009	NDL Par 22035
	
	//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxMoveWagons(wagonMoveController, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			inheritMethod();
			break;
		else
			theResult := app.showErrorWarningDialog(app.getErrorString(Wagon), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;

epilog

	delete wagonSequence;
	delete wagonMoveController;

end;</source>
    </JadeMethod>
    <JadeMethod name="doOrderMouseClick" id="82d130ed-bdf0-449d-aec7-717310b9b1d4">
        <updating/>
        <source>doOrderMouseClick( textBox : TextBox input ) protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 August 2009	cnwndl1	Initial creation

*/

vars

	textString : String;
	intValue : Integer;
	pos : Integer;
	otherEndTextBox : TextBox;
	
begin

	textString := textBox.text.trimBlanks;
	pos := textBox.index;
	if textBox.name = txtRakeLeft1.name then
		otherEndTextBox := self.txtRakeRight1.getControl(pos);
	elseif textBox.name = txtRakeRight1.name then
		otherEndTextBox := self.txtRakeLeft1.getControl(pos);
	endif;
			
	if textString = null then
		if clickInteger = 0 then
			
			// No existing value in click integer and click empty end, swap value from other end.
			textBox.text := otherEndTextBox.text;
			otherEndTextBox.text := null;

			// if there was nothing in the other end, get the first available unused integer.
			if textBox.text = null then
				textBox.text := self.getFirstUnusedIntegerString();
			endif;
			
		elseif clickInteger &gt; 0 then
			textBox.text := clickInteger.String;
			clickInteger := 0;
			// clear the other end.
			otherEndTextBox.text := null;
			
		endif;
		
	else
		if not textString.isInteger then
			return;
		endif;
		intValue := textString.Integer;
		clickInteger := intValue;
		textBox.text := null;
		
	endif;
	
	self.doBubbleHelp( textBox );
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="textBox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="72bd0147-f099-4703-8ce5-bc5dbe6fc022">
        <updating/>
        <source>doResize() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2009	cnwndl1	Initial creation

*/

vars

	pos : Integer;
	textFits : Boolean;
	
begin

	inheritMethod();
	
	self.grpAllRakes.left := 5;
	
	self.grpRake1.width := self.grpAllRakes.width - 6;
	foreach pos in 1 to self.cloneSize do
		self.grpRake1.getControl(pos).width := self.grpRake1.width;
	endforeach;	
	
	resizeOfRakeLabel(); 
	
	self.grpAllRakes.height := self.grpRake1.getControl(self.cloneSize).top + self.grpRake1.getControl(self.cloneSize).height + 4;
	
	if self.grpNoRake.visible then
		self.lblNoRake.width := self.lblRake1.width + 38;
		self.txtWagonsNoRake.left := self.txtWagons1.left;
		self.txtWagonsNoRake.width := self.txtWagons1.width;
		self.grpNoRake.left := self.grpRake1.left + self.grpAllRakes.left;
		self.grpNoRake.width := self.grpRake1.width;
		self.grpNoRake.top := self.grpAllRakes.height + self.grpAllRakes.top + 2;
		self.minimumHeight := (self.grpAllRakes.height + self.grpNoRake.height + self.grpAllRakes.top + 70).Integer;
	else
		self.minimumHeight := (self.grpAllRakes.height + self.grpAllRakes.top + 70).Integer;
	endif;
	
	while not textFits do
		textFits := self.setWagonDisplayText();
		if not textFits then
			self.resize;
		endif;
	endwhile;
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getControlsForPosition" id="508d69fe-8c55-40f5-bda1-176710558a79">
        <source>getControlsForPosition( _pos : Integer;
						_grpRake : CMUI_GroupBox output;
						_lblRake : CMUI_Label output;
						_txtRakeLeft : CMUI_TextBox output;
						_txtRakeRight : CMUI_TextBox output;
						_txtRakeWagons : CMUI_TextBox output;
						_wagonArray : ObjectArray output
						) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 August 2009	cnwndl1	Initial creation

*/

vars

begin

	if _pos &lt; 1 then
		_grpRake := null;
		_lblRake := null;
		_txtRakeLeft := null;
		_txtRakeRight := null;
		_txtRakeWagons := null;
		_txtRakeWagons := null;
		_wagonArray := null;
	else
		_grpRake := self.grpRake1.getControl(_pos);
		_lblRake := self.lblRake1.getControl(_pos);
		_txtRakeLeft := self.txtRakeLeft1.getControl(_pos);
		_txtRakeRight := self.txtRakeRight1.getControl(_pos);
		_txtRakeWagons := self.txtWagons1.getControl(_pos);
		_wagonArray := self.allRakesWagonsArrays[_pos].ObjectArray;
	endif;
	
	
epilog

end;
</source>
        <access>protected</access>
        <Parameter name="_pos" type="Integer"/>
        <Parameter name="_grpRake" type="CMUI_GroupBox" usage="output"/>
        <Parameter name="_lblRake" type="CMUI_Label" usage="output"/>
        <Parameter name="_txtRakeLeft" type="CMUI_TextBox" usage="output"/>
        <Parameter name="_txtRakeRight" type="CMUI_TextBox" usage="output"/>
        <Parameter name="_txtRakeWagons" type="CMUI_TextBox" usage="output"/>
        <Parameter name="_wagonArray" type="ObjectArray" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getFirstUnusedIntegerString" id="54ae798c-e769-4df8-a73f-03fefbdbd256">
        <source>getFirstUnusedIntegerString():String protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 August 2009	cnwndl1	Initial creation

*/

vars
	pos : Integer;
	usedIntegers : IntegerArray;
	int : Integer;
begin
	create usedIntegers transient;
	
	foreach pos in 1 to self.cloneSize do
		int := self.txtRakeLeft1.getControl(pos).text.Integer;
		if int &gt; 0 then
			if not usedIntegers.includes(int) then
				usedIntegers.add(int);
			endif;
		endif;
		int := self.txtRakeRight1.getControl(pos).text.Integer;
		if int &gt; 0 then
			if not usedIntegers.includes(int) then
				usedIntegers.add(int);
			endif;
		endif;
	endforeach;
	
	foreach int in 1 to self.cloneSize do
		if not usedIntegers.includes(int) then
			return int.String;
		endif;
	endforeach;
	
	return null;
epilog
	delete usedIntegers;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSubstituteText" id="305802a3-115b-400c-a0a3-8e0b99515d30">
        <updating/>
        <source>getSubstituteText(	_textBox : TextBox;
					_wagonArray : ObjectArray;
					_wagonText : String io;
					_textLength : Integer
					):Boolean protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 August 2009	cnwndl1	Initial creation

*/
constants
	JoinerString : String = "  --&gt;  ";
vars
	textLength : Integer;
	firstWagonText : String;
	lastWagonText : String;
	minSubstituteText : String;
	maxSubstituteText : String;
	obj : Object;
	firstWagon : CM_Wagon;
	lastWagon : CM_Wagon;
	localWagonArray : ObjectArray;
	doStart : Boolean;
	wagon : CM_Wagon;
	
begin

	textLength := _textLength;
	
	//find first wagon text
	firstWagon := _wagonArray.first.CM_Wagon;
	lastWagon := _wagonArray.last.CM_Wagon;
	firstWagonText := firstWagon.id;
	lastWagonText := lastWagon.id;
	if firstWagon = lastWagon then
		minSubstituteText := firstWagonText;
	elseif _wagonArray.size = 2 then
		minSubstituteText := firstWagonText &amp; ", " &amp; lastWagonText;
	else
		minSubstituteText := firstWagonText &amp; JoinerString &amp; lastWagonText;
	endif;
	_wagonText := minSubstituteText;
	
	textLength := _textBox.getTextExtent(minSubstituteText);
	if textLength &gt;= _textBox.width then
		// we can't even fit the minimum display value, make the form wider
		self.width := ( self.width + (( textLength - _textBox.width ) + 10 ) ).Integer;
		self.minimumWidth := ( self.minimumWidth + (( textLength - _textBox.width ) + 10 ) ).Integer;
		return false;
	endif;
	
	create localWagonArray transient;	
	foreach obj in _wagonArray do
		if obj = firstWagon then
			continue;
		endif;
		if obj = lastWagon then
			continue;
		endif;
		localWagonArray.add(obj);
	endforeach;
	
	if localWagonArray.isEmpty then
		_wagonText := minSubstituteText;
		return true;
	endif;
	
	maxSubstituteText := minSubstituteText;	// default value.
	
	while true do
		if localWagonArray.isEmpty then
			// no more wagons to display
			break;
		endif;
		doStart := not doStart;
		if doStart then
			wagon := localWagonArray.first.CM_Wagon;
			firstWagonText := firstWagonText &amp; ", " &amp; wagon.id;
			localWagonArray.remove(wagon);
		else
			wagon := localWagonArray.last.CM_Wagon;
			lastWagonText := wagon.id &amp; ", " &amp; lastWagonText;
			localWagonArray.remove(wagon);
		endif;
		textLength := _textBox.getTextExtent(firstWagonText &amp; JoinerString &amp; lastWagonText);
		if textLength &lt; _textBox.width then
			maxSubstituteText := firstWagonText &amp; JoinerString &amp; lastWagonText;
		else
			// another wagon would make it too long.
			break;
		endif;
	endwhile;
	
	_wagonText := maxSubstituteText;
	return true;
		
epilog
	
	delete localWagonArray;
	
end;</source>
        <access>protected</access>
        <Parameter name="_textBox" type="TextBox"/>
        <Parameter name="_wagonArray" type="ObjectArray"/>
        <Parameter name="_wagonText" type="String" usage="io"/>
        <Parameter name="_textLength" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadData" id="963dd11e-b0db-434b-90be-bff89aa60e55">
        <updating/>
        <source>loadData() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2009	cnwndl1	Initial creation

*/

vars

	allLines : DynaDictionary;
	wagon : CM_Wagon;
	railLine : CM_RailLine;
	rail : CM_Rail;
	id : String;
	obj : Object;
	pos : Integer;
	grpRake : CMUI_GroupBox;
	lblRake : CMUI_Label;
	txtRakeLeft : CMUI_TextBox;
	txtRakeRight : CMUI_TextBox;
	txtRakeWagons : CMUI_TextBox;
	rakeWagons : ObjectArray;
	wagonDisplay : String;

begin

	create allLines transient;
	allLines.setMembership(CM_RailLine);
	allLines.addExternalKey(String, 43, false, false);
	allLines.endKeys(false);
			
	foreach wagon in self.myTrain.allWagonsByOrderOutward do
		railLine := wagon.myRailLine;
		if railLine &lt;&gt; null then
			rail := railLine.myRailArea;
			if rail &lt;&gt; null then
				id := railLine.id &amp; " " &amp; rail.id;
				if allLines.getAtKey(id) = null then
					allLines.putAtKey(id,railLine);
				endif;
			endif;
		endif;
	endforeach;
	
	self.cloneSize := allLines.size;
	self.addClonedControls();
	
	pos := 0;
	foreach obj in allLines do
		pos := pos + 1;
		self.getControlsForPosition(pos, grpRake, lblRake, txtRakeLeft, txtRakeRight, txtRakeWagons, rakeWagons);
		
		railLine := obj.CM_RailLine;
		rail := railLine.myRailArea;
		
		grpRake.visible := true;
		lblRake.caption := rail.id &amp; " " &amp; railLine.id;
		
		wagonDisplay := null;
		foreach wagon in railLine.allWagons do
			if not CM_Wagon.hasInstance(wagon) then
				continue;
			endif;
			if wagon.myTrainOutwards &lt;&gt; self.myTrain then
				continue;
			endif;
			rakeWagons.add(wagon);
			if wagonDisplay = null then
				wagonDisplay := wagon.id;
			else
				wagonDisplay := wagonDisplay &amp; ", " &amp; wagon.id;
			endif;
		endforeach;
		txtRakeWagons.text := wagonDisplay;
		wagonDisplayArray[pos] := wagonDisplay[1:512];
		
		txtRakeLeft.text := pos.String;
		txtRakeRight.text := null;
		
	endforeach;
	
	//setup no rake wagons
	wagonDisplay := null;
	foreach wagon in myTrain.allWagonsByOrderOutward do
		if not CM_Wagon.hasInstance(wagon) then
			continue;
		endif;
		if wagon.myRailLine &lt;&gt; null then
			continue;
		endif;
		self.noRakeWagons.add(wagon);
		if wagonDisplay = null then
			wagonDisplay := wagon.id;
		else
			wagonDisplay := wagonDisplay &amp; ", " &amp; wagon.id;
		endif;
	endforeach;
	txtWagonsNoRake.text := wagonDisplay[1:512];
	noRakeDisplay := wagonDisplay;
	grpNoRake.visible := not self.noRakeWagons.isEmpty;
	
	if not self.setWagonDisplayText() then
		self.doResize;
	endif;
	
epilog

	delete allLines;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="resizeOfRakeLabel" id="b0779fc3-4e44-4fde-8a3d-112beaf4cc42">
        <updating/>
        <source>resizeOfRakeLabel() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 September 2009	cnwndl1	Initial creation

*/

vars

	minWidth : Integer;
	pos : Integer;
	lblRake : CMUI_Label;
	captionLength : Integer;
	txtRakeLeft : CMUI_TextBox;
	txtWagons : CMUI_TextBox;
	txtRakeRight : CMUI_TextBox;
	
begin

	// find the minimum width of the rake label based on the current text
	if not self.noRakeWagons.isEmpty then
		minWidth := 113;
	endif;
	
	foreach pos in 1 to self.cloneSize do
		lblRake := self.lblRake1.getControl(pos);
		captionLength := lblRake.getTextExtent(lblRake.caption);
		if captionLength &gt; minWidth then
			minWidth := captionLength;
		endif;
	endforeach;
	
	// set the labels and re-position the other controls relative to this.
	minWidth := minWidth + 10;	
	foreach pos in 1 to self.cloneSize do
		lblRake := self.lblRake1.getControl(pos);
		lblRake.width := minWidth;
		txtRakeLeft := self.txtRakeLeft1.getControl(pos);
		txtRakeLeft.left := lblRake.left + minWidth + 10;
		txtWagons := self.txtWagons1.getControl(pos);
		txtWagons.left := txtRakeLeft.left + txtRakeLeft.width + 15;
		txtWagons.width := grpRake1.width - ( txtWagons.left + 35 );
		txtRakeRight := self.txtRakeRight1.getControl(pos);
		txtRakeRight.left := self.grpRake1.width - 27;
	endforeach;
	
	lblOrderLeft.left := minWidth + lblRake1.left + grpRake1.left + 8;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setWagonDisplayText" id="c41e2d11-7414-4273-8347-7ad12f945cb7">
        <updating/>
        <source>setWagonDisplayText():Boolean updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 August 2009	cnwndl1	Initial creation

*/

vars
	pos : Integer;
	wagonText : String;
	wagonArray : ObjectArray;
	textBox : TextBox;
	textLength : Integer;
	resize : Boolean;
	marginForError : Integer;
begin

	marginForError := 0;

	foreach pos in 1 to cloneSize do
		textBox := self.txtWagons1.getControl(pos);
		wagonText := self.wagonDisplayArray[pos];
		textLength := textBox.getTextExtent(wagonText) + marginForError; 
		if textLength &gt;= textBox.width then
			wagonArray := allRakesWagonsArrays[pos].ObjectArray;
			if not getSubstituteText( textBox, wagonArray, wagonText, textLength ) then
				resize := true;
			endif;
		endif;
		textBox.text := wagonText;
	endforeach;
	
	if self.noRakeDisplay.trimBlanks &lt;&gt; null then
		textBox := self.txtWagonsNoRake;
		wagonText := self.noRakeDisplay.trimBlanks;
		textLength := textBox.getTextExtent(wagonText) + marginForError; 
		if textLength &gt;= textBox.width then
			wagonArray := noRakeWagons;
			if not getSubstituteText( textBox, wagonArray, wagonText, textLength ) then
				resize := true;
			endif;
		endif;
		textBox.text := wagonText;
	endif;
	
	return not resize;
	
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="c4ac8063-d70e-4402-bc25-836b8847b4fa">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2009	cnwndl1	Initial creation

*/

vars

	captString : String;
	
begin

	captString := app.getErrorString(Outward_wagon_order_definit) &amp; " - " &amp; self.myTrain.code &amp; " " &amp; self.myTrain.getConfirmedStatus(true) &amp; "";
	self.caption := captString;
	self.width := self.minimumWidth;
	self.height := self.minimumHeight;
	self.centreOverParent(10);
	
	self.btnOk.caption := app.getErrorString(SAVE_THAT_LADY_YO);
	
	
	inheritMethod();
	
	self.loadData();
	self.doResize();


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="c3ef722e-2cf4-4780-80e6-b91d0677943e">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 10 August 2018 13:35:17.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022889, locale);
	cMUI_Label11.translateCaption(Xlat_0012685, locale);
	lblNoRake.translateCaption(Xlat_0012686, locale);
	lblOrderLeft.translateCaption(Xlat_0012687, locale);
	lblOrderRight.translateCaption(Xlat_0012688, locale);
	lblRake1.translateCaption(Xlat_0012689, locale);
end;</source>
    </JadeMethod>
