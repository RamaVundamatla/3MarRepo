    <DbClassMap file="jssxs_datavalue_range"/>
    <ImplicitInverseRef name="myTimeFrom" id="9647e3fb-88be-4cb4-9967-8d4e531e2b36">
        <embedded/>
        <type name="JSSTime"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myTimeTo" id="3cc62a23-6813-4dd2-b5be-35da717ae94c">
        <embedded/>
        <type name="JSSTime"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="getTimeFrom" id="3265d197-db20-4ffe-bf2d-f94fbf5aa002">
        <source>getTimeFrom():Time;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myTimeFrom.timeClient;
end;</source>
        <ReturnType type="Time"/>
    </JadeMethod>
    <JadeMethod name="getTimeTo" id="79cb778b-81ab-420a-99da-1bde13fc9def">
        <source>getTimeTo():Time;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myTimeTo.timeClient;
end;</source>
        <ReturnType type="Time"/>
    </JadeMethod>
    <JadeMethod name="setTimeFrom" id="5b814c3d-c7ae-45c2-ac8e-415d26821f99">
        <updating/>
        <source>setTimeFrom(pTimeFrom:JSSTime) updating;
// --------------------------------------------------------------------------------
// Created:		16 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.validateRange(pTimeFrom.timeClient, self.myTimeTo.timeClient) then
		self.myTimeFrom	:=	pTimeFrom;
	endif;
end;</source>
        <Parameter name="pTimeFrom" type="JSSTime"/>
    </JadeMethod>
    <JadeMethod name="setTimeTo" id="60e0b9f1-d63f-4dcf-b928-15988b82ba77">
        <updating/>
        <source>setTimeTo(pTimeTo:JSSTime) updating;
// --------------------------------------------------------------------------------
// Created:		16 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.validateRange(self.myTimeFrom.timeClient, pTimeTo.timeClient) then
		self.myTimeTo	:=	pTimeTo;
	endif;
end;</source>
        <Parameter name="pTimeTo" type="JSSTime"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="21b19260-897b-482b-812e-fd406ce61a1a">
        <updating/>
        <source>updateMe(pTimeFrom:JSSTime; pTimeTo:JSSTime) updating;
// --------------------------------------------------------------------------------
// Created:		16 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.setTimeTo(pTimeTo);
	self.setTimeFrom(pTimeFrom);
end;</source>
        <Parameter name="pTimeFrom" type="JSSTime"/>
        <Parameter name="pTimeTo" type="JSSTime"/>
    </JadeMethod>
</Class>
