    <JadeMethod name="isClosedOrDeparted" id="05498ade-6f3f-4f30-b763-e8a9d6559824">
        <source>isClosedOrDeparted() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Dec 2023	jlier1	Initial creation 61676
11 Jul 2024	jlier1	TFS  65130- changed from looking at departed dates to departed status
*/

vars

begin
	if self.isStatusDeparted then
		return true;
	endif;
	
	if self.status = Voyage_Status_LoadComplete or
	   self.status = Voyage_Status_Closed or 
	   self.status = Voyage_Status_EUP_Closed or	
	   self.status = Voyage_Status_EUP_Complete then
		return true;
	endif;
	
	return false;
epilog

end;</source>
