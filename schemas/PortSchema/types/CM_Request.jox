    <JadeMethod name="getBulkRelease" id="753d599b-89cd-424e-a674-81319bb80457">
        <source>getBulkRelease(): CM_BulkRelease;

vars
	reserveDetail : CM_ReserveDetail;
	bulkRelease : CM_BulkRelease;
	invalidObj 	: Boolean;
begin
	//epr par 31881 5/11/13
	on Exception do app.handleDeletedObject(exception,reserveDetail,invalidObj);
	
	reserveDetail:=self.getBulkReleaseReserveDetail;
	if reserveDetail = null then
		return null;
	endif;
	
	bulkRelease:=reserveDetail.myReserveHeader;
	
	if invalidObj then
		return null;
	endif;
	
	return bulkRelease;
end;
</source>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
