        <source>doClearCurrentYA() updating;

/*

Purpose:		Clears the current Yard Allocation and its proxy object.	

Parameters:			

Return Value:		


Date			Who		Reason
05 August 2008	consw1	Initial creation

*/

begin
	delete self.myProxyYA;
	self.allTemplateCriteria.purge();
	self.isTemplateModified := false;
	self.myYardAllocation := null;
end;</source>
