    <JadeMethod name="handleCMExceptionUserObject" id="67d9cbe0-f451-4e89-b156-e4bf18e519ff">
        <source>handleCMExceptionUserObject(_exception :CM_Exception input; _context :Object):Integer;
/*
Date		Who		Reason
22/05/2012	cnwcs5	Initial creation - par 29583 - setting context for EDI errors
14/9/2016  cnwer1	TFS 2606 moved from CM_EDIDAta to reuse
*/
vars

begin 
	if _context = null then
		// nothing to do
		return Ex_Pass_Back;
	endif;
	// change the myUserObject property on the error 
	_exception.setUserObject (_context);
	
	return Ex_Pass_Back;

epilog

end;</source>
        <Parameter name="_exception" type="CM_Exception" usage="input"/>
        <Parameter name="_context" type="Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleDecode1420Exc" id="b4977513-960a-41de-b0b6-8e622597d800">
        <source>handleDecode1420Exc( _exObj : Exception; _was1420 : Boolean output ) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2021	navndl1	Initial creation	TFS 51632

*/

vars

	returnVal : Integer;

begin
	
	returnVal := Ex_Pass_Back;
	
	if _exObj.errorCode = 1420 then
		_was1420 := true;
		if _exObj.resumable then
			returnVal := Ex_Resume_Next;
		endif;
	endif;
	
	return returnVal;

epilog

end;</source>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_was1420" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleDeletedObject" id="35b67a5f-8920-4587-a893-047e1bf4ae79">
        <source>handleDeletedObject(_exc : Exception; _obj : Object; _invalidObject : Boolean io) : Integer;

/*

Purpose:			General exception handler to deal with invalid object references.  Needs to be
					armed with a specific object reference to be checked.


Return Value:		Standard Exception return codes, and _invalidObject set to true if
					the specified object reference caused the exception.


Date		Who		Reason
18 Mar 2008	cnwkpd1	PAR #16195 - Allow generic handling of invalid objects
03 Jun 2008	cnwkpd1	PAR #16718 - handle exclusive collection exceptions as well, as there are
					situations where an exclusive collection on the object we are interested in
					will be the error object in the exception
21 May 2009	cnwkpd1	Change to use new JADE Object::getOwnerForObject method
04 Feb 2011	cnwkpd1	PAR #27142 - Added code to handle null _obj, to protect against incorrect
					arming and therefore invalid resume for standard objects (with no owner)
					
*/

constants
	ObjectNotFound	= 4;
	ObjectDeleted	= 1072;
	InvalidClass	= 1046;
	
vars
	returnVal		: Integer;
	
begin
	returnVal := Ex_Pass_Back;
	
	// PAR #27142 - if the handler has been armed for a local variable that has not yet been
	// initialised when the exception occurs, then it is not for us, so just pass back immediately
	if _obj = null then				
		return returnVal;
	endif;
	
	if _exc.errorCode = ObjectNotFound or _exc.errorCode = ObjectDeleted or _exc.errorCode = InvalidClass then
		if _exc.errorObject = _obj or self.getOwnerForObject(_exc.errorObject) = _obj then
			// Set _invalidObject, and resume in the calling method, which will then
			// interrogate excOccurred, to identify an invalid/deleted object
			_invalidObject := true;
			if _exc.resumable then
				returnVal := Ex_Resume_Next;
			endif;
		endif;
	endif;


epilog
	return returnVal;
	
end;</source>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_invalidObject" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleDeletedObjectReferences" id="d5e60e7f-e483-4a4f-8db3-45cc6764df6b">
        <source>handleDeletedObjectReferences(_exc : Exception; _obj : Object) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 December 2018	jlger1	Initial creation

*/

constants
	ObjectNotFound	= 4;
	ObjectDeleted	= 1072;
	InvalidClass	= 1046;
	
vars
	returnVal		: Integer;
	prop : Property;
	props : PropertyNDict;
	obj : Object;
begin
	returnVal := Ex_Pass_Back;
	
	// PAR #27142 - if the handler has been armed for a local variable that has not yet been
	// initialised when the exception occurs, then it is not for us, so just pass back immediately
	if _obj = null then				
		return returnVal;
	endif;
	
	if _exc.errorCode = ObjectNotFound or _exc.errorCode = ObjectDeleted or _exc.errorCode = InvalidClass then
		if _exc.errorObject = _obj or self.getOwnerForObject(_exc.errorObject) = _obj then
			//if the object is deleted passback
			return returnVal;
		else
			//get all obj refences that are not inversed
			props:=_obj.class.getProperties;
			foreach prop in props  discreteLock do
				if prop.isKindOf(ImplicitInverseRef) then
					if prop.ImplicitInverseRef.memberTypeInverse = false then
						obj:=_obj.getPropertyValue(prop.name).Object;
						if _exc.errorObject = obj or self.getOwnerForObject(_exc.errorObject) = obj then
							if _exc.resumable then
								returnVal := Ex_Resume_Next;
							endif;
						endif;
					endif;
				endif;
			endforeach;
		endif;
	endif;


epilog
	return returnVal;

end;</source>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleEdiEmailException" id="99d646ee-18c5-4fbf-b8a0-938cc6038b36">
        <updating/>
        <source>handleEdiEmailException(_exObj		: Exception; 
						_exOccurred : Boolean output) : Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Nov 2021 navma1	Bug 52192: MTN - OAUTH EMail Receive 14576 UEs

*/

vars
	returnVal		: Integer;
begin
	
	returnVal := Ex_Pass_Back;
	
	if  _exObj.errorCode = 1416  or    //1416 : Unicode to Ansi conversion failed
		_exObj.errorCode = 5012  or    // 5012 : Unicode to Ansi conversion failed)  
		_exObj.errorCode = 14575  or   //14576 : Error during conversion between Jade and .NET types	
	    _exObj.errorCode = 14576  then //14576 : Error in .NET object during member call	
		_exOccurred := true;
		returnVal := Ex_Resume_Next;
	endif;
epilog
	
	return returnVal;
end;</source>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_exOccurred" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleEmailAlertException" id="605cd423-9c6d-4560-85ef-bd7f97f073c2">
        <source>handleEmailAlertException(_exc : CM_Exception) : Integer protected;

/*

Purpose:			Handle email validation errors from Alert Type email functionality

Parameters:			Exception

Return Value:		Exception return code


Date		Who		Reason
27 May 2010	cnwkpd1	CCMS 1871 - OMAR changes

*/

vars

begin
	// Nothing we can do, so just log the details of the exception, and resume next
	app.writeLog("Exception " &amp; _exc.errorCode.String &amp; " " &amp; _exc.errorItem &amp; " " &amp; _exc.extendedErrorText, LogINFO);
	
	return Ex_Resume_Next;
	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="CM_Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleEndNotification1066" id="835ac54c-cc92-401a-9fd4-08bd50edf46f">
        <source>handleEndNotification1066( _exObj : SystemException ) : Integer;

/*
Purpose:		Handle the system error you get when attempting to end the notification on an
				object identified (oid) that has no matching begin notification or the target is null.
Parameters:		Exception
Return Value:	Exception return code

Date			Who		Reason
09 August 2010	cnwrl1	Initial creation as part of PAR 24377 - UE 4 from CM_LoadListComparisonAgent.
*/

constants
	EndWithNoMatchingBeginNotify = 1066;				// Notification not set for this OID
	
vars
	
begin
	if _exObj.errorCode = EndWithNoMatchingBeginNotify then
		// ignore this error and continue in the method which has armed this exception handler.
		return Ex_Resume_Next;
	endif;
	
	return Ex_Pass_Back;		// let another handler deal with it
	
epilog
	
end;
</source>
        <Parameter name="_exObj" type="SystemException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleException11052" id="99a0d3fc-f1f1-40fb-b6e2-06a094923a74">
        <source>handleException11052( _exObj : Exception; _was11052 : Boolean output ) : Integer;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 07 October 2022
TFS#		: 54892
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars

	returnVal : Integer;

begin
	
	returnVal := Ex_Pass_Back;
	
	if _exObj.errorCode = 11052 then
		_was11052 := true;
		if _exObj.resumable then
			returnVal := Ex_Resume_Next;
		endif;
	endif;
	
	return returnVal;

epilog

end;</source>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_was11052" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleInvalidJSONException" id="81e7e663-7f6b-46e8-8eab-5ec627824d46">
        <updating/>
        <source>handleInvalidJSONException(ex: Exception input; _exAction : Integer; _escapedText : String output):Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Aug 2025	navnk30	JIRA 35197: CUX - API PUT /voyage response with invalid escaped double quote text

*/

vars

begin
 	if ex.errorCode = 11122 then
		self.escapeJsonForEmbedding(ex.extendedErrorText);
		_escapedText := ex.extendedErrorText;
		return _exAction;
	endif;

	// return to the standard exception handling routine
	return Ex_Pass_Back;
epilog

