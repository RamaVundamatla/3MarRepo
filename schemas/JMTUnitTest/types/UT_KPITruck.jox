    <JadeMethod name="iTruckKPI" id="acb9dcfb-cc64-4785-8418-00d2fd256d4d">
        <source>iTruckKPI();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Jan 2026	navbs1	Initial creation Story MTN-36661: MTN | KPI REST API - Truck Turn Around

*/

vars
	params,
	queryParams,
	response			: String;
	expectErrors		: Boolean;
	
begin

	params := "/truckKPI";
	queryParams := params &amp; "?MasterTerminalAPI=true&amp;startDate=2025-11-20&amp;endDate=2026-01-20&amp;includeCarrier=true&amp;accrualType=1&amp;includeCargo=true&amp;includeDetail=true";
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTGetTruckKPI.name,queryParams,params,response,expectErrors);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="uCreateBBVVRs" id="7b432078-3f62-4e30-b731-29bee070f9e6">
        <source>uCreateBBVVRs(_carrierCode : String; truckID: String; cargoId :String; daysBack: Integer; duration :Integer);
/*
 
Purpose:			
 
Parameters:			
 
Return Value:		
 
Date		Who		Reason
21 Jan 2026	navbs1	Initial creation Story MTN-36661: MTN | KPI REST API - Truck Turn Around
 
*/
 
constants
	REF					: String = "36661";
	Cargo_Type			: String = "BB";

vars
	cargoTypeObj		: CM_CargoType;
	preCargo 			: CM_TrackedItem;
	ifArray				: CMIF_TIObjectArray;
	ifPreNote			: CMIF_PreNote;
	truck				: CM_Vehicle;
	bs1 				: CM_BlockStack;
	vvr 				: CM_VehicleVisitRecord;
	cmif 				: CMIF_KPITruckTurnaround;
	myCarrier 			: CM_Carrier;
	email 				: CM_EmailEntityByTypeNameDict;
	truckId				: String;
begin
	create ifArray transient;
	create ifPreNote transient;	
	//create bbk cargo type with allow duplicates
	cargoTypeObj	:=	app.myRoot.getCargoTypeFromAbbrev(REF &amp; Cargo_Type);
	//cargoTypeObj := self.addCargoType(REF &amp; Cargo_Type, false);
	//bs1:=self.addBlockStack(REF &amp; "BS",999,null);
 
	self.deleteAllCargo(cargoId,cargoTypeObj);
	ifPreNote.id := cargoId;
	ifPreNote.myTerminal := self.getTerminal;
	ifPreNote.cargoType := cargoTypeObj.id;
	ifPreNote.imExStatus := getRoot.allImexStatuses[TI_IMEX_STATUS_STORAGE];
	ifPreNote.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	ifPreNote.transportMode := TI_TRANSMODE_ROAD_STR;
	ifPreNote.numberOfItems :=100;
	ifArray.add(ifPreNote);
	self.ignoreTrxWarnings(true);
	app.myTrxCA.trxCreatePreNotes(ifArray, false, app.myPassport);
	self.assertNoTrxErrorsOrWarnings;
	preCargo := self.getTerminal.lookupTrackedItem(ifPreNote.id, cargoTypeObj.id, TI_STATE_NOTIFIED, null, false);
 
	self.assertNotNull(preCargo);
	self.assertEqual(preCargo.totalQuantity,100);
	self.assertEqual(preCargo.state,TI_STATE_NOTIFIED);
	self.assertNotNull(preCargo.myPinNo);
	
	//create email transient;	
	//myCarrier := self.addCarrier ("Carrier1", "Carrier1", email, false, true, true, null);
	
	self.deleteVehicle(truckID);

	self.opts.purge();
	//self.opts.addAssoc('Carrier',myCarrier.code);
	self.opts.addAssoc('Carrier',_carrierCode);
	self.opts.addAssoc('RetroDT', app.actualTimeServer().addDays(-daysBack));
	vvr := self.gateInGC(truckID,null,truckID,preCargo.id,cargoTypeObj.description,self.getProfileSetting(UT_Profile.P_OPERATOR).asString,null,self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString),100);
	truck := self.getVehicle(truckID);
	
	self.assertNotNull(truck);
	self.workVehicle(vvr);
	
	self.opts.purge();
	self.opts.addAssoc('RetroDT', app.actualTimeServer().addDays(-daysBack).addMinutes(duration));
	self.roadExit(vvr);
	
	create cmif transient;
	cmif.myTerminal := self.getMyTerminal;
	cmif.setMyVehicleVisit(vvr);
	cmif.processKPI();
epilog
	delete ifArray;
	delete ifPreNote;
	delete cmif;
	delete email;
	
end;</source>
        <Parameter name="_carrierCode" type="String"/>
        <Parameter name="truckID" type="String"/>
        <Parameter name="cargoId" type="String"/>
        <Parameter name="daysBack" type="Integer"/>
        <Parameter name="duration" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="uCreateContVVRs" id="0b295c41-11d7-46fb-8419-6becb7269511">
        <source>uCreateContVVRs();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Jan 2026	navbs1	Initial creation Story MTN-36661: MTN | KPI REST API - Truck Turn Around

*/

constants

	Prenote1Id					: String = "UTMDHYBPRE1";
	CarrierId					: String = "UTMHCAR";
	CarrierDesc					: String = "UT MDH Carrier";
	VehicleId					: String = "UTMDH1";
	REF							: String = "36661";
	
vars
	vvr 						: CM_VehicleVisitRecord;
	operator					: CM_Operator;
	cargoType					: CM_CargoType;
	carrier						: CM_Carrier;
	ti							: CM_TrackedItem;	
	pinEmailAddresses			: CM_EmailEntityByTypeNameDict;
	cmif 						: CMIF_KPITruckTurnaround;
		
begin
	self.deleteTrackedItem(self.getTrackedItem(Prenote1Id), false);

	

	// get the operator;
	operator := app.myRoot.allOperators[self.getProfileSetting(UT_Profile.P_OPERATOR).asString].CM_Operator;
	self.assertNotNull(operator);
	
	// get the cargo type
	cargoType := app.myRoot.allCargoTypesById[TI_CargoType_Container];
	self.assertNotNull(cargoType);
	

	// set up the vehicle
	self.deleteVehicle(VehicleId);
	create pinEmailAddresses transient;
	carrier := self.addCarrier(CarrierId, CarrierDesc, pinEmailAddresses, false, false, true, null);
	self.assertNotNull(carrier);	
	
	// gate in the container
	self.opts.purge();
	self.opts.addAssoc('RetroDT', app.actualTimeServer().addDays(-10));
	self.opts.addAssoc('Carrier',carrier.code);
	vvr := self.gateInContainer(VehicleId, Prenote1Id, "2200", operator.code, "MT", self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString));
	self.assertNotNull(vvr);
	self.workVehicle(vvr);
	
	
	ti := self.getTrackedItem(Prenote1Id);
	self.assertNotNull(ti);
	
	self.opts.purge();
	self.opts.addAssoc('RetroDT', app.actualTimeServer().addDays(-10).addMinutes(60));
	self.roadExit(vvr);
	
	create cmif transient;
	cmif.myTerminal := self.getMyTerminal;
	cmif.setMyVehicleVisit(vvr);
	cmif.processKPI();

epilog

	delete pinEmailAddresses;
	delete cmif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="uMain" id="2ef12e91-2b8e-4efb-a413-7e5992136856">
        <source>uMain();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Jan 2026	navbs1	Initial creation Story MTN-36661: MTN | KPI REST API - Truck Turn Around

*/
constants
	REF							: String = "36661";
	Carrier1Id					: String = REF&amp;" car1";
	Carrier2Id					: String = REF&amp;" car2";
	Cargo_Type					: String = "BB";
vars
	
	pinEmailAddresses			: CM_EmailEntityByTypeNameDict;
	carrier1,
	carrier2 					: CM_Carrier;
	cargoTypeObj				: CM_CargoType;
begin
	//create 2 carriers 
	create pinEmailAddresses transient;
	deleteCarrier(Carrier1Id);
	deleteCarrier(Carrier2Id);
	cargoTypeObj := self.addCargoType(REF &amp; Cargo_Type, false);
	carrier1 := self.addCarrier(Carrier1Id, "Carrier1Desc", pinEmailAddresses, false, false, true, null);
	carrier2 := self.addCarrier(Carrier2Id, "Carrier1Desc", pinEmailAddresses, false, false, true, null);
	uCreateBBVVRs(carrier1.code,"TR1_36661",REF&amp;"BBCargo1",10,60);
	uCreateBBVVRs(carrier2.code,"TR2_36661",REF&amp;"BBCargo2",10,70);
	uCreateBBVVRs(carrier1.code,"TR3_36661",REF&amp;"BBCargo3",10,80);
	uCreateBBVVRs(carrier2.code,"TR4_36661",REF&amp;"BBCargo4",10,90);
	
		
epilog
	delete pinEmailAddresses;
end;</source>
    </JadeMethod>
</Class>
