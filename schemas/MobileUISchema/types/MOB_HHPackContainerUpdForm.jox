    <JadeMethod name="loadTblCargo" id="3c174000-318d-4004-a16e-70ac562d3bc5">
        <updating/>
        <source>loadTblCargo() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

	entTableRow : EntTableRow;
	rowIndex : Integer;
	dataValue : String;
	numValue : Integer;
	errMsg : String;
	
begin

	//load up combos used in table
	self.populateCombos();

	// load raw strings into table
	foreach entTableRow in self.myEntTableView.allEntTableRows do

		rowIndex := tblCargo.getRow(entTableRow.name);
		if rowIndex &lt; 1 then
			continue;
		endif;
		
		dataValue := self.getDataFromObject( entTableRow, errMsg );
		
		if entTableRow.myEntTableCellControl &lt;&gt; null then
			if entTableRow.myEntTableCellControl.isKindOf(EntTableTextNumeric) then
				numValue := dataValue.Integer;
				self.tblCargo.setCellText(rowIndex, 2, numValue.String);
				continue;
			endif;
		endif;

		self.tblCargo.setCellText(rowIndex, 2, dataValue);
				
	endforeach;
		
	self.setComboValues();
	
epilog


end;</source>
    </JadeMethod>
    <JadeMethod name="populateCombos" id="7e44f11c-e5b0-407a-a62e-fcc364dd0601">
        <source>populateCombos();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

	commodity : CM_Commodity;
	voyage : CM_Voyage;
	port : CM_Port;
	imex : CM_IMEXStatus;
	cargoType : CM_CargoType;
	
	beforeCommodity : CM_Commodity;

begin

	self.cmbVoyage.clear();
	self.myMobileGenericAgent.setCurrentVoyages();
	foreach voyage in self.myMobileGenericAgent.allCurrentVoyages do
		if self.myMobileGenericAgent.myTerminal.getConfig(VesselNameOnVoyageCombo).Boolean then //cnwrd1 nfs 31095
			self.cmbVoyage.itemObject[self.cmbVoyage.addItem(voyage.code &amp; Tab &amp; voyage.vesselName )] := voyage;
		else
			self.cmbVoyage.itemObject[self.cmbVoyage.addItem(voyage.code)] := voyage;
		endif;
	endforeach;
	
	self.cmbDestination.clear();
	foreach port in app.myRoot.allActiveDestinations do
		if port.isNotAvailableForEntry then
			continue;
		endif;
		self.cmbDestination.itemObject[self.cmbDestination.addItem(port.getDisplayFormatted(false) )] := port;
	endforeach;
	
	self.cmbImexStatus.clear();
	foreach imex in app.myRoot.allImexStatuses do
		self.cmbImexStatus.itemObject[self.cmbImexStatus.addItem(imex.description)] := imex;
	endforeach;
	
	self.populateVoyageDependantCombos();
	
	beforeCommodity := cmbCommodity.listObject.CM_Commodity;
	self.cmbCommodity.clear();
	
	cargoType := self.myPackContainer.myCargoType;
	if cargoType.allCommodities.isEmpty then
		foreach commodity in app.myRoot.allCommodities do
			if commodity.isNotAvailableForEntry then
				continue;
			endif;
			self.cmbCommodity.itemObject[self.cmbCommodity.addItem(commodity.getDisplayDetails(false))] := commodity;
		endforeach;
	else
		foreach commodity in cargoType.allCommodities do
			if commodity.isNotAvailableForEntry then
				continue;
			endif;
			self.cmbCommodity.itemObject[self.cmbCommodity.addItem(commodity.getDisplayDetails(false))] := commodity;
		endforeach;
	endif;
	
	if beforeCommodity &lt;&gt; null then
		self.cmbCommodity.listIndex := self.cmbCommodity.findObject(beforeCommodity);
		self.tblCargo.setValueByControlName(self.cmbCommodity.name, self.cmbCommodity.text);
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateVoyageDependantCombos" id="b0df23c2-2fc6-4856-8fd0-776021d3650c">
        <source>populateVoyageDependantCombos();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 July 2011	cnwndl1	Initial creation

*/

vars

	voyage : CM_Voyage;
	port : CM_Port;
	destPort : CM_Port;
	dischgPort : CM_Port;

begin

	voyage := self.cmbVoyage.listObject.CM_Voyage;
	
	destPort := self.cmbDestination.listObject.CM_Port;
	self.cmbDestination.clear();
	if voyage = null then
		foreach port in app.myRoot.allActiveDestinations do
			if port.isNotAvailableForEntry then
				continue;
			endif;
			self.cmbDestination.itemObject[self.cmbDestination.addItem(port.getDisplayFormatted(false) )] := port;
		endforeach; 
	else
		foreach port in app.myRoot.allActiveDestinations do
			if port.isNotAvailableForEntry then
				continue;
			endif;
			self.cmbDestination.itemObject[self.cmbDestination.addItem(port.getDisplayFormatted(false) )] := port;
		endforeach; 
	endif;
	
	if destPort &lt;&gt; null then
		self.cmbDestination.listIndex := self.cmbDestination.findObject(destPort);
		self.tblCargo.setValueByControlName(self.cmbDestination.name, self.cmbDestination.text);
	endif;	

	
	dischgPort := self.cmbDischarge.listObject.CM_Port;
	self.cmbDischarge.clear();
	if voyage = null then
		foreach port in app.myRoot.allActivePorts do
			if port.isNotAvailableForEntry then
				continue;
			endif;
			self.cmbDischarge.itemObject[self.cmbDischarge.addItem(port.getDisplayFormatted(false) )] := port;
		endforeach; 
	else
		foreach port in voyage.allPorts do
			if port.isNotAvailableForEntry then
				continue;
			endif;
			self.cmbDischarge.itemObject[self.cmbDischarge.addItem(port.getDisplayFormatted(false) )] := port;
		endforeach; 
	endif;
	
	if dischgPort &lt;&gt; null then
		self.cmbDischarge.listIndex := self.cmbDischarge.findObject(dischgPort);
		self.tblCargo.setValueByControlName(self.cmbDischarge.name, self.cmbDischarge.text);
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setComboValues" id="19377f1a-2ef6-4a34-a71a-e6ca39dfa792">
        <updating/>
        <source>setComboValues() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 July 2011	cnwndl1	Initial creation

*/

vars

	port : CM_Port;
	commodity : CM_Commodity;
	voyage : CM_Voyage;
	existingString : String;
	index : Integer;
	imex : CM_IMEXStatus;
	
begin

	//select items in combos used in tables
	
	if tblCargo.getRow(ETRow_VoyageCode) &gt; 0 then
		existingString := null;
		existingString := tblCargo.getCellText(tblCargo.getRow(ETRow_VoyageCode),2);
		if existingString &lt;&gt; null then
			// PAR 33297
			foreach index in 1 to cmbVoyage.listCount do
				voyage := cmbVoyage.itemObject[index].CM_Voyage;
				if voyage.code = existingString then
					break;
				endif;
				voyage := null;
			endforeach;
		//	index := self.cmbVoyage.findStringExact(1,existingString);
		//	if index &gt; 0 then
		//		voyage := cmbVoyage.itemObject[index].CM_Voyage;
		//	endif;
			if voyage &lt;&gt; null then
				self.cmbVoyage.listIndex := self.cmbVoyage.findObject(voyage);
			else
				self.cmbVoyage.listIndex := -1;
			endif;
		else
			self.cmbVoyage.listIndex := -1;
		endif;
		
		self.tblCargo.setValueByControlName(self.cmbVoyage.name, self.cmbVoyage.text);
	endif;
	
	if tblCargo.getRow(ETRow_DestinationPort) &gt; 0 then
		existingString := null;
		existingString := tblCargo.getCellText(tblCargo.getRow(ETRow_DestinationPort),2);
		if existingString &lt;&gt; null then
			index := self.cmbDestination.findStringExact(1,existingString);
			if index &gt; 0 then
				port := cmbDestination.itemObject[index].CM_Port;
			endif;
			if port = null then
				port := app.myRoot.allPorts.getAtKey(existingString);
			endif;
			if port &lt;&gt; null then
				self.cmbDestination.listIndex := self.cmbDestination.findObject(port);
			else
				self.cmbDestination.listIndex := -1;
			endif;
		else
			self.cmbDestination.listIndex := -1;
		endif;

		self.tblCargo.setValueByControlName(self.cmbDestination.name, self.cmbDestination.text);
	endif; 
	
	if tblCargo.getRow(ETRow_DischargePort) &gt; 0 then
		port := null;
		existingString := null;
		existingString := tblCargo.getCellText(tblCargo.getRow(ETRow_DischargePort),2);
		if existingString &lt;&gt; null then
			index := self.cmbDischarge.findStringExact(1,existingString);
			if index &gt; 0 then
				port := cmbDischarge.itemObject[index].CM_Port;
			endif;
			if port = null then
				port := app.myRoot.allPorts.getAtKey(existingString);
			endif;
			if port &lt;&gt; null then
				self.cmbDischarge.listIndex := self.cmbDischarge.findObject(port);
			else
				self.cmbDischarge.listIndex := -1;
			endif;
		else
			self.cmbDischarge.listIndex := -1;
		endif;

		self.tblCargo.setValueByControlName(self.cmbDischarge.name, self.cmbDischarge.text);
	endif; 

	if tblCargo.getRow(ETRow_Commodity) &gt; 0 then
		existingString := null;
		existingString := tblCargo.getCellText(tblCargo.getRow(ETRow_Commodity),2);
		if existingString &lt;&gt; null then
			index := self.cmbCommodity.findStringExact(1,existingString);
			if index &gt; 0 then
				commodity := cmbCommodity.itemObject[index].CM_Commodity;
			endif;
			if commodity = null then
				commodity := app.myRoot.allCommodities.getAtKey(existingString);
			endif;
			if commodity &lt;&gt; null then
				self.cmbCommodity.listIndex := self.cmbCommodity.findObject(commodity);
			else
				self.cmbCommodity.listIndex := -1;
			endif;
		else
			self.cmbCommodity.listIndex := -1;
		endif;		
		self.tblCargo.setValueByControlName(self.cmbCommodity.name, self.cmbCommodity.text);
		
		//20 Oct 2015	NDL	Par 36703
		self.showHidePopulateReeferColumns();
		
	endif;
	
	
	if tblCargo.getRow(ETRow_ImexStatus) &gt; 0 then
		existingString := null;
		existingString := tblCargo.getCellText(tblCargo.getRow(ETRow_ImexStatus),2);
		if existingString &lt;&gt; null then
			index := self.cmbImexStatus.findStringExact(1,existingString);
			if index &gt; 0 then
				imex := self.cmbImexStatus.itemObject[index].CM_IMEXStatus;
			endif;
			
			if imex = null then
				imex := app.myRoot.allImexStatuses.getAtKey(TI_IMEX_STATUS_EXPORT);			//default to export
			endif;
			self.cmbImexStatus.listIndex := self.cmbImexStatus.findObject(imex);

		else
			imex := app.myRoot.allImexStatuses.getAtKey(TI_IMEX_STATUS_EXPORT);			//default to export
			self.cmbImexStatus.listIndex := self.cmbImexStatus.findObject(imex);
		endif;

		self.tblCargo.setValueByControlName(self.cmbImexStatus.name, self.cmbImexStatus.text);
	endif; 	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupControls" id="4f259caa-150f-4a67-845a-2a73faf23a4a">
        <updating/>
        <source>setupControls() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

	height : Real;
	row : Integer;
	tableCell : JadeTableCell;

begin

	self.tblCargo.visible := true;
	self.tblCargo.fixedRows := 0;
	self.tblCargo.fixedColumns := 0;
	self.tblCargo.rows := 0;
	self.tblCargo.columns := 2;
					
//	self.doResizeControls(true);
	
	self.myEntTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_GeneralCargoReefer];
	
	if self.myEntTableDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Def (' &amp; ETDef_GeneralCargoReefer &amp; ') not found');
		return;
	endif;
	
	self.myEntTableView := self.myEntTableDef.allEntTableViews[ETView_HandHeld];
	if self.myEntTableView = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'View (' &amp; ETView_HandHeld &amp; ') within (' &amp; ETDef_GeneralCargoReefer &amp; ') not found');
		return;
	endif;
	
	self.tblCargo.setEntTableFromView(self.myEntTableDef, self.myEntTableView, null, null);
	
	// hide the other columns in the view that we don't want to see. (In this iteration....)
	self.tblCargo.hideRowByName( ETRow_CargoType, false );
	self.tblCargo.hideRowByName( ETRow_SubCargoType, false );
	self.tblCargo.hideRowByName( ETRow_TotalWeight, false );
	self.tblCargo.hideRowByName( ETRow_TotalVolume, false );
	self.tblCargo.hideRowByName( ETRow_Location, false );
	self.tblCargo.hideRowByName( ETRow_VoyageOperator, false );
	self.tblCargo.hideRowByName( ETRow_FreightForwarder, false );
	self.tblCargo.hideRowByName( ETRow_Width, false );
	self.tblCargo.hideRowByName( ETRow_Height, false );
	self.tblCargo.hideRowByName( ETRow_Length, false );
	self.tblCargo.hideRowByName( ETRow_Quantity, false );
	self.tblCargo.hideRowByName(ETRow_Consignee,false); //epr TFS 2526 3/10/16 never saved so hide
	
	//20 Oct 2015	NDL	Par 36703 - Now using ETDef_GeneralCargoReefer
	self.tblCargo.hideRowByName( ETRow_Make, false );
	self.tblCargo.hideRowByName( ETRow_Model, false );
	self.tblCargo.hideRowByName( ETRow_VehicleType, false );
	self.tblCargo.hideRowByName( ETRow_Year, false );
	self.tblCargo.hideRowByName( ETRow_NumItems, false );
	if self.myPackContainer &lt;&gt; null and self.myPackContainer.isKindOf(CM_Container) then
		self.tblCargo.hideRowByName( ETRow_DimType, false );
		self.tblCargo.hideRowByName( ETRow_TrailerType, false );
		self.tblCargo.hideRowByName( ETRow_AlternativeId, false );
		self.tblCargo.hideRowByName( ETRow_Mark, false );
		self.tblCargo.hideRowByName( ETRow_Colour, false );
	endif;
	
//	self.tblCargo.columnWidth[1] := (self.tblCargo.width / 3).Integer;
	
	loadTblCargo();
	
	self.tblCargo.accessRow( self.tblCargo.getRow(ETRow_CargoId)).enabled := false;
	
	self.doResizeControls(true);
	
	//position the cursor on the commodity.
	self.tblCargo.leftColumn := 1;	
	self.tblCargo.column := 2;
	self.tblCargo.row := self.tblCargo.getRow(ETRow_Commodity);

	self.tblCargo.setFocus();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="c4936050-f961-4933-b6ac-b0d0e823b278">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

begin
	
	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	self.myPackContainer := self.myMobileGenericAgent.myPackTi; 

	inheritMethod();
	
	self.setupCmdButtons( 2, app.getErrorString(Pack), app.getErrorString(Back), null, null, null );
	
	self.setupControls();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showHidePopulateReeferColumns" id="49ec2ee0-119f-427c-b224-5d72042a69a0">
        <source>showHidePopulateReeferColumns() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 October 2015	cnwndl1	Initial creation	Par 36703

*/

vars

	commodity : CM_Commodity;

begin

	commodity := self.cmbCommodity.listObject.CM_Commodity;
	
	self.tblCargo.hideRowByName( ETRow_PackTempC, false );

	if ( commodity &lt;&gt; null and commodity.hasTemp ) or ( self.myPackContainer &lt;&gt; null and self.myPackContainer.isReefer ) then
		self.tblCargo.showRowByName( ETRow_CarriageTempC, false );
	else
		self.tblCargo.hideRowByName( ETRow_CarriageTempC, false );
	endif;
	
	if ( self.myPackContainer &lt;&gt; null and self.myPackContainer.isReefer ) then
		self.tblCargo.showRowByName( ETRow_CarbonDioxide, false );
		self.tblCargo.showRowByName( ETRow_Oxygen, false );
		self.tblCargo.showRowByName( ETRow_Humidity, false );
		self.tblCargo.showRowByName( ETRow_Ventilation, false );
	else
		self.tblCargo.hideRowByName( ETRow_CarbonDioxide, false );
		self.tblCargo.hideRowByName( ETRow_Oxygen, false );
		self.tblCargo.hideRowByName( ETRow_Humidity, false );
		self.tblCargo.hideRowByName( ETRow_Ventilation, false );
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="94683ea8-00c7-43eb-9623-e7fb0c1f6ebe">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 20 March 2017 09:31:18.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0016620, locale);
	btnDocActions.translateCaption(Xlat_0021925, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="updatePackContainer" id="be1d8028-41ef-4593-8807-50d31fc74371">
        <source>updatePackContainer():Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01/07/2011	cnwndl1	Initial creation
26/06/2012	cnwdap1	PAR #29735 new parameter for CM_TrackedItem::setBookingRefAndItem method
30/12/2014   xnwma1 PAR #35380 Special Stow Bookings
04/10/2017	jlgdap1	TFS 7204 STWR Correct real handling for non-standard locales
05/05/2020	jlgmd1	TFS #49214 STWR Always (try) and give the handheld pack app priority in deadlocks
10/07/2020	jlgmd1	TFS #49690 STWR Remove the setting of deadlock priority now that CM_Passport::finaliseTransaction doesn't reset it after every trx
*/

vars

	booking : CM_BookingRef;
	bookingItem : CM_BookingRefItem;
	commodity : CM_Commodity;
	destPort : CM_Port;
	dischargePort : CM_Port;
	imexStatus : CM_IMEXStatus;
	pxyTi : CM_TrackedItem;
	result : Integer;
	workStr : String;
	voyage : CM_Voyage;
	bulkRelease : CM_BulkRelease;
	reserveDetail :CM_ReserveDetail;
	reason : String;
	bookingStr	: String;
begin

	booking := self.myMobileGenericAgent.myPackExportBookingRef;
	bookingItem := self.myMobileGenericAgent.myPackExportBookingItem;
	bookingStr :=self.getStringValueFromTable( ETRow_BookingReference );
	
	commodity := self.cmbCommodity.listObject.CM_Commodity;
	destPort := self.cmbDestination.listObject.CM_Port;
	dischargePort := self.cmbDischarge.listObject.CM_Port;
	imexStatus := self.cmbImexStatus.listObject.CM_IMEXStatus;
	voyage := self.cmbVoyage.listObject.CM_Voyage;
	
	app.myMobileAgent.setMyProxy( self.myMobileGenericAgent.myPackTi );
	pxyTi := app.myMobileAgent.getMyProxyObject().CM_TrackedItem;

	//epr TFS 4645 5/9/17 we were nulling the booking just because the export booking wasn't set
	if (bookingStr &lt;&gt; null and booking &lt;&gt; null) or
		( bookingStr = null and booking = null ) then
		pxyTi.setBookingRefAndItem( booking, bookingItem, false, app.myPassport );	// PAR #29735
	endif;
	
	pxyTi.setCommodity( commodity.code );
	if dischargePort &lt;&gt; null then
		pxyTi.setDischargePort( dischargePort.code );
	else
		pxyTi.setDischargePort( null );
	endif;
	if destPort &lt;&gt; null then
		pxyTi.setDestinationPort( destPort.code );
	else
		pxyTi.setDestinationPort( null );
	endif;
	if imexStatus &lt;&gt; null then
		pxyTi.setImExStatus( imexStatus.code );
	else
		pxyTi.setImExStatus( null );
	endif;
	if voyage &lt;&gt; null then
		pxyTi.setVoyageCode( voyage.code, app.myPassport );
	else
		pxyTi.setVoyageCode( null, app.myPassport );
	endif;
	
	//20 Oct 2015	NDL	Par 36703
	if ( commodity &lt;&gt; null and commodity.hasTemp ) or ( self.myPackContainer &lt;&gt; null and self.myPackContainer.isReefer ) then
		workStr := null;
		workStr := self.getStringValueFromTable( ETRow_CarriageTempC );
		//pxyTi.setTemperature( workStr.Real );										// TFS 7204
		pxyTi.setTemperature( workStr.asRealJMT );									// TFS 7204
	endif;
	if ( self.myPackContainer &lt;&gt; null and self.myPackContainer.isReefer ) then
		workStr := null;
		workStr := self.getStringValueFromTable( ETRow_Oxygen );
		pxyTi.setOxygen( workStr.asDecimalJMT );	
		
		workStr := null;
		workStr := self.getStringValueFromTable( ETRow_CarbonDioxide );
		pxyTi.setCarbonDioxide( workStr.asDecimalJMT );	
		
		workStr := null;
		workStr := self.getStringValueFromTable( ETRow_Humidity );
		pxyTi.setHumidity( workStr.asDecimalJMT );	
		
		workStr := null;
		workStr := self.getStringValueFromTable( ETRow_Ventilation );
		//pxyTi.setVentilation( workStr.Integer );									// TFS 7204
		pxyTi.setVentilation( workStr.asRealJMT );									// TFS 7204
		
	endif;
	
	while true do

		app.myPassport.clearErrorsWarnings();
		app.myPassport.setWarningsIgnored(true);
		app.myTrxUA.trxUpdateTrackedItem(	pxyTi,
											null,
											TI_UPDMODE_NORMAL, 
											null, 
											app.myPassport);


		if app.myPassport.trxCompletedOK then
			result := IDOK;
			break;
		else
			app.mousePointer :=	Idle;
			result := app.showErrorWarningDialog(app.getErrorString(Cargo_item_update), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				app.mousePointer :=	Busy;
				continue;
			endif;
		endif;
		break;
		
	endwhile;
	
	//10 Dec 2015	NDL	Par 37288
	if not app.myPassport.hasErrors() then
		bulkRelease := self.myMobileGenericAgent.myBulkRelease;
		if bulkRelease &lt;&gt; null and bulkRelease.isPackingType then
			if self.myPackContainer &lt;&gt; null then
				if self.myPackContainer.allReserveDetails.isEmpty then
					foreach reserveDetail in bulkRelease.allReserveDetails where reserveDetail.isKindOf( CM_ReserveSelection) do
						//on a pack request these are the packing parent selections
						if self.myPackContainer.testAgainstReserveSelection( reserveDetail.CM_ReserveSelection, reason, true, null ) then
							//assign the container as a parent on the packing release.
							app.myTrxUA.trxAddToReserveDetail( reserveDetail, self.myPackContainer, app.myPassport );
							break;
						endif;
					endforeach;
				endif;
			endif;
		endif;
	endif;
	
	return not app.myPassport.hasErrors();
	
epilog

	app.myMobileAgent.setMyProxy( null );

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateSelections" id="6f1ec40c-aac7-4528-a234-1936962d4ae4">
        <source>validateSelections():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 July 2011	cnwndl1	Initial creation

*/

vars

	commodity : CM_Commodity;
	mess : String;

begin

	commodity := self.cmbCommodity.listObject.CM_Commodity;
	if commodity = null then
		mess := app.getErrorString(Commodity_required);
		self.msgBox(mess, app.getErrorString(Error), MsgBox_OK_Only, false );
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
