    <JadeMethod name="hasStateDataOfValueType" id="85ed5990-3527-42d7-851f-8da24c8dafb5">
        <source>hasStateDataOfValueType(_key : String; _stateClass :Class): Boolean;
// ---------------------------------------------------------------------------
// Created:		01 April 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	stateObject		: CM_StateObject;
	stateData		: CM_StateData;
	
begin
	if _stateClass.getSuperclass() &lt;&gt; CM_StateData then
		return false;
	endif;
	
	foreach stateObject in self.allStateObjects do
		foreach stateData in stateObject.allStateData do
			if stateData.isKindOf(_stateClass) then
				if stateData.key = _key then
					return true;
				endif;
			endif;
		endforeach;
	endforeach;
	
	return false;
				
end;</source>
        <Parameter name="_key" type="String"/>
        <Parameter name="_stateClass" type="Class"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasStateDataRefToObj" id="5296e8e6-f721-4835-b7a7-b3fb20e83223">
