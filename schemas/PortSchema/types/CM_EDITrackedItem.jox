    <JadeMethod name="setEDITIProperty" id="c1c43d60-7788-472e-87e5-8dd32dc511e7">
        <final/>
        <updating/>
        <source>setEDITIProperty(_name					 : String; 
				_fullValue				 : Any; 
				_ediFile 		    	 : CM_EDIFile; 
				_allStripChars			 : CharacterArray; 
				_xlationOperator 		 : CM_Operator;
				_ediDataXlationOperator	 : CM_Operator) updating, final; // new rs1 to replace CM_EDIFieldMapping::assignValue ccms 1976
// Dont re-implement this method.  assignValueSpecial, translateValue (maybe) and processAttributeDependencies  can be reimplemented 
//----------------------------------------------------------------
//	Created:	18 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//02 Feb 2012	cnwrs1	Par 29076 Fix up Hazard Processing in EDI
// 31/08/2012 	cnwmh5	#30287 - Fix issue where decimal doesn't take into account locale
// 10/09/2012 	cnwmh5	#30354 - Remove #30287 change
// 07/04/2013	cnwcs5	CCMS POL 2097 / par 31259 - COMMODITY XLATIONS
//10 Jun 2016	cnwrs1	TFS 2150 - If you process an operatorCode and there is not xlation operator then start using that operator
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
// 21 Nov 2022	navma1	ChangeRequest 55424: MTN - Improve the performance of Edi file loading
// 07 Dec 2022  navma1	ChangeRequest 55783: MTN - Removing unnecessary calls for Class::getPropertyInHTree() method while setting EDI property values
//
vars
	property			: Property;
	propertyType		: Type;
	xlationOperator	 	: CM_Operator;
	fileType 			: CM_EDIFileType;	//ccms 1976 cnwrs1 31 Dec 2010
	processedValue 		: String;
	char 				: Character;
	dateDelim 			: String;
	date 				: Date;
	operatorXlationCode : String;
	foundMatch 			: Boolean;
	ts 					: TimeStamp;
	root				: CM_Root;
	ediData				: CM_EDIData;
	propertyLength		: Integer;
	isoType : CM_ISOType;					//navra1 - CR 64620/Task 64658 - 8th July 2024
begin

	ediData := self.myEDIData;													//21.11.2022 navma1 #55424
	
	if _xlationOperator &lt;&gt; null then
		xlationOperator := _xlationOperator;
	else 
		if _ediDataXlationOperator &lt;&gt; null then
			xlationOperator := _ediDataXlationOperator;							    //21.11.2022 navma1 #55424
		else
			/*
				We passed the _ediDataXlationOperator variable here to avoid calling getXlationOperator(),
				for everything single line of user defined edi files .
				later this might require refactor to see why other edi file types passing null XlationOperator 
				rather than using the EdiData XlationOperator.
				
			*/
			xlationOperator := ediData.getXlationOperator();						//21.11.2022 navma1 #55424
		endif;
		
	endif;
	
	if xlationOperator = null and ediData.operatorCode &lt;&gt; null then				//21.11.2022 navma1 #55424
		xlationOperator := app.myRoot.allOperators[ediData.operatorCode];		//21.11.2022 navma1 #55424
	endif;
	
	fileType := _ediFile.myEDIFileType;
	//we can't replace chars with null because this is the string terminator in C++
	//so this will only 'strip' chars off the ends when we trimBlanks
	//at some point I will code a method to strip chars mid-string and close it back up
	processedValue := _fullValue.String.trimCharacters(CrLf);
	
	if _allStripChars &lt;&gt; null then				
		foreach char in _allStripChars do
			processedValue := processedValue.removeString(char);
		endforeach;
	endif;
	
	processedValue := processedValue.trimBlanks();
	
	if self.assignValueSpecial(_name, processedValue, xlationOperator) then
		return;
	endif;
	
	property := self.class.getPropertyInHTree(_name);	//ccms 1976 15 Dec 2010 cnwrs1		//21.11.2022 navma1 #55424

	
	if property = null then
		// there is an invalid property name within the definition - display an error so they can go in and fix it up
		app.raiseCMException3 (EDI_UDFT_PROPERTY_ERROR, fileType.name, _name, self.class.name, null, null);	// par 23326
		return;
	endif;
	
	if property &lt;&gt; null and property.cnEcIsPrimitive then
		propertyType := property.type;
		
		if propertyType = Integer then
			self.setPropertyValue(_name, processedValue[1:9].Integer);	
			
		elseif propertyType = Real then
			self.setPropertyValue(_name, processedValue.Real);	
			
		elseif propertyType = Decimal then							//cnwrs1 10 Dec 2010 ccms 1976
			self.setPropertyValue(_name, processedValue.Decimal);
			
		elseif propertyType = Boolean then
			self.setPropertyValue(_name, processedValue.asBooleanJMT);
			
		elseif propertyType = Character then
			self.setPropertyValue(_name, processedValue.Character);	//par 26848 cnwrs1 31 Jan 2011
			
		elseif propertyType = Time then
			if  processedValue = null then 							//epr TFS 2474 1/8/16
				self.setPropertyValue(_name, NULL_TIME);
			else
				self.setPropertyValue(_name, processedValue.Time);
			endif;
			
		elseif propertyType = TimeStamp then
			//self.setPropertyValue(_name, processedValue.TimeStamp);
			//29 Mar 2017	NDL	TFS 3886
			ts := processedValue.ediTimeStampFormat( fileType, null, null );
			self.setPropertyValue(_name, ts);
			
		elseif propertyType = Date then
			if fileType.isKindOf(CM_EDIFileTypeUser) then //ccms 1976 cnwrs1 31 dec 2010
				if fileType.CM_EDIFileTypeUser.dateFormat &lt;&gt; null then
					if fileType.CM_EDIFileTypeUser.dateDelimeter.Character &gt; #0.Character then
						dateDelim := fileType.CM_EDIFileTypeUser.dateDelimeter.String;
					endif;
					date := processedValue.String.ediDateFormat(fileType.CM_EDIFileTypeUser.dateFormat, dateDelim);
				else
					date := processedValue.String.asDateJMT();
				endif;
			endif;
			
			self.setPropertyValue(_name, date);
			
		elseif propertyType = String then
			if xlationOperator = null and _name = ETRow_OperatorCode then
				// try and use this operator as the xlation Operator
				root				:= app.myRoot;																				//21.11.2022 navma1 #55424
				operatorXlationCode := root.getXlationSystemOperatorCode(xlationOperator, processedValue, foundMatch)[1:4];	    //21.11.2022 navma1 #55424
				xlationOperator 	:= root.allOperators[operatorXlationCode];													//21.11.2022 navma1 #55424
				ediData.setXlationOperator(xlationOperator);																	//21.11.2022 navma1 #55424
			endif;
			
			if xlationOperator &lt;&gt; null then
				self.translateValue(_name, xlationOperator, processedValue);
			endif;
			propertyLength := property.Attribute.length;																		//07.12.2022 navma1	#55783										
			propertyLength := propertyLength -1 ;										                                        //07.12.2022 navma1	#55783
			
			//navra1 - CR 64620/Task 64658 - 8th July 2024
			if self.isKindOf(CM_EDILoadListTI) and  _name.compareEql(ETRow_ISOType, true, false, null) then
				isoType := app.myRoot.allISOTypes[processedValue];
				if isoType &lt;&gt; null then
					self.CM_EDILoadListTI.containerLength := isoType.getLengthInFeet().String;
				endif;			
			endif;
			
			if self.isKindOf(CM_EDILoadListTI) and  _name.compareEql(ETRow_OpStatus, true, false, null) then
				if processedValue = "FCL" or processedValue = "FULL" then
					self.CM_EDILoadListTI.contentsStatus := "FCL";
				elseif processedValue = "MT" or processedValue = "EMPTY" then
					self.CM_EDILoadListTI.contentsStatus := "MT";
				elseif processedValue = "LCL" then
					self.CM_EDILoadListTI.contentsStatus := "LCL";
				elseif processedValue = "FLH" then
					self.CM_EDILoadListTI.contentsStatus := "FLH";
				elseif processedValue = "PLL" then
					self.CM_EDILoadListTI.contentsStatus := "PLL";
				elseif processedValue = "PLL" then
					self.CM_EDILoadListTI.contentsStatus := "PLL";
				elseif processedValue = "PLD" then
					self.CM_EDILoadListTI.contentsStatus := "PLD";
				endif;				
			endif;
			//navra1 - CR 64620/Task 64658 - 8th July 2024
			
			self.setStringValue(_name, processedValue,propertyLength);															//07.12.2022 navma1	#55783	
		else
			//this would be an unhandled type here (not an unhandled property)!! If this happens it SHOULD raise an exception
			//and you should add code to handle the type
			app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled property type (' &amp; propertyType.String &amp; '"');
		endif;
	else
		self.setPropertyValue(_name, processedValue);
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_fullValue" type="Any"/>
        <Parameter name="_ediFile" type="CM_EDIFile"/>
        <Parameter name="_allStripChars" type="CharacterArray"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <Parameter name="_ediDataXlationOperator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="setForCreateNew" id="5c9d0937-7d87-4d22-85ac-c307a71cedf4">
        <updating/>
        <source>setForCreateNew(_ediData: CM_EDIData) updating;
//----------------------------------------------------------------
//	Created:	05 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//03 Apr 2012	cnwrs1	Par 29449 - pad the pseudo generated container numbers
// 26 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 18 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 19 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	intID	: Integer;
	str : String;
	wasLockedByMe : Boolean;
	ediData : CM_EDIData;
begin
	if not self.isEDISealDetails then
/*		intID := 1;
		while true do
			str := intID.String.padZeros(8)[1:8];	//03 Apr 2012	cnwrs1	Par 29449
			if (not _ediData.allEDITrackedItems.includesKey(str)) then
				self.setIdDefault(str);
				break;
			endif;
			intID := intID + 1;
		endwhile;*/
		ediData := _ediData;
		self.setIdDefault(ediData.getNextDefaultIdNumber().String.padZeros(8)[1:8]);
	endif;
/*	if not _ediData.isKindOf(CM_EDIDataShipManifest) then
		wasLockedByMe := self.isLockedByMe(_ediData.ediConfig.allEDITrackedItemsByIdStatus);
		if not wasLockedByMe then
			if not tryLock(_ediData.ediConfig, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
				self.exclusiveLock(_ediData.ediConfig);
			endif;
			if not tryLock(_ediData.ediConfig.allEDITrackedItemsByIdStatus, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
				self.exclusiveLock(_ediData.ediConfig.allEDITrackedItemsByIdStatus);
			endif;
		endif;
		self.setMyEDIData(_ediData);
	endif;*/
	self.myEDIData := _ediData;
	self.cargoType := TI_CargoType_Container;
epilog
	
end;</source>
        <Parameter name="_ediData" type="CM_EDIData"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="bbb7d904-c5d9-4b44-98a9-f3a3765174ac">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
//----------------------------------------------------------------
//	Created:	08 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//03 May 2018	NDL	TFS 37795
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 29 Nov 2022	jlika1	TFS 55586 HS Code User Defined EDI
// 11/01/2023	navkc1	TFS CR 55625 TASK 55660 Task 55660: Jade - Contract Id EDI TRX
vars
	lCargoType		: CM_CargoType;
	
begin
	self.setId(_proxyEDITI.id.toUpper);
	self.cargoType		:= _proxyEDITI.cargoType;
	self.fullOrMT		:= _proxyEDITI.fullOrMT;
	self.cargoTypeDescr	:= _proxyEDITI.cargoTypeDescr;
	self.description	:= _proxyEDITI.description;
	if self.cargoType = null then //par 21239 cnwrs1 Oct 2009
//		self.cargoType	:= app.myRoot.getCargoTypeIDFromAbbrev(self.cargoTypeDescr);	// cnwrl1 25/11/2009 PAR 21713 - what it was
		// cnwrl1 25/11/2009 PAR 21713 - start of coding
		lCargoType	:= app.myRoot.getCargoTypeFromAbbrevOrDescr( self.cargoTypeDescr );
		if lCargoType &lt;&gt; null then
			self.cargoType	:= lCargoType.id;
		endif;
		// cnwrl1 25/11/2009 PAR 21713 - end of coding
	endif;
	
	// cnwrl1 09/09/2009 PAR 20320 - MES 1011 New Messina Messages - start of coding
	self.messageMode		:= _proxyEDITI.messageMode.toUpper;
	self.subTerminalCode	:= _proxyEDITI.subTerminalCode;
	// cnwrl1 09/09/2009 PAR 20320 - MES 1011 New Messina Messages - end of coding
	
	// make sure the manual collection on CM_EDIConfig gets maintained
	self.setVoyageCode( _proxyEDITI.getVoyageCode() );				// cnwrl1 15/06/2010 PAR 24299
	self.specialStowage := _proxyEDITI.specialStowage;  //07 Jun 2017	NDL TFS 4454
	self.remarksAdditional1 := _proxyEDITI.remarksAdditional1;
	self.remarksAdditional2 := _proxyEDITI.remarksAdditional2;
	
	self.shippingLineCodeForTI := _proxyEDITI.shippingLineCodeForTI;
	self.countryOfOriginCode:=_proxyEDITI.countryOfOriginCode; //jlier1 TFS 54846 5/10/22
	self.hsCode	:= _proxyEDITI.hsCode;
	self.contractIdForTIstring := _proxyEDITI.contractIdForTIstring; // 11/01/2023	navkc1	TFS CR 55625 TASK 55660
epilog
	
end;
</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setHSCode" id="cc89c851-3f3b-4b73-978d-8fb535aa61a1">
        <updating/>
        <source>setHSCode(_hsCode : String)  updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 January 2023	jlier1	Initial creation

*/

vars
	terminal : CM_Terminal;
begin
	if self.hsCode &lt;&gt; _hsCode then
		self.hsCode:=_hsCode;
	
		terminal:=self.getMyTerminal;
		if terminal &lt;&gt; null and self.hsCode &lt;&gt; null then
			if terminal.getConfig(EdiHSCodeAddUnknown).Boolean then
				CMIF_TrxActionHSCode@createAction(self.hsCode,app.myPassport);
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_hsCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="setId" id="d42e0771-4fd6-460b-bb02-562400579075">
