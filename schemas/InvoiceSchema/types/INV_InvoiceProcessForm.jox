    <JadeMethod name="addObjectsToTable" id="b632a3b9-a268-4840-913b-063673d7bb9c">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
/*
Purpose:	TFS 39618		
Date				Who			Reason
JANUARY 2019		CNWAB1		Initial creation
*/

vars
	invProcess : CM_InvoiceProcess;
	tmpPassport	: CM_Passport;
	breakOut	: Boolean;
begin

	self.setMyDataClass();
	beginClassNotification(CM_InvoiceProcess, false, Object_Create_Event, Response_Continuous, 0); 

	tmpPassport := app.myPassport;
	
	foreach invProcess in app.myRoot.allInvoiceProcesses  do
		if self.includeObject(invProcess, tmpPassport) then
			self.addObjectToTable(invProcess, _numItems, breakOut);
		endif;
		if breakOut then
			break;
		endif;
	endforeach;

end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="create" id="39170d80-bd79-46b6-94ff-a241e4c0bce2">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2019	jlgab1	Initial creation

*/

vars

begin
	self.permissionView  := PmAdmInvProcessView;
	self.permissionMaint := PmAdmInvProcessMaint;
	
	self.helpFileName := HelpFile_Invoicing;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="3fc5c02e-7a0f-4743-9bda-ed7e645ce31d">
        <updating/>
        <source>doSave(): Boolean updating;
/*
Purpose:	TFS 39618		
Date				Who			Reason
JANUARY 2019		CNWAB1		Initial creation
*/

vars
	pxyInvStatus	: CM_InvoiceProcess;
	theReturn			: Integer;

begin

	if self.mode = Mode_Update then
		pxyInvStatus := self.myProxyObject.CM_InvoiceProcess;
	else
		return false;
	endif;
	
	self.setProxyFromTable(pxyInvStatus);
	
	while true do
		if self.mode = Mode_Update then
			app.myTrxUA.trxUpdateInvoiceProcess(pxyInvStatus, app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			return true;
		else
			global.beep;
			theReturn := app.showErrorWarningDialog("Invoice Process", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
		endif;
		break;
	endwhile;
	
epilog
	if self.mode = Mode_Add then
		delete pxyInvStatus;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doShowEmailForm" id="58d49f97-e8ab-4930-9374-b1fe57393b86">
        <source>doShowEmailForm();
/*
Purpose:			
Date				Who			Reason
// 14 June 2023 navmv20 CR 58215 Task 58217: UI - Invoice Process Email
// 22 July 2025 navhn30 MTN-35477: 1090 exception when updating the Invoice Processes on the Invoice Process Maintenance form
*/

vars
	realProcess, pxyProcess : CM_InvoiceProcess;
	emailDefault, pxyEmailDefaults : CM_InvProcessDefaultEmail;
	emailAdding : Boolean;
	pxyEmailTemplate, oldTemplate : CM_EmailTemplate;
	modalResult : Integer;
	loadState : Boolean;		
	invoiceProcess : CM_InvoiceProcess;
begin
	realProcess := self.myCurrentObject.CM_InvoiceProcess;
	pxyProcess := self.myProxyObject.CM_InvoiceProcess;
	
	if realProcess.myEmailTemplate = null then
		emailAdding := true;
		pxyEmailTemplate := pxyProcess.createPxyEmailTemplate();
		emailDefault := app.myRoot.allInvStatusDefaultEmails[realProcess.pinEmailOffset + 800].CM_InvProcessDefaultEmail;
	else
		pxyEmailTemplate := pxyProcess.myEmailTemplate;
		emailDefault := app.myRoot.allInvStatusDefaultEmails[pxyProcess.myEmailTemplate.type].CM_InvProcessDefaultEmail;
	endif;
	
	pxyEmailDefaults := emailDefault.cloneSelf(true).CM_InvProcessDefaultEmail;
	
	if not emailAdding then	// there is some email info saved on invoice status before
		pxyEmailDefaults.setFromEmailTemplate(pxyEmailTemplate);	//prepare self.myEmailDefaults from persistent stored email template
		pxyEmailDefaults.setAddresses(pxyEmailTemplate.bccAddresses, pxyEmailTemplate.ccAddresses, pxyEmailTemplate.toAddresses);
	endif;
	
	modalResult := self.myAssistant.showInvoiceStatusEmailOptions(pxyEmailDefaults, false);
	
	if modalResult = IDOK then
		pxyEmailTemplate.setFromObjectEmail(pxyEmailDefaults);	//saving email info on the voyage status
		oldTemplate := pxyProcess.myEmailTemplate;
		if oldTemplate &lt;&gt; pxyEmailTemplate then
			delete oldTemplate;
		endif;
		pxyEmailTemplate.setMyParent(pxyProcess);
	/*	if pxyEmailTemplate.canBeDeletedForVoyageStatus then		//22.07.2025	navhn30		MTN-35477	
			pxyEmailTemplate.setMyParent(null);
			delete pxyEmailTemplate;
		endif;*/
	endif;
	
epilog

	delete pxyEmailDefaults;
	if loadState then	
		app.cmsEndLoad(loadState);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="initDataTable" id="6fe649e9-30fd-4e46-87cb-4831e22f4942">
        <updating/>
        <source>initDataTable() updating;
/*
Purpose:	TFS 39618		
Date				Who			Reason
JANUARY 2019		CNWAB1		Initial creation
*/

vars
	area					: CM_TerminalArea;
	title					: String;
	
begin

	self.setTblDataEntRows(ETDef_InvoiceProcessDetail);

	self.zClearSortColumns();
	self.zAddSortColumn(ETRow_InvoiceProcess, false);
	self.zAddSortColumn(ETRow_Description, false);

end;</source>
    </JadeMethod>
    <JadeMethod name="initForm" id="3b8afe24-b67f-43aa-8bdd-a88f7d09d56f">
        <updating/>
        <source>initForm() updating;
/*
Purpose:	TFS 39618		
Date				Who			Reason
JANUARY 2019		CNWAB1		Initial creation
*/

vars
begin

	self.allowPrint		:= true;
	self.allowExportCSV	:= true;
	self.allowSearch	:= false;
	self.allowTblDataSearch := true;
	self.allowDelete := false;
	self.allowAdd := false;
	
	self.setNavigatorHeading(self.caption);

	self.useTblThumb := true;
	self.frmDetailsBottom.visible := false;
	self.mnuTblVPrint.enabled	:= true;	
	self.mnuTblVExportCSV.enabled:= true;	
	
	self.initTblThumb();
	self.initTblEntDetail();
	self.clearErrorWarnings();	

end;</source>
    </JadeMethod>
    <JadeMethod name="initTblEntDetail" id="3f85750b-6805-4bbb-b33c-afcf16dfa2ec">
        <source>initTblEntDetail();
/*
Purpose:	TFS 39618		
Date				Who			Reason
JANUARY 2019		CNWAB1		Initial creation
*/

vars
	entTableDef		: EntTableDef;
	theRow			: Integer;
	theTable		: CM_EntryTable;
	
begin

	theTable := self.tblEntDetail;
	theTable.warningMethod := 'entTableWarning';

	theTable.stretchToParent := true;
	theTable.optimiseRowHeight := true;
	entTableDef := app.myController.getEntTableDef(ETDef_InvoiceProcessDetail);
	theTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	
	theTable.adjustHeight(200);	
	theTable.optimiseHeadingColumn();
	theTable.changeMode := theTable.ChangeMode_FirstOnly;
end;</source>
    </JadeMethod>
    <JadeMethod name="initTblThumb" id="43f77f46-b31a-41e5-ae9c-e0fcdcaba4e9">
        <source>initTblThumb();
/*
Purpose:	TFS 39618		
Date				Who			Reason
JANUARY 2019		CNWAB1		Initial creation
*/

vars

	theTable		: CM_ThumbnailTable;
begin
	theTable := self.tblThumb;
	theTable.clear;
	theTable.scrollBars := Table.ScrollBar_Horizontal;

end;</source>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="7a52ceaf-e5f6-46a8-8b55-c283ed4453e0">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
/*
Purpose:	TFS 39618		
Date				Who			Reason
JANUARY 2019		CNWAB1		Initial creation
*/

vars

begin
	inheritMethod(_colorControl);
	self.setColorsForEntryTable(self.tblEntDetail);
	self.frmDetailsTop.backColor := self.backColor;

end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="d2d7af74-37c0-4b0b-babf-607cdad4483a">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*
Purpose:	TFS 39618		
Date				Who			Reason
JANUARY 2019		CNWAB1		Initial creation
14 June 2023 navmv20 CR 58215 Task 58217: UI - Invoice Process Email
*/

vars
	now : Time;
	entDef		:EntTableDef;
	entRow			: EntTableRow;
	displayValue : String;
begin
	entDef := app.myController.getEntTableDef(ETDef_InvoiceProcessDetail);


	inheritMethod();

	self.tblEntDetail.clearValues();
	self.tblEntDetail.setFocus;
	
	foreach entRow in entDef.allEntTableRows do
		if self.myCurrentObject &lt;&gt; null then
			//14/06/2023 navmv20 CR 58215 Task 58217 - start
			//displayValue := self.myCurrentObject.getDisplayStringForAttribute(entRow.name, false).String;
			if entRow.name = ETRow_EmailOptions 
			and self.mode = self.Mode_Update then
				displayValue := app.getErrorString(Dbl_Click_To_Add_Update);
			else
				displayValue := self.myCurrentObject.getDisplayStringForAttribute(entRow.name, false).String;
			endif;
			//14/06/2023 navmv20 CR 58215 Task 58217 - end
		else
			displayValue := null;
		endif;
		
		tblEntDetail.setValueByName(entRow.name, displayValue);		
	endforeach;
	
	self.tblEntDetail.userInputEnabled := true;
	self.tblEntDetail.goToRowByName(ETRow_Description);

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyDataClass" id="cf4e037b-f314-4f3d-a421-4dd72fd2550d">
        <updating/>
        <source>setMyDataClass() updating;
/*
Purpose:	TFS 39618		
Date				Who			Reason
JANUARY 2019		CNWAB1		Initial creation
*/

vars

begin
	self.myDataClass := CM_InvoiceProcess;

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromTable" id="a746cfcd-9eeb-4a5a-9aa8-260d3c05384e">
        <source>setProxyFromTable(pxyInvProcess : CM_InvoiceProcess input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2019	jlgab1	Initial creation

*/

vars
	description : String;

begin
	description := self.tblEntDetail.getValueByName(ETRow_Description).String;
	pxyInvProcess.setProxy(pxyInvProcess.code, description, pxyInvProcess.pinEmailOffset);

epilog

end;</source>
        <Parameter name="pxyInvProcess" type="CM_InvoiceProcess" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupPermissions" id="32d57904-b68e-4a4e-ad23-9a35fc7f76c3">
        <updating/>
        <source>setupPermissions() updating;
/*
Purpose:	TFS 39618		
Date				Who			Reason
JANUARY 2019		CNWAB1		Initial creation
*/
vars
	canEdit		: Boolean;
begin
	
	canEdit := app.myPassport.myUser.canDo(null, self.permissionMaint);

	// does the user have maintenance premission for this form
	self.allowAdd		:= false;
	self.allowDelete	:= false;
	self.allowUpdate 	:= canEdit;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="86a50881-b5bc-4306-939f-fb3ec69fb3ac">
        <updating/>
        <source>showThumbnailData(_status : CM_InvoiceProcess) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2019	jlgab1	Initial creation

*/

vars

	theTable		: CM_ThumbnailTable;
begin
	theTable := self.tblThumb;

	self.tblThumb.rows := 0;
	self.tblThumb.columns := 2;
	self.showThumbnailForDef(ETDef_InvoiceProcessDetail, _status);
	
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnEditTV.enabled := false;
		self.btnSaveBase.enabled := false;
	endif;

epilog

end;</source>
        <Parameter name="_status" type="CM_InvoiceProcess"/>
    </JadeMethod>
    <JadeMethod name="tblEntDetail_dblClick" id="bfc26967-e5e0-4577-a605-89e8e5aaff53">
        <controlMethod name="CM_EntryTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblEntDetail_dblClick(table: CM_EntryTable input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 June 2023 navmv20 CR 58215 Task 58217: UI - Invoice Process Email

*/

vars
	row	: Integer;
	entTable	: CM_EntryTable;
begin

	entTable := table.CM_EntryTable;
	row := entTable.getRow(ETRow_EmailOptions);
	if table.row = row and row &gt; 0 then
			self.doShowEmailForm();
	endif;


epilog

end;</source>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="4275f460-6f4c-40ef-b191-fe17b7f19d05">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 16 February 2023 14:19:05.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0025635, locale);
end;</source>
    </JadeMethod>
</GUIClass>
