    <JadeMethod name="getVisibleStatus" id="e1d72bbe-4bda-4401-9db4-25619c168bd2">
        <source>getVisibleStatus(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05/06/2024	navkc1 CR 63736 Task 63737: Jade - New Filter Control

*/

vars

begin
	if self.myBtnForToolbarTblFilter &lt;&gt; null then
		return self.myBtnForToolbarTblFilter.visible;
	endif;
	
	if self.myMenuUserToolbar &lt;&gt; null then
		return true;
	endif;
	
	return inheritMethod();

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initFromButton" id="42a9d25a-aed3-490d-84b7-2452d2719ef3">
        <updating/>
        <source>initFromButton(_button: CMUI_ButtonForToolbarTblFilter; _showCaptions: Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05/06/2024	navkc1 CR 63736 Task 63737: Jade - New Filter Control

*/
vars
	tmpHeight,
	tmpWidth	: Real;
	tmpHelp		: String;
	theCaption	: String;

begin
	if _button = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Button passed in is null');
		return;
	endif;
	
	self.myBtnForToolbarTblFilter := _button;
	self.referenceType 		:= self.ReferenceType_Button;
	self.style				:= _button.style;
	
	self.userObjectName := _button.name;

	if _button.fontCharacter &lt;&gt; null then
		self.drawCharacter(_button.fontName, _button.fontCharacter.Character, _button.fontColour);
	else
		self.myToolbarPicture.picture 			:= _button.picture;
		self.myToolbarPicture.pictureDisabled	:= _button.pictureDisabled;
		self.myToolbarPictureCaption.picture 			:= _button.picture;
		self.myToolbarPictureCaption.pictureDisabled	:= _button.pictureDisabled;
		
		
	endif;

	self.setShowCaptions(_showCaptions);

	tmpHelp := _button.bubbleHelp;

	if tmpHelp = null then
		self.myToolbarOverlay.bubbleHelp := _button.caption.replaceString('&amp;', '');
	else
		self.myToolbarOverlay.bubbleHelp := tmpHelp;
	endif;
	
	self.enabled := _button.enabled;
	self.visible := _button.visible;
	
	if _button.value then
		self.resetButtonState(_button.value);
	endif;
end;</source>
        <Parameter name="_button" type="CMUI_ButtonForToolbarTblFilter"/>
        <Parameter name="_showCaptions" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="mouseDown" id="3da76f3c-d7f3-4ff9-b676-e2b556b5c580">
        <controlMethod name="CMUI_ToolbarButton::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>mouseDown(frame: CMUI_ToolbarButton input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05/06/2024	navkc1 CR 63736 Task 63737: Jade - New Filter Control

*/

vars

begin
	if button &lt;&gt; self.MouseButton_Left then
		return;
	endif;

	frame.drawButtonDown();
	if self.myBtnForToolbarTblFilter &lt;&gt; null then
		self.myBtnForToolbarTblFilter.mouseDown(self.myBtnForToolbarTblFilter,button,shift,self.left + x,self.top + y);
	endif;

epilog

end;</source>
        <Parameter name="frame" type="CMUI_ToolbarButton" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseEnter" id="6ad24439-675e-474f-a613-c64853cd6ecc">
        <controlMethod name="CMUI_ToolbarButton::mouseEnter"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>mouseEnter(frame: CMUI_ToolbarButton input) updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05/06/2024	navkc1 CR 63736 Task 63737: Jade - New Filter Control

*/

vars

begin
	if self.style &gt;= Button.Style_Auto2State and
	   self.myBtnForToolbarTblFilter.value then
		// do nothing
	else
		frame.drawButtonUp();
	endif;

epilog

end;</source>
