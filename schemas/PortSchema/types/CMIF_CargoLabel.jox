    <JadeMethod name="getConvertedHeight" id="77cb560b-b2da-4ff7-a61e-5c8a83b894c0">
        <source>getConvertedHeight(_shortName : String) : String;
/*
Purpose:			For JRW reports - to return the height in the measurement unit specified

Parameters:			_units - a valid length measurement type short name

Return Value:		The height converted to the specified measurement type

Changed On	By			Reason
----------	--------	-----------------------------------------------------
9/10/2013	cnwjre1		Initial creation PAR #32751 additional reporting fields
*/
vars
	height : Decimal [12,4];
	measurementType		: CM_MeasurementType;

begin
	measurementType := app.myRoot.allMeasurementTypesByShortName[_shortName];
	if measurementType = null or not measurementType.isLinear() then
		return app.getErrorString(Invalid);
	endif;

	if self.myTrackedItem &lt;&gt; null then
		height := self.myTrackedItem.height;
	elseif self.myBookingRef &lt;&gt; null then
		height := self.myBookingRef.height;
	elseif self.myBOL &lt;&gt; null then
		height := 0;
	elseif self.myGateReceival &lt;&gt; null then
		height := self.myGateReceival.height;
	elseif self.myGateReceivalByType &lt;&gt; null then
		height := self.myGateReceivalByType.height;
	endif;
	
	return app.convertMeasurementForDisplay(measurementType.shortName, height);
	
epilog

end;</source>
        <Parameter name="_shortName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getConvertedLength" id="f2061d9e-c0fe-47e5-a576-ed3ad9352998">
