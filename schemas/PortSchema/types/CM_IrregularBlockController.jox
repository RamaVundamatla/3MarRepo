/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 July 2020	jlgndl1	Initial creation	TFS 49775

*/

vars

	yaCapacity : String;
	subLoc : CM_RackShelfController;
	
begin

	if self.allSubLocations.isEmpty then
		yaCapacity := self.maxCapacity.asStringJMT;
	
	else
		foreach subLoc in self.allSubLocations do
			if yaCapacity &lt;&gt; null then
				yaCapacity := yaCapacity &amp; ", ";
			endif;
			yaCapacity := yaCapacity &amp; subLoc.getYACapacity.asStringJMT;
		endforeach;
	
	endif;
	
	return yaCapacity;

epilog

end;</source>
        <ReturnType type="String"/>
