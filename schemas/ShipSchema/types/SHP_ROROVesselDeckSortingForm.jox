    <JadeMethod name="delete" id="6ecc511f-9a53-4ccc-a075-7783bad704be">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>delete() updating, clientExecution;
// delete proxies here to catch form close from control box 
vars

begin
	self.doDeleteProxies();	
end;
</source>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="66a61cf6-3475-47c7-aa48-2284821795ca">
        <updating/>
        <source>doBaseFormSave() updating, protected;
/*
Date		    Who			Reason
Dec 2011		cnwjre1	Par 28687 after CCMS 1035, implement RORO vessel deck re-ordering
*/

vars
	loadStateSet : Boolean;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	inheritMethod();
	app.cmsBeginLoad(loadStateSet);
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateROROVesselDecksOrd(self.pxyDecks, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
		self.unloadForm();
			break;
		else
			theResult := app.showErrorWarningDialog(app.getErrorString(Decks), app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;
	
epilog
	app.cmsEndLoad(loadStateSet);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDeleteProxies" id="62049274-e8ff-46a1-9d1e-037581403258">
        <source>doDeleteProxies();
/*
Date		    Who			Reason
Dec 2011		cnwjre1	Par 28687 after CCMS 1035, implement RORO vessel deck re-ordering
*/

vars
	deck : CM_DeckVessel;
begin
	foreach deck in self.pxyDecks do
		self.pxyDecks.remove(deck);
		delete deck;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="doDisplayDecks" id="f98b932b-7bfc-4910-b6b7-8af0f98539bb">
        <updating/>
        <source>doDisplayDecks() updating;
/*
Date		    Who			Reason
Dec 2011		cnwjre1	Par 28687 after CCMS 1035, implement RORO vessel deck re-ordering
*/

vars
	deck	: CM_DeckVessel;
	
	pxyDeck : CM_DeckVessel;
	idx : Integer;
	theTable : CM_DataTable;
	
begin
	if self.myCurrentROROVesselStructure = null then
		return;
	endif;
	
	theTable := self.tblDecks;
	
	self.tblDecks.rows := self.tblDecks.fixedRows;	
	
	
	beginLoad;
	foreach deck in self.myCurrentROROVesselStructure.allDecks do		
			
		pxyDeck := deck.pxyCreateUpdateProxy();
		
		pxyDeck.setOrdinal(deck.ordinal);
		self.pxyDecks.add(pxyDeck);
	endforeach;
	endLoad;
	
	
	foreach deck in self.pxyDecks discreteLock do		
		
		idx := self.tblDecks.addItemObject(deck,deck.code &amp; Tab &amp; deck.description &amp; Tab &amp; Tab);		
		self.addUpAndDownArrows(idx);	
		//  Note: no sub-deck ordering here
	endforeach;	
	
	self.tblDecks.adjustHeight(self.FORM_HEIGHT + 50);
	self.tblDecks.height := self.tblDecks.height + 10;	// 28687 avoid the vertical scroll when it actually does fit
	self.height := self.tblDecks.height + 50 + self.frmToolbar.height;
epilog
	endLoad;										// 19/04/2013 cnwmh5 #31457
end;</source>
    </JadeMethod>
    <JadeMethod name="doTblDecksClick" id="430ae427-50a7-46c1-89ae-8f14140cf45b">
        <updating/>
        <source>doTblDecksClick() updating;
/*
Date		    Who			Reason
Dec 2011		cnwjre1	Par 28687 after CCMS 1035, implement RORO vessel deck re-ordering
*/

vars
	theCol, theRow 		: Integer;
	deck 				: CM_DeckVessel;	
	realDeck 			: CM_Deck;
	ordinal1, ordinal2 	: Integer;
begin
	theRow := self.tblDecks.row;
	if theRow &lt;= self.tblDecks.fixedRows then
		return;
	endif;
	theCol := self.tblDecks.column;

	deck := self.tblDecks.accessRow(theRow).itemObject.CM_DeckVessel;
	ordinal1 := deck.ordinal;
	// MOVE UP
	if theCol = self.TblCol_Up and theRow &gt; 2 then
		deck := self.tblDecks.accessRow(theRow - 1).itemObject.CM_DeckVessel;
		ordinal2 := deck.ordinal;
		self.pxyDecks.moveElement(ordinal1,ordinal2, deck, true);
		self.tblDecks.moveRow(theRow,theRow - 1);	
	endif;
	
	// MOVE DOWN
	if theCol = self.TblCol_Down and theRow &lt; self.tblDecks.rows then			
		deck := self.tblDecks.accessRow(theRow +1).itemObject.CM_DeckVessel;
		ordinal2 := deck.ordinal;
		self.pxyDecks.moveElement(ordinal1,ordinal2, deck, true);
		self.tblDecks.moveRow(theRow,theRow + 1);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="59049a31-acda-40b4-855e-6c25e61e6349">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018572, locale);
end;</source>
    </JadeMethod>
</GUIClass>
