    <JadeMethod name="doBuildComboRTQ" id="277babdb-97d8-4ef0-9b4a-01779652fb67">
        <source>doBuildComboRTQ();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2009	cnwrd1	Initial creation

*/


vars
	terminal		: CM_Terminal;
	radioTel		: CM_RadioTelemetry;
	masterQueue 	: CM_MasterQueue;
	queues			: CM_RTQueueArray;	
	fromTA,
	toTA			: CM_TerminalAreaMaster;
	queue			: CM_RadioTelemetryQueue;
begin

	self.cmbRTQueue.clear();
	
	/*
	if self.cmbSourceArea.listIndex &lt;&gt; CNEC_NULL_INDEX then
		fromTA	:=	self.cmbSourceArea.getObject().CM_TerminalAreaMaster;
	endif;
	
	if self.cmbTargetArea.listIndex &lt;&gt; CNEC_NULL_INDEX then
		toTA	:=	self.cmbTargetArea.getObject().CM_TerminalAreaMaster;
	endif;
	*/

	//- cnwmd1, Par 25639
	//toTA := null;  // as sugested by Emmet, rtq's are setup wiht from..
	
	create queues transient;
	
	terminal := self.myTerminal;
	
	radioTel := terminal.radioTelemetry;
	if radioTel = null then
		return;
	endif;
	
	masterQueue	:= radioTel.masterQueue;
	//masterQueue.getAllQueuesForMove( fromTA, toTA , queues); //cnwrd1 par 26395 23.11.2010 --
	masterQueue.getAllQueues(queues); //cnwrd1 par 26395 23.11.2010 ++
	

	foreach queue in queues do
		self.cmbRTQueue.addItemObject( queue.id, queue );
	endforeach;
	
		
epilog
	delete queues;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildComboRelease" id="c448cc2b-ac57-46ec-9883-bda39142b8a7">
        <source>doBuildComboRelease();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12/08/2009	cnwrd1	Initial creation
11/08/2011	cnwdap1	PAR #27972 Bulk release type no longer translatable, replaced by string constants
07/06/2022  navds20	52720 - MTN - Delivery Requests - All Release Types
*/

vars

begin

	//self.myAssistant.comboBoxBulkRelByTypeStatus(self.cmbRelease.getEmbeddedControl.ComboBox, app.getErrorString(BR_TYPE_DESCR_PACKING),BR_ACTIVE_STRING, null);	// PAR #27972
	//self.myAssistant.comboBoxBulkRelByTypeStatus(self.cmbRelease.getEmbeddedControl.ComboBox, BR_TYPE_PACKING_STR ,BR_ACTIVE_STRING, null);	// PAR #27972
	self.myAssistant.comboBoxBulkRelByTypeStatus(self.cmbRelease.getEmbeddedControl.ComboBox, app.yardOpsDeliveryTypeEnumToStr(self.myTerminal.getConfig(YardOpsDelReqTypes).Integer),BR_ACTIVE_STRING, null); //07/06/2022 navds20 TFS 52720
	
	if self.myInitialisingRelease &lt;&gt; null then
		self.cmbRelease.setForObject( self.myInitialisingRelease );
		//self.doReleaseChange();
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildComboReleaseItem" id="503cc6a6-1a77-4dea-9066-7bcb03ddd91f">
        <source>doBuildComboReleaseItem();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 August 2009	cnwrd1	Initial creation

*/

vars

	bulkRelease			: CM_BulkRelease;
	reserveDetail,
	firstDetail			: CM_ReserveDetail;
	first : Boolean;
begin

	first := true;

	bulkRelease := self.myInitialisingRelease; //self.cmbPackingReq.listObject.CM_BulkRelease;
	
	self.cmbReleaseItem.clear();
	self.cmbReleaseItem.setValue(null);
	
	if bulkRelease = null then		
		self.cmbReleaseItem.setValue(null);
		return;
	endif;
	
	// ok we have a bulkrelease now populate item combo.
	
	foreach reserveDetail in bulkRelease.allReserveDetails do
	
		if reserveDetail.isKindOf(CM_ReserveSelection) then
			self.cmbReleaseItem.addItemObject (reserveDetail.CM_ReserveSelection.getDescription(), reserveDetail  ) ;
			
			if first = true then
				firstDetail := reserveDetail;
				first := false;
			endif;
		endif;
	endforeach;
	
	if self.cmbReleaseItem.getEmbeddedControl().ComboBox.listCount &gt; 0 then
		self.cmbReleaseItem.setForObject( firstDetail);
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildComboShifts" id="853c44d4-24f9-41f9-b362-d770eb121f94">
        <source>doBuildComboShifts();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 Aug 2009	cnwrd1	Initial creation
22 Jun 2010	cnwkpd1	PAR #24609 - Change in bahaviour of Terminal shift calculation
//22 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	iter		: Iterator;
	shift		: CM_Shift;
	tmpString : String;
	idxRow,
	oldShiftDay,
	day, idx, shiftDay : Integer;
	isFirst		: Boolean;
//	shifts : CM_ShiftStartDateCodeDict;
	frmTS, toTS : TimeStamp;
	tmpTime : Time;
	isVisible : Boolean;
	nowServerTS : TimeStamp;
	shiftStartTS : TimeStamp;
	shiftEndTS : TimeStamp;
begin
	oldShiftDay := 0;
	idxRow := 2;	
	
	nowServerTS := app.actualTimeServer();
	
	frmTS.setDate(nowServerTS.date());
	tmpTime.setTime(0,0,0,0);
	frmTS.setTime(tmpTime);
	
	toTS.setDate(nowServerTS.date() + 20);
	tmpTime.setTime(23,59,59,0);
	toTS.setTime(tmpTime);
	
	self.cmbShifts.clear();
	self.allShifts.purge();				// PAR #24609
	
	//create shifts transient;
	self.myTerminal.getShiftsFromRange(self.allShifts, frmTS, toTS);
	
	self.cmbShifts.addItemObject('',null  ) ;
	
	iter := self.allShifts.createIterator();
	while iter.next(shift) do
		if shift.ignore then
			continue;
		endif;
		
		//22 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
		shiftStartTS := self.systemToLocalTime(shift.startDateTime);
		shiftEndTS	 := self.systemToLocalTime(shift.endDateTime);
		
		shiftDay := shiftStartTS.Date.dayOfWeek();
		tmpString := shift.getShiftDay().padBlanks(10) &amp; Tab &amp; 
						shiftStartTS.Date.shortFormatJMT &amp; " " &amp; shiftStartTS.Time.String &amp; Tab &amp; 
						shiftEndTS.Date.shortFormatJMT   &amp; " " &amp; shiftEndTS.Time.String &amp; Tab &amp; 
						shift.getShiftLengthDesc() &amp; Tab &amp; 
						shift.code &amp; Tab &amp; 
						shift.description;

		self.cmbShifts.addItemObject(tmpString,shift  ) ;
		isVisible := true;
	endwhile;
	
	self.cmbShifts.visible := isVisible;
	 
epilog

	delete iter;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doBuildComboSource" id="b5e4e543-fd39-46ae-a982-79e7c5a3afac">
        <updating/>
        <source>doBuildComboSource() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
13 August 2009	cnwrd1	Initial creation
25/02/2010 		cnwcs5 	remove VTA references
08/09/2022		jlika1	TFS 54699 - CUX - MAFI Handling Enhancements - MAFI Heap Terminal Area
*/

vars

	aTerminalArea,
	aBlockStack		: CM_TerminalArea;
	aGridArea		: CM_GridArea;
	aGridObject 	: CM_GridObject;
	idx : Integer;
	theFilter		: CMQF_TerminalAreas;
	theQryReport	: CM_QryReport;
begin
	
	self.mousePointer := Window.MousePointer_HourGlass;
	self.cmbSourceArea.clear;
	
	theQryReport := app.myRoot.myReportMenuRoot.getReportByConstantValue(CM_RepTerminalArea);
	
	create theFilter transient;
	theFilter.allTerminals.add(self.myTerminal);
	theFilter.terminalAreaTypes.add(TA_TYPE_DEPOT_LCL);
	theFilter.terminalAreaTypes.add(TA_TYPE_BLOCK_STACK);
	theFilter.terminalAreaTypes.add(TA_TYPE_SUBBLOCK_STACK);	
	theFilter.terminalAreaTypes.add(TA_TYPE_WASH_AREA);			
	theFilter.terminalAreaTypes.add(TA_TYPE_PTI);				
	theFilter.terminalAreaTypes.add(TA_TYPE_REPAIR);				
	theFilter.terminalAreaTypes.add(TA_TYPE_RECTRANS);				
	theFilter.terminalAreaTypes.add(TA_TYPE_RELTRANS);				
	theFilter.terminalAreaTypes.add(TA_TYPE_RAIL_TRANS);				
//	theFilter.terminalAreaTypes.add(TA_TYPE_ROAD_TRANS);			25/02/2010 cnwcs5 remove VTA references	
	theFilter.terminalAreaTypes.add(TA_TYPE_DAIRY);								
//	theFilter.terminalAreaTypes.add(TA_TYPE_FORK_LIFT_STACK);	

	// 12/03/2010	cnwjre1		CCMS 1101 add gridded areas 23098
	// 							same as done in CMUI_SelectISOSource
	theFilter.terminalAreaTypes.add(TA_TYPE_STRADDLE_STACK);	
	theFilter.terminalAreaTypes.add(TA_TYPE_FORK_LIFT_STACK);	
	theFilter.terminalAreaTypes.add(TA_TYPE_RTG);	
	theFilter.terminalAreaTypes.add(TA_TYPE_RMG);
	theFilter.terminalAreaTypes.add(TA_TYPE_RAIL_TRANS);	 //cnwrd1 6.8.2010 par 25315
	theFilter.terminalAreaTypes.add(TA_TYPE_IRREGULAR_BLOCK_AREA);	 //cnwrd1 13.8.2010 par 25315
	theFilter.terminalAreaTypes.add(TA_TYPE_RORO_LANE_AREA);	//29 May 2012	NDL	Par 29642
	theFilter.terminalAreaTypes.add(TA_TYPE_MAFI);
	
	theQryReport.doFilter(theFilter, app.myPassport);
	
	//idx := self.cmbSourceArea.addItem('');
	//self.cmbSourceArea.addItem[idx] := null;
	self.cmbSourceArea.addItemObject('', null);
	
	foreach aTerminalArea in theFilter.allQryTerminalAreas do
	/*	if  aTerminalArea.type = TA_TYPE_RAIL_TRANS
		or  aTerminalArea.type = TA_TYPE_ROAD_TRANS
		or  aTerminalArea.type = TA_TYPE_CRANE_TRANS
		or  aTerminalArea.type = TA_TYPE_DELETE then
			continue;
		endif;*/
		
		if aTerminalArea.type = TA_TYPE_CRANE_TRANS
		or  aTerminalArea.type = TA_TYPE_DELETE then
			continue;
		endif;

		//idx := self.cmbSourceArea.addItem(aTerminalArea.id &amp; " " &amp; aTerminalArea.getMenuDetails(false,REAL_MODE));
		//self.cmbSourceArea.itemObject[idx] := aTerminalArea;
		self.cmbSourceArea.addItemObject( aTerminalArea.id &amp; " " &amp; aTerminalArea.getMenuDetails(false,REAL_MODE) , aTerminalArea);
		
		//cnwrd1 par 28628 4.11.11
		//if self.myTerminal.getConfig(UseBestPickDirector).Boolean then  //cnwrd1 par 29351 3.4.2012 always show all these bits regardless of term config &amp; mvoe type
			if aTerminalArea.isGridArea then
				aGridArea := aTerminalArea.CM_GridArea;
				//OMG hideous hack for bays/rows
				if aGridArea.areLocationIdsColThenRow then
				// forklift/gbs
				//look at columns/bays
					foreach aGridObject in aGridArea.allGridColumns do
						self.cmbSourceArea.addItemObject(aTerminalArea.id &amp; " " &amp; aGridObject.getFullLabel() , aGridObject);		
					endforeach;
				else
				//straddle etc lool at bays/rows
					foreach aGridObject in aGridArea.allGridRows do
						self.cmbSourceArea.addItemObject( aTerminalArea.id &amp; " " &amp; aGridObject.getFullLabel() , aGridObject);		
					endforeach;			
				endif;
			endif;
		//endif;
	endforeach;

epilog
	delete theFilter;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
