    <JadeMethod name="btnCancel_click" id="f35b0173-73de-4fd8-a5cc-35053a7120e1">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2015	cnwndl1	Initial creation

*/

vars

begin
	//jlier1	TFS 53515 30/5/22
	if self.isModal then
		self.modalResult:=IDCANCEL;
	endif;
	self.unloadForm();

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnSave_click" id="d9267470-5686-41dd-a542-74a137818874">
