    <JadeMethod name="validateForCreate" id="9077c1a1-6598-4202-9d9d-105f7134702a">
        <source>validateForCreate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2018	jlgndl1	Initial creation	TFS 38560

*/

vars

begin

	if self.myHarbour = null then
		app.raiseCMException(Must_select_harbour, null, null);
		return;
	endif;
	
	if self.myVoyageProcess = null then
		app.raiseCMException(Voyage_process_selected, null, null); 
		return;
	endif;
	
	self.validateForUpdate();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="d50d55a7-7824-40dd-be38-e5a2ae6ac040">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2018	jlgndl1	Initial creation	TFS 38560
13 Nov 2018	NDL	TFS 41980 - Remove use of some local resource refs
*/

vars

begin

//	if self.myHMSResourceForCancel = null
//	and self.myHMSResourceForDeparture = null
	if self.myHMSResourceForExtension = null
//	and self.myHMSResourceForShift = null
//	and self.myHMSResourceForUpdate = null
	and self.myHMSResourceForWater = null
//	and self.myHMSResourceForEquipment = null	//20 Aug 2018	NDL	TFS 40127
	and self.allHMSResourceTypeForEquip.isEmpty
	and self.allHMSResourcesForShift.isEmpty
	and self.allHMSResourcesForExt.isEmpty	//18 Feb 2019	NDL	TFS 43374
	then
		app.raiseCMException(Resources_selected, null, null); 
	endif;
	
epilog

end;</source>
    </JadeMethod>
