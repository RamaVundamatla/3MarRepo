    <JadeMethod name="utlUpdateVoyageProcess" id="eab3216e-f86e-4099-8f50-45acb61586a8">
        <source>utlUpdateVoyageProcess(_pxyVoyageProcess : CM_VoyageProcess; _passport : CM_Passport input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 07/03/2018	jlgdap1		Initial creation TFS 37427 PEL1 Voyage Status Enhancements
//
vars
	expectedEdition		: Integer;
	realVoyageProcess 	: CM_VoyageProcess;

begin
	self.initialiseActivity();

	_pxyVoyageProcess.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyVoyageProcess.pxyGetRealObjectAndEdition(realVoyageProcess, expectedEdition);
	
	if realVoyageProcess = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_VoyageProcess.name, null, null);
		return;
	endif;

	app.myValUA.valVoyageProcess(_pxyVoyageProcess, realVoyageProcess, _passport);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realVoyageProcess);
	
	if _passport.noErrors and realVoyageProcess.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Voyage Process', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realVoyageProcess, true);
	endif;

	if _passport.noErrors then
		realVoyageProcess.setForUpdate(_pxyVoyageProcess);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realVoyageProcess, false);
	endif;
	
epilog

end;</source>
        <Parameter name="_pxyVoyageProcess" type="CM_VoyageProcess"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageProgress" id="36ddef21-3860-4422-a163-aa5f5c67f12c">
        <updating/>
        <source>utlUpdateVoyageProgress(_pxyVoyageProgress : CM_VoyageProgress input; 						
						_dischargeOperatorsToAdd : CM_OperatorArray; 
						_loadOperatorsToAdd : CM_OperatorArray;  
						_dischargeOperatorsToRemove : CM_OperatorArray; 
						_loadOperatorsToRemove : CM_OperatorArray;
						_pauseAutoProcess : Boolean;										//navra1 - CR 65823 - 6th Sep 2024
						_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 July 2024	navra1	Initial creation for //navra1 - CR-65068/Task-64641 - Auto Comparison - 15th July 2024

*/

vars
	realVoyageProgress : CM_VoyageProgress;
	expectedEdition : Integer;
	voyage : CM_Voyage;
	theTerminal : CM_Terminal;
begin
	self.initialiseActivity();

	_pxyVoyageProgress.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyVoyageProgress.pxyGetRealObjectAndEdition(realVoyageProgress, expectedEdition);
	
	// ### TFS CR 65830 TASK 65833 19SEP2024 NAVAB1
	voyage := realVoyageProgress.myVoyage;
	if voyage &lt;&gt; null then
		if _passport.noErrors then
			self.myUpdateAuditAgent.audUpdateGeneric(voyage, true);
		endif;
	endif;
	
	
	if realVoyageProgress = null then	
		app.raiseCMException(ProxyMgrCannotLocateReal, CM_VoyageStage.name, null);
		return;
	endif;
	
	exclusiveLock(realVoyageProgress);
	
	realVoyageProgress.setForUpdate(_pxyVoyageProgress, 
									_dischargeOperatorsToAdd,
									_loadOperatorsToAdd,
									_dischargeOperatorsToRemove,									
									_loadOperatorsToRemove,
									_pauseAutoProcess);									//navra1 - CR 65823 - 6th Sep 2024
	
	// ### TFS CR 64612 TASK 64659 18JUL2024 NAVAB1
	if _passport.noErrors then
		//theTerminal := _passport.myTerminal;
		//voyage := realVoyageProgress.myVoyage;
		//app.myEventManager.createSingleObjInfoNoteEvt(voyage,theTerminal.getTerminalEvent(Event_VoyageStageUpdate), realVoyageProgress);	
	endif;
	
	
	// ### TFS CR 65830 TASK 65833 19SEP2024 NAVAB1
	if voyage &lt;&gt; null then
		if _passport.noErrors then
			self.myUpdateAuditAgent.audUpdateGeneric(voyage, false);
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_pxyVoyageProgress" type="CM_VoyageProgress" usage="input"/>
        <Parameter name="_dischargeOperatorsToAdd" type="CM_OperatorArray"/>
        <Parameter name="_loadOperatorsToAdd" type="CM_OperatorArray"/>
        <Parameter name="_dischargeOperatorsToRemove" type="CM_OperatorArray"/>
        <Parameter name="_loadOperatorsToRemove" type="CM_OperatorArray"/>
        <Parameter name="_pauseAutoProcess" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageRTReturnToYard" id="900930e3-9515-4397-ad53-ac6eaf2bfba6">
        <source>utlUpdateVoyageRTReturnToYard(	_locationsController : CM_LocationsController;
								_rtTask : CM_RTQueueTask input; 
								_newMoveMethodRule 	: CM_RTMoveMethodRule;
								_passport : CM_Passport input);

/*

Purpose: We are turning around a ship release wle which is int he process of working

We need to preserve the ship WLE as it would have been before the queud move (i.e. revert to director also) 

Then queue it from where it is back to the yard location, including whatever rtentry we have for a current machine

Parameters:			

Return Value:		


Date		Who		Reason
31 August 2012	cnwrd1	Initial creation // par 29286 cnwrd1 
20 Feb 2024 navhl20 ChangeRequest 62525: EUP | Retrospective Operations - [54177.060] - Cargo &amp; Truck Checks
*/
vars
	moveController			: CMIF_MoveController;
	oldRTQueueMoveMethod,
	newRTQueueMoveMethod 	: CM_RTMoveMethod;
	sourceLoc,
	oldFinalLoc				: CM_LocationsController;
	terminal 				: CM_Terminal;
	shipwle,
	yardwle					: CM_WorkListEntry;
	ti 						: CM_TrackedItem;
	rtTask, 
	workingTask				: CM_RTQueueTask;
	entryDescription, 
	theAlertDetails 		: String;
	isAlertRequired 		: Boolean;
	alert					: CM_SystemAlert;
	lc 						: CM_LocationsController;
	rtQueueArbiter 			: CM_RTQueueArbiter;
	qFM						: CM_FutureMoveQueued;
	rtQEntry 				: CM_RTQueueEntry;
	lcs						: CM_LCSet;
	yardJob,
	pxyInternalJob			: CM_YardInternalJob;
	newJob 					: CM_Job;
	allQEntriesToUpdate		: ObjectSet;
	obj						: Object;
	aFutureMove 			: CM_FutureMove;
begin

	self.initialiseActivity();
	
	ti:=_rtTask.ti;
	
	if ti = null then
		//we should just unqueue!
		return;
	endif;
	
	shipwle:=_rtTask.myEntry.myWorkListEntry;
	
	
	//first we need to figure out where it has come from 
	//first task
	
	rtTask := shipwle.allRTQueueEntries.first.allTasks.first;
	sourceLoc:=shipwle.getOriginalTaskSourceLoc;
	terminal:=rtTask.getMyTerminal;
	oldFinalLoc := shipwle.getFinalTaskTargetLoc();
	qFM := shipwle.allRTQueueEntries.first.allQueuedFutureMoves.first;
	
	//lets figure out the move method rule between where we came from and where we want to go now.
	newRTQueueMoveMethod:= terminal.getRTMoveMethod(sourceLoc,_locationsController);
	
	
	
	// lets unplan from ship.
	//ti.doForcedUnplan(_passport);
	
	aFutureMove := ti.getFutureMovePlanned(true);
	if aFutureMove &lt;&gt; null then
		aFutureMove.setMyWorkListEntry(null,true);
		create moveController transient;
		moveController.setForCreateUnplan(ti,null,null,true);
		app.myUtilityUA.utlUpdateMoveTIUndo(moveController, _passport);	
		delete moveController;
	endif;
	
	if _passport.hasErrors then
		return ;
	endif;

	//set up the move controller 
		

	create moveController transient;
	moveController.setMoveMode(QUEUE_MODE);
	moveController.isRadioTelemetryMove := true;
	moveController.setMyTrackedItem(ti);
	moveController.setMyToPrimaryLocation(_locationsController);
	moveController.updatePassportAndUser(_passport);

	oldRTQueueMoveMethod:=rtTask.myEntry.getRTMoveMethod;
	
	app.myValUA.valRTTaskTarget(moveController, _locationsController);
		
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	if qFM = null then
		_passport.setWarningsIgnored(true);
		moveController.executeMove(_passport);
		_passport.setWarningsIgnored(false);
		
		yardwle := moveController.myWorkListEntry;
		qFM := yardwle.myFutureMove.CM_FutureMoveQueued;
	else
		//create a yard job
		create pxyInternalJob transient;
		pxyInternalJob.setProxy(null,null);
		pxyInternalJob.setProxyInternalJob(false, Controller_Single);
		app.myUtilityCA.utlCreateJob(pxyInternalJob, newJob, _passport); 
		if _passport.hasErrors or newJob = null then
			return;
		endif;
		yardJob := newJob.CM_YardInternalJob;
	
		ti.createTiRequest(yardJob,null, null,_passport);
		if _passport.hasErrors then
			return ;
		endif;
		yardJob.addToJobSheet();
			
		entryDescription:=rtTask.myEntry.entryDescription;
		isAlertRequired:=rtTask.alertRequired(sourceLoc);
		
		
		yardwle := yardJob.allRequests.last.allWorkListEntries.first.CM_YardWLE; 
	endif;
		
	if qFM &lt;&gt; null then
		create lcs transient;
		qFM.allLocationsControllers.copy(lcs);
		qFM.setMyWorkListEntry(yardwle,false);
	endif;
		
	create allQEntriesToUpdate transient;
	shipwle.allRTQueueEntries.copy(allQEntriesToUpdate);
	 
	foreach obj in allQEntriesToUpdate do
		obj.CM_RTQueueEntry.setProxy(yardwle);
	endforeach;
	
	create rtQueueArbiter transient;
	rtQueueArbiter.requeueWMMReturnShipToYard(yardwle,_locationsController,_newMoveMethodRule);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
			
	if qFM = null then
		qFM := yardwle.myFutureMove.CM_FutureMoveQueued;
	endif;
	
			
	qFM.resetLocations(moveController);
	ti.refreshMyFutureLocations(QUEUE_MODE,null);

	foreach lc in lcs discreteLock do
		moveController.doUpdateDisplayEvent(lc);
	endforeach;
	moveController.doUpdateDisplayEvent(_locationsController);


	theAlertDetails:=entryDescription  &amp; app.getErrorString1(Target_location_changed, _locationsController.getFullId);
	//need to raise an alert and edit the ti transaction to indicate the target location has changed
	if isAlertRequired then
		create alert;
		alert.details :=  theAlertDetails;
		alert.setSeverity(SEVERE_INFO);
		alert.myTerminal := terminal;
		alert.add;		
	endif;
	
	app.createEditTransaction(ti,theAlertDetails,null,_passport); 		//20.02.2024 navhl20 #62525

	if shipwle.myRequest&lt;&gt; null and shipwle.myRequest.isKindOf(CM_SlotRequest) and shipwle.myRequest.CM_SlotRequest.myBulkReleaseReserveDetail &lt;&gt; null then
		delete moveController;
		create moveController transient;
		moveController.setMoveMode(PLANNING_MODE);
		moveController.setMyWorkListEntry(shipwle);				
		moveController.setMyTrackedItem(shipwle.myTrackedItem);
		app.myUtilityUA.utlUpdateWLEUnassignTI(moveController, _passport);
	endif;
	
	
	foreach rtQEntry in yardwle.allRTQueueEntries discreteLock do
		foreach workingTask in rtQEntry.allTasks discreteLock do
			if workingTask.status &lt;&gt; TASK_COMPLETE and workingTask.machine &lt;&gt; null then
				//workingTask.machine.sendBroadcastMessage(app.getErrorString1(Target_location_changed, _locationsController.getFullId), false);
				//epr par 33401 19/2/14
				workingTask.machine.causeEvent(Event_Machine_Target_Changed,false,rtQEntry);
				break;
			endif;
		endforeach;
	endforeach;

	yardwle.rebuildStatus();

epilog	
	delete allQEntriesToUpdate;
	delete moveController;
	delete rtQueueArbiter;
	delete lcs;
	//abortTransaction;
end;</source>
        <Parameter name="_locationsController" type="CM_LocationsController"/>
        <Parameter name="_rtTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_newMoveMethodRule" type="CM_RTMoveMethodRule"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageRemarks" id="3e152733-c4ff-4965-9401-36d5d5d837cf">
        <source>utlUpdateVoyageRemarks(_realVoyage :CM_Voyage input; _theRemarks : String; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	expectedEdition		: Integer;
	
begin

	self.initialiseActivity();
	
	if _realVoyage = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, _realVoyage.getName, null, null);
		return;
	endif;

	exclusiveLock(_realVoyage);

	if (not _passport.noErrors) then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Cellular Voyage', null, null);
		return;
	endif;
	
	if _realVoyage.remarks &lt;&gt; _theRemarks then
		app.myAA.auditUpdate(_realVoyage, "remarks", _theRemarks);
		_realVoyage.setRemarks(_theRemarks,false);
	endif;



end;</source>
        <Parameter name="_realVoyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_theRemarks" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageSealCheckRec" id="0ab896dc-03ac-4e61-93f5-dbee2dec48c9">
        <updating/>
        <source>utlUpdateVoyageSealCheckRec(_realVoyage :CM_Voyage input; _sealCheck : Integer;_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 April 2012	cnwer1	Par 29487

*/

vars

begin
	self.initialiseActivity();
	
	_realVoyage.setSealCheckReceival(_sealCheck);
epilog

end;</source>
        <Parameter name="_realVoyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_sealCheck" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
