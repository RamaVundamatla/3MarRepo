    <JadeMethod name="createProxy" id="4ac5a2b9-5d75-4b54-a061-4ed1ed73a6ad">
        <source>createProxy() : CM_Carrier;
/*

Date		Who		Reason
27 November 2014	cnwer1	Initial creation PAR 35304
12/05/2022 			navhl20 TFS 53430  EUP - Sub Carrier registration in MTN
*/

vars
	real,
	proxy 		 : CM_Carrier;
	emailAddress : CM_EmailAddress2ByNameDict;
begin
	if self.action = self.EDI_ACTION_ADD then
		create proxy transient;
	else
		real:=self.getCarrier();
		if real = null then
			return null;
		endif;
		
		proxy:=real.pxyCreateUpdateProxy.CM_Carrier;

	endif;
	proxy.setProxy(self.code,
				   self.description,
				   proxy.allPINNotifyEmailAddresses,
				   self.notAvailable.asBooleanJMT,
				   self.isRail.asBooleanJMT,
				   self.isRoad.asBooleanJMT,
				   self.isSubCarrier,
				   self.getDebtor, 
				   self.colour, 
				   null, 
				   null);  //12/05/2022 navhl20 TFS 53430
	
	return proxy;
epilog

end;</source>
        <ReturnType type="CM_Carrier"/>
    </JadeMethod>
    <JadeMethod name="getCarrier" id="457e1c82-aac7-4cd2-878d-65a2b6767f69">
        <source>getCarrier() : CM_Carrier;
/*

Date		Who		Reason
27 November 2014	cnwer1	Initial creation PAR 35304

*/

vars

begin

	return app.myRoot.allCarriers[code];
epilog

end;</source>
