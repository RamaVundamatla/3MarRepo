    <JadeMethod name="getDisplayStringForAttribute" id="d98a03b4-6aa1-4a2c-9899-8e308e0affa1">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 April 2018	jlgsl4	TFS 37410 Import MTs IMEX transition status

*/

vars
	imex : CM_IMEXStatus;
begin
	if _attrName = 'transitionIMEX' then
		imex := app.myRoot.allImexStatuses[self.transitionIMEX];
		if imex &lt;&gt; null then
			return imex.description;
		else
			return "Unknown";
		endif;
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTableDisplayString" id="7af6ef1e-5a0f-407a-a316-10b7a595dcd6">
        <source>getTableDisplayString(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
28 March 2018	jlgsl4	TFS 37410 Import MTs IMEX transition status

*/

vars

begin
	return self.getCriteriaSummary(", ");	

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTransitionIMEX" id="4296fb06-720f-4be8-b3f5-fa24a85c8eb6">
        <source>getTransitionIMEX() : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
