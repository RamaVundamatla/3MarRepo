Date		Who		Reason
31 Jan 2023 navhl20 ChangeRequest 62166: EUP | 53729 - Delivery Dispatch Screen - outstanding issues

*/

vars

begin
	if _show then
		self.cmbTruckStatus.visible := true;
		self.lblTruckStatus.visible := true;
