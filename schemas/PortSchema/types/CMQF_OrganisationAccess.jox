    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>CCMS HAT 2205</text>
    <DbClassMap file="query"/>
    <CompAttribute name="allQrySites" id="f5c1fd51-de07-4e36-bbfe-373af1cd14f7">
        <type name="IntegerArray"/>
    </CompAttribute>
    <ImplicitInverseRef name="allUsers" id="8192d9a3-a440-4396-96d2-0efa465010aa">
        <memberTypeInverse/>
        <type name="CM_UserByCodeDict"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myOrganisation" id="93dcb179-6dcc-4feb-8feb-f0b7a8ff1d07">
        <embedded/>
        <type name="CM_Organisation"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myVoyage" id="c080ef7a-b2f6-4380-81e1-40346597ba2e">
