    <JadeMethod name="createProperties" id="76d8b2ee-b960-436c-acb5-445a1e7ad0d5">
        <source>createProperties();
/*  CCMS 1262 all CM_TITransaction properties for selector queries
	All common properties (in CM_TITransaction class) plus the equivalent CM_TrackedItem properties
	plus 'doesXMatch' CM_TITransaction methods which return false when transaction.X value &lt;&gt; transaction.myTrackedItem.X value.
	
/****Changes

Date		Name	TFS#			Description
============================================================================
21/08/2014	cnwdap1	PAR #33235		Measurement types in Summaries
12/09/2018	jlgka1	TFS 40735 		Add Operator Group Code.
25/09/2018	jlgka1	TFS 40200 		Add User List6 to use CM_QStrUserProperty.
11/10/2018	jlgka1	TFS 40200 		Change Cargo Contents Status from using getCargoContentsStatus to getMyCargoContentsStatus
07/11/2018	jlgka1	TFS 40670 		Add Consignee / Consignor Group.
31/05/2019	jlgdap1	TFS 44554		AAT Stevedore Data Access
20 Sep 2019	jlgdi1	46043			Added Bill of Lading On Transaction of type CM_QStringProperty
27/09/2019 	jlgzm1	TFS 46703		Direct Release Selector Query
03/06/2020  cnwma1	ChangeRequest  49400: ASPA - Invoice Enhancements for Barges
02/10/2020  cnwma1	 ChangeRequest 50112: ASPA - GCI Stevedores
18/05/2022 	navhl20 TFS 53430  		EUP - Sub Carrier registration in MTN
03/05/2023	jlika1	TFS 57679		PEN - Move Source Location &amp; Move Source Location in Cargo Transaction View
14/09/2023  navmv20 Bug 59787: FR | EUP 53131 - Shipping Line Description not shown in the Selector
20/09/2023	navkc1	CR 60426 Task 60570: Jade - Cust Doc on TI and Trans Selector Query
15/05/2024	jlika1	TFS 63961 CUX | MAFI - MAFI Fields on Cargo Invoice Allocations and Transactions - Selector Query
17/09/2024	jlizm1	TFS 66088 		Parent Mafi id is required on cargo transaction
============================================================================*/
vars
	qProp		: CM_QueryProperty;
begin
	inheritMethod();		// 'Terminal', myTerminal
	
	// common CM_TITransaction properties
	create qProp as CM_QStrBusinessUnit persistent;
	qProp.set('Business Unit', CM_TITransaction::companyCode.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(qProp);

	create qProp as CM_QStrCommodityProperty persistent;
	qProp.set('Transaction Commodity', CM_TITransaction::commodity.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(qProp);

	create qProp as CM_QStrConsignProperty persistent;
	qProp.CM_QStrConsignProperty.type := CONSIGNEE;
	qProp.set('Transaction Consignee', CM_TITransaction::consignee.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(qProp);

	create qProp as CM_QStrConsignProperty persistent;
	qProp.CM_QStrConsignProperty.type := CONSIGNOR;
	qProp.set('Transaction Consignor', CM_TITransaction::consignor.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(qProp);

	create qProp as CM_QContentsStatusLookup persistent;
	qProp.set('Transaction Contents Status', CM_TITransaction::contentsStatus.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(qProp);

	create qProp as CM_QStrCustomsAgent persistent;
