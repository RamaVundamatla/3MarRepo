    <JadeMethod name="getInstructionsForContext" id="f66ed5c0-5bcb-4350-a9f3-61c4bb26a023">
        <source>getInstructionsForContext(_instructions: CM_InstructionsIssuedSet io; _passingObject: Object; _context: String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Sep 2023	navma1 ChangeRequest 60066: FR 53127 | EUP - Additional Operational Instructions on the Order (Web)
12 Oct 2023	navnk30	ChangeRequest 59946: EUP - Additional Operational Instructions on the Order - Enhancement 2

*/


vars
	bolDtl : CM_BOLDtl;
begin
	_instructions.tryAddIfNotNull(self.myInstructions);
	
	if _passingObject &lt;&gt; null and _passingObject.isKindOf(CM_BOLDtl) then		//12.10.2023 navnk30 #59946
		_instructions.tryAddIfNotNull(_passingObject.CM_BOLDtl.myInstructions);
	else		
		foreach bolDtl in self.allBOLDtls do
			bolDtl.getInstructionsForContext(_instructions,_passingObject,_context);
		endforeach;
	endif;

epilog

end;</source>
        <Parameter name="_instructions" type="CM_InstructionsIssuedSet" usage="io"/>
        <Parameter name="_passingObject" type="Object"/>
        <Parameter name="_context" type="String"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceLinesFromBOLTrns" id="1c428e88-8824-4ffe-a786-f1b67153190a">
