    <JadeMethod name="resize" id="b9883ec6-8cb2-4bb9-8dee-738fcd2d274c">
        <controlMethod name="Form::resize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>resize() updating;
// --------------------------------------------------------------------------------
// Created:		23 January 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 18/07/1999	cnwdad1		Add movement of the lblInfo and lblManualWarning labels.
//
// --------------------------------------------------------------------------------
vars
	labelTop	: Real;

begin
	btnCancel.move(((self.width - btnCancel.width) - 18), ((self.height - btnCancel.height) - 36), btnCancel.width, btnCancel.height);
	btnOk.move(((btnCancel.left - btnOk.width) - 6), ((self.height - btnOk.height) - 36), btnOk.width, btnOk.height);
	btnClearAll.move(((btnOk.left - btnClearAll.width) - 6), ((self.height - btnClearAll.height) - 36), btnClearAll.width, btnClearAll.height);
	labelTop	:=	(btnOk.height - lblInfo.height) / 2;
	lblInfo.move(lblInfo.left, (btnOk.top + labelTop), lblInfo.width, lblInfo.height);
	lblManualWarning.move((btnClearAll.left - lblManualWarning.width - 5), (btnOk.top + labelTop), lblManualWarning.width, lblManualWarning.height);
	tblObjects.move(tblObjects.left, tblObjects.top, (self.width - (tblObjects.left * 3) + 2), (btnCancel.top - 46));
	tblObjects.positionScrollbar();
end;</source>
    </JadeMethod>
    <JadeMethod name="setIsBrowseOnly" id="fc774b08-b9dd-4b1c-b7e3-da3fc48406ca">
        <updating/>
        <source>setIsBrowseOnly(pValue: Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		15 July 1999 by cnwdad1
//
// Purpose:		Sets a flag to indicate whether the collection is for browse only,
//				i.e. the maintenance of members is not permitted.
//
// Parameters:	pValue - True if browse only is permitted.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if isBrowseOnly &lt;&gt; pValue then 
		isBrowseOnly := pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="Boolean"/>
    </JadeMethod>
