    <JadeMethod name="translateToDisplayValue" id="ef22239b-cbf3-4411-8355-7e91d4dda162">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 April 2020	jlgndl1	Initial creation	TFS 47958

*/

vars

begin

	if _value.Decimal &lt;&gt; NULL_HUMIDITY then
		return _value.String;
	endif;
	
	return null;

epilog

end;</source>
