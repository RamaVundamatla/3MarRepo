    <JadeMethod name="hasMovesOnSelectedDate" id="a8c8615f-f059-42fc-b9f0-7b7e2b3929d0">
        <source>hasMovesOnSelectedDate( _selectedDate : Date ) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars
	
	firstHistory : CM_MachineHistory; 
	startTime : Time;
	startTimeStamp : TimeStamp;
	history : CM_MachineHistory;
	iter : Iterator;
begin

	
	if self.history.isEmpty then
		return false;
	endif;
	
	startTime.setTime(00,00,00,001);
	startTimeStamp.setDate(_selectedDate);
	startTimeStamp.setTime(startTime);
	
	firstHistory := self.history.getAtKeyGeq(startTimeStamp);
	
	if firstHistory = null or firstHistory.dateTime.Date &lt;&gt; _selectedDate then
		return false;
	endif;
	
	iter := self.history.createIterator;
	iter.startAtObject(firstHistory);
	while iter.next( history ) do
		if history.dateTime.Date &lt;&gt; _selectedDate then
			break;
		endif;
		if not history.isMoveHistory then
			continue;
		endif;
		return true;
	endwhile;
	
	return false;
	
epilog

	delete iter;

end;</source>
        <Parameter name="_selectedDate" type="Date"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
