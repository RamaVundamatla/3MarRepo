    <JadeMethod name="populateProductComponents" id="0f581954-5575-4cc0-9345-3fdc43d3e765">
        <source>populateProductComponents() protected;
// --------------------------------------------------------------------------------
// Created:		22 January 2003 by cnwdad1
//
// Purpose:		Populates the listbox of products/components.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theListbox			: ListBox;
	theProduct			: JSSLKProduct;
	theComponent		: JSSLKComponent;
	listPointer			: Integer;
	
begin
	theListbox	:=	lstProducts;
	theListbox.clear();
	
	foreach theProduct in app.myRoot.allProducts do
		listPointer	:=	theListbox.addItem(theProduct.productName);
		theListbox.itemLevel[listPointer]	:=	1;
		theListbox.itemObject[listPointer]	:=	theProduct;
		
		foreach theComponent in theProduct.allComponents do
			listPointer	:=	theListbox.addItem(theComponent.getDisplay());
			theListbox.itemLevel[listPointer]	:=	2;
			theListbox.itemObject[listPointer]	:=	theComponent;
		endforeach;
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateUsedProductComponents" id="aa5cef4f-b7da-4e02-9039-2d4b67f3d098">
        <source>populateUsedProductComponents() protected;
// --------------------------------------------------------------------------------
// Created:		24 January 2003 by cnwdad1
//
// Purpose:		Populates the listbox of used products/components for the currently
//				selected Customer.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theListbox			: ListBox;
	theCustomer			: JSSLKCustomer;
	theUsedProduct		: JSSLKUsedProduct;
	theUsedComponent	: JSSLKUsedComponent;
	listPointer			: Integer;
	
begin
	theListbox	:=	lstUsedComponent;
	theListbox.clear();
	
	if cmbCustomer.listIndex = JSS_NULL_INDEX then
		return;
	else
		theCustomer	:=	cmbCustomer.listObject.JSSLKCustomer;
		
		foreach theUsedProduct in theCustomer.allUsedProducts do
			listPointer		:=	theListbox.addItem(theUsedProduct.getDisplay());
			theListbox.itemLevel[listPointer]	:=	1;
			theListbox.itemObject[listPointer]	:=	theUsedProduct;
			
			foreach theUsedComponent in theUsedProduct.allUsedComponents do
				listPointer	:=	theListbox.addItem(theUsedComponent.getDisplay());
				theListbox.itemLevel[listPointer]	:=	2;
				theListbox.itemObject[listPointer]	:=	theUsedComponent;
			endforeach;
		endforeach;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="removeProductComponents" id="dbbe8b26-5919-4bf2-b332-c06e3cd4e836">
        <updating/>
        <source>removeProductComponents() updating, protected;
// --------------------------------------------------------------------------------
// Created:		22 January 2003 by cnwdad1
//
// Purpose:		Removes the selected used product components from the currently
//				selected Customer.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theCustomer		: JSSLKCustomer;
	theComponent	: JSSLKComponent;
	allComponents	: JSSLKComponentArray;
	theListbox		: ListBox;
	listPointer		: Integer;
	listSize		: Integer;
	
begin
	theListbox	:=	lstUsedComponent;
	
	if theListbox.listCount = 0 then
		app.msgBox("Please select the Product Component(s) to remove from the Customer.", "Edit Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return;
	endif;
	
	theCustomer	:=	cmbCustomer.listObject.JSSLKCustomer;
	listSize	:=	theListbox.listCount;
	create allComponents transient;
	
	foreach listPointer in 1 to listSize do
		if theListbox.itemSelected[listPointer] then
			theComponent	:=	theListbox.itemObject[listPointer].JSSLKUsedComponent.myComponent;
			allComponents.add(theComponent);
		endif;
	endforeach;
	
	if not allComponents.isEmpty() then
		app.myTA.trxRemoveUsedComponents(theCustomer, self.aObjectEdition, allComponents);
	endif;
	
	self.populateUsedProductComponents();
	self.selectUsedProductComponents();
	app.causeEvent(CUSTOMER_USEDCOMPONENT_CHANGE, true, JSSLKMaintenanceForm.EVENT_TAG_USERCOMPONENT);
	self.resynchObjectAndSetEdition(theCustomer);
epilog
	delete allComponents;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="selectUsedProductComponents" id="2e30b048-dd05-4d86-a92c-f08391ed44b9">
        <source>selectUsedProductComponents() protected;
// --------------------------------------------------------------------------------
// Created:		22 January 2003 by cnwdad1
//
// Purpose:		When a Customer is selected in the combobox, highlight all of the
//				product components it uses in the Product Components list (not the
//				used components list).
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theCustomer			: JSSLKCustomer;
	theUsedProduct		: JSSLKUsedProduct;
	theUsedComponent	: JSSLKUsedComponent;
	theListbox			: ListBox;
	listPointer			: Integer;
	
begin
	theListbox	:=	lstProducts;
	theListbox.clearAllSelected();
	
	if cmbCustomer.listIndex = JSS_NULL_INDEX then
		return;
	else
		theCustomer	:=	cmbCustomer.listObject.JSSLKCustomer;
	endif;
	
	foreach theUsedProduct in theCustomer.allUsedProducts do
		foreach theUsedComponent in theUsedProduct.allUsedComponents do
			listPointer	:=	theListbox.findObject(theUsedComponent.myComponent);
			
			if listPointer &lt;&gt; JSS_NULL_INDEX then
				theListbox.itemSelected[listPointer]	:=	true;
			endif;
		endforeach;
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
