    <JadeMethod name="utlCreateInvoiceLineDescMap" id="2978aa78-9d3f-4cbd-b2ed-86acad96cc21">
        <source>utlCreateInvoiceLineDescMap(pProxyInvLineDescMapping : CM_InvoiceLineDescMapping; 
				pNewInvLineDescMapping : CM_InvoiceLineDescMapping output;
				_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		October 2004 By Andrew Bishop cnwab1
// 09 Jan 2017	cnwma1	TFS #2643 :JMT - Audit of Invoice Maintenance Set-up
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valInvoiceLineDescMap(pProxyInvLineDescMapping);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
