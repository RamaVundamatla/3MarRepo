    <JadeMethod name="isAllReqsInJob" id="75cdba91-0533-416a-9542-4356721035b9">
        <source>isAllReqsInJob(_isLoad : Boolean): Boolean;
/* PAR 28787
Purpose:		IF there is a request, is it in a job.	
Date		Who		Reason
02 December 2011	cnwab1	Initial creation
*/

vars

	slotDefn : CM_ROROSlotDefn;
	slotLC : CM_ROROSlotController;
begin
	
	if self.myGCController &lt;&gt; null then
		if _isLoad then
			if self.myGCController.myRORORequestLoad &lt;&gt; null then
				if self.myGCController.myRORORequestLoad.myJob = null 
				and not self.myGCController.myRORORequestLoad.allAllocations.isEmpty() then // PAR 29807
					return false;
				endif;
			else
				return false;
			endif;
		else
			if self.myGCController.myRORORequestDischarge &lt;&gt; null then
				if self.myGCController.myRORORequestDischarge.myJob = null 
				and not self.myGCController.myRORORequestDischarge.allAllocations.isEmpty() then // PAR 29807
					return false;
				endif;
			else
				return false;
			endif;
		endif;
		
	endif;


	return true;
epilog

end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isLocnGC" id="5562daa9-bb5d-49b2-b8ed-9931f93e815e">
        <source>isLocnGC() : Boolean;
/*
Purpose:			
Date		Who		Reason
10 June 2011	cnwab1	Initial creation
*/

vars

begin
	return true;

epilog

