    <JadeMethod name="includeDLRsSOBsImexCheckCase" id="12dc05fc-6d5f-4c75-b9ff-31dac0b8e4c5">
        <source>includeDLRsSOBsImexCheckCase(_yaData: CM_YADataObjects) : Boolean;
/*

Date		    Who			Reason
24 January 2011	cnwas3	  //cnwas3 par 26773

*/

vars
	status		: Integer;
	yaParent 	: CM_YACriteria; 
begin
	
	status := self.myTrackedItem.getTransitStatus();
	if _yaData.myYAParent.isKindOf(CM_YACriteria) then
		yaParent := _yaData.myYAParent.CM_YACriteria;	
		if yaParent.myYardAllocation &lt;&gt; null and 
			yaParent.myYardAllocation.isKindOf(CM_VoyageAllocation) and
			(status = TI_TransitStatusDLR or status = TI_TransitStatusSOB) then
			return true;		
		endif;
	endif;
	
	return false;
	
end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
