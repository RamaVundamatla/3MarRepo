        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextTagValueOfName" id="a927162f-257f-40ad-a4b6-5e71d20371cf">
        <source>getNextTagValueOfName(_theXML, _tagValue : String;  _pos : Integer io) : String;
// ---------------------------------------------------------------------------
// Created:		30/11/2006 cnwvu1
//
// Purpose:		PAR13045
//
// Parameters:	_pos - position in String
//
// Returns:		String - The value contained within the tag (null if the tag is not found).
//				If tag hasn't been found, returns null and saves _pos unchanged
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	tmpPos	: Integer;
	str		: String;

begin

	tmpPos := _pos;

	str := _theXML.cnEcGetNextTagValueOfName(_tagValue, tmpPos);
	
	if tmpPos &gt; 0 then
		_pos := tmpPos;
	endif;
	
	return str;

end;
</source>
        <Parameter name="_theXML" type="String"/>
        <Parameter name="_tagValue" type="String"/>
        <Parameter name="_pos" type="Integer" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNumAftDoors" id="b31d0348-1ce1-413c-908c-8c11550f0855">
        <source>getNumAftDoors() : Integer;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	totalAftDoors : Integer;
	aSlot : CM_SlotDefn;
begin
	
	foreach aSlot in self.allSlotsByOrdinal do
		if aSlot.doors20Aft then
			totalAftDoors := totalAftDoors + 1;
		endif;
	endforeach;
	return totalAftDoors;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNumCellsTotallyAvailable" id="9ed5d53c-396f-4d62-be05-fa9ba9ba5445">
        <source>getNumCellsTotallyAvailable(_ondeck : Boolean) : Integer;
// ---------------------------------------------------------------------------
// Created:     07 February 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpCell : CM_CellDefn;
	idx, midIdx : Integer;
	include : Boolean;
begin
	include := true; // ### PAR 29840
	
	if _ondeck then
		foreach tmpCell in self.allCellsOnDeckByOrdinal discreteLock do
			if tmpCell.isTotallyUnavailable() then
				// ### PAR 29840
				if not include then
					midIdx := midIdx + 1;
				endif;
				continue;
			endif;
			idx := idx + 1;
			include := false;
		endforeach;
	else
		foreach tmpCell in self.allCellsUnderDeckByOrdinal discreteLock do
			if tmpCell.isTotallyUnavailable() then
				// ### PAR 29840
				if not include then
					midIdx := midIdx + 1;
				endif;
				continue;
			endif;
			idx := idx + 1;
			include := false;
		endforeach;
	
	endif;
	
	return idx + midIdx; // ### PAR 29840
epilog

end;</source>
        <Parameter name="_ondeck" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNumCellsTotallyUnavailable" id="944a225e-2539-445d-9ef8-b6992d09d633">
        <source>getNumCellsTotallyUnavailable(_ondeck : Boolean) : Integer;
// ---------------------------------------------------------------------------
// Created:     07 February 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpCell : CM_CellDefn;
	idx : Integer;
begin
	if _ondeck then
		foreach tmpCell in self.allCellsOnDeckByOrdinal discreteLock do
			if not tmpCell.isTotallyUnavailable() then
				break;
			endif;
			idx := idx + 1;
		endforeach;
	else
		foreach tmpCell in self.allCellsOnDeckByOrdinal discreteLock do
			if not tmpCell.isTotallyUnavailable() then
				break;
			endif;
			idx := idx + 1;
		endforeach;
	
	endif;
	
	return idx;
epilog

end;</source>
        <Parameter name="_ondeck" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNumCellsWide" id="52f26ed0-3310-4152-a51c-3ac754f5ae9b">
        <source>getNumCellsWide(_displayMode : Integer) : Integer;
// ---------------------------------------------------------------------------
// Created:     14 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	// PAR 26760 
	if _displayMode = ShpDisplayMode_Defn then
		return self.allCellsOnDeck.size.max(self.allCellsUnderDeck.size);
	else
		return self.getNumCellsTotallyAvailable(true).max(self.getNumCellsTotallyAvailable(false));
	endif;
	
end;</source>
        <Parameter name="_displayMode" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNumTiersTotallyAvailable" id="a60d86d7-1a83-4213-9cc7-f8079f1712a9">
        <source>getNumTiersTotallyAvailable(_ondeck : Boolean) : Integer;
// ---------------------------------------------------------------------------
// Created:     07 February 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpTier : CM_TierDefn;
	idx,numUnAvail : Integer;
begin

	//03 Nov 2011	NDL	Par 28632
	if _ondeck then
		return self.allTiersOnDeck.size;
	else
		return self.allTiersUnderDeck.size;
	endif;

	if _ondeck then
		foreach tmpTier in self.allTiersOnDeck discreteLock do
			if tmpTier.isTotallyUnavailable() then
				if idx = 0 then // PAR 27468
					numUnAvail := numUnAvail + 1; // PAR 27468
				endif;
				continue;
			endif;
			idx := idx + 1;
		endforeach;
		idx  := idx + numUnAvail; // PAR 27468
	else
		foreach tmpTier in self.allTiersUnderDeck discreteLock do
			if tmpTier.isTotallyUnavailable() then
				continue;
			endif;
			idx := idx + 1;
		endforeach;
	
	endif;

	return idx;
epilog

end;</source>
        <Parameter name="_ondeck" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNumTiersTotallyUnavailable" id="475d06ca-2678-464d-a01a-36c508628e38">
        <source>getNumTiersTotallyUnavailable(_ondeck : Boolean) : Integer;
// ---------------------------------------------------------------------------
// Created:     07 February 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpTier : CM_TierDefn;
	idx : Integer;
begin

	//03 Nov 2011	NDL	Par 28632
	return 0;

	if _ondeck then
		foreach tmpTier in self.allTiersOnDeck discreteLock do
			if not tmpTier.isTotallyUnavailable() then
				continue;
			endif;
			idx := idx + 1;
		endforeach;
	else
		foreach tmpTier in self.allTiersUnderDeck discreteLock do
			if not tmpTier.isTotallyUnavailable() then
				continue;
			endif;
			idx := idx + 1;
		endforeach;
	
	endif;

	return idx;
epilog

end;</source>
        <Parameter name="_ondeck" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNumberOfSlotsAvailable" id="acdb5883-67c1-4881-9155-d2b1cec7d92f">
        <source>getNumberOfSlotsAvailable(_numSlotsOD : Integer io; _numSlotsUD : Integer io);
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	anumSlotsOD : Integer;
	anumSlotsUD : Integer;
	aSlot : CM_SlotDefn;
begin

	foreach aSlot in self.allSlotsOnDeck where (not aSlot.unavailable) do
		anumSlotsOD := anumSlotsOD + 1;
	endforeach;

	foreach aSlot in self.allSlotsUnderDeck where (not aSlot.unavailable) do
		anumSlotsUD := anumSlotsUD + 1;
	endforeach;
	
	_numSlotsOD := anumSlotsOD;
	_numSlotsUD := anumSlotsUD;

end;</source>
        <Parameter name="_numSlotsOD" type="Integer" usage="io"/>
        <Parameter name="_numSlotsUD" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getOnDeckSlotForEDI" id="ab692026-ff59-43b2-9660-db0f839ec17c">
        <source>getOnDeckSlotForEDI(_cellID, _tierID: String): CM_SlotDefn;
//----------------------------------------------------------------
//	Created:	01 April 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tmpSlotDef	: CM_SlotDefn;
	newTier		: String;
begin

	tmpSlotDef := self.allSlotsOnDeck[_cellID, _tierID];
	
	if tmpSlotDef = null then
		if _tierID.isInteger 
		and _tierID.Integer.isOdd then
			newTier := (_tierID.Integer + 1).stringWithLeadingZeros(2);
			tmpSlotDef := self.allSlotsOnDeck[_cellID, newTier];
		endif;
	endif;
	
	return tmpSlotDef;

end;</source>
        <Parameter name="_cellID" type="String"/>
        <Parameter name="_tierID" type="String"/>
        <ReturnType type="CM_SlotDefn"/>
    </JadeMethod>
    <JadeMethod name="getOnShipCraneDescription" id="4bb16a83-3958-4a2e-9654-f8cf50a26120">
        <source>getOnShipCraneDescription() : String;
// ---------------------------------------------------------------------------
// Created:		17 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin

	if self.onShipCrane = BayOnShipCrane_None then
		return BayOnShipCraneStr_None;
	elseif self.onShipCrane = BayOnShipCrane_OnP then
		return BayOnShipCraneStr_OnP;
	elseif self.onShipCrane = BayOnShipCrane_OnC then	// cnwvu1 14/11/2006	ccms1048
		return BayOnShipCraneStr_OnC;
	elseif self.onShipCrane = BayOnShipCrane_OnS then
		return BayOnShipCraneStr_OnS;
	elseif self.onShipCrane = BayOnShipCrane_Before then
		return BayOnShipCraneStr_Before;
	elseif self.onShipCrane = BayOnShipCrane_After then
		return BayOnShipCraneStr_After;
	endif;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSlot" id="945c9e0d-bd59-47cc-ab83-6eb6516bf5b4">
        <source>getSlot(isOnDeck : Boolean ; cellID, tierID: String): CM_SlotDefn;
// Find the slot definition for this deck, cell, tier combination
begin
	if isOnDeck then		
		return self.allSlotsOnDeck[cellID, tierID];
	endif;
	return self.allSlotsUnderDeck[cellID, tierID];
end;</source>
        <Parameter name="isOnDeck" type="Boolean"/>
        <Parameter name="cellID" type="String"/>
        <Parameter name="tierID" type="String"/>
        <ReturnType type="CM_SlotDefn"/>
    </JadeMethod>
    <JadeMethod name="getSlotControllersBetween" id="318c31f0-3844-41d1-849e-8ac2924b27fa">
        <source>getSlotControllersBetween(_slotFrom, _slotTo : CM_SlotController; _includeUnavailable : Boolean; _selectedSlots : ObjectSet input);
// ---------------------------------------------------------------------------
// Created:     05 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

end;</source>
        <Parameter name="_slotFrom" type="CM_SlotController"/>
        <Parameter name="_slotTo" type="CM_SlotController"/>
        <Parameter name="_includeUnavailable" type="Boolean"/>
        <Parameter name="_selectedSlots" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSlotDefnsBetween" id="2407f5a2-2a63-49cb-8ae7-d191bdd1f60e">
        <source>getSlotDefnsBetween(_slotFrom, _slotTo : CM_SlotDefn; _selectedSlots : ObjectSet input);
// ---------------------------------------------------------------------------
// Created:     03 February 2004 by cnwrs2
//
// Purpose:     
//
// Note:	If this method needs to be altered you should consider altering
//			CM_Bay.getSlotControllersBetween as well
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
22 Dec 2010	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/
vars
	deckFrom, deckTo,
	cellFrom, cellTo,
	tierFrom, tierTo,
	tmpDeck, 
	tmpCell,
	tmpTier	: Integer;
	tmpSlotDefn		: CM_SlotDefn;
	iter		: Iterator;
begin

	if _slotFrom = null or
	   _slotTo = null then
		app.raiseCMException1(MethodWithNullParam, 'slotFrom or slotTo', null, null);
		return;
	endif;
	
	deckFrom := _slotFrom.ordinalDeck;
	tmpDeck := _slotTo.ordinalDeck;

	if deckFrom &lt;&gt; tmpDeck then
		app.raiseUnexpectedProgramError(class.name, method.name, 'The slot from/to must have the same deck ordinal');
		return;
	endif;

	cellFrom := _slotFrom.ordinalCell;
	tierFrom := _slotFrom.ordinalTier;

	tmpCell := _slotTo.ordinalCell;
	tmpTier := _slotTo.ordinalTier;
	
	deckTo := tmpDeck.max(deckFrom);
	cellTo := tmpCell.max(cellFrom);
	tierTo := tmpTier.max(tierFrom);

	deckFrom := tmpDeck.min(deckFrom);
	cellFrom := tmpCell.min(cellFrom);
	tierFrom := tmpTier.min(tierFrom);

	iter := self.allSlotsByOrdinal.createIterator;
	
	self.allSlotsByOrdinal.startKeyGeq(deckFrom, cellFrom, tierFrom, iter);

/*
write class.name &amp; '::' &amp; method.name &amp; '  getting slots from ' &amp;
		deckFrom.String &amp; ' - ' &amp; deckTo.String &amp; ' :: ' &amp;
		cellFrom.String &amp; ' - ' &amp; cellTo.String &amp; ' :: ' &amp;
		tierFrom.String &amp; ' - ' &amp; tierTo.String;
*/	
	while iter.next(tmpSlotDefn) do
		self.allSlotsByOrdinal.getIteratorKeys(tmpDeck, tmpCell, tmpTier, iter);
		if tmpDeck &gt; deckTo then
			break;
		elseif deckFrom = deckTo and tmpCell &gt; cellTo then
			break;
		elseif deckFrom = deckTo and cellFrom = cellTo and tmpTier &gt; tierTo then
			break;
		endif;	

		if tmpCell &gt;= cellFrom and 
		   tmpCell &lt;= cellTo and
		   tmpTier &gt;= tierFrom and
		   tmpTier &lt;= tierTo then
			if (not _selectedSlots.includes(tmpSlotDefn)) then
				_selectedSlots.add(tmpSlotDefn);
			endif;
		endif;
	endwhile;
	
epilog
	delete iter;		// PAR #26678
	
end;</source>
        <Parameter name="_slotFrom" type="CM_SlotDefn"/>
        <Parameter name="_slotTo" type="CM_SlotDefn"/>
        <Parameter name="_selectedSlots" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSortedHatchLids" id="cb636275-cf88-4ec0-977f-82ce312b81e4">
        <source>getSortedHatchLids(_hatches : CM_HatchLidArray input);
/*
------------------------------------------------------------------------
Created:			08 October 2003 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars
	hatch, tmpHatch : CM_HatchLid;
begin
	if _hatches = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "No hatchlid array", null, null);
		return;
	endif;
	_hatches.clear;
	foreach hatch in self.allHatchLids do
		if self.allSlotsUnderDeck.isEmpty = false then
			//We have some underdeck slots..
			if _hatches.isEmpty then
				_hatches.add(hatch);
			else
				foreach tmpHatch in _hatches do
					if hatch.ordinalUDStartCell &lt; tmpHatch.ordinalUDStartCell then
						_hatches.insert(_hatches.indexOf(tmpHatch), hatch);
						break;
					endif;
				endforeach;
				if not _hatches.includes(hatch) then
					_hatches.add(hatch);
				endif;
			endif;
		else
			//No underdeck, must be some overdeck
			if _hatches.isEmpty then
				_hatches.add(hatch);
			else
				foreach tmpHatch in _hatches do
					if hatch.ordinalODStartCell &lt; tmpHatch.ordinalODStartCell then
						_hatches.insert(_hatches.indexOf(tmpHatch), hatch);
						break;
					endif;
				endforeach;
				if not _hatches.includes(hatch) then
					_hatches.add(hatch);
				endif;
			endif;
		endif;
	endforeach;
end;</source>
        <Parameter name="_hatches" type="CM_HatchLidArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getStarboardMostDrawingPos" id="362745c7-d0ba-4090-84ad-52bdc15d655f">
        <source>getStarboardMostDrawingPos(_cellWidth : Integer) : Integer;
// ---------------------------------------------------------------------------
// Created:     05 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpCell	: CM_CellDefn;
	tmpPos	: Integer;
begin

// should be able to store 
//		maxCellAlignment : Real
//		maxCellAlignmentOD : Real
//		maxCellAlignmentUD : Real
//		minCellAlignmentOD : Real
//		minCellAlignmentUD : Real
// and then do calc based on that
//	return (self.maxCellAlignment * _cellWidth).Integer;


	tmpCell := self.allCellsUnderDeckByOrdinal.last;
	if tmpCell &lt;&gt; null then
		tmpPos := tmpCell.getDrawingPosX(_cellWidth) + _cellWidth;
	endif;
	tmpCell := self.allCellsOnDeckByOrdinal.last;
	if tmpCell &lt;&gt; null then
		tmpPos := tmpPos.max(tmpCell.getDrawingPosX(_cellWidth) + _cellWidth);
	endif;

	return tmpPos;

end;</source>
        <Parameter name="_cellWidth" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getUnderDeckSlotForEDI" id="0dea8bc6-221a-4256-98c3-849283a286a1">
        <source>getUnderDeckSlotForEDI(_cellID, _tierID: String): CM_SlotDefn;
//----------------------------------------------------------------
//	Created:	01 April 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tmpSlotDef	: CM_SlotDefn;
	newTier		: String;
begin

	tmpSlotDef := self.allSlotsUnderDeck[_cellID, _tierID];
	
	if tmpSlotDef = null then
		if _tierID.isInteger
