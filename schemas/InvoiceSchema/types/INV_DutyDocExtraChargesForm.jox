    <JadeMethod name="doCmbInvoiceLineTypeBuild" id="bef4d4e8-3eac-45d9-bb32-89eecac5679c">
        <source>doCmbInvoiceLineTypeBuild() protected;
// ---------------------------------------------------------------------------
// Created:		Sep 2013	cnwjre1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theCombo : CMUI_ComboBox;
	bank	: CM_Bank;
	invLineType : CM_InvoiceLineDesc;
begin
	theCombo := self.cmbLineType;
	theCombo.clear;
	theCombo.sorted := true;
	
	// 35872 get bbank form duty doc
	bank := self.myDutyDoc.getBank();
	foreach invLineType in bank.invoiceLineDescriptors where not invLineType.isNotAvailableForEntry do
		theCombo.addItemObject(invLineType.narration.String, invLineType);
	endforeach;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doMnuInspectObject" id="9ad9304f-1ef8-41d3-98a7-b430ca1dbc31">
        <source>doMnuInspectObject() protected;

vars
	anObject : Object;
begin
	if self.tblData.row &gt; self.tblData.fixedRows then
		anObject := self.tblData.accessRow(self.tblData.row).itemObject;
		if anObject &lt;&gt; null then
			anObject.inspect;
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSave" id="533a9430-52b8-41d4-a907-953294b74eb3">
        <updating/>
        <source>doSave() updating, protected;
// save the entry as a new manual invoice line
//10 March 2023  navmv20 TFS 56128 Task 56129: UI - Manual Invoice Lines - Multi TI Invoice Line Type
vars
	manController : CMIF_InvoiceLineManual;
	realInvLine,
	pxyInvLine : CM_InvoiceLine;
	theReturn : Integer;
	ls : Boolean;
	invLineType : CM_InvoiceLineDesc; //10/03/2023  navmv20 TFS 56128 Task 56129
	
begin

	create manController transient;
	manController.quantity := self.txtQty.text.asRealJMT();
	//manController.narration := self.myDutyDoc.id &amp; " " &amp; self.txtNarration.text;  // cnwma1 - 28/08/2014 PAR#34408
//	manController.narration := self.myDutyDoc.id;	// cnwma1 + 28/08/2014 PAR#34408
	manController.remarks := self.myDutyDoc.id;	// ### JIRA 33007 10DEC2024 NAVAB1
	manController.chargeTime.setDate(self.txtStartDate.getDate());
	manController.myInvoice := self.myInvoice;
	//10/03/2023  navmv20 TFS 56128 Task 56129 - START
	//manController.myInvoiceLineType := self.cmbLineType.listObject.CM_InvoiceLineDesc; 
	invLineType := self.cmbLineType.listObject.CM_InvoiceLineDesc;
	manController.allInvoiceLineTypes.add(invLineType);
	//10/03/2023  navmv20 TFS 56128 Task 56129 - END
		
	while true do
		app.myTrxCA.trxCreateInvoiceLineManual(manController, realInvLine, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			self.unloadForm();
			break;
		else
			theReturn := app.showErrorWarningDialog("Extra Charge Item", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
			
		break;
	endwhile;
	
epilog
	app.cmsEndLoad(ls);
	delete manController;
	delete pxyInvLine;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTblDataContextMenu" id="72dd2119-76f9-484f-a58f-846107ff1bf7">
        <updating/>
        <source>doTblDataContextMenu(cntrl : Table input; conwin : Window input; mouse : Boolean; x : Integer; y : Integer) : Boolean updating;

vars
	xLeft 	: Real;
	yTop	: Real;
	
begin
	xLeft := x;
	yTop := y;
	
	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);
	self.mnuInspect.visible := app.isAllowedToInspect;
	
	self.popupMenu(mnuContext, xLeft.Integer, yTop.Integer);
	
	return false;
	
end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doVoidLine" id="c5c7d943-e563-4963-8f77-a41aa120b343">
        <updating/>
        <source>doVoidLine() updating, protected;
// void the selected invoice line, if permitted
vars
	theReturn	: Integer;
	lineNumber	: String;
	object			: Object;
	invoiceStatus	: CMIF_InvoiceStatus;
	invoiceLine		: CM_InvoiceLine;
	pxyInvoiceLine	: CM_InvoiceLine;
begin
	app.mousePointer := MP_HOURGLASS;
	if not app.myCurrentUserCan(self.myTerminal, PmAdmInvoicelistMaint) then

		app.msgBox(app.getErrorString1(VB_SECMOVE,"Invoice Status Void") ,
										"Invoice Security",
										MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);

		return;
	endif;
	
	if self.tblData.row &gt; self.tblData.fixedRows and
	   self.tblData.row &lt;= self.tblData.rows then
		object := self.tblData.accessRow(self.tblData.row).itemObject;
	endif;
	if object = null then
		return;
	endif;
	invoiceLine := object.CM_InvoiceLine;
	lineNumber := invoiceLine.sequenceNum.String;

	if app.msgBox(app.getErrorString(WARN_CHANGE_CHARGE) &amp; " Do you want to continue?",
				"Voiding this Invoice Line " &amp; lineNumber,
				MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon) = MsgBox_Return_No  then
		return;
	endif;

	create invoiceStatus transient;

	pxyInvoiceLine := app.createUpdateProxy(invoiceLine).CM_InvoiceLine;
	invoiceStatus.allInvoiceLines.add(pxyInvoiceLine);

	invoiceStatus.newStatus := CM_InvoiceLine.STATUS_VOIDED;

	while true do
		app.myTrxUA.trxUpdateInvoiceStatus(invoiceStatus, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			
			// refresh the invoice line table without this line
			self.populateTable();
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(CM_Update_Invoice), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
epilog
	if invoiceStatus &lt;&gt; null then
		invoiceStatus.allInvoiceLines.purge;
	endif;
	delete invoiceStatus;
	app.mousePointer := MP_DEFAULT;

end;</source>
        <access>protected</access>
    </JadeMethod>
