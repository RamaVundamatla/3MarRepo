    <JadeMethod name="getNumReceived" id="7094a539-3a4d-45e6-97c4-6bdd1c68570a">
        <source>getNumReceived() : Integer;
/*

Purpose:		items not on ship	

Parameters:			

Return Value:		

Date		Who		Reason
12 March 2013	cnwer1	Initial creation 31274

*/

vars
	ti : CM_TrackedItem;
	num : Integer;
begin

	foreach ti in self.allTrackedItems do 
		if ti.site &lt;&gt; TI_SITE_ONSHIP then
			num:=num + 1;
		endif;
	endforeach;
	
	return num;
	
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNumReleased" id="d8964ab6-93d6-4573-9b2b-e7c3f80f0fc8">
        <source>getNumReleased(): Integer;
/*

Purpose:		items not on ship or onsite

Parameters:			

Return Value:		

Date		Who		Reason
12 March 2013	cnwer1	Initial creation 31274

*/

vars
	ti : CM_TrackedItem;
	num : Integer;
begin

	foreach ti in self.allTrackedItems do 
		if ti.site &lt;&gt; TI_SITE_ONSHIP and ti.site &lt;&gt; TI_SITE_ONSITE   then
			num:=num + 1;
		endif;
	endforeach;
	
	return num;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getPickerDescription" id="33cbe9af-9382-4fd1-a5c6-cf7b8d173b58">
        <source>getPickerDescription():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 October 2020	jlgndl1	Initial creation	TFS 49189

*/

vars

	retValue : String;
	type  : String;					
	str : String;

begin

	if self.description &lt;&gt; null then
		return self.description;
	endif;
	
	if self.remarks &lt;&gt; null then
		return self.remarks;
	endif;

	if self.quantity &gt; 0 then
		retValue := "x" &amp; self.quantity.String;
	elseif self.volume &gt; 0 then
		retValue := "volume " &amp; self.getDisplayStringForAttribute(ETRow_Volume, false);
	elseif self.weight &gt; 0 then								
		retValue := "weight " &amp; self.getDisplayStringForAttribute(ETRow_WeightTotal, false);
	endif;
	
	if self.commodity &lt;&gt; null then
		if retValue = null then
			retValue := self.commodity;
		else
			retValue := retValue &amp; ", " &amp; self.commodity;
		endif;
	endif;
	
	if self.colour &lt;&gt; null then
		if retValue = null then
			retValue := self.colour;
		else
			retValue := retValue &amp; ", " &amp; self.colour;
		endif;
	endif;
	
	if self.markNumber &lt;&gt; null then
		if retValue = null then
			retValue := self.markNumber;
		else
			retValue := retValue &amp; ", " &amp; self.markNumber;
		endif;
	endif;

	return retValue;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getShortDisplay" id="1fc26c1e-df9e-4553-b8bd-5e1fedc03027">
        <source>getShortDisplay():String;
//	added 21 Jan 2010 for display in combos etc
vars
	str : String;
begin

	if self.quantity &lt;&gt; 0 then
		str := self.quantity.String  &amp; ' X ';
	endif;
	if self.commodity &lt;&gt; null then
		str := str &amp; self.getMyCommodity.description;
		return str;
	endif;
	return str &amp; self.myCargoType.description;		
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTotalCargoItems" id="abdbc1df-a6b3-4c98-8804-4dfbd480e6ca">
        <source>getTotalCargoItems() : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2014	cnwmc5	Initial creation	PAR 34185

*/

vars
	ti 		: CM_TrackedItem;
	
	total 	: Integer;
	
begin
	total := 0;

	foreach ti in self.allTrackedItems do
		total := total + ti.totalQuantity;
	endforeach;
	
	return total;
	
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hasCargoOnShip" id="76399db1-4313-44d0-8c3c-be06b1dc9ba1">
        <source>hasCargoOnShip():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 October 2020	jlgndl1	Initial creation	TFS 49189

*/

vars

	ti : CM_TrackedItem;
	tiSet : CM_TISet;

begin

	create tiSet transient;

	if not self.allTrackedItems.isEmpty then
		self.allTrackedItems.copy( tiSet );
		
	elseif self.myBOL &lt;&gt; null and not self.myBOL.allTrackedItems.isEmpty then
		foreach ti in self.myBOL.allTrackedItems do
			if self.cargoType &lt;&gt; null and ti.cargoType &lt;&gt; self.cargoType then
				continue;
			endif;
			if self.colour &lt;&gt; null and ti.getColour &lt;&gt; self.colour then
				continue;
			endif;
			if self.commodity &lt;&gt; null and ti.commodity &lt;&gt; self.commodity then
				continue;
			endif;
			if self.markNumber &lt;&gt; null and ti.markNumber &lt;&gt; self.markNumber then
				continue;
			endif;
			tiSet.add( ti );
		endforeach;
		
	else
		return false;
		
	endif;
	
	foreach ti in tiSet do
		if ti.isOnShip then
			return true;
		endif;
	endforeach;
	
	return false;
	
epilog

	delete tiSet;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
