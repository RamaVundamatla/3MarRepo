    <JadeMethod name="initGroupBox" id="9f392c99-ca70-4d03-9526-ee79b8cddacc">
        <source>initGroupBox();
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.magRequests.caption := null;
	self.magRequests.distanceFromBottom 	:= 5;
	self.magRequests.distanceFromRight 		:= 5;
	self.magRequests.lockBottom 				:= false;
	self.magRequests.lockRight				:= false;
	self.magRequests.stretchHeight 			:= true;
	self.magRequests.stretchWidth 			:= true;
	self.magRequests.multiSelect 	:= ListBox.MultiSelect_Extended;
	self.magRequests.borderStyle := Frame.BorderStyle_None;
	
	if self.isLeftSideDischarge then
		self.magRequests.availableHeading := app.getErrorString(SHP_Discharge_Colour_Coding);	//cnwmc5 
		self.magRequests.selectedHeading := app.getErrorString(SHP_Load_Colour_Coding);		//cnwmc5
	else
		self.magRequests.availableHeading := app.getErrorString(SHP_Load_Colour_Coding);	//cnwmc5
		self.magRequests.selectedHeading := app.getErrorString(SHP_Discharge_Colour_Coding);	//cnwmc5
	endif;
	self.magRequests.displayAddRemoveBtns(false, false);	//cnwmc5
	self.magRequests.displayOrderBtns(true, true);	//cnwmc5
	self.magRequests.myBaseForm	:= self;
	self.magRequests.mySelectedListBox.sorted := false;
	self.magRequests.cnEcResizeContents();
	self.magRequests.readOnly := false;
	self.magRequests.myAvailableListBox.listObject := null;


end;</source>
    </JadeMethod>
    <JadeMethod name="isLeftSideDischarge" id="f281c25d-73cb-4dda-896d-e10a9a3b6660">
        <source>isLeftSideDischarge() : Boolean;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	isDischarge : Boolean;
	theRequests : CM_RequestArray;
	roroReqs : CM_RequestArray;
begin
	if not self.isRORO then
		create theRequests transient;
		self.magRequests.getItemsOnLeftSide(theRequests);
		return not theRequests.first.isReleaseType; // PAR 28968 isDischarge;
	elseif self.isRORO then
		create roroReqs transient;
		self.magRequests.getItemsOnLeftSide(roroReqs);
		return not roroReqs.first.isReleaseType; // PAR 28968 .isDischarge;
	endif;
epilog
	delete theRequests;
	delete roroReqs;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
