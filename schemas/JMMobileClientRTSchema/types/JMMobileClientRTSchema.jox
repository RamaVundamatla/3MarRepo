/*

Purpose:			


Return Value:		


Date		Who		Reason
25 October 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if set then
		// set code here
	else
		if self.myVehicleMountedLogonGUIAgent &lt;&gt; null then
			_value:= self.myVehicleMountedLogonGUIAgent;
		else
