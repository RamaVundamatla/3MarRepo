    <JadeMethod name="runImportTasks" id="ae609397-ea4a-468a-a52b-9ec45cee5765">
        <updating/>
        <source>runImportTasks() updating;
//----------------------------------------------------------------
//	Created:	15 February 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815

begin

	app.mousePointer := Window.MousePointer_HourGlass;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxRunImportTasksOnShip(self.myCurrentVoyage, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Run Import Tasks', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;

epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="savePreferences" id="bef4bcb2-f013-4b0f-b74d-7dd6b66e8753">
        <updating/>
        <source>savePreferences(): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     21 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if inheritMethod() then
		// do this to reset the showOtherColor settings
		self.myBayDrawingController.setModes(self.displayMode, self.imexMode, self.workingMode);
		self.myBayDrawingController.showHoldID := self.myConfig.CMIF_ConfigUserVoyagePlanning.shipShowHoldId;
		self.mnuGridBigFont.checked := self.myConfig.CMIF_ConfigUserVoyagePlanning.shipMacroUseBigFont;
		

		// refresh the display with the new settings
		self.doRefresh();
		return true;
	endif;
	
	return false;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
