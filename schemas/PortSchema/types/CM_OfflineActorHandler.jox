    <JadeMethod name="actionExceptionHandler" id="3c35dac7-6bf2-4b24-b04c-0c6fcc5671ff">
        <source>actionExceptionHandler(exc : Exception; _offlineActor : CM_OfflineActor) : Integer protected;

/*

Purpose:			Catch-all exception handler for the processing of a single 
					OfflineActor instance, to allow any specific processing in the 
					exception to occur prior to passing back for a stack dump and
					alerts, etc


Return Value:


Date		Who		Reason
*/

vars
	returnVal		: Integer;
	msg				: String;

begin
	returnVal := Ex_Pass_Back;
	
	msg := exc.class.name &amp; " " &amp; exc.errorCode.String;

	if app.isValidObject(_offlineActor) then
		msg := msg &amp; " processing " &amp; _offlineActor.String;
		_offlineActor.processActionException(exc);
	endif;

	msg := msg &amp; ", returning Ex_Pass_Back";
	self.logErrorMessage(msg);
	
epilog
	return returnVal;
	
end;</source>
        <access>protected</access>
        <Parameter name="exc" type="Exception"/>
        <Parameter name="_offlineActor" type="CM_OfflineActor"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSessionLockOnActor" id="0a32d5ad-2771-4a5c-ad28-c65fc6c913eb">
        <source>getSessionLockOnActor(_offlineActor : CM_OfflineActor) : Boolean protected;

/*

Purpose:			Get a Session_Duration lock on the passed in OfflineActor, and any other objects
					required to allow for multiple OfflineActor application copies.
					Uses Reserve_Lock to ensure only one copy gets it, handles the possibility that the
					reference will be invalid, and has no lock timeout.


Return Value:		True if the object is valid and the lock(s) are obtained, otherwise false


Date		Who		Reason

*/

vars
	excOccurred		: Boolean;
	
begin
	on Exception do handleInvalidObject(exception, _offlineActor, excOccurred);
	
	self.logDiagMessage("Attempting to obtain Session_Duration Reserve_Lock on " &amp; _offlineActor.String);
	
	if self.tryLock(_offlineActor, Reserve_Lock, Session_Duration, LockTimeout_Immediate) then
		// Got the lock on the actor, now get any additional locks required
		if _offlineActor.getAdditionalSessionLocks then
			return true;
		endif;
		
		// Got here because the additional locks failed
		self.logDiagMessage("Releasing Session_Duration Reserve_Lock on " &amp; _offlineActor.String);

		self.unlock(_offlineActor);
		return false;
	endif;
	
	if not excOccurred then
		self.logDiagMessage("Session_Duration Reserve_Lock on " &amp; _offlineActor.String &amp; " failed");
	endif;
	
	return false;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_offlineActor" type="CM_OfflineActor"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleInvalidObject" id="bb12b475-f592-4030-91d8-32e65159468c">
        <source>handleInvalidObject(_exc : Exception;
					_object : Object;
					_excOccurred : Boolean io) : Integer protected;

/*

Purpose:			Exception handler for Session_Duration lock methods


Return Value:		Appropriate exception return code


Date		Who		Reason

*/

constants
	ObjectNotFound	= 4;
	
vars
	returnVal		: Integer;
	
begin
	returnVal := Ex_Pass_Back;
	
	if _exc.errorCode = ObjectNotFound and _exc.errorObject = _object and _exc.resumable then
		self.logDiagMessage(method.qualifiedName &amp; " - Invalid object " &amp; _exc.errorObject.String &amp; ", returning Ex_Resume_Next");
		_excOccurred := true;
		returnVal := Ex_Resume_Next;
		return returnVal;
	endif;

epilog
	return returnVal;
	
end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_excOccurred" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="instancesExceptionHandler" id="5f2571b7-e645-4483-af3c-12f1b516ec88">
        <source>instancesExceptionHandler(exc : Exception; actor : CM_OfflineActor) : Integer protected;

/*

Purpose:			Handle any exception during CM_OfflineActorHandler instances processing,
					fire off a timer to reprocess instances, and Ex_Pass_Back, to CardSchema
					exception handler for dump


Return Value:


Date		Who		Reason
*/

constants
	ObjectNotFound	: Integer = 4;
	
vars
	msg				: String;
	returnVal		: Integer;
		
begin
	returnVal := Ex_Pass_Back;
	
	msg := exc.class.name &amp; " " &amp; exc.errorCode.String;
	
	// Deleted OfflineActor, just resume on next one in the processing array
	if exc.errorCode = ObjectNotFound and exc.resumable and CM_OfflineActor.hasInstance(exc.errorObject) then	
		msg := msg &amp; ", returning Ex_Resume_Next";
		self.logErrorMessage(msg);
		app.cmsAbortTransaction;
		returnVal := Ex_Resume_Next;
		return returnVal;
	endif;
	
	if app.isValidObject(actor) then
		msg := msg &amp; " processing " &amp; actor.String &amp; ", retryCount=" &amp; actor.retryCount.String;
		msg := msg &amp; ", adding to non-processing list and returning Ex_Pass_Back";
		self.allNonProcessableActors.addNoDuplicates(actor, false);
	endif;
	
	msg := msg &amp; ", firing timer for instances reprocessing";
	self.logErrorMessage(msg);
	
	self.beginTimer(0, Timer_OneShot, EVENT_TIMER_OFFLINEACTOR_INST);
	
epilog
	return returnVal;
	
end;</source>
        <access>protected</access>
        <Parameter name="exc" type="Exception"/>
        <Parameter name="actor" type="CM_OfflineActor"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="lockExceptionHandler" id="6541ad7b-be60-425b-a511-328c74af3088">
        <source>lockExceptionHandler(pExc : Exception; _offlineActor : CM_OfflineActor input) : Integer protected;

/*

Purpose:			Handler for Lock and Deadlock exceptions, to allow for re-queuing
					of CM_OfflineActor object for processing


Return Value:


Date		Who		Reason

*/

vars
	obtained,
	target,
	str				: String;
	heldBy			: Process;
	
begin
	self.logMessage(pExc.class.name &amp; " " &amp; pExc.errorCode.String &amp; " processing " &amp; _offlineActor.String &amp; ", retryCount=" &amp; _offlineActor.retryCount.String);

	// If we have already retried this transaction the maximum number of times, then give up
	if _offlineActor.retryCount &gt;= Maximum_Retry_Count then
		self.logMessage("Maximum retry count exceeded, now returning Ex_Pass_Back");
		return Ex_Pass_Back;
	endif;

	// If we are not passing back and dumping, then add in more diagnostics 
	// for deadlocks to help in problem resolution
	if pExc.isKindOf(DeadlockException) then
		obtained:= app.cnGetClassAndOid(pExc.DeadlockException.obtainedLock);
 		heldBy	:= pExc.DeadlockException.targetLockedBy;
		target	:= app.cnGetClassAndOid(pExc.DeadlockException.lockTarget);
		
 		if heldBy &lt;&gt; null then													// JADE can't always report all the details
		 	str :=  "Deadlock Exception : locktype=" &amp; pExc.DeadlockException.lockType.String &amp;
				    ", locktarget=" &amp; target &amp; ", " &amp;
				    "currently held by " &amp;  heldBy.String &amp; " " &amp;
				    "(app=" &amp; heldBy.persistentApp.name &amp; ", " &amp;
				    "ipAddress=" &amp; heldBy.networkAddress &amp; ", " &amp;
				    "usercode=" &amp; heldBy.userCode &amp; ")  " &amp;
				    "who is trying to lock " &amp; obtained &amp; " (which this process already has locked).";

		else
		 	str := "Deadlock exception : no targetLockedBy information available from JADE" &amp;
		 		   ", locktype=" &amp; pExc.DeadlockException.lockType.String &amp;
	 			   ", target=" &amp; target &amp;
	 			   ", other user is trying to lock " &amp; obtained &amp; " (which this process already has locked)."; 
		endif;

		self.logMessage(str);
	endif;
	
	// We have encountered a lock or deadlock, so abort the current transaction
	self.logMessage("Aborting current attempted transaction, and re-queueing OfflineActor for processing");
	app.cmsAbortTransaction();
	
	// Lock Exceptions are OK, because they already have a delay built in by JADE, but
	// Deadlocks can occur immediately, so wait before updating to allow other side of the Deadlock to 
	// finish before possibly retrying
	if pExc.isKindOf(DeadlockException) then
		process.sleep(2000);
	endif;
	
	// Now we need to re-enter transaction state, and update the retryCount.  Note that this will cause an
	// Object_Update_Event, which will force it to be requeued at the end of the list of notifications
	// currently outstanding
	beginTransaction;
	// Session_Duration Reserve_Lock is now held on OfflineActor, so it can't be
	// invalid here any more
	_offlineActor.incrementRetryCount;
	
	// Return to the arming method, which will do the commit
	return Ex_Resume_Next;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="pExc" type="Exception"/>
        <Parameter name="_offlineActor" type="CM_OfflineActor" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
