    <JadeMethod name="getKeyLengthForXTABDictionary" id="f306cd93-2201-45d1-ac26-2aa7201ae12e">
        <source>getKeyLengthForXTABDictionary(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2014	cnwndl1	Initial creation	Par 34142

*/

vars

begin
	return CM_Bank::code.length + CM_Terminal::code.length + 10;

epilog

end;</source>
