    <JadeMethod name="getYADisplay" id="13580caa-0ea7-411a-800c-72820da2485b">
        <source>getYADisplay(): String;
// --------------------------------------------------------------------------------
// Created:		28 April 2008 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 12/07/2011	cnwmh5		#27772 - Change to include operator
// 21/08/2103	cnwdap1		PAR #32309 Include Cargo Type code as well
// 05/10/2022   navma1		Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
// --------------------------------------------------------------------------------
vars
	operator	: CM_Operator;
	cargoType	: CM_CargoType;
begin
	
	cargoType := self.myCargoType;		//05.10.2022 navma1 #52967
	operator  := self.myOperator;		//10.01.2022 navma1 #52510
	
	if operator &lt;&gt; null then
		return cargoType.abbreviation &amp; " / " &amp; self.code &amp;" - " &amp; operator.code;
	else
		return  cargoType.abbreviation &amp; " / " &amp; self.code;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getYAIdentifier" id="a92a8785-4ef2-4b9a-be7f-278de81c7854">
        <source>getYAIdentifier(): String;

/*

Purpose:		Refer to superclass implementation.

Date			Who		Reason
26 August 2008	consw1	Initial creation
12/07/2011		cnwmh5	#27772 - Add operator details
*/

vars
	operatorStr	: String;
begin
	
	
	
	if self.myOperator &lt;&gt; null then
		operatorStr := " - " &amp; self.myOperator.code.trimBlanks();
	endif;
	
	//epr TFS 1822 29/4/16
	//write self.myCargoType.getYAIdentifier &amp; " - " &amp; self.code.trimBlanks().toUpper() &amp; operatorStr.toUpper();
	return self.myCargoType.getYAIdentifier &amp; " - " &amp; self.code.trimBlanks().toUpper() &amp; operatorStr.toUpper();
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasEntTableSpecialConditions" id="d63655a4-7884-49f2-8d40-f45a5a2de8a8">
        <source>hasEntTableSpecialConditions(	_entRow : EntTableRow;
								_alteredHeaderName : String output;
								_hideRow : Boolean output;
								_measureType : CM_MeasurementType output
								): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 September 2013	cnwndl1	Initial creation	Par 32413

*/

vars

	attrName : String;
	prodAttr : CM_ProductAttr;
	returnValue : Boolean;

begin

	if _entRow &lt;&gt; null then
		attrName := _entRow.name;
	endif;

	if self.isEntTableSpecialProductAttr( attrName ) then
	
		prodAttr := self.getProdAttrFromName( attrName );
	
		if prodAttr = null or not prodAttr.isViewable then
			_hideRow := true;
			returnValue := true;
		else
			if prodAttr.getDisplayStringForAttribute( ETRow_SystemName, false ) &lt;&gt; prodAttr.displayName then
				_alteredHeaderName := prodAttr.displayName;
				returnValue := true;
			endif;
		endif;
		
		if ( attrName = ETRow_MyWeight or attrName = ETRow_Weight ) and self.myWeight &lt;&gt; null then
			_measureType := self.myWeight.myMeasurementType;
		elseif ( attrName = ETRow_MyWidth or attrName = ETRow_Width ) and self.myWidth &lt;&gt; null then
			_measureType := self.myWidth.myMeasurementType;
		elseif ( attrName = ETRow_MyHeight or attrName = ETRow_Height ) and self.myHeight &lt;&gt; null then
			_measureType := self.myHeight.myMeasurementType;
		elseif ( attrName = ETRow_MyLength or attrName = ETRow_Length ) and self.myLength &lt;&gt; null then
			_measureType := self.myLength.myMeasurementType;
		elseif attrName = ETRow_MyDensity and self.myDensityDec &lt;&gt; null then		// ### TFS 52193 22Nov2021 NAVPW1
			_measureType := self.myDensityDec.myMeasurementType;					// ### TFS 52193 22Nov2021 NAVPW1
		elseif ( attrName = ETRow_MyVolume or attrName = ETRow_Volume ) and self.myVolume &lt;&gt; null then
			_measureType := self.myVolume.myMeasurementType;
		endif;
		
		if _measureType &lt;&gt; null then
			returnValue := true;
		endif;
		
		return returnValue;
	
	else

		return inheritMethod(_entRow, _alteredHeaderName, _hideRow, _measureType);
	
	endif;

epilog

end;</source>
        <Parameter name="_entRow" type="EntTableRow"/>
        <Parameter name="_alteredHeaderName" type="String" usage="output"/>
        <Parameter name="_hideRow" type="Boolean" usage="output"/>
        <Parameter name="_measureType" type="CM_MeasurementType" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="importMyReferencesXML" id="013aafe8-89d2-4d4d-9379-9ff48b98905a">
        <updating/>
        <source>importMyReferencesXML(_referencesBlock: String) updating;
// ---------------------------------------------------------------------------
// Created:     10 February 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	prodAttrBlock			: String;
	prodAttrDec				: CM_ProdAttrDecimal;
	prodAttrInt				: CM_ProdAttrInteger;
	prodAttrStr				: CM_ProdAttrString;
	handlingType			: CM_HandlingType;
	handlingTypeId			: Integer;
	foundCargoType,
	theCargoType			: CM_CargoType;
	cargoTypeDict			: CM_CargoTypesByIdDict;
	op						: CM_Operator;
begin
	cargoTypeDict := app.myRoot.allCargoTypesById;
	foreach theCargoType in cargoTypeDict do
		if theCargoType.abbreviation = 'BMLT' then
			foundCargoType := theCargoType;
			break;
		endif;
	endforeach;
	
	if foundCargoType = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'BMLT cargo type not found');
		return;
	endif;
	
	self.myCargoType := foundCargoType;
	self.myCargoTypeExtBreakBulkGen := foundCargoType.myCargoExtension.CM_CargoTypeExtBreakBulkGen;
	op := app.myRoot.allOperators['BML'];
	if op = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'BML Operator could not be found');
		return;
	endif;
	
	self.myOperator := op;	
	prodAttrBlock := _referencesBlock.cnEcGetTagValueOfName('myColour');
	if prodAttrBlock &lt;&gt; null then
		create prodAttrInt persistent;
		self.setPropertyValue('myColour', prodAttrInt);
		prodAttrInt.importMeXML(prodAttrBlock);
	endif;
	
	prodAttrBlock := _referencesBlock.cnEcGetTagValueOfName('myDensity');
	if prodAttrBlock &lt;&gt; null then
		create prodAttrInt persistent;
		self.setPropertyValue('myDensity', prodAttrInt);
		prodAttrInt.importMeXML(prodAttrBlock);
	endif;

	// ### TFS 52193 22Nov2021 NAVPW1
	prodAttrBlock := _referencesBlock.cnEcGetTagValueOfName('myDensityDec');
	if prodAttrBlock &lt;&gt; null then
		create prodAttrInt persistent;
		self.setPropertyValue('myDensityDec', prodAttrInt);
		prodAttrInt.importMeXML(prodAttrBlock);
	endif;
	// ### TFS 52193 22Nov2021 NAVPW1
	
	handlingType := app.myRoot.allHandlingTypes[TI_HandlingType_Packs];
	self.setPropertyValue('myHandlingType', handlingType);
	
	prodAttrBlock := _referencesBlock.cnEcGetTagValueOfName('myHeight');
	if prodAttrBlock &lt;&gt; null then
		create prodAttrInt persistent;
		self.setPropertyValue('myHeight', prodAttrInt);
		prodAttrInt.importMeXML(prodAttrBlock);
	endif;
	
	prodAttrBlock := _referencesBlock.cnEcGetTagValueOfName('myHeightString');
	if prodAttrBlock &lt;&gt; null then
		create prodAttrStr persistent;
		self.setPropertyValue('myHeightString', prodAttrStr);
		prodAttrStr.importMeXML(prodAttrBlock);
	endif;

	prodAttrBlock := _referencesBlock.cnEcGetTagValueOfName('myLength');
	if prodAttrBlock &lt;&gt; null then
		create prodAttrInt persistent;
		self.setPropertyValue('myLength', prodAttrInt);
		prodAttrInt.importMeXML(prodAttrBlock);
	endif;

	prodAttrBlock := _referencesBlock.cnEcGetTagValueOfName('myLengthString');
	if prodAttrBlock &lt;&gt; null then
		create prodAttrStr persistent;
		self.setPropertyValue('myLengthString', prodAttrStr);
		prodAttrStr.importMeXML(prodAttrBlock);
	endif;
	
	prodAttrBlock := _referencesBlock.cnEcGetTagValueOfName('myQuantity');
	if prodAttrBlock &lt;&gt; null then
		create prodAttrInt persistent;
		self.setPropertyValue('myQuantity', prodAttrInt);
		prodAttrInt.importMeXML(prodAttrBlock);
	endif;
	
	prodAttrBlock := _referencesBlock.cnEcGetTagValueOfName('myType');
	if prodAttrBlock &lt;&gt; null then
		create prodAttrStr persistent;
		prodAttrStr.importMeXML(prodAttrBlock);
		self.setPropertyValue('myType', prodAttrStr);
	endif;
	
	prodAttrBlock := _referencesBlock.cnEcGetTagValueOfName('myVolume');
	if prodAttrBlock &lt;&gt; null then
		create prodAttrDec persistent;
		self.setPropertyValue('myVolume', prodAttrDec);
		prodAttrDec.importMeXML(prodAttrBlock);
	endif;
	
	prodAttrBlock := _referencesBlock.cnEcGetTagValueOfName('myWeight');
	if prodAttrBlock &lt;&gt; null then
		create prodAttrInt persistent;
		self.setPropertyValue('myWeight', prodAttrInt);
		prodAttrInt.importMeXML(prodAttrBlock);
	endif;
	
	prodAttrBlock := _referencesBlock.cnEcGetTagValueOfName('myWidth');
	if prodAttrBlock &lt;&gt; null then
		create prodAttrInt persistent;
		self.setPropertyValue('myWidth', prodAttrInt);
		prodAttrInt.importMeXML(prodAttrBlock);
	endif;

	prodAttrBlock := _referencesBlock.cnEcGetTagValueOfName('myWidthString');
	if prodAttrBlock &lt;&gt; null then
		create prodAttrStr persistent;
		self.setPropertyValue('myWidthString', prodAttrStr);
		prodAttrStr.importMeXML(prodAttrBlock);
	endif;

end;</source>
        <Parameter name="_referencesBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="initializeForActivity" id="a21cbe52-7eac-44d9-972e-83ab0efffcff">
        <updating/>
        <source>initializeForActivity(_ewsOpsView: CM_EWSActivityOpsview; _opsViewTable : CMIF_OpsViewTables) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Jun 2022	navsp1	Initial creation TFS#53104

*/

vars
	opsviewtable : CMIF_AuxCrgProductType;
begin
	if _opsViewTable.isKindOf(CMIF_AuxCrgProductType) then
		opsviewtable					:= _opsViewTable.CMIF_AuxCrgProductType;
		opsviewtable.tableName			:= opsviewtable.Aux_crg_product_type;
		opsviewtable.gkey 				:= opsviewtable.generateFullGKey(self,"");
		opsviewtable.client_id			:= opsviewtable.generateCpxGKey().String;
		opsviewtable.id					:= self.code;
		opsviewtable.description 		:= self.description;
		opsviewtable.created			:= self.createdTime.String.Integer;
		if self.allAuditObjects.first &lt;&gt; null then
			opsviewtable.creator		:= self.allAuditObjects.first.myUser.code;
		else
			opsviewtable.creator		:= "";
		endif;
		opsviewtable.changed			:= app.actualTimeServer.String.Integer;		
		opsviewtable.changer			:= app.getMyUserCode();
	endif;
epilog

end;</source>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <Parameter name="_opsViewTable" type="CMIF_OpsViewTables"/>
    </JadeMethod>
    <JadeMethod name="isAttributeValidForCargoType" id="f096980f-1b4c-4099-87be-d13adca5c6b9">
        <source>isAttributeValidForCargoType(_attrName : String) : Boolean;
//------------------------------------------------
// Created: 28 April 2006 By: cnwgd1
//------------------------------------------------
vars
	tmpProductAttr : CM_ProductAttr;
		
begin
	if _attrName = null then
		return false;
	endif;
	
	tmpProductAttr := self.getProdAttrFromName(_attrName);
	if tmpProductAttr = null then
		return false;
	endif;
	
	//epr par 32951 13/11/13
	if self.myCargoType = null then
		return tmpProductAttr.isViewable;
	endif;
	
	if self.myCargoType.allAttributesOnProduct.includes(_attrName) then
		return tmpProductAttr.isViewable;
	endif;
	
	return false;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
