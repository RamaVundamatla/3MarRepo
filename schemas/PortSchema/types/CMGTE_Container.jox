    <JadeMethod name="populateSealTICollection" id="5bcb622f-6333-41d7-807b-f803d759d973">
        <updating/>
        <source>populateSealTICollection() updating;

/*

Purpose:
			
		//conversion method for CMGTE_Container objects with existig seal data
		
Parameters:			

Return Value:		


Date		Who		Reason
20 September 2010	cnwndl1	Initial creation	Par 25608
05 Dec 2011	NDL	Par 28772
*/

vars
/*
	pxyAllSeals : CM_SealTIBySealTypeDict;
	sealType : CM_SealType;
	pxySealTI : CM_SealTI;
	sealTI : CM_SealTI;
*/	
begin
/*
	if not self.allSeals.isEmpty then
		// this CMGTE_Conatainer object has already been converted.
		return;
	endif;
	
	create pxyAllSeals transient;
	
	if self.sealNum.trimBlanks &lt;&gt; null or self.prevSealNum.trimBlanks &lt;&gt; null then
		sealType := app.myRoot.getSealType( SealType_Operator );
				
		create pxySealTI transient;
		pxySealTI.setProxy(	self.sealNum.trimBlanks,	//_sealNum : String;
							null,	//_sealNumArray : StringArray;
							self.prevSealNum.trimBlanks,	//_prevSeal : String;
							sealType.sealType,	//_sealType : String;
							null,	//_sealedDT : TimeStamp;
							null	//_myTrackedItem : CM_TrackedItem
							);
		pxyAllSeals.add( pxySealTI );				
		
	endif;
	
	if self.sealNumCustoms.trimBlanks &lt;&gt; null then
		sealType := app.myRoot.getSealType( SealType_Customs );
			
		create pxySealTI transient;
		pxySealTI.setProxy(	self.sealNumCustoms.trimBlanks,	//_sealNum : String;
							null,	//_sealNumArray : StringArray;
							null,	//_prevSeal : String;
							sealType.sealType,	//_sealType : String;
							null,	//_sealedDT : TimeStamp;
							null	//_myTrackedItem : CM_TrackedItem
							);
		pxyAllSeals.add( pxySealTI );								
		
	endif;
	
	if self.sealNumShippers.trimBlanks &lt;&gt; null then
		sealType := app.myRoot.getSealType( SealType_Shipper );
			
		create pxySealTI transient;
		pxySealTI.setProxy(	self.sealNumShippers.trimBlanks,	//_sealNum : String;
							null,	//_sealNumArray : StringArray;
							null,	//_prevSeal : String;
							sealType.sealType,	//_sealType : String;
							null,	//_sealedDT : TimeStamp;
							null	//_myTrackedItem : CM_TrackedItem
							);

		pxyAllSeals.add( pxySealTI );					
			
	endif;
	
	if self.sealExtra1.trimBlanks &lt;&gt; null then // yes vent is stored in sealExtra1
		sealType := app.myRoot.getSealType( SealType_Vent );
			
		create pxySealTI transient;
		pxySealTI.setProxy(	self.sealExtra1.trimBlanks,	//_sealNum : String;
							null,	//_sealNumArray : StringArray;
							null,	//_prevSeal : String;
							sealType.sealType,	//_sealType : String;
							null,	//_sealedDT : TimeStamp;
							null	//_myTrackedItem : CM_TrackedItem
							);
		pxyAllSeals.add( pxySealTI );
			
	endif;
	
	beginTransaction;
	
	// populate the new collection as required
	foreach pxySealTI in pxyAllSeals do
	
		create sealTI persistent;
		sealTI.setForCreate(pxySealTI);
		self.allSeals.add(sealTI);
		delete pxySealTI;
		
	endforeach;
	
	// unconditionally clear the old seals fields.
	self.prevSealNum := null;
	self.sealNum := null;
	self.sealNumShippers := null;
	self.sealExtra1 := null;
	self.sealNumCustoms := null;
	
	commitTransaction;
*/	
epilog
/*	
	if pxyAllSeals &lt;&gt; null and not pxyAllSeals.isEmpty then
		pxyAllSeals.purge;
		abortTransaction;
	endif;
	delete pxyAllSeals;
*/
end;</source>
    </JadeMethod>
