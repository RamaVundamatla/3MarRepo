Date		: 04 September 2023
TFS#		: 59856
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
begin    
	self.tblSearch.disableRow(6);
	self.tblSearch.accessRow(6).visible:=false;
	self.tblSearch.repositionAfterResize;

	if self.isSearcherFloating=false then
		tblSearch.resetSize();
		self.zResetDataFilterRatio();
	else
		self.frmSearch.height := self.tblSearch.height + self.tblSearch.top + 20;
