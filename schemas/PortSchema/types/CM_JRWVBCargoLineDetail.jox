    <JadeMethod name="getVehBookTimeSlotDateLocalTZ" id="dafa02c9-a5c5-4381-bfd1-46d6627ed1ce">
        <source>getVehBookTimeSlotDateLocalTZ(): Date;
/*

Purpose:			Return the local timezone version of the receiver's dateTime (for JRW)

Parameters:			None

Return Value:		

Date		Who		Reason
03 Jun 2016	cnwmp6	TFS 488 - Multi Timezone Support

*/
vars
	ts: TimeStamp;
begin
	ts.setDate(self.vehicleBookingTimeslotDate());
	ts.setTime(self.vehicleBookingTimeslotTime());
	return self.systemToLocalTime(ts).Date;
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getVehBookTimeSlotTimeLocalTZ" id="a2f2ef65-32fe-43a3-a27a-f7723c1c9441">
        <source>getVehBookTimeSlotTimeLocalTZ(): Time;
/*

Purpose:			Return the local timezone version of the receiver's dateTime (for JRW)

Parameters:			None

Return Value:		

Date		Who		Reason
03 Jun 2016	cnwmp6	TFS 488 - Multi Timezone Support

*/
vars
	ts: TimeStamp;
begin
	ts.setDate(self.vehicleBookingTimeslotDate());
	ts.setTime(self.vehicleBookingTimeslotTime());
	return self.systemToLocalTime(ts).Time;
epilog

end;</source>
        <ReturnType type="Time"/>
    </JadeMethod>
