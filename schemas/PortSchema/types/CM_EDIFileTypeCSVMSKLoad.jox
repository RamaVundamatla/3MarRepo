<Class name="CM_EDIFileTypeCSVMSKLoad" id="50390095-d129-4b63-8f06-5a032c3df517">
    <superclass name="CM_EDIFileTypeCSV"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <JadeMethod name="create" id="3ce5e030-8deb-4117-a9f0-fa032945a479">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.name	:= "MSK Load List";
	self.type	:= EDIFileType_CSVMSKLoad;
end;</source>
    </JadeMethod>
    <JadeMethod name="extractFile" id="89307b01-d4d5-4834-be46-704ebc3ad580">
        <updating/>
        <source>extractFile(_ediFile: CM_EDIFile input; _number: Integer; _recipient: CM_Operator) updating;
//----------------------------------------------------------------
//	Created:	16 September 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//15 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
vars
	operator	: CM_Operator;
	ediData		: CM_EDIDataLoadList;
	ediTI		: CM_EDITrackedItem;
	i			: Integer;
	str : String;
begin
	ediData := _ediFile.ediData.CM_EDIDataLoadList;
	
	operator := self.getMyOperator();

	str := str &amp; ",,,,,,,,,,,,,,,,,,,," &amp; CrLf;
	str := str &amp; ",FINAL LOAD LIST,,,,,,,,,,,,,,,,,,," &amp; CrLf;
	str := str &amp; ",Nora Maersk,,,,Voy,0208,at,Port Chalmers,,,,,,,,,,,," &amp; CrLf;
	str := str &amp; ",,,,,,,,,,,,,,,,,,,," &amp; CrLf;
	str := str &amp; ",Container #,Booking Ref,ISO,Discharge,Destination,Commodity,Weight,Temp,Hum,Vent,CO2,O2,W/C,Empty,IMO,OOG,Gate-In,Count,," &amp; CrLf;

	foreach ediTI in ediData.allEDITrackedItems do
		i := i + 1;
		str := str &amp; self.extractTI(ediTI, i, operator); 
	endforeach;
	_ediFile.setRawDataString(str);
	_ediFile.writeFile();
end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_number" type="Integer"/>
        <Parameter name="_recipient" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="extractTI" id="64530b1b-1fe1-44f2-9b51-75b4b25222ba">
        <updating/>
        <source>extractTI(_ediTI : CM_EDITrackedItem input; _number : Integer; _operator : CM_Operator) : String updating, protected;
//----------------------------------------------------------------
//	Created:	16 September 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//15 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
vars
	tmpStr	: String;
	str		: String;
	llTI	: CM_EDILoadListTI;
begin
//,Container #,Booking Ref,ISO,Discharge,Destination,Commodity,Weight,Temp,Hum,Vent,CO2,O2,W/C,Empty,IMO,OOG,Gate-In,Count,,
//,APMU2701271,AKL015278,2200,MYTPPTM,CNXIH,MILK PWDR,18100,***,0,0,0,0,-,N,1,N,Y,1,,
//,APMU2771535,UFX022728,2200,MYTPPTM,HKHKG,MILK PWDR,17950,***,0,0,0,0,-,N,1,N,Y,2,,

	if _ediTI.isKindOf(CM_EDILoadListTI) then
		llTI := _ediTI.CM_EDILoadListTI;
	else
		return null;
	endif;
	
	if llTI.temperature &gt; NULL_TEMPERATURE then
		tmpStr := app.temperatureConversion(true, llTI.temperature).String;
	else
		tmpStr := "";
	endif;


	str :=	","&amp; llTI.id &amp;","&amp; llTI.bookingRef.trimBlanks &amp;","&amp; llTI.isoType &amp;","&amp; llTI.dischargePort
			&amp;","&amp; llTI.destinationPort &amp;"," &amp; llTI.commodity &amp; ","&amp; llTI.weight.asStringWeightJMT() &amp; ","&amp; tmpStr &amp;",0,0,0,0,-,N,1,N,Y,"&amp; _number.String &amp;",," &amp; CrLf;

	return str;

end;</source>
        <access>protected</access>
        <Parameter name="_ediTI" type="CM_EDITrackedItem" usage="input"/>
        <Parameter name="_number" type="Integer"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="findEDIDataType" id="99fd669b-e5b3-4c48-913f-bc34df2f6d34">
        <source>findEDIDataType(_ediDataClass: Class io; _dataType, _fileTypeCode: Integer io); // cnwrs1 Par 24207 ccms 1117 11 May 2010
//----------------------------------------------------------------
//	Created:	27 August 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	_ediDataClass := CM_EDIDataLoadList;
	_dataType := EDIDataType_LoadList;
	_fileTypeCode := self.type;

end;</source>
        <Parameter name="_ediDataClass" type="Class" usage="io"/>
        <Parameter name="_dataType" type="Integer" usage="io"/>
        <Parameter name="_fileTypeCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getMyOperator" id="8bfcfeb9-1933-4131-aee3-01e2809f2154">
        <source>getMyOperator(): CM_Operator;
//----------------------------------------------------------------
//	Created:	03 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	return app.myRoot.allOperators["MSK"];

end;</source>
        <ReturnType type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="getTIInfo" id="053e2f1a-9f65-42ca-a5f6-84c4b4dfedd0">
        <source>getTIInfo(_record: String; _tiInfo: StringArray input);
//----------------------------------------------------------------
//	Created:	03 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	inheritMethod(_record, _tiInfo);

	while _tiInfo.size &lt; 17 do
		_tiInfo.add("");
	endwhile;
		

end;</source>
        <Parameter name="_record" type="String"/>
        <Parameter name="_tiInfo" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="hasValidTI" id="a2020e1f-1e7f-47dc-988b-0bede16f2691">
        <source>hasValidTI(_record: String): Boolean;
//----------------------------------------------------------------
//	Created:	24 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	field,
	length,
	endPos,
	startPos	: Integer;
	field2,
	field3,
	field6,
	value,
	strRec		: String;
begin
	strRec := _record;
	
	startPos := 1;
	endPos := 1;
	
	field := 1;
	// look at the 1st and 2nd fields - will be a containerID and booking ref
	while field &lt; 7 do
		endPos := strRec.pos("," , startPos) - 1;
		if endPos &gt;= startPos then
			length := (endPos+1)- startPos;	
			
			value := strRec[startPos:length];
			if field = 2 then
				field2 := value;
			elseif field = 3 then
				field3 := value;
			elseif field = 6 then
				field6 := value;
			endif;
		
		endif;
		startPos := endPos + 2;
		field := field + 1;
	endwhile;	

	//can't be too harsh here - we want to get the voyage info too
	
	if field2 = null or field3 = null then
		if field6 = null then
			return false;
		endif;
	endif;
	
	if field2.length &gt; 8 and field2[1:9].toUpper = "CONTAINER" then
		return false;
	endif;

	return true;

end;</source>
        <Parameter name="_record" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processFile" id="c8b1493e-ce07-4907-b776-3593aad2ba17">
        <updating/>
        <source>processFile(_ediFile: CM_EDIFile input) protected, updating;
//----------------------------------------------------------------
//	Created:	03 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 18 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	infoTI			: StringArray;
	container		: CM_EDILoadListTIMSK;
	ediDataLoadList	: CM_EDIDataLoadList;
	message			: String;
	int				: Integer;
	voyCode			: String;
	pISOType 		: CM_ISOType;
	operator		: CM_Operator;
	msgCount		: Integer;
	numMsgs			: Integer;
	passport		: CM_Passport;
//	binaryLine		: Binary;
	foundMatch		: Boolean;
	theLines : HugeStringArray;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
begin
	progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	passport := app.myPassport;	
	ediDataLoadList := _ediFile.ediData.CM_EDIDataLoadList;

	create infoTI transient;

	ediDataLoadList.operatorCode := self.getMyOperator().code;
	operator := app.myRoot.allOperators[ediDataLoadList.operatorCode];
	create theLines transient;
	self.rawDataToHSA(_ediFile, theLines);
	numMsgs	:= theLines.size;
	foreach message in theLines do
		msgCount	:=	msgCount + 1;
		
		progressInt := app.actualTimeServer() - progressTS;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if passport.myCMIFMonitor &lt;&gt; null and (progressInt.getMilliseconds &gt;= ProgressBarRefresh) then
			passport.myCMIFMonitor.updateProgressWithCaption("Processing File Data", numMsgs, msgCount, "Loading EDI file Step 3 of 3.");
			progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		int := int + 1;
		self.getTIInfo(message, infoTI);
		
		if infoTI[6].toUpper = "VOY" then
			//line 3 might look like this:
			//,Nora Maersk,,,,Voy,0322,at,PORT CHALMERS,,,,,,,,,,,,
			ediDataLoadList.setVesselName(infoTI[2]);
			if operator &lt;&gt; null then
				voyCode := operator.getXlationSystemCode_Voyage(infoTI[7], null, null, null, foundMatch);
			else
				voyCode := infoTI[7];
			endif;
			
			ediDataLoadList.setVoyageCode(voyCode);
			
			continue;
		endif;
		
		create container persistent;
		container.setForCreateNew(ediDataLoadList);
		
		container.setDefault(infoTI);
		
		operator := app.myRoot.allOperators[container.operatorCode];

		pISOType := app.myRoot.allISOTypes[container.isoType];

		if (pISOType &lt;&gt; null) then
			container.setCargoType(pISOType.myCargoType.id);
		else
			container.setCargoType(TI_CargoType_Container);
		endif;
		
	endforeach;
epilog
	delete theLines;
	delete infoTI;
end;</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
    </JadeMethod>
</Class>
