    <JadeMethod name="btnSearchCargo_click" id="9f653632-6add-4561-b56c-1caf516a7bf6">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSearchCargo_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
15 April 2023  navmv20 TFS 55304 Task 55545: UI - Invoice Line List Changes

*/

vars
	tiArray: CM_TIArray;
	form   : CMUI_CargoSearchFormModal;
begin
	form := app.loadForm(CMUI_CargoSearchFormModal, 
							CMUI_Assistant, 
							false, 
							false,
							true, 
							self.myTerminal,
							null).CMUI_CargoSearchFormModal;	

	if form = null then
		return;
	endif;
	
	form.setColumnsAndControlWidth(3, 175);
	form.setParentForm(self);
	
	form.showModal();
epilog
	delete tiArray;
end;</source>
