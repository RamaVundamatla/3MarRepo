    <JadeMethod name="create" id="843ce6de-e985-435a-a4ec-9fda0950a5a3">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts
*/

vars
	operator : CM_QueryOperator;

begin
	if self.isTransient then
		return;
	endif;

	create operator as CM_QStringLookupIsOneOf persistent;
	self.allAllowedOperators.add(operator);
epilog

end;</source>
