    <JadeMethod name="getCaptionExtent" id="135df710-ad8c-4eac-87ab-5298fc706c2f">
        <source>getCaptionExtent(_entTableDef : EntTableDef) : Integer protected;
/*
Purpose:			Reads through all controls to find the longest caption

Parameters:			None

Return Value:		Widest caption getTextExtent

Date		Who		Reason
15 July 2009	cnwdap1	Initial creation
*/
vars
	idx				: Integer;
	ctrl			: Control;
	captionExtent, 
	widestExtent	: Integer;
	row				: EntTableRow;

begin
	foreach idx in 1 to self.controlCount do
		captionExtent := null;
		ctrl := self.controls(idx);
		if ctrl.isKindOf (CMUI_FieldFrame) then
			foreach row in _entTableDef.allEntTableRows where row.controlName = ctrl.name do
				captionExtent := getTextExtent(ctrl.CMUI_FieldFrame.myLabel.caption);
			endforeach;
		endif;
		if captionExtent &lt;&gt; null and captionExtent &gt; widestExtent then
			widestExtent := captionExtent;
		endif;
	endforeach;

	return widestExtent;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_entTableDef" type="EntTableDef"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getControlForEntDefRow" id="c65d237d-d6a1-4e44-99d7-698c7a0ca5ce">
        <source>getControlForEntDefRow(_name : String; _control : Control output) protected;
/*
Purpose:			Retrieves the CMUI_FieldFrame control with the name corresponding to the Ent Table Row name

Parameters:			_name - Ent Table Row control name
					_control - CMUI_FieldFrame control with the matchng name

Return Value:		

Date		Who		Reason
09 July 2009	cnwdap1	Initial creation
*/
vars
	idx		: Integer;
	ctrl	: Control;

begin
	foreach idx in 1 to self.controlCount do
		ctrl := self.controls(idx);
		if ctrl.name = _name then
			_control := ctrl;
			return;
		endif;
	endforeach;
	
	_control := null;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_name" type="String"/>
        <Parameter name="_control" type="Control" usage="output"/>
    </JadeMethod>
