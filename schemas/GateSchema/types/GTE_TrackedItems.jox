    <JadeMethod name="tblInput_cellInputReady" id="2652665a-73b9-424a-b40f-e132375fadf4">
        <controlMethod name="Table::cellInputReady"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblInput_cellInputReady(table: Table; inputControl: Control input; cleft: Real io; ctop: Real io; cwidth: Real io; cheight: Real io) updating;
// ---------------------------------------------------------------------------
// Created:     07 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if inputControl.name = 'cmbISOType' then
/*
		if cmbISOType.listObject &lt;&gt; null then
			cmbISOType.text := controller.displayEntryISOType(cmbISOType.listObject.CM_ISOType);
		else
			if table.text &lt;&gt; null then
				cmbISOType.text := table.text;
			endif;
		endif;
*/

	elseif inputControl.name = 'cmbTI' then
		cmbTI.text := table.text;

	elseif inputControl.name = 'cmbTiType' then
		if table.text &lt;&gt; null then
			cmbTiType.text := table.text;
		endif;
		
	else
		
	endif;
	
end;</source>
        <Parameter name="table" type="Table"/>
        <Parameter name="inputControl" type="Control" usage="input"/>
        <Parameter name="cleft" type="Real" usage="io"/>
        <Parameter name="ctop" type="Real" usage="io"/>
        <Parameter name="cwidth" type="Real" usage="io"/>
        <Parameter name="cheight" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="tblInput_lostFocus" id="28672a79-f93c-4e10-8722-1d8911d695f3">
        <controlMethod name="CM_EntryTable::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblInput_lostFocus(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 August 2019	jlgndl1	Initial creation	TFS 46118

*/

vars

	entryTable : CM_EntryTable;
	rowIndex : Integer;

begin

	entryTable := table.CM_EntryTable;
	rowIndex := entryTable.getRowByName( ETRow_Mark );
	
	if rowIndex &gt; entryTable.fixedRows and entryTable.rows &gt;= rowIndex then
		self.filterMark := entryTable.getValueByName( ETRow_Mark ).String;
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblListAll_click" id="4efc567a-b096-45c3-8b25-c2f8e5df0d75">
