    <JadeMethod name="changeName" id="06d8b6ef-d5c1-40ef-9478-159ab647e0b3">
        <updating/>
        <source>changeName(pName: String) updating;
/*
*/
begin
	name := pName;
end;</source>
        <Parameter name="pName" type="String"/>
    </JadeMethod>
    <JadeMethod name="createEntity" id="a6830d7f-baff-4964-951d-b24043a43f1b">
        <updating/>
        <source>createEntity(pName: String; pValue: String; pDocument: JSSXmlDocument) updating, protected;
/*
*/
vars
	externalClass: Class;
begin
	self.name := pName;
	self.value := pValue;
	self.myDocument := pDocument;
end;</source>
        <access>protected</access>
        <Parameter name="pName" type="String"/>
        <Parameter name="pValue" type="String"/>
        <Parameter name="pDocument" type="JSSXmlDocument"/>
    </JadeMethod>
    <JadeMethod name="parseEntity" id="6e956ed7-f5d0-4db7-b4b4-55a85a6f4b4c">
        <updating/>
        <source>parseEntity(pXmlString: String; pDocument: JSSXmlDocument) updating;
/*
*/
vars
	xmlString: String;
	entityString: String;
	entityName: String;
	entityValue: String;
	pos: Integer;
	posEnd: Integer;
begin
	xmlString := pXmlString;

	pos := "&lt;!ENTITY ".length + 1;
	while xmlString[pos:1] = " " do
		pos := pos + 1;
	endwhile;

	if xmlString[pos:2] = "% " then
		delete self;
		return;
	endif;
	posEnd := xmlString.pos(" ", pos);
	entityName := xmlString[pos:posEnd - pos];

	pos := posEnd + 1;
	while xmlString[pos:1] = " " do
		pos := pos + 1;
	endwhile;

	pos := pos + 1;
	posEnd := xmlString.pos('"', pos);
	entityValue := xmlString[pos:posEnd - pos];

	self.createEntity(entityName, entityValue, pDocument);
end;</source>
        <Parameter name="pXmlString" type="String"/>
        <Parameter name="pDocument" type="JSSXmlDocument"/>
    </JadeMethod>
</Class>
