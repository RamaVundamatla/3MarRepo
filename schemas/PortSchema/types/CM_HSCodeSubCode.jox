    <JadeMethod name="getMyParent" id="eb217b75-d770-4e72-9a38-1a4d5bfe9c48">
        <source>getMyParent(): CM_HSCodeCode;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
09 December 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars

begin
	if self.myHSCode &lt;&gt; null and self.myHSCode.isTransient and not self.myHSCode.pxyIsProxy then
		return app.myRoot.allHSCodes[self.myHSCode.id];
	endif;
	
	return self.myHSCode;

epilog

end;</source>
        <ReturnType type="CM_HSCodeCode"/>
    </JadeMethod>
