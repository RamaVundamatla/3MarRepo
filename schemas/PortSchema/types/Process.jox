        <source>timerEvent(eventTag: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Dec 2017	jlgkpd1	Initial creation

*/

vars

begin
	if eventTag = self.Compact_Transient_File then
