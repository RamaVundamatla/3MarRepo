<CollClass name="CM_TIDictByIdCargoType" id="5d1c2984-d971-4b71-9ad3-36c7ecb6ad77">
    <memberType name="CM_TrackedItem"/>
    <superclass name="CM_TrackedItemDicts"/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="voyages"/>
    <JadeMethod name="isReversed" id="75c157f8-c7c5-4032-82db-4b8d8236ff70">
