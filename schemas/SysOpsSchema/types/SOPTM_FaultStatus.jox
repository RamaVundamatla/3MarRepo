    <JadeMethod name="doSave" id="2f0cfaeb-ad5b-4370-8c69-c03ea60398f1">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
04 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	rtnValue,notAvailable,
	default : Boolean;
	proxyFaultStatus		: CM_FaultStatus;
	description,
	code				: String;
	theForm				: SOP_TableMaintForm;

begin
	theForm := self.myForm; 
	description	:=	theForm.tblInput1.getValueByName(ETRow_Description).String;
	code			:=	theForm.tblInput1.getValueByName(ETRow_Code).String;
	notAvailable	:=	theForm.tblInput1.getValueByName(ETRow_NotAvailable).Boolean;
	default		:= 	theForm.tblInput1.getValueByName(ETRow_IsDefault).Boolean;
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_FaultStatus transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyFaultStatus := theForm.myProxyObject.CM_FaultStatus;
	

	proxyFaultStatus.setProxy(code,description,notAvailable, default);
		
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateFaultStatus(proxyFaultStatus, theForm.myCurrentObject, app.myPassport);
		rtnValue	:=	app.myPassport.trxCompletedOK;
		
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateFaultStatus(proxyFaultStatus, app.myPassport);
		rtnValue	:=	app.myPassport.trxCompletedOK;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return rtnValue;
epilog
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
