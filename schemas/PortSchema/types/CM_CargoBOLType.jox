vars

begin
	//should be re-implemented
end;</source>
        <Parameter name="_qDef" type="CM_QueryDefinition"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="8498292c-663a-4450-b00e-1702e00c61b8">
        <updating/>
        <source>setForUpdate(pProxy : CM_CargoBOLType) updating;
// ---------------------------------------------------------------------------
// Created:     21 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 14 Mar 2016	cnwkpd1		Release upgrade performance
// ---------------------------------------------------------------------------
vars

begin

	self.allEnquiryEntTableDefs.clear;
	pProxy.allEnquiryEntTableDefs.copy(self.allEnquiryEntTableDefs);
	
	self.allEditTableDefs.clear;
	pProxy.allEditTableDefs.copy(self.allEditTableDefs);	
	
	if self.abbreviation &lt;&gt; pProxy.abbreviation then
		self.abbreviation		:= pProxy.abbreviation;
	endif;
	self.description	 	:= pProxy.description;
	if self.id &lt;&gt; pProxy.id then
		self.id				 	:= pProxy.id;
	endif;
	self.idHeading			:= pProxy.idHeading;

	self.gateInOutAttachmentView := pProxy.gateInOutAttachmentView;
	self.gateInOutExtraTblReceiveView := pProxy.gateInOutExtraTblReceiveView;
	self.gateInOutExtraTblReleaseView := pProxy.gateInOutExtraTblReleaseView;
	self.gateInOutMainTblReceiveView  := pProxy.gateInOutMainTblReceiveView;
	self.gateInOutMainTblReleaseView  := pProxy.gateInOutMainTblReleaseView;
	
	self.mainFormFilterView		:= pProxy.mainFormFilterView;
	self.maintFormTblDataDef	:= pProxy.maintFormTblDataDef;

end;</source>
        <Parameter name="pProxy" type="CM_CargoBOLType"/>
    </JadeMethod>
    <JadeMethod name="setProxyForCargoBOLType" id="270b3876-f9c2-4a91-9e26-22f0deff806b">
        <updating/>
        <source>setProxyForCargoBOLType(_id : Integer; 
						_abbr, _descr, _idHeading : String;
						_thumbDefs, _editDefs : StringArray;
						_attachmentView,
		 				_extraReceiveView, _extraReleaseView, 
		 				_mainReceiveView, _mainReleaseView,
		 				_filterView, _tblDataDef : String) updating, protected;
// ---------------------------------------------------------------------------
// Created:     21 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//29/07/2016 cnwma1 TFS #2452  1310 Error in LOLO Planning when using Voyage Allocations
// ---------------------------------------------------------------------------
vars

begin

	self.id				 	:= _id;
	
	self.abbreviation		:= _abbr.toUpper();  //29/07/2016 cnwma1 TFS #2452
	self.description	 	:= _descr;
	self.idHeading			:= _idHeading;

	// Set to Default at this stage but revisit when views are more defined (rjs)
	// They should be added to text on global constants
	
	if _attachmentView &lt;&gt; null then
		self.gateInOutAttachmentView := _attachmentView;
	else
		self.gateInOutAttachmentView := ETDef_Default;
	endif;

	if _extraReceiveView &lt;&gt; null then
		self.gateInOutExtraTblReceiveView := _extraReceiveView;
	else
		self.gateInOutExtraTblReceiveView := ETDef_Default;
	endif;
	
	if _extraReleaseView &lt;&gt; null then
		self.gateInOutExtraTblReleaseView := _extraReleaseView;
	else
		self.gateInOutExtraTblReleaseView := ETDef_Default;
	endif;

	if _mainReceiveView &lt;&gt; null then
		self.gateInOutMainTblReceiveView := _mainReceiveView;
	else
		self.gateInOutMainTblReceiveView := ETDef_Default;
	endif;

	if _mainReleaseView &lt;&gt; null then
		self.gateInOutMainTblReleaseView := _mainReleaseView;
	else
		self.gateInOutMainTblReleaseView := ETDef_Default;
	endif;
	
	self.allEnquiryEntTableDefs.clear();
	if _thumbDefs &lt;&gt; null then
		_thumbDefs.copy(self.allEnquiryEntTableDefs);
	endif;

	self.allEditTableDefs.clear();
	if _editDefs &lt;&gt; null then
		_editDefs.copy(self.allEditTableDefs);
	endif;

	self.mainFormFilterView  := _filterView;
	self.maintFormTblDataDef := _tblDataDef;

end;</source>
        <access>protected</access>
        <Parameter name="_id" type="Integer"/>
        <Parameter name="_abbr" type="String"/>
        <Parameter name="_descr" type="String"/>
        <Parameter name="_idHeading" type="String"/>
        <Parameter name="_thumbDefs" type="StringArray"/>
        <Parameter name="_editDefs" type="StringArray"/>
        <Parameter name="_attachmentView" type="String"/>
        <Parameter name="_extraReceiveView" type="String"/>
        <Parameter name="_extraReleaseView" type="String"/>
        <Parameter name="_mainReceiveView" type="String"/>
        <Parameter name="_mainReleaseView" type="String"/>
        <Parameter name="_filterView" type="String"/>
        <Parameter name="_tblDataDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromXML" id="f20cccde-4fbe-4fed-b04e-72e6284b1c06">
        <updating/>
        <source>setProxyFromXML(_id : Integer; _xml : String; _isCreate : Boolean; _root : CM_Root) updating;
// ---------------------------------------------------------------------------
// Created:     21 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpStr			: String;
	tmpEditDefs,
	tmpThumbDefs	: StringArray;
	pos				: Integer;
	tmpDefName		: String;
begin
/*
&lt;CargoType&gt;
&lt;Descr&gt;ISO Container&lt;/Descr&gt;
&lt;Abbr&gt;CONT&lt;/Abbr&gt;
&lt;Class&gt;CM_Container&lt;/Class&gt;
&lt;GateInOutAttachmentView&gt;Default&lt;/GateInOutAttachmentView&gt;	
&lt;GateInOutExtraTblReceiveView&gt;&lt;/GateInOutExtraTblReceiveView&gt;
&lt;GateInOutExtraTblReleaseView&gt;&lt;/GateInOutExtraTblReleaseView&gt;
&lt;GateInOutMainTblReceiveView&gt;&lt;/GateInOutMainTblReceiveView&gt;
&lt;GateInOutMainTblReleaseView&gt;&lt;/GateInOutMainTblReleaseView&gt;
&lt;EnqDefs&gt;
	&lt;DefName&gt;GeneralData&lt;/DefName&gt;
	&lt;DefName&gt;LocationMoveData&lt;/DefName&gt;
	&lt;DefName&gt;ReceiveData&lt;/DefName&gt;
	&lt;DefName&gt;StatusData&lt;/DefName&gt;
	&lt;DefName&gt;ReeferData&lt;/DefName&gt;
	&lt;DefName&gt;ShipOpsData&lt;/DefName&gt;
&lt;/EnqDefs&gt;
&lt;MaintFormTblDataDef&gt;ContainerData&lt;/MaintFormTblDataDef&gt;
&lt;MaintFormEditDef&gt;DefaultCargoEnt&lt;/MaintFormEditDef&gt;
&lt;MaintFormFilterView&gt;Container&lt;/MaintFormFilterView&gt;
&lt;/CargoType&gt;
*/

	//extract the enqury defs from the constant XML
	create tmpThumbDefs transient;
	tmpStr := _xml.cnEcGetTagValueOfName(XMLTag_ThumbDefs);

	pos := 1;
	while (pos &gt; 0) do
		tmpDefName := tmpStr.cnEcGetNextTagValueOfName(XMLTag_DefName, pos);
		if tmpDefName &lt;&gt; null then
			tmpThumbDefs.add(tmpDefName);
		endif;
	endwhile;
	
	create tmpEditDefs transient;
	tmpStr := _xml.cnEcGetTagValueOfName(XMLTag_EditDefs);

	pos := 1;
	while (pos &gt; 0) do
		tmpDefName := tmpStr.cnEcGetNextTagValueOfName(XMLTag_DefName, pos);
		if tmpDefName &lt;&gt; null then
			tmpEditDefs.add(tmpDefName);
		endif;
	endwhile;
	
	self.setProxyForCargoBOLType(_id,
				_xml.cnEcGetTagValueOfName('Abbr'),
				_xml.cnEcGetTagValueOfName('Descr'),
				_xml.cnEcGetTagValueOfName('IdHeading'),
				tmpThumbDefs,
				tmpEditDefs,
				_xml.cnEcGetTagValueOfName('GateInOutAttachmentView'),				
				_xml.cnEcGetTagValueOfName('GateInOutExtraTblReceiveView'),
				_xml.cnEcGetTagValueOfName('GateInOutExtraTblReleaseView'),
				_xml.cnEcGetTagValueOfName('GateInOutMainTblReceiveView'),
				_xml.cnEcGetTagValueOfName('GateInOutMainTblReleaseView'),
				_xml.cnEcGetTagValueOfName(XMLTag_MaintFormFilterView),
				_xml.cnEcGetTagValueOfName(XMLTag_MaintFormTblDataDef));

epilog
	delete tmpThumbDefs;
	delete tmpEditDefs;
end;</source>
        <Parameter name="_id" type="Integer"/>
        <Parameter name="_xml" type="String"/>
        <Parameter name="_isCreate" type="Boolean"/>
        <Parameter name="_root" type="CM_Root"/>
    </JadeMethod>
    <JadeMethod name="showCargoEnqDebtorTypes" id="f9597b8a-aafc-403b-9478-f6b97b46619d">
        <source>showCargoEnqDebtorTypes() : Boolean;
// CCMS 1776 Aug 2011 code moved from CM_ContainerEnqForm
vars
	result	: Boolean;
begin
	if self.allEnquiryEntTableDefs.includes("ReceiveData") or
	   self.allEnquiryEntTableDefs.includes("DefaultCargoEnt") or
	   self.allEnquiryEntTableDefs.includes("TimberCargoEnt") or
	   self.allEnquiryEntTableDefs.includes("TrailorData") or
	   self.allEnquiryEntTableDefs.includes("BreakBulkEnt") then 
		result := true;
	endif;
	
	return result;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="17ce2613-497c-4219-a618-06291fcf58c6">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     21 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.id = null then
		app.raiseCMException(Input_required_field_Id, 'id', null); // cnwdb2	PAR 35364
	endif;
	
	if self.abbreviation = null then
		app.raiseCMException(Input_required_field_abbrviat, 'abbreviation', null); // cnwdb2	PAR 35364
	endif;
	
	if self.description = null then
		app.raiseCMException(Input_required_field_Desc, 'description', null); // cnwdb2	PAR 35364
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="cb3d7211-5832-4e18-bf7d-5e23849118de">
        <source>validateForDelete();
//------------------------------------------------
// Created: 20 April 2006 By: cnwgd1
//------------------------------------------------
vars
	term : CM_Terminal;
begin
	// If there is cargo for this type and it is deleted then JMTerminal will puke all over your shoes!
	// so make sure there is no cargo with this type before deleting it.
	foreach term in self.allTerminals do
		if term.hasTrackedItemForCargoType(self.id, false) then
			// has ti's, cannot delete
			app.raiseCMException2(ObjectStillHasEntries, 'Cargo Type ' &amp; self.description,term.code &amp;  " cargo items", null, null);			
			return;
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="d6c17afa-5941-4d45-82dd-ff74ab74ca0f">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     21 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/12/2014   cnwdb2	    PAR 35364
// 05/05/2020	jlgdap1		TFS 49252 CPL Cargo Types not showing in System Admin screen
// ---------------------------------------------------------------------------
vars
	tmpId	: Integer;

begin

	tmpId	:= self.id;

	if tmpId = null then
		app.raiseCMException(Input_required_field_Id, 'id', null); // cnwdb2	PAR 35364
	endif;
	
	if self.description = null then
		app.raiseCMException(Input_required_field_Desc, 'description', null); // cnwdb2	PAR 35364
	endif;
	//epr par 36005 9/4/15
	if self.abbreviation = null then
		app.raiseCMException(Input_required_field_abbrviat, 'abbreviation', null); // cnwdb2	PAR 35364
	endif;
	
	if tmpId &gt; TI_CargoBOLType_Max and
	   tmpId &lt; TI_CargoBOLType_JMTMax then
		if (not app.myRoot.canDo(Mod_GeneralCargo)) then
			app.raiseCMException1(NotLicensedToPerformAction, app.getLicenseName(Mod_GeneralCargo), null, null);
		endif;
	endif;
		
	if tmpId &gt; TI_CargoBOLType_JMTMax then
		if not app.myRoot.isClientCentrePort then		// TFS 49252
	//	if (not app.myRoot.canDo(PmDeveloper)) then
	//		app.raiseCMException1(NotLicensedToPerformAction, app.getErrorString(Create_A_Cargo_Type), null, null);
			app.raiseCMException2(ERR_LOWER_GT_UPPER,'id', TI_CargoBOLType_JMTMax.String, null, null);	//07 Oct 2019	NDL	TFS 46169
	//	endif;
		endif;											// TFS 49252
	endif;

end;</source>
    </JadeMethod>
</Class>
