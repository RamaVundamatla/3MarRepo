    <JadeMethod name="setForUpdate" id="3521a450-0955-4838-adf7-2f61ee5e12b4">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
//----------------------------------------------------------------
//	Created:	08 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/// 22 Feb 2016	cnwrs1	TFS 3401 fixup EDI Operations update of EDI TIs
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	voyage : CM_Voyage;
begin
	inheritMethod(_proxyEDITI);
	self.entryNumber 		:= _proxyEDITI.entryNumber;
	self.vesselName 		:= _proxyEDITI.vesselName;
	voyage := self.getMyTerminal.lookupVoyage(self.getVoyageCode(), null, false);
	self.setVoyage(voyage);
	self.responseStatus 	:= _proxyEDITI.responseStatus;
	self.setStatus(_proxyEDITI.status);
	self.userNotes			:= _proxyEDITI.userNotes;
	self.billOfLading		:= _proxyEDITI.billOfLading;
	self.consignor			:= _proxyEDITI.consignor;
	self.consignee			:= _proxyEDITI.consignee;
	self.customsAgent		:= _proxyEDITI.customsAgent;
	self.customsRef	:= _proxyEDITI.customsRef;
	self.clientRef := _proxyEDITI.clientRef;
	self.sequenceNum := _proxyEDITI.sequenceNum;
epilog

end;
</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
