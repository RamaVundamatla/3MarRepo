    <JadeMethod name="calculateFigures" id="991a016b-bd85-42c8-aed0-c0bfc6533f84">
        <updating/>
        <source>calculateFigures(sampleObject  : SampleObjects io; total : Integer io; increment : Integer io) updating;

vars

begin
	sampleObject.countIncrement := sampleObject.count - sampleObject.previousCount;
	sampleObject.previousCount  := sampleObject.count;
	total     := total + sampleObject.count;
	increment := increment + sampleObject.countIncrement;
end;</source>
