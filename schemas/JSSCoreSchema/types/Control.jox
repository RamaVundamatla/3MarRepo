    <JadeMethod name="jssCopyFontSettings" id="ff476155-4917-49a3-a790-ed0d98de5dc6">
        <updating/>
        <source>jssCopyFontSettings(pControl:Control) updating;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		Copy all of the font-related settings from the parameter control to
//				the receiver.
//
// Parameters:	pControl (Control) - The control from which to copy the font settings.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pControl.fontName = null then
		self.fontName 	:= app.fontName;
	else
		self.fontName	:= pControl.fontName;
	endif;

	self.fontBold 		:= pControl.fontBold;
	self.fontItalic 	:= pControl.fontItalic;
	self.fontSize		:= pControl.fontSize;
	self.fontStrikethru	:= pControl.fontStrikethru;
	self.fontUnderline	:= pControl.fontUnderline;
end;</source>
        <Parameter name="pControl" type="Control"/>
    </JadeMethod>
</GUIClass>
