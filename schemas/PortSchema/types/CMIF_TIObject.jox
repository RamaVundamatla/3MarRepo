    <JadeMethod name="actionForAutoPlan" id="96cbd036-6230-480d-818a-67237dd1145c">
        <source>actionForAutoPlan(_theJob : CM_RoadJob; _passport : CM_Passport input) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 June 2009	cnwer1	Initial creation 19912

*/

vars

begin
	if _theJob = null then
		return false;
	endif;
	
	if _theJob.autoComplete then
		return false;
	endif;
	
	if not  self.myTerminal.isAutoPlanningEnabled() then   //SFW1030 04/08/2008
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <Parameter name="_theJob" type="CM_RoadJob"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
