    <JadeMethod name="dragTrackedItem" id="87932376-2ada-4480-9f99-fb465b9a6764">
        <updating/>
        <source>dragTrackedItem(_ti : CM_TrackedItem; _wle : CM_WorkListEntry; _control : Control input) updating;
//--------------------------------------------------------------
//Created: 18 April 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	picture			: Picture;
	wleObj			: CM_WorkListEntry;
	obj				: Object;
	tmpTi			: CM_TrackedItem;
	origLocn		: CM_LocationsController;
	moveController	: CMIF_MoveController;
	invalidWLE		: Boolean;
	retrospectiveTS : TimeStamp;
	
begin
	on Exception do app.handleDeletedObject(exception, wleObj, invalidWLE);		 // PAR 17940

	// Par 14454 Jade doesn't seem to cope with invalid objects in delete
	if global.isValidObject(app.myMoveController) then
		delete app.myMoveController;
	endif;

	create moveController transient;	
	app.myMoveController := moveController;
	moveController.setMoveMode(self.moveModeForm);			
	moveController.setMyTrackedItem(_ti);
	if self.isRailOpsForm then	//14 May 2021	NDL	TFS 51124
		self.getRetrospectiveTS( retrospectiveTS );	
		if retrospectiveTS.date.isValid then
			moveController.setEffectiveTimeStampOverride( retrospectiveTS );
		endif;
	else
		origLocn := _ti.getPrimaryLocation(REAL_MODE);	
		if origLocn &lt;&gt; null then
			moveController.setEffectiveTimeStampOverride(origLocn.getEffectiveTimeStamp());
		endif;
	endif;

	if _control &lt;&gt; null then
		if _control.isKindOf(CMUI_GridAreaFrame) then
			if self.isStartGridPointSkeletonCar(_control.CMUI_GridAreaFrame) then		// TFS 2533
				moveController.isLogWagonDrag := true;
			endif;
		endif;
	endif;
	
	//WLE could be null if drag from grid area.
	
	wleObj	:=	_wle;
	
	if wleObj &lt;&gt; null then
		wleObj.setMoveControllerAllOtherTIs(moveController);
		
		if invalidWLE then // PAR 17940
			self.myCurrentTrackedItem := null; // PAR 17940
			self.myCurrentWLE := null; // PAR 17940
			return; // PAR 17940
		endif; // PAR 17940
	endif;
	
	if _control = self.tblWorkEntries then
		foreach obj in self.tblWorkEntries.allSelectedObjects do
			invalidWLE	:=	false;
			
			if obj = _wle then
				continue;
			endif;
			
			wleObj := obj.CM_WorkListEntry;
			if wleObj.status &lt;&gt; WLE_UNACTIONED then
				continue;
			endif;
			
			if invalidWLE then
				continue;
			endif;
			
			if wleObj.queue &lt;&gt; null then
				continue;
			endif;
			
			tmpTi := wleObj.myTrackedItem;
			if tmpTi &lt;&gt; null and tmpTi &lt;&gt; _ti then
				moveController.allOtherTrackedItems.add(tmpTi);
				moveController.allOtherWLEs.add(wleObj);					
			endif;
		endforeach;	
	endif;
	
	if _wle &lt;&gt; null then
		if moveController.allOtherTrackedItems.isEmpty then
			if moveController.moveMode = REAL_MODE and		// 22/04/2009 cnwar2 #19464
			_ti.myPrimaryQueuedLocation &lt;&gt; null then		// wle should not be updated if the move is instant and the item is queued
				moveController.setMyWorkListEntry(null);	// (unless the move is to the queued location, this is handled later)
			else
				moveController.setMyWorkListEntry(_wle);
			endif;
		else
			moveController.setJobForMove(_wle.job);		
		endif;
	endif;
	
	_control.dragMode := DragMode_Drag;
	
	create picture transient;
	self.setPictureDragCursor(picture);
	if picture &lt;&gt; null then
		_control.dragCursor := picture.picture;
	endif;
epilog
	if picture &lt;&gt; null then
		delete picture;
	endif;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_control" type="Control" usage="input"/>
    </JadeMethod>
