    <JadeMethod name="canDoDelete" id="baf040da-4274-4854-821a-6f72667e27fb">
        <source>canDoDelete(): Boolean;
// ---------------------------------------------------------------------------
// Created:     24 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	//15 Feb 2018	NDL	TFS 36947
	if not app.getMyUser.canDo( null, PmCmpUserTableDelete ) then
		app.msgBox(app.getErrorString1(NoPermission, 'delete this user'), 'Error', MsgBox_OK_Only);
		return false;
	endif;
	
	if (not self.canUserUpdate(self.myForm.myCurrentObject.CM_User)) then
		app.msgBox(app.getErrorString1(NoPermission, 'delete this user'), 'Error', MsgBox_OK_Only);
		return false;
	endif;
	
	return true;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canDoEdit" id="2150dcd5-a805-48f9-8604-a2a7c17c8471">
        <source>canDoEdit(): Boolean;
// ---------------------------------------------------------------------------
// Created:     24 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30 Aug 2019	jlgdi1		45802 Added specific 'JMTSUPPORT' user check.
// 21 Sep 2020 cnwma1 ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data
// ---------------------------------------------------------------------------

vars
	selectedUser : CM_User;

begin
	selectedUser := self.myForm.myCurrentObject.CM_User;
	
	if (not self.canUserUpdate(selectedUser)) then
		app.msgBox(app.getErrorString1(NoPermission, 'update this user'), 'Error', MsgBox_OK_Only);
		return false;
	endif;
	
	if (selectedUser.isJmtSupportUser() or selectedUser.isOpsViewUser()) and not app.getMyUser().isSuperUser() then    //21.09.2020 cnwma1 TFS #49758
		app.msgBox(app.getErrorString1(JMTSupportUserCannotBeChanged, 'update this user'), 'Error', MsgBox_OK_Only);
		return false;
	endif;
	
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canUserUnlock" id="6f3cad38-06c5-4d84-a490-dc4acb6ffd13">
