    <JadeMethod name="displayEntryEventStreamEvent" id="6bcefc77-3e4f-43ef-94de-c0cde471f551">
        <source>displayEntryEventStreamEvent(_obj : CM_Object) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 January 2020		jlgzm1	Initial creation TFS 47920 Event Stream Admin JMT UI

*/

vars

begin
	if _obj.isKindOf(CM_EventType) then
		return _obj.CM_EventType.name;
		
	elseif _obj.isKindOf(CM_TransactionType) then
		return _obj.CM_TransactionType.description;
		
	elseif _obj.isKindOf(CM_LongString) then
		return _obj.CM_LongString.string;
		
	elseif _obj.isKindOf(CM_EventStreamEventType) then
