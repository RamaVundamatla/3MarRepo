    <JadeMethod name="getPermissionNameFromInteger" id="57ac9d97-1030-4f0f-bedf-7c8bb8463099">
        <source>getPermissionNameFromInteger( _permissionInt : Integer ):String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 May 2011	cnwndl1	Initial creation

*/

vars

	permissionName : String;
	
	schema : Schema;
	category : ConstantCategory;
	allConstants : ConstantNDict;
	constant : Constant;
	xmlText : String;
	pos1 : Integer;
	pos2 : Integer;
	start : Integer;
	length : Integer;

begin

	if _permissionInt = 0 then
		permissionName := "Unknown";
		
	else
	
		permissionName := _permissionInt.String;
		schema := rootSchema.getSchema(PortSchemaName);
		category := schema.getConstantCategory("XLAT_Permissions");
		allConstants :=	category.cnEcGetConstants();
		foreach constant in allConstants do
			if constant.getSource = permissionName then
				xmlText := constant.text;
				break;
			endif;
		endforeach;
		if xmlText &lt;&gt; null then
			pos1 := xmlText.pos("&lt;Description&gt;",1);
			pos2 := xmlText.pos("&lt;/Description&gt;",1);
			if pos1 &gt; 0 and pos2 &gt; 0 then
				start :=  pos1 + 13;
				length := pos2 - start;
				permissionName := xmlText[ start : length ];
			endif;
		endif;
	endif;

	return permissionName;

epilog

end;</source>
        <Parameter name="_permissionInt" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getQuickAccessByPermission" id="5c4ada02-1454-438e-8464-2046a5c4fb3b">
        <source>getQuickAccessByPermission( _byPermission : Integer ) : CM_QuickAccess;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2014	cnwndl1	Initial creation

*/

vars

	loopQuickAccess : CM_QuickAccess;
	quickAccess : CM_QuickAccess;

begin

	foreach loopQuickAccess in self.allUserQuickAccess do
		if loopQuickAccess.permissionInteger = _byPermission then
			quickAccess := loopQuickAccess;
			break;
		endif;
	endforeach;
	
	if quickAccess = null then
		// No quick access found yet, try the default ones
		quickAccess := app.myRoot.getQuickAccessByPermission(_byPermission);
	endif;
	
	return quickAccess;

epilog

end;</source>
        <Parameter name="_byPermission" type="Integer"/>
        <ReturnType type="CM_QuickAccess"/>
    </JadeMethod>
