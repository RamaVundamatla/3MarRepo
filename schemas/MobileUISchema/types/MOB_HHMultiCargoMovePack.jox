    <JadeMethod name="txtCargoId_keyPress" id="82ba6f6a-af21-40fe-a54f-44ab38a9445e">
        <controlMethod name="TextBox::keyPress"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_keyPress(textbox: TextBox input; keyCharCode: Integer io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 January 2016	cnwndl1	Initial creation	Par 37390

*/

vars

begin
	if keyCharCode = J_key_Enter then
		app.convertScannedCargoId( self.myTerminal, textbox, false, null );	//06 Jul 2016	NDL	TFS 2275
		self.doClickPartCargoIdSearch();
		self.txtCargoId_gotFocus(self.txtCargoId);	//15 Jan 2016	NDL Par 37390
	endif;
epilog

end;</source>
