				return true;
			endif;
		endif;
	endif;
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAttrHazardous" id="51922405-5466-420f-9eaf-8cf3748eff24">
        <source>getAttrHazardous() : Boolean;
/*
Purpose:			
Date			Who			Reason
JUNE 2011		CNWAB1		Initial creation
23 Nov 2011		cnwkpd1		PAR #28731 - fix transient leaks
// 11/10/2022	navkc1	Bug 54935: MSL - Roro planning - Slow on big decks/large vessels
*/

vars
	criteria 		: CM_YACriteria;	
	terminal		: CM_Terminal;			
	
	hazardArray		: StringArray;			
	
	isHazardous		: Boolean;				
	value			: String;				
	length			: Integer;	
	voyAlloc : CM_VoyageAllocation;
begin
	voyAlloc := self.allAllocations.first().CM_VoyageAllocation;  // 11/10/2022	navkc1	#54935
	if voyAlloc &lt;&gt; null then  // 11/10/2022	navkc1	#54935
		//criteria := self.getAttrByType(YACriteriaType_IsHazardous); 
		criteria := voyAlloc.getCriteriaOfTypeValue(YACriteriaType_IsHazardous); // 11/10/2022	navkc1	#54935
		if criteria &lt;&gt; null then
			if criteria.myYAData.CM_YADataBoolean.getDataValue().Integer = CM_YADataBoolean.VALUE_FALSE then
				isHazardous := false;				
			else
				isHazardous := true;	
			endif;
		endif;
		if not isHazardous then
			//criteria := self.getAttrByType(YACriteriaType_Hazardous);
			criteria := voyAlloc.getCriteriaOfTypeValue(YACriteriaType_Hazardous); // 11/10/2022	navkc1	#54935
			if criteria &lt;&gt; null then
				// get the critiera into an array
				value := criteria.myYAData.getDataValue().String;
				hazardArray := value.getTokens();
				
				// get the terminal and includeLQasHazard
				terminal := self.myTerminal;
				if terminal = null or terminal.includeLQasHazardous() then
					isHazardous := true;
				else
					foreach value in hazardArray do
						length := value.trimBlanks().length;
						if length = 1 or (length &gt; 1 and value[length:1] &lt;&gt; "L") then
							isHazardous := true;
							break;
						endif;
					endforeach;
				endif;
			endif;
		endif;
	endif;
	return isHazardous;
epilog
	delete hazardArray;			// PAR #28731
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAttrHazardousList" id="3f32012a-1a9a-4d61-8691-f8e32832f6cb">
        <source>getAttrHazardousList() : String;
// ---------------------------------------------------------------------------
// Created:     December 2014 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	criteria 		: CM_YACriteria;	
	value			: String;				
	length			: Integer;			
begin
	
		criteria := self.getAttrByType(YACriteriaType_Hazardous);
		if criteria &lt;&gt; null then
			// get the critiera into an array
			value := criteria.myYAData.getDataValue().String;
			
			return value;
		endif;
	return "";
epilog

end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
