    <JadeMethod name="utlUpdateRootStateObject" id="20972b1f-707c-49a3-8d5f-6e0ed6b4a59c">
        <source>utlUpdateRootStateObject(pGroup : Integer; pProxyStateObject : CM_StateObject;
						_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

