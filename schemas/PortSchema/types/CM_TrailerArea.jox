    <JadeMethod name="setGridObjectsForDecking" id="4e06b991-3707-44b4-b1b1-18820d260828">
        <source>setGridObjectsForDecking(_passport: CM_Passport input);
//----------------------------------------------------------------
//	Created:	02 June 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	gridRow : CM_GridObject;
	pDO		: CM_YADeckingOptionsRow;
begin

	foreach gridRow in self.allGridRowsByLabel do
		if gridRow.myDeckingOptions = null then
			create pDO transient;
			pDO.setProxy(false, true, gridRow);
			pDO.setProxyRules(DeckingRule_Default, DeckingRule_Default);
		else
			pDO := gridRow.myDeckingOptions.pxyCreateUpdateProxy;
			pDO.allYALocationCellsIn.clear;
			pDO.allYALocationCellsOut.clear;
		endif;
		
		//update it
		app.myUtilityUA.utlUpdateDeckOptionsApplyRules(pDO, DeckingLevel_Row, _passport);
		
		if app.isValidObject(pDO) then		// is transient - OK
			delete pDO;
		endif;
		
		if _passport.hasErrors then
			return;
		endif;
		
	endforeach;	 

epilog
	if app.isValidObject(pDO) then		// is transient - OK
		delete pDO;
	endif;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="eaf26df0-dde2-42ac-92af-a91aea1c645d">
        <updating/>
        <source>setProxy(pID, pComment			: String; 
		 pType 					: Integer;
		 pRows 					: Integer;
		 pCols 					: Integer;
		 pHeight 				: Integer;
		 pTypeString 			: String;
		 pBack 					: Boolean;
		 pFront 				: Boolean;
		 pFull 					: Integer;
		 pMT 					: Integer;
		 pPower 				: Integer;
		 pStagger 				: String;
		 pActAsReleasePoint 	: Boolean;
		 _terminal				: CM_Terminal;
		 _stockControlled		: Boolean;
		_hideFromOverView : Boolean;
		_deckingStartType : Integer;
		_noLeft, _noRight : Boolean;
		_allInterchangeAreas	:CM_InterchangeAreaArray;	// par 24292
		_defaultInterchangeArea: CM_InterchangeArea) updating;
// ---------------------------------------------------------------------------
// Created:		November 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 26/05/2010		cnwcs5	par 24292 - change _allInterchangeAreas parameter from set to array
begin
	self.raiseExceptionIfNotTransient(method);
	
	self.setGridAreaProxy(pID, pComment, pType, pRows, pCols, pHeight,
			pActAsReleasePoint, _terminal, false, _stockControlled,_hideFromOverView, _deckingStartType,
			_noLeft, _noRight, false, false, false, _allInterchangeAreas,_defaultInterchangeArea , false, false,
			null,null,null,null);
			
//	self.height := pHeight;
//	self.accessBack := pBack;
//	self.accessFront := pFront;
//	self.maxHeightFull := pFull;
//	self.maxHeightMT := pMT;
//	self.maxHeightPower := pPower;
//	setStaggerHeights(pStagger);
end;</source>
        <Parameter name="pID" type="String"/>
        <Parameter name="pComment" type="String"/>
        <Parameter name="pType" type="Integer"/>
        <Parameter name="pRows" type="Integer"/>
        <Parameter name="pCols" type="Integer"/>
        <Parameter name="pHeight" type="Integer"/>
        <Parameter name="pTypeString" type="String"/>
        <Parameter name="pBack" type="Boolean"/>
        <Parameter name="pFront" type="Boolean"/>
        <Parameter name="pFull" type="Integer"/>
        <Parameter name="pMT" type="Integer"/>
        <Parameter name="pPower" type="Integer"/>
        <Parameter name="pStagger" type="String"/>
        <Parameter name="pActAsReleasePoint" type="Boolean"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_stockControlled" type="Boolean"/>
        <Parameter name="_hideFromOverView" type="Boolean"/>
        <Parameter name="_deckingStartType" type="Integer"/>
        <Parameter name="_noLeft" type="Boolean"/>
        <Parameter name="_noRight" type="Boolean"/>
        <Parameter name="_allInterchangeAreas" type="CM_InterchangeAreaArray"/>
        <Parameter name="_defaultInterchangeArea" type="CM_InterchangeArea"/>
    </JadeMethod>
    <JadeMethod name="validate" id="146dcf4d-1025-4d37-91d9-574399035d28">
        <source>validate() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 October 2008	cnwrd1	Initial creation par#18130

*/

vars

begin
	inheritMethod();

	if self.locationLength = 0 then
		app.raiseCMException2(ERR_INVALID_VALUE,'location length','The location length cannot be zero.', ETRow_LocationLength, null);
	endif;
	
	if self.locationWidth = 0 then
		app.raiseCMException2(ERR_INVALID_VALUE,'location width','The location width cannot be zero.', ETRow_LocationWidth, null);
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
