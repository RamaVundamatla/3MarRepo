    </JadeMethod>
    <JadeMethod name="utlUpdateBolFromEDIAction" id="541e53c9-835e-4ab5-b4ed-f9328ec62902">
        <source>utlUpdateBolFromEDIAction( _pxyBol: CM_BOL input; _theEDITI : CM_EDICustomStopTI; _ediFileType : CM_EDIFileType; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 March 2017	cnwndl1	Initial creation	YFS 3857

*/

vars
	theRealBol		: CM_BOL;
	expectedEdition : Integer;
	aTITrans		: CM_TITransaction;
	ediAction		: CM_EDIAction;
	action			: Boolean;
	updated			: Boolean;
	actionObject	: CM_Object;
	invalid 		: Boolean;
	stopTable  		: CM_StopsTable;
	actionType 		: String;
	
begin
	self.initialiseActivity();

	_pxyBol.raiseExceptionIfNotProxy(method);
	_pxyBol.pxyGetRealObjectAndEdition(theRealBol, expectedEdition);

	if theRealBol = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "can't locate real object");
		return;
	endif;

	exclusiveLock(theRealBol);
	
	on Exception do app.handleDeletedObject(exception, actionObject, invalid);
	
	if _ediFileType.type  = EDIFileType_XMLOneStopCust then
		ediAction := _ediFileType.CM_EDIFileTypeXMLOneStopCust.getEdiAction( _theEDITI.clientRef, _theEDITI.description, theRealBol, true );
	endif;
	if ediAction = null or ediAction.myActionObject = null then
		return;
	endif;
	
	// On BOLS this can only be a STOP. (Technically Todos can be set up in the thin client against the EDI actions)
	// But BOLS don't have them.
	actionObject := ediAction.myActionObject;
	if actionObject &lt;&gt; null and actionObject.isKindOf(CM_StopsTable) then
		stopTable := actionObject.CM_StopsTable;
		actionType := ediAction.actionType;
	endif;
	
	if stopTable &lt;&gt; null then
		if actionType = EDIAction_Remove or actionType = EDIAction_Complete or actionType = EDIAction_RemoveHolds then
			theRealBol.removeAStop( stopTable, false, _passport );
		elseif actionType =  EDIAction_Add or actionType = EDIAction_PlaceHold then
			theRealBol.createAStop( stopTable, false, _passport );
		endif;	
	endif;
	
epilog
	
end;</source>
        <Parameter name="_pxyBol" type="CM_BOL" usage="input"/>
        <Parameter name="_theEDITI" type="CM_EDICustomStopTI"/>
        <Parameter name="_ediFileType" type="CM_EDIFileType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateBookingRef" id="798cd21a-5769-40ca-a081-4fa63d30417b">
        <updating/>
        <source>utlUpdateBookingRef(pProxyBookingRef : CM_BookingRef input; _passport : CM_Passport input; _allNewBookingRefProxies: CM_ObjectArrayActual input) updating;
// ---------------------------------------------------------------------------
// Created:     30 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 28/06/2013	cnwdap1		PAR #31816 As we do when creating a booking, check for matching prenoted and onsite cargo
// 21/09/2016	CNWMA1	TFS #2675 PAR #38206 POL - Bookings window - Audit trail menu Audit window
// ---------------------------------------------------------------------------
vars
	realBookingRef	: CM_BookingRef;
	expectedEdition	: Integer;
	bookRefObj      : CM_BookingRefItem;
	itemAudit : CM_UpdateTransactionAuditAgent;
	itemAudits : CM_AgentByObjectDict;
	idx : Integer;
begin

	self.initialiseActivity();

	create itemAudits transient;
	
	pProxyBookingRef.raiseExceptionIfNotProxy(method);
	pProxyBookingRef.pxyGetRealObjectAndEdition(realBookingRef, expectedEdition);
	
	if realBookingRef = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_BookingRef.name, null, null);
		return;
	endif;

	app.setContinueCMExceptions(true);
	
	app.myValUA.valBookingRef(pProxyBookingRef, _passport, null);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);
		
	exclusiveLock(realBookingRef);

	if _passport.noErrors and realBookingRef.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'booking reference', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realBookingRef, true);
		foreach bookRefObj in realBookingRef.allBookingRefItems do  //21/09/2016 cnwma1 TFS #2675 PAR #38206
			create itemAudit transient;
			itemAudits.putAtKey(bookRefObj,itemAudit);
			itemAudit.audUpdateGeneric(bookRefObj, true);
		endforeach;
	endif;
	
	if _passport.noErrors then
		realBookingRef.setForUpdate(pProxyBookingRef, null);
	endif;

	if _passport.noErrors then
		realBookingRef.setForUpdateBookingRefItems(pProxyBookingRef,_allNewBookingRefProxies);
	endif;
	
	// PAR #31816 Look for any on-site and pre-noted mtching TIs
	if _passport.noErrors then					// PAR #31816
		realBookingRef.getTIsOnSite();			// PAR #31816
		realBookingRef.getTIsNotified();		// PAR #31816
	endif;										// PAR #31816
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realBookingRef, false);
		idx := 1; 													 //21/09/2016 cnwma1 TFS #2675 PAR #38206
		foreach bookRefObj in realBookingRef.allBookingRefItems do   //21/09/2016 cnwma1 TFS #2675 PAR #38206
			itemAudit := itemAudits.getAtKey(bookRefObj).CM_UpdateTransactionAuditAgent;
			if itemAudit &lt;&gt; null then
				itemAudit.audUpdateGeneric(bookRefObj, false);
			endif;
		endforeach;
		realBookingRef.causeEvent(realBookingRef.myTerminal.getTerminalEvent(Event_BookingRefUpdate), false, realBookingRef);
		
		realBookingRef.handleOpsView(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE); // ### TFS 53105 30MAY2022 NAVAB1
	endif;
epilog
itemAudits.purge;
	delete itemAudits;

end;</source>
        <Parameter name="pProxyBookingRef" type="CM_BookingRef" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_allNewBookingRefProxies" type="CM_ObjectArrayActual" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateBookingRefMulti" id="2b6166a3-9af7-48ef-91fa-dfd98f0943e0">
        <updating/>
        <source>utlUpdateBookingRefMulti(_cmifBookingRef : CMIF_BookingRef input;  _passport : CM_Passport input; pUserObject : Object) updating;
/*
	Created on 13 February 2008
	
	by Debby Hutchison
	
	Purpose:
	
Changed On	By			Reason
----------	--------	-----------------------------------------------------------------------------------------------------
28/06/2013	cnwdap1		PAR #31816 As we do when creating a booking, check for matching prenoted and onsite cargo
						(but not when the config option RemItemsIfBookItemDel is set, as any attaching has already been done)
// 07/05/2017 cnwrh7         TFS4387       #No auditing on update via EDI
// 31/10/2017 jlgrh7 			 TFS 6947		POL - Missing Audit records for bookings 
*/

vars
	realBookingRef	: CM_BookingRef;
	expectedEdition	: Integer;
	
	bookRefObj      : CM_BookingRefItem;								//+TFS4387
	itemAudit : CM_UpdateTransactionAuditAgent;				//+TFS4387
	itemAudits : CM_AgentByObjectDict;									//+TFS4387
	
begin

	self.initialiseActivity();
	
	create itemAudits transient;													//+TFS4387
	
	_cmifBookingRef.myProxyBookingRef.pxyGetRealObjectAndEdition(realBookingRef, expectedEdition);
	
	if realBookingRef = null then
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_BookingRef.name, null, null);
		return;
	endif;

	app.setContinueCMExceptions(true);
	
	app.myValUA.valBookingRefMulti(_cmifBookingRef, _passport, pUserObject);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	exclusiveLock(realBookingRef);

	if _passport.noErrors and realBookingRef.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'booking reference', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realBookingRef, true);
		foreach bookRefObj in realBookingRef.allBookingRefItems do 															//+TFS4387 Starts
			create itemAudit transient;
			itemAudits.putAtKey(bookRefObj,itemAudit);
			itemAudit.audUpdateGeneric(bookRefObj, true);
		endforeach;
	endif;
	
	if _passport.noErrors then
		realBookingRef.setForUpdateMulti(_cmifBookingRef);																															
		itemAudit.audUpdateGenericWithExtraInfo(realBookingRef,"Booking Items refreshed by EDI");									//+TFS6947
	endif;
	
	// PAR #31816 Look for any on-site and pre-noted mtching TIs											// PAR #31816
	if _passport.noErrors and not realBookingRef.myTerminal.getConfig(RemItemsIfBookItemDel).Boolean then	// PAR #31816
		realBookingRef.getTIsOnSite();																		// PAR #31816
		realBookingRef.getTIsNotified();																	// PAR #31816
	endif;																									// PAR #31816
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realBookingRef, false);
		
		foreach bookRefObj in realBookingRef.allBookingRefItems do  													//+TFS4387 Starts
			itemAudit := itemAudits.getAtKey(bookRefObj).CM_UpdateTransactionAuditAgent;
			if itemAudit &lt;&gt; null then
				itemAudit.audUpdateGeneric(bookRefObj, false);
			endif;
		endforeach;
		
		realBookingRef.causeEvent(realBookingRef.myTerminal.getTerminalEvent(Event_BookingRefUpdate), false, realBookingRef);
		
		realBookingRef.handleOpsView(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE); // ### TFS 53105 30MAY2022 NAVAB1
		
	endif;
	
epilog

	itemAudits.purge;						//+TFS4294
	delete itemAudits;
	
end;</source>
        <Parameter name="_cmifBookingRef" type="CMIF_BookingRef" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="pUserObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateBookingRefRemarks" id="3cc90345-0290-4f0f-9ee0-8ae2e804a183">
        <source>utlUpdateBookingRefRemarks(	_bookingRef : CMEVT_BookingRefDiscrep io;
							_remarks : String;
							_closed : Boolean; 
							_passport : CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 September 2009	cnwndl1	Initial creation CCMS 1609 Par 20521

*/

vars

begin

	self.initialiseActivity();
	app.setContinueCMExceptions(false);

	exclusiveLock(_bookingRef);
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_bookingRef, true);
	else
		return;
	endif;
	
	if _passport.noErrors then
		_bookingRef.setRemarksAndClosed(	_remarks,	// _remarks : String;
											_closed	//_isClosed : Boolean
											);
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_bookingRef, false);
	else
		return;
	endif;
	

epilog

end;</source>
        <Parameter name="_bookingRef" type="CMEVT_BookingRefDiscrep" usage="io"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_closed" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateBookingsSetReconciled" id="3126cb1e-0c82-42ae-bf29-0bed00782018">
        <source>utlUpdateBookingsSetReconciled( _allBookings : CM_BookingRefSet; _reason : String; _date: Date;_passport : CM_Passport);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 March 2013	cnwrd1	Initial creation
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	aBookingRef : CM_BookingRef;
	theReason : String;
	theDate : Date;
	theUser : CM_User;
begin
	

	self.initialiseActivity();
	app.setContinueCMExceptions(false);
	
	if _reason = null then
		theReason := app.getErrorString(Bulk_reconciled);
	else
		theReason := _reason;
	endif;

	if _date = null then
		theDate := app.actualTimeServer.Date;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	else
		theDate := _date;
	endif;

	foreach aBookingRef in _allBookings do
	
		exclusiveLock(aBookingRef);
		
		if _passport.noErrors then
			self.myUpdateAuditAgent.audUpdateGeneric(aBookingRef, true);
		else
			return;
		endif;
		
		aBookingRef.setReconciliation(true, theReason, theDate);
		
		
		if _passport.noErrors then
			self.myUpdateAuditAgent.audUpdateGeneric(aBookingRef, false);
		else
			return;
		endif;
	
	
	endforeach;
	
epilog

end;</source>
        <Parameter name="_allBookings" type="CM_BookingRefSet"/>
        <Parameter name="_reason" type="String"/>
        <Parameter name="_date" type="Date"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateBoom" id="46124dd3-b71c-420e-acd1-2eff20ee434a">
        <source>utlUpdateBoom(	_pxyBoom  : CM_Boom input;
				_passport : CM_Passport input);

/*
Date			Who		Reason
06 July 2009	cnwar2	Initial creation

*/
vars
	realBoom 		: CM_Boom;
	expectedEdition : Integer;
	
begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_pxyBoom, 'Boom Proxy');
	
	_pxyBoom.pxyGetRealObjectAndEdition(realBoom, expectedEdition);
	self.raiseExceptionIfNull(realBoom, 'Boom');
	
	_pxyBoom.validateUpdate(_passport);
	
	if not _passport.noErrors then
		return;
	endif;
	
	realBoom.setForUpdate(_pxyBoom);
end;</source>
        <Parameter name="_pxyBoom" type="CM_Boom" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateBulkInvLineDescMap" id="761ad3a8-75ab-40c9-b8ad-fb5f775b813a">
        <source>utlUpdateBulkInvLineDescMap(_pxyUpdateInvLineDescMappings : CM_InvLineDescMapByDebtorLType; _passport : CM_Passport input);
/*

Purpose:			Updates Invoice Line Mappings

Parameters:			_pxyUpdateInvLineDescMappings	CM_InvLineDescMapByDebtorLType	A collection of proxy invoice line mappings to update
					_passport						CM_Passport						The passport to use for the transaction

Return Value:		NONE

Date		Who		Reason
10 October 2022	navpw1	Initial creation TFS: 54566

*/

vars
	cancelSave				: Boolean;
	invoiceLineDescMap,
	realInvoiceLineDescMap	: CM_InvoiceLineDescMapping;
	expectedEdition			: Integer;
	
begin
	self.initialiseActivity();
	
	foreach invoiceLineDescMap in _pxyUpdateInvLineDescMappings do
		invoiceLineDescMap.raiseExceptionIfNotProxy(method);
		
	endforeach;
	
	app.setContinueCMExceptions(true);
	
	foreach invoiceLineDescMap in _pxyUpdateInvLineDescMappings do
		invoiceLineDescMap.pxyGetRealObjectAndEdition(realInvoiceLineDescMap, expectedEdition);
		
		if realInvoiceLineDescMap = null then	
			app.raiseCMException1(ProxyMgrCannotLocateReal, CM_InvoiceLineDescMapping.name, null, null);
			return;
		endif;
		
		app.myValUA.valInvoiceLineDescMap(realInvoiceLineDescMap, invoiceLineDescMap);
		
	endforeach;
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	//Lock all our objects in one go in case someone grabs the last one and updates it
	foreach invoiceLineDescMap in _pxyUpdateInvLineDescMappings do
		invoiceLineDescMap.pxyGetRealObjectAndEdition(realInvoiceLineDescMap, expectedEdition);
		exclusiveLock(realInvoiceLineDescMap);
		
	endforeach;
	
	//Loop through our transients and update the real object
	foreach invoiceLineDescMap in _pxyUpdateInvLineDescMappings do
		invoiceLineDescMap.pxyGetRealObjectAndEdition(realInvoiceLineDescMap, expectedEdition);
		
		if _passport.noErrors and realInvoiceLineDescMap.edition &lt;&gt; expectedEdition then
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Invoice Line Desc', null, null);
			return;
		endif;
		
		if _passport.noErrors then
			self.myUpdateAuditAgent.audUpdateGeneric(realInvoiceLineDescMap, true);
		endif;
		
		if _passport.noErrors then
			realInvoiceLineDescMap.setForUpdate(invoiceLineDescMap);
		endif;

		if _passport.noErrors then
			self.myUpdateAuditAgent.audUpdateGeneric(realInvoiceLineDescMap, false);
			_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_MAPPING_UPDATE),false,realInvoiceLineDescMap);
			//_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_TRANSACTIONMAP_UPDATE),false,realInvoiceLineDescMap);
		endif;
	endforeach;
	
end;</source>
        <Parameter name="_pxyUpdateInvLineDescMappings" type="CM_InvLineDescMapByDebtorLType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateBulkRelease" id="9d59b55a-2946-4186-bc6c-e0f41c17ce76">
        <source>utlUpdateBulkRelease(_pxyBulkRelease : CM_BulkRelease; 
						_realBooking :CM_BookingRef input;	// par 29847
						_doEditionCheck : Boolean; 
						_allTIPins : CM_StringDict;  		// cnwrd1 par 25594
						_cmifRelease : CMIF_EDIReleaseRequest;		// TFS 58923
						_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     30 January 2001 by cnwrs2
//
// 20/02/2012	cnwcs5	par 28756 - combine utlUpdateBulkRelease and utlUpdateBulkReleaseNew
// 28/06/2012	cnwcs5	par 29847 - new parameter so we can tell if we are maintaining release 
//									from a booking or not
// 29/07/2031	cnwcs5	CCMS POL 2221 / par 32094
// 20/02/2019	jlgrs1	TFS 43312 - More Deadlocking in Multiuser EDI
// 10/07/2020	jlgmd1	TFS 49690 STWR Remove the extra locking added as part of 43312 as its redundant (and doesn't work)
// 25/07/2023	navdap1	TFS 58923 EUP CallOff EDI Data Type / Data Load
// ---------------------------------------------------------------------------
vars
	realBulkRelease	: CM_BulkRelease;
	expectedEdition	: Integer;
	terminal		: CM_Terminal;
begin
	self.initialiseActivity();

	terminal := _passport.myTerminal;
	
	_pxyBulkRelease.raiseExceptionIfNotProxy(method);
	_pxyBulkRelease.pxyGetRealObjectAndEdition(realBulkRelease, expectedEdition);
	
	if realBulkRelease = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_BulkRelease.name, null, null);
		return;
	endif;

	app.myValUA.valBulkRelease(_pxyBulkRelease, _allTIPins, _passport); //cnwrd1 CCMS POL 2032 par 25594 10.12.2010
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	self.exclusiveLock(realBulkRelease);

	if _passport.noErrors and (_doEditionCheck and realBulkRelease.edition &lt;&gt; expectedEdition) then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'bulk release', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realBulkRelease, true);
	endif;
	
	if _passport.noErrors then
		// par 29847 - _realBooking indicates whether we are maintining release as part of booking or not
		if _realBooking &lt;&gt; null and 
			realBulkRelease.type = BR_TYPE_PACKING  and 
			not realBulkRelease.myTerminal.getConfig(PackingRelAsInternalRel).Boolean then 
			// for bookings with a corresponding PACKING release request (Nelson Warehousing), 
			// there is specific way for changing the PACKING release. PAR 21656 18/02/2010
			_realBooking.updateMultiReleases(null);							
		else
			// cnwrd1 ccms pol 2103 par 27856 14.7.2011 for non nelson packing releases for bookings we are looking at internal releases for POL
			realBulkRelease.setForUpdateFromPxy(_pxyBulkRelease);
		endif;
	endif;
	
	// TFS 58923 EDI Release Request update for CallOff may need to update a vehicle booking time slot
	if _passport.noErrors and _cmifRelease &lt;&gt; null then
		app.myUtilityCA.createUpdateVBSFromEDIBR(_cmifRelease, realBulkRelease, _passport);
	endif;
	// TFS 58923 end

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realBulkRelease, false);
	endif;

	if terminal &lt;&gt; null and realBulkRelease &lt;&gt; null then
		global.causeEvent(terminal.getTerminalEvent(Event_BulkRelease_Update), false, realBulkRelease);
	endif;
end;</source>
        <Parameter name="_pxyBulkRelease" type="CM_BulkRelease"/>
        <Parameter name="_realBooking" type="CM_BookingRef" usage="input"/>
        <Parameter name="_doEditionCheck" type="Boolean"/>
        <Parameter name="_allTIPins" type="CM_StringDict"/>
        <Parameter name="_cmifRelease" type="CMIF_EDIReleaseRequest"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateBulkVehicleBookingAdv" id="71ff2613-60b1-40f3-9b96-0da57c954201">
        <source>utlUpdateBulkVehicleBookingAdv(_pxyUpdateVehicleBookings : CM_VehicleBookingByTs; _passport : CM_Passport input);
/*

Purpose:			Updates Vehicle Bookings

Parameters:			_pxyUpdateVehicleBookings		CM_VehicleBookingByTs			A collection of proxy vehicle bookings to update
					_passport						CM_Passport						The passport to use for the transaction

Return Value:		NONE

Date		Who			Reason
10 October 2022	navcs2	ChangeRequest 53899: EUP - VBS MTN - [3] - Maintaining VBS Slot (Task 55831)
25 Apr 2023 	navhl20 ChangeRequest 57733:[57734] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 02]
*/

vars
	cancelSave					: Boolean;
	vehicleBookingTimeslot,
	realVehicleBookingTimeslot	: CM_VehicleBookingTimeSlot;
	expectedEdition				: Integer;
	
begin
	self.initialiseActivity();
	
	foreach vehicleBookingTimeslot in _pxyUpdateVehicleBookings do
		if not vehicleBookingTimeslot.isTransient then
			return;
		endif;
		
	endforeach;
	
	app.setContinueCMExceptions(true);
	
	foreach vehicleBookingTimeslot in _pxyUpdateVehicleBookings do
		vehicleBookingTimeslot.pxyGetRealObjectAndEdition(realVehicleBookingTimeslot, expectedEdition);
		
		if vehicleBookingTimeslot = null then	
			app.raiseCMException1(ProxyMgrCannotLocateReal, CM_VehicleBookingTimeSlot.name, null, null);
			return;
		endif;		
	endforeach;
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	//Lock all our objects in one go in case someone grabs the last one and updates it
	foreach vehicleBookingTimeslot in _pxyUpdateVehicleBookings do
		vehicleBookingTimeslot.pxyGetRealObjectAndEdition(realVehicleBookingTimeslot, expectedEdition);
		self.exclusiveLock(realVehicleBookingTimeslot);
		
	endforeach;
	
	//Loop through our transients and update the real object
	foreach vehicleBookingTimeslot in _pxyUpdateVehicleBookings do
		vehicleBookingTimeslot.pxyGetRealObjectAndEdition(realVehicleBookingTimeslot, expectedEdition);
		
		if _passport.noErrors and realVehicleBookingTimeslot.edition &lt;&gt; expectedEdition then
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Vehicle Booking Timeslot', null, null);
			return;
		endif;
		
		if _passport.noErrors then
			self.myUpdateAuditAgent.audUpdateGeneric(realVehicleBookingTimeslot, true);
		endif;
		
		if _passport.noErrors then
			realVehicleBookingTimeslot.setForUpdate(vehicleBookingTimeslot);
		endif;

		if _passport.noErrors then
			self.myUpdateAuditAgent.audUpdateGeneric(realVehicleBookingTimeslot, false);
			_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_MAPPING_UPDATE),false,realVehicleBookingTimeslot);
		endif;
		
		//delete vehicleBookingTimeslot;														//24.4.2023 navhl20 #57733[57734]
	endforeach;
	
epilog
	//delete vehicleBookingTimeslot;															//24.4.2023 navhl20 #57733[57734]
end;

</source>
        <Parameter name="_pxyUpdateVehicleBookings" type="CM_VehicleBookingByTs"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateCAMLog" id="2d49f4f7-5431-4a98-ba9c-4443fc5d9ad5">
        <updating/>
        <source>utlUpdateCAMLog(_camProtocol:CM_CamProtocol input; _file: File; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		26 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	realCamGroup:CM_CamGroup;
	expectedEdition:Integer;
	
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	
	if _camProtocol = null then	
	//	app.raiseCMException1(REQUIRED_FIELD, 'CAM Protocol', null, null);
		app.raiseCMException(Input_required_field_camProto, null, null); // cnwdb2	PAR 35364
		return;
	endif;

	app.myValUA.valCAMLog(_file);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(_camProtocol);

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_camProtocol, true);
	endif;
	
	if _passport.noErrors then
		//_camProtocol.setLogFile(_file);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_camProtocol, false);
	endif;

end;</source>
