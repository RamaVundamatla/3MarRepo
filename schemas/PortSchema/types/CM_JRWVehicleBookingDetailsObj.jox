    <JadeMethod name="createVBCargoReceive" id="46d13d10-17ec-46f1-94c9-a453bc14c888">
        <source>createVBCargoReceive( _ti : CM_TrackedItem ):CM_JRWVBCargoReceive;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 August 2014	cnwndl1	Initial creation

*/

vars

	cargoRec : CM_JRWVBCargoReceive;

begin

	if _ti = null then
		return null;
	endif;

	create cargoRec transient;
	cargoRec.populateMe( self, _ti );
	
	return cargoRec;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_JRWVBCargoReceive"/>
    </JadeMethod>
