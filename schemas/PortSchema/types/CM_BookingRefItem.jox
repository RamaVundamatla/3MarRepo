    <JadeMethod name="cargoIF_GetObjectForETRow" id="a52472b6-41e3-48e8-8ebb-f9c36b6c6b14">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_CargoField::getObjectForETRow"/>
        </interfaceImplements>
        <source>cargoIF_GetObjectForETRow(pAttrName : String): CM_Object;

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*
	Created on 22 January 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	if pAttrName = ETRow_Commodity then
		if commodity &lt;&gt; null then
			return app.myRoot.allCommodities[commodity];
		endif;
//	elseif pAttrName = ETRow_BolType then // adm 160310 Par 22937 remove bolType
//		return getBOLType;
	elseif pAttrName = ETRow_CargoType then
		return myCargoType;
	elseif pAttrName = ETRow_CargoTypeDescr then // dh 11/6/2008 added for par 16953
		return myCargoType;						//
	elseif pAttrName = ETRow_ConsigneeCode then
		return myBookingReference.myConsignee;
	elseif pAttrName = ETRow_ConsignorCode then
		return myBookingReference.myConsignor;	
	elseif pAttrName = ETRow_DestinationPort then
		if myBookingReference.destinationPort &lt;&gt; null then
			return app.myRoot.allPorts[myBookingReference.destinationPort];
		endif;
	elseif pAttrName = ETRow_DischargePort then
		if myBookingReference.dischargePort &lt;&gt; null then
			return app.myRoot.allPorts[myBookingReference.dischargePort];
		endif;
	elseif pAttrName = ETRow_MyTranshipToPort then
		if myBookingReference.myTranshipToPort &lt;&gt; null then
			return app.myRoot.allPorts[myBookingReference.myTranshipToPort.code];
		endif;
	elseif pAttrName = ETRow_OperatorCode then
		return myBookingReference.myOperator;
	elseif pAttrName = ETRow_VoyageCode then
		return myBookingReference.myVoyage;		
	elseif pAttrName = ETRow_IsoType then
		return app.myRoot.allISOTypes[isoType];
	elseif pAttrName = ETRow_Carrier then
		return myBookingReference.myCarrier;	
	elseif pAttrName = ETRow_Product then
		return myProduct;	
	elseif pAttrName = ETRow_StatusString then
		return app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT];
	elseif pAttrName = ETRow_MyGeneratorType then				//cnwrd1 par 18222 24.2.09
		return self.myGeneratorType;		
	else
		return null;
	endif;
end;</source>
        <Parameter name="pAttrName" type="String"/>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="cargoIF_GetStringForETRow" id="0dcb5c32-6025-44f5-9e92-8c9d5b0fbb44">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_CargoField::getStringForETRow"/>
        </interfaceImplements>
        <source>cargoIF_GetStringForETRow(pAttrName : String) : String;
	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*
	Created on 18 January 2008 by Debby Hutchison

28/01/2011	cnwdap1		PAR #26769 Show over dimension length/width/height
21 May 2011	cnwcs5		CCMS SCT 2058/par 27460 - add carrier reference
19 Mar 2013	cnwdap1		PAR #31155 CCMS SFW 13231 Imperial Measurements
13 Jun 2013	cnwcs5		par 31670 - break bulk quantities (numOnsiteTIs)
09/08/2013	cnwdap1		PAR #32201 Add Colour
19/10/2016	cnwdap1		TFS 2652 Added "Stops to Add" and "Tasks to Add"
*/

vars
	haz		: CM_Hazard;
	tmpStr  : String;
	iso 	: CM_ISOType;
	op      : CM_Operator;
	book 	: CM_BookingRef;
begin
	if pAttrName = ETRow_AvailabilityGradeCode then
		return null;
//	elseif pAttrName = ETRow_BolType then // adm 160310 Par 22937 remove bolType
//		return bolTypeDescr;
	elseif pAttrName = ETRow_CargoType then
		// AER Par16241 18/07/08 - this was an old version of displaying data , when "ETRow_BolType" was not existing
		// return getCargoBOLDesc;
		return cargoTypeDescr ;
	elseif pAttrName = ETRow_CargoTypeDescr then
		return cargoTypeDescr;
	elseif pAttrName = ETRow_CarriageTempC then
		return getTempString(false).String;
	elseif pAttrName = ETRow_CarriageTempF then
		return getTempString(true).String;
	elseif pAttrName = ETRow_Commodity then
		return commodity;
	elseif pAttrName = ETRow_ConsigneeCode then
		return myBookingReference.consigneeCode;
	elseif pAttrName = ETRow_ConsignorCode then
		return myBookingReference.consignorCode;
	elseif pAttrName = ETRow_FreightForwarderCode then
		return null;
	elseif pAttrName = ETRow_DestinationPort then
		return myBookingReference.destinationPort;
	elseif pAttrName = ETRow_DischargePort then
		return myBookingReference.dischargePort;
	elseif pAttrName = ETRow_MyTranshipToPort then
		if myBookingReference.myTranshipToPort &lt;&gt; null then
			return myBookingReference.myTranshipToPort.code;
		else
			return null;
		endif;
	elseif pAttrName = ETRow_IsoType then
		iso := myISOType;
		if iso &lt;&gt; null then
			return iso.getTableDisplay;
		else
			return null;
		endif;
	elseif pAttrName = ETRow_IsoTypeGroup then	//+ cnwmd1, Par 21794
		return self.isoTypeGroup;
	elseif pAttrName = ETRow_IsoTypeCode then
		iso := myISOType;
		if iso &lt;&gt; null then
			return iso.code.String;
		else
			return null;
		endif;
	elseif pAttrName = ETRow_Commodity then
		return commodity;
	elseif pAttrName = ETRow_CoolingType then
		return null;
	elseif pAttrName = ETRow_Description then
		return description;
	elseif pAttrName = ETRow_ShippingReference then
		return myBookingReference.shippingReference;
	elseif pAttrName = ETRow_CarrierReference then				// par 27460 cnwcs5
		return self.myBookingReference.operatorReferenceNumber;	// par 27460 cnwcs5
	elseif pAttrName = ETRow_OperatorCode then
		op := myBookingReference.myOperator;
		if op &lt;&gt; null then
			return myBookingReference.myOperator.code;
		else 
			return null;
		endif;
	elseif pAttrName = ETRow_VoltageType then
		return null;
	elseif pAttrName = ETRow_Humidity then
		//return getHumidity.String;
		return self.getHumidityAsString();
	elseif pAttrName = ETRow_IdTextBox then
		return null;
	elseif pAttrName = ETRow_Quantity then
		
		return self.getQuantity.asStringJMT;
	elseif pAttrName = ETRow_StatusString then
		return null;
	elseif pAttrName = ETRow_Ventilation then
		return self.getVentilationAsString();	// PAR 17601. July 2008
	   	//return getVentilation.String;
	elseif pAttrName = ETRow_VoyageCode then
		if myBookingReference.myVoyage &lt;&gt; null then
			return myBookingReference.myVoyage.code;
		else
			return null;
		endif;
	elseif pAttrName = ETRow_MyProduct then
		if self.myProduct &lt;&gt; null then 
			return self.myProduct.code;
		endif;
	elseif pAttrName = ETRow_WeightTotal then
		return self.getWeightDisplay(); //epr par 34935 23/9/14
	elseif pAttrName = ETRow_MyHeight then
		//return height.asStringMeasurementJMT();																				// PAR #31155
		return app.convertMeasurementForDisplay(self.getDefaultMeasurementForType(Type_Height).shortName, self.height);			// PAR #31155
	elseif pAttrName = ETRow_MyWeight then
		//return self.productWeight.asStringWeightJMT();					//+cnwml2 PAR21626									// PAR #31155
		return app.convertMeasurementForDisplay(self.getDefaultMeasurementForType(Type_Weight).shortName, self.productWeight);	// PAR #31155
	elseif pAttrName = ETRow_MyLength then
		//return length.asStringMeasurementJMT();																				// PAR #31155
		return app.convertMeasurementForDisplay(self.getDefaultMeasurementForType(Type_Length).shortName, self.length);			// PAR #31155
		
	elseif pAttrName = ETRow_MyHeightString then	//17524	Oct 2008
		return self.heightString.String;
	elseif pAttrName = ETRow_MyWidthString then		//17524	Oct 2008
		return self.widthString.String;
	elseif pAttrName = ETRow_MyLengthString then	//17524	Oct 2008
		return self.lengthString.String;
		
	elseif pAttrName = ETRow_NumItems then
		return self.getAmountDisplay;
	elseif pAttrName = ETRow_MyWidth then
		//return width.asStringMeasurementJMT();																				// PAR #31155
		return app.convertMeasurementForDisplay(self.getDefaultMeasurementForType(Type_Width).shortName, self.width);			// PAR #31155
	elseif pAttrName = ETRow_MyQuantity then
		return productQuantity.String;
	elseif  pAttrName = ETRow_ShippingMarks then
		return shippingMarks;
	elseif pAttrName = ETRow_MyDensity then
		//return density.String;																								// PAR #31155
		return app.convertMeasurementForDisplay(self.getDefaultMeasurementForType(Type_Density).shortName, self.density);		// PAR #31155
	elseif pAttrName = ETRow_NumOnsiteTIs then
		// the heading for this row is "Received" so use getReceivedCount
		//return self.getRecievedCount.asStringJMT;		// par 31670
		return self.getReceivedDisplay;
	elseif pAttrName = ETRow_TiRecieved then
		return self.getAssignedIDs();
	elseif pAttrName = ETRow_MyVolume then
		//return self.productVolume.String;			//+cnwml2 PAR21626															// PAR #31155
		return app.convertMeasurementForDisplay(self.getDefaultMeasurementForType(Type_Volume).shortName, self.productVolume);	// PAR #31155
//	elseif pAttrName = ETRow_MultiItem then	//05 Nov 2012	NDL	Par 29859
//		return myBookingReference.isMultiItemBookingRef.cnEcGetYesNo;
	elseif pAttrName = ETRow_CompanyCode then
		if myBookingReference.myVoyage &lt;&gt; null then
			if myBookingReference.myVoyage.myDischargeCompany &lt;&gt; null then
				return myBookingReference.myVoyage.myDischargeCompany.code;
			endif;
		endif;
	elseif pAttrName = ETRow_AllTIHazards then
		foreach haz in self.allTIHazards do
			if tmpStr &lt;&gt; null then
				tmpStr := tmpStr &amp; '; ';
			endif;
			tmpStr := tmpStr &amp; haz.getTableDisplay(false, true);
		endforeach;
		return tmpStr;
	elseif pAttrName = ETRow_Released then
		return self.getReleasedDisplay();
	elseif pAttrName = ETRow_MaxToRelease then
		if self.myReserveDetail &lt;&gt; null then
			return self.myReserveDetail.maxToRelease.String;
		endif;
	elseif pAttrName = ETRow_IsControlledAtmosphere then	// CCMS 1654 - slw 11/09/2008
		return self.getIsControlledAtmosphere.cnEcGetYesNo;
	elseif pAttrName = ETRow_Oxygen then					// CCMS 1654 - slw 11/09/2008
		return self.getOxygen.asNullOxygen;
	elseif pAttrName = ETRow_CarbonDioxide then				// CCMS 1654 - slw 11/09/2008
		return self.getCarbonDioxide.asNullCarbonDioxide;
	elseif pAttrName = ETRow_CurtainsIn then				// CCMS 1654 - slw 11/09/2008
		if self.getIsControlledAtmosphere() then
			return self.getCurtainsIn.cnEcGetYesNo;
		else
			return null;			
		endif;
	elseif pAttrName = ETRow_MyGeneratorType then				//cnwrd1 par 18222 24.2.09
		if self.myGeneratorType &lt;&gt; null then
			return self.myGeneratorType.description;		
		endif;
	elseif pAttrName = ETRow_Type then
		return self.typeString;
	elseif pAttrName = ETRow_Hazardous then
		return self.getIsHazardous.getYesNo;
	elseif pAttrName = ETRow_TrailerType then
		return self.trailerType;
	elseif pAttrName = ETRow_GeneratorType then
		return self.generatorType;
	elseif pAttrName = ETRow_AllLinkedExpBookingsInfo then				//+cnwml2 PAR22653
		foreach book in self.allLinkedExportBookings do
			if tmpStr = null then
				tmpStr := book.bookingReference;
			else
				tmpStr := tmpStr &amp; ", " &amp; book.bookingReference;
			endif;
		endforeach;
		return tmpStr;
		
	elseif pAttrName = ETRow_Colour then								// PAR #32201
		return self.colour;												// PAR #32201
		
	elseif pAttrName = ETRow_StopsToApply then									// TFS 2652
		if self.myBookingRefItemActions &lt;&gt; null then							// TFS 2652
			return self.myBookingRefItemActions.getStopsList(Space, true);		// TFS 2652
		endif;																	// TFS 2652
		return null;															// TFS 2652
	elseif pAttrName = ETRow_TaskToApply then									// TFS 2652
		if self.myBookingRefItemActions &lt;&gt; null then							// TFS 2652
			return self.myBookingRefItemActions.getTaskList(Space, true);		// TFS 2652
		endif;																	// TFS 2652
		return null;															// TFS 2652
	
	// PAR #26769 start
	elseif pAttrName = ETRow_OverLengthFront then
		//return self.length.asStringMeasurementJMT();																			// PAR #31155
		return app.convertMeasurementForDisplay(self.getDefaultMeasurementForType(Type_Length).shortName, self.length);			// PAR #31155
	elseif pAttrName = ETRow_OverWidthLeft then
		//return self.width.asStringMeasurementJMT();																			// PAR #31155
		return app.convertMeasurementForDisplay(self.getDefaultMeasurementForType(Type_Width).shortName, self.width);			// PAR #31155
	elseif pAttrName = ETRow_OverHeight then
		//return self.height.asStringMeasurementJMT();																			// PAR #31155
		return app.convertMeasurementForDisplay(self.getDefaultMeasurementForType(Type_Height).shortName, self.height);			// PAR #31155
	// PAR #26769 end
	
	endif;

	
	return null;
end;</source>
        <Parameter name="pAttrName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cargoIsProspect" id="53cbb96d-3e0a-46c8-b9bc-3a88c3b05fd6">
        <source>cargoIsProspect( _ti : CM_TrackedItem ) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 September 2016	cnwndl1	Initial creation	TFS 2649 / 2001

*/

vars
	
	cont : CM_Container;
	isoGroup : CM_ISOTypeGroup;

begin
	if _ti = null then
		return false;
	endif;
	
	if _ti.isContainer then
		cont := _ti.CM_Container;
	endif;

	if _ti.cargoTypeDescr &lt;&gt; self.cargoTypeDescr then
		return false;
	endif;
	
	if not _ti.myVoyage.isNullVoyage and _ti.myVoyage &lt;&gt; self.myBookingReference.myVoyage then
		return false;
	endif;
	
	if  _ti.myOperator &lt;&gt; self.myBookingReference.myOperator then
		return false;
	endif;
	
	if self.commodity &lt;&gt; null and _ti.commodity &lt;&gt; self.commodity then
		return false;
	endif;
	
	if self.consigneeCode &lt;&gt; null and _ti.consignee &lt;&gt; self.consigneeCode then
		return false;
	endif;
	
	if self.consignorCode &lt;&gt; null and _ti.consignor &lt;&gt; self.consignorCode then
		return false;
	endif;
	
	if self.isoType &lt;&gt; null and _ti.getISOType &lt;&gt; self.isoType then
		return false;
	endif;
	
	if self.isoTypeGroup &lt;&gt; null then
		isoGroup := _ti.getISOTypeGroup();
		if isoGroup = null or isoGroup.code &lt;&gt; self.isoTypeGroup then
			return false;
		endif;
	endif;
	
	if self.markNumber &lt;&gt; null and _ti.markNumber &lt;&gt; self.markNumber then
		return false;
	endif;
	
	if self.clean then
		if cont = null or not cont.isClean then
			return false;
		endif;
	endif;
	
	if self.colour &lt;&gt; null and _ti.getColour &lt;&gt; self.colour then
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cargoType" id="7de77019-03da-4d4f-ba07-39888a20c5b6">
        <methodInvocation>mapping</methodInvocation>
        <source>cargoType(_set : Boolean; _value : Integer io) mapping;
// ---------------------------------------------------------------------------
// Created:     04 March 2010 by cnwcs5
// Purpose:     par 22762
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	type :CM_CargoType;
begin
	if not _set or
		self.isTransient or
		self.cargoType = _value then
		return;
	endif;
	
	type := app.myRoot.allCargoTypesById[_value];
	
	if type &lt;&gt; null then
		type.updateForNonInversedReference;
	endif;
epilog

end;</source>
        <Parameter name="_set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="cargoTypeDescr" id="1d3adb4a-b2ea-4cf2-8e18-592bde0b7982">
        <methodInvocation>mapping</methodInvocation>
        <source>cargoTypeDescr(set : Boolean; _value : String io) mapping;
/*
	Created on 11 January 2008
	
	by Debby Hutchison
	
	Purpose: Copied from CM_BookingRef for CCMS 1618
*/
vars
	tmpCargoType : CM_CargoType;

begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	tmpCargoType := app.myRoot.allCargoTypesById[self.cargoType];
	if tmpCargoType &lt;&gt; null then
		_value := tmpCargoType.description;
	else
		_value := null;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="cloneForRoll" id="aabcac18-1e57-43e3-b39c-32ca7dcd2768">
        <source>cloneForRoll() :SelfType;

vars
	bookingRefItem	: CM_BookingRefItem;
	cargoType : Integer;
	
begin
	//bookingRefItem	:= self.copySelf(false);
	cargoType := self.cargoType;
	bookingRefItem	:= self.copySelf(true); //creat pxy for create later for audit cnwrd1 12.2.09 par #17936
	bookingRefItem.cargoType := cargoType;
	bookingRefItem.myProduct		:=	self.myProduct;
	bookingRefItem.mySpecialStow := self.mySpecialStow;
	self.allSpecialLifts.copy(bookingRefItem.allSpecialLifts);
	self.allTIHazards.copy(bookingRefItem.allTIHazards);
	
	return bookingRefItem;
end;
</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
