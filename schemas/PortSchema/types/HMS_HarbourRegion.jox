    <JadeMethod name="pxyCreateUpdateProxy" id="427d60a4-3c07-41ed-bcc8-d9d44fe787b0">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------------------
//Created: 11 July 2003 By: cnwgd1
//--------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxy : HMS_HarbourRegion;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	proxy.myRoot 	:= self.myRoot;
	proxy.myHarbour := self.myHarbour;
	proxy.myTerminal := self.myTerminal;
	proxy.myPreferredBerth := self.myPreferredBerth;
	
	self.allCheckpoints.copy(proxy.allCheckpoints);
	self.allBerthsInRegion.copy(proxy.allBerthsInRegion);
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setCheckpointForUpdate" id="e6ee632b-0ea1-4b06-9de0-e028e836fde2">
        <updating/>
        <source>setCheckpointForUpdate(_checkpoint : HMS_CheckPoint; _checkpointType : Integer) updating;
/*
IMPORTANT:	SHOULD ONLY BE CALLED BY OLD UPGRADE SCRIPTS

DO NOT USE
*/
/* Changes

Date		Name	TFS#		Description
============================================================================
22/07/2019	jlgka1 	TFS 45620	JMT - Refactor remove remaining  Voyage Commodity  Planning
============================================================================*/
vars
	checkpoint		: HMS_CheckPoint;
	
begin
	self.raiseExceptionIfTransient(method);
	
	checkpoint := _checkpoint;
	
	if checkpoint &lt;&gt; null then
		checkpoint.setNullRegion();
	endif;
	
	if _checkpointType = HMS_ChkPointType_Current then
		self.myCurrentCheckpoint := checkpoint;
	
	elseif _checkpointType = HMS_ChkPointType_Draft then
		self.myHeightCheckpoint := checkpoint;
	
	elseif _checkpointType = HMS_ChkPointType_HiLo then
		self.myHiLoCheckpoint := checkpoint;
	
	elseif _checkpointType = HMS_ChkPointType_TimeGap then
		self.myTimeGapCheckpoint := checkpoint;
	//jlgka1 TFS 45620 --&gt;
	/*elseif _checkpointType = HMS_ChkPointType_TideRange then
		self.myTideRangeCheckPoint	:=	checkpoint;*/
	//jlgka1 TFS 45620 &lt;--	
	endif;

end;</source>
        <Parameter name="_checkpoint" type="HMS_CheckPoint"/>
        <Parameter name="_checkpointType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="e65cc83c-4edf-4964-9e81-7cb9e6f36b00">
        <updating/>
        <source>setForUpdate(_pxyRegion : HMS_HarbourRegion; _passport : CM_Passport input)updating;
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
//--------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	------------------------------------
// 13/03/2012	cnwdap1		CCMS RIO 2132 PAR #29265 New attributes for Berthing Priority
vars
	checkpoint			: HMS_CheckPoint;
begin
	inheritMethod(_pxyRegion, _passport);
	
	self.code 				:= _pxyRegion.code.toUpper.trimBlanks;
	self.description 		:= _pxyRegion.description;
	self.canWaitHere 		:= _pxyRegion.canWaitHere;
	
	self.isHighPriority			:= _pxyRegion.isHighPriority;		// PAR #29265
	self.isPriorityStartPoint	:= _pxyRegion.isPriorityStartPoint;	// PAR #29265

	self.allBerthsInRegion.clear();

	// After setting code but BEFORE we update references check
	// if need to create/delete preferredBerth for non-harbour regions
	if (self.myHarbour &lt;&gt; null and _pxyRegion.myHarbour = null) or
	   (_pxyRegion.myHarbour = null and 
	   (self.myPreferredBerth = null or (not self.myPreferredBerth.isKindOf(HMS_BerthNonHarbour))))
	   then
		// need to create
		create self.myPreferredBerth as HMS_BerthNonHarbour persistent;
		self.myPreferredBerth.HMS_BerthNonHarbour.setBerthNonHarbour(self);
		self.allBerthsInRegion.add(self.myPreferredBerth);

	elseif self.myHarbour = null and _pxyRegion.myHarbour &lt;&gt; null then
		// berth is now linked to a harbour so check if old preferred berth
		// exists and is a non-harbour berth - if so then delete
		if self.myPreferredBerth &lt;&gt; null and
		   self.myPreferredBerth.isKindOf(HMS_BerthNonHarbour) then
			delete myPreferredBerth;
		endif;
	else
		_pxyRegion.allBerthsInRegion.copy(self.allBerthsInRegion);
		self.myPreferredBerth	:= _pxyRegion.myPreferredBerth;
	endif;

	self.allCheckpoints.clear();
	foreach checkpoint in _pxyRegion.allCheckpoints do
		checkpoint.setNullRegion();
		self.allCheckpoints.add(checkpoint);
	endforeach;
	
	self.myHarbour 			:= _pxyRegion.myHarbour;
	self.myTerminal			:= _pxyRegion.myTerminal;
	self.myRoot				:= _pxyRegion.myRoot;
end;</source>
        <Parameter name="_pxyRegion" type="HMS_HarbourRegion"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="78b7ef7d-aaed-43e2-914b-37dde11d1e91">
        <updating/>
        <source>setProxy(_root : CM_Root; 
		_harbour : HMS_Harbour; 
		_terminal : CM_Terminal; 
		_preferredBerth : HMS_Berth;
		_allCheckPoints : HMS_CheckPointByTypeDict) updating;
		
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);
	self.myRoot 			:= _root;
	self.myHarbour 			:= _harbour;
	self.myTerminal 		:= _terminal;
	self.myPreferredBerth 	:= _preferredBerth;
	
	// replaced by collection 
	//epr par 16884
	self.allCheckpoints.clear();
	_allCheckPoints.copy(self.allCheckpoints);
	

end;</source>
        <Parameter name="_root" type="CM_Root"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_preferredBerth" type="HMS_Berth"/>
        <Parameter name="_allCheckPoints" type="HMS_CheckPointByTypeDict"/>
    </JadeMethod>
    <JadeMethod name="validateCheckpointForUpdate" id="dc2da01c-8a60-4000-89f7-25239f014ca8">
        <source>validateCheckpointForUpdate(_checkpoint : HMS_CheckPoint);
/*
----------   ----------  --------------------------------------------------
Created:	17 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	realSelf		: SelfType;
	
begin
	if _checkpoint = null then
		return;
	endif;
	
	realSelf := self.pxyGetRealObject();
	
	if _checkpoint.myRegion &lt;&gt; null and _checkpoint.myRegion &lt;&gt; realSelf then

		app.raiseCMWarning2(	Check_curre_assoc_with_anoth_r,
									ETRow_CheckpointCurrent,
									_checkpoint.description, _checkpoint.myRegion.description,
									null,realSelf);
	endif;

end;


</source>
        <Parameter name="_checkpoint" type="HMS_CheckPoint"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="9a58af53-d235-459e-bed5-26913ec0a350">
        <source>validateForDelete(_passport: CM_Passport input);
//--------------------------------------------------
// Created:	29 September 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpRoute	: HMS_RouteTemplate;
	whereUsed : String;

begin
	if app.myRoot.getSeaHarbourRegion() = self then
		app.raiseCMException2(HarbourRegionSea_CannotRemove, app.getErrorString(Region) &amp; ' ' &amp; self.getDisplayString(), "Sea Harbour Region", null, null);
		return;
	endif;
	
	if self.allPathSegments.size &gt; 0 then
		app.raiseCMException2(ObjectStillHasEntries, app.getErrorString(Region) &amp; ' ' &amp; self.getDisplayString(), "Path Segment", null, null);
		return;
	endif;

	if self.allMovementPaths.size &gt; 0 then
		app.raiseCMException2(ObjectStillHasEntries, app.getErrorString(Region) &amp; ' ' &amp; self.getDisplayString(), "Movement Path", null, null);
		return;
	endif;
	
	foreach tmpRoute in app.myRoot.allRouteTemplates do
		if tmpRoute.allHarbourRegions.includes(self) then
			app.raiseCMException2(ObjectStillHasEntries, app.getErrorString(Region) &amp; ' ' &amp; self.getDisplayString(), app.getErrorString(Route), null, null);
			return;
		endif;
	endforeach;
	
	//10 Nov 2020	NDL	TFS 50279
	if self.isUsedinConfig( whereUsed ) then
		app.raiseCMException2(ERR_CANNOT_DELETE, self.code, whereUsed, null, self);
	endif;
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="b1d43442-3e9b-4c35-8a54-58face80351e">
        <source>validateMe(_passport: CM_Passport input);
//--------------------------------------------------------------
//Created: 04 July 2003 By: cnwgd1
//14/06/2022    navds20     TFS 53760 DuplicateItem not Translatable
//--------------------------------------------------------------
vars
	terminalObj			: CM_Terminal;
	regionObj			: HMS_HarbourRegion;
	berthObj			: HMS_Berth;
	realObj				: SelfType;
	checkpoint			: HMS_CheckPoint;
	
begin
	inheritMethod(_passport);
	
	if self.code = null then
		app.raiseCMException(Input_required_field_code, ETRow_Code, null); // cnwdb2	PAR 35364
	endif;
	if self.description = null then
		app.raiseCMException(Input_required_field_desc, ETRow_Description,  null); // cnwdb2	PAR 35364
	endif;
	
	if self.myRoot = null then
		app.raiseCMException(Input_required_field_harbRoot, null,  null); // cnwdb2	PAR 35364
	endif;	
		
	if _passport.hasErrors then
		return;
	endif;
	
	if self.myHarbour &lt;&gt; null
	and self.myTerminal &lt;&gt; null
	and not self.myHarbour.allTerminalsByCode.includes(self.myTerminal)
	then

		app.raiseCMException2(	Terminal_selected_harbour,
								self.myTerminal.code, self.myHarbour.code,
								null,
								null);
	endif;
	
	terminalObj	:=	self.myTerminal;
	
	if terminalObj &lt;&gt; null then
		// PAR 16411 - ensure that the berths relate to the wharf that this terminal is assigned to
		foreach berthObj in self.allBerthsInRegion do
			if (not berthObj.myWharf.allTerminals.includes(terminalObj)) then
				//app.raiseCMException1(Full_Replacement_Message, 'Berth (' &amp; berthObj.code &amp; ') is not on a wharf that is for this terminal', null, null); //- cnwmd1, Par 20524
				app.raiseCMException1(Berth_wharf_that_this_termin, berthObj.code, null, null);
			endif;
		endforeach;
	endif;
	
	regionObj	:=	self.myRoot.allHMSHarbourRegions.getAtKey(self.code.toUpper);
	
	if regionObj &lt;&gt; null then
		if self.isTransient and regionObj &lt;&gt; self.pxyGetRealObject() then
			//app.raiseCMException2(DuplicateItem, 'Waypoint', self.code, ETRow_Code, null); //14.06.2022 navds20 53760
			// Waypoint already exists for %1 : Waypoint_already_exists
			app.raiseCMException1(Waypoint_already_exists, self.code, ETRow_Code, null); //14.06.2022 navds20 53760
		endif;
	endif;
	
	if self.myHarbour &lt;&gt; null and self.myPreferredBerth &lt;&gt; null then
		if (not self.myHarbour.allBerths.includes(self.myPreferredBerth)) then
			app.raiseCMException2(Preferred_berth_harbour, self.myPreferredBerth.code, self.myHarbour.code, null, null);
		endif;
	endif;

	foreach checkpoint in self.allCheckpoints do
		self.validateCheckpointForUpdate(checkpoint);
	endforeach;
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
