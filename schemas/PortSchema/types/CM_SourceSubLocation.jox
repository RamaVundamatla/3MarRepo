    <JadeMethod name="isCertified" id="22e9ec72-0511-4b6c-8acd-535a9bd639b3">
        <source>isCertified() : Boolean;
/* ---------------------------------------------------------------------------
Created:	05 November 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin
	
	if self.isFSC then
		return true;
	endif;

	return false;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="e44199fa-5418-4c3e-bce0-fe42fcc70baf">
        <updating/>
        <source>setForCreate(pProxy: CM_SourceSubLocation) updating;
//--------------------------------------------------------------
//Created: 07 February 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod(pProxy);
	self.mySourceLocation := pProxy.mySourceLocation;

end;</source>
        <Parameter name="pProxy" type="CM_SourceSubLocation"/>
    </JadeMethod>
    <JadeMethod name="setForProxy" id="9ac5e135-589f-4001-b9aa-64474755647c">
        <updating/>
        <source>setForProxy(pCode, pDescription : String; _isFSC : Boolean; _notAvailableForEntry:Boolean; pSourceLocn: CM_SourceLocation) updating;
//--------------------------------------------------------------
//Created: 07 February 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	self.raiseExceptionIfNotTransient(method);
	self.mySourceLocation := pSourceLocn;
	self.setSuperClassDetailsForProxy(pCode, pDescription,_notAvailableForEntry, null);
	
	self.isFSC := _isFSC;	//ccms jml 1105, par 21535 Nov 2009
	
end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pDescription" type="String"/>
        <Parameter name="_isFSC" type="Boolean"/>
        <Parameter name="_notAvailableForEntry" type="Boolean"/>
        <Parameter name="pSourceLocn" type="CM_SourceLocation"/>
    </JadeMethod>
