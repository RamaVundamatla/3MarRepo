*/
end;</source>
    </JadeMethod>
    <JadeMethod name="initialise" id="29076acc-b03c-49d9-9ee3-93e722210765">
        <updating/>
        <source>initialise(_name: String; _code: String; _parentCompany: CM_Bank; _terminal : CM_Terminal) updating;
/*

Date		Who		Reason
24 Aug 2012	cnwkpd1	PAR #30262 - Fix leaked persistent HugeStringArray
03 Sep 2019	jlgsl4	TFS 45872 - JMT - Cash Credit UI changes
*/

vars
	tranMap:  CM_SystemTranMap;
	ks:       CM_KeySeries;
	sk:       CM_SeriesKey;
	isRoot:   Boolean;
	isBU:     Boolean;
	ksTerm : CM_Terminal;
begin

	isRoot := (_parentCompany = null);
	isBU := (not isRoot) and (not _parentCompany.isRootCompany);

	self.mailingName 	:= _name;
	self.code 			:= _code;
	self.terminal 		:= _terminal;
	self.parentCompany 	:= _parentCompany;
	self.addInvoiceTax  := not isRoot; // PAR 9042
	if isRoot then
		ksTerm := _terminal;
	endif;
	
	if self.allBankDetails = null then			// PAR #30262
		if self.isTransient() then
			create self.allBankDetails transient;
		else
			create self.allBankDetails;
		endif;
	else
		self.allBankDetails.clear();
	endif;
	
	// ### Key Series now for each bank object
		if not global.isValidObject(self.keySeries) then
			create self.keySeries;
		endif;

		if self.keySeries[SN_CHARGE] = null then
			create ks;
			ks.set(SN_CHARGE, "Charge Sequence Number ", ksTerm); // _terminal
			create sk;
			ks.nextKey := sk;
			sk.setForUpdate(null, "CTL", 1, null, null);
			self.keySeries.add(ks);
		endif;

		if self.keySeries[SN_INVOICE] = null then
			create ks;
			ks.set(SN_INVOICE, "Invoice Sequence Number " , ksTerm); // _terminal
			create sk;
			ks.nextKey := sk;
			sk.setForUpdate(null, "CTL", 1, null, null);
			self.keySeries.add(ks);
		endif;
		if self.keySeries[SN_INVOICELINE] = null then
			create ks;
			ks.set(SN_INVOICELINE, "Line Sequence Number ", ksTerm); // _terminal
			create sk;
			ks.nextKey := sk;
			sk.setForUpdate(null, "CTL", 1, null, null);
			self.keySeries.add(ks);
		endif;

		if keySeries[SN_INVOICETYPE] = null then
			create ks;
			ks.set(SN_INVOICETYPE, "Invoice Type Sequence Number " , ksTerm); //_terminal
			create sk;
			ks.nextKey := sk;
			sk.setForUpdate(null, "CTL", 1, null, null);
			self.keySeries.add(ks);
		endif;
		// NOTE AUDITS are actually always from the root bank and so are unique across the system
		if keySeries[SN_AUDIT] = null then
			create ks;
			ks.set(SN_AUDIT, "Audit Sequence Number " , ksTerm); //_terminal
			create sk;
			ks.nextKey := sk;
			sk.setForUpdate(null, "CTL", 1, null, null);
			self.keySeries.add(ks);
		endif;
	
		if keySeries[SN_CashCredit] = null then // --&gt; TFS 45872 - cash credit sequence number
			create ks;
			ks.set(SN_CashCredit, "Cash Credit External Id" , ksTerm);
			create sk;
			ks.nextKey := sk;
			sk.setForUpdate(null, "CTL", 1, null, null);
			self.keySeries.add(ks);
		endif; // &lt;-- TFS 45872
	
	if isRoot then
		if self.myRootIfRootCompany = null then
			self.myRootIfRootCompany := app.myRoot;
		endif;

		rootDebtorGroup := self.getRootDebtorGroup();
		if not global.isValidObject(self.rootDebtor) then
			create self.rootDebtor;
			self.rootDebtor.bank := self;
			self.rootDebtor.name := "RDT";
			self.rootDebtor.remarks := "Root Debtor for the Company. The Root Debtor was created and is owned by the Company.";
			self.rootDebtor.group := rootDebtorGroup;
			self.rootDebtor.initialise;
		endif;		/*
		// create the root Debtor Object
		if not global.isValidObject(self.rootDebtorGroup) then
			create self.rootDebtorGroup;
			self.rootDebtorGroup.bank := self;
			self.rootDebtorGroup.name := "RDG";
			self.rootDebtorGroup.remarks := "Root Debtor Group for the Company." &amp; CrLf &amp; CrLf &amp; "The Root Debtor Group was created and is owned by the Company.";
			self.rootDebtorGroup.group := null;
		endif;
		*/
		
		self.getRootGLCode();


	elseif isBU then
		self.getRootGLCode();

		self.getRootServiceGroup();

		if not global.isValidObject(self.voidService) then
			create self.voidService;
			self.voidService.bank := self;
			self.voidService.name := "Void Service";
			self.voidService.remarks := "Void Service for the Business Unit. The Void Service was created and is owned by the Company. It should be applied to services which are not charged.";
			self.voidService.group := self.rootServiceGroup;
			self.voidService.genLCode := self.rootGLCode;
		endif;

		self.rootDebtorGroup := app.myRoot.myRootCompany.rootDebtorGroup;
		self.rootDebtor := app.myRoot.myRootCompany.rootDebtor;
		self.rootDebtorGroup.addDefaultRateForService(voidService, self);

		// root company has keySeries global key series: make a copy here.
//		self.keySeries := _parentCompany.parentCompany.keySeries;

		if not global.isValidObject(self.voidInvoiceLineDesc) then
			create self.voidInvoiceLineDesc;
			self.voidInvoiceLineDesc.bank := self;
			self.voidInvoiceLineDesc.narration := "VOID";
			self.voidInvoiceLineDesc.services.add(voidService);
			self.voidInvoiceLineDesc.isVoid := true;
			//self.voidInvoiceLineDesc.remarks := "Void InvoiceLine Item.";
		endif;

		if self.currentTransactionMap = null then
			create tranMap;
			tranMap.name := "Default";
			tranMap.description := "Default Transaction Map of the Business Unit";
			tranMap.initialise(self);
			self.currentTransactionMap := tranMap;
		endif;

	endif;

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_parentCompany" type="CM_Bank"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="isBusinessUnit" id="e581f75b-cf6b-4aca-b0f2-3a96e800f81a">
        <methodInvocation>mapping</methodInvocation>
        <source>isBusinessUnit(set: Boolean; value: Boolean io) mapping;

vars

begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		if (not self.isRootCompany) then
			if (not self.parentCompany.isRootCompany) then
				value := self.parentCompany.parentCompany.isRootCompany;
			endif;
		endif;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="isInUse" id="70a19da4-55eb-46ba-8eb2-ccb9a755e204">
        <source>isInUse(_message : String output) : Boolean;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aStr : String;
begin
	if self.alertService &lt;&gt; null then
		aStr := aStr &amp; "Alert Service, ";
	endif;
	if not self.allCharges.isEmpty then
		aStr := aStr &amp; "Charges, ";
	endif;
	if not self.allFinancialPeriods.isEmpty then
		aStr := aStr &amp; "Financial Periods, ";
	endif;
	if not self.allInvoiceLineDescDebtors.isEmpty then
		aStr := aStr &amp; " Invoice Line Consolidations, ";
	endif;
	if not self.allInvoiceLineDescMappings.isEmpty then
		aStr := aStr &amp; " Invoice Line Mappings, ";
	endif;
	if not self.allInvoiceTermsOfTrade.isEmpty then
		aStr := aStr &amp; " Terms Of Trade, ";
	endif;
	if not self.debtorNodes.isEmpty then
		aStr := aStr &amp; " Debtors, ";
	endif;
	if not self.invLineDescGroups.isEmpty then
		aStr := aStr &amp; " Invoice Line Groups, ";
	endif;
	if not self.invoiceLineDescriptors.isEmpty then
		if self.invoiceLineDescriptors.size = 1
		and self.invoiceLineDescriptors.first.isVoid then // if the only inv line is the void then OK to delete
		else
			aStr := aStr &amp; " Invoice Line Types, ";
		endif;
	endif;
	if not self.invoiceTypes.isEmpty then
		aStr := aStr &amp; " Invoice Types, ";
	endif;
	if not self.invoiceLines.isEmpty then
		aStr := aStr &amp; " Invoice Lines, ";
	endif;
	if not self.invoicesByDebtor.isEmpty then
		aStr := aStr &amp; " Invoices, ";
	endif;
	if not self.serviceObjects.isEmpty then
		if self.serviceObjects.size &gt; 2 then
			aStr := aStr &amp; " Services, ";
		endif;
	endif;
	if not self.subCompanies.isEmpty then
		aStr := aStr &amp; " Business Units, ";
	endif;
	if not self.myCurrentTranMapCargo.isEmpty then
		if self.myCurrentTranMapCargo.size = 1
		and self.myCurrentTranMapCargo.first.isKindOf(CM_SystemTranMap) then // if the only tran map is the system one then OK to delete
		else
			aStr := aStr &amp; " Transaction Maps, ";
		endif;
	endif;
	
	//30 May 2017	NDL	TFS 4583
	if self.terminal &lt;&gt; null then
		if terminal.getConfig(DefCompany).CM_Bank = self then
			aStr := aStr &amp; " Terminal Config Default Company, ";
		endif;
	endif;
	
	_message := aStr;
	
	return (aStr &lt;&gt; null);
end;</source>
        <Parameter name="_message" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isRootCompany" id="b54256e6-1a99-4971-9da5-b699e35f2d6f">
        <methodInvocation>mapping</methodInvocation>
        <source>isRootCompany(set: Boolean; value: Boolean io) mapping;

vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		value := (self.parentCompany = null);
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="isUsingDefaultProcessJMT" id="8017bf38-fac8-4ce7-9e54-c39b15b9861d">
        <source>isUsingDefaultProcessJMT():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 July 2018	jlgndl1	Initial creation	TFS 39882

*/

vars

	voyProcess : CM_VoyageProcess;
	
begin

	voyProcess := self.terminal.getDefaultVoyageProcess();
	
	if voyProcess = null then
		return true;
	endif;
	
	return voyProcess.isDefaultProcessJMT();
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
