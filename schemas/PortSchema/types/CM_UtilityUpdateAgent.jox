    <JadeMethod name="utlUpdateBay" id="e89d1215-6e78-4bb8-aa8c-a15f312cf386">
        <source>utlUpdateBay(_skipEditionCheck : Boolean; _proxyBay:CM_Bay; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 June 2002 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	realBay:CM_Bay;
	expectedEdition:Integer;
	
begin

	self.initialiseActivity();
	_proxyBay.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	
	_proxyBay.pxyGetRealObjectAndEdition(realBay, expectedEdition);
	
	if realBay = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Bay.name, null, null);
		return;
	endif;

	app.myValUA.valBay(realBay, _proxyBay);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	//epr par 37218 7/1/16
	if not _skipEditionCheck then  //cnwas3 par 21579 added condition check
		if _passport.noErrors and realBay.edition &lt;&gt; expectedEdition then
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, app.getErrorString(Bay)&amp;' (' &amp; realBay.id &amp; ")", null, null); //cnwas3 par 21579 added translatable string
			return;
		endif;
	endif;
	
	
	if _passport.noErrors then
		realBay.setForUpdate(_proxyBay, _passport);
	endif;



end;</source>
        <Parameter name="_skipEditionCheck" type="Boolean"/>
        <Parameter name="_proxyBay" type="CM_Bay"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateBayRemarks" id="52d69c70-1cef-47d4-9426-91ec1a3a74af">
        <source>utlUpdateBayRemarks(_bay :CM_BayVoyage input; _theRemarks : String; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		18 July 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	expectedEdition		: Integer;
	
begin

	self.initialiseActivity();
	
	if _bay = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, _bay.id, null, null);
		return;
	endif;

	exclusiveLock(_bay);

	if (not _passport.noErrors) then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Bay Voyage', null, null);
		return;
	endif;
	
	if _bay.remarks &lt;&gt; _theRemarks then
		app.myAA.auditUpdate(_bay, "remarks", _theRemarks);
		_bay.setRemarks(_theRemarks,false);
		_bay.myCellularVoyageStructure.myVoyage.causeEvent(_passport.myTerminal.getTerminalEvent(BayRemarks_Event), true,_bay);
	endif;



end;</source>
        <Parameter name="_bay" type="CM_BayVoyage" usage="input"/>
        <Parameter name="_theRemarks" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateBayVoyageUnplan" id="800732ef-b7de-4286-80ee-b3a0c9562739">
        <updating/>
        <source>utlUpdateBayVoyageUnplan(_theMoveMode : Integer;_realBayVoyage : CM_BayVoyage input;_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	self.initialiseActivity();
	if _passport.hasErrors then
		return;
	endif;
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_realBayVoyage, true);
	endif;
	
	_realBayVoyage.unplanAll(_theMoveMode);

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_realBayVoyage, false);
	endif;

epilog

end;</source>
        <Parameter name="_theMoveMode" type="Integer"/>
        <Parameter name="_realBayVoyage" type="CM_BayVoyage" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateBestPickPriority" id="cd9a5aec-6ff9-4f9f-ba89-d14d5d327046">
        <source>utlUpdateBestPickPriority(_pxyBestPickCriteria : CM_BestPickPriority input;
							_allTransientCriteriaObj : CMIF_Array; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2025	jlier1	Initial creation 35632

*/

vars
	realBestPickCriteria :CM_BestPickPriority;
	expectedEdition : Integer;
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	_pxyBestPickCriteria.raiseExceptionIfNotProxy(method);
	_pxyBestPickCriteria.pxyGetRealObjectAndEdition(realBestPickCriteria, expectedEdition);
	
	if realBestPickCriteria = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_BestPickPriority.name, null, null);
		return;
	endif;

	app.setContinueCMExceptions(true);
	
	app.myValUA.valBestPickPriority(_pxyBestPickCriteria, _passport);
		
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);
		
	exclusiveLock(realBestPickCriteria);

	if _passport.noErrors and realBestPickCriteria.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, CM_BestPickPriority.name, null, null);
		return;
	endif;
	
	self.myUpdateAuditAgent.audUpdateGeneric(realBestPickCriteria, true);
	
	realBestPickCriteria.setForUpdate(_pxyBestPickCriteria,_passport);
	
	if _passport.noErrors()  then
		realBestPickCriteria.persistCriteria(_allTransientCriteriaObj, _passport);
	endif;
	
	if _passport.noErrors()  then
		self.myUpdateAuditAgent.audUpdateGeneric(realBestPickCriteria, false);
	endif;

epilog

end;</source>
        <Parameter name="_pxyBestPickCriteria" type="CM_BestPickPriority" usage="input"/>
        <Parameter name="_allTransientCriteriaObj" type="CMIF_Array"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateBlockstackFull" id="1ccbd967-6660-4ee1-9836-e3ea7d497f3f">
        <updating/>
        <source>utlUpdateBlockstackFull(_blockStack : CM_BlockStack input; _isFull : Boolean; _passport : CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	20 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(false);

	self.exclusiveLock(_blockStack);

	_blockStack.setIsFull(_isFull);

end;</source>
        <Parameter name="_blockStack" type="CM_BlockStack" usage="input"/>
        <Parameter name="_isFull" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateBolDateTime" id="c3ae60dd-7b69-4843-ab55-a3ef72f2fcaa">
