    <JadeMethod name="purgeEdiHeadrReferenceDups" id="e7cac5ea-acf1-49ea-85d4-6601389f194a">
        <source>purgeEdiHeadrReferenceDups();

/*

Purpose:		To remove the duplicate header reference key value pair items	

Parameters:			

Return Value:		


Date		Who		Reason
09 February 2024	navsp1	Initial creation TFS 61071

*/

vars
	ediFile 	: CM_EDIFile;
	terminal 	: CM_Terminal;
	ediConfig 	: CM_EDIConfig;
	iter, iter1		: Iterator;
	ediFileItem : CM_EDIFile;
	dic			: CM_NameValuePairDict;
	valuePair,
	valuePairnew,
	valuePairEx   : CM_NameValuePair;
	array		: StringArray;
	found		: Boolean;
begin
	
	foreach terminal in app.myRoot.allTerminals do
		ediConfig 	:= terminal.myEdiConfig;
		iter 		:= ediConfig.allEDIFilesByEdiClientRef.createIterator();
		while iter.next(ediFileItem) do
			if ediFileItem.allHeaderReferences.size &gt; 0 then
				create dic transient;
				foreach valuePair in ediFileItem.allHeaderReferences do
					iter1 := dic.createIterator;
					found := false;
					while iter1.next(valuePairEx) do
						if valuePairEx.name = valuePair.name and valuePairEx.value = valuePair.value then						
							found := true;
							write  terminal.code&amp;"---"&amp;ediFileItem.ediClientRef&amp;"--"&amp;valuePair.name &amp;"---"&amp;valuePair.value;
							beginTransaction;
								//ediFileItem.allHeaderReferences.remove(valuePair);//enable this while running
							commitTransaction;
						
						endif;
					endwhile;
					if not found then
						create valuePairnew transient;
						valuePairnew.createNewPair(valuePair.name, valuePair.value);
						dic.add(valuePairnew);
					endif;
				endforeach;
			endif;
		endwhile;
	endforeach;
epilog
	delete iter;
	delete iter1;
end;</source>
    </JadeMethod>
