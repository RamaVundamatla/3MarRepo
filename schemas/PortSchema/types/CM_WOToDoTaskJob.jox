    <JadeMethod name="getInstructionsForContext" id="d8b85373-6761-406d-9992-d755b32bd59e">
        <source>getInstructionsForContext(_instructions: CM_InstructionsIssuedSet io; _passingObject: Object; _context: String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Apr 2025	navbs1	Initial creation Bug MTN-34396: EUP | Additional Operational Instructions - more issues (part 2)

*/

vars
	wod 		: CM_WorkOrderDtl;
	workOrder 	: CM_WorkOrder;
begin
	wod:= self.myWODtl;
	if wod = null then 
		wod := self.myWorkOrderDtlToDo;
	endif;	
	if wod &lt;&gt; null then
		workOrder := wod.myParent;
		_instructions.tryAddIfNotNull(workOrder.myInstructions);
		wod.getInstructionsForContext(_instructions,_passingObject,_context);
	endif;	
epilog

end;</source>
        <Parameter name="_instructions" type="CM_InstructionsIssuedSet" usage="io"/>
        <Parameter name="_passingObject" type="Object"/>
        <Parameter name="_context" type="String"/>
    </JadeMethod>
    <JadeMethod name="getJobTypeDescription" id="8e3f72f6-d42b-48e1-a37e-1b37e4dcc7b7">
        <source>getJobTypeDescription(): String;
/*
Purpose:			

Date		Who		Reason
25 March 2024	navab1	CR 62818 TASK 62821 
02 Dec 2024	navhl20 Bug MTN-33559: EUP | 53729 - Job Type column not showing correct value for the To Do Task Mode
*/

vars
	desc : String;
begin
	
	if self.myWorkOrderDtlToDo &lt;&gt; null then
		desc := self.myWorkOrderDtlToDo.getToDoTypeDesc();			//02.12.2024 navhl20 #33559
	elseif self.myWODtl &lt;&gt; null then								//02.12.2024 navhl20 #33559
		desc := self.myWODtl.getToDoTypeDesc();						//02.12.2024 navhl20 #33559
	endif;
	
	return desc;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
