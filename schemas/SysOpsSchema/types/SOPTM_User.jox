    <JadeMethod name="doImportTrx" id="c3ff7fd9-bbea-4727-b372-06c46f090871">
        <source>doImportTrx(_impFile: File) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
18 September 2025	navlw1	JIRA:35884 - 34574.014 - Provide User Name and Single Sign On Matching ID import functionality  

*/

vars

begin
