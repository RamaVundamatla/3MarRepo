    <JadeMethod name="translateForm" id="4c3d8624-ef73-4da5-971f-a4358d22ff88">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 31 July 2024 15:57:26.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0009339, locale);
	btnCancel.translateCaption(Xlat_0009340, locale);
	btnDocStopAction.translateBubbleHelp(Xlat_0021320, locale);
	btnDocStopAction.translateCaption(Xlat_0021321, locale);
	btnDocTaskAction.translateBubbleHelp(Xlat_0021322, locale);
	btnDocTaskAction.translateCaption(Xlat_0021323, locale);
	btnHSCode.translateCaption(Xlat_0025232, locale);
	btnHazards.translateBubbleHelp(Xlat_0021552, locale);
	btnHazards.translateCaption(Xlat_0021553, locale);
	btnNext.translateCaption(Xlat_0011281, locale);
	btnSave.translateCaption(Xlat_0009341, locale);
	chkControlAtmo.translateCaption(Xlat_0009342, locale);
	chkCurtainsIn.translateCaption(Xlat_0009343, locale);
	chkHeavy.translateCaption(Xlat_0009344, locale);
	chkIsClean.translateCaption(Xlat_0009345, locale);
	chkPreTripInspec.translateCaption(Xlat_0011282, locale);
	lblAvaliabilityG.translateCaption(Xlat_0011283, locale);
	lblCDDensity.translateCaption(Xlat_0011284, locale);
	lblCDHeight.translateCaption(Xlat_0014310, locale);
	lblCDHeightText.translateCaption(Xlat_0011286, locale);
	lblCDLength.translateCaption(Xlat_0014311, locale);
	lblCDLengthText.translateCaption(Xlat_0011288, locale);
	lblCDQuantity.translateCaption(Xlat_0011289, locale);
	lblCDTitle.translateCaption(Xlat_0014312, locale);
	lblCDType.translateCaption(Xlat_0011291, locale);
	lblCDVolume.translateCaption(Xlat_0011292, locale);
	lblCDWeight.translateCaption(Xlat_0014313, locale);
