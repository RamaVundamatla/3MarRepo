        <source>setMyFutureMovePlanned(_futureMovePlanned : CM_FutureMovePlanned ) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 July 2010	cnwer1	Initial creation PAR 25061

*/

vars

begin
	
