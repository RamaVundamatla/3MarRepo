    <JadeMethod name="txtStartFrom_change" id="7ef2cb5b-681a-4842-97f9-5ea17f970565">
        <controlMethod name="TextBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtStartFrom_change(textbox: TextBox input) updating;
// --------------------------------------------------------------------------------
// Created:		23 June 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	self.setStartRow(textbox.cnEcString());
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtStartFrom_firstChange" id="b5ac4c7a-55f9-4608-868f-40ed0a9a6791">
