	self.lblLoadLastModified.caption 	:= "";
	self.loadedMethod 					:= null;
	self.btnOpenInWinMerge.visible 		:= false;
	self.btnExportReport.enabled 		:= false;
	self.myReport 						:= null;
	self.btnOpenInNPP.visible 			:= false;
	
end;</source>
