	self.assertTrueMsg(cashReceipt1.externalReceiptNumber= EXTRECEIPTNUMBER,  "externalReceiptNumber should be " &amp; EXTRECEIPTNUMBER &amp; ", not " &amp; cashReceipt1.externalReceiptNumber);
	self.assertTrueMsg(cashReceipt1.externalRef1 = EXTREF1,  "externalRef1 should be " &amp; EXTREF1 &amp; ", not " &amp; cashReceipt1.externalRef1);
	self.assertTrueMsg(cashReceipt1.externalTransaction = EXTTRANSACTION,  "externalTransaction should be " &amp; EXTTRANSACTION &amp; ", not " &amp; cashReceipt1.externalTransaction);
		
	
	/*
