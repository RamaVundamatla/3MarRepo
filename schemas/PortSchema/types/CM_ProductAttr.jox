    <JadeMethod name="getDisplayStringForAttribute" id="7458033d-ecb4-46a9-a8c2-bb37b3679701">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     09 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
// Changed On	By			Reason
// ----------	----------	--------------------------------------------------
// 14/03/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
vars

begin
	if _attrName = ETRow_IsViewable then
		if self.isViewable then
			return '1';
		else
			return '0';
		endif;	
		
	elseif _attrName = ETRow_DisplayName then
		return self.displayName;
		
	elseif _attrName = ETRow_DisplayValue then
		return self.getDisplayValueString;
	
	elseif _attrName = ETRow_ValidationType then
		return self.validationType;
	
	elseif _attrName = ETRow_ColumnCode then
		if self.myCode &lt;&gt; null then
			return self.myCode.code;
		else
			return null;
		endif;
	elseif _attrName = ETRow_SystemName then
		return self.name[3:end];
		
	elseif _attrName = ETRow_MeasurementType then														// PAR #31155
		if self.myMeasurementType &lt;&gt; null then															// PAR #31155
			return self.myMeasurementType.measurementType &amp; " - " &amp; self.myMeasurementType.shortName;	// PAR #31155
		else																							// PAR #31155
			return null;																				// PAR #31155
		endif;																							// PAR #31155
	endif;
	
	return inheritMethod(_attrName, _short);
	
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayValueString" id="d225f101-28f3-49d5-9a19-93849b178277">
