    <JadeMethod name="translateForm" id="a6d2fc84-7226-459a-b0d7-e02cb386b816">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 30 January 2018 11:14:07.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014727, locale);
	chkIsCertified.translateCaption(Xlat_0014816, locale);
	chkToDo.translateCaption(Xlat_0014729, locale);
	lblCargoWeight.translateCaption(Xlat_0022187, locale);
	lblTareWeight.translateCaption(Xlat_0022188, locale);
	lblWeight.translateCaption(Xlat_0022189, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
