    <JadeMethod name="recalcJASVolume" id="cce77260-32a9-42c0-9a45-e86916f6b359">
        <updating/>
        <source>recalcJASVolume() updating;
// -----------------------------------------------------------------------------
// Created:		18 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	vol : Decimal [16,4];
begin

//	self.jasVolume := global.calcJASVolume(self.sedMean, self.logLength);
	// DVB changed 2/08/04 Phasing out jas volume.
	
	//03 Jun 2011	NDL	Par 26504
//	self.volume := global.calcJASVolume(self.sedMean, self.logLength);
	vol := global.calcJASVolume(self.sedMean, self.logLength); 
	self.setMyVolume(vol);
	
	// no children for logs
	//self.totalVolume := self.volume;
	self.setMyCargoVolume(vol); 	//03 Jun 2011	NDL	Par 26504
end;</source>
    </JadeMethod>
    <JadeMethod name="scalerCode" id="ca4f932d-70bd-464a-892c-60a28ba95752">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>scalerCode(set: Boolean; _value: String io) mapping, updating;

// cnwdvb1 02 December 2002 

vars
	extension : CM_BOLExtLog;
begin

	if set then
		if (not self.isTransient) then
			if self.myReceivalBOL &lt;&gt; null then
				extension := self.myReceivalBOL.myExtension.CM_BOLExtLog;  // AER 18233 22/10/2008
				if extension &lt;&gt; null then									  // AER 18233 22/10/2008
					extension.updateScalerCodes(self.scalerCode, _value);
				endif;
			endif;
			if self.myReleaseBOL &lt;&gt; null then
				extension := self.myReleaseBOL.myExtension.CM_BOLExtLog;   // AER 18233 22/10/2008
				if extension &lt;&gt; null then									  // AER 18233 22/10/2008
					extension.updateScalerCodes(self.scalerCode, _value);
				endif;
			endif;
		endif;
		self.scalerCode := _value;
	else
		_value := self.scalerCode;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="sedMax" id="86cc196a-9c8a-48eb-93cf-d3dfebdf703a">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>sedMax(set: Boolean; _value: Decimal io) mapping, updating;
//--------------------------------------------------------------
//Created: 03 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	if set then
		self.sedMax := _value;
		self.calculateSedMean();
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
