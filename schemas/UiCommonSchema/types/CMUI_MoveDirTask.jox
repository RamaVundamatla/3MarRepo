        <updating/>
        <source>cmbTAType_lostFocus(combobox: ComboBox input) updating;
//--------------------------------------------------
// Created:	25 August 2003 By: cnwgd1
//--------------------------------------------------
vars
	areaTypeCode : Integer;
	areaType : CM_TerminalAreaType;
begin
	self.tblMove.setValueByControlName(combobox.name, combobox.text);	
	if self.origValueStr &lt;&gt; combobox.text then
		areaTypeCode := TA_TYPE_NULL;
		if combobox.listObject &lt;&gt; null then		
			areaTypeCode := combobox.listObject.CM_TerminalAreaType.type; 
		endif;
		cmbTermArea.gotFocus(cmbTermArea);	
		myAssistant.comboBoxTerminalArea(cmbTermArea,areaTypeCode,null);
		cmbTermArea.lostFocus(cmbTermArea);
	endif;
	
end;</source>
