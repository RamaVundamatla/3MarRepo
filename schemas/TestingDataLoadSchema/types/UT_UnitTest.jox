//16 July 2008	cnwdw1	
//
vars

begin
	app.myProxyManager.clearAllProxies();
	if self.allTerminalsUsed = null then
		create self.allTerminalsUsed transient;
	else
		self.allTerminalsUsed.clear();
	endif;
end;</source>
