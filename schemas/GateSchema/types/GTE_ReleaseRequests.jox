        <updating/>
        <source>cmbISOType_displayEntry(combobox: ComboBox input; _isoTypeObj: CM_ISOType; lstIndex: Integer):String updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10/03/2010	cnwmh5	Initial creation
14/03/2016	cnwdap1	PAR #37606 Exclude not available for entry iso types
*/
vars

begin
	if _isoTypeObj = null then
		return null;
	endif;
	if _isoTypeObj.isNotAvailableForEntry then					// PAR #37606
		return null;											// PAR #37606
	endif;														// PAR #37606
	
	return _isoTypeObj.code.trimRight &amp; Tab &amp; _isoTypeObj.description.trimRight;
epilog

end;</source>
