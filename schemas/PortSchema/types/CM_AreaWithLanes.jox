    <JadeMethod name="setLaneCount" id="ab5ac640-dfbc-4e5b-890a-bdef8cd118d7">
        <updating/>
        <source>setLaneCount(_value :Integer)updating;
// ---------------------------------------------------------------------------
// Created:     29 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient (method);
		
	if self.laneCount &lt;&gt; _value then
		self.laneCount := _value;
	endif;
epilog

end;</source>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validate" id="4a6cb675-8a94-43b5-b36b-4ab0f336dd96">
        <source>validate() protected;
// ---------------------------------------------------------------------------
// Created:     23 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();
	
	if self.numberOfColumns &lt;&gt; 1 then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Number of columns should be 1');
	endif;
	
	self.validateLanes;
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="638bc6f7-9d63-4026-9ae9-795999f0ed71">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     22 June 2009 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	lc	:CM_LocationsController;
begin
	inheritMethod();
	
	foreach lc in self.allLocationsControllers do
		lc.validateForDelete;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="3a0908cf-5354-486e-ad34-b682267d8fec">
