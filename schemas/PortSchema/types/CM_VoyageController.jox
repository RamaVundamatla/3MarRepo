    <JadeMethod name="getTiTxnTypesForMoveFromToLC" id="da5672ef-1482-43a8-ae6e-e1d985e85765">
        <source>getTiTxnTypesForMoveFromToLC(_toController: CM_LocationsController; _intArray: IntegerArray input; _moveController: CMIF_MoveController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2013	cnwndl1	Initial creation	Par 31102

*/

vars

	ti : CM_TrackedItem;
	transReceive : CM_Receive;
	tiType : Integer;

begin

	inheritMethod(_toController, _intArray, _moveController);
	
	ti := _moveController.myTrackedItem;
	if ti = null then
		return;
	endif;
	
	//Direct delivery Ship to Ship, need to ensure we release to this ship 
	if _toController &lt;&gt; null
	and _toController.isKindOf( CM_VoyageController )
	and ( ti.directDelivery or _moveController.isMoveRealNWShipAToNWShipB )	//05 Aug 2013	NDL	Par 32163
	then
		if ti.getLastTransOfType(TRANS_TYPE_REL_SHIP) = null then
			if not _intArray.includes(TRANS_TYPE_REL_SHIP) then	//26 Jun 2013	NDL	Par 31897
				_intArray.add(TRANS_TYPE_REL_SHIP);
				_intArray.add(TRANS_TYPE_WHARFAGE);
				app.addTiTxnSubTerminalRelease(ti, TI_TRANSMODE_SHIP, _intArray);
			endif;
		//07 Nov 2014	NDL	Par 35015
		elseif ti.myCargoType &lt;&gt; null and ti.myCargoType.allowDuplicates then
			if not _intArray.includes(TRANS_TYPE_REL_SHIP) then
				_intArray.add(TRANS_TYPE_REL_SHIP);
			endif;
			if not _intArray.includes(TRANS_TYPE_WHARFAGE) then
				_intArray.add(TRANS_TYPE_WHARFAGE);
			endif;
			if ti.mySubTerminal &lt;&gt; null then
				tiType := app.getSubTerminalReleaseTxnType( ti.mySubTerminal.type, TI_TRANSMODE_SHIP );
				if tiType &lt;&gt; 0 and not _intArray.includes(tiType) then
					_intArray.add(tiType);
				endif;
			endif;
			
		endif;
	endif;
	
	//Direct delivery from ship , need to ensure we have a receipt from ship 
	if _toController &lt;&gt; null
	and ( _toController.isKindOf( CM_VehicleController ) or _toController.isKindOf( CM_WagonController ) or _toController.isKindOf( CM_VoyageController ) )
	and ( ti.directDelivery or _moveController.isMoveRealNWShipAToNWShipB )	//05 Aug 2013	NDL	Par 32163
	then
		if ti.getLastTransOfType(TRANS_TYPE_REC_SHIP) = null then
			if not _intArray.includes(TRANS_TYPE_REC_SHIP) then	//26 Jun 2013	NDL	Par 31897
				_intArray.add(TRANS_TYPE_REC_SHIP);
				_intArray.add(TRANS_TYPE_WHARFAGE);
				app.addTiTxnSubTerminalReceive(ti, TI_TRANSMODE_SHIP, _intArray);
			endif;
		//07 Nov 2014	NDL	Par 35015
		elseif ti.myCargoType &lt;&gt; null and ti.myCargoType.allowDuplicates then
			if not _intArray.includes(TRANS_TYPE_REC_SHIP) then
				_intArray.add(TRANS_TYPE_REC_SHIP);
			endif;
			if not _intArray.includes(TRANS_TYPE_WHARFAGE) then
				_intArray.add(TRANS_TYPE_WHARFAGE);
			endif;
			if ti.mySubTerminal &lt;&gt; null then
				tiType := app.getSubTerminalReceiveTxnType( ti.mySubTerminal.type, TI_TRANSMODE_SHIP );
				if tiType &lt;&gt; 0 and not _intArray.includes(tiType) then
					_intArray.add(tiType);
				endif;
			endif;
			
		endif;
	endif;
	

epilog

end;</source>
        <Parameter name="_toController" type="CM_LocationsController"/>
        <Parameter name="_intArray" type="IntegerArray" usage="input"/>
        <Parameter name="_moveController" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="getTiTxnTypesForMoveFromToNULL" id="0969cc9b-39a0-45c8-b27d-806177147634">
        <source>getTiTxnTypesForMoveFromToNULL(_moveController: CMIF_MoveController; _intArray: IntegerArray input);
//--------------------------------------------------
// Created:	15 January 2004 By: cnwgd1
//--------------------------------------------------
vars
	
begin
	inheritMethod(_moveController, _intArray);
	
// PAR 33644	if self.myVoyage.isNonPlannedVoyage or self.myVoyage.isNonWorkedVoyage then
	//epr par 34837 1/9/14 always create of moving cargo offsite via NWNP if it has lolo slots is irrrelevant
	if _moveController.isNonCraneVoyageMove then

		// The port is not working this voyage (3rd party has)
		// therefore only create wharfage as per Sam 15/1/04
		_intArray.add(TRANS_TYPE_REC_SHIP);
		app.addTiTxnSubTerminalReceive(_moveController.myTrackedItem, TI_TRANSMODE_SHIP, _intArray);
		
		_intArray.add(TRANS_TYPE_WHARFAGE);

		app.addTiTxnSubTerminalRelease(_moveController.myTrackedItem, TI_TRANSMODE_ROAD, _intArray);	// PAR 20706 (swap order)
		_intArray.add(TRANS_TYPE_REL_ROAD);	
	endif;
end;</source>
        <Parameter name="_moveController" type="CMIF_MoveController"/>
        <Parameter name="_intArray" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTiTxnTypesForMoveToFromLC" id="c775aff2-ce6e-420a-9d1e-cd97b5ed6040">
        <source>getTiTxnTypesForMoveToFromLC(_fromController : CM_LocationsController; _intArray: IntegerArray input; _moveController : CMIF_MoveController);
// ---------------------------------------------------------------------------
// Created:     06 January 2004 by cnwrs2
//
// Purpose:     
// 24/03/2023	navkc1	Bug 56613: SNO - Duplicated storage transaction with QTY=0
// ---------------------------------------------------------------------------
vars
	theTI : CM_TrackedItem;
	relTrans : CM_ReleaseShip;
	voyage : CM_Voyage;
begin
	inheritMethod(_fromController, _intArray,_moveController);

	if _fromController.isKindOf(CM_YardController) or _fromController.isKindOf(CM_MachineController) then		
		/* 06 Nov 2014	NDL	Par 35015
		//epr par 32776
		voyage:=self.myVoyage;
		// 32906 add canSplitTotalQuantity to avoid performance issue with logs and probably other cargo
		if voyage &lt;&gt; null and _moveController.myTrackedItem &lt;&gt; null and _moveController.myTrackedItem.canSplitTotalQuantity() then
			relTrans:=voyage.getTITransactionForTIId(TRANS_TYPE_REL_SHIP,_moveController.myTrackedItem.id).CM_ReleaseShip;
			if relTrans &lt;&gt; null then
				return;
			endif;
		endif; */
		
		app.addTiTxnSubTerminalRelease(_moveController.myTrackedItem, TI_TRANSMODE_SHIP, _intArray);	// PAR 20706 (swap order)
		_intArray.add(TRANS_TYPE_MOVE_CRANE); // ### TFS 51855 04FEB2022 NAVAB1
		_intArray.add(TRANS_TYPE_REL_SHIP);
		_intArray.add(TRANS_TYPE_WHARFAGE);	
		
		//_intArray.add(TRANS_TYPE_STORAGE);	// #56613 - Release Ship transaction already has code to create Storage transaction, don't need to do it again.
		
	//elseif (_fromController.isKindOf(CM_VehicleController) or _fromController.isKindOf(CM_WagonController)) then //29 Jan 2013	NDL	Par 31102
	elseif (_fromController.isKindOf(CM_VehicleController) or _fromController.isWagon) then//27 May 2013	NDL	Part of Boxcar conversion
		app.addTiTxnSubTerminalRelease(_moveController.myTrackedItem, TI_TRANSMODE_SHIP, _intArray);
		_intArray.add(TRANS_TYPE_REL_SHIP);
		_intArray.add(TRANS_TYPE_WHARFAGE);		
		
	// going from ship to ship, must be SOB
	elseif _fromController.isKindOf(CM_VoyageController) then	// PAR 7254 AKB2004JAN added
		// OK a slot to slot move, but only create the transaction if its a SOB
		theTI := _moveController.myTrackedItem;
		if theTI &lt;&gt; null then
			if theTI.isSOB then
				app.addTiTxnSubTerminalRelease(_moveController.myTrackedItem, TI_TRANSMODE_SHIP, _intArray);	// PAR 20706 (swap order)
				_intArray.add(TRANS_TYPE_MOVE_CRANE); // ### TFS 51855 03FEB2022 NAVAB1
				_intArray.add(TRANS_TYPE_REL_SHIP);	// PAR 7254 AKB2004JAN added
				
		//	elseif theTI.directDelivery then	//29 Jan 2013	NDL	Par 31102
			elseif ( theTI.directDelivery or _moveController.isMoveRealNWShipAToNWShipB ) then	//05 Aug 2013	NDL	Par 32163
				if not _intArray.includes( TRANS_TYPE_REL_SHIP ) then	//26 Jun 2013	NDL	Par 31897
					app.addTiTxnSubTerminalRelease(_moveController.myTrackedItem, TI_TRANSMODE_SHIP, _intArray);	
					_intArray.add(TRANS_TYPE_REL_SHIP);
					_intArray.add(TRANS_TYPE_WHARFAGE);
				endif;
				
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="_fromController" type="CM_LocationsController"/>
        <Parameter name="_intArray" type="IntegerArray" usage="input"/>
        <Parameter name="_moveController" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="getTiTxnTypesForMoveToFromNULL" id="90a4a12c-2f52-4b13-9650-9b13929c9dfe">
        <source>getTiTxnTypesForMoveToFromNULL(_moveController: CMIF_MoveController; _intArray: IntegerArray input);
//--------------------------------------------------
// Created:	15 January 2004 By: cnwgd1
//--------------------------------------------------
// 15/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport for tranships
// 14/08/2018	jlgdap1		TFS 40003 PEL1 Voyage to Road Moves
// 24/03/2023	navkc1		Bug 56613: SNO - Duplicated storage transaction with QTY=0
vars
	tmpTI	: CM_TrackedItem;
	
begin
	inheritMethod(_moveController, _intArray);

	if _moveController.indexForEDIBayPlan &gt; 0 then	//assume this is an EDI move
		return;
	endif;
	
	tmpTI := _moveController.myTrackedItem;

	//changed to non-exports JC PAR 8567 (was returning for imports only)
	if (not tmpTI.isExport) and (not tmpTI.isTranshipOutbound) then			// PAR #25021
		// Par 8283 - do not create these transactions for imports
		return;
	endif;

// PAR 33644	if self.myVoyage.isNonPlannedVoyage or self.myVoyage.isNonWorkedVoyage then

// TFS 45731 JLGAB1 always create a receive IF coming from NOWHERE e.g. export prenote or export offsite
// TFS 45731	if self.myVoyage.isHOLDSorSHIP() then 
	
		// The port is not working this voyage (3rd party has) as per Sam 15/1/04
		//_intArray.add(TRANS_TYPE_REC_ROAD);										// TFS 40003
		//app.addTiTxnSubTerminalReceive(tmpTI, TI_TRANSMODE_ROAD, _intArray);		// TFS 40003
		if tmpTI.receiptTransportMode = TI_TRANSMODE_RAIL then						// TFS 40003
			_intArray.add(TRANS_TYPE_REC_RAIL);										// TFS 40003
			app.addTiTxnSubTerminalReceive(tmpTI, TI_TRANSMODE_RAIL, _intArray);	// TFS 40003
		else																		// TFS 40003
			_intArray.add(TRANS_TYPE_REC_ROAD);										// TFS 40003
			app.addTiTxnSubTerminalReceive(tmpTI, TI_TRANSMODE_ROAD, _intArray);	// TFS 40003
		endif;																		// TFS 40003

// TFS 45731	endif;
	
	//Par 8502 - Export moved to ship from nowhere
	app.addTiTxnSubTerminalRelease(tmpTI, TI_TRANSMODE_SHIP, _intArray);		// PAR 20706 (swap order)
	_intArray.add(TRANS_TYPE_REL_SHIP);
	_intArray.add(TRANS_TYPE_WHARFAGE);
	//_intArray.add(TRANS_TYPE_STORAGE);	// #56613 - Release Ship transaction already has code to create storage transaction, don't need to do it again;
end;</source>
        <Parameter name="_moveController" type="CMIF_MoveController"/>
        <Parameter name="_intArray" type="IntegerArray" usage="input"/>
    </JadeMethod>
