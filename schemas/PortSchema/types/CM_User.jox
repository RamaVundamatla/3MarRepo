    <JadeMethod name="canViewStop" id="011670b5-e5d7-41cb-bdbe-38b883c8ee97">
        <source>canViewStop(_terminal : CM_Terminal; _stopTable : CM_StopsTable) : Boolean;
//-----------------------------------------
// Created: November 2003 By: cnwgd1
//
//	Returns true if user has view access.  Don't use this to check for Maint access.
// 04 Oct 2023	navma1 ChangeRequest 59638: EUP | Ship Operations in DD - [54176.010] - [Receive] Work Order Detail Grouping
//-----------------------------------------
vars
	tmpUT	: CM_UserTerminal;
	role 	: CM_SecurityRole;
begin
	
	if _terminal = null then		// PAR 16831 - RJS - check terminal first	
		return false;
	endif;
	
	if _stopTable = null then
		return false;
	endif;
	
	if app.isSpecial() then
		return true;
	endif;

	tmpUT := self.getUserTerminal(_terminal);
	
	if tmpUT = null then
		return false;
	endif;

	role := tmpUT.mySecurityRole;						//04.10.2023 navma1 #59638
	
	if role &lt;&gt; null and
	   role.allStopsView.includes(_stopTable) then		//04.10.2023 navma1 #59638
	   	return true;
	endif;

	return false;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_stopTable" type="CM_StopsTable"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkMenuNavAgainstSecurity" id="231f5224-752f-4fea-876e-ed294774b268">
        <source>checkMenuNavAgainstSecurity();
// ---------------------------------------------------------------------------
