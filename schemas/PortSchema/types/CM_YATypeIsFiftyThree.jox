    <JadeMethod name="isCMIFDataMatch" id="763bcdce-8ed3-46a1-9e6c-41c3679edf6f">
        <source>isCMIFDataMatch(_cmifAutoPlan : CMIF_YAAutoPlan; _yaData: CM_YADataBoolean): Boolean;
// -------------------------------------------
// Created 10 May 2005 by cnwdvb1
// -------------------------------------------
vars

	
begin

	return _cmifAutoPlan.isFiftyThree_Match(_yaData);
	
end;</source>
