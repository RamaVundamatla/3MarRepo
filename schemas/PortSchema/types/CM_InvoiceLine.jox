    <JadeMethod name="calculateQuantity" id="64736873-ee8d-449a-bf43-005fe0261253">
        <updating/>
        <source>calculateQuantity() updating; 
/*
Date			Who			Reason
Apr 2012 					CCMS 1264  quantity is no longer dynamic - set at create, pre-post print, post and on demand from invoice re-evaluate
04 Mar 2019 	cnwma1		Bug 43637: PEL1 - Invoice restrictions - GT change
23 Oct 2024		navlw1		JIRA-33107: Invoice Logging Use Levels
25 Feb 2025		navma1		Story 34141: MTN - Performance Improvements - Review for invLog() Methods

*/
vars
	newQuantity	: Real;
	theCalcType : CM_CalculationType;
	canLogExtra	: Boolean;
begin

	if self.invoice = null then
		return;
	endif;
	
	if not self.invoice.canUpdate then  				 				//04.03.2019 cnwma1 #43637
		return;
	endif;

	if self.invoice.isPostedOrReversal then								//04 Sep 2017	NDL	TFS 6759	
		return;
	endif;

	if not self.manual and  not self.invoice.isPostedOrReversal then	//04 Sep 2017	NDL	TFS 6759
		
		newQuantity := self.quantity;	//25 July 2019	NDL - JMT unit test failure, Snapshot quantity getting reset to zero..
		theCalcType := self.invoiceLineDesc.getCalcType(); // ### TFS BUG 61892 29DEC2023 NAVAB1
	   
	   if self.myTransactionHMS  &lt;&gt; null then
			newQuantity := self.quantityVOYAGECalcType(theCalcType); // ### TFS BUG 61892 29DEC2023 NAVAB1
		
		elseif self.myTransactionWO &lt;&gt; null then 
			newQuantity := self.quantityWorkOrderCalcType(theCalcType);  // ### TFS BUG 61892 29DEC2023 NAVAB1
			// ### TFS BUG 61892 29DEC2023 NAVAB1 newQuantity := self.quantityWorkOrder();
			
		elseif self.myTransactionBOL &lt;&gt; null then 	//31 Oct 2019	NDL	TFS 47100
			newQuantity := self.quantityBOL();
		
		elseif self.myTransactionEvent &lt;&gt; null then
			if self.myTransactionEvent.isLocationActivityEvent() then // ### TFS 51219 01JUN2021 NAVAB1
				newQuantity := self.quantityInventoryCalcType(theCalcType); // ### TFS 51219 01JUN2021 NAVAB1
			else
				newQuantity := self.quantityEventCalcType(theCalcType);  // ### TFS BUG 61892 29DEC2023 NAVAB1
				// ### TFS BUG 61892 29DEC2023 NAVAB1 newQuantity := self.quantityEvent(); 
			endif;
		
		elseif self.myTransactionTI  &lt;&gt; null then
			newQuantity := self.quantityCARGO();
		endif;
		
		if newQuantity &lt;&gt; self.quantity then
			canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navma1	#34141
			if canLogExtra then
				app.invLog("Quantity change from " &amp; self.quantity.String &amp; " to " &amp; newQuantity.String, LogINFO.String);
			endif;
			self.quantity := newQuantity;
		endif;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="calculateStorageDays" id="61efcb14-1aa0-49df-b74a-188ec09ef1f3">
        <source>calculateStorageDays() : Integer;
/*

Date		Who		Reason
14 August 2015	cnwer1	Initial creation PAR 36778

*/

vars
	storageDays : Integer;
	calcType : CM_CalculationType;

	chargeByUnits	: Integer;
	convRate	: Real;
	amount		: Real;
begin
	storageDays := 1;
	if self.myTransactionTI = null then
		return storageDays;
	endif;
	
	if self.myTransactionTI.type &lt;&gt; TRANS_TYPE_STORAGE then
		return storageDays;	
	endif;
	
	calcType:= self.invoiceLineDesc.myCalculationType;
	
	if self.quantity = 0 or calcType = null then
		return self.quantity.Integer;
	endif;	
	
	//epr TFS 1693 23/3/16
	if not self.isStorageByDays then
		return 1;
	endif;
	
	chargeByUnits := calcType.calculationType;
	if calcType.myMeasurementType &lt;&gt; null then
		convRate := calcType.myMeasurementType.conversionRate;
	else
		convRate := 1;
	endif;
	
	if chargeByUnits = INV_CALC_TYPE_CARGOWEIGHTCONVT or chargeByUnits =  INV_CALC_TYPE_DAYS_WEIGHT then
		if calcType.isUseCargoWeight() and self.trackedItem &lt;&gt; null then
			amount := self.trackedItem.weightCargo; //02/10/2025	navkc1 JIRA 36149
		else
			amount := self.trackedItemWeight;
		endif;
	elseif chargeByUnits = INV_CALC_TYPE_CARGOVOLUMECONVT or chargeByUnits = INV_CALC_TYPE_DAYS_VOLUME then
		amount := self.trackedItemVolume;
	elseif chargeByUnits = INV_CALC_TYPE_CARGOLENGTHCONVT then
		amount := self.trackedItemLength;
	else
		amount := 1;
	endif;
	
	// safety factor
	if amount = 0 then
		amount := 1;
	endif;
	
	storageDays := ((self.quantity * convRate) / amount).Integer;
		
	return storageDays;
epilog

end;</source>
