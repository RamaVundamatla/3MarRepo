    </JadeMethod>
    <JadeMethod name="validateMe" id="5b75acb4-1862-4746-ae9a-b9090ed0e4b3">
        <source>validateMe();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2013	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	if self.type = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Type_GC), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Type_GC), null, null); // cnwdb2	PAR 35364
	endif;
epilog

end;</source>
    </JadeMethod>
