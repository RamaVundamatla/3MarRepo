    <JadeMethod name="initComboBoxes" id="2e5cb015-d705-4fff-bc04-19b28360b278">
        <source>initComboBoxes();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin

