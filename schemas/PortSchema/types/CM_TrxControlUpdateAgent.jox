    <JadeMethod name="trxUpdateResetSnapShots" id="d633e6dc-3e9c-4a7d-8b73-009c3403251f">
        <updating/>
        <source>trxUpdateResetSnapShots(_snapShots: CM_SnapShotSet;_passport : CM_Passport input) updating;
/*
Purpose:	TFS 40336	Reset the user snap shot transaction	
Date				Who			Reason
SEPTEMBER 2018		CNWAB1		Initial creation
*/

vars
	snapShot	: CM_SnapShot;
	tisnap : CM_TISnapShot;
	userSnap, pxySnapShot : CM_UserTISnapShot;
	type : String;
	chgReason	: CM_MessageUser;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	beginTransaction;
	
	foreach snapShot in _snapShots do
		tisnap := snapShot.CM_TISnapShot;
		userSnap := tisnap.myUserTISnapShot;
		
		delete userSnap;
	
		if app.myPassport.hasErrorsOrWarnings() then
			return;
		endif;
	endforeach;
	
epilog
	delete pxySnapShot;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_snapShots" type="CM_SnapShotSet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
