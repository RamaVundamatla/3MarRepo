    <JadeMethod name="getTokenFromEndpoint" id="3f4de8a1-3b8a-4bb7-817b-e1e86bdb1db3">
        <source>getTokenFromEndpoint(_terminal : CM_Terminal; _type: Integer; _endPoint, _clientId, _clientSecret, _scope, _tenantId, _usercode, _password : String;_oAuth2Version : Integer; _resource : String;  _errorResponseForAlert : String output) : String;
//
// Purpose:					Retrieves an OAuth token and makes sure its still valid. If its not, then request a new one.
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 03/02/2023	navdap1		Initial creation TFS 55159 MTN Export CAMS to JSON API Endpoint
// 19/01/2024	navmd1		TFS 55021 EA Mail Tidyup and Refactor
// 05/08/2024   navsp1      ChangeRequest 63842: NSW | OnePort Integration Dev
// 30/08/2024	navmd1		TFS 65917 Add more error checking if we don't get an 'access_token' back
// 04/09/2024	jlier1 		TFS 65949 - task 65950 - NSW | Dynamics Integration
// 22/10/2024	navdap1		MTN-14005 NSW | OnePort Integration - Requested Changes
// 10/09/2025	navdap1		MTN-35707 YARA | Create a new web service definition to use to send out AG Gateway messages
constants
	RefreshWindowSecs	: Integer = 300;	// 5 minutes
	DefaultTimeout		: Integer = 3600;
	
vars
	oAuthToken		: CMIF_OAuthToken;
	msg 			: String;
	requestData		: String;
	timeout			: Integer;
	address			: String;
	returnVal		: String;
	error			: Integer;
	webAgent		: CM_EAMailConsumerAgent;
	token			: String;
	tokenTimeout	: Integer;
	parser			: JadeJson;
	objs			: ObjectArray;
	msTokenRes		: MSOAuthResponse;
	hadException	: Boolean;
	isPasswordType	: Boolean;
	jsonHelper		: CMIF_JsonHelper;
	header 			: String;				// MTN-35707
begin
	oAuthToken := app.allExtOAuthTokens[_type, _terminal];
	
	// If we don't have a token, or its expired (or near-enough to), then get a new one
	if oAuthToken = null or oAuthToken.expiresIn &lt; RefreshWindowSecs then
		isPasswordType := _clientSecret = null and _usercode &lt;&gt; null and _password &lt;&gt; null;										//TFS 63842
		if _clientId = null or (_clientSecret = null and _usercode = null and _password = null) or _tenantId = null then		//TFS 63842
			// MTN-14005 if oauth type is 0, then we don't have a client secret or client id or tenant id
			if _oAuth2Version &lt;&gt; null then
				msg := "Client ID, Client Secret or Tenant ID not defined in Terminal or System Config";
				app.writeLog(method.qualifiedName &amp; Tab &amp; msg, LogERROR);
				app.createAlert(app.getErrorString1(EmailReceiveFailure, msg), true);
				app.raiseCMException1(EmailReceiveFailure, msg, null, null);			
				return null;
			endif;
		endif;
		
		address := _endPoint;
		if address[_endPoint.length:1] &lt;&gt; "/" then
			address := address &amp; "/";
		endif;
		if _oAuth2Version = 1 then
			address:=address  &amp; _tenantId &amp; "/oauth2/token";
		elseif _oAuth2Version = 2 then									// MTN-14005
			address:=address  &amp; _tenantId &amp; "/oauth2/v2.0/token";
		elseif _oAuth2Version = 0 then									// MTN-14005
			address := address &amp; "token";								// MTN-14005
		endif;
		
		header := "Content-Type: application/x-www-form-urlencoded";	// MTN-35707
		
		if not isPasswordType then																													//TFS 63842
			requestData := "client_id=" &amp; _clientId &amp; "&amp;client_secret=" &amp; _clientSecret  &amp; "&amp;grant_type=client_credentials";
			if _oAuth2Version = 1 then
				requestData:=requestData &amp; "&amp;resource=" &amp; _resource;
			else
				// MTN-35707 "Hacky" stuff to do basic auth (usercode/password) when requesting a token that also uses client ID/secret
				if _scope &lt;&gt; null then
					requestData:=requestData &amp; "&amp;scope=" &amp; _scope;
				endif;
				if _password &lt;&gt; null then
					header := header &amp; CrLf &amp; "Authorization: Basic " &amp; (_clientId &amp; ":" &amp; _password).asANSI(0).base64Encode();	// Using 0 here may cause issues in non-English characterset Unicode environments
				endif;
			endif;
		else																																		//TFS 63842
			if _oAuth2Version &lt;&gt; null then								// MTN-14005
				requestData	:= "grant_type=password&amp;username=" &amp; _usercode &amp; "&amp;password=" &amp; _password &amp; "&amp;client_id=" &amp; _clientId &amp; "&amp;scope=" &amp; _scope;	//TFS 63842
			else
				requestData := "Grant_type=password&amp;Username=" &amp; _usercode.cnEcUrlEncode(1) &amp; "&amp;Password=" &amp; _password.cnEcUrlEncode(1);		// MTN-14005
			endif;
		endif;																																		//TFS 63842
		
		timeout := app.myRoot.getConfig(AutoEmailTimeout).Integer;
		if timeout &lt; 2 or timeout &gt; 60 then
			timeout := 30;
		endif;
		
		// Send a http request for a token
		app.writeLog("Requesting a Token from " &amp; address, LogINFO);
		create webAgent transient;
		webAgent.timeoutSeconds := timeout;
		webAgent.createActivityHistory := true;
		
		returnVal := webAgent.doSendHTTPRequest(	address ,
													"POST",
													header, 		// MTN-14005	// MTN-35707
													requestData, 
													error	);
		
		// Did we get a token?
		if returnVal = null then
			app.writeLog("No response from " &amp; address &amp; " - error code is " &amp; error.String, LogERROR);
			app.createAlert("Token request failed to connect to server - error code was " &amp; error.String, true);
			return null;
		endif;
		
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Got a response: " &amp; CrLf &amp; returnVal, LogDEBUG);
		
		create parser transient;
		create objs transient;
		on Exception do self.handleJSONParsingException(exception, hadException);
		msTokenRes := parser.parse(returnVal, MSOAuthResponse, objs).MSOAuthResponse;
		on Exception do null;
		
		if msTokenRes = null then
			// Welp, something went wrong, can only bail from here
			app.writeLog(returnVal, LogERROR);
			app.writeLog(method.qualifiedName &amp; " Error parsing Token response", LogERROR);
			return null;
		endif;
		
		// If we have a sensible error message back, then let the user see it
		if msTokenRes.error &lt;&gt; null then
			app.writeLog(returnVal, LogERROR);
			app.writeLog(method.qualifiedName &amp; "  Error getting token. (" &amp; msTokenRes.error &amp; ")", LogERROR);
			
			// Use by the alert that'll get created later
			create jsonHelper transient;
			_errorResponseForAlert := jsonHelper.formatJsonString(returnVal);
			if _errorResponseForAlert = null then
				_errorResponseForAlert := returnVal;
			endif;
			
			return null;
		endif;
		
		if msTokenRes.access_token = null then
			// *something* must have gone wrong, not much we can do except bail
			app.writeLog(returnVal, LogERROR);
			app.raiseUnexpectedProgramError(class.name, method.name, "Unknown error. 'access_token' is null");
			return null;
		endif;
		
		token := msTokenRes.access_token;
		tokenTimeout := msTokenRes.expires_in;
		if tokenTimeout = 0 then
			tokenTimeout := DefaultTimeout;
		endif;
		
		if app.logLevel = LogTRACE then
			// The token is a sensitive string and should NOT be logged normally!
			app.writeLog("Got a token back - " &amp; token, LogTRACE);
		else
			app.writeLog("Got a token back - token timeout is " &amp; tokenTimeout.String, LogINFO);
		endif;
		
		if oAuthToken = null then
			oAuthToken := create CMIF_OAuthToken(_terminal, _type);
		endif;
		oAuthToken.accessToken := token;
		oAuthToken.expiresIn := tokenTimeout;
	else
		if app.logLevel = LogTRACE then
			// The token is a sensitive string and should NOT be logged normally!
			app.writeLog("Reusing existing token - " &amp; oAuthToken.accessToken, LogTRACE);
		else
			app.writeLog("Reusing existing token.", LogINFO);
		endif;
	endif;
	
	return oAuthToken.accessToken;
	
epilog
	delete webAgent;
	delete parser;
	if objs &lt;&gt; null then
		objs.purge();
		delete objs;
	endif;
	delete jsonHelper;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_endPoint" type="String"/>
        <Parameter name="_clientId" type="String"/>
        <Parameter name="_clientSecret" type="String"/>
        <Parameter name="_scope" type="String"/>
        <Parameter name="_tenantId" type="String"/>
        <Parameter name="_usercode" type="String"/>
        <Parameter name="_password" type="String"/>
        <Parameter name="_oAuth2Version" type="Integer"/>
        <Parameter name="_resource" type="String"/>
        <Parameter name="_errorResponseForAlert" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTrackedItemCount" id="fa2c9eec-9458-43d0-b00b-c72fed64ad7c">
        <source>getTrackedItemCount( _coll : Collection) : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 June 2013	cnwrd1	Initial creation

*/

vars
	any		: Any;
	aTI : CM_TrackedItem;
	count : Integer;
begin

	if not self.deepCountTrackedItems then
		return _coll.size;
	endif;
	
	
	any := _coll.first;
	if not any.isKindOf(CM_TrackedItem) then
		return  _coll.size;
	endif;
		
	foreach any in _coll do
		aTI := any.CM_TrackedItem;
		count := count + aTI.totalQuantity.max(1);
	endforeach;
	
	return count;
epilog

end;</source>
        <Parameter name="_coll" type="Collection"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
