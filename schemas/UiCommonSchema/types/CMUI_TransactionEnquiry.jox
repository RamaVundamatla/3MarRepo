    <JadeMethod name="doContextMenuDiscrep" id="2ed1605d-ec9b-4053-8cfa-54e9f2007cb4">
        <updating/>
        <source>doContextMenuDiscrep(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 September 2009	cnwndl1	Initial creation

*/

vars
	x1,
	y1			: Real;
	obj 		: Object;
	eventDiscrep : CMEVT_BookingRefDiscrep; 

begin
	x1 := x;
	y1 := y;
	if (not mouse) then
	    x1 := 1;
	    y1 := 1;
	endif;

	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);

	self.mnuInformation.visible := false;
	self.mnuTxnResync.visible := false;
	self.mnuTxnAdd.visible := false;
	self.mnuTxnEdit.visible := false;
	self.mnuTxnDelete.visible := false;
	self.mnuTxnUndelete.visible := false;
	self.mnuTxnResources.visible := false;
	self.mnuTxnViewAudits.visible := false;
	self.mnuPrint.visible := false;
	self.mnuCargoEnquiry.visible := false;
	self.mnuShowInvoice.visible := false;
	
	obj := cntrl.accessRow(cntrl.row).itemObject;
	if CMEVT_BookingRefDiscrep.hasInstance( obj ) then
		eventDiscrep := obj.CMEVT_BookingRefDiscrep; 
	endif;
	
	self.mnuEditBookingRefDiscr.visible := eventDiscrep &lt;&gt; null;
	self.mnuEditBookingRefDiscr.userObject := eventDiscrep;
	self.mnuEditDiscrepRemarks.visible := eventDiscrep &lt;&gt; null;
	self.mnuEditDiscrepRemarks.userObject := eventDiscrep;
	
	self.popupMenu(self.mnuContext, x1.Integer, y1.Integer);
	return false;

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
