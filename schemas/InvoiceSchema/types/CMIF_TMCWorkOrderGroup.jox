    <JadeMethod name="getAvailableWOResources" id="c900219e-3c03-4644-a04a-3c05a18fba40">
        <source>getAvailableWOResources(_resources : CM_ResourceTypeDict io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map

*/

vars
	transType 		: CM_TransactionType;
	toDoTask 		: CM_ToDoTaskDesc;
	resourceObj		: CM_Object;
	resource		: CM_ResourceType;
	root			: CM_Root;
begin
	
	if _resources = null then
		return;
	endif;
	
	transType := self.getMyWorkOderType();
	
	if transType = null then
		return;
	endif;
	
	foreach toDoTask in transType.allToDoTaskDesc discreteLock do
		foreach resourceObj in toDoTask.allResourceTypes discreteLock do
			if not resourceObj.isKindOf(CM_ResourceType) then
				continue;
			endif;
			
			resource := resourceObj.CM_ResourceType;
			
			_resources.addNoDuplicates(resource, false);
			
		endforeach;
	endforeach;
	
	/* // ### TFS BUG 60696 27SEP2023 NAVAB1
	root := app.myRoot;
	
	if root = null then
		return;
	endif;
	
	foreach resource in root.allTaskResourceTypes discreteLock do
		if not resource.type = TODO_TYPE_GROUP_ALL then
			continue;
		endif;
		
		_resources.addNoDuplicates(resource, false);
	endforeach;
*/	
epilog

end;</source>
        <Parameter name="_resources" type="CM_ResourceTypeDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getMyWorkOderType" id="e4b15da3-bf7a-49f3-8722-9b24a0cda2fb">
        <source>getMyWorkOderType() : CM_TransactionType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map

*/

vars
	root		: CM_Root;
	transType	: CM_TransactionType;
begin
	
	if self.workOrderType = null then
		return null;
	endif;
	
	root := app.myRoot;
	
	if root = null then
		return null;
	endif;
	
	transType := root.allTransactionTypes.getAtKey(self.workOrderType);
	
	return transType;
	
epilog

end;</source>
        <ReturnType type="CM_TransactionType"/>
    </JadeMethod>
    <JadeMethod name="getPicture" id="eb7c77c7-f513-419d-9ad5-4525173a447c">
