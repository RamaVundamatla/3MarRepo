// --------------------------------------------------------------------------------
begin
	// Set any attribute values.
	
	//self.value	:=	pProxyObj.value;
	self.allValues.clear();
	pProxyObj.allValues.copy(self.allValues);
	
	// Set any key attribute values.
	
	// Set any inverse references.
end;</source>
        <Parameter name="pProxyObj" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="f306629c-66d3-45d6-b7ed-ef7bb15264ac">
        <updating/>
        <source>setProxy(pAllValues:IntegerArray) updating;
// --------------------------------------------------------------------------------
// Created:		07 March 2005 by cnwdad1
//
// Purpose:		Sets the receiver's property values when the receiver is a transient
//				proxy object.
//
// Parameters:	pValue - The receiver's data value.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.raiseExceptionIfNotTransient(method);
	
	pAllValues.copy(self.allValues);
end;</source>
        <Parameter name="pAllValues" type="IntegerArray"/>
    </JadeMethod>
    <JadeMethod name="setValue" id="c1a3f0b5-e2c0-4e9e-b23d-3b69f2b947b3">
        <updating/>
        <source>setValue(pValue: Any) updating;
