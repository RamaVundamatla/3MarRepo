    <JadeMethod name="addToolbarControls" id="07258c2f-9abf-4a1d-abbf-b6d270990756">
        <updating/>
        <source>addToolbarControls() updating, protected;
// --------------------------------------------------------------------------------
// Created:		09 May 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 03/11/2011	cnwdap1		PAR #28629 Hide Delete button if user cannot maintain YAs
// --------------------------------------------------------------------------------
vars
	toolbarObj	: CMUI_Toolbar;
	
begin
	inheritMethod();

	toolbarObj	:=	self.frmToolbar;

	toolbarObj.addButton(self.btnSearch, CMUI_Toolbar.Control_Alignment_Left);
	toolbarObj.addButton(self.btnAddYA, CMUI_Toolbar.Control_Alignment_Left);
	toolbarObj.addButton(self.btnEditYA, CMUI_Toolbar.Control_Alignment_Left);
// TFS 2198 if app.myCurrentUserCan(self.myTerminal, PmAdmYAMaint) then								// PAR #28629
		toolbarObj.addButton(self.btnDeleteAlloc, CMUI_Toolbar.Control_Alignment_Left);
// TFS 2198	endif;																					// PAR #28629

	toolbarObj.addButton(self.btnWhatIf, CMUI_Toolbar.Control_Alignment_Left);
	//toolbarObj.addButton(self.btnSelectAll, CMUI_Toolbar.Control_Alignment_Left);
	toolbarObj.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbarObj.addButton(self.btnYAConfig, CMUI_Toolbar.Control_Alignment_Left);
	toolbarObj.addButton(self.btnYAOstowRules, CMUI_Toolbar.Control_Alignment_Left);
	toolbarObj.addButton(self.btnYAPriority, CMUI_Toolbar.Control_Alignment_Left);
	toolbarObj.addButton(self.btnYATemplate, CMUI_Toolbar.Control_Alignment_Left);
	toolbarObj.addButton(self.btnVDS, CMUI_Toolbar.Control_Alignment_Left);	//28 Feb 2014	NDL	Par 33607
	toolbarObj.addSeperator(CMUI_Toolbar.Control_Alignment_Left);					// 19/03/2009 cnwar2 #19085 - possibly remove these two lines
	toolbarObj.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);		// 19/03/2009 cnwar2 #19085   if refresh becomes unnecessary
	//toolbarObj.addFrame(self.fraShowDisabled, CMUI_Toolbar.Control_Alignment_Left);
	toolbarObj.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	

	
/*	toolbarObj := self.frmToolbar2;

	toolbarObj.addFrame(self.frmToolbarTmpl, CMUI_Toolbar.Control_Alignment_Left);

	toolbarObj.positionToolbarControls();
	toolbarObj.visible := true;*/
	
	// Setup searchToolbar
	toolbarObj := self.frmSearchToolbar;
	toolbarObj.addButton(self.btnSearchCollaps, CMUI_Toolbar.Control_Alignment_Left);
	toolbarObj.addButton(self.btnSearchExpand, CMUI_Toolbar.Control_Alignment_Left);
	toolbarObj.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbarObj.addButton(self.btnSearchTV, CMUI_Toolbar.Control_Alignment_Left);
	toolbarObj.addButton(self.btnResetSearchTV, CMUI_Toolbar.Control_Alignment_Left);
	//toolbarObj.addButton(self.btnCloseSearchTV, CMUI_Toolbar.Control_Alignment_Left);
	toolbarObj.positionToolbarControls();
	toolbarObj.visible := true;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="allowsTableFilters" id="0fddd54f-35aa-4d7a-baa1-131f37428a95">
        <source>allowsTableFilters(_table: Table): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 January 2012	cnwndl1	Initial creation

*/

vars

begin

	return _table = self.tblData;

epilog

end;</source>
