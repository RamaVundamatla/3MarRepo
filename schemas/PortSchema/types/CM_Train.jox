    <JadeMethod name="confirmWagons" id="c4c88814-4b23-4f00-ba1a-ae56cbe7a8b6">
        <updating/>
        <source>confirmWagons( _wagonMoveControl : CMIF_WagonMoveController; _inward : Boolean; _autoPlan : Boolean; _passport : CM_Passport input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	14 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	iter 	: Iterator;
	wagon 	: CM_Wagon;
begin

	if _inward then
		iter := self.allWagonsByOrderInward.createIterator();
	else
		iter := self.allWagonsByOrderOutward.createIterator();
	endif;
	
	while iter.next(wagon) do
		if (_inward and not wagon.confirmed) then
			wagon.confirmWagonInwards( _wagonMoveControl, _autoPlan, _passport);
		elseif (not _inward and not wagon.confirmedOutwards) then
			wagon.confirmWagonOutwards( _wagonMoveControl, _passport);
		endif;
		if _passport.hasErrors then
			return;
		endif;
	endwhile;

	
epilog
	delete iter;
end;
</source>
        <Parameter name="_wagonMoveControl" type="CMIF_WagonMoveController"/>
        <Parameter name="_inward" type="Boolean"/>
        <Parameter name="_autoPlan" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createOrUpdateWagon" id="7e92c4e2-36aa-4555-869f-e737ffd9e001">
        <updating/>
        <source>createOrUpdateWagon( _newWagonId: String; wagonPos : Integer; railLine : CM_RailLine; errorMess : String output) : CM_Wagon updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Mar 2017	cnwsc8	Initial creation
02 Oct 2020 cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
*/

vars
	warningMess 	: String;
	terminal 		: CM_Terminal;
	carrier 		: CM_Carrier;
	wagonClassCode  : String;
	wagonClass 		: CM_WagonClass;
	wagon 			: CM_Wagon;
	loadState 	    : Boolean;
	pxyWagon 	    : CM_Wagon;
	wagonUpdateCtrl : CMIF_WagonUpdateController;
begin
	terminal 		:= app.myPassport.myTerminal;
	carrier 	    := self.myCarrier;
	wagonClassCode  := app.myRoot.getWagonClassViaHookCode(terminal, _newWagonId, carrier);
	if wagonClassCode = null then
		errorMess := app.getErrorString1(Invalid_wagon_class, _newWagonId);
		return null;
	endif;
	
	wagonClass := app.myRoot.allWagonClasses[wagonClassCode];
	if wagonClass = null then
		errorMess := app.getErrorString1(Unrecognis_wagon_class, wagonClassCode);
		return null;
	endif;

	wagon := terminal.getLatestWagonByCode(_newWagonId);
	
	if wagon = null then
		// wagon not known. Create it.
		create wagonUpdateCtrl transient;
		wagonUpdateCtrl.setBasicDetails(CMIF_WagonUpdateController.Mode_Add,	//_mode : Integer;
											railLine,// rake
											self,	//_train : CM_Train;
											wagonPos, //_wagonPosition : Integer;
											false	// isTrainMode
											);	
											
	//	create pxyWagon transient;
		create pxyWagon as wagonClass.getWagonVisitClassToCreate() transient;	//15 Mar 2013	NDL	Par 31278
		pxyWagon.setProxy(	terminal,	//_term : CM_Terminal; 
							_newWagonId,	//_id : String; 
							wagonClass,	//_class : CM_WagonClass;
							self,	//_train : CM_Train;
							self,	//_outTrain : CM_Train;
							null,	//_remark  : String;
							null,	//_maxCargoHeight : Decimal; 
							null,	//_maxCargoWeight : Decimal;
							null,	//_tareWeight : Decimal;
							carrier,	//_carrier : CM_Carrier
							self.myStevedoreReceive,     //02.10.2020 cnwma1 TFS #50112
							self.myStevedoreRelease   //02.10.2020 cnwma1 TFS #50112 
							);  
		
		wagonUpdateCtrl.myProxyWagon := pxyWagon;
		
		app.myPassport.clearErrorsWarnings();
		app.myPassport.setWarningsIgnored(true);
	
		app.myTrxCA.trxCreateWagonFromCMIF(wagonUpdateCtrl, wagon, false, app.myPassport);
		if app.myPassport.hasErrors then
			errorMess := app.myPassport.getAllErrorsWarningsAsString;	// 10 Aug 2012	NDL	Par 29885
			return null;
		endif;
		
		return terminal.getLatestWagonByCode(_newWagonId);
		
	else

		if wagon.myTrainInwards = terminal.getNullTrain then
			// wagon on the null train, so we can move it to this train.
			app.cmsBeginLoad(loadState);
			pxyWagon :=	wagon.pxyCreateUpdateProxy();
			app.cmsEndLoad(loadState);
			pxyWagon.setMyTrain(true, self);
			pxyWagon.setMyTrain(false, self);
			create wagonUpdateCtrl transient;
			wagonUpdateCtrl.setBasicDetails(CMIF_WagonUpdateController.Mode_Update,	//_mode : Integer;
											railLine,// rake
											self,	//_train : CM_Train;
											wagonPos, //_wagonPosition : Integer;
											false	// isTrainMode
											);										
			wagonUpdateCtrl.myProxyWagon := pxyWagon;
			wagonUpdateCtrl.expectedEditionWagon := wagon.edition;
			wagonUpdateCtrl.populateFromExistingWagonAddTi( wagon, null, 0 );
			
			app.myPassport.clearErrorsWarnings();
			app.myPassport.setWarningsIgnored(true);
			app.myTrxUA.trxUpdateWagonFromCMIF(wagonUpdateCtrl, false, app.myPassport);

			if app.myPassport.hasErrors then
				errorMess := app.myPassport.getAllErrorsWarningsAsString;	// 10 Aug 2012	NDL	Par 29885
				return null;
			endif;
			return terminal.getLatestWagonByCode(_newWagonId);
			
		else
			// wagon is here and on a different train.
			errorMess := app.getErrorString2(Wagon_with_alread_exists_train, _newWagonId, wagon.myTrainInwards.code);
			return null;
		endif;
		
	endif;
	
	return null;
					
epilog

	delete wagonUpdateCtrl;
	delete pxyWagon;
	app.cmsEndLoad(loadState);
end;</source>
        <Parameter name="_newWagonId" type="String"/>
        <Parameter name="wagonPos" type="Integer"/>
        <Parameter name="railLine" type="CM_RailLine"/>
        <Parameter name="errorMess" type="String" usage="output"/>
        <ReturnType type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="createToDoTask" id="6a6127db-bdfe-4432-9382-05d24a373ce9">
        <source>createToDoTask(taskDesc : Integer; _wod : CM_WorkOrderToDoDtl): CM_TrainToDoTask;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 November 2022	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen

*/

vars
	toDoTask : CM_TrainToDoTask;
	toDoDesc : CM_ToDoTaskDesc;
	found	 : Boolean;
	passport : CM_Passport;
begin
	passport := app.myPassport;
	
	toDoDesc := app.myRoot.allToDoTaskDescriptions[taskDesc]; // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
	/* // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
	foreach toDoDesc in app.myRoot.allToDoTaskDescriptions where toDoDesc.description.trimBlanks = taskDesc do
		found := true;		//Found it
		break;
	endforeach;
	
	if found then 
	*/
	if toDoDesc &lt;&gt; null then  // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		create toDoTask persistent;
		toDoTask.setForCreate(STATUS_TODO,	toDoDesc, null, passport, self, _wod); // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		self.updateObjectEdition(self);		
		
		return toDoTask;
	else
		return null;
	endif;
epilog

end;</source>
        <Parameter name="taskDesc" type="Integer"/>
        <Parameter name="_wod" type="CM_WorkOrderToDoDtl"/>
        <ReturnType type="CM_TrainToDoTask"/>
    </JadeMethod>
    <JadeMethod name="createTransaction" id="ae0d8fe4-741e-4435-8d5f-959e73e6a16b">
        <source>createTransaction(_type : Integer; _time : TimeStamp; _resourceUsageProxys : CM_ResourceTypeUsageSet input; _task : CM_ToDoTask; _wod : CM_WorkOrderToDoDtl):CMEVT_TrainTransaction;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 November 2009	cnwndl1	Initial creation

*/

vars
	trans : CMEVT_TrainTransaction;
	wod : CM_WorkOrderToDoDtl;
	cmifEventCtrl : CMIF_TrainEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
begin
	/*
	trans := app.createEvent(_type, _time, self.getTerminal(), app.myPassport.userCode, false, false,0).CMEVT_TrainTransaction;
	if trans  &lt;&gt; null then
		trans.setMyTrain(self);
		trans.addResourcesFromProxys(_resourceUsageProxys); // ### TFS CR 57927 TASK 54268 22MAY2023 NAVAB1
		trans.setToDoTask(_task); // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		
		wod := _wod; // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		if wod = null then // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
			wod := trans.getWorkOrderDetail().CM_WorkOrderToDoDtl; // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		endif;
		if wod &lt;&gt; null then // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
			trans.setFromWOD(wod);// ### TFS CR 56814 TASK 56813 07JUL2023 NAVAB1 // ### TFS CR 58083 Task 58552 06JUL2023 NAVAB1
			//trans.setContractId(wod.contractId); // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		endif;	
		//trans.createCharge(app.myPassport);
		app.myPassport.addEventTransactionForDeferUpd(trans,app.myPassport.myTerminal); // ### JIRA 33567 03DEC2024 NAVAB1
	endif;
	*/
	
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - Starts
	create cmifEventCtrl transient;
	cmifEventCtrl.type := _type;
	cmifEventCtrl.dateTime := _time;
	cmifEventCtrl.myTerminal := self.getTerminal();
	cmifEventCtrl.userCode := app.myPassport.userCode;
	cmifEventCtrl.myTrain := self;
	cmifEventCtrl.myToDoTask := _task;
	cmifEventCtrl.myWorkOrderDetail := wod;
	
	if _resourceUsageProxys &lt;&gt; null then
		_resourceUsageProxys.copy(cmifEventCtrl.allResourceUsages);
	endif;
	
	trans := app.createEventUsingCMIF(cmifEventCtrl).CMEVT_TrainTransaction;
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - Ends
	
	return trans;
epilog
	delete cmifEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_time" type="TimeStamp"/>
        <Parameter name="_resourceUsageProxys" type="CM_ResourceTypeUsageSet" usage="input"/>
        <Parameter name="_task" type="CM_ToDoTask"/>
        <Parameter name="_wod" type="CM_WorkOrderToDoDtl"/>
        <ReturnType type="CMEVT_TrainTransaction"/>
    </JadeMethod>
    <JadeMethod name="delete" id="4c4b40ff-cba3-424b-b848-5a0929d1a034">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 January 2021	jlgndl1	Initial creation

*/

vars
	
begin
	if self.isTransient then    //jlier1 JIRA#33496 5/12/24
		return;
	endif;
	
	
	if app.myPassport.isOpsViewEnabled(self.myTerminal) then // ### TFS 51855 06JAN2022 NAVAB1
		self.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_DELETE,BGP_OpsViewWSRequest.OPS_TYPE_TRAIN, self); // ### TFS 51855 06JAN2022 NAVAB1
	endif;	
	
	self.resetAuditsDuringDelete();	//25 Jan 2021	NDL	TFS 50152

end;</source>
    </JadeMethod>
    <JadeMethod name="departureProcess" id="14ef57fa-279f-467c-a45b-17682edc9608">
        <updating/>
        <source>departureProcess(_cmifRakeRegion : CMIF_RakeRegion; _trainDepartEvent : CMEVT_TrainTransaction output) updating;
/*
----------   ----------  --------------------------------------------------
Created:	13 November 2006 By cnwth2

Changed On  Changed By  Reason
						PAR 18861 - changed setting of myTerminalDeperated to use myTerminal reference (cnwar2, cnwrs2)
30 Aug 2012	cnwcs5		par 30292 - use updateObjectEdition instead of updateEdition 
16 Dec 2013	cnwrs1		Par 33035 - add CamsDateTime to CM_EventTransaction
13 Mar 2019	jlgsl4		TFS 40360 - NXL - KiwiRail EDI message
11 Apr 2023	navcs2		ChangeRequest 55440:[54990]: EUP - Release Cargo Work Order - Enhancement
12 Apr 2023 navdap1		TFS 57362 CUX Changes to Outgoing Message Formats
----------  ----------  --------------------------------------------------
*/
vars
	wagon 			  : CM_Wagon;
	ti 				  : CM_TrackedItem;
	trainDepartEvent  : CMEVT_TrainTransaction;
	wagMoveController : CMIF_WagonMoveController;
	woRelease		  : CM_WorkOrderDtl;
begin
	
	if self.myTerminalDeparted &lt;&gt; null then // PAR 19710 already departed.
		return;
	endif;
	
	self.myTerminalDeparted := self.myTerminal;		// swap the collection
	self.myTerminal 		:= null;
	self.status				:= TrainStatus_Departed; //navsp1 25MAY2022 TFS#53619
	
	//30 Nov 2009	NDL	CCMS 1013 Par 21519
	if not self.isTransient then
		if self.myTerminalDeparted &lt;&gt; null then
			if self.myTerminalDeparted.myEdiConfig &lt;&gt; null then
				self.myTerminalDeparted.myEdiConfig.removeTrainFromProcessing(self);
			endif;
		endif;
	endif;
	
	// Leave as this for now because most clients are not using train functionality yet.
	// When rail simplication is done - review this to alloe user to enter actual
	// departure date/time.
	if not  self.departureDT.isValid() then
		//25 Feb 2021	NDL TFS 50837
		if _cmifRakeRegion &lt;&gt; null and _cmifRakeRegion.effectiveTimeStamp.isValid then
			self.departureDT := _cmifRakeRegion.effectiveTimeStamp;
		else
			self.departureDT := app.actualTimeServer;
		endif;
		trainDepartEvent := self.createTransaction(EVT_TrainDepart, self.departureDT, null, null, null);	// 02 Nov 2009	NDL Par 21519
		if trainDepartEvent &lt;&gt; null then
			_trainDepartEvent := trainDepartEvent;
		endif;
	endif;
	if trainDepartEvent &lt;&gt; null then // TFS 40360
		self.setupBGPRequest(trainDepartEvent); // TFS 40360
	endif; // TFS 40360
	// PAR 19710
	self.allTIsReleased.clear();
	
	//26 Feb 2012	NDL	TFS 50837
	create wagMoveController transient;
	if _cmifRakeRegion &lt;&gt; null and _cmifRakeRegion.effectiveTimeStamp.isValid then	
		wagMoveController.setEffectiveTimeStampOverride( _cmifRakeRegion.effectiveTimeStamp );
	else
		wagMoveController.autoSetEffectiveTimeStamp();
	endif;
	
	foreach wagon in self.allWagonsByOrderOutward discreteLock do
		wagon.departureProcess(wagMoveController,trainDepartEvent);
		if trainDepartEvent &lt;&gt; null then
			_trainDepartEvent := trainDepartEvent;
		endif;
		foreach ti in wagon.allTIsReleased discreteLock do
			if not self.allTIsReleased.includes(ti) then
				self.allTIsReleased.add(ti);
				foreach woRelease in allWOReleases do										//11.04.2023	navcs2  #55440:[54990]
					if woRelease.CM_WodRelease.allActionedTIs.includes(ti) then				//11.04.2023	navcs2  #55440:[54990]
						woRelease.CM_WorkOrderTIDtl.setTIComplete(ti, null);				//11.04.2023	navcs2  #55440:[54990]
					endif;																	//11.04.2023	navcs2  #55440:[54990]
				endforeach;																	//11.04.2023	navcs2  #55440:[54990]
			endif;
		endforeach;
	endforeach;
	
	self.updateObjectEdition(self);	// par 30292
	
	// ### TFS 55215 23Nov2022 NAVPW1
	CMIF_TrxActionTransport@createAction(null, self, null, CMIF_TrxActionTransport.ProcessTrainDeparture, app.myPassport);	// TFS 57362
	// ### TFS 55215 23Nov2022 NAVPW1
	
	if app.myPassport.isOpsViewEnabled(self.myTerminal) then 															 // ### TFS 51855 26MAY2022 NAVAB1
		self.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,BGP_OpsViewWSRequest.OPS_TYPE_TRAIN, self); // ### TFS 51855 26MAY2022 NAVAB1
	endif;	
epilog
	delete wagMoveController;
end;</source>
        <Parameter name="_cmifRakeRegion" type="CMIF_RakeRegion"/>
        <Parameter name="_trainDepartEvent" type="CMEVT_TrainTransaction" usage="output"/>
    </JadeMethod>
    <JadeMethod name="dwellTime" id="74c23002-3f2a-4737-8515-ad894d0ebf06">
        <source>dwellTime() : Integer;
//Returns the time in minutes between the creation of this
//job and now. Indicates how long a train has been inside
//the terminal
vars
	aT	:	Time;
	isPos	:	Integer;
	numDays	:	Integer;
	mins : Integer;
begin
	
	// PAR 24140
	if self.departureDT.isValid then
		if self.arrivalDT.isValid() then
			aT := self.departureDT.differenceAsTime(self.arrivalDT, isPos, numDays);
		else
			aT := self.departureDT.differenceAsTime(self.createdTime, isPos, numDays);
		endif;
	else
// PAR 24140		aT := app.actualTimeServer.differenceAsTime(self.createdTime, isPos, numDays);
		if self.arrivalDT.isValid() then
			aT := app.actualTimeServer.differenceAsTime(self.arrivalDT, isPos, numDays);
		else
			aT := app.actualTimeServer.differenceAsTime(self.createdTime, isPos, numDays);
		endif;
	endif;
	mins :=  (numDays * 24 * 60) + (aT.hour * 60) + aT.minute + 1;
	return mins;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="erase" id="d3cc33aa-de54-457a-8bb6-f00b96c417ef">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
/*
----------   ----------  --------------------------------------------------
Created:	18 June 2007 By cnwth2

Purpose:	

Changed On  Changed By  Reason
26/06/2009	consw1		Par 20132 - Wagons are incorrectly deleted when associated Train is deleted	
----------  ----------  --------------------------------------------------
*/
vars

	tmpTerminal	: CM_Terminal;
	
	//15 Jul 2016	NDL	TFS 2329
	iter : Iterator;
	cmqfTL : CMQF_TrainLoadListTIs;
	cmqfTrain : CMQF_Train;
	deleteArray : ObjectArray;
	
begin
	self.allWagonsByIdInward.clear();//disassociate wagons first
	self.allWagonsByIdOutward.clear();
	self.allWagonsByOrderInward.clear();
	self.allWagonsByOrderOutward.clear();
	
	//09 Nov 2009	NDL	Par 21519
	if not self.isTransient then
		tmpTerminal := self.myTerminal;
		if tmpTerminal &lt;&gt; null then
			if tmpTerminal.myEdiConfig &lt;&gt; null then
				tmpTerminal.myEdiConfig.removeTrainFromProcessing(self);
			endif;
		endif;
	endif;
	
	//15 Jul 2016	NDL	TFS 2329
	iter := CMQF_TrainLoadListTIs.instances.createIterator;
	while iter.next(cmqfTL) do
		if cmqfTL.allTrains.includes(self) then
			cmqfTL.allTrains.remove(self);
		endif;
	endwhile; 
	delete iter;
	
	//11 Jun 2019	NDL	Unit Testing found these corrupt cmqf s
	iter := CMQF_Train.instances.createIterator;
	create deleteArray transient;
	while iter.next(cmqfTrain) do
		if cmqfTrain.getMyTrain = self then
			deleteArray.add( cmqfTrain );
		endif;
	endwhile; 
	if not deleteArray.isEmpty then
		deleteArray.purge();
	endif;
	delete iter;

	inheritMethod(_eraseLevel);
	
epilog
	delete iter;
	delete deleteArray;
end;


</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAllLcs" id="391dd3fa-f468-4a14-8557-b9e32c93c5d6">
        <source>getAllLcs( _inward : Boolean; _allLCs : CM_LCSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2021	navndl1	Initial creation	TFS 50906

*/

vars

	wagon : CM_Wagon;
	iter : Iterator;
	wagLC : CM_WagonController;

begin

	if _inward then
		iter := self.allWagonsByIdInward.createIterator;
	else
		iter := self.allWagonsByIdOutward.createIterator;
	endif;
	
	while iter.next( wagon ) do
		foreach wagLC in wagon.allLocationsControllers discreteLock do
			_allLCs.addNoDuplicates( wagLC, false );
		endforeach;
	endwhile;
	
epilog

	delete iter;

end;</source>
        <Parameter name="_inward" type="Boolean"/>
        <Parameter name="_allLCs" type="CM_LCSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllNotifiedTIsByCargoTypeId" id="04ad419d-db62-4639-aee6-e71f5c454963">
        <source>getAllNotifiedTIsByCargoTypeId( _allNotifiedTIsByCargoTypeId : CM_TIByCargoTypeIdDict io );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 November 2009	cnwndl1	Initial creation

*/

vars

	iter : Iterator;
	wagon : CM_Wagon;
	iter2 : Iterator;
	ti : CM_TrackedItem;
	
begin

	iter := self.allWagonsByIdInward.createIterator;
	while iter.next( wagon ) do
	
		iter2 := wagon.allNotifiedTIsByCargoID.createIterator;
		while iter2.next( ti ) do
			_allNotifiedTIsByCargoTypeId.add(ti);
		endwhile;
		delete iter2;
	
	endwhile;
	delete iter;
	
epilog

	delete iter;
	delete iter2;

end;</source>
        <Parameter name="_allNotifiedTIsByCargoTypeId" type="CM_TIByCargoTypeIdDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAllRailAreas" id="1e332f6e-a6f3-46ea-9b41-ed216fcc0d75">
        <source>getAllRailAreas(_allRailAreas : CM_TAByIdDict input);
/*
----------   ----------  --------------------------------------------------
Created:	13 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	wagon			: CM_Wagon;
	railArea		: CM_Rail;
begin
	_allRailAreas.clear();
	foreach wagon in self.allWagonsByIdInward do
		if wagon.myRailLine = null then
			continue;
		endif;
		railArea := wagon.myRailLine.myRailArea;
		if railArea &lt;&gt; null and (not _allRailAreas.includes(railArea)) then
			_allRailAreas.add(railArea);
		endif;
	endforeach;

end;


</source>
        <Parameter name="_allRailAreas" type="CM_TAByIdDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllTrackedItems" id="3dcb166d-7fdb-4735-8bfc-13c333f8318e">
        <source>getAllTrackedItems(isInward : Boolean; allTrackedItems : CM_TIArray input);

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
22 May 2009			cnwmd1	Initial creation
21 October 2024		jlizm1	TFS 65987 Error 1308 when iterating collections

*/

vars
	wagon 		: CM_Wagon;
	
begin
	
	if isInward then
		if self.allTIsReceived.isEmpty() then
			foreach wagon in self.allWagonsByIdInward discreteLock do
				wagon.getAllTrackedItems(true, allTrackedItems, wagon.confirmed);
			endforeach;
		else
			self.allTIsReceived.copyNoDups(allTrackedItems);
			allTrackedItems.removeInvalidObjects(); //jlier1 JIRA#33496 5/12/24
		endif;
	else
		if self.allTIsReleased.isEmpty() then
			foreach wagon in self.allWagonsByIdOutward discreteLock do
				wagon.getAllTrackedItems(false, allTrackedItems, wagon.confirmedOutwards);
			endforeach;
		else
			self.allTIsReleased.copyNoDups(allTrackedItems);
			allTrackedItems.removeInvalidObjects();  //jlier1 JIRA#33496 5/12/24
		endif;
	endif;
	
//	
	
epilog

end;</source>
        <Parameter name="isInward" type="Boolean"/>
        <Parameter name="allTrackedItems" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllTrackedItemsProposed" id="3324a5b9-4a17-4269-a7a0-2b5442ddb388">
        <source>getAllTrackedItemsProposed(_tis : CM_TIArray input);
// ---------------------------------------------------------------------------
// Created:     March 2010 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// PAR 21977 23113
//12 Feb 2025 		navbs1	  		Bug MTN-33685: NXL - Train Enquiry Screen - Error 1308 Encountered 
// ---------------------------------------------------------------------------

vars
	wagon : CM_Wagon;
	outwardWagons : CM_WagonArray;
begin
	
	create outwardWagons transient;													//12.02.2025 navbs1 #33685
	self.allWagonsByOrderOutward.copy(outwardWagons);								//12.02.2025 navbs1 #33685
	//foreach wagon in self.allWagonsByOrderOutward discreteLock do					//12.02.2025 navbs1 #33685
	foreach wagon in outwardWagons discreteLock do									//12.02.2025 navbs1 #33685

		wagon.getAllTrackedItems(false, _tis, false);
		wagon.getAllTrackedItemsPlanned(_tis, false, QUEUE_MODE);
		wagon.getAllTrackedItemsPlanned(_tis, false, PLANNING_MODE);
		
	endforeach;

epilog 
	delete outwardWagons;															//12.02.2025 navbs1 #33685
end;</source>
        <Parameter name="_tis" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllWLEs" id="57922516-1b56-4dbc-84b7-17e9317052c7">
        <source>getAllWLEs(_wleArray: CM_WLEArray input);
// ---------------------------------------------------------------------------
// Created:     09 June 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	wle : CM_WorkListEntry;
	job : CM_Job;
begin

	if self.myJobSheet = null then // PAR 19987
		return;
	endif;

	foreach job in self.myJobSheet.allJobsByOrder discreteLock do
		job.workListEntries.copy(_wleArray);
	endforeach;
	
epilog

end;</source>
        <Parameter name="_wleArray" type="CM_WLEArray" usage="input"/>
