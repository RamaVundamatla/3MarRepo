    <JadeMethod name="isEventTypeToBeProcessed" id="ebb2a24e-eb5f-40a7-a815-31da1ca96d64">
        <source>isEventTypeToBeProcessed(_camProtocol: CM_CamProtocol; _trans: CM_EventTransaction): Boolean;
/*

Purpose: Suzano Confirmation is triggered by the receipt of an EDI File

Parameters:			

Return Value:		

Date		Who		Reason
05 August 2014	cnwgb1	Initial creation CCMS 2346 PAR 34561

*/

vars

begin
    return _trans.type = EVT_EDIFileReceived;

epilog

end;</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_trans" type="CM_EventTransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="postSpecialFileName" id="ff1cc544-7e0d-4db5-833b-b88fc9da3fdc">
        <source>postSpecialFileName(_camTaskHistory: CM_CamTaskHistory);
//
//19 Oct 2015	cnwrs1	Par37064 special file name
//27 Oct 2015	cnwrs1	Par37082 special file name longer than 30 chars
//17 Nov 2015	cnwrs1	Par37191 worded file name
//
vars
	xmlString : String;
	xmlDoc : JadeXMLDocument;
	xmlParser : JadeXMLDocumentParser;
	xmlElement : JadeXMLElement;
	fileName : String;
	camTaskHistory : CM_CamTaskHistory;
begin
	on JadeXMLException do self.handleXMLExceptions(exception);
	xmlString := _camTaskHistory.getRawDataString();
	if xmlString = null then 
		return;
	endif;
	create xmlParser transient;
	create xmlDoc transient;
	xmlParser.parseDocumentString(xmlDoc,xmlString);
	xmlElement:=xmlDoc.findElementByTagName("ns0:ID");
	
	if xmlElement &lt;&gt; null and xmlElement.textData &lt;&gt; null then
		fileName := "Confirmation_"&amp;xmlElement.textData;
		camTaskHistory := _camTaskHistory;
		fileName := fileName.removeInvalidChars;
		if fileName.length &lt; 56 then
			camTaskHistory.setFileName(fileName&amp;".xml");
		else
			camTaskHistory.setFileName(fileName[1:56]&amp;".xml");
		endif;
	endif;
epilog
	delete xmlDoc;
	delete xmlParser;
end;
</source>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory"/>
    </JadeMethod>
    <JadeMethod name="processEvent" id="5523d3cc-8017-499d-b317-a223df38d629">
        <updating/>
        <source>processEvent(_transaction: CM_EventTransaction; _camProtocol: CM_CamProtocol; _camAgent: CM_CamControllerAgent input; _camFile: CM_CamFile input) updating;
/*

Purpose: Create the XML Confirmation Message

Parameters:			

Return Value:		

Date		Who		Reason
04 August 2014	cnwgb1	Initial creation CCMS 2346 PAR 34561
//25 Aug 2014	cnwrs1	Par 34816 Log message if we return and do nothin'
//27 Aug 2014	cnwrs1	Par 34820 change FileProcessed to File Processed
*/

constants 
    Namespace = "http://CECOL.suzano.com.br/LE/Confirmation";

vars
   	ediRecievedEvent :CMEVT_EDIFileReceived;
    camMessage : CM_CamMessage;
    strMsg : String;
    xmlDoc : JadeXMLDocument;
    attrib : JadeXMLAttribute;
    rootElem : JadeXMLElement;
    element : JadeXMLElement;
    messageElement : JadeXMLElement;
	eventType : CM_EventType;
begin
	_camAgent.writeDebugLog(class.name&amp;'::'&amp;method.name&amp;" process "&amp;_transaction.type.asStringJMT);
    
    if _transaction = null then
		if _camAgent.logExcludedTransactions then
			_camAgent.logReasonForExclusion(_transaction, 'There is no Event transaction');
			return;
		endif;
	endif;
	if not _transaction.isKindOf(CMEVT_EDIFileReceived) then
        //Noooo
		if _camAgent.logExcludedTransactions then
			eventType := app.myRoot.allEventTypesByType[_transaction.type];
			if eventType &lt;&gt; null then
				strMsg := eventType.name;
			else
				strMsg := _transaction.type.asStringJMT;
			endif;
			_camAgent.logReasonForExclusion(_transaction, 'The Event '&amp;strMsg&amp;' is not an EDI File Receive Event');
		endif;
		return;
    endif;
	
    ediRecievedEvent := _transaction.CMEVT_EDIFileReceived;
 	
	camMessage := self.getCamMessage(_camFile, null, null, CODECO_GATEOUT, _camProtocol.singleContainerPerBGM);
    
    create xmlDoc transient;
    xmlDoc.outputDeclaration := true;
    //encoding
    rootElem := xmlDoc.addElementNS(Namespace, "ns0:Confirmation");
    rootElem.addAttribute("xmlns:ns0", Namespace );
    element := rootElem.addElementNS(Namespace, "ns0:Status");
    element.addText("ACK");
    element := rootElem.addElementNS(Namespace, "ns0:Trading_partner_code");
    element.addText( "4103");
    element := rootElem.addElementNS(Namespace, "ns0:ID");
    element.addText(ediRecievedEvent.fileNumber);
    element := rootElem.addElementNS(Namespace, "ns0:Interface");
    if ediRecievedEvent.fileNumber &lt;&gt; null then
        element.addText(ediRecievedEvent.fileNumber[1:2]);
    else
        element.addText( "XX"); //Must not happen
    endif;
    element := rootElem.addElementNS(Namespace, "ns0:Data_Hora");
    element.addText(ediRecievedEvent.createdTime.formatAsYYYYMMDDHHmmSS());
    element := rootElem.addElementNS(Namespace, "ns0:Receive");
    element.addText("X");
    messageElement := rootElem.addElementNS(Namespace, "ns0:Message");
    element := messageElement.addElementNS(Namespace, "ns0:Message_code");
    element.addText("0000");
    element := messageElement.addElementNS(Namespace, "ns0:Description");
    element.addText("File Processed");

    strMsg := xmlDoc.writeToString();
    self.addMessage(camMessage.group3, strMsg );
    
epilog
    delete xmlDoc;
end;</source>
        <Parameter name="_transaction" type="CM_EventTransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
    </JadeMethod>
