    <JadeMethod name="getDefaultFileSuffix" id="aa0c0d3d-44d1-4589-bf1b-52f1c8d93e4d">
        <source>getDefaultFileSuffix() : String;
/* 
---------------------------------------------------------------------------
 Created:     J Harliwich               

 Purpose:     MES1011

 Parameters:  None

 Returns:     dat   csv   xml 

 Changed On   Changed By  Reason
 ----------   ----------  --------------------------------------------------
 
 ---------------------------------------------------------------------------
*/

vars

begin
	if transferFileFormat &lt;&gt; null then 
		return transferFileFormat;	// will be csv or xml
	endif;
	return 'dat';
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="5cf6a863-9a7c-4997-9b33-db3acb34ff6f">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     16 April 2014 by cnwdb2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16 Apr 2014	cnwdb2		PAR #33977  
// ---------------------------------------------------------------------------
// 30 Apr 2015	cnwrs1	Par35784 - increased exclusion reason logging to include non excluded
// 26 Oct 2017	jlgdap1		TFS 7555 Correct the value returned for ETRow_OutputFileFormat - was returning the same as ETRow_FileSuffix
// 12 Jul 2022	jlizm1		TFS 53935 FTP Entity displaying as class/oid

vars

begin
	if _attrName = ETRow_CamGroup then
		if camGroup &lt;&gt; null then
			return camGroup.code ; 
		endif;
		return null;
	endif ; 
	
	if _attrName = ETRow_FirstRunDate then	
		return firstRunDateTime.shortCurrentLocaleFormat.String;	
	endif  ; 
	
	if _attrName = ETRow_LastRunDate then
		return lastRunDateTime.shortCurrentLocaleFormat.String;  
	endif ; 
	
	if _attrName = ETRow_ProtocolDesc then
		if protocolDesc &lt;&gt; null then
			return protocolDesc.name ; 
		endif;
		return null;
	
	endif;
	
	if _attrName = ETRow_EmailAddress then	
		if myEmailEntity &lt;&gt; null then
			return myEmailEntity.name ; 
		endif;
		return null;
	endif ; 
	
	if _attrName = ETRow_NoCrLf then 
		return noCrLfInMessage.String ; 
	endif ;
	
	 if _attrName = ETRow_OutputFileFormat then	
		//return fileSuffix ; 							// TFS 7555
		return transferFileFormat ; 					// TFS 7555
	 endif  ;
	
	if _attrName  = ETRow_MyQFCamTransaction then
		if myQFCamTransactionTemplate &lt;&gt; null then
			return myQFCamTransactionTemplate.queryDesc ; 
		endif  ;
		return "" ; 
	endif  ;
	
	if _attrName = ETRow_OutputFileRollOver then
		return transferFileRollOver.String ; 
	endif ; 
	
	
	if _attrName = ETRow_OutputFileSeqLength then
		return transferFileSeqLength.String ; 
	endif	;
	
	if _attrName = ETRow_OutputFileStartSeq then
		return transferFileStartSeq.String ; 
	endif	;
	
	if _attrName = ETRow_PrcNullVoyageTrans then
		return prcNullVoyageTransaction.String ; 
	endif	;
	
	if _attrName = ETRow_FTPEntity then
		if myFTPEntity &lt;&gt; null then
			return myFTPEntity.id;
		endif;
		return null; 
	endif;
	
	if _attrName = ETRow_ElementSeperator then
		return elementSeparator; 
	endif; 
	
	if _attrName = ETRow_SubElementSeperator then
		return subElementSeparator; 
	endif;
	if _attrName = ETRow_LogExcludeTransactions then
		return self.getLogExcludedTransactions.String; 
	endif;
	if _attrName = ETRow_LogIncludeTransactions then
		return self.getLogIncludedTransactions.String; 
	endif;
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDsiplayNameDate" id="ae00e618-9544-4cf9-b1e2-ab9f8f171ed4">
