	xdbFeature.setupAndBuildSet(CM_ReserveTI::getAvailabilityGradesIntegers.name, "CM_ReserveTI", "getAvailabilityGrades", "", _features);
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_ReserveTI::getTotalOutstanding.name, "CM_ReserveTI", "getTotalOutstanding", "", _features);
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_ReserveTI::myInstructions.name, "CM_ReserveTI", "myInstructions", "", _features);		//03.10.2022 navtnr20 TFS 54967
