    <JadeMethod name="extractMethod" id="e08a2cd7-3f21-44ac-bfe0-43fba7f92492">
        <source>extractMethod(_outputText : String; _devMethod : DEV_Method) : String protected;
/*

Purpose:			Returns a string representing an extracted method

Parameters:			_outputText:	Text to output
					_devMethod:		The method we need to extract

Return Value:		Concatenated string representing method

Date		Who		Reason
15 November 2021	navpw1	Initial creation TFS: 52202

*/

begin
	if _outputText.length = 0 then
		return _outputText &amp; _devMethod.name &amp; CrLf &amp; "{" &amp; CrLf &amp; _devMethod.desc &amp; CrLf &amp; "}" &amp; CrLf;
	else
		return _outputText &amp; CrLf &amp; _devMethod.name &amp; CrLf &amp; "{" &amp; CrLf &amp; _devMethod.desc &amp; CrLf &amp; "}" &amp; CrLf;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_outputText" type="String"/>
        <Parameter name="_devMethod" type="DEV_Method"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="extractMethodSource" id="06954f25-ac89-4662-80d2-6b4305556dda">
        <source>extractMethodSource(_outputText, _methodSource : String; _devClass : DEV_Class) : String protected;
/*

Purpose:			Adds method data to the output text string for a method source. 

Parameters:			_outputText: Text to output
					_methodSource: Source to get methods from for extract
					_devClass: Class to use to get methods from

Return Value:		Concatenated string represeting a method source subsection

Date		Who		Reason
15 November 2021	navpw1	Initial creation TFS: 52202

*/

vars
	wroteHeaderLine : Boolean;
	devMethod		: DEV_Method;
	outputText		: String;
	methods 		: String;
	
begin
	outputText := _outputText; //Set local outputText var to passed in parameter

	foreach devMethod in _devClass.allMethods where devMethod.methodSource = _methodSource do
		methods := self.extractMethod(methods, devMethod); //Add the method to the methods string
		
	endforeach;
	
	if methods.length &gt; 0 then
		outputText &amp;= CrLf &amp; self.getDelimiter() &amp; _methodSource; //Add the section title to the outputText string
		outputText &amp;= CrLf &amp; methods;
		
	endif;
	
	return outputText; //Return the outputText String

end;</source>
        <access>protected</access>
        <Parameter name="_outputText" type="String"/>
        <Parameter name="_methodSource" type="String"/>
        <Parameter name="_devClass" type="DEV_Class"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="extractSection" id="b91811c6-fdbb-4fc2-82ef-ca5a795f3208">
        <source>extractSection(_outputFile : File io);
/*

Purpose:			Extracts the classes section to file

Parameters:			_outputFile: File to write output string/line to

Return Value:		

Date		Who		Reason
15 November 2021	navpw1	Initial creation TFS: 52202

*/

vars
	outputText		: String;
	wroteHeaderLine : Boolean;
	devClass		: DEV_Class;
	devMethod		: DEV_Method;
	
begin

	outputText := "typeSources";
		
	foreach devClass in self.allClasses where devClass.isInterface = false do
		if devClass.allMethods.size = 0 then 
			continue;
		endif;
		
		outputText &amp;= CrLf &amp; self.getDelimiter() &amp; devClass.name &amp; " ("; //Append method start to string
		
		outputText := self.extractMethodSource(outputText, "jadeMethodSources", devClass);
		_outputFile.writeString(outputText); //Append jadeMethodSources sub section out to file. Stops the string becoming too long
		outputText := "";
		
		outputText := self.extractMethodSource(outputText, "externalMethodSources", devClass);
		_outputFile.writeString(outputText); //Append externalMethodSources sub section out to file. Stops the string becoming too long
		outputText := "";
		
		outputText := self.extractMethodSource(outputText, "webServicesMethodSources", devClass);
		_outputFile.writeString(outputText); //Append webServicesMethodSources sub section out to file. Stops the string becoming too long
		outputText := "";
		
		outputText &amp;= CrLf &amp; self.getDelimiter() &amp; ")"; //Append class ending tag
		
	endforeach;

	foreach devClass in self.allClasses where devClass.isInterface = true do
		if devClass.allMethods.size = 0 then 
			continue;
		endif;
		
		outputText &amp;= CrLf &amp; self.getDelimiter() &amp; devClass.name &amp; " ("; //Append method start to string
		
		outputText := self.extractMethodSource(outputText, "jadeMethodSources", devClass);
		_outputFile.writeString(outputText); //Append jadeMethodSources sub section out to file. Stops the string becoming too long
		outputText := "";
		
		outputText := self.extractMethodSource(outputText, "externalMethodSources", devClass);
		_outputFile.writeString(outputText); //Append externalMethodSources sub section out to file. Stops the string becoming too long
		outputText := "";
		
		outputText := self.extractMethodSource(outputText, "webServicesMethodSources", devClass);
		_outputFile.writeString(outputText); //Append webServicesMethodSources sub section out to file. Stops the string becoming too long
		outputText := "";
		
		outputText &amp;= CrLf &amp; self.getDelimiter() &amp; ")"; //Append class ending tag
		
	endforeach;
	
	_outputFile.writeString(outputText &amp; CrLf); //Write out to file
	
end;</source>
        <Parameter name="_outputFile" type="File" usage="io"/>
    </JadeMethod>
    <JadeMethod name="extractTypeDefinitionSection" id="3048b6f1-0f43-4162-b3eb-58ae0b164590">
        <source>extractTypeDefinitionSection(_outputFile : File io);
/*

Purpose:			Extracts the classes section to file

Parameters:			_outputFile: File to write output string/line to

Return Value:		

Date		Who		Reason
30 November 2021	navpw1	Initial creation TFS: 52202

*/

vars
	outputText				: String;
	wroteHeaderLine			: Boolean;
	devClass				: DEV_Class;
	devAttribute			: DEV_Attribute;
	devReference			: DEV_Reference;
	devMethod				: DEV_Method;
	devExternalMethod 		: DEV_ExternalMethod;
	devConstant				: DEV_ClassConstant;
	devEventMethodMapping 	: DEV_EventMethodMapping;
	headerLineWritten		: Boolean;
	
begin
	outputText := self.name;
	
	foreach devClass in self.allClasses where devClass.isInterface = false do
		outputText &amp;= CrLf &amp; self.getDelimiter() &amp; devClass.name &amp; " completeDefinition" &amp; CrLf &amp; self.getDelimiter() &amp; "("; //Append method start to string
		
		if devClass.documentationTextData &lt;&gt; null then
			outputText &amp;= CrLf &amp; self.getDelimiter() &amp; "documentationText" &amp; CrLf &amp; "`" &amp; devClass.documentationTextData &amp; "`" &amp; CrLf;				
		endif;
		
		if devClass.hasTimeStamp() &lt;&gt; null then
			outputText &amp;= CrLf &amp; self.getDelimiter() &amp; self.getDelimiter() &amp; "setModifiedTimeStamp " &amp; devClass.getLastModifiedTimeStamp();
		endif;
		
		if devClass.webServicesClassPropertiesText &lt;&gt; null then
			outputText &amp;= CrLf &amp; devClass.webServicesClassPropertiesText;
		endif;
		
		if devClass.allConstants.size &gt; 0 then
			outputText &amp;= CrLf &amp; self.getDelimiter() &amp; "constantDefinitions";
			foreach devConstant in devClass.allConstants do
				outputText &amp;= CrLf &amp; self.getDelimiter() &amp; self.getDelimiter() &amp; (devConstant.name &amp; ":").cnEcPadTrailing(31, " ") &amp; devConstant.type &amp; " = ";
				
				if devConstant.type = "String" then
					outputText &amp;= devConstant.delimiter &amp; devConstant.value &amp; devConstant.delimiter;
				else
					outputText &amp;= devConstant.value;
				endif;
				
				if devConstant.miscData &lt;&gt; null then
					outputText &amp;=  " " &amp; devConstant.miscData &amp; ";";
				else
					outputText &amp;= ";";
				endif;
				
				if devConstant.documentationTextData &lt;&gt; null then
					outputText &amp;= CrLf &amp; self.getDelimiter() &amp; "documentationText" &amp; CrLf &amp; "`" &amp; devConstant.documentationTextData &amp; "`" &amp; CrLf;
				endif;
				
				if devConstant.hasTimeStamp() then
					outputText &amp;= CrLf &amp; self.getDelimiter() &amp; self.getDelimiter() &amp;  "setModifiedTimeStamp " &amp; devConstant.getLastModifiedTimeStamp();
				endif;
			endforeach;
		endif;
		
		if devClass.allAttributes.size &gt; 0 then
			outputText &amp;= CrLf &amp; self.getDelimiter() &amp; "attributeDefinitions";
			foreach devAttribute in devClass.allAttributes do
				
				if devAttribute.length = 0 then
					outputText &amp;= CrLf &amp; self.getDelimiter() &amp; self.getDelimiter() &amp; (devAttribute.name &amp; ":").cnEcPadTrailing(31, " ") &amp; devAttribute.type &amp; " " &amp; devAttribute.miscData &amp; ";";
				elseif devAttribute.precision &lt;&gt; 0 then
					outputText &amp;= CrLf &amp; self.getDelimiter() &amp; self.getDelimiter() &amp; (devAttribute.name &amp; ":").cnEcPadTrailing(31, " ") &amp; devAttribute.type &amp; "[" &amp; devAttribute.length.String &amp; "," &amp; devAttribute.precision.String &amp; "]" &amp; " " &amp; devAttribute.miscData &amp; ";";
				else
					outputText &amp;= CrLf &amp; self.getDelimiter() &amp; self.getDelimiter() &amp; (devAttribute.name &amp; ":").cnEcPadTrailing(31, " ") &amp; devAttribute.type &amp; "[" &amp; devAttribute.length.String &amp; "]" &amp; " " &amp; devAttribute.miscData &amp; ";";
				endif;
				
				if devAttribute.documentationTextData &lt;&gt; null then
					outputText &amp;= CrLf &amp; self.getDelimiter() &amp; "documentationText" &amp; CrLf &amp; "`" &amp; devAttribute.documentationTextData &amp; "`" &amp; CrLf;
				endif;
				
				if devAttribute.hasTimeStamp() then
					outputText &amp;= CrLf &amp; self.getDelimiter() &amp; self.getDelimiter() &amp;  "setModifiedTimeStamp " &amp; devAttribute.getLastModifiedTimeStamp();
				endif;
			endforeach;
		endif;
		
		if devClass.allReferences.size &gt; 0 then
			outputText &amp;= CrLf &amp; self.getDelimiter() &amp; "referenceDefinitions";
			foreach devReference in devClass.allReferences do
				outputText &amp;= CrLf &amp; self.getDelimiter() &amp; self.getDelimiter() &amp; (devReference.name &amp; ":").cnEcPadTrailing(31, " ") &amp; devReference.type &amp; devReference.miscData &amp; ";";
				
				if devReference.documentationTextData &lt;&gt; null then
					outputText &amp;= CrLf &amp; self.getDelimiter() &amp; "documentationText" &amp; CrLf &amp; "`" &amp; devReference.documentationTextData &amp; "`" &amp; CrLf;
				endif;
				
				if devReference.hasTimeStamp() then
					outputText &amp;= CrLf &amp; self.getDelimiter() &amp; self.getDelimiter() &amp;  "setModifiedTimeStamp " &amp; devReference.getLastModifiedTimeStamp();
				endif;
			endforeach;
		endif;
		
		if devClass.allMethods.size &gt; 0 then
			outputText &amp;= CrLf &amp; " ";
		endif;
		
		if devClass.allMethods.size &gt; 0 then
			foreach devMethod in devClass.allMethods where devMethod.methodSource = "jadeMethodSources" do
				if not headerLineWritten then
					outputText &amp;= CrLf &amp; self.getDelimiter() &amp; "jadeMethodDefinitions";
					headerLineWritten := true;
				endif;
				outputText &amp;= CrLf &amp; self.getDelimiter() &amp; self.getDelimiter() &amp;  devMethod.methodSignature;
				
				if devMethod.documentationTextData &lt;&gt; null then
					outputText &amp;= CrLf &amp; self.getDelimiter() &amp; "documentationText" &amp; CrLf &amp; "`" &amp; devMethod.documentationTextData &amp; "`" &amp; CrLf;
				endif;
				
				if devMethod.hasTimeStamp() then
					outputText &amp;= CrLf &amp; self.getDelimiter() &amp; self.getDelimiter() &amp;  "setModifiedTimeStamp " &amp; devMethod.getLastModifiedTimeStamp();
				endif;
			endforeach;
		endif;
		
		headerLineWritten := false;
		
		if devClass.allExternalMethods.size &gt; 0 then
			outputText &amp;= CrLf &amp; " " &amp; CrLf &amp; self.getDelimiter() &amp; "externalMethodDefinitions";
			foreach devExternalMethod in devClass.allExternalMethods do
				outputText &amp;= CrLf &amp; self.getDelimiter() &amp; self.getDelimiter() &amp; devExternalMethod.description;
				
				if devExternalMethod.hasTimeStamp() then
					outputText &amp;= CrLf &amp; self.getDelimiter() &amp; self.getDelimiter() &amp;  "setModifiedTimeStamp " &amp; devExternalMethod.getLastModifiedTimeStamp();
				endif;
			endforeach;
		endif;
		
		if devClass.allEventMethodMappings.size &gt; 0 then
			outputText &amp;= CrLf &amp; " " &amp; CrLf &amp; self.getDelimiter() &amp; "eventMethodMappings";
			foreach devEventMethodMapping in devClass.allEventMethodMappings do
				outputText &amp;= CrLf &amp; self.getDelimiter() &amp; self.getDelimiter() &amp; devEventMethodMapping.name &amp; " = " &amp; devEventMethodMapping.value &amp; ";";
			endforeach;
		endif;
		
		if devClass.implementInterfacesText &lt;&gt; null then
			outputText &amp;= CrLf &amp; self.getDelimiter() &amp; "implementInterfaces" &amp; CrLf &amp; devClass.implementInterfacesText;
			outputText &amp;= CrLf;
		endif;
		
		if devClass.webServicesMethodDefinitionsText &lt;&gt; null then
			outputText &amp;= CrLf &amp; self.getDelimiter() &amp; "webServicesMethodDefinitions" &amp; CrLf &amp; devClass.webServicesMethodDefinitionsText;
			outputText &amp;= CrLf;
		endif;
		
		outputText &amp;= CrLf &amp; self.getDelimiter() &amp; ")"; //Append class ending tag
	endforeach;
	
	_outputFile.writeString(outputText &amp; CrLf); //Write out to file
epilog

end;</source>
        <Parameter name="_outputFile" type="File" usage="io"/>
    </JadeMethod>
</Class>
