/*
----------   ----------  --------------------------------------------------
Created:	14 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.myHandHeldGateAgent.doGetVehicleDetails(_vehicleID, 
												_numRecievals, 
												_numReleases,
												_inJob,
												_gateLaneStr, 
												_errorMsgs);

end;


</source>
