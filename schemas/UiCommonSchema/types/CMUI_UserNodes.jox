    <JadeMethod name="mnuSetLogLevel_click" id="cc73263a-045e-4862-8269-8a3ca0296551">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuSetLogLevel_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 November 2019	jlgndl1	Initial creation	TFS 47053

*/

vars

	processObj : Process;
	form : CMUI_SetLoggingLevel;
	result : Integer;

begin

	processObj := menuItem.userObject.Process;
	
	if processObj &lt;&gt; null then
		create form transient;
		form.setProcessObject( processObj );
		form.showModal();
		
		result := form.modalResult;
	
		if result &gt;= LogINFO and result &lt;= LogTRACE then
			processObj.causeEvent( EVENT_APP_LOG_LEVEL, true, result );
		endif;
	endif;
	
epilog

	delete form;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuSetLogLvlApp_click" id="729110f7-7218-40b3-827a-5f2223bd0aae">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuSetLogLvlApp_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
27 January 2020	jlgmd1	Initial creation	TFS 48270

*/

vars

	processObj	: Process;
	form 		: CMUI_SetLoggingLevel;
	result		: Integer;
	appName		: String;
	numRows,
	startRow,
	idx			: Integer;

begin

	processObj := menuItem.userObject.Process;
	
	if processObj &lt;&gt; null then
		create form transient;
		form.setProcessObject( processObj );
		form.showModal();
		
		result := form.modalResult;
	
		if result &gt;= LogINFO and result &lt;= LogTRACE then
			appName := processObj.persistentApp.name;
			startRow := self.tblNodes.fixedRows;
			numRows := self.tblNodes.rows;
			
			foreach idx in 1 to numRows do
				processObj := self.tblNodes.accessRow(idx).itemObject.Process;
				if processObj &lt;&gt; null and processObj.persistentApp.name = appName then
					processObj.causeEvent( EVENT_APP_LOG_LEVEL, true, result );
				endif;
			endforeach;
			
		endif;
	endif;
	
epilog

	delete form;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
