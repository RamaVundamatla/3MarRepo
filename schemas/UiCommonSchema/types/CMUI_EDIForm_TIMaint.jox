    <JadeMethod name="doRemoveDeletedEDITIs" id="26ab9a9a-2df2-49ae-b06f-7dda82b57628">
        <source>doRemoveDeletedEDITIs(_ediData: CM_EDIData; userInfo: Any);
// ---------------------------------------------------------------------------
// Created:     13 September 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tbl		: CM_DataTable;
begin
	tbl 	:= self.tblEDITI;

	// make sure we don't register for notes for this deleted object again
	tbl.myDynaDict.removeIfPresent (_ediData);
epilog

end;</source>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="doRemoveEDITI" id="61f9592a-b5b2-41b2-8744-4f340e2b2577">
        <source>doRemoveEDITI(_ediTI: CM_EDITrackedItem) protected;
// ---------------------------------------------------------------------------
// Created:     14 September 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tbl		: CM_DataTable;
	intRow	: Integer;
begin
	tbl 	:= self.tblEDITI;
	intRow	:= 1;
	
	// find the deleted object and remove it from the table
	if tbl.findObjectInRow (_ediTI, intRow) then
		if intRow &gt; tbl.fixedRows then
			tbl.removeItem(intRow);
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ediTI" type="CM_EDITrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doSaveEDIDataDetails" id="1b66c27f-cc53-47bb-b86d-caaa82a4e7d9">
        <updating/>
        <source>doSaveEDIDataDetails(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     09 September 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	loadState		: Boolean;
	cmifMonitor		: CMIF_Monitor;
	passport		: CM_Passport;
begin
	app.mousePointer 	:= MP_HOURGLASS;
	passport 			:= app.myPassport;
			
	if passport.myCMIFMonitor = null then
		create cmifMonitor transient;
		cmifMonitor.myParent := self;
		passport.setMyCMIFMonitor(cmifMonitor);
	endif;
	
	self.initModalDialog();
	
	self.lblModalMessage.caption	:= Cr &amp; "Saving EDI data.";
	self.frmModalDialog.visible		:= true;
	
	app.doWindowEvents(0);

	self.saveEDITIChanges(passport);
	
	if passport.trxCompletedOK then
		self.mode := Mode_View;

		self.setControls();
		self.clearErrorWarnings();
		self.staMain.caption	:= "EDI Details saved";
		self.tiDataHasChanged	:= false;
		// *** SAVED OK *** //
		return true;
	else
		app.showErrorWarningDialog('Save EDI Details', passport, ErrWarnMode_AddUpdate);
	endif;
	
epilog
	self.closeModalDialog();
	delete cmifMonitor;
	passport.setMyCMIFMonitor(null);
	app.mousePointer := MP_DEFAULT;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUpdateEDITI" id="2ac796de-380c-415c-9b1c-98e211f92595">
        <source>doUpdateEDITI(_ediTI: CM_EDITrackedItem;_eventType: Integer);
// ---------------------------------------------------------------------------
// Created:     13 September 2010 by cnwcs5
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29 Jul 2013	cnwcs5		CCMS POL 2221 / par 32094(2)
// 30 Nov 2022 navma1 		ChangeRequest 52499: MTN - Improve the performance of the Edi file verification process.
// ---------------------------------------------------------------------------
vars
	gotException	: Boolean;
	tbl				: CM_DataTable;
	idx				: Integer;
	str				: String;
begin
	on Exception do app.handleDeletedObject (exception, _ediTI, gotException);
	
	tbl := self.tblEDITI;
	idx := 1;
	
	if tbl.findObjectInRow(_ediTI, idx) then
		// it's in our table
		str := _ediTI.getAttributeStringForDefArray(tbl.allTblDataEntRows);
		
		if gotException then
			// we should get a delete notification any time now :-)
			return;
		endif;
		
		tbl.setCellText(idx, 1, str);
		tbl.accessRow(idx);
		
		self.setColoursForEDITrackedItem (_ediTI.myEDIData, _ediTI, null, tbl.accessRow(idx));
	endif;
end;</source>
        <Parameter name="_ediTI" type="CM_EDITrackedItem"/>
        <Parameter name="_eventType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doVerifyEDITIs" id="29224f57-ab7c-4bfd-bf5a-b89ac241aa0c">
        <updating/>
        <source>doVerifyEDITIs() updating;
// ---------------------------------------------------------------------------
// Created:     09 September 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 10/03/2011	cnwmh5		PAR #27142 - Clarify what object is getting handled by handleDeleteObject
// 23/08/2012 	cnwcs5		par 30136 - transient errors
// 25/10/2012	cnwcs5	 	par 28376 - tidy up of show/hide warnings
// ---------------------------------------------------------------------------
vars
	ediData		: CM_EDIData;
	passport	: CM_Passport;
	cmifMonitor	: CMIF_Monitor;
	table		: CM_DataTable;
	hasErrors,
	gotException: Boolean;
begin
	app.mousePointer	:= MP_HOURGLASS;
	passport			:= app.myPassport;
	table				:= self.tblEDITIError;
	
	if self.allEDIData.size = 0 then
		app.raiseUnexpectedProgramError(class.name, method.name, 'no current ediData object');	
	endif;
	
	on Exception do app.handleDeletedObject (exception, ediData, gotException);
	
	passport.clearErrorsWarnings();
	
	if passport.myCMIFMonitor = null then
		create cmifMonitor transient;
		cmifMonitor.myParent := self;
		passport.setMyCMIFMonitor(cmifMonitor);
	endif;
	
	self.initModalDialog();
	self.lblModalMessage.caption	:= Cr &amp; app.getErrorString (XLAT_Verifying_EDIData);
	self.frmModalDialog.visible 	:= true;
	
	app.doWindowEvents(0);

	foreach ediData in self.allEDIData do		
		if ediData.status = CM_EDIFile.EDI_STATUS_DBLOADED then
			// don't bother verifying if already DB loaded
			continue;
		endif;
		
		if gotException then	
			// edidata has been deleted
			continue;
		endif;
		
		self.myEDIAgent.verifyEdiData(ediData);

		if self.hasVerifyErrorsToShow (ediData) then	// par 30136 Aug 2012
			if not hasErrors then
				// first error
				self.initTblEDITIError();
				self.sptData.showRightControl(35, true);
				
				self.btnPrintTV.enabled	:= true;
		
				hasErrors 			:= true;
			endif;
			// add these errors to the table
			self.showVerifyErrors(ediData);	//par 27392 13 Apr 2011
		endif;
	endforeach;
	
	if hasErrors then
		table.cnAdjustColumnWidths();
		table.autoSize 						:= table.AutoSize_BothColumnMinimum;
		table.accessColumn(4).wordWrap 		:= true;
		table.accessedColumn.widthPercent	:= 70;
		self.ediTIDataNeedsRefresh			:= true;
	else
		table.rows 	:= table.fixedRows;
		self.mode 	:= self.Mode_View;
		
		self.setControls();	
		self.clearErrorWarnings();
		
		self.staMain.caption 	:= app.getErrorString (Verify_sucessful);
	endif;
	
	self.updateTblData(ediData);
epilog
	self.closeModalDialog();
	
	delete cmifMonitor;
	
	passport.setMyCMIFMonitor(null);
	
	app.mousePointer := MP_DEFAULT;
end;</source>
    </JadeMethod>
    <JadeMethod name="handleNotification" id="7fe739ac-08b8-4304-80cd-569b643ad8cf">
        <updating/>
        <source>handleNotification(_eventType: Integer; _object: Object; _eventTag: Integer; _userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:     13 September 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30 Nov 2022  navma1 		ChangeRequest 52499: MTN - Improve the performance of the Edi file verification process.
// ---------------------------------------------------------------------------
vars
	invalidTI	: Boolean;
begin 
	if _eventType = Object_Update_Event then
		// an EDI tracked item has been updates
		if _object.isKindOf(CM_EDITrackedItem) then
			self.doUpdateEDITI(_object.CM_EDITrackedItem,_eventType);		//30.11.2022 navma1 #52499
		endif;
	elseif _eventType = Object_Delete_Event then
		// an EDI tracked item has been deleted
		if _object.isKindOf(CM_EDITrackedItem) then
			self.doRemoveEDITI(_object.CM_EDITrackedItem);
		endif;
	else
		inheritMethod (_eventType, _object, _eventTag, _userInfo);
	endif;
end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
        <Parameter name="_userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="initEDITrackedItemsColl" id="ecacbc2f-b4b7-42aa-8b7b-c4b99fa8696e">
        <source>initEDITrackedItemsColl() protected;
// ---------------------------------------------------------------------------
// Created:     09 September 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	obj				: Object;
	data			: CM_EDIData;
	ediTI			: CM_EDITrackedItem;
	gotException	: Boolean;
begin
	on Exception do app.handleDeletedObject(exception, obj, gotException);
	
	foreach data in self.allEDIData do
		obj := data;		// for exception handler
		// just get all the unprocessed ones
		foreach ediTI in data.allEDITrackedItems do
			obj := ediTI;	// for exception handler
			self.allEDITrackedItems.addNoDuplicates (ediTI, false);
			// if ediTI is invalid exception handler will resume here
		endforeach;
		// if data is invalid exception handler will resume here
	endforeach;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initForm" id="d215721d-1ee8-496f-9b15-fbc77cb9d28f">
        <updating/>
        <source>initForm() updating;
// ---------------------------------------------------------------------------
// Created:     09 September 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.allowAdd	 := false;
	self.allowDelete := false;
	self.allowUpdate := false;
	
	self.filterAppliesToThumbnail 	:= false;
	self.allowSearch 				:= false;
	self.showFilterOnStartup 		:= false;
	self.showDataOnStartup 			:= true;
	self.frmDetailsBottom.visible 	:= false;
	self.ediTIDynaDictFirstUse 		:= true;
	self.useTblThumb 				:= false;
	self.useThumbArea				:= false;
	self.useTblData					:= false;
	self.allowPrint					:= false;
	self.allowExportCSV				:= false;
	
	self.initEDITables(0);
	self.initDetailControls();
	self.initEDIAgent();
	
	self.fldDetail.useSheetBackColors := true;

	self.fldDetail.setDefaultSheetBackColors();
	self.fldDetail.initSheetBackColors();
	
	self.ediTIDataNeedsRefresh := true;
		
	self.initEDITrackedItemsColl;
	self.shtEDIDetails.visible	:= false;
	
	self.myCurrentDataTable 	:= self.tblData;	
epilog

end;</source>
    </JadeMethod>
