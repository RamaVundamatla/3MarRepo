    <JadeMethod name="getGateTicketErrorWarnings_JRW" id="1331c1dd-b2f2-4bde-aac7-0770160c999e">
        <updating/>
        <source>getGateTicketErrorWarnings_JRW() : String updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2008	conkc1	Initial creation

*/
vars
	instructions : String;
	error        : CM_ErrorPersistent;
	count        : Integer;
begin

	foreach error in self.allErrorsWarningsByTranNum where error.type &lt;&gt; Message_Statement do
		if error.status = Error_Status_Open then
			count := count + 1;
			if count &gt; 1 then
				instructions := instructions &amp; CrLf;
			endif;
			instructions := instructions &amp; error.errorCode.String &amp; ' : ' &amp; error.text;
		endif;
	endforeach;
	return instructions;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getGateTicketGrossWeight_JRW" id="61b633fb-c06a-4896-894b-20cd76c68763">
        <updating/>
        <source>getGateTicketGrossWeight_JRW() : String updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2008	conkc1	Initial creation

*/

vars
	container   : CM_Container;
	tilc        : CM_TILC;
	grossWeight : Decimal[14,4];
begin
	container := self.getGateTicketContainer();
	//  Should always find one container
	if container = null then
		return 'missing container';
	endif;
	// Container total weight
	grossWeight := container.totalWeight;
	tilc := self.getGateTicketTILC();
	// TILC total weight
	if tilc &lt;&gt; null then
		grossWeight := grossWeight + tilc.totalWeight;
	endif;
	
	return (grossWeight / 1000).String &amp; ' MT';
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getGateTicketInstructions_JRW" id="ec3709be-f721-4077-b2f1-188466660d95">
        <updating/>
