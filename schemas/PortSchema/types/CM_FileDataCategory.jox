        <updating/>
        <source>setForUpdate(_pxyFileDataCategory : CM_FileDataCategory) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/11/2022 navmv20 TFS CR 55299 TFS CR 55299 TASK 55516: Jade - Write TRX for new file category
24/01/2023 navvt20 TFS CR 56204 Task 56206: UI - File Category Maintenance
*/

vars

begin
	self.categoryContext := _pxyFileDataCategory.categoryContext;
	self.code := _pxyFileDataCategory.code;
