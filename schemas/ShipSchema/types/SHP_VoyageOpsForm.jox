    <JadeMethod name="buildDischargeCombo" id="c7fe3e1f-93ff-486c-803a-fa3e9ee73df6">
        <source>buildDischargeCombo();
//--------------------------------------------------
// Created:	20 October 2003 By: cnwgd1
//--------------------------------------------------
/*

Date		Who		Reason
10 Jun 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens
15 Jul 2013 cnwer1  PAR 31985 removed trailer areas and old general cargo areas while here
25 Nov 2014 cnwma1  PAR #27002 NPNW -  Discharge to Areas - should include RoRo Lanes
29 Nov 2017 cnwma1  TFS #7905: STWO - Null objects error message while loading cargo on vessel - JMT production environment
25 Jun 2020	jlgdap1	TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
08 Sep 2022	jlika1	TFS 54699 - CUX - MAFI Handling Enhancements - MAFI Heap Terminal Area
*/

vars
	aTerminalArea : CM_TerminalArea;
	idx : Integer;
	theFilter		: CMQF_TerminalAreas;
	theQryReport	: CM_QryReport;
	shipBlockStack : CM_ShipBlockController;
	voyage : CM_Voyage;
	vehicle : CM_Vehicle;
	train : CM_Train;
	wagon : CM_Wagon;
	targetLocation : CM_LocationsController;
	targetLocations : CM_LCSet;
	job : CM_Job;
	invalidVoyage : Boolean;
	voyEdition : Integer;
begin
	
	self.cmbTerminalArea.clear;
	self.cmbTARow.clear();
	
	theQryReport := app.myRoot.myReportMenuRoot.getReportByConstantValue(CM_RepTerminalArea);
	
	create theFilter transient;
	theFilter.allTerminals.add(self.myTerminal);
	theFilter.terminalAreaTypes.add(TA_TYPE_DEPOT_LCL);
	theFilter.terminalAreaTypes.add(TA_TYPE_BLOCK_STACK);
	theFilter.terminalAreaTypes.add(TA_TYPE_SUBBLOCK_STACK);	
	theFilter.terminalAreaTypes.add(TA_TYPE_WASH_AREA);			
	theFilter.terminalAreaTypes.add(TA_TYPE_PTI);				
	theFilter.terminalAreaTypes.add(TA_TYPE_REPAIR);				
	theFilter.terminalAreaTypes.add(TA_TYPE_IRREGULAR_BLOCK_AREA);		// was TA_TYPE_GENERAL_CARGO_AREA
	theFilter.terminalAreaTypes.add(TA_TYPE_FORK_LIFT_STACK); // PAR 19450 - CCMS 1064 SFW extras
	theFilter.terminalAreaTypes.add(TA_TYPE_STRADDLE_STACK); // PAR 19450 - CCMS 1064 SFW extras
	theFilter.terminalAreaTypes.add(TA_TYPE_RTG); // PAR 19450 - CCMS 1064 SFW extras
	theFilter.terminalAreaTypes.add(TA_TYPE_RMG); //+ cnwmd1, Par 24382
	theFilter.terminalAreaTypes.add(TA_TYPE_RORO_LANE_AREA);   //+ cnwma1 25/11/2014 PAR #27002
	theFilter.terminalAreaTypes.add(TA_TYPE_BULK);	//19 Feb 2016	NDL	Par 37557
	theFilter.terminalAreaTypes.add(TA_TYPE_RELTRANS);	//28 May 2018	NDL	TFS 38897
	theFilter.terminalAreaTypes.add(TA_TYPE_GEN_CARGO_ALLOC_ROW);		// TFS 49453
	theFilter.terminalAreaTypes.add(TA_TYPE_MAFI);	
	if process.isShanu then
        theFilter.terminalAreaTypes.add(TA_TYPE_COU_STORE_AREA);
    endif;
	// Does not handle straddle stacks, only single controller areas
	theQryReport.doFilter(theFilter, app.myPassport);

	//08 Apr 2011	NDL	Par 27045
	if self.showOffsite then
		self.cmbTerminalArea.addItem('**Off Site**');			
	endif;
	
	self.cmbTerminalArea.addItemAt(app.getErrorString(Planned_location), self.cmbTerminalArea.listCount + 1);		// 26/6/17 MAP TFS4719
	
	foreach aTerminalArea in theFilter.allQryTerminalAreas do	
		idx := self.cmbTerminalArea.addItem(aTerminalArea.id);
		self.cmbTerminalArea.itemObject[idx] := aTerminalArea;	
	endforeach;
	
	//13 Feb 2013	NDL	Par 31102 - Include direct delivery locations.
	if self.chkDirDel.value and self.myCurrentVoyage &lt;&gt; null then
		create targetLocations transient;
		//Other NWNP voyages
		on Exception do app.handleDeletedObject( exception, voyage, invalidVoyage );  //29.11.2017 cnwma1 TFS #7905
		
		foreach voyage in self.allVoyages where voyage &lt;&gt; self.myCurrentVoyage do
			
			voyEdition := voyage.edition;
			if invalidVoyage then              //29.11.2017 cnwma1 TFS #7905
				invalidVoyage := false;
				continue;
			endif;
			
			shipBlockStack := voyage.myShipBlockStack.CM_ShipBlockController;
			if shipBlockStack &lt;&gt; null then
				targetLocations.addNoDuplicates(shipBlockStack,false);
			endif;
		endforeach;
		//Trucks
		foreach job in self.myTerminal.myRoadJobSheet.allJobsByOrder discreteLock do
			vehicle := job.CM_RoadJob.myVehicle;
			if vehicle &lt;&gt; null then
				targetLocations.addNoDuplicates(vehicle.locationsController,false);
			endif;
		endforeach;
		//Rail
		foreach train in self.myTerminal.allTrainsOnTerminal discreteLock do
			foreach wagon in train.allWagonsByIdOutward discreteLock where wagon.confirmed do
				idx := self.cmbTerminalArea.addItem( wagon.id &amp; " " &amp; app.getErrorString(Rail) );
				self.cmbTerminalArea.itemObject[idx] := wagon;
			endforeach;
		endforeach;
		
		if not targetLocations.isEmpty then
			foreach targetLocation in targetLocations do
				if targetLocation.isKindOf(CM_ShipBlockController) then
					idx := self.cmbTerminalArea.addItem( targetLocation.getFullId &amp; " " &amp; app.getErrorString(Voyage) );
				else
					idx := self.cmbTerminalArea.addItem( targetLocation.getFullId );
				endif;
				self.cmbTerminalArea.itemObject[idx] := targetLocation;
			endforeach;
		endif;
	endif;

epilog
	delete theFilter;
	delete targetLocations;
end;</source>
    </JadeMethod>
    <JadeMethod name="buildLoadToCombo" id="9602ada4-4ce8-450a-b138-ee3f38600dd0">
        <source>buildLoadToCombo() protected;
//------------------------------------------------
// Created: 26 April 2006 By: cnwgd1
//------------------------------------------------
vars
	tmpDict : CM_GeneralCCtrByHatchPlaceDict;
	hatch : CM_LocationsController;
	objSet : CM_ObjectSetActual;
	obj : Object;
	cta : CM_CraneTransferArea;
	lc : CM_LocationsController;
	wpIa : CM_WorkPointInterchangeArea;
	wpLanes : CM_LCArray;
begin
	
	self.cmbLoadLocation.clear();
	
	if self.myCurrentVoyage = null then
		return;
	endif;
	
	self.cmbLoadLocation.addItem(app.getErrorString(Planned_location));		// 26/6/17 MAP TFS4719
	
	if self.myCurrentVoyage.myShipBlockStack &lt;&gt; null then
		self.cmbLoadLocation.addItemObject(self.myCurrentVoyage.myShipBlockStack.getFullId(), self.myCurrentVoyage.myShipBlockStack);
	endif;
	
	if self.myCurrentVoyage.myGeneralCargoVoyage &lt;&gt; null then
		tmpDict := self.myCurrentVoyage.myGeneralCargoVoyage.allLocationsByHatchPlace;
	
		foreach hatch in tmpDict discreteLock, reversed do
			self.cmbLoadLocation.addItemObject(hatch.getFullId(), hatch);		
		endforeach;
	endif;
	
	//22 Jun 2021	NDL	TFS 51231
	if self.myCurrentVoyage.isBarge then
		create objSet transient;
		self.myCurrentVoyage.findAllMyCranesAndWorkpoints( objSet );
		if not objSet.isEmpty then
		
			foreach obj in objSet do
				if obj.isKindOf( CM_Crane ) then
					cta := obj.CM_Crane.getCraneTransferArea;
					if cta &lt;&gt; null then
						foreach lc in cta.loadLanes do
							self.cmbLoadLocation.addItemObject(lc.getFullId(), lc);
						endforeach;
					endif;
					
				elseif obj.isKindOf( CM_WorkPoint ) then
					wpIa := obj.CM_WorkPoint.myWorkPointInterchangeArea;
					if wpIa &lt;&gt; null then
						create wpLanes transient;
						wpIa.getLanes(wpLanes);
						foreach lc in wpLanes do
							self.cmbLoadLocation.addItemObject(lc.getFullId(), lc);
						endforeach;
					endif;
				
				endif;
			endforeach;
			
		endif;
	endif;
	

epilog
	
	delete objSet;
	delete wpLanes;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="buildTransferTypeCombo" id="7a97317a-bddf-48df-bebf-54e42aa2ba33">
        <source>buildTransferTypeCombo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 March 2018	jlgndl1	Initial creation	TFS 37444

*/

vars

	voyTfrType : CM_VoyageJobTransferType;
	
	defaultLOLO : CM_VoyageJobTransferType;
	index : Integer;

begin
	
	self.cmbTransferType.clear();
	foreach voyTfrType in app.myRoot.allVoyageJobTransferTypes do
		if voyTfrType.id = 0 then
			continue;
		elseif voyTfrType.id = 1 then
			defaultLOLO := voyTfrType;
		endif;
		index := self.cmbTransferType.addItem( voyTfrType.description );
		self.cmbTransferType.itemObject[ index ] := voyTfrType;
	endforeach;
	
	if defaultLOLO &lt;&gt; null then
		self.cmbTransferType.listIndex := self.cmbTransferType.findObject( defaultLOLO );
	else
		self.cmbTransferType.listIndex := -1;
	endif;

epilog

end;</source>
    </JadeMethod>
