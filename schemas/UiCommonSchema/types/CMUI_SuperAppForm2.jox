    <JadeMethod name="userNotify" id="73ccb50e-e547-4165-becb-1e41d50ee324">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:     24 January 2003		cnwth2	
//
// Purpose:     
// Added the user notify show a message			 
// ----------   ----------  --------------------------------------------------
vars
	dataStr : String;
	userNames: String;
	i : Integer;
begin

	if eventType = Event_MenuUserToolbarRoot then	//Par15018
		self.loadToolbar();
		return;
	endif;

	if eventType &lt;&gt; Event_SendMessage then
		return;
	endif;
	//----------------------
	//Someone has sent me a message, determine if I show it or not
	//----------------------
	dataStr := userInfo.String;
	i := dataStr.pos('%^%', 1);	//Search for our "special string", if its there in 1st 4 chars, the msg is to ALL
	if i &lt; 4 then
		global.beep;
		app.msgBox(dataStr, app.getErrorString(NewMessage), MsgBox_OK_Only + MsgBox_Information_Icon);
	else
		userNames := dataStr[1 : i - 1];
		if userNames.pos('&amp;&amp;' &amp; process.userCode &amp; '&amp;&amp;', 1) &gt; 0 then //par13933
			global.beep;
			app.msgBox(dataStr[i + 3 : end], app.getErrorString(NewMessage), MsgBox_OK_Only + MsgBox_Information_Icon);
		endif;
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validateToolbarClick" id="8e707295-5afa-470d-9ec0-c59160f91182">
        <source>validateToolbarClick(jadeMask: JadeMask input) : CM_MenuToolbar protected;
// ------------------- --------------------------------------------------------
// Created:     24 January 2003		cnwth2	
//
// Purpose:     If everything checks out it passes back a the system toolbar object
//			 
// ----------   ----------  --------------------------------------------------
vars
	userTool		: CM_MenuUserToolbar;
	menuEnt			: CM_MenuEntity;
	idx				: Integer;
begin
	idx := jadeMask.index;
	if idx &lt; 1 or idx &gt; self.allToolBarMenuItems.size then
		return null;
	endif;
	
	menuEnt := self.allToolBarMenuItems[idx];
	
	if (menuEnt = null) or 
		(not menuEnt.isKindOf(CM_MenuUserToolbar)) or 
		menuEnt.CM_MenuUserToolbar.mySystemToolbar = null then
		return null;
	endif;
	
	return menuEnt.CM_MenuUserToolbar.mySystemToolbar;
	
end;</source>
        <access>protected</access>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
        <ReturnType type="CM_MenuToolbar"/>
    </JadeMethod>
