    <JadeMethod name="setProxyRORO" id="2bbe0d58-b939-4adb-9287-06c70a2bb942">
        <updating/>
        <source>setProxyRORO(pWidth, pHeight : Integer; pTA : CM_TerminalArea; pColour, pTop, pLeft : Integer; pOrientation : Real; 
							_pointsPolygon : PointArray input;_label : String;_shipLayer : CM_ShipDeckLayer; _drawFillColor, _drawFillStyle, _drawWidth : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		Dec 2010 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
begin
	self.raiseExceptionIfNotTransient(method);

	self.width := pWidth;
	self.height := pHeight;
	self.drawLineColour := pColour;
	self.top := pTop;
	self.left := pLeft;
	self.orientation := pOrientation;
	self.label := _label;
	
	self.myShipLayer := _shipLayer;
	
	self.drawFillColor := _drawFillColor; //Black;
	self.drawFillStyle := _drawFillStyle; //Frame.DrawFillStyle_Transparent;
	self.drawWidth := _drawWidth; //1;
	self.setPointsPolygon(_pointsPolygon);
	
end;</source>
        <Parameter name="pWidth" type="Integer"/>
        <Parameter name="pHeight" type="Integer"/>
        <Parameter name="pTA" type="CM_TerminalArea"/>
        <Parameter name="pColour" type="Integer"/>
        <Parameter name="pTop" type="Integer"/>
        <Parameter name="pLeft" type="Integer"/>
        <Parameter name="pOrientation" type="Real"/>
        <Parameter name="_pointsPolygon" type="PointArray" usage="input"/>
        <Parameter name="_label" type="String"/>
        <Parameter name="_shipLayer" type="CM_ShipDeckLayer"/>
        <Parameter name="_drawFillColor" type="Integer"/>
        <Parameter name="_drawFillStyle" type="Integer"/>
        <Parameter name="_drawWidth" type="Integer"/>
    </JadeMethod>
