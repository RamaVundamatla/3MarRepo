    <JadeMethod name="populateRowTotals" id="a0e5088a-5315-47b1-8853-474cb2d7db5c">
        <source>populateRowTotals(_column : Integer) protected;
/*

Date		    Who			Reason
04 October 2010	cnwas3	  Initial creation

*/

vars
	idx : Integer;
	totals : Decimal[23,5];
	rowHeader  : String;
begin
			
	foreach idx in 2 to self.tblCargoCounter.rows do	
		//row Headers does not include fixed first row
		rowHeader:=self.rowHeaders[idx-1] ;
		if rowHeader.endsWith(self.TotalRow)   then 
			self.tblCargoCounter.accessCell(idx,_column).text := totals.cnEcNumberFormat().cnEcStripDecimalZeros();
			self.tblCargoCounter.accessCell(idx,_column).fontBold := true;
			totals :=0;
		else		
			totals:=totals  + self.tblCargoCounter.accessCell(idx,_column).text.asDecimalJMT.Real;	
		endif;
		self.rowTotals[idx - 1] := self.rowTotals[idx - 1] + self.tblCargoCounter.accessCell(idx,_column).text.asDecimalJMT;
	endforeach;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_column" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="populateTable" id="7501f7fd-f4b2-4cb8-87e2-2752a71a47be">
        <updating/>
        <source>populateTable() updating;
/*

Date		    	Who			Reason
30 September 2010	cnwas3	  	Initial creation
// 16 May 2016		cnwns1		TFS 488 - Multi Timezone Support
8 February 2022 	navcs2		TFS 52784 Added Boolean flags to method signature to be able to select certain rows in a table

*/

vars
	cargoType 					: CM_CargoType;
	ts,now 						: TimeStamp;
	date 						: Date;
	idxMonth 					: Integer;	
begin
	if self.monthsSpan &lt; 1 then
		self.tblCargoCounter.clearAllData();
		return;
	endif;	
	
	ts := self.localToSystemTime(self.referenceTimeStamp.cnEcGetFirstDayOfMonth().asTimeStamp);
	now := app.actualTimeServer().addDays(-1);// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	if ts &gt; now then
		return;
	endif;
	self.rowTotals.clear();
	self.rowTotals[self.rowHeaders.size()] := 0;
	//months
	if self.monthsSpan &gt; 1 or not self.isChildForm then			
		foreach idxMonth in 2 to self.tblCargoCounter.columns - 1 do
			foreach cargoType in self.cargoTypes do		
				//epr par 36624 16/4/15
				self.getKPITotalsPerMonths(ts,cargoType,idxMonth);			
			endforeach;
			self.populateRowTotals(idxMonth);
			ts := ts.addMonths(1);			
		endforeach;		
		self.stripTotalsColumnDecimals();
	else	
		//days
		foreach idxMonth in 2 to self.tblCargoCounter.columns - 1 do
			foreach cargoType in self.cargoTypes do	
				//epr par 36624 16/4/15
				self.getKPITotalsPerDays(ts,cargoType,idxMonth);		
			endforeach;
			self.populateRowTotals(idxMonth);	
			ts := ts.addDays(1);
		endforeach;	
		self.stripTotalsColumnDecimals();
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCargoTypeRowHeadings" id="003eed08-3f0e-450f-8aae-959dc1d2a8b7">
        <source>setCargoTypeRowHeadings(	_isForContainer : Boolean;
							_attributeHeading : String input) protected;
/*

Date		Who		Reason
14 July 2015	cnwer1	Initial creation PAR 36624

*/

vars
	rowType : String;
	otherLengths : Boolean;
	rowColor : Integer;
	cargoType : CM_CargoType;
begin
	
	if  _isForContainer then
		cargoType:=self.cargoTypes.first;
		if cargoType.id &lt;&gt; TI_CargoType_Container then
			return;
		endif;
		rowType := cargoType.abbreviation &amp; _attributeHeading;
		if self.show30s = ISOTypeOtherIncludedAsOther or self.show45s = ISOTypeOtherIncludedAsOther or self.show53s = ISOTypeOtherIncludedAsOther then
			otherLengths := true;
		endif;
		//cargo type heading
		self.setHeading(cargoType.description &amp; " " &amp; _attributeHeading,self.xmlColourCargoType);
		self.rowHeaders.add(rowType  &amp; self.HeaderRow);
		
		self.setHeading(app.getErrorString(TwentyFoot),self.xmlColourRowColour);
		self.rowHeaders.add(rowType &amp; app.getErrorString(TwentyFoot));
		
		self.setHeading(app.getErrorString(FortyFoot),self.xmlColourAltRow);
		self.rowHeaders.add(rowType &amp; app.getErrorString(FortyFoot));	
		if self.show30s = ISOTypeOtherIncludedAsOwn then
			self.setHeading(app.getErrorString(ThirtyFoot),self.xmlColourRowColour);		
			self.rowHeaders.add(rowType &amp; app.getErrorString(ThirtyFoot));	
		endif;
		
		if self.show45s = ISOTypeOtherIncludedAsOwn then
			self.setHeading(app.getErrorString(FortyFiveFoot),self.xmlColourAltRow);	
			self.rowHeaders.add(rowType &amp; app.getErrorString(FortyFiveFoot));	
		endif;
		
		if self.show53s = ISOTypeOtherIncludedAsOwn then
			self.setHeading(app.getErrorString(FiftyThreeFoot),self.xmlColourRowColour);
			self.rowHeaders.add(rowType &amp; app.getErrorString(FiftyThreeFoot));	
		endif;
		
		if otherLengths then
			self.setHeading(app.getErrorString(Other),self.xmlColourAltRow);	
			self.rowHeaders.add(rowType &amp; app.getErrorString(Other));	
		endif;
		
		self.setHeading(app.getErrorString(Total),self.xmlColourTotals);		
		self.rowHeaders.add(rowType &amp; self.TotalRow);	
		self.tblCargoCounter.accessRow(self.tblCargoCounter.rows).backColor := self.xmlColourTotals;
		self.tblCargoCounter.accessedRow.fontBold := true;
		self.tblCargoCounter.accessedRow.marginBottom := 2;
		self.tblCargoCounter.accessedRow.marginTop := 2;
	else
		self.setHeading(app.getErrorString(CMQF_GeneralCargo) &amp; " " &amp; _attributeHeading,self.xmlColourCargoType);
		self.rowHeaders.add(app.getErrorString(CMQF_GeneralCargo)&amp; _attributeHeading  &amp; self.HeaderRow);
		
		foreach cargoType in self.cargoTypes where cargoType.id &lt;&gt; TI_CargoType_Container do
			if not cargoType.isSystemCargoBOLType then
				if _attributeHeading = app.getErrorString(CM_VolumeM3) then
					if not cargoType.allAttributesOnProduct.includes(ETRow_MyVolume) then
						continue;
					endif;
				elseif _attributeHeading = app.getErrorString(Weight_kg) then
					if not cargoType.allAttributesOnProduct.includes(ETRow_MyWeight) then
						continue;
					endif;
				endif;
			endif;
				if self.tblCargoCounter.accessRow(self.tblCargoCounter.rows).backColor = self.xmlColourRowColour then
					rowColor:=self.xmlColourAltRow;
				else
					rowColor:=self.xmlColourRowColour;
				endif;
				rowType:=cargoType.abbreviation &amp; _attributeHeading;
				self.setHeading(cargoType.description ,rowColor);
				self.rowHeaders.add(rowType);
		endforeach;
		self.setHeading(app.getErrorString(Total),self.xmlColourTotals);
		self.rowHeaders.add(app.getErrorString(CMQF_GeneralCargo)&amp; _attributeHeading  &amp;  self.TotalRow);
		self.tblCargoCounter.accessRow(self.tblCargoCounter.rows).backColor := self.xmlColourTotals;
		self.tblCargoCounter.accessedRow.fontBold := true;
		self.tblCargoCounter.accessedRow.marginBottom := 2;
		self.tblCargoCounter.accessedRow.marginTop := 2;
	endif;
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_isForContainer" type="Boolean"/>
        <Parameter name="_attributeHeading" type="String" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setCargoTypes" id="5f4175ff-b9b3-4285-8777-317c516d7463">
        <source>setCargoTypes(_cargoTypes : CM_CargoTypesByIdDict);
/*

Date		    Who			Reason
15 September 2010	cnwas3	  Initial creation

*/

vars

begin
	if _cargoTypes &lt;&gt; null then
		if _cargoTypes &lt;&gt; self.cargoTypes then
			self.cargoTypes.clear();
			_cargoTypes.copy(self.cargoTypes);
		endif;		
	endif;
	
epilog

end;</source>
        <Parameter name="_cargoTypes" type="CM_CargoTypesByIdDict"/>
    </JadeMethod>
    <JadeMethod name="setColumnHeadings" id="4ab91566-cf43-4ccd-8a53-d7c816608eef">
        <updating/>
        <source>setColumnHeadings(_months : Integer; _initMonth : Date) updating;
/*

Date		    Who			Reason
13 September 2010	cnwas3	  Initial creation
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars	
	columns,idx,iDay : Integer;
	currentMonth : Date;
	currentDay : Date;
	columnHeading : String;
	localeId 	: Integer;
begin
	if _initMonth = null then
		self.tblCargoCounter.columns := 0;		
		return;
	endif;
	currentDay := app.actualTimeServer().date;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	localeId:=app.myCurrentLocale.localeId.Integer;
	
	if _months &gt; 1 or not self.isChildForm then
		if _initMonth.addMonths(_months).cnEcIsInFuture() then
			columns := currentDay.differenceInMonths(_initMonth) + 3;
		else
			columns := _months + 2;
		endif;
		currentMonth := _initMonth;
		self.tblCargoCounter.columns := columns;
		self.tblCargoCounter.fixedRows := 1;
		self.tblCargoCounter.accessCell(1,1).text:= app.getErrorString(Month);	
		self.tblCargoCounter.accessedCell.alignment := Table.Alignment_Left;
		foreach idx in 2 to columns - 1 do
			//epr par 36624 16/7/15
			columnHeading := currentMonth.userShortFormatPicAndLcid("MMM yy",localeId); 
			self.tblCargoCounter.accessCell(1,idx).text := columnHeading;
			self.tblCargoCounter.accessedCell.fontBold := false;
			self.tblCargoCounter.accessedCell.alignment := Table.Alignment_Left;
			currentMonth := currentMonth.addMonths(1);			
		endforeach;		
		self.tblCargoCounter.accessCell(1,columns).text := app.getErrorString(Total);		
		self.tblCargoCounter.accessedCell.fontBold := true;		
		self.tblCargoCounter.accessedCell.alignment := Table.Alignment_Left;
		
	elseif _months = 1 then		
		if _initMonth.month = currentDay.month then
			columns := currentDay.day() + 1;
		else
			columns :=  _initMonth.cnEcDaysInMonth() + 2;
		endif;		
		currentDay:= _initMonth.cnEcGetFirstDayOfMonth();
		self.tblCargoCounter.columns := columns;
		self.tblCargoCounter.fixedRows := 1;
		self.tblCargoCounter.accessCell(1,1).text:= _initMonth.userShortFormatPicAndLcid("MMMM yyyy",localeId); 

		self.tblCargoCounter.accessedCell.alignment := Table.Alignment_Left;
		foreach idx in 2 to columns - 1 do
			iDay := currentDay.day();
			columnHeading := currentDay.shortDayNameWithLcid(localeId) &amp; ' ' &amp; iDay.asStringJMT();			
			self.tblCargoCounter.accessCell(1,idx).text := columnHeading;	
			self.tblCargoCounter.accessedCell.fontBold := false;
			self.tblCargoCounter.accessedCell.alignment := Table.Alignment_Left;
			currentDay := currentDay.addDays(1);
		endforeach;
		self.tblCargoCounter.accessCell(1,columns).text := app.getErrorString(Total);		
		self.tblCargoCounter.accessedCell.fontBold := true;			
		self.tblCargoCounter.accessedCell.alignment := Table.Alignment_Left;
	else
		self.tblCargoCounter.columns := 0;
	endif;
epilog

end;</source>
        <Parameter name="_months" type="Integer"/>
        <Parameter name="_initMonth" type="Date"/>
    </JadeMethod>
    <JadeMethod name="setHeading" id="4c69f458-0391-480e-8fd3-6bda9d3a8dbb">
        <source>setHeading(	_heading : String;
			_colour : Integer);
/*

Date		    Who			Reason
01 October 2010	cnwas3	  populate each of the rows' headings

*/

vars
	row : Integer;
begin
	
	self.tblCargoCounter.rows := self.tblCargoCounter.rows  + 1;
	row:=self.tblCargoCounter.rows;
	self.tblCargoCounter.accessCell(row, 1).text := _heading;
	self.tblCargoCounter.accessRow(row).backColor := _colour;
	self.tblCargoCounter.accessedRow.foreColor := _colour.getInverseColour();
	self.tblCargoCounter.accessCell(row, 1).backColor := _colour;

	if _colour = self.xmlColourCargoType then
		self.tblCargoCounter.accessedCell.fontBold := true;
		self.tblCargoCounter.accessedCell.alignment := Table.Alignment_Left;
	endif;
epilog

end;</source>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_colour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setKPICargoTypeStatsCont" id="27ba5f95-e692-41f3-9d33-4fd77946fd99">
        <source>setKPICargoTypeStatsCont(_kpiStat : CMIF_KPICounterStat input;
						_col : Integer) protected;
/*

Date		Who		Reason
13 July 2015	cnwer1	Initial creation PAR 36624

*/

vars
	numTEU20,numTEU30,numTEU40,numTEU45,numTEU53,numTEUOther : Integer;
	numItems20,numItems30,numItems40,numItems45,numItems53,numItemsOther : Integer;
	idx : Integer;
	cargoType : CM_CargoType;
	rowType : String;
begin
	if _kpiStat = null then
		return;
	endif;
	
	numItems20:=_kpiStat.total20;
	numItems30:=_kpiStat.total30;
	numItems40:=_kpiStat.total40;
	numItems45:=_kpiStat.total45;
	numItems53:=_kpiStat.total53;
	numTEU20:=_kpiStat.getTEU20.Integer;
	numTEU30:=_kpiStat.getTEU30.Integer;
	numTEU40:=_kpiStat.getTEU40.Integer;
	numTEU45:=_kpiStat.getTEU45.Integer;
	numTEU53:=_kpiStat.getTEU53.Integer;
	
	cargoType:=_kpiStat.getCargoType;
	rowType:=cargoType.abbreviation &amp; app.getErrorString(TeuHeading);
	idx := self.rowHeaders.indexOf(rowType &amp; app.getErrorString(TwentyFoot));
	if idx &gt; 0 then
		self.tblCargoCounter.accessCell(idx + 1,_col).itemObject :=_kpiStat;
		self.tblCargoCounter.accessCell(idx+1,_col).text		:=numTEU20.asStringJMT.nullWhenZero();
	endif;
	
	idx := self.rowHeaders.indexOf(rowType &amp;app.getErrorString(ThirtyFoot));
	if idx &gt; 0 then
		self.tblCargoCounter.accessCell(idx+1,_col).itemObject :=_kpiStat;
		self.tblCargoCounter.accessCell(idx+1,_col).text		:=numTEU30.asStringJMT.nullWhenZero();
	else
		if self.show30s = ISOTypeOtherIncludedAsOther then
			numTEUOther := numTEUOther + numTEU30;
		else
			numTEU40 := numTEU40 + numTEU30;
			numItems40 := numItems40 + numItems30;
		endif;
		numTEU30 := 0;
	endif;	
	
	idx := self.rowHeaders.indexOf(rowType &amp;app.getErrorString(FortyFiveFoot));
	if idx &gt; 0 then
		self.tblCargoCounter.accessCell(idx+1,_col).itemObject :=_kpiStat;
		self.tblCargoCounter.accessCell(idx+1,_col).text		:=numTEU45.asStringJMT.nullWhenZero();
	else
		if self.show45s = ISOTypeOtherIncludedAsOther then
			numTEUOther := numTEUOther + numTEU45;
		else
			numTEU40 := numTEU40 + numTEU45;
			numItems40 := numItems40 + numItems45;
		endif;
		numTEU45 := 0;
	endif;
	
	idx := self.rowHeaders.indexOf(rowType &amp;app.getErrorString(FiftyThreeFoot));
	if idx &gt; 0 then
		self.tblCargoCounter.accessCell(idx+1,_col).itemObject :=_kpiStat;
		self.tblCargoCounter.accessCell(idx+1,_col).text		:=numTEU53.asStringJMT.nullWhenZero();
	else
		if self.show53s = ISOTypeOtherIncludedAsOther then
			numTEUOther := numTEUOther + numTEU53;
		else
			numTEU40 := numTEU40 + numTEU53;
			numItems40 := numItems40 + numItems53;
		endif;
		numTEU53 := 0;
	endif;
	
	idx := self.rowHeaders.indexOf(rowType &amp;app.getErrorString(FortyFoot));
	if idx &gt; 0 then
		self.tblCargoCounter.accessCell(idx + 1,_col).itemObject :=_kpiStat;
		self.tblCargoCounter.accessCell(idx+1,_col).text		:=numTEU40.asStringJMT.nullWhenZero();
	endif;
	
	idx := self.rowHeaders.indexOf(rowType &amp;app.getErrorString(Other));
	if idx &gt; 0 then
		self.tblCargoCounter.accessCell(idx + 1,_col).itemObject :=_kpiStat;
		self.tblCargoCounter.accessCell(idx+1,_col).text		:=numTEUOther.asStringJMT.nullWhenZero();
	endif;
	
	
		//////////////////////////////////////////////////////////////////////////////////////////////////////////
	rowType:=cargoType.abbreviation &amp; app.getErrorString(CM_Total_Quantity);
	idx := self.rowHeaders.indexOf(rowType &amp; app.getErrorString(TwentyFoot));
	if idx &gt; 0 then
		self.tblCargoCounter.accessCell(idx+ 1,_col).itemObject :=_kpiStat;
		self.tblCargoCounter.accessCell(idx+1,_col).text		:=numItems20.asStringJMT.nullWhenZero();
	endif;
	
	idx := self.rowHeaders.indexOf(rowType &amp; app.getErrorString(FortyFoot));
	if idx &gt; 0 then
		self.tblCargoCounter.accessCell(idx+ 1,_col).itemObject :=_kpiStat;
		self.tblCargoCounter.accessCell(idx+1,_col).text		:=numItems40.asStringJMT.nullWhenZero();
	endif;
	
	idx := self.rowHeaders.indexOf(rowType &amp; app.getErrorString(ThirtyFoot));
	if idx &gt; 0 then
		self.tblCargoCounter.accessCell(idx+ 1,_col).itemObject :=_kpiStat;
		self.tblCargoCounter.accessCell(idx+1,_col).text		:=numItems30.asStringJMT.nullWhenZero();
	else
		if self.show30s = ISOTypeOtherIncludedAsOther then
			numItemsOther := numItemsOther + numItems30;		
		endif;
		numItems30 := 0;
	endif;
	
	idx := self.rowHeaders.indexOf(rowType &amp; app.getErrorString(FortyFiveFoot));
	if idx &gt; 0 then	
		self.tblCargoCounter.accessCell(idx+ 1,_col).itemObject :=_kpiStat;
		self.tblCargoCounter.accessCell(idx+1,_col).text		:=numItems45.asStringJMT.nullWhenZero();
	else
		if self.show45s = ISOTypeOtherIncludedAsOther then
			numItemsOther := numItemsOther + numItems45;
		endif;
		numItems45 := 0;
	endif;
	
	idx := self.rowHeaders.indexOf(rowType &amp; app.getErrorString(FiftyThreeFoot));
	if idx &gt; 0 then	
		self.tblCargoCounter.accessCell(idx+ 1,_col).itemObject :=_kpiStat;
		self.tblCargoCounter.accessCell(idx+1,_col).text		:=numItems53.asStringJMT.nullWhenZero();
	else
		if self.show53s = ISOTypeOtherIncludedAsOther then
			numItemsOther := numItemsOther + numItems53;
		endif;
		numItems53 := 0;
	endif;		
	
	idx := self.rowHeaders.indexOf(rowType &amp; app.getErrorString(Other));
	if idx &gt; 0 then	
		self.tblCargoCounter.accessCell(idx+ 1,_col).itemObject :=_kpiStat;
		self.tblCargoCounter.accessCell(idx+1,_col).text		:=numItemsOther.asStringJMT.nullWhenZero();
	endif;	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_kpiStat" type="CMIF_KPICounterStat" usage="input"/>
        <Parameter name="_col" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setKPICargoTypeStatsGC" id="af12215f-5d7e-473f-b3f5-e1a1689b72f7">
        <source>setKPICargoTypeStatsGC(_kpiStat : CMIF_KPICounterStat input;
						_col : Integer) protected;
/*

Date		Who		Reason
13 July 2015	cnwer1	Initial creation PAR 36624

*/

vars
	idx : Integer;
	cargoType : CM_CargoType;
begin
	if _kpiStat = null then
		return;
	endif;
	
	cargoType:=_kpiStat.getCargoType;
	
	//////////// volume
	idx := self.rowHeaders.indexOf(cargoType.abbreviation &amp;  app.getErrorString(CM_VolumeM3));
	if idx &gt; 0 then	
		self.tblCargoCounter.accessCell(idx+1,_col).text:=_kpiStat.totalVolume.cnEcNumberFormat().cnEcStripDecimalZeros().nullWhenZero();
		self.tblCargoCounter.accessCell(idx+1,_col).itemObject :=_kpiStat;
	endif;

	/////////////// total quantity 
	idx := self.rowHeaders.indexOf(cargoType.abbreviation &amp;  app.getErrorString(CM_Total_Quantity));
	if idx &gt; 0 then
		self.tblCargoCounter.accessCell(idx+1,_col).text:=_kpiStat.totalQuantity.asStringJMT.nullWhenZero();
		self.tblCargoCounter.accessCell(idx+1,_col).itemObject :=_kpiStat;
	endif;
	///////////// weight
	idx := self.rowHeaders.indexOf(cargoType.abbreviation &amp;  app.getErrorString(Weight_kg));
	if idx &gt; 0 then
		self.tblCargoCounter.accessCell(idx+1,_col).text:=_kpiStat.totalWeight.cnEcNumberFormat().cnEcStripDecimalZeros().nullWhenZero();
		self.tblCargoCounter.accessCell(idx+1,_col).itemObject :=_kpiStat;
	endif;	
	///////////// weight
	idx := self.rowHeaders.indexOf(cargoType.abbreviation &amp;  app.getErrorString(TeuHeading));
	if idx &gt; 0 then
		self.tblCargoCounter.accessCell(idx+1,_col).text:=_kpiStat.getTEUGC.cnEcNumberFormat().cnEcStripDecimalZeros().nullWhenZero();
		self.tblCargoCounter.accessCell(idx+1,_col).itemObject :=_kpiStat;
	endif;	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_kpiStat" type="CMIF_KPICounterStat" usage="input"/>
        <Parameter name="_col" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setRowHeadings" id="4a820308-5757-443c-be40-2dc115f9bcbb">
        <updating/>
        <source>setRowHeadings(_containterCount ,_containterTeu, _teu, _weight, _count,_volume: Boolean) updating;
/*

Date		    	Who			Reason
13 September 2010	cnwas3	  	Initial creation
8 February 2022 	navcs2		TFS 52784 Added Boolean flags to method signature to be able to select certain rows in a table

*/

vars
	rows : Integer;
begin
	
	if self.cargoTypes.isEmpty() or
		self.tblCargoCounter.columns &lt;=1 then
		self.tblCargoCounter.rows := 1;
		return;
	endif;
	
	self.tblCargoCounter.fixedColumns := 1;		
	rows := 1;
	self.tblCargoCounter.rows := rows ;

	self.rowHeaders.clear();
	//epr par 36624 16/7/15
	if self.cargoTypes.first().isContainer then 
		if _containterTeu = true then
			self.setCargoTypeRowHeadings(true, app.getErrorString(TeuHeading));
		endif;
		if _containterCount = true then
			self.setCargoTypeRowHeadings(true,app.getErrorString(CM_Total_Quantity));
		endif;
	endif;
	
	if (self.cargoTypes.size() &gt; 1 or self.cargoTypes.first().id &lt;&gt; TI_CargoType_Container) then
		if _teu = true then
			self.setCargoTypeRowHeadings(false,app.getErrorString(TeuHeading));
		endif;
		if _count = true then
			self.setCargoTypeRowHeadings(false,app.getErrorString(CM_Total_Quantity));
		endif;
		if _volume = true then
			self.setCargoTypeRowHeadings(false,app.getErrorString(CM_VolumeM3));
		endif;
		if _weight = true then
			self.setCargoTypeRowHeadings(false,app.getErrorString(Weight_kg));
		endif;
	endif;
	
epilog

end;

</source>
        <Parameter name="_containterCount" type="Boolean"/>
        <Parameter name="_containterTeu" type="Boolean"/>
        <Parameter name="_teu" type="Boolean"/>
        <Parameter name="_weight" type="Boolean"/>
        <Parameter name="_count" type="Boolean"/>
        <Parameter name="_volume" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="fa850675-16d2-422c-a873-da6638a6641c">
        <updating/>
        <source>setupForm() updating;
/*

Date		    Who			Reason
16 September 2010	cnwas3	  Initial creation

*/

vars

begin
	inheritMethod();
	self.frmToolbar.alignContainer	:=	Frame.AlignContainer_Top; // this will make the dkcMain line up its top	
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;
	self.frmUserColours.visible := false;
	self.getXMLSettingsForSetup();	
	self.setNavigatorHeading(self.caption);		
	self.tblCargoCounter.rows := 0;
	self.tblCargoCounter.alignment := Table.Alignment_Right;
	self.tblCargoCounter.accessMode:=Table.AccessMode_Cell;
	self.tblCargoCounter.selectMode:=Table.SelectMode_Multiple;
	self.show30s := self.myTerminal.getConfig(Is30IncludedForReports).Integer;
	self.show45s := self.myTerminal.getConfig(Is45IncludedForReports).Integer;
	self.show53s := self.myTerminal.getConfig(Is53IncludedForReports).Integer;
	self.showSearcher := true;
	
	// register for notifications on KPI cargo count BGP completion/failure
	beginClassNotification(CM_Terminal, false, Event_KPICargoCountCompleted, Response_Continuous, 0);
	beginClassNotification(CM_Terminal, false, Event_KPICargoCountFailed, Response_Continuous, 0);
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnUpdate.enabled:= false;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="showUserColourFrame" id="876d4c48-8e25-4598-804e-5a2c8be646af">
        <source>showUserColourFrame();
/*

Date		    Who			Reason
09 November 2010	cnwas3	  Initial creation

*/

vars

begin
	self.frmUserColours.visible := not self.frmUserColours.visible;

	self.frmUserColours.centreWindow();
	self.clrCargoType.setColor(xmlColourCargoType);
	self.clrTotals.setColor(xmlColourTotals);
	self.clrRowColour.setColor(xmlColourRowColour);
	self.clrAltRowColour.setColor(xmlColourAltRow);
	self.frmUserColours.zOrder(1);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="stripTotalsColumnDecimals" id="5f1a7b12-c1e9-4778-b3e2-2ee757e4ccb2">
        <source>stripTotalsColumnDecimals();
/*

Date		    Who			Reason
13 October 2010	cnwas3	  Initial creation

*/

vars
	idx,columns : Integer;
	rowHeader  : String;
begin
	columns := self.tblCargoCounter.columns;
	foreach idx in 2 to self.rowHeaders.size() + 1 do
		rowHeader:=self.rowHeaders[idx-1] ;
		//epr par 36624 16/7/15
		if not rowHeader.endsWith(self.HeaderRow)   then 
			self.tblCargoCounter.accessCell(idx,columns).text := self.rowTotals[idx-1].cnEcNumberFormat().cnEcStripDecimalZeros();
			self.tblCargoCounter.accessedCell.fontBold := true;
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
