    <JadeMethod name="getObjectAndPointsForPosClass" id="ea038048-b079-4da7-abb3-58d21dbfa975">
        <source>getObjectAndPointsForPosClass(_class: Class; x: Integer; y: Integer; xy1: Point output; xy2: Point output): Object;
/* ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
10 Mar 2017 cnwer1 		removed references to trailer drawing controler

*/
vars
	tmpDrawingController	: YRD_ContainerDrawingController;
	tmpRDrawingController	: YRD_RoRoLaneDrawingController;
	anObject : Object;
begin

	tmpDrawingController := self.myDockBar.myDrawingController;
	if tmpDrawingController = null then
		
		tmpRDrawingController  := self.myDockBar.myRoRoLaneDrawingController;								// cnwjk3 ccms 1018 4/12/09	
		if  tmpRDrawingController = null then								// cnwjk3 ccms 1018 4/12/09	
			return null;																					// cnwjk3 ccms 1018 4/12/09			
		endif;																								// cnwjk3 ccms 1018 4/12/09	
				
																										// cnwjk3 ccms 1018 4/12/09	
		anObject:= tmpRDrawingController.allDrawnObjects.findObjectInDictFromPointClass(x, y,_class);	// cnwjk3 ccms 1018 4/12/09	
	
		
		return anObject;

	endif;
	
	anObject:= tmpDrawingController.getObjectAndPointsForPosition(x, y, xy1, xy2,_class);

	
	return anObject;

end;</source>
        <Parameter name="_class" type="Class"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <Parameter name="xy1" type="Point" usage="output"/>
        <Parameter name="xy2" type="Point" usage="output"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="getObjectAndPointsForPosition" id="6e1ad52b-c1bf-4716-8abd-b7838238f266">
        <source>getObjectAndPointsForPosition(x, y : Integer; xy1, xy2 : Point output) : Object;
// ---------------------------------------------------------------------------
// Created:     27 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpDrawingController	: YRD_ContainerDrawingController;
	anObject : Object;
	
	otherObject : Object;
begin

	// PAR 18682 tmpDrawingController := self.myDockBar.myDrawingController;
	if self.myDockBar &lt;&gt; null then
		tmpDrawingController := self.myDockBar.myDrawingController;
	elseif self.myDockBarBackground &lt;&gt; null then
		tmpDrawingController := self.myDockBarBackground.myDrawingController;
	endif;
	
	if tmpDrawingController = null then
		return null;
	endif;
	

	if anObject = null then
		anObject:= tmpDrawingController.getObjectAndPointsForPosition(x, y, xy1, xy2,CM_TrackedItem);
	endif;
	if anObject = null then
		anObject:= tmpDrawingController.getObjectAndPointsForPosition(x, y, xy1, xy2,CM_FutureMove); // PAR 18682
		if anObject = null then
			anObject:= tmpDrawingController.getObjectAndPointsForPosition(x, y, xy1, xy2,CM_Restriction);
			if anObject = null then
				anObject:= tmpDrawingController.getObjectAndPointsForPosition(x, y, xy1, xy2,CM_LocationsController);
				if anObject = null then
					anObject:= tmpDrawingController.getObjectAndPointsForPosition(x, y, xy1, xy2, CMIF_YardHeightExceeded);	// PAR 21532 CCMS SFW 1025
					if anObject = null then
						anObject:= tmpDrawingController.getObjectAndPointsForPosition(x, y, xy1, xy2,null);
						//cnwjo3 ccms 1018.  find the bounds of RoRoLaneAreas.  They only have thin lanes which are hard to select.
						if anObject = null then
							anObject := tmpDrawingController.allSelectionBoundsObjects.findObjectInDictByClass(x, y, xy1, xy2,CM_RoRoLaneArea);
						endif;
					endif;
				endif;
			endif;
		endif;
	endif;
	
	return anObject;
end;</source>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <Parameter name="xy1" type="Point" usage="output"/>
        <Parameter name="xy2" type="Point" usage="output"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="getObjectForPosition" id="e6423547-cbf6-446f-a96d-b366e84c3f47">
        <updating/>
        <source>getObjectForPosition(x: Integer; y: Integer): Object updating;
/* ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
10 Mar 2017 cnwer1 		removed references to trailer drawing controler
*/
vars
	xy1, xy2	: Point;
	tmpRDrawingController	: YRD_RoRoLaneDrawingController;
	anObject : Object;
begin


	if self.myDockBar.isForRoRoLanes then											// cnwjk3 ccms 1018 4/12/09
		tmpRDrawingController := self.myDockBar.myRoRoLaneDrawingController;			// cnwjk3 ccms 1018 4/12/09
		if tmpRDrawingController = null then											// cnwjk3 ccms 1018 4/12/09
			return null;																// cnwjk3 ccms 1018 4/12/09
		endif;																			// cnwjk3 ccms 1018 4/12/09
		return tmpRDrawingController.allDrawnObjects.findObjectInDictFromPoint(x, y);	// cnwjk3 ccms 1018 4/12/09
	else

		return self.getObjectAndPointsForPosition(x, y, xy1, xy2);
	endif;
end;</source>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Object"/>
    </JadeMethod>
