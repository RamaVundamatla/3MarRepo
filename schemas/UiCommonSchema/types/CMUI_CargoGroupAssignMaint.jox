    <JadeMethod name="setFilterValues" id="e36275ce-2502-4436-9edd-8b175e0907e2">
        <updating/>
        <source>setFilterValues() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 July 2018	jlgndl1	Initial creation	TFS 39186

*/

vars


	filterEdiDateFrom : Date;
	filterEdiTimeFrom : Time;
	filterEdiDateTo : Date;
	filterEdiTimeTo : Time;
	filterGrpCompDateFrom : Date;
	filterGrpCompTimeFrom : Time;
	filterGrpCompDateTo : Date;
	filterGrpCompTimeTo : Time;

begin

	self.filterCGAId := self.tblSearch.getValueByNameIfVisible( ETRow_AssignmentId ).String.toUpper;
	self.filterCGId := self.tblSearch.getValueByNameIfVisible( ETRow_CargoGroupId ).String.toUpper;
	self.filterCargoType := self.cmbCargoType.listObject.CM_CargoType;
	self.filterSubCargoType := self.cmbSubCargoType.listObject.CM_Product;
	self.filterStatus := self.cmbStatus.listData.Integer;		//( completed/non-completed, scanned / no scanned )
	filterEdiDateFrom := self.tblSearch.getValueByNameIfVisible( ETRow_EdiDateFrom ).Date;
	filterEdiTimeFrom := self.tblSearch.getValueByNameIfVisible( ETRow_EdiTimeFrom ).Time;
	if filterEdiDateFrom.isValid then
		self.filterEdiTSFrom.setDate(filterEdiDateFrom);
		self.filterEdiTSFrom.setTime(filterEdiTimeFrom);
	else
		self.filterEdiTSFrom := null;
	endif;
	filterEdiDateTo := self.tblSearch.getValueByNameIfVisible( ETRow_EdiDateTo ).Date;
	filterEdiTimeTo := self.tblSearch.getValueByNameIfVisible( ETRow_EdiTimeTo ).Time;
	if filterEdiDateTo.isValid then
		self.filterEdiTSTo.setDate(filterEdiDateTo);
		self.filterEdiTSTo.setTime(filterEdiTimeTo);
	else
		self.filterEdiTSTo := null;
	endif;
	filterGrpCompDateFrom := self.tblSearch.getValueByNameIfVisible( ETRow_GrpCompDateFrom ).Date;
	filterGrpCompTimeFrom := self.tblSearch.getValueByNameIfVisible( ETRow_GrpCompTimeFrom ).Time;
	if filterGrpCompDateFrom.isValid then
		self.filterGrpCompTSFrom.setDate(filterGrpCompDateFrom);
		self.filterGrpCompTSFrom.setTime(filterGrpCompTimeFrom);
	else
		self.filterGrpCompTSFrom := null;
	endif;
	filterGrpCompDateTo := self.tblSearch.getValueByNameIfVisible( ETRow_GrpCompDateTo ).Date;
	filterGrpCompTimeTo := self.tblSearch.getValueByNameIfVisible( ETRow_GrpCompTimeTo ).Time;
	if filterGrpCompDateTo.isValid then
		self.filterGrpCompTSTo.setDate(filterGrpCompDateTo);
		self.filterGrpCompTSTo.setTime(filterGrpCompTimeTo);
	else
		self.filterGrpCompTSTo := null;
	endif;
	self.filterAssignmentType := self.cmbCGAType.listData.Integer;		//Selectable / Pre-Assigned
	

epilog

end;</source>
    </JadeMethod>
