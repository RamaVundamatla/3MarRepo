    <JadeMethod name="setMyCurrentVoyage" id="ba2da908-fa6e-4e9f-b2eb-1eae23f9fa29">
        <updating/>
        <source>setMyCurrentVoyage(_newVoyage : CM_Voyage) updating;
// --------------------------------------------------------------------------------
// Created:		16 March 2010 by cnwjo3
//
// Purpose:		This is a safety method to deal with self.myCurrentVoyage being invalid sometimes
//				Ideally you should never use self.myCurrentVoyage.  Only use this method.  par 23105
//				If code attempts to set self.myCurrentVoyage to an invalid object it will set
//				it to null
//
vars
	currentVoyage : CM_Voyage;
	invalid : Boolean;
	voyageCode : String;
begin
	currentVoyage := _newVoyage;

	if currentVoyage &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception,currentVoyage,invalid);
		
		//cause exception if invalid object
		voyageCode := currentVoyage.code;
	endif;
	
	//we don't want to set an invalid voyage to myCurrentVoyage.  just in case
	if invalid then
		self.myCurrentVoyage := null;
	else
		self.myCurrentVoyage := currentVoyage;
	endif;
end;</source>
        <Parameter name="_newVoyage" type="CM_Voyage"/>
    </JadeMethod>
