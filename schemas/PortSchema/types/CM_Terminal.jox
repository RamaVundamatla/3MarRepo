    <JadeMethod name="setDefaultGate_IN" id="1ac28fc4-5db7-4bea-9e63-64172d885149">
        <updating/>
        <source>setDefaultGate_IN(_gate :CM_Gate) updating;
// ---------------------------------------------------------------------------
// Created:     31 July 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if not _gate.isInGate then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Gate is not an entry gate');
	endif;

	self.setConfig (GateDefaultEntry, _gate);
epilog

end;</source>
        <Parameter name="_gate" type="CM_Gate"/>
    </JadeMethod>
    <JadeMethod name="setDefaultGate_OUT" id="625a8b83-0f50-4b45-a719-81fde96b78ba">
        <updating/>
        <source>setDefaultGate_OUT(_gate :CM_Gate) updating;
// ---------------------------------------------------------------------------
// Created:     31 July 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if not _gate.isOutGate then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Gate is not an exit gate');
	endif;
	
	self.setConfig (GateDefaultExit, _gate);
epilog

end;</source>
        <Parameter name="_gate" type="CM_Gate"/>
    </JadeMethod>
    <JadeMethod name="setDefaultReeferCmdty" id="ea3e03ba-f0fd-4b55-a692-48e6efe9a29e">
        <source>setDefaultReeferCmdty(_cmdtyCode: String): String;
//----------------------------------------------------------------
//	Created:	07 April 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//	Can remove after 722c
//----------------------------------------------------------------

vars
	theCode	: String;
	cmdty	: CM_Commodity;
begin
	theCode := _cmdtyCode.trimBlanks;
	cmdty := self.myRoot.allCommodities[theCode];

	if cmdty = null then
		return "Commodity with code " &amp; theCode &amp; " not found in the system.";
	endif;
	beginTransaction;
	self.setConfig(DefReeferComdty, theCode);
	commitTransaction;
	if self.getConfig(DefReeferComdty).String = theCode then
		return "The default reefer commodity is now " &amp; theCode &amp; ".";
	else
		return "There was a problem setting the default reefer commodity.  Contact supplier";
	endif;
		

end;</source>
        <Parameter name="_cmdtyCode" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
