    <JadeMethod name="getFirstTrackedItemSubType" id="846ed84e-1f37-4d5c-9285-652a6017a428">
        <source>getFirstTrackedItemSubType():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 October 2020	jlgndl1	Initial creation	TFS 49189
07 March   2022	navpw1	Applied changes to fix issues where cargo sub type not displaying even though there is a cargo sub type

*/

vars
	gateEntity 	: CMGTE_Entity;		// ### TFS 52862 22Mar2022 NAVPW1
	ti 			: CM_TrackedItem;

begin

	if self.allReceivedTrackedItems.size &gt; 0 then
		ti := self.allReceivedTrackedItems.first;
		
	elseif self.allReleasedTrackedItems.size &gt; 0 then	// ### TFS 52862 22Mar2022 NAVPW1
		ti := self.allReleasedTrackedItems.first;		// ### TFS 52862 22Mar2022 NAVPW1
		
	// ### TFS 52862 22Mar2022 NAVPW1
	elseif self.allGateEntities.size &gt; 0 then
		foreach gateEntity in self.allGateEntities do
			if gateEntity.isRelease() and gateEntity.CMGTE_Release.myTrackedItem &lt;&gt; null and not gateEntity.isTrailer() then
				ti := gateEntity.CMGTE_Release.myTrackedItem;
				break;
			elseif not gateEntity.isTrailer() and not gateEntity.isRecievalByType() and not gateEntity.isRelease() and gateEntity.CMGTE_Receival.myTrackedItem &lt;&gt; null then
				ti := gateEntity.CMGTE_Receival.myTrackedItem;
				break;
			endif;
		endforeach;
	// ### TFS 52862 22Mar2022 NAVPW1
	
	//elseif self.allGateEntities.size &gt; 0  and self.allGateEntities.first.isRelease then
	//	ti := self.allGateEntities.first.CMGTE_Release.myTrackedItem;
		
	else
		ti := null;
		
	endif;
	
	if ti &lt;&gt; null and ti.myProduct &lt;&gt; null then
		return ti.myProduct.code;
	endif;
	
	return null;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFirstTrackedItemType" id="234044f0-a46c-4bb9-8107-2a88828669af">
        <source>getFirstTrackedItemType() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 January 2017	cnwns1	Initial creation
07 March   2022	navpw1	Applied changes to fix issues where cargo type not displaying even though there is a cargo type

*/

vars
	gateEntity : CMGTE_Entity;	// ### TFS 52862 22Mar2022 NAVPW1
	
begin
    if self.allReceivedTrackedItems.size &gt; 0 then
		return self.allReceivedTrackedItems.first.cargoTypeDescr;
		
	elseif self.allReleasedTrackedItems.size &gt; 0 then				// ### TFS 52862 22Mar2022 NAVPW1
		return self.allReleasedTrackedItems.first.cargoTypeDescr;	// ### TFS 52862 22Mar2022 NAVPW1
	
	// ### TFS 52862 22Mar2022 NAVPW1
	elseif self.allGateEntities.size &gt; 0 then
		foreach gateEntity in self.allGateEntities do
			if gateEntity.isRelease() and gateEntity.CMGTE_Release.myTrackedItem &lt;&gt; null and not gateEntity.isTrailer() then
				return gateEntity.CMGTE_Release.myTrackedItem.cargoTypeDescr;
			elseif not gateEntity.isTrailer() and not gateEntity.isRecievalByType() and not gateEntity.isRelease() and gateEntity.CMGTE_Receival.myTrackedItem &lt;&gt; null then
				return gateEntity.CMGTE_Receival.myTrackedItem.cargoTypeDescr;
			endif;
		endforeach;
	// ### TFS 52862 22Mar2022 NAVPW1
	
	//elseif ( self.allGateEntities.size &gt; 0
	//		and self.allGateEntities.first.isRelease
	//		and self.allGateEntities.first.CMGTE_Release.myTrackedItem &lt;&gt; null	//14 Oct 2020	NDL	TFS 49189
	//		) then
	//	return self.allGateEntities.first.CMGTE_Release.myTrackedItem.cargoTypeDescr;
	else
		return null;
	endif;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
