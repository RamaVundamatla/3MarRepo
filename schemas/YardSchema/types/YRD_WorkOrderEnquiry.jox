    <JadeMethod name="setSearchValues" id="29617c99-85fe-46a8-886f-7755d5fa67ac">
        <updating/>
        <source>setSearchValues() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2025	navsp1	Initial creation JIRA-34585 MTN | Work Order Enquiry Query Refactor

*/

vars
    ts                  : TimeStamp;
    voyWoToInclude   	: IntegerArray;
	cargoWoToInclude 	: IntegerArray;
	toDoWoToInclude	 	: IntegerArray;
	transModeToInclude	: IntegerArray; 
begin
    self.filterOrganisation             := self.cmbOrganisation.listObject.CM_Organisation;
    self.filterCustomerRef              := self.txtCustomerRef.text;
    self.filterVoyage                   := self.cmbVoyage.listObject.CM_Voyage;
    self.filterVessel                   := self.cmbVessel.listObject.CM_Vessel;
    self.filterToDoTask                 := self.cmbToDoTask.listObject.CM_ToDoTaskDesc;
    self.filterCargoGroupID             := self.txtCargoGroupID.text;
    self.filterOperator                 := self.cmbOperator.listObject.CM_Operator;
    self.filterBookingID                := self.txtBookingID.text;
    self.filterReleaseReqNum            := self.txtReleaseReqNum.text;
    self.filterBOL                      := self.cmbBOL.listObject.CM_BOL;
    self.filterTrain                    := self.cmbTrain.listObject.CM_Train;
    self.filterDebtor                   := self.cmbDebtor.listObject.CM_Debtor;
    self.filterContractID               := self.txtContractID.text;
    self.filterVehicleVisit             := self.cmbVehicleVisit.listObject.CM_VehicleVisitRecord;
    self.filterWagon                    := self.cmbWagon.listObject.CM_Wagon;
    self.filterVBSExtRef                := self.txtVBSExtRef.text;
    self.filterCustomsEntryNumber       := self.txtCustomsEntryNum.text;    
    self.filterUser                     := self.cmbUsers.listObject.CM_User;
	self.filterWorkOrderNum				:= self.txtWorkOrderNum.text; //13/06/2025	navkc1 JIRA MTN 35077
    
    //Set the date properties
    self.filterMskRequestedByFromTS.setDate(self.mskRequestedByFromDT.getDate());
    self.filterMskRequestedByFromTS.setTime(self.mskRequestedByFromTM.getTime());
    
    self.filterMskCompletedTS.setDate(self.mskCompletedDT.getDate());
    self.filterMskCompletedTS.setTime(self.mskCompletedTM.getTime());
    
    self.filterMskCompletedToTS.setDate(self.mskCompletedToDT.getDate());
    self.filterMskCompletedToTS.setTime(self.mskCompletedToTM.getTime());
    
    self.filterMskRequestTS.setDate(self.mskRequestlDT.getDate());
    self.filterMskRequestTS.setTime(self.mskRequestTM.getTime());
    
    self.filterMskRequestToTS.setDate(self.mskRequestToDT.getDate());
    self.filterMskRequestToTS.setTime(self.mskRequestToTM.getTime());
    
    self.filterMskRequestedByToTS.setDate(self.mskRequestedByToDT.getDate());
    self.filterMskRequestedByToTS.setTime(self.mskRequestedByToTM.getTime());
    
    self.filterMskScheduleTS.setDate(self.mskScheduleDT.getDate());
    self.filterMskScheduleTS.setTime(self.mskScheduleTM.getTime());
    
    self.filterMskScheduleToTS.setDate(self.mskScheduleToDT.getDate());
    self.filterMskScheduleToTS.setTime(self.mskScheduleToTM.getTime());   
    
    //Set the collection properties
    create voyWoToInclude transient;
    self.getVoyWOdtlTaskNos( voyWoToInclude );
    self.filterVoyWOdtlTaskNos := voyWoToInclude;

    create cargoWoToInclude transient;
    self.getCargoWOdtlTaskNos( cargoWoToInclude );
    self.filterCargoWOdtlTaskNos := cargoWoToInclude;
    
    create toDoWoToInclude transient;
    self.getToDoWOdtlTasksNos( toDoWoToInclude );
    self.filterToDoWOdtlTasksNos := toDoWoToInclude;
    
    create transModeToInclude transient;
    self.getTransportModes(transModeToInclude);
    self.filterTransportModes := transModeToInclude;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
