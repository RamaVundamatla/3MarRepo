    <JadeMethod name="create" id="effa1985-6f52-45c9-b811-514c4aaba32d">
        <updating/>
        <source>create() updating;
// if properties are set via setProperty and not via setForUpdate, default moveType to queued move and cargoType to Container
vars

begin
	self.moveType := QUEUE_MODE;
	self.cargoType := TI_CargoType_Container;
end;
</source>
    </JadeMethod>
    <JadeMethod name="getMyTIDisplayDefName" id="7da9c806-0a2d-4779-9622-e882950b5c43">
        <source>getMyTIDisplayDefName(): String;
// Sep 2015 36912 TFS 456 EDI queued move
vars

begin
	return ETDef_EDITIMove;
end;
</source>
        <ReturnType type="String"/>
