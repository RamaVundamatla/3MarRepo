    <JadeMethod name="setOpsViewData" id="a2685e02-c12d-4a13-97db-1d2520b7910c">
        <updating/>
        <source>setOpsViewData(_isVesselData : Boolean; _mandatorySnapshot : Boolean)updating;
/*

Purpose:		the URL for OpsView must end in 'OpsView', the producer API endpoint is appended for read only.	

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2020 cnwma1 ChangeRequest 49906: MTN - Ops View External Webservice
*/

vars
	postrt, len : Integer;
begin
// NOT USED	self.isVesselData :=_isVesselData;
	self.mandatorySnapshot := _mandatorySnapshot; // ### TFS 50669 18AUG2021 NAVAB1
	
	
	// Auto add 'OpsView/' on the end.
	// make sure 'opsview/' is 'OpsView/'
	//make the API URL be same as OpsViews

	len := self.baseEndpoint.length;
	
	if len &gt; 6 then
		if self.baseEndpoint[len - 6:end].toLower = "opsview" then
			self.baseEndpointAPI := self.baseEndpoint[1:len - 7] &amp; "api/"; // ### TFS 52598 21DEC2021 NAVAB1
			self.baseEndpoint := self.baseEndpoint[1:len - 7] &amp; "OpsView/"; // ### TFS 52598 21DEC2021 NAVAB1
		elseif len &gt; 7 and self.baseEndpoint[len - 7:end].toLower = "opsview/" then
			self.baseEndpointAPI := self.baseEndpoint[1:len - 8] &amp; "api/"; // ### TFS 52598 21DEC2021 NAVAB1
			self.baseEndpoint := self.baseEndpoint[1:len - 8] &amp; "OpsView/"; // ### TFS 52598 21DEC2021 NAVAB1
		else
			if self.baseEndpoint[len:len] &lt;&gt; "/" then
				self.baseEndpoint := self.baseEndpoint &amp; "/";	// '/'. Consequently the baseEndpointAPI would also end 
			
			endif;
			self.baseEndpointAPI := self.baseEndpoint &amp; "api/"; // ### TFS 52598 21DEC2021 NAVAB1
			self.baseEndpoint := self.baseEndpoint &amp; "OpsView/"; // ### TFS 52598 21DEC2021 NAVAB1
		
		endif;
	else
		if self.baseEndpoint[len:len] &lt;&gt; "/" then
			self.baseEndpoint := self.baseEndpoint &amp; "/";	// '/'. Consequently the baseEndpointAPI would also end 
		endif;
		self.baseEndpointAPI := self.baseEndpoint &amp; "api/"; // ### TFS 52598 21DEC2021 NAVAB1
		self.baseEndpoint := self.baseEndpoint &amp; "OpsView/"; // ### TFS 52598 21DEC2021 NAVAB1
	endif;


epilog

end;</source>
        <Parameter name="_isVesselData" type="Boolean"/>
        <Parameter name="_mandatorySnapshot" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxyForStatus" id="67fec29e-69ad-43c6-97ec-5c55398f1f58">
        <updating/>
        <source>setProxyForStatus(_status : String; _sequence : Integer64; _lastTs : TimeStamp; _statusMessage : String) updating;
/*
