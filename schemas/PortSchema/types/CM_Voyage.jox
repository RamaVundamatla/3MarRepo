    <JadeMethod name="updateCode" id="0b014feb-762e-40c0-9c64-44e1e1535f6b">
        <updating/>
        <source>updateCode(_newCode : String; _passport : CM_Passport input) updating, protected;
//--------------------------------------------------
// Created:	01 March 2004 By: cnwgd1
//--------------------------------------------------
// Should only be called from self.setForUpdate 
// as it also handles the update to CM_Terminal.allVoyage external key dict
// 15/04/2013	cnwcs5		CCMS POL 2097 / par 31259

vars
	origCode 		: String;
	xlation			: CM_Xlation;
	bookingRef		: CM_BookingRef;
	voyGlobalRealNew: CM_VoyageGlobal;
	voyGlobalRemove	: CM_VoyageGlobalSet;
begin
	
	// Should be called when updating the actual voyage code
	self.raiseExceptionIfTransient(method);
	
	// Check code has changed
	if _newCode = self.code or _newCode = null then
		return;
	endif;
	
	// Save off original code before changing
	origCode := self.code;
	
	/*
		   Date		      Who		Reason
		30 July 2008	cnwdz2	    Par15231 - The voyages are keyed by code and arrival date in the external dictionary
											   on terminal(allVoyagesNew). Thus, it needs to be manually maintained by removing the voyage
											   from the dictionary before changing its code.
	*/
	if not self.isTransient then
		if self.myTerminal &lt;&gt; null then
			self.myTerminal.removeVoyageFromDict(self, false);
			//22/12/2009 cnwdz2 Par21551 The voyages are keyed by code in the dictionary M_EDIConfig::allVoyagesToProcess. Thus
			//it needs to be manually maintained by removing the voyage from the dictionary before changing its code.
			//13/05/2010 - PAR24219 - Because we should only be updating the key if the voyage is already in the collection, this has been removed and the update made
			// further down in the self.myTerminal.myEdiConfig.updateVoyagesToProcess(self, origCode); method.
			//if self.myTerminal.myEdiConfig &lt;&gt; null then
			//	self.myTerminal.myEdiConfig.removeVoyageFromProcessing(self);
			//endif;
		endif;
	endif;
	
	// Change to the new code before updating the tracked items
	self.code := _newCode;
	
	/*
		   Date		      Who		Reason
		30 July 2008	cnwdz2	    Par15231 - The voyages are keyed by code and arrival date in the external dictionary
											   on terminal (allVoyagesNew). Thus, it needs to be manually maintained by adding the voyage
											   into the dictionary after changing its code.
	*/
	if not self.isTransient then
		if self.myTerminal &lt;&gt; null then
			self.myTerminal.addVoyageToDict(self.code, self.inwardCode, self);
			//22/12/2009 cnwdz2 Par21551 needs to be manually maintained by adding the voyage into the dictionary after changing its code.
			if self.myTerminal.myEdiConfig &lt;&gt; null then
				//self.myTerminal.myEdiConfig.addVoyageToProcessing(self);
				self.myTerminal.myEdiConfig.updateVoyagesToProcess(self, origCode); //PAR24219
			endif;
		endif;
	endif;
	
	// Update voyageCode property on all associated Tracked items
	// if the tracked items voyageCode property matches the origCode
	// Note: CM_TrackedItem::voyageCode is set by either self.code or self.inwardCode
	self.updateTrackedItemVoyageCode(origCode, self.code, _passport);
	//fixup all xlations that will be using the old code PAR10189 may 2005 RS
	self.updateXlations_Code (_newCode, origCode, self.allXlations);	// par 31259

	//CCMS 1069
	//th2 for PAR 14274 -  needs to update for voyage translations as well
	//method moved to app
	// app.reconcileBookingRefsToVoyage(self, null); Removed PAR 19171 cnwgb1 19.3.09. Would have only worked if the EDI voyage code was the same as this voyage
	
	// Lorcan 17/8/2007 If the code gets changed we must update the code on the Global Voyage
	voyGlobalRealNew := app.myRoot.allVoyagesGlobal[_newCode];			// 5/11/18 MAP TFS41143
	create voyGlobalRemove transient;
	if self.myVoyageGlobalArrival &lt;&gt; null and self.myVoyageGlobalArrival.code = origCode then
		if voyGlobalRealNew = null then									// check whether global voyage already exists for new code
			self.myVoyageGlobalArrival.setCode(_newCode);
		else	// voyage code is being renamed to one that already exists
			if self.myVoyageGlobalArrival.allVoyages.size() = 1 then
				voyGlobalRemove.add(self.myVoyageGlobalArrival);
			endif;
			self.setMyVoyageGlobalArrival(voyGlobalRealNew);
			voyGlobalRemove.purge();
		endif;
	endif;
	if self.myVoyageGlobalDeparture &lt;&gt; null and self.myVoyageGlobalDeparture.code = origCode then
		if voyGlobalRealNew = null then
			self.myVoyageGlobalDeparture.setCode(_newCode);
		else
			if self.myVoyageGlobalDeparture.allVoyages.size() = 1 then
				voyGlobalRemove.add(self.myVoyageGlobalDeparture);
			endif;
			self.setMyVoyageGlobalDeparture(voyGlobalRealNew);
			voyGlobalRemove.purge();
		endif;
	endif;
	
epilog
	delete voyGlobalRemove;
end;</source>
        <access>protected</access>
        <Parameter name="_newCode" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateInvoiceVoyageGrpCode" id="0b3186ba-eb20-41fb-a1c7-2b2df58edd0b">
        <source>updateInvoiceVoyageGrpCode(_voyageGroupCode : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/06/2020 cnwma1 ChangeRequest 49400: ASPA - Invoice Enhancements for Barges

*/

vars
	invoice : CM_Invoice;
	
begin
	self.raiseExceptionIfTransient(method);
	
	if self.allInvoices.isEmpty then
		return;
	endif;
		
	foreach invoice in self.allInvoices do
		invoice.setVoyageGroupCode(_voyageGroupCode);
	endforeach;
epilog

end;</source>
        <Parameter name="_voyageGroupCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateInwardCode" id="40684200-0dfe-499a-a1ad-0ce195d501b0">
        <updating/>
        <source>updateInwardCode(_newInwardCode : String; _passport : CM_Passport input) updating, protected;
//--------------------------------------------------
// Created:	01 March 2004 By: cnwgd1
//--------------------------------------------------
// Should only be called from self.setForUpdate 
// as it also handles the update to CM_Terminal.allVoyage external key dict
// 20/09/2010	cnwdap1		PAR #25784 Don't update the voyage code on all attached TIs just because we changed the inwards code
// 15/04/2013	cnwcs5		CCMS POL 2097 / par 31259
// 17/10/2017	jlgdap1		CIG 7366 Ensure voyage is added to inwards code collection on terminal
vars
	origInwardCode,
	newCode: String;
begin
	
	// Should be called when updating the actual voyage code
	self.raiseExceptionIfTransient(method);
	
	// Check code has changed
	if _newInwardCode = self.inwardCode then
		return;
	endif;
	
	// Save off original code before changing
	origInwardCode := self.inwardCode;
	
	/*
		   Date		      Who		Reason
		30 July 2008	cnwdz2	    Par15231 - The external dictionary on terminal (allVoyagesNew) contains both the code and the inwardcode.
		                                       Thus, the voyage should be removed from the manual dictionary before its code is changed.
	*/
	if not self.isTransient then
		if self.myTerminal &lt;&gt; null then
			self.myTerminal.removeVoyageFromDict(self, false);
		endif;
	endif;
	
	//epr par 20749  28/10/09
	if self.myTerminalForInwardCode &lt;&gt; null and _newInwardCode = null then
		self.myTerminalForInwardCode:=null;
	endif;
	// Change to the new code before updating the tracked items
	self.inwardCode := _newInwardCode;
	if self.myTerminalForInwardCode = null and self.inwardCode &lt;&gt; null then		// TFS 7366
		self.myTerminalForInwardCode := self.myTerminal;						// TFS 7366
	endif;																		// TFS 7366
	
	
	/*
		   Date		      Who		Reason
		30 July 2008	cnwdz2	    Par15231 - The external dictionary on terminal (allVoyagesNew) contains both the code and the inwardcode.
		                                       Thus, the voyage should be added into the manual dictionary after its code is changed.
	*/
	if not self.isTransient then
		if self.myTerminal &lt;&gt; null then
			self.myTerminal.addVoyageToDict(self.code, self.inwardCode, self);
		endif;
	endif;
	
	//epr par 20749 28/9/09 its null then new code will be self.code
	newCode:=self.inwardCode;
	if  newCode = null then
		newCode:=self.code;
	endif;
	// Update voyageCode property on all associated Tracked items
	// if the tracked items voyageCode property matches the origCode
	// Note: CM_TrackedItem::voyageCode is set by either self.code or self.inwardCode
	// PAR #25784 DON'T do this - it resets the voyageCode reference on all tracked items assigned to this voyage,
	// and means a Selector Query on this voyage WILL NOT find them.
	//self.updateTrackedItemVoyageCode(origInwardCode, newCode, _passport);

	self.updateXlations_Code (newCode, origInwardCode, self.allXlations);	// par 31259

	// Lorcan 17/8/2007 If the code gets changed we must update the code on the Global Voyage
	if self.myVoyageGlobalArrival &lt;&gt; null and
	   self.myVoyageGlobalArrival.code = origInwardCode then
		self.myVoyageGlobalArrival.setCode(newCode);
	endif;
	if self.myVoyageGlobalDeparture &lt;&gt; null and
	   self.myVoyageGlobalDeparture.code = origInwardCode then
		self.myVoyageGlobalDeparture.setCode(newCode);
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_newInwardCode" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateInwardCodeAuto" id="f49becaf-1d7b-4b2a-bed0-d9ec036fb290">
        <updating/>
        <source>updateInwardCodeAuto(_newCode : String; _passport : CM_Passport input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
16 July 2024	navlw1	ChangeRequest 63839: NSW | OnePort - Uniqueness of Inward and External Code 

*/

vars
	origInwardCodeAuto,
	newCode				: String;
begin
	// Should be called when updating the actual voyage code
	self.raiseExceptionIfTransient(method);
	
	// Check code has changed
	if _newCode = self.inwardCodeAuto then
		return;
	endif;
	
	// Save off original code before changing
	origInwardCodeAuto := self.inwardCodeAuto;
	
	if self.myTerminalForInwardCodeAuto &lt;&gt; null and _newCode = null then
		self.myTerminalForInwardCodeAuto:=null;
	endif;
	
	self.inwardCodeAuto := _newCode;
	if self.myTerminalForInwardCodeAuto = null and self.inwardCodeAuto &lt;&gt; null then
		self.myTerminalForInwardCodeAuto := self.myTerminal;						
	endif;
	
	if not self.isTransient then
		if self.myTerminal &lt;&gt; null then
			self.myTerminal.addVoyageToDict(self.code, self.inwardCodeAuto, self);
		endif;
	endif;
	
	newCode := self.inwardCodeAuto;
	if  newCode = null then
		newCode := self.code;
	endif;
	
	self.updateXlations_Code (newCode, origInwardCodeAuto, self.allXlations);
	
	// global voyage
	if self.myVoyageGlobalArrival &lt;&gt; null and
	   self.myVoyageGlobalArrival.code = origInwardCodeAuto then
		self.myVoyageGlobalArrival.setCode(newCode);
	endif;
	
	if self.myVoyageGlobalDeparture &lt;&gt; null and
	   self.myVoyageGlobalDeparture.code = origInwardCodeAuto then
		self.myVoyageGlobalDeparture.setCode(newCode);
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_newCode" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateMovementsSequence" id="dec51be0-089d-4ab7-a9ea-0dc379c5f440">
        <updating/>
        <source>updateMovementsSequence() updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 01 September 2023
TFS#		: 59854
Function	:

*** Changes ***
Date			Name		TFS#		Description
18/09/2023		jlika1		60515		POB - Unable to create a Shift Movement by loading the edi file
****************************************************/

vars
	upMovement  : HMS_VoyageMovement;
	movement 	: HMS_VoyageMovement;
	recNo		: Integer;
	recCount 	: Integer;
	voyageData 	: HMS_VoyageData;
	index		: Integer;
begin
	if self.myHMSVoyageData = null then
		return;
	endif;
	
	voyageData := self.myHMSVoyageData;
	recCount := voyageData.allVoyageMovements.size;
	
	//Reset all previous and next movement to null 
	foreach movement in voyageData.allVoyageMovements do				
		movement.setMyPreviousMovement(null);					
		movement.setMyNextMovement(null);		
	endforeach;	
	
	//Remapped the mypreviousmovement and mynextmovement based on the sorting within the collection
	while recNo &lt; recCount do
		index := 0;
		if recNo = 0 then // Expect it to be an Arrival
			foreach movement in voyageData.allVoyageMovements do				
				if recNo = index then
					upMovement := movement;
					upMovement.setMyPreviousMovement(null);
				else
					if recNo + 1 = index then						
						upMovement.setMyNextMovement(movement);						
						break;
					endif;	
				endif;				
				index := index + 1;
			endforeach;
		elseif recNo = recCount - 1 then // Departure
			index := recCount;
			foreach movement in voyageData.allVoyageMovements reversed do
				index := index - 1;
				if recNo = index then
					upMovement := movement;
					upMovement.setMyNextMovement(null);	
				else
					if recNo - 1 = index then
						upMovement.setMyPreviousMovement(movement);
						break;
					endif;	
				endif;				
			endforeach;
		else// all the other movements
			foreach movement in voyageData.allVoyageMovements do				
				if recNo = index then
					upMovement := movement;					
				else
					if recNo + 1 = index then
						upMovement.setMyNextMovement(movement);
						break;
					endif;	
				endif;				
				index := index + 1;
			endforeach;
		endif;		
		recNo := recNo + 1;
	endwhile;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="updateTrackedItemVoyageCode" id="063eaaaf-b7a9-4235-9df7-3a9b7aa9e369">
        <updating/>
        <source>updateTrackedItemVoyageCode(_origCode, _newCode : String; /* _isInwardCode : Boolean; */ _passport : CM_Passport input) updating, protected;
//--------------------------------------------------
// Created:	01 March 2004 By: cnwgd1
//--------------------------------------------------
// Update voyageCode property on all associated Tracked items
// if the tracked items voyageCode property matches the origCode
// Note: CM_TrackedItem::voyageCode is set by either self.code or self.inwardCode
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------------------------
// 30/03/2016	cnwdap1		PAR #35843 Monitor shold update on a time basis, not a per-object basis
vars
	ti : CM_TrackedItem;
	count : Integer;
	cmifMonitor : CMIF_Monitor;
	msg : String;
	lastUpdated : Decimal [20];							// PAR #35843
begin
	
	// Should be called when updating the actual voyage code
	self.raiseExceptionIfTransient(method);
	cmifMonitor := _passport.myCMIFMonitor;
	
	msg := 'Updating Prenotified cargo';
	if cmifMonitor &lt;&gt; null then
		cmifMonitor.updateProgress(msg, cmifMonitor.partsInJob, count);
	endif;		
	foreach ti in self.allNotifiedTIsByIdCargoType do
		count := count+1;
		
		/*
		if _isInwardCode then
			if ti.voyageCode.trimBlanks = _origCode and
			   ti.voyageCode.trimBlanks &lt;&gt; self.code then
				ti.setVoyageCodeForVoyCodeChange(_newCode, _passport);
			endif;
		else
		*/
			if ti.voyageCode.trimBlanks = _origCode then
				ti.setVoyageCodeForVoyCodeChange(_newCode, _passport);
			endif;
		//endif;
		
		if ti.voyageCode.trimBlanks = _origCode and
		   ti.voyageCode.trimBlanks &lt;&gt; self.code then
		
		
		
			ti.setVoyageCodeForVoyCodeChange(_newCode, _passport);
		endif;
		if cmifMonitor &lt;&gt; null then
			if (app.relativeMachineTime - lastUpdated) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	// PAR #35843
				cmifMonitor.updateProgress(msg, cmifMonitor.partsInJob, count);
				lastUpdated := app.relativeMachineTime;													// PAR #35843
			endif;																						// PAR #35843
		endif;		
	endforeach;
	
	msg := 'Updating Off loaded cargo';
	if cmifMonitor &lt;&gt; null then
		cmifMonitor.updateProgress(msg, cmifMonitor.partsInJob, count);
	endif;	
	foreach ti in self.allOffloadedTIsByIdCargoType do
		count := count+1;
		if ti.voyageCode.trimBlanks = _origCode then
			ti.setVoyageCodeForVoyCodeChange(_newCode, _passport);
		endif;
		if cmifMonitor &lt;&gt; null then
			if (app.relativeMachineTime - lastUpdated) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	// PAR #35843
				cmifMonitor.updateProgress(msg, cmifMonitor.partsInJob, count);
				lastUpdated := app.relativeMachineTime;													// PAR #35843
			endif;																						// PAR #35843
		endif;
	endforeach;
	
	msg := 'Updating Off site cargo';
	if cmifMonitor &lt;&gt; null then
		cmifMonitor.updateProgress(msg, cmifMonitor.partsInJob, count);
	endif;		
	foreach ti in self.allOffsiteTIsByIdCargoType do
		count := count+1;
		if ti.voyageCode.trimBlanks = _origCode then
			ti.setVoyageCodeForVoyCodeChange(_newCode, _passport);
		endif;
		if cmifMonitor &lt;&gt; null then
			if (app.relativeMachineTime - lastUpdated) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	// PAR #35843
				cmifMonitor.updateProgress(msg, cmifMonitor.partsInJob, count);
				lastUpdated := app.relativeMachineTime;													// PAR #35843
			endif;																						// PAR #35843
		endif;
	endforeach;	
	
	msg := 'Updating On ship cargo';
	if cmifMonitor &lt;&gt; null then
		cmifMonitor.updateProgress(msg, cmifMonitor.partsInJob, count);
	endif;		
	foreach ti in self.allOnshipTIsByIdCargoType do
		count := count+1;
		if ti.voyageCode.trimBlanks = _origCode then
			ti.setVoyageCodeForVoyCodeChange(_newCode, _passport);
		endif;
		if cmifMonitor &lt;&gt; null then
			if (app.relativeMachineTime - lastUpdated) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	// PAR #35843
				cmifMonitor.updateProgress(msg, cmifMonitor.partsInJob, count);
				lastUpdated := app.relativeMachineTime;													// PAR #35843
			endif;																						// PAR #35843
		endif;
	endforeach;

	msg := 'Updating On site cargo';
	if cmifMonitor &lt;&gt; null then
		cmifMonitor.updateProgress(msg, cmifMonitor.partsInJob, count);
	endif;		
	foreach ti in self.allOnsiteTIsByIdCargoType do
		count := count+1;
		if ti.voyageCode.trimBlanks = _origCode then
			ti.setVoyageCodeForVoyCodeChange(_newCode, _passport);
		endif;
		if cmifMonitor &lt;&gt; null then
			if (app.relativeMachineTime - lastUpdated) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	// PAR #35843
				cmifMonitor.updateProgress(msg, cmifMonitor.partsInJob, count);
				lastUpdated := app.relativeMachineTime;													// PAR #35843
			endif;																						// PAR #35843
		endif;
	endforeach;				

end;</source>
        <access>protected</access>
        <Parameter name="_origCode" type="String"/>
        <Parameter name="_newCode" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateVesselCodeVesselName" id="e3eb075e-a8aa-4866-9ae5-b638fbc30cbb">
        <updating/>
        <source>updateVesselCodeVesselName(_vesselCode, _vesselName : String)updating;
//--------------------------------------------------
// Created:	30 August 2004 By: cnwgd1
//--------------------------------------------------
/*

Date		Who		Reason
15 Mar 2012	cnwkpd1	PAR #29274 - only set key values if they have changed
	
*/

vars
	newCode			: String;
	
begin
	newCode := _vesselCode.trimBlanks();
	if self.vesselCode &lt;&gt; newCode then
		self.vesselCode := newCode;
		self.myVessel := self.getMyVesselFromCollection(); // PAR 30558
	endif;
	self.vesselName := _vesselName.trimRight();
	
end;</source>
        <Parameter name="_vesselCode" type="String"/>
        <Parameter name="_vesselName" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateVoyageFromVessel" id="4152d30a-00ae-400e-adad-f4bb41e06969">
        <updating/>
        <source>updateVoyageFromVessel(_vessel : CM_Vessel; _passport : CM_Passport input)updating;
//--------------------------------------------------
// Created:	27 September 2005 By: cnwgd1
//--------------------------------------------------
/*

Date		Who		Reason
15 Mar 2012	cnwkpd1	PAR #29274 - only set key values if they have changed

*/

vars
	newCode			: String;
	
begin
	if _vessel = null then
		return;
	endif;
	
	self.bitmap := _vessel.bitmap;
	self.callSign := _vessel.callSign.trimBlanks;
	self.craneClearance := _vessel.craneClearance;	
	self.lloydsNumber := _vessel.lloydsNumber;	    
	newCode := _vessel.code.trimBlanks();
	if self.vesselCode  &lt;&gt; newCode then
		self.vesselCode := newCode;
		self.myVessel := self.getMyVesselFromCollection(); // PAR 30558
	endif;
	self.vesselName := _vessel.name.trimRight();
	self.vesselType := _vessel.vesselType;
		    		
	if self.remarks = null then
		self.remarks := _vessel.remarks;
	endif;
    
    if self.myHMSVoyageData &lt;&gt; null then
    	self.myHMSVoyageData.updateVoyageDataFromVesselData(_vessel, _passport);
    endif;
    		
end;</source>
        <Parameter name="_vessel" type="CM_Vessel"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateVoyageGroupCode" id="aacdac70-a147-4de2-b45a-604aab4ec113">
        <updating/>
        <source>updateVoyageGroupCode(_proxyVoyage : CM_Voyage) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/06/2020 cnwma1 ChangeRequest 49400: ASPA - Invoice Enhancements for Barges

*/

vars
	origGroupCode 		: String;
	newGroupCode        : String;
begin
	self.raiseExceptionIfTransient(method);
	
	origGroupCode := self.voyageGroupCode;
	newGroupCode  := _proxyVoyage.voyageGroupCode;
	
	if _proxyVoyage.voyageGroupCode &lt;&gt; null then							
		self.voyageGroupCode        := newGroupCode;		
		self.myTerminalForGroupCode := _proxyVoyage.myTerminal;		
	else																	
		self.myTerminalForGroupCode := null;								
		self.voyageGroupCode        := null;								
	endif;
	
	if newGroupCode = origGroupCode  then
		return;
	endif;
	
	self.updateInvoiceVoyageGrpCode(newGroupCode);
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_proxyVoyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="updateVoyageInlandTerminals" id="b8098a2f-c291-4041-a31b-ec88582a8922">
        <updating/>
        <source>updateVoyageInlandTerminals(_passport : CM_Passport input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     17 September 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpVoyageInland				: CM_VoyageInlandTerminal;
	tmpVoy		: CM_Voyage;
begin
	foreach tmpVoyageInland in self.allVoyageInlandTerminals do
		//jlger1 TFS 52797 10/2/22
		tmpVoy := tmpVoyageInland.myTerminal.lookupVoyage(self.code, null, true);
		if tmpVoy &lt;&gt; null and tmpVoy &lt;&gt; tmpVoyageInland then
			app.raiseCMException1(Not_updat_becau_there_inlan_vo,tmpVoyageInland.myTerminal.code,null,null);
		endif;
		tmpVoyageInland.setFromVoyageForUpdate(self, _passport);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateXlations_Code" id="c9b3ac36-a795-4ae1-9986-c594fcc53e3d">
        <source>updateXlations_Code(_newCode: String; _oldCode: String; _coll: CM_XlationSet) protected;
/*
Date		Who		Reason
16 April 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars
	xlation	:CM_Xlation;
begin
	// we expect _coll to be the collection of xlations for the  receiver
	foreach xlation in _coll do
		// we don't know if we are updating inward code or voyage code so only
		// update if the codes match
		if xlation.systemCode = _oldCode then
			xlation.setSystemCode (_newCode);
		endif;
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_newCode" type="String"/>
        <Parameter name="_oldCode" type="String"/>
        <Parameter name="_coll" type="CM_XlationSet"/>
    </JadeMethod>
    <JadeMethod name="validate" id="4496f090-665a-4786-93ab-fae8afa05db0">
        <source>validate(_passport : CM_Passport input) protected;
//--------------------------------------------------------------
//Created: 20 June 2002 By: cnwgd1
//--------------------------------------------------------------
/*

Date		Who		Reason
27 Mar 2008	cnwkpd1	PAR #16220 additional changes - use exception handler to deal with invalid voyages
06/03/2012	cnwcs5	par 29158 - EDI Booking cutoffs
15/03/2012	cnwcs5	par 29279
13/03/2013	PJS		PAR #31232
11/04/2017	cnwdap1	TFS 4050 LNX Job ID Enhancements
31/05/2019	jlgdap1	TFS 44554 AAT Stevedore Data Access
10/09/2019 	JLGNS1	Bug 46446: ADP - RE: JMT Error
06/10/2021	jlizm1	TFS 51963 SAL Voyage Request Changes
07 Mar 2023 navmp20 Bug 56603: FR 53330/54104 | EUP - Unexpected warnings when changing Barges or Vessels
*/

vars
	voy,
	realVoyage		: CM_Voyage;
	tmpVoyGlobal	: CM_VoyageGlobal;
	blnNeedsHMSData : Boolean;
	invalidVoyage	: Boolean;
	recRestrict		: CM_ReceivalCutoffVoyage;
	portRotation	: CM_PortRotation;
	earlyTSPN, cutoffTSPN, //04/03/2025	navkc1 JIRA Story MTN-34227
	earlyTS, cutoffTS,
	departTS		: TimeStamp;
	recCutoffDef	: CM_ReceivalCutoffTermDef;	// par 29279
	aBerthPref		: HMS_BerthPreference;
	numTI 			: Integer;
	alloc			: CM_YardAllocation;
	hasColourCoding	: Boolean;
	externalCode	: String;					// TFS 4050
	error			: String;					// TFS 4050
	extCodeValid	: Boolean;					// TFS 4050
	objArray		: ObjectArray;		// TFS 44554
	stevedore		: CM_Stevedore;		// TFS 44554
	errorCode : String;
begin
	if self.myTerminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Terminal), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Terminal), null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.code = null and not app.myPassport.myTerminal.getConfig(VoyageCodeHookTRX).Boolean then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(VoyageCode), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(VoyageCode), null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.vesselName = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(VesselName), null, null);	
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(VesselName), null, null);	 // cnwdb2	PAR 35364
	endif;
	
	self.validateCode(_passport);
	
	self.validateDates();
	
	if self.lloydsNumber &lt;&gt; null and not self.lloydsNumber.cnIsNumeric then
		app.raiseCMException1(Value_field_must_integer,app.getErrorString(Lloyds_number),"",null);	//Bug 46446
	endif;
	

	// TFS 4050 validate voyage external code through hook code Voyage_external_code_invalid
	if self.voyageCodeExternal &lt;&gt; null then
		externalCode := self.voyageCodeExternal;
		app.myHookAgent.runHookLinkPublic(HookType_VoyageCodeExtCheck, self.myTerminal, self.myTerminal, externalCode, error);
		if error &lt;&gt; null and error &lt;&gt; "** not initialised **" then
			app.raiseCMException1(Voyage_external_code_invalid, error, null, null);
		endif;
	endif;
	// TFS 4050 end

	

	realVoyage := self.pxyGetRealObject(); 
	
	/* PAR 33644 REMOVED NOT REQUIRED
	//check for ti's in the shipblockstack if planned and worked
	if (not self.isNonPlannedVoyage) and (not self.isNonWorkedVoyage) and 
		realVoyage &lt;&gt; null and 
		realVoyage.myShipBlockStack &lt;&gt; null and 
		(not realVoyage.myShipBlockStack.allTrackedItems.isEmpty) then
		app.raiseCMException1(ERR_SHIPBLOCK_HAS_TIS, realVoyage.myShipBlockStack.allTrackedItems.size.String, 'myShipBlockStack', null);	
	endif;	
	*/
	
	// 31232 
	if realVoyage &lt;&gt; null then
	
		// 22/09/2014 cnwar2 #34136
		foreach alloc in realVoyage.allVoyageAllocations do
			if not alloc.CM_VoyageAllocation.allRequests.isEmpty()
			or not alloc.CM_VoyageAllocation.allSlotRequests.isEmpty() then
				hasColourCoding := true;
			endif;
		endforeach;
	
		if realVoyage.structureIncludesLOLO and not self.structureIncludesLOLO then
			// 22/09/2014 cnwar2 #34136
			if hasColourCoding then
				app.raiseCMException(Voyag_colour_coding_lolo, null, null);
			endif;
			
			numTI := realVoyage.getNumTIOnLOLO(); // PAR 34677
			// PAR 34677 if not realVoyage.canRemoveLOLOStructure then
			if numTI &gt; 0 then // PAR 34677
				// **** uput in proper message when putting code back in dev
				
// PAR 34677				app.raiseCMException1(ERR_SHIPBLOCK_HAS_TIS, realVoyage.myShipBlockStack.allTrackedItems.size.String, 'myShipBlockStack', null);	
				app.raiseCMException1(Voyag_cargo_items_lolo_struc_t, numTI.String, null, null);	// PAR 34677
				
			endif;
		endif;	
		
		// 31232 
		if realVoyage.structureIncludesRORO and not self.structureIncludesRORO then
			// 22/09/2014 cnwar2 #34136
			if hasColourCoding then
				app.raiseCMException(Voyag_colour_coding_roro, null, null);
			endif;
			
			numTI := realVoyage.getNumTIOnRORO(); // PAR 34677
			// PAR 34677 if not realVoyage.canRemoveROROStructure then
			if numTI &gt; 0 then // PAR 34677
				// **** uput in proper message when putting code back in dev
				// PAR 34677
// PAR 34677				app.raiseCMException1(ERR_SHIPBLOCK_HAS_TIS, realVoyage.myShipBlockStack.allTrackedItems.size.String, 'myShipBlockStack', null);	
				app.raiseCMException1(Voyag_cargo_items_roro_struc_t, numTI.String, null, null);	// PAR 34677
				
			endif;
		endif;	
		
		// 31232 
		if realVoyage.structureIncludesHolds and not self.structureIncludesHolds then
			// 22/09/2014 cnwar2 #34136
			if hasColourCoding then
				app.raiseCMException(Voyag_colour_coding_hold, null, null);
			endif;
			
			numTI := realVoyage.getNumTIOnHOLD(); // PAR 34677
			// PAR 34677 if not realVoyage.canRemoveHoldsStructure then
			if numTI &gt; 0 then // PAR 34677
				// **** uput in proper message when putting code back in dev
				
// PAR 34677				app.raiseCMException1(ERR_SHIPBLOCK_HAS_TIS, realVoyage.myShipBlockStack.allTrackedItems.size.String, 'myShipBlockStack', null);	
				app.raiseCMException1(Voyag_cargo_items_hold_struc_t, numTI.String, null, null);	// PAR 34677
				
			endif;
		endif;	
	endif;
	
	
	//validate ourselves against voyages under same global
	tmpVoyGlobal := self.myVoyageGlobalArrival;
	
	if tmpVoyGlobal &lt;&gt; null then
		// still need to check vessel is the same
		on Exception do app.handleDeletedObject(exception, voy, invalidVoyage);		// cnwkpd1 PAR #16220
		
		foreach voy in tmpVoyGlobal.allVoyages do
			//if not self.isBarge then  //29 Jun 2020	NDL	TFS 49677
			if not self.isBarge and not _passport.ignoreVesselChanges then   //07.03.2023 navmp20 TFS 56603
				if voy.vesselCode &lt;&gt; self.vesselCode then// par 15259
					app.raiseCMWarning2(ERR_INVALID_VALUE, ' vessel', "The specified vessel doesn't match other voyages under this global voyage (" &amp; self.myVoyageGlobalArrival.code &amp; ").", null, null, voy);
				endif;
			endif;
			
			if voy.myHMSVoyageData &lt;&gt; null then // dh 19/3/2008 par 16220 - if one has hms detail, all must. 
				blnNeedsHMSData := true;
			endif;
		endforeach;
		
		on Exception do null;														// cnwkpd1 PAR #16220
		
		
		if blnNeedsHMSData then
			if self.myHMSVoyageData = null then
				app.raiseCMException1(ERR_GVOYAGE_HMS_MISMATCH, '', 'myHMSVoyageData', null);	
			endif;
//		14/8/19 MAP TFS45926
//		else
//			if self.myHMSVoyageData &lt;&gt; null then
//				app.raiseCMException1(ERR_GVOYAGE_HMS_MISMATCH, 'not', 'myHMSVoyageData', null);	
//			endif;
		endif;
		
	endif;
	
	self.validateShippingLinePorts;
	
	// validate receival restrictions
	foreach recRestrict in self.allReceivalCutoffs do
		errorCode := recRestrict.code;
		if recRestrict.myOperator &lt;&gt; null then
			errorCode := errorCode &amp; " " &amp; recRestrict.myOperator.code;
		endif;
		// par 29158 - March 2012 - reworked code in this loop
		earlyTS		:= recRestrict.earliestDateTime;	
		cutoffTS	:= recRestrict.cutoffDateTime;		
		departTS	:= self.departedDT;					
		
		earlyTSPN	:= recRestrict.earliestDateTimePN; //04/03/2025	navkc1 JIRA Story MTN-34227
		cutoffTSPN	:= recRestrict.cutoffDateTimePN; //04/03/2025	navkc1 JIRA Story MTN-34227
		
		if earlyTS.isValid and cutoffTS.isValid and cutoffTS &lt;= earlyTS then 
			//app.raiseCMException2(Must_before, 'Earliest receival time', 'cutoff time', null, null); //04/03/2025	navkc1 JIRA Story MTN-34227
//			app.raiseCMException(EarlyReceiveMustBeforeCutoff, null, null); //04/03/2025	navkc1 JIRA Story MTN-34227
			app.raiseCMException1(EarlyReceiveMustBeforeCutoff,errorCode,  null, null); // ### JIRA 34233 19MAR 2025 NAVAB1
//			break;
		endif;
		
		//04/03/2025	navkc1 JIRA Story MTN-34227
		if earlyTSPN.isValid() and cutoffTSPN.isValid() and cutoffTSPN &lt;= earlyTSPN then
			app.raiseCMException1(EarlyRecPNMustBeforeCutoffPN,errorCode, null, null); // ### JIRA 34233 19MAR 2025 NAVAB1
//			break;
		endif;
		
		if departTS.isValid then
			recCutoffDef := self.myTerminal.allReceivalCutoffDefs[recRestrict.code];								// par 29279
			
			if recCutoffDef &lt;&gt; null and recCutoffDef.isEDIType then													// par 29279
				if (earlyTS.isValid and earlyTS &gt; departTS) or (cutoffTS.isValid and cutoffTS &gt; departTS) then		// par 29279
					//app.raiseCMException2(Cannot_be_after, 'Cutoff time', 'voyage departure', null, null);		// par 29279
					app.raiseCMException1(CuttimeCannotAfterVoyDepart,errorCode, null, null);//04/03/2025	navkc1 JIRA Story MTN-34227 // ### JIRA 34233 19MAR 2025 NAVAB1
//					break;																							// par 29279
				endif;
				
				//04/03/2025	navkc1 JIRA Story MTN-34227
				if (earlyTSPN.isValid and earlyTSPN &gt; departTS) or (cutoffTSPN.isValid and cutoffTSPN &gt; departTS) then
					app.raiseCMException1(CuttimePNCannotAfterVoyDepart,errorCode, null, null); // ### JIRA 34233 19MAR 2025 NAVAB1
//					break;
				endif;
			else
				if (earlyTS.isValid and earlyTS &gt;= departTS) or (cutoffTS.isValid and cutoffTS &gt;= departTS) then	// par 29279
					//app.raiseCMException2(Must_before, 'Receival times', 'voyage departure', null, null);
					app.raiseCMException1(ReceiveTimeMustBeforeVoyDepart,errorCode, null, null); //04/03/2025	navkc1 JIRA Story MTN-34227 // ### JIRA 34233 19MAR 2025 NAVAB1
//					break;
				endif;
				
				//04/03/2025	navkc1 JIRA Story MTN-34227
				if (earlyTSPN.isValid and earlyTSPN &gt;= departTS) or (cutoffTSPN.isValid and cutoffTSPN &gt;= departTS) then
					app.raiseCMException1(RecTimePNMustBeforeVoyDepart,errorCode, null, null);// ### JIRA 34233 19MAR 2025 NAVAB1
//					break;
				endif;
			endif;
		endif;
	endforeach;
	
	//validate port rotation - cnwrd1 par 24405 27.7.2010
	// from 28948 testing Jan 2012 not for log voyages
	if self.myLogVoyageStructure = null then
		foreach portRotation in self.allPortRotations do
			if portRotation.myPort = null then
				app.raiseCMException1(Port_invalid, null, null, null);
			endif;
		endforeach;
	endif;

	// cnwrd1 par 31283
	if self.myHMSVoyageData &lt;&gt; null then
		if self.myHMSVoyageData.getMyBerth &lt;&gt; null and not self.myHMSVoyageData.allBerthPreferencesArray.isEmpty then
			foreach aBerthPref	in self.myHMSVoyageData.allBerthPreferencesArray do
				if aBerthPref.getMyBerth = self.myHMSVoyageData.getMyBerth then
						if (aBerthPref.orientation = OrientPortSideTo and self.starboardBerthed )
							or (aBerthPref.orientation = OrientStarboardSideTo and not self.starboardBerthed ) then
							app.raiseCMWarning(Berth_orien_diffe_from_prefe_b,null, null, voy);							
						endif;						
					break;
				endif;
			endforeach;					
		endif;
	endif;
	
	// TFS 44554 start
	if self.myTerminal.getConfig(MandatoryOneStevedore).Boolean then
		if self.myHMSVoyageData &lt;&gt; null then
			create objArray transient;
			foreach stevedore in self.myHMSVoyageData.allStevedoresDischarge do
				objArray.addExclusive(stevedore);
			endforeach;
			foreach stevedore in self.myHMSVoyageData.allStevedoresLoad do
				objArray.addExclusive(stevedore);
			endforeach;
			if objArray.size &gt; 1 then
				app.raiseCMException1(Only_One_Stevedore, self.code, null, null);
			endif;
		endif;
	endif;
	// TFS 44554 end

epilog
	delete objArray;			// TFS 44554
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateArrivalDepartedDates" id="7302f0ca-5a7f-441f-b1ea-dd68b2e337b4">
        <source>validateArrivalDepartedDates();
// ---------------------------------------------------------------------------
// Created:     30 September 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 14/08/2008	concms1	par 17714 Display warning if there are delays outside
// 						departure and arrival dates		
// 18/12/2023	navdap1	TFS 61782 POB - QShips - Arrival must Before Departure Error Does Not Show Voyage Code
vars
	delay		:CM_Delay;	// par 17714
	realVoyage	:CM_Voyage;
begin
	if self.arrivedDT.isValid()
	and self.departedDT.isValid()
	and (self.arrivedDT &gt;= self.departedDT)
	then
		app.raiseCMException1(AutoScheduleDateError, "Voyage " &amp; self.code &amp; " The arrival date/time must be before the departure date/time", null, null);	// TFS 61782
	endif;
	
// cnwdad1 06/09/2006 - CCMS #1039.
	// 28082 Sep 2011 departedDT used as sail date, don't check for log voyages (which don't necessarily have arrival date)
	if self.myLogVoyageStructure = null and
	   self.departedDT &lt;&gt; null
	and self.departedDT.isValid()
	and self.arrivedDT = null
	then
		app.raiseCMException1(AutoScheduleDateError, "Voyage " &amp; self.code &amp; " The arrival date/time must be entered", null, null);		// TFS 61782
	endif;
	
// concms1 14/08/2008 - par 17714
//	if there are delays that are outside the arrival/departure dates then display a warning message
	realVoyage := self.pxyGetRealObject();

	if realVoyage &lt;&gt; null and				
		realVoyage.allDelays.size &gt; 0 and	// we have some delays
		self.arrivedDT &lt;&gt; null then			// we have arrived
		
		if self.arrivedDT &lt;&gt; realVoyage.arrivedDT or
			self.departedDT &lt;&gt; realVoyage.departedDT then		// dates have changed
			
			foreach delay in realVoyage.allDelays do
				if delay.startDT &lt; self.arrivedDT or			// delay starts B4 arrival
					(self.departedDT &lt;&gt; null and				// we have departed
						(delay.startDT &gt; self.departedDT or		// delay starts after departure
						delay.endDT &gt; self.departedDT)) then    // delay ends after departure
					if self.departedDT &lt;&gt; null then
						app.raiseCMWarning2 (WARN_DelaysAreOutsideVoyDates, '(' &amp; self.arrivedDT.asStringJMT &amp; ')', '(' &amp; self.departedDT.asStringJMT &amp; ')', null, null, null);
					else
						app.raiseCMWarning2 (WARN_DelaysAreOutsideVoyDates, '(' &amp; self.arrivedDT.asStringJMT &amp; ')', null, null, null, null);
					endif;		
					break;
				endif;
			endforeach;
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateCode" id="5ec3b5ff-1b92-4428-ab36-ef4f6d26cfa3">
        <source>validateCode(_passport : CM_Passport input) protected;
//--------------------------------------------------
// Created:	30 March 2006 By: cnwgd1
//--------------------------------------------------
vars

begin

	if self.myLogVoyageStructure &lt;&gt; null
	and self.myCellularVoyageStructure = null
	and self.myGeneralCargoVoyage = null
	and self.myHMSVoyageData = null then
		// This is a log only voyage
		// vesselCode NA and spaces are ok for log only voyages
		return;
	endif;
	
	if self.code &lt;&gt; null and self.code.cnContains(' ') then
		app.raiseCMException1(VB_SPACE_IN_AREA_NAME, self.code, null, null);
	endif;

	//Inward code is optional.
	if self.inwardCode.trimBlanks &lt;&gt; null then
		if self.inwardCode.cnContains(' ') then
			app.raiseCMException1(VB_SPACE_IN_AREA_NAME, self.inwardCode, null, null);
		endif;
	endif;	
	
	if self.vesselCode = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Vessel Code', null, null);	
		app.raiseCMException(Input_required_field_VesselCod, null, null);	 // cnwdb2	PAR 35364
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateDates" id="beb8e6a3-2be7-4125-90d2-e5e0a9ea1d21">
        <source>validateDates();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12/05/2009	cnwer1	Initial creation - extracted out of validate
15/01/2010	cnwmh5	Par 22117 - Change 10 year validation to 50 years
05/03/2015	cnwdap1	PAR #35826 CCMS SFW 1410 Added expected arrival/departure date validation
11/12/2023	navdap1	TFS 61734 POB | Qships - Voyage info for EDI errors.
*/

	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	today: TimeStamp;
	pastDate, futureDate : TimeStamp;
	aTS : TimeStamp;
	aDate, dDate : Date;
	aTime : Time;
	fieldName : String;
	msg : String;
	translation	: XLAT_Translation;
	etRow : EntTableRow;
	rowName : String;
begin
	aDate.setDate(1,1,1900); // PAR 9109
	aTS.setDate(aDate); // PAR 9109
	
	//cnwjo3 par 22117
	pastDate := today.subtractYears(50);
	futureDate := today.addYears(50);
	
	//14 Jun 2016	NDL	TFS 2140
	if self.myTerminal &lt;&gt; null and self.myTerminal.getConfig(EtaEtdMandatory).Boolean then
		etRow := app.myRoot.myEntTableDataRoot.allEntTableRowsByNumber.getAtKey(260611).EntTableRow; //ETRow_EtaEtdMandatory
		if etRow &lt;&gt; null then
			rowName := etRow.getRawHeadingValue;
		else
			rowName := "ETA and ETD are Mandatory";
		endif;
		if not self.estimatedArrivalDT.isValid then
			msg := null;
			translation := app.zGetTranslatedText(XLAT_FormCaptions, Xlat_0020266);
			if translation &lt;&gt; null then
				fieldName := translation.text;
				msg := "[" &amp; app.getErrorString1(AutoScheduleDateError, fieldName) &amp; "]";
			endif;
			app.raiseCMException3(Terminal_config_option_set, rowName, app.getErrorString(Yes), msg, null, null);
		endif;
		if not self.estimatedDepartureDT.isValid then
			msg := null;
			translation := app.zGetTranslatedText(XLAT_FormCaptions, Xlat_0020267);
			if translation &lt;&gt; null then
				fieldName := translation.text;
				msg := "[" &amp; app.getErrorString1(AutoScheduleDateError, fieldName) &amp; "]";
			endif;
			app.raiseCMException3(Terminal_config_option_set, rowName, app.getErrorString(Yes), msg, null, null);
		endif;
	endif;
	
	self.validateArrivalDepartedDates();
		
	//rs par 9090 oct 2004 this is because POE are loading rediculus dates into these fields causing SQL to crash	
	if self.arrivedDT.isValid() then
		if self.arrivedDT.date &lt; pastDate.date then // 15/10/2010 cnwmh5 #22117 - Change from 10 to 50 years
			app.raiseCMException1(AutoScheduleDateError, 'Voyage ' &amp; self.getDisplayDetails(false) &amp; ' Arrival date cannot be more than 50 years in the past!', null, null);						// TFS 61734
		endif;			
		if self.arrivedDT.date &gt; futureDate.date then	// 15/10/2010 cnwmh5 #22117 - Change from 10 to 50 years
			app.raiseCMException1(AutoScheduleDateError, 'Voyage ' &amp; self.getDisplayDetails(false) &amp; ' Arrival date cannot be more than 50 years in the future!', null, null);						// TFS 61734
		endif;

		if self.arrivedDT.date() &lt; aTS.date() then
			app.raiseCMException1(AutoScheduleDateError, 'Voyage ' &amp; self.getDisplayDetails(false) &amp; " The Arrival Date '" &amp; self.arrivedDT.date().String &amp; "' is invalid. It must be a date since " &amp; aDate.String, null, null);	// TFS 61734
		endif;
				
	elseif self.arrivedDT.date.isValid then
		app.raiseCMException1(AutoScheduleDateError, 'Voyage ' &amp; self.getDisplayDetails(false) &amp; ' Arrival time is invalid.', null, null);															// TFS 61734
	endif;
					
	if self.departedDT.isValid() then
		if self.departedDT.date &lt; pastDate.date then				// 15/10/2010 cnwmh5 #22117 - Change from 10 to 50 years
			app.raiseCMException1(AutoScheduleDateError, 'Voyage ' &amp; self.getDisplayDetails(false) &amp; ' Departed date cannot be more than 50 years in the past!', null, null);						// TFS 61734
		endif;			
	
		if self.departedDT.date &gt; futureDate.date then			// 15/10/2010 cnwmh5 #22117 - Change from 10 to 50 years
			app.raiseCMException1(AutoScheduleDateError, 'Voyage ' &amp; self.getDisplayDetails(false) &amp; ' Departed date cannot be more than 50 years in the future!', null, null);						// TFS 61734
		endif;

		if self.departedDT.date() &lt; aTS.date() then
			app.raiseCMException1(AutoScheduleDateError, 'Voyage ' &amp; self.getDisplayDetails(false) &amp; " The Departure Date '" &amp; self.departedDT.date().String &amp; "' is invalid. It must be a date since " &amp; aDate.String, null, null);	// TFS 61734
		endif;
				
	elseif self.departedDT.date.isValid then
		app.raiseCMException1(AutoScheduleDateError, 'Voyage ' &amp; self.getDisplayDetails(false) &amp; ' Departure time is invalid.', null, null);														// TFS 61734
	endif;
	
	if self.loadEndDT.isValid then
		if self.loadStartDT &gt;= self.loadEndDT 
		or (not self.loadStartDT.isValid()
		and self.loadEndDT.isValid) then
			app.raiseCMException1(EndBeforeStart, 'Voyage ' &amp; self.getDisplayDetails(false), null, null);	
		endif;
	elseif self.loadEndDT.date.isValid then
		app.raiseCMException1(AutoScheduleDateError, 'Voyage ' &amp; self.getDisplayDetails(false) &amp; ' load end time is invalid.', null, null);															// TFS 61734
	endif;

	// CCMS 1124, check arrival date against start date, limit to log voyages to avoid introducing new errors for other users.
	if self.myLogVoyageStructure &lt;&gt; null then
		if self.arrivedDT.isValid and self.loadStartDT.isValid then
			if self.arrivedDT &gt; self.loadStartDT then
				app.raiseCMException1(AutoScheduleDateError, 'Voyage ' &amp; self.getDisplayDetails(false) &amp; "Arrival Date " &amp; self.arrivedDT.String &amp; " must be before Start Date " &amp; self.loadStartDT.String, null, null);	// TFS 61734
			endif;
		endif;
	endif;
	
// PAR 33644	if self.isNonPlannedVoyage
// PAR 33644	or self.isNonWorkedVoyage then
	if self.isHOLDSorSHIP() then
	
		if self.nonPlannedEffectiveDT.isValid then
			if self.departedDT.isValid and self.nonPlannedEffectiveDT &gt; self.departedDT then
				app.raiseCMException1(AutoScheduleDateError, 'Voyage ' &amp; self.getDisplayDetails(false) &amp; ' Retrospective operations cannot be after the departure date.', null, self);				// TFS 61734
			endif;
			if self.arrivedDT.isValid and self.nonPlannedEffectiveDT &lt; self.arrivedDT then // PAR 15078
				app.raiseCMException1(AutoScheduleDateError, 'Voyage ' &amp; self.getDisplayDetails(false) &amp; ' Retrospective operations cannot be before the arrival date.', null, self);	 			// TFS 61734
			endif;
		elseif self.nonPlannedEffectiveDT.date.isValid then
			app.raiseCMException1(AutoScheduleDateError, 'Voyage ' &amp; self.getDisplayDetails(false) &amp; ' retrospective time is invalid.', null, null);
		endif;
	endif;


	 // ### PAR 9109. Added validation to dates
	if self.departTargetDT.isValid then
		if self.departTargetDT.date() &lt; aTS.date() then
			app.raiseCMException1(AutoScheduleDateError, 'Voyage ' &amp; self.getDisplayDetails(false) &amp; " The target departure '" &amp; self.departTargetDT.date().String &amp; "' is invalid. It must be a date since " &amp; aDate.String, null, null);	// TFS 61734
		endif;

	elseif self.departTargetDT.date.isValid then
		app.raiseCMException1(AutoScheduleDateError, 'Voyage ' &amp; self.getDisplayDetails(false) &amp; ' The target departure time is invalid.', null, null);												// TFS 61734
	endif;	
		
	if self.shipExchangeDate.isValid then
		if self.shipExchangeDate.date() &lt; aTS.date() then
			app.raiseCMException1(AutoScheduleDateError, 'Voyage ' &amp; self.getDisplayDetails(false) &amp; " The Ship Exchange Date '" &amp; self.shipExchangeDate.date().String &amp; "' is invalid. It must be a date since " &amp; aDate.String, null, null);	// TFS 61734
		endif;
	elseif self.shipExchangeDate.date.isValid then
		app.raiseCMException1(AutoScheduleDateError, 'Voyage ' &amp; self.getDisplayDetails(false) &amp; ' Ship Exchange time is invalid.', null, null);													// TFS 61734
	endif;

	if self.shipExchangeCompleteDT.isValid then
		if self.shipExchangeCompleteDT.date() &lt; aTS.date() then
			app.raiseCMException1(AutoScheduleDateError, 'Voyage ' &amp; self.getDisplayDetails(false) &amp; " The Ship Exchange Complete Date '" &amp; self.shipExchangeCompleteDT.date().String &amp; "' is invalid. It must be a date since " &amp; aDate.String, null, null);	// TFS 61734
		endif;
	elseif self.shipExchangeCompleteDT.date.isValid then
		app.raiseCMException1(AutoScheduleDateError, 'Voyage ' &amp; self.getDisplayDetails(false) &amp; ' Ship Exchange Complete time is invalid.', null, null);											// TFS 61734
	endif;	
	
	//31 May 2021	NDL	TFS 51199
	if self.myTerminal.getConfig(VoyageRetroDefault).Boolean and self.shipExchangeCompleteDT.isValid then
		if self.shipExchangeCompleteDT &gt; app.actualTimeServer then
			app.raiseCMWarning1( Termi_confi_voyag_retro_defau_, self.shipExchangeCompleteDT.asStringJMT, null, null, null );
		endif;
	endif;

	if self.shipAnchorDownDT.isValid then
		if self.shipAnchorDownDT.date() &lt; aTS.date() then
			app.raiseCMException1(AutoScheduleDateError, 'Voyage ' &amp; self.getDisplayDetails(false) &amp; " The Ship Anchor Down Date '" &amp; self.shipAnchorDownDT.date().String &amp; "' is invalid. It must be a date since " &amp; aDate.String, null, null);	// TFS 61734
		endif;
	elseif self.shipAnchorDownDT.date.isValid then
		app.raiseCMException1(AutoScheduleDateError, 'Voyage ' &amp; self.getDisplayDetails(false) &amp; ' Ship Anchor Down time is invalid.', null, null);													// TFS 61734
	endif;	
	if self.shipPilotReturnDT.isValid then
		if self.shipPilotReturnDT.date() &lt; aTS.date() then
			app.raiseCMException1(AutoScheduleDateError, 'Voyage ' &amp; self.getDisplayDetails(false) &amp; " The Pilot Return Date '" &amp; self.shipPilotReturnDT.date().String &amp; "' is invalid. It must be a date since " &amp; aDate.String, null, null);	// TFS 61734
		endif;
	elseif self.shipPilotReturnDT.date.isValid then
		app.raiseCMException1(AutoScheduleDateError, 'Voyage ' &amp; self.getDisplayDetails(false) &amp; ' Ship Pilot Return time is invalid.', null, null);												// TFS 61734
	endif;	
	
	
	if self.labourOnBoard.isValid then
		if self.labourOnBoard.date() &lt; aTS.date() then
			app.raiseCMException1(AutoScheduleDateError, 'Voyage ' &amp; self.getDisplayDetails(false) &amp; " The Labour On Board Date '" &amp; self.labourOnBoard.date().String &amp; "' is invalid. It must be a date since " &amp; aDate.String, null, null);	// TFS 61734
		endif;
	elseif self.labourOnBoard.date.isValid then
		app.raiseCMException1(AutoScheduleDateError, 'Voyage ' &amp; self.getDisplayDetails(false) &amp; ' The labour on board time is invalid.', null, null);												// TFS 61734
	endif;

	if self.labourOnShore.isValid then
		if self.labourOnShore.date() &lt; aTS.date() then
			app.raiseCMException1(AutoScheduleDateError, 'Voyage ' &amp; self.getDisplayDetails(false) &amp; " The Labour On Shore Date '" &amp; self.labourOnShore.date().String &amp; "' is invalid. It must be a date since " &amp; aDate.String, null, null);	// TFS 61734
		endif;

	elseif self.labourOnShore.date.isValid then
		app.raiseCMException1(AutoScheduleDateError, 'Voyage ' &amp; self.getDisplayDetails(false) &amp; ' The labour on shore time is invalid.', null, null);												// TFS 61734
	endif;

	if self.pilotOnBoardDT.isValid then
		if self.pilotOnBoardDT.date() &lt; aTS.date() then
			app.raiseCMException1(AutoScheduleDateError, 'Voyage ' &amp; self.getDisplayDetails(false) &amp; " The pilot on board '" &amp; self.pilotOnBoardDT.date().String &amp; "' is invalid. It must be a date since " &amp; aDate.String, null, null);	// TFS 61734
		endif;

	elseif self.pilotOnBoardDT.date.isValid then
		app.raiseCMException1(AutoScheduleDateError, 'Voyage ' &amp; self.getDisplayDetails(false) &amp; ' The pilot on board time is invalid.', null, null);												// TFS 61734
	endif;
	
	// PAR #35826 Expected Arrival and Departure Date/Time validation
	// Expected Arrival must be before Expected Departure
	// Expected Arrival and Expected Departure must be within 50 year limits
	if self.estimatedArrivalDT.isValid()
	and self.estimatedDepartureDT.isValid()
	and (self.estimatedArrivalDT &gt;= self.estimatedDepartureDT)
	then
		app.raiseCMException1(AutoScheduleDateError, 'Voyage ' &amp; self.getDisplayDetails(false) &amp; " The expected arrival date/time must be before the expected departure date/time", null, null);	// TFS 61734
	endif;
	
	if self.estimatedArrivalDT.isValid() then
		if self.estimatedArrivalDT.date &lt; pastDate.date then
			app.raiseCMException1(AutoScheduleDateError, 'Voyage ' &amp; self.getDisplayDetails(false) &amp; ' Expected arrival date cannot be more than 50 years in the past!', null, null);				// TFS 61734
		endif;			
		if self.estimatedArrivalDT.date &gt; futureDate.date then
			app.raiseCMException1(AutoScheduleDateError, 'Voyage ' &amp; self.getDisplayDetails(false) &amp; ' Expected arrival date cannot be more than 50 years in the future!', null, null);				// TFS 61734
		endif;

		if self.estimatedArrivalDT.date() &lt; aTS.date() then
			app.raiseCMException1(AutoScheduleDateError, 'Voyage ' &amp; self.getDisplayDetails(false) &amp; " The Expected Arrival Date '" &amp; self.estimatedArrivalDT.date().String &amp; "' is invalid. It must be a date since " &amp; aDate.String, null, null);	// TFS 61734
		endif;
				
	elseif self.estimatedArrivalDT.date.isValid then
		app.raiseCMException1(AutoScheduleDateError, 'Voyage ' &amp; self.getDisplayDetails(false) &amp; ' Expected arrival time is invalid.', null, null);													// TFS 61734
	endif;
					
	if self.estimatedDepartureDT.isValid() then
		if self.estimatedDepartureDT.date &lt; pastDate.date then
			app.raiseCMException1(AutoScheduleDateError, 'Voyage ' &amp; self.getDisplayDetails(false) &amp; ' Expected Departure date cannot be more than 50 years in the past!', null, null);				// TFS 61734
		endif;
	
		if self.estimatedDepartureDT.date &gt; futureDate.date then
			app.raiseCMException1(AutoScheduleDateError, 'Voyage ' &amp; self.getDisplayDetails(false) &amp; ' Expected departure date cannot be more than 50 years in the future!', null, null);			// TFS 61734
		endif;

		if self.estimatedDepartureDT.date() &lt; aTS.date() then
			app.raiseCMException1(AutoScheduleDateError, 'Voyage ' &amp; self.getDisplayDetails(false) &amp; " The Expected Departure Date '" &amp; self.estimatedDepartureDT.date().String &amp; "' is invalid. It must be a date since " &amp; aDate.String, null, null);	// TFS 61734
		endif;
				
	elseif self.estimatedDepartureDT.date.isValid then
		app.raiseCMException1(AutoScheduleDateError, 'Voyage ' &amp; self.getDisplayDetails(false) &amp; ' Expected departure time is invalid.', null, null);												// TFS 61734
	endif;
	// PAR #35826 end
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateDelete" id="1666ca7b-99b7-49cf-ba5e-bb6ca53444c6">
        <source>validateDelete(_passport: CM_Passport input);
//--------------------------------------------------
// Created:	18 July 2005 By: cnwgd1
//--------------------------------------------------
vars

begin

	self.validateForDelete(true, _passport);

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateDepartureProcess" id="7a4227d5-00db-47a7-83e8-83fa24e92d06">
        <source>validateDepartureProcess();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22/08/2023	navkc1	CR 59610 Task 59611: Jade - Stop Prevention
21 Oct 2024	navbs1  Story MTN-14791: EUP | 53856 - New Scanning App - Unpack mode issue

*/

vars
	ti			: CM_TrackedItem;
	tis			: CM_TISet;
	realVoy		: CM_Voyage;
begin
	create tis transient;
	
	if self.isTransient() then
		realVoy := self.pxyGetRealObject();
	else
		realVoy := self;
	endif;
	
	// Check all tis when setting status to depart
	if self.isStatusDeparted() and realVoy.getVoyageDepartureEvent() = null then
		realVoy.getAllTrackedItems(tis);
		
		foreach ti in tis do
			app.myPassport.setContext(Context_Pass_CUST_FullyCleared); // ### TFS CR 60424 TASK 60549 16OCT2023 NAVAB1		//21.10.2024  navbs1  #14791
			ti.checkStopsToBePrevented(StopPreventVoyageDeparture, null, true);
			app.myPassport.setContext(Context_Pass_Null); // ### TFS CR 60424 TASK 60549 17OCT2023 NAVAB1					//21.10.2024  navbs1  #14791
		endforeach;
	endif;
epilog
	app.myPassport.setContext(Context_Pass_Null); // ### TFS CR 60424 TASK 60549 17OCT2023 NAVAB1							//21.10.2024  navbs1  #14791
	delete tis;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateDischargePort" id="628ee288-2af2-41d0-81d3-4b1f4c0e4f72">
        <source>validateDischargePort(_port : CM_Port; _control : CMIF_TIUpdateController);
// ---------------------------------------------------------------------------
// Created:     24 September 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12/03/2010	cnwmh5		PAR22235 - Change so when TO_UPDMODE_RECEIPT not msg occurs, 
//							captured on tracked item validation
// ---------------------------------------------------------------------------
vars
	userObject	: Object;
begin

	if self.myLogVoyageStructure &lt;&gt; null
	and self.myCellularVoyageStructure = null
	and self.myGeneralCargoVoyage = null
	and self.myHMSVoyageData = null then
		// This is a log only voyage
		// Discharge Port NA for log only voyages
		return;
	endif;

	if _control &lt;&gt; null then
		userObject := _control.myUserObject;
	endif;
	
	if (not self.allPorts.includes(_port)) then
		//th2 CCMS1547
		//if _control &lt;&gt; null and _control.mode = TI_UPDMODE_LOADLIST then
		if _control &lt;&gt; null then											// 12/03/2010 cnwmh5 #22235
			if _control.mode = TI_UPDMODE_LOADLIST then						// 12/03/2010 cnwmh5 #22235
				app.raiseCMWarning2(VB_VALID_DISCHPORT, _port.code, self.code, ETRow_DischargePort, userObject, self);
			endif;
		else
			app.raiseCMException2(VB_VALID_DISCHPORT, _port.code, self.code, ETRow_DischargePort, userObject);
		endif;
	endif;

end;</source>
        <Parameter name="_port" type="CM_Port"/>
        <Parameter name="_control" type="CMIF_TIUpdateController"/>
    </JadeMethod>
    <JadeMethod name="validateDuplicateCode" id="08525148-1b2d-4796-8c38-6ac69323edeb">
        <source>validateDuplicateCode(_passport : CM_Passport input) protected;
//--------------------------------------------------------------
//Created: 20 June 2002 By: cnwgd1
//--------------------------------------------------------------
// 09/12/2014 	cnwdb2 		PAR 35364
// 06/10/2017	cnwma1  	TFS #7257 JMT - Refactoring - Commodity Planning
// 28/06/2022	navds20	 	TFS 53760 MTN - DuplicateItem not Translatable
// 16/07/2024 	navlw1		ChangeRequest 63839: NSW | OnePort - Uniqueness of Inward and External Code
// 26/11/2024	navdap1		MTN-33516 NSW | OnePort - Voyage Already Exists With External Code Error
vars
	tmpVoyage	: CM_Voyage;
	msg			: String;
begin
	
	if _passport.hasErrors then
		return;
	endif;
	
	tmpVoyage := self.myTerminal.lookupVoyage(self.code, null, true);

	if tmpVoyage &lt;&gt; null and tmpVoyage &lt;&gt; self.pxyGetRealObject then
		if tmpVoyage.archived then
			msg := app.getErrorString(Archived);
		endif;
		//app.raiseCMException2(DuplicateItem, app.getErrorString(Voyage), self.code &amp; msg, ETRow_Place, null);	//28/06/2022 navds20 TFS 53760
		//Voyage already exists for %1 : Voyage_already_exists
		app.raiseCMException1(Voyage_already_exists, self.code &amp; msg, ETRow_Place, null); //28/06/2022 navds20 TFS 53760
	endif;
	
	//if self.isAutomaticProcess() and self.inwardCodeAuto &lt;&gt; null then // navlw1 #63839					// MTN-33516
	if self.myTerminal.getConfig(AllowDupVoyageInOutCodes).Boolean and self.inwardCodeAuto &lt;&gt; null then		// MTN-33516
		tmpVoyage := self.myTerminal.lookupVoyageAuto(self.inwardCodeAuto, self.vesselCode, null, true);
		if tmpVoyage &lt;&gt; null and tmpVoyage &lt;&gt; self.pxyGetRealObject then			
			app.raiseCMException1(Already_exist_inward_voyage,self.inwardCodeAuto,null,null);
		endif;
	else
		if self.inwardCode &lt;&gt; null then
			tmpVoyage := self.myTerminal.lookupVoyage(self.inwardCode, null, true);
		endif;
		if tmpVoyage &lt;&gt; null and tmpVoyage &lt;&gt; self.pxyGetRealObject then			
			app.raiseCMException1(Already_exist_inward_voyage,self.inwardCode,null,null); //cnwdb2 PAR 35364
		endif;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForCellularStructure" id="09d35827-29fd-457f-926e-b2c1639020f3">
        <source>validateForCellularStructure(_passport : CM_Passport input);
//--------------------------------------------------
// Created:	03 April 2006 By: cnwgd1
//--------------------------------------------------
vars
	tmpString : String;	
begin

//20 Aug 2019	NDL	TFS 46160 - No longer just valid for LOLO, should always be called.	
//	if self.myCellularVoyageStructure = null then
//		return;
//	endif;
	
	if self.myOperator = null then
		tmpString := app.getTerminologyAlternate(null,	_passport.myTerminal, CM_TerminologyOperator, CM_TermExpressionSingular, 'Operator');
	//	app.raiseCMException1(REQUIRED_FIELD, tmpString, ETRow_Operator, null);
		app.raiseCMException1(Input_required_field_Required, tmpString, ETRow_Operator, null); // cnwdb2	PAR 35364
	endif;
	
	if self.myShippingLine = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Shipping Line', ETRow_ShippingLine, null);
		app.raiseCMException(Input_required_field_shipLine, ETRow_ShippingLine, null); // cnwdb2	PAR 35364
	endif;
	
	// only raise this one if they have trades on this system
	if self.myTrade = null and app.myRoot.allTradesByDescription.isEmpty = false then
//		app.raiseCMException1(REQUIRED_FIELD, 'Trade', null, null);
		if self.getMyTerminal.getConfig( NoVoyTradeVal ).Boolean then	//31 May 2018	NDL	TFS 38905
			app.raiseCMWarning(Trade_selected, null, null, null);
		else
			app.raiseCMException(Input_required_field_trade, null, null); // cnwdb2	PAR 35364
		endif;
	endif;

	if self.allOperators.isEmpty and self.myOperator = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'list of voyage operators', null, null);
		app.raiseCMException(Input_required_field_lstVoyOp, null, null); // cnwdb2	PAR 35364
	endif;		
			
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForConvertFromOther" id="e497c6d5-9d91-4b21-9905-47a01aa9722e">
        <source>validateForConvertFromOther(_realOrigVoyage : CM_Voyage; _passport : CM_Passport input);
//--------------------------------------------------
// Created:	02 April 2004 By: cnwgd1
//28/06/2022 navds20 TFS 53760 MTN - DuplicateItem not Translatable
//--------------------------------------------------
// 09/12/2014 	cnwdb2 PAR 35364
// 16/07/2024	navlw1	ChangeRequest 63839: NSW | OnePort - Uniqueness of Inward and External Code
// 26/11/2024	navdap1	MTN-33516 NSW | OnePort - Voyage Already Exists With External Code Error
vars
	tmpVoyage 		: CM_Voyage;
	inwardCodeStr	: String;
begin
	self.validate(_passport);

	if _passport.hasErrors then
		return;
	endif;
	
	tmpVoyage := self.myTerminal.lookupVoyage(self.code, null, false);
	if tmpVoyage &lt;&gt; null 
	and tmpVoyage &lt;&gt; _realOrigVoyage
	and tmpVoyage &lt;&gt; self.pxyGetRealObject then
		//app.raiseCMException2(DuplicateItem, app.getErrorString(Voyage), self.code, ETRow_Place, null);	//28/06/2022 navds20 TFS 53760
		//Voyage_already_exists -&gt; Voyage already exists for %1 
		app.raiseCMException1(Voyage_already_exists, self.code, ETRow_Place, null);	 //28/06/2022 navds20 TFS 53760
	endif;
	
	//if self.isAutomaticProcess() and self.inwardCodeAuto &lt;&gt; null then // navlw1 #63839					// MTN-33516
	if self.myTerminal.getConfig(AllowDupVoyageInOutCodes).Boolean and self.inwardCodeAuto &lt;&gt; null then		// MTN-33516
		inwardCodeStr := self.inwardCodeAuto;
		tmpVoyage := self.myTerminal.lookupVoyageAuto(self.inwardCodeAuto, self.vesselCode, null, false);
	else
		if self.inwardCode &lt;&gt; null then
			inwardCodeStr := self.inwardCode;
			tmpVoyage := self.myTerminal.lookupVoyage(self.inwardCode, null, false);
		endif;
	endif;
	// navlw1 #63839
	if tmpVoyage &lt;&gt; null and tmpVoyage &lt;&gt; _realOrigVoyage and tmpVoyage &lt;&gt; self.pxyGetRealObject and inwardCodeStr &lt;&gt; null then			
		app.raiseCMException1(Already_exist_inward_voyage,inwardCodeStr,null,null); //cnwdb2 PAR 35364
	endif;
end;</source>
        <Parameter name="_realOrigVoyage" type="CM_Voyage"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="57ac3911-0918-4220-ad11-b274a424fe1c">
        <source>validateForCreate(_passport : CM_Passport input);
//--------------------------------------------------------------
//Created: 20 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	vessel: CM_Vessel;
begin
	vessel := self.vessel();
	self.validateMe(_passport);
	if self.myHMSVoyageData &lt;&gt; null and vessel &lt;&gt; null and vessel.hasHarbourDetails() then		// 19/8/19 MAP TFS45926
		self.myHMSVoyageData.validateForCreate(_passport);
	endif;	
	if self.myGeneralCargoVoyage &lt;&gt; null then
		self.myGeneralCargoVoyage.validateForCreate(_passport);
	endif;
	if self.myCellularVoyageStructure &lt;&gt; null then
		self.myCellularVoyageStructure.validateForCreate(_passport);
	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="d52b191c-5a67-4a5c-9891-0983c212eeaa">
        <source>validateForDelete(_valHMSVoyageData : Boolean; _passport : CM_Passport input);
//--------------------------------------------------------------
//Created: 20 June 2002 By: cnwgd1
//--------------------------------------------------------------

// 26/09/2008	concms1	par 17009 - check all inversed TI collection b4 allowing delete
// 26/09/2014	PAR #34221	Re-instate checks on Tranship collections 
//							- if a TI is in the allTranshipTIsExport collection but still on my Import voyage, deny the delete
//							- if a TI is in the allTranshipTIsExport collection and on the Export voyage, only raise a warning if I've been archived
// 08/06/2015	cnwdap1	PAR #36364 Validate that all inland terminal voyages can be deleted as well (if an inland terminal voyage had TIs
//						but the parent voyage didn't, the parent voyage could still be deleted, which would leave the TIs on the 
//						inland termianl voyage with an invalid object reference as their voyage
vars
	restrictionObj	: CM_LocationRestriction;
	restrictId		: String;
	tisIDs			: String;
	jobSheetObj		: CM_VoyageJobSheet;
	trackedItemObj	: CM_TrackedItem;
	terminalObj		: CM_Terminal;
	numInv			: Integer;
	importTS		: Integer;					// PAR #34221
	exportTS		: Integer;					// PAR #34221
	ti				: CM_TrackedItem;			// PAR #34221
	inlandVoyage	: CM_VoyageInlandTerminal;	// PAR #36364
	whereUsed : String;
	
begin
	terminalObj	:=	self.myTerminal;
	
	if terminalObj &lt;&gt; null then
		if terminalObj.getConfig(DefVoyage).CM_Voyage = self then
			app.raiseCMException3(ERR_USED_IN_CONFIG, "Voyage", self.code, "Terminal " &amp; app.myPassport.myTerminal.code, null, null);
		endif;
	endif;
	
	// any TIs in any collections
	if not self.allNotifiedTIsByCargoTypeId.isEmpty() then
		app.raiseCMException2(ERR_VOY_ERASE_TIS, self.code, self.allNotifiedTIsByCargoTypeId.size.String &amp;  " PreNote", null, null);
	endif;
	
	if not self.allOffsiteTIsByCargoTypeId.isEmpty() then
		app.raiseCMException2(ERR_VOY_ERASE_TIS, self.code, self.allOffsiteTIsByCargoTypeId.size.String &amp;  " Off-Site", null, null);
	endif;
	
	if not self.allOnshipTIsByCargoTypeId.isEmpty() then
		if  self.archived then
			app.raiseCMWarning2(ERR_VOY_ERASE_TIS, self.code, self.allOnshipTIsByCargoTypeId.size.String &amp;  " On-Ship", null, null, self);
		else
			app.raiseCMException2(ERR_VOY_ERASE_TIS, self.code, self.allOnshipTIsByCargoTypeId.size.String &amp;  " On-Ship", null, null);
		endif;
	endif;
	

	if not self.allOnsiteTIsByCargoTypeId.isEmpty() then
		app.raiseCMException2(ERR_VOY_ERASE_TIS, self.code, self.allOnsiteTIsByCargoTypeId.size.String &amp;  " On-Site", null, null);
	endif;
	
	if not self.allTbaTIsByCargoTypeId.isEmpty() then
		app.raiseCMException2(ERR_VOY_ERASE_TIS, self.code, self.allTbaTIsByCargoTypeId.size.String &amp;  " TBA", null, null);
	endif;
	
	//16 Mar 2020	NDL	TFS 47004
	if not self.allRRPTIsByCargoTypeId.isEmpty() then
		app.raiseCMException2(ERR_VOY_ERASE_TIS, self.code, self.allRRPTIsByCargoTypeId.size.String &amp;  " RRP", null, null);
	endif;

	if not self.allDeletedTIsByCargoTypeId.isEmpty then
	
		foreach trackedItemObj in self.allDeletedTIsByCargoTypeId discreteLock do
			if not trackedItemObj.invoiceLines.isEmpty() then
				numInv := numInv + 1;
				if tisIDs = null then
					tisIDs := trackedItemObj.id;
				else
					tisIDs := tisIDs &amp; ", " &amp; trackedItemObj.id;
				endif;
					
			endif;
		endforeach;
		
		if numInv &gt; 0 then
			app.raiseCMException4(ERR_No_Delete_Voyage_Invoice, self.code, " Deleted",self.code, " - " &amp; tisIDs &amp; ".", null, null);
		endif;
	endif;
	
	/*
	// commented out 03 Apr 2013 NDL Par 31368 - These are Inversed Peer to Peer, so who cares if the voyage is deleted....
	if not self.allTisByHouseBol.isEmpty then
		app.raiseCMException2(ERR_VOY_ERASE_TIS, self.code, self.allTisByHouseBol.size.String &amp;  " House BOL", null, null);
	endif;
	
	if not self.allOffloadedTIsByCargoTypeId.isEmpty then
		app.raiseCMException2(ERR_VOY_ERASE_TIS, self.code, self.allOffloadedTIsByCargoTypeId.size.String &amp;  " Offloaded", null, null);
	endif;
	
	if not self.allTranshipTIsExport.isEmpty then
		app.raiseCMException2(ERR_VOY_ERASE_TIS, self.code, self.allTranshipTIsExport.size.String &amp;  " Trans-ship Export", null, null);
	endif;
	
	if not self.allTranshipTIsImport.isEmpty then
		app.raiseCMException2(ERR_VOY_ERASE_TIS, self.code, self.allTranshipTIsImport.size.String &amp;  " Trans-ship Import", null, null);
	endif;
	*/
	
	// PAR #34221
	if not self.allTranshipTIsExport.isEmpty then
		foreach ti in self.allTranshipTIsExport discreteLock do
			if ti.myVoyage = ti.myImportVoyage then
				importTS := importTS + 1;
			endif;
			if ti.myVoyage = ti.myExportVoyage then
				exportTS := exportTS + 1;
			endif;
		endforeach;
		if importTS &lt;&gt; null then
			app.raiseCMException2(ERR_VOY_ERASE_TIS, self.code, importTS.String &amp;  " Trans-ship Import", null, null);
		endif;
		if exportTS &lt;&gt; null then
			if not self.archived then
				app.raiseCMException2(ERR_VOY_ERASE_TIS, self.code, exportTS.String &amp;  " Trans-ship Export", null, null);
			else
				app.raiseCMWarning2(ERR_VOY_ERASE_TIS, self.code, exportTS.String &amp;  " Trans-ship Export", null, null, null);
			endif;
		endif;
	endif;
	// PAR #34221 end
	
	// PAR #36364 Check all associated inland terminal voyages can also be deleted	// PAR #36364
	foreach inlandVoyage in self.allVoyageInlandTerminals do						// PAR #36364
		inlandVoyage.validateDelete(_passport);										// PAR #36364
	endforeach;																		// PAR #36364

	if not self.archived then
		// check all jobs - order of works
		foreach jobSheetObj in self.allJobSheets do
			jobSheetObj.validateForDelete();
		endforeach;
	endif;
	// check all location restrictions
	if not self.allLocationRestrictions.isEmpty() then
		foreach restrictionObj in self.allLocationRestrictions do
			restrictId := restrictId &amp; restrictionObj.myTerminalArea.id &amp; " ";
		endforeach;
		
		app.raiseCMException1(ERR_VOYAGE_USED_REST, restrictId, null, null);
	endif;
	
	if _valHMSVoyageData
	and self.myHMSVoyageData &lt;&gt; null then
		self.myHMSVoyageData.validateForDelete(_passport);
	endif;

	if self.myGeneralCargoVoyage &lt;&gt; null then
		self.myGeneralCargoVoyage.validateDelete(_passport);
	endif;

	if (not self.allOrdersByOperatorOrderNo.isEmpty) then
		app.raiseCMException2(ObjectStillHasEntries, 'Voyage ' &amp; self.code, 'Stock Orders', null, null);
	endif;
	
	if (not self.allBOLOutByTypeStatusNumDT.isEmpty) then
		app.raiseCMException2(StockOrderLoadedToShip, 'Voyage ' &amp; self.code, 'the ship', null, null);
	endif;
	
	if self.allBookingRefs.cnEcIsNotEmpty() then
		app.raiseCMException2(ObjectStillHasEntries, 'Voyage ' &amp; self.code, 'Booking References', null, null);
	endif;
	
	//10 Nov 2020	NDL	TFS 50279
	if self.isUsedinConfig( whereUsed ) then
		app.raiseCMException2(ERR_CANNOT_DELETE, self.code, whereUsed, null, self);
	endif;
	
end;</source>
        <Parameter name="_valHMSVoyageData" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForGarbageCollection" id="9c542c00-7f2c-431b-97d2-0ade8b1ed964">
        <source>validateForGarbageCollection();
// -------------------------------------------
// Created 24 August 2004 by cnwdvb1
// -------------------------------------------
vars

	stockHeader : CM_StockOrderHeader;

begin

	foreach stockHeader in self.allOrdersByOperatorOrderNo do
		stockHeader.validateForGarbageCollection();
	endforeach;


end;</source>
    </JadeMethod>
    <JadeMethod name="validateForStopReceival" id="de635da2-f693-446d-93d5-c747a22ef9a7">
        <source>validateForStopReceival(_theController:CMIF_OpCargoRecController);
// ---------------------------------------------------------------------------
// Created:		October 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if self.hasDeparted then
		app.raiseCMException3(ErrVoyageIsUnusable,self.code, " used for stopping cargo receival", "It has departed.", null, null);
	endif;
	
	if self.archived then
		app.raiseCMException3(ErrVoyageIsUnusable,self.code, " used for stopping cargo receival", "It is archived.", null, null);
	endif;
end;</source>
        <Parameter name="_theController" type="CMIF_OpCargoRecController"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="ad2ab878-ce23-4ef4-89eb-adc4bed309a4">
        <source>validateForUpdate(_passport : CM_Passport input;_includeStructures : Boolean);
//--------------------------------------------------------------
//Created: 20 June 2002 By: cnwgd1
//22/08/2023	navkc1	CR 59610 Task 59611: Jade - Stop Prevention
//--------------------------------------------------------------
vars
	vessel: CM_Vessel;
begin
	vessel := self.vessel();

	self.validateUseAllocations(_passport); // PAR 23216
	
	self.validateMe(_passport);
	
	if (not self.archived) then
		if self.myHMSVoyageData &lt;&gt; null  and vessel &lt;&gt; null and vessel.hasHarbourDetails() then		// 19/8/19 MAP TFS45926
			self.myHMSVoyageData.validateForUpdate(_passport);
		endif;
		if self.myGeneralCargoVoyage &lt;&gt; null then
			self.myGeneralCargoVoyage.validateForUpdate(_passport);
		endif;				
		if self.myLogVoyageStructure &lt;&gt; null then
			self.myLogVoyageStructure.validateForUpdate(_passport);
		endif;
		if self.myCellularVoyageStructure &lt;&gt; null then
			self.myCellularVoyageStructure.validateForUpdate(_passport);
		endif;									
	endif;	

	if  self.myHMSVoyageData &lt;&gt; null then
		// ### check that invoices have been produced before allowing archiving
		if self.status = Voyage_Status_Archived
		and not self.invoiceChargesProduced 
		and self.myTerminal.getConfig(FinancialsEnabled).Boolean
		and app.myRoot.canDo(Mod_Invoicing)  // Invoice License
		and app.myRoot.canDo(Mod_Harbour)  then // VTMIS License
			app.raiseCMException2(ERR_INVOICES_NOT_PRODUCED, self.code,"'Archived'",null, null);
		
		endif;
	endif;
	
	self.validateDepartureProcess(); //22/08/2023	navkc1	CR 59610 Task 59611
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_includeStructures" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateJobSheetCreate" id="33ace39a-caa6-488f-879c-b2355c11b3f9">
        <source>validateJobSheetCreate(_theCrane : CM_Machine;_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if not _theCrane.isKindOf(CM_Crane) then
		app.raiseCMException2(ERR_INVALID_VALUE, 'Crane Job Sheet', _theCrane.id &amp; "is not a crane. As such it cannot be added to " 
			&amp; self.code &amp; "'s job sheets",null, null);
	endif;
	if self.allJobSheets[_theCrane.id.trimBlanks] &lt;&gt; null then
		app.raiseCMException2(ERR_INVALID_VALUE, 'Crane Job Sheet', "A job sheet for crane " &amp; _theCrane.id &amp; " already exists for voyage " &amp; self.code,null, null);
	
	endif;
	
	if _theCrane.isNotAvailableForEntry then
		app.raiseCMException1(NotAvailableForEntry, app.getErrorString(Machine) &amp; ' (' &amp; _theCrane.id &amp; ') ', null, null);
		return; 
	endif;
end;</source>
        <Parameter name="_theCrane" type="CM_Machine"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateJobSheetUpdate" id="e9d61479-b006-4c73-9d85-416b07754181">
        <source>validateJobSheetUpdate(_theCranes : ObjectArray;_passport : CM_Passport input);
/* ---------------------------------------------------------------------------
// Created:		April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 01 Aug 2011 cnwer1	CCMS 1033 RORO operations _theCranes passed in can now include either CM_Crane or CM_WorkPoint objects
						changed method to handle this 
*/
vars
	vjs : CM_VoyageJobSheet;
	anObj : Object;
	workPointObject : CM_Object;
begin
	foreach anObj in _theCranes do
		if not anObj.isKindOf(CM_Crane)and not anObj.isKindOf(CM_WorkPoint) then
			app.raiseCMException2(ERR_INVALID_VALUE, 'Crane Job Sheet', "It is not a Crane or a Work Point. As such it cannot be added to " 
				&amp; self.code &amp; "'s job sheets",null, null);
		endif;
		
		if anObj.IF_VoyageWorkPoint.getIsNotAvailableForEntry then
			app.raiseCMException1(NotAvailableForEntry, app.getErrorString(Machine) &amp; ' (' &amp;  anObj.IF_VoyageWorkPoint.getID &amp; ') ', null, null);
		endif;

	endforeach;
	
	// ### check if a crane is being removed, if so then has it got any jobs
	foreach vjs in self.allJobSheets do
		workPointObject :=vjs.getMyWorkPointObject;
		if workPointObject &lt;&gt; null then
			if not _theCranes.includes(workPointObject) then // removing a crane
				if not vjs.allJobsByOrder.isEmpty then // that has jobs!!!!
					app.raiseCMException2(ERR_INVALID_VALUE, 'Crane Job Sheet', "The job sheet for crane " &amp; workPointObject.IF_VoyageWorkPoint.getID &amp; 
											" has jobs allocated to it for voyage " &amp; self.code &amp; ". It cannot be removed.",null, null);
				endif;
			endif;
		endif;
	endforeach;
	
end;</source>
        <Parameter name="_theCranes" type="ObjectArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="c29107d1-157c-4a82-badf-67577d32c294">
        <source>validateMe(_passport : CM_Passport input) protected;
//--------------------------------------------------------------
//Created: 20 June 2002 By: cnwgd1
//--------------------------------------------------------------
/*

Date		Who		Reason
31/03/2008	cnwkpd1	PAR #16388 - Remove duplicate validation for VCP mode - validation
					is done at the Global Voyage level
03/05/2017	cnwdap1	TFS 4293 Check for duplicate external voyage codes
06/10/2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
05/11/2019	jlgmd1	TFS 47321 Show an error if External Code is modified and terminal config says it shouldn't
03/06/2020  cnwma1  ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
17/07/2024	navlw1	ChangeRequest 63839: NSW | OnePort - Uniqueness of Inward and External Code 
26/11/2024	navdap1	MTN-33516 NSW | OnePort - Voyage Already Exists With External Code Error
*/

vars
	chkVoyage, 
	selfVoyage  	: CM_Voyage;				// TFS 4293
	termConfigName, 
	errStr 			: String;
	termCheck : CM_Terminal;	//22 Jul 2021	NDL	TFS 51601
	externalCodeStr	: String;
begin

	self.validate(_passport);

	self.validateDuplicateCode(_passport);	
	
	// Start navlw1 #63839
	//if self.isAutomaticProcess() then										// MTN-33516
	if self.myTerminal.getConfig(AllowDupVoyageInOutCodes).Boolean then		// MTN-33516
		chkVoyage := self.myTerminal.allVoyagesByExtCodeAuto [self.voyageCodeExternalAuto, self.vesselCode];
		externalCodeStr := self.voyageCodeExternalAuto;
	else
		chkVoyage := self.myTerminal.allVoyagesByExternalCode[self.voyageCodeExternal];
		externalCodeStr := self.voyageCodeExternal;						
	endif;
	
	if self.isTransient then																						// TFS 4293
		selfVoyage := app.myProxyManager.getRealObject(self).CM_Voyage;												// TFS 4293										
	else																										
		selfVoyage := self;																							
	endif;
	if chkVoyage &lt;&gt; null and chkVoyage &lt;&gt; selfVoyage then															// TFS 4293
		app.raiseCMException2(Voyage_Duplicate_External, chkVoyage.code, externalCodeStr, null, null);				// TFS 4293
	endif;	
	// End navlw1 #63839
		
	//22 July 2021	NDL	TFS 51601
	if app.myRoot.isClientLinx and self.voyageCodeExternal &lt;&gt; null then
		//Linx want the external voyage code unique across the whole system, whereas the norm is the code above, i.e. unique only within each terminal
		foreach termCheck in app.myRoot.allTerminals  discreteLock do
			if termCheck = self.myTerminal then
				//already checked above
				continue;
			endif;
			chkVoyage := termCheck.allVoyagesByExternalCode[self.voyageCodeExternal];
			if chkVoyage &lt;&gt; null and chkVoyage &lt;&gt; selfVoyage then
				app.raiseCMException2(Voyage_Duplicate_External, chkVoyage.code, self.voyageCodeExternal, null, null);
			endif;
		endforeach;	
	endif;
	
	// TFS47321 Raise an error if we are changing the external voyage code when we're not supposed to be able to
	if self.myTerminal.getConfig(CannotUpdateExternalCode).Boolean and selfVoyage &lt;&gt; null then
		if self.voyageCodeExternal &lt;&gt; selfVoyage.voyageCodeExternal then
			termConfigName := self.myTerminal.getConfigCodeNiceName(CannotUpdateExternalCode, true);
			errStr         := app.getErrorString(Voyage_ext_code_no_change);
			app.raiseCMException3(Terminal_config_option_set, termConfigName, true.String, errStr, null, null);	// complain
		endif;	
	endif;
	
	//03/06/2020 cnwma1 Tfs #49400
	if self.myTerminal.getConfig(CannotUpdateVoyGrpCode).Boolean and selfVoyage &lt;&gt; null then
		if self.voyageGroupCode &lt;&gt; selfVoyage.voyageGroupCode then
			termConfigName := self.myTerminal.getConfigCodeNiceName(CannotUpdateVoyGrpCode, true);
			errStr         := app.getErrorString(Voyage_group_code_no_change);
			app.raiseCMException3(Terminal_config_option_set, termConfigName, true.String, errStr, null, null);	
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMovements" id="da8efce7-2763-474e-ac54-67eb2619fd61">
        <source>validateMovements(_infoArray : HugeStringArray input);
// --------------------------------------------------------------------------------
// Created:		19 November 2007 by cnwdad1
//
// Purpose:		Used to validate movements for debugging purposes
// --------------------------------------------------------------------------------
vars
	tmpMove,
	prevMove	: HMS_Movement;
	firstTime	: Boolean;
	errStartPos		: Integer;		
begin
	if self.myHMSVoyageData = null then
		return;
	endif;
	
	errStartPos := _infoArray.size;
	
	firstTime := true;
	
	foreach tmpMove in self.myHMSVoyageData.allVoyageMovements do
		if firstTime then
			firstTime := false;
			
			if tmpMove.moveType &lt;&gt; HMSMovementTypeArrival then
				_infoArray.add('First movement is invalid type (' &amp; tmpMove.moveType &amp; ')');
			elseif tmpMove.occursOnDTNEW &lt;&gt; self.arrivedDT then
				_infoArray.add('First movement occurs DT (' &amp; tmpMove.occursOnDTNEW.asStringJMT &amp; ')' &amp;
					' &lt;&gt; vessel arrival DT (' &amp; self.arrivedDT.asStringJMT &amp; ')');
			endif;
		endif;
		
		if tmpMove.arrivalTimeAtFromRegion.cnEcAddMinutes(tmpMove.waitingTime + tmpMove.steamingTime) &lt;&gt; tmpMove.arrivalTimeAtToRegion then
			_infoArray.add('Movement ' &amp; tmpMove.getDescription &amp; ' - Arrival at A + waiting/steaming &lt;&gt; arrival at B - ' &amp; 
						tmpMove.arrivalTimeAtFromRegion.asStringJMT &amp; ' + ' &amp; 
						(tmpMove.waitingTime + tmpMove.steamingTime).asDaysHoursMinutesString &amp; 
						" should = " &amp; tmpMove.arrivalTimeAtToRegion.String);
		endif;
		
		if prevMove &lt;&gt; null then
			if prevMove.arrivalTimeAtToRegion &lt;&gt; tmpMove.arrivalTimeAtFromRegion then
				_infoArray.add('Movement ' &amp; tmpMove.getDescription &amp; 
					"ArrivalTime at A (" &amp; tmpMove.arrivalTimeAtFromRegion.asStringJMT &amp; ") &lt;&gt; ArrivalTime at B (" &amp; 
					prevMove.arrivalTimeAtToRegion.asStringJMT &amp; ") on prev Move " &amp; prevMove.getDescription);
			endif;
		endif;
		
		prevMove	:=	tmpMove;
	endforeach;
	
	if tmpMove = null then
		_infoArray.add('No movements found');
	elseif tmpMove.moveType &lt;&gt; HMSMovementTypeDeparture then
		_infoArray.add('Last movement is invalid type (' &amp; tmpMove.moveType &amp; ')');
	endif;
	
	if errStartPos &lt;&gt; _infoArray.size then
		// there have been some errors
		_infoArray.insert(errStartPos + 1, '*** Voyage ' &amp; self.code &amp; ' at ' &amp; self.myTerminal.code);
	endif;
	
end;</source>
        <Parameter name="_infoArray" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateNoCargoMatchingPreNote" id="efab1f81-f96c-46f9-9290-fd16305640c8">
        <source>validateNoCargoMatchingPreNote( _proxyTI : CM_TrackedItem; _locn : CM_LocationsController );


// TFS 54000 NOT USED ANYMORE THIS CODE WAS VERY SIMILAR TO CODE on CM_LocationsController::searchForOnsiteTI() SO now that is used.


/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 August 2013	cnwndl1	Initial creation	Par 32154
08 july 2022    navds20 Bug 54000: EUP - Unable to create same Cargo Id with different Cargo Group Ids
*/

vars

	cargoTypeObj : CM_CargoType;
	allowDuplicates : Boolean;
	iter : Iterator;
	firstMatch : CM_TrackedItem;
	ti : CM_TrackedItem;
	cargoUniqueness : Boolean; // 08/07/2022 navds20 TFS 54000
	
begin

	cargoTypeObj := _proxyTI.myCargoType;
	if cargoTypeObj &lt;&gt; null then
		allowDuplicates := cargoTypeObj.allowDuplicates;
		cargoUniqueness := cargoTypeObj.useCargoGroupForUniqueness; // 08/07/2022 navds20 TFS 54000
	endif;

	
	if not allowDuplicates then
		if self.allOnshipTIsByCargoTypeId[_proxyTI.cargoType, _proxyTI.id] &lt;&gt; null then
			//app.raiseCMException2(DuplicateItem, _proxyTI.id, self.code, null, null);		//13.07.2022 navsrk20 53760
			app.raiseCMException2(Onship_already_exists, _proxyTI.id, self.code, null, null);		//13.07.2022 navsrk20 53760
		endif;
				
	else
		// this is break bulk, so can use the same id, as long as its in different locations
		iter := self.allOnshipTIsByIdCargoType.createIterator;
		firstMatch := self.allOnshipTIsByIdCargoType.getAtKeyGeq( _proxyTI.id, null );
		if firstMatch &lt;&gt; null then
			iter.startAtObject(firstMatch);
			while iter.next( ti ) do
				if ti.id &lt;&gt; _proxyTI.id then
					break;
				endif;
				if ti.cargoType &lt;&gt; _proxyTI.cargoType then
					continue;
				endif;
				if ti.myPrimaryActualLocation &lt;&gt; _locn then
					continue;
				endif;
				if ti.isChild then	//07 Jul 2016	NDL	TFS 2297
					continue;
				endif;
				//start 08/07/2022 navds20 TFS 54000
				if cargoUniqueness then
					if ti.getMyCargoGroupId() &lt;&gt; _proxyTI.getMyCargoGroupId() then
						continue;
					endif;
				endif;
				//end 08/07/2022 navds20 TFS 54000
				//app.raiseCMException2(DuplicateItem, _proxyTI.id, _locn.getFullId, null, null);		//13.07.2022 navsrk20 53760
				app.raiseCMException2(Onship_already_exists, _proxyTI.id, _locn.getFullId, null, null);		//13.07.2022 navsrk20 53760
			endwhile;
		endif;
		
	endif;

epilog

	delete iter;

end;</source>
        <Parameter name="_proxyTI" type="CM_TrackedItem"/>
        <Parameter name="_locn" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="validateShippingLinePorts" id="791ec6fd-2566-4533-8dfd-15f842205737">
        <source>validateShippingLinePorts();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 May 2009	cnwer1	Initial creation CCMS 1058 - validating that the default debtors shipping lines ports are included in the 
									allPorts collection

*/

vars
	portSet		: CM_PortSet;
	port		: CM_Port;
	//portList	: String;
begin
	if self.myShippingLine = null or not self.myTerminal.getConfig( ShipLinePortGroupsForInv ).Boolean then
		return;
	endif;
		
	//get ports 
	create portSet transient;
	self.myShippingLine.getAllDischargePorts(portSet);
	
	foreach port in portSet do
		if (not self.includesPortInRotation(port)) then
			//portList := portList &amp; port.code &amp; ", ";
			app.raiseCMWarning1(Ship_line_Ports_discrepency,port.code,null,null,null);
		endif;
	endforeach;
	
	/*if portList.length &gt; 0 then
		portList := portList[1:portList.length-2];
		app.raiseCMWarning1(Ship_line_Ports_discrepency,portList,null,null,null);
	endif;*/
	
epilog
	delete portSet;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateUseAllocations" id="5034be4d-4305-458f-abb1-37522fd19ae1">
        <source>validateUseAllocations(_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     March 2010 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	useVAChanged, hasCC, hasJOB : Boolean;
	realMe : CM_Voyage;
	slot : CM_LocationsController;
	slotRequest : CM_Request;
begin
	
	realMe := self.pxyGetRealObject().CM_Voyage;
	if realMe &lt;&gt; null then
		useVAChanged := (realMe.useVoyageAllocations &lt;&gt; self.useVoyageAllocations);
		
		if useVAChanged then
			foreach slot in realMe.allVoyageLocations discreteLock do
				slotRequest := slot.CM_VoyageController.getColourCoding(true);
				if slotRequest &lt;&gt; null then
					hasCC := true;
					if slotRequest.myJob &lt;&gt; null then
						hasJOB := true;
					endif;
				endif;

				slotRequest := slot.CM_VoyageController.getColourCoding(false);
				if slotRequest &lt;&gt; null then
					hasCC := true;
					if slotRequest.myJob &lt;&gt; null then
						hasJOB := true;
					endif;
				endif;
			
				if hasCC and hasJOB then
					break;
				endif;
			endforeach;
			if hasJOB then
				if self.useVoyageAllocations then
					app.raiseCMException1(Canno_voyag_alloc_colou_codin_ , self.code, null,null);
				else
					app.raiseCMException1(Voyag_used_voyag_alloc_creat_c , self.code, null,null);
				endif;
			elseif hasCC then
				if self.useVoyageAllocations then
					app.raiseCMWarning(Have_selec_voyag_alloc_this_me, null,null, self);
				else
					app.raiseCMWarning1(Voyag_used_voyag_alloc_creat_X, self.code, null,null, self);
				endif;
			endif;
		endif;
	endif;
	
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="vessel" id="bc721ff3-09fd-4a79-bf92-bd44e8fbebfa">
