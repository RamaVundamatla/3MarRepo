    <JadeMethod name="getAvailable" id="37402db9-4e3f-44ac-9c3d-a4cb60cd99fe">
        <source>getAvailable( pCollectionObj : Collection );
// --------------------------------------------------------------------------------
// Created:		04 October 2006 by cnwdad1
//
// Purpose:		Populates the specified collection parameter with all objects that
//				are available for selection, but have not been selected.
//
// Parameters:	pCollectionObj - A reference to the collection to populate.
//
// Returns:		The populated collection object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 28/07/2010	cnwrl1		PAR 24415 - EDI Admin form does not handle deleted of EDI File Types.
// --------------------------------------------------------------------------------
vars
	isInvalid		: Boolean;
	ed				: Integer;
	listPointer		: Integer;
	itemObj			: Object;
	collectionObj	: Collection;
	
begin
	on Exception do app.handleDeletedObject( exception, itemObj, isInvalid );	// cnwrl1 28/07/2010 PAR 24415
	
	collectionObj	:=	pCollectionObj;
	
	foreach listPointer in 1 to self.myAvailableListBox.listCount do
		itemObj	:=	self.myAvailableListBox.itemObject[listPointer];
		// cnwrl1 28/07/2010 PAR 24415 - start of coding
		// Check that the object is still valid do this by assumming
		// it is valid and using an exception handler if it is not.
		isInvalid	:= false;
		if itemObj = null then
			continue;
		endif;
		ed	:= itemObj.edition();		// if invalid will trigger the armed exceptionHandler
		if isInvalid then
			continue;
		endif;
		// cnwrl1 28/07/2010 PAR 24415 - end of coding
		collectionObj.tryAddIfNotNull( itemObj ); // ### JIRA 35154 11JUL2025 NAVAB1 changed to tryAddIfNotNull
	endforeach;
	
epilog
	
end;
</source>
        <Parameter name="pCollectionObj" type="Collection"/>
    </JadeMethod>
    <JadeMethod name="getCurrentSelections" id="c160445c-f8c6-45ca-bc77-48ccca327439">
        <source>getCurrentSelections(availableSelections, selectedSelections : StringArray input; availableListIndex, selectedListIndex : Integer output);

// R Barr 6/11/2006 Comalco -- get currently selected items in both listboxes; then use restoreSelections()

vars
begin
	availableListIndex	:= myAvailableListBox.listIndex;
	myAvailableListBox.getCurrentSelections(availableSelections);
	selectedListIndex	:= mySelectedListBox.listIndex;
	mySelectedListBox.getCurrentSelections(selectedSelections);
end;
</source>
        <Parameter name="availableSelections" type="StringArray" usage="input"/>
        <Parameter name="selectedSelections" type="StringArray" usage="input"/>
        <Parameter name="availableListIndex" type="Integer" usage="output"/>
        <Parameter name="selectedListIndex" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getFirstSelectedObjInSelected" id="d460f75a-338f-40d6-b02f-d4e7bd9ca8d8">
        <source>getFirstSelectedObjInSelected():Object;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 August 2009	cnwndl1	Initial creation

*/

vars
	
begin
	return self.mySelectedListBox.getFirstSelectedObject();
epilog

end;</source>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="getSelected" id="f014c783-f31d-4621-9151-3d5b6f947499">
        <source>getSelected( pCol : Any );
// ---------------------------------------------------------------------------
// Created:     02 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 28/07/2010	cnwrl1		PAR 24415 - EDI Admin form does not handle deleted of EDI File Types.
// ---------------------------------------------------------------------------
vars
	isInvalid	: Boolean;
	ed			: Integer;
	index		: Integer;
	listSize	: Integer;
	obj			: Object;
	tmpCol		: Collection;
	invalidObjType : Boolean;
    
begin
	on Exception do app.handleDeletedObject( exception, obj, isInvalid );	// cnwrl1 28/07/2010 PAR 24415
	on Exception do self.handle1312Exception( exception, invalidObjType );	//18 Aug 2014	NDL	Par 34727
	
	tmpCol		:=	pCol.Collection;
	listSize	:=	self.mySelectedListBox.listCount();
	
	foreach index in 1 to listSize do
		obj	:=	self.mySelectedListBox.itemObject[index];
		
		/* cnwrl1 28/07/2010 PAR 24415 - what it was
		if obj &lt;&gt; null and global.isValidObject(obj) then
			tmpCol.add(obj);
		endif;
		cnwrl1 28/07/2010 PAR 24415 - end of what it was */
		
		// cnwrl1 28/07/2010 PAR 24415 - start of replacement coding
		// Check that the object is still valid do this by assumming
		// it is valid and using an exception handler if it is not.
		isInvalid	:= false;
		if obj = null then
			continue;
		endif;
		ed	:= obj.edition();		// if invalid will trigger the armed exceptionHandler
		if isInvalid then
			continue;
		endif;
		tmpCol.tryAddIfNotNull( obj );  // ### JIRA 35154 11JUL2025 NAVAB1
		// cnwrl1 28/07/2010 PAR 24415 - end of coding
	endforeach;
	
epilog
	
end;
</source>
        <Parameter name="pCol" type="Any"/>
    </JadeMethod>
    <JadeMethod name="getSelectedDisplayEntries" id="e32d03d4-9216-407c-9ee6-b248d4be7b43">
        <updating/>
        <source>getSelectedDisplayEntries(_sa: StringArray) updating;
//----------------------------------------------------------------
//	Created:	23 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	i		: Integer;
	obj		: Object;
	tmpSA	: StringArray;
	str : String;
begin

	tmpSA := _sa;
	
	foreach i in 1 to self.mySelectedListBox.listCount do
		obj := self.mySelectedListBox.itemObject[i];
		
		// ### JIRA 35154 11JUL2025 NAVAB1
		str := self.displayEntry(obj);
		if str &lt;&gt; null then
			tmpSA.add(str); 
		endif;
	endforeach;
end;</source>
        <Parameter name="_sa" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="getXMLStringForSelected" id="19908481-8073-4ca3-aa22-9553a99ba25a">
        <source>getXMLStringForSelected(_attrNames:StringArray):String;
// --------------------------------------------------------------------------------
// Created:		29 November 2006 by cnwdad1
//
// Purpose:		Returns XML tags for the contents of the receiver.
//
// Parameters:	_attrNames - An array of key attribute names, who's values are to be
//					included in the XML stream.  These values can then be used to
//					look up the object(s) the next time the User opens the form.
//
// Returns:		The XML stream for the receiver's contents.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	listboxObj	: ListBox;
	listObject	: Object;
	xmlData		: String;
	propValue	: String;
	attrName	: String;
	rowPointer	: Integer;
	rowCount	: Integer;

begin
	listboxObj	:=	self.mySelectedListBox;
	rowCount	:=	listboxObj.listCount();
	
	if rowCount &gt; 0 then
		xmlData	:=	self.formatAsXMLPrefix(XMLTag_ListTable &amp; self.name);
		
		foreach rowPointer in 1 to rowCount do
			listObject	:=	listboxObj.itemObject[rowPointer];
			propValue	:=	null;
			
			foreach attrName in _attrNames do
				if propValue &lt;&gt; null then
					propValue	:=	propValue &amp; ',';
				endif;
				
				propValue	:=	propValue &amp; listObject.getPropertyValue(attrName).String;
			endforeach;
			
			xmlData	:=	xmlData &amp;  global.formatAsXML(XMLTag_SelectedValue, propValue);
		endforeach;
		
		xmlData	:=	xmlData &amp; self.formatAsXMLSuffix(XMLTag_ListTable &amp; self.name);
	endif;
	
	return xmlData;
end;</source>
        <Parameter name="_attrNames" type="StringArray"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handle1312Exception" id="6324e0f5-9cac-4128-8e31-07929f2c3cc4">
        <source>handle1312Exception( _exc : Exception; _invalidObjType : Boolean io ):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 August 2014	cnwndl1	Initial creation	Par 34727

*/

constants

	InvalidClassOfObject	= 1312;
	
vars

	returnVal		: Integer;

begin

	returnVal := Ex_Pass_Back;
	
	if _exc.errorCode = InvalidClassOfObject then
		_invalidObjType := true;
		if _exc.resumable then
			returnVal := Ex_Resume_Next;
		endif;
	endif;

epilog

	return returnVal;

end;</source>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_invalidObjType" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleBtnClick" id="a158597f-c0b2-4e06-9f47-1b347720956d">
        <updating/>
        <source>handleBtnClick( _btn : CM_MultiSelectButton ) updating;
// ---------------------------------------------------------------------------
// Created:     29 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/03/2009	cnwrl1		PAR 19174 - Fix Control resizing issue.
//15 May 2024   navbs1      Bug 64102: Cannot add todo task if there are multiple todo work order tasks
// ---------------------------------------------------------------------------
vars
	selectedStr : String;
	selectedObj	: Object;
	totRows,
	idx,
	selectedIdx	: Integer;
	objsReversed : ObjectArray;
	origIdx: Integer;
	str : String;
	coll : Collection;
	iter : Iterator;
begin

	// if isMultipleSelectAllowed then
	// 		handleBtnClickMultiple();
	// else
	// ....
	
	if _btn = self.myAddSelectedBtn then
		if self.myAvailableListBox.selectedCount &gt; 1 then
			totRows := self.myAvailableListBox.listCount;
			//10 Jul 2020	NDL	TFS 49579
			if  app.activeForm.name = "SOP_ReeferWalkPathForm" and not self.mySelectedListBox.sorted then
				//do all the removes first in reverse order
				create objsReversed transient;
				foreach idx in totRows to 1 step -1 do
					selectedObj := self.myAvailableListBox.itemObject[idx];
					if self.myAvailableListBox.itemSelected[idx] then
						str := null;
						if self.mySelectedListBox.formDisplayEntryMethodName &lt;&gt; null then
							str := self.mySelectedListBox.displayEntry(self.mySelectedListBox, selectedObj, null);
						else
							str := self.displayEntry(selectedObj);
						endif;
						if str &lt;&gt; null then
							objsReversed.add( selectedObj );
							self.myAvailableListBox.removeItem(idx);
						endif;
					endif;
				endforeach;
				//now do the adds in the correct order
				iter := objsReversed.createIterator;
				while iter.back( selectedObj ) do
					if self.mySelectedListBox.formDisplayEntryMethodName &lt;&gt; null then
						str := self.mySelectedListBox.displayEntry(self.mySelectedListBox, selectedObj, null);
					else
						str := self.displayEntry(selectedObj);
					endif;
					idx := self.mySelectedListBox.addItem(str);
					self.mySelectedListBox.itemObject[idx] := selectedObj;
				endwhile;
				delete iter;
				
			else
				foreach idx in totRows to 1 step -1 do
					// do in reverse order as removing items
					// will screw up index
					if self.myAvailableListBox.itemSelected[idx] then
						self.selectItem(idx, self.myAvailableListBox.itemObject[idx]);
					endif;
				endforeach;
			endif;
		else
			//+cnwml2 PAR24472
			selectedObj := self.myAvailableListBox.listObject;
			selectedIdx := self.myAvailableListBox.listIndex;
			self.selectItem(selectedIdx, selectedObj);
		endif;

	elseif _btn = self.myRemoveSelectedBtn then
		if self.mySelectedListBox.selectedCount &gt; 1 then
			totRows := self.mySelectedListBox.listCount;
			foreach idx in totRows to 1 step -1 do
				// do in reverse order as removing items
				// will screw up index
				if self.mySelectedListBox.itemSelected[idx] then
					self.removeItem(idx, self.mySelectedListBox.itemObject[idx]);
				endif;
			endforeach;
		else
			selectedObj := self.mySelectedListBox.listObject;
			selectedIdx := self.mySelectedListBox.listIndex;
			self.removeItem(selectedIdx, selectedObj);
		endif;

	elseif _btn = self.myUpSelectedBtn then
		/*if self.mySelectedListBox.selectedCount &gt; 1 then
			app.msgBox(app.getErrorString(Please_Select_One), app.getErrorString(Move_Up), MsgBox_Stop_Icon+MsgBox_OK_Only);
		else
			selectedObj := self.mySelectedListBox.listObject;
			selectedIdx := self.mySelectedListBox.listIndex;
			self.moveItem(selectedIdx, selectedObj, -1);
		endif;*/
		//cnwmc5 - 10/12/2012
		totRows := self.mySelectedListBox.listCount;
		idx := 1;
		while idx &lt;= totRows do
			if self.mySelectedListBox.itemSelected[idx] then
				self.moveItem(idx, self.mySelectedListBox.itemObject[idx], -1);
			endif;
			idx := idx + 1;
		endwhile;
	elseif _btn = self.myDownSelectedBtn then
		/*if self.mySelectedListBox.selectedCount &gt; 1 then
			app.msgBox(app.getErrorString(Please_Select_One), app.getErrorString(Move_Down), MsgBox_Stop_Icon+MsgBox_OK_Only);
		else
			selectedObj := self.mySelectedListBox.listObject;
			selectedIdx := self.mySelectedListBox.listIndex;
			self.moveItem(selectedIdx, selectedObj, 1);
		endif;*/
		//cnwmc5 - 10/12/2012
		totRows := self.mySelectedListBox.listCount;
		foreach idx in totRows to 1 step -1 do
			if self.mySelectedListBox.itemSelected[idx] then
				self.moveItem(idx, self.mySelectedListBox.itemObject[idx], 1);
			endif;
		endforeach;
	elseif _btn = self.myAddAllBtn then
		totRows := self.myAvailableListBox.listCount;
		foreach idx in totRows to 1 step -1 do
			// do in reverse order as removing items
			// will screw up index
			self.selectItem(idx, self.myAvailableListBox.itemObject[idx]);
		endforeach;
	elseif _btn = self.myRemoveAllBtn then
		totRows := self.mySelectedListBox.listCount;
		foreach idx in totRows to 1 step -1 do
			// do in reverse order as removing items
			// will screw up index
			self.removeItem(idx, self.mySelectedListBox.itemObject[idx]);
		endforeach;
	//cnwmc5 - 10/12/2012 - added 2 new buttons	
	elseif _btn = self.myTopSelectedBtn then
		totRows := self.mySelectedListBox.listCount;
		foreach idx in 1 to totRows do
			if self.mySelectedListBox.itemSelected[idx] then
				self.moveItemTo(idx, self.mySelectedListBox.itemObject[idx], 1);
			endif;
		endforeach;
		//Run through this code twice to fix the order in which items are moved to the top
		foreach idx in 1 to totRows do
			if self.mySelectedListBox.itemSelected[idx] then
				self.moveItemTo(idx, self.mySelectedListBox.itemObject[idx], 1);
			endif;
		endforeach;
	elseif _btn = self.myBottomSelectedBtn then
		totRows := self.mySelectedListBox.listCount;
		foreach idx in totRows to 1 step -1 do
			if self.mySelectedListBox.itemSelected[idx] then
				self.moveItemTo(idx, self.mySelectedListBox.itemObject[idx], totRows);
			endif;
		endforeach;
		//Run through this code twice to fix the order in which items are moved to the bottom
		foreach idx in totRows to 1 step -1 do
			if self.mySelectedListBox.itemSelected[idx] then
				self.moveItemTo(idx, self.mySelectedListBox.itemObject[idx], totRows);
			endif;
		endforeach;
	endif;
	if self.myBaseForm &lt;&gt; null then
		self.myBaseForm.doControlEvent(_btn);
	endif;
	
epilog
	
	delete objsReversed;
	delete iter;
	
end;</source>
        <Parameter name="_btn" type="CM_MultiSelectButton"/>
    </JadeMethod>
    <JadeMethod name="handleListBoxClick" id="fc2c74a5-3bee-4e7a-b961-6dbe3d9d8618">
        <source>handleListBoxClick(_listBox : CM_MultiSelectListBox);

// cnwdvb1 16 January 2003 

vars

begin
	if self.myBaseForm &lt;&gt; null then
		self.myBaseForm.doControlEvent(_listBox);
	endif;

end;</source>
        <Parameter name="_listBox" type="CM_MultiSelectListBox"/>
    </JadeMethod>
    <JadeMethod name="handleListBoxDblClick" id="e2478ec7-d8f9-44b5-828d-3255bb73398f">
        <updating/>
        <source>handleListBoxDblClick(listBox : CM_MultiSelectListBox) updating;

// ---------------------------------------------------------------------------
// Created:		10 December 2002 By Jason Chapman cnwjc2
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
begin
	if (not self.readOnly) or (self.userInputEnabled) then
		if listBox = self.myAvailableListBox then
			self.handleBtnClick(self.myAddSelectedBtn);
		else
			self.handleBtnClick(self.myRemoveSelectedBtn);
		endif;
	endif;
end;</source>
        <Parameter name="listBox" type="CM_MultiSelectListBox"/>
    </JadeMethod>
    <JadeMethod name="isSelected" id="15f4c1e7-0549-4b54-bc2c-6a6324a315f7">
        <source>isSelected( _obj : Object) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwrd1	Initial creation

*/

vars
	rowPointer	: Integer;
begin
	rowPointer	:=	self.mySelectedListBox.findObject(_obj);
	
	if rowPointer &lt;&gt; CNEC_NULL_INDEX then
		return true;
	endif;

	return false;

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="moveItem" id="fc3ae764-4e29-4e48-9b5a-3c28c0fef7e4">
        <updating/>
        <source>moveItem(pIdx : Integer; pObj : Object;_moveNum : Integer) protected, updating;
// ---------------------------------------------------------------------------
// Created:     29 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	nexIndex	: Integer;
	theText : String;
	itemBackColor : Integer;
begin

	if pIdx &gt; 0 and pObj &lt;&gt; null then
		// remove from the selected list box
		nexIndex := pIdx + _moveNum;

		if nexIndex &lt; 1 or nexIndex &gt; self.mySelectedListBox.listCount then
			return;
		endif;
		theText := self.mySelectedListBox.itemText[pIdx];
		//jlier1 TFS 53515 2/6/22
		itemBackColor:=self.mySelectedListBox.itemBackColor[pIdx];
		
		self.mySelectedListBox.removeItem(pIdx);
		self.mySelectedListBox.addItemAt(theText,nexIndex);
		self.mySelectedListBox.itemObject[nexIndex] := pObj;
		self.mySelectedListBox.itemSelected[nexIndex] := true;
		if itemBackColor &gt; 0 then
			self.mySelectedListBox.itemBackColor[nexIndex]:=itemBackColor;
		endif;
		self.mySelectedListBox.listIndex := nexIndex;
		
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="pIdx" type="Integer"/>
        <Parameter name="pObj" type="Object"/>
        <Parameter name="_moveNum" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="moveItemTo" id="db30ab72-e796-4efd-9abc-04c1a2a69e92">
        <updating/>
        <source>moveItemTo(pIdx : Integer; pObj : Object;_moveTo : Integer) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 December 2012	cnwmc5	Initial creation

*/

vars
	nexIndex	: Integer;
	theText : String;
begin

	if pIdx &gt; 0 and pObj &lt;&gt; null then
		// remove from the selected list box
		nexIndex := _moveTo;

		if nexIndex &lt; 1 or nexIndex &gt; self.mySelectedListBox.listCount then
			return;
		endif;
		theText := self.mySelectedListBox.itemText[pIdx];
		self.mySelectedListBox.removeItem(pIdx);
		self.mySelectedListBox.addItemAt(theText,nexIndex);
		self.mySelectedListBox.itemObject[nexIndex] := pObj;
		self.mySelectedListBox.itemSelected[nexIndex] := true;
		self.mySelectedListBox.listIndex := nexIndex;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="pIdx" type="Integer"/>
        <Parameter name="pObj" type="Object"/>
        <Parameter name="_moveTo" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="multiClear" id="d4a66561-649a-4bb8-bb27-b2afb69b2edb">
        <source>multiClear();

vars

begin

	self.myAvailableListBox.clear;
	self.mySelectedListBox.clear;
	
end;</source>
