    <JadeMethod name="shChangeEnviroment" id="33a14bef-d3f4-4f1e-9804-6780b7d9772f">
        <source>shChangeEnviroment();

vars

	fIni_old, fIni_new, fConf_old, fConf_new : File;
	fn1, fn2 : FileNode;
	ff1, ff2 : FileFolder;
	s : String;
	
begin

	//modify the ini file
	create fIni_old;
	create fIni_new;
	fIni_new.allowCreate := true;
	fIni_old.fileName := "\\cnwchcs55\t$\jdin7010\server\c_bin\jdin7010.ini";
	fIni_new.fileName := "\\cnwchcs55\t$\jdin7010\server\c_bin\jdin7106.ini";
	while not fIni_old.endOfFile() do
		s := fIni_old.readLine();
		if s.contains("7010") then
			s := s.replace("7010", "7106");
		endif;
		fIni_new.writeLine(s);
	endwhile;	
	fIni_old.purge;	
	fIni_new.close;
	
	//modify the conf file
	create fConf_old;
	create fConf_new;
	fConf_new.allowCreate := true;
	fConf_old.fileName := "\\cnwchcs55\c$\thinbin\tools\configuration\Autodino.conf";
	fConf_new.fileName := "\\cnwchcs55\c$\thinbin\tools\configuration\Autodino_temp.conf";
	while not fConf_old.endOfFile() do
		s := fConf_old.readLine();
		if s.contains("7010") then
			s := s.replace("7010", "7106");
		endif;
		fConf_new.writeLine(s);
	endwhile;
	fConf_old.purge;
	fConf_new.rename("\\cnwchcs55\c$\thinbin\tools\configuration\Autodino.conf");
	
	//delete folders that are not used 
	create ff1;
	create ff2; 
	ff1.fileName := "\\cnwchcs55\t$\jdin7010\server";
	foreach fn1 in ff1.files do 	
		if fn1.fileName &lt;&gt; "\\cnwchcs55\t$\jdin7010\server\c_system" and fn1.fileName &lt;&gt; "\\cnwchcs55\t$\jdin7010\server\c_bin" and fn1.fileName &lt;&gt; "\\cnwchcs55\t$\jdin7010\server\i686-msoft-win32-ansi" and fn1.fileName &lt;&gt; "\\cnwchcs55\t$\jdin7010\server\x64-msoft-win64-ansi" then
			ff2.fileName := fn1.fileName;
			foreach fn2 in ff2.files do
				fn2.purge;
			endforeach;

			fn1.purge;
		endif;
		if fn1.fileName = "\\cnwchcs55\t$\jdin7010\server\i686-msoft-win32-ansi" or fn1.fileName = "\\cnwchcs55\t$\jdin7010\server\x64-msoft-win64-ansi" then
			ff2.fileName := fn1.fileName &amp; "\download\bin"; 
			foreach fn2 in ff2.files do 
				fn2.purge;
			endforeach;
			ff2.fileName := fn1.fileName &amp; "\download"; 
			foreach fn2 in ff2.files do 
				fn2.purge;
			endforeach;
			ff2.purge;
			fn1.purge;
		endif;
	endforeach;
	//rename the enviroment folder
	ff1.fileName := "\\cnwchcs55\t$\jdin7010";
	ff1.rename("\\cnwchcs55\t$\jdin7106");
epilog
	delete fIni_old;
	delete fIni_new;
	delete fConf_old;
	delete fConf_new;
	delete ff1;
	delete ff2;
end;

</source>
    </JadeMethod>
    <JadeMethod name="shChangeFileNames" id="8f325f06-a424-4a12-bf88-62c1e371c79c">
        <source>shChangeFileNames();

vars
	f : File;
	fn : FileNode;
	ff : FileFolder;
begin
	create ff;
	create f;
	ff.fileName := "\\cnwchcm24\cnwjbl$\BenchMarkResults\JCC\20160406_s25\upg_c";
	foreach fn in ff.files do 
		f.fileName := fn.fileName;
		f.rename (fn.fileName.replace ("base_", "upg_"));
	endforeach;
	
	delete ff;
end;
</source>
    </JadeMethod>
