    <JadeMethod name="setMultiSelectForCargoType" id="a9a6193e-2260-468b-8705-638e605e9eb7">
        <source>setMultiSelectForCargoType(_editMode : Boolean) protected;
/* ---------------------------------------------------------------------------
Created:	19 May 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	cargoType				: CM_CargoType;
	allUserTerminals		: CM_TerminalByCodeDict;
	userSelectedTerminals	: CM_TerminalSet;
	
begin
	
	cargoType := self.myCurrentObject.CM_CargoType;
	
	if _editMode then
		self.mulSelectTerm.userInputEnabled		:= true;
		self.mulSelectCommod.userInputEnabled	:= true;
		self.mulDmgePosition.userInputEnabled 	:= true; // CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
		self.mulDmgeDefCode.userInputEnabled 	:= true; // CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
		self.mulSeals.userInputEnabled			:= true;	//+cnwml2 PAR23715 SFW CCMS 1131
	else
		self.mulSelectTerm.userInputEnabled		:= false;
		self.mulSelectCommod.userInputEnabled	:= false;
		self.mulDmgePosition.userInputEnabled 	:= false;
		self.mulDmgeDefCode.userInputEnabled 	:= false;
		self.mulSeals.userInputEnabled			:= false;	//+cnwml2 PAR23715 SFW CCMS 1131
	endif;
	
	// ------------------------------------------------------
	//				multi select for allUserTerminals
	// ------------------------------------------------------
	create allUserTerminals transient;
	create userSelectedTerminals transient;
	
	app.getMyUser.getTerminals(allUserTerminals);
	self.mulSelectTerm.setAvailable(allUserTerminals, true);
	
	if cargoType &lt;&gt; null then	// existing cargo type
		cargoType.getUserTerminalsForCargoType(userSelectedTerminals);
		self.mulSelectTerm.setSelected(userSelectedTerminals);	
	endif;

	//--------------------------------------------------------
	//               multi select for damage positions
	// CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
	//--------------------------------------------------------
	self.mulDmgePosition.setAvailable(app.myRoot.allDamagePositionsByCode, true);
	if cargoType &lt;&gt; null then
		self.mulDmgePosition.setSelected(cargoType.allDamagePositions);
	endif;
	
	//--------------------------------------------------------
	//               multi select for damage defintion code
	// CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
	//--------------------------------------------------------
	self.mulDmgeDefCode.setAvailable(app.myRoot.allDamageDefinitionCodes, true);
	if cargoType &lt;&gt; null then
		self.mulDmgeDefCode.setSelected(cargoType.allDamageDefinitionCodes);
	endif;
	
	// ------------------------------------------------------
	//				multi select for commodities
	// ------------------------------------------------------
	self.mulSelectCommod.setAvailable(app.myRoot.allCommodities, true);
	if cargoType &lt;&gt; null then	// existing cargo type
		self.mulSelectCommod.setSelected(cargoType.allCommodities);	//need to initialize for each cargo type. Comboboc Track As can be changed to have commodities and selected should be null.
	endif;
	
	self.shtCommodityEnableDisable(null, cargoType, -1);	//CCMS 1080, PAR 19704, 20316. July 2009
	
	// -------------------------------------------------------
	//				multi select for Seals
	// -------------------------------------------------------
	//+cnwml2 PAR23715 SFW CCMS1131
	self.mulSeals.setAvailable(app.myRoot.allSealTypes, true);
	if cargoType &lt;&gt; null then
		self.mulSeals.setSelected(cargoType.allSealTypes);
	endif;
	
epilog
	delete allUserTerminals;
	delete userSelectedTerminals;

end;</source>
        <access>protected</access>
        <Parameter name="_editMode" type="Boolean"/>
    </JadeMethod>
