    <JadeMethod name="utlUpdateInvTypeDtrSeparation" id="adfc7a53-d31b-4624-bdf6-f083b296eda6">
        <source>utlUpdateInvTypeDtrSeparation(_proxy : CM_InvTypeDebtorSeparation input; 
								_passport : CM_Passport input);
/*

Purpose:			Updates an Invoice Type Debtor Separation

Parameters:			_proxy		CM_InvTypeDebtorSeparation	The proxy/transient object
					_passport	CM_Passport					The passport to use to hold the transaction information

Return Value:		NONE

Date		Who		Reason
24 August 2022	navpw1	Initial creation TFS: 54565 (54384)

*/

vars
	cancelSave		: Boolean;
	real 			: CM_InvTypeDebtorSeparation;
	expectedEdition	: Integer;
	
begin
	self.initialiseActivity();

	_proxy.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxy.pxyGetRealObjectAndEdition(real, expectedEdition);
	
	if real = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Invoice.name, null, null);
		return;
	endif;

	app.myValUA.valInvTypeDebtorSeparation(real, _proxy);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(real);

	if _passport.noErrors and real.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'InvTypeDebtorSeparation', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(real, true);
	endif;
	
	if _passport.noErrors then
		real.setForUpdate(_proxy);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(real, false);
	endif;

end;</source>
        <Parameter name="_proxy" type="CM_InvTypeDebtorSeparation" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
