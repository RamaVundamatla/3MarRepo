// MES CCMS 1015 PAR22444 - cnwsh3. Messina Reports (Document - Teminal Ops BRS 2.1)
//----------------------------------------------------------------------
vars

begin
	inheritMethod();
	self.allTxnTypes.add(TRANS_TYPE_EDIT);
epilog
end;</source>
    </JadeMethod>
</Class>
