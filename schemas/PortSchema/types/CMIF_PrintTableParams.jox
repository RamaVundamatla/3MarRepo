    <JadeMethod name="delete" id="36b3ee98-e9ec-4ad0-89e7-9425f3f9d632">
        <updating/>
        <source>delete() updating;
//----------------------------------------------------------------
//	Created:	24 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
begin

	if self.jadeReport &lt;&gt; null and self.closePrinter then
		delete self.jadeReport;
	endif;

end;</source>
