    <JadeMethod name="getNumTugsOnContractFromVessel" id="c1f46575-a108-42af-ad51-023b3ac33fce">
        <source>getNumTugsOnContractFromVessel() : Integer;
// ---------------------------------------------------------------------------
// Created:		17 January 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	vessData : HMS_VesselData;
	vessDataHarbour : HMS_VesselDataHarbour;
	rtfm : HMS_ResourceTypeForMovement;
begin
	if self.myHMSVoyageData &lt;&gt; null then
		vessData := self.myHMSVoyageData.getMyHMSVesselData();
		if vessData &lt;&gt; null then
			vessDataHarbour := vessData.getVesselDataHarbour(self.myHarbour);
			if vessDataHarbour &lt;&gt; null then
				rtfm := vessDataHarbour.allMovementResourcesByMovement[self.moveType];
				if rtfm &lt;&gt; null then
					return rtfm.numTugsForMovement;
				endif;
			endif;
		endif;
	endif;
	
	return 0;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
