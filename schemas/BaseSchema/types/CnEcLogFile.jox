    <Constant name="Rollover_Mode_Daily" id="c6702670-6870-4714-aa4c-48fc6d3f6112">
        <source>0</source>
        <type name="Integer"/>
    </Constant>
    <Constant name="Rollover_Mode_Length_Exceeded" id="b43e4dc2-2baf-49eb-877d-f2364028df8a">
        <source>1</source>
        <type name="Integer"/>
    </Constant>
    <PrimAttribute name="currentDate" id="1b6babf2-2507-4d78-9366-113a7e2ba980">
        <embedded/>
        <type name="Date"/>
    </PrimAttribute>
    <PrimAttribute name="maxLength" id="c6211661-5a84-422a-b852-c0f1d79dbf78">
        <embedded/>
        <type name="Integer"/>
        <access>protected</access>
    </PrimAttribute>
    <PrimAttribute name="nameRoot" id="d5eeee44-35ab-49a7-b16c-3ca4ae98aaad">
        <length>129</length>
        <embedded/>
        <type name="String"/>
        <access>protected</access>
    </PrimAttribute>
    <PrimAttribute name="rolloverMode" id="b32f9621-0049-4f50-bd84-30c4726810fd">
        <embedded/>
        <type name="Integer"/>
        <access>protected</access>
    </PrimAttribute>
    <JadeMethod name="checkForRollover" id="80a64dff-f0ed-4ff6-b3b2-6ccfab89aea1">
        <updating/>
        <source>checkForRollover() updating;

vars
 	filename 	: String;
 	extension	: Integer;
 	length		: Integer;
	today		: Date;
	oldFileObj 	: CnEcLogFile;

begin
	on FileException do cnEcFileExceptionHandler(exception);

	if rolloverMode = Rollover_Mode_Daily then
		if currentDate &lt;&gt; today then
			// new day - need to roll over to a new file
			self.close();
			self.kind := File.Kind_Unknown_Text; // 26/2/16  cnwns1 PAR 36286 unicode version
			// now reopen again 
			self.fileName := nameRoot &amp; today.format("ddMMyyy") &amp; '.log';
			self.mode := File.Mode_Append;
			self.allowReplace := true;
			self.shareMode :=File.Share_Read;
			self.open;
		endif;
	else	// rollover after max length exceeded
		if self.fileLength() &gt; (maxLength)  then
			// need to determine the  name and append the 'old' extension to it 
			// or  just add the OLD if the filename has no extension
			
			filename := self.fileName;
			extension := filename.pos('.',1);

			if extension &lt;&gt; null then 	
				filename[extension + 1 :end] := "old";
			else
		 		length := self.fileName.length;
		    	filename[length + 1 : end] := "OLD";
			endif;

			// check to see if the old file already exists, and if so, delete it as
			// the rename wont replace an exist file if its there already 

			self.close();
	 	   	create oldFileObj transient;
			oldFileObj.kind := File.Kind_Unknown_Text; // 26/2/16  cnwns1 PAR 36286 unicode version
	  		oldFileObj.fileName := filename;
	  		oldFileObj.mode := File.Mode_Input;
	  		
	  		if oldFileObj.isAvailable() then	
				oldFileObj.purge;
 	 		endif;
 	 		
 	 		delete oldFileObj; 

			// now we can do the rename
			self.rename(filename); 
			
			// now reopen again 
			self.kind := File.Kind_Unknown_Text; // 26/2/16  cnwns1 PAR 36286 unicode version7
			self.fileName := nameRoot &amp; '.log';
			self.mode := File.Mode_Append;
			self.allowReplace := true;
			self.shareMode :=File.Share_Read;
			self.open;
		endif; // of file length &gt; maximum logfile size
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="init" id="6597ab34-1c0a-470a-9eb5-e1a068600d52">
        <updating/>
        <source>init(event:Integer; name:String; spec:Integer) updating;
// Initialise the logfile. 
// This method should be executed immediately after creation
// 
// event: Integer constant - normally 'Message_Log'
// name : logfile name including path if required
// spec : 0 	indicates daily rollover
//		  other value indicates max logfile size before rollover
vars
	today:Date;
	msg:String;
	logdir:String;

begin
	on FileException do cnEcFileExceptionHandler(exception);

	// Register for the appropriate event type

	beginNotification(global, event, Response_Continuous, 0);

	logdir := cnEcIniString('CardLog', 'LogPath'); // default to cardScema log file directory

	if name = '' then
		nameRoot := logdir &amp; global.cnEcGetFileSeparator() &amp; app.name;	// default to application name
	else
		nameRoot := logdir &amp; global.cnEcGetFileSeparator() &amp; name;
	endif;

	if spec = Rollover_Mode_Daily then
		rolloverMode := Rollover_Mode_Daily;
		currentDate := today;
  		self.fileName := nameRoot &amp; today.format("ddMMyyyy") &amp; '.log';
        msg := 'Daily';
	else
		rolloverMode := Rollover_Mode_Length_Exceeded;
		maxLength := spec;
		fileName := nameRoot &amp; '.log';
        msg := '&gt; maxLength';
	endif;

	msg := 'Initialised log ' &amp; fileName &amp; '. rollover mode: ' &amp; msg;
	self.out(msg, true);
end;</source>
        <Parameter name="event" type="Integer"/>
        <Parameter name="name" type="String"/>
        <Parameter name="spec" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="out" id="de437370-e2a2-4791-b63f-2a163c01f478">
        <updating/>
        <source>out(msg:String; newLine:Boolean) updating;

vars
	currDate	: Date;
 	currTime 	: Time;
	outString	: String;
	timeString	: String;

begin
	on FileException do cnEcFileExceptionHandler(exception);

	if not self.isOpen() then
		self.kind := File.Kind_Unknown_Text; // 26/2/16  cnwns1 PAR 36286 unicode version
		self.mode := File.Mode_Append;
		self.allowReplace := true;
		self.shareMode :=File.Share_ReadWrite;
		self.open;
	endif; 

	// need to check here for the logfile being too big
	// or it's the next day, and rollover if required 

	self.checkForRollover();

	if newLine then	// prepend a new line and timestamp
		outString := CrLf &amp; currDate.format("ddMMMyy") &amp; " " &amp; currTime.format("HH:mm:ss") &amp; ' '; // &amp; app.name;
	endif;

	// append the message
	outString := outString &amp; ' ' &amp; msg;

	// now output to the log file
	self.writeString(outString);
end;</source>
        <Parameter name="msg" type="String"/>
        <Parameter name="newLine" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="userNotification" id="fc3dfe3a-e30f-485d-b502-302a60eebf29">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;

begin
	out(userInfo.String, true);
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</Class>
