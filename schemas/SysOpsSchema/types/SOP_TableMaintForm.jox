    <JadeMethod name="lstPackGroup_lostFocus" id="1c6fcffd-54b6-41b7-aa5a-821ea50b09ed">
        <controlMethod name="Table::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstPackGroup_lostFocus(table: CMUI_ListTable input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 11/06/2015	cnwdap1		Initial creation PAR #36421 Hazardous Materials Handling
//
vars
	theRow			: Integer;
	str				: String;
	tbl				: CM_EntryTable;
	lstTbl			: CMUI_ListTable;
	row 			: Integer;
begin
	tbl := self.tblInput1;
	lstTbl := table;
	
	theRow := tbl.getRowByControlName(lstTbl.name);

	if (theRow &gt; tbl.fixedRows) and (theRow &lt;= tbl.rows) then
		tbl.accessRow(theRow).height := self.saveRowHeight.Integer;
		lstTbl.height := saveRowHeight.Integer; 
		self.saveRowHeight := 0;		// set to 0 so that can use in tbl.cellInputReady;
		tbl.scrollBars := Table.ScrollBars_Both;
		
		foreach row in 1 to lstTbl.rows do
			if lstTbl.accessCell(row, 1).text = "1" then
				if str = null then
					str := lstTbl.accessCell(row, 3).text;
				else
					str := str &amp; Comma &amp; Space &amp; lstTbl.accessCell(row, 3).text;
				endif;
			endif;
		endforeach;
		tbl.setValue(theRow, str);
		
	endif;
	self.tblInput1.adjustHeight(200);
epilog

end;</source>
        <Parameter name="table" type="CMUI_ListTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstSecClasses_displayRow" id="586fe0b1-0b83-466a-8a27-ea9a5e61f36d">
        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstSecClasses_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 12/06/2015	cnwdap1		Initial creation PAR #36421 Hazardous Materials Handling
//
vars
	selected			: Boolean;
	
begin
	selected := table.CMUI_ListTable.allSelectedObjects.includes(obj);
	if selected then
		return TableCheckBox_Selected &amp; Tab &amp; obj.CM_HazardClass.code &amp; Space &amp; obj.CM_HazardClass.description;
	else
		return TableCheckBox_NotSelected &amp; Tab &amp; obj.CM_HazardClass.code &amp; Space &amp; obj.CM_HazardClass.description;
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="lstSecClasses_lostFocus" id="ae5ffa97-d742-427b-b18f-1d8e2e5e93b9">
        <controlMethod name="Table::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstSecClasses_lostFocus(table: Table input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 12/06/2015	cnwdap1		Initial creation PAR #36421 Hazardous Materials Handling
//
vars
	
begin
	self.myAssistant.listTableLostFocus(self.tblInput1, self.saveRowHeight, self.lstSecClasses, 'code', false);
	self.tblInput1.adjustHeight(200);
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
