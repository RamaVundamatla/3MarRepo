    <JadeMethod name="comboBoxFaultType" id="5cacbfe6-694b-4990-9758-f5c72a22f7e7">
        <source>comboBoxFaultType(_cmb : CMUI_ComboBox input;_faultType : CM_FaultType; _addNullEntry : Boolean);
/*

Purpose:			


Return Value:		


Date		Who		Reason
05 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	indx,fndIndx,cnt : Integer;
	found : Boolean;
	extrEntry : String;
	faulType :CM_FaultType;
begin
	_cmb.clear;
	if _addNullEntry then
		extrEntry:='            ';
	else
		extrEntry:=null;
	endif;
	//epr par 15173 5/11/07 don't use display collection the find object only gets those displayed in the drop down part of the combobox
	fndIndx:=-1;
	if extrEntry &lt;&gt; null then
		_cmb.addItem(extrEntry);
	endif;
	foreach faulType in app.myRoot.allFaultTypes do
		indx:=_cmb.addItem(self.displayEntryFaultType(faulType));
		_cmb.itemObject[indx]:=faulType;
		if faulType = _faultType then
			fndIndx:=indx;
		endif;
	endforeach;
		
	if fndIndx &lt;&gt; -1 then
		_cmb.listIndex:=fndIndx;
	endif;
	
		

epilog

end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_faultType" type="CM_FaultType"/>
        <Parameter name="_addNullEntry" type="Boolean"/>
    </JadeMethod>
