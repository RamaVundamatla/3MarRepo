    <JadeMethod name="yaIterateControllerRange" id="3b275ef7-da9e-44b2-a261-a7bf25ba8a3b">
        <source>yaIterateControllerRange(	pIteratorObj:Iterator input;
							pFromId: String;
							pToId: String;
							pAllControllersObj: CM_LCArray input) protected;
// --------------------------------------------------------------------------------
// Created:		14 April 2005 by cnwdad1:2
//
// Purpose:		Iterates a collection of Location Controllers, and populates another
//				collection (parameter) with those who's identity key is within the
//				specified From/To range (inclusive).
//				
//
// Parameters:	pIteratorObj - A reference to the Iterator.  This must already have
//					been instantiated for an existing collection.
//				pFromId - The starting ID for the range of Location Controllers.
//				pToId - The ending ID for the range of Location Controllers.
//				pAllControllersObj - A reference to the collection to populate with
//					the Location Controllers found to be within the range.
//
// Returns:		The populated collection of Location Controllers.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	controllerObj	: CM_LocationsController;
	locationId		: String;
	
begin
	while pIteratorObj.next(controllerObj) do
		if controllerObj.yaHasSubBlockStack()
		or not CM_YardController.hasInstance(controllerObj)
		then
			continue;
		endif;
		
		locationId	:=	controllerObj.ident;
		
		if locationId = pFromId then
			// This is the first LC within the range.
			pAllControllersObj.add(controllerObj);
		else
			if pToId = null then
				break;
			else
				if locationId &gt; pToId then
					break;		// We've gone past the end of the range.
				endif;
				
				pAllControllersObj.add(controllerObj);
			endif;
		endif;
	endwhile;
end;</source>
        <access>protected</access>
        <Parameter name="pIteratorObj" type="Iterator" usage="input"/>
        <Parameter name="pFromId" type="String"/>
        <Parameter name="pToId" type="String"/>
        <Parameter name="pAllControllersObj" type="CM_LCArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="yaUpdateBlock" id="9443a67c-e442-411f-9d4e-d9dcd7f7788b">
        <source>yaUpdateBlock(pBlockObj:CM_YABlock input) protected;
// --------------------------------------------------------------------------------
// Created:		21 April 2005 by cnwdad1:2
//
// Purpose:		Updates the details of a YA Block with the necessary details from
//				the receiver.  This will be reimplemented on sub-classes as required
//				if there are other properties that need to be updated.
//
// Parameters:	pBlockObj - A reference to the receiver's YA Block object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// There's nothing to set at this level (beyond the "setProxy" which is done
	// when the YA Block object is instantiated).
end;</source>
        <access>protected</access>
        <Parameter name="pBlockObj" type="CM_YABlock" usage="input"/>
    </JadeMethod>
</Class>
