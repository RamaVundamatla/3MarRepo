				if transCount = 1 then
					if invCount = 1 then
						self.assertEqualMsg(invLine.quantity, 4.Real, "Cargo 2 tr 1 inv 1 quantity");
						self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeStore1", "Cargo 2 tr 1 inv 1 ILD");
					endif;
