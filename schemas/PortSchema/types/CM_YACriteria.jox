end;</source>
        <Parameter name="pYardAllocationObj" type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="42d5af89-9d93-4459-918d-5cb50c885725">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;

vars

begin
	if _property.name = CM_YACriteria::myYardAllocation.name then
		return false;
	endif;
	return inheritMethod(_rootClass, _property);
end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="xHandler" id="356d0b74-1a79-45dd-bb93-e2642a9d03a9">
        <source>xHandler(_ex : Exception; _wantError : Boolean) : Integer;

// Created by cnwdvb1 on 02 July 2007

vars

	theType,
	theAllocation: String;

begin

	// We have an invalid object.
	if _ex.errorCode = 4 then
		if _wantError then
			if self.myYACriteriaType &lt;&gt; null then
				theType := self.myYACriteriaType.description;
			endif;
			
			if self.myYardAllocation &lt;&gt; null then
				theAllocation := self.myYardAllocation.code;
			endif;
			
			app.raiseCMWarning2(Data_from_crite_type_been_dele, theType, theAllocation, null, null, self);
		endif;
		return Ex_Resume_Next;
	endif;
	
	return Ex_Pass_Back;
	

end;</source>
        <Parameter name="_ex" type="Exception"/>
        <Parameter name="_wantError" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
