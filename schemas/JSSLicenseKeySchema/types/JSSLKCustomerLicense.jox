    <JadeMethod name="getTableDisplay" id="a034502c-ff50-4e02-9cb1-177aee5c1f13">
        <source>getTableDisplay():String;
// --------------------------------------------------------------------------------
// Created:		26 March 2003 by cnwdad2
//
// Purpose:		Returns a tab-delimited display string for displaying the license
//				details in a GUI table control.
//
// Parameters:	None
//
// Returns:		The display string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	displayValue	: String;
	
begin
	displayValue	:=	self.customerName &amp; Tab &amp; self.productCode &amp; Tab;
	
	if self.expiryDate = null then
		displayValue	:=	displayValue &amp; "&lt;never&gt;";
	elseif self.expiryDate.isValid then
		displayValue	:=	displayValue &amp; self.expiryDate.shortFormat();
	else
		displayValue	:=	displayValue &amp; "&lt;*****&gt;";
	endif;
	
	return displayValue;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isBit" id="a06a2fa1-ecd6-4016-b61f-18b8088ae5ff">
        <source>isBit(pComponentId:Integer):Boolean;
// --------------------------------------------------------------------------------
// Created:		16 January 2003 by cnwdad1
//
// Purpose:		Returns a flag to indicate whether a bit in the receiver is on.
//
// Parameters:	pComponentId - The identifier of the product component to access.
//
// Returns:		True if the bit is set, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 03/04/2003	cnwdad1		Added
// --------------------------------------------------------------------------------
vars
	maximumIndex	: Integer;
	byteIndex		: Integer;
	byteValue		: Integer;
	bitPointer		: Integer;
	
begin
	maximumIndex	:=	(self.bitMask.length() * 8);
	
	if pComponentId &lt;= 0 or pComponentId &gt; maximumIndex then
		return false;
	endif;
	
	byteIndex	:=	((pComponentId - 1) div 8) + 1;
	byteValue	:=	self.bitMask[byteIndex];
	bitPointer	:=	(pComponentId mod 8);
	
	if bitPointer = 1 then			// Right-most bit.
		return byteValue.bitAnd(1) &lt;&gt; 0;
	elseif bitPointer = 2 then
		return byteValue.bitAnd(2) &lt;&gt; 0;
	elseif bitPointer = 3 then
		return byteValue.bitAnd(4) &lt;&gt; 0;
	elseif bitPointer = 4 then
		return byteValue.bitAnd(8) &lt;&gt; 0;
	elseif bitPointer = 5 then
		return byteValue.bitAnd(16) &lt;&gt; 0;
	elseif bitPointer = 6 then
		return byteValue.bitAnd(32) &lt;&gt; 0;
	elseif bitPointer = 7 then
		return byteValue.bitAnd(64) &lt;&gt; 0;
	elseif bitPointer = 0 then		// Left-most bit.
		return byteValue.bitAnd(128) &lt;&gt; 0;
	endif;
	
	return false;
end;</source>
        <Parameter name="pComponentId" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDateArray" id="6ad5dc32-3473-4b3e-96e6-32fdfdc5c5ef">
        <updating/>
        <source>setDateArray( _dateStr : String ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2020	jlgndl1	Initial creation	TFS 49569

*/

vars

	indexStr : Integer;
	segment : String;
	indexArrayInt : Integer;
	dateStr : String;
	date : Date;
	
begin

	if self.allExpiries = null then
		create self.allExpiries;
	endif;
	self.allExpiries.clear();

	indexStr := 1;
	while true do
		if indexStr &gt; _dateStr.length then
			break;
		endif;
		segment := _dateStr[indexStr:11];	//05 Aug 2020	NDL		TFS 49869
		indexStr := indexStr + 11;
		indexArrayInt := segment[1:3].Integer;
		dateStr := segment[4:8];
		date.setDate( dateStr[1:2].Integer, dateStr[3:2].Integer, dateStr[5:4].Integer );
		if date.isValid then
			self.allExpiries.atPut( indexArrayInt, date );
		endif;
	endwhile;

epilog

end;</source>
        <Parameter name="_dateStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="edeb1636-80f5-48c4-ab50-c23366be7249">
        <updating/>
        <source>updateMe(	pTheServiceManager:JSSLKServiceManager input;
			pCustomerName:String;
			pProductCode:String;
			pLicenseKey:String;
			pTheRoot:JSSLKRoot) updating;
// --------------------------------------------------------------------------------
// Created:		17 January 2003 by cnwdad1
//
// Purpose:		Updates the receiver's properties.
//
// Parameters:	pTheServiceManager - A reference to the Service Manager object.
//				pCustomerName - The name of the Customer.
//				pProductCode - A unique code identifying the product being licensed.
//				pLicenseKey - The Customer's Product license key.
//				pTheRoot - The root data object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theKey	: JSSLKey;
	
begin
	if self.registrationKey = pLicenseKey then
		return;
	endif;
	
	create theKey transient;
	theKey.setServiceManager(pTheServiceManager);
	
	if pProductCode = "SUBS" then	//19 Jun 2020	NDL	TFS 49569
		if not theKey.decomposeSubs(pCustomerName, pLicenseKey) then
			return;
		endif;
	// ### JIRA 33541 12DEC2024 NAVAB1
	elseif pProductCode = "EWS" then
		if not theKey.decomposeEWS(pCustomerName, pLicenseKey) then
			return;
		endif;
	else
		if not theKey.decompose(pCustomerName, pLicenseKey) then
			return;
		endif;
	endif;
	
//	if theKey.decompose(pCustomerName, pLicenseKey) then
		self.bitMask			:=	theKey.data2;
		self.registrationKey	:=	pLicenseKey;
		self.expiryDate			:=	theKey.data3.Date;
		
		//self.setDateArray( theKey.data5.String );	//19 Jun 2020	NDL	TFS 49569
		self.setDateArray( theKey.data5.ansiToString() );	// 09/05/2022 navmd1 TFS 53592 - The license string is always in ANSI, so we need to take that into account in Unicode environments
		
		// Update the key property.
		
		if self.customerName &lt;&gt; pCustomerName then
			self.customerName	:=	pCustomerName;
		endif;
		
		if self.productCode &lt;&gt; pProductCode then
			self.productCode	:=	pProductCode;
		endif;
		
		// Update any inverse references.
		
		if self.myRoot &lt;&gt; pTheRoot then
			self.myRoot			:=	pTheRoot;
		endif;
//	endif;
epilog
	delete theKey;
end;</source>
        <Parameter name="pTheServiceManager" type="JSSLKServiceManager" usage="input"/>
        <Parameter name="pCustomerName" type="String"/>
        <Parameter name="pProductCode" type="String"/>
        <Parameter name="pLicenseKey" type="String"/>
        <Parameter name="pTheRoot" type="JSSLKRoot"/>
    </JadeMethod>
</Class>
