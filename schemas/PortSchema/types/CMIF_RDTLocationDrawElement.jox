        <Parameter name="_flipH" type="Boolean"/>
        <Parameter name="_flipV" type="Boolean"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawCargoCount" id="a6b7c195-1446-4a10-be9c-3e3e6096384c">
        <source>drawCargoCount(_x1: Real; _y1: Real; _x2: Real; _y2: Real; _frame: Frame input; _scaleFactor: Real; _isLandscape: Boolean; _flipH: Boolean; _flipV: Boolean; _mode : Integer) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 March 2013	cnwndl1	Initial creation

*/


/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 March 2013	cnwndl1	Initial creation	Par 31278

*/

vars
	x1, y1,
	x2, y2			: Real;
	count : Integer;
	oldFontSize : Real;
	
begin

	if not self.showCargoCount then
		return;
	endif;

	x1 := _x1;
	y1 := _y1;
	x2 := _x2;
	y2 := _y2;

	self.gridPointsToElementPoints(x1, y1, x2, y2, _scaleFactor, _isLandscape, _flipH, _flipV);

	count := self.myLocationsController.allTrackedItems.size;
	
	oldFontSize := _frame.drawFontSize;	
	if _scaleFactor &gt;= 1 and _scaleFactor &lt;= 3 then
		_frame.drawFontSize := 10 * _scaleFactor;
	elseif _scaleFactor &gt;= 1 then
		_frame.drawFontSize := 8 * _scaleFactor;	
	endif;

	_frame.drawTextAt(count.String, x1 + (_scaleFactor * 2), y1, White);
	
	_frame.drawFontSize := oldFontSize;
	

epilog

end;</source>
