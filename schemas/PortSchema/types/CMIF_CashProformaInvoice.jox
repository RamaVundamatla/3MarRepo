    <JadeMethod name="setBaseDetails" id="358d848d-b8f9-4e25-97c9-e84d8bd4c769">
        <updating/>
        <source>setBaseDetails(_cashProforma: CM_CashPayment; cmifSumm: CMIF_CashTrxSummary) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	numRows : Integer;
	type : String;
	amount : String;

begin

	inheritMethod(_cashProforma, cmifSumm);
	
	if _cashProforma.myTrackedItem &lt;&gt; null then
		self.cargoId :=  _cashProforma.myTrackedItem.id;
	endif;
	if _cashProforma.myCarrier &lt;&gt; null then
		self.carrier :=  _cashProforma.myCarrier.description;
	endif;
	if _cashProforma.myDriver &lt;&gt; null then
		self.driver :=  _cashProforma.myDriver.name;
	endif;
	
	_cashProforma.expandedRows(	numRows, type, amount );
	self.proformaDesc := type;
	
	if _cashProforma.myUser &lt;&gt; null then
		user := _cashProforma.myUser.code[1:30];
	endif;

epilog

end;</source>
        <Parameter name="_cashProforma" type="CM_CashPayment"/>
        <Parameter name="cmifSumm" type="CMIF_CashTrxSummary"/>
    </JadeMethod>
</Class>
