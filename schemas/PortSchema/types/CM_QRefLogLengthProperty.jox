    <JadeMethod name="setComboValues" id="2c58d934-49dd-46e6-88b8-d70eb4e99ac8">
        <source>setComboValues(_combo : ComboBox input; _params : CM_QueryCriteriaLineHolder; _queryOperator : CM_QueryOperator; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     18 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	crit				: CM_SelectorCriteriaLine;
	gradeCode			: CM_LogGrade;
	logLength			: CM_LogLength;
	codes : CM_CodeSet;
	code : CM_Code;
begin

	_combo.clear;
	
	if _params = null then
		return;
	endif;

	crit := _params.allCriteriaByPropertyName['myLogGrade', CM_BOL.name/*CM_Log.name*/];	// Par16731. cnwvu1 15 May 2008
	if crit = null then		
		crit := _params.allCriteriaByPropertyName['myLogGrade', CM_Log.name];	// TFS 7821
		if crit = null then		
			_combo.addItem('Must select a log grade');
			return;
		endif;
	endif;
	
	codes := self.getGradesList(crit); // TFS 7821
	
	
	foreach code in codes do // TFS 7821
		gradeCode := code.CM_LogGrade; // TFS 7821
		foreach logLength in gradeCode.allLogLengths do // TFS 7821
			if _combo.findObject(logLength) &lt;= 0 then // TFS 7821
				_combo.itemObject[_combo.addItem(logLength.code &amp; '   ' &amp; logLength.description)] := logLength;
			endif;
		endforeach;
	endforeach;
	
	if CM_QReferenceLookup.hasInstance(_queryOperator) then
		logLength := _queryOperator.CM_QReferenceLookup.mySelectionValue.CM_LogLength;
		if logLength &lt;&gt; null then
			if _combo.findObject(logLength) &gt; 0 then // TFS 7821
				_combo.listObject := logLength;
			endif;
		endif;
	endif;
	
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="e14b1299-cb22-42d8-b6cd-a307903c7bc4">
        <source>setListValues(_tbl : Table input; _params : CM_QueryCriteriaLineHolder; _operator : CM_QReferenceIsOneOf; _passport : CM_Passport);
/*
Purpose:		TFS 7821	
Date				Who			Reason
NOVEMBER 2017		CNWAB1		Initial creation
*/

vars
	
	
	
	crit				: CM_SelectorCriteriaLine;
	gradeCode			: CM_LogGrade;
	logLength			: CM_LogLength;
	selectionValue, idx : Integer;
	codes : CM_CodeSet;
	code : CM_Code;
begin
	_tbl.clear;
	_tbl.rows := _tbl.fixedRows;
	_tbl.sortColumn[1] := 2;
	
	if _params = null then
		return;
	endif;

	crit := _params.allCriteriaByPropertyName['myLogGrade', CM_BOL.name/*CM_Log.name*/];	// Par16731. cnwvu1 15 May 2008
	if crit = null then		
		crit := _params.allCriteriaByPropertyName['myLogGrade', CM_Log.name];	// TFS 7821
		if crit = null then		
			_tbl.addItem('Must select a log grade');
			return;
		endif;
	endif;

	codes := self.getGradesList(crit); // TFS 7821
	
	
	foreach code in codes do // TFS 7821
		gradeCode := code.CM_LogGrade; // TFS 7821
		foreach logLength in gradeCode.allLogLengths do // TFS 7821
			if _tbl.cnEcFindObjectRow(logLength) = null then // TFS 7821
				selectionValue := 0;
				if _operator &lt;&gt; null and _operator.allSelectionValues.includes(logLength) then
					selectionValue := 1;
				endif;
				idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; logLength.code &amp; '   ' &amp; logLength.description);
				_tbl.accessRow(idx).itemObject := logLength;
				_tbl.row := idx;
				_tbl.change(_tbl);
			endif;
		endforeach;
	endforeach;


epilog
	
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QReferenceIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="translateStringToSearchValue" id="f1558e46-dcc3-492e-ab68-e72ed72cfbc4">
        <source>translateStringToSearchValue( _value: Any; _criteriaLine : CM_SelectorCriteriaLine ): Any;
// ----------------------------------------------------------------------
// Created 13 May 2008 by cnwvu1
//
// Purpose:	Gets value as String from RT screen and returns value
//			 into criteriaLineLine for running a query
// ----------------------------------------------------------------------

vars
	logLength	: CM_LogLength;
	gradeCode	: CM_LogGrade;
	critHolder	: CM_QueryCriteriaLineHolder;
	critLine	: CM_SelectorCriteriaLine;
	dict		: CM_LogLengthsByCode;
	tmpValue	: String;
	
begin

	if _value.isKindOf( CM_LogLength ) then
		return _value;
	endif;

	tmpValue := _value.String.toUpper();
	
	critHolder	:= _criteriaLine.myCriteriaLineHolder;
	critLine	:= critHolder.allCriteriaByPropertyName['myLogGrade', CM_BOL.name];

	gradeCode := critLine.myQueryOperator.getSearchValue().CM_LogGrade;
	dict	:= gradeCode.allLogLengths;
	
	foreach logLength in dict discreteLock do
		if logLength.code.toUpper() = tmpValue then
			return logLength;
		endif;
	endforeach;

	// when not found. Par 17092	cnwvu1, June 2008
	inheritMethod( _value, _criteriaLine );

end;
</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="744e9baa-8fec-4217-8877-fa3a7a1ce853">
        <source>translateToDisplayValue(_value: Any): String;
// ---------------------------------------------------------------------------
// Created:     19 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
22 Oct 2008	cnwkpd1	PAR #18099 - Handle null objects in selector queries

*/

vars

begin
	if _value &lt;&gt; null then
		return _value.CM_LogLength.code;
	endif;
	
	return null;


end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="13d911ea-fc8e-4a77-8562-1f10f4c9bd84">
        <source>translateToSearchValue(_value: Any): Any;
// ---------------------------------------------------------------------------
// Created:     19 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
06 Oct 2008	cnwkpd1	PAR #18099 - Correct Selector query processing
22 Oct 2008	cnwkpd1	PAR #18348 - Prevent 1002 exceptions in Selector query processing with isOneOf

*/

vars
	returnVal		: CM_LogLength;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			// PAR #18348
			return _value;
		endif;
		
		if _value.isKindOf(CM_LogLength) then
			returnVal := _value.CM_LogLength;
		endif;
	endif;
	
	return returnVal;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
