    <JadeMethod name="populateCombos" id="a2e3702e-03bf-4ed5-affd-e4c98230222c">
        <source>populateCombos();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 December 2009	cnwndl1	Initial creation

*/

vars
	tmpUT : CM_UserTerminal;
	term : CM_Terminal;
	newIndex : Integer;
	format_SS : CM_OutputFormat;
begin

	cmbTerminal.clear();
	foreach tmpUT in app.myPassport.myUser.allUserTerminals do
		term := tmpUT.getMyTerminal;
		if cmbTerminal.findObject(term) &lt; 1 then
			newIndex := cmbTerminal.addItem(term.name);
			cmbTerminal.itemObject[newIndex] := term;
		endif;
	endforeach;
	
	cmbTerminal.listIndex := cmbTerminal.findObject(self.myTerminal);
	cmbTerminal.enabled := false;	// not going to allow users to change this at present....

	cmbDefinition.clear();
	foreach format_SS in app.myRoot.allOutputFormats_SS do
		newIndex := cmbDefinition.addItem(format_SS.name);
		cmbDefinition.itemObject[newIndex] := format_SS;
	endforeach;

	if self.myDefinition &lt;&gt; null then
		cmbDefinition.listIndex := cmbDefinition.findObject(self.myDefinition);
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateSnapshotCollection" id="bcf18207-61d1-4c48-9e74-f16c7439c4e4">
        <source>populateSnapshotCollection(_coll :Collection input)protected;
// ---------------------------------------------------------------------------
// Created:     14 December 2009 by cnwcs5
// Purpose:     CCMS 1028 - summary mappings
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	obj	:Object;
begin
	foreach obj in self.tblData.allSelectedObjects do
		obj.CM_SnapshotData.allSnapshotData.copy (_coll);
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_coll" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMaintButtons" id="23ac8b00-87ce-4375-b020-ce962ab48b32">
        <source>setMaintButtons();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 December 2009	cnwndl1	Initial creation

*/

vars

	edition : Integer;
	invalidObject : Boolean;

begin

	//03 Jun 2016	NDL	TFS 2100
	on Exception do app.handleDeletedObject( exception, self.myDefinition, invalidObject );
	if self.myDefinition &lt;&gt; null then
		edition := self.myDefinition.edition;
	endif;

	if self.myDefinition = null or invalidObject then
		self.btnDeleteDef.enabled := false;
		self.btnEditDef.enabled := false;
		self.btnNewDef.enabled := true;
		self.setNavigatorHeading( app.getErrorString(Snap_shot_summary) );
		self.btnCreateData.enabled := false;
		self.btnNewData.enabled := false;
	else
		self.btnDeleteDef.enabled := true;
		self.btnEditDef.enabled := true;
		self.btnNewDef.enabled := true;
		self.setNavigatorHeading( self.myDefinition.name );
		self.btnCreateData.enabled := ( self.myDefinition.myBankToCharge &lt;&gt; null );
		self.btnNewData.enabled := true; 	// ( self.myDefinition = self.myTerminal.getConfig(SnapshotSummOnsiteCargo).CM_OutputFormat_SS); - allow this for all (from AB)??
	endif;
	
	// TFS 2101 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then // TFS 2734
		self.btnDeleteDef.enabled := false;
		self.btnEditDef.enabled := false;
		self.btnNewDef.enabled := false;
		self.btnCreateData.enabled := false;
		self.btnNewData.enabled := false;
		self.mnuCharge.enabled := false;
		self.mnuResync.enabled := false;
		self.mnuDelSnapShot.enabled := false;
	endif;
	
epilog

end;</source>
    </JadeMethod>
