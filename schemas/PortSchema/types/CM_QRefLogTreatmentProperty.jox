<Class name="CM_QRefLogTreatmentProperty" id="32313011-569c-4802-b3a0-1bfde6545907">
    <superclass name="CM_QReferenceLookupProperty"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="e1e508e8-e5ea-4f76-8635-82730e1922da">
        <updating/>
        <source>create() updating;
// -------------------------------------------
// Created 16 September 2004 by cnwdvb1
// -------------------------------------------
vars

	oper : CM_QueryOperator;

begin

	if self.isTransient then 
		return;
	endif;

	create oper as CM_QReferenceIsOneOf persistent;
	self.allAllowedOperators.add(oper);

end;</source>
    </JadeMethod>
    <JadeMethod name="getControlNameForOperator" id="58d6993c-3c2d-4663-a5e1-eb30b096d26e">
        <source>getControlNameForOperator(_operator: CM_QueryOperator): String;
// ---------------------------------------------------------------------------
// Created:     16 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if CM_QReferenceLookup.hasInstance(_operator) then
		return 'cmbLogTreatement';
	endif;


end;</source>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setComboValues" id="e4b4bfa1-1665-4b52-8478-8cafe04d9df3">
        <source>setComboValues(_combo : ComboBox input; _params : CM_QueryCriteriaLineHolder; _queryOperator : CM_QueryOperator; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     18 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	crit				: CM_SelectorCriteriaLine;
	gradeCode			: CM_LogGrade;
	logTreat			: CM_LogTreatment;
	codes : CM_CodeSet;
	code : CM_Code;
begin

	_combo.clear;
	
	if _params = null then
		return;
	endif;

	crit := _params.allCriteriaByPropertyName['myLogGrade', CM_BOL.name/*CM_Log.name*/];	// Par16731. cnwvu1 15 May 2008
	if crit = null then		
		crit := _params.allCriteriaByPropertyName['myLogGrade', CM_Log.name];	// TFS 7821
		if crit = null then		
			_combo.addItem('Must select a log grade');
			return;
		endif;
	endif;
	codes := self.getGradesList(crit); // TFS 7821
	
	
	foreach code in codes do // TFS 7821
		gradeCode := code.CM_LogGrade; // TFS 7821
		foreach logTreat in gradeCode.allLogTreatments do // TFS 7821
			if _combo.findObject(logTreat) &lt;= 0 then // TFS 7821
				_combo.itemObject[_combo.addItem(logTreat.code &amp; '   ' &amp; logTreat.description)] := logTreat;
			endif;
		endforeach;
	endforeach;
	
	if CM_QReferenceLookup.hasInstance(_queryOperator) then
		logTreat := _queryOperator.CM_QReferenceLookup.mySelectionValue.CM_LogTreatment;
		if logTreat &lt;&gt; null then
			if _combo.findObject(logTreat) &gt; 0 then // TFS 7821
				_combo.listObject := logTreat;
			endif;
		endif;
	endif;
	
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="1329b347-1ec4-4200-a989-88cc813528c7">
        <source>setListValues(_tbl : Table input; _params : CM_QueryCriteriaLineHolder; _operator : CM_QReferenceIsOneOf; _passport : CM_Passport);
/*
Purpose:		TFS 7821	
Date				Who			Reason
NOVEMBER 2017		CNWAB1		Initial creation
*/

vars
	code		: CM_Code;	
	gradeCode : CM_LogGrade;
	logTreat			: CM_LogTreatment;
	crit				: CM_SelectorCriteriaLine;
	selectionValue, idx : Integer;
	codes : CM_CodeSet;
begin
	_tbl.clear;
	_tbl.rows := _tbl.fixedRows;
	_tbl.sortColumn[1] := 2;
	
	if _params = null then
		return;
	endif;

	crit := _params.allCriteriaByPropertyName['myLogGrade', CM_BOL.name/*CM_Log.name*/];	// Par16731. cnwvu1 15 May 2008
	if crit = null then		
		crit := _params.allCriteriaByPropertyName['myLogGrade', CM_Log.name];	// TFS 7821
		if crit = null then		
			_tbl.addItem("" &amp; Tab &amp; 'Must select a log grade');
			return;
		endif;
	endif;
	

	codes := self.getGradesList(crit); // TFS 7821
	
	
	foreach code in codes do // TFS 7821
		gradeCode := code.CM_LogGrade; // TFS 7821
		foreach logTreat in gradeCode.allLogTreatments do // TFS 7821
			if _tbl.cnEcFindObjectRow(logTreat) = null then // TFS 7821
				selectionValue := 0;
				if _operator &lt;&gt; null and _operator.allSelectionValues.includes(logTreat) then
					selectionValue := 1;
				endif;
				idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; logTreat.code &amp; '   ' &amp; logTreat.description);
				_tbl.accessRow(idx).itemObject := logTreat;
				_tbl.row := idx;
				_tbl.change(_tbl);
			endif;
		endforeach;
	endforeach;


epilog
	
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QReferenceIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="translateStringToSearchValue" id="e715bd5c-b958-4efb-ad9f-460be0f75859">
        <source>translateStringToSearchValue( _value: Any; _criteriaLine : CM_SelectorCriteriaLine ): Any;
// ----------------------------------------------------------------------
// Created 13 May 2008 by cnwvu1
//
// Purpose:	Gets value as String from RT screen and returns value
//			 into criteriaLineLine for running a query
// ----------------------------------------------------------------------

vars
	logTreat	: CM_LogTreatment;
	gradeCode	: CM_LogGrade;
	critHolder	: CM_QueryCriteriaLineHolder;
	critLine	: CM_SelectorCriteriaLine;
	dict		: CM_LogTreatmentsByCodeDict;
	tmpValue	: String;
	
begin

	if _value.isKindOf( CM_LogTreatment ) then
		return _value;
	endif;

	tmpValue 	:= _value.String.toUpper();
	
	critHolder	:= _criteriaLine.myCriteriaLineHolder;
	critLine	:= critHolder.allCriteriaByPropertyName['myLogGrade', CM_BOL.name];

	gradeCode	:= critLine.myQueryOperator.getSearchValue().CM_LogGrade;
	dict		:= gradeCode.allLogTreatments;
	
	foreach logTreat in dict discreteLock do
		if logTreat.code.toUpper() = tmpValue then
			return logTreat;
		endif;
	endforeach;

	// when not found. Par 17092	cnwvu1, June 2008
	inheritMethod( _value, _criteriaLine );

end;
</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="84090f61-4822-4c34-8c8f-9657835a03f8">
        <source>translateToDisplayValue(_value: Any): String;
// ---------------------------------------------------------------------------
// Created:     19 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
22 Oct 2008	cnwkpd1	PAR #18099 - Handle null objects in selector queries

*/

vars

begin
	if _value &lt;&gt; null then
		return _value.CM_LogTreatment.code;
	endif;
	
	return null;


end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="083b458d-9d2f-45b1-bea5-0d44757e42bb">
        <source>translateToSearchValue(_value: Any): Any;
// ---------------------------------------------------------------------------
// Created:     19 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
06 Oct 2008	cnwkpd1	PAR #18099 - Correct Selector query processing
22 Oct 2008	cnwkpd1	PAR #18348 - Prevent 1002 exceptions in Selector query processing with isOneOf

*/

vars
	returnVal		: CM_LogTreatment;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			// PAR #18348
			return _value;
		endif;

		if _value.isKindOf(CM_LogTreatment) then
			returnVal := _value.CM_LogTreatment;
		endif;
	endif;
	
	return returnVal;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
