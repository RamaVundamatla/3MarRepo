    <JadeMethod name="setForCreate" id="b2c54052-4a21-43b5-b076-bf0e6a61d487">
        <updating/>
        <source>setForCreate(_proxyDetails : SelfType) updating;
/*

Purpose:		TFS 44275	

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2019	jlgab1	Initial creation

*/

vars

begin
	self.chargeTime 	   := _proxyDetails.chargeTime;
	self.lineTotal 	       := _proxyDetails.lineTotal;
	self.myInvoiceLineType := _proxyDetails.myInvoiceLineType;
	self.myTrackedItem     := _proxyDetails.myTrackedItem;
	self.myVoyage          := _proxyDetails.myVoyage;
	self.overridden        := _proxyDetails.overridden;
	self.quantity 	       := _proxyDetails.quantity;
	self.rate 		       := _proxyDetails.rate;
	self.remarks 		   := _proxyDetails.remarks;
	self.transactionType   := _proxyDetails.transactionType;
epilog

end;</source>
        <Parameter name="_proxyDetails" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setMinChargeRate" id="959b9c1d-7414-4dd8-8cc3-4b7a950e4c32">
        <updating/>
        <source>setMinChargeRate(_pxyCashPay : CM_CashPayment)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Jan 2020	jlgma1	Bug 48298: ADP - FW: Ticket 48149 - Minimum Charge Line remove in UAT - ##336278##

*/

vars

begin
	
	if not _pxyCashPay.isMinimumCharge then
		return;
	endif;
	
	self.rate := _pxyCashPay.cashValue;
epilog

end;</source>
        <Parameter name="_pxyCashPay" type="CM_CashPayment"/>
    </JadeMethod>
    <JadeMethod name="setMyCashReceipt" id="1929dc75-a18d-43e0-82ad-82bcd38f5186">
        <updating/>
        <source>setMyCashReceipt(_cashReceipt : CM_CashReceipt) updating;
/*
Purpose:	TFS 44275		
Date				Who			Reason
MAY 2019		JLGAB1 initial creation
*/


vars

begin
	self.myCashReceipt := _cashReceipt;

	self.myCashReceipt.allProformaDetails.addNoDuplicates(self, false); // not inversed!

epilog

end;</source>
        <Parameter name="_cashReceipt" type="CM_CashReceipt"/>
    </JadeMethod>
