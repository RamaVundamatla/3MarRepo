    <JadeMethod name="utlCreatePreNote" id="f498d98e-839a-472f-9b03-125f395182ff">
        <updating/>
        <source>utlCreatePreNote(_intFaceObject : CMIF_PreNote io; _validateOnly: Boolean; _isInitialise : Boolean; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     Jan 2010 cnwrs1 par 21329
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 28/07/2010	cnwdad1		PAR #25120, added parameter for calling "initialiseActivity".
// 06/06/2017	cnwdap1		TFS 4434 SNO COPARN Prenotes and VGM Updates
// 11 Sep 2023	jlirs1	TFS 60392 EUP | FR 53824 - Transport Manifest - Cargo Group Details
// 24/07/2025	naviv1	MTN-34763 : MTN - Deferred Updates Required For Train Consist EDI
// ---------------------------------------------------------------------------
vars
	nullObject : CM_Object;
	tmpEvent : Integer;
begin
	if _isInitialise then
		self.initialiseActivity();
	endif;
	
	app.setContinueCMExceptions(true);

	// do the validation here
	//don't do validation if not deferred.
	if (_passport.useTIDictDeferUpdate &lt;&gt; true
	and _passport.useTITransactionDeferUpdate &lt;&gt; true)  //par 19057
	or _intFaceObject.myProxyTrackedItem = null		// MTN-34763
	then
		_intFaceObject.validateForCreate(_passport);		//Also does the sub items
		if _passport.allErrors.size() &gt; 100 then
			app.setContinueCMExceptions(false);  // dh 10/7/2008 par 17254 added this option for performance
		else
			app.setContinueCMExceptions(true);
		endif;
	endif;
	
	if (not self.checkValidationWithPassport(_passport))
	and (not _validateOnly)
	then
		return;
	endif;

	if _validateOnly then
		app.setContinueCMExceptions(true);
	else
		app.setContinueCMExceptions(false);
	endif;
	
	//want to keep going to get all errors at once while _validateOnly = true
	if (not _intFaceObject.actionForCreate(nullObject, _passport))
	and (not _validateOnly) 	//Also does sub items
	then
	   return;
	endif;

	if _passport.noErrors() and (not _validateOnly) then
		// TFS 4434 If we've just done a VGM update for an EDI prenote where the item 	// TFS 4434
		// is already on site, then we won't have a persistent tracked item				// TFS 4434
		if not _intFaceObject.updateVGMOnly then										// TFS 4434
			// issue notifications on created objcets
			tmpEvent := _passport.myTerminal.getTerminalEvent(TIEvent_PreNote_Add);
			_intFaceObject.myPersistentTrackedItem.causeEvent(tmpEvent, false, _intFaceObject.myPersistentTrackedItem);
		endif;																			// TFS 4434
	endif;
	
	CMIF_TrxActionCargoGroup@createAction(_intFaceObject.myPersistentTrackedItem, _intFaceObject.myPersistentTrackedItem.myCargoGroup, _passport);	 // ### TFS BUG 58853 04JUL2023 NAVAB1
	
end;</source>
        <Parameter name="_intFaceObject" type="CMIF_PreNote" usage="io"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_isInitialise" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreatePreNoteForMerge" id="9518c509-a00f-4dc6-9ee7-6d6de14929c1">
        <updating/>
        <source>utlCreatePreNoteForMerge(	_splitOffCargoOnTruck : CM_Cargo input;
							_newPrenotedTi : CM_Cargo output;
							_passport : CM_Passport input
							)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/09/2018	jlgndl1	Initial creation	TFS 39769
14/11/2018	jlgdap1	TFS 41300 PEL1 Unable to load to vessel from truck in Job Lander
*/

vars

	term : CM_Terminal;
	newPreNoteProxy : CM_TrackedItem;

begin

	term := _splitOffCargoOnTruck.myTerminal;
	

	newPreNoteProxy := _splitOffCargoOnTruck.cloneForInterTerminalPreNote( term, true );
	if newPreNoteProxy &lt;&gt; null then
		_newPrenotedTi := term.createTrackedItem( newPreNoteProxy, app.myPassport ).CM_Cargo;
		if app.myPassport.hasErrors then
			return;
		endif;
		_newPrenotedTi.setupNewPreNoteForMerge();
		_newPrenotedTi.setNewPreNoteVoyagePlanning(_splitOffCargoOnTruck);		// TFS 41300
	endif;
	
epilog

	delete newPreNoteProxy;

end;</source>
        <Parameter name="_splitOffCargoOnTruck" type="CM_Cargo" usage="input"/>
        <Parameter name="_newPrenotedTi" type="CM_Cargo" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreatePreNotes" id="f7666c0c-6af6-4ab9-8e16-1b0587991714">
        <updating/>
        <source>utlCreatePreNotes(pIntFaceArray : CMIF_TIObjectArray; _validateOnly: Boolean; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     15 February 2001 by cnwrs2
//
// Purpose:     
// 09/11/2022	navkc1		Bug 55382: MTN - Cargo Group Details recalculated after each change to TI when bulk editing
// ---------------------------------------------------------------------------
vars
	item		: CMIF_TIObject;
	nullObject	: CM_Object;
	tmpEvent	: Integer;
	todo, done	: Integer;
	ti : CM_TrackedItem;
	voy : CM_Voyage;
	cargoGroupSiteTrxAction  : CMIF_TrxActionCargoGroup; //TFS 53390
	
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);

	// deleted validation code -  must be called prior to calling the utl
	
	if (not self.checkValidationWithPassport(_passport))
	and (not _validateOnly)
	then
		return;
	endif;

	if _validateOnly then
		app.setContinueCMExceptions(true);
	else
		app.setContinueCMExceptions(false);
	endif;

	todo := pIntFaceArray.size();
	
	foreach item in pIntFaceArray do
		done := done + 1;
		
		if (_passport.myCMIFMonitor &lt;&gt; null) then
			_passport.myCMIFMonitor.updateProgress("Creating prenote", todo, done);
		endif;
			
		//want to keep going to get all errors at once while _validateOnly = true
		if (not item.actionForCreate(nullObject, _passport))
		and (not _validateOnly) 	//Also does sub items
		then
			break;
		endif;
		
		if (not _passport.noErrors()) and (not _validateOnly) then
			break;
		endif;
	endforeach;

	if _passport.noErrors() and (not _validateOnly) then
		// issue notifications on created objcets
		tmpEvent := _passport.myTerminal.getTerminalEvent(TIEvent_PreNote_Add);
		
		foreach item in pIntFaceArray do
			if item.isKindOf(CMIF_PreNote) and not item.isKindOf(CMIF_TBACargo) then
				if item.CMIF_PreNote.myPersistentTrackedItem&lt;&gt; null then // TFS 2318
					item.CMIF_PreNote.myPersistentTrackedItem.causeEvent(tmpEvent, false, item.CMIF_PreNote.myPersistentTrackedItem);
				endif;
			endif;
		endforeach;
		
		tmpEvent := _passport.myTerminal.getTerminalEvent(Event_TBA_Create); // TFS 45590
		foreach item in pIntFaceArray do // TFS 45590
			if item.isKindOf(CMIF_TBACargo) then // TFS 45590
				ti := item.CMIF_TBACargo.myPersistentTrackedItem; // TFS 45590
				if ti &lt;&gt; null then // TFS 45590
					voy := ti.myVoyage; // TFS 45590
					if voy &lt;&gt; null then // TFS 45590
						voy.causeEvent(tmpEvent, true,ti); // TFS 45590
					endif;
				endif;
			endif;
		endforeach;
	endif;
	
	//TFS 53390, AjitM, navam1
	if _passport.noErrors() then
		
		foreach item in pIntFaceArray do
			if item.isPreNote() then
				
				CMIF_TrxActionCargoGroup@createAction(item.CMIF_PreNote.myPersistentTrackedItem, null, _passport); // navkc1	09/11/2022	#55382
				
				/*	// navkc1	09/11/2022	#55382 - Moved to CMIF_TrxActionCargoGroup@createAction
				create cargoGroupSiteTrxAction transient;
				cargoGroupSiteTrxAction.setMyCargoGroup(item.CMIF_PreNote.myPersistentTrackedItem.myCargoGroup,CM_TrxControlAgent.Trx_Create);
				_passport.addTrxPostAction(cargoGroupSiteTrxAction);
				//delete cargoGroupSiteTrxAction;
				*/	// navkc1	09/11/2022	#55382
			endif;
		endforeach;
	endif;
end;</source>
        <Parameter name="pIntFaceArray" type="CMIF_TIObjectArray"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
