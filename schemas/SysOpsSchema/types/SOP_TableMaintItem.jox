    <JadeMethod name="isObjectRelevant" id="896da86e-baba-47a9-b5aa-79b5e191c2a2">
        <source>isObjectRelevant(_obj: Object):Boolean;
//-----------------------------------------------------------------------
//	Created:	30 March 2006	by Jason Chapman  (cnwjc2)
//
//	Is the object relevant for this terminal?
//-----------------------------------------------------------------------
vars
	clas		: Class;
begin

	if not self.isSystemItem then
	//need to check the terminal...
	//	app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  " You must always implement and inherit this method for non-system items.  Refer to Local Implementors.");
	else
	//yes, always relevant if the classes match
	endif;

	clas := self.myDataClass;
	
	if clas = null then
		return false;
	endif;
	
	if not clas.hasInstance(_obj) then
		return false;
	endif;

	return true;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
