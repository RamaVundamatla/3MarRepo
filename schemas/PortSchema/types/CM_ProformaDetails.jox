        <embedded/>
        <type name="CM_InvoiceLineDesc"/>
        <access>readonly</access>
        <text>The invoice line type of the original pro forma invoice line from the configured transactions.
Used in cash receipt printing and also to match this charge with the eventual actual invoice lines.
Is the VOID invoice line type for a manual entry.</text>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myTrackedItem" id="6f2d5d0a-8602-4bff-9768-50a783210cc8">
        <embedded/>
