    <JadeMethod name="setForCreate" id="058f4c38-860e-4539-9359-ef371f06bf31">
        <updating/>
        <source>setForCreate(pProxyRequest : CM_Request) updating;
// ---------------------------------------------------------------------------
// Created:     22 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/07/2009	consw1		Par 20293 - UE 1090
// ---------------------------------------------------------------------------
// 08 Feb 2019	jlgrs1	TFS 43312 - More Deadlocking in Multiuser EDI
// 30 Jun 2025  navma1  MTN-34090  MTN | Dead lock (1081) on CM_TIByIdCargoTypeRelseDictRev
vars
	term			: CM_Terminal;
begin

	pProxyRequest.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);

	self.userCode := pProxyRequest.userCode;

	self.setJob(pProxyRequest.myJob);

	self.setForUpdate(pProxyRequest);
	
	self.createWLEs();
	
	term := self.myTerminal;	
	/*
	Collections Should be locked in the right Oid Order
	30.06.2025 navma1 #MTN-34090
	*/
	self.exclusiveLock(term.allBulkReleasesByCodeDate);    //004 - CM_BulkReleaseByCodeDict
	self.exclusiveLock(term.allBulkReleasesByDelRelNo);    //021 - CM_BulkReleaseByDelRelNoDict
	self.exclusiveLock(term.allBulkReleaseByTypeByStByCd); //159 - CM_BulkReleaseByTypeStCodeDict
	
	// Par8380 create bulk release for request	
	self.createBulkReleaseFromSelf(app.myPassport);
end;</source>
        <Parameter name="pProxyRequest" type="CM_Request"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="37d5a565-f71a-4d33-b53a-8e7bc89aeb5e">
        <updating/>
        <source>setForUpdate(pProxyRequest : CM_Request) updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	pProxyRequest.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);
	
	if (not self.isTransient) then
		// setting this reference gives an error.  The reference
		// should be set later
	else
		self.bulkRelease := pProxyRequest.bulkRelease;
	endif;
	self.freightForwarderCode	:= pProxyRequest.freightForwarderCode;
	self.freightPayerCode := pProxyRequest.freightPayerCode;
	self.weightRequested	:= pProxyRequest.weightRequested;
end;</source>
        <Parameter name="pProxyRequest" type="CM_Request"/>
    </JadeMethod>
