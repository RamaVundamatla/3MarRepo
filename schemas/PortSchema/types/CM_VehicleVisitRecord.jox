        <ReturnType type="CM_VehicleVisitRecordDetail"/>
    </JadeMethod>
    <JadeMethod name="getGateRecieval" id="e75e0778-0132-4bdb-afb1-35ffca1bd786">
        <source>getGateRecieval( _id : String; _cargoType : Integer ):CMGTE_Receival;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 May 2014	cnwndl1	Initial creation	Par 34076

*/

vars
	entity : CMGTE_Entity;
	ti : CM_TrackedItem;
begin
	
	foreach entity in self.allGateEntities do
		if not entity.isKindOf( CMGTE_Receival ) then
			continue;
		endif;
		if entity.id &lt;&gt; _id then
			continue;
		endif;
		if entity.CMGTE_Receival.cargoType &lt;&gt; _cargoType then
			continue;
		endif;
		
		return entity.CMGTE_Receival;
	endforeach;
	
	return null;

epilog

end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="Integer"/>
        <ReturnType type="CMGTE_Receival"/>
    </JadeMethod>
    <JadeMethod name="getGateRecievalMatchingThis" id="d3209434-f235-400b-8977-55eb6e1ec680">
        <source>getGateRecievalMatchingThis( _entity : CMGTE_Receival ):CMGTE_Receival;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 May 2014	cnwndl1	Initial creation	Par 34076

*/

vars
	entity : CMGTE_Entity;
	ti : CM_TrackedItem;
begin
	
	foreach entity in self.allGateEntities do
		if not entity.isKindOf( CMGTE_Receival ) then
			continue;
		endif;
		if entity.id &lt;&gt; _entity.id then
			continue;
		endif;
		if entity.CMGTE_Receival.cargoType &lt;&gt; _entity.CMGTE_Receival.cargoType then
			continue;
		endif;
		
		return entity.CMGTE_Receival;
	endforeach;
	
	return null;

epilog

end;</source>
        <Parameter name="_entity" type="CMGTE_Receival"/>
        <ReturnType type="CMGTE_Receival"/>
    </JadeMethod>
    <JadeMethod name="getGateTicketContainer" id="404a24e1-2332-4414-931c-6c29e827b5b9">
        <updating/>
        <source>getGateTicketContainer() : CM_Container updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2008	conkc1	Initial creation

*/
vars
	found, trackedItem : CM_TrackedItem;

begin
	// find first container
	foreach trackedItem in self.allReceivedTrackedItems do
		if trackedItem.isKindOf(CM_Container) then
			found := trackedItem;
			break;
		endif;
	endforeach;

	// if we dont have a received container it must be released
	if found = null then
		foreach trackedItem in self.allReleasedTrackedItems do
			if trackedItem.isKindOf(CM_Container) then
				found := trackedItem;
				break;
			endif;
		endforeach;
	endif;

	return found.CM_Container;
end;</source>
        <ReturnType type="CM_Container"/>
    </JadeMethod>
    <JadeMethod name="getGateTicketContainerCool_JRW" id="5cd3d8e3-997a-4b2e-86ad-72af162977b5">
        <updating/>
        <source>getGateTicketContainerCool_JRW() : String updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2008	conkc1	Initial creation

*/

vars
	trackedItem : CM_Container;

begin
	trackedItem := self.getGateTicketContainer();
	//  Should always find one container
	if trackedItem = null then
		return 'missing container';
	endif;

