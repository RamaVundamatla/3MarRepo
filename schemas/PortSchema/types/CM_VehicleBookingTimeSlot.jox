    <JadeMethod name="isVehicleVisitOnSchedule" id="3a1a82b1-053c-4852-915e-9611393e1e4b">
        <source>isVehicleVisitOnSchedule(_realVVR : CM_VehicleVisitRecord) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Mar 2025	navlc30	Initial creation
31 Mar 2025 navlc30 JIRA 34265 TPT | FR 33661.030 VBS - One Release Request and One VBS slot ? Off Schedule

*/

vars

	arrivalTime : TimeStamp;
	graceMins : Integer;
	startPeriod : TimeStamp;
	endPeriod : TimeStamp;
	graceTSInterval : TimeStampInterval;

begin

	if _realVVR = null then
		return false;
	endif;
	
	arrivalTime := _realVVR.timeIn;
	graceTSInterval := self.getTimeslotGraceTimeInterval( graceMins );
	
	if graceMins = 0 then
		startPeriod := self.bookingTSstart;
		endPeriod := self.bookingTSend;
	else
		startPeriod := self.bookingTSstart - graceTSInterval;
		endPeriod := self.bookingTSend + graceTSInterval;
	endif;
	
	if arrivalTime &lt; startPeriod then
		return false;
	endif;
	
	if arrivalTime &gt; endPeriod then
		return false;
	endif;
	
	return true;
	
epilog

end;</source>
        <Parameter name="_realVVR" type="CM_VehicleVisitRecord"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="myTerminal" id="b141035f-4841-4ccc-b864-6a6c2233d372">
