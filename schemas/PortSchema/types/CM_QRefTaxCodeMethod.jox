    <JadeMethod name="setComboValues" id="a8b547e2-625b-440e-8ba2-20ae9c08e9a4">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);

/*

Purpose:			

Parameters:			

Return Value:		

Date		      Who		Reason
12 December 2022  navmv20   Defect 55746: MTN - New tax fields not in selectors or summaries as per BRD

*/

vars

	terminal 	: CM_Terminal;
	termCrit	: CM_SelectorCriteriaLine;
	ut			: CM_UserTerminal;
	obj			: Object;
	os			: ObjectSet;
	bank 		: CM_Bank;
	taxCode 	: CM_TaxCode;
	qrl 		: CM_QReferenceLookup;
begin
	_combo.clear();
	
	create os transient;
	// 34364 company and invoice types specific to terminal otherwise companies for terminals the user can see
	foreach termCrit in _params.allCriteriaLines do
		if termCrit.myQueryProperty.propertyName = 'myTerminal' or
		   termCrit.myQueryProperty.propertyName = 'getTerminal' then
			termCrit.myQueryOperator.getSearchValueAsObjectSet(os);
			break;
		endif;
	endforeach;
	if os.isEmpty() then
		foreach ut in app.myPassport.myUser.allUserTerminals do
			os.add(ut.getMyTerminal);
		endforeach;
	endif;

	foreach obj in os do
		terminal := obj.CM_Terminal;
		foreach bank in terminal.companies discreteLock where bank.isBusinessUnit do
			foreach taxCode in bank.allTaxCodes  do
				_combo.itemObject[_combo.addItem( self.translateToDisplayValue(taxCode).String ) ] := taxCode;
			endforeach;
		endforeach;
	endforeach;

	if CM_QReferenceLookup.hasInstance(_queryOperator) then
		qrl := _queryOperator.CM_QReferenceLookup;
		if global.isValidObject(qrl.mySelectionValue) and
		   _combo.findObject(qrl.mySelectionValue) &gt; 0 then
			_combo.listObject := qrl.mySelectionValue;
		endif;
	endif;

epilog
	delete os;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="88f675a3-f4b9-4824-a6fc-2001454c9623">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QReferenceIsOneOf; _passport: CM_Passport);

/*

Purpose:			

Parameters:			

Return Value:		

Date		      Who		Reason
12 December 2022  navmv20   Defect 55746: MTN - New tax fields not in selectors or summaries as per BRD

*/


vars

	selectionValue  : Integer;
	terminal 	    : CM_Terminal;
	bank 		    : CM_Bank;
	idx 			: Integer;
	termCrit		: CM_SelectorCriteriaLine;
	ut				: CM_UserTerminal;
	obj				: Object;
	os				: ObjectSet;
	taxCode         : CM_TaxCode;
	qrl             : CM_QReferenceLookup;
	
begin

	_tbl.clear;
	_tbl.rows := 0;
	_tbl.sortColumn[1] := 2;
	
	create os transient;
	foreach termCrit in _params.allCriteriaLines do
		if termCrit.myQueryProperty.propertyName = 'myTerminal' or
		   termCrit.myQueryProperty.propertyName = 'getTerminal' then
			termCrit.myQueryOperator.getSearchValueAsObjectSet(os);
			break;
		endif;
	endforeach;
	if os.isEmpty() then
		foreach ut in app.myPassport.myUser.allUserTerminals do
			os.add(ut.getMyTerminal);
		endforeach;
	endif;

	foreach obj in os do
		terminal := obj.CM_Terminal;
		foreach bank in terminal.companies discreteLock where bank.isBusinessUnit do
			foreach taxCode in bank.allTaxCodes do
				selectionValue := 0;
				if _operator &lt;&gt; null and _operator.allSelectionValues.includes(taxCode) then
					selectionValue := 1;
				endif;
				idx := _tbl.addItem( selectionValue.String &amp; Tab &amp; self.translateToDisplayValue(taxCode).String );
				_tbl.accessRow(idx).itemObject := taxCode;
				_tbl.row := idx;
				_tbl.change(_tbl);
			endforeach;
		endforeach;
	endforeach;
	
epilog
	delete os;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QReferenceIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="05ae57c7-c9f8-4756-bf6f-816e74ebbc6f">
        <source>translateToDisplayValue(_value: Any): String;


/*

Purpose:			

Parameters:			

Return Value:		

Date		      Who		Reason
12 December 2022  navmv20   Defect 55746: MTN - New tax fields not in selectors or summaries as per BRD

// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27/02/2023	navmk20		Bug 56090: EUP - Remedial 54831 - Invoice Line Mode Selector Query
*/

vars

	taxCode  :  CM_TaxCode;

begin
	if _value.isKindOf(CM_TaxCode) then
		if _value &lt;&gt; null then
			taxCode := _value.CM_TaxCode;
			//return taxCode.description &amp; "  [" &amp; taxCode.myBank.code &amp; "/" &amp; taxCode.myBank.terminal.code &amp; "]";	// 27.2.2023 navmk20 TFS 56090
			return taxCode.code &amp; "  [" &amp; taxCode.myBank.code &amp; "/" &amp; taxCode.myBank.terminal.code &amp; "]"; 			// 27.2.2023 navmk20 TFS 56090
		else
			return null;
		endif;
	else
		return _value.String;
	endif;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="48a91834-5c6d-4fab-b6a6-7e0aa2e44fb4">
        <source>translateToSearchValue(_value: Any): Any;

/*

Purpose:			

Parameters:			

Return Value:		

Date		      Who		Reason
12 December 2022  navmv20   Defect 55746: MTN - New tax fields not in selectors or summaries as per BRD

*/

vars

begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then	
			return _value;
		endif;
	
		if _value.isKindOf(CM_TaxCode) then
			return _value.CM_TaxCode;
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
