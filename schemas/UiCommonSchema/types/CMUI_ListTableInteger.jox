<GUIClass name="CMUI_ListTableInteger" id="f95de80b-6980-4d1a-8207-dd55decf878a">
    <superclass name="CMUI_ListTable"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <ImplicitInverseRef name="allDummyObjects" id="a09e5346-c586-4fb9-af43-58dc194e2757">
        <memberTypeInverse/>
        <type name="DynaDictionary"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <JadeMethod name="addItemInteger" id="c04a94ba-86e1-43fc-a583-936ab4320c39">
        <updating/>
        <source>addItemInteger(_int	:Integer; _str :String):Integer updating;
/*
Date		Who		Reason
06 Aug 2012	cnwcs5	Initial creation - par 30136
*/
vars
	obj	:CM_Association;
begin
	create obj transient;
	
	obj.set2Values (_int, _str);
	
	self.allDummyObjects.add (obj);
	
	return self.addItemObject (_str, obj);
epilog

end;</source>
        <Parameter name="_int" type="Integer"/>
        <Parameter name="_str" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="clear" id="867ab81c-8ab6-44c1-8613-8a0bd7e0a46f">
        <executionLocation>client</executionLocation>
        <source>clear() clientExecution;
/*
Date		Who		Reason
06 August 2012	cnwcs5	Initial creation - par 
*/
vars

begin
	inheritMethod();

	self.allDummyObjects.purge;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="e1eda7ad-f647-4733-a0c0-ba1d3cca8584">
        <updating/>
        <source>create() updating;
/*
Date		Who		Reason
06 Aug 2012	cnwcs5	Initial creation - par 30136
*/
vars
	dd	:DynaDictionary;
	obj	:CM_Association;
begin 
	dd	:= self.allDummyObjects;
	
	dd.setMembership (CM_Association); 
	dd.addMemberKey (CM_Association::integerValue.name, false, false);
	dd.endKeys (true);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="e15b7d80-4c1a-4b7c-b6c3-d1904a6b90b2">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>delete() updating, clientExecution;
/*
Date		Who		Reason
06 Aug 2012	cnwcs5	Initial creation - par 30136
*/
vars
	dd	:DynaDictionary;
begin
	dd := self.allDummyObjects;
	
	if dd.isValid then
		dd.purge;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getSelectedAsString" id="558573b0-aaba-40ee-8d13-575c1839c7cf">
        <source>getSelectedAsString(): String;
/*
Date		Who		Reason
06 Aug 2012	cnwcs5	Initial creation - par 30136
*/
vars

begin
	return self.getSelectedString (CM_Association::stringValue.name);

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSelectedIntegers" id="a7a6a437-a298-43ab-b052-7949c5a4135c">
        <source>getSelectedIntegers(_array :IntegerArray input);
/*
Date		Who		Reason
06 Aug 2012	cnwcs5	Initial creation - par 30136
*/
vars
	obj	:Object;
begin
	foreach obj in self.allSelectedObjects do
		_array.add (obj.CM_Association.asInteger);
	endforeach;
epilog

end;</source>
        <Parameter name="_array" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setSelected" id="38537d22-4a6e-42ce-91d7-a7233bd0da69">
        <updating/>
        <source>setSelected(_objs: IntegerArray) updating;
/*
Date		Who		Reason
06 Aug 2012	cnwcs5	Initial creation - par 30136
*/
vars
	int		:Integer;
	obj		:Object;
	coll	:ObjectSet;
begin
	create coll transient;
	
	foreach int in _objs do
		obj := self.allDummyObjects[int];
		
		if obj &lt;&gt; null then 
			coll.add (obj);
		endif;
	endforeach;
	
	inheritMethod(coll);

epilog
	delete coll;
end;</source>
        <Parameter name="_objs" type="IntegerArray"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="f2c39273-45e7-4c31-a659-2cf789dbddef">
        <controlMethod name="CMUI_ListTable::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>windowCreated(_control: Control input; _persistentControl: Control) updating;
/*
Date		Who		Reason
06 Aug 2012	cnwcs5	Initial creation - par 30136
*/
vars
	dd	:DynaDictionary;
	obj	:CM_Association;
begin 
	inheritMethod (_control, _persistentControl);
	
	dd	:= self.allDummyObjects;
	
	if dd.isValid then
		return;
	endif;
	
	dd.setMembership (CM_Association); 
	dd.addMemberKey (CM_Association::integerValue.name, false, false);
	dd.endKeys (true);
epilog

end;</source>
        <Parameter name="_control" type="Control" usage="input"/>
        <Parameter name="_persistentControl" type="Control"/>
    </JadeMethod>
