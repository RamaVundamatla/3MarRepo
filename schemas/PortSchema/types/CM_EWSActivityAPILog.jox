    <JadeMethod name="getDisplayStringForAttribute" id="bcc470d2-50a5-4e89-8b01-946b68350b08">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 December 2024	navrv30	JIRA 33578 EUP | Incoming API Logging

*/



begin
	if _attrName = ETRow_RemoteAddress then
		return self.remoteAddress;
	elseif _attrName = ETRow_UrlString then        
		return self.urlString;	
	elseif _attrName = ETRow_ServerName then        
		return self.serverName;
	elseif _attrName = ETRow_UnencodedURL then
		return self.unencodedURL;
	elseif _attrName = ETRow_HttpMethod then
		return self.httpMethod;
	endif;
	
	return inheritMethod(_attrName, _short);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="a144cfa4-d7a4-4573-aafb-196083ba5cc9">
        <updating/>
        <source>setForCreate(_proxy: SelfType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 December 2024	navrv30	JIRA 33578 EUP | Incoming API Logging

*/

vars

begin
	inheritMethod(_proxy);
	self.request := _proxy.request;
	self.response := _proxy.response;
	self.responseCode := _proxy.responseCode;
	self.httpMethod := _proxy.httpMethod;
	self.unencodedURL := _proxy.unencodedURL;
	self.serverName := _proxy.serverName;
	self.urlString := _proxy.urlString;
	self.remoteAddress := _proxy.remoteAddress;
epilog

end;</source>
        <Parameter name="_proxy" type="SelfType"/>
    </JadeMethod>
