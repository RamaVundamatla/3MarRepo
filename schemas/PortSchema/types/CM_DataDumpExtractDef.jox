    <JadeMethod name="validateCommon" id="bfffb0fe-fe4d-40fc-a7de-2e2e2cb45a73">
        <source>validateCommon() protected;
// ---------------------------------------------------------------------------
// Created:     27 May 2003 by cnwsb1
//13/06/2022 navds20 TFS 53760 DuplicateItem not Translatable
// ---------------------------------------------------------------------------
vars
	proxyClass : CM_DataDumpExtractClass;
	extractClasses : CM_DataDumpExtractClassSet;
	className : String;
begin
	self.raiseExceptionIfNotTransient(method);
	
	if self.description.trimBlanks() = null then//25/06/2010 cnwdz2 24487
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Err_Description), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Err_Description), null, null); // cnwdb2	PAR 35364

	endif;
	if self.extractFormat = null or
			self.extractFormat &lt; self.FmtMin or
			self.extractFormat &gt; self.FmtMax then
	//	app.raiseCMException1(REQUIRED_FIELD,  app.getErrorString(Err_Extractformat), null, null);
		app.raiseCMException1(Input_required_field_Required,  app.getErrorString(Err_Extractformat), null, null); // cnwdb2	PAR 35364

	endif;
	
	//30/04/2010 cnwdz2
	if self.extractFormat = self.FmtSQLNative then
		if self.oidFormat = null then
		//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Err_OIDFormat), null, null);
			app.raiseCMException1(Input_required_field_Required, app.getErrorString(Err_OIDFormat), null, null); // cnwdb2	PAR 35364


		endif;
		
		if self.oidColumnName = null then
		//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Err_OIDColumnName), null, null);
			app.raiseCMException1(Input_required_field_Required, app.getErrorString(Err_OIDColumnName), null, null); // cnwdb2	PAR 35364

		elseif	self.oidColumnName.startsWith(self.oidColumnName.truncatedAt(1).toUpper()) or 
				not self.oidColumnName.containsOnlyAlphaAndReal() then
			app.raiseCMException1(Err_InvalidOIDColumnFormat, self.oidColumnName, null, null);
		endif;
		
		if self.sqlServerVersion = null then
		//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Err_NullServerVersion), null, null);
			app.raiseCMException1(Input_required_field_Required, app.getErrorString(Err_NullServerVersion), null, null); // cnwdb2	PAR 35364


		endif;
	endif;
	
	
	if self.extractFormat = self.FmtSQLNative or 
	   self.extractFormat = self.FmtExternalDatabase then
		if self.edbUserName = null then
		//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Err_NullUserName), null, null);
			app.raiseCMException1(Input_required_field_Required, app.getErrorString(Err_NullUserName), null, null); // cnwdb2	PAR 35364


		endif;
	   
		if self.edbServerName = null then
		//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Err_NullServerName), null, null);
			app.raiseCMException1(Input_required_field_Required, app.getErrorString(Err_NullServerName), null, null); // cnwdb2	PAR 35364
		endif;
	   
		if self.edbConnectionString = null then
		//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Err_NullConnectionString), null, null);
			app.raiseCMException1(Input_required_field_Required, app.getErrorString(Err_NullConnectionString), null, null); // cnwdb2	PAR 35364

		endif;
		
		if self.edbPassword = null then
//			app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Err_NullPassword), null, null);
			app.raiseCMException1(Input_required_field_Required, app.getErrorString(Err_NullPassword), null, null); // cnwdb2	PAR 35364
		endif;

		if self.edbMachineDSN = null then
		//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Err_NullMachineDSN), null, null);
			app.raiseCMException1(Input_required_field_Required, app.getErrorString(Err_NullMachineDSN), null, null); // cnwdb2	PAR 35364
		endif;
	endif;
	
	if self.extractFormat = self.FmtXML_Generic then
		if self.fileFolderName = null then
		//	app.raiseCMException1(REQUIRED_FIELD, "fileFolderName", null, null);
			app.raiseCMException(Input_required_field_fleFoldNa, null, null); // cnwdb2	PAR 35364


		endif;
	elseif self.extractFormat = self.FmtExternalDatabase then
		// Nothing to check
	endif;
	
	create extractClasses transient;
	
	foreach proxyClass in self.allDataDumpExtractClasses do
		if extractClasses.includes(proxyClass) then
			if proxyClass.myDataDumpClass = null then
				className := "Unknown";
			else
				className := proxyClass.myDataDumpClass.className;
			endif;
			//app.raiseCMException2(DuplicateItem, "ExtractClass " &amp; className, "ExtractDef " &amp; self.description, null, null); //13.06.2022 navds20 53760
			// ExtractClass %1 already exists for ExtractDef %2 : Extract_already_exists_extract
			app.raiseCMException2(Extract_already_exists_extract, className, self.description, null, null); //13.06.2022 navds20 53760
		else
			extractClasses.add(proxyClass);
		endif;
		
		proxyClass.validateCommon;
	endforeach;
	
epilog
	delete extractClasses;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="8188651c-e8d5-4e19-b732-9f4a0ec6410f">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     27 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	self.validateCommon;
	
	if app.myRoot.allDataDumpExtractDefs[self.description] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.description, null, null);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="db45ce62-be5b-4419-a0f1-6e7f8de357c1">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:		07 August 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	self.raiseExceptionIfTransient(method);
	
	if self.allAutoTasks.size &gt; 0 then
		app.raiseCMException2(ObjectStillHasEntries, "Extract Definition",
				"Auto Task", null, null);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="0c8d2758-9cdd-489e-9c07-9dc33477b2ea">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     27 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	realDef : CM_DataDumpExtractDef;
	testDef : CM_DataDumpExtractDef;

begin
	self.validateCommon;
	
	realDef := self.pxyGetRealObject;
	if realDef = null then
		app.raiseCMException1(ProxyMgrCannotLocateReal, self.class.name, null, null);
	endif;
	
	testDef := app.myRoot.allDataDumpExtractDefs[self.description];
	
	if testDef &lt;&gt; null and testDef &lt;&gt; realDef then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.description, null, null);
	endif;
end;</source>
    </JadeMethod>
</Class>
