    <JadeMethod name="pxyCreateUpdateProxy" id="b978201f-0d3d-486f-a004-ee589128924c">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 May 2010	cnwmd1	Initial creation
20/04/2011	cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
					trying to create the proxy
*/

vars
	pxySysAlertType		: CM_SystemAlertType;
	completedOK		: Boolean;
begin
	pxySysAlertType := inheritMethod();
	self.allNotifyEmailAddresses.copy(pxySysAlertType.allNotifyEmailAddresses);
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxySysAlertType;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxySysAlertType;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="de179a55-5f03-49fa-b7a8-b426c3e9fcff">
        <updating/>
        <source>setForCreate(_proxy : CM_SystemAlertType) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
28 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.setForUpdate(_proxy);
epilog

end;</source>
        <Parameter name="_proxy" type="CM_SystemAlertType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="e9c84000-41f8-4e37-aff7-99b83931ac91">
        <updating/>
        <source>setForUpdate(_proxy : CM_SystemAlertType) updating;
/*
----------   ----------  --------------------------------------------------
Created:	06 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.type := _proxy.type;
	self.name := _proxy.name;
	self.description:= _proxy.description;
	self.area		:= _proxy.area;
	self.myRoot := _proxy.myRoot;
	self.allNotifyEmailAddresses.clear;
	_proxy.allNotifyEmailAddresses.copy(self.allNotifyEmailAddresses);

end;


</source>
        <Parameter name="_proxy" type="CM_SystemAlertType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="7f348ee7-9439-4477-8426-25f82f2d382a">
        <updating/>
        <source>setProxy(	_type : Integer;
			_name,
			_description,
			_area			: String;
			_root : CM_Root;
			_notifyEmailAddresses : CM_EmailEntityByTypeNameDict) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
28 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.raiseExceptionIfNotTransient(method);
	
	self.type		:= _type;
	self.name 		:= _name;
	self.description :=_description;
	self.area		:= _area;
	self.myRoot 	:= _root;
	self.allNotifyEmailAddresses.clear;
	if _notifyEmailAddresses &lt;&gt; null then
		_notifyEmailAddresses.copy(self.allNotifyEmailAddresses);
	endif;
epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_name" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_area" type="String"/>
        <Parameter name="_root" type="CM_Root"/>
        <Parameter name="_notifyEmailAddresses" type="CM_EmailEntityByTypeNameDict"/>
    </JadeMethod>
</Class>
