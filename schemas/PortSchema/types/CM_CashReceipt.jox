CM_CashReceipt.API_RECEIPT_EXPIRED = 21
CM_CashReceipt.API_RECEIPT_HOLD = 22
CM_CashReceipt.API_RECEIPT_CANCELLED = 23
CM_CashReceipt.API_RECEIPT_PAID = 24
CM_CashReceipt.API_RECEIPT_FINAL = 25</text>
    </PrimAttribute>
