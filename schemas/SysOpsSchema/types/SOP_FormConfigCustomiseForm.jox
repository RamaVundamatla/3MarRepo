    <JadeMethod name="refreshToolbar" id="aa28831d-568b-45f9-8ba9-a2485173f759">
        <updating/>
        <source>refreshToolbar() updating;
// ---------------------------------------------------------------------------
// Created:     01 August 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	toolbar			: CMUI_Toolbar;
begin
	toolbar := self.frmToolbar;
	
	toolbar.isPositionsCalculated := false;
	toolbar.allLeftControls.purge();
	toolbar.allRightControls.purge();

	self.addToolbarControls();
	toolbar.positionToolbarControls();
//	toolbar.updateSelfForPermissions(app.getMyUser, app.getMyTerminal());

	toolbar.zOrder(1);
//	toolbar.refreshNow();

end;</source>
    </JadeMethod>
    <JadeMethod name="registerFormKeys" id="59307392-73c1-43d3-bb6e-b2a9bae0ccf2">
        <executionLocation>client</executionLocation>
        <source>registerFormKeys(_array: IntegerArray) clientExecution;
// ---------------------------------------------------------------------------
// Created:     02 September 2008 by concms1:1
//
// Purpose:     User definable forms - CCMS 1011
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	array	:IntegerArray;
begin
	create array transient;
	
	array.add (J_key_LeftArrow);
	array.add (J_key_RightArrow);
	array.add (J_key_UpArrow);
	array.add (J_key_DownArrow);
	array.add (CMUI_Key_F11); // Inspect
	array.add( CMUI_Key_F12); // GUI info
	
	inheritMethod(array);

epilog
	delete array;
end;</source>
        <Parameter name="_array" type="IntegerArray"/>
    </JadeMethod>
    <JadeMethod name="selectControl" id="0fdd868d-4087-4968-a870-a57260bd01bd">
        <updating/>
        <source>selectControl(_control :Control)updating;
/*
	Purpose:			
	Parameters:			
	Return Value:		

Date				Who		Reason
03 September 2008	concms1	Initial creation
*/

vars

begin
	self.mySelectedControl	:= null;
	
	if self.getCustomisableControls.includes (_control) then
		self.mySelectedControl := _control;
	endif;
	
	self.highlightSelectedControl;
	
	if self.myPropertiesForm &lt;&gt; null then
		self.myPropertiesForm.displaySelectedControl (_control);
	endif;
	
epilog

end;</source>
        <Parameter name="_control" type="Control"/>
    </JadeMethod>
    <JadeMethod name="setControlCaption" id="dc7a2d46-a34c-4cd8-8cc1-d41f51f5318c">
        <source>setControlCaption(_control :Control input; _caption :String);
// ---------------------------------------------------------------------------
// Created:     03 September 2008 by concms1
// Purpose:     User definable forms - CCMS 1011
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
