    <JadeMethod name="txtCargoId_lostFocus" id="a987e34c-a192-4df6-b203-e57bc24aa868">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_lostFocus(textbox: TextBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

begin

	app.convertScannedCargoId( self.myTerminal, textbox, false, null );	//06 Jul 2016	NDL	TFS 2275
	
	if txtCargoId.text.trimBlanks = null then
		txtCargoId.text := lblCargoId.caption.toUpper;
	endif;
	
	txtCargoId.selStart := 0;
	txtCargoId.selLength := 0;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validatePreCargoChecks" id="3d56fa0b-cb7c-45ef-8fae-01e592feb3c1">
        <source>validatePreCargoChecks( _myChildCargo : CM_TrackedItem ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 July 2011	cnwndl1	Initial creation

*/

vars

	msg : String;

begin

	if _myChildCargo = null then
		msg := app.getErrorString(No_Cargo_To_Pack);
		self.msgBox(msg, app.getErrorString(Error), MsgBox_OK_Only,false);
		return false;
	endif;
	if myPackContainer = null then
		msg := app.getErrorString(No_Pack_Container);
		self.msgBox(msg, app.getErrorString(Error), MsgBox_OK_Only,false);
		return false;
	endif;

	if not myPackContainer.myVoyage.isNullVoyage then  //36111      
		if not _myChildCargo.myVoyage.isNullVoyage then        // 33622 
			if myPackContainer.myVoyage &lt;&gt; _myChildCargo.myVoyage then
				if myPackContainer.myVoyage &lt;&gt; null then
					msg := app.getErrorString2(Not_marked_voyage, _myChildCargo.id, myPackContainer.myVoyage.code);
				else
					msg := app.getErrorString2(Marked_voyage, _myChildCargo.id, _myChildCargo.myVoyage.code);
				endif;
				self.msgBox(msg, app.getErrorString(Error), MsgBox_OK_Only, false);
				return false;
			endif;
			
			if myPackContainer.dischargePort &lt;&gt; _myChildCargo.dischargePort then
				if myPackContainer.dischargePort &lt;&gt; null then
					msg := app.getErrorString2(Not_marked_discharge, _myChildCargo.id,  myPackContainer.dischargePort);
				else
					msg := app.getErrorString2(Marked_discharge, _myChildCargo.id, _myChildCargo.dischargePort);
				endif;
				self.msgBox(msg, app.getErrorString(Error), MsgBox_OK_Only, false);
				return false;
			endif;
		endif;
	endif;
	
	if _myChildCargo = myPackContainer then
		self.msgBox(app.getString(Cannot_pack_cargo_inside_itsel), 
				app.getString(Physically_impossible), MsgBox_Exclamation_Mark_Icon,false);
		return false;	
	endif;
	
	if _myChildCargo.myBookingRef &lt;&gt; null then							//child ti has a booking
		if _myChildCargo.myBookingRef.isStockBookingRef then				//child ti is stock booking
			if myPackContainer.myBookingRef &lt;&gt; null and not myPackContainer.myBookingRef.isStockBookingRef then
				if _myChildCargo.myBookingRefItem = null or not _myChildCargo.myBookingRefItem.allLinkedExportBookings.includes( myPackContainer.myBookingRef ) then
					self.msgBox(app.getString(CargoNotPartExBook), app.getString(Wrong_booking), MsgBox_Exclamation_Mark_Icon, false);
					return false;
				endif;
			endif;
		endif;
	endif;
	
	if myPackContainer.hasChild(_myChildCargo) then
		app.msgBox('Item ' &amp; _myChildCargo.id &amp; ' has already been packed into container ' &amp; myPackContainer.id, 'Item already packed', MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_myChildCargo" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
