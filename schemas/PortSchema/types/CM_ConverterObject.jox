    <JadeMethod name="getOutput" id="1196a0d9-c4b6-4868-ad3b-51496f927a38">
        <source>getOutput(_input : Real) : Real;
// ---------------------------------------------------------------------------
// Created:     23 February 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	
	i				: Integer;
	value,
	result			: Real;
	operationChar	: Character;
begin
	result := _input;

	foreach	i in 1 to self.numberOfOperations do
		if (i &gt; self.allOperations.size) or
			(i &gt; self.allValues.size)	then
			break; //this should never happen because of validateForCreate logic
		endif;
		
		operationChar := self.allOperations[i];
		value := self.allValues[i];

		if operationChar = Operation_Add then
			result := result + value;
		elseif operationChar = Operation_Subtract then
			result := result - value;
		elseif operationChar = Operation_Multiply then
			result := result * value;
		elseif operationChar = Operation_Divide then
			result := result / value;
		elseif operationChar = Operation_Square then
			result := result ^ value;	
		endif;		
	endforeach;

	return result.roundedTo(self.outputPrecision);

end;</source>
        <Parameter name="_input" type="Real"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getOutputDescription" id="3c1ece93-b3b4-40e2-b40a-1e490f71c56c">
        <source>getOutputDescription(_input : Real) : String;
// ---------------------------------------------------------------------------
// Created:     23 February 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	return self.getOutput(_input).String &amp; ' ' &amp; self.outputUnitString;

end;</source>
        <Parameter name="_input" type="Real"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="9951ac75-d8f7-467c-91c1-74e3100d324d">
        <updating/>
        <source>setForCreate(_proxy : CM_ConverterObject) updating;
// ---------------------------------------------------------------------------
// Created:     23 February 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.constValue 			:= _proxy.constValue; 
	self.numberOfOperations		:= _proxy.numberOfOperations;
	self.outputPrecision		:= _proxy.outputPrecision;
	self.outputUnitString		:= _proxy.outputUnitString;
	
	self.myConverterAgent		:= _proxy.myConverterAgent;

	_proxy.allOperations.copy(self.allOperations);
	_proxy.allValues.copy(self.allValues);
	

end;</source>
        <Parameter name="_proxy" type="CM_ConverterObject"/>
    </JadeMethod>
    <JadeMethod name="setFromXML" id="36b0aa63-ade7-4a25-bb63-fb798a46f372">
        <updating/>
        <source>setFromXML(_xmlStr : String) updating;
// ---------------------------------------------------------------------------
// Created:     23 February 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	i					: Integer;
	value				: Real;
	operation			: Character;
	pos,
	numOperations		: Integer;
	theName,
	theOutputType		: String;
	
begin
	self.outputPrecision := _xmlStr.cnEcGetTagValueOfName(XMLTag_OutputPrecision).Integer;
	self.outputUnitString := _xmlStr.cnEcGetTagValueOfName(XMLTag_OutputUnitString).String;
	self.numberOfOperations := _xmlStr.cnEcGetTagValueOfName(XMLTag_NumberOfOperations).Integer;
	pos := 1;
	foreach i in 1 to self.numberOfOperations do
		self.allValues.add(_xmlStr.cnEcGetNextTagValueOfName(XMLTag_Value, pos).Real);
	endforeach;
	
	pos := 1;
	foreach i in 1 to self.numberOfOperations do
		self.allOperations.add(_xmlStr.cnEcGetNextTagValueOfName(XMLTag_Operation, pos).Character);
	endforeach;
	

end;</source>
        <Parameter name="_xmlStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="1ddf3109-61e7-45fb-b98c-f71592f05613">
        <updating/>
        <source>setProxy(_const : Constant; _converterAgent : CM_ConverterAgent) updating;
// ---------------------------------------------------------------------------
// Created:     23 February 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.myConverterAgent := _converterAgent;
	self.constValue := _const.valueAsInteger;
	self.setFromXML(_const.text);
	
end;</source>
        <Parameter name="_const" type="Constant"/>
        <Parameter name="_converterAgent" type="CM_ConverterAgent"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="7d433821-1fc8-4630-ac71-809b5938ac9b">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     23 February 2003		cnwth2	
//
// Purpose: 
//13/06/2022     navds20     TFS 53760 DuplicateItem not Translatable    		 
// ----------   ----------  --------------------------------------------------

vars

begin
	
	if self.constValue = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Constant value', 'Constant value', null);
		app.raiseCMException(Input_required_field_constVal, 'Constant value', null); // cnwdb2	PAR 35364

	endif;

	if self.myConverterAgent.allConverterObjects[self.constValue] &lt;&gt; null then
		//app.raiseCMException(DuplicateItem, 'Converter object: ' &amp; self.constValue.String, null); //13.06.2022 navds20 53760
		// Converter object: already exists for %1 : Convert_object_already_exists
		app.raiseCMException(Convert_object_already_exists, self.constValue.String, null); //13.06.2022 navds20 53760
	endif;

	if self.numberOfOperations &gt; self.allOperations.size then
		app.raiseUnexpectedProgramError(class.name, method.name, 'More operations than numeric operators');
	endif;
	
	if self.numberOfOperations &gt; self.allValues.size then
		app.raiseUnexpectedProgramError(class.name, method.name, 'More operations than numeric values');
	endif;
	
end;</source>
    </JadeMethod>
</Class>
