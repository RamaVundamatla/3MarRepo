    <JadeMethod name="refreshCmbFilterColour" id="8a0ff3a8-e467-4b21-9bd7-9b677c6d742d">
        <source>refreshCmbFilterColour();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 December 2011	cnwndl1	Initial creation	Par 28889

*/

vars

	index : Integer;
	column : Integer;
	entableRowHeading : String;
	count : Integer;
	str : String;

begin

	foreach index in 1 to self.cmbColumnFilter.listCount do
		column := self.myDataTable.allTblDataEntRows.indexOf( self.cmbColumnFilter.itemObject[ index ].EntTableRow );
		entableRowHeading := self.cmbColumnFilter.itemObject[ index ].EntTableRow.getHeading(self.myDataTable.myTerminologyCargoBOLType, self.myDataTable.myTerminologyTerminal, app.myCurrentLocale);
		if self.allFilterColumns.getColumnFilter( self.myDataTable, column, entableRowHeading ) &lt;&gt; null then
			self.cmbColumnFilter.itemForeColor[index] := Red;
			count := count + 1;
		else
			self.cmbColumnFilter.itemForeColor[index] := Black;
		endif;
	endforeach;
	
	if count = 0 then
		self.btnClearAll.enabled := false;
		self.btnShow.caption := "No filters applied";
		self.lblShowFilter.caption := null;
		self.btnShow.enabled := false;
	else
		self.btnClearAll.enabled := true;
		self.btnShow.caption := count.String &amp; " filter(s) applied";
		self.lblShowFilter.caption := self.getFilterDetailsForDisplay();
		self.btnShow.enabled := true;
	endif;
	
	self.enabledFilterButtons();
	
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="resetDefaults" id="0b2d2dbb-17ba-4927-aa57-f5024171c507">
        <updating/>
        <source>resetDefaults(_system : Boolean) updating, protected;
//--------------------------------------------------------------
//Created: 14 January 2003 By: cnwgd1
//15 Sep 2023 navnk30 ChangeRequest 60463: MTN - Adding Filter to column organizer screen
//--------------------------------------------------------------
vars
	rowArray: EntTableRowArray;
	idx		: Integer;
	entRow	: EntTableRow;
	view	: EntTableView;
begin
	
	create rowArray transient;

	//see if there is a system deafult first
	if _system then
		view := self.myEntTableDef.allEntTableViews[SystemDefault];
	endif;

	//if not then use the JMT default
	if view	= null then
		view := self.myEntTableDef.allEntTableViews['Default'];
	endif;
	
	if view &lt;&gt; null then
		view.allEntTableRows.copy(rowArray);
	else
		self.myEntTableDef.allEntTableRows.copy(rowArray);
	endif;
	
	self.mulColumns.setAvailable(self.myEntTableDef.allEntTableRows, true);
	self.setFilterCollection(self.mulColumns);	//16/04/2024	navkc1 Bug 63657 - Moved here before setSelected so the parentCollection will not be empty
	self.mulColumns.setSelected(rowArray);
	//self.setFilterCollection(self.mulColumns);	//15.09.2023 navnk30 #60463

	self.setColumnSorter(true);

epilog
	delete rowArray;
end;</source>
        <access>protected</access>
        <Parameter name="_system" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="430a71b2-9c82-4592-8854-1e3f46e9a8d9">
        <updating/>
        <source>setColorsFromController(_colorControl : CM_ColorController) updating;
//--------------------------------------------------
// Created:	08 September 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(_colorControl);

	self.setColorsForMultiSelectGrpBox(self.mulColumns);
	self.setColorsForMultiSelectGrpBox(self.mulColumnSorter);

	self.fldMain.tabsStyle := Folder.TabsStyle_RightSloped;

	self.fldMain.useSheetBackColors := true;
	self.fldMain.setDefaultSheetBackColors();
	self.fldMain.initSheetBackColors();		
end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setColumnSorter" id="53bd0339-3fa4-412c-a194-e6af93531b9e">
        <updating/>
        <source>setColumnSorter(_resetSelected : Boolean)protected, updating;
//--------------------------------------------------
// Created:	08 September 2005 By: cnwgd1
// 15 Sep 2023 navnk30 ChangeRequest 60463: MTN - Adding Filter to column organizer screen
//--------------------------------------------------
vars
	tmpAvailable,
	tmpSelected : EntTableRowArray;
begin
	if myDataTable = null then
		return;
	endif;
	// the avaiable sort columns are the selected table columns
	create tmpAvailable transient;
	self.mulColumns.getSelected(tmpAvailable);
	self.mulColumnSorter.formDisplayEntryMethodName :=CMUI_ColumnOrganiserForm::displayMultiSelectAvailable.name; //+cnwml2 PAR25840
	self.mulColumnSorter.setAvailable(tmpAvailable, _resetSelected);
	self.setFilterCollection(self.mulColumnSorter);						//15.09.2023 navnk30 #60463
			
	if _resetSelected then
		create tmpSelected transient;
		self.myDataTable.getSortColumnEntRows(tmpSelected);
		self.mulColumnSorter.formDisplayEntryMethodName:=CMUI_ColumnOrganiserForm::displayMultiSelectSorted.name;	//+cnwml2 PAR25840
		self.mulColumnSorter.setSelected(tmpSelected);			
	endif;
	
epilog
	delete tmpAvailable;
	delete tmpSelected;
end;</source>
        <access>protected</access>
        <Parameter name="_resetSelected" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFilterCollection" id="eb4b4687-e523-4698-a912-435d0a5e662f">
        <source>setFilterCollection(_mulSelectGroupBox : CMUI_MultiSelectFilterGroupBox io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Sep 2023 navnk30 ChangeRequest 60463: MTN - Adding Filter to column organizer screen

*/

vars
	collection	: ObjectSet;
begin
	create collection transient;
	_mulSelectGroupBox.getAvailable(collection);
	_mulSelectGroupBox.setParentCollection(collection);
epilog
	delete collection;
end;</source>
        <Parameter name="_mulSelectGroupBox" type="CMUI_MultiSelectFilterGroupBox" usage="io"/>
