    <JadeMethod name="utlCreateDutyDocReserve" id="6eaf9350-9da0-4979-b213-ef8ec1eae0d2">
        <source>utlCreateDutyDocReserve(_pxyReleaseRequest: CM_BulkRelease input; _cargoType: CM_CargoType; _iso: CM_ISOType; _reserve: CM_ReserveSelection output);
//
//09 Sep 2014	cnwrs1	CCMS 2351 att Sequence to Release request 
//19/07/2022	navtnr20	ChangeRequest 53974: EUP - OUT - Additional Fields on Release Line Level
//28 June 2023 navmv20 CR 58410 Task 58411: UI - Cargo Review - Release Request																	
// 6/12/2023	navcs2	ChangeRequest 57537: EUP | Release Request By Type - with Weight
vars

begin
	create _reserve transient;
	_reserve.setMyHeader(_pxyReleaseRequest);
	_reserve.setPxyDefaults();

	_reserve.setProxy(0, 
					_cargoType,
					null,
					_iso,
					null,
					null,
					null,
					null,
					0,
					null, //avail grades
					null,//clean
					null, //iso check
					false, //heavy rated
					null, //mask ids
					0,
					null,
					null,
					null,
					null,
					null,
					null,
					null,
					null,
					null,
					null,
					null,
					null,
					null,
					null,
					null,
					null,
					null,null,null,null,null,null,false,false,null,null,null,null,null,null,null,null,
					null,	// ### TFS 53953 11July2022 NAVPW1
					null,null,  //12-07-2022 navtnr20 53974
					null, //28/06/2023 navmv20 CR 58410 Task 58411
					false,	// 6/12/2023 navcs2 ChangeRequest 57537
					false, //19/02/2023	navkc1 CR 60078 Task 62450
					null,  //24/04/2025	navrv30	MTN 34319
					null);

epilog

end;</source>
        <Parameter name="_pxyReleaseRequest" type="CM_BulkRelease" usage="input"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_iso" type="CM_ISOType"/>
        <Parameter name="_reserve" type="CM_ReserveSelection" usage="output"/>
    </JadeMethod>
    <JadeMethod name="utlCreateDutyDocRoadRelease" id="5d5b541a-64c9-49fd-94db-08715cb48e6a">
        <source>utlCreateDutyDocRoadRelease(_dutyDoc: CM_DutyDoc; _tis: CM_TISet; _release: CM_BulkRelease output; _passport: CM_Passport input);
/* Changes

Date		Name	TFS#			Description
============================================================================
24/01/2019	jlgka1	41708	As a result of the changes in the CM_BulkRelease.setProxy
							we also need to add myBOLIn here.
20/07/2023	navdap1	58923 	EUP CallOff EDI Data Type / Data Load
============================================================================*/
vars
	pxyReleaseRequest	: CM_BulkRelease;
	release				: CM_BulkRelease;
	pxyReserveSelection	: CM_ReserveSelection;
	tisByCargoType		: CM_TIByCargoTypeDict;
	containersByISO		: CM_ContsByISOTypeDIct;
	ti					: CM_TrackedItem;
	container			: CM_Container;
	iter				: Iterator;
begin

	create pxyReleaseRequest transient;
	pxyReleaseRequest.setProxy(_dutyDoc.id,
								BR_TYPE_ROAD,
								true,
								BR_ACTIVE,
								null,
								null,
								null,
								null,
								null, // consignee
								null,
								null, // consignor
								null,
								null, //consign voyage
								app.actualTimeServer(),// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
								null, //today,		
								null,
								null,
								null,
								null, 
								null,
								null,
								null, //load port
								null, //_destinationPort
								null,
								null, //freightForwarder
								null,
								_dutyDoc.getMyTerminal(),
								_dutyDoc.getMyOperator(),
								null,
								_dutyDoc.getMyVoyage(),//voyage
								null,//bank
// TFS 2686								false,
								true,
								null,null,null,
								_dutyDoc.getMyTerminal().getDefaultSubTerminalForRel(BR_TYPE_ROAD),
								null, // subterm target
								null, 	//_assignedTrain : CM_Train
								false,
								null,				
								false,				
								false, false,				
								false, 
								null,
								null,
								null,	// jlgka1 TFS 41708
								null	// ### TFS 53953 27June2022 NAVPW1
								);
	
	create tisByCargoType transient;
	_tis.copy(tisByCargoType);

	
	// Need to group the cargo by Cargo Type ( and ISO in as well for containers)
	iter := tisByCargoType.createIterator;
	while iter.next(ti) do
		if ti.myCargoType.id = TI_CargoType_Container then
			container := ti.CM_Container;
			create containersByISO transient;
			containersByISO.add(container);
			while iter.next(ti) do
				if ti.myCargoType.id &lt;&gt; TI_CargoType_Container then
					iter.back(ti);
					break;
				endif;
				containersByISO.add(ti.CM_Container);
			endwhile;
			
			foreach container in containersByISO do
				if pxyReserveSelection = null or pxyReserveSelection.myISOType &lt;&gt; container.getISOTypeObject then
					app.myUtilityCA.utlCreateDutyDocReserve(pxyReleaseRequest, container.myCargoType, container.getISOTypeObject, pxyReserveSelection);
				endif;
				pxyReserveSelection.allTrackedItems.add(container);
				pxyReserveSelection.setTotalRequested(pxyReserveSelection.allTrackedItems.size);
			endforeach;
			delete containersByISO;
		else
			if pxyReserveSelection = null or pxyReserveSelection.myCargoType &lt;&gt; ti.myCargoType then
				app.myUtilityCA.utlCreateDutyDocReserve(pxyReleaseRequest, ti.myCargoType, null, pxyReserveSelection);
			endif;
			pxyReserveSelection.allTrackedItems.add(ti);
			pxyReserveSelection.setTotalRequested(pxyReserveSelection.allTrackedItems.size);
		endif;
	endwhile;
	
	_tis.copy(pxyReleaseRequest.allTrackedItemsAssigned);
	
	pxyReleaseRequest.createRequests();
	
	app.myUtilityCA.utlCreateBulkRelease (pxyReleaseRequest, _release, null, null, null, null, _passport);	// TFS 58923
		
epilog
	delete pxyReleaseRequest;
	delete tisByCargoType;
	delete containersByISO;
	delete iter;
end;</source>
        <Parameter name="_dutyDoc" type="CM_DutyDoc"/>
        <Parameter name="_tis" type="CM_TISet"/>
        <Parameter name="_release" type="CM_BulkRelease" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateDutyDocRoadReleaseID" id="c9550985-6b2e-4b84-8be6-deb7d3ff83b7">
        <source>utlCreateDutyDocRoadReleaseID(_dutyDoc: CM_DutyDoc; _tis: CM_TISet; _release: CM_BulkRelease output; _passport: CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		

/* Changes

Date		Name	TFS#		Description
============================================================================
25/08/2014	cnwma1				Initial creation
16 May 2016	cnwns1	TFS 488 	Multi Timezone Support
24/01/2019	jlgka1	41708		As a result of the changes in the CM_BulkRelease.setProxy
								we also need to add myBOLIn here.
20/07/2023	navdap1	58923 		EUP CallOff EDI Data Type / Data Load
============================================================================*/

vars
	pxyReleaseRequest, release: CM_BulkRelease;
	pxyReserveTI: CM_ReserveTI;
	tisByCargoType: CM_TIByCargoTypeDict;
	containersByISO: CM_ContsByISOTypeDIct;
	iter: Iterator;
	ti: CM_TrackedItem;
	container: CM_Container;
begin
	
	create pxyReleaseRequest transient;
	pxyReleaseRequest.setProxy(_dutyDoc.id,
								BR_TYPE_ROAD,
								false,
								BR_ACTIVE,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,//consign voyage
								app.actualTimeServer(),// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
								null, //today,		
								null,
								null,
								null,
								null, //door dir
								null,
								null,
								null,
								null,//_destinationPort
								null,
								null,//freightForwarder
								null,
								_dutyDoc.getMyTerminal(),
								_dutyDoc.getMyOperator(),
								null,
								_dutyDoc.getMyVoyage(),//voyage
								null,//bank
// TFS 2686								false,
								true,
								null,null,null,
								_dutyDoc.getMyTerminal().getDefaultSubTerminalForRel(BR_TYPE_ROAD),
								null, 
								null, 	
								false,						
								null,				
								false,
								false, false,
								false, 	
								null,
								null,
								null,	// jlgka1 TFS 41708
								null	// ### TFS 53953 27June2022 NAVPW1
								);
	create tisByCargoType transient;
	_tis.copy(tisByCargoType);
	
	// Need to group the cargo by Cargo Type ( and ISO in as well for containers)
	iter := tisByCargoType.createIterator;
	while iter.next(ti) do
		if ti.myCargoType.id = TI_CargoType_Container then
			container := ti.CM_Container;
			create containersByISO transient;
			containersByISO.add(container);
			/*while iter.next(ti) do
				if ti.myCargoType.id &lt;&gt; TI_CargoType_Container then
					iter.back(ti);
					break;
				endif;
				containersByISO.add(ti.CM_Container);
			endwhile;*/
			create pxyReserveTI transient;
			foreach container in containersByISO do
				pxyReserveTI.setMyHeader(pxyReleaseRequest);
				pxyReserveTI.allTrackedItems.add(ti);
				pxyReleaseRequest.allTrackedItemsAssigned.add(ti);
				//pxyReleaseRequest.setTotalRequested(pxyReserveTI.allTrackedItems.size);
			endforeach;
			delete containersByISO;
		endif;
	endwhile;
	
	//_tis.copy(pxyReleaseRequest.allTrackedItemsAssigned);
	
	pxyReleaseRequest.createRequests();
	
	app.myUtilityCA.utlCreateBulkRelease (pxyReleaseRequest, _release, null, null, null, null, _passport);	// TFS 58923
	
								
epilog
	delete pxyReleaseRequest;
	delete tisByCargoType;
	delete containersByISO;
	delete iter;
end;</source>
        <Parameter name="_dutyDoc" type="CM_DutyDoc"/>
        <Parameter name="_tis" type="CM_TISet"/>
        <Parameter name="_release" type="CM_BulkRelease" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
