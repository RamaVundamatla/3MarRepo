    <JadeMethod name="setApproved" id="1e290cff-10dd-42fe-9c88-21f35256bd2d">
        <updating/>
        <source>setApproved(_approvedBy: String; _approvedBtDT: TimeStamp; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21/08/2009	cnwrd1	Initial creation
11/09/2018	jlgdap1	TFS 40202 PEL1 Estimation SAP Integration
22/01/2019	jlgdap1	TFS 42925 PEL1 Container Services - Estimation Approval Countdown
25/01/2019	cnwma1	ChangeRequest 42942: PEL1 - Container Services - SAP Process
20/03/2019	jlgdap1	TFS 43888 PEL1 Container services - Invoice created on Work-Order receival (Cargo Receival) Transaction
29 Sep 2021 navma1  ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
19/07/2022	navcs2	ChangeRequest 53932: MTN - Jobs Changes
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
24 Jan 2023 navdp20 ChangeRequest 54344:[56236] - New Terminal Config Options for Auto Action Tasks
12 Apr 2023 navma1 ChangeRequest 57569:[57570] EUP - [Framework] Refactor Actioning Work Order Tasks
19 Apr 2023 navhl20 Defect 57648: MTN - Issues when actioning the multiple Receive Cargo Work Order tasks
02 May 2024 navhl20 ChangeRequest 63971: FR | 54176 - Ship operations in Delivery Dispatch screen
*/

vars	
	wod 			: CM_WorkOrderDtl;
	allTIs			: CM_TISet;
	aTI 			: CM_TrackedItem;
	wodtl 			: CM_WorkOrderDtl;					
	tranType 		: Integer;								// TFS 43888
	txnParams 		: CMIF_WorkOrderTransController;		// TFS 43888
	root			: CM_Root;
	term			: CM_Terminal;
	woActionIF 		: CMIF_WorkOrderAction;
	statusUpdated	: Boolean;
	realJob			: CM_Job;
	useYardJob 		: Boolean;
	wodTodo			: CM_WodToDo;
begin

	if self.isTransient or not process.isInTransactionState then
		//error
		return;		
	endif;
	
	root := app.myRoot;															 //12.01.2023 navma1 #56141 Task#56147
	term := self.myTerminal;													 //12.01.2023 navma1 #56141 Task#56147
	
	//19.01.2023 navma1 #56141 Task#56147
	foreach wodtl in self.allWoDtls do
		wodtl.createWOTransaction(wodtl.TRANS_UPDATED, null, null); 
	endforeach;
	
	self.createPaymenTypeInvoice();												 //24.01.2023 navma1 #56141 Task#56147
	statusUpdated:= self.setFinancePending();									 //24.01.2023 navma1 #56141 Task#56147
	
	
	if statusUpdated then
		//Status updated to finance pending
		return;
	endif;
	
	inheritMethod(_approvedBy, _approvedBtDT,  _passport );
	
	
	// now create a basic schedule for each task - do this before we add ti's so we can update schedule with auto stuff.
	// only do this if we have a start date on the work orer
	
	foreach wod in self.allWoDtls do
		wod.CM_WorkOrderTIDtl.setTotalUnactioned(wod.CM_WorkOrderTIDtl.allSelectedTIs.size);								//08.02.2023 navma1 #56457 Task#56458
	endforeach;
	
	
	foreach wodtl in self.allWoDtls do										//08.02.2023 navma1 #56457 Task#56458
		foreach aTI in wodtl.CM_WorkOrderTIDtl.allSelectedTIs do
			self.addTrackedItem(aTI,wodtl);
		endforeach;
		wodtl.setStatus(WO_STATUS_APPROVED);								//08.02.2023 navma1 #56457 Task#56458
		
		wodTodo := wodtl.CM_WorkOrderTIDtl.allToDoRequests.first;			//19.4.2023 navhl20	#57648
		if wodTodo &lt;&gt; null then												//19.4.2023 navhl20	#57648
			wodTodo.setStatus(WO_STATUS_APPROVED);
		endif;
	endforeach;
	
	// TFS 43888 Web Portal creates work orders in Pending Approval status, // TFS 43888
	// so the allTIs are already populated when the source is set up. 		// TFS 43888
	// We don't create transactions for those TIs when thw web portal 		// TFS 43888
	// creates the work order, but we do need to check now that they have	// TFS 43888
	// been done															// TFS 43888
	/*
	//08.02.2023 navma1 #56457 Task#56458
	foreach aTI in self.allTIs do											// TFS 43888
		wodtl := self.allWoDtls.first;										// TFS 43888
		if wodtl &lt;&gt; null then												// TFS 43888
			tranType := self.allWoDtls.first.getWOTransactionType();		// TFS 43888
			if aTI.getTransactionOfType(tranType) = null then				// TFS 43888
				create txnParams transient;									// TFS 43888
				txnParams.type := tranType;									// TFS 43888
				txnParams.myWorkOrder := self;								// TFS 43888
				aTI.createTransaction(txnParams, app.myPassport);			// TFS 43888
				delete txnParams;											// TFS 43888
			endif;															// TFS 43888
		endif;																// TFS 43888
	endforeach;																// TFS 43888
	*/
	
	foreach wodtl in self.allWoDtls do										//08.02.2023 navma1 #56457 Task#56458
		foreach aTI in wodtl.CM_WorkOrderTIDtl.allSelectedTIs do
			tranType := wodtl.getWOTransactionType();		
			
			if aTI.getTransactionOfType(tranType) = null then				
				create txnParams transient;									
				txnParams.type 		  := tranType;									
				txnParams.myWorkOrder := self;								
				aTI.createTransaction(txnParams, app.myPassport);			
				delete txnParams;											
			endif;			
		endforeach;
	endforeach;
	
	
	
	self.updateCustomsExportEntryNum(_passport);							//24.01.2023 navma1 #56141 Task#56147
	self.createPinNumber();													//24.01.2023 navma1 #56141 Task#56147
	self.createCargoToDoTask();												//24.01.2023 navma1 #56141 Task#56147	//08.02.2023 navma1 #56457 Task#56458
	
	
	useYardJob := term.isUseYardJobsForCargoWo;		
	
	if term.getConfig(AllowAutoActionCargoWo).Boolean and useYardJob then   //24.01.2023 navdp20 #56236
	
		foreach wod in self.allWoDtls do 
		
			create woActionIF transient;
			woActionIF.myWorkOrderDtl		 := wod;
			woActionIF.numberFromKnownCargo  := wod.CM_WorkOrderTIDtl.allAvailableTIs.size;
			woActionIF.useYardJobs			 := useYardJob;
			
			wod.doActionTask(woActionIF,realJob,_passport);			//12.04.2023 navma1 #57569:[57570]
			delete woActionIF;
		endforeach;
	endif;
epilog
	delete allTIs;
	delete txnParams;					// TFS 43888
	delete woActionIF;					//19.01.2023 navma1 #56141 Task#56147
end;</source>
        <Parameter name="_approvedBy" type="String"/>
        <Parameter name="_approvedBtDT" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setCancelled" id="bd7e850d-0895-4611-a665-6112cae0b6da">
        <source>setCancelled();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Jul 2019	jlgndl1	Initial creation	TFS 45637
17/10/2022  navcs2	ChangeRequest 56633:[56211] 54253.101 - Work order Transactions
08 Feb 2023 navma1 	ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
*/

vars
	woDtl 	 : CM_WorkOrderDtl;
	tranType : Integer;
	aTI 	 : CM_TrackedItem;
	woTrx 	 : CM_WorkOrderAssign;
begin

	inheritMethod();
	
	woDtl := self.allWoDtls.first;
	
	if woDtl &lt;&gt; null then
		tranType := woDtl.getWOTransactionType();
		
		if tranType.isOneOf(	TRANS_TYPE_WORKORDER_RETURNED,
								TRANS_TYPE_WORKORDER_MOVE,
								TRANS_TYPE_WORKORDER_NULLVOY,
								TRANS_TYPE_WORKORDER_RECEIVE,
								TRANS_TYPE_WORKORDER_RELEASE,
								TRANS_TYPE_WORKORDER_RELEXTEND
								//TRANS_TYPE_WORKORDER_ASSIGN    //08.02.2023 navma1 #56457 Task#56458 /* do we need thisPending */
							) then
								
			foreach aTI in self.allTIs do
				woTrx := aTI.getTransactionOfType(tranType).CM_WorkOrderAssign;
				while woTrx &lt;&gt; null do
					woTrx.setForDelete( app.getErrorString1(Work_order_cancelled, self.id ) );
					woTrx := aTI.getTransactionOfType(tranType).CM_WorkOrderAssign;
				endwhile;
			endforeach;
			
		endif;
		
	endif;
	
	// 17.10.2022 navcs2 #56633:[56211]
	foreach woDtl in self.allWoDtls do
		woDtl.createWOTransaction(woDtl.TRANS_UPDATED, null, null);
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setFinancePending" id="16bbaa78-aec4-4d2e-b80a-55092967491c">
        <updating/>
        <source>setFinancePending():Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Jan 2023	navma1  	ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI

*/

vars
	financeApproved : Boolean;
	cashReceipt		: CM_CashReceipt;
	statusUpdated	: Boolean;
begin
	if not self.isTransient and self.requireFinanceApproval then  		  	  	 //29.09.2021 navma1 #51925	
		financeApproved:=true;
		foreach cashReceipt in	self.allCashReceipts discreteLock do
			if  cashReceipt.requireFinanceCheck then						    //29.09.2021 navma1 #51925
				financeApproved:=false;
				break;
			endif;
		endforeach;
		
		if not financeApproved then
			//if there are BGP requests  leave it as is and return
			if self.taskStatus &lt;&gt; WO_STATUS_PENDING_FIN then
				self.taskStatus := WO_STATUS_PENDING_FIN;
			endif;
			statusUpdated := true;
		endif;
	endif;
	
	return statusUpdated;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="18440be8-b95d-4ba5-ae8d-4e36492ae26a">
        <updating/>
        <source>setForCreate(_proxyWO: CM_WorkOrder) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date	Who		Reason
24 July 2009	cnwrd1	Initial creation
11 June 2018 	jlger1	tfs 38947 lets not call set for update twice
12 Jan 2023		navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
08 Feb 2023 	navma1  ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
*/

vars	
	realTISource : CM_WorkOrderTISource;
	ti			 : CM_TrackedItem;
begin	
	
	inheritMethod(_proxyWO);	

	/*
	12.01.2023 navma1 #56141 Task#56147
	if _proxyWO.CM_WorkOrderTI.mySource.isTransient then //should be here
		create realTISource persistent;
		realTISource.setMyParent ( self );
		realTISource.setForCreate(_proxyWO.CM_WorkOrderTI.mySource ) ;	
	endif;
	*/
	/*
	08.02.2023 navma1 #56457 Task#56458
	foreach ti in _proxyWO.CM_WorkOrderTI.allTIs do						//12.01.2023 navma1 #56141 Task#56147
		self.CM_WorkOrderTI.allTIs.addNoDuplicates(ti, false);
	endforeach;
	*/
epilog

end;</source>
        <Parameter name="_proxyWO" type="CM_WorkOrder"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="2efa84cf-41f0-4889-ac6b-8afb24093a81">
        <updating/>
        <source>setForUpdate(_proxyWO: CM_WorkOrder;_updateTasks: Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
24 July 2009	cnwrd1	Initial creation
11 June 2018 	jlger1	tfs 38947 do this after inherit so the status is set 
15 Oct 	2021 	jlier1	TFS 52195 
12 Jan 2023		navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
08 Feb 2023 	navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
*/

vars
	extraToDo : Integer;
	wod 	  : CM_WorkOrderDtl;
	ti		  : CM_TrackedItem;
begin	
	inheritMethod(_proxyWO,_updateTasks);
	
	/*
	12.01.2023 navma1 #56141 Task#56147
	if self.mySource &lt;&gt; null then
		self.mySource.setForUpdate(_proxyWO.CM_WorkOrderTI.mySource ) ;	
	endif;
	*/
	
	/*
	06.03.2023 navma1 #56457:[56458]
	if self.totalRequired &lt; _proxyWO.CM_WorkOrderTI.totalRequired then	 //we should validate out a reduction in totals as this shouldnt be allowed
		if self.hasBeenApproved() then //if status approved or greater we can upp the number of cargo items for the work order, but not reduce it
			//so here we need to update the work order details totals
			extraToDo := _proxyWO.CM_WorkOrderTI.totalRequired  - self.totalRequired;
		
			foreach wod in self.allWoDtls do
				wod.CM_WorkOrderTIDtl.setTotalUnactioned ( wod.CM_WorkOrderTIDtl.totalUnactioned + extraToDo);			
			endforeach;
		
		else
		endif;
	endif;
	self.totalRequired := _proxyWO.CM_WorkOrderTI.totalRequired;				//08.02.2023 navma1  #56457:[56458]
	*/
	
	/*
	08.02.2023 navma1 #56457 Task#56458
	self.CM_WorkOrderTI.allTIs.clear();											//12.01.2023 navma1 #56141 Task#56147
	foreach ti in _proxyWO.CM_WorkOrderTI.allTIs do								//12.01.2023 navma1 #56141 Task#56147
		self.CM_WorkOrderTI.allTIs.addNoDuplicates(ti, false);
	endforeach;
	*/

epilog

end;</source>
        <Parameter name="_proxyWO" type="CM_WorkOrder"/>
        <Parameter name="_updateTasks" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setNotApproved" id="e475df60-1151-40dd-a13d-7449ce1eab8d">
        <updating/>
        <source>setNotApproved(_notApprovedBy: String; _remarks: String; _totDays: Decimal) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 January 2019	jlger1	Initial creation 42924

*/

vars
	receipt 		: CM_CashReceipt;	
begin
	inheritMethod(_notApprovedBy, _remarks, _totDays);

	//TFS 42924 when the not approve the work order make sure the future actor is deleted otherwise invoice will be created 
	foreach receipt in self.allCashReceipts discreteLock do				// TFS 40202						// TFS 40202
		// TFS 42925 and delete any future actors
		app.myRoot.deleteFutureActor(receipt, CM_CashStatusAdvanceProcess);
	endforeach;	
	
epilog

end;</source>
        <Parameter name="_notApprovedBy" type="String"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_totDays" type="Decimal"/>
    </JadeMethod>
