<GUIClass name="CMUI_ColourLegendFrame" id="9e5bfb81-fdff-4162-a892-159a57d1e3b9">
    <superclass name="CMUI_Frame"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <ImplicitInverseRef name="allUsedProducts" id="d467bb84-4ab4-43c3-bcb1-84669b9c9157">
        <memberTypeInverse/>
        <type name="CM_ProductByCodeCargoTypeDict"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <PrimAttribute name="dwellDays" id="9b713825-bff9-4bc8-97e0-3bf264f52d53">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <ImplicitInverseRef name="myLegendTable" id="56d7f09f-74b2-4e47-811c-86bb81d1ad02">
        <embedded/>
        <type name="CM_ColourLegendTable"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myParent" id="862bfb75-f5ab-4c1a-af9a-8a17f0b3de77">
        <embedded/>
        <type name="Form"/>
    </ImplicitInverseRef>
    <PrimAttribute name="viewMode" id="f5248474-713a-454d-954b-d850d0b382d9">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="addRow" id="9a5be5d3-8990-4177-8ad8-776c3f54365d">
        <source>addRow(xLabel : String; xColor : Integer; _theObject : CM_Object; _checkIfAlreadyInTable : Boolean);
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx : Integer;
	
begin
	//16 Sep 2009	NDL	Par 20051 - add parameter _checkIfAlreadyInTable for performance...
	if (not _checkIfAlreadyInTable) or (not  self.myLegendTable.findObjectInRow(_theObject,idx) ) then
		idx := self.myLegendTable.addItem(xLabel);
		self.myLegendTable.accessRow(idx).backColor := xColor;
		self.myLegendTable.accessedRow.foreColor := xColor.getInverseColour();
		self.myLegendTable.accessedRow.alignment := Table.Alignment_Center_Middle;
//		self.myLegendTable.accessedRow.fontName := app."Arial";
		self.myLegendTable.accessedRow.fontSize := 8;
		self.myLegendTable.accessedRow.itemObject := _theObject;
	endif;
end;</source>
        <Parameter name="xLabel" type="String"/>
        <Parameter name="xColor" type="Integer"/>
        <Parameter name="_theObject" type="CM_Object"/>
        <Parameter name="_checkIfAlreadyInTable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addRowAt" id="302f1b7c-7047-4f90-8234-ba57b1293c71">
        <source>addRowAt(xLabel : String; xColor : Integer; _theObject : CM_Object;_index : Integer);
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx : Integer;
	
begin
	if not  self.myLegendTable.findObjectInRow(_theObject,idx) then
		self.myLegendTable.addItemAt(xLabel,_index);
		self.myLegendTable.accessRow(_index).backColor := xColor;
		self.myLegendTable.accessedRow.foreColor := xColor.getInverseColour();
		self.myLegendTable.accessedRow.alignment := Table.Alignment_Center_Middle;
//		self.myLegendTable.accessedRow.fontName := "Arial";
		self.myLegendTable.accessedRow.fontSize := 8;
		self.myLegendTable.accessedRow.itemObject := _theObject;
	endif;
end;</source>
        <Parameter name="xLabel" type="String"/>
        <Parameter name="xColor" type="Integer"/>
        <Parameter name="_theObject" type="CM_Object"/>
        <Parameter name="_index" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="contextMenu" id="3fd4c6bc-f88b-41a0-8c60-32eace9d9ead">
        <updating/>
        <source>contextMenu(cntrl: Frame input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
begin
	return self.form.CM_BaseForm.doMnuContext(cntrl,conwin,mouse, x, y);
end;</source>
        <Parameter name="cntrl" type="Frame" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="4dc83f97-6d4c-4662-931d-b9c861ebaf10">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	self.borderStyle := Table.BorderStyle_Single;
	self.boundaryWidth := 0;
	self.bevelInnerWidth := 0;
	self.bevelOuterWidth := 0;
	self.backColor := White;
	self.caption := null;
	self.enabled := true;
end;</source>
    </JadeMethod>
    <JadeMethod name="createLegendTable" id="7b426008-45d8-4443-89c3-a0de3bb48bcb">
        <updating/>
        <source>createLegendTable() updating, protected;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpTable	: CM_ColourLegendTable;
	tableCol	: JadeTableColumn;
	
begin
	create tmpTable transient;
	tmpTable.parent := self;
	tmpTable.top := 0;
	tmpTable.left := 0;
	tmpTable.width := self.clientWidth;
	tmpTable.height := self.clientHeight;
	tmpTable.columns := 1;
	tmpTable.rows := 0;
	tmpTable.scrollBars := Table.ScrollBar_Vertical;
	tmpTable.selectMode := Table.SelectMode_Row;
	
	self.myLegendTable := tmpTable;
	self.form.addControl(tmpTable);
	tmpTable.myCaller := self;
	
	tableCol := tmpTable.accessColumn(1);
	tableCol.alignment := Table.Alignment_Left_Middle;
//	tableCol.fontName := "Arial";
	tableCol.fontSize := 8;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayCargoType" id="8034d84a-06bd-4ae9-a7ff-eddce1b7d182">
        <source>displayCargoType() protected;

/*

Purpose:			Display all the Cargo Types in the legend table


Return Value:		


Date		Who		Reason
20 May 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/

vars
	cargoType : CM_CargoType;
	iter01 : Iterator;
	
begin
	self.myLegendTable.rows := 0;
	self.addRow("Cargo Type",Red,null,true);
	self.myLegendTable.fixedRows := 1;
	
	iter01 := app.myRoot.allCargoTypesById.createIterator;
	
	while iter01.next(cargoType) do
		// from 31981 skip not-available-for-entry cargo types
		if cargoType.isNotAvailableForEntry then
			continue;
		endif;
		self.addRow(cargoType.abbreviation.trimBlanks, cargoType.getDrawColour, cargoType, false);
	endwhile;
	
	
epilog
	delete iter01;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayCargoTypeEx" id="f6d59db7-4524-45f2-a14d-e066ec229d17">
        <updating/>
        <source>displayCargoTypeEx(controller : CMIF_DrawingAttrController) protected, updating;
// Add a list of cargo types to the legend table
vars
	cargoType : CM_CargoType;
	viewObjectColour : CM_ViewObjectColour;
	iter : Iterator;
begin
	self.viewMode := VIEW_CARGO_TYPE; 
	self.myLegendTable.rows := 0;
	self.addRow("Cargo Type", Red, null,true);
	self.myLegendTable.fixedRows := 1;
	
	iter := controller.allCargoTypes.createIterator;
	while iter.next(viewObjectColour) do
		cargoType := viewObjectColour.myObject.CM_CargoType;
		self.addRow(viewObjectColour.code, viewObjectColour.colour,cargoType,false);
	endwhile;
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="controller" type="CMIF_DrawingAttrController"/>
    </JadeMethod>
    <JadeMethod name="displayCarrier" id="ddca820a-8480-498c-9f61-ce7b30d1f4d3">
        <source>displayCarrier() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 June 2017	cnwmp6	Initial creation	TFS4209

*/

vars
	carrier	: CM_Carrier;
	iter01	: Iterator;
	
begin
	self.myLegendTable.rows := 0;
	self.addRow(app.getErrorString(Carrier), Red, null, true);
	self.myLegendTable.fixedRows := 1;
	
	iter01 := app.myRoot.allCarriers.createIterator;
	
	while iter01.next(carrier) do
		self.addRow(carrier.code.trimBlanks, carrier.colour, carrier, false);
	endwhile;
epilog
	delete iter01;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayCodesForMode" id="0647e750-9649-41b5-baf2-a0bb28603111">
        <updating/>
        <source>displayCodesForMode(_viewMode : Integer; _controller : CMIF_DrawingAttrController) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		March  2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 15/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// 01 Jun 2010	cnwkpd1		PAR #21914 - Improve legend load performance when loading entire table
// 29/10/2012	cnwdap1		PAR #30480 - tidy up commodity / commodity group confusion, 
//										correct display when only one colour code was found,
//										used standard error strings for column heading where available
// 09/04/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// 19/05/2022 	navtnr20 	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
// ---------------------------------------------------------------------------
vars
	tmpCommodityGroup	: CM_CommodityGroup;
	tmpConsignee		: CM_ConsigneeConsignor;
	anOperator			: CM_Operator;
	productObj			: CM_Product;
	aPort				: CM_Port;
	aVoyage				: CM_Voyage;
	aHaz : CM_HazardClass;
	aTrain				: CM_Train;
	invalidObject		: Boolean;
	theColour 			: Integer;
	theViewMode, idx	: Integer;
	theTitle			: String;
	tmpRange			: CM_TempRange;
	tmpISOGroup			: CM_ISOTypeGroup;
	tmpISO				: CM_ISOType;
	newMode				: Boolean;
	yac					: CM_YardAllocation;
	anIMEX : CM_IMEXStatus;
	tmpWeightRange		: CM_WeightRange; // (11836) 27/09/2006 cnwmo1 
	local : CMIF_DrawingAttrController;
	dwellDayRange : CM_DwellDayRange;	//20 Jul 2011	NDL	Par 27890
	mtGrade : CM_MTGrade;	//29 Jul 2011	NDL	Par 27890
	showFahr : Boolean;					// PAR #31155
	terminal : CM_Terminal;				// PAR #31155
	cargoType: CM_ViewObjectColour;
	carrier: CM_Carrier;	// 9/6/17 MAP TFS4209
	shipLine : CM_ShippingLine; //19-may-2022 navtnr20 tfs 53204

begin
	newMode := false;
	
	if self.myLegendTable.rows &gt; 0 then
		self.myLegendTable.removeItem(1);
	else
		newMode := true;
	endif;

	if self.viewMode &lt;&gt; _viewMode then
		self.myLegendTable.rows := 0;
		newMode := true;
	endif;
	
	theViewMode := _viewMode;
	self.viewMode := theViewMode;

	if theViewMode = VIEW_COMMODITY then
		//theTitle := "Commd";									// PAR #30480
		theTitle := app.getErrorString(CommodityGroup);			// PAR #30480
		foreach tmpCommodityGroup in _controller.allCommodityGroups do
			self.addRow(tmpCommodityGroup.code, tmpCommodityGroup.colour, tmpCommodityGroup, not newMode);
		endforeach;

	elseif theViewMode = VIEW_HAZ then
		theTitle := "Hazard";
		foreach aHaz in app.myRoot.allHazardClasses do
			self.addRow(aHaz.code, aHaz.colour, aHaz, not newMode);
		endforeach;
	elseif theViewMode = VIEW_HEIGHT then
		theTitle := "Heights";
		self.displayStackHeights();
	elseif theViewMode = VIEW_IMEX then
		//theTitle := "ImEx";									// PAR #30480
		theTitle := app.getErrorString(IMEX);					// PAR #30480
		foreach anIMEX in app.myRoot.allImexStatuses do
			if anIMEX.description = null then
				continue;
			endif;
			self.addRow(anIMEX.description, anIMEX.colour, anIMEX, not newMode);
		endforeach;
	
	elseif theViewMode = VIEW_DWELL then
		theTitle := "Dwell";
		self.myLegendTable.rows := 0;
		self.addRow(" &lt;= " &amp; self.dwellDays.String &amp; " Days", Blue, null,true);
		self.addRow(" &gt; " &amp; self.dwellDays.String &amp; " Days", Red, null,true);
		
	//20 Jul 2011	NDL	Par 27890
	elseif theViewMode = VIEW_DWELL_DAYS then
		theTitle := "Dwell Days";
		foreach dwellDayRange in _controller.allDwellRanges do
			self.addRow(dwellDayRange.getDisplayValue, dwellDayRange.colour, dwellDayRange, not newMode);
		endforeach;
		
	//29 Jul 2011	NDL	Par 27890
	elseif theViewMode = VIEW_MTGRADE then
		//theTitle := "Availability Grade";						// PAR #30480
		theTitle := app.getErrorString(AvailabilityGrade);		// PAR #30480
		foreach mtGrade in _controller.allAvailGrades do
			self.addRow(mtGrade.description, mtGrade.colour, mtGrade, not newMode);
		endforeach;
	
	elseif theViewMode = VIEW_YARD_ALLOC then
		on Exception do app.handleDeletedObject(exception, yac, invalidObject);
		//theTitle := "Allocations"; // PAR 23426					// PAR #30480
		theTitle := app.getErrorString(Allocations); // PAR 23426	// PAR #30480
		self.myLegendTable.rows := 0;
		 // There may be yard allocations that have been deleted in the yard allocation form 
		foreach yac in _controller.allYardAllocations do 
			invalidObject := false;
			if not invalidObject then
				self.addRow(yac.code.String, yac.color, yac,false);
			endif;
		endforeach;
	elseif theViewMode = VIEW_TEMPERATURE then
		//theTitle := "Temp.";									// PAR #30480
		theTitle := app.getErrorString(Temperature);			// PAR #30480
		terminal := self.form.CM_BaseForm.myTerminal;																			// PAR #31155
		showFahr := terminal.getConfig(TempFahForFahOperator).Boolean;															// PAR #31155
		foreach tmpRange in _controller.allTempRanges do
			if showFahr then																									// PAR #31155
				self.addRow(app.temperatureConversion(true, tmpRange.value).String &amp; Degrees_F, tmpRange.colour, tmpRange, not newMode);	// PAR #31155
			else																												// PAR #31155
				self.addRow(tmpRange.value.String &amp; Degrees_C, tmpRange.colour, tmpRange, not newMode);
			endif;																												// PAR #31155
		endforeach;
	elseif theViewMode = VIEW_WEIGHT then
	  // (11836) 27/09/2006 cnwmo1 
		//theTitle := "Weight";									// PAR #30480
		theTitle := app.getErrorString(Weight);					// PAR #30480
		foreach tmpWeightRange in _controller.allWeightRanges do
			self.addRow(tmpWeightRange.value.String, tmpWeightRange.colour, tmpWeightRange, not newMode);
		endforeach;
		// return false; (11836) 27/09/2006 cnwmo1 
/*
		theTitle := "Weight";
		foreach idx in 1 to _theSDF.myViewModeAttribute.allDisplayIcons.size do
			theCode := _theSDF.myViewModeAttribute.allDisplayIcons[idx];
			theColour := _theSDF.myViewModeAttribute.allDisplayColors[idx];
			self.addRow(theCode, theColour, null);
		endforeach;
*/
	elseif theViewMode = VIEW_CONSIGNEE then
		//theTitle := "Consign";								// PAR #30480
		theTitle := app.getErrorString(Consignee);				// PAR #30480
		foreach tmpConsignee in _controller.allConsignees do
			self.addRow(tmpConsignee.code, tmpConsignee.colour, tmpConsignee, not newMode);
		endforeach;
	//Start 19-may-2022 navtnr20 53204
	elseif theViewMode = VIEW_SHIPPINGLINE then
		theTitle := app.getErrorString(ShippingLine);												
		foreach shipLine in _controller.allShippingLines do			
			self.addRow(shipLine.code, shipLine.colour, shipLine, not newMode);
		endforeach;
	//END 19-may-2022 navtnr20 53204
	elseif theViewMode = VIEW_OPERATOR then
		//theTitle := "Operator";								// PAR #30480
		theTitle := app.getErrorString(Operator);				// PAR #30480
		foreach anOperator in _controller.allOperators do
			self.addRow(anOperator.code.trimBlanks,anOperator.colour,anOperator, not newMode);
		endforeach;
		
	elseif theViewMode = VIEW_PRODUCT then
		theTitle := app.getErrorString(Product);
		
		foreach productObj in _controller.allProducts do
			self.addRow(productObj.code.trimBlanks(), productObj.colour, productObj, not newMode);
		endforeach;
		
	elseif theViewMode = VIEW_ISOGROUP and _controller.shipShowISOType then
		//theTitle := "ISO Type";								// PAR #30480
		theTitle := app.getErrorString(ISO_Type);				// PAR #30480
		foreach tmpISO in _controller.allISOTypes do
			self.addRow(tmpISO.code.trimBlanks,tmpISO.colour,tmpISO, not newMode);
		endforeach;
	elseif theViewMode = VIEW_ISOGROUP then
		//theTitle := "ISO Grp";								// PAR #30480
		theTitle := app.getErrorString(ISO_Group);				// PAR #30480
		foreach tmpISOGroup in _controller.allISOTypeGroups do
			self.addRow(tmpISOGroup.code.trimBlanks,tmpISOGroup.colour,tmpISOGroup, not newMode);
		endforeach;
	elseif theViewMode = VIEW_VOYAGE then
		//theTitle := "Voyages";								// PAR #30480
		theTitle := app.getErrorString(Voyage);					// PAR #30480
		foreach aVoyage in _controller.allVoyages do
			if aVoyage &lt;&gt; null and app.isValidObject(aVoyage) then// par 15230
				self.addRow(aVoyage.code.trimBlanks,aVoyage.colour,aVoyage, not newMode);
			endif;
		endforeach;

	elseif theViewMode = VIEW_TRAIN then
		on Exception do app.handleDeletedObject(exception, aTrain, invalidObject);
		//theTitle := "Trains";									// PAR #30480
		theTitle := app.getErrorString(Trains);					// PAR #30480
		foreach aTrain in _controller.allTrains do
			invalidObject := false;
			theColour := aTrain.colour;
			if not invalidObject then
				self.addRow(aTrain.code.trimBlanks,theColour,aTrain, not newMode);
			endif;
		endforeach;

	elseif theViewMode = VIEW_LOADPORT then
		theTitle := "Load Port";
		foreach aPort in _controller.allLoadPorts do
			//self.addRow(aPort.portCode &amp; " " &amp; aPort.myCountry.code.trimBlanks,aPort.colour,aPort);
			self.addRow(aPort.code.trimBlanks,aPort.colour,aPort, not newMode);
		endforeach;

	elseif theViewMode = VIEW_DISPORT then
		//theTitle := "Disch Port";								// PAR #30480
		theTitle := app.getErrorString(DischargePort);			// PAR #30480
		
		foreach aPort in _controller.allDischargePorts do
			//self.addRow(aPort.portCode &amp; " " &amp; aPort.myCountry.code.trimBlanks,aPort.colour,aPort);
			self.addRow(aPort.portCode.trimBlanks,aPort.colour,aPort, not newMode);//for par13664
		endforeach;
	elseif theViewMode = VIEW_DESTPORT then
	//par 13964
		//theTitle := " Dest Port";								// PAR #30480
		theTitle := app.getErrorString(Destination_Port);		// PAR #30480
		foreach aPort in _controller.allDestinationPorts do
			self.addRow(aPort.portCode.trimBlanks,aPort.colour,aPort, not newMode);
		endforeach;

	elseif theViewMode = VIEW_CARGO_TYPE then					// 11/7/16 cnwmp6 TFS 1601
		theTitle := app.getErrorString(CargoType);
		foreach cargoType in _controller.allCargoTypes do
			self.addRow(cargoType.code, cargoType.colour, cargoType.myObject, not newMode);
		endforeach;

	elseif theViewMode = VIEW_CARRIERIN then						// 9/6/17 MAP TFS4209
		theTitle := (app.getErrorString(Receive) &amp; " " &amp; app.getErrorString(Carrier)).trimBlanks();
		foreach carrier in _controller.allCarriersIn do
			self.addRow(carrier.code.trimBlanks(), carrier.colour, carrier, not newMode);
		endforeach;
	elseif theViewMode = VIEW_CARRIEROUT then						// 9/6/17 MAP TFS4209
		theTitle := app.getErrorString(Release_carrier);
		foreach carrier in _controller.allCarriersOut do
			self.addRow(carrier.code.trimBlanks(), carrier.colour, carrier, not newMode);
		endforeach;
		
	else
		return false;
	endif;
	
	//if self.myLegendTable.rows = 1 and (not newMode) and theViewMode &lt;&gt; VIEW_YARD_ALLOC then														// PAR #30480
	if self.myLegendTable.rows = 1 and (not newMode) and theViewMode &lt;&gt; VIEW_YARD_ALLOC and self.myLegendTable.accessRow(1).itemObject = null then	// PAR #30480
		return false;
	elseif self.myLegendTable.rows = 0 then
		self.addRowAt(theTitle,Red,null,1);
	/* PAR 23426	
		if theViewMode = VIEW_YARD_ALLOC then
			self.myLegendTable.sortColumn[1] := 0;
			self.myLegendTable.sortAsc[1] := false;
			self.addRowAt("New",White, null,2);
		endif;
*/
		self.myLegendTable.fixedRows := 1;
		self.doResize;
		
		if theViewMode = VIEW_YARD_ALLOC then
			return true;
		else
			return false;
		endif;
	endif;
		
	if theViewMode &lt;&gt; VIEW_HEIGHT then
		self.myLegendTable.sortColumn[1] := 0;
		self.myLegendTable.sortAsc[1] := false;
	else
		self.myLegendTable.sortColumn[1] := 1;
		self.myLegendTable.sortAsc[1] := true;
	endif;
	/* PAR 23426
	if theViewMode = VIEW_YARD_ALLOC then
		self.myLegendTable.sortColumn[1] := 0;
		self.myLegendTable.sortAsc[1] := false;
		foreach idx in 1 to self.myLegendTable.rows reversed do
			if self.myLegendTable.accessRow(idx).itemObject = null then
				self.myLegendTable.removeItem(idx);
			endif;
		endforeach;
	endif;
	
	*/
	if theViewMode &lt;&gt; VIEW_HEIGHT then
		self.addRowAt(theTitle,Red,null,1);
	endif;
// PAR 23426	if theViewMode = VIEW_YARD_ALLOC then
// PAR 23426		self.addRowAt("New",White, null,2);
// PAR 23426	endif;

	self.myLegendTable.fixedRows := 1;
	self.doResize;

	return true;
end;</source>
        <Parameter name="_viewMode" type="Integer"/>
        <Parameter name="_controller" type="CMIF_DrawingAttrController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="displayCommodity" id="62d6f1db-92fe-4d7a-beed-8d09415b9f07">
        <source>displayCommodity() protected;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	lCommodity : CM_Commodity;
	iter01 : Iterator;
	
begin
