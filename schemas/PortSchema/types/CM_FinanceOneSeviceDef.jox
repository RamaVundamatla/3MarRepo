        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="cde2894b-5b76-4f51-a448-6fde253347cc">
        <source>validateMe() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 March 2023	jlier1	Initial creation 56856

*/

vars

	ext,realMe : CM_ExternalWebServiceDef;
begin
	inheritMethod();
	if self.userCode = null then
		app.raiseCMException1(Input_required_field_Required, app.getString(User), self.userCode, null);
	endif;
	if self.password = null then
		app.raiseCMException1(Input_required_field_Required, app.getString(Password), null, null);
	endif;
	
	 // Check if there is already an active Ext Web Service def of our type
    if self.active then
		realMe := self.pxyGetRealObject();
        foreach ext in app.myRoot.allExternalWebServices discreteLock where ext.active do
            if ext.isKindOf(CM_FinanceOneSeviceDef) then
                if realMe = null or ext &lt;&gt; realMe then
                    app.raiseCMException2(ERR_Active_ExtWebDef, ExternalWebServiceFinanceOne, ext.name, null, null);
                    break;
                endif;
            endif;
        endforeach;
    endif;	

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
