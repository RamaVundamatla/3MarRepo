	endforeach;
//	write stateInvalid.String &amp; " State Objects with " &amp; stateStringInvalid.String &amp; " invalid strings";
	file.writeLine(stateInvalid.String &amp; " State Objects with " &amp; stateStringInvalid.String &amp; " invalid strings");
//	write stringsAttachedToObjects.String &amp; " CM_Objects objects actually attached to a CM_DataObject instance";
	file.writeLine(stringsAttachedToObjects.String &amp; " CM_StateString objects actually attached to a CM_StateObject instance");
//	write "Latest invalid state data string from State Objects was in " &amp; year.String;
	file.writeLine("latest invalid state data string from State Objects was in " &amp; year.String);
	
	file.writeLine(vvrPre2014Count.String &amp; "  CM_StateString prior to 2014, with " &amp; vvrPre2014DetailCount.String 		  &amp; " Parents");
	file.writeLine(vvrPre2015Count.String &amp; " CM_StateString records prior to 2015, with " &amp; vvrPre2015DetailCount.String &amp; " Parents");
	file.writeLine(vvrPre2016Count.String &amp; " CM_StateString records prior to 2016, with " &amp; vvrPre2016DetailCount.String &amp; " Parents");
	
	*/
	
	progress := null;
	
	
	nbr := CM_AuditObject.instances.size;
//	write nbr.String &amp; " State Data to process";
	file.writeLine(nbr.String &amp; " detail");
	//year := null;
	foreach thing  in CM_AuditObject.instances do
	
		
		if app.isValidObject(thing) and	thing &lt;&gt; null  then
		
		
			
		
		//	myParentCount := (stateData.myParent &lt;&gt; null).Integer;
			
			// prior to 1/1/2014?
			if thing.createdTime.Date.year &lt; 2014 then
				vvrPre2014Count := vvrPre2014Count + 1;
			//	vvrPre2014DetailCount := vvrPre2014DetailCount  + myParentCount;
			endif;
			// prior to 1/1/2015?
			if thing.createdTime.Date.year &lt; 2015 then
				vvrPre2015Count := vvrPre2015Count + 1;
			//	vvrPre2015DetailCount := vvrPre2015DetailCount  + myParentCount;
			endif;
			// prior to 1/1/2016?
			if thing.createdTime.Date.year &lt; 2016 then
				vvrPre2016Count := vvrPre2016Count + 1;
			//	vvrPre2016DetailCount := vvrPre2016DetailCount  + myParentCount;
			endif;
				
		endif;
		
	endforeach;
//	write stateInvalid.String &amp; " State Objects with " &amp; stateStringInvalid.String &amp; " invalid strings";
//	file.writeLine(stateInvalid.String &amp; " State Objects with " &amp; stateStringInvalid.String &amp; " invalid strings");
///	write stringsAttachedToObjects.String &amp; " CM_Objects objects actually attached to a CM_DataObject instance";
//	file.writeLine(stringsAttachedToObjects.String &amp; " CM_StateString objects actually attached to a CM_StateObject instance");
//	write "Latest invalid state data string from State Objects was in " &amp; year.String;
//	file.writeLine("latest invalid state data string from State Objects was in " &amp; year.String);
	
	
	file.writeLine("2014" &amp; Tab &amp;"2015" &amp; Tab &amp;"2016");
	file.writeLine(vvrPre2014Count.String  &amp; Tab &amp; vvrPre2015Count.String &amp; Tab &amp; vvrPre2016Count.String );
//	file.writeLine(vvrPre2014DetailCount.String &amp; Tab &amp; vvrPre2015DetailCount.String &amp; Tab &amp; vvrPre2016DetailCount.String);
		
	/*
	nbr := CM_StateObject.instances.size;
	write nbr.String &amp; " State Objects to process";
	file.writeLine(nbr.String &amp; " State Objects to process");
	year := null;
	foreach stateObject in CM_StateObject.instances do
		progress := progress + 1;
		if progress mod 200000 = 0 then
			write progress.String &amp; " state objects read";
		endif;
		
		// check strings are all valid
		badString := false;
		handledEx := false;
		badStrings := null;
		stringsAttachedToObjects := stringsAttachedToObjects + stateObject.allStateData.size;
		foreach stateData in stateObject.allStateData do
			handledEx := false;
			badString := false;
			idx := stateData.key.pos("-", 1);
			if idx &lt;&gt; null then
				oid := stateData.key[idx+1:stateData.key.length-idx];
				obj := oid.asObject;
				obj.creationTime;
				if handledEx then
					stateStringInvalid := stateStringInvalid + 1;
					if stateData.createdTime.date.year &gt; year then
						year := stateData.createdTime.date.year;
					endif;
					badString := true;
					badStrings := badStrings + 1;
				endif;
			endif;
		endforeach;
		//if badString then
		if badStrings = stateObject.allStateData.size then
			stateInvalid := stateInvalid + 1;
		endif;
	endforeach;
	write stateInvalid.String &amp; " State Objects with " &amp; stateStringInvalid.String &amp; " invalid strings";
	file.writeLine(stateInvalid.String &amp; " State Objects with " &amp; stateStringInvalid.String &amp; " invalid strings");
	write stringsAttachedToObjects.String &amp; " CM_StateString objects actually attached to a CM_StateObject instance";
	file.writeLine(stringsAttachedToObjects.String &amp; " CM_StateString objects actually attached to a CM_StateObject instance");
	write "Latest invalid state data string from State Objects was in " &amp; year.String;
	file.writeLine("latest invalid state data string from State Objects was in " &amp; year.String);

*//*
	progress := null;
	year := null;
//	nbr := CM_StateString.instances.size;
//	write nbr.String &amp; " State Strings to process";
//	file.writeLine(nbr.String &amp; " State Strings to process");
	create stringKeys transient;
	foreach stateData in CM_StateString.instances do
		progress := progress + 1;
		if progress mod 200000 = 0 then
			write app.actualTimeServer.Time.format("HH:mm:ss") &amp; Tab &amp; progress.String &amp; " state objects read, " &amp; stateInvalid.String &amp; " strings with invalid myStateObject, " &amp; stateStringNoParent.String &amp; " strings with no parent, " &amp; stateStringInvalid.String &amp; " invalid string keys from " &amp; stateStringToCheck.String &amp; " strings to check";
			//if progress &gt; 10000000 then
			//	break;
			//endif;
		endif;
		
		// check strings are all valid
		if stateData.myStateObject &lt;&gt; null and not app.isValidObject(stateData.myStateObject) then
			stateInvalid := stateInvalid + 1;
			if stateData.createdTime.date.year &gt; year then
				year := stateData.createdTime.date.year;
			endif;
		elseif stateData.myStateObject = null and stateData.myTrackedItem = null and stateData.myBOL = null and stateData.myParent = null then
			stateStringNoParent := stateStringNoParent + 1;
			if stateData.createdTime.date.year &gt; year then
				year := stateData.createdTime.date.year;
			endif;
		elseif stateData.myTrackedItem = null and stateData.myBOL = null and stateData.myParent = null then
			stateStringToCheck := stateStringToCheck + 1;
			
			idx := stateData.key.pos("-", 1);
			if idx &lt;&gt; null then
				oid := stateData.key[idx+1:stateData.key.length-idx];
				key := stateData.key[1:idx-1];
				obj := oid.asObject;
				obj.creationTime;
				if handledEx then
					stateStringInvalid := stateStringInvalid + 1;
					if stateData.createdTime.date.year &gt; year then
						year := stateData.createdTime.date.year;
					endif;
					badStrings := badStrings + 1;
				endif;
				idx := stringKeys.indexOf(key);
				if idx = null then
					stringKeys.add(key);
					numTIs.add(0);
					idx := stringKeys.indexOf(key);
				endif;
				numTIs[idx] := numTIs[idx] + 1;
			endif;
		else
			if stateData.myBOL &lt;&gt; null then
				if stateData.key = "ActualPieceCountError" then
					continue;
				endif;
				if stateData.key = "OPID" then
					oid := "opid";
				else	
					oid := stateData.key;
				endif;
				key := stateData.myBOL.getPropertyValue(oid).String;
				if key = stateData.CM_StateString.value then
					keySame := keySame + 1;
					//if not stringKeys.includes(stateData.key) then
					//	stringKeys.add(stateData.key);
					//endif;
				endif;
			endif;					
		endif;
	endforeach;
	write stateStringInvalid.String &amp; " StateStrings with invalid parent and " &amp; stateStringNoParent.String &amp; " with no parent and " &amp; stateStringToCheck.String &amp; " state strings to check for valid keys";
	write keySame.String &amp; " StateStrings with value the same as the BOL attribute of the same name";
	file.writeLine(stateStringInvalid.String &amp; " StateStrings with invalid parent and " &amp; stateStringNoParent.String &amp; " with no parent and " &amp; stateStringToCheck.String &amp; " state strings to check for valid keys");
	file.writeLine(keySame.String &amp; " StateStrings with value the same as the BOL attribute of the same name");
	write "Latest invalid state data string from State Strings was in " &amp; year.String;
	file.writeLine("latest invalid state data string from State Strings was in " &amp; year.String);
	write badStrings.String &amp; Tab &amp; "badStrings";
	foreach idx in 1 to stringKeys.size do
		write stringKeys[idx] &amp; Tab &amp; numTIs[idx].String;
		file.writeLine(stringKeys[idx] &amp; Tab &amp; numTIs[idx].String);
	endforeach;

/*	progress := null;
	foreach wharfage in CM_Wharfage.instances do
		progress := progress + 1;
		if progress mod 200000 = 0 then
			write progress.String &amp; " wharfage transactions read";
		endif;
		
		if wharfage.myTrackedItem = null or not app.isValidObject(wharfage.myTrackedItem) then
			wharfageCount := wharfageCount + 1;
		elseif wharfage.myTrackedItem &lt;&gt; null and wharfage.myTrackedItem.myVoyage &lt;&gt; null and not app.isValidObject(wharfage.myTrackedItem.myVoyage) then
			wharfageCount := wharfageCount + 1;
		endif;
	endforeach;
	write wharfageCount.String &amp; " Wharfage transactions with no TI or TI for an invalid voyage";
	file.writeLine(wharfageCount.String &amp; " Wharfage transactions with no TI or TI for an invalid voyage");
	
	progress := null;
	foreach inspect in CM_Inspect.instances do
		progress := progress + 1;
		if progress mod 200000 = 0 then
			write progress.String &amp; " inspect transactions read";
		endif;
		
		if inspect.myTrackedItem = null or not app.isValidObject(inspect.myTrackedItem) then
			inspectCount := inspectCount + 1;
		elseif inspect.myTrackedItem &lt;&gt; null and inspect.myTrackedItem.myVoyage &lt;&gt; null and not app.isValidObject(inspect.myTrackedItem.myVoyage) then
			inspectCount := inspectCount + 1;
		endif;
	endforeach;
	write inspectCount.String &amp; " Inspect transactions with no TI or TI for an invalid voyage";
	file.writeLine(inspectCount.String &amp; " Inspect transactions with no TI or TI for an invalid voyage");
*/
	progress := null;
	if years = null then
		create years transient;
	endif;
	years.clear;
	if numTIs = null then
		create numTIs transient;
	endif;
	numTIs.clear;
	if stringKeys = null then
		create stringKeys transient;
	endif;
	stringKeys.clear;
	create jdoArray transient;
	nbr := CM_AuditObject.instances.size;
	write nbr.String &amp; " CM_AuditObjects to read";
	file.writeLine(nbr.String &amp; " CM_AuditObjects to read");
	foreach audit in CM_AuditObject.instances do
		progress := progress + 1;
		if progress mod 200000 = 0 then
			write progress.String &amp; " audit objects read";
		endif;
		
		if audit.mySubject &lt;&gt; null then
			if not app.isValidObject(audit.mySubject) then
				invalidSubject := invalidSubject + 1;
			endif;
			continue;
		endif;
		
		date := audit.timestamp.Date;
		year := date.year;
		idx := years.indexOf(year);
		if idx = null then
			years.add(year);
			idx := years.indexOf(year);
		endif;
		if numTIs.size &lt; idx then
			numTIs.add(0);
		endif;
		numTIs[idx] := numTIs[idx] + 1;
		// what is this audit for?
		str := audit.getSubjectClassName;
		found := false;
		foreach jdo in jdoArray do
			if jdo.getPropertyValue("subjectClass").String = str and jdo.getPropertyValue("year").Integer = year then
				nbr := jdo.getPropertyValue("count").Integer + 1;
				jdo.setPropertyValue("count", nbr);
				found := true;
				break;
			endif;
		endforeach;
		if not found then 
			create jdo transient;
			jdo.addProperty("subjectClass", String);
			jdo.addProperty("year", Integer);
			jdo.addProperty("count", Integer);
			jdo.setPropertyValue("subjectClass", str);
			jdo.setPropertyValue("year", year);
			jdo.setPropertyValue("count", 1);
			jdoArray.add(jdo);
		endif;
		
	endforeach;
	write invalidSubject.String &amp; " Audit Objects with an invalid subject";
	file.writeLine(invalidSubject.String &amp; " Audit Objects with an invalid subject");
	foreach jdo in jdoArray do
		write jdo.getPropertyValue("subjectClass").String &amp; Tab &amp; jdo.getPropertyValue("year").Integer.String &amp; Tab &amp; jdo.getPropertyValue("count").Integer.String;
	endforeach;

write "Done";
epilog
	foreach idx in 1 to years.size do
		//write years[idx].String &amp; " has " &amp; numTIs[idx].String &amp; " errors";
		//file.writeLine(years[idx].String &amp; " has " &amp; numTIs[idx].String &amp; " errors");
		write years[idx].String &amp; " has " &amp; numTIs[idx].String &amp; " logs";
		file.writeLine(years[idx].String &amp; " has " &amp; numTIs[idx].String &amp; " logs");
	endforeach;
	delete years;
	delete numTIs;
	delete stringKeys;
	if jdoArray &lt;&gt; null then
		jdoArray.purge;
	endif;
	delete jdoArray;
	delete bolsToDelete;
	file.close;
	delete file;
end;
</source>
    </JadeMethod>
    <JadeMethod name="aBitOfAnalysisTemp" id="e5d7eec8-eded-4d33-95c5-9e4774c9b912">
        <source>aBitOfAnalysisTemp();

vars
	file : DbFile;
	class : Class;
	name : String;
	schema, portSchema : Schema;
	classColl : ClassColl;
	skip : Boolean;
begin
	foreach schema in Schema.instances do
		if schema.name = "PortSchema" then
			portSchema := schema;
			break;
		endif;
	endforeach;
	if portSchema = null then
		write "didn't find PortSchema";
		return;
	endif;
	create classColl transient;
	CM_Object.allSubclasses(classColl);
	CM_Query.allSubclasses(classColl);
	CM_Transient.allSubclasses(classColl);
	CMIF_Object.allSubclasses(classColl);
	//classColl.inspectModal;
	skip := true;
	foreach class in classColl where not class.abstract do
		if class.name.isOneOf(CM_EDIRule.name, CM_NavigationEntity.name, CM_NavObjectDef.name, CM_OfflineActorHandler.name,
		CM_EnqControllerTransaction.name, CM_EnqControllerCargoTrans.name, CM_EnqControllerEventTrans.name, CM_EnqControllerHMSTrans.name, 
		 CMIF_OrganisationCargoItem.name, CMIF_OutputFormatAgent_VoyKPI.name, CMIF_OutputFormatAgent_Counter.name, CMIF_OutputFormatAgent_ROROKPI.name,
		CMIF_OutputFormatAgent_XTAB.name) then
			continue;
		endif;
		if class.abstract then
			continue;
		endif;
		if class.name = CMIF_OutputFormatAgent_SS.name then
			skip := false;
		endif;
		if skip then continue; endif;
		file := class.getDbFile;
		if file = null then
			continue;
		endif;
		name := file.name;
		write name &amp; Tab &amp; class.name &amp; Tab &amp; class.instances.size.String;
	endforeach;
epilog
	delete classColl;
end;</source>
    </JadeMethod>
    <JadeMethod name="aDP2988" id="0a309921-0690-4d1e-aecb-a9c02740223c">
        <source>aDP2988(_cmif : CMIF_CalcTypeQuantityHook) : Real;
//23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
vars
	newQty : Real;
	transactionDate : TimeStamp;
	theTI : CM_TrackedItem;
	theVoyage : CM_Voyage;
	dischargeDays, daysStored, freeDays, graceDays, coveredDays, chargedDays, storageExpiryDays : Integer;
	storageDetail	: CM_StorageDetail;
	grossRevenueTonnes, totalWeight, totalVolume : Decimal[12,4]; 
	
	receivedByShip : String;
begin
	newQty := _cmif.origQty;
	
	transactionDate := _cmif.myTransaction.CM_TITransaction.dateTime;
	
	app.invLog("Hook Code for " &amp; _cmif.myTransaction.getTypeString() &amp; " transaction. Original Quantity is " &amp; _cmif.origQty.String, LogINFO.String);
		
	// ### IF ANY NULLS RETURN ORIGINAL QUANTITY
	theTI := _cmif.myTransaction.CM_TITransaction.myTrackedItem;
		if theTI = null then
		app.invLog("TI is null", LogINFO.String);
		return _cmif.origQty;
	endif;
	
	
	totalVolume := theTI.totalVolume;
	//totalVolume := _cmif.myTransaction.CM_TITransaction.totalVolume;
	
	totalWeight := theTI.totalWeight;
	//totalWeight := _cmif.myTransaction.CM_TITransaction.totalWeight;
	
	if totalWeight = null and totalVolume = null then
	app.invLog("Weight and Volume both are null, return original quantity " &amp; _cmif.origQty.String, LogINFO.String);
		return _cmif.origQty;
	endif;
	
	app.invLog("Checking received by Ship?", LogINFO.String);
	
	receivedByShip := theTI.receiptTransportMode.String;// = TI_TRANSMODE_SHIP;
		
	/*if not receivedByShip then
		app.invLog("Yes, theTI.receiptTransportMode is NOT ReceivedByShip");
		// ### DETERMINE GRT
		
		if totalVolume &gt; (totalWeight / 1000) then
			grossRevenueTonnes := totalVolume;
		else
			grossRevenueTonnes := totalWeight / 1000;
		endif;
		
		// _cmif.origQty is the number of days storage.
		return _cmif.origQty * grossRevenueTonnes;
	
	endif;
	*/
	theVoyage := theTI.myVoyage;
	app.invLog("Checking if theVoyage = null ", LogINFO.String);
	
	if theVoyage = null then
		return _cmif.origQty;
	endif;
	
	app.invLog("theVoyage.arrivedDT.isValid() ", LogINFO.String);
	
	if not theVoyage.arrivedDT.isValid() then
		return _cmif.origQty;
	endif;
	
		
	/*if not theVoyage.shipExchangeCompleteDT.isValid() then
		return _cmif.origQty;
	endif;
	*/
	app.invLog("theTI.receivedDT.isValid()", LogINFO.String);
	
	if not theTI.receivedDT.isValid() and not theTI.getStatusCode = 'EXP' then
		return _cmif.origQty;
	endif;
	
	
	// ### GET THE CONFIGURED FREE STORAGE DETAIL FOR THIS CARGO ITEM
	storageDetail := theTI.getMatchingFreeStorageDetail( null );
	
	if storageDetail = null then
	
		app.invLog("No storageDetail for " &amp; _cmif.myTransaction.getTypeString() &amp; " transaction", LogINFO.String);
		return _cmif.origQty;
	endif;
	
	app.invLog("StorageDetail free days is  " &amp; storageDetail.freeStorageDays.String &amp; " days for " &amp; _cmif.myTransaction.getTypeString() &amp; " transaction", LogINFO.String);
	
	// ### CALCULATE THE NUMBER OF DAYS FROM VOYAGE ARRIVAL TO CARGO RELEASE: +1 BECAUSE DAYS ARE INCLUSIVE 
		daysStored := (transactionDate.Date - theVoyage.arrivedDT.date) + 1;

		
	// ### A MAXIMUM OF 4 DAYS GRACE IS ALLOWED FOR DISCHARGE AFTER THAT STORAGE APPLIES.
	// ### DETERMINE IF GRACE PERIOD HAS BEEN EXCEEDED
	if theVoyage.shipExchangeCompleteDT.isValid() then
	dischargeDays := theVoyage.shipExchangeCompleteDT.date -  theVoyage.arrivedDT.date;
	
	app.invLog("Exchange complete - Voyage arrival Date in days is  " &amp; dischargeDays.String &amp; " days for " &amp; _cmif.myTransaction.getTypeString() &amp; " transaction", LogINFO.String);
	
	if dischargeDays &gt; 4 then
		graceDays := 4;
	else
		graceDays := dischargeDays;
	endif;
	
	endif;
	// ### ADJUST FREE STORAGE DAYS TAKING GRACE PERIOD INTO ACCOUNT
	
		freeDays := storageDetail.freeStorageDays + graceDays;
	
	// ### CALCULATE STORAGE DAYS TO BE CHARGED
	
		chargedDays := daysStored - freeDays;
		
		
	//## Setting the Free Storage Days correctly for Cargo Enquiry and for Receipt printing
	if dischargeDays &gt; 4 then
	app.invLog("Setting free storage days", LogINFO.String);
	storageExpiryDays:=theTI.receivedDT.Date - theVoyage.arrivedDT.date;
	app.invLog("storageExpiryDays for Cargo Free Storage Expiry Date: " &amp; storageExpiryDays.String, LogINFO.String);
	theTI.setFreeStorageDays(freeDays-storageExpiryDays);
	app.invLog("Free days = " &amp; freeDays.String, LogINFO.String);
	app.invLog("Free storage days updated ", LogINFO.String);
	endif;
	if chargedDays &lt; 0 then
		chargedDays := 0;		
	endif;
	// ### DETERMINE GRT
		
		if totalVolume &gt; (totalWeight / 1000) then
			grossRevenueTonnes := totalVolume;
		else
			grossRevenueTonnes := totalWeight / 1000;
		endif;
		
	// ### MULTIPLY CHARGED DAYS BY GRT TO GET NEW QUANTITY
	
		newQty := chargedDays * grossRevenueTonnes;
	
	app.invLog("Grace days = " &amp; graceDays.String, LogINFO.String);
	app.invLog("Original Qty is " &amp; _cmif.origQty.String, LogINFO.String);
	app.invLog("Days Charged is " &amp; chargedDays.String, LogINFO.String);
	app.invLog("Total Weight is " &amp; totalWeight.String, LogINFO.String);
	app.invLog("Total Volume is " &amp; totalVolume.String, LogINFO.String);
	app.invLog("GRT is " &amp; grossRevenueTonnes.String, LogINFO.String);
	app.invLog("Chargable Qty is " &amp; newQty.String, LogINFO.String);
	
	return newQty;
end;</source>
        <Parameter name="_cmif" type="CMIF_CalcTypeQuantityHook"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="aDP6672" id="bc3bcbd6-d881-490f-96c2-f4bded9ec6b2">
