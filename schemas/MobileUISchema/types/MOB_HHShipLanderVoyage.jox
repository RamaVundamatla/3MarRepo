epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupControls" id="43e644ec-52fe-426b-b7df-039cca8d3d15">
        <updating/>
        <source>setupControls() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	voyage : CM_Voyage;
	bols : CM_ObjectArray;
	bol : CM_BOL;
	
begin
						 
	self.cmbVoyage.clear();
	self.myMobileGenericAgent.setCurrentVoyages();
	self.cmbVoyage.addItem(lblVoyage.caption);
	foreach voyage in self.myMobileGenericAgent.allCurrentVoyages do
		if voyage.isNullVoyage then
			continue;
		endif;
		if self.myMobileGenericAgent.myTerminal.getConfig(VesselNameOnVoyageCombo).Boolean then //cnwrd1 nfs 31095
			self.cmbVoyage.itemObject[self.cmbVoyage.addItem(voyage.code &amp; Tab &amp; voyage.vesselName )] := voyage;
		else
			self.cmbVoyage.itemObject[self.cmbVoyage.addItem(voyage.code)] := voyage;
		endif;
	endforeach;
	
	voyage := self.myMobileGenericAgent.myVoyage;
	
	if voyage &lt;&gt; null and cmbVoyage.findObject(voyage) &gt; 0 then
		cmbVoyage.listIndex := cmbVoyage.findObject(voyage);
	elseif cmbVoyage.listCount = 2 then
		cmbVoyage.listIndex := 2;
	else
		cmbVoyage.listIndex := 1;
	endif;
	
	
/*	self.cmbBOL.visible := true;
	self.cmbBOL.move( self.MARGIN,
						 self.MARGIN + self.cmbVoyage.height + self.cmbVoyage.top,
						 self.clientWidth - self.MARGIN - self.MARGIN,
						 stdHeight ); */
						 
	self.doResizeControls(true);
						 
	self.populateBOL();
	
	setActionButtons();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="c849a6e5-fb62-40d6-9934-6930a894e710">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

begin

	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	self.setupCmdButtons( 2, app.getErrorString(Next), app.getErrorString(Back), null, null, null );
	self.btnOne.enabled := false;
	
	inheritMethod();
	
	setupControls();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="dd35a03f-84d0-4f7e-8b3b-00a010be7bd8">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014428, locale);
	lblBOL.translateCaption(Xlat_0013974, locale);
	lblVoyage.translateCaption(Xlat_0013975, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
