    <JadeMethod name="deleteDirectory" id="fa4b80be-f9ef-499d-a0e4-5f198609ca8c">
        <updating/>
        <source>deleteDirectory(pDirectoryName:String; pNodeOptions:Integer):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		09 July 2002 by cnwdad2
//
// Purpose:		Deletes the specified directory on the specified source node.
//
// Parameters:	pDirectoryName - The path name of the directory to delete.
//				pNodeOptions - Specifies the source JADE node.
//
// Returns:		True if the operation succeeded, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	sourceNode		: Integer;
	
begin
	on Exception do self.xHandler(exception);
	
	self.doFileErrorSet(0, null);
	
	if self.interpretSourceNodeOptions(pNodeOptions, sourceNode) then
		
		if sourceNode = JSSFMFileManagerService.NODE_SOURCE_CLIENT then
			return self.deleteDiskDirectoryClient(pDirectoryName);
		elseif sourceNode = JSSFMFileManagerService.NODE_SOURCE_APPSERVER then
			return self.deleteDiskDirectoryAppServer(pDirectoryName);
		elseif sourceNode = JSSFMFileManagerService.NODE_SOURCE_DBSERVER then
			return self.deleteDiskDirectoryDbServer(pDirectoryName);
		endif;
		
	endif;
epilog
	on Exception do null;
	
	self.doFileErrorCheck();
end;</source>
        <Parameter name="pDirectoryName" type="String"/>
        <Parameter name="pNodeOptions" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="deleteDiskDirectory" id="6759ccf1-d337-4570-90ce-5b7028e84153">
        <updating/>
        <source>deleteDiskDirectory(pDirectoryName:String; pIsPresentationFileSystem:Boolean):Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		02 July 2002 by cnwdad1
//
// Purpose:		Deletes the specified disk directory.
//
// Parameters:	pDirectoryName - The path name of the directory to delete.
//				pIsPresentationFileSystem - For thin client nodes, this flag indicates
//					whether to use the thin client's own file system rather than the
//					Application Server node's file system.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	diskFolderObj	: FileFolder;
	theDiskNode		: FileNode;
	returnValue		: Boolean;
	
begin
	create diskFolderObj transient;
	diskFolderObj.usePresentationFileSystem	:=	pIsPresentationFileSystem;
	diskFolderObj.fileName					:=	pDirectoryName;
	
	returnValue	:=	true;
	
	foreach theDiskNode in diskFolderObj.files() do
		if theDiskNode.isKindOf(FileFolder) then
			if not deleteDiskDirectory(theDiskNode.fileName, pIsPresentationFileSystem) then
				returnValue	:=	false;
			endif;
				
		else
			if not self.deleteDiskFile(theDiskNode.fileName, pIsPresentationFileSystem) then
				returnValue	:=	false;
			endif;
		endif;
		
		if self.errorCode &lt;&gt; 0 then
			returnValue	:=	false;
			break;
		endif;
	endforeach;
	
	if returnValue then
		diskFolderObj.purge();
	endif;
epilog
	delete diskFolderObj;
	
	return returnValue;
end;</source>
        <access>protected</access>
        <Parameter name="pDirectoryName" type="String"/>
        <Parameter name="pIsPresentationFileSystem" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="deleteDiskDirectoryAppServer" id="c1f39f1e-1006-49d9-bff1-954e358c61cf">
