    <JadeMethod name="getName" id="78183e82-51db-4299-8f0a-99127a525c37">
        <source>getName(): String;
// ---------------------------------------------------------------------------
// Created:     14 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.myType = null then
		return inheritMethod() &amp; ' (' &amp; self.id &amp; ')';
	else
		if self.myType.description.trimBlanks = null then
			return inheritMethod() &amp; ' ' &amp; self.id.trimBlanks;
		else
			return inheritMethod() &amp; ' ' &amp; self.myType.description &amp; ' (' &amp; self.id.trimBlanks &amp; ')';
		endif;
	endif;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNetBalance" id="1caf8e5a-b3a8-44d0-b749-93ce49ac4afd">
        <source>getNetBalance(	_balAct : CMEVT_LocationActivity;
				_toAct : CMEVT_LocationActivity;
				_netQuantity : Integer output;
				_netVolume : Decimal output;
				_netWeight : Decimal output
				);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	iter : Iterator;
	startObject : CMEVT_LocationActivity;
	locAct : CMEVT_LocationActivity;

begin

	iter := self.allLocationActivity.createIterator;
	if _balAct &lt;&gt; null then
		iter.startAtObject( _balAct );
	endif;
	
	while iter.next( locAct ) do
	
		if _balAct &lt;&gt; null and locAct = _balAct then
			_netQuantity := locAct.quantity;
			_netVolume := locAct.volume;
			_netWeight := locAct.weight;
			continue;
		endif;
		if locAct.cargoType &lt;&gt; _toAct.cargoType then
			continue;
		endif;
		if locAct.operatorCode &lt;&gt; _toAct.operatorCode then
			continue;
		endif;
		if locAct.isLocationBalance then
			break;
		endif;
		if locAct.isLocationMove and locAct.mySourceTA = self and locAct.myTargetTA = self then
			//moving from one of our sub areas to one of our other sub areas, i.e. no change at this level
			continue;
		endif;
		if locAct.isLocationDiscrepancyDecrease 
		or ( locAct.isLocationMove and locAct.mySourceTA = self ) then
			_netQuantity := _netQuantity - locAct.quantity;
			_netVolume := _netVolume - locAct.volume;
			_netWeight := _netWeight - locAct.weight;
		elseif locAct.isLocationDiscrepancyIncrease
		or ( locAct.isLocationMove and locAct.myTargetTA = self ) then
			_netQuantity := _netQuantity + locAct.quantity;
			_netVolume := _netVolume + locAct.volume;
			_netWeight := _netWeight + locAct.weight;
		endif;
		if locAct = _toAct then
			break;
		endif;
	endwhile;

epilog

	delete iter;

end;</source>
        <Parameter name="_balAct" type="CMEVT_LocationActivity"/>
        <Parameter name="_toAct" type="CMEVT_LocationActivity"/>
        <Parameter name="_netQuantity" type="Integer" usage="output"/>
        <Parameter name="_netVolume" type="Decimal" usage="output"/>
        <Parameter name="_netWeight" type="Decimal" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getNextQuickCargoID" id="c173caaa-5b3e-4b09-8037-e8cde59dc271">
        <source>getNextQuickCargoID(_cargoType : Integer) : String;
// ---------------------------------------------------------------------------
// Created:     05 January 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aTI : CM_TrackedItem;
	nextID, numId : String;
	nextNum : Integer;
	now : Date;
begin
	nextNum := (now.formatAsYYMMDD() &amp; "1").asIntegerJMT;

	while true do
		nextID := "CNTU" &amp; nextNum.String;
			if self.myTerminal.allOnsiteTIsByIdCargoType[nextID,_cargoType] = null then
				return nextID;
			endif;
		nextNum := nextNum + 1;
	endwhile;
	
	return nextID;
epilog

end;</source>
        <Parameter name="_cargoType" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNoAccessString" id="73c08c21-6473-452b-b9ef-f1c9d11e4771">
