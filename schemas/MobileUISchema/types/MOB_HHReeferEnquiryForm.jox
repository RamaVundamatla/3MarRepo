    <JadeMethod name="setCaption" id="d59e307b-5b58-4f76-a58e-1a4f79964524">
        <updating/>
        <source>setCaption() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2013	cnwndl1	Initial creation

*/

