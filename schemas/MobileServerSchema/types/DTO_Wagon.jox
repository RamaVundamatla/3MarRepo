    <JadeMethod name="buildDTOWagonPositions" id="42f9bfc2-a5a2-44c4-807f-ef953a907713">
        <source>buildDTOWagonPositions();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 November 2009	cnwer1	Initial creation

*/

vars
	idx,
	lengthUnit,
	stackHeight		 : Integer;
	dtoWagonsToDelete : ObjectSet;
	dtoWagonPos		: DTO_WagonPosition;
	dtoContainer	: DTO_ContainerInfo;
	wagonController	: CM_WagonController;
	ti				: CM_TrackedItem;
begin
	create dtoWagonsToDelete transient;
	self.allDTOWagonPositions.copy(dtoWagonsToDelete);
	
	stackHeight:=1;
	
	//may need to change because if container is in position 2 what happens ? 
	//for now leave
	idx :=null;
	foreach lengthUnit in 1 to self.myWagonClass.getLenInUnits step 2 do
		stackHeight:=1;
		if lengthUnit + 1 &gt; self.myWagonClass.getLenInUnits then
			//there's only one 10ft slot left - doesn't qualify as a valid container pos
			break;
		endif;
		idx := idx + 1;
		
		//also poulate with existing TI if there is one at the location
		while stackHeight &lt;= self.myWagonClass.maxNumInStack do
			ti:=null;
			dtoWagonPos:=self.getDTOWagonPosition(idx,stackHeight);
			dtoContainer:=dtoWagonPos.myDTOContainer;
			if dtoWagonsToDelete.includes(dtoWagonPos) then
				dtoWagonsToDelete.remove(dtoWagonPos);
			endif;
		
			if self.myWagon &lt;&gt; null and 
				(not self.myWagon.allLocationsControllersArray.isEmpty) and
				(self.myWagon.allLocationsControllersArray.size &gt;= lengthUnit) then
				wagonController := self.myWagon.allLocationsControllersArray[lengthUnit];
			
				if wagonController &lt;&gt; null then
					if wagonController.allTrackedItems.size &gt; 0 and wagonController.allTrackedItems.size &gt;= stackHeight then
						ti := wagonController.allTrackedItems[stackHeight];
					endif;
					
					if ti &lt;&gt; null and 
					   ti.myPrimaryActualLocation = wagonController then //check that it's not a 'backend'
						dtoContainer.setMyRealTrackedItem(ti);
						if dtoContainer.containerId &lt;&gt; null and dtoContainer.myPxyTrackedItem &lt;&gt; null and 
							ti.id	 = dtoContainer.containerId  then
							stackHeight:=stackHeight+1;
							continue;
						endif;
						dtoContainer.setSelfFromTI;
						dtoContainer.myPxyTrackedItem.setPxyForRailHandHeld(dtoContainer.containerId,
													dtoContainer.isoTypeCode,
													dtoContainer.customsSeal,
													dtoContainer.operatorSeal,
													dtoContainer.shipperSeal,
													dtoContainer.allDamageInstancesByDmgePos);
													// 26/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
													
													
					else
						if dtoContainer.containerId &lt;&gt; null then
							delete dtoWagonPos.myDTOContainer;
							create dtoWagonPos.myDTOContainer transient;
						endif;
					
					endif;				
				endif;
		
			endif;
			stackHeight:=stackHeight+1;
		endwhile;		
	endforeach;
	
epilog
	if dtoWagonsToDelete &lt;&gt; null then
		dtoWagonsToDelete.purge;
		delete dtoWagonsToDelete;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="getDTOContainerInfo" id="54387b29-9017-4121-b6f4-6a4befb7b2c6">
        <source>getDTOContainerInfo(_idx : Integer) : DTO_ContainerInfo;
/*
----------   ----------  --------------------------------------------------
Created:	30 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	dtoWagonPos		: DTO_WagonPosition;
begin
	dtoWagonPos := self.allDTOWagonPositions[_idx,1];
	if dtoWagonPos &lt;&gt; null then
		return dtoWagonPos.myDTOContainer;
	endif;
	
	return null;
	
end;


</source>
        <Parameter name="_idx" type="Integer"/>
        <ReturnType type="DTO_ContainerInfo"/>
    </JadeMethod>
    <JadeMethod name="getDTOWagonPosition" id="8ada3c52-0f20-4c19-a6dc-c8d3c007ef9a">
        <source>getDTOWagonPosition(	_idx : Integer;
						_stackHeight : Integer) : DTO_WagonPosition;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 November 2009	cnwer1	Initial creation

*/

vars	
	dtoWagonPos,
	prevWagonPos : DTO_WagonPosition;
	dtoContainer : DTO_ContainerInfo;
	
begin
	dtoWagonPos:=self.allDTOWagonPositions[_idx,_stackHeight];
	if dtoWagonPos = null then
		create dtoWagonPos transient;
	endif;
	
	dtoContainer:=dtoWagonPos.myDTOContainer;
	if dtoContainer &lt;&gt; null and self.myWagon =  null then
		delete dtoContainer;
	endif;
	if dtoContainer = null  then
		create dtoContainer transient;
	endif;
	
	dtoWagonPos.idx:=_idx;
	dtoWagonPos.stackHeight:=_stackHeight;
	dtoWagonPos.position:=(_idx*2)-1;
	dtoWagonPos.myDTOWagon:=self;
	dtoWagonPos.myDTOContainer:=dtoContainer;
	dtoWagonPos.isBackEnd:=false;
	if _idx &gt; 1 then
		prevWagonPos:=self.allDTOWagonPositions[_idx-1,_stackHeight];
	endif;
	if prevWagonPos &lt;&gt; null and 
		prevWagonPos.hasProxyContainer then
		dtoWagonPos.isBackEnd:=	prevWagonPos.myDTOContainer.myPxyTrackedItem.isForty;
	endif;
	//don't think below is used
	dtoContainer.idx:=_idx;
	return dtoWagonPos;
epilog

end;</source>
        <Parameter name="_idx" type="Integer"/>
        <Parameter name="_stackHeight" type="Integer"/>
        <ReturnType type="DTO_WagonPosition"/>
    </JadeMethod>
    <JadeMethod name="getNumConfirmed" id="fd92cd56-0010-4443-bc79-31b925edf32a">
        <source>getNumConfirmed() : Integer;
/*
----------   ----------  --------------------------------------------------
Created:	02 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	dtoWagonPos		: DTO_WagonPosition;
	count				: Integer;
begin
	foreach dtoWagonPos in self.allDTOWagonPositions where 
	   dtoWagonPos.myDTOContainer.confirmed and dtoWagonPos.myDTOContainer.myPxyTrackedItem &lt;&gt; null do
		count := count + 1;
	endforeach;
	
	return count;

end;


</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setMyWagon" id="33f1c9d1-b599-474f-a8b5-8b1766d5836e">
        <updating/>
        <source>setMyWagon(_wagon : CM_Wagon) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 November 2009	cnwer1	Initial creation

*/

vars

begin
	self.myWagon:=_wagon;
	if self.myWagon &lt;&gt; null then
		self.wagonID:=self.myWagon.id;
		self.myWagonClass:=self.myWagon.myWagonClass;
	else
		self.wagonID:="";
		self.myWagonClass:=null;
	endif;
		
epilog

end;</source>
        <Parameter name="_wagon" type="CM_Wagon"/>
    </JadeMethod>
</Class>
