    <JadeMethod name="pxyCreateUpdateProxy" id="74d49e5d-4712-434f-93a5-6a4d6101914f">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     09 February 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	proxyTemperatureConversion:CM_TemperatureConversion;
	completedOK		: Boolean;
begin

	proxyTemperatureConversion := inheritMethod();

	// RJS - need to add other references here, including collections
	// self.ports is inversed and this is the auto end so no need
	// to copy to the proxy
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyTemperatureConversion;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyTemperatureConversion;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="6cce688e-e111-4de2-adc4-7c8afd940e6a">
        <updating/>
        <source>setForCreate(pProxyTemperatureConversion:CM_TemperatureConversion) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	pProxyTemperatureConversion.raiseExceptionIfNotTransient(method);
	
	setForUpdate(pProxyTemperatureConversion);
	self.myRoot := app.myRoot;

end;</source>
        <Parameter name="pProxyTemperatureConversion" type="CM_TemperatureConversion"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="a238609b-6f00-4268-a0fe-8e82202bf648">
        <updating/>
        <source>setForUpdate(pProxyTemperatureConversion:CM_TemperatureConversion) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.celsius := pProxyTemperatureConversion.celsius;
	self.fahrenheit := pProxyTemperatureConversion.fahrenheit;

end;</source>
        <Parameter name="pProxyTemperatureConversion" type="CM_TemperatureConversion"/>
    </JadeMethod>
