    <JadeMethod name="exHandler" id="8372b80b-b933-4a4e-9116-1629e76acdbc">
        <updating/>
        <source>exHandler(exObj : Exception) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     07 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	methodDtls	: String;
	methodDesc	: MethodCallDesc;

begin

	if process.isInTransactionState then
		abortTransaction;
	endif;

	methodDesc := exObj.currentMethodDesc;
	if methodDesc &lt;&gt; null then
		methodDtls := methodDesc.method.name &amp; ' (' &amp; methodDesc.position.String &amp; ')';
	else
		methodDtls := '&lt;not available&gt;';
	endif;
	
	if tryLock(self, Exclusive_Lock, Transaction_Duration, 0) then
		beginTransaction;
		self.logEntry('*** Exception has occured ****');
		self.logEntry('Exception: ' &amp; exObj.errorCode.String &amp; '  ' &amp; exObj.extendedErrorText);
		self.logEntry('Exception Object: ' &amp; exObj.errorItem.String);
		self.logEntry('Method Details: ' &amp; methodDtls);
		self.isBeingActioned	:= false;
		self.isRequestComplete 	:= true;
		self.logEntry('**** Request processing complete. ****');
		commitTransaction;
	endif;
	
	/*
	As we have not called app.initialize we don't have CnCntrl which is required for log file name
	app.writeLog('*** Exception has occured ****', LogAlways);
	app.writeLog('Exception: ' &amp; exObj.errorCode.String &amp; '  ' &amp; exObj.extendedErrorText, LogAlways);
	app.writeLog('Exception Object: ' &amp; exObj.errorItem.String, LogAlways);
	app.writeLog('Method Details: ' &amp; methodDtls, LogAlways);
	*/

	return Ex_Abort_Action;

end;</source>
        <Parameter name="exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="logEntry" id="1416963d-a56a-480e-8f2a-6d07c1097ccd">
        <updating/>
        <source>logEntry(_msg : String) updating;
// ---------------------------------------------------------------------------
// Created:     02 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	needCommit	: Boolean;
	
begin

	if (not process.isInTransactionState) then
		needCommit := true;
		beginTransaction;
	endif;
	
	self.allLogEntries.add(_msg);
	
	if needCommit then
		commitTransaction;
	endif;
	
	self.causeEvent(NR_NodeRequestLogEntryEvent, true, _msg);

end;</source>
        <Parameter name="_msg" type="String"/>
    </JadeMethod>
    <JadeMethod name="outputVersionInfo" id="f684d31a-f969-494e-bee8-fdd4f8f29eb2">
        <source>outputVersionInfo(_toDir : String; _callBackObject : Object; _callBackMethod : String);
// ---------------------------------------------------------------------------
// Created:     06 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	file		: File;
	outDir,
	lastName	: String;
	tmpBin		: Binary;
	
begin

	create file transient;
	file.mode		:=	File.Mode_Output;
	file.shareMode	:=	File.Share_Write;
	file.kind		:=	File.Kind_Binary;

	file.fileName := _toDir &amp; '\jadeVersion.txt';

	if _callBackObject &lt;&gt; null and _callBackMethod &lt;&gt; null then
		_callBackObject.sendMsgWithParams(_callBackMethod, 'Saving &gt;&gt; version info to ' &amp; file.fileName);
	endif;

	file.writeBinary(self.versionText.asANSI(0));// 15/3/16  cnwns1 PAR 36286 unicode version

	if _callBackObject &lt;&gt; null and _callBackMethod &lt;&gt; null then
		_callBackObject.sendMsgWithParams(_callBackMethod, 'Version info saved as ' &amp; file.fileName);
	endif;

epilog
	if file &lt;&gt; null then
		file.close;
	endif;
	delete file;
	
end;</source>
        <Parameter name="_toDir" type="String"/>
        <Parameter name="_callBackObject" type="Object"/>
        <Parameter name="_callBackMethod" type="String"/>
    </JadeMethod>
