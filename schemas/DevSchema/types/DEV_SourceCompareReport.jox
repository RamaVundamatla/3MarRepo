				endif;
				
				concatenatedString &amp;= CrLf &amp; devSchema.name &amp; "::" &amp; devClass.name &amp; "::" &amp; devConstant.name &amp; " - " &amp; devConstant.modifiedBy &amp;  " | " &amp; devConstant.modifiedTimeStamp.String;
				constantsDifferentCount += 1;
			endforeach;
		endforeach;
	endforeach;
	
	if constantsDifferentCount &lt;&gt; 0 then
		concatenatedString &amp;= CrLf &amp; "Differing Constants Count: " &amp; constantsDifferentCount.String;
		concatenatedString &amp;= CrLf &amp; CrLf;
	endif;
	
	wroteHeaderLine := false;
	foreach devSchema in self.allSchemas do
		foreach devClass in devSchema.allClassesOrd where devClass.reason = DEV_SourceCompareReportAgent.Object_Link do
			foreach devReference in devClass.allReferencesOrd where devReference.reason = DEV_SourceCompareReportAgent.Object_Missing and devReference.resolvedBy = null do
				if _usercode &lt;&gt; null and devReference.modifiedBy &lt;&gt; _usercode then
					continue;
				endif;
				
				if not wroteHeaderLine then
					concatenatedString &amp;= "Missing References:";
					wroteHeaderLine := true;
				endif;
				
				concatenatedString &amp;= CrLf &amp; devSchema.name &amp; "::" &amp; devClass.name &amp; "::" &amp; devReference.name &amp; " - " &amp; devReference.modifiedBy &amp;  " | " &amp; devReference.modifiedTimeStamp.String;
				referencesMissingCount += 1;
			endforeach;
		endforeach;
	endforeach;
	
	if referencesMissingCount &lt;&gt; 0 then
		concatenatedString &amp;= CrLf &amp; "Missing References Count: " &amp; referencesMissingCount.String;
		concatenatedString &amp;= CrLf &amp; CrLf;
	endif;
	
	wroteHeaderLine := false;
	foreach devSchema in self.allSchemas do
		foreach devClass in devSchema.allClassesOrd where devClass.reason = DEV_SourceCompareReportAgent.Object_Link do
			foreach devReference in devClass.allReferencesOrd where devReference.reason = DEV_SourceCompareReportAgent.Object_Different and devReference.resolvedBy = null do
				if _usercode &lt;&gt; null and devReference.modifiedBy &lt;&gt; _usercode then
					continue;
				endif;
				
				if not wroteHeaderLine then
					concatenatedString &amp;= "Differing References:";
					wroteHeaderLine := true;
				endif;
				
				concatenatedString &amp;= CrLf &amp; devSchema.name &amp; "::" &amp; devClass.name &amp; "::" &amp; devReference.name &amp; " - " &amp; devReference.modifiedBy &amp;  " | " &amp; devReference.modifiedTimeStamp.String;
				referencesDifferentCount += 1;
			endforeach;
		endforeach;
	endforeach;

	if referencesDifferentCount &lt;&gt; 0 then
		concatenatedString &amp;= CrLf &amp; "Differing References Count: " &amp; referencesDifferentCount.String;
		concatenatedString &amp;= CrLf &amp; CrLf;	
	endif;
	
	return concatenatedString;

end;</source>
        <Parameter name="_usercode" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getReportUserSummary" id="cced7a00-cb9b-4089-8a72-cdab23c4b0eb">
        <updating/>
        <source>getReportUserSummary(): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2025	navsaa30	Initial creation
21/5/2025 navsaa30 MTN-34812 MTN - Source Compare/Unit Test - Change Email to be a Summary Count by User - Phase1
*/

vars
	concatenatedString 			: String;
	devSchema 					: DEV_Schema;
	grouping,jdo 				: JadeDynamicObject;
	devGlobalConstantCategory 	: DEV_GlobalConstantCategory;
	devClass 					: DEV_Class;
	devAttribute 				: DEV_Attribute;
	devConstant 				: DEV_ClassConstant;
	devReference 				: DEV_Reference;
	devMethod 					: DEV_Method;
	devGlobalConstant 			: DEV_GlobalConstant;
	allGrouppedUsers			: JadeDynamicObjectArray;
	

begin
	create allGrouppedUsers transient;
	create jdo transient;
	foreach devSchema in self.allSchemas do
		foreach devGlobalConstantCategory in devSchema.allGlobalConstantCategories where devGlobalConstantCategory.reason = DEV_SourceCompareReportAgent.Object_Missing do
			grouping := null;
			foreach jdo in allGrouppedUsers discreteLock where jdo.getPropertyValue(GroupingUserName).String = devGlobalConstantCategory.modifiedBy  do	
				grouping := jdo;
			endforeach;
			if grouping = null then
				create grouping transient;
				createGrouping(devGlobalConstantCategory.modifiedBy,grouping);
				grouping.setPropertyValue(GlobalCnstCatMissingCount,1);
				allGrouppedUsers.add(grouping);
			else
				grouping.setPropertyValue(GlobalCnstCatMissingCount,grouping.getPropertyValue(GlobalCnstCatMissingCount).Integer + 1);
			endif;			
		endforeach;
	endforeach;
	
	
	foreach devSchema in self.allSchemas do
		foreach devGlobalConstantCategory in devSchema.allGlobalConstantCategories where devGlobalConstantCategory.reason = DEV_SourceCompareReportAgent.Object_Different do
			grouping := null;
			foreach jdo in allGrouppedUsers discreteLock where jdo.getPropertyValue(GroupingUserName).String = devGlobalConstantCategory.modifiedBy  do
				grouping := jdo;
			endforeach;
			if grouping = null then
				create grouping transient;
				createGrouping(devGlobalConstantCategory.modifiedBy,grouping);
				grouping.setPropertyValue(GlobalCnstCatDifferentCount,1);
				allGrouppedUsers.add(grouping);
			else
				grouping.setPropertyValue(GlobalCnstCatDifferentCount,grouping.getPropertyValue(GlobalCnstCatDifferentCount).Integer + 1);
			endif;			
		endforeach;
	endforeach;

	foreach devSchema in self.allSchemas do
		foreach devGlobalConstantCategory in devSchema.allGlobalConstantCategories where devGlobalConstantCategory.reason = DEV_SourceCompareReportAgent.Object_Link do
			foreach devGlobalConstant in devGlobalConstantCategory.allConstants where devGlobalConstant.reason = DEV_SourceCompareReportAgent.Object_Missing do
			grouping := null;
			foreach jdo in allGrouppedUsers discreteLock where jdo.getPropertyValue(GroupingUserName).String = devGlobalConstant.modifiedBy  do
				grouping := jdo;
			endforeach;
			if grouping = null then
				create grouping transient;
				createGrouping(devGlobalConstant.modifiedBy,grouping);
				grouping.setPropertyValue(GlobalCnstMissingCount,1);
				allGrouppedUsers.add(grouping);
			else
				grouping.setPropertyValue(GlobalCnstMissingCount,grouping.getPropertyValue(GlobalCnstMissingCount).Integer + 1);
			endif;			
		endforeach;
	endforeach;
	endforeach;
	
	
	foreach devSchema in self.allSchemas do
		foreach devGlobalConstantCategory in devSchema.allGlobalConstantCategories where devGlobalConstantCategory.reason = DEV_SourceCompareReportAgent.Object_Link do
			foreach devGlobalConstant in devGlobalConstantCategory.allConstants where devGlobalConstant.reason = DEV_SourceCompareReportAgent.Object_Different do
				grouping := null;
				foreach jdo in allGrouppedUsers discreteLock where jdo.getPropertyValue(GroupingUserName).String = devGlobalConstant.modifiedBy  do
					grouping := jdo;
				endforeach;
				if grouping = null then
					create grouping transient;
					createGrouping(devGlobalConstant.modifiedBy,grouping);
					grouping.setPropertyValue(GlobalCnstDifferentCount,1);
					allGrouppedUsers.add(grouping);
				else
					grouping.setPropertyValue(GlobalCnstDifferentCount,grouping.getPropertyValue(GlobalCnstDifferentCount).Integer + 1);
				endif;
			endforeach;
		endforeach;
	endforeach;
	
	foreach devSchema in self.allSchemas do
		foreach devClass in devSchema.allClasses where devClass.reason = DEV_SourceCompareReportAgent.Object_Missing do
			grouping := null;
			foreach jdo in allGrouppedUsers discreteLock where jdo.getPropertyValue(GroupingUserName).String = devClass.modifiedBy  do
				grouping := jdo;
			endforeach;
			if grouping = null then
				create grouping transient;
				createGrouping(devClass.modifiedBy,grouping);
				grouping.setPropertyValue(ClassesMissingCount,1);
				allGrouppedUsers.add(grouping);
			else
				grouping.setPropertyValue(ClassesMissingCount,grouping.getPropertyValue(ClassesMissingCount).Integer + 1);
			endif;
		endforeach;
	endforeach;
	
	
	foreach devSchema in self.allSchemas do
		foreach devClass in devSchema.allClasses where devClass.reason = DEV_SourceCompareReportAgent.Object_Link do
			foreach devMethod in devClass.allMethods where devMethod.reason = DEV_SourceCompareReportAgent.Object_Missing do
				grouping := null;
				foreach jdo in allGrouppedUsers discreteLock where jdo.getPropertyValue(GroupingUserName).String = devMethod.modifiedBy  do
					grouping := jdo;
				endforeach;
				if grouping = null then
					create grouping transient;
					createGrouping(devMethod.modifiedBy,grouping);
					grouping.setPropertyValue(MethodsMissingCount,1);
					allGrouppedUsers.add(grouping);
				else
					grouping.setPropertyValue(MethodsMissingCount,grouping.getPropertyValue(MethodsMissingCount).Integer + 1);
				endif;
			endforeach;
		endforeach;
	endforeach;
	
	
	foreach devSchema in self.allSchemas do
		foreach devClass in devSchema.allClasses where devClass.reason = DEV_SourceCompareReportAgent.Object_Link do
			foreach devMethod in devClass.allMethods where devMethod.reason = DEV_SourceCompareReportAgent.Object_Different do
				grouping := null;
				foreach jdo in allGrouppedUsers discreteLock where jdo.getPropertyValue(GroupingUserName).String = devMethod.modifiedBy  do
					grouping := jdo;
				endforeach;
				if grouping = null then
					create grouping transient;
					createGrouping(devMethod.modifiedBy,grouping);
					grouping.setPropertyValue(MethodsDifferentCount,1);
					allGrouppedUsers.add(grouping);
				else
					grouping.setPropertyValue(MethodsDifferentCount,grouping.getPropertyValue(MethodsDifferentCount).Integer + 1);
				endif;
			endforeach;
		endforeach;
	endforeach;
	
	
	foreach devSchema in self.allSchemas do
		foreach devClass in devSchema.allClasses where devClass.reason = DEV_SourceCompareReportAgent.Object_Link do
			foreach devAttribute in devClass.allAttributes where devAttribute.reason = DEV_SourceCompareReportAgent.Object_Missing do
				grouping := null;
				foreach jdo in allGrouppedUsers discreteLock where jdo.getPropertyValue(GroupingUserName).String = devAttribute.modifiedBy  do
					grouping := jdo;
				endforeach;
				if grouping = null then
					create grouping transient;
					createGrouping(devAttribute.modifiedBy,grouping);
					grouping.setPropertyValue(AttributesMissingCount,1);
					allGrouppedUsers.add(grouping);
				else
					grouping.setPropertyValue(AttributesMissingCount,grouping.getPropertyValue(AttributesMissingCount).Integer + 1);
				endif;
			endforeach;
		endforeach;
	endforeach;
	
	
	foreach devSchema in self.allSchemas do
		foreach devClass in devSchema.allClasses where devClass.reason = DEV_SourceCompareReportAgent.Object_Link do
			foreach devAttribute in devClass.allAttributes where devAttribute.reason = DEV_SourceCompareReportAgent.Object_Different do
				grouping := null;
				foreach jdo in allGrouppedUsers discreteLock where jdo.getPropertyValue(GroupingUserName).String = devAttribute.modifiedBy  do
					grouping := jdo;
				endforeach;
				if grouping = null then
					create grouping transient;
					createGrouping(devAttribute.modifiedBy,grouping);
					grouping.setPropertyValue(AttributesDifferentCount,1);
					allGrouppedUsers.add(grouping);
				else
					grouping.setPropertyValue(AttributesDifferentCount,grouping.getPropertyValue(AttributesDifferentCount).Integer + 1);
				endif;
			endforeach;
		endforeach;
	endforeach;
	
	
	foreach devSchema in self.allSchemas do
		foreach devClass in devSchema.allClasses where devClass.reason = DEV_SourceCompareReportAgent.Object_Link do
			foreach devConstant in devClass.allConstants where devConstant.reason = DEV_SourceCompareReportAgent.Object_Missing do
				grouping := null;
				foreach jdo in allGrouppedUsers discreteLock where jdo.getPropertyValue(GroupingUserName).String = devConstant.modifiedBy  do
					grouping := jdo;
				endforeach;
				if grouping = null then
					create grouping transient;
					createGrouping(devConstant.modifiedBy,grouping);
					grouping.setPropertyValue(ConstantsMissingCount,1);
					allGrouppedUsers.add(grouping);
				else
					grouping.setPropertyValue(ConstantsMissingCount,grouping.getPropertyValue(ConstantsMissingCount).Integer + 1);
				endif;
			endforeach;
		endforeach;
	endforeach;
	
	
	foreach devSchema in self.allSchemas do
		foreach devClass in devSchema.allClasses where devClass.reason = DEV_SourceCompareReportAgent.Object_Link do
			foreach devConstant in devClass.allConstants where devConstant.reason = DEV_SourceCompareReportAgent.Object_Different do
				grouping := null;
				foreach jdo in allGrouppedUsers discreteLock where jdo.getPropertyValue(GroupingUserName).String = devConstant.modifiedBy  do
					grouping := jdo;
				endforeach;
				if grouping = null then
					create grouping transient;
					createGrouping(devConstant.modifiedBy,grouping);
					grouping.setPropertyValue(ConstantsDifferentCount,1);
					allGrouppedUsers.add(grouping);
				else
					grouping.setPropertyValue(ConstantsDifferentCount,grouping.getPropertyValue(ConstantsDifferentCount).Integer + 1);
				endif;
			endforeach;
		endforeach;
	endforeach;
	
	
	foreach devSchema in self.allSchemas do
		foreach devClass in devSchema.allClasses where devClass.reason = DEV_SourceCompareReportAgent.Object_Link do
			foreach devReference in devClass.allReferences where devReference.reason = DEV_SourceCompareReportAgent.Object_Missing do
				grouping := null;
				foreach jdo in allGrouppedUsers discreteLock where jdo.getPropertyValue(GroupingUserName).String = devReference.modifiedBy  do
					grouping := jdo;
				endforeach;
				if grouping = null then
					create grouping transient;
					createGrouping(devReference.modifiedBy,grouping);
					grouping.setPropertyValue(ReferencesMissingCount,1);
					allGrouppedUsers.add(grouping);
				else
					grouping.setPropertyValue(ReferencesMissingCount,grouping.getPropertyValue(ReferencesMissingCount).Integer + 1);
				endif;
			endforeach;
		endforeach;
	endforeach;
	
	
	foreach devSchema in self.allSchemas do
		foreach devClass in devSchema.allClasses where devClass.reason = DEV_SourceCompareReportAgent.Object_Link do
			foreach devReference in devClass.allReferences where devReference.reason = DEV_SourceCompareReportAgent.Object_Different do
				grouping := null;
				foreach jdo in allGrouppedUsers discreteLock where jdo.getPropertyValue(GroupingUserName).String = devReference.modifiedBy  do
					grouping := jdo;
				endforeach;
				if grouping = null then
					create grouping transient;
					createGrouping(devReference.modifiedBy,grouping);
					grouping.setPropertyValue(ReferencesDifferentCount,1);
					allGrouppedUsers.add(grouping);
				else
					grouping.setPropertyValue(ReferencesDifferentCount,grouping.getPropertyValue(ReferencesDifferentCount).Integer + 1);
				endif;
			endforeach;
		endforeach;
	endforeach;
	concatenatedString &amp;= CrLf &amp; " User ".padBlanks(30) &amp; " CategoryMissingCount ".padBlanks(30) &amp; " CategoryDifferentCount ".padBlanks(30) &amp; " GlobalConstantMissingCount ".padBlanks(30) &amp; " GlobalConstantDifferentCount ".padBlanks(30) &amp; " ClassesMissingCount ".padBlanks(30)
	&amp; " MethodsMissingCount ".padBlanks(30) &amp; " MethodsDifferentCount ".padBlanks(30) &amp; " AttributesMissingCount ".padBlanks(30) &amp; " AttributesDifferentCount ".padBlanks(30) &amp; " ConstantsMissingCount ".padBlanks(30) &amp; " ConstantsDifferentCount ".padBlanks(30) &amp; " ReferencesMissingCount ".padBlanks(30) &amp; " ReferencesDifferentCount "; 
	
	foreach jdo in allGrouppedUsers do 
		if jdo &lt;&gt; null then 
			concatenatedString &amp;= CrLf &amp; jdo.getPropertyValue(GroupingUserName).String.padBlanks(35) &amp; jdo.getPropertyValue(GlobalCnstCatMissingCount).String.padBlanks(30) &amp; jdo.getPropertyValue(GlobalCnstCatDifferentCount).String.padBlanks(30) &amp; jdo.getPropertyValue(GlobalCnstMissingCount).String.padBlanks(30) &amp; jdo.getPropertyValue(GlobalCnstDifferentCount).String.padBlanks(30) &amp;
			jdo.getPropertyValue(ClassesMissingCount).String.padBlanks(30) &amp; jdo.getPropertyValue(MethodsMissingCount).String.padBlanks(30) &amp; jdo.getPropertyValue(MethodsDifferentCount).String.padBlanks(30) &amp; jdo.getPropertyValue(AttributesMissingCount).String.padBlanks(30) &amp; jdo.getPropertyValue(AttributesDifferentCount).String.padBlanks(30)  &amp;
			jdo.getPropertyValue(ConstantsMissingCount).String.padBlanks(30)  &amp; jdo.getPropertyValue(ConstantsDifferentCount).String.padBlanks(30)  &amp; jdo.getPropertyValue(ReferencesMissingCount).String.padBlanks(30)  &amp; jdo.getPropertyValue(ReferencesDifferentCount).String;
		endif;
	endforeach;
	
	return concatenatedString;
epilog
delete allGrouppedUsers;
delete grouping;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStats" id="c0432ef1-980a-4fe2-9dc2-a5e224aff413">
        <source>getStats(_usercode : String) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 September 2023	navpw1	Initial creation

*/

vars
	concatenatedString 			: String;
	devSchema 					: DEV_Schema;
	devGlobalConstantCategory 	: DEV_GlobalConstantCategory;
	devGlobalConstant 			: DEV_GlobalConstant;
	devClass 					: DEV_Class;
	devAttribute 				: DEV_Attribute;
	devConstant 				: DEV_ClassConstant;
	devReference 				: DEV_Reference;
	devMethod 					: DEV_Method;
	
	globalCnstCatMissingCount,
 	globalCnstCatDifferentCount,
	globalCnstCatAestheticDifferentCount,
	globalCnstMissingCount,
	globalCnstDifferentCount,
	globalCnstAestheticDifferentCount,
	classesMissingCount,
	classesAestheticDifferentCount,
	classesDifferentCount,
	methodsMissingCount,
	methodsDifferentCount,
	methodsAestheticDifferentCount,
	attributesMissingCount,
	attributesDifferentCount,
	constantsMissingCount,
	constantsDifferentCount,
	referencesMissingCount,
	referencesDifferentCount	: Integer;
	scm : Schema;
	currentConstant : Constant;
	currentConstantCategory : ConstantCategory;
	currentClass : Class;
	currentMethod : Method;
	jadeRegexReplacePat : JadeRegexPattern;
	
begin
	create jadeRegexReplacePat transient;
	jadeRegexReplacePat.compile("[\r\n\t\s]");
	jadeRegexReplacePat.setIgnoreCase(true);
	jadeRegexReplacePat.setExplicitCapture(true);
	
	//Global Constant Categories
	foreach devSchema in self.allSchemas do
		foreach devGlobalConstantCategory in devSchema.allGlobalConstantCategoriesOrd where devGlobalConstantCategory.resolvedBy = null do
			if _usercode &lt;&gt; null and devGlobalConstantCategory.modifiedBy &lt;&gt; _usercode then
				continue;
			endif;
			
			if devGlobalConstantCategory.reason = DEV_SourceCompareReportAgent.Object_Missing then
				globalCnstCatMissingCount += 1;
				
			elseif devGlobalConstantCategory.reason = DEV_SourceCompareReportAgent.Object_Different then
				currentConstantCategory := scm.getConstantCategory(devGlobalConstantCategory.name);
				if jadeRegexReplacePat.replaceAll(currentConstantCategory.text, "") = jadeRegexReplacePat.replaceAll(devGlobalConstantCategory.documentationTextData, "") then
					globalCnstCatAestheticDifferentCount += 1;
					
				else
					globalCnstCatDifferentCount += 1;
					
				endif;
				
			endif;
		endforeach;
	endforeach;
	
	if globalCnstCatMissingCount &lt;&gt; 0 or globalCnstCatDifferentCount &lt;&gt; 0  or globalCnstCatAestheticDifferentCount &lt;&gt; 0 then
		concatenatedString &amp;= CrLf &amp; "Missing Global Constant Categories Count: " &amp; globalCnstCatMissingCount.String;
		concatenatedString &amp;= CrLf &amp; "Logic Differing Global Constant Categories Count: " &amp; globalCnstCatDifferentCount.String;
		concatenatedString &amp;= CrLf &amp; "Aesthetic Only Differing Global Constant Categories Count: " &amp; globalCnstCatAestheticDifferentCount.String;
		concatenatedString &amp;= CrLf &amp; CrLf;
	endif;
	
	//Global Constants
	foreach devSchema in self.allSchemas do
		scm := rootSchema.getSchema(devSchema.name);
		foreach devGlobalConstantCategory in devSchema.allGlobalConstantCategoriesOrd where devGlobalConstantCategory.reason = DEV_SourceCompareReportAgent.Object_Link do
			foreach devGlobalConstant in devGlobalConstantCategory.allGlobalConstantsOrd where devGlobalConstant.resolvedBy = null do
				if _usercode &lt;&gt; null and devGlobalConstant.modifiedBy &lt;&gt; _usercode then
					continue;
				endif;
				
				if devGlobalConstant.reason = DEV_SourceCompareReportAgent.Object_Missing then
					globalCnstMissingCount += 1;
					
				elseif devGlobalConstant.reason = DEV_SourceCompareReportAgent.Object_Different then
					currentConstant := scm.getConstant(devGlobalConstant.name);
					if jadeRegexReplacePat.replaceAll(currentConstant.text, "") = jadeRegexReplacePat.replaceAll(devGlobalConstant.documentationTextData, "") then
						globalCnstAestheticDifferentCount += 1;
						
					else
						globalCnstDifferentCount += 1;
						
					endif;
				endif;
				
			endforeach;
			
		endforeach;
		
	endforeach;
	
	if globalCnstMissingCount &lt;&gt; 0 or globalCnstDifferentCount &lt;&gt; 0 or globalCnstAestheticDifferentCount &lt;&gt; 0 then
		concatenatedString &amp;= "Missing Global Constants Count: " &amp; globalCnstMissingCount.String &amp; CrLf;
		concatenatedString &amp;= "Logic Differing Global Constants Count: " &amp; globalCnstDifferentCount.String &amp; CrLf;
		concatenatedString &amp;= "Aesthetic Only Differing Global Constants Count: " &amp; globalCnstAestheticDifferentCount.String &amp; CrLf;
		concatenatedString &amp;= CrLf;
	endif;
	
	//Classes
	foreach devSchema in self.allSchemas do
		scm := rootSchema.getSchema(devSchema.name);
		foreach devClass in devSchema.allClassesOrd where devClass.resolvedBy = null do
			if _usercode &lt;&gt; null and devClass.modifiedBy &lt;&gt; _usercode then
				continue;
			endif;
			
			if devClass.reason = DEV_SourceCompareReportAgent.Object_Missing then
				classesMissingCount += 1;
				
			elseif devClass.reason = DEV_SourceCompareReportAgent.Object_Different then
				currentClass := scm.getClass(devClass.name);
				if jadeRegexReplacePat.replaceAll(currentClass.text, "") = jadeRegexReplacePat.replaceAll(devClass.documentationTextData, "") then
					classesAestheticDifferentCount += 1;
					
				else
					classesDifferentCount += 1;
					
				endif;
				
			endif;
		endforeach;
	endforeach;
	
	if classesMissingCount &lt;&gt; 0 or classesAestheticDifferentCount &lt;&gt; 0 or classesDifferentCount &lt;&gt; 0 then
		concatenatedString &amp;= "Missing Classes Count: " &amp; classesMissingCount.String &amp; CrLf;
		concatenatedString &amp;= "Logic Differing Classes Count: " &amp; classesDifferentCount.String &amp; CrLf;
		concatenatedString &amp;= "Aesthetic Only Differing Classes Count: " &amp; classesAestheticDifferentCount.String &amp; CrLf;
		concatenatedString &amp;= CrLf;
	endif;
	
	//Methods
	foreach devSchema in self.allSchemas do
		scm := rootSchema.getSchema(devSchema.name);
		
		foreach devClass in devSchema.allClassesOrd where devClass.reason = DEV_SourceCompareReportAgent.Object_Link do
			currentClass := scm.getClass(devClass.name);
			
			foreach devMethod in devClass.allMethodsOrd where devMethod.resolvedBy = null do
				if _usercode &lt;&gt; null and devMethod.modifiedBy &lt;&gt; _usercode then
					continue;
				endif;
				
				if devMethod.reason = DEV_SourceCompareReportAgent.Object_Missing then
					methodsMissingCount += 1;
					
				elseif devMethod.reason = DEV_SourceCompareReportAgent.Object_Different then
					currentMethod := scm.getClass(devClass.name).getMethod(devMethod.name);
					
					if jadeRegexReplacePat.replaceAll(currentMethod.getSource(), "") = jadeRegexReplacePat.replaceAll(devMethod.desc, "") then
						methodsAestheticDifferentCount += 1;
					else
						methodsDifferentCount += 1;
						
					endif;
					
				endif;
				
			endforeach;
		endforeach;
	endforeach;
	
	if methodsMissingCount &lt;&gt; 0 or methodsDifferentCount &lt;&gt; 0 or methodsAestheticDifferentCount &lt;&gt; 0 then
		concatenatedString &amp;= "Missing Methods Count: " &amp; methodsMissingCount.String &amp; CrLf;
		concatenatedString &amp;= "Differing Methods: " &amp; 
								methodsAestheticDifferentCount.String &amp; "(Aesthetic) | " &amp;
								methodsDifferentCount.String &amp; "(Logical) | " &amp;
								(methodsAestheticDifferentCount+methodsDifferentCount).String &amp; "(Total)" 
								&amp; CrLf;
		concatenatedString &amp;= "Logic Differing Methods Count: " &amp; methodsDifferentCount.String &amp; CrLf;
		concatenatedString &amp;= "Aesthetic Only Differing Methods Count: " &amp; methodsAestheticDifferentCount.String &amp; CrLf;
		concatenatedString &amp;= CrLf;
	endif;
	
	if concatenatedString.length &gt; 0 then
		concatenatedString &amp;= "Key/Meaning:" &amp; CrLf &amp;
								"Aesthetic: Count of differences with space, tabs, new lines only" &amp; CrLf &amp;
								"Logic: Count of differences between code/logic which means the code behaves differently" &amp; CrLf &amp;
								"Total: Total count of Aesthetic &amp; Logic differences" &amp; CrLf;
	endif;
	/*
	//Attributes
	foreach devSchema in self.allSchemas do
		foreach devClass in devSchema.allClassesOrd where devClass.reason = DEV_SourceCompareReportAgent.Object_Link do
			foreach devAttribute in devClass.allAttributesOrd where devAttribute.reason = DEV_SourceCompareReportAgent.Object_Missing do
				if _usercode &lt;&gt; null and devAttribute.modifiedBy &lt;&gt; _usercode then
					continue;
				endif;
				
				if not wroteHeaderLine then
					concatenatedString &amp;= "Missing Attributes:";
					wroteHeaderLine := true;
				endif;
				
				concatenatedString &amp;= CrLf &amp; devSchema.name &amp; "::" &amp; devClass.name &amp; "::" &amp; devAttribute.name &amp; " - " &amp; devAttribute.modifiedBy &amp;  " | " &amp; devAttribute.modifiedTimeStamp.String;
				attributesMissingCount += 1;
			endforeach;
		endforeach;
	endforeach;
	
	if attributesMissingCount &lt;&gt; 0 then
		concatenatedString &amp;= CrLf &amp; "Missing Attributes Count: " &amp; attributesMissingCount.String;
		concatenatedString &amp;= CrLf &amp; CrLf;
	endif;
	
	//Issue with Differing Attributes - Check Comparison might have false positives
	//Attributes
	foreach devSchema in self.allSchemas do
		foreach devClass in devSchema.allClassesOrd where devClass.reason = DEV_SourceCompareReportAgent.Object_Link do
			foreach devAttribute in devClass.allAttributesOrd where devAttribute.reason = DEV_SourceCompareReportAgent.Object_Different and devAttribute.resolvedBy = null do
				if _usercode &lt;&gt; null and devAttribute.modifiedBy &lt;&gt; _usercode then
					continue;
				endif;
				
				if not wroteHeaderLine then
					concatenatedString &amp;= "Differing Attributes:";
					wroteHeaderLine := true;
				endif;
				
				concatenatedString &amp;= CrLf &amp; devSchema.name &amp; "::" &amp; devClass.name &amp; "::" &amp; devAttribute.name &amp; " - " &amp; devAttribute.modifiedBy &amp;  " | " &amp; devAttribute.modifiedTimeStamp.String;
				attributesDifferentCount += 1;
			endforeach;
		endforeach;
	endforeach;
	
	if attributesDifferentCount &lt;&gt; 0 then
		concatenatedString &amp;= CrLf &amp; "Differing Attributes Count: " &amp; attributesDifferentCount.String;
		concatenatedString &amp;= CrLf &amp; CrLf;
	endif;
	
	//Constants
	foreach devSchema in self.allSchemas do
		foreach devClass in devSchema.allClassesOrd where devClass.reason = DEV_SourceCompareReportAgent.Object_Link do
			foreach devConstant in devClass.allConstantsOrd where devConstant.reason = DEV_SourceCompareReportAgent.Object_Missing do
				if _usercode &lt;&gt; null and devConstant.modifiedBy &lt;&gt; _usercode then
					continue;
				endif;
				
				if not wroteHeaderLine then
					concatenatedString &amp;= "Missing Constants:";
					wroteHeaderLine := true;
				endif;
				
				concatenatedString &amp;= CrLf &amp; devSchema.name &amp; "::" &amp; devClass.name &amp; "::" &amp; devConstant.name &amp; " - " &amp; devConstant.modifiedBy &amp;  " | " &amp; devConstant.modifiedTimeStamp.String;
				constantsMissingCount += 1;
			endforeach;
		endforeach;
	endforeach;
	
	if constantsMissingCount &lt;&gt; 0 then
		concatenatedString &amp;= CrLf &amp; "Missing Constants Count: " &amp; constantsMissingCount.String;
		concatenatedString &amp;= CrLf &amp; CrLf;
	endif;
	
	//Constants
	foreach devSchema in self.allSchemas do
		foreach devClass in devSchema.allClassesOrd where devClass.reason = DEV_SourceCompareReportAgent.Object_Link do
			foreach devConstant in devClass.allConstantsOrd where devConstant.reason = DEV_SourceCompareReportAgent.Object_Different and devConstant.resolvedBy = null do
				if _usercode &lt;&gt; null and devConstant.modifiedBy &lt;&gt; _usercode then
					continue;
				endif;
				
				if not wroteHeaderLine then
					concatenatedString &amp;= "Differing Constants:";
					wroteHeaderLine := true;
				endif;
				
				concatenatedString &amp;= CrLf &amp; devSchema.name &amp; "::" &amp; devClass.name &amp; "::" &amp; devConstant.name &amp; " - " &amp; devConstant.modifiedBy &amp;  " | " &amp; devConstant.modifiedTimeStamp.String;
				constantsDifferentCount += 1;
			endforeach;
		endforeach;
	endforeach;
	
	if constantsDifferentCount &lt;&gt; 0 then
		concatenatedString &amp;= CrLf &amp; "Differing Constants Count: " &amp; constantsDifferentCount.String;
		concatenatedString &amp;= CrLf &amp; CrLf;
	endif;
	
	//References
	foreach devSchema in self.allSchemas do
		foreach devClass in devSchema.allClassesOrd where devClass.reason = DEV_SourceCompareReportAgent.Object_Link do
			foreach devReference in devClass.allReferencesOrd where devReference.reason = DEV_SourceCompareReportAgent.Object_Missing do
				if _usercode &lt;&gt; null and devReference.modifiedBy &lt;&gt; _usercode then
					continue;
				endif;
				
				if not wroteHeaderLine then
					concatenatedString &amp;= "Missing References:";
					wroteHeaderLine := true;
				endif;
				
				concatenatedString &amp;= CrLf &amp; devSchema.name &amp; "::" &amp; devClass.name &amp; "::" &amp; devReference.name &amp; " - " &amp; devReference.modifiedBy &amp;  " | " &amp; devReference.modifiedTimeStamp.String;
				referencesMissingCount += 1;
			endforeach;
		endforeach;
	endforeach;
	
	if referencesMissingCount &lt;&gt; 0 then
		concatenatedString &amp;= CrLf &amp; "Missing References Count: " &amp; referencesMissingCount.String;
		concatenatedString &amp;= CrLf &amp; CrLf;
	endif;
	
	//References
	foreach devSchema in self.allSchemas do
		foreach devClass in devSchema.allClassesOrd where devClass.reason = DEV_SourceCompareReportAgent.Object_Link do
			foreach devReference in devClass.allReferencesOrd where devReference.reason = DEV_SourceCompareReportAgent.Object_Different and devReference.resolvedBy = null do
				if _usercode &lt;&gt; null and devReference.modifiedBy &lt;&gt; _usercode then
					continue;
				endif;
				
				if not wroteHeaderLine then
					concatenatedString &amp;= "Differing References:";
					wroteHeaderLine := true;
				endif;
				
				concatenatedString &amp;= CrLf &amp; devSchema.name &amp; "::" &amp; devClass.name &amp; "::" &amp; devReference.name &amp; " - " &amp; devReference.modifiedBy &amp;  " | " &amp; devReference.modifiedTimeStamp.String;
				referencesDifferentCount += 1;
			endforeach;
		endforeach;
	endforeach;

	if referencesDifferentCount &lt;&gt; 0 then
		concatenatedString &amp;= CrLf &amp; "Differing References Count: " &amp; referencesDifferentCount.String;
		concatenatedString &amp;= CrLf &amp; CrLf;	
	endif;
	*/
	return concatenatedString;
	
epilog
	delete jadeRegexReplacePat;
	
end;</source>
        <Parameter name="_usercode" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setGenerationTime" id="ab2a7d4b-3057-458c-b50a-fe90beecb5b7">
        <updating/>
        <source>setGenerationTime(_duration : Time) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
24 June 2023	navmd1	Initial creation

*/

vars

begin
	beginTransaction;
	self.generationTime := _duration;
	commitTransaction;
	
	if self.myRoot &lt;&gt; null then
		self.myRoot.updateDuration(self);
	endif;
epilog

end;</source>
        <Parameter name="_duration" type="Time"/>
    </JadeMethod>
