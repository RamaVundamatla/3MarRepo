    <JadeMethod name="getMyMovementObject" id="ae7ac524-ffea-4165-8949-66dd90d1a9c7">
        <source>getMyMovementObject():HMS_VoyageMovement;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 March 2019	jlgndl1	Initial creation	TFS 43687

*/

vars

	voyage : CM_Voyage;
	tmpMove : HMS_VoyageMovement;

begin

	voyage := self.getMyVoyageObject();
	
	if voyage &lt;&gt; null then
	
		if self.myTransactionWO &lt;&gt; null then
			if app.isInProformaMode then
				if self.myTransactionWO.myWorkOrder &lt;&gt; null then
					tmpMove := self.myTransactionWO.myWorkOrder.getMyHMSVoyageMovement();
					if tmpMove &lt;&gt; null then
						return tmpMove;
					endif;
				endif;
			endif;
		endif;
		
		if self.myTransactionHMS &lt;&gt; null then
			if self.myTransactionHMS.myResourceUsed &lt;&gt; null then
				tmpMove := self.myTransactionHMS.myResourceUsed.myVoyageMovement;
				if tmpMove &lt;&gt; null then
					return tmpMove;
				endif;
			endif;
		endif;
		
		if voyage.myHMSVoyageData &lt;&gt; null then
			if not voyage.myHMSVoyageData.allVoyageMovements.isEmpty then
				tmpMove := voyage.myHMSVoyageData.allVoyageMovements.getAtKeyGtr(self.chargeTime).HMS_VoyageMovement;
				if tmpMove = null then
					tmpMove := voyage.getMovementDeparture();
					if tmpMove &lt;&gt; null then
						tmpMove := tmpMove.myPreviousMovement.HMS_VoyageMovement;
					endif;
				endif;
			endif;
		endif;
	endif;
	
	return tmpMove;
	
epilog

end;</source>
        <ReturnType type="HMS_VoyageMovement"/>
    </JadeMethod>
    <JadeMethod name="getMyShippingLine" id="c42388a5-79b5-43b9-94da-d77c38f3f1fb">
