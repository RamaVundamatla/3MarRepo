    <DbClassMap file="unitTest"/>
    <JadeMethod name="tCheckTideTablesForFlood" id="27239962-997d-4521-9116-2bc489fcbf01">
        <source>tCheckTideTablesForFlood();
// cnwdap1
//22 September 2008	cnwdw1	
//
vars
	tidalModelHiLo	: HMS_TidalModelDefinition;
	lowTide1, highTide1, lowTide2, highTide2: Time;
	nextFloodTime	: TimeStamp;
	timeToCheck, earliestTime: TimeStamp;
	date: Date;
	time: Time;
	isFlood: Boolean;
begin
	tidalModelHiLo := app.myRoot.allHMSTidalModelDefinitions['AUCK - HIL'];
	assertTrueMsg(tidalModelHiLo &lt;&gt; null, "Couldn't find tide tables");
	
	// Tide Table Data for Gladstone 22 Sept 2008
	date.setDate(22,9,2008);
	highTide1.setTime(01, 58, 0, 0);  // High  Tide  01:58
	lowTide1.setTime(08, 08, 0, 0); // Low Tide  08:08
	highTide2.setTime(15, 01, 0, 0);  // High  Tide  15:01
	lowTide2.setTime(21, 45, 0, 0); // Low Tide  21:45

	timeToCheck.setDate(date);
	timeToCheck.setTime(highTide1);
	isFlood := tidalModelHiLo.isFloodTideAtTime(timeToCheck, nextFloodTime);
	assertFalseMsg(isFlood, "High tide is not flood");
	
	timeToCheck.setTime(highTide1.addMinutes(1));
	isFlood := tidalModelHiLo.isFloodTideAtTime(timeToCheck, nextFloodTime);
	assertFalseMsg(isFlood, "High tide + 1 is not flood");

	timeToCheck.setTime(highTide1.addMinutes(-1));
	isFlood := tidalModelHiLo.isFloodTideAtTime(timeToCheck, nextFloodTime);
	assertTrueMsg(isFlood, "High tide - 1 is flood");

	timeToCheck.setTime(lowTide1);
	isFlood := tidalModelHiLo.isFloodTideAtTime(timeToCheck, nextFloodTime);
	assertFalseMsg(isFlood, "Low tide is not flood");

	timeToCheck.setTime(lowTide1.addMinutes(-1));
	isFlood := tidalModelHiLo.isFloodTideAtTime(timeToCheck, nextFloodTime);
	assertFalseMsg(isFlood, "Low tide -1 is not flood");

	timeToCheck.setTime(lowTide1.addMinutes(1));
	isFlood := tidalModelHiLo.isFloodTideAtTime(timeToCheck, nextFloodTime);
	assertTrueMsg(isFlood, "Low tide +1 is flood");
end;</source>
    </JadeMethod>
    <JadeMethod name="tDaylightSavings" id="1cf87988-5482-440c-a19c-b052918602fb">
        <source>tDaylightSavings();
//cnwndl1
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 March 2012	cnwndl1	Initial creation	Par 28251

*/

vars

	harbour : HMS_Harbour;
	startTimezone : Integer;
	ts : TimeStamp;
	startDate : Date;
	endDate : Date;
	startTime : Time;
	endTime : Time;
	dstChangesToday : Boolean;

begin

	harbour := self.getTerminal.myHarbour;
	self.assertTrueMsg( harbour &lt;&gt; null, "No Harbour!");
	
	startTimezone := harbour.timezone;
	startDate := "30 Sep 2012".Date;
	endDate := "01 Apr 2012".Date;
	startTime := "02:00".Time;
	endTime := "03:00".Time;
	
	
	if harbour.timezone &lt;&gt; TimezoneUnknown then
		beginTransaction;
		harbour.setTimezone( TimezoneUnknown );
		commitTransaction;
	endif;	
	
	ts.setDate(startDate);
	ts.setTime(startTime);
	ts.checkIfDaylightSaving( dstChangesToday, harbour.getTimezoneDescr );
	self.assertTrueMsg( dstChangesToday = false, "Zone of " &amp; TimezoneUnknownStr &amp; " should return false for any date. [" &amp; ts.String &amp; "](1)" );
	
	ts.setDate(startDate - 1);
	ts.checkIfDaylightSaving( dstChangesToday, harbour.getTimezoneDescr );
	self.assertTrueMsg( dstChangesToday = false, "Zone of " &amp; TimezoneUnknownStr &amp; " should return false for any date. [" &amp; ts.String &amp; "](2)" );
	
	
	beginTransaction;
	harbour.setTimezone( TimezoneNZ );
	commitTransaction;
	
	ts.setDate(startDate);
	ts.setTime(startTime);	// The time and day light savings starts
	ts.checkIfDaylightSaving( dstChangesToday, harbour.getTimezoneDescr );
	self.assertTrueMsg( dstChangesToday = true, "Zone of " &amp; TimezoneNZStr &amp; " should return true for [" &amp; ts.String &amp; "](3)" );
	
	ts.setDate(startDate - 1);
	ts.setTime(startTime);	// 24 hours before time and day light savings starts
	ts.checkIfDaylightSaving( dstChangesToday, harbour.getTimezoneDescr );
	self.assertTrueMsg( dstChangesToday = false, "Zone of " &amp; TimezoneNZStr &amp; " should return false for [" &amp; ts.String &amp; "](4)" );
	
	ts.setDate(startDate - 1);
	ts.setTime( startTime.cnEcAddHours(11) );	// 12 hours 01 mins before time and day light savings starts
	ts.setTime( ts.time.cnEcAddMinutes(59));
	ts.checkIfDaylightSaving( dstChangesToday, harbour.getTimezoneDescr );
	self.assertTrueMsg( dstChangesToday = false, "Zone of " &amp; TimezoneNZStr &amp; " should return false for [" &amp; ts.String &amp; "](5)" );
	
	ts.setDate(startDate - 1);
	ts.setTime( startTime.cnEcAddHours(12) );	// 11 hours 59 mins before time and day light savings starts
	ts.setTime( ts.time.cnEcAddMinutes(1));
	ts.checkIfDaylightSaving( dstChangesToday, harbour.getTimezoneDescr );
	self.assertTrueMsg( dstChangesToday = true, "Zone of " &amp; TimezoneNZStr &amp; " should return true for [" &amp; ts.String &amp; "](6)" );
	
	ts.setDate(startDate);
	ts.setTime(startTime.cnEcAddHours(12));	// 11 hours 59 mins after time and day light savings starts (remembering we have added one for ds)
	ts.setTime( ts.time.cnEcAddMinutes(59));
	ts.checkIfDaylightSaving( dstChangesToday, harbour.getTimezoneDescr );
	self.assertTrueMsg( dstChangesToday = true, "Zone of " &amp; TimezoneNZStr &amp; " should return true for [" &amp; ts.String &amp; "](7)" );
	
	ts.setDate(startDate);
	ts.setTime(startTime.cnEcAddHours(13));
	ts.setTime( ts.time.cnEcAddMinutes(1));	// 12 hours 01 mins after time and day light savings starts (remembering we have added one for ds)
	ts.checkIfDaylightSaving( dstChangesToday, harbour.getTimezoneDescr );
	self.assertTrueMsg( dstChangesToday = false, "Zone of " &amp; TimezoneNZStr &amp; " should return false for [" &amp; ts.String &amp; "](8)" );
	
	ts.setDate(endDate);
	ts.setTime(endTime);	// The time and day light savings ends
	ts.checkIfDaylightSaving( dstChangesToday, harbour.getTimezoneDescr );
	self.assertTrueMsg( dstChangesToday = true, "Zone of " &amp; TimezoneNZStr &amp; " should return true for [" &amp; ts.String &amp; "](9)" );
	
	ts.setDate(endDate - 1);
	ts.setTime(endTime.cnEcAddHours(12));
	ts.setTime( ts.time.cnEcAddMinutes(-1)); // 12 hours 01 mins before time and day light savings ends
	ts.checkIfDaylightSaving( dstChangesToday, harbour.getTimezoneDescr );
	self.assertTrueMsg( dstChangesToday = false, "Zone of " &amp; TimezoneNZStr &amp; " should return false for [" &amp; ts.String &amp; "](10)" );
	
	ts.setDate(endDate - 1);
	ts.setTime(endTime.cnEcAddHours(12));
	ts.setTime( ts.time.cnEcAddMinutes(1)); // 11 hours 59 mins before time and day light savings ends
	ts.checkIfDaylightSaving( dstChangesToday, harbour.getTimezoneDescr );
	self.assertTrueMsg( dstChangesToday = false, "Zone of " &amp; TimezoneNZStr &amp; " should return false for [" &amp; ts.String &amp; "](11)" );
	
	ts.setDate(endDate);
	ts.setTime(endTime.cnEcAddHours(11));
	ts.setTime( ts.time.cnEcAddMinutes(59));
	ts.checkIfDaylightSaving( dstChangesToday, harbour.getTimezoneDescr );
	self.assertTrueMsg( dstChangesToday = true, "Zone of " &amp; TimezoneNZStr &amp; " should return true for [" &amp; ts.String &amp; "](12)" );
	
	ts.setDate(endDate);
	ts.setTime(endTime.cnEcAddHours(12));
	ts.setTime( ts.time.cnEcAddMinutes(01));
	ts.checkIfDaylightSaving( dstChangesToday, harbour.getTimezoneDescr );
	self.assertTrueMsg( dstChangesToday = false, "Zone of " &amp; TimezoneNZStr &amp; " should return false for [" &amp; ts.String &amp; "](13)" );
	
epilog

	if harbour &lt;&gt; null and startTimezone &lt;&gt; harbour.timezone then
		abortTransaction;
		beginTransaction;
		harbour.setTimezone(startTimezone);
		commitTransaction;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="tTestGetTide" id="df5b0756-27ca-49fa-9e56-d22bba2eb0bb">
        <source>tTestGetTide();
// cnwrs1
//19 December 2011	cnwgb1
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 December 2011	cnwgb1	Initial creation

*/
vars
	rvTide : HMS_RvTide;
	str : String;
	ok : Integer;
	times : TimeStampArray;
	days : RealArray;
	tides : RealArray;
    reference : StringArray;
	timeStamp : TimeStamp;
	tide : Real;
	i : Integer;
	date: Date;
	time : Time;
	interval, readings : Integer;
    returnedTideString : String;
begin

	if app.isUnicode then						// 30/06/2015 cnwmh5
		return;
	endif;

	interval := 10; //minutes
	readings := 42;
	create rvTide transient;
	create times transient;
	create days transient;
    create reference transient;

    reference[ 1] := "0.949326";    
    reference[ 2] := "0.845908";    
    reference[ 3] := "0.746397";    
    reference[ 4] := "0.652794";    
    reference[ 5] := "0.566393";    
    reference[ 6] := "0.487801";    
    reference[ 7] := "0.417020";    
    reference[ 8] := "0.353560";    
    reference[ 9] := "0.296586";    
    reference[10] := "0.245061";    
    reference[11] := "0.197887";    
    reference[12] := "0.154015";    
    reference[13] := "0.112518";    
    reference[14] := "0.072621";
    reference[15] := "0.033694";
    reference[16] := "-0.004793";
    reference[17] := "-0.043338";
    reference[18] := "-0.082479";
    reference[19] := "-0.122863";    
    reference[20] := "-0.165293";    
    reference[21] := "-0.210737";    
    reference[22] := "-0.260304";    
    reference[23] := "-0.315170";    
    reference[24] := "-0.376469";    
    reference[25] := "-0.445159";    
    reference[26] := "-0.521869";    
    reference[27] := "-0.606754";    
    reference[28] := "-0.699371";    
    reference[29] := "-0.798597";    
    reference[30] := "-0.902593";    
    reference[31] := "-1.008844";    
    reference[32] := "-1.114246";    
    reference[33] := "-1.215268";    
    reference[34] := "-1.308156";    
    reference[35] := "-1.389163";    
    reference[36] := "-1.454802";    
    reference[37] := "-1.502078";    
    reference[38] := "-1.528686";    
    reference[39] := "-1.533161";    
    reference[40] := "-1.514960";    
    reference[41] := "-1.474460";    
    reference[42] := "-1.412897";    
    reference[43] := "-1.332223";    
	str := "bbeacon.nml";
	date.setDate(05,11,2010);
	time.setTime(0,0,0,0);
	timeStamp.setDate(date);
	timeStamp.setTime(time);
	times.add(timeStamp);
	foreach i in 1 to readings do
		timeStamp := timeStamp.addMinutes(interval);
		times.add(timeStamp);
	endforeach;
	create tides transient;
	rvTide.convertTSArrayToDaysArray(times, days);
    //write str.String&amp;' '&amp;days.String&amp;' '&amp;tides.String;
	ok := rvTide.xGetTide(str, days, tides);
	i := 1;
    assertEqualMsg(0, ok, "Error returned from GetTide");
	if ok = 0 then
		foreach tide in tides do
            returnedTideString := tide.asStringJMTWithPrecision(6, false);
            assertEqualMsg( returnedTideString, reference[i], 'for time '&amp;times[i].String);
            i := i + 1;
		endforeach;
	endif;
epilog
	delete rvTide;
	delete times;
	delete tides;
	delete days;
    delete reference;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tTestRvTide" id="16c346e2-ecf8-45a0-abaa-9cb46bee8236">
        <source>tTestRvTide();
// cnwrs1
//19 December 2011	cnwgb1
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 December 2011	cnwgb1	Initial creation

*/
vars
	rvTide : HMS_RvTide;
	gaugePredictions, currentPredictions, idx : Integer;
    str : String;
    
	times : TimeStampArray;
	days : RealArray;
	tides : RealArray;
    speeds : RealArray;
    refGauge : StringArray;
    refCurrent : StringArray;
	timeStamp : TimeStamp;
    returnedTideString : String;
	tide : Real;
    speed : Real;
	i,n : Integer;
	date: Date;
	time : Time;
begin

	if app.isUnicode then						// 30/06/2015 cnwmh5
		return;
	endif;

	create rvTide transient;
	create times transient;
	create days transient;
    create refGauge transient;
	create refCurrent transient;
	create tides transient;
	create speeds transient;
 
    refGauge[1] := "0.614461";
    refGauge[2] := "1.055274";
    refGauge[3] := "1.707661";
    refGauge[4] := "0.070565";
    refGauge[5] := "1.872025";
    
    refCurrent[1] := "-3.783818";
    refCurrent[2] := "2.368312";
    refCurrent[3] := "-0.882095";
    refCurrent[4] := "-2.056994";
    refCurrent[5] := "3.030468"; 
    
	rvTide.xGetNumPredictions( gaugePredictions, currentPredictions);
    assertEqualMsg(gaugePredictions, 3, "Number of gauge predictions wrong");
    assertEqualMsg(currentPredictions, 1, "Number of current predictions wrong");
     
    foreach idx in 1 to gaugePredictions do
        str := rvTide.xGetGaugeLabel(idx).trimLeft.trimRight;
        if     idx = 1 then
            if str &lt;&gt; "Tauranga, A Buoy" and str &lt;&gt; "Tauranga, A Bouy" then  // Tee Hee - Misspellings in the 32 bit RvTide only
                assertEqualMsg( str, "Tauranga, A Buoy", "Gauge label is wrong");
            endif;
        elseif idx = 2 then
            assertEqualMsg( str, "Tauranga, Tug Berth", "Gauge label is wrong"); 
        elseif idx = 3 then
            if str &lt;&gt; "Tauranga, Sulphur Point" and str &lt;&gt; "Tauranga, Sulpher Point" then // Tee Hee - Misspellings in the 32 bit RvTide only
                assertEqualMsg( str, "Tauranga, Sulphur Point", "Gauge label is wrong");
            endif;
        endif;
    endforeach;
        
    foreach idx in 1 to currentPredictions do
        str := rvTide.xGetCurrentLabel(idx).trimLeft.trimRight;
        if idx = 1 then 
            assertEqualMsg( str, "Tauranga Entrance ADCP", "Current label is wrong");
        endif;
    endforeach;

	date.setDate(01,01,2014);
	time.setTime(11,20,47,0);
	timeStamp.setDate(date);
	timeStamp.setTime(time);
	times.add(timeStamp);
	foreach n in 1 to 4 do
		timeStamp := timeStamp.addMinutes(288);
		times.add(timeStamp);
	endforeach;
    idx := 1;
    rvTide.xGetTideGaugeLevel(idx, times, tides);
 /*   
    write( "Tides========================");
    n := 1;
    foreach tide in tides do
        write(n.asStringJMT &amp; " " &amp; times[n].asStringJMT &amp; " " &amp; tide.asStringJMT);
        returnedTideString := tide.asStringJMTWithPrecision(6, false);
        //assertEqualMsg( returnedTideString, refGauge[n], 'for time '&amp;times[n].String);
        n:= n+1;
    endforeach; 
    write( "Currents=====================");
    
    rvTide.xGetFloodCurrent(idx, times, speeds );
    n := 1;
    foreach speed in speeds do
        write(n.asStringJMT &amp; " " &amp; times[n].asStringJMT &amp; " " &amp; speed.asStringJMT);
        returnedTideString := speed.asStringJMTWithPrecision(6, false);
        //assertEqualMsg( returnedTideString, refCurrent[n], 'for time '&amp;times[n].String);
        n:= n+1;
    endforeach; 
*/    
epilog
	delete rvTide;
    delete times;
	delete days;
    delete refGauge;
    delete refCurrent;
    delete tides;
    delete speeds;
end;
</source>
    </JadeMethod>
</Class>
