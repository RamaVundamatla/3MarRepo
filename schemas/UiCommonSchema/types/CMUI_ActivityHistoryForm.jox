    <JadeMethod name="tblActivity_contextMenu" id="2942fe68-4c2a-428d-9243-617fc4a902c8">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblActivity_contextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
23 August 2024	navpw1	Modified the method called for visibility of mnuInspect to match what is used everywhere else in code

*/
vars
	selectedObject : Object;
	extInterface : CM_ActivityHistoryExtInterface;
begin
	//Par17332	11/07/2008
	self.mnuSAExtra.enabled := self.tblActivity.allSelectedObjects.size &gt; 0;	//disable when there are no rows selected
	self.mnuSADelete.enabled := self.tblActivity.allSelectedObjects.size &gt; 0;
	//epr TFS 42098 25/11/18
	self.mnuResend.visible:= false;
	self.mnuInspect.visible:=false;
	self.mnuReprocess.visible := false;	//27 Sep 2019	NDL	TFS 46758
	
	if self.tblActivity.allSelectedObjects.size = 1 then
		//self.mnuInspect.visible:=app.isDevelopmentSystem or app.getMyUser.isSuperUser;
		self.mnuInspect.visible := app.isAllowedToInspect();
		selectedObject:=self.tblActivity.allSelectedObjects.first;
		self.mnuInspect.userObject:=selectedObject;
		if selectedObject.isKindOf(CM_ActivityHistoryExtInterface) then
			extInterface:= selectedObject.CM_ActivityHistoryExtInterface;
			//11/10/21 jlier1 TFS 51963
			//27 Sep 2019	NDL	TFS 46758
			if app.myCurrentUserCan( self.myTerminal, PmInvSAPReprocess ) then
				if extInterface.canReprocessSapResponse then
					self.mnuReprocess.visible := true;
					self.mnuReprocess.userObject := extInterface;
				endif;
			endif;
		endif;
	endif;
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnDelete.enabled := false;
		self.mnuSADelete.enabled:= false;
	endif;
	
	
	return self.showContextMenu(mnuSA, cntrl, conwin, mouse, x, y);

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
