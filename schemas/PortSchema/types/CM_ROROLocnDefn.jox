    <JadeMethod name="createRealSlots" id="dd9ae7bc-e33f-4922-bda7-81d8c4826da4">
        <updating/>
        <source>createRealSlots(_proxyDeckItem: CM_ROROLocnDefn; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

	pxySlot : CM_ROROSlotDefn;
	realSlot : CM_ROROSlotDefn;
begin
	foreach pxySlot in _proxyDeckItem.allROROSlotDefnByOrdinal discreteLock do
		pxySlot.setRealLocnDefn(self);
		app.myUtilityCA.utlCreateROROSlotDefn(pxySlot, realSlot, _passport);
		pxySlot.setRealLocnDefn(_proxyDeckItem); // AKB to fix UT proxy cleanup
	
	endforeach;

epilog

end;</source>
        <Parameter name="_proxyDeckItem" type="CM_ROROLocnDefn"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
