end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="jtdObjNotFoundExceptionHandler" id="70ba7157-0899-4ecc-8676-6cd31c464f1a">
        <source>jtdObjNotFoundExceptionHandler(exObj : Exception; error : Boolean output) : Integer protected;

vars

begin
	if exObj.errorCode = 4 		or
	   exObj.errorCode = 1046	or				// invalid class number
	   exObj.errorCode = 1072   or
	   exObj.errorCode = 1090 	or
	   exObj.errorCode = 1092	then
	   	error := true;
		return Ex_Resume_Next;
		
	else
		return Ex_Pass_Back;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="error" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="logMessage" id="47957bf0-b8ef-40dc-8d78-47b318a21895">
        <updating/>
        <source>logMessage(s:String) updating;
/*  Uses the JadeLog class to write a message to msg&lt;n&gt;.log  */
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
begin
	if msgLog=null then
		create msgLog;
		msgLog.fileName:="msg";
		msgLog.formatOutput:=false;
//		msgLog.maxFileSize:=1000;  // leave commented out to use value from ini file
	endif;
	msgLog.log(actualTimeServer.logFormat&amp;" "&amp;(getIdString&amp;" ").padBlanks(24)&amp;s&amp;CrLf);	// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
end;
</source>
        <Parameter name="s" type="String"/>
    </JadeMethod>
    <JadeMethod name="msgBox" id="8771e260-b9b1-441f-88f8-a4a6bd78773f">
        <source>msgBox(msg:String; title:String; flags:Integer):Integer;
//	reimplemented to capture and action msgboxes
begin
	if atcgRunningAtcg and not atcgRunningAtcgReplay then
		if msg.jtdContains("Are you sure you want to exit") and flags = MsgBox_Question_Mark_Icon + MsgBox_Yes_No + MsgBox_Default_Second and app.atcgCleanStartMode then
			return MsgBox_Return_Yes;
		else
			return inheritMethod(msg, title, flags);  // comment out this line to auto-close msgBoxes
		endif;
	endif;
	
	/*if msg.jtdContains("Wrong user code or password") then
		return MsgBox_Return_OK;  // don't log it
	endif;/**/
	
	app.logMessage(method.qualifiedName&amp;' msg=&lt;'&amp;msg.jtdReplace(Cr,'\r').jtdReplace(Lf,'\n')&amp;'&gt; title=&lt;'&amp;title&amp;'&gt; flags=&lt;'&amp;flags.String&amp;'&gt;');

	if msg.jtdContains("This form will now be closed") then
		app.logMessage(method.qualifiedName&amp;" -------------------------------------");
		app.logMessage(method.qualifiedName&amp;" Error - This form will now be closed");
		app.logMessage(method.qualifiedName&amp;" -------------------------------------");
	endif;

	if msg.jtdContains("These will now be inspected") then  // this will cause a hang
		app.logMessage(method.qualifiedName&amp;" releasing control lock");
		app.controlLockRelease;
	endif;
	
	if  (flags = MsgBox_Question_Mark_Icon + MsgBox_Yes_No or flags = MsgBox_Question_Mark_Icon + MsgBox_Yes_No + MsgBox_Default_Second or flags = MsgBox_Yes_No)
	and (msg.jtdContains("Are you sure you want to exit")
	or   msg.jtdContains("Exiting will close this application. Are you sure you wish to exit?")
	or   msg.jtdContains("Do you want to abandon your changes")
	or   msg.jtdContains("Resetting the OOW Creation resets all the")
	or   msg.jtdContains("Do you want to auto set the OOW Creation details")//OOW creation screen
	or   msg.jtdContains("Are you sure that you want to create the OOW for voyage")//OOW creation screen
	or   msg.jtdContains("Are you sure you want to delete  the selected item?") 
	or   msg.jtdContains("You are about to delete all of the sheets, do you wish to continue?")
	or  (msg.jtdContains("Instant Move tracked item(s)") and msg.jtdContains("to location") and msg.jtdContains("Do you wish to continue?"))
	or  (msg.jtdContains("Make EDI Bay Plan") and msg.jtdContains("Actual?"))) then
		app.logMessage(method.qualifiedName&amp;" clicking Yes button");
		return MsgBox_Return_Yes;

	elseif  (flags = MsgBox_Question_Mark_Icon + MsgBox_Yes_No or flags = MsgBox_Question_Mark_Icon + MsgBox_Yes_No + MsgBox_Default_Second or flags = MsgBox_Yes_No)
	and (msg.jtdContains("Do you want to reset all cranes")  //OOW creation screen
	or   msg.jtdContains("Check communication status with RefCon?")) then
		app.logMessage(method.qualifiedName&amp;" clicking No button");
		return MsgBox_Return_No;

	elseif (flags = MsgBox_Default_Second + MsgBox_Yes_No)
	and msg.jtdContains("You have not entered sufficient information to save this sheet.  Do you wish to delete it?") then
		app.logMessage(method.qualifiedName&amp;" clicking Yes button");
		return MsgBox_Return_Yes;
		
	elseif  (flags = MsgBox_OK_Only or flags = MsgBox_Stop_Icon or flags = MsgBox_Question_Mark_Icon + MsgBox_Stop_Icon or flags = MsgBox_Exclamation_Mark_Icon or flags = MsgBox_Information_Icon)
	and not msg.jtdContains("blerch") then
		if msg.jtdContains("The system could not log you on") then
			//if 14/0=1 then endif;
			app.logMessage(method.qualifiedName&amp;" terminating");
			terminate;
		else
			app.lastMsgBoxText:=msg;
			app.logMessage(method.qualifiedName&amp;" clicking OK button");
		endif;
		return MsgBox_Return_OK;
		
	elseif  (flags = MsgBox_OK_Cancel)
	and msg.jtdContains("Are you sure you want to log off?") then
		app.logMessage(method.qualifiedName&amp;" clicking OK button");
		return MsgBox_Return_OK;

	else
		write method.qualifiedName&amp;" "&amp;msg&amp;" "&amp;title&amp;" "&amp;flags.String;
		app.logMessage(method.qualifiedName&amp;" "&amp;msg&amp;" "&amp;title&amp;" "&amp;flags.String);
		return inheritMethod(msg, title, flags);
	endif;/**/
end;</source>
        <Parameter name="msg" type="String"/>
        <Parameter name="title" type="String"/>
        <Parameter name="flags" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setProcessUserInfo" id="cee92a3f-33ee-403d-8841-56537c3aa2a6">
        <source>setProcessUserInfo();

begin
	beginTransaction;
	//process.userInfo := "Jtd - (" &amp; app.computerName.toLower &amp; ")";
	process.userInfo := getIdString&amp;"@"&amp;app.computerName.toLower;
	commitTransaction;
end;
</source>
    </JadeMethod>
    <JadeMethod name="setSequenceId" id="687f5c33-9202-44e0-ab63-a77c782a1f95">
        <updating/>
        <source>setSequenceId() updating;
//	among all running apps of the same name, which one am I?
vars
	nod:Node;
	proc:Process;
	invalid:Boolean;
begin
	sequenceId:=0;
	profileSequenceId:=0;
	processId:=getInstanceIdForObject(process).Integer;
	
	on Exception do app.handleDeletedObject(exception, proc, invalid);
	
	foreach nod in system.nodes discreteLock do
		foreach proc in nod.processes discreteLock do
			if proc.persistentApp.name = process.persistentApp.name then
				if getInstanceIdForObject(proc) &lt; processId then
					sequenceId:=sequenceId+1;
					if getProcessProfileName(proc) = profileName then
						profileSequenceId:=profileSequenceId+1;
					endif;
				endif;
			endif;
		endforeach;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="unloadAllForms" id="ec51c931-5bd1-4f2b-ad57-25294c02a302">
        <source>unloadAllForms();

vars
	idx:Integer;
	form:Form;
begin
	idx := app.formsCount;
	while idx &gt; 0 do
		form := app.forms(idx);
		if form &lt;&gt; null
		and (not form.isKindOf(JtdDriverForm)) then
			// the error warning form is unloaded in the app.logout method.
			app.logMessage(method.qualifiedName&amp;" unloading surplus form '"&amp;form.caption&amp;"'("&amp;form.class.name&amp;")");
			form.unloadForm;
			delete form;
		endif;
		idx := idx - 1;
	endwhile;
end;</source>
    </JadeMethod>
</Class>
