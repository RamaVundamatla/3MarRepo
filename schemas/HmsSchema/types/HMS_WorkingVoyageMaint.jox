    <JadeMethod name="doDeleteClones" id="eb6faf9a-b098-4a28-97de-4f1032cab5b0">
        <updating/>
        <source>doDeleteClones() updating, protected;
//--------------------------------------------------
// Created:	21 January 2004 By: cnwgd1
//--------------------------------------------------
vars
 	clonedMovement	: CMIF_HMS_WorkingMovement;
	
begin
	if self.myCurrentWorkingVoyage = null then
		return;
	endif;
	
	// Add or Edit of voyage has been aborted
	// Delete clonedVoyage, resources and movements
	
	foreach clonedMovement in self.myCurrentWorkingVoyage.allClonedMovements do
		clonedMovement.allWorkingResUsed.purge();
		
		if self.mode = self.Mode_Update then
			clonedMovement.myClonedMovement	:=	null;
			clonedMovement.myClonedVoyage	:=	null;
		endif;
	endforeach;
	
	self.myCurrentWorkingVoyage.allClonedMovements.purge();
	self.myCurrentVessel	:=	null;
	delete self.myCurrentWorkingVoyage;
end;</source>
        <access>protected</access>
    </JadeMethod>
