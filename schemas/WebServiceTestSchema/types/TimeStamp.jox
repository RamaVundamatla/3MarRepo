<PrimType name="TimeStamp">
    <JadeMethod name="getNumeralString" id="dfe42331-2d42-4de5-b276-eae6d097bbbe">
        <source>getNumeralString() : String;

/*

Purpose:			Return a string containing the numerals of the receiver in a format
					that can be sorted, or used to build a time-sensitive returnString


Return Value:		String containing the digits of the receiver, unique down to milliseconds


Date		Who		Reason
30 Aug 2005	KPD		Initial creation

*/

vars
	returnString	: String;
	myDate			: Date;
	myTime			: Time;
	
begin
	myDate := self.Date;
	if myDate = null then
		returnString := "00000000";
	else
		returnString := myDate.year.String.padLeadingZeros(4);
		returnString := returnString &amp; myDate.month.String.padLeadingZeros(2);
		returnString := returnString &amp; myDate.day.String.padLeadingZeros(2);
	endif;
	myTime := self.Time;
	returnString := returnString &amp; myTime.hour.String.padLeadingZeros(2);
	returnString := returnString &amp; myTime.minute.String.padLeadingZeros(2);
	returnString := returnString &amp; myTime.second.String.padLeadingZeros(2);
	returnString := returnString &amp; myTime.milliSecond.String.padLeadingZeros(3);

	return returnString;
			

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="xmlFormat" id="38484667-2583-4b5e-b9a6-1561a23eefce">
        <source>xmlFormat() : String;

/*

Purpose:			


Return Value:		


Date		Who		Reason
02 November 2004	cnwkpd1	PAR #4801 - Web Service application

*/

vars

begin
	return self.date.format("dd/MM/yyy") &amp; " " &amp; self.time.format("HH:mm");

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</PrimType>
