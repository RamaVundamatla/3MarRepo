    <JadeMethod name="setPxyFromCMGTE_Receival" id="08ae761f-9ddb-4ffd-8e71-b18f8f5fc4d3">
        <updating/>
        <source>setPxyFromCMGTE_Receival(_pxyGTE: CMGTE_Receival; _passport: CM_Passport input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/08/2009	cnwjk3	Initial creation
12/10/2009	cnwdap1	PAR #21139 Colour attribute added
11/05/2022	jlika1	TFS 53316 - EUP - GEN - Additional Dimensions For Cargo - PortSchema
*/

vars

begin
	inheritMethod(_pxyGTE, _passport);
	self.widthString 		:= _pxyGTE.widthString;
	self.heightString		:= _pxyGTE.heightString;
	self.lengthString 		:= _pxyGTE.lengthString;	 
	self.type				:= _pxyGTE.type;
	self.unsplitQuantity	:= _pxyGTE.totalQuantity;
	self.unsplitVolume		:= _pxyGTE.getMyVolume;
	self.unsplitWeight		:= _pxyGTE.weight;
	self.colour				:= _pxyGTE.colour;
	// jlika1 TFS 53316 --&gt;
	//self.diameter		:= _pxyGTE.diameter;
	self.setDiameter(_pxyGTE.diameter);				// ### TFS 54021 29June2022 NAVPW1
	//self.grade			:= _pxyGTE.grade;
	self.setGrade(_pxyGTE.grade);					// ### TFS 54021 29June2022 NAVPW1
	//self.grammage		:= _pxyGTE.grammage;
	self.setGrammage(_pxyGTE.grammage);				// ### TFS 54021 29June2022 NAVPW1
	//self.rollingLength	:= _pxyGTE.rollingLength;
	self.setRollingLength(_pxyGTE.rollingLength);	// ### TFS 54021 29June2022 NAVPW1
	// jlika1 TFS 53316 &lt;--
epilog

end;</source>
        <Parameter name="_pxyGTE" type="CMGTE_Receival"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setPxyFromCMIF_InOutAttachment" id="7e19389f-7d3f-4bad-8a90-ef9f85c7dd56">
        <updating/>
        <source>setPxyFromCMIF_InOutAttachment(_intFaceInOut: CMIF_InOutAttachment;_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     23 October 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
12/05/2022	jlika1		TFS 53316 - EUP - GEN - Additional Dimensions For Cargo - PortSchema
============================================================================*/
vars

begin
	inheritMethod(_intFaceInOut, _passport);
	
	self.colour				:= _intFaceInOut.colourDesc;
	self.widthString 		:= _intFaceInOut.widthString;
	self.heightString		:= _intFaceInOut.heightString;
	self.lengthString 		:= _intFaceInOut.lengthString;	 
	self.type				:= _intFaceInOut.type;
	// jlika1 TFS 53316 --&gt;
	//self.diameter		:= _intFaceInOut.diameter;
	self.setDiameter(_intFaceInOut.diameter); 			// ### TFS 54021 29June2022 NAVPW1
	//self.grade			:= _intFaceInOut.grade;
	self.setGrade(_intFaceInOut.grade);					// ### TFS 54021 29June2022 NAVPW1
	//self.grammage		:= _intFaceInOut.grammage;
	self.setGrammage(_intFaceInOut.grammage);			// ### TFS 54021 29June2022 NAVPW1
	//self.rollingLength	:= _intFaceInOut.rollingLength;
	self.setRollingLength(_intFaceInOut.rollingLength);	// ### TFS 54021 29June2022 NAVPW1
	// jlika1 TFS 53316 &lt;--
	
end;</source>
        <Parameter name="_intFaceInOut" type="CMIF_InOutAttachment"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setPxyFromCMIF_Receival" id="819046bb-0504-4fca-b887-93bd1ca73d66">
        <updating/>
        <source>setPxyFromCMIF_Receival(isUpdateTI: Boolean;_receival: CMIF_Receival; _passport: CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	21 April 2006	by Jason Chapman  (cnwjc2)
// 17/04/2018    jlgrh7 TFS 38055 MSL - coparn deletes stop fields
// 12/05/2022	 jlika1	TFS 53316 - EUP - GEN - Additional Dimensions For Cargo - PortSchema
//----------------------------------------------------------------
vars

	handlingType : CM_HandlingType;
	palletDetailsTI : CM_PalletDetailsTI;
	palletType :	CM_PalletType;

begin
	inheritMethod(isUpdateTI,_receival, _passport);				//+TFS38055
	
	self.widthString 		:= _receival.widthString;
	self.heightString		:= _receival.heightString;
	self.lengthString 		:= _receival.lengthString;	 
	self.type				:= _receival.type;
	self.unsplitQuantity	:= _receival.numberOfItems;
	self.unsplitVolume		:= _receival.volume;
	self.unsplitWeight		:= _receival.weight;
	self.colour				:= _receival.colour;
	
	//24 Apr 2017	NDL	TFS 3414
	handlingType := self.getHandlingType;
	if handlingType &lt;&gt; null and handlingType.isPallet then
		if _receival.palletType &lt;&gt; null then
			palletType := handlingType.getHandlingSubType( _receival.palletType ).CM_PalletType;
		endif;
		
		if palletType &lt;&gt; null then
			if self.myPalletDetailsTI = null then
				create palletDetailsTI transient;
				palletDetailsTI.setMyTrackedItem( self );
			endif;
			self.myPalletDetailsTI.setBaseDetails(	_receival.heatTreated,	//_heatTreated : Boolean;
													_receival.storeOnPallet,	//_storeOnPallets : Boolean;
													palletType	//_myPalletType :	CM_PalletType
													);
		else
			if self.myPalletDetailsTI &lt;&gt; null then
				delete self.myPalletDetailsTI;
			endif;
		endif;
	endif;
	
	// jlika1 TFS 53316 --&gt;
	//self.diameter		:= _receival.diameter;
	self.setDiameter(_receival.diameter);			// ### TFS 54021 29June2022 NAVPW1
	//self.grade			:= _receival.grade;
	self.setGrade(_receival.grade); 				// ### TFS 54021 29June2022 NAVPW1
	//self.grammage		:= _receival.grammage;
	self.setGrammage(_receival.grammage);			// ### TFS 54021 29June2022 NAVPW1
	//self.rollingLength	:= _receival.rollingLength;
	self.setRollingLength(_receival.rollingLength);	// ### TFS 54021 29June2022 NAVPW1
	// jlika1 TFS 53316 &lt;--
end;</source>
        <Parameter name="isUpdateTI" type="Boolean"/>
        <Parameter name="_receival" type="CMIF_Receival"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setPxyFromEDIPackTI" id="f949563d-8c86-4bae-b57a-dc0b9bc7301b">
        <updating/>
        <source>setPxyFromEDIPackTI(_ediTi: CM_EDIPackTI; _updateController: CMIF_TIUpdateController input; _passport: CM_Passport input) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 13 June 2022
TFS#		: 53316
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	inheritMethod(_ediTi, _updateController, _passport);
	
	if _ediTi.diameter &lt;&gt; null then
		//self.diameter := _ediTi.diameter;
		self.setDiameter(_ediTi.diameter); 				// ### TFS 54021 29June2022 NAVPW1
	endif;
	
	if _ediTi.grade &lt;&gt; null then
		//self.grade := _ediTi.grade;
		self.setGrade(_ediTi.grade); 					// ### TFS 54021 29June2022 NAVPW1
	endif;
	
	if _ediTi.grammage &lt;&gt; null then
		//self.grammage := _ediTi.grammage;
		self.setGrammage(_ediTi.grammage);				// ### TFS 54021 29June2022 NAVPW1
	endif;
	
	if _ediTi.rollingLength &lt;&gt; null then
		//self.rollingLength := _ediTi.rollingLength;
		self.setRollingLength(_ediTi.rollingLength);	// ### TFS 54021 29June2022 NAVPW1
	endif;

end;</source>
        <Parameter name="_ediTi" type="CM_EDIPackTI"/>
        <Parameter name="_updateController" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setPxyFromFieldValue" id="24c1352d-33f4-49a4-bb0a-ffd4619414be">
        <updating/>
        <source>setPxyFromFieldValue(_fieldName: String; _fieldValue: String; _errLinkObj: Object; _passportObj: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 January 2020	jlgndl1	Initial creation	TFS 48250

*/

vars

	upperFieldName	: String;
	handlingType : CM_HandlingType;
	handlingSubType : CM_HandlingSubType;
	selectedPalletType : CM_PalletType;

begin

	upperFieldName := _fieldName.toUpper;
	
	if upperFieldName = CM_EDICargoFieldUpdateTI.F_HeatTreated.toUpper then
		if self.myPalletDetailsTI = null then
			create self.myPalletDetailsTI transient;
		endif;
		self.myPalletDetailsTI.setBaseDetails(	_fieldValue.asBooleanJMT,
												self.myPalletDetailsTI.storeOnPallets,
												self.myPalletDetailsTI.myPalletType
												);
		
	
	elseif upperFieldName = CM_EDICargoFieldUpdateTI.F_PalletType.toUpper then
		if self.myPalletDetailsTI = null then
			create self.myPalletDetailsTI transient;
		endif;
		handlingType := app.myRoot.allHandlingTypes.getAtKey(TI_HandlingType_Pallets);
		if handlingType &lt;&gt; null then
			foreach handlingSubType in handlingType.allHandlingSubTypes do
				if handlingSubType.code.toUpper = _fieldValue.toUpper then
					selectedPalletType := handlingSubType.CM_PalletType;
					break;
				endif;
			endforeach;
		endif;
		self.myPalletDetailsTI.setBaseDetails(	self.myPalletDetailsTI.heatTreated,
												self.myPalletDetailsTI.storeOnPallets,
												selectedPalletType
												);
	
	elseif upperFieldName = CM_EDICargoFieldUpdateTI.F_StoreOnPallet.toUpper then
		if self.myPalletDetailsTI = null then
			create self.myPalletDetailsTI transient;
		endif;
		self.myPalletDetailsTI.setBaseDetails(	self.myPalletDetailsTI.heatTreated,
												_fieldValue.asBooleanJMT,
												self.myPalletDetailsTI.myPalletType
												);
	
	else
	
		inheritMethod(_fieldName, _fieldValue, _errLinkObj, _passportObj);
	
	endif;

epilog

end;</source>
        <Parameter name="_fieldName" type="String"/>
        <Parameter name="_fieldValue" type="String"/>
        <Parameter name="_errLinkObj" type="Object"/>
        <Parameter name="_passportObj" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setRollingLength" id="9c65d2ec-d7e7-426d-847c-b8eb11174f1d">
        <updating/>
        <source>setRollingLength(_rollingLength : Decimal) updating;
/* --------------------------------------------
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 13 May 2022
TFS#		: 53316
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	self.rollingLength := _rollingLength; // ### TFS 54021 22July2022 NAVPW1 - Using a virtual property
	//global.setExtraData(self.allExtraData, self, ExtraRollingLength, _rollingLength); // ### TFS 54021 29June2022 NAVPW1
	
end;</source>
        <Parameter name="_rollingLength" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setUnsplitValues" id="c9cc962c-702b-44f5-b6d9-595c44f30b35">
        <updating/>
        <source>setUnsplitValues() updating, protected;

// Created by cnwdvb1 on 18 May 2006

vars

	master : SelfType;
begin

	// Must be the original ti as splits should always set the master ti.
	if self.myMasterTi = null then
		self.getUnsplitQuantityVolWeight(self.unsplitQuantity, self.unsplitWeight, self.unsplitVolume);
	else
		master := self.myMasterTi.CM_BreakBulkGeneric;
		self.getUnsplitQuantityVolWeight(master.unsplitQuantity, master.unsplitWeight, master.unsplitVolume);
	endif;


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setUserDefinedTI" id="c10b0a5c-1b0a-4da4-82af-bc3d8896445b">
        <updating/>
        <source>setUserDefinedTI(_ediTi 		  : CM_EDICargoTI; 
				_site 			  : Integer;
				_terminal		  : CM_Terminal;
				_updateController : CMIF_TIUpdateController input; 
				_passport 		  : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:	26 February 2010 By Graeme Black cnwgb1 PAR 22476
// Purpose:	Set values from EDI Cargo Load
// 29/06/2015   cnwma1		PAR #36540 CM_BreakBulkGeneric.unsplitQuantity returning 0 if cargo is created via user defined EDI file
// 11/05/2022	jlika1		TFS 53316 - EUP - GEN - Additional Dimensions For Cargo - PortSchema
// 07 Dec 2022  navma1 		ChangeRequest 52499: MTN - Improve the performance of the Edi file verification process.
// ---------------------------------------------------------------------------
vars
	handlingType 	: CM_HandlingType;
	palletDetailsTI : CM_PalletDetailsTI;
	palletType 		: CM_PalletType;
	heatTreated 	: Boolean;
	storeOnPallet 	: Boolean;
begin
	inheritMethod(_ediTi, _site, _terminal, _updateController, _passport);
	
	self.colour 		  := _ediTi.colour;
	self.heightString 	  := _ediTi.heightString;
	self.lengthString 	  := _ediTi.lengthString;
	self.widthString 	  := _ediTi.widthString;
	self.type 			  := _ediTi.breakBulkType;
	self.unsplitQuantity  := _ediTi.totalQuantity;    	 // 29/06/2015 cnwma1 PAR #36540
	self.unsplitVolume 	  := _ediTi.volume; 			 // 29/06/2015 cnwma1 PAR #36540
	self.unsplitWeight 	  := _ediTi.weight;  			 // 29/06/2015 cnwma1 PAR #36540
		
	//24 Apr 2017	NDL	TFS 3414
	handlingType := self.getHandlingType;
	if handlingType &lt;&gt; null and handlingType.isPallet then
		if _ediTi.palletType &lt;&gt; null then
			palletType := handlingType.getHandlingSubType( _ediTi.palletType ).CM_PalletType;
		endif;
		
		if palletType &lt;&gt; null then
			if self.myPalletDetailsTI = null then
				create palletDetailsTI transient;
				palletDetailsTI.setMyTrackedItem( self );
			endif;
			if _ediTi.heatTreated &lt;&gt; null then
				heatTreated := _ediTi.heatTreated.Boolean;
			endif;
			if _ediTi.storeOnPallet &lt;&gt; null then
				storeOnPallet := _ediTi.storeOnPallet.Boolean;
			endif;
			self.myPalletDetailsTI.setBaseDetails(	heatTreated,	//_heatTreated : Boolean;
													storeOnPallet,	//_storeOnPallets : Boolean;
													palletType		//_myPalletType :	CM_PalletType
													);
		else
			if self.myPalletDetailsTI &lt;&gt; null then
				delete self.myPalletDetailsTI;
			endif;
		endif;
	endif;
	
	/*
	All Extra Data
	*/
	
	//07.12.2022 navma1 #52499
	if _ediTi.messageMode = CM_EDITrackedItem.EDI_ACTION_ADD then
		
		if _ediTi.diameter &lt;&gt; null then
			self.setDiameter(_ediTi.diameter); 
		endif;
		
		if _ediTi.grade &lt;&gt; null then
			self.setGrade(_ediTi.grade); 
		endif;
		
		if _ediTi.grammage &lt;&gt; null then
			self.setGrammage(_ediTi.grammage);
		endif;
		
		if _ediTi.rollingLength &lt;&gt; null then
			self.setRollingLength(_ediTi.rollingLength);
		endif;
		
	else
		// jlika1 TFS 53316 --&gt;
		self.setDiameter(_ediTi.diameter); 				// ### TFS 54021 29June2022 NAVPW1
		self.setGrade(_ediTi.grade); 					// ### TFS 54021 29June2022 NAVPW1
		self.setGrammage(_ediTi.grammage);				// ### TFS 54021 29June2022 NAVPW1
		self.setRollingLength(_ediTi.rollingLength);	// ### TFS 54021 29June2022 NAVPW1
		// jlika1 TFS 53316 &lt;--
	endif;
	
	
epilog
end;</source>
        <Parameter name="_ediTi" type="CM_EDICargoTI"/>
        <Parameter name="_site" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_updateController" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setUserDefinedTIForModify" id="81a0a7fb-b015-4e13-bbc6-beb63a6bfc83">
        <updating/>
        <source>setUserDefinedTIForModify(_ediTi: CM_EDICargoTI; _terminal: CM_Terminal; _updateController: CMIF_TIUpdateController input; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2014	cnwmc5	Initial creation	CCMS 2352
// 29/06/2015   cnwma1		PAR #36540 CM_BreakBulkGeneric.unsplitQuantity returning 0 if cargo is created via user defined EDI file
// 11/05/2022	jlika1		TFS 53316 - EUP - GEN - Additional Dimensions For Cargo - PortSchema
*/

vars

	handlingType : CM_HandlingType;
	palletType : CM_PalletType;
	palletDetailsTI : CM_PalletDetailsTI;

begin

	inheritMethod(_ediTi, _terminal, _updateController, _passport);
	
	if _ediTi.colour &lt;&gt; null then
		self.colour := _ediTi.colour;
	endif;
	
	if _ediTi.heightString &lt;&gt; null then
		self.heightString := _ediTi.heightString;
	endif;
	
	if _ediTi.lengthString &lt;&gt; null then
		self.lengthString := _ediTi.lengthString;
	endif;
	
	if _ediTi.widthString &lt;&gt; null then
		self.widthString := _ediTi.widthString;
	endif;
	
	if _ediTi.breakBulkType &lt;&gt; null then
		self.type := _ediTi.breakBulkType;
	endif;
	
	if _ediTi.totalQuantity &lt;&gt; null then
		self.unsplitQuantity := _ediTi.totalQuantity;    // 29/06/2015 cnwma1 PAR #36540
	endif;
	
	if _ediTi.volume &lt;&gt; null then
		self.unsplitVolume := _ediTi.volume; 			 // 29/06/2015 cnwma1 PAR #36540
	endif;
	
	if _ediTi.weight &lt;&gt; null then
		self.unsplitWeight := _ediTi.weight;  			 // 29/06/2015 cnwma1 PAR #36540
	endif;
	
	//24 Apr 2017	NDL	TFS 3414
	handlingType := self.getHandlingType;
	if handlingType &lt;&gt; null and handlingType.isPallet then
		if _ediTi.palletType &lt;&gt; null then
			palletType := handlingType.getHandlingSubType( _ediTi.palletType ).CM_PalletType;
		endif;
		
		if palletType &lt;&gt; null then
			if self.myPalletDetailsTI = null then
				create palletDetailsTI transient;
				palletDetailsTI.setMyTrackedItem( self );
			endif;
			self.myPalletDetailsTI.setBaseDetails(	self.myPalletDetailsTI.heatTreated,	//_heatTreated : Boolean;
													self.myPalletDetailsTI.storeOnPallets,	//_storeOnPallets : Boolean;
													palletType	//_myPalletType :	CM_PalletType
													);
		
		endif;
		if self.myPalletDetailsTI &lt;&gt; null then
			if _ediTi.heatTreated &lt;&gt; null then
				self.myPalletDetailsTI.setBaseDetails(	_ediTi.heatTreated.Boolean,	//_heatTreated : Boolean;
														self.myPalletDetailsTI.storeOnPallets,	//_storeOnPallets : Boolean;
														self.myPalletDetailsTI.getPalletTypeObj	//_myPalletType :	CM_PalletType
														);
			endif;
			if _ediTi.storeOnPallet &lt;&gt; null then
				self.myPalletDetailsTI.setBaseDetails(	self.myPalletDetailsTI.heatTreated,	//_heatTreated : Boolean;
														_ediTi.storeOnPallet.Boolean,	//_storeOnPallets : Boolean;
														self.myPalletDetailsTI.getPalletTypeObj	//_myPalletType :	CM_PalletType
														);
			endif;
		endif;
	endif;	
	
	// jlika1 TFS 53316 --&gt;
	//self.diameter		:= _ediTi.diameter;
	self.setDiameter(_ediTi.diameter); 				// ### TFS 54021 29June2022 NAVPW1
	//self.grade			:= _ediTi.grade;
	self.setGrade(_ediTi.grade);					// ### TFS 54021 29June2022 NAVPW1
	//self.grammage		:= _ediTi.grammage;
	self.setGrammage(_ediTi.grammage);				// ### TFS 54021 29June2022 NAVPW1
	//self.rollingLength	:= _ediTi.rollingLength;
	self.setRollingLength(_ediTi.rollingLength);	// ### TFS 54021 29June2022 NAVPW1
	// jlika1 TFS 53316 &lt;--
epilog

end;</source>
        <Parameter name="_ediTi" type="CM_EDICargoTI"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_updateController" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="splitBreakBulkGeneric" id="69b2d9b1-d6a4-4621-88f7-290192b5927a">
        <updating/>
        <source>splitBreakBulkGeneric(_control : CMIF_MoveController input; _newIdForSplit : String ):CM_BreakBulkGeneric protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Apr 2013	cnwer1	Initial creation CCMS DPH 2274
28 Jul 2020	jlgdap1	TFS 49851 ASPA Satellite View Graphical Display
30 Aug 2024 navnk30	Bug 65775: EUP | Road job is not getting created if the partial quantity is given on the road gate form
12 Jun 2025 navhn30 Bug 35040: TPT - Instructions are lost when splitting cargo
12 Dec 2025 navsp1  MTN-36700  STWO - Damage Photos Not Visible for Multi-Quantity Cargo IDs After Full Discharge
*/

vars
	
	moveControl : CMIF_MoveController;
	newTI : CM_BreakBulkGeneric;	
	passport : CM_Passport;
	wowle,
	newWowle,
	moveWLE : CM_WorkListEntry;
	cloneId : String;
	newState : Integer;
	cargoGroup : CM_CargoGroup;
	trans : CM_TITransaction;
	storageConfig	: CM_StorageConfig;
	bulkRelease : CM_BulkRelease;
	instructions : CM_InstructionsIssued;
begin
	
	//update self quanity less the move quantity
	passport:=_control.myPassport;
	
	// PAR 36472
	storageConfig := self.myTerminal.myStorageConfig;
	if storageConfig &lt;&gt; null and storageConfig.includesTriggerType(CargoSplitMerge) then
		self.createStorageTransaction(_control,passport);
		if not passport.noErrors() then
			return null;
		endif;
	endif;
	
	if _newIdForSplit &lt;&gt; null then
		cloneId := _newIdForSplit;
	else
		cloneId := self.id;
	endif;
	
	//epr par 34472 if pack it sets location to null
	if _control.myToPrimaryLocation &lt;&gt; null then
		create moveControl transient;
		moveControl.setMyPassport(passport);	//19 Aug 2013	NDL	Par 32175
		if _control.myToPrimaryLocation.isKindOf(CM_GeneralCargoAllocController) then	// TFS 49851
			_control.myToSecondaryLocations.copy(moveControl.myToSecondaryLocations);	// TFS 49851
		endif;																			// TFS 49851
	endif;
	//create new ti from old
	newTI:=	self.cloneMe(cloneId, self.state, moveControl, false, true, true, false, _control.myToPrimaryLocation, self.myVoyage, passport).CM_BreakBulkGeneric;

	newTI.setMasterTI(self);
	newState := newTI.calculateState(REAL_MODE);
	
	if self.myInstructions &lt;&gt; null then		//12.06.2025	navhn30		MTN-35040
		create instructions persistent;
		instructions.setForUpdate(self.myInstructions);	
		instructions.setMyParent(newTI);
	endif;
	
	//29 May 2018	NDL	 TFS 38897
	if _control.myDirectReleaseArea &lt;&gt; null and newState = TI_STATE_UNDEFINED then
		newState := TI_STATE_OFFSITE;
	endif;
	newTI.changeState(newState, passport);
	
	if newTI = null then
		app.raiseCMException1(Err_Unexpected_Program_Error,"split cargo not created",null,null);
		return null;
	endif;
	
	foreach wowle in self.allWorklistEntries where wowle.isKindOf(CM_WOReceiveCargoWLE) do	//30.08.2024 navnk30 #65775
		if wowle.myRequest = null or not wowle.myRequest.isKindOf(CM_WOReceiveCargoRequest) then
			continue;
		endif;
	
		newWowle := wowle.myRequest.CM_WOReceiveCargoRequest.createWLE();
		if newWowle = null then
			continue;
		endif;
		
		newWowle.setMyTrackedItem(newTI);
		wowle.setQuantity(self.totalQuantity - _control.quantity);
		newWowle.setQuantity(_control.quantity);
	endforeach;
	
	self.splitSetQVW(_control,newTI);

	// Need to copy the last storage/received tx to prior trans so correct storage can be calculated on split cargo
	trans := self.allTransactions.findLastStorageRelevantTrans();
	// TFS 7548 splittable cargo carries forward the received transaction from the 'original' cargo item, 
	// TFS 7548 this is done by using the allPriorTransactions collection
	// TFS 7548 however this was not happending in here by looking at the allPriorTransactions
	if trans = null then // TFS 7548
		trans := self.allPriorTransactions.findLastStorageRelevantTrans(); // TFS 7548
	endif;
	if trans &lt;&gt; null then
		newTI.allPriorTransactions.add(trans);
	endif;
	
	//22 Jun 2015	NDL	Par 36338
	if self.myCargoGroup &lt;&gt; null then
		self.myCargoGroup.addAssignedCargo(newTI,passport);
	endif;
	//epr TFS 43404 14/2/19
	moveWLE:=_control.myWorkListEntry;
	if moveWLE &lt;&gt; null and moveWLE.myRequest &lt;&gt; null then
		bulkRelease:= moveWLE.myRequest.myOriginatingBulkRelease;
	endif; 
	//29 Nov 2016	NDL	TFS 3016 / 2549
	self.handleSplitDocActions(	self, newTI );
	self.handleSplitReserveDetail( newTI,bulkRelease	);	//22 Feb 2018	NDL	TFS 37026
    
    self.handleMergeAttachments(newTI);     //MTN-36700
	
	//epr par 32474 12/9/13 when create the new cargo needs the same stops as the cargo it was split from
	if self.id = newTI.id then
		newTI.updateDetailsFromCargoMulti(false,self,true,true,true,true,passport); // ### JIRA 35283 30JUN2025 NAVAB1
	endif;
	
	//this will make sure move transaction is on the new cargo split to
	_control.setMyTrackedItem(newTI);
	_control.myOriginalTI := self;	//26 Nov 2020	NDL	TFS 50422
	_control.setMyOriginatingLocation(self.myPrimaryActualLocation);
	
	
	if  moveWLE &lt;&gt; null  then
		if moveWLE.job.isKindOf(CM_RoadJob) and moveWLE.myRequest.isReleaseType then //need to remove the original TI from the release collection as we arnt releasing it
			if moveWLE.job.CM_RoadJob.myVehicleVisit &lt;&gt; null then			
				if moveWLE.job.CM_RoadJob.allReleaseTrackedItems.includes(self) then
					moveWLE.job.CM_RoadJob.allReleaseTrackedItems.remove(self);
				endif;
				if moveWLE.job.CM_RoadJob.myVehicleVisit.allReleasedTrackedItems.includes(self) then					
					moveWLE.job.CM_RoadJob.myVehicleVisit.allReleasedTrackedItems.remove(self);					
				endif;
			endif;
		elseif moveWLE.job.isKindOf(CM_RailJob) and moveWLE.myRequest.isReleaseType then	//04 Dec 2020	NDL	TFS 50031
			if moveWLE.job.CM_RailJob.allReleaseTrackedItems.includes(self) then
				moveWLE.job.CM_RailJob.allReleaseTrackedItems.remove(self);
			endif;
		endif;
		
		//epr par 33195 16/12/13 
		if moveWLE.myRequest &lt;&gt; null and moveWLE.myRequest.isKindOf(CM_DeliveryRequest) then
			moveWLE.myRequest.CM_DeliveryRequest.setBulkReleaseTI(newTI);
		endif;
		//epr par 35702 CCMS 2457 17/2/15
		if _control.isRTMultiMove and not _control.isRTPickupTask and _control.myRTQueueEntry &lt;&gt; null and _control.myRTQueueEntry.myBreakBulkMaster &lt;&gt; null and
			_control.myRTQueueEntry.myBreakBulkMaster.areAllTasksEqualStatus(TASK_COMPLETE)   then
				self.splitMergeUpdateWLEsTI(moveWLE,newTI,_control);
		else
			//split create new wle future planned move and future queued move
			if moveWLE.quantity - newTI.totalQuantity &gt; 0 then
				if moveWLE.isAnyAmount then	//20 May 2020	NDL	TFS 49167
					self.splitMergeUpdateWLEsTI(moveWLE,newTI,_control);
				else
					self.splitMergeCreateNewWLE(_control,moveWLE,newTI,true);
				endif;
			else
				self.splitMergeUpdateWLEsTI(moveWLE,newTI,_control);
			endif;
		endif;
	endif;
	
	//epr the cloneMe should already move it not sure why we do it twice
	//newTI.setMyLocations(_control);	
	newTI.refreshMyFutureLocations(_control.moveMode, null);
	newTI.setLocationString(_control);
	
	//epr par 33948 28/5/14 if moving to a voyage has to update the voyage  to where it is
	if newTI.myPrimaryActualLocation &lt;&gt; null and newTI.myPrimaryActualLocation.isKindOf(CM_VoyageController) then
		if newTI.myVoyage &lt;&gt; newTI.myPrimaryActualLocation.CM_VoyageController.myVoyage then
			newTI.setMyVoyage(newTI.myPrimaryActualLocation.CM_VoyageController.myVoyage,passport);
		endif;
	endif;

	if _control.myDirectReleaseArea &lt;&gt; null and newState = TI_STATE_OFFSITE then // ### TFS 51936 07SEP2021 NAVAB1
		newTI.releaseFromTransferArea(newTI.consignee,self.getBulkReleaseAssignedCode(),DEL_SNT, app.myPassport,false); // ### TFS 51936 07SEP2021 NAVAB1
	endif;
	
	if app.myPassport.isOpsViewEnabled(self.myTerminal) then // ### TFS 53105 07JUN2022 NAVAB1
		newTI.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,BGP_OpsViewWSRequest.OPS_TYPE_TRACKEDITEM, newTI); // ### TFS 53105 07JUN2022 NAVAB1
		self.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,BGP_OpsViewWSRequest.OPS_TYPE_TRACKEDITEM, self); // ### TFS 53105 07JUN2022 NAVAB1

	endif;
	
	return newTI;
	
epilog
	delete moveControl;
end;</source>
        <access>protected</access>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_newIdForSplit" type="String"/>
        <ReturnType type="CM_BreakBulkGeneric"/>
    </JadeMethod>
    <JadeMethod name="splitSetQVW" id="fa5999a7-4bc5-4005-a2da-b0bda30795db">
        <updating/>
        <source>splitSetQVW(_control : CMIF_MoveController input; 
			_newTI   : CM_TrackedItem input)  updating;
/*

Date		Who		Reason
11 March 2014	cnwer1	Initial creation PAR

*/

vars
	oldQuantity,
	adjustedQuantity 			: Integer;
	newVolume,oldVolume, adjustedVolume		: Real;
	newWeight,oldWeight, adjustedWeight		: Decimal[14,4]; 
	tiUpdateCntrlr 	: CMIF_TIUpdateController;
	ct : CM_CargoType;
	prod : CM_Product;
	calcVolFromProd : Boolean;
	oldCargoWeight : Decimal[14,4];	//18 Jan 2018	NDL	TFS 36697
	oldTareWeight : Decimal[14,4];	//18 Jan 2018	NDL	TFS 36697
	adjustedCargoWeight : Decimal[14,4];	//18 Jan 2018	NDL	TFS 36697
	adjustedTareWeight : Decimal[14,4];	//18 Jan 2018	NDL	TFS 36697
	newCargoWeight : Decimal[14,4];	//18 Jan 2018	NDL	TFS 36697
	newTareWeight : Decimal[14,4];	//18 Jan 2018	NDL	TFS 36697
	useTareCargoWeight : Boolean;
begin	
	
	oldQuantity    := self.totalQuantity;
	oldVolume	   := self.totalVolume;
	oldWeight      := self.totalWeight;	
	oldCargoWeight := self.weightCargo;	//18 Jan 2018	NDL	TFS 36697
	oldTareWeight  := self.weightTare;	//18 Jan 2018	NDL	TFS 36697
	
	adjustedQuantity:=self.totalQuantity - _control.quantity;
	if adjustedQuantity &lt; 0 then
		app.raiseCMException(Remai_quant_will_less_than_zer, null, null);
		return;		
	endif;
	
	ct 				   := self.myCargoType;			//28.05.2024 navma1 #64224
	useTareCargoWeight := ct.useTareCargoWeight;	//28.05.2024 navma1 #64224
	
	if ct &lt;&gt; null and ct.allowAutoVolumeCalc then
		prod := self.myProduct;
		if prod &lt;&gt; null and prod.autoVolumeCalculate then
			// Only allowed on track as Break Bulk that are configured with a myVoume to unconditionally use...
			calcVolFromProd := true;
		endif;
	endif;
	
	if calcVolFromProd then	//10 Jun 2016	NDL	TFS 2141
		//set both the new and the remaining volume values from the product values regardless - Yep, that's the rules as of today 10 Jun 2016 @ 10:50 am 
		newVolume := prod.calculateCargoVolume(null,_control.quantity, self.quantity );
		if self.totalQuantity &gt; _control.quantity then
			adjustedVolume := prod.calculateCargoVolume( null, ( self.totalQuantity - _control.quantity ), self.quantity );
		endif;
		
	elseif self.getMyTotalVolume &lt;&gt; 0 and self.totalQuantity &gt; 0 then
		
		if _newTI = null and _control.volume &lt;&gt; null then
			newVolume := _control.volume;
		else
			// apportion weight based on the quantity
			if self.totalQuantity = 0 then
				newVolume := ((_control.quantity) * self.getMyTotalVolume);	//07 Oct 2013	NDL	Par 32722
			else
				newVolume := ((_control.quantity / self.totalQuantity) * self.getMyTotalVolume);	//07 Oct 2013	NDL	Par 32722
			endif;
		endif;
	endif;
	if not calcVolFromProd then	//10 Jun 2016	NDL	TFS 2141
		adjustedVolume	:= self.getMyTotalVolume - newVolume;
	endif;
	
	
	if self.totalWeight &lt;&gt; 0 and self.totalQuantity &gt; 0 then						//+cnwml2 MSL CCMS 1017
		// apportion weight based on the quantity
		//epr TFS 1707 6/4/16
		if _newTI = null and _control.weight &lt;&gt; null then
			newWeight := _control.weight;
		else
			if self.totalQuantity = 0 then
				newWeight := ((_control.quantity) * self.totalWeight);									//+cnwml2 MSL CCMS 1017
			else
				newWeight := ((_control.quantity / self.totalQuantity) * self.totalWeight);										// PAR #32323
			endif;
		endif;
	endif;
	
	adjustedWeight := self.totalWeight - newWeight;	
	
	//29 Jan 2018	 NDL TFS 36697
	if self.usesAutoWeightCalculate then
		if self.weightCargo &lt;&gt; 0 and self.totalQuantity &gt; 0 and _control.quantity &gt; 0 then		
			newCargoWeight := ((_control.quantity / self.totalQuantity) * self.weightCargo);		
		endif;
		adjustedCargoWeight := self.weightCargo - newCargoWeight;
		
		if self.weightTare &lt;&gt; 0 and self.totalQuantity &gt; 0 and _control.quantity &gt; 0 then		
			newTareWeight := ((_control.quantity / self.totalQuantity) * self.weightTare);		
		endif;
		adjustedTareWeight := self.weightTare - newTareWeight;
	endif;
	
	if _newTI &lt;&gt; null then
		self.setTotalQuantity(adjustedQuantity);
		self.setMyTotalVolume(adjustedVolume);
		self.setTotalWeightWithoutTrans(adjustedWeight);
		//29 Jan 2018	 NDL TFS 36697
		if self.usesAutoWeightCalculate then
			self.setWeightCargo(adjustedCargoWeight);		//18 Jan 2018	NDL	TFS 36697
			self.setWeightTare(adjustedTareWeight);			//18 Jan 2018	NDL	TFS 36697
		elseif useTareCargoWeight then						//28 Mar 2018	NDL	TFS 37621		//28.05.2024 navma1 #64224	
			//28 Mar 2018	NDL	TFS 37621
			if oldCargoWeight &gt;= newWeight then
				// no change to Tare Weight, just reduce cargo weight
				self.setWeightCargo(  oldCargoWeight - newWeight  );
			elseif newWeight &lt;= oldWeight then
				//no cargo weight left, tare must be the same as totalweight
				self.setWeightCargo( 0 );
				self.setWeightTare(  adjustedWeight );
			else
				//must be none left
				self.setWeightCargo( 0 );
				self.setWeightTare( 0 );
			endif;
		endif;
		
		_newTI.setTotalQuantity(_control.quantity);
		_newTI.setMyTotalVolume(newVolume);	
		_newTI.setTotalWeightWithoutTrans(newWeight);
		//29 Jan 2018	 NDL TFS 36697
		if self.usesAutoWeightCalculate then
			_newTI.setWeightCargo(newCargoWeight);	//18 Jan 2018	NDL	TFS 36697
			_newTI.setWeightTare(newTareWeight);	//18 Jan 2018	NDL	TFS 36697
		elseif useTareCargoWeight then				//28 Mar 2018	NDL	TFS 37621	//28.05.2024 navma1 #64224
			_newTI.setWeightCargo(newWeight);		//28 Mar 2018	NDL	TFS 37621
			_newTI.setWeightTare(0);				//28 Mar 2018	NDL	TFS 37621
		endif;
	
		//epr 30/1/14 refactored out to method on CM_TrackedItem so can be used for bulk split
		self.createSplitTransactions(	_newTI, oldQuantity,
										oldVolume, oldWeight, oldCargoWeight, oldTareWeight,
										false,
										0, 0, 0, 0, 0, _control,
										_control.myPassport);
		
		self.splitChargesByFactor(oldWeight, oldVolume, newWeight, newVolume, oldQuantity, _control.quantity,_newTI); // TFS 7311 // ### JIRA 34760 30APR2025 NAVAB1 // JIRA 35213 renamed from splitMergeChargesByFactor
	else
		//epr TFS 1707 6/4/16
		tiUpdateCntrlr := app.createTIUpdateControl( TI_UPDMODE_NORMAL, app.myPassport.userCode, null );
		self.beginUpdate(tiUpdateCntrlr, _control.myPassport);
		
		self.setTotalQuantity(adjustedQuantity);
		self.setMyTotalVolume(adjustedVolume);
		self.setTotalWeightWithoutTrans(adjustedWeight);
		//29 Jan 2018	 NDL TFS 36697
		if self.usesAutoWeightCalculate then
			self.setWeightCargo(adjustedCargoWeight);	//18 Jan 2018	NDL	TFS 36697
			self.setWeightTare(adjustedTareWeight);	//18 Jan 2018	NDL	TFS 36697
		endif;
		
		self.endUpdate(tiUpdateCntrlr, _control.myPassport);
	endif;
	
epilog
	delete tiUpdateCntrlr;
end;</source>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_newTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
