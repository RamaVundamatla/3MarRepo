    <JadeMethod name="erase" id="4ef62752-0689-4905-b697-6cd75ce2f861">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     18 March 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.lineGroupDebtors.purge;
	self.shipPorts.purge;
	inheritMethod(_eraseLevel);

end;</source>
