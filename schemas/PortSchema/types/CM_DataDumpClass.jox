    <JadeMethod name="createFeature" id="68482e1c-2c2e-4b20-870a-0c0985821735">
        <source>createFeature(_proxyAttr: CM_DataDumpFeature) : CM_DataDumpFeature;
// ---------------------------------------------------------------------------
// Created:     19 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	attr : CM_DataDumpFeature;

begin
	create attr persistent;
	attr.setForCreate(_proxyAttr);
	self.allDataDumpFeatures.add(attr);
	
	return attr;
end;</source>
        <Parameter name="_proxyAttr" type="CM_DataDumpFeature"/>
        <ReturnType type="CM_DataDumpFeature"/>
    </JadeMethod>
    <JadeMethod name="doObjectVolatilityConversion" id="8f5bba19-ea0c-4405-aa6b-7b51d060b307">
        <updating/>
        <source>doObjectVolatilityConversion(_converter: CM_ObjectVolatilityConverter input; _logIndent: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Feb 2017	cnwkpd1	TFS 3369 - Push Events application


*/

vars
	indent			: Integer;
	
begin
	_converter.logMessage("Processing collections for " &amp; self.String, _logIndent);
	indent := _logIndent + 1;

	inheritMethod(_converter, indent);

	_converter.doChangeVolatilityOfObject(self.allDataDumpFeatures, _logIndent);
	
	_converter.logMessage("Finished processing collections for " &amp; self.String, _logIndent);


epilog

end;</source>
        <Parameter name="_converter" type="CM_ObjectVolatilityConverter" usage="input"/>
        <Parameter name="_logIndent" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getClassId" id="9eda5734-7740-4e0b-90ba-2739db928f54">
        <source>getClassId() : String;
// ---------------------------------------------------------------------------
// Created:     24 July 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	return self.classAlias &amp; " (" &amp; self.className &amp; ")";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDSSFeatures" id="ed830de6-8f79-409b-8510-537f334b28ed">
        <source>getDSSFeatures(_dssDataDumpFeatures : CM_DataDumpFeatureArray io);
//
//23 Apr 2015	cnwrs1	Par 36113 Adding DSS Class to data extract can cause extract to fail.
//
vars
	ddFeature : CM_DataDumpFeature;
begin
	foreach ddFeature in self.allDataDumpFeatures do
		if ddFeature.isDSS then
			_dssDataDumpFeatures.add(ddFeature);
		endif;
	endforeach;
end;
</source>
        <Parameter name="_dssDataDumpFeatures" type="CM_DataDumpFeatureArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getFeature" id="e8d6aa45-a5ba-4486-beae-b055c3ae7bef">
        <source>getFeature(_featureName: String) : Feature;
// ---------------------------------------------------------------------------
// Created:     23 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	cls : Class;
	
begin
	cls := self.myClass;
	if cls = null then
		return null;
	endif;
	
	return self.getFeatureForClass(cls, _featureName);
end;</source>
        <Parameter name="_featureName" type="String"/>
        <ReturnType type="Feature"/>
    </JadeMethod>
    <JadeMethod name="getFeatureForClass" id="617090f6-56c2-4e97-ab71-fdcc2a4666a6">
        <source>getFeatureForClass(_class: Class; _featureName: String) : Feature;
// ---------------------------------------------------------------------------
// Created:     23 May 2003 by cnwsb1
//
// Purpose:		Returns the feature for the class, or returns null if invalid.
//				The feature can be any of the following:
//				- Attribute
//				- Reference
//				- Method
// ---------------------------------------------------------------------------
vars
	prop : Property;
	meth : Method;
	fName : String;
	fNameLen : Integer;

begin
	fName := _featureName;
	fNameLen := fName.length;
	
	// Translate feature name if relevant
	
	if fName = DataDumpOidStr then
		fName := DataDumpGetOidStringMethod;
	elseif fName = DataDumpOidHex then
		fName := DataDumpGetOidHexMethod;
	elseif fName = DataDumpOidBin then
		fName := DataDumpGetOidBinaryMethod;
			
	elseif fNameLen &gt; DataDumpUnderOidStrLen and
			fName[fNameLen-DataDumpUnderOidStrLen+1:DataDumpUnderOidStrLen] = DataDumpUnderOidStr then
		// Allow "_oid" to be used at the end of the feature name, which
		// is interpreted as "get the oid of the reference mentioned at the
		// start of the feature name".
		fName := fName[1:fNameLen-DataDumpUnderOidStrLen];
	endif;

	prop := _class.getPropertyInHTree(fName);
	if prop &lt;&gt; null then
		return prop;
	endif;
	
	meth := _class.getMethodInHTree(fName);
	if meth &lt;&gt; null then
		return meth;
	endif;
	
	return null;
end;</source>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_featureName" type="String"/>
        <ReturnType type="Feature"/>
    </JadeMethod>
    <JadeMethod name="getFeatureForSubClass" id="488b920b-1e85-4c80-bd85-10f6824ab113">
        <source>getFeatureForSubClass(_class: Class; _featureName: String) : Feature;
// ---------------------------------------------------------------------------
// Created:     16 July 2003 by cnwsb1
//
// Purpose:		Returns the Type of the feature with the given name on any
//				of the real sub-classes of the given class.
//				The feature can be any of the following:
//				- Attribute
//				- Reference
//				- Method
// ---------------------------------------------------------------------------
vars
	subClasses: ClassColl;
	cls : Class;
	ftr : Feature;
	
begin
	create subClasses transient;
	
	self.getRealSubClasses(subClasses, false);
	
	foreach cls in subClasses do
		ftr := self.getFeatureForClass(cls, _featureName);
		if ftr &lt;&gt; null then
			return ftr;
		endif;
	endforeach;
	
	return null;
	
epilog
	delete subClasses;
end;</source>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_featureName" type="String"/>
        <ReturnType type="Feature"/>
    </JadeMethod>
    <JadeMethod name="getFeatureTypeForSubClass" id="20c5891d-aae0-4d17-b739-c72045a7fbd8">
        <source>getFeatureTypeForSubClass(_class: Class; _featureName: String) : Type;
// ---------------------------------------------------------------------------
// Created:     16 July 2003 by cnwsb1
//
// Purpose:		Returns the Type of the feature with the given name on any
//				of the real sub-classes of the given class.
//				The feature can be any of the following:
//				- Attribute
//				- Reference
//				- Method
// ---------------------------------------------------------------------------
vars
	subClasses: ClassColl;
	cls : Class;
	ftr : Feature;
	
begin
	create subClasses transient;
	
	self.getRealSubClasses(subClasses, false);
	
	foreach cls in subClasses do
		ftr := self.getFeatureForClass(cls, _featureName);
		if ftr &lt;&gt; null then
			return ftr.getFeatureType;
		endif;
	endforeach;
	
	return null;
	
epilog
	delete subClasses;
end;</source>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_featureName" type="String"/>
        <ReturnType type="Type"/>
    </JadeMethod>
    <JadeMethod name="getName" id="eea0f115-70c5-42f8-8388-fc6200e9bc86">
        <source>getName(): String;
// ---------------------------------------------------------------------------
// Created:     24 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	return inheritMethod() &amp; ' (' &amp; className &amp; ')';


end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRealSubClasses" id="663bbd72-a5d5-4eaa-9178-3b18e860c98e">
        <source>getRealSubClasses(_subClasses: ClassColl input; includeParentIfReal: Boolean);
// ---------------------------------------------------------------------------
// Created:     23 May 2003 by cnwsb1
//
// Purpose:		For efficiency reasons, we only want the Real sub-classes
//				(ie. ignore the abstract ones).  Includes myClass if Real.
// ---------------------------------------------------------------------------
vars
	class : Class;
	toDelete : ClassSet;
	tmpSchema	: Schema;

begin
	create toDelete transient;
	_subClasses.clear;

	class := self.myClass;
	if class = null then
		return;
	endif;
	
	// As allSubClasses returns sub-schema copies of classes and
	// we need the actual classes. We need to do use PortSchema.getClass(class.name)
	// to ensure that we get the actual class instance and not the sub-schema copy of the class
	// RJS/DVD 30Dec03
	
	//class.allSubclasses(_subClasses);
	tmpSchema := rootSchema.getSchema(PortSchemaName);
	if tmpSchema = null then
		app.raiseUnexpectedProgramError(class.name, method.name, PortSchemaName &amp; ' not found');
		return;
	endif;
	
	class := tmpSchema.getClass(class.name);
	
	class.allSubclasses(_subClasses);
	if includeParentIfReal and not class.abstract then
		_subClasses.insert(1, class);
	endif;
	
	// Remove all abstract classes.  NB: Can't update an array during an iteration
	foreach class in _subClasses do // where class.abstract do
		class := tmpSchema.getClass(class.name);
		if class.abstract then
			toDelete.add(class);
		elseif class.name = CM_DailyReeferTemp.name then //rs 21/10/2003 we done want any of these
			toDelete.add(class);
		endif;
		
		//cnwrd1 par 34512 , we dont wat to touch Logs now if we are looing at tracked items
		if self.myClass.name = CM_TrackedItem.name then
			if class.name = CM_Log.name or class.name = CM_LogNoNumber.name then
				toDelete.add(class);
			endif;
		endif;
		
	endforeach;
	foreach class in toDelete do
		class := tmpSchema.getClass(class.name);
		_subClasses.remove(class);
	endforeach;
	
epilog
	delete toDelete;
end;</source>
        <Parameter name="_subClasses" type="ClassColl" usage="input"/>
        <Parameter name="includeParentIfReal" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isAFeatureAvailableForDSS" id="157271d9-952b-455b-b6f4-9dc62ea5ebbc">
        <source>isAFeatureAvailableForDSS(_feature:CM_DataDumpFeature):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2010	#cnwdz2	 refer to CM_EcternalDatabaseAgent::setClass for accessing each property 
                         (e.g. edb_AddInvoiceTax) of each external class (e.g. EDB_Bank) 

*/

vars
	properties       : PropertyNDict;
	property         : Property;
	extAttributeName : String;
	featureAlias : String;
	newType : Type;
	newLength : Integer;
begin
	properties := self.myExternalObjectClass.getProperties;
	foreach property in properties where property.isKindOf(ExternalPrimAttribute) do
		extAttributeName := property.ExternalPrimAttribute.getName[CM_DataDumpClass.EDBAttrPrefix.length+1:end];
		//01/03/2011 cnwdz2 27010 start
		featureAlias := _feature.getExternalDatabaseFeatureName(self.myClass, newType, newLength);					
		if extAttributeName.toLower() =  featureAlias.toLower() then
		//01/03/2011 cnwdz2 27010 end
			return true;
		endif;
	endforeach;
	return false;
epilog

end;</source>
        <Parameter name="_feature" type="CM_DataDumpFeature"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isAvailableForDSS" id="aed00f3c-32c5-4f5f-8383-6014d56213ed">
        <source>isAvailableForDSS():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2010	#cnwdz2	 

*/

vars

begin
	return not (myExternalObjectClass = null); 
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isFeatureForSubClass" id="65a5316d-5a32-401a-87f8-897248be9f86">
        <source>isFeatureForSubClass(_featureName: String) : Boolean;
// ---------------------------------------------------------------------------
// Created:     23 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	subClasses : ClassColl;
	cls : Class;
	
begin
	create subClasses transient;
	self.getRealSubClasses(subClasses, false);
	
	foreach cls in subClasses where
			self.getFeatureForClass(cls, _featureName) &lt;&gt; null do
		return true;
	endforeach;
	
	return false;
	
epilog
	delete subClasses;
end;</source>
        <Parameter name="_featureName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="myClass" id="ad2525ad-88b3-4f30-ac64-97f35dc42d62">
        <methodInvocation>mapping</methodInvocation>
        <source>myClass(set: Boolean; _value: Class io) mapping;
// ---------------------------------------------------------------------------
// Created:     22 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		_value := currentSchema.getClass(self.className);
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Class" usage="io"/>
    </JadeMethod>
    <JadeMethod name="myExternalDictionaryClass" id="b09d6def-df96-41d2-a981-8263a8e83869">
        <methodInvocation>mapping</methodInvocation>
        <source>myExternalDictionaryClass(set: Boolean; _value: Class io) mapping;
// ---------------------------------------------------------------------------
// Created:     25 June 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	extObjClassName : String;

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		if self.classAlias.length &gt; 1 then
			// cnwrs1 may 2006 need to be able to handle class names of max length Then replace the last char with "D"
			if self.classAlias.length &gt; (DataDumpMaxLengthClassName-5) then
				extObjClassName := (self.EDBPrefix &amp; self.classAlias[1].toUpper &amp;
						self.classAlias[2:(DataDumpMaxLengthClassName-6)] &amp; self.EDBDictSuffix)[1:DataDumpMaxLengthClassName];
			else
				extObjClassName := (self.EDBPrefix &amp; self.classAlias[1].toUpper &amp;
						self.classAlias[2:end] &amp; self.EDBDictSuffix)[1:DataDumpMaxLengthClassName];
			endif;
			_value := currentSchema.getClass(extObjClassName);
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Class" usage="io"/>
    </JadeMethod>
    <JadeMethod name="myExternalObjectClass" id="58dcc16d-2f8e-4649-b6bf-f516fdb5082b">
        <methodInvocation>mapping</methodInvocation>
        <source>myExternalObjectClass(set: Boolean; _value: Class io) mapping;
// ---------------------------------------------------------------------------
// Created:     25 June 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	extObjClassName : String;

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		if self.classAlias.length &gt; 1 then
			extObjClassName := (self.EDBPrefix &amp; self.classAlias[1].toUpper &amp;
					self.classAlias[2:end])[1:DataDumpMaxLengthClassName];
			_value := currentSchema.getClass(extObjClassName);
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Class" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateFeature" id="fd6f5fcd-3464-427e-8058-5c2821c5e557">
        <source>pxyCreateFeature(_featureName: String; _xdbFeature : CMIF_ExternalDBFeature) : CM_DataDumpFeature;
//_actualClassName: String; _returnValueIsAnObject : Boolean; _isProtected : Boolean) : CM_DataDumpFeature;
// ---------------------------------------------------------------------------
// Created:     21 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	feature : CM_DataDumpFeature;

begin
	create feature transient;
	feature.setProxy(_featureName, _xdbFeature);

	self.allDataDumpFeatures.add(feature);
	
	return feature;
end;</source>
        <Parameter name="_featureName" type="String"/>
        <Parameter name="_xdbFeature" type="CMIF_ExternalDBFeature"/>
        <ReturnType type="CM_DataDumpFeature"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="59e95ba2-4c35-44db-a1a5-4524eb498d52">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     23 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	pxyClass : CM_DataDumpClass;
	realFeature : CM_DataDumpFeature;
	pxyFeature : CM_DataDumpFeature;
	completedOK		: Boolean;
	
begin
	pxyClass := inheritMethod;
	
	foreach realFeature in self.allDataDumpFeatures do
		pxyFeature := realFeature.pxyCreateUpdateProxy;
		pxyClass.allDataDumpFeatures.add(pxyFeature);
	endforeach;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyClass;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyClass;
	endif;
	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setCommon" id="66fa5a4b-e96a-4c4e-8da3-d32e63746b0d">
        <updating/>
        <source>setCommon(_proxyClass: CM_DataDumpClass) updating, protected;
// ---------------------------------------------------------------------------
// Created:     22 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	_proxyClass.raiseExceptionIfNotTransient(method);
	
	self.className := _proxyClass.className;
	self.classAlias := _proxyClass.classAlias;
end;</source>
        <access>protected</access>
        <Parameter name="_proxyClass" type="CM_DataDumpClass"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="6fcec70c-760b-4207-9b7c-6492017aae84">
        <updating/>
        <source>setForCreate(_proxyClass: CM_DataDumpClass) updating;
// ---------------------------------------------------------------------------
// Created:     21 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
14 Feb 2017	cnwkpd1	TFS 3369 - Push Events application
	
*/

vars
	proxyFeature : CM_DataDumpFeature;
	agent		: CM_ObjectVolatilityConverter;
	
begin
	self.setCommon(_proxyClass);
	
	foreach proxyFeature in _proxyClass.allDataDumpFeatures do
		self.createFeature(proxyFeature);
	endforeach;
	
	// TFS 3369 - If system is using stable objects, then need to change the volatility of
	// the newly created object's collections
	if app.myRoot.useStableObjects then
		create agent transient;
		agent.newVolatility := Volatility_Stable;
		agent.multipleTransactions := false;
		
		self.doObjectVolatilityConversion(agent, 1);
	endif;

epilog
	delete agent;
	
end;</source>
        <Parameter name="_proxyClass" type="CM_DataDumpClass"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="d07e6131-54ac-4bad-a585-18eba48da00f">
        <updating/>
        <source>setForUpdate(_proxyClass: CM_DataDumpClass) updating;
// ---------------------------------------------------------------------------
// Created:     22 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
// 29/08/2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition
vars
	proxyFeature : CM_DataDumpFeature;
	realFeature : CM_DataDumpFeature;
	toDelete : CM_DataDumpFeatureSet;
	expectedEdition : Integer;
	
begin
	self.updateObjectEdition (self);	// par 30292
	
	self.setCommon(_proxyClass);
	
	create toDelete transient;
	exclusiveLock(self.allDataDumpFeatures);
	self.allDataDumpFeatures.copy(toDelete);
	
	// 1. Create new features, update existing ones
	foreach proxyFeature in _proxyClass.allDataDumpFeatures do
		proxyFeature.pxyGetRealObjectAndEdition(realFeature, expectedEdition);
		if realFeature = null then
			self.createFeature(proxyFeature);
		else
			toDelete.remove(realFeature);
			exclusiveLock(realFeature);
			if realFeature.edition &lt;&gt; expectedEdition then
				app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'dataDumpFeature', null, null);
				return;
			endif;
			realFeature.setForUpdate(proxyFeature);
		endif;
	endforeach;
	
	// 2. Delete missing features
	foreach realFeature in toDelete do
		delete realFeature;
	endforeach;
	
epilog
	delete toDelete;
end;</source>
        <Parameter name="_proxyClass" type="CM_DataDumpClass"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="ca49a3a6-28f7-495f-b442-5a675a823b9d">
        <updating/>
        <source>setProxy(_className, _classAlias: String) updating;
// ---------------------------------------------------------------------------
// Created:     21 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	self.raiseExceptionIfNotTransient(method);
	
	self.className := _className[1:self.className.maxLength].trimBlanks;
	self.classAlias := _classAlias[1:self.classAlias.maxLength].trimBlanks;
end;</source>
        <Parameter name="_className" type="String"/>
        <Parameter name="_classAlias" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateCommon" id="a20b9add-9ebb-4d86-b5a1-7357d3d116e4">
        <source>validateCommon() protected;
// ---------------------------------------------------------------------------
// Created:     22 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	proxyFeature : CM_DataDumpFeature;

begin
	self.raiseExceptionIfNotTransient(method);
	
	if self.classAlias = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "classAlias", null, null);
		app.raiseCMException(Input_required_field_clasAlias, null, null); // cnwdb2	PAR 35364
	endif;
	if self.className = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "className", null, null);
		app.raiseCMException(Input_required_field_className, null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.myClass = null then
		app.raiseCMException1(Err_InvalidClass, self.className, null, null);
	endif;
	
	foreach proxyFeature in self.allDataDumpFeatures do
		proxyFeature.validateCommon;
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="9df0a3a4-2f74-47bf-a129-ea3f37cc0c95">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     21 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	self.validateCommon;
	
	if app.myRoot.allDataDumpClasses[self.className] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.className, null, null);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="2295d5ed-6ed4-4312-9d0d-c441251b5c4a">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     22 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	self.raiseExceptionIfTransient(method);
	
	// Seems logical to just delete the ExtractClass if the DumpClass
	// has been removed.  Parent-child relationship will do this.
	//if self.allDataDumpExtracts.size &gt; 0 then
	//	app.raiseCMException1(ObjectStillHasEntries, self.className,
	//			"extract", null);
	//endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="214e395b-42b0-4423-8e63-818f42673329">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     22 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	realClass : CM_DataDumpClass;
	testClass : CM_DataDumpClass;
	
begin
	self.validateCommon;
	
	realClass := self.pxyGetRealObject;
	if realClass = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, self.class.name, null, null);
	endif;	

	testClass := app.myRoot.allDataDumpClasses[self.className];
	
	if testClass &lt;&gt; null and testClass &lt;&gt; realClass then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.className, null, null);
	endif;
end;</source>
    </JadeMethod>
</Class>
