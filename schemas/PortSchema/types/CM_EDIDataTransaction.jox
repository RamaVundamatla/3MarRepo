    <JadeMethod name="getTransaction" id="67f26481-8a07-47fd-b36e-4b3a0ba0f0d3">
        <source>getTransaction(_ediTransactionTI : CM_EDITransactionTI; _ti : CM_TrackedItem) : CM_TITransaction;
/*

Date		Who		Reason
19 Sep 2012	cnwrs1	CCMS SFW 1290 Transaction file
27 Sep 2012	cnwkpd1	PAR #30400 - SFW 1290 - Transaction EDI file type
					Correct validation to ensure transaction matches on type as well
						
*/
vars
	transaction : CM_TITransaction;
	tiTrans : CM_TITransaction;
	iter : Iterator;
begin
	if _ediTransactionTI.orderNumber &lt;&gt; 0 then
		transaction := _ti.allTransactions[_ediTransactionTI.transactionTime, _ediTransactionTI.orderNumber];
		if transaction &lt;&gt; null then
			tiTrans := transaction;
		endif;
	else
		iter := _ti.allTransactions.createIterator();
		_ti.allTransactions.startKeyGeq(_ediTransactionTI.transactionTime, null, iter);
		while iter.next(transaction) do
			if transaction.dateTime &gt; _ediTransactionTI.transactionTime then
				break;
			endif;
			if transaction.isDeleted then
				continue;
			endif;
			if transaction.type = _ediTransactionTI.transactionType then
				tiTrans := transaction;
				break;
			endif;
		endwhile;
	endif;
	return tiTrans;
	
epilog
	delete iter;
	
end;
</source>
        <Parameter name="_ediTransactionTI" type="CM_EDITransactionTI"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="loadDB" id="036de152-77ed-4e2f-b099-374295afd8f0">
        <updating/>
        <source>loadDB(_mergeCargo: Boolean; _passport: CM_Passport input) updating;
//
//19 Sep 2012	cnwrs1		CCMS SFW 1290 Transaction file
//
vars

begin
	// Arm our base exception handlers
	on Exception do validationExceptionHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	app.myTrxUA.trxProcessEDITransactions(self, false, _passport);
end;
</source>
        <Parameter name="_mergeCargo" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
