    <JadeMethod name="getChildCargoGrpId" id="0741f2a7-9d0a-41d0-85d2-9bdff917436e">
        <source>getChildCargoGrpId():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Jul 2023	navhl20	ChangeRequest 54550: EUP | Delivery Dispatch Screen - Pack Operation

*/

vars
	resDtl : CM_ReserveDetail;
begin
	resDtl := self.myReserveDetail;
	if resDtl &lt;&gt; null and resDtl.packType = CM_ReserveDetail.PackType_Child then
		return resDtl.getMyCargoGroupId();
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getChildCargoSubType" id="be0b0769-9a04-4077-ade1-df9e2d0258af">
        <source>getChildCargoSubType():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Jul 2023	navhl20	ChangeRequest 54550: EUP | Delivery Dispatch Screen - Pack Operation
*/

vars
	resDtl : CM_ReserveDetail;
begin
	resDtl := self.myReserveDetail;
	if resDtl &lt;&gt; null and resDtl.packType = CM_ReserveDetail.PackType_Child then
