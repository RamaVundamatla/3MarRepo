    <JadeMethod name="doSave" id="10c6f517-934b-4cb2-b7a4-64053fb88981">
        <updating/>
        <source>doSave(): Boolean updating;

/*
Date		Who		Reason
20 May 2009	cnwar2	Initial creation
23/02/2012	cnwcs5	par 29158 - CCMS CPL 2086 - EDI Booking Cutoff
*/
vars
	proxy						: CM_ReceivalCutoffTermDef;
	code, description			: String;
	sortKey, defaultRelativeTo,
	criteriaType				: Integer;			// par 29158 Feb 2012
	defaultCutoffPN,								//20/03/2025	navkc1 JIRA Story MTN-34231
	defaultEarliestPN,								//20/03/2025	navkc1 JIRA Story MTN-34231
	defaultCutoff, 
	defaultEarliest				: Decimal[7,2];
	isAvailableForEntry			: Boolean;
	form 						: SOP_TableMaintForm;
	table						: CM_EntryTable;	// par 29158 Feb 2012
	array						: CMIF_Array;
	
begin
  	form 	:= self.myForm;
	table	:= form.tblInput1;
	
	code 					:= table.getValueByName(ETRow_Code).String;
	description 			:= table.getValueByName(ETRow_Description).String;
	sortKey 				:= table.getValueByName(ETRow_SortKey).Integer;
	defaultRelativeTo		:= app.defRelativeToStringToEnum(table.getValueByName(ETRow_DefaultRelativeTo).String);
	defaultCutoff			:= table.getValueByName(ETRow_DefaultCutoff).Decimal;
	defaultCutoffPN			:= table.getValueByName(ETRow_DefaultCutoffPN).Decimal; //20/03/2025	navkc1 JIRA Story MTN-34231
	defaultEarliest			:= table.getValueByName(ETRow_DefaultEarliestReceival).Decimal;
	defaultEarliestPN		:= table.getValueByName(ETRow_DefaultEarliestReceivePN).Decimal; //20/03/2025	navkc1 JIRA Story MTN-34231
	isAvailableForEntry 	:= table.getValueByName(ETRow_IsAvailableForEntry).Boolean;

	create array transient;

	if table.getValueByName (ETRow_CriteriaType).String = CM_ReceivalCutoffTermDef.CriteriaType_EDI_Desc then
		criteriaType := CM_ReceivalCutoffTermDef.CriteriaType_EDI;
	else
		criteriaType	:= CM_ReceivalCutoffTermDef.CriteriaType_CARGO;
		
		self.getCriteriaAllCMIF( array );
	endif;
	
	if form.myProxyObject = null then
		if form.mode = form.Mode_Add then
			create form.myProxyObject as CM_ReceivalCutoffTermDef transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxy := form.myProxyObject.CM_ReceivalCutoffTermDef;
	
	proxy.setValues(code, description, sortKey, defaultRelativeTo, defaultCutoff, defaultEarliest, 
						isAvailableForEntry, criteriaType, form.myTerminal, 
						defaultCutoffPN, 	//04/03/2025	navkc1 JIRA Story MTN-34227
						defaultEarliestPN); 	//04/03/2025	navkc1 JIRA Story MTN-34227
	if criteriaType = CM_ReceivalCutoffTermDef.CriteriaType_EDI then
		proxy.allEDIDataTypes.clear;						// par 29257 - march 2012
		self.allEDIDataTypes.copy (proxy.allEDIDataTypes);	// par 29257 - march 2012
	endif;
	
	if form.mode = form.Mode_Add then
		app.myTrxCA.trxCreateRecRestrictionDef(proxy, array, form.myCurrentObject, app.myPassport);
	elseif form.mode = form.Mode_Update then
		app.myTrxUA.trxUpdateRecRestrictionDef(proxy, array, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; form.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK;
	
epilog
	if array &lt;&gt; null then
		array.purge;
	endif;
	
	delete array;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doShowCriteriaForm" id="4ed385e3-0cd5-4966-8b35-ec856c69e451">
        <updating/>
        <source>doShowCriteriaForm() updating;

/*
Date		Who		Reason
21 May 2009	cnwar2	Initial creation
28/02/2012	cnwcs5	par 29158 - EDI Booking cut-off
*/
vars
	form 	: Form;					// par 29158 - Feb 2012
	table	: CM_EntryTable;		// par 29158 - Feb 2012
	isCargo	: Boolean;				// par 29158 - Feb 2012
begin
	table 	:= self.myForm.tblInput1;									
	isCargo	:= (table.getValueByName (ETRow_CriteriaType).String = CM_ReceivalCutoffTermDef.CriteriaType_CARGO_Desc);	
	
	// if criteria type is CARGO we use CMUI_YACriteriaMaintForm otherwise if it is EDI then we
	// just maintain a collection of EDI file types using CMUI_EDIDataTypeSelectForm
	if isCargo then
		//epr refactored part of tfs  1882 13/5/16
		if self.myForm.myAssistant.showCritieriaMaintForm(null,self.myForm.myTerminal,CMUI_YACriteriaMaintForm.VoyageCutOffCriteria, self.allCriteria) then
			table.setValueByName(ETRow_CriteriaDblClick, self.getCriteriaText());
		endif;
	else
		form := app.loadForm(CMUI_EDIDataTypeSelectForm, CMUI_Assistant, false, false, true, self.myForm.myTerminal, null);
		
		if form = null then
			return;
		endif;	
		
		self.allEDIDataTypes.copy (form.CMUI_EDIDataTypeSelectForm.allEDIFileTypes);	
		
		form.showModal();
		
		if form.modalResult = IDOK then
		
			self.allEDIDataTypes.clear;
				
			form.CMUI_EDIDataTypeSelectForm.allEDIFileTypes.copy (self.allEDIDataTypes);
				
			table.setValueByName(ETRow_CriteriaDblClick, self.getCriteriaText());
		endif;
	endif;
epilog
	delete form;
end;</source>
    </JadeMethod>
    <JadeMethod name="getCollection" id="e0e7fb46-6d20-4815-af57-c4255bf9d21f">
        <source>getCollection(): Collection;

/*
Date		Who		Reason
20 May 2009	cnwar2	Initial creation

