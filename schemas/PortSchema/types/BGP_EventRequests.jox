    <JadeMethod name="action" id="89cf8f4f-3542-4084-8777-c04a2936ab3c">
        <updating/>
        <source>action(): Boolean updating;
//--------------------------------------------------
// Created:	23 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	errCode		: Integer;
	errTxt		: String;
	terminal	: CM_Terminal;		// cnwrl1 23/02/2010 PAR 22445
	
begin
	on Exception do app.alertExceptionHandler(exception, null, self.getErrorDesc(), errCode, errTxt, true, true);
	on LockException do app.alertLockExceptionHandler(exception);
	
	self.setUser();
	
//	self.processRequest();			// cnwrl1 23/02/2010 PAR 22445 - what it was
	// cnwrl1 23/02/2010 PAR 22445 - start of coding
	// Because (via PAR 21974) the Event Notification and Stops Requests are now stored
	// at the terminal level instead of at the system-wide root level,
	// the processRequest needs to be called for each terminal in turn.
	foreach terminal in app.myRoot.allTerminals do
		app.myPassport.setMyTerminal( terminal );
		self.processRequest();
		if errCode &lt;&gt; null then
			break;
		endif;
	endforeach;
	// cnwrl1 23/02/2010 PAR 22445 - end of coding
	
epilog
	if errCode &lt;&gt; null then
		app.myTrxUA.trxUpdateBGPRequest(self, true, errCode, errTxt, app.myPassport);
	else
	//	app.createActivityHistory(ActivityHistoryGeneral, self.myTerminal, null, self.typeString, false);
	// Glenys. I wouldn't bother creating a activity history for this as it will flood the activity screen and
	// doesn't tell the user very much.
	endif;
	inheritMethod();
	return true;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="cb355f46-fbb8-4ba3-9be2-46ef8c5088ca">
        <source>getDisplay(): String;
//--------------------------------------------------
// Created:	26 May 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	return inheritMethod &amp; Tab &amp; 'Event Requests';

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initRequestFromTask" id="6f945521-d985-430f-8090-d0342b0145f5">
        <updating/>
        <source>initRequestFromTask(_task: CM_AutoTask) updating;
//--------------------------------------------------
// Created:	26 May 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	
	if CM_AutoTaskEventReqExpNotify.hasInstance(_task) then
		self.typeString := self.EventReqExpNotify;
	
	elseif CM_AutoTaskEventReqExpStops.hasInstance(_task) then
		self.typeString := self.EventReqExpStops;
	
	elseif CM_AutoTaskEventReqNotifyEmail.hasInstance(_task) then
		self.typeString := self.EventReqEmailNotify;
	
	elseif CM_AutoTaskEventReqStopsEmail.hasInstance(_task) then
		self.typeString := self.EventReqEmailStops;				
	endif;
	
	inheritMethod(_task);
	
end;</source>
        <Parameter name="_task" type="CM_AutoTask"/>
    </JadeMethod>
    <JadeMethod name="processExpiredNotifyRequest" id="836fd7e8-b1a9-4eac-ac91-be0764ef31de">
        <source>processExpiredNotifyRequest();
//--------------------------------------------------
// Created:	23 May 2005 By: cnwgd1
//--------------------------------------------------
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
vars
	passport : CM_Passport;
	theUser : CM_User;
	msg : String;
begin
	msg := "=====================  Expired Notification Requests Start  =====================";
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	passport := app.myPassport;	
	
	app.myTrxDA.trxDeleteExpEventRequestNotify(passport);
			
	if (not passport.trxCompletedOK) then
		app.remoteErrorWarningToAlert('Unable to process Expired Notification Requests', null, passport.allErrors, null, true, true);
	endif;
	msg := "=====================  Expired Notification Requests Finished  =====================";
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
end;</source>
    </JadeMethod>
    <JadeMethod name="processExpiredStopRequests" id="d8492638-77a6-46d5-9875-1bb86666d849">
        <source>processExpiredStopRequests();
//--------------------------------------------------
// Created:	23 May 2005 By: cnwgd1
//--------------------------------------------------
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
vars
	passport : CM_Passport;
	theUser : CM_User;
	msg : String;
begin
	msg := "=====================  Expired Stop Requests Start  =====================";
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	passport := app.myPassport;		
	
	app.myTrxDA.trxDeleteExpEventRequestStops(passport);
			
	if (not passport.trxCompletedOK) then
		app.remoteErrorWarningToAlert('Unable to process Expired Stop Requests', null, passport.allErrors, null, true, true);
	endif;
	msg := "=====================  Expired Stop Requests Finished  =====================";
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
end;</source>
    </JadeMethod>
    <JadeMethod name="processRequest" id="b8143b22-a1aa-4e9d-8e7c-21e7904c5766">
        <source>processRequest();
//--------------------------------------------------
// Created:	26 May 2005 By: cnwgd1
//--------------------------------------------------
vars

	user	: CM_User;
	error	: String;

begin

	user := app.getMyUser();
	
	if self.typeString = self.EventReqExpNotify then
	//	if user.canDo(null,PmCargoNotificationReq) then
		if user.canDo(null,Mod_BaseSystem) then	//07 Oct 2019	NDL	TFS 46169
			self.processExpiredNotifyRequest();
			return;
		endif;
	elseif self.typeString = self.EventReqExpStops then
		//if user.canDo(null,PmCargoStopsReq) then
		if user.canDo(null,Mod_BaseSystem) then	//07 Oct 2019	NDL	TFS 46169
			self.processExpiredStopRequests();	
			return;
		endif;
	
	elseif self.typeString = self.EventReqEmailNotify then
		//if user.canDo(null,PmCargoNotificationReq) then
		if user.canDo(null,Mod_BaseSystem) then	//07 Oct 2019	NDL	TFS 46169
			self.sendEmailNotifications();	
			return;
		endif;
	
	elseif self.typeString = self.EventReqEmailStops then
		//if user.canDo(null,PmCargoStopsReq) then
		if user.canDo(null,Mod_BaseSystem) then	//07 Oct 2019	NDL	TFS 46169
			self.sendEmailStopRequests();		
			return;
		endif;
	endif;
	
	error := app.getErrorString1(ModuleNotLicensed, self.typeString);
	app.remoteErrorWarningToAlert(error, null, null, null, false, false);

	
end;</source>
    </JadeMethod>
    <JadeMethod name="sendEmailNotifications" id="ddacdb8c-3387-4d06-9e9d-a4c50265d12c">
        <source>sendEmailNotifications();
//--------------------------------------------------
// Created:	23 May 2005 By: cnwgd1
//--------------------------------------------------
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
vars
	passport : CM_Passport;
	theUser : CM_User;
	msg : String;
begin
	msg := "=====================  Email Notifaction of Matched Event Requests Start  =====================";
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	passport := app.myPassport;		
	
	app.myTrxCA.trxCreateBGPEventReqEmail(EventRequestTypeNotify, passport);
			
	if (not passport.trxCompletedOK) then
		app.remoteErrorWarningToAlert('Unable to process email notifaction of matched event requests', null, passport.allErrors, null, true, true);
	endif;
	msg := "=====================  Email Notifaction of Matched Event Requests Finished  =====================";
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
end;</source>
    </JadeMethod>
    <JadeMethod name="sendEmailStopRequests" id="775d34f0-3d58-4e82-bbf6-3baf89200ffb">
        <source>sendEmailStopRequests();
//--------------------------------------------------
// Created:	23 May 2005 By: cnwgd1
//--------------------------------------------------
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
vars
	passport : CM_Passport;
	theUser : CM_User;
	msg : String;
begin
	msg := "=====================  Email Notifaction of Matched Stop Requests Start  =====================";
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	passport := app.myPassport;		
	
	app.myTrxCA.trxCreateBGPEventReqEmail(EventRequestTypeStops, passport);
			
	if (not passport.trxCompletedOK) then
		app.remoteErrorWarningToAlert('Unable to process email notifaction of matched stop requests', null, passport.allErrors, null, true, true);
	endif;
	msg := "=====================  Email Notifaction of Matched Stop Requests Finished  =====================";
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
end;</source>
    </JadeMethod>
</Class>
