    <JadeMethod name="setBody" id="6e77db84-9dbe-46c3-95f5-c8324b11e26a">
        <updating/>
        <source>setBody(pBodyObj:CnEcPageBody) updating;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Purpose:		Set a reference to the receiver's body tag
//
// Parameters:	pBodyObj - The body tag object
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myBody &lt;&gt; pBodyObj then
		self.myBody	:=	pBodyObj;
	endif;
end;</source>
        <Parameter name="pBodyObj" type="CnEcPageBody"/>
    </JadeMethod>
    <JadeMethod name="setTag" id="4ce5c5be-f39b-405b-a59c-323e778e0b69">
        <updating/>
        <source>setTag(pTagObj:CnEcHtmlBodyTag) updating;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Purpose:		Set a reference to the receiver's parent tag.
//
// Parameters:	pTagObj - The parent tag.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myTag &lt;&gt; pTagObj then
		self.myTag	:=	pTagObj;
	endif;
end;</source>
        <Parameter name="pTagObj" type="CnEcHtmlBodyTag"/>
    </JadeMethod>
