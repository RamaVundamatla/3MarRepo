    <JadeMethod name="hasGroups" id="7e0d51d4-0680-4010-bfda-177a845382e7">
        <source>hasGroups():Boolean;
// ---------------------------------------------------------------------------
// Created:     12 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
