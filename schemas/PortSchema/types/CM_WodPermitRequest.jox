Return Value:		

Date		Who		Reason
28 November 2018	jlgndl1	Initial creation	TFS 41980

*/

vars

	marineServiceDetail : CM_WodMarineServiceDetail;

begin

	inheritMethod();
	
	foreach marineServiceDetail in self.allMarineServiceDetails do
		marineServiceDetail.validateForUpdate();
	endforeach;

epilog

end;</source>
