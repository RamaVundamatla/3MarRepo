    <JadeMethod name="assertTrxError" id="b8d914e8-dbb1-4934-95b4-4750e3db83da">
        <source>assertTrxError(_errorCode: Integer) protected;
//17 November 2008	cnwdw1	
//
vars
	allErrorsStr	: String;
begin
	allErrorsStr := app.myPassport.getAllErrorsWarningsAsString();
	if allErrorsStr = null then
		allErrorsStr := "&lt;None&gt;";
	endif;
	self.assertTrxErrorMsg(_errorCode, "expecting error: " &amp; _errorCode.String &amp; " but got" &amp; CrLf &amp; allErrorsStr);
end;</source>
        <access>protected</access>
        <Parameter name="_errorCode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="assertTrxErrorMsg" id="b8d96a94-8251-4f65-b332-48f7f12ca562">
        <source>assertTrxErrorMsg(_errorCode: Integer; _message: String) protected;
//17 November 2008	cnwdw1	
// 30/07/2012	cnwmh5	Change to see if there are any Jade Errors and fail
//
vars
	error: CM_Error;
begin

	foreach error in app.myPassport.allErrors do
		if error.errorCode &lt;= app.myRoot.baseErrorNum then
			self.assertTrueMsg(false, error.text);
			return;
		endif;	
	endforeach;
	
	foreach error in app.myPassport.allErrors do
		if error.errorCode = _errorCode then
			return;
		endif;
	endforeach;
	// didn't find the error so force a failure
	self.assertTrueMsg(false, _message);
end;</source>
        <access>protected</access>
        <Parameter name="_errorCode" type="Integer"/>
        <Parameter name="_message" type="String"/>
    </JadeMethod>
    <JadeMethod name="assertTrxWarning" id="e6c38125-2b52-4109-b075-f55066620c1b">
        <source>assertTrxWarning(_errorCode: Integer) protected;
/*
Date		Who		Reason
07 May 2012	cnwcs5	Initial creation - par 29402 - coparn release updates*/
vars
	allErrorsStr	: String;
begin
	allErrorsStr := app.myPassport.getAllErrorsWarningsAsString();
	
	if allErrorsStr = null then
		allErrorsStr := "&lt;None&gt;";
	endif;
	
	self.assertTrxWarningMsg(_errorCode, "expecting warning: " &amp; _errorCode.String &amp; " but got" &amp; CrLf &amp; allErrorsStr);
end;</source>
        <access>protected</access>
        <Parameter name="_errorCode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="assertTrxWarningMsg" id="bea5c9a5-9e03-406f-b97f-35f7172212a1">
        <source>assertTrxWarningMsg(_errorCode: Integer; _message: String) protected;
/*
Date		Who		Reason
07 May 2012	cnwcs5	Initial creation - par 29402 - coparn release updates
*/
vars
	warning: CM_Error;
begin
	foreach warning in app.myPassport.allWarnings do
		if warning.errorCode = _errorCode then
			return;
		endif;
	endforeach;
	// didn't find the warning so force a failure
	self.assertTrueMsg(false, _message);
end;</source>
        <access>protected</access>
        <Parameter name="_errorCode" type="Integer"/>
        <Parameter name="_message" type="String"/>
    </JadeMethod>
    <JadeMethod name="checkErrorWarningHasOccurred" id="62a2ef95-ebe4-4290-8134-5d9a32a847bf">
        <source>checkErrorWarningHasOccurred() : Boolean protected;

/*

Purpose:		Check to see if the passed in error code exists in
				either the errors or warnings collection

Date			Who		Reason
29/10/2014		cnwmh5	Initial creation

*/

vars
	
	error					: CM_Error;
	
	hasOccurred				: Boolean;
	
begin

	hasOccurred := false;

	foreach error in app.myPassport.allErrorWarnings do
		if self.expectedTrxErrors.includes(error.errorCode) then
			hasOccurred := true;
			break;
		endif;
	endforeach;

	return hasOccurred;
	
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkNeedToRunMethod" id="69874b58-d3f4-437b-9d8e-7e74d4c6a59e">
        <source>checkNeedToRunMethod(_method : Method) : Boolean;

/*

Purpose:		Check whether method needs to be run	

Date			Who		Reason
28 April 2011	cnwmh5	Initial creation

*/

vars

	scheduleArray	: StringArray;
	
	returnVal		: Boolean;
	text			: String;
	
begin

	returnVal := true;
	
	create scheduleArray transient;
	text := _method.text.replaceString(", ", ",");
	text.replaceString("," &amp; Tab, ",");
	text.replaceString(CrLf, ",");
	scheduleArray.cnGetTokens(text, ",", false);
	
	if self.myScheduleConstant = null then
		if scheduleArray.includes(DO_NOT_RUN) then
			returnVal := false;
		endif;
	else
		if not scheduleArray.includes(self.myScheduleConstant.name) then
			returnVal := false;
		endif;
	endif;
	
	return returnVal;
	
epilog

	delete scheduleArray;

end;</source>
        <Parameter name="_method" type="Method"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
