    <JadeMethod name="loadDB" id="bad8bdaa-c6fb-4214-b700-799163033201">
        <updating/>
        <source>loadDB(_mergeCargo: Boolean; _passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     10 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

/* Changes

Date		Name	TFS#		Description
============================================================================
17 Jun 2008	cnwkpd1	PAR #17014 	Correct conversion of cargo type description to cargo type,
								ensure description is provided, and allow null operator
21 Feb 2013	cnwrs1	Par 31143 	EDI TRX not handling dbLoadErrors after no verify errors take 3
08 Oct 2015	cnwrs1	Par 36863 	make EDI consistant times when refreshing progress bar
13 May 2016	cnwns1	TFS 488  	Multi Timezone Support
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
============================================================================*/

vars
	pxyProduct		: CM_Product;
	realObjFound	: CM_Product;
	ediProductTI	: CM_EDIProductTI;
	prodSet			: CM_ObjectSet;
	terminal		: CM_Terminal;
	done, todo		: Integer;
	cargoType 		: CM_CargoType;
	cargoTypeID		: Integer;
	operatorCode	: String;
	operator		: CM_Operator;
	prodDict		: CM_ProductByCargoTypeCodeDict;
	iter			: Iterator;					// PAR #17014
	progressTS 		: TimeStamp;
begin
	// Arm our base exception handlers
	on Exception do validationExceptionHandler(exception, _passport);
	
	progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	app.setContinueCMExceptions(false);
	create prodSet transient;
	create prodDict transient;
	
	terminal := self.getMyTerminal();
	if terminal = null then
		app.raiseCMException1(Err_InvalidTerminal, 'null', null, null);
		return;
	endif;
	
	todo := self.allEDITrackedItems.size;
	self.updateProgress(progressTS, "Loading into JMT...", todo, done, true, _passport);
	
	iter := self.allEDITrackedItems.createIterator;
	while iter.next(ediProductTI) do
		done := done + 1;
		self.updateProgress(progressTS, "Loading into JMT...", todo, done, false, _passport);
		
		// find real product
		cargoTypeID := app.myRoot.getCargoTypeIDFromDescription(ediProductTI.cargoTypeDescr);		// PAR #17014
		if cargoTypeID = null then
			cargoTypeID := app.myRoot.getCargoTypeIDFromAbbrev(ediProductTI.cargoTypeDescr);		// PAR #17014
		endif;
		cargoType := app.myRoot.allCargoTypesById[cargoTypeID];
		
		if cargoType &lt;&gt; null then
			// PAR #17104 - need to validate operator if it is provided
			if ediProductTI.operatorCode &lt;&gt; null then
				operator := app.myRoot.allOperators[ediProductTI.operatorCode];
				if operator = null then
					app.raiseCMException1(ERR_INVALID_OPERATOR, ediProductTI.operatorCode, "Operator", null);
					continue;
				endif;
				operatorCode := operator.code;
			else
				operatorCode := null;				// PAR #17014
			endif;		
		
			if prodDict[cargoTypeID, ediProductTI.code] &lt;&gt; null then
				app.raiseCMException1(CMUI_Selector_Duplicate_Line, 'null', null, null);
				return;
			endif;			
			// Par 17020 - aer 18/06/2008 : operator can be entered from file and the products that have null operator needs to be updated as well.
			realObjFound := cargoType.allProducts[operatorCode, ediProductTI.code];
			
			if realObjFound &lt;&gt; null then
				// Update existing product
				pxyProduct := app.createUpdateProxy(realObjFound).CM_Product;
				pxyProduct.CM_Product.createProductAttributes();
			else
				// Add new product
				create pxyProduct transient;
				pxyProduct.setProductDefaults(cargoType);
			endif;	
			ediProductTI.setProxyData(pxyProduct, _passport);
			ediProductTI.setProxyAttributes(pxyProduct, _passport);
			prodSet.add(pxyProduct);
			prodDict.add(pxyProduct);
		endif;
	endwhile;
	
	self.updateProgress(progressTS, "Loading into JMT...", todo, done, true, _passport);

	if prodSet.isEmpty then
		app.writeLog(class.name &amp; " " &amp; method.name &amp;  " no TI's found to load", LogINFO);
		return;
	endif;

	app.myTrxCA.trxCreateEDIUpdateProducts(prodSet, self, false, _passport);
	
//	if _passport.noErrors then //ccms1845
//		app.myTrxUA.trxSetEDIDataStatus(self, CM_EDIFile.EDI_STATUS_DBLOADED);
//	endif;

	
epilog
	if prodSet &lt;&gt; null then
		prodSet.purge;
		delete prodSet;
	endif;
	delete prodDict;
	delete iter;
	
end;</source>
        <Parameter name="_mergeCargo" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
