// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theForm : SOP_TableMaintForm;

begin
	//cnwmc5 - 17 Oct 2013 - PAR 32622
	inheritMethod();
	
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := false;
	theForm.mulSelect1.setSelected(null);
	theForm.tblInput1.cnEcResizeContents();
end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="ba3eee0e-6069-49ad-8146-1a7ede1fdf83">
        <updating/>
        <source>setupThumbnailDetails() updating;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theForm : SOP_TableMaintForm;

begin
	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_EventGroupData);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Name, false);
	
	theForm.setupMTReportColumnCombo();
	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_EventGroupData);
	theForm.shtTblInput1.visible := true;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="0d319695-d660-4797-9cd3-7ba8ec04e7e1">
        <updating/>
        <source>showThumbnail(pEventGroup: CM_EventTypeGroup) updating;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theForm		: SOP_TableMaintForm;
begin
	theForm	:=	self.myForm;
	theForm.tblInput1.clearValues();
	theForm.tblInput1.setValueByName(ETRow_Description,	pEventGroup.description);
	theForm.tblInput1.setValueByName(ETRow_Name, pEventGroup.name);
	//theForm.tblInput1.setValueByName(ETRow_Colour, pEventType.colour);
	//theForm.tblInput1.showRowByName(ETRow_Type, false);
	theForm.mulSelect1.setSorted(true);
	theForm.mulSelect1.setSelected(pEventGroup.allEventTypes);
	self.disableMulSelect1Contents();
epilog

end;</source>
        <Parameter name="pEventGroup" type="CM_EventTypeGroup"/>
    </JadeMethod>
</Class>
