    <JadeMethod name="doMACS3VPSProcessCall" id="53fbf1b5-abce-4bc2-9f0b-31ba7a56a48c">
        <source>doMACS3VPSProcessCall(_action : String; _vessel : CM_Vessel) : Boolean;
//
// Purpose:			Try and do sensible up front validation here, before we get into the meaty methods
//
// Parameters:			
//
// Return Value:		True if successful. False if unsuccessful/cancelled
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 09/04/2020	jlgdap1		Initial creation TFS 49003 MTN API Inline Agent
// 02/02/2021	jlgmd1		TFS 49052 MACS3 Vessel Library API - Refactor
//
vars
	pxyStructure		: CM_CellularVesselStructure;
	
	consumer 			: CM_MACS3ConsumerAgent;
	webService 			: CM_NavisMACS3Service;
	
	jsonResponse		: String;
	dataAgent			: CM_NavisJSONAgent;
	
	invalid,
	isOk				: Boolean;
	result,
	credits				: Decimal[12,2];

begin
	if _vessel = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "Missing Vessel - unable to continue");
		return false;
	endif;
	
	pxyStructure := app.createUpdateProxy(_vessel.myCellularVesselStructure).CM_CellularVesselStructure;
	if pxyStructure = null then
		return false;
	endif;
	
	// Set up the External Web Service Consumer Agent - this is what actually handles the HTTP calls
	webService := app.myRoot.allExternalWebServices[ExternalWebServiceNavisMACS3].CM_NavisMACS3Service;
	if webService = null then
		return false;	// Web Service not set up, nothing to do
	endif;
	
	create consumer transient;
	consumer.setupFromWebServiceDefinition(webService);
	consumer.myVessel := _vessel;
	
	// First thing to do is a credit check, and display the appropriate warning if its low
	if consumer.doSendCheckCreditReq(credits) then
		if credits &lt;= webService.creditWarnThreshold then
			if _action = CM_MACS3ConsumerAgent.MethodValidateIMO then
				return false;	// Don't cause the creation of the vessel to fail, just because we can't do the IMO check
			endif;
			if not app.myPassport.warningsAcknowledged then
				app.raiseCMWarning1(MACS3_LOW_CREDITS, credits.String, null, null, null);
				result := app.showErrorWarningDialog('MACS3 VPS', app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
				if result = IDOK then
					app.myPassport.clearErrorsWarnings();
				else
					// User Cancelled, return early
					return false;
				endif;
			endif;
		endif;
	endif;	
	
	process.isMPD;
	// TODO: Read the Validate IMO checkbox on the ExtWSDef and validate the IMO on vessel creation.
	
	// GET /vessels/{imo}/productive-metadata - checks whether an IMO (Lloyd's) number is known to MACS3
	if	_action = CM_MACS3ConsumerAgent.MethodProdMetaData /* or
		(webservice.validateIMO and _action = ACTION_VALIDATE_IMO)*/ then
		
		jsonResponse := consumer.doSendProdMetaReq();
		if jsonResponse = null then
			return false;
		endif;
			
		create dataAgent transient;
		dataAgent.parseJSONMetadataRes(jsonResponse, pxyStructure);
		
	// GET /vessels/{imo}/profiles/{version}/{type} - does a thing
	// GET /vessels/{imo}/versions/{version}/json - Grabs the specified version JSON file for the given IMO
	elseif	_action = CM_MACS3ConsumerAgent.MethodVesselProfiles or
			_action = CM_MACS3ConsumerAgent.MethodVesselVersions then
		// IMO number is the first entry in the parameter array, version is the second
		if _vessel.lloydsNumber = null then
			app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Lloyds_number), CM_Vessel::lloydsNumber.name, _vessel);
			return false;
		endif;
		if pxyStructure.definitionVersion = null then
			app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(File_Version), null, null);
			return false;
		endif;
		
		if _action = CM_MACS3ConsumerAgent.MethodVesselProfiles then
			jsonResponse := consumer.doSendVesselProfileReq();
		else
			jsonResponse := consumer.doSendVesselVersionsReq();
		endif;
		
		if jsonResponse = null then
			return false;
		endif;
		
		create dataAgent transient;
		
		while true do
			dataAgent.parseJSONShipDataRes(jsonResponse, pxyStructure);
			
			if app.myPassport.hasWarningsToAcknowledge then
				result := app.showErrorWarningDialog('MACS3 VPS', app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					app.myPassport.clearErrorsWarnings();
					
					continue;
				else
					// User Cancelled, return early
					return false;
				endif;
			endif;
			
			break;
		endwhile;
		
	endif;
	
	while true do
		app.myTrxUA.trxUpdateVesselStructure(pxyStructure, app.myPassport);
		if app.myPassport.trxCompletedOK then
			isOk := true;
			break;
		else
			result := app.showErrorWarningDialog('MACS3 VPS', app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
	endwhile;
	
	return isOk;
epilog
	delete consumer;
	delete dataAgent;
	delete pxyStructure;
end;</source>
        <Parameter name="_action" type="String"/>
        <Parameter name="_vessel" type="CM_Vessel"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doReorderCargoLongestFirst" id="5cf9f079-5788-4a31-860a-c4c812ffa98a">
        <source>doReorderCargoLongestFirst( _allCargoUNSorted : CM_TIArray; _allCargoSorted : CM_TIArray io);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 August 2011	cnwndl1	Initial creation	Par 28035

*/

vars

	localTiArray : DynaDictionary;
	ti : CM_TrackedItem;
	obj : Object;
	key : Integer;
	isoTypeCode : String;
	isoType : CM_ISOType;
	metre : Real;

begin

	create localTiArray transient;
	localTiArray.setMembership(CM_TrackedItem);
	localTiArray.addExternalKey(Integer,4,true,false);
	localTiArray.endKeys(true);
	
	// sort the requests into longest first so we try to assign the hardest to fit on the wagons
	// first otherwise we may use all the big spaces with small containers and have no useable space left.
	foreach ti in _allCargoUNSorted do
		key := 0;
		isoTypeCode := ti.getISOType;
		if isoTypeCode &lt;&gt; null then
			isoType	:=	app.myRoot.allISOTypes[isoTypeCode];
			if isoType &lt;&gt; null then
				key := isoType.getLengthInFeet;
			endif;
		else
			metre := ti.getLengthInMetres();
			if metre &gt; 0 then
				key := (((metre  / 100) * 39.37) / 12).Integer; // turn metres into feet....
			endif;
		endif;
		if key = 0 then
			continue;
		endif;
		localTiArray.putAtKey(key,ti);
	endforeach;
	
	
	foreach obj in localTiArray do
		ti := obj.CM_TrackedItem;
		_allCargoSorted.addExclusive( ti );
	endforeach;

epilog

	delete localTiArray;

end;</source>
        <Parameter name="_allCargoUNSorted" type="CM_TIArray"/>
        <Parameter name="_allCargoSorted" type="CM_TIArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doReorderCargoShipJobSequence" id="86be0fa4-9d3c-4879-8666-497ac50ebc8f">
        <source>doReorderCargoShipJobSequence( _allCargoUNSorted : CM_TIArray; _allCargoSorted : CM_TIArray io);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 August 2011	cnwndl1	Initial creation	Par 28035

*/

vars

	localTiArray : DynaDictionary;
	ti : CM_TrackedItem;
	obj : Object;
	jobKey : Integer;
	seqKey : Integer;
	wle : CM_VoyageWLE;
	job : CM_VoyageJob;

begin

	create localTiArray transient;
	localTiArray.setMembership(CM_TrackedItem);
	localTiArray.addExternalKey(Integer,4,false,false);	// job number
	localTiArray.addExternalKey(Integer,4,false,false);	// seq number
	localTiArray.endKeys(true);
	
	// sort the requests into discharge sequence number within  voyage job number.
	foreach ti in _allCargoUNSorted do
		jobKey := 0;
		seqKey := 0;
		job := ti.allJobsShipReceive.first;
		if job = null then
			continue;
		endif;
		jobKey := job.id.Integer;
		wle := job.getWLEForTI( ti ).CM_VoyageWLE;
		if wle = null then
			continue;
		endif;
		seqKey := wle.id.Integer;
		localTiArray.putAtKey(jobKey, seqKey, ti);
	endforeach;
	
	
	foreach obj in localTiArray do
		ti := obj.CM_TrackedItem;
		_allCargoSorted.addExclusive( ti );
	endforeach;

epilog

	delete localTiArray;

end;</source>
        <Parameter name="_allCargoUNSorted" type="CM_TIArray"/>
        <Parameter name="_allCargoSorted" type="CM_TIArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doSortLCsInToSeqOrder" id="0ed453db-196e-4c0d-845b-44e2468aab5f">
        <source>doSortLCsInToSeqOrder(_lcs : CM_LCArray input);
// ---------------------------------------------------------------------------
// Created:		30 September 2005  By Andrew Bishop cnwab1
//
// Purpose:		This takes the Slot Controllers converts them into VoyageWLES, Sorts by the correct seqnum 
//				
// ---------------------------------------------------------------------------

vars
	theSC : CM_VoyageController;
	theSReq : CM_Request;
	anLC : CM_LocationsController;
	aWLE : CM_WorkListEntry;
	wleSorter :	CM_VoyageWLEDynaDict;
	iter : Iterator;
begin
	if _lcs.isEmpty then
		return;
	endif;
	
	anLC := _lcs.first;
	if not anLC.isKindOf(CM_VoyageController) then
		return;
	endif;

	theSC := _lcs.first.CM_VoyageController;
	
	theSReq := theSC.getRequest(true);
	if theSReq = null
	or theSReq.myJob = null then
		return;
	endif;
	// PAR 28365 - No need to sort GC WLEs. RORO GC Request may have many WLEs all for the same LC.
	if theSReq.allWorkListEntries.size &gt; 1 then
		return;
	endif;
		
	wleSorter :=self.myWLESorter;	
	wleSorter.init(theSC.myVoyage,theSReq.myJob.CM_VoyageJob);
	
	foreach anLC in _lcs do
		theSC := anLC.CM_VoyageController;
		theSReq := theSC.getColourCoding(true);
		if theSReq &lt;&gt; null then
			theSReq.allWorkListEntries.copy(wleSorter);
		endif;
	endforeach;

	_lcs.clear;
	iter := wleSorter.createIterator();
	while iter.next(aWLE) do
		theSReq := aWLE.CM_VoyageWLE.myRequest;
		theSC := theSReq.getVoyageController().CM_VoyageController;

		if not _lcs.includes(theSC) then
			_lcs.add(theSC);
		endif;
	endwhile;
//app.cnwdad1_write(method.name);
epilog
	delete iter;
	
end;</source>
        <Parameter name="_lcs" type="CM_LCArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTaskProxyGatherForComplete" id="edfd5680-e8a8-4afc-bf7a-ba3a6a00405e">
        <source>doTaskProxyGatherForComplete();

