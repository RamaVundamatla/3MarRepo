    <JadeMethod name="populateExtractClass" id="05014faa-970c-4144-ac84-b562a4d96fdc">
        <source>populateExtractClass() protected;
// ---------------------------------------------------------------------------
// Created:		07 August 2003 by cnwsb1
//
// Updated CNWTH2 - cell item object hold the master dataDumpClass
//					row item object holds dataDumpExtract proxy if included and editing
// 13 March 2018		jlgrh7 TFS #37526 STWO - Add CM_Product (Cargo Subtype) to Data Export Maintenance
// ---------------------------------------------------------------------------
vars
	compareDef,
	def 				: CM_DataDumpExtractDef;
	tmpExportClass,
	pxyExportClass 		: CM_DataDumpExtractClass;
	cnt 				: Integer;
	lineStr 			: String;
	idx 				: Integer;
	masterClass			: CM_DataDumpClass;
	masterDict			: CM_DataDumpClassDict;
	ls,
	included			: Boolean;
	extractedUpTo		: String;
	viewing				: Boolean;
	
begin
	viewing := self.mode = self.Mode_View;
	self.tblExtractClass.allSelectedObjects.clear();
	self.tblExtractClass.rows := self.tblExtractClass.fixedRows;
	masterDict := app.myRoot.allDataDumpClasses;

	if viewing then
		def := self.myCurrentObject.CM_DataDumpExtractDef;
	else
		def := self.myProxyObject.CM_DataDumpExtractDef;
	endif;
	
	if def = null then
		return;
	endif;
	foreach masterClass in masterDict do : masterLoop
		included := false;
		extractedUpTo := null;
		tmpExportClass := null;
		//for the time being, we find out whether the data dump calss is included in the def be looping
		//through matching the name - it's an array =(
		foreach tmpExportClass in def.allDataDumpExtractClasses do : defLoop
			if tmpExportClass.className = masterClass.className then
				if tmpExportClass.extractedUpToDateTime.isValid then
					extractedUpTo := tmpExportClass.extractedUpToDateTime.String;
				else
					extractedUpTo := null;
				endif;
				included := true;
				if def.extractFormat = CM_DataDumpExtractDef.FmtSQLNative then //19/04/2010 cnwdz2
					lineStr := included.cnEcGetTableCheckBoxValue &amp; Tab &amp; 
							tmpExportClass.className &amp; Tab &amp; 
							tmpExportClass.classAlias &amp; Tab &amp;
							extractedUpTo;
		
					idx := self.tblExtractClass.addItem(lineStr);
					self.tblExtractClass.accessCell(idx, 1).itemObject := masterClass;
					//if included then
					self.tblExtractClass.accessRow(idx).itemObject := tmpExportClass;
					//endif;
					self.tblExtractClass.colourRows(self.colorRow1, self.colorRow2);
				else
					break defLoop;
				endif;	
			endif;
		endforeach;
		if not def.extractFormat = CM_DataDumpExtractDef.FmtSQLNative then
			lineStr := included.cnEcGetTableCheckBoxValue &amp; Tab &amp; 
						masterClass.className &amp; Tab &amp; 
						masterClass.classAlias &amp; Tab &amp;
						extractedUpTo;
			if not def.extractFormat = CM_DataDumpExtractDef.FmtXML_Generic then							//+TFS37526 Bypass 
				if not masterClass.isAvailableForDSS() then
					continue;
				endif;
			endif;
			idx := self.tblExtractClass.addItem(lineStr);
			self.tblExtractClass.accessCell(idx, 1).itemObject := masterClass;
			if included then
				self.tblExtractClass.accessRow(idx).itemObject := tmpExportClass;
			endif;
			self.tblExtractClass.colourRows(self.colorRow1, self.colorRow2);	
		endif;
	endforeach;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateExtractDef" id="19855336-b6d2-4d14-b05b-b18c7fa7d85d">
        <updating/>
        <source>populateExtractDef(obj: Object) updating, protected;
// ---------------------------------------------------------------------------
// Created:		05 August 2003 by cnwsb1
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
26 May 2008	cnwkpd1	PAR #16814 - Replace global.commonResumInvalidObjHandler
29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
*/

vars
	gotException : Boolean;
	def : CM_DataDumpExtractDef;
	viewName : String;
	terminalName : String;
	user : CM_User;	//07 Jan 2014	NDL	Par 33264
	userName : String;	//07 Jan 2014	NDL	Par 33264

begin
	self.shtExtractHist.caption := "History";
	self.shtExtractClass.caption := "Classes";
	
	def := obj.CM_DataDumpExtractDef;
	if def = null then
		self.setNavigatorHeading(null);
		return;
	endif;
	// Setup sheet headers
	if def.extractFormat = CM_DataDumpExtractDef.FmtExternalDatabase then
		self.shtExtractDef.caption := global.getExtractFormatDescr(def.extractFormat);
	elseif def.extractFormat = CM_DataDumpExtractDef.FmtSQLNative then        //20/04/2010 cnwdz2
		self.shtExtractDef.caption := global.getExtractFormatDescr(def.extractFormat);
	else
		self.shtExtractDef.caption := global.getExtractFormatDescr(def.FmtXML_Generic);
	endif;

	// Populate sheet data.
	on Exception do app.handleDeletedObject(exception, def, gotException);		// PAR #16814
	
	if def.myTerminal &lt;&gt; null then
		terminalName := def.myTerminal.name;
	endif;
	//07 Jan 2014	NDL	Par 33264
	if def.ignoreDeletesFromUser &lt;&gt; null then
		user := def.ignoreDeletesFromUser;
		userName := user.userName &amp; ' (' &amp; user.code &amp; ')';
	endif;

	tblExtractDef.setValueByName(ETRow_Description, def.description);
	if gotException then
		return;
	endif;
	tblExtractDef.setValueByName(ETRow_ExtractFormat, def.getExtractFormatDescr);
	tblExtractDef.setValueByName(ETRow_OidFormat, def.getOidFormatDescr());
	tblExtractDef.setValueByName(ETRow_OidColumnName, def.oidColumnName);
	tblExtractDef.setValueByName(ETRow_IsActive, def.isActive.String);
	tblExtractDef.setValueByName(ETRow_FileFolderName, def.fileFolderName);
	tblExtractDef.setValueByName(ETRow_EdbUserName, def.edbUserName);
	tblExtractDef.setValueByName(ETRow_SqlServerVersion, def.sqlServerVersion);
	tblExtractDef.setValueByName(ETRow_EdbServerName, def.edbServerName);
	tblExtractDef.setValueByName(ETRow_EdbConnectionString, def.edbConnectionString);
	tblExtractDef.setValueByName(ETRow_EdbMachineDSN, def.edbMachineDSN);
	tblExtractDef.setValueByName(ETRow_CreateSQLStatements, def.createSQLStatements);
	tblExtractDef.setValueByName(ETRow_AlertLimit, def.alertLimit.String);
	tblExtractDef.setValueByName(ETRow_BulkDataLoadFileFolder, def.fileFolderName);
	tblExtractDef.setValueByName(ETRow_IgnoreDelUser, userName);	//07 Jan 2014	NDL	Par 33264
	self.cmbIgnoreDelUser.listIndex := self.cmbIgnoreDelUser.findObject( user );	//07 Jan 2014	NDL	Par 33264
	
	if def.edbPassword &lt;&gt; null then
		self.enteredPassword := def.edbPassword;
		tblExtractDef.setValueByName(ETRow_EdbPassword, '******');
	endif;
	tblExtractDef.setValueByName(ETRow_Terminal, terminalName);

	if def.isFormatExternalDatabase then
		viewName := self.ViewEDB;
	elseif def.isFormatSQLNative then
		viewName := self.ViewSQLNative;
	else
		viewName := self.ViewXML;
	endif;
	
	self.tblExtractDef.showHideRowsByViewName(viewName,
			CM_EntryTable.ShowHideRows, false);
			//ShowRowsOnly or ShowHideRows or HideRowsOnly
			
	self.cmbExtractFormat.text := def.getExtractFormatDescr;
	
	//Syatem unable to process the extract DB request by normal mode if the app server we are connecting to is not on the DB server, hence introduced a new checkbox to do this job via a BGP request.
	//By enabling this checkbox, system by default process the external DB request via a queued BGP process.
	//System by default disable (but leave ticked) if both are on different servers.
	if app.dbServerComputerName() &lt;&gt; app.computerNameAppServer() then	//JIRA 23326
		self.chkExtractAllBGP.value := true;							//JIRA 23326
		self.chkExtractAllBGP.enabled := false;  						//JIRA 23326
		self.chkExtractAllBGP.bubbleHelp := app.getErrorString(Extra_works_only_serve_not_ser); //JIRA 23326
	else																//JIRA 23326
		self.chkExtractAllBGP.value := true;							//JIRA 23326
		self.chkExtractAllBGP.enabled := true;  						//JIRA 23326
	endif;																//JIRA 23326
	
	self.tblExtractDef.resetSize;
	self.setNavigatorHeading(def.description);
end;</source>
        <access>protected</access>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="populateExtractFeatures" id="6b5b1230-afd0-476a-b4c0-14f4531e7768">
        <updating/>
        <source>populateExtractFeatures() updating, protected;
// ---------------------------------------------------------------------------
// Created:     24 May 2004	cnwth2
//
// Purpose:     
//			 
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 24/11/2017	jlgdap1		TFS 7511 LNX Don't show duplicate attribute names from different subclasses.
// 27/04/2018	jlgmd1		TFS 38242 STWO Fixed 'features' not appearing when exporting as XML (Part of TFS 37526)
vars
	pxyDataDumpClass	: CM_DataDumpExtractClass;
	numRows,
	row					: Integer;
	tbl					: CM_DataTable;
	sysFeatureDict		: CM_DataDumpFeatureByNameDict;
	sysFeature			: CM_DataDumpFeature;
	lastFeature			: String;							// TFS 7511
begin

	pxyDataDumpClass := self.cmbSelectedClass.listObject.CM_DataDumpExtractClass;

	if pxyDataDumpClass = null then
		self.mulFeatures.setAvailable(null, true);
		self.mulFeatures.setSelected(null);
		return;
	endif;
	
	self.allAvailableFeaturesDict.clear();
	foreach sysFeature in pxyDataDumpClass.myDataDumpClass.allDataDumpFeatures do
        if sysFeature.isRestrictedToExpose() then //cnwgb1 11 June 2013 PAR 31663
			continue;
		endif;
		if sysFeature.featureName = lastFeature then		// TFS 7511
			continue;										// TFS 7511
		endif;												// TFS 7511
		if self.myCurrentObject &lt;&gt; null and 
		   self.myCurrentObject.CM_DataDumpExtractDef.extractFormat = CM_DataDumpExtractDef.FmtSQLNative then
			if not sysFeature.isOidBin() then
				self.allAvailableFeaturesDict.add(sysFeature);
			endif;
		elseif self.myCurrentObject &lt;&gt; null and																			// TFS 38242
			   self.myCurrentObject.CM_DataDumpExtractDef.extractFormat = CM_DataDumpExtractDef.FmtXML_Generic then		// TFS 38242
			    self.allAvailableFeaturesDict.add(sysFeature);															// TFS 38242
		else		
			if sysFeature.isDSS or sysFeature.isOidBin() then
				self.allAvailableFeaturesDict.add(sysFeature);
			endif;
		endif;
		lastFeature := sysFeature.featureName;				// TFS 7511
	endforeach;
	
	self.mulFeatures.formDisplayEntryMethodName := 'displayEntryFeature';
	self.mulFeatures.setAvailable(self.allAvailableFeaturesDict, true);
	self.mulFeatures.setSelected(pxyDataDumpClass.allDataDumpFeatures);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateExtractHistory" id="01a20d07-f380-4019-83a4-b96ee333980a">
        <source>populateExtractHistory() protected;
// ---------------------------------------------------------------------------
// Created:		07 August 2003 by cnwsb1
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
02 Feb 2012	cnwkpd1	PAR #28906 - Speed up performance of form load and edit
	
*/

vars
	def : CM_DataDumpExtractDef;
	hist : CM_DataDumpExtractHistory;
	cnt : Integer;
	lineStr : String;
	idx : Integer;
	ddExtClass : CM_DataDumpExtractClass;
	
begin
	self.tblExtractHist.rows := self.tblExtractHist.fixedRows;
	
	def := self.myCurrentObject.CM_DataDumpExtractDef;
	if def = null then
		return;
	endif;
	
	// PAR #28906 - don't bother loading if the sheet is disabled
	if not self.shtExtractHist.enabled then
		return;
	endif;
	
	foreach ddExtClass in def.allDataDumpExtractClasses do
		cnt := 0;
		foreach hist in ddExtClass.allDataDumpExtractHistory reversed do
	//	foreach hist in def.allDataDumpExtractHistory reversed do
			cnt := cnt + 1;
			if cnt &gt; 20 then
				break;
			endif;
			
			lineStr := hist.getAttributeStringForDefArray(self.tblExtractHist.allTblDataEntRows);
			idx := self.tblExtractHist.addItem(lineStr);
			self.tblExtractHist.accessRow(idx).itemObject := hist;
		endforeach;
	endforeach;

	// PAR #28906 - moved outside loop - only needs to be done once at the end
	self.tblExtractHist.colourRows(self.colorRow1, self.colorRow2);		

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateExtractObjects" id="ef56cea7-1532-436b-85a2-e54dd35e0e31">
        <updating/>
        <source>populateExtractObjects() updating, protected;
// ---------------------------------------------------------------------------
// Created:     Aug 2004	cnwrs1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
/*
01 Mar 2024 navrv30	Bug 59712: EUP Change of Ownership Other - Data Extract - Unable to extract CM_TrackedItem
*/
vars
	theClass : Class;
	selectorForm : CMUI_Selector;
	userTerminal	: CM_Terminal;
begin
	app.mousePointer := Busy;
	self.mySelectedClass := self.cmbSctObjClass.listObject.CM_DataDumpExtractClass;
	self.btnExtract.enabled := false;
//	if self.mySelectedClass = null then
		self.mulObjects.setAvailable(null, true);
		self.mulObjects.setSelected(null);
//	else
		theClass := self.mySelectedClass.myDataDumpClass.myClass;
		if theClass.name = CM_MachineHistory.name or
		   theClass.name = CM_TempReading.name or
		   theClass.name = CM_TITransaction.name or
		   theClass.name = CM_VehicleVisitRecord.name then
			self.mulObjects.setAvailable(null, true);
			self.mulObjects.setSelected(null);
			self.mulObjects.visible := false;
			self.txtDateFrom.visible := true;
			self.txtDateTo.visible := true;
			self.lblDateFrom.visible := true;
			self.lblDateTo.visible := true;
			self.txtDateFrom.setDate(null);
			self.txtDateTo.setDate(null);
		elseif theClass.name = CM_TrackedItem.name then
			self.mulObjects.visible := true;
			self.txtDateFrom.visible := false;
			self.txtDateTo.visible := false;
			self.lblDateFrom.visible := false;
			self.lblDateTo.visible := false;
			
			userTerminal := app.getMyUser().getFirstTerminal();   //01 Mar 2024 navrv30	Bug 59712
			if userTerminal &lt;&gt; null then						  //01 Mar 2024 navrv30	Bug 59712
				if app.getMyUser().canDo(userTerminal, PmAdmSelectorView) then
					self.btnExtract.enabled := true;
					selectorForm := app.getSelectorForm(self, self.myMasterMenuAction);
					selectorForm.show;
				endif;
			endif;
		else
			self.btnExtract.enabled := true;
			self.mulObjects.visible := true;
			self.txtDateFrom.visible := false;
			self.txtDateTo.visible := false;
			self.lblDateFrom.visible := false;
			self.lblDateTo.visible := false;
			self.mulObjects.formDisplayEntryMethodName := 'displayEntryObject';
			myObjArray.clear;
			theClass.allInstances(myObjArray, 32000, true);
			self.mulObjects.setAvailable(myObjArray, true);
			self.mulObjects.setSelected(null);
		endif;
//	endif;
epilog
	app.mousePointer := Idle;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="searcherTblGetDefName" id="a0cabe6d-803f-46da-9d35-50740e344fcd">
