    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="53c53c28-7e31-4c1c-8b78-5d38b6ae464f">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	str		: String;
	pos		: Integer;
	tmpTA	: CM_TerminalArea;
	
begin
	inheritMethod(_userWindow);
	
	pos := 1;
	
	while true do
		str := _userWindow.xmlInfo.cnEcGetNextTagValueOfName(XML_TA, pos);
		if pos &lt;= 0 then
			break;
		endif;
		
		tmpTA := self.myTerminal.allTerminalAreas[str];
		if tmpTA = null then
			continue;
		endif;

		self.myCurrentTerminalArea := tmpTA;
		self.allTerminalAreas.add(tmpTA);

	endwhile;
	
end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="initSelectAreasCollection" id="d94645e4-d83c-4058-98ea-b00555c144c5">
        <source>initSelectAreasCollection();
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	terminalArea	: CM_TerminalArea;
	iter01 : Iterator;
	ls, haveStarted : Boolean;
	theTAs : CM_TAByTypeIdDict;
begin
	self.allAvailableGridAreas.clear;
	
	app.cmsBeginLoad(ls);
	theTAs := self.myTerminal.allTerminalAreasByTypeId;
	iter01 := theTAs.createIterator();

	theTAs.startKeyGeq(TA_TYPE_RTG, null, iter01);
	while iter01.next(terminalArea) do
		if iter01.getCurrentKey(1).Integer = TA_TYPE_RTG then
			self.allAvailableGridAreas.add(terminalArea);
		else
			break;
		endif;
	endwhile;
	
	//epr par 21115 9/10/09
	theTAs.startKeyGeq(TA_TYPE_RMG, null, iter01);
	while iter01.next(terminalArea) do
		if iter01.getCurrentKey(1).Integer = TA_TYPE_RMG then
			self.allAvailableGridAreas.add(terminalArea);
		else
			break;
		endif;
	endwhile;
	
	
	theTAs.startKeyGeq(TA_TYPE_STRADDLE_STACK, null, iter01);
	while iter01.next(terminalArea) do
		if iter01.getCurrentKey(1).Integer = TA_TYPE_STRADDLE_STACK then
			self.allAvailableGridAreas.add(terminalArea);
		else
			break;
		endif;
	endwhile;

	theTAs.startKeyGeq(TA_TYPE_FORK_LIFT_STACK, null, iter01);
	while iter01.next(terminalArea) do
		if iter01.getCurrentKey(1).Integer = TA_TYPE_FORK_LIFT_STACK then
			self.allAvailableGridAreas.add(terminalArea);
		else
			break;
		endif;
	endwhile;
	self.msgSelectAreas.setAvailable(self.allAvailableGridAreas,true);

epilog
	delete iter01;
	app.cmsEndLoad(ls);
end;</source>
    </JadeMethod>
    <JadeMethod name="initSelectAreasGroupBox" id="30cdc037-b86f-43a0-be44-77b14559e457">
        <source>initSelectAreasGroupBox();
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theGroupBox : CMUI_MultiSelectGroupBox;
begin
	theGroupBox := self.msgSelectAreas;
	theGroupBox.caption := null;
	theGroupBox.distanceFromBottom 	:= 5;
	theGroupBox.distanceFromRight 		:= 5;
	theGroupBox.lockBottom 				:= false;
	theGroupBox.lockRight				:= false;
	theGroupBox.stretchHeight 			:= false;
	theGroupBox.stretchWidth 			:= true;
	theGroupBox.multiSelect 	:= ListBox.MultiSelect_Extended;
	theGroupBox.formDisplayEntryMethodName := YRD_GridAreasForm::displaySelectAreas.name;
	theGroupBox.availableHeading := app.getErrorString(Available_areas);
	theGroupBox.selectedHeading := app.getErrorString(Selected_areas);
	
	theGroupBox.myBaseForm	:= self;
	theGroupBox.mySelectedListBox.sorted := false;
	theGroupBox.cnEcResizeContents();
	theGroupBox.readOnly := false;

end;</source>
    </JadeMethod>
    <JadeMethod name="isMultiCargoDrop" id="2f709a18-1ab7-4040-8a59-1a87404c7fc7">
        <updating/>
        <source>isMultiCargoDrop(frame: YRD_ContainerDrawingFrame input; win: Window input; x: Real; y: Real ):Boolean updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 August 2011	cnwndl1	Initial creation	Par 28035

*/

vars

	theTIs : CM_TIArray;
	moveMode : Integer;

begin

	create theTIs transient;
	self.gridAreaMultiDragGetCargoMode( 	win,	//_win : Window input;
											moveMode,	//_moveMode : Integer output;
											theTIs	//_theTIs : CM_TIArray io
											);
	
	if moveMode &lt;&gt; QUEUE_MODE and moveMode &lt;&gt; PLANNING_MODE then
		return false;
	endif;
	
	if theTIs.size &gt; 1 then
		return self.doGridAreaDragDropMulti(frame,win,moveMode,theTIs,app.myDraggedTrackedItem,x,y);
	endif;
	
	return false;
		
epilog

	delete theTIs;

end;</source>
        <access>protected</access>
        <Parameter name="frame" type="YRD_ContainerDrawingFrame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="fb49e170-b16c-462d-b8e4-4d8a4f893d93">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 08/03/2011	cnwcs5	CCMS CPL 2027/PAR 27126 - add F6 short cut for pad edit
// 07/11/2012	cnwcs5	par 30475
vars
	ydc 	: YRD_ContainerDrawingController;
	anObj 	: Object;
	ta		: CM_TerminalAreaMaster;
begin

	if keyCode = CMUI_Key_F3 then
		if app.isControlKeyDown()
		and not app.isAltKeyDown()
		and not app.isShiftKeyDown()
		then
			self.showSelectorForm();
		else
			if self.frmSelectAreas.visible then
				self.showAreaSelectorEnable(false);
			else
				self.showAreaSelector();
			endif;
			return;
		endif;
	elseif keyCode = CMUI_Key_F6 then 
		// pad edit
		ydc := self.myCurrentDrawingController;
		
		if ydc &lt;&gt; null then
			ta := ydc.myTerminalArea;
			
			if ta.isTAArea then
				self.myAssistant.showLocationMaintenanceForm(ta.CM_TerminalArea, self.myMasterMenuAction, YRD_PadArea.AreaMode_Height,false, false); // cnwcs5 CCMS CPL 2017/PAR 27126
			endif;
		endif;
		return;
	elseif keyCode = CMUI_Key_Esc then
		delete app.myMoveController;
		app.myDraggedTrackedItem := null;
		app.isDragging := false;
		self.dragMode := self.DragMode_None;
		
		foreach anObj in self.allDrawingControllers do
			ydc := anObj.YRD_ContainerDrawingController;
			ydc.doCancelDrag();
		endforeach;
		
//		self.sdf01.clearUpDragDrop();
		return;
		
	elseif keyCode = J_key_LeftArrow then

		if self.canShiftLeft(self.myCurrentDrawingController.myTrackedItem) then
			if self.frmStatusLine.displayMode = DISPLAY_MODE_ACTUAL then
				self.doShiftContainer(self.myCurrentDrawingController.myTrackedItem, CMIF_MoveController.ShiftLeft);		
			elseif self.frmStatusLine.displayMode = DISPLAY_MODE_QUEUE then
				self.doShiftContainer(self.myCurrentDrawingController.myTrackedItem.allQueuedFutureMoves.first, CMIF_MoveController.ShiftLeft);		
			elseif self.frmStatusLine.displayMode = DISPLAY_MODE_PLAN then
				self.doShiftContainer(self.myCurrentDrawingController.myTrackedItem.allPlannedFutureMoves.first, CMIF_MoveController.ShiftLeft);		
			endif;
		endif;
	elseif keyCode = J_key_RightArrow then
		if self.canShiftRight(self.myCurrentDrawingController.myTrackedItem) then
			if self.frmStatusLine.displayMode = DISPLAY_MODE_ACTUAL then
				self.doShiftContainer(self.myCurrentDrawingController.myTrackedItem, CMIF_MoveController.ShiftRight);		
			elseif self.frmStatusLine.displayMode = DISPLAY_MODE_QUEUE then
				self.doShiftContainer(self.myCurrentDrawingController.myTrackedItem.allQueuedFutureMoves.first, CMIF_MoveController.ShiftRight);		
			elseif self.frmStatusLine.displayMode = DISPLAY_MODE_PLAN then
				self.doShiftContainer(self.myCurrentDrawingController.myTrackedItem.allPlannedFutureMoves.first, CMIF_MoveController.ShiftRight);		
			endif;
		endif;
	elseif keyCode = J_key_Delete then
		self.doDeleteKeyDown();
		
	endif;

	inheritMethod(keyCode, shift);
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="918e4fe8-9032-4d0c-a0d3-fe4bcfbf5d4b">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	regKeys : IntegerArray;
	key1, key2 : Point;
	x1,x2,y1,y2 : Integer;
begin

	inheritMethod();
	self.positionScaleX := 10;

	if self.xmlToolbar then
		self.mnuGridHideToolbar.caption := self.MNU_TOOLBAR_HIDE;
	else
		self.mnuGridHideToolbar.caption := self.MNU_TOOLBAR_SHOW;
	endif;
	self.mnuGridHideToolbar_click(self.mnuGridHideToolbar); 

	self.defYardBackColUnselected := self.myTerminal.getConfig(DefYardBackColUnselected).Integer;
	self.defYardBackColSelected := self.myTerminal.getConfig(DefYardBackColSelected).Integer;
	self.isSelectorCapable := true;

	
	self.picCargo.stretch := Picture.Stretch_Pic_Proportional;  // ### TFS 50421 22OCT2021 NAVAB1
		
	self.initSelectAreasGroupBox();
	self.initSelectAreasCollection();

	if self.allParameters.size &gt; 0 then
		self.setupFormFromParameters();
	elseif self.allTerminalAreas.size &gt; 0 then
		// have setup in initFromUserWindow
		self.msgSelectAreas.setSelected(self.allTerminalAreas);
		self.doBtnSelectAreaShow();
	else
		if self.myInitializeObject &lt;&gt; null then
			if self.myInitializeObject.isKindOf(CM_GridArea) then
				self.myCurrentTerminalArea := self.myInitializeObject;
				self.allTerminalAreas.add(self.myCurrentTerminalArea);
				self.setupFormFromAreaSelector();
				self.myCurrentDrawingController.setViewMode(0);
				self.btnViewVoyage.value := true;
				self.viewForMode(VIEW_VOYAGE);
				if self.myInitializeLocation &lt;&gt; null then
					if self.myInitializeTI &lt;&gt; null then
						self.myCurrentDrawingController.selectObject(self.myInitializeTI,null,false);
					else
						self.myCurrentDrawingController.selectObject(self.myInitializeLocation.allTrackedItems.first,null,false);
						
					endif;
					self.myCurrentDrawingController.setMyCurrentObject(self.myInitializeLocation);
					
					self.myCurrentDrawingController.allGridObjects.findObjectInDictGetXY(self.myInitializeLocation,key1, key2);
					self.myCurrentDrawingController.setForRedraw(self.myInitializeLocation,key1.x,key1.y,key2.x,key2.y);

					self.myCurrentDrawingController.drawCurrentObject(null);
					if self.myInitializeTI &lt;&gt; null then
						self.picCargo.picture := self.showCargoPicture(self.myInitializeTI);
						self.showExtraInfoForObject(self.myInitializeTI);
					endif;
					self.myCurrentDrawingController.doCentreOnSelectedObject();
				endif;
			endif;
			self.doSetCaption();
		else
			self.showAreaSelector(); 
		endif;
	endif;


	create regKeys transient;
	regKeys.add(CMUI_Key_Esc);
	self.addRegisteredKeys(regKeys);
	regKeys.add(J_key_Delete);
	self.addRegisteredKeys(regKeys);
	regKeys.add(J_key_LeftArrow);
	self.addRegisteredKeys(regKeys);
	regKeys.add(J_key_RightArrow);
	self.addRegisteredKeys(regKeys);

	self.dkbCargoPic.ignoreSkin := true;
	self.dkbCargoPic.backColor := White;
	self.picCargo.ignoreSkin := true;


epilog
	delete regKeys;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="minimisedStateBegin" id="ef13ee6f-c4fc-4e48-a08c-5fe09756be58">
        <updating/>
        <source>minimisedStateBegin() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	26 May 2006 By cnwth2

Purpose:	Called when the grid area for becomes minimized. Doesn't bother redrawing while minimsed
			but sets 'needsRefresh' if receives a note while minimised.
			This significantly reduces 'spikes' caused by many grid area forms open on many machines
			and thin client 'hanging' while unnecessary redrawing took place after some bulk action
			(like adding a labour restriction to an area)

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	obj					: Object;
begin
	if self.currentlyMinimised then
		return;
	endif;
	
	foreach obj in self.allDrawingControllers do
		obj.CMUI_GridDrawingController.minimisedStateBegin();
	endforeach;
	self.currentlyMinimised := true;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="minimisedStateEnd" id="a4cf2b78-66c9-434f-aa4a-3c018c88b9e1">
        <updating/>
        <source>minimisedStateEnd() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	26 May 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	obj			: Object;
begin
	if (not self.currentlyMinimised) then
		return;
	endif;

	foreach obj in self.allDrawingControllers do
		obj.CMUI_GridDrawingController.minimisedStateEnd();
	endforeach;
	self.currentlyMinimised := false;
	
	
end;</source>
        <access>protected</access>
    </JadeMethod>
