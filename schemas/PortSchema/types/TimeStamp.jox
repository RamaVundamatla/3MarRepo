        <Parameter name="_millisec" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setFromYYYYMMDDHHmm" id="d0636a50-901c-41f1-9694-f50c4f3d0558">
        <updating/>
        <source>setFromYYYYMMDDHHmm(_dtString : String) updating;
//
//14 Aug 2013	cnwrs1	Par 32148 for unitsets. Enable dateTime to be set from UN/EDIFACT DTM record
vars
	yyyy : Integer;
	mth : Integer;
	dd : Integer;
	hh : Integer;
	mm : Integer;
begin
	yyyy := _dtString[1:4].Integer;
	mth := _dtString[5:2].Integer;
	dd := _dtString[7:2].Integer;
	hh := _dtString[9:2].Integer;
	mm := _dtString[11:2].Integer;
	self.setDateTime(yyyy, mth, dd, hh, mm, 0, 0);
end;
</source>
        <Parameter name="_dtString" type="String"/>
    </JadeMethod>
    <JadeMethod name="shortCurrentLocaleFormat" id="5d94888b-edcc-4ae4-88f8-1e3175d65ea9">
        <source>shortCurrentLocaleFormat() : String;
// if format changes then you may have to change primitiveType String.convertToTimeStamp() as well
vars

begin
	
	//Make sure self is valid as time.currentLocaleFormat returns 12:00:00am (midnight) if not set	
	//if date is set and time is 00:00:00 then timeStamp is valid and therefore must be midnight
	//if Date is not set then self is invalid.
	
	if self.isValid then
		// Par 9488
		// DVB changed this to cast time as a string because time.currentLocaleFormat screws up sorting. Date is still using locale.
	    return date.shortFormatJMT() &amp; ' ' &amp; time.currentLocaleFormatJMT();
//	    return date.shortFormat &amp; ' ' &amp; time.String;//time.currentLocaleFormat;
//	  return date.shortFormat &amp; ' ' &amp; time.currentLocaleFormat;
	endif;
	return null;
		   
//    return time.currentLocaleFormat &amp; " " &amp; date.shortFormat;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="shortCurrentLocaleFormatSecs" id="c562f551-c3c2-4f6e-998c-c071299b2d62">
        <source>shortCurrentLocaleFormatSecs() : String;
// if format changes then you may have to change primitiveType String.convertToTimeStamp() as well
vars

begin
	
	//Make sure self is valid as time.currentLocaleFormat returns 12:00:00am (midnight) if not set	
	//if date is set and time is 00:00:00 then timeStamp is valid and therefore must be midnight
	//if Date is not set then self is invalid.
	
	if self.isValid then
		// Par 9488
		// DVB changed this to cast time as a string because time.currentLocaleFormat screws up sorting. Date is still using locale.
	    //par#12447 4/10/2006
		return date.shortFormatJMT() &amp; ' ' &amp; time.shortFormatJMTSecs();
//	    return date.shortFormat &amp; ' ' &amp; time.String;//time.currentLocaleFormat;
//	  return date.shortFormat &amp; ' ' &amp; time.currentLocaleFormat;
	endif;
	return null;
		   
//    return time.currentLocaleFormat &amp; " " &amp; date.shortFormat;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="shortCurrentLocaleSystemUTC" id="b1a85bcd-0f64-436e-87bb-423fb57a687b">
        <source>shortCurrentLocaleSystemUTC() : String;
/*

Purpose:			Return a string equivalent of a system timezone TimeStamp including
					the UTC offset

Parameters:			None

Return Value:		

Date		Who		Reason
10 May 2016	cnwns1	Initial creation

*/

vars
	returnVal		: String;
	utc				: TimeStamp;
	interval		: TimeStampInterval;
	time			: Time;
	millisecs		: Integer64;
	
begin
	if app.myTimeZoneHelper = null then
		return self.shortCurrentLocaleFormat();
	else
		returnVal := self.shortCurrentLocaleFormat();
		
		utc := app.myTimeZoneHelper.convertTimeToUtc(self, app.systemTimeZoneID);
		interval := self - utc;
		
		millisecs := interval.getMilliseconds();
		
		if millisecs = 0 then
			returnVal := returnVal &amp; " (UTC)";
		elseif millisecs &lt; 0 then
			returnVal := returnVal &amp; " (UTC-" &amp; millisecs.abs.Time.currentLocaleFormatJMT() &amp; ")";
		else
			returnVal := returnVal &amp; " (UTC+" &amp; millisecs.abs.Time.currentLocaleFormatJMT() &amp; ")";
		endif;
	endif;

	return returnVal;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="sqlFormat" id="087ed77f-1165-4405-a27c-480de407146f">
        <source>sqlFormat() : String;

vars

begin
	if self.isValid then
		return self.date.dataDumpFormat() &amp; " " &amp;
				self.time.formatAsHHmmSS();
	else
		return DataDumpDefaultNullValue;
	endif;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="subtractHoursAndMinutes" id="d268023a-4ddd-4dfc-bd19-25fdfaea5797">
        <source>subtractHoursAndMinutes(_hoursAndMinutes :Decimal):TimeStamp;
/*
Purpose	Add an offset (hours &amp; minutes) to the receiver. 1.50 = 1 hour and 30 minutes
		Used for voyage cutoffs
Date		Who		Reason
01/03/2012	cnwcs5	Initial creation - par 29158 EDI Booking Cutoff
*/
vars
	ts		:TimeStamp;
	minutes, hours	:Integer;
begin
	ts := self;
	
	if ts = null then
		return null;
	endif;
	
	if _hoursAndMinutes = null then
		return ts;
	endif;
	// hours is number b4 decimal point
	hours	:= _hoursAndMinutes.truncated;
	// minutes is after decimal point
	minutes := ((_hoursAndMinutes - hours) * 60).Integer;
	// add hours &amp; minutes to receiver
	ts		:= self.addHours(-1 * hours).addMinutes(-1 * minutes);
	// return result
	return ts;
epilog

end;</source>
        <Parameter name="_hoursAndMinutes" type="Decimal"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="subtractYears" id="1cd6df9e-f522-475a-a5d1-f2ef976f8c08">
        <source>subtractYears(_amountToAdd: Integer):TimeStamp;
// --------------------------------------------------------------------------------
// Created:		16 February 2010 by cnwjo3
//
// Purpose:		cnwjo3.  Make your code look a little nicer
//				
//
vars
	currentTimestamp	: TimeStamp;
	negativeValue		: Integer;
begin
	negativeValue := _amountToAdd*-1;
	currentTimestamp	:=	self;
	currentTimestamp.setDate(self.date.cnEcAddYears(negativeValue));
	
	return currentTimestamp;
end;</source>
        <Parameter name="_amountToAdd" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="systemToLocalTime" id="851d2ef5-1ef9-49f5-8848-56775599a121">
        <source>systemToLocalTime(_timeZoneID : String) : TimeStamp;
/*

Purpose:			Convert the receiver TimeStamp from the current System TimeZone to
					then passed in TimeZone

Parameters:			Windows ID of the required timezone

Return Value:		Receiver TimeStamp converted to the passed in TimeZone

Date		Who		Reason
11 Mar 2016	cnwkpd1	TFS 488 - Multi Timezone Support

*/

vars

begin
	if app.myTimeZoneHelper = null then
		return self;
	else
		return app.myTimeZoneHelper.convertTime(self, app.systemTimeZoneID, _timeZoneID);
	endif;

epilog

end;</source>
        <Parameter name="_timeZoneID" type="String"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="systemToLocalTimeUsingObject" id="7fffd24b-d65a-483b-b480-a52056a51697">
        <source>systemToLocalTimeUsingObject(_ownerObject : Object) : TimeStamp;
/*

Purpose:			Convert the receiver TimeStamp from the current System TimeZone to the TimeZone
					the passed in object belongs to

Parameters:			Object the receiver belongs to

Return Value:		Receiver TimeStamp converted to the TimeZone of the Terminal the passed in object belongs

Date		Who		Reason
11 Mar 2016	cnwkpd1	TFS 488 - Multi Timezone Support

*/

vars
	terminal		: CM_Terminal;
	
begin
	terminal := _ownerObject.getMyTerminal();
	
	if terminal = null then
		return self;
	else
		return self.systemToLocalTime(terminal.timeZoneID);
	endif;
	
epilog

end;</source>
        <Parameter name="_ownerObject" type="Object"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="systemToUTC" id="1511906b-4fd6-4dff-82ae-dea15459f6c2">
        <source>systemToUTC():TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 August 2016	cnwndl1	Initial creation	TFS 2277 / 2561

*/

vars

	returnVal		: TimeStamp;
	utc				: TimeStamp;
	
begin

	returnVal := self;
	
	if app.myTimeZoneHelper = null then
		//do nothing
		
	else
		utc := app.myTimeZoneHelper.convertTimeToUtc(self, app.systemTimeZoneID);	
		returnVal := utc;
		
	endif;

	return returnVal;
	
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="truncateTo10Millisecs" id="01b84102-86a2-48cf-879c-422abfc44078">
        <source>truncateTo10Millisecs() : TimeStamp;
// ---------------------------------------------------------------------------
// Created:     09 dec 2009 cnwrs1 par21887
// ---------------------------------------------------------------------------
vars
	timeToMinute: Time;
	timeStampToMinute : TimeStamp;

begin
	timeToMinute := self.time.truncateTo10Millisecs;
	timeStampToMinute.setDate(self.date);
	timeStampToMinute.setTime(timeToMinute);
	return timeStampToMinute;
end;
</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
