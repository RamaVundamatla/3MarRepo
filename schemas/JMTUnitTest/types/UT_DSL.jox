    <JadeMethod name="addCustomsAgent" id="c6a7f50e-2a8a-4ba9-a9e6-9e224d3b1846">
        <source>addCustomsAgent(_customsAgentId, _customsAgentDesc : String) : CM_CustomsAgent;

/*

Purpose:		Add a Customs Agent

Date			Who		Reason
06/12/2011		cnwmh5	Initial creation

*/

vars

	pxyCustomsAgent					: CM_CustomsAgent;
	customsAgent					: CM_CustomsAgent;
	
	notAvailableForEntry			: Boolean;
	
begin

	self.deleteCustomsAgent(_customsAgentId);

	if self.opts.includesKey("NotAvailableForEntry") then
		notAvailableForEntry := self.opts.bool("NotAvailableForEntry");
	endif;
	
	create pxyCustomsAgent transient;
	
	pxyCustomsAgent.setProxy(_customsAgentId,				// Id / Code
							 _customsAgentDesc,				// Description
						     notAvailableForEntry,			// not available for entry
							 null);							// Debtor
												  
	app.myTrxCA.trxCreateCustomsAgent(pxyCustomsAgent, customsAgent, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	return customsAgent;

epilog
	delete pxyCustomsAgent;
	
end;</source>
        <Parameter name="_customsAgentId" type="String"/>
        <Parameter name="_customsAgentDesc" type="String"/>
        <ReturnType type="CM_CustomsAgent"/>
    </JadeMethod>
    <JadeMethod name="addDamage" id="7415f203-ab20-405e-88ad-0ddda6a6565d">
        <source>addDamage(_ti :CM_TrackedItem; _code :String; _pos :String; _severity :CM_DamageSeverity; _qty :Integer; _remarks :String);
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
========================================================
11 June 2012		cnwcs5	 (Initial creation)
01/07/2022  navak20 ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
11 July 2022	navak20	TFS 53862 EUP - WMS - Damage Recording Extra Details
*/

vars
	pxyTI		:CM_TrackedItem;
	pxyDamage	:CM_DamageInstance;
	code		:CM_DamageDefinitionCode;
	pos			:CM_DamagePosition;
	party 		:CM_DamageParty;
	reason 		:CM_DamageReason;
	place		:CM_DamagePlace;
	terminal	:CM_Terminal;
	severity	:CM_DamageSeverity;	//11.07.2022 navak20 TFS 53862
	damStatus : Integer;
begin
	damStatus := DamageStatusDamaged; // ### TFS 55314 07NOV2022 NAVAB1
	if self.opts.includesKey("DamageStatus") then	 // ### TFS 55314 07NOV2022 NAVAB1
		damStatus := self.opts.int( "DamageStatus" ); // ### TFS 55314 07NOV2022 NAVAB1
	endif;

	beginLoad;
	pxyTI := _ti.pxyCreateUpdateProxy;
	endLoad;
	
	code 	:= app.myRoot.allDamageDefinitionCodes[_code];
	self.assertNotNullMsg (code, ' invalid damage code');
	
	pos		:= app.myRoot.allDamagePositionsByCode [_pos];
	self.assertNotNullMsg (pos, ' invalid damage position');
	
	terminal := self.getMyTerminal();
	if terminal &lt;&gt; null then
		party := terminal.allDamageParties.first;
		reason := terminal.allDamageReasons.first;
		place := terminal.allDamagePlaces.first;
		severity := _severity;	//11.07.2022 navak20 TFS 53862
		if severity = null then	//11.07.2022 navak20 TFS 53862
			severity := terminal.allDamageSeverities.first;	//11.07.2022 navak20 TFS 53862
		endif;	//11.07.2022 navak20 TFS 53862
	endif;
	
	create pxyDamage transient;
	pxyDamage.setProxy (pxyTI, null, code, pos, _remarks, true, _qty, severity, null,
							place, party, reason, null, null, app.actualTimeServer, damStatus, null, null	//July 1, 2022 navak20 TFS 53862   // ### TFS 55314 07NOV2022 NAVAB1 added damStatus
							);
	
	app.myTrxUA.trxUpdateTrackedItem (pxyTI, _remarks, TI_UPDMODE_NORMAL, null, app.myPassport);

	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
epilog
	endLoad;													// 19/04/2013 cnwmh5 #31457
	delete pxyTI;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_pos" type="String"/>
        <Parameter name="_severity" type="CM_DamageSeverity"/>
        <Parameter name="_qty" type="Integer"/>
        <Parameter name="_remarks" type="String"/>
    </JadeMethod>
    <JadeMethod name="addDamageDefinition" id="61286ebe-c307-45f9-875e-427025aa0a8f">
        <source>addDamageDefinition(_damageId, _damageDesc : String; _selectedCargoTypes : CM_ObjectSet) : CM_DamageDefinitionCode;

/*

Purpose:		Add a Damage

Date			Who		Reason
14/12/2011		cnwmh5	Initial creation

*/

vars

	pxyDamage						: CM_DamageDefinitionCode;
	damage							: CM_DamageDefinitionCode;
	
	gadArray						: StringArray;
	
	str								: String;
	
begin

	self.deleteDamage(_damageId);

	create pxyDamage transient;
			
	pxyDamage.setProxy(_damageId,				// Id / Code
					 _damageDesc,				// Description
					 _selectedCargoTypes,
					 null);		// selected cargo types
						  
	
	app.myTrxCA.trxCreateDamageDefCode(pxyDamage, damage, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	return damage;

epilog
	delete pxyDamage;
end;</source>
        <Parameter name="_damageId" type="String"/>
