    <JadeMethod name="updateStatusLine" id="e865eb50-dbe2-4dd7-a59f-4be0cda04d39">
        <source>updateStatusLine();
/*

Date		    Who			Reason
15 September 2010	cnwas3	  Initial creation

*/

vars
	caption : String;
	months 	: Integer;
begin
	
	caption := app.getErrorString(Results) &amp; " " &amp; self.monthPicker.getMonthName() &amp; " " &amp; self.monthPicker.getYearAsString();
	if self.txtMonths.text &lt;&gt; "" then
		months := self.txtMonths.text.asIntegerJMT();
		if months = 2 then			
			caption := caption &amp; " " &amp; app.getErrorString(And_for_the) &amp; " " &amp; app.getErrorString(Following_month);
		elseif months &gt; 2 then
			caption := caption &amp; " " &amp; app.getErrorString(And_for_the) &amp; " " &amp; (months-1).asStringJMT() &amp; " " &amp; app.getErrorString(Following_months);
		endif;		
	endif;
	self.statusLine.caption := caption;
	
epilog

end;</source>
    </JadeMethod>
</GUIClass>
