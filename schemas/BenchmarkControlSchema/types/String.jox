    <JadeMethod name="getFileName" id="30aefd95-ac8b-4b5c-993c-85931d849a38">
        <source>getFileName():String;

vars
	i,j:Integer;
	s,t:String;
begin
	s:=self&amp;" ";
	s.replaceChar("/", "\");
	i:=s.reversePos('\');
	if i = 0 then
		return null;
	else
		return s[i+1:end].trimBlanks;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextLine" id="30ec23a5-2ea0-4de7-a4cd-7979f5fec458">
        <source>getNextLine(pos:Integer io; line:String output):Boolean;
//	simulates File::readLine
//
//	example usage:
//
//	s := f.readString(f.fileLength);
//	f.close;
//	while s.getNextLine(pos, line) do
//		write "&lt;" &amp; line &amp; "&gt;";
//	endwhile;
//
//	set pos to 0 or 1 to start at the beginning
//	returns false if there is no more, and pos is set to self.length + 1
//	note: empty lines are ignored, and are not returned as empty strings
begin
	if pos = 0 then
		pos := 1;
	endif;
	
	if pos &gt; self.length then
		return false;
	endif;
	
	line := self.scanUntil(CrLf, pos);
	if pos = 0 then
		pos := self.length + 1;
		return true;
	endif;
	
	self.scanWhile(CrLf, pos);
	if pos = 0 then
		pos := self.length + 1;
	endif;
	return true;
end;
</source>
        <Parameter name="pos" type="Integer" usage="io"/>
        <Parameter name="line" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getThisToken" id="cbc773d1-adbf-4860-aaf9-55103345b8fd">
        <source>getThisToken(num:Integer):String;

vars
	i,j:Integer;
	s,t:String;
begin
	s:=self.trimLeft;
	j:=1;
	foreach i in 1 to num do
		if j &gt; s.length then return null; endif;
		t:=s.scanUntil(" ", j);
		if j = 0 then break; endif;
		j:=j+1;
	endforeach;
	return t;
end;
	</source>
        <Parameter name="num" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLTag" id="b002769a-1e51-4353-89de-e79f96e24ade">
        <source>getXMLTag(pos:Integer io):String;
//	gets the tag of the next element in self, starting at position pos
//	updates pos to the end of the opening tag
vars
	i,j:Integer;
	s,t,tag:String;
begin
	s:=self;
	i:=pos;
	i:=s.pos("&lt;", i);
	if i = 0 then  // no tag found
		pos:=s.length+1;
		return null;
	endif;
	i:=i+1;
	tag:=s.scanUntil(" &gt;", i);  // there may be a space after the tag name, and some attributes
	t:="&lt;/"&amp;tag&amp;"&gt;";
	i:=s.pos(t, i);
	if i = 0 then  // invalid XML
		pos:=s.length+1;
		return "invalid";
	endif;
	pos:=i+t.length;
	return tag;
end;
</source>
        <Parameter name="pos" type="Integer" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLValue" id="f6009c3e-a85f-4176-8d5d-5c941627e2a0">
        <source>getXMLValue(tag:String):String;
//	returns the value between &lt;tag and &lt;/tag&gt;
vars
	i,j:Integer;
	s,t,u:String;
begin
	s:=self;
	//i:=s.pos("&lt;"&amp;tag&amp;"&gt;", 1);
	i:=s.pos("&lt;"&amp;tag, 1);  // there may be a space after the tag name, and some attributes
	if i = 0 then
		return null;
	endif;
	i:=i+tag.length+2;
//	t:=s.scanUntil("&lt;/"&amp;tag&amp;"&gt;", i);
	j:=s.pos("&lt;/"&amp;tag&amp;"&gt;", i);
	if j = 0 then
		return null;
	else
		return s[i:j-i];
	endif;
end;</source>
        <Parameter name="tag" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hkGetQueueInfo" id="5a8d7ea8-cc75-4509-b8f9-73be0f57d558">
        <source>hkGetQueueInfo(queueType,minRelease1,minRelease2:String output; special:Boolean output);

vars
	buff,s,t,u:String;
	templates:StringArray;
	i,j:Integer;
begin
	i := self.pos("eptemplates", 1);
	if i = 0 then return; endif;
	
	i := i + 11;
	buff := self;  // enable seeing self in debugger
	self.scanUntil('"', i); i := i + 1;
	t := self.scanUntil('"', i);
	//write t.asXML(null)[2:end];
	queueType := t;  // temp - return something, even though it's not fully processed yet
	
	create templates transient;
	i:= 1;
	while i &lt; t.length do
		s := t.scanUntil(".", i); i := i + 1;
		if i = 1 then break; endif;
		templates.add(s);
		t.scanUntil(";", i); i := i + 1;
		if i = 1 then break; endif;
		if templates.size &gt; 5 then break; endif;  // protect against a runaway loop
	endwhile;
	write templates.display;
	foreach s in templates do
		if s[1:2] &lt;&gt; "bt" and s[1:2] &lt;&gt; "ge" then  // check for unusual ones
			write s;
		endif;
		if s[3:4].Integer &lt; 6305 or s[3:4].Integer &gt; 9800 then  // check for bogus release levels
			write s;
		endif;
		if s[1:2] = "eq" then
			if s[1:6] = "eq7012" then
				s[1:6] := "ge7012";
			elseif s[1:6] = "eq7005" or s[1:6] = "eq7006" then
				s[1:6] := "ge9999";  // deprecate these tests
			else
				special := true;  // skip 7051
			endif;
		endif;
	endforeach;
	
	t := templates.last;
	if t.contains("iis") then
		queueType := "iis";
	elseif t.contains("clientmachine") then
		queueType := "clientmachine";
	elseif t.contains("sql2008") then
		queueType := "sql2008";
	elseif t.contains("win2k8physical") then
		queueType := "win2k8physical";
	elseif t.contains("win2k8") then
		queueType := "win2k8";
	elseif t.contains("winge2k8physical") then
		queueType := "winge2k8physical";
	elseif t.contains("winge2k8") then
		queueType := "winge2k8";
	elseif t.contains("win2k12physical") then
		queueType := "win2k12physical";
	elseif t.contains("win2k12") then
		queueType := "win2k12";
	elseif t.contains("plantphysical") then
		queueType := "plantphysical";
	elseif t.contains("plant") then
		queueType := "plant";
	elseif t.contains("contops") then
		queueType := "contops";
	else
		queueType := "";
	endif;
	
epilog
	delete templates;
end;
</source>
        <Parameter name="queueType" type="String" usage="output"/>
        <Parameter name="minRelease1" type="String" usage="output"/>
        <Parameter name="minRelease2" type="String" usage="output"/>
        <Parameter name="special" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="jhpGetExePlanQueueInfo" id="254dacd1-eaed-45ba-86a7-ba3924fa8869">
        <source>jhpGetExePlanQueueInfo(queueType,minRelease1,minRelease2,special:String output);

vars
	tag,testconfig,executionplan,s,t,u:String;
	versions,queues:StringArray;
	i,j,pos,prevPos:Integer;
begin
	testconfig := self;  // enable seeing self in debugger
	//write testconfig[1:160];
	create versions transient;
	create queues transient;
	
	pos := 1;
	while true do
		pos := testconfig.pos("&lt;executionplan&gt;", pos);
		if pos = 0 then break; endif;
		
		prevPos := pos;
		tag := testconfig.getXMLTag(pos);
		executionplan := testconfig[prevPos:end].getXMLValue(tag);
		//write "tag=" &amp; tag &amp; Tab &amp; "executionplan=" &amp; executionplan; 
		versions.add(executionplan.getXMLValue("productversion"));
		queues.add(executionplan.getXMLValue("queue"));
		if versions.size &gt; 10 then break; endif;  // protect against a runaway loop
	endwhile;
	//write versions.display;
	//write queues.display;
	
	queueType := queues.last.jhpGetQueueType;
	
	versions.jhpGetMinReleases(minRelease1, minRelease2, special);
	
	if (testconfig.toLower.contains("&lt;encoding&gt;ansi").Integer
	+ testconfig.toLower.contains("&lt;encoding&gt;unicode").Integer
	+ testconfig.toLower.contains("&lt;encoding&gt;jade").Integer
	+ testconfig.toLower.contains("&lt;encoding&gt;all").Integer) = 1 
	and not testconfig.toLower.contains("&lt;encoding&gt;jade")
	and not testconfig.toLower.contains("&lt;encoding&gt;all") then
		if special &lt;&gt; null then write "double special:" &amp; testconfig; endif;
		special := testconfig.getXMLValue("encoding").toLower &amp; " only";  // either just ansi or just unicode
		//write "special:" &amp; special;
	endif;
epilog
	delete versions;
	delete queues;
end;
</source>
        <Parameter name="queueType" type="String" usage="output"/>
        <Parameter name="minRelease1" type="String" usage="output"/>
        <Parameter name="minRelease2" type="String" usage="output"/>
        <Parameter name="special" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="jhpGetQueueType" id="8dd480e2-ab41-47dc-9774-336eea090b20">
        <source>jhpGetQueueType():String;

vars
	t,queueType:String;
	i:Integer;
begin
	t := self.toLower;
	if 		t.contains("iis") then						queueType := "iis";
	elseif t.contains("clientmachine") then		queueType := "clientmachine";
	elseif t.contains("sql2008") then				queueType := "sql2008";
	elseif t.contains("win2k8") then				queueType := "generic";
	elseif t.contains("winge2k8") then			queueType := "generic";
	elseif t.contains("plant") then					queueType := "generic";
	elseif t.contains("contops") then				queueType := "contops";
	elseif t.contains("physical") then				queueType := "physical";
	elseif t.contains("cnwchcs") or t.contains("lowprioritys") then
		i := t.pos("s", 1);
		queueType := t[i:end];
		//write "check queue type " &amp; t;
	else
		//write "unmatched queue type " &amp; t;
		queueType := "generic";
	endif;
	
	return queueType;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jhpGetTemplateQueueInfo" id="8a90bba7-ae25-4cb8-a254-6ee651d6ace9">
        <source>jhpGetTemplateQueueInfo(queueType,minRelease1,minRelease2,special:String output);

vars
	testconfig,s,t,u:String;
	templates:StringArray;
	i,j:Integer;
begin
	testconfig := self;  // enable seeing self in debugger
	
	if testconfig.contains("eptemplates") and testconfig.contains("&lt;executionplan&gt;") then
		//write "warning: templates and executionplan, ignoring executionplan for ..." &amp; testconfig[84:40];
	endif;
	
	i := testconfig.pos("eptemplates", 1);
	if i = 0 then return; endif;
	
	i := i + 11;
	testconfig.scanUntil('"', i); i := i + 1;
	t := testconfig.scanUntil('"', i);
	//write t.asXML(null)[2:end];
	//queueType := t;  // temp - return something, even though it's not fully processed yet
	
	create templates transient;
	i:= 1;
	while i &lt; t.length do
		s := t.scanUntil(".", i); i := i + 1;
		if i = 1 then break; endif;
		templates.add(s);
		t.scanUntil(";", i); i := i + 1;
		if i = 1 then break; endif;
		if templates.size &gt; 5 then break; endif;  // protect against a runaway loop
	endwhile;
	//write templates.display;

	queueType := templates.last.jhpGetQueueType;
	
	templates.jhpGetMinReleases(minRelease1, minRelease2, special);
epilog
	delete templates;
end;
</source>
        <Parameter name="queueType" type="String" usage="output"/>
        <Parameter name="minRelease1" type="String" usage="output"/>
        <Parameter name="minRelease2" type="String" usage="output"/>
        <Parameter name="special" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="replace" id="3e004dd7-c25a-4f7b-bb38-bffa52f4b961">
        <source>replace(scanFor,replaceWith:String):String;

begin
	return self.cnEcFindReplace(scanFor,replaceWith,false);
end;</source>
        <Parameter name="scanFor" type="String"/>
        <Parameter name="replaceWith" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="rightAlign" id="62c8ecd7-d41b-4d53-885e-b7ff4cda49c5">
        <source>rightAlign(len:Integer):String;

vars
	s:String;
	i:Integer;
begin
	i:=len-self.length;
	if i&gt;0 then
		s[i]:=" ";
	endif;
	return s&amp;self;
end;</source>
        <Parameter name="len" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="serverNumber" id="216455a6-256e-4189-8279-98c54186d506">
        <source>serverNumber():Integer;

begin
	if self[1:7]='cnwchcs' and self.length &gt;= 8 then
		return self[8:end].Integer;
	else
		return 0;
	endif;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setXMLValue" id="f4db4212-bd32-4ae4-9273-d3c094d7b116">
        <updating/>
        <source>setXMLValue(tag,value:String) updating;

vars
	i,j:Integer;
	s,t,u:String;
begin
	s:=self;
	t:="&lt;"&amp;tag&amp;"&gt;";
	i:=s.pos(t, 1);
	i:=i+t.length;
//	t:=s.scanUntil("&lt;/"&amp;tag&amp;"&gt;", i);
	t:="&lt;/"&amp;tag&amp;"&gt;";
	j:=s.pos(t, i);
	self:=s[1:i-1]&amp;value&amp;s[j:end];
end;</source>
        <Parameter name="tag" type="String"/>
        <Parameter name="value" type="String"/>
    </JadeMethod>
    <JadeMethod name="withoutFileName" id="04a073a1-85fb-42ba-a863-f843e47b3e5b">
        <source>withoutFileName():String;

vars
	i,j:Integer;
	s,t:String;
begin
	s:=self&amp;" ";
	i:=s.reversePos('\');
	if i = 0 then
		return null;
	else
		return s[1:i-1];
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="zap" id="80603f44-eb1a-4645-9b34-005489652d8f">
        <source>zap(tok:String):String;

vars
	s,t:String;
	i,j:Integer;
begin
	s:=self;
	if tok[1] = "*" then
		if tok.length &lt; 2 then
			return s;
		endif;
		i:=s.pos(tok[2:end], 1);
		if i = 0 then
			return s;
		endif;
		j:=i+tok.length-1;
		if j &gt; s.length then
			return null;
		else
			return s[j:end];
		endif;
	else
		return s.replace(tok, "");
	endif;
end;
</source>
        <Parameter name="tok" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
</PrimType>
