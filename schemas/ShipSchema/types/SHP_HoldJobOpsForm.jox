    <JadeMethod name="doRefresh" id="c5b9c3a6-affa-4fcd-ad0d-d2e3648b7a4c">
        <updating/>
        <source>doRefresh() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 02/02/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
// 24/02/2024 	navcs2 		MTN-29368 EUP | Transaction Instrumentation - Voyage Discharge
// 14 Jan 2026 	navhl20 	Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
vars
	
begin
	// reload workpoints combo
	self.loadCombos();
	
	// reload job combo
	self.loadCurrentVoyage();
	
	// set job combo to current job
	if self.myCurrentJob &lt;&gt; null then
		self.cmbJob.listIndex := self.cmbJob.findObject(self.myCurrentJob);
		self.loadJobDetails(self.myCurrentJob);
	endif;
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="77696b91-ec50-4d7e-bf29-19db4ea1ffcb">
