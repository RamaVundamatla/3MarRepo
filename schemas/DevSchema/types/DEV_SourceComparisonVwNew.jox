    </JadeMethod>
    <JadeMethod name="setupForm" id="dd139c91-6a49-4a32-9343-e378fdc4a6a6">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 September 2022	navpw1	Initial creation

*/

vars

begin
	self.modalDialogResize();
	self.resetFirstChangeFlag();
	self.isBaseFormModal := true;
	
	self.frmQuery.zOrder(1); //+ cnwmd1 29/07/2009 - The zOrder has been changed in painter.
	
	self.usesQueryFrame := true;
	
	if self.usesQueryFrame then
		self.positionQueryFrame();
		self.initQueryFrame();
	else
		self.frmQuery.visible := false;
	endif;
	
	if self.isBaseFormModal then
		self.handleMenusForModalDisplay();
	endif;
	
	self.setCaption(self.caption);
	
	if not app.defaultMdi then
		self.centreWindow;
	endif;
	
	self.splHorizMain.width := self.clientWidth - 10;
	self.splHorizMain.height := self.clientHeight - 10;
	self.splHorizMain.height -= self.slStatus.height;
	
	self.splHorizMain.cnEcResizeContents();
	self.splCodeCompare.cnEcResizeContents(); //Resize our split container contents
	self.splData.cnEcResizeContents(); //Resize our split container contents
	self.splLeft.cnEcResizeContents(); //Resize our split container contents
	self.splRight.cnEcResizeContents(); //Resize our split container contents
	
	//self.splLeft.borderStyle := 0;
	//self.splRight.borderStyle := 0;
	//self.frmGlobalConstants.borderStyle := 0;
	//self.frmMissingMethods.borderStyle := 0;
	//self.frmClassData.borderStyle := 0;
	//self.frmDifferingMethods.borderStyle := 0;
	
	self.frmToolbar.alignContainer	:=	Frame.AlignContainer_Top; // this will make the dkcMain line up its top	
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.frmToolbar.priorityRight := true;
	self.showToolbar := true;
	
	// Disable search until a report is selected
	self.btnQuery.enabled := false;
	
	//reset Data
	self.resetData();
	
	// Select the first report by default
	if self.cmbSelectReport.listCount &gt; 0 then
		self.cmbSelectReport.setIndex(1);
		self.btnQuery.enabled := true;
	endif;
	
	//Check Merge Tools Available
	self.checkWinMergeAvailable();
	self.checkNppAvailable();
	
	/*
	*	Setup Jade Editor
	*	Loaded Source Jade Editor
	*/
	self.setupJadeEditor(self.jeLoaded);
	
	/*
	*	Setup Jade Editor
	*	Current Source Jade Editor
	*/
	self.setupJadeEditor(self.jeCurrent);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupJadeEditor" id="daf08838-9147-4e46-a23b-5bfeca415b7d">
        <updating/>
        <source>setupJadeEditor(_jadeEditor : JadeEditor io) protected, updating;
/*

Purpose:			Sets up a Jade Editor

Parameters:			_jadeEditor:	JadeEditor	The jade editor we are setting up

Return Value:		

Date		Who		Reason
17 December 2024	navpw1	Initial creation

*/

begin
	_jadeEditor.configureFor_Jade();
	_jadeEditor.initializeJadeEditor(false);
	//_jadeEditor.setCurrentSchema(currentSchema);	// enable class name highlighting
	
	_jadeEditor.tabWidth		:= 4;
	_jadeEditor.fontSize		:= 12;				// has no effect ...
	_jadeEditor.currentPosition := 17;
	_jadeEditor.viewLinenumbers := true;
	_jadeEditor.readOnly 		:= true;
	
	_jadeEditor.setNamedAttribute("caret.line.back.color", PaleGreen);
	_jadeEditor.setLinemarkAttributes(JadeTextEdit.MARKER_JAD_LINEMARK, JadeTextEdit.SC_MARK_BACKGROUND, 0, PalePink);
	
end;</source>
        <access>protected</access>
        <Parameter name="_jadeEditor" type="JadeEditor" usage="io"/>
    </JadeMethod>
</GUIClass>
