/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Apr 2017	cnwma1 TFS #3890:STWO - Add 'in transit' to Cargo allocations

*/

vars

begin
	if _yaData.allValues.isEmpty() then
		return true;
	endif;
	
	return _yaData.allValues.includes(self.myTrackedItem.getTransitStatus);

epilog

end;</source>
