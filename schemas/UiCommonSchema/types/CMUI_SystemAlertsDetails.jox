    <JadeMethod name="doSearch" id="b911a839-9e3e-4ea7-b99c-832b1accfdd9">
        <source>doSearch() protected;
// --------------------------------------------------------------------------------
// Created:		29 February 2008 by cnwdad1
//
// Purpose:		Searches the Alerts table for user-specified text, and highlights
//				each row in which the text is found.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableObj	: Table;
	rowStart	: Integer;
	rowCount	: Integer;
	rowPointer	: Integer;
	searchFor	: String;
	cellText	: String;
	colSearch	: Integer;
begin
	searchFor	:=	self.cnEcGetUserInput("Find Text", "Enter the text to search for:", null);
	
	if searchFor = null then
		return;
	endif;
	
	tableObj	:=	tblAlerts;
	rowStart	:=	tableObj.fixedRows + 1;
	rowCount	:=	tableObj.rows;
	tableObj.clearAllSelected();

	//cnwjo3 par 22493  Only want to fool around with these settings if looking at autoplan logging
	colSearch := 1;
	if self.caption = "Logging Details" then
		if tableObj.row = 1 then
			rowStart := tableObj.row;
		elseif tableObj.row + 1 &lt;= tableObj.rows then
			rowStart := tableObj.row + 1;
		endif;
		colSearch := 2;
	endif;	
	
	foreach rowPointer in rowStart to rowCount do
		cellText	:=	tableObj.getCellText(rowPointer, colSearch);
		
		if cellText.toLower().pos(searchFor.toLower(), 1) &gt; 0 then
			//tableObj.setCellSelected(rowPointer, 1, true); // no good as the table selectMode = SelectMode_CurrentRow //cnwrd1 par 23004 9.3.2010
			tableObj.row := rowPointer; //cnwrd1 par 23004 9.3.12010 select the row not the cell
			break; //cnwrd1 par 23004 9.3.12010 and stop when we find the first instance
		endif;
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
