    <JadeMethod name="getExtraInfo" id="42218d1b-7058-4448-a115-c19e4bebbcaf">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
06 January 2023	navcs2  ChangeRequest 56835:[56836] EUP - VAS Truck Work Order

*/

vars
	block   	: CM_DataContainerBlock;
	addStr  	: String;	
begin
	
	inheritMethod(_dataContainer);

	addStr := self.allVBSSlots.listString(Comma,CM_VehicleBookingTimeSlot::id.name);
	
	if addStr &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(ToDo_Vehicle_booking), DC_Label, 1, self.allVBSSlots.first);
		block.addNewItem(addStr, DC_Data, 1, self.allVBSSlots.first);
	endif;	
epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getMyDebtor" id="70a56d74-c548-431f-aa72-7d33ad97abdf">
        <source>getMyDebtor() : CM_Debtor;
/*
Purpose:			

Date		Who		Reason
23JUN2023	NAVAB1	 BUG 58790
*/
vars
	debtor : CM_Debtor;
	vbs : CM_VehicleBookingTimeSlot;
begin
	 // ### TFS CR 56814 TASK 56813 07JUL2023 NAVAB1
	if self.myDebtor &lt;&gt; null then
		return self.myDebtor;
	endif;

	vbs := self.allVBSSlots.first;
	if vbs = null then
		vbs := self.allVBSSlotsCompleted.first;
	endif;
	
	if vbs &lt;&gt; null then
		if vbs.myCarrier &lt;&gt; null then
			debtor := vbs.myCarrier.myDebtor;
		endif;
	endif;
	
	if debtor = null then
		debtor :=  self.myParent.getMyDebtor();
	endif;
	
	return debtor;
epilog

end;</source>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
