    <JadeMethod name="addToolbarControls" id="bf74b929-4443-41b9-87d8-c795bb3f8f02">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	toolbar : CMUI_Toolbar;
begin
	inheritMethod();
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Left);			

	toolbar.visible := true;
	toolbar.positionToolbarControls();
end;</source>
        <access>protected</access>
    </JadeMethod>
