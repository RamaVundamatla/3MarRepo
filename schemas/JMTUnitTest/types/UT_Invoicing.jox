    <JadeMethod name="tranMapLoadSnapShot02" id="1757aef6-4f17-4d95-ba4d-99ab2d3cca06">
        <source>tranMapLoadSnapShot02(_bank : CM_Bank) : CM_TranMapSSSummary;
/*
Purpose:			

Date		Who		Reason
04 April 2023	navab1	TFS BUG 57457
*/

vars
	fileContent : String;
	fileName : String;
	mapName : String;
	ssMap : CM_TranMapSSSummary;
	ssb	: CM_SnapShotServiceBroker;
	invoice : CM_Invoice;
	invAlloc : CM_YardAllocation;
	qRMap : CM_QuantityRangeMap;
	invLineDesc : CM_InvoiceLineDesc;
	bank: CM_Bank;
begin
	fileName := "TFS6759";
	mapName := "UT_TFS6759";
	
	bank := _bank;
	
	ssMap := bank.allSnapShotTranMaps[mapName];
	if ssMap &lt;&gt; null then
		ssb := ssMap.allSnapShotServiceBrokers.first();
		if ssb &lt;&gt; null then
			foreach invAlloc in ssb.allInvoiceAllocations do
				app.myTrxDA.trxDeleteInvoiceAllocation(invAlloc.CM_InvoiceAllocation, qRMap, invLineDesc, app.myPassport);
			endforeach;
		endif;
		if self.myBank.myCurrentTranMapSnapShot &lt;&gt; ssMap then
			app.myTrxDA.trxDeleteInvoiceTranMapSS(ssMap, app.myPassport);
		endif;
	endif;
		
fileContent := 'TranMap Type,TranMap Name,Invoice Map,Empty Pool Party,Debtor Type,Quantity Attribute,Default,Range,Invoice Line' &amp; CrLf &amp;
'Snapshot Summary,UT_OnsiteContMap,UT_OnsiteCont,"(Default)",SDT0 (Empty Pool Party),SUM (Number of TEUs Integer),true,0 to 99999999,Empty Pool Party Release Road' &amp; CrLf &amp;
'Snapshot Summary,UT_OnsiteContMap,UT_OnsiteCont,"(Default)",SDT0 (Empty Pool Party),SUM (Number of TEUs Integer),true,0 to 99999999,Empty Pool Party Release Ship' &amp; CrLf;



	//load up the snapshot transaction map
	self.transactionMapLoad(fileContent, fileName);


	self.assertNoTrxErrorsOrWarnings(); 
	
	ssMap := bank.allSnapShotTranMaps[mapName];
	self.assertTrueMsg( ssMap &lt;&gt; null, "Snapshot Map not found" );
	
	//make the map active
	app.myTrxUA.trxUpdateBankTMSActive(ssMap,app.myPassport);
	self.assertTrueMsg( app.myPassport.trxCompletedOK, "Snapshot Map not made active - " &amp; app.myPassport.getAllErrorsWarningsAsString );

	return ssMap;
epilog

end;

</source>
        <Parameter name="_bank" type="CM_Bank"/>
        <ReturnType type="CM_TranMapSSSummary"/>
    </JadeMethod>
    <JadeMethod name="tranMapLoadSplitMerge" id="9d986f26-c243-402e-af86-e376558f2c9c">
        <source>tranMapLoadSplitMerge();
// cnwjre1 
// set up tran map with cargo weight invoice line types
vars
	fileContent : String;
	fileName	: String;
	mapName		: String;
	bank		: CM_Bank;
	cargoMap	: CM_TranMap;

begin
	fileName := "SplitMerge";
	mapName := "UT_SplitMerge";
	fileContent := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,RORO?,Is 45?,Is 30?,Is 53?,Is Child?' &amp; CrLf &amp;
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),VOID' &amp; CrLf &amp;
						'Cargo,'&amp;mapName&amp;',UTREBAR,(Default),(Default),Import,(Default),(Default),Received - Ship,,(Default),CCT04 Cargo Weight Kilos ›,00 to MAX,UT_LineTypeWeight1,,,,,,,,,,' &amp; CrLf &amp;
						'Cargo,'&amp;mapName&amp;',UTREBAR,(Default),(Default),Import,(Default),(Default),Received - Ship,,(Default),CCT04 Cargo Weight Kilos ›,00 to MAX,UT_ILT9,,,,,,,,,,' &amp; CrLf &amp;
						'Cargo,'&amp;mapName&amp;',UTREBAR,(Default),(Default),Import,(Default),(Default),Storage,,(Default),CCT04 Cargo Weight Kilos ›,00 to MAX,UT_LineTypeWeight1,,,,,,,,,,';

	
	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();
	
	bank := app.myPassport.myTerminal.getDefaultCompanyBank();
	cargoMap := bank.myCurrentTranMapCargo[mapName];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");

	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);

epilog

end;
</source>
