    <JadeMethod name="createActivityHistory" id="76fee9bb-432d-4739-80b4-2b86eca00e88">
        <source>createActivityHistory(_type: Integer; _terminal: CM_Terminal; _objectForExtraDetail: Object; _description: String; _insideTransaction: Boolean; _temp: Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
20 September 2019	jlgndl1	Initial creation	TFS 46655
23 August 2024		navpw1	Removed truncation to 80 chars as this is handled by the framework and automatically puts it in the extra data array
*/

vars

