    <JadeMethod name="canActionTask" id="a1672835-7974-458e-85ca-58df9ea6837d">
        <source>canActionTask(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2018	jlgdap1	Initial creation TFS 38560 PEL1 Voyage Work Orders
16 Mar 2023 navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task

*/

vars
	parent : CM_WorkOrderVoyage;
begin
	parent:= self.getMyParent.CM_WorkOrderVoyage;
	
	if parent.taskStatus = WO_STATUS_COMPLETE then
		return false;
	endif;
		
	if parent.taskStatus = WO_STATUS_PENDING_CANCEL then
		return false;
	endif;
	
	if parent.taskStatus = WO_STATUS_PENDING_HOLD then
		return false;
	endif;
	
	if parent.taskStatus = WO_STATUS_HELD then
		return false;
	endif;	
	
	if parent.taskStatus = WO_STATUS_CANCELLED then
		return false;
	endif;
	
	if not parent.hasBeenApproved then
		return false;
	endif;
	
	if self.isComplete then
		return false;
	endif;
	
	return true;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canCancel" id="09408a5d-4ac3-4d25-911a-2ba0978e4046">
        <source>canCancel() :Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 August 2018	jlger1	Initial creation

*/

vars
	parent : CM_WorkOrderVoyage;
begin
	if self.getMyParent &lt;&gt;null then
		return not ( self.getMyParent.taskStatus = WO_STATUS_COMPLETE
		or  self.getMyParent.taskStatus = WO_STATUS_PARTCOMPLETE);
		
	endif;

	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createWorkOrderTransaction" id="c991bfba-cfb2-4c37-8d0a-576fcf60fb74">
        <updating/>
        <source>createWorkOrderTransaction(_transType : Integer) updating;
/*
Purpose:		TFS 39237	
Date			Who			Reason
JUNE 2018		CNWAB1		Initial creation
23 Oct 2024 	navlw1 		JIRA-33107: Invoice Logging Use Levels
*/

vars
	classToCreate : Class;
	woTrans : CM_WOTransaction;
	term : CM_Terminal;
	
	chargetran : Boolean;
begin

	// TFS 42161
	term := self.getMyTerminal();
	if term &lt;&gt; null then
	
		chargetran := term.getConfig(InvWOVoyageTranOnAction).Boolean;
		if not chargetran then
			app.invLog("Terminal configuration 'Work Order Voyage Transaction Charge on Actioning' is false. Work order transaction will not be charged.", LogTRACE.String);
		endif;
	endif;

	classToCreate := self.getClassForTransType(_transType);
	create woTrans as classToCreate persistent;
	woTrans.setBaseAttributes(app.serverTimestampAtTrxStart, self.getMyParent, _transType, self.getMyTerminal()); // TFS 39237 - terminal
	woTrans.setNoCharge(not chargetran); // TFS 42161
	woTrans.createCharge();
epilog
	
end;</source>
        <Parameter name="_transType" type="Integer"/>
    </JadeMethod>
