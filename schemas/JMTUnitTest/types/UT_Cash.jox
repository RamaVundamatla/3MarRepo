    <JadeMethod name="createBOLCashCargo" id="2931ab66-d083-4761-9e59-270f21e59c16">
        <updating/>
        <source>createBOLCashCargo(_terminalId : String; _voyage : CM_Voyage; _containers : CM_TISet input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     17/02/2015	create on-site cargo directly
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

constants
	BlockStack = "UTBOLBS2";
vars
	terminalId,
	id			: String;
	bs: CM_BlockStack;
	packTIs	: CM_TIArray;
	wh: CM_IrregularBlockArea;
	cargoType: CM_CargoType;
	product	: CM_Product;
	location: CM_LocationsController;
	voy : CM_Voyage;
	terminal	: CM_Terminal;
	parent : CM_TrackedItem;
	child1,
	child2,
	child3,
	child4	: CM_TrackedItem;

begin
	voy := _voyage;

	terminalId := _terminalId;
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminalId);
	terminal := self.getTerminal();

	bs:= self.getTerminalArea(BlockStack).CM_BlockStack;
	if bs &lt;&gt; null then
		self.deleteInvoiceLines(bs.myLocationsController);
	endif;
	deleteTerminalArea(BlockStack);
	bs:= addBlockStack(BlockStack, 100, null);

	// scenario 1 - 1 FCL container with 4 children, one BOL
	self.createBOLCargoScenario1(terminalId, voy, _containers);

	// scenario 2 - 1 FCL container with 4 children, 2 BOLs
	self.createBOLCargoScenario2a(terminalId, voy, _containers);

	self.createBOLCargoScenario3(terminalId, voy, _containers);
	self.createBOLCargoScenario4(terminalId, voy, _containers);
	self.createBOLCargoScenario5(terminalId, voy, _containers);
	self.createBOLCargoScenario6(terminalId, voy, _containers);
	self.createBOLCargoScenario7(terminalId, voy, _containers);
	
epilog
	delete packTIs;
end;</source>
        <access>protected</access>
