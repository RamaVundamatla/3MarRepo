    <JadeMethod name="doResize" id="e88e98ac-586b-4cb9-995e-097cd17f52f5">
        <source>doResize();

/*
Date			Who		Reason
05 August 2016	cnwar2	Initial creation

*/
vars

begin
	// adjust folder height and width relative to new form size
	self.folder1.height := self.height - 49;
	self.folder1.width  := self.width - 26;
	
	
	// Current tab
	// -------------------------------------------
	// adjust kpi box position (top,left) relative to folder
	self.frame1.top  := self.folder1.height - self.frame1.height - 37;
	self.frame1.left := self.folder1.width - self.frame1.width - 15;
	
	// adjust remarks box width and position (top) relative to kpi box
	self.txtRemarks.top	  := self.frame1.top;
	self.txtRemarks.width := self.frame1.left - 26;
	
	// adjust history box height and position (left) relative to kpi box
	self.tblHistory.height := self.frame1.top - 78;
	self.tblHistory.left   := self.frame1.left;
	
	// adjust main table height and width based on remarks box, history box height and width
	self.tblContacts.height := self.tblHistory.height;
	self.tblContacts.width	:= self.txtRemarks.width;
	
	// adjust button and label positions (top,left) relative to corresponding tables
	self.btnRemarks.top 	 := self.txtRemarks.top + self.txtRemarks.height + 7;
	self.lblRemarks.top 	 := self.txtRemarks.top - 25;
	self.btnRemarks.left	 := self.txtRemarks.left + self.txtRemarks.width - self.btnRemarks.width;
	self.btnLog.top			 := self.tblHistory.top + self.tblHistory.height + 7;
	self.btnLog.left	 	 := self.tblHistory.left + self.tblHistory.width - self.btnLog.width;
	self.lblItemHistory.left := self.tblHistory.left;
	self.btnNew.top			 := self.tblContacts.top + self.tblContacts.height + 7;
	self.btnNew.left		 := self.tblContacts.left + self.tblContacts.width - self.btnNew.width;
	self.btnFixup.left		 := self.tblHistory.left + 360;
	
	if self.tblContacts.width &gt; 1039 then
		self.tblContacts.accessColumn(1).width := ((60/1039)*self.tblContacts.width).rounded();
		self.tblContacts.accessColumn(2).width := ((40/1039)*self.tblContacts.width).rounded();
		self.tblContacts.accessColumn(3).width := ((65/1039)*self.tblContacts.width).rounded();
		self.tblContacts.accessColumn(5).width := ((120/1039)*self.tblContacts.width).rounded();
		self.tblContacts.accessColumn(6).width := ((65/1039)*self.tblContacts.width).rounded();
		self.tblContacts.accessColumn(7).width := ((65/1039)*self.tblContacts.width).rounded();
		self.tblContacts.accessColumn(8).width := ((160/1039)*self.tblContacts.width).rounded();
		self.tblContacts.accessColumn(9).width := ((120/1039)*self.tblContacts.width).rounded();
		self.tblContacts.accessColumn(10).width := ((80/1039)*self.tblContacts.width).rounded();
		self.tblContacts.accessColumn(11).width := ((45/1039)*self.tblContacts.width).rounded();
		self.tblContacts.accessColumn(12).width := ((45/1039)*self.tblContacts.width).rounded();
		self.tblContacts.accessColumn(13).width := ((45/1039)*self.tblContacts.width).rounded();
	endif;
	self.cmbRelease.left  := self.tblContacts.left + self.tblContacts.accessColumn(1).width + self.tblContacts.accessColumn(2).width + self.tblContacts.accessColumn(3).width + self.tblContacts.accessColumn(4).width + self.tblContacts.accessColumn(5).width;
	self.cmbOwner.left 	  := self.cmbRelease.left + self.tblContacts.accessColumn(6).width;
	self.cmbState.left 	  := self.cmbOwner.left + self.tblContacts.accessColumn(7).width + self.tblContacts.accessColumn(8).width;
	self.cmbKPI.left 	  := self.cmbState.left + self.tblContacts.accessColumn(9).width + self.tblContacts.accessColumn(10).width;
	self.cmbRelease.width := self.tblContacts.accessColumn(6).width;
	self.cmbOwner.width   := self.tblContacts.accessColumn(7).width;
	self.cmbState.width   := self.tblContacts.accessColumn(9).width;
	self.cmbKPI.width     := self.tblContacts.accessColumn(11).width + self.tblContacts.accessColumn(12).width + self.tblContacts.accessColumn(13).width;
	
	
	// Closed tab
	// -------------------------------------------
	// adjust kpi box position (top,left) relative to folder
	self.frame1_2.top  := self.folder1.height - self.frame1_2.height - 37;
	self.frame1_2.left := self.folder1.width - self.frame1_2.width - 15;
	
	// adjust remarks box width and position (top) relative to kpi box
	self.txtRemarksClosed.top	:= self.frame1_2.top + 35;
	self.txtRemarksClosed.width := self.frame1_2.left - 26;
	
	// adjust history box height and position (left) relative to kpi box
	self.tblClosedHistory.height := self.frame1_2.top - 68;
	self.tblClosedHistory.left   := self.frame1_2.left;
	
	// adjust main table height and width based on remarks box, history box height and width
	self.tblClosed.height 	:= self.tblClosedHistory.height + 37;
	self.tblClosed.width	:= self.txtRemarksClosed.width;
	
	// adjust button and label positions (top,left) relative to corresponding tables
	self.lblRemarksClosed.top 		:= self.txtRemarksClosed.top - 25;
	self.btnLogClosed.top			:= self.tblClosedHistory.top + self.tblClosedHistory.height + 7;
	self.btnLogClosed.left	 		:= self.tblClosedHistory.left + self.tblClosedHistory.width - self.btnLogClosed.width;
	self.lblItemHistoryClosed.left 	:= self.tblClosedHistory.left;

	if self.tblContacts.width &gt; 1039 then
		self.tblClosed.accessColumn(1).width := ((60/1039)*self.tblContacts.width).rounded();
		self.tblClosed.accessColumn(2).width := ((40/1039)*self.tblContacts.width).rounded();
		self.tblClosed.accessColumn(3).width := ((65/1039)*self.tblContacts.width).rounded();
		self.tblClosed.accessColumn(5).width := ((120/1039)*self.tblContacts.width).rounded();
		self.tblClosed.accessColumn(6).width := ((65/1039)*self.tblContacts.width).rounded();
		self.tblClosed.accessColumn(7).width := ((65/1039)*self.tblContacts.width).rounded();
		self.tblClosed.accessColumn(10).width := ((80/1039)*self.tblContacts.width).rounded();
		self.tblClosed.accessColumn(11).width := ((45/1039)*self.tblContacts.width).rounded();
		self.tblClosed.accessColumn(12).width := ((45/1039)*self.tblContacts.width).rounded();
		self.tblClosed.accessColumn(13).width := ((45/1039)*self.tblContacts.width).rounded();
	endif;
	self.cmbReleaseClosed.left  := self.tblClosed.left + self.tblClosed.accessColumn(1).width + self.tblClosed.accessColumn(2).width + self.tblClosed.accessColumn(3).width + self.tblClosed.accessColumn(4).width + self.tblClosed.accessColumn(5).width;
	self.cmbOwnerClosed.left 	:= self.cmbReleaseClosed.left + self.tblClosed.accessColumn(6).width;
	self.cmbKPIClosed.left 		:= self.cmbOwnerClosed.left + self.tblClosed.accessColumn(7).width + self.tblClosed.accessColumn(8).width + self.tblClosed.accessColumn(9).width + self.tblClosed.accessColumn(10).width;
	self.cmbReleaseClosed.width := self.tblClosed.accessColumn(6).width;
	self.cmbOwnerClosed.width   := self.tblClosed.accessColumn(7).width;
	self.cmbKPIClosed.width   	:= self.tblClosed.accessColumn(11).width + self.tblClosed.accessColumn(12).width + self.tblClosed.accessColumn(13).width;
	
	
	// Timezones tab
	// -------------------------------------------
	self.tblTimezones.width := self.width - 522;
	self.tblTimezones2.left := self.tblTimezones.left + self.tblTimezones.width + 19;
	self.tblDST.width	 	:= self.tblTimezones.width;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="7e4dc2c8-6c88-4d99-b877-a9c50c61c8c4">
        <updating/>
        <source>doSave() updating;

/*
Date			Who		Reason
08 July 2016	cnwar2	Initial creation

*/
vars
	i : Integer;
	parsys, tfs, customer, description, owner, opened, topic, release, errorStr : String;
	contact : DEV_SupportContact;
	state	: DEV_SupportState;
	
begin
	// create new contact from details in last table row, set row to readonly
	
	parsys 		:= self.tblContacts.accessCell(tblContacts.rows,1).text;
	tfs			:= self.tblContacts.accessCell(tblContacts.rows,2).text;
	customer	:= self.tblContacts.accessCell(tblContacts.rows,3).text;
	description	:= self.tblContacts.accessCell(tblContacts.rows,4).text;
	topic		:= self.tblContacts.accessCell(tblContacts.rows,5).text;
	release		:= self.tblContacts.accessCell(tblContacts.rows,6).text;
	owner		:= self.tblContacts.accessCell(tblContacts.rows,7).text;
	opened		:= self.tblContacts.accessCell(tblContacts.rows,8).text;
	
	beginTransaction;
	create contact persistent;
	create state persistent;
	contact.number 			:= parsys.Integer;
	contact.tfsNumber 		:= tfs.Integer;
	contact.customer		:= customer;
	contact.description		:= description;
	contact.topic			:= owner;
	contact.releaseOpened	:= release;
	contact.owner			:= owner;
	contact.openedTS		:= opened.TimeStamp;
	contact.myRoot			:= DEV_SupportRoot.firstInstance;
	contact.myTimezone		:= self.getTimezoneForCust(customer);
	
	state.type				:= "Active Support";
	state.startTS			:= opened.TimeStamp;
	state.myContact			:= contact;
	commitTransaction;
	
	
	self.loadTables();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveRemarks" id="4a2c8980-eedd-4c8b-aa1c-a5f08887a3c3">
        <source>doSaveRemarks();

/*
Date			Who		Reason
14 July 2016	cnwar2	Initial creation

*/
vars

begin
	if self.myCurrentContact = null then
		return;
	endif;
	
	beginTransaction;
	self.myCurrentContact.remarks := self.txtRemarks.text;
	commitTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="getReleasePatched" id="eda741e6-7bf2-46b0-9a76-ab29a2a834c5">
        <source>getReleasePatched(_closed : String): String;

/*
Date			Who		Reason
09 August 2016	cnwar2	Initial creation

*/
vars
	date : Date;
	
begin
	/* 	Update from https://wiki.cnw.co.nz/JMTReleaseSchedule
	
		Release		Cut			Released
	 	8.4.2.020	26/11/2015	07/12/2015
		8.4.2.030	17/12/2015	05/01/2016
		8.4.2.040	21/01/2016	01/02/2016
		8.4.2.050	25/02/2016	07/03/2016
		8.4.2.060	23/03/2016	04/04/2016
		8.4.2.070	21/04/2016	02/05/2016
		8.4.2.080	26/05/2016	07/06/2016
		8.4.2.090	23/06/2016	04/07/2016
		8.4.2.100	21/07/2016	01/08/2016
		8.4.2.110	25/08/2016	05/09/2016
		8.4.2.120	22/09/2016	03/10/2016
		8.5.1.000	27/10/2016?	07/11/2016
	*/
	
	date := _closed.TimeStamp.date;

	if date &lt;= '26/11/2015'.Date then
		return "8.4.2.020";
	elseif date &lt;= '17/12/2015'.Date then
		return "8.4.2.030";
	elseif date &lt;= '21/01/2016'.Date then
		return "8.4.2.040";
	elseif date &lt;= '25/02/2016'.Date then
		return "8.4.2.050";
	elseif date &lt;= '23/03/2016'.Date then
		return "8.4.2.060";
	elseif date &lt;= '21/04/2016'.Date then
		return "8.4.2.070";
	elseif date &lt;= '26/05/2016'.Date then
		return "8.4.2.080";
	elseif date &lt;= '23/06/2016'.Date then
		return "8.4.2.090";
	elseif date &lt;= '21/07/2016'.Date then
		return "8.4.2.100";
	elseif date &lt;= '25/08/2016'.Date then
		return "8.4.2.110";
	elseif date &lt;= '22/09/2016'.Date then
		return "8.4.2.120";
	elseif date &lt;= '27/10/2016'.Date then
		return "8.5.1.000";
	else
		return "";
	endif;
	
end;</source>
        <Parameter name="_closed" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getReleaseReleased" id="237b9b34-fae3-44c0-8c10-0096ce96fe19">
        <source>getReleaseReleased(_release : String): String;

/*
Date			Who		Reason
09 August 2016	cnwar2	Initial creation

*/
vars

begin
	/* 	Update from https://wiki.cnw.co.nz/JMTReleaseSchedule
	
		Release		Cut			Released
	 	8.4.2.020	26/11/2015	07/12/2015
		8.4.2.030	17/12/2015	05/01/2016
		8.4.2.040	21/01/2016	01/02/2016
		8.4.2.050	25/02/2016	07/03/2016
		8.4.2.060	23/03/2016	04/04/2016
		8.4.2.070	21/04/2016	02/05/2016
		8.4.2.080	26/05/2016	07/06/2016
		8.4.2.090	23/06/2016	04/07/2016
		8.4.2.100	21/07/2016	01/08/2016
		8.4.2.110	25/08/2016	05/09/2016
		8.4.2.120	22/09/2016	03/10/2016
		8.5.1.000	27/10/2016?	07/11/2016
	*/
	
	if _release = "8.4.2.020" then
		return "07/12/2015";
	elseif _release = "8.4.2.030" then
		return "05/01/2016";
	elseif _release = "8.4.2.040" then
		return "01/02/2016";
	elseif _release = "8.4.2.050" then
		return "07/03/2016";
	elseif _release = "8.4.2.060" then
		return "04/04/2016";
	elseif _release = "8.4.2.070" then
		return "02/05/2016";
	elseif _release = "8.4.2.080" then
		return "07/06/2016";
	elseif _release = "8.4.2.090" then
		return "04/07/2016";
	elseif _release = "8.4.2.100" then
		return "01/08/2016";
	elseif _release = "8.4.2.110" then
		return "05/09/2016";
	elseif _release = "8.4.2.120" then
		return "03/10/2016";
	elseif _release = "8.5.1.000" then
		return "07/11/2016";
	else
		return "";
	endif;
	
end;</source>
        <Parameter name="_release" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTimezoneForCust" id="2e49d66a-f39d-47e0-8a57-ae370b3b7feb">
        <source>getTimezoneForCust(_cust : String): DEV_SupportTimezone;

/*
Date			Who		Reason
11 July 2016	cnwar2	Initial creation

*/
vars
	root 		: DEV_SupportRoot;
	timezone 	: DEV_SupportTimezone;
	
begin
	root := DEV_SupportRoot.firstInstance;
	
	foreach timezone in root.allTimezones do
		if timezone.customers.pos(_cust,1) &gt; 0 then
			return timezone;
		endif;
	endforeach;
	
	return null;
	
end;</source>
        <Parameter name="_cust" type="String"/>
        <ReturnType type="DEV_SupportTimezone"/>
    </JadeMethod>
    <JadeMethod name="initTables" id="56a3f6a8-e38d-44da-9cbb-92639358ba9f">
        <source>initTables();

/*
Date			Who		Reason
08 July 2016	cnwar2	Initial creation

*/
vars
	tz 			 : DEV_SupportTimezone;
	printerArray : CnStringArray;
	printerName  : String;
	i			 : Integer;
	date		 : Date;
	nextDSTStart,
	nextDSTEnd	 : String;
	ts			 : TimeStamp;
	
begin
	tblContacts.row  := 1;
	tblContacts.text := "PARSYS" &amp; Tab &amp; "TFS" &amp; Tab &amp; "Customer" &amp; Tab &amp; "Description" &amp; Tab &amp; "Topic" &amp; Tab &amp; "Release" &amp; Tab &amp; "Owner" &amp; Tab &amp; 
						"Opened" &amp; Tab &amp; "State" &amp; Tab &amp; "Time in State" &amp; Tab &amp; "KPI1" &amp; Tab &amp; "KPI2" &amp; Tab &amp; "KPI3";
						
	tblContacts.accessColumn(1).width := 60;
	tblContacts.accessColumn(1).fontBold := true;
	tblContacts.accessColumn(2).width := 40;
	tblContacts.accessColumn(3).width := 65;
	tblContacts.accessColumn(5).width := 120;
	tblContacts.accessColumn(6).width := 65;
	tblContacts.accessColumn(7).width := 65;
	tblContacts.accessColumn(8).width := 160;
	tblContacts.accessColumn(9).width := 120;
	tblContacts.accessColumn(10).width := 80;
	tblContacts.accessColumn(11).width := 45;
	tblContacts.accessColumn(12).width := 45;
	tblContacts.accessColumn(13).width := 45;
	tblContacts.accessColumn(11).fontBold := true;
	tblContacts.accessColumn(12).fontBold := true;
	tblContacts.accessColumn(13).fontBold := true;
	tblContacts.accessRow(1).fontBold := false;
	tblContacts.selectMode := Table.SelectMode_CurrentRow;
		
	//------------------------------------------------
	tblClosed.row  := 1;
	tblClosed.text := "PARSYS" &amp; Tab &amp; "TFS" &amp; Tab &amp; "Customer" &amp; Tab &amp; "Description" &amp; Tab &amp; "Topic" &amp; Tab &amp; "Release" &amp; Tab &amp; "Owner" &amp; Tab &amp; 
					  "Opened" &amp; Tab &amp; "State" &amp; Tab &amp; "Total Duration" &amp; Tab &amp; "KPI1" &amp; Tab &amp; "KPI2" &amp; Tab &amp; "KPI3";
						
	tblClosed.accessColumn(1).width := 60;
	tblClosed.accessColumn(1).fontBold := true;
	tblClosed.accessColumn(2).width := 40;
	tblClosed.accessColumn(3).width := 65;
	tblClosed.accessColumn(5).width := 120;
	tblClosed.accessColumn(6).width := 65;
	tblClosed.accessColumn(7).width := 65;
	tblClosed.accessColumn(10).width := 80;
	tblClosed.accessColumn(11).width := 45;
	tblClosed.accessColumn(12).width := 45;
	tblClosed.accessColumn(13).width := 45;
	tblClosed.accessColumn(11).fontBold := true;
	tblClosed.accessColumn(12).fontBold := true;
	tblClosed.accessColumn(13).fontBold := true;
	tblClosed.accessRow(1).fontBold := false;
	tblClosed.selectMode := Table.SelectMode_CurrentRow;
	
	//------------------------------------------------
	tblHistory.row  := 1;
	tblHistory.text := "State" &amp; Tab &amp; "Start" &amp; Tab &amp; "End" &amp; Tab &amp; "Duration";
	
	tblClosedHistory.row  := 1;
	tblClosedHistory.text := "State" &amp; Tab &amp; "Start" &amp; Tab &amp; "End" &amp; Tab &amp; "Duration";
	
	//------------------------------------------------
	tblTimezones.row  := 1;
	tblTimezones.text := "Name" &amp; Tab &amp; Tab &amp; Tab &amp; "Customers" &amp; Tab &amp; "Local Business Hours in NZT";
	tblTimezones.accessColumn(2).width := 60;
	tblTimezones.accessColumn(3).width := 60;
	tblTimezones.readOnly := true;
		
	tblTimezones2.selectMode := Table.SelectMode_CurrentRow;
	
	//------------------------------------------------
	cmbOwner.addItem("*ALL*");
	cmbOwner.addItem("Adam");
	cmbOwner.addItem("Reji");
	cmbOwner.addItem("Phil");
	cmbOwner.listIndex := 1;
	
	cmbOwnerClosed.addItem("*ALL*");
	cmbOwnerClosed.addItem("Adam");
	cmbOwnerClosed.addItem("Reji");
	cmbOwnerClosed.addItem("Phil");
	cmbOwnerClosed.listIndex := 1;
	
	cmbOwnerStats.addItem("*ALL*");
	cmbOwnerStats.addItem("Adam");
	cmbOwnerStats.addItem("Reji");
	cmbOwnerStats.listIndex := 1;
	
	cmbState.addItem("*ALL*");
	cmbState.addItem("*ALL ACTIVE*");
	cmbState.addItem("Active Support");
	cmbState.addItem("Active Development");
	cmbState.addItem("Pending Response");
	cmbState.listIndex := 1;
	
	cmbKPI.addItem("*ALL*");
	cmbKPI.addItem("*KPI Failed*");
	cmbKPI.addItem("*Nearing KPI Failure*");
	cmbKPI.listIndex := 1;
	
	cmbKPIClosed.addItem("*ALL*");
	cmbKPIClosed.addItem("*KPI Failed*");
	cmbKPIClosed.listIndex := 1;
	
	//------------------------------------------------
	cmbOwnerRpt.addItem("*ALL*");
	cmbOwnerRpt.addItem("Adam");
	cmbOwnerRpt.addItem("Reji");
	cmbOwnerRpt.listIndex := 1;
	
	cmbCustomerRpt.addItem('*ALL*');
	cmbCustomerRpt.addItem('ADP');
	cmbCustomerRpt.addItem('AST');
	cmbCustomerRpt.addItem('C3');
	cmbCustomerRpt.addItem('CIG');
	cmbCustomerRpt.addItem('CPL');
	cmbCustomerRpt.addItem('DPH');
	cmbCustomerRpt.addItem('DUQ');
	cmbCustomerRpt.addItem('GHPA');
	cmbCustomerRpt.addItem('GUQ');
	cmbCustomerRpt.addItem('HAT');
	cmbCustomerRpt.addItem('MSL');
	cmbCustomerRpt.addItem('PEN');
	cmbCustomerRpt.addItem('PNL');
	cmbCustomerRpt.addItem('POL');
	cmbCustomerRpt.addItem('PTL');
	cmbCustomerRpt.addItem('QNS');
	cmbCustomerRpt.addItem('RUW');
	cmbCustomerRpt.addItem('SPL');
	cmbCustomerRpt.addItem('STWR');
	cmbCustomerRpt.addItem('STWO');
	cmbCustomerRpt.listIndex := 1;
	
	cmbTimezone.addItem('*ALL*');
	foreach tz in self.myRoot.allTimezones do
		cmbTimezone.addItem(tz.name);
	endforeach;
	cmbTimezone.listIndex := 1;
	
	create printerArray transient;
	app.printer.getAllPrinters(printerArray);
	foreach printerName in printerArray do
		cmbPrinter.addItem(printerName);
	endforeach;
	cmbPrinter.listIndex := cmbPrinter.findStringExact(1, app.printer.getPrinterName());
	
	//------------------------------------------------
	ts := app.actualTimeServer();
		
	tblDST.row  := 1;
	tblDST.text := "Daylight Savings Time" &amp; Tab &amp; "Start DST" &amp; Tab &amp; "Next" &amp; Tab &amp; "End DST" &amp; Tab &amp; "Next";
	
	tblDST.row  := 3;
	date.setDate(30,9,ts.date.year);
	while date.dayName &lt;&gt; 'Sunday' do
		date := date - 1;
	endwhile;
	if date &lt; ts.date then
		date.setDate(date.day-1,date.month,date.year+1);
	endif;
	nextDSTStart := date.format("dd/MM/yyy");
	date.setDate(1,4,ts.date.year);
	while date.dayName &lt;&gt; 'Sunday' do
		date := date + 1;
	endwhile;
	if date &lt; ts.date then
		date.setDate(date.day-1,date.month,date.year+1);
	endif;
	nextDSTEnd := date.format("dd/MM/yyy");
	tblDST.text := "NZ" &amp; Tab &amp; "last Sunday in September (2am-&gt;3am)" &amp; Tab &amp; nextDSTStart &amp; Tab &amp; "first Sunday in April (3am-&gt;2am)" &amp; Tab &amp; nextDSTEnd;
	
	tblDST.row  := 4;
	date.setDate(31,3,ts.date.year);
	while date.dayName &lt;&gt; 'Sunday' do
		date := date - 1;
	endwhile;
	if date &lt; ts.date then
		date.setDate(date.day-1,date.month,date.year+1);
	endif;
	nextDSTStart := date.format("dd/MM/yyy");
	date.setDate(31,10,ts.date.year);
	while date.dayName &lt;&gt; 'Sunday' do
		date := date - 1;
	endwhile;
	if date &lt; ts.date then
		date.setDate(date.day-1,date.month,date.year+1);
	endif;
	nextDSTEnd := date.format("dd/MM/yyy");
	tblDST.text := "Italy, Netherlands" &amp; Tab &amp; "last Sunday in March (2am-&gt;3am)" &amp; Tab &amp; nextDSTStart &amp; Tab &amp; "last Sunday in October (3am-&gt;2am)" &amp; Tab &amp; nextDSTEnd;
	
	tblDST.row  := 5;
	date.setDate(1,3,ts.date.year);
	while date.dayName &lt;&gt; 'Sunday' do
		date := date + 1;
	endwhile;
	date := date + 1;
	while date.dayName &lt;&gt; 'Sunday' do
		date := date + 1;
	endwhile;
	if date &lt; ts.date then
		date.setDate(date.day-1,date.month,date.year+1);
	endif;
	nextDSTStart := date.format("dd/MM/yyy");
	date.setDate(1,11,ts.date.year);
	while date.dayName &lt;&gt; 'Sunday' do
		date := date + 1;
	endwhile;
	if date &lt; ts.date then
		date.setDate(date.day-1,date.month,date.year+1);
	endif;
	nextDSTEnd := date.format("dd/MM/yyy");
	tblDST.text := "USA" &amp; Tab &amp; "second Sunday in March (2am-&gt;3am)" &amp; Tab &amp; nextDSTStart &amp; Tab &amp; "first Sunday in November (2am-&gt;1am)" &amp; Tab &amp; nextDSTEnd;
	
	tblDST.row  := 6;
	date.setDate(1,4,ts.date.year);
	while date.dayName &lt;&gt; 'Sunday' do
		date := date + 1;
	endwhile;
	if date &lt; ts.date then
		date.setDate(date.day-1,date.month,date.year+1);
	endif;
	nextDSTStart := date.format("dd/MM/yyy");
	date.setDate(31,10,ts.date.year);
	while date.dayName &lt;&gt; 'Sunday' do
		date := date - 1;
	endwhile;
	if date &lt; ts.date then
		date.setDate(date.day-1,date.month,date.year+1);
	endif;
	nextDSTEnd := date.format("dd/MM/yyy");
	tblDST.text := "Mexico" &amp; Tab &amp; "first Sunday in April (2am-&gt;3am)" &amp; Tab &amp; nextDSTStart &amp; Tab &amp; "last Sunday in October (2am-&gt;1am)" &amp; Tab &amp; nextDSTEnd;
	
	tblDST.row  := 8;
	tblDST.text := "UAE, Qatar, Oman, Iraq, Ghana" &amp; Tab &amp; "Don't observe DST";
	
	tblDST.accessColumn(1).fontBold 	 := true;
	tblDST.accessCell(1,1).fontUnderline := true;
	foreach i in 3 to 6 do
		if tblDST.accessCell(i,3).text.Date &lt; tblDST.accessCell(i,5).text.Date then
			tblDST.accessCell(i,3).fontBold := true;
		else
			tblDST.accessCell(i,5).fontBold := true;
		endif;
	endforeach;
	tblDST.readOnly := true;
	
	date := app.actualTimeServer().date;
	if date.month = 1 then
		date.setDate(date.day,12,date.year-1);
	else
		date.setDate(date.day,date.month-1,date.year);
	endif;
	optCSVMonthly.caption := "CSV Monthly Stats (" &amp; date.monthName &amp; ")";
	
	
epilog
	delete printerArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="keyDown" id="11c674cd-0224-4082-9502-100f4ce15f18">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;

/*
Date			Who		Reason
15 July 2016	cnwar2	Initial creation

*/
vars

begin
	if keyCode = CMUI_Key_F5 then
		if self.folder1.topSheet.name = 'shtCurrent' then
			self.loadTblContacts();
		elseif self.folder1.topSheet.name = 'shtClosed' then
			self.loadTblClosed();
		endif;
	endif;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="load" id="91efe202-2c9e-4d89-adbb-d6a100e0289f">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

/*
Date			Who		Reason
07 July 2016	cnwar2	Initial creation

*/
vars
	
begin
	self.centreWindow();
	
	self.myRoot := DEV_SupportRoot.firstInstance();
	
	self.txtStatsStart.text  := "04/07/2016";
	self.txtStatsEnd.text 	 := app.actualTimeServer().Date.format("dd/MM/yyy");
	
	self.txtOpenedStart.text := "04/07/2016";
	self.txtOpenedEnd.text 	 := app.actualTimeServer().Date.format("dd/MM/yyy");
	
	self.txtFileName.text	 := 'c:\temp\supportKPIData.txt';
	
	self.initTables();
	self.loadTables();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="loadTables" id="2a62f102-e5fe-4074-9616-da3c1be55cb5">
        <updating/>
        <source>loadTables() updating;

/*
Date			Who		Reason
08 July 2016	cnwar2	Initial creation

*/
vars
	
begin
	self.loadTblContacts();
	self.loadTblClosed();
	self.loadTblTimezones();
	
	self.calculateStats();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="loadTblClosed" id="8093f059-e0a5-4752-8bfe-f360eb60eb75">
        <source>loadTblClosed();

/*
Date			Who		Reason
15 July 2016	cnwar2	Initial creation

*/
vars
	itemString, tfs,
	kpi1,kpi2,kpi3			: String;
	contact 				: DEV_SupportContact;	
	firstTime, kpiFailed	: Boolean;
	
begin
	if self.cmbReleaseClosed.listCount = 0 then
		self.cmbReleaseClosed.clear;
		self.cmbReleaseClosed.addItem("*ALL*");
		self.cmbReleaseClosed.listIndex := 1;
		firstTime := true;
	else
		firstTime := false;
	endif;

	self.tblClosed.rows := 1;
	
	foreach contact in self.myRoot.allContacts do
		tfs := contact.tfsNumber.String;
		if tfs = "0" then
			tfs := "";
		endif;
		
		kpi1 := contact.kpi1FailedBy;
		kpi2 := contact.kpi2FailedBy;
		kpi3 := contact.kpi3FailedBy;
		if kpi1 = "" then
			kpi1 := "Done";
		endif;
		if kpi2 = "" then
			kpi2 := "Done";
		endif;
		if kpi3 = "" then
			kpi3 := "Done";
		endif;
		if kpi1 = "Done" and kpi2 = "Done" and kpi3 = "Done" then
			kpiFailed := false;
		else
			kpiFailed := true;
		endif;
			
		if contact.getCurrentState &lt;&gt; 'Closed' then
			continue;
		elseif cmbOwnerClosed.text &lt;&gt; "*ALL*" and cmbOwnerClosed.text &lt;&gt; contact.owner then
			continue;
		elseif cmbReleaseClosed.text &lt;&gt; "*ALL*" and cmbReleaseClosed.text &lt;&gt; contact.releaseOpened then
			continue;
		elseif cmbKPIClosed.text = "*KPI Failed*" and not kpiFailed then
			continue;
	
		else
			itemString := contact.number.String &amp; Tab &amp; tfs &amp; Tab &amp; contact.customer &amp; Tab &amp; contact.description &amp; Tab &amp; 
						  contact.topic &amp; Tab &amp; contact.releaseOpened &amp; Tab &amp; contact.owner &amp; Tab &amp; contact.openedTS.String &amp; Tab &amp;
						  contact.getCurrentState() &amp; Tab &amp; contact.getTotalDuration() &amp; Tab &amp; 
						  kpi1 &amp; Tab &amp; kpi2 &amp; Tab &amp; kpi3;
		
			self.tblClosed.row := self.tblClosed.addItem(itemString);
			if contact.kpi1FailedBy &lt;&gt; "" or contact.kpi2FailedBy &lt;&gt; "" or contact.kpi3FailedBy &lt;&gt; "" then
				if (contact.kpi1FailedBy &lt;&gt; "" and contact.kpi1FailedBy.Real &lt;= -4)
				or (contact.kpi2FailedBy &lt;&gt; "" and contact.kpi2FailedBy.Real &lt;= -24)
				or (contact.kpi3FailedBy &lt;&gt; "" and contact.kpi3FailedBy.Real &lt;= -35) then
				   self.tblClosed.accessRow(self.tblClosed.rows).backColor := #9999FF;
				else
					self.tblClosed.accessRow(self.tblClosed.rows).backColor := #DDDDFF;
				endif;
			else
				self.tblClosed.accessRow(self.tblClosed.rows).backColor := #DDDDDD;
			endif;
			if contact.kpi1FailedBy &lt;&gt; "" then
				self.tblClosed.accessCell(self.tblClosed.rows,11).text := contact.kpi1FailedBy;
				self.tblClosed.accessCell(self.tblClosed.rows,11).foreColor := Red;
			else
				self.tblClosed.accessCell(self.tblClosed.rows,11).fontBold := false;
			endif;
			if contact.kpi2FailedBy &lt;&gt; "" then
				self.tblClosed.accessCell(self.tblClosed.rows,12).text := contact.kpi2FailedBy;
				self.tblClosed.accessCell(self.tblClosed.rows,12).foreColor := Red;
			else
				self.tblClosed.accessCell(self.tblClosed.rows,12).fontBold := false;
			endif;
			if contact.kpi3FailedBy &lt;&gt; "" then
				self.tblClosed.accessCell(self.tblClosed.rows,13).text := contact.kpi3FailedBy;
				self.tblClosed.accessCell(self.tblClosed.rows,13).foreColor := Red;
			else
				self.tblClosed.accessCell(self.tblClosed.rows,13).fontBold := false;
			endif;
			
			if self.cmbReleaseClosed.findString(1, contact.releaseOpened) = -1 then
				self.cmbReleaseClosed.addItem(contact.releaseOpened);
			endif;
		
			if firstTime and self.cmbReleaseClosed.findString(1, contact.releaseOpened) = -1 then
				self.cmbReleaseClosed.addItem(contact.releaseOpened);
			endif;
				
		endif;
	endforeach;
	
	self.tblClosed.row := 1;
	self.doResize();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="loadTblContacts" id="adb2c5ad-0232-4307-a1aa-1796c267b322">
        <source>loadTblContacts();

/*
Date			Who		Reason
15 July 2016	cnwar2	Initial creation

*/
vars
	itemString, tfs,
	kpi1,kpi2,kpi3			: String;
	contact 				: DEV_SupportContact;
	sort, count				: Integer;
	firstTime, kpiFailed,
	nearingFailure			: Boolean;
	
begin
	if self.cmbRelease.listCount = 0 then
		self.cmbRelease.clear;
		self.cmbRelease.addItem("*ALL*");
		self.cmbRelease.listIndex := 1;
		firstTime := true;
	else
		firstTime := false;
	endif;
	
	sort := self.tblContacts.sortColumn[1];
	self.tblContacts.sortColumn[1]	:= 1;
	self.tblContacts.resort();

	self.tblContacts.rows := 1;
	
	count := 0;
	foreach contact in self.myRoot.allContacts do	
		tfs := contact.tfsNumber.String;
		if tfs = "0" then
			tfs := "";
		endif;
		kpi1 := contact.getRemainingTimeKPI1();
		kpi2 := contact.getRemainingTimeKPI2();
		kpi3 := contact.getRemainingTimeKPI3();
		
		if kpi1 &lt;&gt; 'Done' and kpi1.Real &gt;= 0 then
			nearingFailure := true;
		elseif kpi2 &lt;&gt; 'Done' and kpi2.Real &gt;= 0 and kpi2.Real &lt; 10 then
			nearingFailure := true;
		elseif kpi3 &lt;&gt; 'Done' and kpi3.Real &gt;= 0 and kpi3.Real &lt; 10 then
			nearingFailure := true;
		else
			nearingFailure := false;
		endif;
		
		if contact.kpi1FailedBy &lt;&gt; "" or kpi1.Real &lt; 0 then
			kpiFailed := true;
		elseif contact.kpi2FailedBy &lt;&gt; "" or kpi2.Real &lt; 0 then
			kpiFailed := true;
		elseif contact.kpi3FailedBy &lt;&gt; "" or kpi3.Real &lt; 0 then
			kpiFailed := true;
		else
			kpiFailed := false;
		endif;
			
		if contact.getCurrentState = 'no state' or contact.getCurrentState = 'Closed' then
			continue;
		elseif cmbState.text &lt;&gt; "*ALL*" and cmbState.text &lt;&gt; "*ALL ACTIVE*" and cmbState.text &lt;&gt; contact.getCurrentState then
			continue;
		elseif cmbState.text = "*ALL ACTIVE*" and contact.getCurrentState = 'Pending Response' then
			continue;
		elseif cmbOwner.text &lt;&gt; "*ALL*" and cmbOwner.text &lt;&gt; contact.owner then
			continue;
		elseif cmbRelease.text &lt;&gt; "*ALL*" and cmbRelease.text &lt;&gt; contact.releaseOpened then
			continue;
		elseif cmbKPI.text = "*KPI Failed*" and not kpiFailed then
			continue;
		elseif cmbKPI.text = "*Nearing KPI Failure*" and not nearingFailure then
			continue;
		else
			count := count + 1;
			itemString := contact.number.String &amp; Tab &amp; tfs &amp; Tab &amp; contact.customer &amp; Tab &amp; contact.description &amp; Tab &amp; 
						  contact.topic &amp; Tab &amp; contact.releaseOpened &amp; Tab &amp; contact.owner &amp; Tab &amp; 
						  contact.openedTS.String &amp; Tab &amp; contact.getCurrentState() &amp; Tab &amp; contact.getTimeInCurrentState() &amp; Tab &amp; 
						  kpi1 &amp; Tab &amp; kpi2 &amp; Tab &amp; kpi3;
		
			self.tblContacts.row := self.tblContacts.addItem(itemString);
			if contact.getCurrentState = 'Pending Response' then
				self.tblContacts.accessRow(self.tblContacts.rows).backColor := #DDDDDD;
			endif;
			if contact.getCurrentState = 'Active Support' then
				if contact.owner = 'Manila' then
					self.tblContacts.accessRow(self.tblContacts.rows).backColor := #BBFFBB;
				else
					self.tblContacts.accessRow(self.tblContacts.rows).backColor := #FFBBBB;
				endif;
			endif;
			if contact.getCurrentState = 'Architect/Dev Support' then
				if contact.owner = 'Manila' then
					self.tblContacts.accessRow(self.tblContacts.rows).backColor := #BBFFBB;
				else
					self.tblContacts.accessRow(self.tblContacts.rows).backColor := #FFBBFF;
				endif;
			endif;
			if contact.getCurrentState = 'Active Development' then
				if contact.owner = 'Manila' then
					self.tblContacts.accessRow(self.tblContacts.rows).backColor := #DDFFDD;
				else
					self.tblContacts.accessRow(self.tblContacts.rows).backColor := #FFDDDD;
				endif;
			endif;
		endif;
		
		if kpi1 = 'Done' then
			tblContacts.accessCell(self.tblContacts.rows,11).fontBold := false;
			if contact.kpi1FailedBy &lt;&gt; "" then
				tblContacts.accessCell(self.tblContacts.rows,11).foreColor := Red;
				tblContacts.accessCell(self.tblContacts.rows,11).text := 'Failed';
			endif;			
		else
			tblContacts.accessCell(self.tblContacts.rows,11).fontBold := true;
			tblContacts.accessCell(self.tblContacts.rows,11).foreColor := Red;
		endif;
		if kpi2 = 'Done' then
			tblContacts.accessCell(self.tblContacts.rows,12).fontBold := false;
			if contact.kpi2FailedBy &lt;&gt; "" then
				tblContacts.accessCell(self.tblContacts.rows,12).foreColor := Red;
				tblContacts.accessCell(self.tblContacts.rows,12).text := 'Failed';
			endif;
		elseif kpi2.Real &lt; 10 then
			tblContacts.accessCell(self.tblContacts.rows,12).foreColor := Red;
		elseif kpi2.Real &lt; 20 then
			tblContacts.accessCell(self.tblContacts.rows,12).foreColor := #0088FF;
		else
			tblContacts.accessCell(self.tblContacts.rows,12).fontBold := false;
			tblContacts.accessCell(self.tblContacts.rows,12).foreColor := #008800;
		endif;
		if kpi3.Real &lt; 10 then
			tblContacts.accessCell(self.tblContacts.rows,13).foreColor := Red;
		elseif kpi3.Real &lt; 20 then
			tblContacts.accessCell(self.tblContacts.rows,13).foreColor := #0088FF;
		else
			tblContacts.accessCell(self.tblContacts.rows,13).fontBold := false;
			tblContacts.accessCell(self.tblContacts.rows,13).foreColor := #008800;
		endif;
		
		if firstTime and self.cmbRelease.findString(1, contact.releaseOpened) = -1 then
			self.cmbRelease.addItem(contact.releaseOpened);
		endif;
	endforeach;
	self.tblContacts.row := 1;
	
	self.tblContacts.sortColumn[1]	:= sort;
	self.tblContacts.resort();
	
	self.label1.caption := "Support Items (" &amp; count.String &amp; ")";
	
	self.doResize();
end;</source>
    </JadeMethod>
    <JadeMethod name="loadTblTimezones" id="551f103a-d401-464b-9dc9-51437838a305">
        <source>loadTblTimezones();

/*
Date			Who		Reason
15 July 2016	cnwar2	Initial creation

*/
vars
	itemString, gmt	: String;
	timezone		: DEV_SupportTimezone;
	i,j,k			: Integer;
	dark, dark2		: Boolean;

begin
	self.tblTimezones.rows 		:= 1;
	self.tblTimezones2.columns 	:= self.myRoot.allTimezones.size;
	self.tblTimezones2.rows 	:= 25;
	
	i := 1;
	foreach timezone in self.myRoot.allTimezones do
		if timezone.gmtDiff &lt; 0 then
			gmt := "GMT " &amp; timezone.gmtDiff.String;
		else
			gmt := "GMT +" &amp; timezone.gmtDiff.String;
		endif;
		if timezone.isDaylightSavings() then
			gmt := gmt &amp; Tab &amp; "DST";
		else
			gmt := gmt &amp; Tab &amp; "Not DST";
		endif;
		
		itemString := timezone.name &amp; Tab &amp; gmt &amp; Tab &amp; timezone.customers &amp; Tab &amp; timezone.getLocalHoursStr();
		
		self.tblTimezones.row := self.tblTimezones.addItem(itemString);
		if dark then
			self.tblTimezones.accessRow(self.tblTimezones.rows).backColor := #CCEEEE;
			dark := false;
		else
			self.tblTimezones.accessRow(self.tblTimezones.rows).backColor := #DDFFFF;
			dark := true;
		endif;
		
		self.tblTimezones.accessCell(self.tblTimezones.rows,3).fontSize := 6;
		if timezone.isDaylightSavings() then
			self.tblTimezones.accessCell(self.tblTimezones.rows,3).fontBold := true;
			self.tblTimezones.accessCell(self.tblTimezones.rows,3).foreColor := #00AAAA;
		else
			if timezone.name = "NZ" or timezone.name = "Europe" or timezone.name = "USA (West)" or timezone.name = "USA (East)" or timezone.name = "Mexico" then
				self.tblTimezones.accessCell(self.tblTimezones.rows,3).foreColor := #888888;
			else
				self.tblTimezones.accessCell(self.tblTimezones.rows,3).foreColor := self.tblTimezones.accessRow(self.tblTimezones.rows).backColor;
			endif;
		endif;
		
		tblTimezones2.row  	:= 1;
		j					:= 1;
		if timezone.name = "USA (West)" then
			tblTimezones2.accessCell(1,i).text := "USA-W";
		elseif timezone.name = "USA (East)" then
			tblTimezones2.accessCell(1,i).text := "USA-E";
		else
			tblTimezones2.accessCell(1,i).text := timezone.name.getNextToken(j);
		endif;
		j := (12+timezone.getGMTDiff())*100;
		if j &gt;= 2400 then
			j := j-2400;
		endif;
		dark2 := false;
		foreach k in 1 to 24 do
			tblTimezones2.accessCell(k+1,i).text := j.String.padLeadingZeros(4);
			if timezone.name = "NZ" then
				tblTimezones2.accessCell(k+1,i).backColor := #DDDDDD;
				tblTimezones2.accessCell(1,i).fontBold := true;
			elseif dark2 then 
				tblTimezones2.accessCell(k+1,i).backColor := #F0F0F0;
				dark2 := false;
			else
				tblTimezones2.accessCell(k+1,i).backColor := #F8F8F8;
				dark2 := true;
			endif;
			j := j + 100;
			if j = 2400 then
				j := 0;
			endif;
		endforeach;
		
		i := i + 1;
	endforeach;
		
	self.tblTimezones.row := 1;
	self.tblTimezones2.row := 1;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="optCSVMonthly_click" id="8dc0e268-2813-4548-8330-e36e910cd51f">
        <controlMethod name="OptionButton::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>optCSVMonthly_click(optionbutton: OptionButton input) updating;

/*
Date			Who		Reason
08 August 2016	cnwar2	Initial creation

*/
vars

begin
	if optionbutton.value then
		lblFileName.visible := true;
		txtFileName.visible	:= true;
		btnFile.visible		:= true;
		
		lblPrinter.visible	:= false;
		cmbPrinter.visible	:= false;
		
		groupBox1.enabled	:= false;
		groupBox2.enabled	:= false;
	endif;
end;</source>
        <Parameter name="optionbutton" type="OptionButton" usage="input"/>
    </JadeMethod>
    <JadeMethod name="optCSV_click" id="47caf597-81ba-4945-863e-bb5304605772">
