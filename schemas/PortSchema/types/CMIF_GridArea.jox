    <JadeMethod name="validate" id="3bbb864c-f43f-4646-998b-7cdb850e7aff">
        <source>validate(_errStr : String io);
/*
----------   ----------  --------------------------------------------------
Created:	25 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	inheritMethod(_errStr);
	
	if self.decrementRowNums and self.startNumRow - self.numRows &lt; 0 then
		_errStr := _errStr &amp; 'Rows numbers will become negative with the current settings. This is not allowed' &amp; CrLf;
	endif;

	if self.decrementColNums and self.startNumColumn - self.numColumns &lt; 0 then
		_errStr := _errStr &amp; 'Column numbers will become negative with the current settings. This is not allowed' &amp; CrLf;
	endif;
		
end;</source>
        <Parameter name="_errStr" type="String" usage="io"/>
    </JadeMethod>
</Class>
