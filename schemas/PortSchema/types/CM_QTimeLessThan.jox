    <JadeMethod name="doMatch" id="7ee35bbe-04bf-4800-9cdb-a6a10599193f">
        <source>doMatch(_value: Any): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2012	cnwndl1	Initial creation	Par 29532

*/

vars

begin
	if not _value.Time.isValid then
          return false;
	endif;
	
	return _value.Time &lt; self.searchValue;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
