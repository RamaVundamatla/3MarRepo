    <JadeMethod name="terminologyTypeName" id="f7918a38-c717-480a-9d85-dc5418c91363">
        <methodInvocation>mapping</methodInvocation>
        <source>terminologyTypeName(set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:     19 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		if self.myTerminologyType &lt;&gt; null then
			_value := self.myTerminologyType.name;
		endif;
	endif;



end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
