    <JadeMethod name="setupDefaultMapFilesToCompress" id="b8fef1ed-7027-498c-b513-586bf9b7f240">
        <source>setupDefaultMapFilesToCompress();

/*

Purpose:		Setup the default map files to compact
				Added to initialise method so gets set 
				when new system is setup, so I don't have
				to remember to do it.

Date			Who		Reason
11/06/2015		cnwmh5	Initial creation

*/

vars

	mapToCompact					: UM_MapFilesToCompact;
	oldCleanUpDetails				: UM_CleanUpResultsDetails;
	cleanUpDetailsCompact			: UM_CleanUpDetailsCompact;
	root							: UM_Root;
	
	count							: Integer;
	mapFileName						: String;
	
begin

	root := UM_Root.firstInstance;
	if root = null then
		app.msgBox("Unable to find root object.  Exiting JadeScript...", "Error", MsgBox_OK_Only);
		return;
	endif;
	
	beginTransaction;
	create mapToCompact persistent;
	mapToCompact.updateDetails("unitTest", UM_MapFilesToCompact.WhenToCompactWeekly);
	create mapToCompact persistent;
	mapToCompact.updateDetails("audit", UM_MapFilesToCompact.WhenToCompactWeekly);
	create mapToCompact persistent;
	mapToCompact.updateDetails("cams", UM_MapFilesToCompact.WhenToCompactWeekly);
	create mapToCompact persistent;
	mapToCompact.updateDetails("_rootdef", UM_MapFilesToCompact.WhenToCompactWeekly);
	create mapToCompact persistent;
	mapToCompact.updateDetails("terminal", UM_MapFilesToCompact.WhenToCompactWeekly);
	commitTransaction;
	
	count := 0;
	beginTransaction;
	foreach oldCleanUpDetails in UM_CleanUpResultsDetails.instances discreteLock do
		if not oldCleanUpDetails.taskDescription.cnContains("Compact - ") then
			continue;
		endif;
		
		mapFileName := oldCleanUpDetails.taskDescription[oldCleanUpDetails.taskDescription.reversePos("Compact -") + ("Compact - ").length:end];
		///write mapFileName;
		
		create cleanUpDetailsCompact persistent;
		cleanUpDetailsCompact.updateDetailsCompact(mapFileName, oldCleanUpDetails.startTS, oldCleanUpDetails.endTS, 
			oldCleanUpDetails.startingSize.Decimal, oldCleanUpDetails.endingSize.Decimal);
		
	endforeach;
	commitTransaction;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="startUnitTestAutoRun" id="eba9c20d-bfcb-42a2-a259-282560b9d0b9">
