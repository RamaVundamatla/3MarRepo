    <JadeMethod name="getCurrentLengthOfTime" id="ee552d3a-442e-4e63-b6de-1769317fb4db">
        <source>getCurrentLengthOfTime() : Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 November 2018	jlger1	Initial creation

*/

vars
	workOrderVoyage  : CM_WorkOrderVoyage;
	voyage : CM_Voyage;
	wodVoyageRequest : CM_WorkOrderDtl;
	lengthOfTime : Decimal[12,2];
	
begin
	lengthOfTime:= inheritMethod();
	
	if lengthOfTime &gt; 0 then
		return lengthOfTime;
	endif;
	
	if not self.requiresLengthOfTime then
		return null;
	endif;
	
	voyage := self.getMyVoyageObject;
	
	wodVoyageRequest := voyage.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_CARGOINITIAL);
	//25 Mar 2019 jlger1	Issues with not working with IMSR and DMSR
	if wodVoyageRequest = null then
		wodVoyageRequest:= self.myRelatedPermitRequest;
	endif;
	
	if wodVoyageRequest &lt;&gt; null then
		workOrderVoyage := wodVoyageRequest.getMyParent.CM_WorkOrderVoyage;
	else
		workOrderVoyage := self.getMyParent.CM_WorkOrderVoyage;
	endif;
	
	return  workOrderVoyage.lengthOfTime;
	
	
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
