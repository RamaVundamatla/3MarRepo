    <JadeMethod name="setupProceedOptions" id="99117aa5-af71-428b-b552-b3be5ec243ae">
        <updating/>
        <source>setupProceedOptions(_mnuProceed: MenuItem input) updating;
/*
Purpose:			
Return Value:		

Date					Who		Reason
15 August 2006	cnwer1	Initial creation - PAR#xxxx
17 August 2009	cnwcs5	ccms 1061 - road ops form changes. changed to reuse menuitems
02/09/2009		cnwcs5	ccms 1061 - remove old VTA handling
*/
vars
	menu, subMenu 	: MenuItem;
begin
	menu := self.getProceedMenuItem;
	
	if menu = null then
		self.myRoadOpController.setNumberOfMenuItems(self.myRoadOpController.numberOfMenuItems+1);
		
		menu			:= _mnuProceed.loadMenu(self.myRoadOpController.numberOfMenuItems);
		menu.caption	:= Proceed;
		menu.userObject	:= self;
		
		self.allMenuItems.add(menu);
	endif;
	
	menu.visible	:= true;
	
	//Proceeding to the Yard
	subMenu := self.getYardMenuItem;
	
	if subMenu = null then
		self.myRoadOpController.setNumberOfMenuItems(self.myRoadOpController.numberOfMenuItems+1);
		
		subMenu	:= menu.loadSubMenu(self.myRoadOpController.numberOfMenuItems);
		
		subMenu.setEventMapping(MenuItem::click.name,YRD_RoadOperationsForm::mProceed_click.name);
	
		self.allMenuItems.add(subMenu);
	
		subMenu.caption		:= self.getYardMenuCaption;	
	endif;
	
	subMenu.visible		:= true;
	subMenu.enabled		:= true;
	subMenu.userObject	:= null;
epilog

end;</source>
        <Parameter name="_mnuProceed" type="MenuItem" usage="input"/>
    </JadeMethod>
