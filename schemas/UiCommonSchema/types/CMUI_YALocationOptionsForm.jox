    <JadeMethod name="doSave" id="215c84de-d740-4af1-a73e-c19d3a676acc">
        <updating/>
        <source>doSave() updating;
//20 August 2008	cnwdw1	
//
vars
	proxyYABlock: CM_YABlock;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin

	proxyYABlock := app.createUpdateProxy(self.yaBlock).CM_YABlock;
	
	//par 19569 cnwjo3
	if proxyYABlock.isKindOf(CM_YABlockGridArea) then
		proxyYABlock.setMinMaxHeight(self.cmbMinHeight.itemText[self.cmbMinHeight.listIndex].Integer, 
									 self.cmbMaxHeight.itemText[self.cmbMaxHeight.listIndex].Integer);
	endif;
	
	if self.optOpen.value then
		proxyYABlock.openBlock();
	else
		proxyYABlock.closeBlock();
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateYABlock(proxyYABlock, self.yaBlock, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			unloadForm;
			break;
		else
			theResult := app.showErrorWarningDialog("Yard Allocation Location", app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
	// cnwjk3 16/03/09 - PAR 19076
	self.rebuildStats();
		
epilog
	delete proxyYABlock;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSpecifyDeckingOptions" id="95ab0226-2453-47c4-aeda-a26bbb044e0b">
        <updating/>
        <source>doSpecifyDeckingOptions() updating;
//20 August 2008	cnwdw1	
//
vars
	assistantObj: CMUI_Assistant;
	returnValue: Integer;
	theForm : CMUI_DeckingRulesForm;
	proxyYABlock: CM_YABlock;	
begin
	theForm := app.loadForm(CMUI_DeckingRulesForm, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_DeckingRulesForm;
	
	if theForm = null then
		return;
	endif;
	
	proxyYABlock := app.createUpdateProxy(self.yaBlock).CM_YABlock;	

	theForm.onCreate(proxyYABlock.myDeckingOptions, self.yaBlock, null);
	theForm.setParentForm(self);
	theForm.showModal();
	
	self.showDeckingOptions;
epilog
	delete proxyYABlock;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateForm" id="61898269-4b93-420c-b0ba-347903ff0f67">
        <updating/>
        <source>populateForm() updating;
/*
Date			Who		Reason
29 August 2008	consw1	Initial creation
10 June 2013	cnwcs5	Deleted grpAutoDelete
*/

vars
	stackHeight	: Integer;
	listIndex	: Integer;
	h			: Integer;
begin
	self.optOpen.value 		:= self.yaBlock.isOpen();
	self.optClosed.value 	:= not self.optOpen.value;
	
	self.showDeckingOptions();
	
	stackHeight := self.yaBlock.getHeightOfStack();
	
	if stackHeight &gt; 0 then
		foreach h in 1 to stackHeight do
			listIndex := cmbMinHeight.addItem(h.String);
			
			if self.yaBlock.getMinHeight = h.Integer then
				cmbMinHeight.listIndex := listIndex;
			endif;
			
			listIndex := cmbMaxHeight.addItem(h.String);
			
			if self.yaBlock.getMaxHeight = h.Integer then
				cmbMaxHeight.listIndex := listIndex;
			endif;
		endforeach;
	else
		cmbMinHeight.enabled := false;
		cmbMaxHeight.enabled := false;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="rebuildStats" id="3d29e1a4-331d-4f74-8001-ea3444aeb09f">
        <source>rebuildStats() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 March 2009	cnwjk3	PAR 19076

*/

vars
	movementLogObj	: CMIF_MovementLogController;
begin
	create movementLogObj transient;
//	movementLogObj.rebuildStats(self.yaBlock);		// cnwrl1 21/04/2009 PAR 19463/19330
	movementLogObj.rebuildStats( self.yaBlock, null );
	
epilog
	delete movementLogObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
