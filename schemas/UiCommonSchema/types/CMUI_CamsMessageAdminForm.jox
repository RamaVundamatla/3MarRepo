Parameters:			

Return Value:		

Date			Who		Reason
04 July 2024	navcs2	ChangeRequest 63797: EUP | CAMS Search for outgoing messages - CAMS Message Enquiry

*/
vars

begin
	if self.btnSelectAll.caption = app.getErrorString(SelectAll) then
		self.tblData.selectAll;
	else
		self.tblData.clearAllSelected;
	endif;

	inheritMethod();
epilog

end;</source>
