    <JadeMethod name="createNewParent" id="55a97b06-141d-4674-89e5-ef47358ba6cc">
        <source>createNewParent( _newId : String ):CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	pxyParentTi : CM_TrackedItem;
	moveController	: CMIF_MoveController;
	realParentTI : CM_TrackedItem;

begin

	pxyParentTi := self.myTerminal.createTI( self.myNewCargoType, true );
	pxyParentTi.zSetPxyId( _newId );
	pxyParentTi.zSetPxyTerminal(self.myTerminal);
	
	pxyParentTi.setCargoType(self.myNewCargoType.id);
	pxyParentTi.setMyProduct(self.myNewProduct);
	pxyParentTi.setMyOperator(self.myNewOperator);
	
	if app.isSubTerminalsOn(self.myTerminal) then
		pxyParentTi.setSubTerminalDefaultFromTerm(self.myTerminal);	
	endif;
	
	pxyParentTi.changeState(TI_STATE_NORMAL, self.myPassport);
	
	if self.totalQuantity &gt; 0 then
		pxyParentTi.setTotalQuantity( self.totalQuantity );
	endif;
	if self.totalWeight &gt; 0 then
		pxyParentTi.setTotalWeightWithoutTrans(self.totalWeight);
	endif;
	if self.totalVolume &gt; 0 then
		pxyParentTi.setMyTotalVolume(self.totalVolume);
	endif;
	
	
	
	create moveController transient;
	moveController.setMyToPrimaryLocation( self.myNewLocation );
	
	app.myUtilityCA.utlCreateTrackedItem( pxyParentTi, realParentTI, self.myPassport);

	if not self.myPassport.noErrors() then
		return null;
	endif;
	
	moveController.setMyTrackedItem( realParentTI );

	realParentTI.setMyLocationsPublic( moveController );
	return realParentTI;

epilog

	delete moveController;

end;</source>
        <Parameter name="_newId" type="String"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="performBlending" id="8559852a-e793-4f4a-a163-b06fe27e1a6b">
        <updating/>
        <source>performBlending()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	parentTI : CM_TrackedItem;
	parentBlendTrx : CM_Blend;
	parentTrxController : CMIF_ActionTransController;
	
	trxController : CMIF_TITransactionController;
	blendCompleteTrx : CM_BlendComplete;
	
	obj : CMIF_Object;
	cmif : CMIF_BlendingComponent;
	newId : String;
	allParents : CM_TIArray;

begin

	self.myPassport := app.myPassport;
	self.myPassport.setMyTerminal(self.myTerminal);

	if not self.validateAmounts( true ) then
		return;
	endif;
	
	if not self.validateCreatingNewCargo( true ) then
		return;
	endif;
	
	if not self.validateSufficientCompCargo( true ) then
		return;
	endif;
	
	if not self.validateUseExistingCargo( true ) then
		return;
	endif;
	
	if not self.validateUsingRecipe( true ) then
		return;
	endif;
	
	self.myPassport.warningsAcknowledged := true;
	self.myPassport.setIsBackgroundWarningsIgnored(true);
	
	create allParents transient;
	
	if self.doCreateNewCargoItem then
	
		foreach newId in self.newParentIdArray do
			parentTI := self.createNewParent( newId );
			if self.myPassport.hasErrors() then
				return;
			endif;
			allParents.add( parentTI );
		endforeach;
		
	else
		parentTI := self.myExistingParentCargo;
		//Increment the volume / weight / quantity of the existing parent, if newly created it will already be correct
		if self.totalQuantity &gt; 0 then
			parentTI.setTotalQuantity( parentTI.totalQuantity + self.totalQuantity );
		endif;
		if self.totalWeight &gt; 0 then
			parentTI.setTotalWeightWithoutTrans( parentTI.totalWeight + self.totalWeight );
		endif;
		if self.totalVolume &gt; 0 then
			parentTI.setMyTotalVolume( parentTI.totalVolume + self.totalVolume );
		endif;
		allParents.add( parentTI );
		
	endif;
	
	foreach parentTI in allParents do
	
		create parentTrxController transient;
		parentTrxController.type := TRANS_TYPE_Blend;
		parentTrxController.myTrackedItem := parentTI;
		parentTrxController.action := ACTION_BLEND_PARENT;
		// the amount that was added.
		parentTrxController.totalQuantity := self.totalQuantity; 
		parentTrxController.totalWeight := self.totalWeight;
		parentTrxController.totalVolume := self.totalVolume;
		
		parentBlendTrx := parentTI.createTransaction(parentTrxController, self.myPassport).CM_Blend;
		
		delete parentTrxController;
		
		if parentBlendTrx = null or self.myPassport.hasErrors then
			return;
		endif;
		
		parentBlendTrx.setMyRecipe( self.myRecipe );
		
		//Now create the Blend Complete - thios sucker is the one used for billing if they are going to
		create trxController transient;
		trxController.type := TRANS_TYPE_BlendComplete;
		trxController.myTrackedItem := parentTI;
		// the amount that was added.
		trxController.totalQuantity := self.totalQuantity; 
		trxController.totalWeight := self.totalWeight;
		trxController.totalVolume := self.totalVolume;
		
		blendCompleteTrx := parentTI.createTransaction(trxController, self.myPassport).CM_BlendComplete;
		
		delete trxController;
		
		if blendCompleteTrx = null or self.myPassport.hasErrors then
			return;
		endif;
		
		blendCompleteTrx.setMyParentBlendTrx( parentBlendTrx );
		//////////////////////////////
		
		//consume the child cargo items, (spliting) and 'zombie'ing them (OR down sizing) and adding child Blend transactions
		foreach obj in self.allBlendingComponents do
			cmif := obj.CMIF_BlendingComponent;
			cmif.consumeChildComponents( parentBlendTrx, self.myPassport );
		endforeach;
		
	endforeach;
		
epilog

	delete allParents;
	delete parentTrxController;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateAmounts" id="6d7255e2-61ae-462c-a328-3ef0da663231">
        <source>validateAmounts( _raiseExc : Boolean ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	msg : String;
	cargoType : CM_CargoType;

begin

	if self.totalQuantity = 0 and  self.totalVolume = 0 and self.totalWeight = 0 then
		if _raiseExc then
			app.raiseCMException(Amoun_quant_weigh_volum_enter_,null, null);
		else
			msg := app.getErrorString(Amoun_quant_weigh_volum_enter_);
			app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		endif;
		return false;
	endif;
	
	if self.myExistingParentCargo = null then
		cargoType := self.myNewCargoType;
	else
		cargoType := self.myExistingParentCargo.myCargoType;
	endif;
	
	if cargoType.isTrackByVolume or cargoType.trackByMeasureType = CargoType_TrackByVolume then
		if self.totalVolume = 0 then
			if _raiseExc then
				app.raiseCMException(Volume_requir_entere_blende_ca,null, null);
			else
				msg := app.getErrorString(Volume_requir_entere_blende_ca);
				app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
			endif;
			return false;	
		endif;
		
	elseif cargoType.isTrackByWeight or cargoType.trackByMeasureType = CargoType_TrackByWeight then
		if self.totalWeight = 0 then
			if _raiseExc then
				app.raiseCMException(Weigh_requi_enter_blend_cargo_,null, null);
			else
				msg := app.getErrorString(Weigh_requi_enter_blend_cargo_);
				app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
			endif;
			return false;	
		endif;
	else
		if self.totalQuantity = 0 then
			if _raiseExc then
				app.raiseCMException(Quant_requi_enter_blend_cargo_,null, null);
			else
				msg := app.getErrorString(Quant_requi_enter_blend_cargo_);
				app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
			endif;
			return false;	
		endif;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_raiseExc" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateCreatingNewCargo" id="f197c99d-4770-4876-9428-83316143f1d6">
        <source>validateCreatingNewCargo( _raiseExc : Boolean ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 May 2021	navndl1	Initial creation	TFS 

*/

vars

	msg : String;
	existingCargo : CM_TrackedItem;
	iter : Iterator;
	startObject : CM_TrackedItem;
	whereString : String;
	newId : String;

begin

	if not self.doCreateNewCargoItem then
		return true;
	endif;
	
	if self.newParentIdArray.isEmpty then
		if _raiseExc then
			app.raiseCMException(Must_enter_cargo_creat_item_fr,null, null);
		else
			msg := app.getErrorString(Must_enter_cargo_creat_item_fr);
			app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		endif;
		return false;
	endif;
	
	if self.myNewCargoType = null then
		if _raiseExc then
			app.raiseCMException(Please_select_cargo_type,null, null);
		else
			msg := app.getErrorString(Please_select_cargo_type);
			app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		endif;
		return false;
	endif;
	
	if self.myNewOperator = null then
		if _raiseExc then
			app.raiseCMException(Please_select_operator,null, null);
		else
			msg := app.getErrorString(Please_select_operator);
			app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		endif;
		return false;
	endif;
	
	if self.myNewLocation = null then
		if _raiseExc then
			app.raiseCMException(WARN_DoorDirectionRuleLocation,null, null);
		else
			msg := app.getErrorString(WARN_DoorDirectionRuleLocation);
			app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		endif;
		return false;
	endif;
	
	foreach newId in self.newParentIdArray do
	
		if not self.myNewCargoType.allowDuplicates then
			startObject := self.myTerminal.allOnsiteTIsByIdCargoType.getAtKeyGeq( newId, self.myNewCargoType.id );
		else
			startObject := self.myNewLocation.allTrackedItemsById.getAtKeyGeq( newId, self.myNewCargoType.id );
		endif;
		if startObject &lt;&gt; null then
			if not self.myNewCargoType.allowDuplicates then
				iter := self.myTerminal.allOnsiteTIsByIdCargoType.createIterator;
				whereString := self.myTerminal.name;
			else
				iter := self.myNewLocation.allTrackedItemsById.createIterator;
				whereString := self.myNewLocation.getFullId;
			endif;
			iter.startAtObject( startObject );
			while iter.next( existingCargo ) do
				if existingCargo.id &lt;&gt; newId then
					break;
				endif;
				if existingCargo.myCargoType &lt;&gt; self.myNewCargoType then
					break;
				endif;
				if existingCargo.myOperator &lt;&gt; self.myNewOperator then
					continue;
				endif;
				//we already have a matching item, can't create a new one.
				if _raiseExc then
					app.raiseCMException1(Cargo_cargo_type_opera_combi_m, whereString, null, null);
				else
					msg := app.getErrorString1(Cargo_cargo_type_opera_combi_m, whereString );
					app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
				endif;
				return false;
			endwhile;
		endif;
		
		delete iter;
	
	endforeach;
	
	
	return true;

epilog

	delete iter;

end;</source>
        <Parameter name="_raiseExc" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateSufficientCompCargo" id="35fdda18-c75f-4102-b10e-1aeb347cddd3">
        <source>validateSufficientCompCargo( _raiseExc : Boolean ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	obj : Object;
	cmif : CMIF_BlendingComponent;
	msg : String;
	underAmount : String;

begin
	
	if self.allBlendingComponents.isEmpty then
		if _raiseExc then
			app.raiseCMException(Blending_components_supplied,null, null);
		else
			msg := app.getErrorString(Blending_components_supplied);
			app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		endif;
		return false;
	endif;

	foreach obj in self.allBlendingComponents do
		cmif := obj.CMIF_BlendingComponent;
		if cmif.allTis.isEmpty or cmif.insufficientComponent( underAmount ) then
			if _raiseExc then
				app.raiseCMException1(Blendin_compone_insuffi_assign, cmif.getCargoTypeProdString &amp; " for " &amp; cmif.getAmountString( false ),null, null);
			else
				msg := app.getErrorString1(Blendin_compone_insuffi_assign, cmif.getCargoTypeProdString &amp; " for " &amp; cmif.getAmountString( false ) );
				app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
			endif;
			return false;
		endif;
	endforeach;
	
	return true;

epilog

end;</source>
        <Parameter name="_raiseExc" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateUseExistingCargo" id="94371a2a-5a02-4bd2-b297-7de89309741a">
        <source>validateUseExistingCargo( _raiseExc : Boolean ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 May 2021	navndl1	Initial creation	TFS 

*/

vars

	msg : String;

begin

	if self.doCreateNewCargoItem then
		return true;
	endif;
	
	if self.myExistingParentCargo = null then
		if _raiseExc then
			app.raiseCMException(Existi_cargo_select_blende_car,null, null);
		else
			msg := app.getErrorString( Existi_cargo_select_blende_car );
			app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		endif;
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_raiseExc" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateUsingRecipe" id="85d2537b-90f8-4e42-b266-adaf460caf02">
        <source>validateUsingRecipe( _raiseExc : Boolean ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	msg : String;

begin

	if not self.doUseRecipe then
		return true;
	endif;
	
	if self.myRecipe = null then
		if _raiseExc then
			app.raiseCMException(Recipe_selected,null,null);
		else
			msg := app.getErrorString( Recipe_selected );
			app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		endif;
		return false;
	endif;
	
	if not self.myRecipe.canFactor then
		if self.factor &lt;&gt; 0 and self.factor &lt;&gt; 1 then
			if _raiseExc then
				app.raiseCMException(Not_multipl_this_recipe,null, null);
			else
				msg := app.getErrorString(Not_multipl_this_recipe);
				app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
			endif;
			return false;
		endif;
	else
		if not self.myRecipe.canfactorBy( self.factor, _raiseExc ) then
			return false;
		endif;
	
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_raiseExc" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
