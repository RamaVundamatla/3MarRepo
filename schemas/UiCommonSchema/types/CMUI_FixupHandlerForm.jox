    <JadeMethod name="doResize" id="f41fa08c-d5a4-4cdc-8681-babb87ea4847">
        <updating/>
        <source>doResize() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2011	cnwndl1	Initial creation	Par 27438

*/

vars

begin

	inheritMethod();
	
	self.grpMethods.left := 5;
	self.grpMethods.top := 5;
	self.grpMethods.width := self.clientWidth - 10;
	self.grpMethods.height := self.clientHeight - 10;
	
	self.cmbMethods.width := self.grpMethods.width - ( self.cmbMethods.left * 2 );
	self.txtParams.width := self.cmbMethods.width;
	self.txtOutput.width := self.cmbMethods.width;
	
	self.txtOutput.height := self.grpMethods.height - ( self.txtOutput.top + 30 );
	
	self.btnClose.top := self.txtOutput.top + self.txtOutput.height + 5;
	self.btnClose.left := self.cmbMethods.width - ( self.btnClose.width - self.cmbMethods.left );
	self.btnRun.left := self.btnClose.left - ( self.btnClose.width + 5 );
	self.btnPrint.top := self.btnClose.top;
	self.btnRun.top := self.btnClose.top;
	self.btnFile.top := self.btnClose.top;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="logTheOutcome" id="a6c11f1e-f332-4fe4-9595-5479b35cb915">
        <source>logTheOutcome( _msg : String; _detail : String );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 May 2011	cnwndl1	Initial creation	Par 27438

*/

vars
	alert: CM_SystemAlert;
	setInTransState: Boolean;
begin

	
	if not process.isInTransactionState then
		setInTransState := true;
		beginTransaction;
	endif;
	create alert;
	alert.details := _msg;
	alert.addLogEntry(_detail);
	alert.setSeverity(SEVERE_INFO);
	//-----------
	//Tell alert to add itself to system
	//-----------
	alert.add;
epilog
	if setInTransState then
		app.cmsCommitTransaction(app.myPassport);
	endif;
end;</source>
        <Parameter name="_msg" type="String"/>
        <Parameter name="_detail" type="String"/>
    </JadeMethod>
    <JadeMethod name="populateCmbMethods" id="a03eee4a-3b67-46dc-9c01-31b41063731a">
        <source>populateCmbMethods();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2011	cnwndl1	Initial creation	Par 27438
12 Sep 2019	jlgdi1	46471 Added methods visibility check for specific client (Pelindo)
08 Oct 2021	jlier1  TFS 51963 - removed pelindo methods
*/

vars
	index : Integer;
	meths : MethodNDict;
	meth : Method;
	iter : Iterator;
	methodName : String;

begin
	
	cmbMethods.clear;
	
	create meths transient;
	self.myFixupHandlerAgent.class.getMethods(meths);
	
	iter := meths.createIterator;
	while iter.next(meth) do
		if meth.access = 2.Character then
			// the method is protected, don't list it.
			continue;
		endif;
		if meth.name[1] = "z" then
			// the method is internal to the agent, don't list it.
			continue;
		endif;
		
		methodName := self.myFixupHandlerAgent.zGetNiceName(meth);
		if methodName = null then 
			continue;
		endif;
				
		index := cmbMethods.addItem( methodName );
		cmbMethods.itemObject[index] := meth;
	endwhile;
	
	index := cmbMethods.addItem(" &lt;Please select a special method&gt;");
	cmbMethods.itemObject[index] := null;
	cmbMethods.listIndex := 1;
	
epilog
	
	delete iter;		// PAR #27874
	delete meths;
end;</source>
    </JadeMethod>
    <JadeMethod name="setButtons" id="eefeddba-ee87-405e-b1ad-fb892474d468">
        <source>setButtons();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2011	cnwndl1	Initial creation	Par 27438

*/

vars

	obj : Object;

begin

	self.btnRun.enabled := false;
	self.btnPrint.enabled := false;
	self.btnFile.enabled := false;

	obj := cmbMethods.listObject;	
	if obj = null then
		//do nothing
	elseif obj.isKindOf(Method) then
		self.btnRun.enabled := true;
	endif;
	
	if txtOutput.text.trimBlanks &lt;&gt; null then
		self.btnPrint.enabled := true;
		self.btnFile.enabled := true;
	endif;

	// TFS 2101 CNWAB1
	if not app.myCurrentUserCan(null, self.permissionMaint) then
		self.btnRun.enabled := false;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="be91367d-3f72-4135-b529-16c4a112e9b6">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2011	cnwndl1	Initial creation	Par 27438

*/

vars

begin

	inheritMethod();
	
	self.caption := "System Supervisor Special Methods form";
	create self.myFixupHandlerAgent transient;
	self.myFixupHandlerAgent.zSetMyForm( self );
	
	self.populateCmbMethods();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="5634bbf5-e78e-47aa-8b01-b7162fa622e1">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017365, locale);
	btnClose.translateBubbleHelp(Xlat_0016032, locale);
	btnClose.translateCaption(Xlat_0016033, locale);
	btnFile.translateBubbleHelp(Xlat_0016034, locale);
	btnFile.translateCaption(Xlat_0016035, locale);
	btnPrint.translateBubbleHelp(Xlat_0016036, locale);
	btnPrint.translateCaption(Xlat_0016037, locale);
	btnRun.translateBubbleHelp(Xlat_0016038, locale);
	btnRun.translateCaption(Xlat_0016039, locale);
	lblOutput.translateCaption(Xlat_0016040, locale);
	lblParameters.translateCaption(Xlat_0016041, locale);
	lblRepair.translateCaption(Xlat_0016042, locale);
	txtParams.translateBubbleHelp(Xlat_0018768, locale);
end;</source>
    </JadeMethod>
