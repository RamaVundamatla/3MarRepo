    <JadeMethod name="pxyCreateUpdateProxy" id="38ec77f9-3175-445d-b0e2-81f7f1a7c421">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		 PAR 8896 new
//
// ---------------------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxy : SelfType;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	self.allISOTypes.copy(proxy.allISOTypes);
	self.allSubstitutingISOGroups.copy(proxy.allSubstitutingISOGroups); //cnwrd1 par 30414 25.9.2012
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="a4635aee-5a60-4b4a-ab74-b48f8c8521e2">
        <updating/>
        <source>setForCreate(pProxyISOTypeGroup:CM_ISOTypeGroup) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 01 Jun 2010	cnwkpd1		PAR #23525 - System performance enhancements
// ---------------------------------------------------------------------------
vars
	agent		: CM_ObjectVolatilityConverter;
	
begin

	setForUpdate(pProxyISOTypeGroup);
	
	// PAR #23525 - If system is using stable objects, then need to change the volatility of
	// the newly created object's collections
	if app.myRoot.useStableObjects then
		create agent transient;
		agent.newVolatility := Volatility_Stable;
		agent.multipleTransactions := false;
		
		self.doObjectVolatilityConversion(agent, 1);
	endif;

	self.myRoot := app.myRoot;

	
epilog
	delete agent;
	
end;</source>
        <Parameter name="pProxyISOTypeGroup" type="CM_ISOTypeGroup"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="83a9b1cd-1d22-4cf9-9c06-b72e20f24f9f">
        <updating/>
        <source>setForUpdate(pProxyISOTypeGroup:CM_ISOTypeGroup) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 05/09/2024	jlizm1		TFS 65952 NSW Dynamics Integration - ISO Type Group and Cargo Type external references
// ---------------------------------------------------------------------------
vars
	isoType	:	CM_ISOType;
begin
	self.code 				:= pProxyISOTypeGroup.code.trimBlanks;
	self.description 		:= pProxyISOTypeGroup.description.trimBlanks;
	self.reportGroupOrder	:= pProxyISOTypeGroup.reportGroupOrder;
	self.colour				:= pProxyISOTypeGroup.colour;
	self.externalReference1	:= pProxyISOTypeGroup.externalReference1;
	self.externalReference2	:= pProxyISOTypeGroup.externalReference2;
	// CCMS 1496
	self.maxTareWeight		:= pProxyISOTypeGroup.maxTareWeight;
	self.maxTotalWeight		:= pProxyISOTypeGroup.maxTotalWeight;
	
	 // PAR 8896 - dettach
	foreach isoType in self.allISOTypes do // PAR 8896 added
		isoType.setMyISOTypeGroup(null); // PAR 8896 added
	endforeach;
	// attach
	foreach isoType in pProxyISOTypeGroup.allISOTypes do
		isoType.setMyISOTypeGroup(self);
	endforeach;
	
	//cnwrd1 par 30414 25.9.2012
	self.allSubstitutingISOGroups.clear;
	pProxyISOTypeGroup.allSubstitutingISOGroups.copy(self.allSubstitutingISOGroups);
end;</source>
        <Parameter name="pProxyISOTypeGroup" type="CM_ISOTypeGroup"/>
    </JadeMethod>
    <JadeMethod name="setMyRoot" id="a13c17eb-5c1b-44cb-a10e-33271ea6eab3">
