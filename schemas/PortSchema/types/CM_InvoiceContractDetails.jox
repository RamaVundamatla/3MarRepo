    <JadeMethod name="validateForCreate" id="9a7fcdbb-6a7f-4037-aea7-e6bb090ff25f">
        <source>validateForCreate();
/*
Purpose:			

Date		Who		Reason
01 December 2022	navab1	TFS CR 55623 TASK 55673
15 Feb 2023 navtnr20	TFS CR 55646	Task 55665: UI - Contract Details
*/

vars
begin
	self.validateForMe();
	
	if self.myInvoiceContract &lt;&gt; null then
		if self.myInvoiceContract.fromTS &gt; self.fromTS then // my from TS must be within the contract's from TS
			app.raiseCMException2(Contr_detai_from_datet_must_wi,
				self.systemToLocalTime(self.myInvoiceContract.fromTS).shortCurrentLocaleFormat(),
				self.systemToLocalTime(self.fromTS).shortCurrentLocaleFormat(),
				null,null);
		endif;
		
		if self.myInvoiceContract.toTS &lt; self.toTS then // my to TS must be within the contract's to TS
		
			app.raiseCMException2(Contr_detai_datet_must_withi_c,
				self.systemToLocalTime(self.myInvoiceContract.toTS).shortCurrentLocaleFormat(),
				self.systemToLocalTime(self.toTS).shortCurrentLocaleFormat(),
				null,null);
		endif;
	endif;
	
	if self.myInvoiceContractCriteria = null then
		//if self.myInvoiceContractCriteria.allCriteria.isEmpty() then  //navtnr20 15-02-2023 TFS 55665
			app.raiseCMWarning(Crite_been_enter_contr_detai_t, null, null, null);
		//endif;	//navtnr20 15-02-2023 TFS 55665
	else
		self.myInvoiceContractCriteria.validateForCreate();
	endif;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="35be424d-0b92-49bb-a1ce-5f9d07175ef1">
        <source>validateForDelete();
/*
Purpose:			

Date		Who		Reason
01 December 2022	navab1	TFS CR 55623 TASK 55673
16 October 2023 navmv20 Bug 60896: FR | 54089 - Invoice Contracts - Rate audit trail
25 July    2024 navrv30 Bug 65128: FR | 54089 - Invoice Contracts - Deletion of a Debtor with used rates
*/

vars
	contractRate : CM_InvoiceContractRate; //16/10/2023 navmv20 Bug 60896
begin
	//16/10/2023 navmv20 Bug 60896 - start
	if not app.isJMTUnitTest then
	
	/* / ### JIRA 33307 19NOV2024 NAVAB1
		foreach contractRate in self.allInvoiceContractRates do
			if contractRate.myService &lt;&gt; null and contractRate.myService.charges.isNotEmpty then
				app.raiseCMException1(Cannot_delete_been_used_invoic,self.auditId(),null,null);
			endif;
		endforeach;
		*/
		// ### JIRA 33307 19NOV2024 NAVAB1
		if self.allInvoiceLines.isNotEmpty then
			app.raiseCMException1(Cannot_delete_been_used_invoic,self.auditId(),null,null);
		endif;
	endif;
	//16/10/2023 navmv20 Bug 60896 - end
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForMe" id="2964b5f5-c40c-4f14-b8b4-e2070e1b2b0e">
        <source>validateForMe();
/*
Purpose:			

Date		Who		Reason
01 December 2022	navab1	TFS CR 55623 TASK 55673
*/

vars
	contract : SelfType;
	rate : CM_InvoiceContractRate;
begin
	if self.contractType = null then
		app.raiseCMException(Invoi_contr_detai_contr_type_m,null,null);
	endif;
	
	if self.contractType &lt;&gt; INV_CONTRACT_TYPE_STANDARD
	and self.contractType &lt;&gt; INV_CONTRACT_TYPE_VOLUME_BASED   then
		app.raiseCMException1(Contra_detail_type_invali_shou,"1,2", null,null);
	endif;
	
	if self.myCalculationType = null then
		app.raiseCMException(Calcu_type_contr_detai_must_en,null,null);
	endif;
	
	if self.myInvoiceContract = null then
		app.raiseCMException(Contra_must_given_contra_detai,null,null);
	endif;
	
	if self.myInvoiceLineType = null then
		app.raiseCMException(Invoi_line_type_contr_detai_mu,null,null);
	endif;
	
	if self.fromTS = null then
		app.raiseCMException(Invoi_contr_detai_from_date_ti, null, null);
	elseif self.fromTS &gt; self.toTS then
		app.raiseCMException(Invoi_contr_detai_from_date898,null,null);
	elseif self.fromTS &lt; self.systemToLocalTime(app.actualTimeServer).subtractYears(100) then
		app.raiseCMWarning(Invoi_contr_detai_from_date_88, null, null, null);
	endif;
	
	if self.toTS = null then
		app.raiseCMException(Invoi_contr_detai_date_time_mu, null, null);
	elseif self.toTS &lt; self.fromTS then
		app.raiseCMException(Invoi_contr_detai_date_time_ca,null,null);
	elseif self.toTS &gt; self.systemToLocalTime(app.actualTimeServer).addYears(100) then
		app.raiseCMWarning(Invoi_contr_detai_date_time_88, null, null, null);
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="4cb87ae5-de81-48ee-ad8d-6164013c5db6">
        <source>validateForUpdate();
/*
Purpose:			

Date		Who		Reason
01 December 2022	navab1	TFS CR 55623 TASK 55673
15 Feb 2023 navtnr20	TFS CR 55646	Task 55665: UI - Contract Details
*/

vars
	endDate,startDate : TimeStamp;
	rateEntry : CM_InvoiceContractRateEntry;
	realMe : SelfType;
	rate : CM_InvoiceContractRate;
	detail : CM_InvoiceContractDetails;
begin
	self.validateForMe();
	
	if self.myInvoiceContract &lt;&gt; null then
		if self.myInvoiceContract.fromTS &gt; self.fromTS then // my from TS must be within the contract's from TS
			app.raiseCMException2(Contr_detai_from_datet_must_wi,
				self.systemToLocalTime(self.myInvoiceContract.fromTS).shortCurrentLocaleFormat(),
				self.systemToLocalTime(self.fromTS).shortCurrentLocaleFormat(),
				null,null);
		endif;
		
		if self.myInvoiceContract.toTS &lt; self.toTS then // my to TS must be within the contract's to TS
		
			app.raiseCMException2(Contr_detai_datet_must_withi_c,
				self.systemToLocalTime(self.myInvoiceContract.toTS).shortCurrentLocaleFormat(),
				self.systemToLocalTime(self.toTS).shortCurrentLocaleFormat(),
				null,null);
		endif;
	endif;
	
	if self.myInvoiceContractCriteria = null then
		//if self.myInvoiceContractCriteria.allCriteria.isEmpty() then	 //navtnr20 15-02-2023 TFS 55665
			app.raiseCMWarning(Crite_been_enter_contr_detai_t, null, null, null);
		//endif;	//navtnr20 15-02-2023 TFS 55665
	else
		self.myInvoiceContractCriteria.validateForUpdate();
	endif;
	
	// Start navtnr20 10-03-2023 bug 56908 
	
	realMe := self.pxyGetRealObject();
	foreach rate in realMe.allInvoiceContractRates discreteLock do
		foreach rateEntry in rate.allInvoiceContractRateEntries discreteLock do
			if rateEntry.fromTS &lt; self.fromTS or rateEntry.toTS &gt; self.toTS then  // ### TFS BUG 56908 15MAR2023 NAVAB1
				app.raiseCMException3(Contr_date_range_confl_with_ra,self.fromTS.shortCurrentLocaleFormat,self.toTS.shortCurrentLocaleFormat,rateEntry.auditId,null,null);
 // ### TFS BUG 56908 15MAR2023 NAVAB1				break;
			endif;
		endforeach;
	
	endforeach;
	// End navtnr20 10-03-2023 bug 56908 
epilog
end;</source>
    </JadeMethod>
</Class>
