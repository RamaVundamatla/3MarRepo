	self.makeDepCarrTypeSubSectXML( _ti, rootElem );
	
	self.makeDepCarrTruckSubSectXML( _ti, rootElem );
	
	self.makeDepCarrVesselSubSectXML( _ti, rootElem );
	
	
epilog

end;</source>
