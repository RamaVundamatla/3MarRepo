    <JadeMethod name="getProposedVisiblity" id="d29a4b45-476a-44b2-867c-c7ac86659991">
        <source>getProposedVisiblity(_colour : Integer output): Boolean;
/*
Purpose:			
Date		Who		Reason
21 September 2011	cnwab1	Initial creation
*/

vars
	req : CM_RORORequest;
	slotLC : CM_ROROGCController;
	theTI : CM_TrackedItem;
	aWLE : CM_WorkListEntry;
	tis : CM_TIArray;
	defn : CM_DeckItem;
	slot : CM_ROROSlotDefn;
	isComp, found : Boolean;
begin
	_colour := White;

	if not  self.isLoad then
		return false;
	endif;
	
// PAR 31073	if self.isComplete then 
// PAR 31073		return false;
// PAR 31073	endif;
	
	
	// ### Load Colour Coding
	foreach aWLE in self.allWorkListEntries discreteLock do
		// If load CC has a TI it is planned
		if aWLE.myTrackedItem &lt;&gt; null then
			found := true;
			_colour := self.getAllocationColour(); 
			
			if aWLE.status = WLE_COMPLETED then // PAR 31073
				isComp := true;//  PAR 31073
			endif;
		endif;
	endforeach;
	if found then
		if isComp then
			return false;
		else
			return true;
		endif;
	endif;

	// PAR 30944
	// #### When we 'cover' standard positions with load CC, we actually only cover with 1 of the load requests in each OOTL stack.
	// #### If that request is unplanned, but the other requests are planned,  the above code does not accommodate that there are other requests in the stack that are still planned.
	// #### We are in this method because this request is the one that is covering the standard position, but at this point it does not have a planned TI.
	// #### If we have got to this position we have to go through the stack to see if any of the items are planned.
	create tis transient;
	defn := self.myROROController.getDefn();
	if defn &lt;&gt; null then
		defn.getProposedTIs(tis,true); // do this incase we are a 20 under a 40 or a 40 on top of a 20.
		if not tis.isEmpty() then
			_colour := self.getAllocationColour(); 
			return true;
		endif;
	endif;

	return false; // do not show 

epilog
	delete tis;
end;</source>
        <Parameter name="_colour" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleAllWLEsComplete" id="07a14873-46f0-4c3e-a146-7eee4237962a">
        <updating/>
        <source>handleAllWLEsComplete() updating;
/*
Purpose:	If the load request is complete and we are for a OOTL then move the OOTL defn layout to the OOTL Cargo layer		
Purpose:	If the discharge request is complete and we are for a OOTL then hide the OOTL defn layout 
Date		Who		Reason
31 August 2011	cnwab1	Initial creation
*/

vars
	layer, newLayer, cargoLayer : CM_DeckLayerLayout;
	defn : CM_DeckItem;
		lc : CM_VoyageROROController;
	voy : CM_Voyage;
	is40 : Boolean;
	aftReq : CM_ROROSlotRequest;

begin
	if self.isLoad and self.isComplete then
		if self.myLayout &lt;&gt; null then
			defn := self.myROROController.getDefn();
			// only if we are an non standard OOTL locn
			if defn &lt;&gt; null and defn.isOOTL() then
			
				layer := self.myLayout.myDeckLayer; // Load CC Layer
				if layer &lt;&gt; null and layer.myDeckLayout &lt;&gt; null then
					newLayer := layer.myDeckLayout.getOOTLLayer(); // The actual OOTL Cargo Layer
					if newLayer &lt;&gt; null then
						defn.myLayout.setMyDeckLayer(newLayer);
					endif;
				endif;

				// PAR 30231
				cargoLayer := self.myROROController.myDeck.myDeckLayout.getCargoLayer();
				if cargoLayer &lt;&gt; null then
					cargoLayer.hideContainerPositionsUnderGA(defn.myLayout);
				endif;
			
				// PAR 30996 - move the aft to the ACTUAL OOTL cargo layer
				is40 := self.getAttrIs40();
				if is40 then
					aftReq := self.mySlotRequestAft;
					if aftReq &lt;&gt; null then
						defn := aftReq.myROROController.getDefn();
						defn.myLayout.setMyDeckLayer(newLayer);
						// PAR 31116
						if cargoLayer &lt;&gt; null then
							cargoLayer.hideContainerPositionsUnderGA(defn.myLayout);
						endif;
						
						
					endif;
				endif;
				
				
				// PAR 29807 update the RORO Planning. This will add the new OOTL layer as necessary
				lc := self.myROROController;
				voy := lc.myVoyage;
				app.myEventManager.createSingleObjInfoNoteEvt(voy,voy.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA),	lc);
				
			endif;
		endif;
	elseif self.isDischarge and self.isComplete then
		defn := self.myROROController.getDefn();
		if defn &lt;&gt; null and defn.isOOTL() then
			if defn.handleAllWLEsComplete(false) then // PAR 30656
				defn.myLayout.hideMe(); // this will stop any moves to the LC, see CM_LC::testIsControllerAvailable
				defn.myLayout.showAllCoveredPolygons();// PAR 30231
				//epr par 29079 also need to hide the linked aft/fwd for OOTL
				if defn.CM_ROROLocnDefn.myAdjacentSlotFwd &lt;&gt; null then
					defn.CM_ROROLocnDefn.myAdjacentSlotFwd.myLayout.hideMe();
					defn.CM_ROROLocnDefn.myAdjacentSlotFwd.myLayout.showAllCoveredPolygons();// PAR 30231
				endif;
				if defn.CM_ROROLocnDefn.myAdjacentSlotAft &lt;&gt; null then
					defn.CM_ROROLocnDefn.myAdjacentSlotAft.myLayout.hideMe();
					defn.CM_ROROLocnDefn.myAdjacentSlotAft.myLayout.showAllCoveredPolygons();// PAR 30231
				endif;
			endif;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="isBackEndRequest" id="974119e8-dd94-42db-8a84-b8427e902899">
        <source>isBackEndRequest() : Boolean;
/*
Purpose:			
Date				Who			Reason
JULY 2011		CNWAB1		Initial creation
*/

vars
begin

	// if we have a forward slot request must currently be on the backend
	return (self.mySlotRequestForward &lt;&gt; null);
	

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isMoveable" id="50d70bc7-f3b7-4052-8003-94d2c0171090">
        <source>isMoveable(): Boolean;
/*
Purpose:			
Date		Who		Reason
12 October 2011	cnwab1	Initial creation
*/

vars
	theDefn : CM_DeckItem;
begin

	theDefn := self.myROROController.getDefn();
	if theDefn = null then
		return false;
	endif;
	
	if theDefn.isOOTL() then
		return (not self.isComplete);
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isRehandle" id="b777323e-895b-414c-8cdb-b4801d0c6e7f">
        <methodInvocation>mapping</methodInvocation>
        <source>isRehandle(set: Boolean; _value: Boolean io) mapping;
/*
Purpose:			
Date		Who		Reason
09 September 2011	cnwab1	Initial creation
*/

vars

begin
	if self.isBackEndRequest() then
		_value :=  self.mySlotRequestForward.moveType = DLR_MOVETYPE;
	else
		_value :=  self.moveType = DLR_MOVETYPE;
	endif;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
