    <JadeMethod name="isCMIFDataMatch" id="8d199265-c2d8-49f1-be3a-ff1d33707959">
        <source>isCMIFDataMatch(_cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YADataBoolean): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 September 2012	cnwer1	Initial creation SFW 1295

*/

vars
	
begin
	return _yaData.value = null or _cmifAutoPlan.isDamaged_Match(_yaData);

epilog

end;</source>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <Parameter name="_yaData" type="CM_YADataBoolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
