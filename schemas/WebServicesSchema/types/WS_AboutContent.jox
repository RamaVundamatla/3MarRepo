<Class name="WS_AboutContent" id="0116bbe4-7f75-47db-bfac-30d33d179f8c">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Product name, product version, environment name and copyright notice.</text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="content" id="5005da94-39e8-4143-8e92-3da1c8ab498d">
        <type name="String"/>
        <access>readonly</access>
        <text>Product name, product version, environment name and copyright notice.</text>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="b0379e8e-a4e7-45e3-83b4-6a0475e178e1">
        <updating/>
        <source>setProxyFromObject(_object: Object) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 Feb 2009	cnwdz2	 
12 Jun 2009	cnwkpd1	Get version number from CM_Root::versionString
1  Sep 2009 cnwdz2  PAR20566 Add contents to the About JMT tab of the Options window.
21 Jun 2013	cnwkpd1	Add environment name to About content
13 Apr 2021	navmd1	TFS 51086 JADE 2020 Fixes
*/

constants
	FontFamily		= 'font-family:verdana,arial,sans serif;';
	FontSize		= 'font-size:11px;';
	LeftAlign		= 'left: -60px;';
	WidthString		= 'width: 450px;';
	
vars
	userName	: String;
	lDate		: Date;
	envName		: String;
	
begin
	inheritMethod(_object);
	if currentSession.myUser &lt;&gt; app.myPublicUser then
		userName :=  currentSession.myUser.userName;
	else
		userName := 'Anonymous';
	endif;
	
	//envName := app.cnGetEnvironmentId(app.dbPath).toUpper;
	envName := app.getEnvName().toUpper;	// TFS 51086
	
	self.content := '&lt;div style="position: absolute; top: 0px; ' &amp; LeftAlign &amp; ' ' &amp; FontFamily &amp; ' ' &amp; FontSize &amp; ' ' &amp; WidthString &amp; ' font-weight:bold;"&gt;Master Terminal&lt;/div&gt;' &amp;
					'&lt;div style="position: absolute; top: 25px; ' &amp; LeftAlign &amp; ' ' &amp; FontFamily &amp; ' ' &amp; FontSize &amp; ' ' &amp; WidthString &amp; '"&gt;Environment: ' &amp; envName &amp; '&lt;/div&gt;' &amp;
					'&lt;div style="position: absolute; top: 50px; ' &amp; LeftAlign &amp; ' ' &amp; FontFamily &amp; ' ' &amp; FontSize &amp; ' ' &amp; WidthString &amp; '"&gt;User Name: ' &amp; userName &amp; '&lt;/div&gt;' &amp;
					'&lt;div style="position: absolute; top: 75px; ' &amp; LeftAlign &amp; ' ' &amp; FontFamily &amp; ' ' &amp; FontSize &amp; ' ' &amp; WidthString &amp; '"&gt;' &amp; app.getCopyrightLine &amp; '&lt;/div&gt;' &amp;
					'&lt;div style="position: absolute; top: 100px; ' &amp; LeftAlign &amp; ' ' &amp; FontFamily &amp; ' ' &amp; FontSize &amp; ' ' &amp; WidthString &amp; '"&gt;All Rights Reserved&lt;/div&gt;';
					
					
		
epilog

end;</source>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
</Class>
