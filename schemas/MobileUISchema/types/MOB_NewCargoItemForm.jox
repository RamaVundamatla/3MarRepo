    <JadeMethod name="doSave" id="70e3128b-ce3d-47f0-8de2-2cf50ad45454">
        <updating/>
        <source>doSave():Boolean updating;
// ---------------------------------------------------------------------------
// Created:     15 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpCargoType		: CM_CargoBOLType;
	cmifCommon 			: CMIF_InOutCommon;
begin
	if myMobileDataAgent.myRoadJob &lt;&gt; null then // dh par 17068
		create self.myIntFacePrenote transient;
	else
		create self.myIntFacePrenote as CMIF_PreNote transient;
		self.myIntFacePrenote.CMIF_PreNote.transportMode := TI_TRANSMODE_ROAD_STR;
	endif;
	
	tmpCargoType := self.cmb_CargoType.listObject.CM_CargoBOLType;
	if tmpCargoType &lt;&gt; null then
		myIntFacePrenote.cargoType := tmpCargoType.id;
	endif;
	self.myIntFacePrenote.weightTotal := self.txt_Weight.text.Integer; 
	self.myIntFacePrenote.myProduct := self.cmb_Product.listObject.CM_Product;
	self.myIntFacePrenote.operatorCode := self.cmb_Operator.text;
	self.myIntFacePrenote.id := self.txt_CargoID.text;
	self.myIntFacePrenote.mark := self.txt_Mark.text;
	self.myIntFacePrenote.myTerminal := myMobileDataAgent.myTerminal;
	self.myIntFacePrenote.setWasCreatedFromMobApp();
// now only validate location if it has been entered
	if txt_Location.text &lt;&gt; null then
		myNewLocation := myMobileDataAgent.findAndVerifyLocation(txt_Location.text.trimBlanks.toUpper);
		if myNewLocation = null then
			return false;
		endif;
		self.myIntFacePrenote.yardLocationTxt := myNewLocation.getFullId;
	endif;	
	if myMobileDataAgent.myRoadJob &lt;&gt; null then
		create cmifCommon transient;
		cmifCommon.setFromRoadJob(myMobileDataAgent.myRoadJob, myMobileDataAgent.myTerminal);
		self.myIntFacePrenote.setMyInOutCommon(cmifCommon);
	endif;
	app.myPassport.clearErrorsWarnings;
	myIntFacePrenote.validateForCreate(app.myPassport);
	if checkAndShowErrors then
		delete myIntFacePrenote;
		return false;
	endif;


	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="filterCargoType" id="eed5e553-4b4a-4067-969f-5aaa9c8eea59">
        <source>filterCargoType(_type: CM_CargoType): Boolean;
/*
	Created on 19 May 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	return _type.CM_CargoType.classNameToCreate = "CM_BreakBulkGeneric" ;

end;</source>
        <Parameter name="_type" type="CM_CargoType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
