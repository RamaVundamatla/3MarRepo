    <JadeMethod name="doSave" id="83201d20-7b21-4664-9829-8233354edbe8">
        <updating/>
        <source>doSave(): Boolean updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25/06/2009	cnwndl1	Initial creation
05/03/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars
	
	theForm : SOP_TableMaintForm;
	errObj : CM_Error;
	allowHiCube : Boolean;
	code : String;
	description : String;
	maxHeight : Decimal [12,2];
	maxWeightWagon : Decimal [12,2];
	maxWeight : Decimal [12,2];
	maxWidth : Decimal [12,2];
	isNotAvailableForEntry : Boolean;
	noMTs : Boolean;
	proxyTrackClearance : CM_TrackClearance;
	rtnValue : Boolean;
	
begin

	theForm := self.myForm; 

	code := theForm.tblInput1.getValueByName(ETRow_Code).String;
	description := theForm.tblInput1.getValueByName(ETRow_Description).String;
	maxHeight := theForm.tblInput1.getValueByName(ETRow_MaxHeight).Decimal;
	maxWeightWagon := theForm.tblInput1.getValueByName(ETRow_MaxWeightWagon).Decimal;
	maxWeight := theForm.tblInput1.getValueByName(ETRow_MaxWeight).Decimal;
	maxWidth := theForm.tblInput1.getValueByName(ETRow_MaxWidth).Decimal;
	allowHiCube := theForm.tblInput1.getValueByName(ETRow_AllowHiCube).Boolean;
	noMTs := theForm.tblInput1.getValueByName(ETRow_NoEmptyWagons).Boolean;
	isNotAvailableForEntry := theForm.tblInput1.getValueByName(ETRow_IsNotAvailableForEntry).Boolean;
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_TrackClearance transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(Proxy_Object_Null_For_Update) );
			return false;
		endif;
	endif;

	proxyTrackClearance := theForm.myProxyObject.CM_TrackClearance;
	proxyTrackClearance.setProxy(	allowHiCube,	//_allowHiCube : Boolean;
									code,	//_code : String;
									description,	//_description : String;
									maxHeight,	//_maxHeight : Decimal;
									maxWeightWagon,	//_maxWeightWagon : Decimal;
									maxWidth,	//_maxWidth : Decimal;
									isNotAvailableForEntry, //_isNotAvailableForEntry : Boolean
									maxWeight, // Decimal
									noMTs // Boolean
									);

	theForm.tblInput1.setProxyFromMeasureTables(proxyTrackClearance);			// PAR #31155
	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateTrackClearance(proxyTrackClearance, theForm.myCurrentObject, app.myPassport);
		rtnValue := app.myPassport.trxCompletedOK;
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateTrackClearance(proxyTrackClearance, app.myPassport);
		rtnValue := app.myPassport.trxCompletedOK;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(ERR_INVALID_MODE) &amp; ' (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return rtnValue;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
