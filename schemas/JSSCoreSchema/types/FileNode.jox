    <JadeMethod name="jssIsFile" id="be7ee8d2-2152-449c-b7c3-827df564cc54">
        <source>jssIsFile(): Boolean;
// -----------------------------------------------------------------------------
// Created:		22 January 2002 by cnwdad1
//
// Purpose:		Returns a flag to indicate whether the receiver is a File object.
//
// Parameters:	None
//
// Returns:		True if the receiver is a file, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
