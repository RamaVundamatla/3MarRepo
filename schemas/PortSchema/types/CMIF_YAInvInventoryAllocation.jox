    <JadeMethod name="isCargoType_Match" id="d988b6ee-d955-4ef9-aff6-bab5b4ceab09">
        <source>isCargoType_Match(_yaData: CM_YADataObjects): Boolean;
/*
Purpose:			

Date		Who		Reason
24MAY2021	NAVAB1	TFS 51219
*/

vars
	ct : CM_CargoType;
begin

	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	ct := app.myRoot.allCargoTypesById[self.myLocationEvent.cargoType];
	if ct = null then
		return false;
	endif;
	
	// Do we have a match?
	if _yaData.matches(ct) then
		return true;
	endif;
	
	return false;


end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isCarrier_Match" id="b23ed9a4-7f37-489b-ae03-8eb32eb7b677">
        <source>isCarrier_Match(_yaData: CM_YADataObjects): Boolean;
/*
Purpose:			

Date		Who		Reason
24MAY2021	NAVAB1	TFS 51219
*/


vars
	carrier : CM_Carrier;
	
begin

	carrier := app.myRoot.allCarriers[self.myLocationEvent.carrierCode];
	if carrier = null then
		return false;
	endif;
	
	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	return _yaData.matches(carrier);

epilog

end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
