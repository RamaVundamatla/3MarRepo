    <JadeMethod name="displayDefaultFields" id="acbdd257-55a7-4eee-a0e9-6422d79d26bc">
        <source>displayDefaultFields();
/*
Purpose:			

Date		Who		Reason
01JUL2021	NAVAB1	TFS 51361
*/


vars
	idx : Integer;
	entDefAll, entDefUsed : EntTableDef;
	entRow : EntTableRow;
begin
	self.lstFieldsAvailable.clear();
	self.lstFieldsUsed.clear();
	
	entDefUsed := app.myController.getEntTableDef(ETDef_ReeferAPIDefault);
	entDefAll := app.myController.getEntTableDef(ETDef_ReeferAPIAll);
	
	self.lstFieldsAvailable.sorted := true;
	self.lstFieldsUsed.sorted := false;

	foreach entRow in entDefAll.allEntTableRows do
		if entDefUsed.getRowByName(entRow.name) &gt; 0 then
			continue;
		endif;
		
		idx := self.lstFieldsAvailable.addItem(self.getRowHeading(entRow));
		self.lstFieldsAvailable.itemObject[idx] := entRow;
	endforeach;
	
	foreach entRow in entDefUsed.allEntTableRows do
		if entRow.isGroupRow then
			idx := self.lstFieldsUsed.addItem(app.getErrorString(Etrow_newLine));
			self.lstFieldsUsed.itemObject[idx] := entRow;

			self.lstFieldsUsed.itemBackColor[idx] := DarkGray;
			self.lstFieldsUsed.itemForeColor[idx] := White;
		else
		
	
			idx := self.lstFieldsUsed.addItem(self.getRowHeading(entRow));
			self.lstFieldsUsed.itemObject[idx] := entRow;
		endif;
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayUsedFields" id="8a636825-9790-46b5-8fb8-87b9c5003c5d">
        <source>displayUsedFields();
/*
Purpose:			

Date		Who		Reason
01JUL2021	NAVAB1	TFS 51361
*/


vars
	idx : Integer;
	entDefAll, entDefUsed : EntTableDef;
	entRow : EntTableRow;
begin

	
	entDefUsed := app.myController.getEntTableDef(ETDef_ReeferAPI);
	entDefAll := app.myController.getEntTableDef(ETDef_ReeferAPIAll);
	
	self.lstFieldsAvailable.sorted := true;
	self.lstFieldsUsed.sorted := false;

	foreach entRow in entDefAll.allEntTableRows do
		if entDefUsed.getRowByName(entRow.name) &gt; 0 then
			continue;
		endif;
		
		idx := self.lstFieldsAvailable.addItem(self.getRowHeading(entRow));
		self.lstFieldsAvailable.itemObject[idx] := entRow;
	endforeach;
	

	foreach entRow in entDefUsed.allEntTableRows do
		if entRow.isGroupRow then
			idx := self.lstFieldsUsed.addItem(app.getErrorString(Etrow_newLine));
			self.lstFieldsUsed.itemObject[idx] := entRow;

			self.lstFieldsUsed.itemBackColor[idx] := DarkGray;
			self.lstFieldsUsed.itemForeColor[idx] := White;
		else
		
			idx := self.lstFieldsUsed.addItem(self.getRowHeading(entRow));
			self.lstFieldsUsed.itemObject[idx] := entRow;
		endif;
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="a44f93d1-3ce8-4ce7-9eb4-1afaa412c2ed">
        <updating/>
        <source>doOK() updating;
/*
Purpose:			


01 July 2021	navab1		TFS 51361
*/

vars
	theReturn : Integer;
	newtext : String;

begin
	if not self.validate() then
		return;
	endif;

	app.mousePointer := MousePointer_HourGlass;

	
	self.setNewLines();
	newtext := self.getNewENTDEFText();
	
	
	while true do
		app.myTrxUA.trxUpdateReeferAPILayout(newtext, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			app.msgBox(app.getErrorString(Nreef_field_saved_layou_shown_), app.getErrorString(Updated), MsgBox_OK_Only);
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Nreefer_layout), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		
		break;
	endwhile;



epilog
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="getNewENTDEFText" id="50bb80de-e2ae-4bb9-bcc5-f29838c7ec76">
        <source>getNewENTDEFText() : String;
/*
Purpose:			


01 July 2021	navab1		TFS 51361
*/

vars
	firstPart, lastPart, newtext : String;
	idx, numrows : Integer;
	entRow : EntTableRow;
begin


firstPart:= "&lt;EntTableDef&gt;
&lt;DefName&gt;reeferAPI&lt;/DefName&gt;
&lt;Descr&gt;&lt;/Descr&gt;
&lt;ConstantName&gt;ETDef_ReeferAPI&lt;/ConstantName&gt;
&lt;GroupName&gt;ReeferAPI&lt;/GroupName&gt;
&lt;Rows&gt;";
lastPart := "&lt;/Rows&gt;
&lt;/EntTableDef&gt;";

	newtext := newtext &amp; firstPart;

	numrows := self.lstFieldsUsed.listCount();
	
	foreach idx in 1 to numrows do
		entRow := self.lstFieldsUsed.itemObject[idx].EntTableRow;

		newtext := newtext &amp; CrLf &amp;  "&lt;RowName&gt;" &amp; entRow.name &amp; "&lt;/RowName&gt;";
	endforeach;
	
	newtext := newtext &amp; CrLf &amp; lastPart;
	
	return newtext;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRowHeading" id="5d07a5d2-de5b-4af2-8969-34d7b63c49bc">
        <source>getRowHeading(_row : EntTableRow) : String;
/*
Purpose:			


06 July 2021	navab1		TFS 51361
*/

vars
	suffix : String;
begin
		suffix := "";
		if _row.inputType = EntTableRow.InputTypeWeb_ReadOnly then
			suffix := " " &amp; app.getErrorString(ReefeAppReadOnly);
		endif;
		
		return _row.getHeading(null,self.myTerminal, app.myCurrentLocale) &amp; suffix;

epilog

end;</source>
        <Parameter name="_row" type="EntTableRow"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setNewLines" id="4c2730d4-8a72-40b5-a3bb-e0f476c32ae1">
        <source>setNewLines();
/*
Purpose: When adding a new line in the UI we always use ETRow_Div1. This method changes this to Div1, Div2, Div3 etc.


01 July 2021	navab1		TFS 51361
*/

vars
	idx, numrows, numlines, rowcount : Integer;
	entRow : EntTableRow;
	result : Boolean;
	newLineRows : StringArray;
	entGrp : EntTableGroup;
begin

	create newLineRows transient;
	
	newLineRows.add(ETRow_Div1);
	newLineRows.add(ETRow_Div2);
	newLineRows.add(ETRow_Div3);
	newLineRows.add(ETRow_Div4);
	newLineRows.add(ETRow_Div5);
	newLineRows.add(ETRow_Div6);
	newLineRows.add(ETRow_Div7);
	newLineRows.add(ETRow_Div8);
	newLineRows.add(ETRow_Div9);
	newLineRows.add(ETRow_Div10);
	
	numrows := self.lstFieldsUsed.listCount();
	entGrp := app.myController.getEntTableGroup(ETGrp_ReeferAPI);
	
	foreach idx in 1 to numrows do
		entRow := self.lstFieldsUsed.itemObject[idx].EntTableRow;
		
		if entRow.isGroupRow then
			numlines := numlines + 1;
			entRow := entGrp.getEntTableRow(newLineRows[numlines]);
			
			self.lstFieldsUsed.itemObject[idx] := entRow;
		endif;
	endforeach;
	

epilog
	delete newLineRows;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="81cb8e7b-c577-4b11-92a2-a84912f71522">
        <updating/>
        <source>setupForm() updating;
/*
Purpose:			

Date		Who		Reason
01JUL2021	NAVAB1	TFS 51361
*/

vars

begin
	inheritMethod();
	
	self.displayUsedFields();

	self.txtTitle.caption := app.getErrorString(System_wide_settings) &amp; CrLf &amp; CrLf &amp; app.getErrorString(Maxim_items_line_maxim_lines_r);

	self.btnCancel.caption := app.getErrorString( Close );
	self.btnOk.caption := app.getErrorString( Save );

	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnAdd.enabled := false;
		self.btnDefaults.enabled := false;
		self.btnMoveDown.enabled := false;
		self.btnMoveUp.enabled := false;
		self.btnNewLine.enabled := false;
		self.btnRemove.enabled := false;
		self.btnOk.enabled := false;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="5e4e4ab6-94e0-43a4-be0d-7b7956f1215a">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 22 July 2021 11:44:30.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0024385, locale);
	btnAdd.translateCaption(Xlat_0024386, locale);
	btnDefaults.translateCaption(Xlat_0024387, locale);
	btnMoveDown.translateCaption(Xlat_0024388, locale);
	btnMoveUp.translateCaption(Xlat_0024389, locale);
	btnNewLine.translateCaption(Xlat_0024390, locale);
	btnRemove.translateCaption(Xlat_0024391, locale);
	lblAvailable.translateCaption(Xlat_0024402, locale);
	lblUsed.translateCaption(Xlat_0024403, locale);
	txtTitle.translateCaption(Xlat_0024392, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="validate" id="8609adc7-a0de-4119-a1dc-57fcc41096ca">
        <source>validate() : Boolean;
/*
Purpose:			


01 July 2021	navab1		TFS 51361
*/

vars
	idx, numrows, groupcount, rowcount : Integer;
	entRow : EntTableRow;
	result : Boolean;
begin
	numrows := self.lstFieldsUsed.listCount();
	result := true;
	
	foreach idx in 1 to numrows do
		entRow := self.lstFieldsUsed.itemObject[idx].EntTableRow;
		
		if entRow.isGroupRow then
			groupcount := groupcount+ 1;
			rowcount := 0;
		else	
			rowcount := rowcount + 1;
			
			if rowcount &gt;= 4 then
				app.msgBox(app.getErrorString(Only_fields_allowed_line),app.getErrorString(Problem), MsgBox_OK_Only + MsgBox_Information_Icon);
				result := false;
				break;
			endif;
		endif;
	endforeach;
	
	if groupcount &gt;= 10 then
		app.msgBox(app.getErrorString(Only_differe_lines_allowed), app.getErrorString(Problem), MsgBox_OK_Only + MsgBox_Information_Icon);
		result := false;
	endif;

	return result;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
