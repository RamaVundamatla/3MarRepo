    <JadeMethod name="utlDeleteOpCarrierCriteria" id="1c0073a5-df22-498a-8094-bdd9cc5f43cc">
        <source>utlDeleteOpCarrierCriteria(_opCarrierCrit : CM_OperatorCarrierCriteria io; _passport : CM_Passport input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/08/2019	jlgdap1		Initial creation TFS 45836 PEN Approved Carrier for ISO Type and Trailer type
//
vars
	operator : CM_Operator;
	updAgent : CM_UtilityUpdateAgent;

begin
	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;

	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(_opCarrierCrit);
		operator := _opCarrierCrit.myOperator;
		create updAgent transient;
		updAgent.myUpdateAuditAgent.audUpdateGeneric(operator, true);
	endif;

	if _passport.noErrors then
		_opCarrierCrit.erase(NORMAL_ERASE);
	endif;
	
	if _passport.noErrors and updAgent &lt;&gt; null then
		updAgent.myUpdateAuditAgent.audUpdateGeneric(operator, false);
	endif;
epilog
	delete updAgent;
end;</source>
        <Parameter name="_opCarrierCrit" type="CM_OperatorCarrierCriteria" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
