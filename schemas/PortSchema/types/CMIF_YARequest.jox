    <JadeMethod name="isLoadPort_Match" id="e4f43056-ee95-4161-b52d-db8228ca567e">
        <source>isLoadPort_Match(_yaData: CM_YADataObjects): Boolean;
// --------------------------------------------------------------------------------
// Created:		13 February 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars

	yaData : CM_YAData;
	yaDataObjs : CM_YADataObjects;
	obj : Object;

begin

	//12 Aug 2016	NDL	TFS 2527
	yaData := self.getExtraCriteriaMatchData( YACriteriaType_LoadPort );

	if yaData &lt;&gt; null and yaData.isKindOf(CM_YADataObjects) then
		yaDataObjs := yaData.CM_YADataObjects;
		if not yaDataObjs.isEmpty then
			obj := yaDataObjs.getFirstObject;
		endif;
		if obj &lt;&gt; null then
			return _yaData.includes(obj);
		endif;
	endif;
		
	return true;
	
end;</source>
