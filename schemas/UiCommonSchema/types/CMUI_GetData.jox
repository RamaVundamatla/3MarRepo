    <JadeMethod name="setupForm" id="181f6962-fc6f-489b-a44e-7e4d28f30303">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	nextTop : Real;
	h : Real;
	w : Real;
begin


	inheritMethod();

	if self.bigSize then
		h := 250;
		w := 350;
	else
		h := 150;
		w := 280;
	endif;
	
	self.height := h;
	self.width := w+3;
	self.minimumHeightX		:= h;
	self.minimumWidthX		:= w+3;
	
	if self.lblTextCaption &lt;&gt; null then
		self.lblText.caption:=self.lblTextCaption;
	endif;
	if self.formCaption &lt;&gt; null then
		self.caption:=self.formCaption ;
	endif;
	
	self.lblText.move(0,3,w,25);
	self.lblText.wordWrap := true;
	
	nextTop := self.lblText.top + self.lblText.height;
	
	if self.msrWeight.visible then
		self.msrWeight.move(0,nextTop,w - 20,22);
		self.msrWeight.setup(Type_Weight, self.backColor);
		self.msrWeight.tabKey := J_key_Tab;
		
	elseif self.txtReadOnly.visible then
		if self.txtReadOnly.text.trimBlanks = null then
			self.txtReadOnly.move(0,nextTop,w,h/5);
		else
			self.txtReadOnly.move(0,nextTop,w,h/3);
		endif;
		
		nextTop := self.txtReadOnly.top + self.txtReadOnly.height+2;
		self.txtData.move(0,nextTop,w,h/3);
	else
		self.txtData.move(0,nextTop,w,h/3);
	endif;
	
	self.handleMenusForModalDisplay();					// 07/12/2011 cnwmh5 #28531 - Dont' want the menus to show when this form is called
	
	self.btnOK.default := true;
	self.btnCancel.cancel := true;
	self.enableEvent("keyDown", false);
	self.txtData.selectionStyle := TextBox.SelectionStyle_SelectAll;
	self.myTerminal	:= app.getMyTerminalDO_NOT_USE();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="867531dd-13cf-4198-bf11-f33f916dce3b">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0013445, locale);
	btnCancel.translateCaption(Xlat_0000427, locale);
	btnOK.translateCaption(Xlat_0000428, locale);
//	lblText.translateCaption(Xlat_0013446, locale);
end;</source>
    </JadeMethod>
</GUIClass>
