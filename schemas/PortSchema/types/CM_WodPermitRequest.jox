    <JadeMethod name="actionItems" id="0ae4cc54-13ae-40d2-bf7c-bc9dd489bf3a">
        <updating/>
        <source>actionItems(_woActionIF: CMIF_WorkOrderAction; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 October 2018	jlger1	Initial creation

*/

vars
	departureDT : TimeStamp;
	voyage : CM_Voyage;
	departure : HMS_VoyageMovement;
	cargoRequest : CM_WodCargoRequest;
	voyStatus  : CM_VoyageStatus;
	
begin
	
	voyage:=self.getMyVoyageObject;
	if self.isAdditionalCargo  then
		//new cargo 
		foreach cargoRequest in self.allCargoDetails discreteLock do
			cargoRequest.actionItems(null,app.myPassport);
		endforeach;
	else
		if self.permitType = INV_WO_PERMIT_CONTINUEPENALTY then // TFS 42221
			self.createCargoTransaction();
			
		endif;
		
	
	
		//epr TFS 41880 13/11/18
		if self.permitDetailType = WO_TASK_MARINEINITIAL then
			departureDT:=self.myParent.CM_WorkOrderVoyage.addLengthOfTimeToDT(self.getMyVoyageObject.arrivedDT);
			voyage.setDepartureDT(departureDT);
			// also change the date on the departure movement
			departure := voyage.myHMSVoyageData.allVoyageMovements.last;
			if departure.moveType = HMSMovementTypeDeparture then
				departure.setOccursOnDT(departureDT);
			endif;
			
			if voyage.myVoyageProcess.isMTNWOProcess then //jlier1 TFS 51963 1/10/21
				voyStatus:=voyage.myVoyageProcess.allStatusesById[Voyage_Status_ServicesPending];
				voyage.setStatusFromObject(voyStatus);
			endif;
			voyage.setTotalTimeInPort(self.myParent.CM_WorkOrderVoyage.lengthOfTime);
			
			
			
		elseif self.permitDetailType = WO_TASK_EXTENSION then
			voyage.setTotalTimeInPort(voyage.totalTimeInPort + self.myParent.CM_WorkOrderVoyage.lengthOfTime);
			//epr TFS 41880 13/11/18
			if self.myPermitWodVoyageDetail &lt;&gt; null then
				self.myPermitWodVoyageDetail.myParent.setLengthOfTime(self.myParent.CM_WorkOrderVoyage.lengthOfTime);
			endif;
		elseif self.permitDetailType = WO_TASK_SHIFTMOVEMENT then
			//epr TFS 41880 13/11/18
			if self.myPermitWodVoyageDetail &lt;&gt; null then
				self.myPermitWodVoyageDetail.myParent.setLengthOfTime(self.myParent.CM_WorkOrderVoyage.lengthOfTime);
			endif;
			
		endif;
		
	
	endif;
	
	
	
	self.setIsComplete;
	
	if self.isAdditionalCargo then
		self.createWorkOrderTransaction(self.getWOTransactionType());	
	endif;
epilog

end;</source>
        <Parameter name="_woActionIF" type="CMIF_WorkOrderAction"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="canAccessConsigneeConsignor" id="484d8001-2417-4c6c-b431-f19d41192db6">
        <source>canAccessConsigneeConsignor(_user: CM_User): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/12/2018	jlgdap1		Initial creation TFS 42219 PEL1 Consignee Access Issues
//
vars
	cargoRequest : CM_WodCargoRequest;

begin
	foreach cargoRequest in self.allCargoDetails discreteLock do
		if cargoRequest.canAccessConsigneeConsignor(_user) then
			return true;
		endif;
	endforeach;
	
	return false;

epilog

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
