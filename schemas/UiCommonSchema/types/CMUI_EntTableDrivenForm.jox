    </JadeMethod>
    <JadeMethod name="initAnyClonedFields" id="a90e22cf-4907-481d-9b2a-1cd3a471b2ec">
        <updating/>
        <source>initAnyClonedFields(_entTableDef : EntTableDef) updating, protected;
/*
Purpose:			Initialize the inputs to doAddExtraControls
					to be re-implemented in any subclassed forms that require cloned/repeated fields

Parameters:			_entTableDef	The form's current Ent Table Definition

Return Value:		

Date		Who		Reason
31/08/2010	cnwdap1	Initial creation CCMS SFW 1131 PAR #25596
*/
vars
	entRow		: EntTableRow;

begin
	if _entTableDef = null then
		return;
	endif;
	
	// default allEntTableRows to the ent def rows
	foreach entRow in _entTableDef.allEntTableRows discreteLock do
		self.allEntTableRows.add(entRow);
	endforeach;
	
	// Create a string array to contain all the control captions you want, in the order you want them.
	// Call doAddExtraControls method in your subclassed form with the ent row constant you're going 
	// to clone, and the array of captions.

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_entTableDef" type="EntTableDef"/>
    </JadeMethod>
    <JadeMethod name="initFieldsForEntDefName" id="3bb6f7a8-6e20-48af-9cff-2676e4535ed0">
        <updating/>
        <source>initFieldsForEntDefName(_theEntDef : String; _setFocus : Boolean) updating, protected;
/*
Date		Who		Reason
09/07/2009	cnwdap1	Initial creation
25/03/2010	cnwdap1	PAR #22938 use translated string from ent table row to set control caption
31/08/2010	cnwdap1	CCMS SFW 1131 PAR #25596 Allow for cloned/repetitive fields in the ent table def
27/01/2011	cnwdap1	PAR #26785 re-instate cargo subtype captions
17/01/2023	navcs2	Defect 56200: MTN - Commodity field is not populated when the specific cargo type is selected
12 Jan 2026 navlc30 JIRA 36954 Story MTN | Highlight Mandatory fields
*/
vars
	headings				: StringArray;
	controlsPerHeading		: IntegerArray;
	entTableDef				: EntTableDef;
	row						: EntTableRow;
	nbrRows, nbrControls	: Integer;
	idx, controlTop, columnTop,
	saveControlTop,
	controlLeft, currentRow,
	controlExtent, formWidth, 
	formHeight,	columnsUsed	: Integer;
	isHeading, odd			: Boolean;
	ctrl, frame				: Control;
	fieldFrame				: CMUI_FieldFrame;
	parentWindow			: Window;
	controlHeight			: Integer;
	activeCntrl				: Control;
	activeParent			: CMUI_FieldFrame;
	tabOrderDict			: DynaDictionary;
	iter					: Iterator;
	oldIndex				: Integer;
	moveIt					: Integer;
	xlat					: XLAT_Translation;
	invalidActiveParent		: Boolean;
	doActiveParentCode : Boolean;	// Par 30244
	heading : String;				//12.01.2026 navlc30 #36954
begin
	activeCntrl			:= app.activeControl;
	if activeCntrl &lt;&gt; null then
		oldIndex		:= activeCntrl.tabIndex;
		if activeCntrl.parent.isKindOf(CMUI_FieldFrame) then
			activeParent	:= activeCntrl.parent.CMUI_FieldFrame;
		endif;
	endif;
	controlTop			:= self.PADDING_TOP;
	columnTop 			:= self.PADDING_TOP;
	controlLeft			:= self.PADDING_LEFT;
	create headings transient;
	create controlsPerHeading transient;
	create tabOrderDict transient;
	tabOrderDict.setMembership(Control);
	tabOrderDict.addMemberKey(Control::tabIndex.name, false, true);
	tabOrderDict.endKeys(true);
	
	// hide all controls for a start off until we know which ones we need to display
	self.makeControlsInvisible();
	self.allFieldFrames.clear;
	self.hideSelectedControls();
	
	// do we in fact have an EntTableDef at all?
	if _theEntDef = null then
		return;
	endif;

	
	self.currentEntTableDef := _theEntDef;
	entTableDef := app.myController.getEntTableDef(_theEntDef);
	
	// CCMS SFW 1131 PAR #25596 Include any cloned/repeated controls the user might want
	self.allEntTableRows.clear;
	self.allClonedControls.clear;
	self.initAnyClonedFields(entTableDef);
	
	// get the heading controls and the number of controls between each heading
	//foreach row in entTableDef.allEntTableRows discreteLock where row.visible do	// CCMS SFW 1131 PAR #25596
	foreach row in self.allEntTableRows where row.visible do						// CCMS SFW 1131 PAR #25596

		self.getControlForEntDefRow(row.controlName, ctrl);
		//////////RAISE EXCEPTION IF CTRL IS NULL//////////
		if ctrl = null then
			app.msgBox(row.name &amp; Space &amp; row.controlName &amp; " is not defined on this form - EntTableDef error", "Error!", MsgBox_Stop_Icon + MsgBox_OK_Only); 
			continue;
		endif;
		
		// if this control has been hidden, ignore it and carry on
		if ctrl.CMUI_FieldFrame.isHidden then
			continue;
		endif;

		if row.inputType = row.InputType_Group then
			headings.add(row.getHeadingUnaltered);
			idx := headings.indexOf(row.getHeadingUnaltered);
			if nbrControls &lt;&gt; null then
				controlsPerHeading.atPut(idx - 1, nbrControls);
				nbrControls := null;
			endif;
		else
			if ctrl.CMUI_FieldFrame.retainPaintedHeight then
				nbrControls := nbrControls + (ctrl.height / self.DEFAULT_CONTROL_HEIGHT).Integer;
			else
				nbrControls := nbrControls + 1;
			endif;
		endif;
		
		// set caption so that getCaptionExtent below has the correct (entTableDef) caption
		fieldFrame := ctrl.CMUI_FieldFrame;
		xlat := row.getTranslation(app.myCurrentLocale);
		if xlat = null then
			if row.isMandatoryField then																//12.01.2026 navlc30 #36954
				heading := row.getHeadingUnaltered &amp; "*";
			else
				heading := row.getHeadingUnaltered;
			endif;
			//fieldFrame.setMyCaption(row.getHeadingUnaltered);						// PAR #22938 		//12.01.2026 navlc30 #36954
			fieldFrame.setMyCaption(heading);													  		//12.01.2026 navlc30 #36954
		else
			if row.isMandatoryField then																//12.01.2026 navlc30 #36954
				heading := row.getTranslation(app.myCurrentLocale).text &amp; "*";
			else
				heading := row.getTranslation(app.myCurrentLocale).text;
			endif;				
			//fieldFrame.setMyCaption(row.getTranslation(app.myCurrentLocale).text);	// PAR #22938	//12.01.2026 navlc30 #36954
			fieldFrame.setMyCaption(heading);															//12.01.2026 navlc30 #36954
		endif;
	endforeach;
	// last one
	idx := headings.size;
	// we may not have any headings
	if idx &lt;&gt; null then
		controlsPerHeading.atPut(idx, nbrControls);
	endif;
	
	// PAR #26785 setMyCaption for each fieldFrame above has just remvoed any cargo subtype - specific captions
	// put them back again
	self.recheckSubCargoTypeAttributes();
	
	// get the biggest caption for all controls
	self.widestCaptionExtent := self.getCaptionExtent(entTableDef);
	
	// display controls in order under their heading, with a separate row for the heading, 
	//and sub controls split in to columns under the heading
	currentRow 	:= 1;
	//foreach row in entTableDef.allEntTableRows discreteLock where row.visible do	// CCMS SFW 1131 PAR #25596
	foreach row in self.allEntTableRows discreteLock where row.visible do			// CCMS SFW 1131 PAR #25596
	
		self.getControlForEntDefRow(row.controlName, ctrl);
		// if no control is found, or this control has been hidden, ignore it and carry on
		if ctrl = null or ctrl.CMUI_FieldFrame.isHidden then
			continue;
		endif;
		
		// record the parent of this frame - could be another frame, a group box or a form
		parentWindow := ctrl.parent;
		
		// set number of rows for this section based on number of controls in this section
		isHeading := false;
		idx := headings.indexOf(row.getHeadingUnaltered);
		if idx &lt;&gt; null then
			controlLeft := self.PADDING_LEFT;
			if idx &gt; 1 then
				columnTop := columnTop + ((nbrRows + 1) * self.PADDING_PER_ROW);
			endif;
			controlTop := columnTop;
			// 28063 cnwjre1 Sep 2011 multi-column form where 1st column is longer than 2nd etc
			if saveControlTop &gt; controlTop then
				controlTop := saveControlTop;
			endif;
			nbrRows := (controlsPerHeading[idx] / self.numberOfColumns).Integer;
			if controlsPerHeading[idx] mod 2 &lt;&gt; 0 then
				odd := true;
			else
				odd := false;
			endif;
			
			if controlsPerHeading[idx] mod self.numberOfColumns &lt;&gt; 0 then
				nbrRows := nbrRows + 1;
			endif;
			isHeading := true;
			currentRow := 1;
			saveControlTop := 0;
		endif;
		// if we only have one column, number of rows is the number of ent table rows
		if self.numberOfColumns = 1 then
			nbrRows := entTableDef.allEntTableRows.size;
		endif;
		// if we don't have any headings, calculate the number of rows anyway
		if headings.isEmpty then
			nbrRows := (nbrControls / self.numberOfColumns).roundedTo(0).Integer;
			if nbrControls mod 2 &lt;&gt; 0 then
				odd := true;
			else
				odd := false;
			endif;
//			if entTableDef.allEntTableRows.size mod self.numberOfColumns &lt;&gt; 0 then
			if nbrControls mod self.numberOfColumns &lt;&gt; 0 then
				nbrRows := nbrRows + 1;
			endif;
			isHeading := false;
		endif;
		
		fieldFrame := ctrl.CMUI_FieldFrame;
		fieldFrame.visible := true;
		fieldFrame.setWidths(self.defaultControlWidth, self.widestCaptionExtent);
		if row.myEntTableCellControl &lt;&gt; null then
			row.myEntTableCellControl.initialiseFieldFrame(fieldFrame);
		endif;
		allFieldFrames.add(fieldFrame);
		
		// headings are declared as "groups" in EntTableDef - make them bold and left-aligned
		if row.inputType = row.InputType_Group then
			fieldFrame.myLabel.fontBold := true;
			fieldFrame.myLabel.alignment := Label.Alignment_Left_Middle;
			// override the default width to allow for the bold caption being bigger than the greatest text extent
			fieldFrame.myLabel.width := self.widestCaptionExtent * 2;
			fieldFrame.labelWidth := self.widestCaptionExtent * 2;
		endif;
		// record the widest control
		if fieldFrame.width &gt; controlExtent then
			controlExtent := (fieldFrame.width).Integer;
		endif;
		
		if fieldFrame.retainPaintedHeight then
			controlHeight := fieldFrame.height.Integer;
			
			// can we fit this control in the current column?
			// if it's bigger than 2* normal, we have to change column anyway
			if (controlHeight / self.DEFAULT_CONTROL_HEIGHT) &gt; (nbrRows - currentRow + 1) then
				// move to the next column
				// 28063 cnwjre1 Sep 2011 multi-column form where 1st column is longer than 2nd etc
				if controlTop &gt; saveControlTop then
					saveControlTop := controlTop;
				endif;
				controlTop := (columnTop + self.PADDING_PER_ROW).Integer;
				controlLeft := controlLeft + controlExtent + self.PADDING_LEFT;
				formWidth := formWidth + controlExtent + self.PADDING_LEFT;
				currentRow := 1;
				columnsUsed := columnsUsed + 1;
			endif;
		else
			controlHeight := self.DEFAULT_CONTROL_HEIGHT;
		endif;
		
		fieldFrame.move(controlLeft, controlTop, fieldFrame.width, controlHeight);
		
		//adjust form height
		if fieldFrame.top + controlHeight &gt; formHeight then
			formHeight := (fieldFrame.top + controlHeight).Integer;
		endif;
		
		// set top for next control (if retain height set, we need to add in the control height as well)
		controlTop := (controlTop + self.PADDING_PER_ROW).Integer;
		if fieldFrame.retainPaintedHeight  then
			controlTop := (controlTop + fieldFrame.height - self.DEFAULT_CONTROL_HEIGHT).Integer;
		endif;
		if not isHeading then
			currentRow := currentRow + 1;
		endif;
		if currentRow &gt; nbrRows  then
			// move to the next column
			// 28063 cnwjre1 Sep 2011 multi-column form where 1st column is longer than 2nd etc
			if controlTop &gt; saveControlTop then
				saveControlTop := controlTop;
			endif;
			if headings.isEmpty then
				controlTop := columnTop;
			else
				controlTop := (columnTop + self.PADDING_PER_ROW).Integer;
			endif;
			controlLeft := controlLeft + controlExtent + self.PADDING_LEFT;
			formWidth := formWidth + controlExtent + self.PADDING_LEFT;
			currentRow := 1;
			columnsUsed := columnsUsed + 1;
		endif;
		
	endforeach;																	
	
	// align child controls inside generic controls
	self.doAlignControlsInGenericFrames();

	// all controls moved - now set parent width and height
	if odd then 
		columnsUsed := columnsUsed + 1;
	endif;
	if (columnsUsed &gt; self.numberOfColumns) or columnsUsed &lt; (nbrControls / nbrRows).roundedUp then		// 17/01/2023	navcs2	Defect 56200
		columnsUsed := self.numberOfColumns;
	endif;
	formWidth := (controlExtent + self.PADDING_LEFT) * columnsUsed + self.PADDING_RIGHT;
	// if parent is the form itself, include the button bar in the height calculation
	if parentWindow = self then
		formHeight := (formHeight + self.PADDING_BOTTOM + frmButtons.height).Integer;
	elseif parentWindow.isKindOf(Frame) then
		formHeight := formHeight + parentWindow.Frame.bevelInnerWidth + parentWindow.Frame.bevelOuterWidth + parentWindow.Frame.boundaryWidth;
	endif;
	// if the subsequent parent height would exceed the area on the form allowed for it, increase the size of the form
	if formHeight + parentWindow.top &gt; frmButtons.top then
		moveIt := (formHeight + parentWindow.top - frmButtons.top).Integer;
		self.height := self.height + moveIt;
	endif;
	
	parentWindow.width := formWidth;
	parentWindow.height := formHeight;
	allFieldFrames.doTabOrders(10000);
	
	ctrl := null;//15/03/2011 cnwdz2 27143
	
	// figure out where were going to set the focus
	if _setFocus then
		// if we've been told to default to the first frame, do just that
		allFieldFrames.first.setFocus;
	else
	
		//04 Sep 2012	NDL	Par 30244
		if activeParent &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception, activeParent, invalidActiveParent);
			if activeParent.visible and not activeParent.isHidden then
				doActiveParentCode := true;
			endif;
		endif;
		// if the active control is the right one, just set focus to that
		if doActiveParentCode &lt;&gt; null then
			ctrl := activeParent;
			// but check we don't have a gap in the tab order
			if not activeParent.isKindOf(CMUI_FieldGeneric) and activeParent.getEmbeddedControl.tabIndex - oldIndex &gt; 1 then
				idx := self.allFieldFrames.indexOf(activeParent);
				ctrl := self.allFieldFrames[idx - 1];
			endif;
			
		elseif activeCntrl &lt;&gt; null then
			foreach idx in 1 to self.controlCount do
				frame := self.controls(idx);
				if not frame.visible or not frame.parent.visible or (frame.parent.isKindOf(CMUI_FieldFrame) and frame.parent.CMUI_FieldFrame.isHidden) then
					continue;
				endif;
				if frame.tabIndex &lt; 10000 then
					continue;
				endif;
				tabOrderDict.add(frame);
			endforeach;
			iter := tabOrderDict.createIterator;
			tabOrderDict.startKeyGeq(oldIndex, iter);
			while iter.next(frame) do
				if not frame.isKindOf(Label) then
					ctrl := frame;
					break;
				endif;
			endwhile;
		else
			ctrl := allFieldFrames.first;
		endif;
		if ctrl &lt;&gt; null then //15/03/2011 cnwdz2 27143
			if ctrl.isKindOf(CMUI_FieldFrame) and not ctrl.isKindOf(CMUI_FieldGeneric) and ctrl.CMUI_FieldFrame.getEmbeddedControl &lt;&gt; null then
				ctrl.CMUI_FieldFrame.getEmbeddedControl.setFocus;
			else
				ctrl.setFocus;
			endif;
		endif;
	endif;
	
epilog
	delete headings;
	delete controlsPerHeading;
	delete tabOrderDict;
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_theEntDef" type="String"/>
        <Parameter name="_setFocus" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="makeControlsInvisible" id="6f02c0fa-3db6-428d-a9d0-e0f8c58d2d74">
        <source>makeControlsInvisible() protected;
/*
Purpose:			makes all CMUI_FieldFrame controls invisibile as a default starting point
					Reimplement at your screen level if there are some controls that are always visible
					(or implement without an inheritMethod if all fields are always visible)

Parameters:			None

Return Value:		None

Date		Who		Reason
09 July 2009	cnwdap1	Initial creation
*/
vars
	idx		: Integer;
	ctrl	: Control;

begin
	foreach idx in 1 to self.controlCount do
		ctrl := self.controls(idx);
		if ctrl.isKindOf(CMUI_FieldFrame) then
			ctrl.visible 					:= false;
			ctrl.CMUI_FieldFrame.isHidden 	:= false;
		endif;
	endforeach;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="queryUnload" id="c94b5c0c-ad44-493f-ab12-7db5bc1e72bb">
        <controlMethod name="Form::queryUnload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>queryUnload(cancel: Integer io; reason: Integer) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 September 2009	cnwdap1	Initial creation
*/
vars

begin
	if reason = self.QueryUnload_User and not self.doCancel() then
		cancel := 1;
	endif;
epilog

end;</source>
        <Parameter name="cancel" type="Integer" usage="io"/>
        <Parameter name="reason" type="Integer"/>
    </JadeMethod>
