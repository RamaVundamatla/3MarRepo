    <JadeMethod name="initShtMultiSelect" id="7b7af2c5-c55c-40cb-9ffa-982721877929">
        <source>initShtMultiSelect();
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	theForm	: SOP_HMS_TableMaintForm;
	tmpCombo 		: CMUI_ComboBox;
begin

	theForm := self.myForm.SOP_HMS_TableMaintForm;
	inheritMethod;
	
	theForm.shtPathSegments.visible := true;
	theForm.lblStartRoute.caption := 'Path Segments';

	tmpCombo := theForm.cmbRegionSource;		
	theForm.myAssistant.comboBoxHMSRegion(tmpCombo, null, null);				
	tmpCombo.lostFocus(tmpCombo);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="8dbc8897-d1c1-4ae2-9073-1ba9f031e1a1">
        <updating/>
        <source>setControlsForAddEdit() updating;
//--------------------------------------------------
// Created:	06 April 2004 By: cnwgd1
//--------------------------------------------------
vars
	theForm : SOP_HMS_TableMaintForm;
	fieldRoute : CMUI_FieldFrame;
begin
	inheritMethod();
	theForm := self.myForm.SOP_HMS_TableMaintForm;	

	theForm.tblRoute.userInputEnabled := true;

	if theForm.mode = theForm.Mode_Add then
		theForm.tblRoute.rows := theForm.tblRoute.fixedRows;
		
		// add 2 blank rows so the auto-insert works ok
		// need to do like this to ensure row object is set to null
		theForm.tblRoute.addItemObject(null, '');
		theForm.tblRoute.addItemObject(null, '');
	endif;
	
/*	if theForm.mode = theForm.Mode_Add then
		theForm.mulSelect1.setSelected(null);
		theForm.cmbRegionSource.listIndex := -1;
		doFieldRouteSegClick(null);

	else
		if theForm.shtPathSegments.visible = true then
		else
			theForm.mulSelect1.setSelected(theForm.myProxyObject.HMS_MovementPath.allPathSegments);	
		endif;
	endif;
	*/
end;</source>
    </JadeMethod>
