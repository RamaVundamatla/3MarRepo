    <JadeMethod name="delete" id="227a82f6-e73d-4652-96b9-79d73d2b2062">
        <updating/>
        <source>delete() updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 03 July 2023
TFS#		: 58506
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
begin
	if self.subhaulier &lt;&gt; null then
		delete self.subhaulier;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setFromTI" id="0a35d36a-ab04-43b8-9a5c-50f5aa6a09e9">
        <updating/>
        <source>setFromTI(_theTI : CM_TrackedItem input; _transaction : CM_TITransaction; _translationOperator : CM_Operator;  _vehicleVisit : CM_VehicleVisitRecord; _isForLoadConfirmation : Boolean) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 22 June 2023
TFS#		: 58506
Function	:

*** Changes ***
Date			Name		TFS#		Description
24/07/2023		jlika1		55938		EUP | Load Confirmation Protocol
11/09/2023		jlika1		60337		EUP | FR EDI - EUP CAMS protocols: Translations based on Receiver
25/09/2023		navdap1		60365		EUP | FR 53853 - Goods Receipt Message Grouping
6/10/2023		navra1		60396		EUP | FR 54085 - Load Confirmation - Field Mapping
05/11/2024		navnk30		JIRA 12432: EUP | FR - 54085 - LoadConfirmation - Missing External and Internal References for VBS Detail
****************************************************/

vars
	subCarrier 		: CMIF_JsonSubHaulierEUP;	
	vehicleTimeSlot	: CM_VehicleBookingTimeSlot;
	tiSubCarrier	: CM_Carrier;
begin
	if _vehicleVisit &lt;&gt; null then
		self.type := _vehicleVisit.getTrailerTypeCode(_transaction);
		self.licensePlate := _vehicleVisit.regNumber;
		self.trailerLicensePlate := _vehicleVisit.getChassisID();
		self.driverName :=  _vehicleVisit.driversName;
		self.driverLicenseNumber := _vehicleVisit.driverCode;
		
		// TFS 60365 A vehicle visit can cover more than one vehicle booking slot
		//vehicleTimeSlot := _vehicleVisit.myVehicleBookingTimeslot;
		//if vehicleTimeSlot &lt;&gt; null then
		foreach vehicleTimeSlot in _vehicleVisit.allVehicleBookingSlots do
			//if vehicleTimeSlot.allBookedTrackedItems.includes(_theTI) then	//05.11.2024 navnk30 JIRA 12432
			if vehicleTimeSlot.allBookedTrackedItems.includes(_theTI) or		//05.11.2024 navnk30 JIRA 12432
				_vehicleVisit.allReleasedTrackedItems.includes(_theTI) then
				self.transportReferenceCustomer := vehicleTimeSlot.externalReference;
				self.transportReferenceInternal := vehicleTimeSlot.id;
			endif;
		endforeach;
		// TFS 60365 end
		
		if _isForLoadConfirmation then			//navra1 - TFS 60396 - 6th Oct 2023
			tiSubCarrier := _theTI.getReleaseSubCarrier;
		else 
			tiSubCarrier := _theTI.getReceiveSubCarrier;
		endif;
		if  tiSubCarrier &lt;&gt; null then
			create subCarrier transient;			
			subCarrier.setFromCarrier(tiSubCarrier, _translationOperator);
			
			self.subhaulier := subCarrier;
		endif;
		
		if _isForLoadConfirmation and _vehicleVisit.allTruckSeals.size &gt; 0 then			//navra1 - TFS 60396 - 6th Oct 2023
			self.sealNumber := _vehicleVisit.allTruckSeals.first.getSealValueAsString();
		endif;
	endif; 	
end;
</source>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_translationOperator" type="CM_Operator"/>
        <Parameter name="_vehicleVisit" type="CM_VehicleVisitRecord"/>
        <Parameter name="_isForLoadConfirmation" type="Boolean"/>
    </JadeMethod>
</Class>
