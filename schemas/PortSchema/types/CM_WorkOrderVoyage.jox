    <JadeMethod name="getProgressString" id="8420c3ea-ca57-46a9-b6b3-dbdb7ff87de4">
        <source>getProgressString(): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 25/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
//
vars
	task : CM_WorkOrderDtl;
	done : Integer;
	result : String;
begin
	
	if self.taskStatus = WO_STATUS_COMPLETE then
		return app.getErrorString(Complete);
	else
		foreach task in self.allWoDtls do
			if task.CM_WorkOrderVoyageDtl.isComplete then
				done := done + 1;
			endif;
		endforeach;
		
		return app.getErrorString2(N_of_n_Complete, done.String, self.allWoDtls.size.String);
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
