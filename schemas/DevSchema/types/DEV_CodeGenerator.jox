<Class name="DEV_CodeGenerator" id="f56a9426-377c-40ae-bcee-b95bf3d2b881">
    <superclass name="Object"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="dev"/>
    <ImplicitInverseRef name="genClass" id="c25976d5-46f5-4c1a-ac8e-cb675dc4743e">
        <embedded/>
        <type name="Class"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <PrimAttribute name="genClassName" id="70b08ff7-36ab-4339-a47b-2b7f1c5988c3">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>protected</access>
    </PrimAttribute>
    <PrimAttribute name="genComment" id="bc185000-e586-4d00-a96c-4a479afa2336">
        <type name="String"/>
        <access>protected</access>
    </PrimAttribute>
    <ImplicitInverseRef name="genFile" id="c981bc11-b1e1-4345-a38c-789ba2854b2c">
        <embedded/>
        <type name="File"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="genProps" id="13ad6a70-d175-43c7-9e98-18355da39ca3">
        <memberTypeInverse/>
        <type name="ObjectArray"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <JadeMethod name="generate" id="2cb94112-e964-47bf-ba4c-48f1c87038b5">
        <updating/>
        <source>generate(className : String; commentText : String; fileName : String) updating;
// write out to the nominated file the class and trx/utl methods for add/update/delete functionality
vars
	pos	: Integer;
	work	: String;
	now	 : Date;
	scm	: Schema;
	prop	: Property;
	propDict : PropertyNDict;
begin
	scm := rootSchema.getSchema("PortSchema");
	self.genClass := scm.getClass(className);
	if self.genClass = null then
		write className &amp; " not found";
		return;
	endif;
	// get the part of the class name after the CM_ or equivalent prefix, to use in method names
	pos := className.pos('_', 1);
	if pos = 0 then
		self.genClassName := className;
	else
		self.genClassName := className[pos+1:end];
	endif;
	// get the user name
	work := process.userCode;
	pos := work.pos('_', 1);
	if pos &gt; 0 then
		work := work[1:pos-1];
	endif;
	self.genComment := '// ' &amp; now.String &amp; Tab &amp; work &amp; Tab &amp; commentText;

	propDict := self.genClass.getProperties();	// just this class, not super class properties as well
	// filter out the automatic end of an inverse
	foreach prop in propDict do
		if prop.isKindOf(ExplicitInverseRef) and
		   prop.ExplicitInverseRef.updateMode.Integer = 2 then	// automatic
			continue;
		endif;
		self.genProps.add(prop);
	endforeach;
	create self.genFile transient;
	self.genFile.openOutput(fileName);
	// write out in the sequence in which they are referenced so can cut-and-paste top to bottom
	
	self.generateSetForUpdate();
	self.generateSetForCreate();
	self.generatePxyCreateUpdateProxy();
	self.generateValidateForCreate();
	self.generateValidateForUpdate();
	self.generateValidateForDelete();

	self.generateValCreate();
	self.generateValDelete();
	self.generateValUpdate();

	self.generateUtlCreate();
	self.generateUtlDelete();
	self.generateUtlUpdate();

	self.generateTrxCreate();
	self.generateTrxDelete();
	self.generateTrxUpdate();
		
epilog
	if self.genFile &lt;&gt; null then
		if self.genFile.isOpen then
			self.genFile.close;
		endif;
		delete self.genFile;
	endif;

end;</source>
        <Parameter name="className" type="String"/>
        <Parameter name="commentText" type="String"/>
        <Parameter name="fileName" type="String"/>
    </JadeMethod>
    <JadeMethod name="generateDoSave" id="09d6a3fe-ebc9-45ae-9632-49f2d168189a">
        <source>generateDoSave() protected;

vars
	proxyName	: String;
	className	: String;
	obj		: Object;
	prop	: Property;
begin
	className := self.genClass.name;
	proxyName := 'proxy' &amp; self.genClassName;

	self.genFile.writeLine("&lt; Maintaining Form&gt;");
	self.genFile.writeLine("doSave() : Boolean updating;");
	self.genFile.writeLine(self.genComment);
	self.genFile.writeLine('// this code assumes a self.myProxyObject and self.mode for add/update');
	self.genFile.writeLine('vars');
	self.genFile.writeLine(Tab &amp; proxyName &amp; Tab &amp; ': ' &amp; className &amp; ';');
	foreach obj in self.genProps do
	
	endforeach;
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="generatePxyCreateUpdateProxy" id="ba8642d9-ecb6-4ce2-ad09-adee257cba2d">
        <updating/>
        <source>generatePxyCreateUpdateProxy() updating, protected;

vars
	className	: String;
	proxyName	: String;
	obj		: Object;
	prop	: Property;
begin
	className := self.genClass.name;
	proxyName := 'proxy' &amp; self.genClassName;

	self.genFile.writeLine(className);
	self.genFile.writeLine('pxyCreateUpdateProxy() : SelfType;');
	self.genFile.writeLine(self.genComment);
	self.genFile.writeLine('vars');
	self.genFile.writeLine(Tab &amp; proxyName &amp; Tab &amp; ': ' &amp; className &amp; ';');
	self.genFile.writeLine('begin');
	self.genFile.writeLine(Tab &amp; proxyName &amp; ' := inheritMethod();');
	// revisit this ***
	foreach obj in self.genProps do
		prop := obj.Property;
		if prop.getType.isPrimitive then
			self.genFile.writeLine(Tab &amp; proxyName &amp; '.' &amp; prop.name &amp; ' := self.' &amp; prop.name &amp; ';');
		endif;
	endforeach;
	self.genFile.writeLine(CrLf &amp; Tab &amp; 'return ' &amp; proxyName &amp; ';');
	self.genFile.writeLine('end;' &amp; CrLf);
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="generateSetForCreate" id="c3f6f5df-b5c8-4edf-898c-b7a665f61a05">
        <updating/>
        <source>generateSetForCreate() updating, protected;

vars
	className	: String;
	paramName	: String;
begin
	className := self.genClass.name;
	paramName := '_proxy' &amp; self.genClassName;

	self.genFile.writeLine(className);
	self.genFile.writeLine('setForCreate(' &amp; paramName &amp; ' : ' &amp; className &amp; '; _passport : CM_Passport input) updating;');
	self.genFile.writeLine(self.genComment);
	self.genFile.writeLine('begin');
	self.genFile.writeLine(Tab &amp; paramName &amp; '.raiseExceptionIfNotTransient(method);' &amp; CrLf);
	self.genFile.writeLine(Tab &amp; 'self.setForUpdate(' &amp; paramName &amp; ');');
	self.genFile.writeLine('//	set any properties which are only to be done from create, not update');
	self.genFile.writeLine('end;' &amp; CrLf);
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="generateSetForUpdate" id="f1380c7e-3024-4b5e-94a3-9715208b8945">
        <updating/>
        <source>generateSetForUpdate() updating, protected;

vars
	className	: String;
	paramName	: String;
	propName	: String;
	obj		: Object;
	prop	: Property;
	propType	: Type;
begin
	className := self.genClass.name;
	paramName := '_proxy' &amp; self.genClassName;

	self.genFile.writeLine(className);
	self.genFile.writeLine('setForUpdate(' &amp; paramName &amp; ' : ' &amp; className &amp; ') updating;');
	self.genFile.writeLine(self.genComment);
	self.genFile.writeLine('begin');
	// set primitives first
	foreach obj in self.genProps do
		prop := obj.Property;
		propName := prop.name;
		if prop.getType.isPrimitive then
			self.genFile.writeLine(Tab &amp; 'self.' &amp; propName &amp; ' := ' &amp; paramName &amp; '.' &amp; propName &amp; ';');
		endif;
	endforeach;
	// set references last.  Do collections as copies.
	foreach obj in self.genProps do
		prop := obj.Property;
		propType := prop.getType;
		propName := prop.name;
		if not propType.isPrimitive then
			if propType.isCollection then
				self.genFile.writeLine(Tab &amp; 'self.' &amp; propName &amp; '.clear();');
				self.genFile.writeLine(Tab &amp; paramName &amp; '.' &amp; propName &amp; '.copy(self.' &amp; propName &amp; ');');
			else
				self.genFile.writeLine(Tab &amp; 'self.' &amp; propName &amp; ' := ' &amp; paramName &amp; '.' &amp; propName &amp; ';');
			endif;
		endif;
	endforeach;
	self.genFile.writeLine('end;' &amp; CrLf);
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="generateTrxCreate" id="666b5181-a268-48a9-ae09-befdc418d76e">
        <updating/>
        <source>generateTrxCreate() updating, protected;

vars
	className	: String;
	paramName1	: String;
	paramName2	: String;
begin
	className := self.genClass.name;
	paramName1 := '_proxy' &amp; self.genClassName;
	paramName2 := '_new' &amp; self.genClassName;

	self.genFile.writeLine("CM_TrxControlCreateAgent");
	self.genFile.writeLine('trxCreate' &amp; self.genClassName &amp; '(' &amp; paramName1 &amp; ' : ' &amp; className &amp; ' input; ' &amp; paramName2 &amp;
							' : ' &amp; className &amp; ' output; _passport : CM_Passport input) updating;');
	self.genFile.writeLine(self.genComment);
	self.genFile.writeLine('begin');
	self.genFile.writeLine(Tab &amp; '// Always initialize the activity first');
	self.genFile.writeLine(Tab &amp; 'self.initialiseActivityWithPassport(_passport, method);' &amp; CrLf);
	self.genFile.writeLine(Tab &amp; '// Arm our base exception handlers');
	self.genFile.writeLine(Tab &amp; 'on Exception do agtPassportExHandler(exception, _passport);');
	self.genFile.writeLine(Tab &amp; 'on LockException do agtPassportLockExHandler(exception, _passport);' &amp; CrLf);
	self.genFile.writeLine(Tab &amp; 'app.setContinueCMExceptions(false);' &amp; CrLf);
	self.genFile.writeLine(Tab &amp; 'beginTransaction;');
	self.genFile.writeLine(Tab &amp; 'app.myUtilityCA.utlCreate' &amp; self.genClassName &amp; '(' &amp; paramName1 &amp; ', ' &amp; paramName2 &amp; ', _passport);');
	self.genFile.writeLine('epilog');
	self.genFile.writeLine(Tab &amp; 'self.finaliseActivityWithPassport(_passport);');
	self.genFile.writeLine('end;' &amp; CrLf);
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="generateTrxDelete" id="b8df13ef-4438-495b-9d91-1293ffc77b89">
