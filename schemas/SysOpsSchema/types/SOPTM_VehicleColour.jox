    <JadeMethod name="setupThumbnailDetails" id="6dd500ad-3bae-42be-8461-3bd0f28dc76a">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2013	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	self.myForm.useProxyObject := true;
	self.myForm.setTblDataEntRows(ETDef_VehicleColour);
	
	self.myForm.shtTblInput1.caption := 'Details';
	self.myForm.initTblInput(self.myForm.tblInput1, ETDef_VehicleColour);	
	self.myForm.shtTblInput1.visible := true;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="b8177357-af2b-437d-9e0a-9ca61ce696de">
        <updating/>
        <source>showThumbnail(_vehicleColour : CM_VehicleColour) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2013	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	self.myForm.tblInput1.clearValues;

	self.myForm.tblInput1.setValueByName(ETRow_Colour, _vehicleColour.colour);

epilog

end;</source>
        <Parameter name="_vehicleColour" type="CM_VehicleColour"/>
    </JadeMethod>
</Class>
