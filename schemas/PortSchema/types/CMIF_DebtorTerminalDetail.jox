    <JadeMethod name="setPaymentTypeFromDescription" id="df781fae-d52e-4057-b1e8-a05ed3a92b3d">
        <updating/>
        <source>setPaymentTypeFromDescription(_description : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25/09/2018	jlgsl4	TFS 40294 PEL1 - extract/import new fields incl. Payment Type details

*/

vars
	paymentTerms : StringArray;
	paymentType : Integer;
begin
	create paymentTerms transient;
	paymentTerms.add(app.getErrorString(PaymentType_NoneStr));
	paymentTerms.add(app.getErrorString(PaymentType_AutoCollectionStr));
	paymentTerms.add(app.getErrorString(PaymentType_PrePayStr));
	paymentTerms.add(app.getErrorString(PaymentType_PostPayStr));
	paymentType := paymentTerms.indexOf(_description) - 1; // PaymentType_None's index is 1, but paymentType is 0...!
	setPaymentType(paymentType);
epilog
	delete paymentTerms;
end;</source>
        <Parameter name="_description" type="String"/>
    </JadeMethod>
</Class>
