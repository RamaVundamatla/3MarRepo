    <JadeMethod name="batchNoDescr" id="c8f14703-0bcc-4889-b2f1-a28f748b83e8">
        <methodInvocation>mapping</methodInvocation>
        <source>batchNoDescr(set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:     13 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	_value := self.batchNo.String &amp; ' - ' &amp; self.terminalCode;	

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="date" id="d2aab4e1-0ef0-4624-989a-0e8a7c54c6f7">
