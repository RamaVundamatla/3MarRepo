    <JadeMethod name="tLOLOTLTestDiffWeight" id="96c84208-e894-46de-8caa-3f43b6dfec32">
        <updating/>
        <source>tLOLOTLTestDiffWeight() updating;
// CNWNDL1
/*
Purpose:		PAR 32318 . a twin lift of 2 20's should not happen	if the difference between the 2 20s is greater than the diff weight on the crane 
Date				Who			Reason
AUGUST 2013		NAVAB1		Initial creation
*/
constants
	VOYAGE = "AABISH_TL";
	VESSEL = "AABISH_TL";
	CRANE = "CRN2";
vars
	slots, jobSlots : CM_SlotControllerArray;
	aSlot, chkSlot1, chkSlot2 : CM_SlotController;
	voyageJob : CM_VoyageJob;
	ct : CM_CargoType;
	product: CM_Product;
	voyage : CM_Voyage;
	realAlloc : CM_VoyageAllocation;
	seqGroupSingleLifts : Boolean;
	crane : CM_Crane;
	maxDIFF, tl : Integer;
begin
	crane := self.getCrane(CRANE);
	self.assertTrueMsg(crane &lt;&gt; null, "Could not find crane " &amp; CRANE);
	
	tl := crane.machineLiftType;
	
	if tl &lt;&gt; TWIN_LIFT then
		beginTransaction;
		crane.setPropertyValue(CM_Crane::machineLiftType.name,TWIN_LIFT);
		commitTransaction;
	endif;
	maxDIFF := crane.weightDifference;
	setCraneWeightDiff(crane, 0);
	
	self.setTerminalConfig(SeqGroupSingleLifts, true);

	voyage := self.createVesselVoyage(VOYAGE, VESSEL, null);
	
	self.createCargoOnship(voyage);


	app.myTrxUA.trxSetDfltDischargeColourCode(voyage.myCellularVoyageStructure, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	// ### LOLO DISCHARGE JOB
	create slots transient;
	voyage := self.getVoyage(VOYAGE);
	aSlot := self.getJobLOLOControllerByID(VOYAGE, "01", "010688"); slots.add(aSlot); chkSlot1 := aSlot;
	aSlot := self.getJobLOLOControllerByID(VOYAGE, "01", "010686"); slots.add(aSlot);
	aSlot := self.getJobLOLOControllerByID(VOYAGE, "01", "010488"); slots.add(aSlot);
	aSlot := self.getJobLOLOControllerByID(VOYAGE, "01", "010486"); slots.add(aSlot);

	aSlot := self.getJobLOLOControllerByID(VOYAGE, "03", "030688"); slots.add(aSlot);
	aSlot := self.getJobLOLOControllerByID(VOYAGE, "03", "030686"); slots.add(aSlot);
	aSlot := self.getJobLOLOControllerByID(VOYAGE, "03", "030488"); slots.add(aSlot);
	aSlot := self.getJobLOLOControllerByID(VOYAGE, "03", "030486"); slots.add(aSlot);
	
	voyageJob:=self.addVoyageJob(voyage,CRANE,slots, true);
	assertTrue(voyageJob &lt;&gt; null);

	self.assertTrueMsg(chkSlot1.mySlotRequestDischarge.isTwinLiftPort, chkSlot1.getFullId() &amp; " should be TL!");
	
	self.assertTrueMsg(voyageJob.isTwinLift,"Job " &amp; voyageJob.jobNum &amp; " is not Twin Lift");
	

	self.deleteVoyageJob(voyage, CRANE, voyageJob.jobNum);
	setCraneWeightDiff(crane, 5000);
	
	voyageJob:=self.addVoyageJob(voyage,CRANE,slots, true);
	assertTrue(voyageJob &lt;&gt; null);
	self.assertTrueMsg(not chkSlot1.mySlotRequestDischarge.isTwinLiftPort, chkSlot1.getFullId() &amp; " should be SL!");
	
epilog

	setCraneWeightDiff(crane, maxDIFF);
	
	if tl &lt;&gt; TWIN_LIFT then
		beginTransaction;
		crane.setPropertyValue(CM_Crane::machineLiftType.name,TWIN_LIFT);
		commitTransaction;
	endif;

	delete slots;
	delete jobSlots;
end;</source>
