    <JadeMethod name="doMnuRailAreaConfirm" id="07a82eba-61cc-4272-b523-e065625661f0">
        <updating/>
        <source>doMnuRailAreaConfirm() updating;
// ---------------------------------------------------------------------------
// Created:		November  2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	railLine : CM_RailLine;
	autoPlan : Boolean;
	result	 : Integer;
	wagonMoveController : CMIF_WagonMoveController;
begin
	if self.myCurrentRailArea = null then	
		return;
	endif;
	//result := app.msgBox('Are you sure that you want to confirm all wagons in rail area ' &amp; self.myCurrentRailArea.id &amp; ' onto the tracks?', "Rail line Confirmation", MsgBox_Question_Mark_Icon + MsgBox_Yes_No); //- cnwmd1, CCMS 1067, Par 19710
	result := app.msgBox(app.getErrorString1(Sure_that_want_confi_wagon_tra, self.myCurrentRailArea.id), app.getErrorString(Rail_line_confirmati), MsgBox_Question_Mark_Icon + MsgBox_Yes_No);//+ cnwmd1, CCMS 1067, Par 19710
	
	if result = MsgBox_Return_No then
		return;
	endif;
	//result := app.msgBox("Do you want the system to Autoplan the cargo?", "Auto Plan?", MsgBox_Question_Mark_Icon + MsgBox_Yes_No); //- cnwmd1, CCMS 1067, Par 19710
	result := app.msgBox(app.getErrorString(Want_system_autopla_cargo),  app.getErrorString(AutoPlan), MsgBox_Question_Mark_Icon + MsgBox_Yes_No);//+ cnwmd1, CCMS 1067, Par 19710
	if result = MsgBox_Return_Yes then
		autoPlan := true;
	endif;
	
	//25 Feb 2021	NDL	TFS 50837
	create wagonMoveController transient;
	if not self.validateRetrospectiveTS( wagonMoveController ) then
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	//th2 31/05/2007 for PAR14154 - continuable warnings raised here so provide the ability to continue
	foreach railLine in self.myCurrentRailArea.allRailLines do : railLineLoop
		while true do : warningsLoop
			app.myTrxUA.trxUpdateWagonConfirmRailLine( wagonMoveController, railLine, autoPlan, app.myPassport);
			
			if app.myPassport.trxCompletedOK then
				self.clearErrorWarnings();
				continue railLineLoop;
			else
				//result := app.showErrorWarningDialog('Rail Line Confirmation', app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings); //- cnwmd1, CCMS 1067, Par 19710
				result := app.showErrorWarningDialog(app.getErrorString(Rail_line_confirmati), app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);//+ cnwmd1, CCMS 1067, Par 19710
				if app.myPassport.noErrors and
				   result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue warningsLoop;
				endif;
				
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
				break railLineLoop;
			endif;
			
			continue railLineLoop;//shouldn't get down here, but want to prevent infinite loop in the event it does for some reason
		endwhile;
		
	endforeach;	
	
	
epilog
	delete wagonMoveController;
	app.mousePointer := MousePointer_Default;				
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuRailLineClear" id="988a7183-13c4-4ddd-a3c5-bf82df4afd2f">
        <updating/>
        <source>doMnuRailLineClear() updating;
//--------------------------------------------------------------
//Created: 18 February 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	cmifRakeRegion : CMIF_RakeRegion;
	result : Integer;
	msg : String;
begin
	if self.myCurrentListObject = null then
		return;
	endif;
	
	if self.myCurrentListObject &lt;&gt; self.myCurrentJSIORake then
		return;
	endif;
		
	app.mousePointer := MousePointer_HourGlass;
	
	create cmifRakeRegion transient;
	
	if (not self.setCMIF_RakeRegion(cmifRakeRegion)) then
		return;
	endif;
	
	//25 Feb 2021	NDL	TFS 50837
	if not validateRetrospectiveTS(null) then
		return;
	elseif self.chkRetrospect.value and self.retrospectiveDate.date.isValid then
		cmifRakeRegion.setEffectiveTimeStampOverride( self.retrospectiveDate );
	endif;
	
	while true do
		app.myTrxUA.trxUpdateRailClearRake(cmifRakeRegion, app.myPassport);	
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			//result := app.showErrorWarningDialog('Clear Rail Line', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);//- cnwmd1, CCMS 1067, Par 19710
			result := app.showErrorWarningDialog(app.getErrorString(Clear_rail_line), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);//+ cnwmd1, CCMS 1067, Par 19710
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;	

epilog
	delete cmifRakeRegion;
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuRakeJobDelete" id="dde42550-dc0a-4101-bb83-9e3bdffe1f59">
        <updating/>
        <source>doMnuRakeJobDelete(_job : CM_Job io)updating;
//--------------------------------------------------------------
//Created: 18 February 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	result : Integer;
begin
	if _job = null then
		return;
	endif;

//	sgp 14 August 2003: warning given by the model
//	if app.msgBox('Are you sure you want to erase job ' &amp; self.myCurrentJob.jobId &amp; '?', 'Confirm Erase Job', MsgBox_Stop_Icon + MsgBox_Yes_No) = MsgBox_Return_No then
//		return;
//	endif;

	app.mousePointer := MousePointer_HourGlass;
	
	while true do
		app.myTrxDA.trxDeleteJob(_job, app.myPassport);	
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			//result := app.showErrorWarningDialog('Delete Job', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);//- cnwmd1, CCMS 1067, Par 19710
			result := app.showErrorWarningDialog(app.getErrorString(Delete_Job), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);//+ cnwmd1, CCMS 1067, Par 19710
			
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;

epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_job" type="CM_Job" usage="io"/>
    </JadeMethod>
