<Class name="CMIF_FuelTransController" id="f3c5ed1d-4345-4d72-bcd9-90dfccda58e1">
    <superclass name="CMIF_TITransactionController"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="transact"/>
    <PrimAttribute name="litres" id="f3ce3ab3-4a59-49da-8422-2dc461029e9c">
        <precision>12</precision>
        <embedded/>
        <type name="Decimal"/>
    </PrimAttribute>
    <JadeMethod name="setFromTransaction" id="d10e6b6c-07b1-4a8b-8515-b1c6341bad2e">
        <updating/>
        <source>setFromTransaction(_txn: CM_Fuel) updating;
// ---------------------------------------------------------------------------
// Created:     24 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod(_txn);
	self.litres := _txn.litres;

end;</source>
        <Parameter name="_txn" type="CM_Fuel"/>
    </JadeMethod>
    <JadeMethod name="setTransactionDetails" id="8e856d7f-efdb-450f-8ab0-18a225fe210d">
        <updating/>
        <source>setTransactionDetails(_txn : CM_Fuel input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     06 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod(_txn);

	_txn.setFuelDetails(self.litres);

end;</source>
        <access>protected</access>
        <Parameter name="_txn" type="CM_Fuel" usage="input"/>
    </JadeMethod>
</Class>
