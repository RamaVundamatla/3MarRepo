    <JadeMethod name="purgeInterfaceMessageHistory" id="aeea1222-8821-474c-ba80-2701e5455dd2">
        <source>purgeInterfaceMessageHistory(_ts: TimeStamp; _agent: CM_DBPurgeAgent input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 Jan 2010	cnwmd1	Initial creation
08 Jun 2011	cnwkpd1	PAR #27693 - 1086 exception during Garbage Collection
06 Jul 2011 cnwjre1	par 27778 this code is holding locks for long periods - add time-based commits
*/
constants
	MaxTransactionTime = 2000;
vars
	lastCommit,
	now					: Decimal[20];
	iter				: Iterator;
	interfaceMessage	: CM_ITSInterfaceMessage;			// PAR #27693
	completed			: Integer;
	
begin
	lastCommit := app.relativeMachineTime();

	iter := self.allMessages.createIterator;
	self.allMessages.startKeyLeq( _ts, iter );
	while iter.back( interfaceMessage ) do
		self.exclusiveLock( interfaceMessage );
		delete interfaceMessage;
		completed	:= completed + 1;
		// Check for commit 27778
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			app.myPassport.doDeferredUpdates();
			app.cmsCommitTransaction(app.myPassport);
			lastCommit := app.relativeMachineTime();
			beginTransaction;
		endif;
	endwhile;
	
	_agent.setStats(	app.getErrorString( Purged ) &amp; Space &amp; completed.display &amp;
						' for ' &amp; self.name &amp; Space &amp; app.getErrorString( Interface_message ) );
epilog
	delete iter;
end;</source>
        <Parameter name="_ts" type="TimeStamp"/>
        <Parameter name="_agent" type="CM_DBPurgeAgent" usage="input"/>
    </JadeMethod>
