    <JadeMethod name="tblRemarks_contextMenu" id="e4e2f717-d647-4b52-bd16-678c79ba0044">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblRemarks_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*
Date		    Who			Reason
28 April 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars
	xLeft 	: Real;
	yTop	: Real;
begin

	xLeft := x;
	yTop := y;


	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   // convert x, y relative to form

	self.popupMenu(self.mnuTblContext, xLeft.Integer, yTop.Integer);

	return false;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
