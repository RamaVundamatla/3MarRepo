<Class name="CM_ITSWorkerAgent" id="cd5dc76c-370a-44ce-a734-9d8dece8e075">
    <superclass name="CM_InterfaceAgent"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>CCMS MES 1014 - RDT ITS Interface (Narrowband Radio solution provided International Terminal Solutions).</text>
    <DbClassMap file="mobileServer"/>
    <ImplicitInverseRef name="myInterfaceDefinition" id="edb3d7cc-19f0-4276-b4f9-6fa33125d6d1">
        <embedded/>
        <type name="CM_ITSInterfaceDefinition"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myTrxHook" id="4ffc94ab-df84-4000-a0bd-3e698a9e262e">
        <embedded/>
        <type name="CMIF_InterfaceTransactionHook"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="acceptRequestedTask" id="a98feec2-4e2f-43cf-a183-bfe19d362af9">
        <source>acceptRequestedTask(_message : CMIF_ITSInterfaceMsgController input;
					_requestedTask : CM_RTQueueTask input) protected;

/*

Purpose:			Accept the passed in requested task on behalf of the current machine

Parameters:			Current message, and task to accept

Return Value:		None


Date		Who		Reason
14 Sep 2010	cnwkpd1	PAR #24294 - CCMS MES 1080 - ITS Driver Initiated Move 
					Factored out from doProcessAcceptJob to use in doProcessInitiateMove as well

*/

vars
	invalidTask		: Boolean;
	lockedTask		: CM_RTQueueTask;
	
begin
	if _requestedTask &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, _requestedTask, invalidTask);
		self.reserveLock(_requestedTask);
		lockedTask := _requestedTask;
	endif;
	
	if invalidTask or
	   _requestedTask = null then
		// Task is no longer available
		self.deleteResponseForRTQueueEntry(_message.myMachine, _message.myRTQueueEntry);
		_message.errorQueueEntryNotAvailable();
	endif;

	// Transaction wrap up method
	self.myTrxHook.set(_message, CMIF_ITSInterfaceMsgController::postTransactionComplete);
	
	// Accept task
	app.myTrxRT.trxAcceptSpecifiedTask(_requestedTask, _message.myMediator, self.myTrxHook, app.myPassport);
	
	lockedTask := null;
	
	
epilog
	if lockedTask &lt;&gt; null then
		self.unlock(lockedTask);
	endif;
	
end;

</source>
        <access>protected</access>
        <Parameter name="_message" type="CMIF_ITSInterfaceMsgController" usage="input"/>
        <Parameter name="_requestedTask" type="CM_RTQueueTask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addNextQueueEntryResponse" id="8c6c5a68-75c7-4894-992c-ed6e29785c93">
        <source>addNextQueueEntryResponse(_machine : CM_Machine;
						  _fromQueueEntry : CM_RTQueueEntry) protected;

/*

Purpose:			Add next Queue Entry Response to send queue. 

Parameters:			Machine, and optional specific queue entry to send

Return Value:		Queue Entry Response created


Date		Who		Reason
20 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface
09 Nov 2010	cnwkpd1	PAR #26113 - To allow for refreshes of the queue entries for a machine, ensure
					the first entries checked are the ones currently assigned to the machine
27 Apr 2015	cnwkpd1	PAR #35832 - Additional diagnostics required to determine reason queue entries are not
					created
11 Feb 2016	cnwkpd1	PAR #37534 - Handle multiple ITS worker apps simultaneously processing a new queue entry
			cnwndl1
					
*/

vars
	currentQEs	: CM_RTQueueEntrySet;
	nextTask	: CM_RTQueueTask;
	response	: CM_ITSInterfaceResponse;
	
begin
	
	app.writeLog(method.qualifiedName &amp; " for machine " &amp; _machine.String &amp;
				   " with " &amp; _machine.allITSInterfaceResponsesActive.size().String &amp; " active responses", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	
	// Firstly find all the Queue Entries already displayed
	create currentQEs transient;

	foreach response in _machine.allITSInterfaceResponsesActive do
		// Exit if there is a Queue Entry Response to be sent, or waiting acknowledgement.
		// The processing of that response will trigger the next Add.
		if response.isToBeSent() or
		   response.isWaitingAcknowledge() then
			app.writeLog(method.qualifiedName &amp; " machine " &amp; _machine.String &amp;
						   " has outstanding response " &amp; response.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
			return;
		endif;
		// Build list of queue entries currently on display for the Driver
		if response.myRTQueueEntry &lt;&gt; null then
			currentQEs.add(response.myRTQueueEntry);
		endif;
	endforeach;
	
	app.writeLog(method.qualifiedName &amp; " machine " &amp; _machine.String &amp;
				   " has " &amp; currentQEs.size().String &amp; " current queue entries", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
				   
	// PAR #26113 - Before any other checks, ensure that the currently assigned task(s) are sent out,
	// regardless of how many entries have been sent before
	foreach nextTask in _machine.allCurrentQueueTasks do
		if not currentQEs.includes(nextTask.myEntry) then
			app.writeLog(method.qualifiedName &amp; " sending current " &amp; nextTask.myEntry.String &amp; 
						   " to " &amp; _machine.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
			self.addQueueEntryResponse(nextTask, false, _machine, null);
			return;
		endif;
	endforeach;
	
	// Then, also need to check next allocated task, also regardless of number already sent out
	nextTask := _machine.allAllocatedQueueTasks.first;
	if nextTask &lt;&gt; null then
		if nextTask.status = TASK_ALLOCATED and
		   not currentQEs.includes(nextTask.myEntry) then
			app.writeLog(method.qualifiedName &amp; " sending allocated " &amp; nextTask.myEntry.String &amp; 
						   " to " &amp; _machine.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
			self.addQueueEntryResponse(nextTask, false, _machine, null);
			return;
		endif;
	endif;
	
	// Don't send out any entries not assigned to an IMV
	if _machine.isIMV() then
		return;
	endif;

	// Exit if maximum number of queue entries on display for Driver
	if _machine.allITSInterfaceResponsesActive.size &gt;= self.myInterfaceDefinition.maxQEntriesPerMachine then
		app.writeLog(method.qualifiedName &amp; " maximum queue entries exceeded for " &amp; _machine.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		return;
	endif;
	
	if _fromQueueEntry &lt;&gt; null then
		nextTask := app.myUtlRT.getTaskForMachineFromQEntry(_machine, _fromQueueEntry, false, false);		// PAR #37534
	else
		nextTask := app.myUtlRT.getTaskForMachine(_machine, currentQEs);
	endif;
		
	if nextTask &lt;&gt; null then
		app.writeLog(method.qualifiedName &amp; " sending next " &amp; nextTask.myEntry.String &amp; 
					   " to " &amp; _machine.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		self.addQueueEntryResponse(nextTask, false, _machine, null);
	else
		app.writeLog(method.qualifiedName &amp; " no next task found", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	endif;

epilog
	delete currentQEs;
end;</source>
        <access>protected</access>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_fromQueueEntry" type="CM_RTQueueEntry"/>
    </JadeMethod>
    <JadeMethod name="addQueueEntryResponse" id="ccbd0314-9960-401b-b630-8937d3a66171">
        <source>addQueueEntryResponse(	_task 				: CM_RTQueueTask;
						_forceDespatchNow 	: Boolean;
						_machine			: CM_Machine;
						_requestMessage		: CMIF_ITSInterfaceMsgController) protected;

/*

Purpose:			Add a Queue Entry Response to send queue.

Parameters:			_task				: Task for Queue Entry of response.
					_forceDespatchNow	: Forces despatchNow tag value to be set to "Y".
					_machine			: Machine that Queue Entry response is being sent to.
					_requestMessage 	: controller for incoming ITS message that is being responded to, null for internal message.

Return Value:		None


Date		Who		Reason
27 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	originalMsgNo	: Integer;
	proxyResponse	: CM_ITSInterfaceResponse;
	realResponse	: CM_ITSInterfaceResponse;
	request			: CM_ITSInterfaceRequestMessage;
	
begin
	if _requestMessage &lt;&gt; null then
		request			:= _requestMessage.myMessage.CM_ITSInterfaceRequestMessage;
		originalMsgNo	:= _requestMessage.messageNumber;
	endif;

	// Create the Response
	create proxyResponse transient;
	proxyResponse.setProxyForQueueEntry(_task, _forceDespatchNow, originalMsgNo, _machine, self.myInterfaceDefinition);
	app.myTrxCA.trxCreateITSInterfaceResponse(proxyResponse, realResponse, request, app.myPassport);
	
epilog
	delete proxyResponse;
end;</source>
        <access>protected</access>
        <Parameter name="_task" type="CM_RTQueueTask"/>
        <Parameter name="_forceDespatchNow" type="Boolean"/>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_requestMessage" type="CMIF_ITSInterfaceMsgController"/>
    </JadeMethod>
