    <JadeMethod name="showPopupInfoFrame" id="62eba9c7-43d4-42a6-8bc5-0885144875d2">
        <source>showPopupInfoFrame(thePIC: CMIF_PopupInfoController input);
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	
begin
	
	if self.mnuGridHideMacro.caption = self.MNU_MACRO_HIDE then
		return;
	endif;

	inheritMethod(thePIC);

end;</source>
        <Parameter name="thePIC" type="CMIF_PopupInfoController" usage="input"/>
