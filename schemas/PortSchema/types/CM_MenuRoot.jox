    <JadeMethod name="clearMenu" id="90d8bf8d-5cd9-4662-aa54-809625cea883">
        <source>clearMenu();
// ---------------------------------------------------------------------------
// Created:     02 December 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.allChildren.purge;
	if (not self.allMenuUserItemsWithAMenuItem.isEmpty) then
		// a bug at one point meant that this had items in it
		// that were not in the allChildren hierachy so do
		// this for belts and braces
		self.allMenuUserItemsWithAMenuItem.purge;
	endif;

end;</source>
    </JadeMethod>
