    <JadeMethod name="getNumTI" id="dd0f8624-f72f-46ae-b8b5-e262cd41065f">
        <source>getNumTI(_mode : Integer; _dTI : CM_TrackedItem) : Integer;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	dTI,aTI : CM_TrackedItem;
	numTi : Integer;
begin
	dTI := self.myGridArea.myDummyTI;
	if _mode = REAL_MODE then
		foreach aTI in self.allTrackedItems do
			if aTI &lt;&gt; dTI 
			and aTI &lt;&gt; _dTI then
				numTi := numTi + 1;
			endif;
		endforeach;
	endif;
	return numTi;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_dTI" type="CM_TrackedItem"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getPicture" id="d046a349-febf-4f2b-b007-5e5a009327a0">
        <updating/>
        <source>getPicture(_thePicture : Binary) : Picture updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	thePicture,aPicture : Object;

begin
	thePicture := null;
	foreach aPicture in self.allPictures do
		if aPicture.Picture.picture = _thePicture then
			thePicture := aPicture;
			break;
		endif;
	endforeach;
	
	return thePicture.Picture;
	
end;</source>
        <Parameter name="_thePicture" type="Binary"/>
        <ReturnType type="Picture"/>
    </JadeMethod>
