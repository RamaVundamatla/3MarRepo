    <JadeMethod name="setComboValues" id="11f25579-defc-4111-8411-6c7027c80d9b">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 May 2023	navlw1	Initial creation ChangeRequest 58146: EUP - VBS MTN - [6] - Selector Query and JRW Part 2

*/

vars
	selectStr		: String;
	
begin
	_combo.clear();
	_combo.sorted := true;
	
	_combo.addItem(app.vbsStatusNumToString(CM_VehicleBookingTimeSlot.AvailableNotBookedInt));
	_combo.addItem(app.vbsStatusNumToString(CM_VehicleBookingTimeSlot.BookedNotYetDueInt));
	_combo.addItem(app.vbsStatusNumToString(CM_VehicleBookingTimeSlot.BookedOverdueInt));
	_combo.addItem(app.vbsStatusNumToString(CM_VehicleBookingTimeSlot.BookedCurrentInt));
	_combo.addItem(app.vbsStatusNumToString(CM_VehicleBookingTimeSlot.BookedArrivedEarlyInt));
	_combo.addItem(app.vbsStatusNumToString(CM_VehicleBookingTimeSlot.BookedArrivedLateInt));
	_combo.addItem(app.vbsStatusNumToString(CM_VehicleBookingTimeSlot.BookedArrivedOntimeInt));
	_combo.addItem(app.vbsStatusNumToString(CM_VehicleBookingTimeSlot.NoLongerAvailInt));
	
	if CM_QStringLookup.hasInstance(_queryOperator) then
		_combo.text := _queryOperator.CM_QStringLookup.selectionValue;
	elseif CM_QStringLookupNotEqual.hasInstance(_queryOperator) then
		_combo.text := _queryOperator.CM_QStringLookupNotEqual.selectionValue;
	endif;

epilog

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="715ddd76-d92a-47fe-8ff5-f1e674dabbe8">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Aug 2023 navhl20 Bug 60056: FR | 53429 - VBS Selector issues

*/

vars
	idx,intSite	: Integer;
	strObj		: CM_String;
	objArr		: ObjectArray;
begin

	_tbl.purgeTableObjects();
	_tbl.clear;
	_tbl.rows := _tbl.fixedRows;	

	create objArr transient;
	create strObj transient;
	strObj.string := app.vbsStatusNumToString(CM_VehicleBookingTimeSlot.AvailableNotBookedInt);
	objArr.add(strObj);
	create strObj transient;
	strObj.string := app.vbsStatusNumToString(CM_VehicleBookingTimeSlot.BookedNotYetDueInt);
	objArr.add(strObj);
	create strObj transient;
	strObj.string := app.vbsStatusNumToString(CM_VehicleBookingTimeSlot.BookedOverdueInt);
	objArr.add(strObj);
	create strObj transient;
	strObj.string := app.vbsStatusNumToString(CM_VehicleBookingTimeSlot.BookedCurrentInt);
	objArr.add(strObj);
	create strObj transient;
	strObj.string := app.vbsStatusNumToString(CM_VehicleBookingTimeSlot.BookedArrivedEarlyInt);
	objArr.add(strObj);
	create strObj transient;
	strObj.string := app.vbsStatusNumToString(CM_VehicleBookingTimeSlot.BookedArrivedLateInt);
	objArr.add(strObj);
	create strObj transient;
	strObj.string := app.vbsStatusNumToString(CM_VehicleBookingTimeSlot.BookedArrivedOntimeInt);
	objArr.add(strObj);
	create strObj transient;
	strObj.string := app.vbsStatusNumToString(CM_VehicleBookingTimeSlot.NoLongerAvailInt);
	objArr.add(strObj);
	
	foreach strObj in objArr as CM_String do
		if _operator &lt;&gt; null and _operator.CM_QStringIsOneOf.allSelectionValues.includes(strObj.string) then
			idx := _tbl.addItem(1.String &amp; Tab &amp; strObj.string);
		else
			idx := _tbl.addItem(0.String &amp; Tab &amp; strObj.string);	
		endif;
		_tbl.accessRow(idx).itemObject := strObj;
		_tbl.row := idx;
		_tbl.change(_tbl);
	endforeach;
epilog
	
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="fbc210e4-fb3a-44cc-9ffc-ba6b903d81e5">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Aug 2023 navhl20 Bug 60056: FR | 53429 - VBS Selector issues

*/

vars
	str				: String;
	numRows,
	idx				: Integer;
	strObj			: CM_String;
	vbsStatusArr	: StringArray;  

begin

	create vbsStatusArr transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			strObj := _tbl.accessRow(idx).itemObject.CM_String;
			vbsStatusArr.add(strObj.string);
		endif;
	endforeach;
	
	_op.setSearchValue(vbsStatusArr);

epilog
	delete vbsStatusArr;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
</Class>
