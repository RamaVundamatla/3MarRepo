        <source>valMachineForLogon(_machineId : String; 
					_terminalId	 : String;
					_passport : CM_Passport input) : CM_Machine;
/*

Date		Who		Reason
19 May 2017	cnwer1	Initial creation TFS 995

*/

vars
	machine : CM_Machine;
	terminal : CM_Terminal;
begin
	terminal :=app.myRoot.allTerminals[_terminalId];
	if terminal = null then
		app.raiseCMException(Input_required_field_terminal,null,null);
		return null;
	endif;
		
	// Validate incoming machine Id
	if _machineId = null then
		app.raiseCMException1(Input_required_field_Required, CM_ITSInterfaceMessage.XMLTag_MachineId, null, null); // cnwdb2	PAR 35364
		return null;
	endif;
	
	machine:= terminal.machines[_machineId];
	if machine = null then
		app.raiseCMException2(ERR_MACH_NOTFOUND,_machineId,_terminalId,null,null);
		return null;
	endif;
	
	if not machine.isValidForRT then
		app.raiseCMException1(ERR_MACH_NO_RT, _machineId, null, null);
		return null;
	endif;
		
	return machine;
epilog

end;</source>
        <Parameter name="_machineId" type="String"/>
        <Parameter name="_terminalId" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="valMachineQueue" id="231113d3-88e8-41f9-8540-223a23003747">
        <source>valMachineQueue(_proxyMachine : CM_Machine; _queue : CM_RadioTelemetryQueue);
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	machineType : CM_MachineType;

begin
	self.raiseExceptionIfNull(_proxyMachine, 'Machine Proxy');
	
	// DVB now done later in addMachine 11/03/2005
//	_proxyMachine.checkCanJoinQueue();
	_proxyMachine.canAddToQueue(_queue);
	_queue.canMachineAccess(_proxyMachine);
	
	machineType := _proxyMachine.getMachineType();
	if machineType &lt;&gt; null then
		if not _queue.compareQueueToType(machineType.myMachineTypeGroup) then
			app.setContinueCMExceptions(false);
			app.raiseCMException3(MACH_QUEUE_MACH_TYPE, _proxyMachine.id, _queue.id,machineType.description,  null, null);
		endif;
	endif;
	
end;</source>
        <Parameter name="_proxyMachine" type="CM_Machine"/>
        <Parameter name="_queue" type="CM_RadioTelemetryQueue"/>
    </JadeMethod>
    <JadeMethod name="valMachineRejectTask" id="34193ebf-2982-4ca8-8f6c-93df98e4f241">
        <source>valMachineRejectTask(	_machine : CM_Machine ;
						_rtQueueTask : CM_RTQueueTask;
						_addToRejectList : Boolean);
/*

Date		Who		Reason
09 May 2017	cnwer1	Initial creation TFS  995 refactored from MobileServerSchema CM_ValidationAgent::valCancelTask

*/

vars

queue 	: CM_RadioTelemetryQueue;
	queueId : String;
	
begin
	if _machine = null then
		return; //don't raise error anymore.  The valMediator() will pick up this error
	endif;
	
	if _rtQueueTask = null then
		queue := _machine.getQueue();
		if queue &lt;&gt; null then
			queueId := queue.id;
		endif;

		app.raiseCMException2(ERR_ALERT_NOTASKS,_machine.id,queueId,null,null);
		return;
	endif;
	
	if (_addToRejectList or _rtQueueTask.status &lt;&gt; TASK_UNACTIONED) and  _rtQueueTask.intendedMachine = _machine then
		app.raiseCMException(Cannot_reject_control_alloc,null,null);
	endif;
	
	if _rtQueueTask.machine = null then
		//epr par 16746 if it is null then don't add exception just return to cancel the task
		return;
	endif;
	
	if _rtQueueTask.machine &lt;&gt;  _machine then
		app.raiseCMException2(ERR_MACH_BUSY,_rtQueueTask.machine.id,_rtQueueTask.queueId,null,null);
	endif;	

epilog

end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_rtQueueTask" type="CM_RTQueueTask"/>
        <Parameter name="_addToRejectList" type="Boolean"/>
    </JadeMethod>
