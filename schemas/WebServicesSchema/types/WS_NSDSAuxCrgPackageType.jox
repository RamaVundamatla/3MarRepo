<Class name="WS_NSDSAuxCrgPackageType" id="56bae03b-b157-429f-bcc4-0cb7f6273622">
    <superclass name="WS_NSDSObject"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="client_id" id="34552d24-2a0d-43d8-8e31-a8134c484168">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="description" id="1649f8c8-9e01-4767-bc2c-bd9393338fe5">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="id" id="189b0dff-1377-4e20-8e1b-be47370d16e0">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="ucc_code" id="e1ce3267-3745-47d9-af12-5d97714b7b73">
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="setProxyObject" id="f2bfc8fa-21be-4945-b1d7-30ff59ee96be">
        <updating/>
        <source>setProxyObject(_any : Any) updating;
/*
Purpose:			

Date		Who		Reason
20MAY2022	NAVAB1	TFS 53105
*/

vars
	helper 	: CMIF_AuxCrgPackageType;
	ewsOpsView: CM_EWSActivityOpsview;
begin
	
	inheritMethod(_any);
	
	create helper transient;
	create ewsOpsView transient;
	ewsOpsView.initialiseActivity("","",_any.CM_Object.getMyTerminal(),_any.CM_Object, null,null,false,null);
	helper.initializeForActivity(_any, ewsOpsView);
	
	self.tableName	:= helper.tableName;
	self.gkey       := helper.gkey;
	self.client_id 	:= helper.client_id;
	self.id 		:= helper.id;
	self.description := helper.description;
	self.ucc_code	:= helper.ucc_code;

epilog
	delete helper;
	delete ewsOpsView;
end;</source>
        <Parameter name="_any" type="Any"/>
    </JadeMethod>
</Class>
