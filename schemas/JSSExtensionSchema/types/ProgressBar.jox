<GUIClass name="ProgressBar">
    <JadeMethod name="jssDone" id="ad658728-6285-492a-a978-d9e14f52c368">
        <updating/>
        <source>jssDone(pValue:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		Updates the receiver's parts-done with the specified value.
//
// Parameters:	pValue - The number of a task's parts that are completed.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.partsDone &lt;&gt; pValue then
		self.partsDone	:=	pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="Integer"/>
    </JadeMethod>
</GUIClass>
