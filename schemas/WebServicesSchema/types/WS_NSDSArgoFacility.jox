    <JadeMethod name="setProxyObject" id="6ac5dc22-609f-4ece-b6f6-c2d0c1b46672">
        <updating/>
        <source>setProxyObject(_any : Any) updating;
/*

Purpose:			
	Mapping 
	MTN : CM_Terminal
	N4  : argo_facility
Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2020 cnwma1 ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data

*/

vars
	helper 	: CMIF_ArgoFacility;
	ewsOpsView: CM_EWSActivityOpsview;
begin
	
	inheritMethod(_any);
	
	create helper transient;
	create ewsOpsView transient;
	ewsOpsView.initialiseActivity("","",_any.CM_Object.getMyTerminal(),_any.CM_Object, null,null,false,null);
	helper.initializeForActivity(_any, ewsOpsView);
	
	self.tableName	:= helper.tableName;
	self.gkey       := helper.gkey;
	self.cpx_gkey 	:= helper.cpx_gkey;
	self.id 		:= helper.id;
	self.name 	    := helper.name;
	self.time_zone	:= helper.time_zone;
	self.mu_gkey := helper.mu_gkey; // ### TFS 53105 31MAY2022 NAVAB1

epilog
	delete helper;
	delete ewsOpsView;
end;</source>
        <Parameter name="_any" type="Any"/>
    </JadeMethod>
</Class>
