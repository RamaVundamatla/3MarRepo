<Class name="UT_Contract" id="cbcb32c1-07f1-4960-9f4f-50f1af83b119">
    <superclass name="UT_Invoicing"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="unitTest"/>
    <JadeMethod name="addNewCargoType" id="020fcf3e-3b34-4ab2-be83-db4e1c3b5bcc">
        <source>addNewCargoType() : CM_CargoType;
/*
Purpose:			

Date		Who		Reason
14 February 2024	navab1	CR 61579 TASK 62453
*/
constants
	CARGOTYPEDESC = "UTSLO";
vars
	cargoType: CM_CargoType;
	term : CM_Terminal;
begin
	term := self.getTerminal();

	self.opts.purge;
	self.opts.addAssociation("teuMultiplier", TEUMultiplierIndexQ);
	self.opts.addAssoc("AllowDuplicateId", false);
	self.opts.addAssoc("isCargoGroupRequired", false);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	
	
	return cargoType;
epilog

end;</source>
        <ReturnType type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="createContainerOnShip" id="b0299be6-ad97-4f0c-9456-a606af8fd9b4">
        <source>createContainerOnShip(_contractId, _id : String; _operator : CM_Operator; _voyage : CM_Voyage; _port : CM_Port; _weight : Integer) : CM_Container;
/*
Purpose:			

Date		Who		Reason
26 January 2023	navab1	TFS CR 55624 TASK 55700 
*/

vars
	cont : CM_Container;
begin
	self.deleteContainer(_id);

	self.opts.purge();
	
	cont := self.addContainerOnShip( _id , _operator, "2200", "GENL", null, _voyage, _port.code, _voyage.code).CM_Container;
	self.assertNotNull(cont);
	self.opts.addAssoc("Description", "CargoDesc1");
	self.opts.addAssoc("ClientRef",  "ClientRef21");
	self.opts.addAssoc("Consignee",  "UTDDC");
	self.opts.addAssoc("Consignor",  "UTMO1");
	self.opts.addAssoc("ContractId",_contractId);
	self.opts.addAssoc("TotalWeight",_weight);

	self.updateTI(cont);

	self.assertTrueMsg(cont.contractId = _contractId, "Container Contract Id is wrong");
	assertEqual(cont.totalWeight, _weight.Decimal);

	return cont;
epilog

end;</source>
        <Parameter name="_contractId" type="String"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_port" type="CM_Port"/>
        <Parameter name="_weight" type="Integer"/>
        <ReturnType type="CM_Container"/>
    </JadeMethod>
    <JadeMethod name="createContract" id="82679203-f1d9-489f-95b2-17e6dc562c53">
        <updating/>
        <source>createContract(_debtor : CM_Debtor; _contractId : String; _active, primary : Boolean; _fromTS, _toTS : TimeStamp; _purgeContracts : Boolean) : CM_InvoiceContract updating;
/*
Purpose:			

Date		Who		Reason
08 December 2022	navab1	TFS CR 55623 TASK 55672
*/
 // ### TFS CR 55645 TASK 55662 13DEC2022 NAVAB1 added debtor parameter
 
vars
	pxyCon, realCon : CM_InvoiceContract;
	terminal : CM_Terminal;
	bank : CM_Bank;
	debtor : CM_Debtor;
begin
	debtor := _debtor;
	terminal := self.getTerminal();
	bank := terminal.getDefaultCompanyBank();

	if _purgeContracts then
		self.deleteAllContractsForDebtor(debtor);
	endif;
	
	create pxyCon transient;
	pxyCon.setProxy(_active,_contractId, _fromTS, _toTS, primary, bank, terminal, debtor, "Generated By Unit Test");
	
	app.myTrxCA.trxCreateInvContract(pxyCon, realCon, app.myPassport);
	
	assertNoTrxErrorsOrWarnings();
	assertTrueMsg(realCon.contractId = _contractId, "Contract Id should be " &amp; _contractId &amp; ", it is &gt;&gt;&gt;" &amp; realCon.contractId &amp; "&lt;&lt;&lt;");
	assertTrueMsg(realCon.primary = primary, "Contract should NOT be PRIMARY");
	assertTrueMsg(realCon.active = _active, "Contract should NOT be ACTIVE");
	assertTrueMsg(realCon.myBusinessUnit &lt;&gt; null, "BANK is null");
	assertTrueMsg(realCon.myBusinessUnit = bank, "BANK is wrong");
	assertTrueMsg(realCon.myTerminal &lt;&gt; null, "TERMINAL is null");
	assertTrueMsg(realCon.myTerminal = terminal, "TERMINAL is wrong");
	assertTrueMsg(realCon.myDebtor &lt;&gt; null, "DEBTOR is null");
	assertTrueMsg(realCon.myDebtor = debtor, "DEBTOR is wrong");
	assertTrueMsg(realCon.description = "Generated By Unit Test", "Description is wrong");
	
	return realCon;
epilog
	delete pxyCon;
end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_contractId" type="String"/>
        <Parameter name="_active" type="Boolean"/>
        <Parameter name="primary" type="Boolean"/>
        <Parameter name="_fromTS" type="TimeStamp"/>
        <Parameter name="_toTS" type="TimeStamp"/>
        <Parameter name="_purgeContracts" type="Boolean"/>
        <ReturnType type="CM_InvoiceContract"/>
    </JadeMethod>
    <JadeMethod name="createContract4DebtRte" id="f1211e51-9654-4a1f-a4c0-54bde6efe469">
        <updating/>
        <source>createContract4DebtRte(_contractid : String; _debtor : CM_Debtor; _fromTS, _toTS : TimeStamp; _active, primary : Boolean; _operator : CM_Operator; _cargoType : CM_CargoType; 
							_ildl : CM_InvoiceLineDesc; _service : CM_Service; _purgeContracts : Boolean; _cpu : Decimal; _shipTerm : CM_InvoiceContractShipTerm) : CM_InvoiceContract updating;
/*
Purpose:			

Date		Who		Reason
16 January 2023	navab1	TFS CR 55644 TASK 55684
*/

vars
	realCon : CM_InvoiceContract;
	realConDtl : CM_InvoiceContractDetails;
	realRate : CM_InvoiceContractRate;
	realRateEntry01, realRateEntry02, realRateEntry03 : CM_InvoiceContractRateEntry;

begin
	// Contract
	realCon := self.createContract(_debtor,_contractid,_active, primary, _fromTS, _toTS,_purgeContracts);

	// Detail
	realConDtl := self.createContractDetail4DebtrRate(realCon,_operator, _cargoType, _ildl,_fromTS, _toTS, _shipTerm);
	
	// Rate
	realRate := self.createContractRate(realConDtl,_service);
	
	// Entries
	realRateEntry01 := self.createContractRateEntry(realRate,_cpu,0,100,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry02 := self.createContractRateEntry(realRate,_cpu * 10,101,500,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry03 := self.createContractRateEntry(realRate,_cpu * 100,501,99999999,realConDtl.fromTS, realConDtl.toTS);

	return realCon;
epilog

end;</source>
        <Parameter name="_contractid" type="String"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_fromTS" type="TimeStamp"/>
        <Parameter name="_toTS" type="TimeStamp"/>
        <Parameter name="_active" type="Boolean"/>
        <Parameter name="primary" type="Boolean"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_ildl" type="CM_InvoiceLineDesc"/>
        <Parameter name="_service" type="CM_Service"/>
        <Parameter name="_purgeContracts" type="Boolean"/>
        <Parameter name="_cpu" type="Decimal"/>
        <Parameter name="_shipTerm" type="CM_InvoiceContractShipTerm"/>
        <ReturnType type="CM_InvoiceContract"/>
    </JadeMethod>
    <JadeMethod name="createContract4DebtRte3Dtl" id="5a1847cc-4877-46eb-a3c1-2a477c3215e0">
        <updating/>
        <source>createContract4DebtRte3Dtl(_contractid : String; _debtor : CM_Debtor; _fromTS, _toTS : TimeStamp; _active, primary : Boolean; _operator : CM_Operator; _cargoType : CM_CargoType; 
							_ildl : CM_InvoiceLineDesc; _service : CM_Service; _purgeContracts : Boolean; _cpu : Decimal) : CM_InvoiceContract updating;
/*
Purpose:			

Date		Who		Reason
16 January 2023	navab1	TFS CR 55644 TASK 55684
*/

vars
	realCon : CM_InvoiceContract;
	realConDtl : CM_InvoiceContractDetails;
	realRate : CM_InvoiceContractRate;
	realRateEntry01, realRateEntry02, realRateEntry03 : CM_InvoiceContractRateEntry;
	
	dtlFrom1, dtlFrom2, dtlFrom3 : TimeStamp;
	dtlTo1, dtlTo2, dtlTo3 : TimeStamp;
	
begin
	
	// Contract
	realCon := self.createContract(_debtor,_contractid,_active, primary, _fromTS, _toTS,_purgeContracts);

	// create 3  details each with its own date range. The passed in date range will be for 15 days, so make each detail 5 days.
	dtlFrom1 := _fromTS;
	dtlTo1 := dtlFrom1.addDays(2);
	dtlFrom2 := dtlTo1.addDays(1);
	dtlTo2 := dtlFrom2.addDays(4);
	dtlFrom3 := dtlTo2.addDays(1);
	dtlTo3 := _toTS;
	

	// ### Detail 1
	realConDtl := self.createContractDetail4DebtrRate(realCon,_operator, _cargoType, _ildl,dtlFrom1, dtlTo1, null);
	
	// Rate
	realRate := self.createContractRate(realConDtl,_service);
	
	// Entries
	
	// Rate Entries ONE
	realRateEntry01 := self.createContractRateEntry(realRate,_cpu * 11,0,100,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry02 := self.createContractRateEntry(realRate,_cpu * 111,101,500,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry03 := self.createContractRateEntry(realRate,_cpu * 1111,501,99999999,realConDtl.fromTS, realConDtl.toTS);

	// ### Detail 2
	realConDtl := self.createContractDetail4DebtrRate(realCon,_operator, _cargoType, _ildl, dtlFrom2, dtlTo2, null);
	
	// Rate
	realRate := self.createContractRate(realConDtl,_service);
	
	// Entries
	realRateEntry01 := self.createContractRateEntry(realRate,_cpu * 20,0,100,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry02 := self.createContractRateEntry(realRate,_cpu * 200,101,500,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry03 := self.createContractRateEntry(realRate,_cpu * 2000,501,99999999,realConDtl.fromTS, realConDtl.toTS);

	// ### Detail 3
	realConDtl := self.createContractDetail4DebtrRate(realCon,_operator, _cargoType, _ildl, dtlFrom3, dtlTo3, null);
	
	// Rate
	realRate := self.createContractRate(realConDtl,_service);
	
	// Entries
	realRateEntry01 := self.createContractRateEntry(realRate,_cpu * 30,0,100,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry02 := self.createContractRateEntry(realRate,_cpu * 300,101,500,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry03 := self.createContractRateEntry(realRate,_cpu * 3000,501,99999999,realConDtl.fromTS, realConDtl.toTS);

	return realCon;
epilog

end;</source>
        <Parameter name="_contractid" type="String"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_fromTS" type="TimeStamp"/>
        <Parameter name="_toTS" type="TimeStamp"/>
        <Parameter name="_active" type="Boolean"/>
        <Parameter name="primary" type="Boolean"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_ildl" type="CM_InvoiceLineDesc"/>
        <Parameter name="_service" type="CM_Service"/>
        <Parameter name="_purgeContracts" type="Boolean"/>
        <Parameter name="_cpu" type="Decimal"/>
        <ReturnType type="CM_InvoiceContract"/>
    </JadeMethod>
    <JadeMethod name="createContract4DebtRte3Dtl3Rte" id="896e8e93-c6da-4461-a3ee-6a26b86143c1">
        <updating/>
        <source>createContract4DebtRte3Dtl3Rte(_contractid : String; _debtor : CM_Debtor; _fromTS, _toTS : TimeStamp; _active, primary : Boolean; _operator : CM_Operator; _cargoType : CM_CargoType; 
							_ildl : CM_InvoiceLineDesc; _service : CM_Service; _purgeContracts : Boolean; _cpu : Decimal) : CM_InvoiceContract updating;
/*
Purpose:			

Date		Who		Reason
16 January 2023	navab1	TFS CR 55644 TASK 55684
*/

vars
	realCon : CM_InvoiceContract;
	realConDtl : CM_InvoiceContractDetails;
	realRate : CM_InvoiceContractRate;
	realRateEntry01, realRateEntry02, realRateEntry03 : CM_InvoiceContractRateEntry;
	
	dtlFrom1, dtlFrom2, dtlFrom3 : TimeStamp;
	dtlTo1, dtlTo2, dtlTo3 : TimeStamp;
	
	rteFrom1, rteFrom2, rteFrom3 : TimeStamp;
	rteTo1, rteTo2, rteTo3 : TimeStamp;
	stTime, endTime : Time;
	

begin
	stTime.setTime(0,0,0,0);
	endTime.setTime(23,59,59,999);
	
	// Contract
	realCon := self.createContract(_debtor,_contractid,_active, primary, _fromTS, _toTS,_purgeContracts);

	// create 3  details each with its own date range. The passed in date range will be for 15 days, so make each detail 5 days.
	dtlFrom1 := _fromTS;
	dtlTo1 := dtlFrom1.addDays(2);
	dtlFrom1.setTime(stTime);
	dtlTo1.setTime(endTime);

	dtlFrom2 := dtlTo1.addDays(1);
	dtlTo2 := dtlFrom2.addDays(4);
	dtlFrom2.setTime(stTime);
	dtlTo2.setTime(endTime);

	dtlFrom3 := dtlTo2.addDays(1);
	dtlTo3 := _toTS;
	dtlFrom3.setTime(stTime);
	dtlTo3.setTime(endTime);

	

	// ########### Detail 1
	realConDtl := self.createContractDetail4DebtrRate(realCon,_operator, _cargoType, _ildl,dtlFrom1, dtlTo1, null);
	
	// Rate
	realRate := self.createContractRate(realConDtl,_service);
	
	// Entries
	// create 3  Entries each with its own date range. 
	rteFrom1 := dtlFrom1;
	rteTo1 := rteFrom1;
	rteFrom1.setTime(stTime);
	rteTo1.setTime(endTime);

	rteFrom2 := rteTo1.addDays(1);
	rteTo2 := rteFrom2;
	rteFrom2.setTime(stTime);
	rteTo2.setTime(endTime);

	rteFrom3 := rteTo2.addDays(1);
	rteTo3 := dtlTo1;
	rteFrom3.setTime(stTime);
	rteTo3.setTime(endTime);

	
	// Rate Entries ONE
	realRateEntry01 := self.createContractRateEntry(realRate,_cpu * 1.1,0,100,rteFrom1, rteTo1);
	realRateEntry02 := self.createContractRateEntry(realRate,_cpu * 1.11,101,500,rteFrom1, rteTo1);
	realRateEntry03 := self.createContractRateEntry(realRate,_cpu * 1.111,501,99999999,rteFrom1, rteTo1);
	
	// Rate Entries TWO
	realRateEntry01 := self.createContractRateEntry(realRate,_cpu * 2.2,0,100,rteFrom2, rteTo2);
	realRateEntry02 := self.createContractRateEntry(realRate,_cpu * 2.22,101,500,rteFrom2, rteTo2);
	realRateEntry03 := self.createContractRateEntry(realRate,_cpu * 2.222,501,99999999,rteFrom2, rteTo2);
	
	// Rate Entries THREE
	realRateEntry01 := self.createContractRateEntry(realRate,_cpu * 3.3,0,100,rteFrom3, rteTo3);
	realRateEntry02 := self.createContractRateEntry(realRate,_cpu * 3.33,101,500,rteFrom3, rteTo3);
	realRateEntry03 := self.createContractRateEntry(realRate,_cpu * 3.333,501,99999999,rteFrom3, rteTo3);

	// ########### Detail 2
	realConDtl := self.createContractDetail4DebtrRate(realCon,_operator, _cargoType, _ildl, dtlFrom2, dtlTo2, null);
	
	// Rate
	realRate := self.createContractRate(realConDtl,_service);
	// create 3  Entries each with its own date range. 
	rteFrom1 := dtlFrom2;
	rteTo1 := rteFrom1;
	rteFrom1.setTime(stTime);
	rteTo1.setTime(endTime);

	rteFrom2 := rteTo1.addDays(1);
	rteTo2 := rteFrom2;
	rteFrom2.setTime(stTime);
	rteTo2.setTime(endTime);

	rteFrom3 := rteTo2.addDays(1);
	rteTo3 := dtlTo2;
	rteFrom3.setTime(stTime);
	rteTo3.setTime(endTime);

	
	// Entries
	// Rate Entries ONE
	realRateEntry01 := self.createContractRateEntry(realRate,_cpu * 1.18,0,100,rteFrom1, rteTo1);
	realRateEntry02 := self.createContractRateEntry(realRate,_cpu * 1.118,101,500,rteFrom1, rteTo1);
	realRateEntry03 := self.createContractRateEntry(realRate,_cpu * 1.1118,501,99999999,rteFrom1, rteTo1);
	
	// Rate Entries TWO
	realRateEntry01 := self.createContractRateEntry(realRate,_cpu * 2.28,0,100,rteFrom2, rteTo2);
	realRateEntry02 := self.createContractRateEntry(realRate,_cpu * 2.228,101,500,rteFrom2, rteTo2);
	realRateEntry03 := self.createContractRateEntry(realRate,_cpu * 2.2228,501,99999999,rteFrom2, rteTo2);
	
	// Rate Entries THREE
	realRateEntry01 := self.createContractRateEntry(realRate,_cpu * 3.38,0,100,rteFrom3, rteTo3);
	realRateEntry02 := self.createContractRateEntry(realRate,_cpu * 3.338,101,500,rteFrom3, rteTo3);
	realRateEntry03 := self.createContractRateEntry(realRate,_cpu * 3.3338,501,99999999,rteFrom3, rteTo3);

	// ### Detail 3
	realConDtl := self.createContractDetail4DebtrRate(realCon,_operator, _cargoType, _ildl, dtlFrom3, dtlTo3, null);
	
	// Rate
	realRate := self.createContractRate(realConDtl,_service);
	// create 3  Entries each with its own date range. 
	rteFrom1 := dtlFrom3;
	rteTo1 := rteFrom1;
	rteFrom1.setTime(stTime);
	rteTo1.setTime(endTime);

	rteFrom2 := rteTo1.addDays(1);
	rteTo2 := rteFrom2;
	rteFrom2.setTime(stTime);
	rteTo2.setTime(endTime);

	rteFrom3 := rteTo2.addDays(1);
	rteTo3 := dtlTo3;
	rteFrom3.setTime(stTime);
	rteTo3.setTime(endTime);

	
	// Entries
	// Rate Entries ONE
	realRateEntry01 := self.createContractRateEntry(realRate,_cpu * 1.19,0,100,rteFrom1, rteTo1);
	realRateEntry02 := self.createContractRateEntry(realRate,_cpu * 1.119,101,500,rteFrom1, rteTo1);
	realRateEntry03 := self.createContractRateEntry(realRate,_cpu * 1.1119,501,99999999,rteFrom1, rteTo1);
	
	// Rate Entries TWO
	realRateEntry01 := self.createContractRateEntry(realRate,_cpu * 2.29,0,100,rteFrom2, rteTo2);
	realRateEntry02 := self.createContractRateEntry(realRate,_cpu * 2.229,101,500,rteFrom2, rteTo2);
	realRateEntry03 := self.createContractRateEntry(realRate,_cpu * 2.2229,501,99999999,rteFrom2, rteTo2);
	
	// Rate Entries THREE
	realRateEntry01 := self.createContractRateEntry(realRate,_cpu * 3.39,0,100,rteFrom3, rteTo3);
	realRateEntry02 := self.createContractRateEntry(realRate,_cpu * 3.339,101,500,rteFrom3, rteTo3);
	realRateEntry03 := self.createContractRateEntry(realRate,_cpu * 3.3339,501,99999999,rteFrom3, rteTo3);

	return realCon;
epilog

end;</source>
        <Parameter name="_contractid" type="String"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_fromTS" type="TimeStamp"/>
        <Parameter name="_toTS" type="TimeStamp"/>
        <Parameter name="_active" type="Boolean"/>
        <Parameter name="primary" type="Boolean"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_ildl" type="CM_InvoiceLineDesc"/>
        <Parameter name="_service" type="CM_Service"/>
