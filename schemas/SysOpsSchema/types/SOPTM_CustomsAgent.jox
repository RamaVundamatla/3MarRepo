    <JadeMethod name="doSave" id="3455416f-e9f5-4129-a832-ed0461301c45">
        <updating/>
        <source>doSave(): Boolean updating;

vars
	lDebtor : CM_Debtor;
	ignoreWarnings,rtnValue,
	lIsSuitableForRelease,
	isNotAvailableForEntry	: Boolean;
	proxyCustomsAgent	: CM_CustomsAgent;
	lCode					: String;
	lDescription			: String;
	theForm					: SOP_TableMaintForm;
	
begin
  
	theForm 				:= self.myForm;
	lCode 					:= theForm.tblInput1.getValueByName(ETRow_Code).String;
	lDescription 			:= theForm.tblInput1.getValueByName(ETRow_Name).String;
	isNotAvailableForEntry	:= theForm.tblInput1.getValueByName(ETRow_IsNotAvailableForEntry).Boolean;
	lDebtor := theForm.cmbDebtor.myObject.CM_Debtor;

	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_CustomsAgent transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyCustomsAgent := theForm.myProxyObject.CM_CustomsAgent;
	proxyCustomsAgent.setProxy(lCode, lDescription, isNotAvailableForEntry,lDebtor);

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateCustomsAgent(proxyCustomsAgent, theForm.myCurrentObject,app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateCustomsAgent(proxyCustomsAgent, app.myPassport);
	endif;

epilog
	return app.myPassport.trxCompletedOK;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
