    <JadeMethod name="addCalendarControl" id="9d2da564-08d8-47b1-a255-dd07f24aaedc">
        <source>addCalendarControl():CMUI_DateMask;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 April 2022	navhl20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	dateMaskInt : Integer;
	dateMask    : CMUI_DateMask;
begin
	dateMaskInt  := self.dateMaskArray.size + 1;
	dateMask	 := self.tblDate.loadControl( dateMaskInt ).CMUI_DateMask;
	self.dateMaskArray.add( dateMask );
	return dateMask;
epilog

end;</source>
        <ReturnType type="CMUI_DateMask"/>
    </JadeMethod>
    <JadeMethod name="addHoldJobToOOWConfrm" id="c7384010-5d1d-403a-bc87-d10acb7a42b7">
        <source>addHoldJobToOOWConfrm(_holdJob : CM_VoyageHoldJob; comboValues : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
25 April 2022	navhl20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	operStr : String;
	consignStr : String;
	workPointVar,
	workPoint : CM_WorkPoint;
	daysToComplete : Decimal[6,2];
	wpRate : CM_WorkPointCargoRates;
	dummyTi : CM_TrackedItem;
	gangs : Integer;
	wodDisplayStr : String;	
	rowIndex : Integer;
	commodStr : String;
	moveAmountStr : String;
	holdId : String;	
	hrsPerDay : String;
	targetPerHr : String;
	transferTypeStr : String;
	cargo   : CM_TrackedItem;
	transferTypesComboList : String;
	wpComboList : String;
	voyTfrType  : CM_VoyageJobTransferType;
	permitWod : CM_WodPermitRequest;
	cargoWod : CM_WodCargoRequest;
begin
	cargo:=_holdJob.workListEntries.first.myTrackedItem;
	
	operStr := cargo.operatorCode;
	consignStr := cargo.consignee;
	workPoint := _holdJob.getMyWorkPointObject.CM_WorkPoint;
	daysToComplete := 0.0;
	gangs := _holdJob.numOfGangs ;
	commodStr := cargo.commodity;
	moveAmountStr := _holdJob.workListEntries.first.getMoveAmountDisplay(true);
	holdId := _holdJob.getHoldId;
	transferTypeStr := _holdJob.getTransferTypeStr();
	
	if workPoint &lt;&gt; null then
		wpRate := workPoint.getDefinedTargetRate( _holdJob, null, dummyTi );
		if wpRate &lt;&gt; null then
			hrsPerDay 	   := wpRate.dailyHoursWorkable.asStringJMT;
			targetPerHr    := wpRate.getTargetRateStr;
			daysToComplete := wpRate.getDaysToComplete( _holdJob, gangs, false );
		endif;
	endif;
	
	
	if self.myPxyTask &lt;&gt; null and self.myPxyTask.isWorkOrderPermitContCargoPen() then
		permitWod := self.myPxyWorkOrder.allWoDtls.first.CM_WodPermitRequest;
		
		foreach cargoWod in permitWod.allCargoDetails	discreteLock do
			if cargoWod.taskID = cargo.id then
				workPoint 		:= cargoWod.myWorkpoint;
				gangs 			:= cargoWod.numGangs ;
				transferTypeStr := app.vesselAccessTypeEnumToStr( cargoWod.transferType );
				moveAmountStr   := cargoWod.getMoveAmountDisplay();
				break;
			endif;
		endforeach;
	endif;
	
	wodDisplayStr := holdId &amp; Tab						  // hold Id
				&amp;	 workPoint.code &amp; Tab				  // work point
				&amp;	 _holdJob.getJobTypeDescription &amp; Tab //job  type
				&amp;	 operStr &amp; Tab // operator
				&amp;	 consignStr &amp; Tab // consignee
				&amp;	 commodStr &amp; Tab // commodity
				&amp;	 moveAmountStr &amp; Tab // moveAmount
				&amp;	 transferTypeStr &amp; Tab // transfer type // TFS 42221 19DEC18
				&amp;	 gangs.asStringJMT &amp; Tab // gangs
				&amp;	 hrsPerDay &amp; Tab // hrs/day
				&amp;	 targetPerHr &amp; Tab // target/hr
				&amp;	 daysToComplete.asStringJMT &amp; Tab // days to complete
				&amp;	 "";	// Hold sub total
					
	rowIndex := self.tblOOWConfirm.addItem( wodDisplayStr );
	self.tblOOWConfirm.accessRow( rowIndex ).itemObject := _holdJob;
	self.tblOOWConfirm.accessRow( rowIndex ).inputType  := Table.InputType_None;
	
	foreach workPointVar in self.myTerminal.allWorkPointsByCode where not workPointVar.isNotAvailableForEntry do
		if wpComboList &lt;&gt; null then
			wpComboList := wpComboList &amp; Tab;
		endif;
		wpComboList := wpComboList &amp; workPointVar.code;
	
	endforeach;
	
	self.tblOOWConfirm.accessCell( rowIndex, WPCol ).inputType := Table.InputType_ComboBox;
	self.tblOOWConfirm.accessCell( rowIndex, WPCol).comboList  := wpComboList;// comboValues;
	
	foreach voyTfrType in app.myRoot.allVoyageJobTransferTypes do
		if voyTfrType.id = 0 then
			continue;
		endif;
		if transferTypesComboList &lt;&gt; null then
			transferTypesComboList := transferTypesComboList &amp; Tab;
		endif;
		transferTypesComboList := transferTypesComboList &amp; voyTfrType.description;
	endforeach;
	
	self.tblOOWConfirm.accessCell( rowIndex, TransferTypeCol ).inputType := Table.InputType_ComboBox;
	self.tblOOWConfirm.accessCell( rowIndex, TransferTypeCol).comboList  := transferTypesComboList;
	self.tblOOWConfirm.accessCell( rowIndex, GangsCol ).inputType        := Table.InputType_TextNumeric;
	self.tblOOWConfirm.accessCell( rowIndex, AmountCol ).inputType 		 := Table.InputType_TextBox;
epilog

end;</source>
        <Parameter name="_holdJob" type="CM_VoyageHoldJob"/>
        <Parameter name="comboValues" type="String"/>
    </JadeMethod>
    <JadeMethod name="addHoldSubTotalLine" id="05788dbb-b7ea-40ad-974d-b343b3070f74">
        <source>addHoldSubTotalLine(_holdId : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 April 2022	navhl20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	subTotal : Decimal[6,2];
	rowIndex : Integer;
	holdDisplayStr : String;

begin
	
	holdDisplayStr := _holdId &amp; Tab	// hold Id
				&amp;	 "" &amp; Tab	// work point
				&amp;	 "" &amp; Tab //job  type
				&amp;	 "" &amp; Tab // operator
				&amp;	 "" &amp; Tab // consignee
				&amp;	 "" &amp; Tab // commodity
				&amp;	 "" &amp; Tab // moveAmount
				&amp;	 "" &amp; Tab // transfer type
				&amp;	 "" &amp; Tab // gangs
				&amp;	 "" &amp; Tab // hrs/day
				&amp;	 "" &amp; Tab // target/hr
				&amp;	 "" &amp; Tab // days to complete
				&amp;	 subTotal.asStringJMT;	// Hold sub total
					
	rowIndex := self.tblOOWConfirm.addItem( holdDisplayStr );
	self.tblOOWConfirm.accessRow( rowIndex ).inputType := Table.InputType_None;
	self.tblOOWConfirm.accessRow( rowIndex ).backColor := self.tblOOWConfirm.accessRow( 1 ).backColor;
epilog

end;</source>
        <Parameter name="_holdId" type="String"/>
    </JadeMethod>
    <JadeMethod name="addWONewTask" id="6d6bd5f9-a77b-4c88-acf2-e5fe54551f46">
        <updating/>
        <source>addWONewTask(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 March 2023	navhl20	Defect 57097: MTN - 1090 exception when creating a work order using cargo enquiry screen
17 Feb 2025	navhl20 CR MTN-14693: EUP | Work Order improvement - automatic WO Tasks for Release Cargo Work Order Line items &lt;&lt;54014&gt;&gt;
*/

vars

begin
	self.doBtnTaskAdd(false);			//17.02.2025 navhl20 #14693
	
	if self.myPxyTask &lt;&gt; null then
		return true;
	endif;
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="adjustMulTablesHeights" id="f0cf930a-d333-40fb-b93c-bb0fc8f4c3fa">
        <source>adjustMulTablesHeights(isSecondaryVisible : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 December 2022	navcs2	ChangeRequest 56840:[54265] EUP - [Framework] - VAS Work Order Maintenance Sceen
24 Mar 2023 		navhl20 ChangeRequest 57301:[57303] EUP - [Framework] - Improve Audits on Work orders
14 April 2023	navcs2	Defect 57574: MTN - WO - The filter text is not getting cleared when selecting a new work order task

*/

vars

begin
	if isSecondaryVisible then
		self.mulToDoEntity.top	  := 25;
		self.mulToDoEntity.height := 200;
		self.mulToDoEntity.parentAspect := 1;											//24.3.2023 navhl20	#57301[57303] 14.04.2023 navcs2 Defect 57574
	else
		self.mulToDoEntity.top 	  := 25;												//24.3.2023 navhl20	#57301[57303] 14.04.2023 navcs2 Defect 57574
		self.mulToDoEntity.height := self.clientWindowHeight - 410;						//24.3.2023 navhl20	#57301[57303]
		self.mulToDoEntity.parentAspect := 3;											//24.3.2023 navhl20	#57301[57303]
	endif;
epilog

end;</source>
        <Parameter name="isSecondaryVisible" type="Boolean"/>
    </JadeMethod>
