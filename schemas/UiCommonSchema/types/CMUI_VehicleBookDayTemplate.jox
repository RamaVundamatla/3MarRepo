    <JadeMethod name="doResize" id="14e84a92-1365-475c-abb0-ee453f283368">
        <updating/>
        <source>doResize() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 April 2013	cnwndl1	Initial creation

*/

vars

begin

	inheritMethod();
	
