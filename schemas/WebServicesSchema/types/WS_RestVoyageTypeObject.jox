    <JadeMethod name="setProxyFromObject" id="97b62272-7294-41ca-ba91-4ca7df8773a4">
        <updating/>
        <source>setProxyFromObject(_voyage : CM_Voyage) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 22/07/2024	navdap1		Initial creation TFS 65286 CUX | Include cargo structure flags in voyage API
//
vars

begin
	self.holds := _voyage.structureIncludesHolds();
	self.lolo := _voyage.structureIncludesLOLO();
	self.roro := _voyage.structureIncludesRORO();
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
