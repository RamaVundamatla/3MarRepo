    <JadeMethod name="eprTestProspectiveCargo" id="0f9b0d1c-27d6-410b-b1eb-51a05cff1857">
        <source>eprTestProspectiveCargo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2021	jlier1	Initial creation

*/

vars
	terminal : CM_Terminal;
	br : CM_BulkRelease;
	target , source: CM_LocationsController;
		failedDAC  		 : CM_DataAccessController ;
	stwRule 		: Integer;
	tiArray 			 : CM_TIArray;
	cmifMobile 		: 	CMIF_MobileGenericAgent;
	tiSet				: CM_TISet;
	iter 			 : Iterator;
		cargo 			 : CM_TrackedItem;
begin
app.initialize();
	app.myPassport.setMyUserFromCode("JLGR1");
	
	terminal:=CM_Root.firstInstance.allTerminals["JBL"];
	app.myPassport.setMyTerminal(terminal);
	br:="2161.489537".asOid.CM_BulkRelease;
		target :="4519.6013042".asOid.CM_LocationsController;
		
	create cmifMobile transient;
	cmifMobile.setMyTerminal( app.myPassport.myTerminal);
	create tiArray transient;
	cmifMobile.getCargoBasedOnSTW12Rules(br,null, source, target,stwRule,tiArray);
		
	create tiSet transient;

	
	iter := tiArray.createIterator;	
	while iter.next(cargo) do
		
		if not cargo.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
			continue;
		endif;
		if  tiSet.includes(cargo) then
			continue;
		endif;
		write cargo.id;
		tiSet.add(cargo);
	endwhile;
epilog
	delete cmifMobile;
	delete iter;
	delete tiSet;
	delete tiArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="eprTestQShips" id="628b9fd6-95b6-4567-b280-79c20b5a158f">
        <executionLocation>client</executionLocation>
        <source>eprTestQShips()  clientExecution ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 October 2022	jlier1	Initial creation

*/

vars
request : Qships_Login;
	response : Qships_LoginResponse;
	//endPoint : Qships_PublicWebServicesWSSoap;
	rawRequest,rawRequest2 : String;
	endPoint: JadeWebServiceConsumer;
	requestBGP : BGP_QshipsRequest;
begin

	/*beginTransaction;
	BGP_QshipsRequest.instances.purge;
	create requestBGP persistent;
	requestBGP.setTerminal(CM_Root.firstInstance.allTerminals["JBL"]);
	commitTransaction;
	return;*/
	app.initialize;
		app.myPassport.setMyUserFromCode("JLGER1");
	app.myPassport.setMyTerminal(CM_Root.firstInstance.allTerminals["JBL"]);

	rawRequest:='&lt;?xml version="1.0" encoding="utf-8"?&gt;
&lt;soap:Envelope xmlns:soap="http://schemas.xmlsoap.org/soap/envelope/"&gt;
&lt;soap:Body&gt;
&lt;Login xmlns="http://kleinsystem.com/webservices/"&gt;
&lt;aUser&gt;9potest&lt;/aUser&gt;
&lt;aPasswd&gt;Brisbane99&lt;/aPasswd&gt;
