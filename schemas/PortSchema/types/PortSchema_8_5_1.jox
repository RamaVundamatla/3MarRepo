    <JadeMethod name="updateOperatorRequiresRequest" id="72d0ec15-3add-418b-9d14-785e508261e4">
        <source>updateOperatorRequiresRequest();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2015	cnwma1	Initial creation PAR #37125
There was an issue raised bt Centre Port,
If an Operator is configured to "Require Import Operator PIN" 
Then the system will give an error if a user attempts to move an item of this operator onto a wagon 
if the item is not currently assigned to a rail release request.

The Script will updates Otago Env to Set operator.requiresRequestNumber to true if the operator have the "RequiresImportOperatorPIN" set to true
and will set for any other customer to false .
*/

vars
	etAgent		: EntTableAgent;
	array 		: StringArray;
	isOtago			: Boolean;
	opr 		 : CM_Operator;
	
begin
	
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	app.writeLog(method.qualifiedName &amp; " Update Operator Requires Request", LogINFO);
	
	isOtago := app.myRoot.isClientPortOtago;
	
	foreach opr  in app.myRoot.allOperators discreteLock do
		if opr.getRequiresImpOperatorPIN then
			if isOtago then
				beginTransaction;
				opr.setPropertyValue("requiresRequestNumber",true);
				commitTransaction;
			endif;
		endif;
	endforeach;
	
	foreach opr  in app.myRoot.allOperators discreteLock do
		if not isOtago then
			beginTransaction;
			opr.setPropertyValue("requiresRequestNumber",false);
			commitTransaction;
		endif;
	endforeach;
	
	create etAgent transient;
	create array transient;

	etAgent.myEntTableDataRoot := app.myRoot.myEntTableDataRoot;

	array.add ("ETRow_RequiresRequestNumber");
	etAgent.trxUpdateFromConstant(array);
	
	write ETRow_RequiresRequestNumber;
	app.writeLog(method.qualifiedName &amp; " Update Operator Requires Request - Completed", LogINFO);
	self.addScriptRun(method.name);
epilog
	
	delete etAgent;
	delete array;
end;</source>
    </JadeMethod>
