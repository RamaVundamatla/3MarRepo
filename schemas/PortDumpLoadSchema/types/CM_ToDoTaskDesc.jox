<Class name="CM_ToDoTaskDesc">
    <JadeMethod name="exportPDXMLMyCollections" id="16e78ba6-f1e7-48a8-9dfb-daf9a8b13e66">
        <source>exportPDXMLMyCollections(_file: File; _objArray: ObjectArray io; _property: Property; _object: Object);

vars
	obj: Object;
begin
	if _property.name = CM_ToDoTaskDesc::allCargoTypes.name then
		_file.writeLine('&lt;'&amp;CM_ToDoTaskDesc::allCargoTypes.name&amp;'&gt;');
		foreach obj in self.allCargoTypes do
			_file.writeLine('&lt;class&gt;'&amp;obj.class.name&amp;'&lt;/class&gt;');
			_file.writeLine('&lt;theKey&gt;' &amp; obj.theKey &amp; '&lt;/theKey&gt;');
		endforeach;
		_file.writeLine('&lt;/'&amp;CM_ToDoTaskDesc::allCargoTypes.name&amp;'&gt;');
	endif;
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLCollections" id="63a9dbb1-13b9-4d79-9779-4cc2ee3f074d">
        <source>importPLXMLCollections(_name: String; _collectionsBlock: String);

vars
	aClass: Class;
	objBlock, nameBlock, theCode, theKey: String;
	blockLength, pos: Integer;
	cargoType: CM_CargoType;
	termArea: CM_TerminalArea;
begin
	if _name = CM_ToDoTaskDesc::allCargoTypes.name then
		objBlock := _collectionsBlock.cnEcGetTagValueOfName(CM_ToDoTaskDesc::allCargoTypes.name);
		if objBlock = null then
			return;
		endif;
		pos := 1;
		blockLength := objBlock.length;
		while pos &lt; blockLength do
			theCode := objBlock.cnEcGetNextTagValueOfName('class', pos);
			if pos &lt; 1 then
				break;
			endif;
			theKey := objBlock.cnEcGetNextTagValueOfName('theKey', pos);
			
			if theCode = null then
				continue;
			endif;
			aClass := currentSchema.getClass(theCode);
			if aClass &lt;&gt; null then
				cargoType := app.myRoot.allCargoTypesById[theKey.Integer];
				if cargoType &lt;&gt; null then
					self.allCargoTypes.add(cargoType);
				endif;				
			endif;
		endwhile;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_collectionsBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLFixupPost" id="7cc790ab-137f-40ec-945e-c4162121a45c">
        <updating/>
        <source>importPLXMLFixupPost() updating;

vars

begin
	// code is automaticly allocated
	self.code := 0;
end;</source>
    </JadeMethod>
    <JadeMethod name="importPLXMLReference" id="e94d4748-ed03-4f9e-a12e-95196b3d0542">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = CM_ToDoTaskDesc::myRoot.name then
		return app.myRoot;
	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</Class>
