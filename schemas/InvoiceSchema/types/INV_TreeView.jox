    <JadeMethod name="translateForm" id="85e5e5a3-015f-4334-8ef6-c7f9899e0dc1">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 January 2026 10:36:00.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
//	self.translateCaption(Xlat_0017592, locale);
	btnClearFilter.translateBubbleHelp(Xlat_0024513, locale);
	btnClearFilter.translateCaption(Xlat_0024514, locale);
	btnPrintList.translateBubbleHelp(Xlat_0006289, locale);
	btnPrintList.translateCaption(Xlat_0006290, locale);
	btnPropCancel.translateBubbleHelp(Xlat_0002291, locale);
	btnPropCancel.translateCaption(Xlat_0002298, locale);
	btnPropNext.translateBubbleHelp(Xlat_0002292, locale);
	btnPropNext.translateCaption(Xlat_0002299, locale);
	btnPropSave.translateBubbleHelp(Xlat_0002293, locale);
	btnPropSave.translateCaption(Xlat_0002300, locale);
	btnRefresh.translateBubbleHelp(Xlat_0002294, locale);
	btnRefresh.translateCaption(Xlat_0002301, locale);
	btnSearch.translateBubbleHelp(Xlat_0002295, locale);
	btnSearch.translateCaption(Xlat_0002302, locale);
	btnSearchCancel.translateBubbleHelp(Xlat_0002296, locale);
	btnSearchCancel.translateCaption(Xlat_0002303, locale);
	btnSearchSearch.translateBubbleHelp(Xlat_0002297, locale);
	btnSearchSearch.translateCaption(Xlat_0002304, locale);
	lblBank.translateCaption(Xlat_0020733, locale);
	lblSearch.translateCaption(Xlat_0002305, locale);		 
	msgPropFour.translateCaption(Xlat_0002306, locale);
	msgPropSix.translateCaption(Xlat_0006291, locale);
	msgPropThree.translateCaption(Xlat_0002307, locale);
	msgPropTwo.translateCaption(Xlat_0002308, locale);
	shtProp5.translateCaption(Xlat_0002309, locale);
	shtPropFour.translateCaption(Xlat_0002310, locale);
	shtPropOne.translateCaption(Xlat_0002311, locale);
	shtPropSix.translateCaption(Xlat_0006292, locale);
	shtPropThree.translateCaption(Xlat_0002312, locale);
	shtPropTwo.translateCaption(Xlat_0002313, locale);
	txtBank.translateCaption(Xlat_0020734, locale);
	txtFilterBox.translateBubbleHelp(Xlat_0024515, locale);
end;</source>
    </JadeMethod>
