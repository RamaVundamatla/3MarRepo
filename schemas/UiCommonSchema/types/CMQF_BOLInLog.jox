<Class name="CMQF_BOLInLog">
    <JadeMethod name="setFromAgent" id="d4d63296-ca0c-48d1-b5da-f00a9a9513e1">
        <updating/>
        <source>setFromAgent(_agent : CMUI_ReportAgent input) updating;
// ---------------------------------------------------------------------------
// Created:     06 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	aTime			: Time;
	tmpCarrier		: CM_Carrier;
	tmpString 		: String;
	iDPCount		: Integer;
begin
	inheritMethod(_agent);
	self.hasComments := _agent.getValueByNameIfVisible(ETRow_HasComments).Boolean;

	if _agent.isRowIncluded(ETRow_MatchDateStart) then
		if _agent.state = _agent.STATE_TEMPLATE_SAVE or
		   _agent.state = _agent.STATE_TEMPLATE_EDIT then
			/*self.setTemplateDateFields(_agent.getValueByNameIfVisible(ETRow_MatchDateStart).String, 
								self.matchStartDateTplType, self.matchStartDateTplFactor, ETRow_MatchDateStart);
			self.setTemplateDateFields(_agent.getValueByNameIfVisible(ETRow_MatchDateEnd).String, 
								self.matchEndDateTplType, self.matchEndDateTplFactor, ETRow_MatchDateEnd);*/
			self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_MatchDateStart), 
								self.matchStartDateTplType, self.matchStartDateTplFactor, ETRow_MatchDateStart);
			self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_MatchDateEnd), 
								self.matchEndDateTplType, self.matchEndDateTplFactor, ETRow_MatchDateEnd);
		else
			self.matchStartDate.setDate(_agent.getValueByName(ETRow_MatchDateStart).Date);
			self.matchEndDate.setDate(_agent.getValueByName(ETRow_MatchDateEnd).Date);
			self.startDate := null;
			self.endDate := null;
		endif;

	elseif _agent.isRowIncluded(ETRow_StartDate) then
		if _agent.state = _agent.STATE_TEMPLATE_SAVE or
		   _agent.state = _agent.STATE_TEMPLATE_EDIT then
			/*self.setTemplateDateFields(_agent.getValueByNameIfVisible(ETRow_StartDate).String, 
								self.startDateTplType, self.startDateTplFactor, ETRow_StartDate);
								
			self.setTemplateDateFields(_agent.getValueByNameIfVisible(ETRow_EndDate).String, 
								self.endDateTplType, self.endDateTplFactor, ETRow_EndDate);*/
			self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_StartDate), 
								self.startDateTplType, self.startDateTplFactor, ETRow_StartDate);
								
			self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_EndDate), 
								self.endDateTplType, self.endDateTplFactor, ETRow_EndDate);
		else
			//PAR16192 - cnwsh3 account for locale to accommodate web reports.
			//self.startDate := _agent.getValueByName(ETRow_StartDate).Date;
			//self.endDate := _agent.getValueByName(ETRow_EndDate).Date;
			self.startDate := _agent.getValueByNameForDateIfVisible(ETRow_StartDate);
			self.endDate := _agent.getValueByNameForDateIfVisible(ETRow_EndDate);

			self.matchStartDate := null;
			self.matchEndDate := null;
		endif;
	endif;

	//Start Time//////////////////////////////
	if _agent.isRowIncluded(ETRow_MatchTimeStart) then
		//set the time entered with explicit 000 milliseconds - just in case
		aTime := _agent.getValueByName(ETRow_MatchTimeStart).Time;
		if aTime.isValid then
			aTime.setTime(aTime.hour, aTime.minute, aTime.second, 0);
		else
			aTime.setTime(0, 0, 0, 0);//what happened if it got in here??!!??
		endif;
	else
		aTime.setTime(0, 0, 0, 0);
	endif;
	
	self.matchStartDate.setTime(aTime);
	//End Time ///////////////////////////////
	if _agent.isRowIncluded(ETRow_MatchTimeEnd) then
		//set the time entered with explicit 999 milliseconds - to be inclusive of entire second
		aTime := _agent.getValueByName(ETRow_MatchTimeEnd).Time;
		if aTime.isValid then
			if aTime.second = 0 then//par 16017
				aTime.setTime(aTime.hour, aTime.minute, 59, 999);
			else
				aTime.setTime(aTime.hour, aTime.minute, aTime.second, 999);
			endif;
		else
			aTime.setTime(0, 0, 0, 0);
		endif;
	else
		aTime.setTime(23, 59, 59, 999);
	endif;
	
	self.matchEndDate.setTime(aTime);
	
	self.loggingOrganisation := _agent.getValueByNameIfVisible(ETRow_LoggingOrganisation).String;
	self.loggingOperation := _agent.getValueByNameIfVisible(ETRow_LoggingOperation).String;
	self.gangNumber := _agent.getValueByNameIfVisible(ETRow_GangNumber).String;
	
	if self.myOperator &lt;&gt; null then
		self.setMyLogSpecies( self.myOperator.getLogSpecies(_agent.getValueByNameIfVisible(ETRow_LogSpecies).String) );
		if self.getMyLogSpecies &lt;&gt; null then
			self.setMyLogGrade( self.myOperator.getLogGrade(_agent.getValueByNameIfVisible(ETRow_LogSpecies).String,_agent.getValueByName(ETRow_LogGrade).String) );
		endif;
		if self.getMyLogGrade &lt;&gt; null then
			self.setMyLogType( self.myOperator.getLogType(_agent.getValueByNameIfVisible(ETRow_LogType).String) );
			self.setMyLogTreatment( self.myOperator.getLogTreatment(_agent.getValueByNameIfVisible(ETRow_LogTreatment).String) );
			self.setMyLogLength( self.myOperator.getLogLength(_agent.getValueByNameIfVisible(ETRow_LogLength).String) );
		endif;
	endif;

	self.sourceLocation := _agent.getSelectedSrcLocationCode();
	self.sourceSubLocation := _agent.getSelectedSrcSubLocationCode();
	self.sourceSubSubLocation := _agent.getSelectedSrcSubSubLocnCode();
	
	
	if _agent.isRowIncluded(ETRow_CarrierCode) then
		tmpCarrier := _agent.getSelectedCarrier();
		if tmpCarrier &lt;&gt; null then
			self.carrierCode := tmpCarrier.code;
		endif;
	endif;

	self.isPieceCountError			:= _agent.getValueByNameIfVisible(ETRow_PieceCountError).Boolean;		//#23894 CCMS JML 1110
	
end;</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
