        <updating/>
        <source>btnFindCarrier_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 August 2015	cnwndl1	Initial creation	Par 36789

*/

vars

	form : CMUI_ComboFilterSelectionForm;

begin

	create form transient;
	form.setMyRelatedCombo( self, self.cmbCarrier, self.lblCarrier.caption );
	if form.showModal() = IDOK then
		self.populateTblBulkRelease(self.cmbCarrier.listObject.CM_Carrier);
	endif;

epilog

end;</source>
