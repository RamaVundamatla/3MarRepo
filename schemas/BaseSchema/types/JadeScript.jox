    <JadeMethod name="cnwdad1_List_Translatables" id="22ea2e62-369b-40b1-9247-00c2acaa292e">
        <source>cnwdad1_List_Translatables();
// --------------------------------------------------------------------------------
// Created:		20 November 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	baseSchemaObj		: Schema;
	allXstrings			: ConstantNDict;
	localeArray			: ObjectArray;
	constantObj			: Constant;
	localeObject		: Object;
	localeName			: String;
	startTime			: Integer;
	
begin
	startTime		:=	app.clock();
	baseSchemaObj	:=	rootSchema.getSchema("BaseSchema");

	create localeArray transient;
	
	baseSchemaObj.getAllBaseLocales(localeArray);

	foreach localeObject in localeArray do
		localeName	:=	localeObject.Locale.makeLocaleName;
		allXstrings	:=	localeObject.Locale.getTranslatableStrings;
		
		foreach constantObj in allXstrings do
			write localeName &amp; ": " &amp; constantObj.TranslatableString.display;
		endforeach;
	endforeach;
epilog
	delete localeArray;
	
	write CrLf &amp; "Translatable String list completed in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_List_Unused_Methods" id="8b814903-dde6-4fe2-a929-38cad86b6d45">
        <source>cnwdad1_List_Unused_Methods() protected;
// --------------------------------------------------------------------------------
// Created:		23 August 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allClassesObj		: ClassColl;
	classObj			: Class;
	allMethodsObj		: MethodSet;
	allMethodRefsObj	: MethodSet;
	methodObj			: Method;
	unusedCount			: Integer;
	startTime			: Integer;
	
begin
	startTime	:=	app.clock();
	create allClassesObj transient;
	create allMethodsObj transient;
	create allMethodRefsObj transient;
	
	self.cnwdad1_GetBaseSchemaClasses(allClassesObj);
	write "Checking for unreferenced methods...";
	
	foreach classObj in allClassesObj do
		allMethodRefsObj.clear();
		allMethodsObj.clear();
		classObj.allMethods(allMethodsObj);
		
		foreach methodObj in allMethodsObj do
			methodObj.getMethodRefs(allMethodRefsObj);
			
			if allMethodRefsObj.isEmpty() then
				write classObj.name &amp; "::" &amp; methodObj.name;
				unusedCount	:=	unusedCount + 1;
			endif;
		endforeach;
	endforeach;
epilog
	delete allClassesObj;
	delete allMethodsObj;
	delete allMethodRefsObj;
	
	write unusedCount.cnEcNumberFormat() &amp; " unreferenced methods found in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="cnwdad1_List_Uses_Of_Class" id="049e670f-195b-4dc5-8201-16e269cc0993">
