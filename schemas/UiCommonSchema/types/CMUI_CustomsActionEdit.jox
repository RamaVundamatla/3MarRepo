    <JadeMethod name="doComboFileSegmentChange" id="69faf90c-cd7c-4a8a-8ae6-4e286d31dc00">
        <updating/>
        <source>doComboFileSegmentChange(_comboBox : ComboBox) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 July 2023	navpw1	Initial creation TFS: 58831 (58833)

*/

begin
	if _comboBox.itemData[_comboBox.listIndex] = EDIKeyField_Clearance_Value then
		self.height := 275;
		self.lblRoleCode.visible := true;
		self.cmbRoleCode.visible := true;
	else
		self.height := 255;
		self.lblRoleCode.visible := false;
		self.cmbRoleCode.visible := false;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_comboBox" type="ComboBox"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="7ef694c1-4b80-450a-97fc-d83f8b7b40a2">
        <updating/>
        <source>doSave( _next: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:	15 September 2008 By Graeme Black cnwgb1
// Purpose:	CCMS SFW 1012 Customs AMS Interface (PAR 17931)
// ---------------------------------------------------------------------------
vars
	pxyEDIAction 	: CM_EDIAction;
	realEDIAction	: CM_EDIAction;
	theReturn 		:Integer;
	isNew			:Boolean;
begin
	isNew := self.myEDIAction = null;
	// Create Proxy from Form
	create pxyEDIAction transient;
	if self.loadProxy( pxyEDIAction ) then
		app.myProxyManager.createProxyLink(self.myEDIAction, pxyEDIAction);
		
		// Validate
		if isNew then
			pxyEDIAction.validateForCreate();
		else
			pxyEDIAction.validateForUpdate();
		endif;
		
		// Update
		while true do
			if isNew then
				app.myTrxCA.trxCreateEDIAction(pxyEDIAction,realEDIAction, app.myPassport);
			else
				app.myTrxUA.trxUpdateEDIAction(pxyEDIAction,app.myPassport);
			endif;
	
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				break;
			else
				theReturn := app.showErrorWarningDialog("Customs Action", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
				return;
			endif;
			break;
		endwhile;
		
		self.myEDIAction := null;
	endif;
	
epilog
	delete pxyEDIAction;
end;</source>
        <Parameter name="_next" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initActionTypeCombo" id="d05bc569-9d5b-488d-a298-0fb673a0c459">
        <source>initActionTypeCombo();
// ---------------------------------------------------------------------------
// Created:	10 September 2008 By Graeme Black cnwgb1
// Purpose:	CCMS SFW 1012 Customs AMS Interface (PAR 17931)
// ---------------------------------------------------------------------------
// 30 Jul 2018	jlgsl4	TFS 39133 - Trade Single Window - NZCS &amp; MPI stops
// 31/10/2019	JLGNS1	ChangeRequest 46721: PEN - CAMIR Message Processing
vars
begin
	// CCMS SFW1039 PAR18889 - US Customs &amp; Border Protection messaging changes.
	// Added Global Constants to describe EDI Actions for X12.
	if self.ediFileType = EDIFileTypeX12_350_4010
	or self.ediFileType = EDIFileTypeCAMIR_CustomsStatus then		//cnwmc5 - 10 July 2014 - CCMS 2353 PEN
		self.cmbActionType.addItem(EDIAction_None);
		self.cmbActionType.addItem(EDIAction_PlaceContHold);	//ChangeRequest 46721
		self.cmbActionType.addItem(EDIAction_RemoveContHold);	//ChangeRequest 46721
		self.cmbActionType.addItem(EDIAction_PlaceHold);
		self.cmbActionType.addItem(EDIAction_RemoveHolds);	
		self.cmbActionType.addItem(EDIAction_AddToDoTask);		//ChangeRequest 46721
		self.cmbActionType.addItem(EDIAction_DeleteToDoTask);	//ChangeRequest 46721

	elseif self.ediFileType = EDIFileType_CusRes or self.ediFileType = EDIFileType_XMLOneStopCust or self.ediFileType = EDIFileType_JMTInternal then // TFS 39133
		self.cmbActionType.addItem(EDIAction_Add);
		self.cmbActionType.addItem(EDIAction_Complete);
		self.cmbActionType.addItem(EDIAction_Remove);
	else
		self.cmbActionType.addItem(EDIAction_None);
	endif;
	
	self.cmbActionType.setIndex(1);
end;</source>
    </JadeMethod>
    <JadeMethod name="initDataCombo" id="98e887b8-3e44-4930-b299-3c8b54978c8a">
        <source>initDataCombo(_type : String);
// ---------------------------------------------------------------------------
// Created:	10 September 2008 By Graeme Black cnwgb1
// Purpose:	Load Stops which are relevant to Holds for AMS system
// CCMS SFW 1012 Customs AMS Interface (PAR 17931)
// ---------------------------------------------------------------------------
// 30 Jul 2018	jlgsl4	TFS 39133 - Trade Single Window - NZCS &amp; MPI stops
// 31/10/2019	JLGNS1	ChangeRequest 46721: PEN - CAMIR Message Processing

vars
	bolStopTypes : ObjectSet;
	stopType : CM_StopsTable;
	todoType : CM_ToDoTaskDesc;
begin
	create bolStopTypes transient;
	if _type = null then
		foreach stopType in app.myRoot.allStopsTable do
			if self.ediFileType = EDIFileType_CusRes or stopType.isValidForCargoType(BOLType_GeneralBillOfLading)
			or self.ediFileType = EDIFileType_XMLOneStopCust or self.ediFileType = EDIFileType_JMTInternal // TFS 39133
			then
				bolStopTypes.add( stopType);
			endif;
		endforeach;
		if self.ediFileType = EDIFileType_CusRes or self.ediFileType = EDIFileType_XMLOneStopCust or self.ediFileType = EDIFileType_JMTInternal then // TFS 39133
			app.myRoot.allToDoTaskDescriptions.copy(bolStopTypes);
		endif;
	else
		if _type =  EDIAction_PlaceHold or _type =  EDIAction_RemoveHolds then 																		//ChangeRequest 46721
			foreach stopType in app.myRoot.allStopsTable do																							//ChangeRequest 46721
				if stopType.isValidForCargoType(BOLType_GeneralBillOfLading)  then																	//ChangeRequest 46721
					bolStopTypes.add( stopType);																									//ChangeRequest 46721
				endif;																																//ChangeRequest 46721
			endforeach;																																//ChangeRequest 46721
		elseif _type =  EDIAction_PlaceContHold or _type =  EDIAction_RemoveContHold  then															//ChangeRequest 46721
			//stops																																	//ChangeRequest 46721
			foreach stopType in app.myRoot.allStopsTable do																							//ChangeRequest 46721
				if stopType.isValidForCargoType(TI_CargoType_Container)  then																		//ChangeRequest 46721
					bolStopTypes.add( stopType);																									//ChangeRequest 46721
				endif;																																//ChangeRequest 46721
			endforeach;																																//ChangeRequest 46721
		elseif  _type =  EDIAction_AddToDoTask /*or _type =  EDIAction_CompleteToDoTask */or _type = EDIAction_DeleteToDoTask then					//ChangeRequest 46721 EDIAction_CompleteToDoTask Not Used
			//To-DOs																																//ChangeRequest 46721
			foreach todoType in app.myRoot.allToDoTaskDescriptions do																				//ChangeRequest 46721
				if todoType.isAvailableForCargoType(TI_CargoType_Container) then																	//ChangeRequest 46721
					bolStopTypes.add( todoType);																									//ChangeRequest 46721
				endif;																																//ChangeRequest 46721
			endforeach;																																//ChangeRequest 46721
		endif;		
	endif;
	self.cmbData.listCollection(bolStopTypes, false, 0);
epilog
	delete bolStopTypes;
end;</source>
        <Parameter name="_type" type="String"/>
    </JadeMethod>
    <JadeMethod name="initRoleCodeCombo" id="36306483-439b-4cb7-8096-0e9fe7060301">
