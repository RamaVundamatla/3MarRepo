    <JadeMethod name="getUNBData" id="5e31257b-be9c-40e6-8051-e96c9c4d732e">
        <source>getUNBData(_ediData :CM_EDIData input; _msgHelper : CMIF_EDIFACTHelper; _senderOperatorCode : String output;_rawSenderCode : String output; _rawRecipientCode : String output;
			_senderPartyRules :CM_EDIPartyRules output; _senderOperator : CM_Operator output; _creationTS : TimeStamp output; _sequence : String output) protected;

/*
Purpose:	This method extracts the CM_EDIParty and CM_Operator responsible for the EDI transmission.
			These may be null, in which case the _senderOperatorCode will be the only result.
            EDI Party is added for CCMS 2122 and is not initially used for translations 
			
			
Date			Who		Reason
21.11.11        cnwgb1  CCMS 2122 
03 Apr 2013		cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures, renamed method, added edipartyrules parameter
11 Jul 2013		cnwcs5	par 31942
//27 Jul 2015	cnwrs1	Par 32883 - EDI File Type sequence number
// 21 Aug 2017	jlgrs1	TFS 6564 add Coparn and Coreor RFF and NAD translation
// 20 Jul 2018	jlgrs1	TFS SNO translation operator being cleared when null om EDI party
*/
	
vars
	senderParty		: CM_EDIParty;
	maxLength 		: Integer;
	msgHelper 		: CMIF_EDIFACTHelper;
    terminal 		: CM_Terminal;
//    senderCode 	: String;
    params 			: CMIF_EDIFACTParams;	// local variable
	foundMatch		: Boolean;
	date : Date;
	time : Time;
	str : String;
begin
	msgHelper	:= _msgHelper;
	maxLength	:= CM_Operator::code.getLengthForString();
    params 		:= _msgHelper.myCurrentParams;
	params.clearAll;
	
	msgHelper.setNextField;
	msgHelper.setNextField;
	
	_rawSenderCode 	:= msgHelper.currentSubItem; 
    terminal 		:= app.myPassport.myTerminal;
	
    if terminal &lt;&gt; null then
        senderParty := terminal.allEDIPartiesBySenderCode[_rawSenderCode];
    endif;
	params.senderCode 	:= _rawSenderCode;
	_senderOperatorCode	:= app.myRoot.getXlationSystemOperatorCode(_senderOperator, _rawSenderCode, foundMatch )[ 1 : maxLength];
	_senderOperator	:= app.myRoot.allOperators[_senderOperatorCode];
	
	//jlier1	TFS 57187 22/3/23
	if senderParty = null then
		senderParty:=terminal.allEDIPartiesBySenderCode[_senderOperatorCode];
		if senderParty &lt;&gt; null then
			params.senderCode 	:=_senderOperatorCode;
		endif;
	endif;
	
	if senderParty &lt;&gt; null then
		//jlier1 TFS 57381 29/3/23
		//jlier1	TFS 57187 22/3/23
		if not senderParty.onlyUseXlationOpForXlation then
			if senderParty.myTranslationOperator &lt;&gt; null then
				_senderOperator := senderParty.myTranslationOperator;
			endif;
		endif;
		_senderPartyRules 	:= self.getEDIPartyRules (senderParty);
	endif;
	
	// set sender code regardless of whether there is an edi party of not
	
	msgHelper.setNextField;
	_rawRecipientCode := msgHelper.currentSubItem;
	msgHelper.setNextField;
	str := msgHelper.currentSubItem;
	if str.length = 8 then
		str := str[3:6];
	endif;
	date.setDate(str[5:2].Integer, str[3:2].Integer, str[1:2].Integer); 
	msgHelper.setNextSubItem;
	str := msgHelper.currentSubItem; 
	time.setTime(str[1:2].Integer, str[3:2].Integer, 0, 0);
	_creationTS.setDate(date);
	_creationTS.setTime(time);
	msgHelper.setNextField;
	_sequence := msgHelper.currentSubItem; 
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
        <Parameter name="_msgHelper" type="CMIF_EDIFACTHelper"/>
        <Parameter name="_senderOperatorCode" type="String" usage="output"/>
        <Parameter name="_rawSenderCode" type="String" usage="output"/>
        <Parameter name="_rawRecipientCode" type="String" usage="output"/>
        <Parameter name="_senderPartyRules" type="CM_EDIPartyRules" usage="output"/>
        <Parameter name="_senderOperator" type="CM_Operator" usage="output"/>
        <Parameter name="_creationTS" type="TimeStamp" usage="output"/>
        <Parameter name="_sequence" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getUNB_ElementData" id="78deaa36-d096-49ce-9ee5-0fa2e2022b9d">
        <source>getUNB_ElementData(	_msgHelper			: CMIF_EDIFACTHelper;
					_senderOperatorCode	: String output;
					_senderOperator		: CM_Operator output; _rawSenderCode : String output;  _rawRecipientCode : String output; _creationTS : TimeStamp output; _sequence : String output) protected;

/*
Purpose:	This method will get certain element data from the mandatory UNH header record.
			The exact layout is described in this methods text.
			
			Note: Even though this is a mandatory record, some of Nelson's clients (eg ANL and COS)
			do not send through the mandatory UNB record so the the sender operator is not getting set up.
			
Date			Who		Reason
21 July 2010	cnwrl1	Initial creation as part of PAR 25093 - Obtain the Sender Operator.
03 Apr 2013		cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
//01 Sep 2015	cnwrs1	Par 32883 - EDI File Type sequence number
*/
vars
	maxLength	: Integer;
	msgHelper	: CMIF_EDIFACTHelper;
	foundMatch	: Boolean;
	date : Date;
	time : Time;
	str : String;
begin
	msgHelper	:= _msgHelper;		// to reduce dereferencing
	maxLength	:= CM_Operator::code.getLengthForString();
	
	// Set up the translated Sender Operator and Code.
	msgHelper.setNextField;			// Syntax Identifier eg UNOA
	msgHelper.setNextField;			// Sender Operator
	_senderOperatorCode		:= msgHelper.currentSubItem;	// use full text eg COSCO for the translation below!
	_rawSenderCode := _senderOperatorCode;
	_senderOperatorCode		:= app.myRoot.getXlationSystemOperatorCode( _senderOperator, _senderOperatorCode, foundMatch )[ 1 : maxLength ];
	_senderOperator			:= app.myRoot.allOperators[ _senderOperatorCode ];
	msgHelper.setNextField;
	_rawRecipientCode := msgHelper.currentSubItem;
	msgHelper.setNextField;
	str := msgHelper.currentSubItem;
	if str.length = 8 then
		str := str[3:6];
	endif;
	date.setDate(str[5:2].Integer, str[3:2].Integer, str[1:2].Integer); 
	msgHelper.setNextSubItem;
	str := msgHelper.currentSubItem; 
	time.setTime(str[1:2].Integer, str[3:2].Integer, 0, 0);
	_creationTS.setDate(date);
	_creationTS.setTime(time);
	msgHelper.setNextField;
	_sequence := msgHelper.currentSubItem; 
epilog
	
end;
</source>
        <access>protected</access>
        <text>The UNB layout is described below:

Syntax Identifier.					MANDATORY
This mandatory element identifies both the level of the syntax and the agency controlling the syntax, for example UNOA.

Syntax Version Number.				MANDATORY
This mandatory element indicates the version number identified in the Syntax Identifier element.

Sender Identification.				MANDATORY
This mandatory element identifies the name of or a code for, the sender of the data.

Identification Code Qualifier.
This optional element refers to the sources for the codes of the interchanging partners identifiers.
For example, a qualifier of ZZ indicates that the partners mutually defined the codes.

Address for Reverse Routing.
This optional element contains a return address specified by the sender of the message.
The recipient may want to include this address in any response messages to this sender to facilitate internal routing.

Recipient Identification.			MANDATORY
This mandatory element identifies the name of or a code for, the recipient of the data.

Identification Code Qualifier.
This optional element refers to the sources for the codes of the interchanging partners identifiers.
For example, a qualifier of ZZ indicates that the partners mutually defined the codes.

Routing Address.
This optional element contains the address specified by the recipient of the message that the sender is to include.
The recipient uses this address for routing messages received by the sender.

Date of Preparation.				MANDATORY
This mandatory element indicates the date that the interchange was prepared.
This information is in the format YYMMDD.

Time of Preparation.				MANDATORY
This mandatory element indicates the time that the interchange was prepared.
This information is in the 24-hour clock format.

Interchange Control Reference.		MANDATORY
This mandatory element is a unique reference that the sender assigns to the interchange.

Recipient Reference Password.
This optional element indicates the reference or password for the recipient that the partners mutually define.

Recipient Reference Password/Qualifier.
This optional element indicates the qualifier for the reference or password for the recipient.

Application Reference.
This optional element assigned by the sender identifies the application associated with the messages in the interchange.

Processing Priority Code.
This optional element indicates the processing priority for the interchange requested from the sender.

Acknowledgement Request.
This optional element the sender uses indicates a request for an acknowledgement of the interchange from the recipient.

Communications Agreement Id.
This optional element indicates by name or code the type of agreement under which the interchange took place.

Test Indicator.
This optional element indicates that the interchange is a test.
</text>
