    <JadeMethod name="create" id="ab817819-a184-47d9-88fd-ee325148453f">
        <updating/>
        <source>create() updating;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
========================================================
08/02/2010	cnwcs5	CCMS 1925/Par 22295 Release Summaries (Initial creation)
*/

vars

begin
	self.className	:= CM_BulkRelease.name;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createProperties" id="28b8a522-56ae-41f0-9512-a9b2d552a603">
        <source>createProperties();
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
========================================================
08/02/2010	cnwcs5	CCMS 1925/PAR 22295 Release Summaries (Initial creation)
30/11/2011	cnwcs5	CCMS POL 2122 / PAR 28696 - add needsReview
*/

vars
	prop	:CM_QueryProperty;
begin
	inheritMethod();

	// Consignee
	create prop as CM_QStringProperty persistent;
	prop.set ('Consignee', CM_BulkRelease::consigneeCode.name, self.className);
	prop.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add (prop);
	
	// Consignor Voyage Code
	create prop as CM_QStringProperty persistent;
	prop.set ('Consignor Voyage Code', CM_BulkRelease::consignorVoyageCode.name, self.className);
	prop.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add (prop);
	
	// Freight Forwarder Code
	create prop as CM_QStringProperty persistent;
	prop.set ('Freight Forwarder Code', CM_BulkRelease::freightForwarderCode.name, self.className);
	prop.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add (prop);
	
	// Freight Forwarder Code
	create prop as CM_QStringProperty persistent;
	prop.set ('Freight Payer Code', CM_BulkRelease::freightPayerCode.name, self.className);
	prop.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add (prop);
	
	// Estimated Required Date
	create prop as CM_QDateMethod persistent;
	prop.set ('Estimated Required Date', CM_BulkRelease::getEstimatedRequiredDate.name, self.className);
	prop.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add (prop);
	
	// Needs Review (par 28696)
	create prop as CM_QBooleanProperty persistent;
	prop.set ('Needs Review', CM_BulkRelease::needsReview.name, self.className);
	prop.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add (prop);
	
	// Operator
	create prop as CM_QRefOperatorProperty persistent;
	prop.set ('Operator', CM_BulkRelease::myOperator.name, self.className);
	prop.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add (prop);
	
	// Operator group
	create prop as CM_QRefOperatorGroupProperty persistent;
	prop.set ('Operator Group', CM_BulkRelease::myOperatorGroup.name, self.className);
	prop.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add (prop);
	
	// Pack location 21 July 2010	NDL	Par 25076 
	create prop as CM_QStringMethod persistent;
	prop.set ('Pack Location', CM_BulkRelease::getPackLocationString.name, self.className);
	prop.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add (prop);
	
	// Total Requested
	create prop as CM_QIntegerMethod persistent;
	prop.set ('Total Requested', CM_BulkRelease::getTotalRequested.name, self.className);
	prop.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add (prop);
	
	// Items Delivered
	create prop as CM_QIntegerMethod persistent;
	prop.set ('Items Delivered', CM_BulkRelease::getTotalReleased.name, self.className);
	prop.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add (prop);
	
	// Items Remaining
	create prop as CM_QIntegerMethod persistent;
	prop.set ('Items Remaining', CM_BulkRelease::getTotalOutstanding.name, self.className);
	prop.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add (prop);
	
	// Voyage
	create prop as CM_QRefVoyageProperty persistent;
	prop.set ('Voyage', CM_BulkRelease::myVoyage.name, self.className);
	prop.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add (prop);
epilog

end;</source>
    </JadeMethod>
