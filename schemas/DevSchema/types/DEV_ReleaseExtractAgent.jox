    </JadeMethod>
    <JadeMethod name="handleFileException" id="307676cf-6000-47cd-bac2-d1b2eb886b67">
        <source>handleFileException(_exc : FileException;
					_exceptionOccurred : Boolean io;
					_dumpStack : Boolean ) : Integer protected;

/*

Purpose:			Handle file exceptions during an attempt to remove or copy files

Parameters:			Exception

Return Value:		Exception return code, _exceptionOccurred updated


Date		Who		Reason
24 May 2011	cnwkpd1	JMT Release process changes
09 Feb 2016	cnwkpd1	Extend file exception handling to copy as well as remove
24 Jun 2019 jlgmd1	Dump the stack if we need to

*/

vars
	returnVal		: Integer;
	msg				: String;
	file			: File;
	fileName		: String;
	
begin
	returnVal := Ex_Pass_Back;
	
	file := _exc.file();
	if app.isValidObject(file) then
		fileName := file.fileName;
	else
		fileName := "&lt;unknown&gt;";
	endif;

	msg := _exc.class.name &amp; " " &amp; _exc.errorCode.String &amp; " processing " &amp; fileName &amp; ", returning Ex_Resume_Next";
	self.log(msg);

	if _dumpStack then
		app.doDumpStack(_exc);
	endif;
	
	_exceptionOccurred := true;
	returnVal := Ex_Resume_Next;
		
epilog
	return returnVal;
	
end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="FileException"/>
        <Parameter name="_exceptionOccurred" type="Boolean" usage="io"/>
        <Parameter name="_dumpStack" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleUTException" id="bbc9760b-fd53-468b-9748-26f1e23ef7cb">
        <source>handleUTException(_ex: Exception; _hadException : Boolean output; _exMsg : String output) : Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
04 October 2019		jlgmd1	Initial creation TFS 45294

*/

constants
	UTSchema 	: String = "JMTUnitTest";
	ExClass		: String = "UT_TestFailureException";
vars
	returnVal : Integer;
	utExClass : Class;
begin
	returnVal := Ex_Pass_Back;
	
	utExClass := rootSchema.getSchema(UTSchema).getClass(ExClass);
	if _ex.isKindOf(utExClass) then
		returnVal := Ex_Resume_Next;
		_exMsg := _ex.getPropertyValue("message").String;
		_hadException := true;
	endif;
	
epilog
	return returnVal;
end;</source>
        <access>protected</access>
        <Parameter name="_ex" type="Exception"/>
        <Parameter name="_hadException" type="Boolean" usage="output"/>
        <Parameter name="_exMsg" type="String" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="insertFileContents" id="6dba9e39-2880-4750-92f7-fc2eb87c7468">
        <source>insertFileContents(_toFile : File;
				   _fromFileName : String;
				   _fromFilePresentation : Boolean) : Boolean;
				   
/*

Purpose:			if the (text) file named _fromFileName exists, then read it and insert the 
					contents at the current point in the currently open (output) file _toFile

Parameters:			Currently open output file, Name and Presentation details of the file
					to be inserted

Return Value:		True if the _fromFileName exists and was inserted

Date		Who		Reason
17 Nov 2011	cnwkpd1	PAR #28262 - CCMS 1223 - Delivery Mechanisms

*/

vars
	fromFile		: File;
	line			: String;
	
begin
	create fromFile transient;
	fromFile.fileName := _fromFileName;
	fromFile.usePresentationFileSystem := _fromFilePresentation;
	fromFile.mode := File.Mode_Input;
	fromFile.kind := File.Kind_Unknown_Text;	// 24/2/16 cnwmp6 PAR 36286 unicode version
	
	if fromFile.isAvailable() then
		fromFile.open();
		
		self.log("Inserting contents of " &amp; self.getFileNameDisplay(fromFile) &amp; " into " &amp; self.getFileNameDisplay(_toFile));
		while not fromFile.endOfFile() do
			line := fromFile.readLine();
			_toFile.writeLine(line);
		endwhile;
	
		return true;
	endif;
	
	return false;
		
epilog
	delete fromFile;

end;</source>
        <Parameter name="_toFile" type="File"/>
        <Parameter name="_fromFileName" type="String"/>
        <Parameter name="_fromFilePresentation" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="log" id="988dcf78-6fe7-4960-908f-6fbb79e3d56c">
        <source>log(_msg : String);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 Mar 2011	cnwkpd1	CCMS SFW 1223 - Prototyping code for new Release Mechanism
04/07/2019	jlgmd1	TFS Automation - Write to a log we can read again
*/

vars

begin

	app.writeLog(_msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	write self.getTimeDisplayString() &amp; ": " &amp; _msg;
	
	if self.thinclientLog &lt;&gt; null then
		if self.thinclientLog.isOpen() then
			self.thinclientLog.writeLine(self.getTimeDisplayString() &amp; ": " &amp; _msg);
		endif;
	endif;	
epilog

end;</source>
        <Parameter name="_msg" type="String"/>
    </JadeMethod>
    <JadeMethod name="lookForNewWSDLAttributes" id="98c2daa1-e0da-459b-967f-f89ce9bf012e">
        <source>lookForNewWSDLAttributes(_wsClass : Class; _checkTS : TimeStamp; _previousWSDLClasses : DEV_REOWsdlClassDict; _allChangedClasses : DEV_REOWsdlClassDict io);
/*

Purpose:			Go through the attributes from the given class, and compare them against what they last were, noting any changed ones.

Parameters:			

Return Value:		

Date			Who		Reason
08 May 2019		jlgmd1	Initial creation - TFS 79667 - JMT - API Documentation

*/


vars
	snapshotClass,
	newClass,
	parent			: DEV_REOWsdlClass;
	allProps		: PropertyNDict;
	prop			: Property;
	snapshotFeature,
	feature			: DEV_REOWsdlFeature;
	length			: Integer;
begin
	// Check to see if our snapshot has already been marked as changed first
	snapshotClass := _allChangedClasses[_wsClass.name];
	if snapshotClass = null then
		snapshotClass := _previousWSDLClasses[_wsClass.name];
	endif;
	
	// Same with the parent class
	parent := _allChangedClasses[_wsClass.getSuperclass().name];
	if parent = null then
		parent := _previousWSDLClasses[_wsClass.getSuperclass().name];
	endif;
	
	if parent = null and snapshotClass = null then
		write method.qualifiedName &amp; " Error, unable to find parent class. Unable to create child.";
		return;
	endif;
	
	// Grab our attributes to check
	allProps := _wsClass.getProperties();
	
	foreach prop in allProps do
		// Fudge the initial creation slightly
		if _checkTS &lt;&gt; null and prop.creationTime &gt; _checkTS or prop.getModifiedTimestamp &gt; _checkTS then
			continue;
		endif;
		
		// Ignore non public methods
		if not prop.access = SchemaEntity.Access_Public then
			continue;
		endif;
	
		// Does this property already exist ?
		feature := snapshotClass.allProperties[prop.name];
		if feature &lt;&gt; null then
			length := prop.getLength();
			if length &gt; 0 then
				length := length - 1;	// a 30 character string is stored as 31 in the database
			endif;
			// Check the properties name, type, and size haven't changed
			if prop.type.name = feature.type and length = feature.size then
				// All good, everything is the same
				continue;
			endif;
		endif;
		
		// If we get this far, then there is a difference
		newClass := _allChangedClasses[_wsClass.name];
		if newClass = null then
			// this wont work if snapshot is null
			create newClass transient;
			newClass.set(_wsClass.name, parent);
			_allChangedClasses.add(newClass);
		endif;
		
		create feature transient;
		feature.set(null, prop, newClass);
		
	endforeach;
	
	// Now check for any attributes that might have been removed
	if snapshotClass &lt;&gt; null and not snapshotClass.isTransient then
		foreach snapshotFeature in snapshotClass.allProperties do
			if allProps[snapshotFeature.name] = null then
				newClass := _allChangedClasses[_wsClass.name];
				if newClass = null then
					create newClass transient;
					newClass.set(_wsClass.name, parent);
					_allChangedClasses.add(newClass);
				endif;
				
				create feature transient;
				feature.setForUpdateFromProxy(snapshotFeature, app.myPassport);
				feature.setWSDLClass(newClass);
				feature.setDeleted(true);
			endif;
		endforeach;
	endif;
	
epilog

end;</source>
        <Parameter name="_wsClass" type="Class"/>
        <Parameter name="_checkTS" type="TimeStamp"/>
        <Parameter name="_previousWSDLClasses" type="DEV_REOWsdlClassDict"/>
        <Parameter name="_allChangedClasses" type="DEV_REOWsdlClassDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="lookForNewWSDLClasses" id="679aaf82-709d-402e-93c2-8d98e069941e">
        <source>lookForNewWSDLClasses(_wsClass : Class; _checkTS : TimeStamp; _previousWSDLClasses : DEV_REOWsdlClassDict; _allNewClasses : DEV_REOWsdlClassDict io; _isNewClass : Boolean output);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
08 May 2019		jlgmd1	Initial creation - TFS 39667 JMT - API Documentation

*/

vars
	snapshotClass,
	parent		: DEV_REOWsdlClass;
begin	
	_isNewClass := false;
	
	snapshotClass := _previousWSDLClasses[_wsClass.name];
	parent := _previousWSDLClasses[_wsClass.getSuperclass().name];
	
	// If we don't have a parent yet, then check to see if its a new one
	if parent = null then
		parent := _allNewClasses[_wsClass.getSuperclass().name];
	endif;
	
	if parent = null then
		write method.qualifiedName &amp; " Error, unable to find parent class. Unable to create child.";
		return;
	endif;
	
	// If the class has been reparented, then treat it as a new one
	if snapshotClass &lt;&gt; null then
		if snapshotClass.myParent &lt;&gt; parent then
			snapshotClass := null;
		endif;
	endif;
	
	// Fudge the initial creation slightly
	if _checkTS &lt;&gt; null then
		if _wsClass.creationTime &gt; _checkTS then
			if snapshotClass = null then
				_isNewClass := true;
			endif;
			return;
		endif;
	endif;
	
	if snapshotClass = null then
		// Create the new Class
		create snapshotClass transient;
		snapshotClass.set(_wsClass.name, parent);
		_allNewClasses.add(snapshotClass);
		_isNewClass := true;
		
		// Record its methods
		self.lookForNewWSDLMethods(_wsClass, _checkTS, _previousWSDLClasses, _allNewClasses);
		
		// Record its attributes
		self.lookForNewWSDLAttributes(_wsClass, _checkTS, _previousWSDLClasses, _allNewClasses);
	endif;
epilog
	
end;</source>
        <Parameter name="_wsClass" type="Class"/>
        <Parameter name="_checkTS" type="TimeStamp"/>
        <Parameter name="_previousWSDLClasses" type="DEV_REOWsdlClassDict"/>
        <Parameter name="_allNewClasses" type="DEV_REOWsdlClassDict" usage="io"/>
        <Parameter name="_isNewClass" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="lookForNewWSDLMethods" id="5b899d1f-3d25-491f-a26f-88a8a4e03aa2">
        <source>lookForNewWSDLMethods(_wsClass : Class; _checkTS : TimeStamp; _previousWSDLClasses : DEV_REOWsdlClassDict; _allChangedClasses : DEV_REOWsdlClassDict io);
/*

Purpose:			Go through the methods from the given class, and compare them against what they last were, noting any changed ones.

Parameters:			

Return Value:		

Date			Who		Reason
07 May 2019		jlgmd1	Initial creation - TFS 79667 - JMT - API Documentation
20 June 2019	jlgmd1	TFS 45268 - Ignore method signature qualifer changes (eg, making the method an updating one)

*/

vars
	snapshotClass,
	newClass,
	parent			: DEV_REOWsdlClass;
	methods			: MethodNDict;
	newMeth			: Method;
	snapshotFeature,
	newFeature,
	input			: DEV_REOWsdlFeature;
	oldSig,
	newSig,
	oldRet,
	newRet			: String;
	idx				: Integer;
	different		: Boolean;
	
begin
	// Check to see if our snapshot has already been marked as changed first
	snapshotClass := _previousWSDLClasses[_wsClass.name];
	if snapshotClass = null then
		snapshotClass := _allChangedClasses[_wsClass.name];
	endif;
	
	// Same with the parent class
	parent := _allChangedClasses[_wsClass.getSuperclass().name];
	if parent = null then
		parent := _previousWSDLClasses[_wsClass.getSuperclass().name];
	endif;
	
	if parent = null and snapshotClass = null then
		write method.qualifiedName &amp; " Error, unable to find parent class. Unable to create child.";
		return;
	endif;
	
	// Grab our methods to check
	create methods transient;
	_wsClass.getMethods(methods);
	
	foreach newMeth in methods do
		// Fudge the initial creation slightly
		if _checkTS &lt;&gt; null and newMeth.creationTime &gt; _checkTS or newMeth.getModifiedTimestamp &gt; _checkTS then
			continue;
		endif;
		
		// Ignore non public methods
		if not newMeth.access = SchemaEntity.Access_Public then
			continue;
		endif;
	
		if snapshotClass &lt;&gt; null then
			// Does this method already exist ?
			snapshotFeature := snapshotClass.allMethods[newMeth.name];
			if snapshotFeature &lt;&gt; null then
				// Check method signature
				oldSig := snapshotFeature.signature;
				idx := 1;
				newSig := newMeth.getSource().scanUntil(")", idx);
				newSig := newSig &amp; newMeth.getSource().scanUntil(";", idx) &amp; ";";
				
				// Sigs match, skip
				if oldSig = newSig then
					continue;
				endif;
				
				create newFeature transient;	// Create a dummy feature for comparison use
				newFeature.set(newMeth.JadeMethod, null, null);
				
				different := false;
				foreach input in newFeature.allInputs do
					if snapshotFeature.allInputs[input.name] = null then
						different := true;
						break;
					endif;
				endforeach;
				
				if not different and (newFeature.getMethodOutput &lt;&gt; snapshotFeature.getMethodOutput) then
					different := true;
				endif;
				
				// Get reid of our dummy feature
				delete newFeature;
				
				// If the inputs and the return match, then skip
				if not different then
					continue;
				endif;
				
			endif;
		endif;
		
		// If we get this far, then there is a difference
		if newClass = null then
			if snapshotClass = null or not snapshotClass.isTransient then
				create newClass transient;
				newClass.set(_wsClass.name, parent);
				_allChangedClasses.add(newClass);
			else
				newClass := snapshotClass;
			endif;
		endif;
		
		create newFeature transient;
		newFeature.set(newMeth.JadeMethod, null, newClass);
		
	endforeach;
	
	// Now check for any methods that might have been removed
	if snapshotClass &lt;&gt; null and not snapshotClass.isTransient then
		foreach snapshotFeature in snapshotClass.allMethods do
			if methods[snapshotFeature.name] = null then
				newClass := _allChangedClasses[_wsClass.name];
				if newClass = null then
					create newClass transient;
					newClass.set(_wsClass.name, parent);
					_allChangedClasses.add(newClass);
				endif;
				
				create newFeature transient;
				newFeature.setForUpdateFromProxy(snapshotFeature, app.myPassport);
				newFeature.setWSDLClass(newClass);
				newFeature.setDeleted(true);
				
			endif;
		endforeach;
	endif;
epilog
	delete methods;
end;</source>
        <Parameter name="_wsClass" type="Class"/>
        <Parameter name="_checkTS" type="TimeStamp"/>
        <Parameter name="_previousWSDLClasses" type="DEV_REOWsdlClassDict"/>
        <Parameter name="_allChangedClasses" type="DEV_REOWsdlClassDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="onlyContainsWSDocumentation" id="e4a91ee1-aa0c-4e23-8994-0f251056ac38">
        <source>onlyContainsWSDocumentation(folder: FileFolder io; depth: Integer input) : Boolean;
/*

Purpose:			Check if the given folder (and any subfolders) only contains the WSDL documentation

Parameters:			The base folder to check

Return Value:		True if the folder only contains the file we are looking for

Date		Who		Reason
06 September 2017	jlgmd1	Initial creation

*/

constants
	FileName = "WebServicesDocumentation";
vars
	fileNode : FileNode;	
	fna : FileNodeArray;
	ret : Boolean;
begin
	fna := folder.files;
	
	// write "Running test at depth: " &amp; depth.String;
	
	// Don't go too far down the rabbit hole
	if depth &gt;= 5 then
		return false;
	endif;
	
	if fna &lt;&gt; null then
		foreach fileNode in fna do
			if fileNode.isKindOf(FileFolder) then
				// Folder
				// write "Found a folder: " &amp; fileNode.name;
				if onlyContainsWSDocumentation(fileNode.FileFolder, depth + 1) then
					return true;
				endif;
			else
				// File
				// write "Found a file: " &amp; fileNode.name;
				if fileNode.name.pos(FileName, 1) &gt; 0 then
					ret := true;
				else
					// If we find anything else we aren't looking for, we should return false
					return false;
				endif;
			endif;
		endforeach;
	else
		return false;
	endif;
	
	return ret;
	
epilog

end;</source>
        <Parameter name="folder" type="FileFolder" usage="io"/>
        <Parameter name="depth" type="Integer" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="removeDirectoryName" id="bb5b5beb-bde5-46bb-832c-fd52d9c86956">
        <source>removeDirectoryName(_fileName : String; _usePresentation : Boolean) : Boolean;
/*

Purpose:			Remove the directory named _fileName from the "_usePresenation" file system

Parameters:			Directory to be removed, whether or not it is presentation client relative

Return Value:		True if the directory is successfully removed, false otherwise

Date		Who		Reason
24 Sep 2014	cnwkpd1	PAR #28262 - CCMS 1223 - Delivery Mechanisms

*/

vars
	directory		: FileFolder;
	
begin
	create directory transient;
	directory.fileName := _fileName;
	directory.usePresentationFileSystem := _usePresentation;
	
	self.log("Deleting directory " &amp; self.getFileNameDisplay(directory));
	return self.removeFile(directory);
	
epilog
	delete directory;
	
end;</source>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_usePresentation" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="removeFile" id="073444a9-9efc-486e-81a8-d1afb3d05f48">
        <source>removeFile(_file : FileNode input) : Boolean;

/*

Purpose:			Remove the passed in file from disk

Parameters:			FileNode to be purged

Return Value:		True if the file is removed


Date		Who		Reason
24 May 2011	cnwkpd1	JMT release management
09 Feb 2016	cnwkpd1	Extend file exception handling to copy as well as remove

*/

vars
	excOccurred		: Boolean;
	
begin
	if _file.isAvailable then
		on FileException do self.handleFileException(exception, excOccurred, false);
		_file.purge;
		on FileException do null;
		if _file.isAvailable then
			self.log("Delete of file " &amp; self.getFileNameDisplay(_file) &amp; " failed");
			return false;
		else
			return true;
		endif;
	else
		self.log("File " &amp; self.getFileNameDisplay(_file) &amp; " not available to delete");
		return false;
	endif;


epilog
	
end;</source>
        <Parameter name="_file" type="FileNode" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="removeFileName" id="6dd01de0-d5b4-4c38-9e4e-2e2e191c2373">
        <source>removeFileName(_fileName : String; _usePresentation : Boolean) : Boolean;
/*

Purpose:			Remove the file named _fileName from the "_usePresenation" file system

Parameters:			Filename to be removed, whether or not it is presentation client relative

Return Value:		True if the file is successfully removed, false otherwise

Date		Who		Reason
07 Nov 2011	cnwkpd1	PAR #28262 - CCMS 1223 - Delivery Mechanisms

*/

vars
	file			: File;
	
begin
	create file transient;
	file.fileName := _fileName;
	file.usePresentationFileSystem := _usePresentation;
	
	self.log("Deleting file " &amp; self.getFileNameDisplay(file));
	return self.removeFile(file);
	
epilog
	delete file;
	
end;</source>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_usePresentation" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="removeJCFRef" id="d43fd13f-0325-420a-803d-e009038b8ff3">
        <source>removeJCFRef(_schemaFile : String;
			 _usePresentationFileSystem : Boolean);

/*

Purpose:			Remove the JADE COMMAND FILE from the top of the schema file
					passed in, if it exists


Return Value:		


Date		Who		Reason
08 May 2008	cnwkpd1	Automate release extract process

*/

constants
	JADECommandFile	= "/* JADE COMMAND FILE NAME";
		
vars
	inFile,
	outFile			: File;
	line			: String;
	jcfLen			: Integer;
	
begin
	create inFile transient;
	inFile.usePresentationFileSystem := _usePresentationFileSystem;
	inFile.kind := File.Kind_Unknown_Text;	// 24/2/16 cnwmp6 PAR 36286 unicode version
	inFile.openInput(_schemaFile);

	jcfLen := JADECommandFile.length;

	line := inFile.readLine;
	if line.length &lt; jcfLen or line[1:jcfLen] &lt;&gt; JADECommandFile then
		self.log("File " &amp; self.getFileNameDisplay(inFile) &amp; " has no command file line");
	else
		self.log("Removing command file line from " &amp; self.getFileNameDisplay(inFile));
		
		// Have to close file to rename
		inFile.close;
		inFile.rename(_schemaFile &amp; ".old");
		
		// Reopen old file, and skip first line
		inFile.openInput(_schemaFile &amp; ".old");
		inFile.readLine;
		
		// Now copy the rest of the file to a new output file
		create outFile transient;
		outFile.usePresentationFileSystem := _usePresentationFileSystem;
		outFile.openOutput(_schemaFile);
		
		while not inFile.endOfFile do
			line := inFile.readLine;
			outFile.writeLine(line);	
		endwhile;
		
		self.log("Command file line removed from " &amp; self.getFileNameDisplay(outFile));
	endif;
	
	
epilog
	delete inFile;
	delete outFile;

end;</source>
        <Parameter name="_schemaFile" type="String"/>
        <Parameter name="_usePresentationFileSystem" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="runExtractCommand" id="78cd7f3b-1af4-4ac1-b799-d3579a2ef2cd">
        <source>runExtractCommand(_schema, _app, _extraCommandInfo : String) : Boolean;

/*

Purpose:			Run a jadclient process to execute the app passed in with the passed in
					extra command


Return Value:		True if it completed OK, false if not


Date		Who		Reason
23 Feb 2010	cnwkpd1	Automate release extract process

*/

constants
	Space			= " ";
	
vars
	dir,
	command			: String;
	args			: StringArray512;
	result,
	result2			: Integer;
	
begin
	dir := app.getJadeInstallDirAppServer;
	command := "jadclient";

	create args transient;
	args.add("path=" &amp; app.dbPath);
	args.add("ini=" &amp; app.getIniFileNameAppServer);
	args.add("server=multiUser");	
	args.add("schema=" &amp; _schema);
	args.add("app=" &amp; _app);
	args.add("endJade");
	args.add(_extraCommandInfo);
	
	// Now run the process (run modally, so we wait until it's complete)
	self.log("Running command " &amp; command &amp; Space &amp; args.concatenate(Space));
	result := node.createExternalProcess(dir, command, args, null, false, true, result2);

	if result &lt;&gt; Node.ExternalProcess_Successful or result2 &lt;&gt; 0 then
		self.log("Possible problem: result = " &amp; result.String &amp; ", result2 = " &amp; result2.String);
	endif;

	return result = Node.ExternalProcess_Successful;

epilog
	delete args;
	
end;</source>
        <Parameter name="_schema" type="String"/>
        <Parameter name="_app" type="String"/>
        <Parameter name="_extraCommandInfo" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="runJRWExtractCommand" id="47092734-a0fb-4228-9c46-934c9d9a13ce">
        <source>runJRWExtractCommand(_extractCommand : String) : Boolean;

/*

Purpose:			Run a jadclient process to perform the JRW extract command passed in


Return Value:		True if it completed OK, false if not


Date		Who		Reason
23 Feb 2010	cnwkpd1	Automate release extract process

*/

vars
	
begin
	return self.runExtractCommand("JRWDocSchema", "JRWUnload", _extractCommand);
	
	
epilog
		
end;
</source>
        <Parameter name="_extractCommand" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="runLoadCommand" id="940146ad-51d1-49f8-8e1d-638ca54d4c85">
        <source>runLoadCommand(_loadCommand : String) : Boolean;
/*

Purpose:			Run jadloadb in online mode with the passed in command

Parameters:			Load command for jadloadb

Return Value:		True if it completed OK, false if not

Date		Who		Reason
17 Sep 2015	cnwkpd1	Monthly releases - need an extract timestamp embedded in the release

*/

constants
	Space			= " ";
	
vars
	dir,
	command			: String;
	args			: StringArray512;
	result,
	result2			: Integer;
	
begin
	dir := app.getJadeInstallDirAppServer;
	command := "jadloadb";

	create args transient;
	args.add("path=" &amp; app.dbPath);
	args.add("ini=" &amp; app.getIniFileNameAppServer);
	args.add("server=multiUser");
	args.add("loadStyle=currentSchemaVersion");
	args.add(_loadCommand);
	
	// Now run the process (run modally, so we wait until it's complete)
	self.log("Running command " &amp; command &amp; Space &amp; args.concatenate(Space));
	result := node.createExternalProcess(dir, command, args, null, false, true, result2);

	if result &lt;&gt; Node.ExternalProcess_Successful or result2 &lt;&gt; 0 then
		self.log("Possible problem: result = " &amp; result.String &amp; ", result2 = " &amp; result2.String);
	endif;

	return result = Node.ExternalProcess_Successful;

epilog
	delete args;
	
end;</source>
        <Parameter name="_loadCommand" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="runSchemaExtractCommand" id="b19fa4fe-3d0a-4a27-9a41-fe3a0162d44b">
        <source>runSchemaExtractCommand(_extractCommand : String) : Boolean;

/*

Purpose:			Run a jadclient process to perform the schema extract command passed in


Return Value:		True if it completed OK, false if not


Date		Who		Reason
08 May 2008	cnwkpd1	Automate release extract process

*/

vars
	
begin
	return self.runExtractCommand("JadeSchema", "JadeBatchExtract", _extractCommand);
		
epilog
		
end;</source>
        <Parameter name="_extractCommand" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="schemaNeedsDeferredDDBLoad" id="ace70cc1-5920-46df-bd44-8cac6b48e1ce">
        <source>schemaNeedsDeferredDDBLoad(_schemaName : String) : Boolean;
/*

Purpose:			Determine whether or not the passed in schema name requires a deferred DDB load
					during a release (for JADE PAR #62383)

Parameters:			Schema name

Return Value:		True if the DDB of the passed in schema needs to be deferred, false otherwise

Date		Who		Reason
21 Jul 2015	cnwkpd1	JADE PAR #62383 - 1100 target object is already versioned
29 Oct 2021 navmd1	JADE2020/MTN 20.0.21 - changed version check from string to integer, to actually do what it says it should

*/

vars

begin
	// Deferred DDB load issues are resolved in JADE 7.1, and therefore JMT 8.5.1 and above
	if app.myRoot.getVersionString().Integer &lt; 851 then
		if _schemaName = "WebSchema" or _schemaName = "WebExampleSchema" then
			return true;
		endif;
	endif;
	
	return false;
	
epilog

end;</source>
        <Parameter name="_schemaName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDefaultsForFullRelease" id="30a1c1f0-79b5-4432-ab78-d7597e4a36e7">
        <updating/>
        <source>setDefaultsForFullRelease() updating;
/*

Purpose:			Set all the default values for a full extract run

Parameters:			None

Return Value:		None

Date		Who		Reason
04 Nov 2011	cnwkpd1	PAR #28262 - CCMS 1223 - Delivery Mechanisms
22 Aug 2013	cnwkpd1	CCMS SFW 1347 - JADE 7 Deployment

*/

vars
	root			: CM_Root;
	
begin
	root := CM_Root.firstInstance();
	if root &lt;&gt; null then
		self.versionString := root.getVersionString();
	endif;
	
	self.extractAllSchemas := true;
	self.extractEncryptedSchemas := true;
	self.extractJRWFiles := true;
	self.createJMTInstallFile := true;
	self.createJARIRelease := true;
	
	self.targetReleaseDirectory := "F:\Releases\" &amp; self.versionString;
	self.baseReleaseDirectory := self.targetReleaseDirectory &amp; "\BaseRelease";
	self.baseJARIDirectory := self.targetReleaseDirectory &amp; "\BaseJARIRelease";
	self.tempServerDirectory := app.cnGetServerMiscPath();
	
	self.resultEmailAddress := null;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setDefaultsForSingleSchema" id="a68708f9-3fac-4f9c-8cbd-890576ef1bb8">
        <updating/>
        <source>setDefaultsForSingleSchema() updating;
/*

Purpose:			Set all the default values for an extract of a single schema

Parameters:			None

Return Value:		None

Date		Who		Reason
04 Nov 2011	cnwkpd1	PAR #28262 - CCMS 1223 - Delivery Mechanisms

*/

vars
	root			: CM_Root;
	
begin
	root := CM_Root.firstInstance();
	if root &lt;&gt; null then
		self.versionString := root.getVersionString();
	endif;
	
	self.extractAllSchemas := false;
	self.extractEncryptedSchemas := true;
	self.extractJRWFiles := false;
	self.createJMTInstallFile := false;
	self.extractSingleSchema := true;
	
	self.targetReleaseDirectory := "F:\Releases\" &amp; self.versionString;
	self.baseReleaseDirectory := null;
	self.tempServerDirectory := app.cnGetServerMiscPath();
	
	self.resultEmailAddress := null;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupThinClientLog" id="62aa5f1f-7f30-4e0f-9569-b6bd7515f370">
        <updating/>
        <source>setupThinClientLog(_logName : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04/07/2019	jlgmd1	TFS Automation - Write to a log we can read again

*/

vars
	logsDir : String;
	name 	: String;
begin
	create self.thinclientLog transient;
	
	logsDir := app.getProfileStringMyIni("JadeLog", "LogDirectory", null);
	if logsDir[2:1] &lt;&gt; ":" then
		// Append the base directory if the path is relative
		logsDir := process.getJadeHomeDirectory() &amp; logsDir;
	endif;
	
	if _logName = null then
		name := app.name &amp; "_" &amp; app.actualTime.date.formatAsYYMMDD &amp; app.actualTime.time.formatAsHHMMSS;
	else
		name := _logName;
	endif;
	
	self.thinclientLog.usePresentationFileSystem := true;
	self.thinclientLog.fileName := logsDir &amp; "\" &amp; name &amp; ".log";
	self.thinclientLog.mode := File.Mode_Append;
	self.thinclientLog.kind := File.Kind_ANSI;
	self.thinclientLog.open();
epilog

end;</source>
        <Parameter name="_logName" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateReleaseExtractParams" id="9eedf513-9c63-46d3-9881-f6b15397021d">
        <updating/>
        <source>validateReleaseExtractParams() : Boolean updating;
/*

Purpose:			Validate input parameters, and set up all required internal directory
					names

Parameters:			None

Return Value:		True if parameters are valid, false otherwise

Date		Who		Reason
04 Nov 2011	cnwkpd1	PAR #28262 - CCMS 1223 - Delivery Mechanisms
22 Aug 2013	cnwkpd1	CCMS SFW 1347 - JADE 7 Deployment
19 Nov 2019	jlgmd1	TFS 45294 Added validation to prevent Extract all schemas and monthly release being enabled at the same time

*/

constants
	PublicAccess	= "public";

vars
	folder			: FileFolder;
	prop			: Property;
	now				: TimeStamp;
	
begin
	// Validate parameters and setting directory names
	self.log("Starting Release Extract with the following parameters:");
	foreach prop in self.class.getProperties where prop.accessDisplay = PublicAccess do
		self.log(prop.name &amp; "=" &amp; self.getPropertyValue(prop.name).String);
	endforeach;
	
	create folder transient;
	
	// Must have a valid target release directory
	if self.targetReleaseDirectory = null then
		self.log("Target release directory must be provided");
		return false;
	endif;
	folder.fileName := self.targetReleaseDirectory;
	folder.usePresentationFileSystem := true;
	if not folder.isAvailable() then
		//epr TFS 336 - Monthly Releases
		if self.isMonthlyExtract then
			folder.make;
			self.log("Created release directory" &amp; self.targetReleaseDirectory);
		else
			self.log("Target release directory " &amp; self.getFileNameDisplay(folder) &amp; " must be valid");
			return false;
		endif;
	endif;
	
	// Must have a valid server temporary extract directory
	if self.tempServerDirectory = null then
		self.log("Temporary server extract directory must be provided");
		return false;
	endif;
	folder.fileName := self.tempServerDirectory;
	folder.usePresentationFileSystem := false;
	if not folder.isAvailable() then
		self.log("Temporary server extract directory " &amp; self.getFileNameDisplay(folder) &amp; " must be valid");
		return false;
	endif;
	
	// If base release directory is provided, then it must be valid
	if self.baseReleaseDirectory &lt;&gt; null then
		folder.fileName := self.baseReleaseDirectory;
		folder.usePresentationFileSystem := true;
		if not folder.isAvailable() then
			self.log("Base release directory " &amp; self.getFileNameDisplay(folder) &amp; " must be valid");
			return false;
		endif;
	endif;
	
	// If a JARI release needs to be built, then there's some extra validation
	if self.createJARIRelease then
		// Encrypted schemas must be extracted
		if not self.extractEncryptedSchemas then
			self.log("Encrypted schemas must be extracted to create a JARI release");
			return false;
		endif;
		
		// If a JARI base directory is provided, it must be valid
		if self.baseJARIDirectory &lt;&gt; null then
			folder.fileName := self.baseJARIDirectory;
			folder.usePresentationFileSystem := true;
			if not folder.isAvailable() then
				self.log("Base JARI release directory " &amp; self.getFileNameDisplay(folder) &amp; " must be valid");
				return false;
			endif;
		endif;
	endif;

	// If a single schema extract, then check that a valid name has been provided
	if self.extractSingleSchema then
		if self.schemaToExtract = null then
			self.log("Schema to extract must be provided for single schema extract");
			return false;
		endif;
		
		if rootSchema.getSchema(self.schemaToExtract) = null then
			self.log("Schema to extract " &amp; self.schemaToExtract &amp; " must be valid");
			return false;
		endif;
	endif;
	
	// If doing a monthly extract then extract all schemas should be false
	if self.isMonthlyExtract then
		if self.extractAllSchemas then
			self.log("Extract all schemas is selected at the same time as monthly release. Only one should be selected");
			return false;
		endif;
	endif;
	
	// Set up target source and (optionally) encrypted directory names
	self.targetSourceDirectory := self.targetReleaseDirectory &amp; "\" &amp; "JadeMaster";
	if self.extractEncryptedSchemas then
		self.targetEncryptedDirectory := self.targetReleaseDirectory &amp; "\" &amp; "JMT" &amp; self.versionString;
	endif;
	if self.createJARIRelease then
		self.targetJARIDirectory := self.targetReleaseDirectory &amp; "\" &amp; "JARI_JMT" &amp; self.versionString;
	endif;
	
	// Set up server-side source and (optionally) encrypted directory names
	now := app.actualTimeServer();
	self.serverReleaseDirectory := self.tempServerDirectory &amp; "\" &amp; now.getNumeralString;
	self.serverSourceDirectory := self.serverReleaseDirectory &amp; "\" &amp; "JadeMaster";
	if self.extractEncryptedSchemas then
		self.serverEncryptedDirectory := self.serverReleaseDirectory &amp; "\" &amp; "JMT" &amp; self.versionString;
	endif;
	

	return true;
	
epilog
	delete folder;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateReport" id="c74df124-d421-4bfe-a275-12d0f05c02fc">
        <source>validateReport(_reportName : String) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 January 2014	cnwjre1	Initial creation

*/

vars
	report	: Object;
	root	: Object;
	scm		: Schema;
	cls		: Class;
begin
	scm := rootSchema.getSchema("JadeReportWriterSchema");
	if scm = null then
		return false;
	endif;
	cls := scm.getClass("JRDRoot");
	root := cls.firstInstance;
	report := root.sendMsgWithParams("findReport", _reportName, true, null, null).Object;
	return (report &lt;&gt; null);

epilog

end;</source>
        <Parameter name="_reportName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateReportView" id="c14c574b-b0af-4fde-b691-cb96bd5095f7">
        <source>validateReportView(_viewName : String) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 January 2014	cnwjre1	Initial creation

*/

vars
	view	: Object;
	root	: Object;
	dict	: Dictionary;
	scm		: Schema;
	cls		: Class;
begin
	scm := rootSchema.getSchema("JadeReportWriterSchema");
	if scm = null then
		return false;
	endif;
	cls := scm.getClass("JRDRoot");
	root := cls.firstInstance;
	dict := root.getPropertyValue("allReportingViews").Dictionary;
	view := dict.getAtKey(_viewName);
	return (view &lt;&gt; null);
epilog

end;</source>
        <Parameter name="_viewName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="writeLineToFile" id="426969c3-90d1-44a7-bfb5-78782966f03a">
        <source>writeLineToFile(file : File; line : String);
/*

Purpose:			Retry writing to a file if it fails the first time - no need to fail the entire release.
					Expects the file to already be setup/open.

Parameters:			

Return Value:		

Date				Who		Reason
28 November 2018	jlgmd1	Initial creation TFS41422
24 June 2019		jlgmd1	TFS 41422 take 2 - rejig the retry mechanism slightly

*/

constants
	MaxRetries		= 5;
	RetryInterval	= 1000;
vars
	retryCount		: Integer;
	excOccurred		: Boolean;
	response		: Integer;
	dumpStack		: Boolean;
	
begin	
	
	on FileException do self.handleFileException(exception, excOccurred, dumpStack);
	
	while retryCount &lt; MaxRetries do
		excOccurred := false;
		
		file.writeLine(line);
		
		if not excOccurred then
			break;
		endif;
		
		if app.applicationType &lt;&gt; app.ApplicationType_GUI then
			process.sleep(RetryInterval);
			// Only increment the retry count if we're a batch job. Otherwise, wait for the user to press cancel
			retryCount := retryCount + 1;
		else
			response := app.msgBox("Failed to write to " &amp; file.fileName, method.qualifiedName &amp; ": Unexpected file error", MsgBox_Retry_Cancel);
		endif;
		
		if response = MsgBox_Return_Cancel or retryCount &gt;= MaxRetries then
			dumpStack := true;
			//on FileException do null;	// disarm the handler
			file.writeLine(line);		// and have one last go at trying to write the file. if it fails, raise an exception and resume next
			terminate;					// and give-up
		endif;
		
	endwhile;
	
epilog

end;</source>
        <Parameter name="file" type="File"/>
        <Parameter name="line" type="String"/>
    </JadeMethod>
    <JadeMethod name="writeWSDLChangesDoc" id="acad2224-c3ea-4367-ace4-29c7ec58bb10">
        <source>writeWSDLChangesDoc(_new, _changes, _current : DEV_REOWsdlClassDict; _schema : Schema input);
/*

Purpose:			Takes our changes/updates and new features and outputs it in a nice way

Parameters:			

Return Value:		

Date			Who		Reason
09 May 2019		jlgmd1	Initial creation - TFS 39667 - JMT - API Documentation
21 June 2019	jlgmd1	TFS 45268 Fix some formatting issues and ignore signature formatting changes
12 Dec 2019		jlgmd1	Fixed formatting of Changed service calls New Inputs if there weren't any Old Inputs

*/

constants
	ProviderName	: String = "WS_WebServiceProvider";
	IFObjName		: String = "WS_InterfaceObject";
	PxyObjName		: String = "WS_ProxyObject";

	Title			: String = "Master Terminal Web Services: Changes from previous version";
	CSS				: String = '
	html, body {
		height: 99%;
	}
	body {
		font-family: Arial, sans-serif;
		letter-spacing: 0.03em;
		display: flex;
		flex-direction: column;
	}
	.content {
		flex: 1 0 auto;
	}
	h2 {
		margin-left: 2em;
		margin-top: 0;
	}
	p {
		font-size: .75em;
		margin-top: 0;
		margin-bottom: .9em;
		margin-left: 4em;
		line-height: 1.5em;
	}
	table {
		margin-bottom: .7em;
		margin-left: 4em;
		width: 100%;
		border-collapse: collapse;
	}
	table.main {
		border-bottom: thin solid black;
		border-collapse: collapse;
		margin-bottom: 3em;
		margin-left: 4em;
		width: 55%;
		font-size: .75em;
	}
	th {
		border-bottom: thin solid black;
		font-weight: bold;
	}
	td {
		line-height: 1.5em;
	}
	th, td {
		padding: .3em 1em .3em 0;
		text-align: left;
		vertical-align: top;
		line-height: 1.2em;
		width: 35%;
	}
	table p {
		font-size: 1em;
		margin-left: 0;
		line-height: 1.5em;
	}
	table th:first-child, td:first-child {
		width: 30%;
	}
	table table {
		margin: 0;
	}
	table table td {
		width: 51% !important;
		padding-top: 0;
	}
	caption {
		font-size: 1.2em;
		font-weight: bold;
		margin-bottom: 1em;
		text-align: left;
	}
	.footer {
		border-top: thin solid #808285;
		width: 99%;
		flex-shrink: 0;	
		padding: .3em;
	}
	.footer p {
		float: right;
		
	}';
vars
	htmlDocStr,
	tmpHtmlStr		: String;
	header,
	mthRet			: String;
	class,
	parent,
	snapshot		: DEV_REOWsdlClass;
	feat,
	oldFeat,
	input			: DEV_REOWsdlFeature;
	tmpIdx			: Integer;
	pxyClass		: Class;
	prop			: Property;
	tableAdded,
	col3Added,
	col4Added		: Boolean;
	outClassStr		: String;
	loopNum			: Integer;
	changes			: Boolean;
	paramsAdded		: Boolean;
	
	wsProviderChanges,
	ifObjChanges,
	pxyObjChanges,
	allClasses,
	dictToUse		: DEV_REOWsdlClassParentDict;
	
	htmlFile		: File;
	today			: Date;
begin
	header := "WSDL Changes for Master Terminal " &amp; self.versionString;

	// There is probably a better way to do some of this
	htmlDocStr := '&lt;!DOCTYPE html&gt;&lt;html lang="en"&gt;&lt;head&gt;&lt;title&gt;' &amp; Title &amp; '&lt;/title&gt;&lt;style&gt;' &amp; CSS &amp; '&lt;/style&gt;&lt;/head&gt;';
	htmlDocStr := htmlDocStr &amp; '&lt;body&gt;&lt;div class="content"&gt;&lt;h2&gt;' &amp; header &amp; '&lt;/h2&gt;';
	htmlDocStr := htmlDocStr &amp; '&lt;p&gt;The following tables summarize the changes between the current and previous versions of the Master Terminal Web Services.&lt;/p&gt;';
	
	create wsProviderChanges transient;
	create ifObjChanges transient;
	create pxyObjChanges transient;
	
	create allClasses transient;
	_new.copy(allClasses);
	_changes.copy(allClasses);
	
	if allClasses.size = 0 then
		// No WSDL changes for this release
		htmlDocStr := htmlDocStr &amp; '&lt;p&gt;No WSDL changes in this verison&lt;/p&gt;';
	endif;
	
	foreach class in allClasses do
		parent := class.myParent;
		while true do
			if parent.name = ProviderName then
				wsProviderChanges.add(class);
				break;
			elseif parent.name = IFObjName then
				ifObjChanges.add(class);
				break;
			elseif parent.name = PxyObjName then
				pxyObjChanges.add(class);
				break;
			endif;
			parent := parent.myParent;
			if parent = null then
				write method.qualifiedName &amp; " Unable to group changes for class " &amp; class.name;
				break;
			endif;
		endwhile;
	endforeach;
	
	
	// 1. New WS Calls
	foreach class in wsProviderChanges do
		tmpHtmlStr := null;
		tableAdded := false;
		
		// Grab our previous class
		snapshot := _current[class.name];
		
		// foreach method, get its input parameters and outputs
		foreach feat in class.allMethods do
			if snapshot &lt;&gt; null and snapshot.allMethods[feat.name] &lt;&gt; null then
				// This must be a change to an existing method, not a new one
				continue;
			endif;
			
			// Column 1 : Name
			tmpHtmlStr := tmpHtmlStr &amp; '&lt;tr&gt;&lt;td&gt;' &amp; feat.name &amp; '&lt;/td&gt;';
			
			// Column 2 : Inputs
			tmpHtmlStr := tmpHtmlStr &amp; '&lt;td colspan="2"&gt;';
			
			if feat.allInputs.size &gt; 0 then
				tmpHtmlStr := tmpHtmlStr &amp; '&lt;table&gt;';
				foreach input in feat.allInputs do
					tmpHtmlStr := tmpHtmlStr &amp; '&lt;tr&gt;&lt;td&gt;' &amp; input.name &amp; '&lt;/td&gt;&lt;td&gt;' &amp; input.type &amp; '&lt;/td&gt;&lt;/tr&gt;';
				endforeach;
				tmpHtmlStr := tmpHtmlStr &amp; '&lt;/table&gt;';
			else
				tmpHtmlStr := tmpHtmlStr &amp; '&amp;nbsp;';
			endif;
			
			tmpHtmlStr := tmpHtmlStr &amp; '&lt;/td&gt;';
			
			// Column 3 : Outputs
			tmpHtmlStr := tmpHtmlStr &amp; '&lt;td&gt;';
			outClassStr := feat.getMethodOutput();
			tmpHtmlStr := tmpHtmlStr &amp; outClassStr;
			tmpHtmlStr := tmpHtmlStr &amp; '&lt;/td&gt;';
			
			tmpHtmlStr := tmpHtmlStr &amp; '&lt;/tr&gt;';
			tableAdded := true;
		endforeach;
		
		if tableAdded then
			// Set up the new table
			htmlDocStr := htmlDocStr &amp; '&lt;table class="main"&gt;&lt;caption&gt;New ' &amp; class.name &amp; ' calls&lt;/caption&gt;';
			htmlDocStr := htmlDocStr &amp; '&lt;thead&gt;&lt;tr&gt;&lt;th&gt;&amp;nbsp;&lt;/th&gt;&lt;th&gt;Inputs&lt;/th&gt;&lt;th&gt;Input Type&lt;/th&gt;&lt;th&gt;Response&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;';
			htmlDocStr := htmlDocStr &amp; tmpHtmlStr;
			htmlDocStr := htmlDocStr &amp; '&lt;/tbody&gt;&lt;/table&gt;';
		endif;
		
	endforeach;
	
	// 2. Changed WS Calls
	foreach class in wsProviderChanges do
		tmpHtmlStr := null;
		tableAdded := false;
		
		// Grab our previous class
		snapshot := _current[class.name];
		
		foreach feat in class.allMethods do
			if snapshot = null or snapshot.allMethods[feat.name] = null then
				// We only are about changes here
				continue;
			endif;
			
			oldFeat := snapshot.allMethods[feat.name];
			
			if feat.signature &lt;&gt; oldFeat.signature then
				// Column 1 : Name
				tmpHtmlStr := tmpHtmlStr &amp; '&lt;tr&gt;&lt;td&gt;' &amp; feat.name &amp; '&lt;/td&gt;';
				
				// Column 2 : Return Type
				tmpHtmlStr := tmpHtmlStr &amp; '&lt;td&gt;' &amp; feat.getMethodOutput() &amp; '&lt;/td&gt;';
				
				// Column 3 : Old Inputs
				col3Added := false;
				tmpHtmlStr := tmpHtmlStr &amp; '&lt;td&gt;&lt;table&gt;';
				foreach input in oldFeat.allInputs do
					if feat.allInputs[input.name] &lt;&gt; null then
						continue;
					endif;
					tmpHtmlStr := tmpHtmlStr &amp; '&lt;tr&gt;&lt;td&gt;' &amp; input.name &amp; '&lt;/td&gt;&lt;td&gt;' &amp; input.type &amp; '&lt;/td&gt;&lt;/tr&gt;';
					col3Added := true;
				endforeach;
				if not col3Added then
					tmpHtmlStr := tmpHtmlStr &amp; '&lt;tr&gt;&lt;td&gt;&amp;nbsp;&lt;/td&gt;&lt;/tr&gt;';
				else
					tableAdded := true;
				endif;
				tmpHtmlStr := tmpHtmlStr &amp; '&lt;/table&gt;&lt;/td&gt;';
				
				// Column 4 : New Inputs
				col4Added := false;
				tmpHtmlStr := tmpHtmlStr &amp; '&lt;td&gt;&lt;table&gt;';
				foreach input in feat.allInputs do
					if oldFeat.allInputs[input.name] &lt;&gt; null then
						continue;
					endif;
					tmpHtmlStr := tmpHtmlStr &amp; '&lt;tr&gt;&lt;td&gt;' &amp; input.name &amp; '&lt;/td&gt;&lt;td&gt;' &amp; input.type &amp; '&lt;/td&gt;&lt;/tr&gt;';
					col4Added := true;
				endforeach;
				if not col4Added then
					tmpHtmlStr := tmpHtmlStr &amp; '&lt;tr&gt;&lt;td&gt;&amp;nbsp;&lt;/td&gt;&lt;/tr&gt;';
				else
					tableAdded := true;
				endif;
				tmpHtmlStr := tmpHtmlStr &amp; '&lt;/table&gt;&lt;/td&gt;';
				tmpHtmlStr := tmpHtmlStr &amp; '&lt;/tr&gt;';
			endif;
		endforeach;
		
		if tableAdded then
			// Set up the new table
			htmlDocStr := htmlDocStr &amp; '&lt;table class="main"&gt;&lt;caption&gt;Changed ' &amp; class.name &amp; ' calls&lt;/caption&gt;';
			htmlDocStr := htmlDocStr &amp; '&lt;thead&gt;&lt;tr&gt;&lt;th&gt;&amp;nbsp;&lt;/th&gt;&lt;th&gt;Return Type&lt;/th&gt;&lt;th&gt;Old Inputs&lt;/th&gt;&lt;th&gt;New Inputs&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;';
			htmlDocStr := htmlDocStr &amp; tmpHtmlStr;
			htmlDocStr := htmlDocStr &amp; '&lt;/tbody&gt;&lt;/table&gt;';
		endif;
		
	endforeach;
	
	// 3. New Response/Request Objects
	// 4. Changed Response/Request Objects
	// 5. New 'complex' WSDL Objects
	// 6. Changed 'complex' WSDL Objects
	loopNum := 0;
	while true do
		loopNum := loopNum + 1;
		if loopNum = 1 or loopNum = 2 then
			dictToUse := ifObjChanges;
		elseif loopNum = 3 or loopNum = 4 then
			dictToUse := pxyObjChanges;
		else
			// 4 times is enough for now
			break;
		endif;
	
		tableAdded := false;
		tmpHtmlStr := null;
		
		changes := (loopNum mod 2) = 0;	// New Objects = 1, Changes = 0
		
		foreach class in dictToUse do			
			// Grab our previous class
			snapshot := _current[class.name];
			
			// 'Odd' times around the loop, snapshot should be null for New objects
			// 'Even' times around the loop, snapshot should NOT be null for Changed objects
			if not changes and snapshot &lt;&gt; null then
				continue;
			elseif changes and snapshot = null then
				continue;
			endif;
		
			// Column 1 : Class Name
			tmpHtmlStr := tmpHtmlStr &amp; '&lt;tr&gt;&lt;td&gt;' &amp; class.name &amp; '&lt;/td&gt;';
		
			// Columns 2-3 : New Attributes
			paramsAdded := false;
			if changes then
				tmpHtmlStr := tmpHtmlStr &amp; '&lt;td&gt;&lt;table&gt;';
			else
				tmpHtmlStr := tmpHtmlStr &amp; '&lt;td colspan="2"&gt;&lt;table&gt;';
			endif;
			foreach feat in class.allProperties where not feat.deleted do
				paramsAdded := true;
				// Column A : Attribute Name
				tmpHtmlStr := tmpHtmlStr &amp; '&lt;tr&gt;&lt;td&gt;' &amp; feat.name &amp; '&lt;/td&gt;';
				// Column B : Attribute Type/Size
				tmpHtmlStr := tmpHtmlStr &amp; '&lt;td&gt;' &amp; feat.type;
				if feat.size &gt; 0 and feat.type.pos("WS_", 1) = 0 then
					tmpHtmlStr := tmpHtmlStr &amp; ' [0-' &amp; feat.size.String &amp; ']';
				endif;
				tmpHtmlStr := tmpHtmlStr &amp; '&lt;/td&gt;&lt;/tr&gt;';
			endforeach;
			if not paramsAdded then
				tmpHtmlStr := tmpHtmlStr &amp; '&lt;tr&gt;&lt;td&gt;&amp;nbsp;&lt;/td&gt;&lt;td&gt;&amp;nbsp;&lt;/td&gt;&lt;/tr&gt;';
			endif;
			tmpHtmlStr := tmpHtmlStr &amp; '&lt;/table&gt;&lt;/td&gt;';
			
			if changes then
				// Columns 4-5 : Deleted Attributes
				paramsAdded := false;
				tmpHtmlStr := tmpHtmlStr &amp; '&lt;td&gt;&lt;table&gt;';
				foreach feat in class.allProperties do
					oldFeat := snapshot.allProperties[feat.name];

					if 	feat.deleted or
						(oldFeat &lt;&gt; null and
							(feat.name &lt;&gt; oldFeat.name or
							feat.size &lt;&gt; oldFeat.size)
						)
					then
						// Show the old features attributes
						paramsAdded := true;
						// Column A : Attribute Name
						tmpHtmlStr := tmpHtmlStr &amp; '&lt;tr&gt;&lt;td&gt;' &amp; oldFeat.name &amp; '&lt;/td&gt;';
						// Column B : Attribute Type
						tmpHtmlStr := tmpHtmlStr &amp; '&lt;td&gt;' &amp; oldFeat.type;
						if oldFeat.size &gt; 0 and oldFeat.type.pos("WS_", 1) = 0 then
							tmpHtmlStr := tmpHtmlStr &amp; ' [0-' &amp; oldFeat.size.String &amp; ']';
						endif;
						tmpHtmlStr := tmpHtmlStr &amp; '&lt;/td&gt;&lt;/tr&gt;';
					endif;
				endforeach;
				if not paramsAdded then
					tmpHtmlStr := tmpHtmlStr &amp; '&lt;tr&gt;&lt;td&gt;&amp;nbsp;&lt;/td&gt;&lt;td&gt;&amp;nbsp;&lt;/td&gt;&lt;/tr&gt;';
				endif;
				tmpHtmlStr := tmpHtmlStr &amp; '&lt;/table&gt;&lt;/td&gt;';
			endif;
		
			tmpHtmlStr := tmpHtmlStr &amp; '&lt;/tr&gt;';
			tableAdded := true;
		endforeach;
	
		if tableAdded then
			// Set up the new table
			if loopNum = 1 then
				htmlDocStr := htmlDocStr &amp; '&lt;table class="main"&gt;&lt;caption&gt;New Request/Response Objects&lt;/caption&gt;';
			elseif loopNum = 2 then
				htmlDocStr := htmlDocStr &amp; '&lt;table class="main"&gt;&lt;caption&gt;Changed Request/Response Objects&lt;/caption&gt;';
			elseif loopNum = 3 then
				htmlDocStr := htmlDocStr &amp; '&lt;table class="main"&gt;&lt;caption&gt;New WSDL Objects&lt;/caption&gt;';
			elseif loopNum = 4 then
				htmlDocStr := htmlDocStr &amp; '&lt;table class="main"&gt;&lt;caption&gt;Changed WSDL Objects&lt;/caption&gt;';
			endif;
			if not changes then
				htmlDocStr := htmlDocStr &amp; '&lt;thead&gt;&lt;tr&gt;&lt;th&gt;&amp;nbsp;&lt;/th&gt;&lt;th&gt;Attribute Name&lt;/th&gt;&lt;th&gt;Attribute Type&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;';
			else
				htmlDocStr := htmlDocStr &amp; '&lt;thead&gt;&lt;tr&gt;&lt;th&gt;&amp;nbsp;&lt;/th&gt;&lt;th&gt;New Attributes&lt;/th&gt;&lt;th&gt;Deleted Attributes&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;';
			endif;
			htmlDocStr := htmlDocStr &amp; tmpHtmlStr;
			htmlDocStr := htmlDocStr &amp; '&lt;/tbody&gt;&lt;/table&gt;';
		endif;
	endwhile;	
	
	htmlDocStr := htmlDocStr &amp; '&lt;/div&gt;&lt;footer class="footer"&gt;';
	htmlDocStr := htmlDocStr &amp; '&lt;img src="data:image/png;base64," alt="logo small" /&gt;';
	htmlDocStr := htmlDocStr &amp; '&lt;p&gt;Copyright &amp;copy; ' &amp; today.year.String &amp; ' Jade Logistics Group Limited. All rights reserved.&lt;/p&gt;';
	htmlDocStr := htmlDocStr &amp; '&lt;/footer&gt;&lt;/body&gt;&lt;/html&gt;';
	
	create htmlFile transient;
	htmlFile.fileName := self.targetSourceDirectory &amp; "\documentation\JMTNewWSDLFeatures" &amp; self.versionString &amp; ".html";
	htmlFile.mode := File.Mode_Output;
	htmlFile.usePresentationFileSystem := true;
	
	htmlFile.writeString(htmlDocStr);
	
	htmlFile.close();
epilog
	delete wsProviderChanges;
	delete ifObjChanges;
	delete pxyObjChanges;
	delete allClasses;
	if htmlFile.isOpen then
		htmlFile.close();
	endif;
	delete htmlFile;
end;</source>
        <Parameter name="_new" type="DEV_REOWsdlClassDict"/>
        <Parameter name="_changes" type="DEV_REOWsdlClassDict"/>
        <Parameter name="_current" type="DEV_REOWsdlClassDict"/>
        <Parameter name="_schema" type="Schema" usage="input"/>
    </JadeMethod>
</Class>
