    <JadeMethod name="validateForUpdate" id="4ff03a0a-5b2a-49c8-b6a7-3cf89d1eee76">
        <source>validateForUpdate(_existingContRange: CM_ContRange);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	self.testForOverlappingRange(_existingContRange);
	self.validateMe;
end;</source>
        <Parameter name="_existingContRange" type="CM_ContRange"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="7b9489bc-71e5-4735-af56-316cafd2c35d">
        <source>validateMe() protected;
// 16/12/2014  cnwdb2	PAR 35364
vars
	curr : CM_ContRange;
begin
	if self.upper = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Container Range Upper', null, null);
		app.raiseCMException(Input_required_field_contRngUp, null, null); // cnwdb2	PAR 35364
	endif;
	if self.lower = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Container Range Lower', null, null);
		app.raiseCMException(Input_required_field_contRngLw, null, null); // cnwdb2	PAR 35364
	endif;
	
	//09 Feb 2014	NDL	Par 35634
	if self.lower.length &lt;&gt; 11 then
		app.raiseCMException(Cont_range_value_11_chars, null, null);
	elseif self.upper.length &lt;&gt; 11 then
		app.raiseCMException(Cont_range_value_11_chars, null, null);
	endif;
	
	
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
