        <controlMethod name="CMUI_FieldFrame::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>fieldIsBackupJnl_windowCreated(cntrl: CMUI_FieldCheckBox input; persistCntrl: Control) updating;
// --------------------------------------------------------------------------------
