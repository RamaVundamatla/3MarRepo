    <JadeMethod name="setMyProcessObject" id="7b9030d1-98ba-4bcc-ba66-085065c4724a">
        <updating/>
        <source>setMyProcessObject(pValue: JSSProcessObject) updating;
// --------------------------------------------------------------------------------
// Created:		21 May 2002 by cnwwmb1
//
// Purpose:		Sets a reference to the receiver's process object.
//
// Parameters:	pValue - The process object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myProcessObject &lt;&gt; pValue then 
		self.myProcessObject := pValue;
	endif;

end;</source>
        <Parameter name="pValue" type="JSSProcessObject"/>
    </JadeMethod>
