    <JadeMethod name="doBtnSaveClick" id="7e073767-1f18-49fe-8212-485d1e7f03be">
        <updating/>
        <source>doBtnSaveClick() updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 09/10/2017	jlgdap1		TFS 7204 STWR Correct real handling for non-standard locales
// ---------------------------------------------------------------------------

vars
	result,loadState : Boolean;
	theProxyTower : CM_Tower;
	thenextLocationId,thenextSlideFault,theprevLocationId,theprevSlideFault,theremarks : String; 
	thenextSlideDisabled,theprevSlideDisabled,thenonOperational : Boolean; 
	thenextPortHole,theprevPortHole,aProxyContainer : CM_Container;
	thetemperature:Real;
	theRemarksTINext, theRemarksTIPrev : String;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	
begin

	theRemarksTINext := self.tblContainer1.getValueByName(ETRow_Remarks).String;
	theRemarksTIPrev := self.tblContainer2.getValueByName(ETRow_Remarks).String;
	if self.cmbFaultNext.listIndex &gt; 0 then
		thenextSlideFault := self.cmbFaultNext.itemObject[self.cmbFaultNext.listIndex].CM_TowerFault.code; //self.tblTowerDetails.getValueByName(ETRow_NextSlideFault).String;
	endif;
	if self.cmbFaultPrev.listIndex &gt; 0 then
		theprevSlideFault := self.cmbFaultPrev.itemObject[self.cmbFaultPrev.listIndex].CM_TowerFault.code; //self.tblTowerDetails.getValueByName(ETRow_PrevSlideFault).String;
	endif;
	
	theremarks := self.tblTowerDetails.getValueByName(ETRow_Remarks).String;
	thenextSlideDisabled := self.tblTowerDetails.getValueByName(ETRow_NextSlideDisabled).Boolean;
	theprevSlideDisabled := self.tblTowerDetails.getValueByName(ETRow_PrevSlideDisabled).Boolean;
	thenonOperational := self.tblTowerDetails.getValueByName(ETRow_NonOperational).Boolean;
	//thetemperature := self.tblTowerDetails.getValueByName(ETRow_Temperature).Real;					// TFS 7204
	thetemperature := self.tblTowerDetails.getValueByName(ETRow_Temperature).String.asRealJMT;			// TFS 7204

	thenextPortHole := self.myContainerNext;
	theprevPortHole := self.myContainerPrev;

	app.cmsBeginLoad(loadState);
	theProxyTower := self.myTower.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadState);
	theProxyTower.setProxy(thenextSlideFault,theprevSlideFault,theremarks, 
							thenextSlideDisabled,theprevSlideDisabled,thenonOperational, 
							thenextPortHole,theprevPortHole,thetemperature);

	//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateTower(theProxyTower,theRemarksTINext,theRemarksTIPrev,app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Tower Edit', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;
	
	if self.myContainerNext &lt;&gt; null then
		if myContainerNext.remarks &lt;&gt; theRemarksTINext then
			app.cmsBeginLoad(loadState);
			aProxyContainer := self.myContainerNext.pxyCreateUpdateProxy();
			app.cmsEndLoad(loadState);
			
			//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
			while true do
			
				app.myTrxUA.trxUpdateTIRemarks(aProxyContainer, theRemarksTINext, app.myPassport);
			
				if app.myPassport.trxCompletedOK then
					break;
				else
					theResult := app.showErrorWarningDialog('Tower Edit Next Cargo', app.myPassport, ErrWarnMode_Update);
					if app.myPassport.noErrors and theResult = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
				
				return;
				
			endwhile;
	
		endif;
	endif;
	if self.myContainerPrev &lt;&gt; null then
		if myContainerPrev.remarks &lt;&gt; theRemarksTIPrev then
			app.cmsBeginLoad(loadState);
			aProxyContainer := self.myContainerPrev.pxyCreateUpdateProxy();
			app.cmsEndLoad(loadState);
			
			//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
			while true do
			
				app.myTrxUA.trxUpdateTIRemarks(aProxyContainer,theRemarksTIPrev, app.myPassport);
			
				if app.myPassport.trxCompletedOK then
					break;
				else
					theResult := app.showErrorWarningDialog('Tower Edit Previous Cargo', app.myPassport, ErrWarnMode_Update);
					if app.myPassport.noErrors and theResult = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
				
				return;
				
			endwhile;
	
		endif;
	endif;

	global.beep;
epilog
	app.cmsEndLoad(loadState);		// 08/04/2011 cnwmh5 #27347
	delete aProxyContainer;
	delete theProxyTower;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildComboFault" id="74b668c6-1ecd-481b-a725-cfd86da3acdb">
        <source>doBuildComboFault();
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aFault : CM_TowerFault;
	idx : Integer;
begin
	self.cmbFaultNext.clear();
	self.cmbFaultPrev.clear();
	
	
	foreach aFault in app.myRoot.allTowerFaults do
		idx := self.cmbFaultNext.addItem(aFault.code &amp; " - " &amp; aFault.description);
		self.cmbFaultNext.itemObject[idx] := aFault;
		idx := self.cmbFaultPrev.addItem(aFault.code &amp; " - " &amp; aFault.description);
		self.cmbFaultPrev.itemObject[idx] := aFault;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildComboTIs" id="bfb0796a-2557-4e64-80ba-329c5dc263ec">
        <source>doBuildComboTIs(_theCargoType : CM_CargoType);
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks
// ---------------------------------------------------------------------------

vars
	aTrackedItem	 : CM_TrackedItem;
	idx : Integer;
	iter : Iterator;
	loadStateSet : Boolean;
begin

	self.cmbTowerID.clear();
//	app.cmsBeginLoad(loadStateSet);
	iter := self.myTerminal.allOnsiteTIsByCargoTypeId.createIterator();
	self.myTerminal.allOnsiteTIsByCargoTypeId.startKeyGeq(_theCargoType.id,null,iter);

	while iter.next(aTrackedItem) do
		if aTrackedItem.myCargoType.id &lt;&gt; _theCargoType.id then
			break;
		endif;
		
		idx := self.cmbTowerID.addItem(aTrackedItem.id);
		self.cmbTowerID.itemObject[idx] := aTrackedItem;
	endwhile;	
epilog
	delete iter;		// PAR #26678
//	app.cmsEndLoad(loadStateSet);
end;</source>
        <Parameter name="_theCargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="doDisplayContainer" id="3208748b-0d8e-43ea-aca3-584dccb7b3e1">
        <updating/>
        <source>doDisplayContainer(_theTable : CM_EntryTable input; _theContainer : CM_Container) updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/06/20022	navdap1		TFS 53362 EUP Master Data interface customers between TOS and ERP
// ---------------------------------------------------------------------------

vars
	aString : String;
//	aStop : CM_Stops;
//	aTask : CM_ToDoTask;
//	aPort : CM_Port;
	aVoyage : CM_Voyage;
	aComm : CM_Commodity;
//	aLocation : CM_LocationsController;

begin	
	if _theContainer = null then
		return;
	endif;

	_theTable.setValueByName(ETRow_Id,_theContainer.id);
	_theTable.setValueByName(ETRow_FullName,_theContainer.getFullName(REAL_MODE));
	if app.myRoot.getConfig(ComboByNameOperator).Boolean then								// TFS 53362
		_theTable.setValueByName(ETRow_Operator,_theContainer.myOperator.description);		// TFS 53362
	else																					// TFS 53362
		_theTable.setValueByName(ETRow_Operator,_theContainer.myOperator.code);
	endif;																					// TFS 53362

	aString := null;
	aVoyage := self.myTerminal.lookupVoyage(_theContainer.voyageCode, null, false);
	if aVoyage &lt;&gt; null then
		aString := aVoyage.code;
		if aVoyage.description &lt;&gt; null then
			aString := aString &amp; " - " &amp; aVoyage.description;
		endif;
	endif;
	_theTable.setValueByName(ETRow_Voyage,aString);
	
	aString := null;
	aComm := app.myRoot.allCommodities[_theContainer.commodity];
	if aComm &lt;&gt; null then
		aString := aComm.code;
		if aComm.description &lt;&gt; null then
			aString := aString &amp; " - " &amp; aComm.description;
		endif;
	endif;
	_theTable.setValueByName(ETRow_Commodity,aString);


	aString := null;
	if _theContainer.dischargePort &lt;&gt; null then
		aString := _theContainer.dischargePort;
		if _theContainer.dischargePortDescription &lt;&gt; null then
			aString := aString &amp; " - " &amp; _theContainer.dischargePortDescription;
		endif;
	endif;
	_theTable.setValueByName(ETRow_DisPort,aString);
	_theTable.setValueByName(ETRow_SetTemp,_theContainer.getTemperature);
	_theTable.setValueByName(ETRow_DateOnPower,_theContainer.getFirstConnectDT);
	_theTable.setValueByName(ETRow_Remarks,_theContainer.remarks);


	_theTable.disableRowByName(ETRow_Id);
	_theTable.disableRowByName(ETRow_FullName);
	_theTable.disableRowByName(ETRow_DisPort);
	_theTable.disableRowByName(ETRow_DateOnPower);
	_theTable.disableRowByName(ETRow_SetTemp);
	_theTable.disableRowByName(ETRow_Commodity);
	_theTable.disableRowByName(ETRow_Voyage);
	_theTable.disableRowByName(ETRow_Operator);

end;</source>
        <Parameter name="_theTable" type="CM_EntryTable" usage="input"/>
        <Parameter name="_theContainer" type="CM_Container"/>
    </JadeMethod>
    <JadeMethod name="doDisplayTowerTable" id="71170bf2-167d-4128-a870-5e77103d4e19">
        <source>doDisplayTowerTable();
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/06/2022	navdap1		TFS 53362 EUP Master Data interface customers between TOS and ERP
// ---------------------------------------------------------------------------

vars
	theTower : CM_Tower;
	theFault : CM_TowerFault;
begin
	theTower := self.myTower;
	
	self.tblTowerDetails.setValueByName(ETRow_Id,theTower.id);
	self.tblTowerDetails.setValueByName(ETRow_FullName,theTower.getFullName(REAL_MODE));
	if app.myRoot.getConfig(ComboByNameOperator).Boolean then									// TFS 53362
		self.tblTowerDetails.setValueByName(ETRow_Operator,theTower.myOperator.description);	// TFS 53362
	else																						// TFS 53362
		self.tblTowerDetails.setValueByName(ETRow_Operator,theTower.myOperator.code);
	endif;																						// TFS 53362
	self.tblTowerDetails.setValueByName(ETRow_NonOperational,theTower.nonOperational);
	self.tblTowerDetails.setValueByName(ETRow_NextSlideDisabled,theTower.nextSlideDisabled);
	self.tblTowerDetails.setValueByName(ETRow_PrevSlideDisabled,theTower.prevSlideDisabled);
	theFault := app.myRoot.allTowerFaults[theTower.nextSlideFault.trimBlanks];
	if theFault &lt;&gt; null then
		self.tblTowerDetails.setValueByName(ETRow_NextSlideFault,theFault.code &amp; " - " &amp; theFault.description);
	endif;
	theFault := app.myRoot.allTowerFaults[theTower.prevSlideFault.trimBlanks];
	if theFault &lt;&gt; null then
		self.tblTowerDetails.setValueByName(ETRow_PrevSlideFault,theFault.code &amp; " - " &amp; theFault.description);
	endif;

	self.tblTowerDetails.setValueByName(ETRow_Temperature,theTower.temperature);
	self.tblTowerDetails.setValueByName(ETRow_Remarks,theTower.remarks);
	
	self.cmbFaultNext.text := self.tblTowerDetails.getValueByName(ETRow_NextSlideFault).String; //theTower.nextSlideFault;
	self.cmbFaultPrev.text := self.tblTowerDetails.getValueByName(ETRow_PrevSlideFault).String; //theTower.prevSlideFault;
	
	self.tblTowerDetails.disableRowByName(ETRow_Id);
	self.tblTowerDetails.disableRowByName(ETRow_FullName);
	self.tblTowerDetails.disableRowByName(ETRow_Operator);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="715ff950-af43-4cae-89b8-e4cd50fbd2a0">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod();
	if self.width &lt; 400 then
		self.width := 400;
	endif;
	
	self.height := 300;
	
	self.btnClose.move(self.clientWidth - self.btnClose.width - 5, self.clientHeight - self.btnClose.height - 5,self.btnClose.width, self.btnClose.height);
	self.btnEdit.move(self.btnClose.left - self.btnClose.width - 5, self.clientHeight - self.btnClose.height - 5,self.btnClose.width, self.btnClose.height);
	self.btnSave.move(self.btnEdit.left - self.btnEdit.width - 5, self.clientHeight - self.btnClose.height - 5,self.btnClose.width, self.btnClose.height);

	self.fldTower.tabsStyle := Folder.TabsStyle_RightSloped;
	self.fldTower.move(5,5,self.clientWidth - 10, self.btnSave.top - 10);
	self.shtTowerDetails.move(5,30,self.fldTower.clientWidth - 10,self.fldTower.clientHeight - 40);
	self.tblTowerDetails.move(5,5,shtTowerDetails.clientWidth - 10,shtTowerDetails.clientHeight - 10);
	self.tblContainer1.move(self.tblTowerDetails.left,self.tblTowerDetails.top,self.tblTowerDetails.width,self.tblTowerDetails.height);
	self.tblContainer2.move(self.tblTowerDetails.left,self.tblTowerDetails.top,self.tblTowerDetails.width,self.tblTowerDetails.height);


	self.tblTowerDetails.optimiseHeadingColumn();
	self.tblContainer1.optimiseHeadingColumn();
	self.tblContainer2.optimiseHeadingColumn();
end;</source>
    </JadeMethod>
    <JadeMethod name="initContainerTable" id="560f9f2f-fbaa-4c93-9b3e-58ca38431845">
        <updating/>
        <source>initContainerTable(_theTable		: CM_EntryTable) updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	entTableControl	: EntTableDef;
	theTable		: CM_EntryTable;
	aTS : TimeStamp;	
begin


	theTable := _theTable;
	theTable.rows := 0;
	theTable.optimiseRowHeight := true;
	
	entTableControl := app.myController.getEntTableDef(ETDef_TowerContainer); 
	
	theTable.setEntTableDef(entTableControl, null, 'entTableDefSetupWarning');

	theTable.top 	:= 5;
	theTable.left	:= 5;
	theTable.parentTopMargin	:= theTable.top;
	theTable.parentLeftMargin	:= theTable.left;
	theTable.parentRightMargin	:= 15;
	theTable.parentBottomMargin := 10;
	theTable.changeMode := theTable.ChangeMode_FirstOnly;
	theTable.lockBottom := false;
	theTable.lockRight	:= false;
	theTable.stretchHeight := true;
	theTable.stretchWidth := true;
	theTable.visible := true;
	theTable.pictureViewMethod := 'picViewMethod';
	theTable.pictureLoadMethod := 'picLoadMethod';
	theTable.pictureExtractMethod := 'picExtractMethod';
	theTable.resetSize();




end;</source>
        <Parameter name="_theTable" type="CM_EntryTable"/>
    </JadeMethod>
    <JadeMethod name="initTowerTable" id="2f9fea65-25a5-49e0-8171-630b48f4572e">
        <updating/>
        <source>initTowerTable() updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	entTableControl	: EntTableDef;
	theTable		: CM_EntryTable;
	aTS : TimeStamp;	
begin


	theTable := self.tblTowerDetails;
	theTable.rows := 0;
	theTable.optimiseRowHeight := true;
	
	entTableControl := app.myController.getEntTableDef(ETDef_TowerEdit); 
	
	theTable.setEntTableDef(entTableControl, null, 'entTableDefSetupWarning');

	theTable.top 	:= 5;
	theTable.left	:= 5;
	theTable.parentTopMargin	:= theTable.top;
	theTable.parentLeftMargin	:= theTable.left;
	theTable.parentRightMargin	:= 15;
	theTable.parentBottomMargin := 10;
	theTable.changeMode := theTable.ChangeMode_FirstOnly;

	theTable.lockBottom := false;
	theTable.lockRight	:= false;
	theTable.stretchHeight := true;
	theTable.stretchWidth := true;
	theTable.visible := true;
	theTable.pictureViewMethod := 'picViewMethod';
	theTable.pictureLoadMethod := 'picLoadMethod';
	theTable.pictureExtractMethod := 'picExtractMethod';
	theTable.resetSize();


end;</source>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="db217641-5365-4190-8e0e-d8c6ca963cdc">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:      03 June 2003 by cnwsgp1
// ---------------------------------------------------------------------------
begin
	self.doBuildComboFault();
	
	self.caption := self.caption &amp; " " &amp; self.myTower.id;
	if self.myContainerNext &lt;&gt; null then
		self.shtContainer1.caption := self.myContainerNext.id &amp; " (next)";
		self.shtContainer1.visible := true;
	else
		self.shtContainer1.visible := false;
	endif;

	if self.myContainerPrev &lt;&gt; null then
		self.shtContainer2.caption := self.myContainerPrev.id &amp; " (previous)";
		self.shtContainer2.visible := true;
	else
		self.shtContainer2.visible := false;
	endif;

	self.doDisplayTowerTable();
	self.doDisplayContainer(self.tblContainer1,self.myContainerNext);	
	self.doDisplayContainer(self.tblContainer2,self.myContainerPrev);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="7d196614-64f6-4171-ac54-f751fccaa3ff">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
