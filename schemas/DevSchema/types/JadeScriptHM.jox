    <JadeMethod name="clearInvalidRecVoyageTi" id="eb77b1eb-3977-4390-9a79-1b66208a5208">
        <source>clearInvalidRecVoyageTi();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2025	navhl20	Initial creation

*/

vars
	term 	: CM_Terminal;
	ti		: CM_TrackedItem;
	lFile	: File;
begin
	app.initialize();
	term := app.myRoot.allTerminals['WO'];
	create lFile transient;
	lFile.fileName := "C:\TEMP\" &amp; term.code &amp;"VoyageData-1.csv";
    lFile.open;
	
	lFile.writeLine("Voyage Oid"  	  			&amp; Comma &amp;
					"Release Date"  			&amp; Comma &amp;
					"TrackedItem Code"  		&amp; Comma &amp;
					"TrackedItem Oid"
					);
	
	foreach ti in term.allOffsiteTIsByCargoTypeId do
		if ti.receiveVoyage &lt;&gt; null and not app.isValidObject(ti.receiveVoyage) then
			lFile.writeLine(ti.receiveVoyage.getOidAsString 	&amp; Comma &amp;
							ti.releasedDT.asStringJMT  			&amp; Comma &amp;
							ti.getOidAsString  					&amp; Comma &amp;
							ti.id
							);
		endif;
	endforeach;
epilog
	delete lFile;
end;</source>
    </JadeMethod>
