<Class name="CMQF_InvoiceContract">
    <JadeMethod name="setFromAgent" id="28393214-7953-47f0-b6a1-7f9bc95041f5">
        <updating/>
        <source>setFromAgent(_agent: CMUI_ReportAgent input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
// 24/04/2023	navkc1	CR 55654 Task 55670: Jade - Contract reporting
// 22/11/2023	navkc1 Bug 61266: FR | 54089 - EUP - Invoice Contracts - Reporting
*/

vars
	debtor	 	: CM_Debtor;
	invLineType : CM_InvoiceLineDesc;
	service		: CM_Service;
	calType		: CM_CalculationType;
	uom			: CM_InvoiceUnitOfMeasure;
	
begin
	inheritMethod(_agent);
	
	if _agent.isRowIncluded(ETRow_Active) then
		self.isActive := _agent.getValueByName(ETRow_Active).Boolean;
	endif;
	
	if _agent.isRowIncluded(ETRow_Company) then
		self.myBusinessUnit := _agent.getSelectedCompany();
	endif;
	
	if _agent.isRowIncluded(ETRow_ContractFromStartDate) then
		self.contractFromStartDate := _agent.getValueByName(ETRow_ContractFromStartDate).Date;
	endif;
	
	if _agent.isRowIncluded(ETRow_ContractFromEndDate) then
		self.contractFromEndDate := _agent.getValueByName(ETRow_ContractFromEndDate).Date;
	endif;
	
	if _agent.isRowIncluded(ETRow_ContractId) then
		self.contractId := _agent.getValueByName(ETRow_ContractId).String;
	endif;
	
	if _agent.isRowIncluded(ETRow_ContractToStartDate) then
		self.contractToStartDate := _agent.getValueByName(ETRow_ContractToStartDate).Date;
	endif;
	
	if _agent.isRowIncluded(ETRow_ContractToEndDate) then
		self.contractToEndDate := _agent.getValueByName(ETRow_ContractToEndDate).Date;
	endif;
	
	if _agent.isRowIncluded(ETRow_Debtor) then
		debtor := _agent.getSelectedDebtor();
		if debtor &lt;&gt; null then
			self.allDebtors.add(debtor);
		endif;
	endif;
	
	if _agent.isRowIncluded(ETRow_Description) then
		self.description := _agent.getValueByName(ETRow_Description).String.toUpper();
	endif;
	
	if _agent.isRowIncluded(ETRow_DetailFromStartDate) then
		self.detailsFromStartDate := _agent.getValueByName(ETRow_DetailFromStartDate).Date;
	endif;
	
	if _agent.isRowIncluded(ETRow_DetailFromEndDate) then
		self.detailsFromEndDate := _agent.getValueByName(ETRow_DetailFromEndDate).Date;
	endif;
	
	if _agent.isRowIncluded(ETRow_CalculationType) then
		calType := _agent.getSelectedCalculationType();
		if calType &lt;&gt; null then
			self.allCalculationTypes.add(calType);
		endif;
	endif;
	
	if _agent.isRowIncluded(ETRow_DetailToStartDate) then
		self.detailsToStartDate := _agent.getValueByName(ETRow_DetailToStartDate).Date;
	endif;
	
	if _agent.isRowIncluded(ETRow_DetailToEndDate) then
		self.detailsToEndDate := _agent.getValueByName(ETRow_DetailToEndDate).Date;
	endif;
	
	if _agent.isRowIncluded(ETRow_InvLineType) then
		invLineType := _agent.getSelectedInvoiceLineType();
		if invLineType &lt;&gt; null then
			self.allInvoiceLineTypes.add(invLineType);
		endif;
	endif;
	
	if _agent.isRowIncluded(ETRow_Primary) then
		self.isPrimary := _agent.getValueByName(ETRow_Primary).Boolean;
	endif;
	
	if _agent.isRowIncluded(ETRow_RateFromStartDate) then
		self.rateFromStartDate := _agent.getValueByName(ETRow_RateFromStartDate).Date;
	endif;
	
	if _agent.isRowIncluded(ETRow_RateFromEndDate) then
		self.rateFromEndDate := _agent.getValueByName(ETRow_RateFromEndDate).Date;
	endif;
	
	if _agent.isRowIncluded(ETRow_RateToStartDate) then
		self.rateToStartDate := _agent.getValueByName(ETRow_RateToStartDate).Date;
	endif;
	
	if _agent.isRowIncluded(ETRow_RateToEndDate) then
		self.rateToEndDate := _agent.getValueByName(ETRow_RateToEndDate).Date;
	endif;
	
	if _agent.isRowIncluded(ETRow_Service) then
		service := _agent.getSelectedService();
		if service &lt;&gt; null then
			self.allRateServices.add(service);
		endif;
	endif;
	
	if _agent.isRowIncluded(ETRow_UnitOfMeasureCode) then
		uom := _agent.getSelectedUnitOfMeasure();
		if uom &lt;&gt; null then
			self.allUnitOfMeasures.add(_agent.getSelectedUnitOfMeasure());
		endif;
	endif;
	
	// 22/11/2023	navkc1 Bug 61266
	if _agent.isRowIncluded(ETRow_VolumeBased) then
		self.isVolBased := _agent.getValueByName(ETRow_VolumeBased).Boolean;
	endif;
	
epilog

end;</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
