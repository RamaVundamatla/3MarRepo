    <JadeMethod name="executeDisplayNotesForMove" id="52b3c4e4-57c5-42c4-a33c-c9a17193fe20">
        <source>executeDisplayNotesForMove(_controller : CMIF_MoveController);
// ---------------------------------------------------------------------------
// Created:		29 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theVoyage : CM_Voyage;	
	theTerminal : CM_Terminal;
	theTI : CM_TrackedItem;
begin

	theTerminal := self.myTerminal;
	//epr par 15648 14/1/2008
	theTI := _controller.myTrackedItem;
	if theTI &lt;&gt; null then
		if  self = _controller.myOriginatingLocation then
			app.myEventManager.createSingleObjInfoNoteEvt(self.myVoyage, theTerminal.getTerminalEvent(EVENT_TI_MOVE_FROM_LOCATION),theTI);
		elseif self = _controller.myToPrimaryLocation then
			app.myEventManager.createSingleObjInfoNoteEvt(self.myVoyage, theTerminal.getTerminalEvent(EVENT_TI_MOVE_TO_LOCATION),theTI);
		endif;
		app.myEventManager.createSingleObjInfoNoteEvt(self.myVoyage, theTerminal.getTerminalEvent(EVENT_TI_MOVE),self);
	endif;

	app.myEventManager.createSingleObjInfoNoteEvt(self.myVoyage,  theTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA), self);
	
end;</source>
        <Parameter name="_controller" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="executePreMoveFromLocation" id="2e3bdbea-30cf-42f8-a2fd-b3469d4052d7">
        <updating/>
        <source>executePreMoveFromLocation(_control: CMIF_MoveController) updating;
//--------------------------------------------------------------
//Created: 17 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	tiEvent : Integer;
	ti : CM_TrackedItem;
begin
	inheritMethod(_control);
	tiEvent := NULL_TI_EV;

	if _control.moveMode = REAL_MODE then
		//Force this update
		if self.myTerminalArea &lt;&gt; null then		
			self.myTerminalArea.calculateFIFODate();
		endif;
		
		if _control.isForcedMove then
			tiEvent := NON_OPS_REAL_MOVE_FROM_EV;
		else
			tiEvent := OPS_MOVE_FROM_EV;
	    endif;
	elseif _control.moveMode = PLANNING_MODE and _control.isForcedMove = false then
		tiEvent := PLANNED_MOVE_FROM_EV;
	endif;

	if tiEvent = NULL_TI_EV then
		return;
	endif;
	//---------------------
	//Update the TI/Job ect
	//---------------------
	ti := _control.myTrackedItem;
	//Comment by DQ 19 feb 03. I'm not sure if this is still needed, its a little rough!
	ti.miscTIEvent(tiEvent);

end;</source>
        <Parameter name="_control" type="CMIF_MoveController"/>
    </JadeMethod>
