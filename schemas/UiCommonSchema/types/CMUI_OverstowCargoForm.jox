    <JadeMethod name="doQuery" id="a4342d59-658f-4bd7-82f4-436cff510c7e">
        <updating/>
        <source>doQuery() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 November 2009	cnwphb1	Initial creation

*/

vars
	invalidItem	: Boolean;
begin
	on Exception do app.handleDeletedObject(exception, self.myTrackedItem, invalidItem);
	
	self.mousePointer := Window.MousePointer_HourGlass;
	self.tblData.rows := self.tblData.fixedRows;
	self.tblData.clearAllSelected();

	self.displayTable(self.tblData);
epilog
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryAddItem" id="db524634-9e32-4740-ad5e-01b78ebe3126">
        <updating/>
        <source>doQueryAddItem(_table : CM_DataTable input; _theRow : Integer; _theTI : CM_TrackedItem) : Integer updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 November 2009	cnwphb1	Initial creation

*/

vars
	theDataLine	: String;
	idx			: Integer;
begin
	theDataLine := _theTI.getAttributeStringForDefArray(_table.allTblDataEntRows);

	if _theRow = 0 then
		idx := _table.addItem(theDataLine.trimBlanks);
	else
		idx := _theRow;
		if idx &gt; _table.rows then
			idx := _table.addItem(theDataLine.trimBlanks);
		else
			_table.addItemAt(theDataLine.trimBlanks, idx);
		endif;

	endif;
	_table.accessRow(idx).itemObject := _theTI;
	
	// Setup note for this item
	self.doNotableAdd(_theTI);

	// General renumber is called later
	self.doQueryColourUp(_table, _theTI, idx);
	
	return idx;
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_theRow" type="Integer"/>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doQueryColourUp" id="e0ad6128-67ef-4d99-b0e2-e99fb904ce79">
        <source>doQueryColourUp(_table : CM_DataTable input;_theTI : CM_TrackedItem;_theRow : Integer);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 November 2009	cnwphb1	Initial creation

*/

vars
	thePort			: CM_Port;
	theColour,
	theColumn		: Integer;
	theCommodity	: CM_Commodity;
	theISOType		: CM_ISOType;
	theCell			: JadeTableCell;
	drwAtt			: CM_DrawingAttribute;
	carrier			: CM_Carrier;
begin
	// COLOUR UP THE ISO Type
	theColumn := _table.getColumnByRowName(ETRow_IsoTypeDesc);
	if theColumn &gt; 0 then
		if _theTI.isKindOf(CM_Container) then 
			theISOType := _theTI.CM_Container.getISOTypeObject();
			if theISOType &lt;&gt; null then
				theColour := theISOType.colour;
			endif;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Ready To Ship
	theColumn := _table.getColumnByRowName(ETRow_ReadyToShip);
	if theColumn &gt; 0 then
		if _theTI.readyToShip then
			theColour := Green;
		else
			theColour := Red;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Operator
	theColumn := _table.getColumnByRowName(ETRow_OperatorCode);
	if theColumn &gt; 0 then
		if _theTI.myOperator &lt;&gt; null then
			theColour := _theTI.myOperator.colour;
		else
			theColour := White;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Discharge Port
	theColumn := _table.getColumnByRowName(ETRow_DischargePort);
	if theColumn &gt; 0 then
		thePort := app.myRoot.allPorts[_theTI.dischargePort];
		if thePort &lt;&gt; null then
			theColour := thePort.colour;
		else
			theColour := White;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Commodity
	theColumn := _table.getColumnByRowName(ETRow_Commodity);
	if theColumn &gt; 0 then
		theCommodity := app.myRoot.allCommodities[_theTI.commodity];
		if theCommodity &lt;&gt; null then
			theColour := theCommodity.colour;
		else
			theColour := White;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Voyage
	theColumn := _table.getColumnByRowName(ETRow_VoyageCode);
	if theColumn &gt; 0 then
		if _theTI.myVoyage &lt;&gt; null then
			theColour := _theTI.myVoyage.colour;
		else
			theColour := White;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;

	// COLOUR UP THE Custom Export Delivery Number
	theColumn := _table.getColumnByRowName(ETRow_CustomExportEntryNumber);
	if theColumn &gt; 0 then
		if _theTI.customExportEntryNumber = null then
			theColour := Red;
		else
			theColour := White;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;

	// COLOUR UP THE Custom Export Hold
	theColumn := _table.getColumnByRowName(ETRow_CustomExportStop);
	if theColumn &gt; 0 then
		theCell := _table.accessCell(_theRow, theColumn);
		if theCell.text &lt;&gt; null then
			drwAtt := app.myRoot.allDrawingAttributes[PicTICustomHold];
			if drwAtt &lt;&gt; null then
				theCell.foreColor := drwAtt.colour;
				theCell.text := drwAtt.fontCharacter.Character;
				theCell.fontName := drwAtt.fontName;
			endif;
		endif;
	endif;

	// COLOUR UP THE carrier	TFS4209 MAP 8/6/17
	theColumn := _table.getColumnByRowName(ETRow_Carrier);
	if theColumn &gt; 0 then
		carrier := app.myRoot.allCarriers[_theTI.carrier];
		if carrier &lt;&gt; null then
			theColour := carrier.colour;
		else
			theColour := White;
		endif;
		_table.accessCell(_theRow, theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	theColumn := _table.getColumnByRowName(ETRow_ReleaseCarrier);
	if theColumn &gt; 0 then
		carrier := app.myRoot.allCarriers[_theTI.releaseCarrier];
		if carrier &lt;&gt; null then
			theColour := carrier.colour;
		else
			theColour := White;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_theRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doSystemNotification" id="08ca910f-616f-4da2-885e-98f040b64c61">
        <updating/>
        <source>doSystemNotification(eventType: Integer; theObject: Object; eventTag: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 November 2009	cnwphb1	Initial creation

*/

vars
	ti				: CM_TrackedItem;
	renumberData	: Boolean;
begin
	app.mousePointer :=	Busy;

	if not theObject.isKindOf(CM_TrackedItem) then
		return;
	endif;
	ti := theObject.CM_TrackedItem;
	if ti &lt;&gt; null then
		self.doTIUpdate(ti, renumberData);
	endif;
	
	if renumberData then
		self.doTblDataRenumberItems(self.tblData, 0);
	endif;
epilog
	endLoad;
	app.mousePointer :=	Idle;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doTIUpdate" id="ad64d8ad-42cd-4455-a9df-96f22ea8ed2d">
        <updating/>
        <source>doTIUpdate(_theTI : CM_TrackedItem;_renumberData : Boolean output) updating;
/*
Date		Who		Reason
17 November 2009	cnwphb1	Initial creation
29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
*/

vars
	aTI		: CM_TrackedItem;
	theRow	: Integer;
begin
	aTI := _theTI;

	if not app.isValidObject(aTI) then
		if self.tblData.findObjectInRow(aTI, theRow) then
			// If non planned is to be removed (eg voyage changed) then need to update summary immediately so can be removed from totals. 
			self.tblData.removeItemObject(aTI);
			_renumberData := true;
			self.doNotableRemove(aTI);
		endif;
	else
		self.tblData.removeItemObject(aTI);
		self.updateTableItem(self.tblData, aTI);
		_renumberData := true;
	endif;
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_renumberData" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="doTblDataContextMenu" id="d5370d81-602f-4feb-ad77-6d8cfc568dc6">
        <updating/>
        <source>doTblDataContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 November 2009	cnwphb1	Initial creation

*/

vars
	theRow	: Integer;
	theTI	: CM_TrackedItem;
begin
	if app.isAllowedToInspect then
		self.mnuInspectObject.visible := true;
	else
		self.mnuInspectObject.visible := false;	
	endif;
	
	self.doContextMenuBuild();
	theRow := cntrl.CM_BaseTable.getRowFromY(y);
	if theRow &gt; cntrl.fixedRows then
		theTI := cntrl.accessRow(theRow).itemObject.CM_TrackedItem;
		self.mnuInspectObject.userObject := theTI;
	endif;

	return self.showContextMenu(self.mnuContextTable,cntrl,conwin,mouse,x,y);
end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblDataDBClick" id="b02c4e12-5a10-4377-ad11-d0faed85c9de">
        <updating/>
        <source>doTblDataDBClick(table: CM_DataTable input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 November 2009	cnwphb1	Initial creation

*/

vars
	theTI	: CM_TrackedItem;
	theRow	: Integer;
begin
	inheritMethod(table);
	
	if table.row &gt; table.fixedRows then
		theTI := table.accessRow(table.row).itemObject.CM_TrackedItem;
		if theTI &lt;&gt; null then
			self.myAssistant.showCargoEnquiryForm(theTI, self.myMasterMenuAction, true, false);	
		endif;
	endif;
end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblDataRenumberItems" id="e9566ccb-55d5-44e5-947e-68e7109313d7">
        <updating/>
        <source>doTblDataRenumberItems(_table :CM_DataTable input; _fromRow : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		November 2009 By Pieter Bremmers cnwphb1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	tmpFixedRows,
	idx,
	numZeros,
	startRow,
	endRow,
	col			: Integer;
	itemObject 	: Object;
begin
	col :=  _table.getColumnByRowName(ETRow_RowNumber); 
	
	if col = 0 then
		return;
	endif;

	tmpFixedRows := _table.fixedRows;
	if _fromRow &lt;= tmpFixedRows then
		startRow := tmpFixedRows + 1;
	else
		startRow := _fromRow;
	endif;
	endRow := _table.rows;
	numZeros := endRow.String.length;
	
	foreach idx in startRow to endRow do
		itemObject:=_table.accessRow(idx).itemObject;
		_table.accessCell(idx, col).text:=self.allTrackedItems.indexOf(itemObject.CM_TrackedItem).String.padLeadingZeros(numZeros);
	endforeach;
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_fromRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initTableData" id="4a970dfd-bb32-4046-83da-9b7da8cbd367">
        <updating/>
        <source>initTableData(_theEntDef: String) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 November 2009	cnwphb1	Initial creation

*/

vars
	theTable	: CM_DataTable;
begin
	inheritMethod(_theEntDef);
	
	// Data table
	theTable := self.tblData;
	theTable.multiSelect := CM_BaseTable.MultiSelect_None;
	theTable.allowDragSelect := true;
	// Use dynaDict to sort table as jade cannot sort more than 3 columns
	theTable.initTableObjectsDynaDict(CM_TrackedItem, theTable.myEntTableDef.allEntTableRows.size);
end;</source>
        <Parameter name="_theEntDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="9389cb84-8a1a-491b-99e7-5860f3e02673">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
16 Nov 2009	cnwphb1	Initial creation

*/
vars

begin
	self.usesQueryFrame		:= false;
	self.toolbarStyle		:= self.ToolbarStyle_ShowNoHide;
	self.showToolbar		:= true;
	self.useTableInfo		:= false;
	self.useTableSorting	:= true;
	
	inheritMethod();

	self.caption := self.caption &amp; " " &amp; self.myTrackedItem.auditIdDisplay;
	
	self.mnuLLLocateGridArea.caption := app.getErrorString(Locate_yard_enquiry_form);
	
	self.initTableData(ETDef_LlHeadings);
	
	self.mode := self.Mode_Enquire;
	
	if self.myTrackedItem &lt;&gt; null then
		self.doQuery();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="28855994-3773-44bb-8f22-4b5cb4468755">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 24 May 2018 08:47:02.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0012915, locale);
	btnEdit.translateCaption(Xlat_0012916, locale);
	btnEnquire.translateCaption(Xlat_0012917, locale);
	btnLocate.translateCaption(Xlat_0012918, locale);
	lblMachine.translateCaption(Xlat_0022436, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="updateTableItem" id="96387ae6-df92-4518-aca0-a77e0edcc702">
        <updating/>
        <source>updateTableItem(_table : CM_DataTable input; _ti : CM_TrackedItem) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 November 2009	cnwphb1	Initial creation

*/

vars
	rowIdx	: Integer;
begin
	if _table = null then
		return;
	endif;

	if _table.allTableObjects &lt;&gt; null and
	  (not _table.allTableObjects.noKeys()) then
		// sorting by more than 3 columns update dynaDict to sort
		//_table.setSortColumnTableObjects();
		
		if not _table.allTableObjects.includes(_ti) then
			_table.allTableObjects.addObject(_ti);
		endif;
		
		rowIdx := _table.allTableObjects.indexOf(_ti) + _table.fixedRows;
		
		self.doQueryAddItem(_table, rowIdx, _ti);
	else
		rowIdx := self.doQueryAddItem(_table, 0, _ti);
	endif;
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
</GUIClass>
