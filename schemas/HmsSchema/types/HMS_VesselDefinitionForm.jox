		// BowToFwdContainer
		tblKeyDistances.row:=4;
		tblKeyDistances.text:= self.myCurrentVesselData.dist_BowToFwdContainer.String;
		// SternToAftContainer
		tblKeyDistances.row:=5;
		tblKeyDistances.text:= self.myCurrentVesselData.dist_SternToAftContainer.String;
		// SternToBunker
		tblKeyDistances.row:=6;
		tblKeyDistances.text:= self.myCurrentVesselData.dist_SternToBunker.String;
	endif;



	// Set enteries in "Units" column
	tblKeyDistances.column:=3;
	tblKeyDistances.row:=2;
	tblKeyDistances.text:="m";
	tblKeyDistances.row:=3;
	tblKeyDistances.text:="m";
	tblKeyDistances.row:=4;
	tblKeyDistances.text:="m";
	tblKeyDistances.row:=5;
	tblKeyDistances.text:="m";
	tblKeyDistances.row:=6;
	tblKeyDistances.text:="m";





end;</source>
    </JadeMethod>
    <JadeMethod name="loadResourceList" id="83ccb285-db2c-4966-97ad-940e5270b23a">
        <updating/>
        <source>loadResourceList() updating;

vars
	resourceDescription:	HMS_ResourceType;
	resource:				HMS_Resource;
	tmpResourceTypes:		HMS_ResourceTypeByCodeDict;
begin
 	// This method loads all resources available for selection into the resource list
 	if (not self.lbxResourceList.visible) then
 		return;
 	endif;
 	
 	lbxResourceList.clear;
 	lbxResourceList.hasPictures:=false;
 	
 	tmpResourceTypes := app.myRoot.allResourceTypes;

 	foreach resourceDescription in tmpResourceTypes discreteLock 
 		where resourceDescription.isNotAvailableForEntry = false  do // CCMS1350
 		
 		lbxResourceList.addItem(resourceDescription.description);
 		lbxResourceList.itemObject[lbxResourceList.newIndex]:=resourceDescription;
		lbxResourceList.itemLevel[lbxResourceList.newIndex]:=1;
		lbxResourceList.itemPicture[lbxResourceList.newIndex]:=resourceDescription.iconUpState;
		lbxResourceList.itemExpanded[lbxResourceList.newIndex]:=true;
		foreach resource in resourceDescription.allResources discreteLock 
	 		where resource.isNotAvailableForEntry = false  do // CCMS1350
			lbxResourceList.addItem(resource.description);
 			lbxResourceList.itemObject[lbxResourceList.newIndex]:=resource;
			lbxResourceList.itemLevel[lbxResourceList.newIndex]:=2;
			lbxResourceList.itemExpanded[lbxResourceList.newIndex]:=false;
		endforeach;
	endforeach;

	// Select resources that have been selected for use
	self.setResourcesForDefault();



end;</source>
    </JadeMethod>
    <JadeMethod name="loadResourceTypeRow" id="1a1100e1-e078-486f-a3c9-9ae9831ef27e">
        <updating/>
        <source>loadResourceTypeRow(_resourceMove : HMS_ResourceTypeForMovement) updating;

vars
	int,
	newRow : Integer;
	newCntrl : Control;
	newCombo : CMUI_ComboBox;
	tmpTable : CM_DataTable;
	resourcType : HMS_ResourceType;
begin

	tmpTable := self.tblResources;
	tmpTable.clearAllSelected();
	newRow := tmpTable.rows+1;
	tmpTable.rows := newRow;
	tmpTable.row := newRow;
	tmpTable.column:=1;

	if _resourceMove &lt;&gt; null then
		tmpTable.itemObject:=_resourceMove;
	endif;			
	
	tmpTable.column := tmpTable.getColumnByRowName(ETRow_MoveType);
	newCombo := self.cmbMovementType.loadControl(newIndex).CMUI_ComboBox;
	self.allClonedControls.add(newCombo);
	tmpTable.accessCell(newRow, tmpTable.column).cellControl := newCombo;
	newCombo.addItem(HMSMovementTypeArrival);
	newCombo.addItem(HMSMovementTypeShift);
	newCombo.addItem(HMSMovementTypeDeparture);
	if _resourceMove &lt;&gt; null then
		tmpTable.text := _resourceMove.movementType;
	else		
		tmpTable.text := HMSMovementTypeArrival;
	endif;
	newCombo.listIndex := newCombo.findStringExact(1, tmpTable.text);
	
	newIndex := newIndex+1;
	tmpTable.column := tmpTable.getColumnByRowName(ETRow_ResourceTypes);	
	newCntrl := self.lstResourceType.loadControl(newIndex);
	self.allClonedControls.add(newCntrl);
	tmpTable.accessCell(newRow, tmpTable.column).cellControl := newCntrl;
	self.myAssistant.listTableResouceType(newCntrl.CMUI_ListTable);
	if _resourceMove &lt;&gt; null then
//		_resourceMove.allResourceTypes.copy(newCntrl.CMUI_ListTable.allSelectedObjects);
		foreach resourcType in _resourceMove.allResourceTypes discreteLock do 
			if resourcType.isNotAvailableForEntry then // will need to be added to table 
				if not newCntrl.CMUI_ListTable.findObject(resourcType, int) then 
					newCntrl.CMUI_ListTable.addItemObject(self.myAssistant.displayEntryHMSResourceType(resourcType), resourcType);
				endif;
			endif;
			newCntrl.CMUI_ListTable.addSelectedObject(resourcType);		
		endforeach;
		tmpTable.text := newCntrl.CMUI_ListTable.getSelectedFromDisplay();
	endif;

	newIndex := newIndex+1;
	tmpTable.column := tmpTable.getColumnByRowName(ETRow_NumTugsForMovement);		
	newCntrl := self.txtTugsForMove.loadControl(newIndex);
	self.allClonedControls.add(newCntrl);
	tmpTable.accessCell(newRow, tmpTable.column).cellControl := newCntrl;
	
	if _resourceMove &lt;&gt; null then	
		tmpTable.text := _resourceMove.numTugsForMovement.String;
		newCntrl.TextBox.text := _resourceMove.numTugsForMovement.String;
	endif;

	self.btnDelResource.enabled := true;		

	
end;</source>
        <Parameter name="_resourceMove" type="HMS_ResourceTypeForMovement"/>
    </JadeMethod>
    <JadeMethod name="loadSummaryTbl" id="ad042092-ce5d-47a2-bf8a-e8dceb0523c5">
        <updating/>
        <source>loadSummaryTbl() updating;

vars
 	berthPref: String;
begin

	// Set column widths
	tblSummary.columnWidth[1] := 110;
	tblSummary.columnWidth[2] := 192;

	// Set number of rows
	tblSummary.rows:=9;

	// Set table input modes
	tblSummary.accessMode:=tblSummary.AccessMode_Column;
	tblSummary.column:=1;
	tblSummary.inputType:=tblSummary.InputType_None;	
	tblSummary.column:=2;
	tblSummary.inputType:=tblSummary.InputType_None;
	tblSummary.alignment:=tblSummary.Alignment_Right;	

	// Set enteries in "Titles" column
	tblSummary.column:=1;
	tblSummary.row:=1;
	tblSummary.text:="Name:";
	tblSummary.row:=2;
	tblSummary.text:="Class:";
	tblSummary.row:=3;
	tblSummary.text:="Type:";
	tblSummary.row:=4;
	tblSummary.text:="LOA:";
	tblSummary.row:=5;
	tblSummary.text:="GRT:";
	tblSummary.row:=6;
	tblSummary.text:="Preferred Berth:";
	tblSummary.row:=7;
	tblSummary.text:="Shipping Line:";
	tblSummary.row:=8;
	tblSummary.text:="Agent/Rep.:";
	tblSummary.row:=9;
	// Modified by Russell 26/03/99
	// ---------------------------------------------------------
	//tblSummary.text:="Default Tidal Class:";
	tblSummary.text:="Default Tidal Classes:";
	// ---------------------------------------------------------

	// Set enteries in "Values" column
	tblSummary.column:=2;
	tblSummary.row:=1;
	tblSummary.text:=tbxShipName.text;
	tblSummary.row:=2;
	tblSummary.text:=cbxShipClass.text;
	tblSummary.row:=3;
	tblSummary.text:=cbxShipType.text;
	tblSummary.row:=7;
	tblSummary.text:= self.cmbShippingLine.text;

	// Get LOA from dimensions table
	tblSummary.row:=4;
	tblBasicDimension.column:=2;
	tblBasicDimension.row:=2;
	tblSummary.text:=tblBasicDimension.text &amp; "m";

	// Get GRT from dimensions table
	tblSummary.row:=5;
	tblBasicDimension.column:=2;
	tblBasicDimension.row:=3;
	tblSummary.text:=tblBasicDimension.text.Integer.userNumberFormat($CM_HMS_Tonnage) &amp; "T";

	tblSummary.row:=6;
	if tblPrefBerth.rows&gt;1 then
		tblPrefBerth.row:=2;
		tblPrefBerth.column:=1;
		berthPref:=tblPrefBerth.accessCell(2,1).text;
		if berthPref=null then
			tblSummary.text:="None selected";
		else
			tblSummary.text:=berthPref;
		endif;
	else
		tblSummary.text:="None selected";
    endif;

	tblSummary.row:=7;
	tblSummary.text:= self.cmbShippingLine.text;
	tblSummary.row:=8;
	tblSummary.text:= self.cmbShippingAgent.text;
	tblSummary.row:=9;
	tblSummary.text:="Arrive [" &amp; cbxTidalClassArrv.text &amp; "]; Depart [" &amp; cbxTidalClassDept.text &amp; "]";

end;</source>
    </JadeMethod>
    <JadeMethod name="loadTidalClassTbl" id="52901026-02b3-4c0b-9fb7-fc254056b90a">
        <updating/>
        <source>loadTidalClassTbl() updating;

vars
 	count: 		Integer;
 	tidalClass: HMS_TidalClass;
 	tidalClassDept: HMS_TidalClass;
begin
	// Arrival Tidal Classes Setup
	// ----------------------------------------------------------------------
	// Set column widths
	tblMaxCurrentsArr.columnWidth[1]:=205;
	tblMaxCurrentsArr.columnWidth[2]:=65;
	tblMaxCurrentsArr.columnWidth[3]:=40;


	// Set number of rows
	tblMaxCurrentsArr.rows:=5;

	// Make table readOnly
	tblMaxCurrentsArr.readOnly:=true;

	// Set table input modes
	tblMaxCurrentsArr.row:=1;
	tblMaxCurrentsArr.accessMode:=tblMaxCurrentsArr.AccessMode_Column;
	tblMaxCurrentsArr.column:=1;
	tblMaxCurrentsArr.inputType:=tblMaxCurrentsArr.InputType_None;	
	tblMaxCurrentsArr.column:=2;
	tblMaxCurrentsArr.inputType:=tblMaxCurrentsArr.InputType_None;
	tblMaxCurrentsArr.alignment:=tblMaxCurrentsArr.Alignment_Right;
	tblMaxCurrentsArr.column:=3;
	tblMaxCurrentsArr.inputType:=tblMaxCurrentsArr.InputType_None;
	tblMaxCurrentsArr.alignment:=tblMaxCurrentsArr.Alignment_Center;


	// Set dimensions table headings
	tblMaxCurrentsArr.column:=1;
	tblMaxCurrentsArr.row:=1;
	tblMaxCurrentsArr.text:="Direction and Tide Type";
	tblMaxCurrentsArr.column:=2;
	tblMaxCurrentsArr.text:="Max current";
	tblMaxCurrentsArr.column:=3;
	tblMaxCurrentsArr.text:="Unit";


	// Set enteries in "Titles" column
	tblMaxCurrentsArr.column:=1;
	tblMaxCurrentsArr.row:=2;
	tblMaxCurrentsArr.text:="Arrival, maximum flood tide:";
	tblMaxCurrentsArr.row:=3;
	tblMaxCurrentsArr.text:="Arrival, maximum ebb tide:";
	tblMaxCurrentsArr.row:=4;
	tblMaxCurrentsArr.text:="Departure, maximum flood tide:";
	tblMaxCurrentsArr.row:=5;
	tblMaxCurrentsArr.text:="Departure, maximum ebb tide:";


	// Set entries in "Values" column
	tblMaxCurrentsArr.column:=2;
	if cbxTidalClassArrv.listIndex&gt;0 then
		if cbxTidalClassArrv.itemObject[cbxTidalClassArrv.listIndex]&lt;&gt;null then
			tidalClass:=cbxTidalClassArrv.itemObject[cbxTidalClassArrv.listIndex].HMS_TidalClass;
			count:=1;
			while count&lt;=4 do
				tblMaxCurrentsArr.row:=count+1;
				tblMaxCurrentsArr.text:=tidalClass.allMaximumCurrents[count].String;
				count:=count+1;
			endwhile;
		endif;
	endif;



	// Set entries in "Units" column
	tblMaxCurrentsArr.column:=3;
	tblMaxCurrentsArr.row:=2;
	tblMaxCurrentsArr.text:="knots";
	tblMaxCurrentsArr.row:=3;
	tblMaxCurrentsArr.text:="knots";
	tblMaxCurrentsArr.row:=4;
	tblMaxCurrentsArr.text:="knots";
	tblMaxCurrentsArr.row:=5;
	tblMaxCurrentsArr.text:="knots";

	// ----------------------------------------------------------------------

	// Departure Tidal Classes Setup
	// Modified by Russell 26/03/99
	// ----------------------------------------------------------------------
	// Set column widths
	tblMaxCurrentsDep.columnWidth[1]:=205;
	tblMaxCurrentsDep.columnWidth[2]:=65;
	tblMaxCurrentsDep.columnWidth[3]:=40;


	// Set number of rows
	tblMaxCurrentsDep.rows:=5;

	// Make table readOnly
	tblMaxCurrentsDep.readOnly:=true;

	// Set table input modes
	tblMaxCurrentsDep.row:=1;
	tblMaxCurrentsDep.accessMode:=tblMaxCurrentsDep.AccessMode_Column;
	tblMaxCurrentsDep.column:=1;
	tblMaxCurrentsDep.inputType:=tblMaxCurrentsDep.InputType_None;	
	tblMaxCurrentsDep.column:=2;
	tblMaxCurrentsDep.inputType:=tblMaxCurrentsDep.InputType_None;
	tblMaxCurrentsDep.alignment:=tblMaxCurrentsDep.Alignment_Right;
	tblMaxCurrentsDep.column:=3;
	tblMaxCurrentsDep.inputType:=tblMaxCurrentsDep.InputType_None;
	tblMaxCurrentsDep.alignment:=tblMaxCurrentsDep.Alignment_Center;


	// Set dimensions table headings
	tblMaxCurrentsDep.column:=1;
	tblMaxCurrentsDep.row:=1;
	tblMaxCurrentsDep.text:="Direction and Tide Type";
	tblMaxCurrentsDep.column:=2;
	tblMaxCurrentsDep.text:="Max current";
	tblMaxCurrentsDep.column:=3;
	tblMaxCurrentsDep.text:="Unit";


	// Set enteries in "Titles" column
	tblMaxCurrentsDep.column:=1;
	tblMaxCurrentsDep.row:=2;
	tblMaxCurrentsDep.text:="Arrival, maximum flood tide:";
	tblMaxCurrentsDep.row:=3;
	tblMaxCurrentsDep.text:="Arrival, maximum ebb tide:";
	tblMaxCurrentsDep.row:=4;
	tblMaxCurrentsDep.text:="Departure, maximum flood tide:";
	tblMaxCurrentsDep.row:=5;
	tblMaxCurrentsDep.text:="Departure, maximum ebb tide:";


	// Set entries in "Values" column
	tblMaxCurrentsDep.column:=2;
	if cbxTidalClassDept.listIndex&gt;0 then
		if cbxTidalClassDept.itemObject[cbxTidalClassDept.listIndex]&lt;&gt;null then
			tidalClassDept:=cbxTidalClassDept.itemObject[cbxTidalClassDept.listIndex].HMS_TidalClass;
			count:=1;
			while count&lt;=4 do
				tblMaxCurrentsDep.row:=count+1;
				tblMaxCurrentsDep.text:=tidalClassDept.allMaximumCurrents[count].String;
				count:=count+1;
			endwhile;
		endif;
	endif;



	// Set entries in "Units" column
	tblMaxCurrentsDep.column:=3;
	tblMaxCurrentsDep.row:=2;
	tblMaxCurrentsDep.text:="knots";
	tblMaxCurrentsDep.row:=3;
	tblMaxCurrentsDep.text:="knots";
	tblMaxCurrentsDep.row:=4;
	tblMaxCurrentsDep.text:="knots";
	tblMaxCurrentsDep.row:=5;
	tblMaxCurrentsDep.text:="knots";

	// ----------------------------------------------------------------------


end;</source>
    </JadeMethod>
    <JadeMethod name="lstResourceType_displayRow" id="0a05c6e2-3b61-49c2-b725-bcfdd3943100">
        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstResourceType_displayRow(table: Table input; theSheet: Integer; obj: HMS_ResourceType; theRow: Integer; bcontinue: Boolean io):String updating;
//--------------------------------------------------
// Created:	08 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	selected		: Boolean;
begin

	selected := self.lstResourceType.allSelectedObjects.includes(obj);

	if selected then
		return TableCheckBox_Selected  &amp; Tab &amp; obj.description;
	else
		return  TableCheckBox_NotSelected &amp; Tab &amp; obj.description;
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="HMS_ResourceType"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
