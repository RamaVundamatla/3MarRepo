    <JadeMethod name="addSlotRequestItem" id="5357fc81-f0bd-41cf-979d-ec476840a8a3">
        <updating/>
        <source>addSlotRequestItem(sr : CM_SlotRequest) updating;

vars
	fortyFooter	:	Boolean;
	isEmpty : Boolean; //cnwas3 PAR 24273
begin
	numCCThisKey := numCCThisKey + 1;
	//----------------
	//Add the slotRequest's totals in first
	//----------------
	fortyFooter := sr.getAttrIs40();
	isEmpty := sr.getAttrEmpty();//cnwas3 PAR 24273
	if sr.isRehandle then
		//----------------
		//Is a DLR..
		//----------------
		if fortyFooter then
// PAR7496 AKB2004FEB				if sr.reefer then
// PAR7496 AKB2004FEB					numCC40DLRReefer := numCC40DLRReefer +1;
// PAR7496 AKB2004FEB				else
				numCC40DLRGenl := numCC40DLRGenl +1;
// PAR7496 AKB2004FEB				endif;
		else
// PAR7496 AKB2004FEB				if sr.reefer then
// PAR7496 AKB2004FEB					numCC20DLRReefer := numCC20DLRReefer +1;
// PAR7496 AKB2004FEB				else
				numCC20DLRGenl := numCC20DLRGenl +1;
// PAR7496 AKB2004FEB				endif;
		endif;

	elseif sr.moveType = LOAD_MOVETYPE then
		if fortyFooter then
			if isEmpty then		//cnwas3 PAR 24273
				numCC40Empty := numCC40Empty +1;
			else
				//PAR 3726 AJA 30/10/00: Power means that it is integral
				//isIntegralType method was not returning integrals
				if sr.getAttrPowerRequired() then //isIntegralType() then
					numCC40Integral := numCC40Integral +1;
// PAR7496 AKB2004FEB					elseif sr.reefer then
// PAR7496 AKB2004FEB						numCC40Reefer := numCC40Reefer +1;
				else
					numCC40Genl := numCC40Genl + 1;
				endif;
			endif;
	    else
	    	//Is 20'
			if isEmpty then		//cnwas3 PAR 24273
				numCC20Empty := numCC20Empty +1;
			else
				if sr.getAttrPowerRequired() then //isIntegralType() then
					numCC20Integral := numCC20Integral +1;
// PAR7496 AKB2004FEB					elseif sr.reefer then
// PAR7496 AKB2004FEB						numCC20Reefer := numCC20Reefer +1;
				else
					numCC20Genl := numCC20Genl +1;
				endif;
			endif;	    
		endif; 
	endif;

end;</source>
        <Parameter name="sr" type="CM_SlotRequest"/>
    </JadeMethod>
    <JadeMethod name="addTrackedItem" id="2804fc39-381d-4bbb-a240-235d65e712a5">
        <updating/>
        <source>addTrackedItem(pTI : CM_TrackedItem) updating;

vars
	tmpContainer	: CM_Container;
	fortyFooter 	: Boolean;
	empty 			: Boolean;
	isInteg			:	Boolean;
begin
	//-----------------
	//If I am a child of a container (like an attachedCOU) then quit
	//-----------------
	numThisKey := numThisKey +1;
	if pTI.isChild then
		return;
	endif;
	if pTI.isSOB then
		return;
	endif;
	
	if (not pTI.isKindOf(CM_Container)) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Call for non-container - need to check if correct');
		return;
	endif;
	
	tmpContainer := pTI.CM_Container;
	
	// Save this so we can determine the ti type (Crib etc)
	self.tiTypeAttributes := tmpContainer.typeAttributes;
	// Determine if empty
	empty := (tmpContainer.contentsStatus = TI_CONTENTS_STATUS_EMPTY);
	fortyFooter := tmpContainer.is40;
	isInteg := tmpContainer.isIntegral();
	//-----------------
	//First up, is the box a DLR?
	//-----------------
	if tmpContainer.isRehandle then
		if (tmpContainer.typeAttributes.bitAnd(ISO_REEFER) &gt; 0) then 
			if tmpContainer.requiresTemperature then
				if fortyFooter then
					num40DLRReefer := num40DLRReefer + 1;
				else
					num20DLRReefer := num20DLRReefer + 1;
				endif;
			else
				//Genl in a reefer box
				if fortyFooter then
					num40DLRGenl := num40DLRGenl + 1;
				else
					num20DLRGenl := num20DLRGenl + 1;
				endif;
			endif;
		else
			if fortyFooter then
				num40DLRGenl := num40DLRGenl + 1;
			else
				num20DLRGenl := num20DLRGenl + 1;
			endif;
		endif;
		return;
	endif;

	if empty then
		if fortyFooter then
			num40Empty := num40Empty + 1;
		else
			num20Empty := num20Empty + 1;
		endif;
		return;
	endif;
	//--------------------
	//NOT MT.
	//--------------------
	if ((tmpContainer.typeAttributes.bitAnd(ISO_REEFER) &gt; 0) or 
		(tmpContainer.typeAttributes.bitAnd(ISO_PORTHOLE) &gt; 0)) then
		//These are REEFERS!!
		if tmpContainer.requiresTemperature then
			if tmpContainer.isIntegral then
				if fortyFooter then
					num40Integral := num40Integral + 1;
				else
					num20Integral := num20Integral + 1;
				endif;
			else
				if fortyFooter then
					num40Reefer := num40Reefer + 1;
				else
					num20Reefer := num20Reefer + 1;
				endif;
			endif;
		else
			//Hmm, reefer boxes without commodities requiring temperature
			if fortyFooter then
				num40Genl := num40Genl + 1;
			else
				num20Genl := num20Genl + 1;
			endif;
		endif;
		return;
	endif;
	//----------------
	//These are GENERALS!!
	//----------------
	if fortyFooter then
		num40Genl := num40Genl + 1;
	else
		num20Genl := num20Genl + 1;
	endif;
end;</source>
        <Parameter name="pTI" type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
