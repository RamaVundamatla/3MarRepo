    <JadeMethod name="lostFocus" id="24ea853a-4755-4353-86ec-734fd5160b72">
        <controlMethod name="CMUI_DateMask::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>lostFocus(editMask: JadeEditMask input) updating, clientExecution;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27 May 2025	navdap1		Initial creation MTN-34981 MTN -Yard Allocations - Storing Cargo Based on a Date Range
//
vars

begin
	inheritMethod(editMask);
	
	self.parent.CMUI_YACriteriaCntl.doCriteriaChanged();
epilog

end;</source>
        <Parameter name="editMask" type="JadeEditMask" usage="input"/>
