        <updating/>
        <source>tblMain_click(table: CM_EntryTable input) updating;
//--------------------------------------------------------------
//Created: 18 February 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpRow : Integer;
begin
	tmpRow := table.getRow(ETRow_ReleaseByType);
	if tmpRow = table.row then
		self.setReleaseFields();
		self.resize();	//fix splitter problem 
	endif;
	
end;</source>
