<Class name="CM_QFlatRackStatusProperty" id="7457e829-98f9-4124-ba44-ed9db5d471cf">
    <superclass name="CM_QIntegerLookupProperty"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="f73433c1-6476-40ee-b4c5-c47545c971b5">
        <updating/>
        <source>create() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/11/2019	jlgdap1		Initial creation TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
//
vars
	oper : CM_QueryOperator;

begin
	if self.isTransient then 
		return;
	endif;
		
	create oper as CM_QIntegerLookupEqual persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QIntegerLookupNotEqual persistent;
	self.allAllowedOperators.add(oper);
epilog

end;</source>
    </JadeMethod>
