    <JadeMethod name="doCancelReportQueueEntry" id="1773b98b-3bd5-4e17-817a-cb7c2f580dc8">
        <updating/>
        <source>doCancelReportQueueEntry(pTable:Table input) updating, protected;

vars
	theQueueEntry	: CnEcReportQueueEntry;
	tableRow		: JadeTableRow;

begin
	if pTable.cnEcIsRowSelected(pTable.row) then
		tableRow		:=	pTable.accessRow(pTable.row);
		theQueueEntry	:=	tableRow.itemObject.CnEcReportQueueEntry;
		
		self.aMyTA.trxReportQueueEntrySetStatus(theQueueEntry, 0, CNEC_REPORT_CANCELLED, null);
	endif;

	self.doEnableButtons();
end;</source>
        <access>protected</access>
        <Parameter name="pTable" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doEnableButtons" id="aeb3da59-2c30-43ed-bf81-8fd6be84a45f">
        <updating/>
        <source>doEnableButtons() updating, protected;

vars
	theQueueEntry	: CnEcReportQueueEntry;
	tableRow		: JadeTableRow;

begin
	if tblQueueR.cnEcIsRowSelected(tblQueueR.row) then
		tableRow		:=	tblQueueR.accessRow(tblQueueR.row);
		theQueueEntry	:=	tableRow.itemObject.CnEcReportQueueEntry;

		if theQueueEntry &lt;&gt; null and app.isValidObject(theQueueEntry) then
			btnPauseR.enabled	:=	(theQueueEntry.printStatus = CNEC_REPORT_PENDING) or (theQueueEntry.printStatus = CNEC_REPORT_PRINTING);
			btnRestartR.enabled	:=	(theQueueEntry.printStatus = CNEC_REPORT_PAUSED);
		endif;

		btnCancelR.enabled	:=	(theQueueEntry.printStatus &lt;&gt; CNEC_REPORT_CANCELLED);
	else
		btnPauseR.enabled	:=	false;
		btnRestartR.enabled	:=	false;
		btnCancelR.enabled	:=	false;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="5259c7d6-9cfa-4653-b1b1-096215fbc7fa">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		01 August 2000 by cnwdad1
//
// Purpose:		Standard form load method.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	categoryIterator	: Iterator;
	reportIterator		: Iterator;
	isAdmin				: Boolean;
	theCategory			: CnEcReportCategory;
	theReport			: CnEcReportDefinition;

begin
	inheritMethod();

	if self.isKindOf(global.cnEcGetReportModuleForm(CnEcReportQueueListForm)) then
		isAdmin	:=	true;
	else
		isAdmin	:=	false;
	endif;

	cmbCategory.listCollection(app.myBaseRoot.allReportCategories, true, 0);
	
	self.setTableProperties(tblQueueR, 5);
	self.doSetupListReportQueue();
	
	beginClassNotification(CnEcReportQueueEntry, false, Object_Update_Event, Response_Continuous, 0);
epilog
	delete categoryIterator;
	delete reportIterator;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoadReports" id="556574e5-778f-427b-9e22-a94ecf88ab19">
        <updating/>
        <source>doLoadReports() updating, protected;

vars
	theCategory		: CnEcReportCategory;

begin
	cmbReport.clear;

	if chkShowAllReport.value then
		cmbReport.listCollection(app.myBaseRoot.allReportDefinitions, true, 0);
		cmbCategory.listIndex	:=	CNEC_NULL_INDEX;
		cmbCategory.enabled		:=	false;
	else
		theCategory	:=	cmbCategory.listObject.CnEcReportCategory;

		if theCategory &lt;&gt; null then
			cmbReport.listCollection(theCategory.allReportDefinitions, true, 0);
		endif;
		
		cmbCategory.enabled	:=	true;
	endif;
	
	self.doSetupListReportQueue();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSetupListReportQueue" id="07284442-ac37-498f-ab07-f7a1ad34852b">
        <updating/>
        <source>doSetupListReportQueue() updating, protected;
// --------------------------------------------------------------------------------
// Created:		09 August 2000 by cnwdad1
//
// Purpose:		Populates the report queue table.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On Changed By Reason
// ---------- ---------- ----------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theReportDefinition	: CnEcReportDefinition;
	
begin
	tblQueueR.clear;
	tblQueueR.setCellText(1, 1, TABLE_HEADER_REPORT);
	theReportDefinition	:=	cmbReport.listObject.CnEcReportDefinition;
	
	if theReportDefinition &lt;&gt; null then
		tblQueueR.displayCollection(theReportDefinition.allReportQueueEntries, true, 0, null);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
