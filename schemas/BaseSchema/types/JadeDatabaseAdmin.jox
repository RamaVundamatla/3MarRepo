<Class name="JadeDatabaseAdmin">
    <JadeMethod name="cnEcBackupAllLogFiles" id="29490c57-f12d-45d2-be94-86d6a58a13f1">
        <source>cnEcBackupAllLogFiles(	pSourceDirectory:String;
						pBackupDirectory:String;
						pIsVerify:Boolean;
						pIsCompress:Boolean;
						pIsOverwriteExisting:Boolean);
// --------------------------------------------------------------------------------
// Created:		19 July 2001 by cnwdad1
//
// Purpose:		Backs up the JADE audit log files.
//
// Parameters:	pSourceDirectory - The directory containing the JADE audit log files.
//				pBackupDirectory - The directory to copy the audit log files to.
//				pIsVerify - If true, each log will be verified as it is backed up.
//				pIsCompress - if true, each log will be compressed as it is backed up.
//				pIsOverwriteExisting - If true, existing log files in the backup
//					directory will be overwritten.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	LOG_FILE_PREFIX	: String = "db";
	LOG_FILE_SUFFIX	: String = ".log";
	LOG_NAME_LENGTH	: Integer = 6;

vars
	logFileObj	: File;
	logFileName	: String;
	currentLog	: Integer;
	logIndex	: Integer;
	
begin
	currentLog	:=	self.getCurrentLogNumber;
	self.closeCurrentJournal;		// Switch to a new log file to release the current one.
	
	foreach logIndex in currentLog to 1 step -1 do
		self.backupLog(logIndex, pSourceDirectory, pBackupDirectory, pIsVerify, pIsCompress, pIsOverwriteExisting);
	endforeach;
end;</source>
        <Parameter name="pSourceDirectory" type="String"/>
        <Parameter name="pBackupDirectory" type="String"/>
        <Parameter name="pIsVerify" type="Boolean"/>
        <Parameter name="pIsCompress" type="Boolean"/>
        <Parameter name="pIsOverwriteExisting" type="Boolean"/>
    </JadeMethod>
</Class>
