    <JadeMethod name="initializeODBCServer" id="f8a43933-348e-4d12-aead-9041c17ac2f0">
        <updating/>
        <source>initializeODBCServer(_initializeParam : Object) updating;
/*
Purpose:			Initialize the ODBC server application for SQL queries

Parameters:			

Return Value:		

Date		Who		Reason
01/11/2012	cnwdap1	Initial creation PAR #30668 SQL interface for APM Terminals
*/
vars
	root	: CM_Root;

begin
	app.odbcWorkerInitialize();
	app.initialize();
	
	// Ensure no pass back to JADE exception handler
	app.setPassBackExceptions(false, false);
	
	// Needs to be a background app so no lock dialogs are shown
	app.setIsBackGroundApp(true);
	
	// Check application licensing
	root := self.myRoot;
//	if root = null or not root.canDo(PmODBCModule) then
	if root = null or not root.canDo(Mod_DataExtract) then	//07 Oct 2019	NDL	TFS 46169
		app.writeLog('Application is not licensed to run ODBC application - terminating', LogFATAL);	//26 Nov 2019	NDL	TFS 47053
		terminate;
	endif;
epilog

end;</source>
        <Parameter name="_initializeParam" type="Object"/>
    </JadeMethod>
    <JadeMethod name="initializeOdbcSelect" id="f899e2d5-c79b-40a9-8deb-459d32931e5c">
        <source>initializeOdbcSelect(rv: RelationalView; username: String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Nov 2012	cnwkpd1	PAR #30668 - CCMS APM 2208 - ODBC access to HMS data

*/

vars
	user			: CM_User;
	
begin
	inheritMethod(rv, username);

	app.writeLog(method.qualifiedName() &amp; " username = " &amp; username, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	
	user := app.myRoot.allUsers[username.toUpper];
	if user = null then
		// BAD
		app.writeLog(method.qualifiedName() &amp; " invalid username = " &amp; username, LogERROR);	//25 Nov 2019	NDL	TFS 47053
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, "invalid username", null, null);
		return;
	endif;
	
	app.myPassport.initialiseTransaction();
	app.myPassport.setMyUser(user);
	
	app.writeLog(method.qualifiedName() &amp; " passport initialized with username = " &amp; username, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053

epilog

end;</source>
        <Parameter name="rv" type="RelationalView"/>
        <Parameter name="username" type="String"/>
    </JadeMethod>
    <JadeMethod name="installScript" id="caf5db8f-1b79-405c-a94d-3068249c822a">
        <source>installScript();
//
// Called from application JadeScript
// DO NOT CHANGE THIS METHOD - make changes to jadeScript::appInstallScript
//
vars
	portSchemaRelease: PortSchema_7_3_3;//PortSchemaRelease;
	str: String;
	js: JadeScript;
	ti: CM_TrackedItem;
	objArray: ObjectArray;
	userTerminal: CM_UserTerminal;
	obj: Object;
	menuAgent: CM_MenuAgent;
	userExitCode: Integer;
	file : File; //add application file for Jari
	fileMessage : String;
begin
	userExitCode := 63;
	app.initialize();
	create file transient;
	file.mode := File.Mode_Output;	// 4/3/16 cnwmp6 PAR 36286 unicode version
	file.fileName := app.myCnCntrl.logPath&amp;"\app_upgrade.log";
	if file.isAvailable then
		file.purge;
	endif;
	fileMessage := "UpgradeError";
	create js transient;
	///////////////////////////////////////
//	cnwjr2  -  commented out next line as it called a JadeScript method - these methods were deleted 12/12/2011 - temporarily in DummySchema

//	js.appInstallScript();

	///////////////////////////////////////
	userExitCode := 0;	
	fileMessage := "completedOK";
	file.writeLine(fileMessage);
epilog
	file.close;
	delete file;
	delete js;
//	delete menuAgent;
	beginTransaction;
	node.userExitCode := userExitCode;
	commitTransaction;
	app.finalize;
	terminate;
end;</source>
    </JadeMethod>
    <JadeMethod name="installScriptPrevious" id="9b8f41e3-0fa4-4cf5-abd3-ac576b0acc10">
        <source>installScriptPrevious();
// 17/03/2015	cnwmh5	Transient Leak
vars
	portSchemaRelease:PortSchemaRelease;
	str:String;
	js:JadeScript;
	ti:CM_TrackedItem;
	objArray:ObjectArray;
	userTerminal		: CM_UserTerminal;
	obj					: Object;
	file: File;
	fileFolder: FileFolder;
begin
	
	create file transient;
	file.mode := File.Mode_Output;	// 4/3/16 cnwmp6 PAR 36286 unicode version
	file.fileName := app.dbPath&amp;"\..\completed.txt";
	if file.isAvailable then
		file.purge;
	endif;
	file.close;
	delete file;

	app.initialize();
	//app.isConverting := true;
	create objArray transient;
	PortSchemaRelease.allInstances(objArray,0,true);	
	//Stuff to do every release
	///////////////////////////////////////
	portSchemaRelease := objArray[1].PortSchemaRelease;
		 // RBarr 1/9/2006 Superceded (localisation changes)
//	app.myRoot.loadErrMsgsFromGlbConstantsOLD();
	app.myRoot.createQueryDefinitionObjects();
	portSchemaRelease.sendMsg(PortSchemaRelease::loadEntTableDetails.name);
	//th2 - changed to one method on app
	app.sendMsg(PortSchema::loadIcons.name);
// rs 24/11/2003 this fails in unlicensed schemas so cant be done in the conversion
//	portSchemaRelease.sendMsg("resetRootSecurityRoles");

	portSchemaRelease.sendMsg(PortSchemaRelease::resetAllJMTMenus.name);
	portSchemaRelease.sendMsg(PortSchemaRelease::resetCargoTypes.name);
	portSchemaRelease.sendMsg(PortSchemaRelease::resetHandlingTypes.name);
	portSchemaRelease.sendMsg(PortSchemaRelease::resetAuditedClassProperties.name);

//	app.isConverting := true;

	create js transient;
	///////////////////////////////////////
	//Specific for this release. Date:
//	js.runConvertToNewStructure; //720 Beta5e only rs 31/10/2003
//	js.fixupSecurityRoleTerminals; //720 Beta 5c only rs 15/10/2003 par 6261
//	js.updateRestrictionsNewStops; //720 Beta 5c only jc 16/10/2003 
	
	
//	js.fixTemperatureConversion; //720 Beta5b rs 07/10/2003

/*	js.convertTILocation;	//720 Beta 5only by DWQ
	js.convertEDITIs;		//720 Beta 5only by JC 08/09/2003
	js.fixEDIDatas;			//720 Beta 5only by JC 11/09/2003
	js.convertBlockStacks;	//720 Beta 5only rs/gd 08/09/2003
	js.fixEmail();			//720 Beta 5only by DVB 24/09/03
	js.initializeBGP();		//720 Beta 5only by DVB 24/09/03 Default BGP set up.
	js.resetAllSelectorColumns(); //720 Beta 5 only by CNWTH2A 25/09/03
	js.setSpecialToolBarPictures(); //720 Beta 5 only sh3
*/	

	//Stuff to do every release
	///////////////////////////////////////
	
	app.writeStatement( "end installScript");	
	create fileFolder transient;
	fileFolder.fileName := app.dbPath;
	if fileFolder.isAvailable then
		create file transient;
		file.mode := File.Mode_Output;
		file.fileName := app.dbPath &amp; "\..\completed.txt";
		file.open;
		file.writeLine("Completed");
		file.close;
		delete file;
	endif;
	delete fileFolder;
	
	///////////////////////////////////////
epilog
	delete js;
	delete objArray;		// PAR #27874
	if fileFolder &lt;&gt; null then
		delete fileFolder;
	endif;
//	delete theForm;
	terminate;
end;</source>
    </JadeMethod>
    <JadeMethod name="instrumentFormUsage" id="669c5756-06e8-4651-b46f-cafd26d1e0bd">
        <source>instrumentFormUsage( _form : Form );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 February 2014	cnwndl1	Initial creation	Par 33587

*/

vars

begin

	cnStartTransaction('Form ' &amp;  _form.class.name );
	cnEndTransaction();

epilog

end;</source>
