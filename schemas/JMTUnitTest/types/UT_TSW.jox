    <JadeMethod name="iTSWDTRNZCSClearances" id="fca89ef9-4973-471f-b33b-6956003e3c15">
        <source>iTSWDTRNZCSClearances();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
11 October 2023	navpw1	Initial creation TFS: 60682 (60752)

*/

constants
	TSW_NAME_CODE_807				: String	= '807';
	BLOCKSTACK						: String	= 'B60682';
	MASTERBOL						: String	= "PMWLQ6952";		// Master BOL
	HOUSEBOL						: String	= "TLL014121";		// House BOL
	TSW_VESSEL_CODE					: String	= 'UTTSW60682';
	TSW_VOYAGE_CODE					: String	= 'UT_TSW_60682';
	OPERATOR						: String	= 'UTOP';
	USER_DEF_NAME					: String	= 'TSW';
	
	TSW_CONTAINER_1					: String	= "60682-1";
	TSW_CONTAINER_2					: String	= "60682-2";
	TSW_CONTAINER_3					: String	= "60682-3";
	TSW_CONTAINER_4					: String	= "60682-4";
	TSW_CONTAINER_5					: String	= "60682-5";
	TSW_CONTAINER_6					: String	= "60682-6";
	TSW_BOL							: String	= "BOL120N28100-1";
	
	TSW_STOP_CODE_CIDO				: String	= "TSWGC";
	TSW_STOP_ID_CIDO				: Integer	= 879;
	TSW_STOP_HEADING_CIDO			: String	= "TSW CIDO Underbond";
	TSW_CUSTOMS_ACTION_NAME_CIDO	: String	= "TSW CIDO Underbond";
	TSW_CUSTOMS_ACTION_KEYWORD_CIDO	: String	= TSW_NAME_CODE_807;
	
vars
	blockStack						: CM_BlockStack;
	pxyStopsTableCIDOU,
	realStopsTableCIDOU,
	stopsTableGC					: CM_StopsTable;
	vessel							: CM_Vessel;
	voyage							: CM_Voyage;
	operator						: CM_Operator;
	ti								: CM_TrackedItem;
	ediText, tempStr				: String;
	ediFile							: CM_EDIFile;
	ediTI							: CM_EDITrackedItem;
	ediStop							: CM_EDICustomStopTI;
	found1							: Boolean;
	pxyCustomsActionCIDOU,
	realCustomsActionCIDOU			: CM_EDIAction;
	
	pxyStopsTableTemplateCIDOU		: CM_StopTableTemplate;
	intArray						: IntegerArray;
	setArray						: IntegerArray;
	noImportStops,
	completedOk						: Boolean;
	
	tiTransaction					: CM_TITransaction;
	
begin
	noImportStops := self.getTerminalConfig(NoImportStops).Boolean;
	self.setTerminalConfig(NoImportStops, true);
	self.assertTrueMsg(self.getTerminalConfig(NoImportStops).Boolean, "Terminal Config -&gt; Settings Tab -&gt; 'No Import Stops' should be set to true");
	
	// get rid of stuff - block stack, bols, voyage, vessel
	self.deleteTerminalArea(BLOCKSTACK);
	self.deleteVoyage(TSW_VOYAGE_CODE);
	self.deleteVessel(TSW_VESSEL_CODE);
	
	// setup stuff 
	blockStack := self.addBlockStack(BLOCKSTACK, 10, null);
	
	//Get Operator
	operator := self.getOperator(OPERATOR);
	self.assertNotNull(operator);
	
	vessel := self.addVesselGeneralCargo(TSW_VESSEL_CODE, operator, 5);
	self.assertNotNull(vessel);
	
	voyage := self.addVoyageWithGeneralCargoStruc(TSW_VOYAGE_CODE, TSW_VESSEL_CODE, OPERATOR, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 2);
	self.assertNotNull(voyage);
	
	//Delete TSW CIDO STOP
	stopsTableGC := self.getRoot.getStopTableForId(TSW_STOP_ID_CIDO);
	if stopsTableGC &lt;&gt; null then
		self.deleteStopsTable(TSW_STOP_ID_CIDO);
		self.assertIsDeletedMsg(stopsTableGC, "stopsTableGC");
	endif;
	
	//Get Stops Table MAF
	//stopsTableMAF := self.getRoot.getStopTableForId(TI_Stop_MAF);
	
	//Create TSW CIDO STOP
	create pxyStopsTableCIDOU transient;
	pxyStopsTableCIDOU.setProxy(false, TSW_STOP_CODE_CIDO, TSW_STOP_HEADING_CIDO, TSW_STOP_CODE_CIDO, null, TSW_STOP_ID_CIDO, null, false, false, app.myRoot, null, app.myPassport.myUser.code, null);
	
	create pxyStopsTableTemplateCIDOU transient;
	pxyStopsTableTemplateCIDOU.setKeys(app.getMyTerminalDO_NOT_USE, pxyStopsTableCIDOU);
	
	delete intArray;
	delete setArray;
	
	create intArray transient;
	create setArray transient;
	setArray.add(StopApplyExport);
	
	pxyStopsTableTemplateCIDOU.setProxy(intArray,
									setArray,
									intArray,
									null,									// Hold Voyages
									false,
									false,
									false,
									false,
									false,
									false,
									false,
									true);
	
	app.myTrxCA.trxCreateStopsTable(pxyStopsTableCIDOU, realStopsTableCIDOU, app.myPassport);
	self.assertNotNullMsg(realStopsTableCIDOU, "realStopsTableCIDOU");
	
	//Delete Customs Action GC
	realCustomsActionCIDOU := app.myRoot.allEDIActions[TSW_CUSTOMS_ACTION_NAME_CIDO];
	if realCustomsActionCIDOU &lt;&gt; null then
		self.deleteEDIAction(TSW_CUSTOMS_ACTION_NAME_CIDO, null, EDIKeyField_Clearance);
		self.assertIsDeleted(realCustomsActionCIDOU);
	endif;
	
	realCustomsActionCIDOU := null;
	
	//Create Customs Action GC
	create pxyCustomsActionCIDOU transient;
	pxyCustomsActionCIDOU.setProxy(TSW_CUSTOMS_ACTION_NAME_CIDO, TSW_CUSTOMS_ACTION_KEYWORD_CIDO, EDIKeyField_Clearance, EDIAction_Remove, realStopsTableCIDOU, CM_EDIFileTypeXMLJMTInternal.firstInstance, null, null, null, null);
	app.myTrxCA.trxCreateEDIAction(pxyCustomsActionCIDOU, realCustomsActionCIDOU, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realCustomsActionCIDOU, "realCustomsActionCIDOU");
	
	/*
	**	Test 1 Start - Test Role Code that is TT. Should add the TSW TT HOLD stop with stopId as 874
	*/
	
	/*
	** Setup
	*/
	// create cargo - two containers
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_TotalWeight, 2000.Decimal);
	self.opts.addAssoc(UT_OPTS_DestinationPort, "NZAKL");
	ti := self.addContainerOnShip(TSW_CONTAINER_1, operator, "22G1", "GENL", null, voyage, null, TSW_VOYAGE_CODE);
	
	//Move contaienr on site
	self.move(ti, blockStack);
	
	// assign house bol number and voyage
	beginTransaction;
	ti.setPropertyValue(CM_TrackedItem::houseBillOfLading.name, TSW_BOL);
	ti.setMyVoyage(voyage, app.myPassport);
	commitTransaction;
	
	self.assertEqualMsg(voyage.allTisByHouseBol.size, 1, "Test 1 - Voyage has incorrect number of House BOL TIs");
	
	// edi text - one master BOL (which JMT ignores) and 1 house BOl (but 2 house BOL segments with the same BOL number)
	ediText := self.zTSWFile(TSW_VESSEL_CODE, TSW_VOYAGE_CODE, TSW_CONTAINER_1, CM_EDIAction.RoleCode_TT, TSW_NAME_CODE_807, TSW_BOL, null, null);
	
	/*
	** Run
	*/
	ediFile := self.ediLoadFileName(ediText, EDIFileType_XML, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);
	self.assertNotNull(ediFile);
	
	// should be 1 edi tracked item
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.size, 1, "Test 1 - EDI Data has incorrect number of EDI tracked items");
	
	// Both EDI tracked items should have pack count of 1 (pack count is set to 1 by the plugin for container cargo)
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		ediStop := ediTI.CM_EDICustomStopTI;
		if ediStop.billOfLading = TSW_BOL then
			found1 := true;
			self.assertEqualMsg(ediStop.packCount, 1, "Test 1 - BOL 1 has incorrect pack count");
		endif;
	endforeach;
	self.assertTrueMsg(found1, "Test 1 - BOL 1 not found");
	
	self.ediVerify(ediFile);
	tempStr	:= 'Test 1 - Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	//return;
	self.ediDBLoad(ediFile);
	tempStr	:= 'Test 1 - DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	self.assertNoTrxErrorsOrWarnings();
	
	/*
	** Assert
	*/
	// Check the cargo transactions for an add stop and remove stop transaction
	
	foreach tiTransaction in ti.allTransactions do
		//tiTransaction.inspect;
	endforeach;
	
	tempStr	:= 'Test 1 - Stop ' &amp; TSW_STOP_ID_CIDO.display &amp; Space &amp; realStopsTableCIDOU.heading.display &amp; ' does not exist for cargo ' &amp; ti.id;
	self.assertEqualMsg(ti.isStopSet(TSW_STOP_ID_CIDO), true, tempStr);
	return;
	/*
	** Cleanup
	*/
	
	/*
	**	Test 1 End - Test Role Code that is TT. Should add the TSW TT HOLD stop with stopId as 874
	*/
	
	/*
	**	Test 2 Start - Test Role Code that is GC. Should not add the TSW TT HOLD stop with stopId as 874
	*/
	
	/*
	** Setup
	*/
	// create cargo - two containers
	ti := self.addContainerAtLocation(TSW_CONTAINER_2, operator, "22G1", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.myLocationsController);
	
	// assign house bol number and voyage
	beginTransaction;
	ti.setPropertyValue(CM_TrackedItem::houseBillOfLading.name, TSW_BOL);
	ti.setMyVoyage(voyage, app.myPassport);
	commitTransaction;
	
	self.assertEqualMsg(voyage.allTisByHouseBol.size, 4, "Test 2 - Voyage has incorrect number of House BOL TIs");
	
	// edi text - one master BOL (which JMT ignores) and 1 house BOl (but 2 house BOL segments with the same BOL number)
	ediText := self.zTSWFile(TSW_VESSEL_CODE, TSW_VOYAGE_CODE, TSW_CONTAINER_2, CM_EDIAction.RoleCode_GC, TSW_NAME_CODE_807, TSW_BOL, null, null);
	
	/*
	** Run
	*/
	ediFile := self.ediLoadFileName(ediText, EDIFileType_XML, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);
	self.assertNotNull(ediFile);
	
	// should be 1 edi tracked item
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.size, 2, "Test 2 - EDI Data has incorrect number of EDI tracked items");
	
	// Both EDI tracked items should have pack count of 1 (pack count is set to 1 by the plugin for container cargo)
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		ediStop := ediTI.CM_EDICustomStopTI;
		if ediStop.billOfLading = TSW_BOL then
			found1 := true;
			self.assertEqualMsg(ediStop.packCount, 1, "Test 2 - BOL 1 has incorrect pack count");
		endif;
	endforeach;
	self.assertTrueMsg(found1, "Test 2 - BOL 1 not found");
	
	self.ediVerify(ediFile);
	tempStr	:= 'Test 2 - Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	//return;
	self.ediDBLoad(ediFile);
	tempStr	:= 'Test 2 - DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	self.assertNoTrxErrorsOrWarnings();
	
	/*
	** Assert
	*/
	// Check the cargo for import stop
	// stop should have been added
	tempStr	:= 'Test 2 - Stop ' &amp; TSW_STOP_ID_CIDO.display &amp; Space &amp; realStopsTableCIDOU.heading.display &amp; ' exists for cargo ' &amp; ti.id &amp; '. It should not';
	self.assertEqualMsg(ti.isStopSet(TSW_STOP_ID_CIDO), false, tempStr);
	
	/*
	** Cleanup
	*/
	
	/*
	**	Test 2 End - Test Role Code that is GC. Should not add the TSW TT HOLD stop with stopId as 874
	*/
	
	/*
	**	Test 3 Start - Test Role Code that is GC. Should remove the TSW TT HOLD stop with stopId as 874
	*/
	
	/*
	** Setup
	*/
	// create cargo - two containers
	ti := self.addContainerAtLocation(TSW_CONTAINER_3, operator, "22G1", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.myLocationsController);
	
	// assign house bol number and voyage
	beginTransaction;
	ti.setPropertyValue(CM_TrackedItem::houseBillOfLading.name, TSW_BOL);
	ti.setMyVoyage(voyage, app.myPassport);
	commitTransaction;
	
	// add an import stop
	self.addStopById(ti, TSW_STOP_ID_CIDO);
	
	// check - cargo should have the TT stop
	tempStr	:= 'Test 3 - Stop ' &amp; TSW_STOP_ID_CIDO.display &amp; Space &amp; realStopsTableCIDOU.heading.display &amp; ' does not exist for cargo ' &amp; ti.id;
	self.assertEqualMsg(ti.isStopSet(TSW_STOP_ID_CIDO), true, tempStr);
	
	self.assertEqualMsg(voyage.allTisByHouseBol.size, 6, "Test 3 - Voyage has incorrect number of House BOL TIs");
	
	// edi text - one master BOL (which JMT ignores) and 1 house BOl (but 2 house BOL segments with the same BOL number)
	ediText := self.zTSWFile(TSW_VESSEL_CODE, TSW_VOYAGE_CODE, TSW_CONTAINER_3, CM_EDIAction.RoleCode_GC, TSW_NAME_CODE_807, TSW_BOL, null, null);
	
	/*
	** Run
	*/
	ediFile := self.ediLoadFileName(ediText, EDIFileType_XML, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);
	self.assertNotNull(ediFile);
	
	// should be 1 edi tracked item
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.size, 2, "Test 3 - EDI Data has incorrect number of EDI tracked items");
	
	// Both EDI tracked items should have pack count of 1 (pack count is set to 1 by the plugin for container cargo)
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		ediStop := ediTI.CM_EDICustomStopTI;
		if ediStop.billOfLading = TSW_BOL then
			found1 := true;
			self.assertEqualMsg(ediStop.packCount, 1, "Test 3 - BOL 1 has incorrect pack count");
		endif;
	endforeach;
	self.assertTrueMsg(found1, "Test 3 - BOL 1 not found");
	
	self.ediVerify(ediFile);
	tempStr	:= 'Test 3 - Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	//return;
	self.ediDBLoad(ediFile);
	tempStr	:= 'Test 3 - DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	self.assertNoTrxErrorsOrWarnings();
	
	/*
	** Assert
	*/
	
	// Check the cargo for import stop
	// stop should have been cleared
	tempStr	:= 'Test 3 - Stop ' &amp; TSW_STOP_ID_CIDO.display &amp; Space &amp; realStopsTableCIDOU.heading.display &amp; ' still exists for cargo ' &amp; ti.id;
	self.assertEqualMsg(ti.isStopSet(TSW_STOP_ID_CIDO), false, tempStr);
	
	/*
	**	Test 3 End - Test Role Code that is TT. Should remove the TSW TT HOLD stop with stopId as 874
	*/
	
	beginTransaction;
	realStopsTableCIDOU.setPropertyValue(CM_StopsTable::isNotAvailableForEntry.name, true);
	commitTransaction;
	
	completedOk := true;
	
epilog
	self.setTerminalConfig(NoImportStops, noImportStops);
	if not completedOk and realStopsTableCIDOU &lt;&gt; null then
		abortTransaction;
		beginTransaction;
		realStopsTableCIDOU.setPropertyValue(CM_StopsTable::isNotAvailableForEntry.name, true);
		commitTransaction;
	endif;
	delete pxyStopsTableCIDOU;
	delete pxyCustomsActionCIDOU;
	delete intArray;
	delete setArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="tMutipleFilesWithSameName" id="d98902ab-88c7-4ab6-a0af-4d9bb40a9275">
        <executionLocation>server</executionLocation>
        <source>tMutipleFilesWithSameName() serverExecution;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/03/2021	navdap1		Initial creation TFS 50809 CPL TSW responses not processing
//
constants
	VoyageName = 'TSWVOY0001';
	ShipName = 'TSWSHIP';
	TestOperator = 'MSK';
	USER_DEF_NAME : String = "JMTInternalCargoOnSite";
	CONTAINER01 : String = "UTTSW654321";
	CONTAINER02 : String = "UTTSW654322";
	CONTAINER03 : String = "UTTSW654323";

vars
	terminal : CM_Terminal;
	file, checkFile : File;
	ff : FileFolder;
	fileNode : FileNode;
	miscDir, ediDir : String;
	fileNameInEDI : String;
	fileName1, fileName2, fileName3,
	fileName4, fileName5, fileName6 : String;
	fileCreatedTS : TimeStamp;
	dateToday : String;
	copyFileName : String;
	args : StringArray;
	errString : String;
	ediDataTypes : IntegerArray;
	task : CM_AutoTaskEDITerminal;
	request : BGP_EdiRequest;
	agent : CM_EDIControllerAgent;
	iter : Iterator;
	ediFile : CM_EDIFile;
	file1Found, file2Found, file3Found,
	file4Found, file5Found, file6Found : Boolean;
	file1Status, file2Status, file3Status,
	file4Status, file5Status, file6Status: Integer;
	fileCopied : Boolean;
	fileCopyTime, contents : String;
	lines : HugeStringArray;
	aLine : String;
	voyage : CM_Voyage;
	vessel : CM_Vessel;
	isDoClearanceCheck : Boolean;
	currentLogLevel : Integer;
	procRes, result : Integer;

begin
	//currentLogLevel := app.logLevel;
	//app.changeLogLevel(LogINFO);
	terminal := self.getTerminal;
	dateToday := app.actualTimeServer.date.format('yyyyMMdd');
	create args transient;
	
	miscDir := app.cnGetServerMiscPath;
	ediDir := self.getTerminal.getConfig_FileDirectory(EDIFileDirectory).String;
	
	// create a dummy file away from the EDI processing directory
	create file transient;
	file.usePresentationFileSystem := false;
	
	// create the first TSW file
	file.openOutput(miscDir &amp; "\40522745C_" &amp; dateToday &amp; ".xml");
	file.writeString(self.zTSWFile(ShipName, VoyageName, CONTAINER01, null, null, null, null, null));
	file.close;
	file.commit;
	copyFileName := "40522745C_" &amp; dateToday &amp; ".xml";
	fileNameInEDI := ediDir &amp; "\" &amp; copyFileName;
	fileName1 := fileNameInEDI;
	args[1] := '"' &amp; miscDir &amp; '"';
	args[2] := '"' &amp; ediDir &amp; '"';
	args[3] := '"' &amp; copyFileName &amp; '"';
	procRes := node.createExternalProcess("", "robocopy", args, null, true, true, result);
	create checkFile transient;
	checkFile.fileName := fileNameInEDI;
	fileCopied := checkFile.isAvailable;
	fileCopyTime := checkFile.timeCreated.literalFormat;
	contents := checkFile.readString(checkFile.fileLength);
	self.assertNotNullMsg(contents, "File 1 contents is null");
	self.assertTrueMsg(contents.pos(CONTAINER01, 1) &lt;&gt; null, "File 1 doesn't contain Container 1");
	self.assertTrueMsg(fileCopied, "First file is NOT in the terminal EDI directory!! - procRes is " &amp; procRes.String);
	app.writeLog(method.qualifiedName &amp; Tab &amp; fileNameInEDI &amp; Tab &amp; fileCopyTime &amp; Tab &amp; checkFile.createdTime.literalFormat, LogINFO);
	delete checkFile;	
	
	// second TSW file - rename to _0001.xml and copy to EDI directory
	file.rename(miscDir &amp; "\40522745C_" &amp; dateToday &amp; "_0001.xml");
	copyFileName := "40522745C_" &amp; dateToday &amp; "_0001.xml";
	fileNameInEDI := ediDir &amp; "\" &amp; copyFileName;
	fileName2 := fileNameInEDI;
	args.clear;
	args[1] := '"' &amp; miscDir &amp; '"';
	args[2] := '"' &amp; ediDir &amp; '"';
	args[3] := '"' &amp; copyFileName &amp; '"';
	//procRes := node.createExternalProcess("", "cmd /c ECHO F|xcopy " &amp; file.fileName &amp; " " &amp; fileName2 &amp; " /K /X", null, null, true, true, result);
	procRes := node.createExternalProcess("", "robocopy", args, null, true, true, result);
	create checkFile transient;
	checkFile.fileName := fileNameInEDI;
	fileCopied := checkFile.isAvailable;
	if fileCopied then
		checkFile.mode := checkFile.Mode_IO;
		checkFile.open;
		checkFile.writeString(self.zTSWFile(ShipName, VoyageName, CONTAINER02, null, null, null, null, null));
		checkFile.close;
	endif;
	fileCopyTime := checkFile.timeCreated.literalFormat;
	contents := checkFile.readString(checkFile.fileLength);
	self.assertNotNullMsg(contents, "File 2 contents is null");
	self.assertTrueMsg(contents.pos(CONTAINER02, 1) &lt;&gt; null, "File 2 doesn't contain Container 2");
	self.assertTrueMsg(fileCopied, "Second file is NOT in the terminal EDI directory!! - procRes is " &amp; procRes.String);
	app.writeLog(method.qualifiedName &amp; Tab &amp; fileNameInEDI &amp; Tab &amp; fileCopyTime &amp; Tab &amp; checkFile.createdTime.literalFormat, LogINFO);
	delete checkFile;
	
	// create a BGP request to process the two files
	create agent transient;
	agent.setTerminal(terminal);
	create task transient;
	task.setValueForRow(ETRow_BgpEDIProcessNewFiles, true);
	beginTransaction;
	create request persistent;
	request.initRequestFromTask(task);
	commitTransaction;
	request.sendMsgWithParams (BGP_EdiRequest::initiateTerminal.name, agent, terminal);
	
	// check files are at Loaded status
	iter := terminal.myEdiConfig.ediFiles.createIterator;
	terminal.myEdiConfig.ediFiles.startKeyGeq(fileCreatedTS, iter);
	while iter.next(ediFile) do
		if ediFile.fileName = fileName1 then
			file1Found := true;
			file1Status := ediFile.fileStatus;
		elseif ediFile.fileName = fileName2 then
			file2Found := true;
			file2Status := ediFile.fileStatus;
		endif;
	endwhile;
	app.writeLog(method.qualifiedName &amp; Tab &amp; "file1Found: " &amp; file1Found.String &amp; ", file1Status: " &amp; file1Status.String, LogINFO);
	app.writeLog(method.qualifiedName &amp; Tab &amp; "file2Found: " &amp; file2Found.String &amp; ", file2Status: " &amp; file2Status.String, LogINFO);
	self.assertTrueMsg(file1Found, "First file not found in EDI files collection");
	self.assertIsOneOf(file1Status, "First file status is " &amp; file1Status.String, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL, CM_EDIFile.EDI_STATUS_DBLOADED);
	self.assertTrueMsg(file2Found, "Second file not found in EDI files collection");
	self.assertIsOneOf(file2Status, "Second file status is " &amp; file2Status.String, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL, CM_EDIFile.EDI_STATUS_DBLOADED);
	
	// third TSW file, update contents and copy to EDI directory
	delete file;
	create file transient;
	file.fileName := miscDir &amp; "\40522745C_" &amp; dateToday &amp; "_0001.xml";
	file.rename(miscDir &amp; "\40522745C_" &amp; dateToday &amp; ".xml");
	copyFileName := "40522745C_" &amp; dateToday &amp; ".xml";
	fileNameInEDI := ediDir &amp; "\" &amp; copyFileName;
	fileName3 := fileNameInEDI;
	args.clear;
	args[1] := '"' &amp; miscDir &amp; '"';
	args[2] := '"' &amp; ediDir &amp; '"';
	args[3] := '"' &amp; copyFileName &amp; '"';
	//procRes := node.createExternalProcess("", "cmd /c ECHO F|xcopy " &amp; file.fileName &amp; " " &amp; fileName2 &amp; " /K /X", null, null, true, true, result);
	procRes := node.createExternalProcess("", "robocopy", args, null, true, true, result);
	create checkFile transient;
	checkFile.fileName := fileName3;
	fileCopied := checkFile.isAvailable;
	if fileCopied then
		checkFile.mode := checkFile.Mode_IO;
		checkFile.open;
		checkFile.writeString(self.zTSWFile(ShipName, VoyageName, CONTAINER03, null, null, null, null, null));
		checkFile.close;
	endif;
	fileCopyTime := checkFile.timeCreated.literalFormat;
	contents := checkFile.readString(checkFile.fileLength);
	self.assertNotNullMsg(contents, "File 3 contents is null");
	self.assertTrueMsg(contents.pos(CONTAINER03, 1) &lt;&gt; null, "File 3 doesn't contain Container 3");
	self.assertTrueMsg(fileCopied, "Third file is NOT in the terminal EDI directory!! - procRes is " &amp; procRes.String);
	app.writeLog(method.qualifiedName &amp; Tab &amp; fileNameInEDI &amp; Tab &amp; fileCopyTime &amp; Tab &amp; checkFile.createdTime.literalFormat, LogINFO);
	delete checkFile;
	
	// Run BGP request again to process the third file
	request.sendMsgWithParams (BGP_EdiRequest::initiateTerminal.name, agent, terminal);
	
	// check file is DB Partially Loaded - should not have been renamed .xml_0001
	create lines transient;
	foreach ediFile in terminal.myEdiConfig.ediFiles reversed do	: outerLoop1
		if ediFile.fileName = fileName1 then
			// this could be file 1 OR file 3 - have a look at the raw data to find a unique detail
			ediFile.myEDIFileType.rawDataToHSA(ediFile, lines);
			foreach aLine in lines do
				if aLine.pos(CONTAINER03, 1) &lt;&gt; null then
					// this is file 3 - hooray!
					file3Found := true;
					file3Status := ediFile.fileStatus;
					break outerLoop1;
				elseif aLine.pos(CONTAINER01, 1) &lt;&gt; null then
					// this is file 1 - break
					break outerLoop1;
				endif;
			endforeach;
		endif;
	endforeach;
	self.assertTrueMsg(file3Found, "Third file not found in EDI files collection");
	self.assertIsOneOf(file3Status, "Third file status is " &amp; file3Status.String, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL, CM_EDIFile.EDI_STATUS_DBLOADED);
	
	////////////////////////////////////////////////////////////////////////////////////////////////
	// repeat the test with a different EDI file type to make sure the third file isn't processed //
	////////////////////////////////////////////////////////////////////////////////////////////////
	// Set up some data - couple of containers, voyage, block stack, etc
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	self.setTerminalConfig(EdiCargoByAllowPartial, true);
	self.deleteContainer(CONTAINER01);
	self.deleteContainer(CONTAINER02);
	self.deleteContainer(CONTAINER03);
	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	self.deleteVessel(ShipName);
	vessel := self.getVessel(ShipName);
	self.assertIsDeleted(vessel);
	
	// now set up cleanly
	vessel := self.addVesselCellular(ShipName, self.getOperator(TestOperator));
	self.assertNotNullMsg(vessel, 'Add vessel failed');

	voyage	:= self.addVoyageWithContainerStructur(VoyageName,
													ShipName,
													TestOperator, 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString);
	self.assertNotNullMsg( voyage, 'Add voyage failed' );
	voyage := self.getVoyage(VoyageName);
	self.assertNotNull(voyage);
	
	//self.gateInContainer("UTTSWTRUCK", CONTAINER01, "2200", "UTOP", "GENL", null);
	//self.gateInContainer("UTTSWTRUCK", CONTAINER02, "2200", "UTOP", "GENL", null);
	//self.gateInContainer("UTTSWTRUCK", CONTAINER03, "2200", "UTOP", "GENL", null);
	
	delete file;
	// clean up the misc directory of any files left behind
	create ff transient;
	ff.fileName := miscDir;
	foreach fileNode in ff.files where fileNode.cnEcIsFile do
		if fileNode.fileName.pos("40522745C_" &amp; dateToday, 1) &lt;&gt; null 
		or fileNode.fileName.pos("CargoOnSite_" &amp; dateToday, 1) &lt;&gt; null then
			fileNode.purge;
		endif;
	endforeach;
	
	create file transient;
	file.usePresentationFileSystem := false;
	file.openOutput(app.cnGetServerMiscPath &amp; "\CargoOnSite_" &amp; dateToday &amp; ".xml");
	file.writeString(self.zCargoOnSiteFile(CONTAINER01, VoyageName));
	file.close;
	file.commit;
	copyFileName := "CargoOnSite_" &amp; dateToday &amp; ".xml";
	fileNameInEDI := ediDir &amp; "\" &amp; copyFileName;
	fileName4 := fileNameInEDI;
	args.clear;
	args[1] := '"' &amp; miscDir &amp; '"';
	args[2] := '"' &amp; ediDir &amp; '"';
	args[3] := copyFileName;
	//procRes := node.createExternalProcess("", "cmd /c ECHO F|xcopy " &amp; file.fileName &amp; " " &amp; fileName4 &amp; " /K", null, null, true, true, result);
	procRes := node.createExternalProcess("", "robocopy", args, null, true, true, result);
	create checkFile transient;
	checkFile.fileName := fileName4;
	fileCopied := checkFile.isAvailable;
	fileCopyTime := checkFile.timeCreated.literalFormat;
	contents := checkFile.readString(checkFile.fileLength);
	self.assertNotNullMsg(contents, "File 4 (first non-TSW file) has no contents");
	self.assertTrueMsg(contents.pos(CONTAINER01, 1) &lt;&gt; null, "File 4 (first non-TSW file) doesn't contain Container 1");
	checkFile.close;
	app.writeLog(method.qualifiedName &amp; Tab &amp; fileNameInEDI &amp; Tab &amp; fileCopyTime &amp; Tab &amp; checkFile.createdTime.literalFormat, LogINFO);
	delete checkFile;
	self.assertTrueMsg(fileCopied, "Fourth (first non-TSW) file is NOT in the terminal EDI directory!! - procRes is " &amp; procRes.String);
	self.assertEqualMsg(fileCopyTime, file.createdTime.literalFormat, "Fourth file (first non-TSW) copied timeCreated is " &amp; fileCopyTime &amp; ", original file timeCreated is " &amp; file.createdTime.literalFormat);
	
	// second non-TSW file contents, and rename to _0001.xml and copy to EDI directory
	file.rename(miscDir &amp; "\" &amp; "CargoOnSite_" &amp; dateToday &amp; "_0001.xml");
	copyFileName := "CargoOnSite_" &amp; dateToday &amp; "_0001.xml";
	fileNameInEDI := ediDir &amp; "\" &amp; copyFileName;
	fileName5 := fileNameInEDI;
	args.clear;
	args[1] := '"' &amp; miscDir &amp; '"';
	args[2] := '"' &amp; ediDir &amp; '"';
	args[3] := '"' &amp; copyFileName &amp; '"';
	//procRes := node.createExternalProcess("", "cmd /c ECHO F|xcopy " &amp; file.fileName &amp; " " &amp; fileName5 &amp; " /K", null, null, true, true, result);
	procRes := node.createExternalProcess("", "robocopy", args, null, true, true, result);
	create checkFile transient;
	checkFile.fileName := fileName5;
	fileCopied := checkFile.isAvailable;
	if fileCopied then
		checkFile.mode := checkFile.Mode_IO;
		checkFile.open;
		checkFile.writeString(self.zCargoOnSiteFile(CONTAINER02, VoyageName));
		checkFile.close;
	endif;
	fileCopyTime := checkFile.timeCreated.literalFormat;
	contents := checkFile.readString(checkFile.fileLength);
	self.assertNotNullMsg(contents, "File 5 (second non-TSW file) contents is null");
	self.assertTrueMsg(contents.pos(CONTAINER02, 1) &lt;&gt; null, "File 5 (second non-TSW file), does not contain Container 2");
	self.assertTrueMsg(fileCopied, "Fifth (second non-TSW) file is NOT in the terminal EDI directory!!");
	app.writeLog(method.qualifiedName &amp; Tab &amp; fileNameInEDI &amp; Tab &amp; fileCopyTime &amp; Tab &amp; checkFile.createdTime.literalFormat, LogINFO);
	checkFile.close;
	delete checkFile;
	
	// Rerun the BGP request to process the two new files (different EDI File types)
	request.sendMsgWithParams (BGP_EdiRequest::initiateTerminal.name, agent, terminal);
	
	// check files are at Loaded status
	iter.reset;
	terminal.myEdiConfig.ediFiles.startKeyGeq(fileCreatedTS, iter);
	while iter.next(ediFile) do
		if ediFile.fileName = fileName4 then
			file4Found := true;
			file4Status := ediFile.fileStatus;
		elseif ediFile.fileName = fileName5 then
			file5Found := true;
			file5Status := ediFile.fileStatus;
		endif;
	endwhile;
	self.assertTrueMsg(file4Found, "Fourth file (first non-TSW) not found in EDI files collection");
	self.assertIsOneOf(file4Status, "Fourth file (first non-TSW) status is " &amp; file4Status.String, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL, CM_EDIFile.EDI_STATUS_DBLOADED);
	self.assertTrueMsg(file5Found, "Fifth file (second non-TSW) not found in EDI files collection");
	self.assertIsOneOf(file5Status, "Fifth file (second non-TSW) status is " &amp; file5Status.String, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL, CM_EDIFile.EDI_STATUS_DBLOADED);
	
	// third non-TSW file, update contents and copy to EDI directory
	delete file;
	create file transient;
	file.fileName := miscDir &amp; "\" &amp; "CargoOnSite_" &amp; dateToday &amp; "_0001.xml";
	file.rename(miscDir &amp; "\" &amp; "CargoOnSite_" &amp; dateToday &amp; ".xml");
	copyFileName := "CargoOnSite_" &amp; dateToday &amp; ".xml";
	fileNameInEDI := ediDir &amp; "\" &amp; copyFileName;
	fileName6 := fileNameInEDI;
	args.clear;
	args[1] := '"' &amp; miscDir &amp; '"';
	args[2] := '"' &amp; ediDir &amp; '"';
	args[3] := '"' &amp; copyFileName &amp; '"';
	//procRes := node.createExternalProcess("", "cmd /c ECHO F|xcopy " &amp; file.fileName &amp; " " &amp; fileName6 &amp; " /K", null, null, true, true, result);
	procRes := node.createExternalProcess("", "robocopy", args, null, true, true, result);
	create checkFile transient;
	checkFile.fileName := fileName6;
	fileCopied := checkFile.isAvailable;
	if fileCopied then
		checkFile.mode := checkFile.Mode_IO;
		checkFile.open;
		checkFile.writeString(self.zCargoOnSiteFile(CONTAINER03, VoyageName));
		checkFile.close;
	endif;
	fileCopyTime := checkFile.timeCreated.literalFormat;
	contents := checkFile.readString(checkFile.fileLength);
	self.assertNotNullMsg(contents, "Sixth file (third non-TSW file) has no contents");
	self.assertTrueMsg(contents.pos(CONTAINER03, 1) &lt;&gt; null, "Sixth file (third non-TSW) does not contain Container 3");
	self.assertTrueMsg(fileCopied, "Sixth (third non-TSW) file is NOT in the terminal EDI directory!!");
	app.writeLog(method.qualifiedName &amp; Tab &amp; fileNameInEDI &amp; Tab &amp; fileCopyTime &amp; Tab &amp; checkFile.createdTime.literalFormat, LogINFO);
	delete checkFile;
	
	// Run BGP request again to process the sixth file
	request.sendMsgWithParams (BGP_EdiRequest::initiateTerminal.name, agent, terminal);
	
	// check file is NOT loaded
	lines.clear;
	foreach ediFile in terminal.myEdiConfig.ediFiles reversed do	: outerLoop2
		if ediFile.fileName = fileName4 then
			// this could be file 4 OR file 6 - have a look at the raw data to find a unique detail
			ediFile.myEDIFileType.rawDataToHSA(ediFile, lines);
			foreach aLine in lines do
				if aLine.pos(CONTAINER03, 1) &lt;&gt; null then
					// this is file 6 - bugger
					file6Found := true;
					file6Status := ediFile.fileStatus;
					break outerLoop2;
				elseif aLine.pos(CONTAINER01, 1) &lt;&gt; null then
					// this is file 4 - break
					break outerLoop2;
				endif;
			endforeach;
		endif;
	endforeach;
	self.assertTrueMsg(not file6Found, "Sixth file WAS found in EDI files collection");
	if file6Found then
		self.assertNullMsg(file6Status, "Sixth file status is " &amp; file6Status.String);
	endif;
	
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	if file &lt;&gt; null and file.isAvailable then		
		file.close;
		file.purge;
	endif;
	delete file;
	if checkFile &lt;&gt; null and checkFile.isAvailable then
		checkFile.close;
		checkFile.purge;
	endif;
	delete checkFile;
	
	// clean up the misc directory of any files left behind
	delete ff;
	create ff transient;
	ff.fileName := miscDir;
	foreach fileNode in ff.files where fileNode.cnEcIsFile do
		if fileNode.fileName.pos("40522745C_", 1) &lt;&gt; null 
		or fileNode.fileName.pos("CargoOnSite_", 1) &lt;&gt; null then
			fileNode.purge;
		endif;
	endforeach;
	delete ff;
	delete args;
	delete agent;
	delete iter;
	delete ediDataTypes;
	delete task;
	delete lines;
	if not process.isInTransactionState then
		beginTransaction;
	endif;
	delete request;
	commitTransaction;
	//app.changeLogLevel(currentLogLevel);
end;</source>
    </JadeMethod>
    <JadeMethod name="tTSWBillWithMultiplePackages" id="5d8a9daf-0264-422b-8f00-220dfd970183">
        <source>tTSWBillWithMultiplePackages();
//
// Purpose:			1 Master BOL, 1 House BOL with pointers to two packaging segments so we need to
//					include both packaging segments in the pack count for the House BOL
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 21/04/2021	navdap1		Initial creation TFS 51057 CPL Customs TSW for vehicles with multiple "Packaging" elements
//
constants
	BLOCKSTACK = 'UTBTSW1';
	MASTERBOL = "PMWLQ6952";		// Master BOL
	HOUSEBOL = "TLL014121";			// House BOL
	VESSEL = 'UTBOLV1';
	VOYAGE = 'UTBOLV10';
	OPERATOR = 'UTOP';
	USER_DEF_NAME = 'TSW';
	
vars
	blockStack : CM_BlockStack;
	stopsTable : CM_StopsTable;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	operator : CM_Operator;
	allCargoForBol : CM_TISet;
	ti : CM_TrackedItem;
	ediText, tempStr : String;
	ediFile : CM_EDIFile;
	ediTI : CM_EDITrackedItem;
	ediStop : CM_EDICustomStopTI;
	found : Boolean;

begin
	// get rid of stuff - block stack, bols, voyage, vessel
	self.deleteTerminalArea(BLOCKSTACK);
	self.deleteVoyage(VOYAGE);
	self.deleteVessel(VESSEL);
	
	// setup stuff 
	blockStack := self.addBlockStack(BLOCKSTACK, 10, null);
	
	stopsTable := self.getRoot.getStopTableForId(TI_Stop_Customs);
	self.assertNotNullMsg(stopsTable, 'StopsTable ' &amp; TI_Stop_Customs.display &amp; ' does not exist');
	
	operator := self.getOperator(OPERATOR);
	self.assertNotNull(operator);

	vessel := self.addVesselGeneralCargo(VESSEL, operator, 5);
	self.assertNotNull(vessel);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL, OPERATOR, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 2);
	self.assertNotNull(voyage);

	// create cargo for the BOLs - will use rebar cargo type
	create allCargoForBol transient;
	allCargoForBol.add(self.addCargoAtLocation("UT_BOLREBAR01", "Rebar", operator, blockStack.myLocationsController));
	allCargoForBol.add(self.addCargoAtLocation("UT_BOLREBAR01", "Rebar", operator, blockStack.myLocationsController));
	allCargoForBol.add(self.addCargoAtLocation("UT_BOLREBAR02", "Rebar", operator, blockStack.myLocationsController));
	allCargoForBol.add(self.addCargoAtLocation("UT_BOLREBAR03", "Rebar", operator, blockStack.myLocationsController));
	
	beginTransaction;
	foreach ti in allCargoForBol do
		ti.setPropertyValue(CM_TrackedItem::houseBillOfLading.name, HOUSEBOL);
		ti.setMyVoyage(voyage, app.myPassport);
		ti.setImExStatus(TI_IMEX_STATUS_IMPORT);
	endforeach;
	commitTransaction;
	// now add an import stop
	foreach ti in allCargoForBol do
		self.addStopById(ti, TI_Stop_Customs);
	endforeach;
	
	// check - voyage should have 4 cargo items in its house bol collection, cargo should all have a stop
	self.assertEqualMsg(voyage.allTisByHouseBol.size, 4, "Voyage has incorrect number of TIs with house BOLs");
	foreach ti in allCargoForBol do
		tempStr	:= 'Stop ' &amp; TI_Stop_Customs.display &amp; Space &amp; stopsTable.heading.display &amp; ' does not exist for cargo ' &amp; ti.id;
		self.assertEqualMsg(ti.isStopSet(TI_Stop_Customs), true, tempStr);
	endforeach;
	
	// edi text - one master BOL (which JMT ignores) and 1 house BOl (but 2 house BOL segments with the same BOL number)
	ediText := 
'&lt;DocumentMetaData xmlns="urn:wco:datamodel:WCO:DM:1"&gt;
  &lt;WCODataModelVersion&gt;3.2&lt;/WCODataModelVersion&gt;
  &lt;WCODocumentName&gt;RES&lt;/WCODocumentName&gt;
  &lt;CountryCode&gt;NZ&lt;/CountryCode&gt;
  &lt;AgencyAssignedCustomizedDocumentName&gt;RESIM1&lt;/AgencyAssignedCustomizedDocumentName&gt;
  &lt;AgencyAssignedCustomizedDocumentVersion&gt;V1.1&lt;/AgencyAssignedCustomizedDocumentVersion&gt;
  &lt;CommunicationMetaData&gt;
    &lt;Recipient&gt;
      &lt;ID&gt;40522745C&lt;/ID&gt;
      &lt;RoleCode&gt;GC&lt;/RoleCode&gt;
    &lt;/Recipient&gt;
  &lt;/CommunicationMetaData&gt;
  &lt;Response xmlns="urn:wco:datamodel:WCO:ResponseModel:1"&gt;
    &lt;IssueDateTime formatCode="204"&gt;20210204162630&lt;/IssueDateTime&gt;
    &lt;FunctionalReferenceID&gt;122698&lt;/FunctionalReferenceID&gt;
    &lt;FunctionCode&gt;24&lt;/FunctionCode&gt;
    &lt;AdditionalInformation&gt;
      &lt;StatementDescription&gt;2 LOOSE PACKAGE(S) OR ITEM(S)&lt;/StatementDescription&gt;
      &lt;StatementTypeCode&gt;DIN&lt;/StatementTypeCode&gt;
    &lt;/AdditionalInformation&gt;
    &lt;OverallDeclaration&gt;
      &lt;Declaration&gt;
        &lt;ID&gt;47905771&lt;/ID&gt;
        &lt;AcceptanceDateTime formatCode="204"&gt;20210204162630&lt;/AcceptanceDateTime&gt;
        &lt;FunctionalReferenceID&gt;S00014121&lt;/FunctionalReferenceID&gt;
        &lt;TotalGrossMassMeasure unitCode="KGM"&gt;3002&lt;/TotalGrossMassMeasure&gt;
        &lt;VersionID&gt;1&lt;/VersionID&gt;
        &lt;JurisdictionDateTime formatCode="102"&gt;20210214&lt;/JurisdictionDateTime&gt;
        &lt;Submitter&gt;
          &lt;Name&gt;Taurus Logistics Limited&lt;/Name&gt;
        &lt;/Submitter&gt;
        &lt;Agent&gt;
          &lt;Name&gt;Taurus Logistics Limited&lt;/Name&gt;
        &lt;/Agent&gt;
        &lt;BorderTransportMeans&gt;
          &lt;Name&gt;TRANS FUTURE 5&lt;/Name&gt;
          &lt;ID&gt;' &amp; VESSEL &amp; '&lt;/ID&gt;
          &lt;TypeCode&gt;1&lt;/TypeCode&gt;
          &lt;JourneyID&gt;' &amp; VOYAGE &amp; '&lt;/JourneyID&gt;
        &lt;/BorderTransportMeans&gt;
        &lt;Carrier&gt;
          &lt;Name&gt;TOYOFUJI SHIPPING LINE CO LTD&lt;/Name&gt;
        &lt;/Carrier&gt;
        &lt;GoodsShipment&gt;
          &lt;Consignment&gt;
            &lt;TransportContractDocument&gt;
              &lt;ID&gt;' &amp; MASTERBOL &amp; '&lt;/ID&gt;
              &lt;TypeCode&gt;MB&lt;/TypeCode&gt;
            &lt;/TransportContractDocument&gt;
            &lt;TransportContractDocument&gt;
              &lt;ID&gt;' &amp; HOUSEBOL &amp; '&lt;/ID&gt;
              &lt;TypeCode&gt;BM&lt;/TypeCode&gt;
              &lt;Pointer&gt;
                &lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
              &lt;/Pointer&gt;
              &lt;Pointer&gt;
                &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
                &lt;DocumentSectionCode&gt;93A&lt;/DocumentSectionCode&gt;
              &lt;/Pointer&gt;
              &lt;Pointer&gt;
                &lt;SequenceNumeric&gt;2&lt;/SequenceNumeric&gt;
                &lt;DocumentSectionCode&gt;93A&lt;/DocumentSectionCode&gt;
              &lt;/Pointer&gt;
            &lt;/TransportContractDocument&gt;
          &lt;/Consignment&gt;
        &lt;/GoodsShipment&gt;
        &lt;Importer&gt;
          &lt;Name&gt;Mark Stuart Watson&lt;/Name&gt;
        &lt;/Importer&gt;
        &lt;Packaging&gt;
          &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
          &lt;QuantityQuantity&gt;2&lt;/QuantityQuantity&gt;
          &lt;TypeCode&gt;VN&lt;/TypeCode&gt;
        &lt;/Packaging&gt;
        &lt;Packaging&gt;
          &lt;SequenceNumeric&gt;2&lt;/SequenceNumeric&gt;
          &lt;QuantityQuantity&gt;2&lt;/QuantityQuantity&gt;
          &lt;TypeCode&gt;VN&lt;/TypeCode&gt;
        &lt;/Packaging&gt;
        &lt;UnloadingLocation&gt;
          &lt;ID&gt;NZWLG&lt;/ID&gt;
        &lt;/UnloadingLocation&gt;
        &lt;ResponsibleGovernmentAgency&gt;
          &lt;ID&gt;NZCS&lt;/ID&gt;
        &lt;/ResponsibleGovernmentAgency&gt;
      &lt;/Declaration&gt;
    &lt;/OverallDeclaration&gt;
    &lt;Status&gt;
      &lt;EffectiveDateTime formatCode="204"&gt;20210204162630&lt;/EffectiveDateTime&gt;
      &lt;NameCode&gt;819&lt;/NameCode&gt;
      &lt;ReleaseDateTime formatCode="204"&gt;20210204162630&lt;/ReleaseDateTime&gt;
      &lt;Pointer&gt;
        &lt;DocumentSectionCode&gt;07B&lt;/DocumentSectionCode&gt;
      &lt;/Pointer&gt;
      &lt;Pointer&gt;
        &lt;DocumentSectionCode&gt;42A&lt;/DocumentSectionCode&gt;
      &lt;/Pointer&gt;
      &lt;Pointer&gt;
        &lt;SequenceNumeric&gt;1&lt;/SequenceNumeric&gt;
        &lt;DocumentSectionCode&gt;08B&lt;/DocumentSectionCode&gt;
        &lt;TagID&gt;G007&lt;/TagID&gt;
      &lt;/Pointer&gt;
    &lt;/Status&gt;
  &lt;/Response&gt;
&lt;/DocumentMetaData&gt;';
	
	ediFile := self.ediLoadFileName(ediText, EDIFileType_XML, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);
	self.assertNotNull(ediFile);
	
	// should be 1 edi tracked item
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.size, 1, "EDI Data has incorrect number of EDI tracked items");
	
	// EDI tracked item with BOL id should have pack count of 4
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		ediStop := ediTI.CM_EDICustomStopTI;
		if ediStop.id = HOUSEBOL then
			found := true;
			self.assertEqualMsg(ediStop.packCount, 4, "House BOL has incorrect pack count");
		endif;
	endforeach;
	self.assertTrueMsg(found, "House BOL not found");
	
	self.ediVerify(ediFile);
	tempStr	:= 'Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);
	tempStr	:= 'DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	self.assertNoTrxErrorsOrWarnings();
	
	// Check the cargo for import stop
	foreach ti in allCargoForBol do
		// stop should have been cleared
		tempStr	:= 'Stop ' &amp; TI_Stop_Customs.display &amp; Space &amp; stopsTable.heading.display &amp; ' still exists for cargo ' &amp; ti.id;
		self.assertEqualMsg(ti.isStopSet(TI_Stop_Customs), false, tempStr);
	endforeach;
	
epilog
	delete allCargoForBol;
end;</source>
    </JadeMethod>
    <JadeMethod name="tTSWDTRB07BBIsCoastal" id="b34fd0e2-ac92-4666-80e4-89189e12c1dc">
        <source>tTSWDTRB07BBIsCoastal();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
18 December 2023	navpw1	Initial creation TFS: 61769 (61773)
//30/6/2025 navsaa30 MTN-35121 CPL | TSW 819 Clearance - Clarify Error Message
*/

constants
	UT_TFSNumber				: String	= "617691";
	UT_CargoPrefixId			: String 	= "UT" &amp; UT_TFSNumber;
	UT_CargoTypeAbbrev			: String	= "BBLK";
	UT_BOLNumber				: String	= "UTBOL" &amp; UT_TFSNumber ;
	UT_PackCount				: Integer	= 25;
	UT_EDINameCode				: String	= "B07";
	UT_BlockStack				: String	= "UTB" &amp; UT_EDINameCode;
	UT_VesselCode				: String	= "UTBOLBB" &amp; UT_EDINameCode;
	UT_VoyageCode				: String	= "UTBB61769_" &amp; UT_EDINameCode;
	UT_OperatorCode				: String	= "UTOP";
	UT_EDIUserDefName			: String	= "TSW";
	UT_StopCode					: String	= "TSWBB";
	UT_StopId					: Integer	= 879;
	UT_StopHeading				: String	= "TSW BACC Underbond HOLD";
	UT_CustomsActionName		: String	= "TSW TT " &amp; UT_EDINameCode;
	UT_CustomsActionKeyword		: String	= UT_EDINameCode;
	
vars
	blockStack					: CM_BlockStack;
	vessel						: CM_Vessel;
	voyage						: CM_Voyage;
	operator					: CM_Operator;
	terminal					: CM_Terminal;
	systemUTHelper				: UT_HelperAdmSys;
	terminalUTHelper			: UT_HelperAdmTerm;
	bolIn						: CM_BOLIn;
	tiTerminalArea				: CM_TerminalArea;
	pxyStopsTable,
	realStopsTable				: CM_StopsTable;
	pxyStopsTableTemplate		: CM_StopTableTemplate;
	pxyStopCriteria				: CM_StopCriteria;
	tiSet						: CM_TISet;
	ti							: CM_TrackedItem;
	ediFile						: CM_EDIFile;
	pxyCustomsAction,
	realCustomsAction			: CM_EDIAction;
	cargoTypeSet,
	imexStatusSet				: CM_ObjectSet;
	ediText						: String;
	processAreasArr,
	setAreasArr,
	checkAreasArr				: IntegerArray;
	noImportStops,
	completedBOLUpdate,
	ediEnforceVeslMatchExprt	: Boolean;
	bolDuplicateCheckPeriod		: Integer;
	valid						: Integer;
	
begin
	/*
	** Global Setup
	*/
	self.logMessage("Global Setup: Started");
	terminal := app.myPassport.myTerminal;
	self.assertNotNullMsg(terminal, "Global Setup - terminal");
	
	noImportStops := self.getTerminalConfig(NoImportStops).Boolean;
	self.setTerminalConfig(NoImportStops, true);
	self.assertTrueMsg(self.getTerminalConfig(NoImportStops).Boolean, "Global Setup - Terminal Config -&gt; Settings Tab -&gt; 'No Import Stops' should be set to true");
	
	ediEnforceVeslMatchExprt := self.getTerminalConfig(EDIEnforceVeslMatchExprt).Boolean;
	self.setTerminalConfig(EDIEnforceVeslMatchExprt, true);
	self.assertTrueMsg(self.getTerminalConfig(EDIEnforceVeslMatchExprt).Boolean, "Global Setup - Terminal Config -&gt; EDI Tab -&gt; 'Enforce Vessel Name Match for Customs EDI' should be set to true");
	
	bolDuplicateCheckPeriod := self.getTerminalConfig(BOLDuplicateCheckPeriod).Integer;
	self.setTerminalConfig(BOLDuplicateCheckPeriod, 0);
	self.assertTrueMsg(self.getTerminalConfig(BOLDuplicateCheckPeriod).Integer = 0, "Global Setup - Terminal Config -&gt; Defaults Tab -&gt; 'Bill Of Lading Duplicate Check Period' should be set to true");
	
	create systemUTHelper transient;
	systemUTHelper.setActiveProfile;
	systemUTHelper.currentMethodBeingRun := UT_TSW::tTSWDTRB07BBIsCoastal;
	
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_TSW::tTSWDTRB07BBIsCoastal;
	
	//Delete BlockStack
	self.deleteTerminalArea(UT_BlockStack);
	self.logMessage("Deleted Blockstack: Id:'" &amp; UT_BlockStack);
	
	//Create BlockStack
	blockStack := self.addBlockStack(UT_BlockStack, 10, null);
	self.assertNotNullMsg(blockStack, "Global Setup - blockStack");
	self.logMessage("Added Blockstack: Id:'" &amp; UT_BlockStack);
	
	//Get Operator
	operator := self.getOperator(UT_OperatorCode);
	self.assertNotNullMsg(operator, "Global Setup - operator");
	self.logMessage("Found Operator: Id:'" &amp; UT_OperatorCode);
	
	//Delete Voyage
	self.deleteVoyage(UT_VoyageCode);
	self.logMessage("Deleted Voyage: Id:'" &amp; UT_VoyageCode);
	
	//Delete Vessel
	self.deleteVessel(UT_VesselCode);
	self.logMessage("Deleted Vessel: Id:'" &amp; UT_VesselCode);
	
	//Create Vessel
	vessel := self.addVesselGeneralCargo(UT_VesselCode, operator, 5);
	self.assertNotNullMsg(vessel, "Global Setup - vessel");
	self.logMessage("Added Vessel: Id:'" &amp; UT_VesselCode);
	
	//Create Voyage
	voyage := self.addVoyageWithGeneralCargoStruc(UT_VoyageCode, UT_VesselCode, UT_OperatorCode, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 2);
	self.assertNotNullMsg(voyage, "Global Setup - voyage");
	self.logMessage("Added Voyage: Id:'" &amp; UT_VoyageCode);
	
	//Delete TSW TT BACC Underbond STOP
	realStopsTable := self.getRoot.getStopTableForId(UT_StopId);
	if realStopsTable &lt;&gt; null then
		self.deleteStopsTable(UT_StopId);
		self.assertIsDeletedMsg(realStopsTable, "Global Setup - realStopsTable");
		self.logMessage("Deleted Stops Table: Id:'" &amp; UT_StopId.String &amp; " Code: " &amp; UT_StopCode);
	endif;
	
	//Create TSW TT BACC Underbond STOP
	create pxyStopsTable transient;
	pxyStopsTable.setProxy(false, UT_StopCode, UT_StopHeading, UT_StopCode, null, UT_StopId, null, false, false, app.myRoot, null, app.myPassport.myUser.code, null);
	
	create pxyStopsTableTemplate transient;
	pxyStopsTableTemplate.setKeys(app.getMyTerminalDO_NOT_USE, pxyStopsTable);
	
	create processAreasArr transient;
	create setAreasArr transient;
	
	create checkAreasArr transient;
	checkAreasArr.add(StopPreventDeliveryRequest);
	checkAreasArr.add(StopPreventReleaseRequest);
	checkAreasArr.add(StopPreventYardMove);
	checkAreasArr.add(StopPreventGateOut);
	
	pxyStopsTableTemplate.setProxy(checkAreasArr,
									setAreasArr,
									processAreasArr,
									null,
									false,
									false,
									false,
									false,
									false,
									false,
									true,
									true);
	
	create cargoTypeSet transient;
	cargoTypeSet.add(app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation("BBLK"));
	cargoTypeSet.add(app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation("CAR"));
	cargoTypeSet.add(app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation("CONT"));
	cargoTypeSet.add(app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation("MDF"));
	
	create imexStatusSet transient;
	imexStatusSet.add(app.myRoot.allImexStatuses[TI_IMEX_STATUS_IMPORT]);
	
	create pxyStopCriteria transient;
	pxyStopCriteria.createStopCriteria(cargoTypeSet, YACriteriaType_CargoType, pxyStopCriteria);
	pxyStopCriteria.createStopCriteria(imexStatusSet, YACriteriaType_ImexStatus, pxyStopCriteria);
	pxyStopCriteria.createStopCriteria(CM_YADataBoolean.VALUE_TRUE, YACriteriaType_IsCoastal, pxyStopCriteria);
	pxyStopCriteria.setProxyBaseData(pxyStopsTable);
	
	app.myTrxCA.trxCreateStopsTable(pxyStopsTable, realStopsTable, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realStopsTable, "Global Setup - realStopsTable");
	self.logMessage("Created Stops Table: Id:'" &amp; UT_StopId.String &amp; " Code: " &amp; UT_StopCode);
	
	//Delete Customs Action TSW TT BACC Underbond STOP
	realCustomsAction := app.myRoot.allEDIActions[UT_CustomsActionName];
	if realCustomsAction &lt;&gt; null then
		self.deleteEDIAction(UT_CustomsActionName, null, EDIKeyField_Clearance);
		self.assertIsDeleted(realCustomsAction);
		self.logMessage("Deleted Customs Action: Id:'" &amp; UT_CustomsActionName);
	endif;
	
	realCustomsAction := null;
	
	//Create Customs Action TSW TT BACC Underbond STOP
	create pxyCustomsAction transient;
	pxyCustomsAction.setProxy(UT_CustomsActionName, UT_CustomsActionKeyword, EDIKeyField_Clearance, EDIAction_Add, realStopsTable, CM_EDIFileTypeXMLJMTInternal.firstInstance, null, null, null, CM_EDIAction.RoleCode_TT);
	app.myTrxCA.trxCreateEDIAction(pxyCustomsAction, realCustomsAction, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realCustomsAction, "Global Setup - realCustomsAction");
	self.logMessage("Created Customs Action: Id:'" &amp; UT_CustomsActionName);
	
	self.logMessage("Global Setup: Finished" &amp; CrLf);
	
	/*
	**	Test 1 Start - Test Role Code that is TT. Cargo is Coastal, Break-Bulk and on BOL. Should add the BACC Underbond HOLD stop with stopId as 879
	*/
	
	/*
	** Setup
	*/
	self.logMessage("Test 1 - Started | Details: Test Role Code that is TT. Cargo is Coastal, Break-Bulk and on BOL. Should add the BACC Underbond HOLD stop with stopId as 879");
	
	bolIn := self.zTSWDTRGenerateBBBOL(UT_CargoTypeAbbrev, UT_BOLNumber, voyage, operator, terminal, UT_CargoPrefixId, 1, 25, terminalUTHelper, tiSet);
	self.assertNotNullMsg(bolIn, "Test 1 - Setup - bolIn");
	
	beginTransaction;
	tiSet.copyNoDups(bolIn.allTrackedItems);
	commitTransaction;
	completedBOLUpdate := true;
	
	foreach ti in tiSet do
		self.move(ti, blockStack);
		tiTerminalArea := ti.myPrimaryActualLocation.myTerminalArea;
		self.assertTrueMsg(tiTerminalArea = blockStack, "Test 1 - Ti with Id: '" &amp; ti.id &amp; "' is not in correct location. Expected: '" &amp; UT_BlockStack &amp; "' | Actual: '" &amp; tiTerminalArea.id &amp; "'");
		self.assertEqualMsg(ti.totalQuantity, 50, "Test 1 - Setup - Ti with Id: '" &amp; ti.id &amp; "' ti.totalQuantity Expected: " &amp; 50.String &amp; " | Actual: " &amp; ti.totalQuantity.String);
		self.assertEqualMsg(ti.totalVolume.Real, 50000.Real, "Test 1 - Setup - Ti with Id: '" &amp; ti.id &amp; "' ti.totalVolume Expected: " &amp; 50000.String &amp; " | Actual: " &amp; ti.totalVolume.String);
		self.assertEqualMsg(ti.totalWeight, 50000.Decimal, "Test 1 - Setup - Ti with Id: '" &amp; ti.id &amp; "' ti.totalWeight Expected: " &amp; 50000.String &amp; " | Actual: " &amp; ti.totalWeight.String);
		self.assertEqualMsg(ti.getImExStatus, TI_IMEX_STATUS_IMPORT, "Test 1 - Setup - Ti with Id: '" &amp; ti.id &amp; "' ti.getImExStatus Expected: " &amp; TI_IMEX_STATUS_IMPORT.String &amp; " | Actual: " &amp; ti.getImExStatus.String);
		self.assertEqualMsg(ti.destinationPort, "NZAKL", "Test 1 - Setup - Ti with Id: '" &amp; ti.id &amp; "' ti.destinationPort Expected: " &amp; "NZAKL" &amp; " | Actual: " &amp; ti.destinationPort);
		self.assertEqualMsg(ti.loadPort, "NZAKL", "Test 1 - Setup - Ti with Id: '" &amp; ti.id &amp; "' ti.loadPort Expected: " &amp; "NZAKL" &amp; " | Actual: " &amp; ti.loadPort);
		self.assertEqualMsg(ti.dischargePort, "NZPOE", "Test 1 - Setup - Ti with Id: '" &amp; ti.id &amp; "' ti.dischargePort Expected: " &amp; "NZPOE" &amp; " | Actual: " &amp; ti.dischargePort);
	endforeach;
	
	delete tiSet;
	
	// BOl should have the same number of tis as the pack count
	self.assertEqualMsg(bolIn.allTrackedItems.size, UT_PackCount, "Test 1 - BOL has incorrect number of TIs");
	
	// edi text - different voyage and veseel but has a BOL which matches a voyage on the terminal and pack count
	ediText := self.zTSWDTRFileBOL("RIO MADEIRA", "327N", CM_EDIAction.RoleCode_TT, UT_CustomsActionKeyword, UT_BOLNumber, UT_PackCount, "MPIBIO");
	
	/*
	** Run
	*/
	ediFile := self.ediLoadFileName(ediText, EDIFileType_XML, UT_EDIUserDefName, UT_EDIUserDefName &amp; method.name);
	self.assertNotNullMsg(ediFile, "Test 1 - ediFile");
	
	// should be 1 edi tracked item
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.size, 1, "Test 1 - EDI Data has incorrect number of EDI tracked items | Expected: '1' | Actual: '" &amp; ediFile.ediData.allEDITrackedItems.size.String &amp; "'");
	
	self.ediVerify(ediFile);
	self.assertIsOneOf(ediFile.fileStatus, 'Test 1 - Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.logMessage("Test 1 - EDI Verified successfully");
	
	self.ediDBLoad(ediFile);
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, "Test 1 - Expected: '" &amp; app.getString(Loaded) &amp; "' | Actual: '" &amp; self.zGetEdiStatus(ediFile.fileStatus) &amp; "' |  Errors: " &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString);
	self.assertNoTrxErrorsOrWarnings();
	self.logMessage("Test 1 - EDI DB Loaded successfully");
	
	/*
	** Assert
	*/
	// Check the cargo for import stop
	create tiSet transient;
	bolIn := terminal.getBOLInByNumberPackCount(UT_BOLNumber, UT_PackCount,valid);		//navsaa30 #35121
	self.assertNotNullMsg(bolIn, "Test 1 - bolIn");
	self.logMessage("Test 1 - Found BOL on terminal. BOl Number: '" &amp; UT_BOLNumber &amp; "'");
	
	bolIn.allTrackedItems.copyNoDups(tiSet);
	// Check the cargo for import stop
	foreach ti in tiSet do
		// stop should have been added
		self.assertEqualMsg(ti.isStopSet(UT_StopId), true, "Test 1 - Stop '" &amp; UT_StopId.display &amp; Space &amp; realStopsTable.heading.display &amp; "' does not exist for cargo '" &amp; ti.id &amp; "'");
		
	endforeach;
	
	/*
	** Cleanup
	*/
	delete tiSet;
	
	self.logMessage("Test 1 - Finished - PASSED | Details: Test Role Code that is TT. Cargo is Coastal, Break-Bulk and on BOL. Should add the BACC Underbond HOLD stop with stopId as 879" &amp; CrLf);
	
	/*
	**	Test 1 End - Test Role Code that is TT. Cargo is Coastal, Break-Bulk and on BOL. Should add the BACC Underbond HOLD stop with stopId as 879
	*/
	
	/*
	** Global Cleanup
	*/
	self.logMessage("Global Cleanup: Started");
	
	//Delete BlockStack
	self.deleteTerminalArea(UT_BlockStack);
	self.logMessage("Deleted Blockstack: Id:'" &amp; UT_BlockStack);
	
	//Delete Voyage
	self.deleteVoyage(UT_VoyageCode);
	self.logMessage("Deleted Voyage: Id:'" &amp; UT_VoyageCode);
	
	//Delete Vessel
	self.deleteVessel(UT_VesselCode);
	self.logMessage("Deleted Vessel: Id:'" &amp; UT_VesselCode);
	
	//Delete Customs Action TSW TT BACC Underbond STOP
	realCustomsAction := app.myRoot.allEDIActions[UT_CustomsActionName];
	if realCustomsAction &lt;&gt; null then
		self.deleteEDIAction(UT_CustomsActionName, null, EDIKeyField_Clearance);
		self.assertIsDeleted(realCustomsAction);
		self.logMessage("Deleted Customs Action: Id:'" &amp; UT_CustomsActionName);
	endif;
	
	realCustomsAction := null;
	
	//Delete TSW TT BACC Underbond STOP
	realStopsTable := self.getRoot.getStopTableForId(UT_StopId);
	if realStopsTable &lt;&gt; null then
		self.deleteStopsTable(UT_StopId);
		self.assertIsDeletedMsg(realStopsTable, "Global Setup - realStopsTable");
		self.logMessage("Deleted Stops Table: Id:'" &amp; UT_StopId.String &amp; " Code: " &amp; UT_StopCode);
	endif;
	
	self.logMessage("Global Cleanup: Finished");
	
epilog
	if not completedBOLUpdate then
		abortTransaction;
	endif;
	
	delete systemUTHelper;
	delete terminalUTHelper;
	delete pxyStopsTable;
	delete pxyCustomsAction;
	delete processAreasArr;
	delete setAreasArr;
	delete checkAreasArr;
	delete cargoTypeSet;
	delete imexStatusSet;
	delete tiSet;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tTSWDTRBOLChange" id="6490a349-6226-4241-9eb8-1ffcd2b279ba">
        <source>tTSWDTRBOLChange();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
24 November 2023	navpw1	Initial creation TFS: 61364 (61375)
//30/6/2025 navsaa30 MTN-35121 CPL | TSW 819 Clearance - Clarify Error Message
02 September 2025	navpw1	JIRA: MTN-35898 - Fixed warning message mismatch caused by the above change MTN-35121
*/

constants
	TFSNumber					: String	= "61364";
	ContainerStartNumber		: String 	= "UT" &amp; TFSNumber;
	BLOCKSTACK					: String	= 'UTB' &amp; TFSNumber;
	VESSEL						: String	= 'UTVES' &amp; TFSNumber;
	VOYAGE						: String	= 'UT' &amp; TFSNumber;
	OPERATOR					: String	= 'UTOP';
	USER_DEF_NAME				: String	= 'TSW';
	STOP_ID_IMPORT_CUSTOMS		: Integer	= 1;
	
	TSW_BOL						: String	= "UTBOL" &amp; TFSNumber &amp; "-1";
	
	CUSTOMS_ACTION_KEYWORD_1	: String	= "C06";
	CUSTOMS_ACTION_KEYWORD_2	: String	= "B07";
	
	UT_PackCount				: Integer	= 20;
	UT_PackCountFail			: Integer	= 100;
	UT_PackCount2				: Integer	= 15;
	
	STOP_ID_TSW_TT_HOLD			: Integer	= 875;
	STOP_CODE_TT				: String	= "TSWTT";
	STOP_HEADING_TT				: String	= "TSW TT HOLD " &amp; CUSTOMS_ACTION_KEYWORD_2;
	CUSTOMS_ACTION_NAME_TT		: String	= "TSW TT " &amp; CUSTOMS_ACTION_KEYWORD_2;
	CUSTOMS_ACTION_KEYWORD_TT	: String	= CUSTOMS_ACTION_KEYWORD_2;
	CUSTOMS_ACTION_NAME_GC		: String	= "TSW GC " &amp; CUSTOMS_ACTION_KEYWORD_2;
	CUSTOMS_ACTION_KEYWORD_GC	: String	= CUSTOMS_ACTION_KEYWORD_2;
	
vars
	noImportStops,
	ediEnforceVeslMatchExprt,
	bolVoyageNotFoundError,
	voyageCodeNotValidError		: Boolean;
	bolDuplicateCheckPeriod		: Integer;
	ediText, tempStr			: String;
	systemUTHelper				: UT_HelperAdmSys;
	terminalUTHelper			: UT_HelperAdmTerm;
	blockStack					: CM_BlockStack;
	operator					: CM_Operator;
	vessel						: CM_Vessel;
	voyage						: CM_Voyage;
	ediFile						: CM_EDIFile;
	tiSet						: CM_TISet;
	ti1							: CM_TrackedItem;
	
	bolIn						: CM_BOLIn;
	realStopsTable,
	stopsTableB07,
	pxyStopsTableB07			: CM_StopsTable;
	realCustomsActionB07,
	pxyCustomsActionB07,
	realCustomsActionGC			: CM_EDIAction;
	
	terminal					: CM_Terminal;
	error						: CM_Error;
	pxyStopsTableTemplateB07	: CM_StopTableTemplate;
	intArray					: IntegerArray;
	setArray					: IntegerArray;
	valid						: Integer;		//navsaa30 #35121
begin
	/*
	** Global Setup
	*/
	terminal := app.myPassport.myTerminal;
	noImportStops := self.getTerminalConfig(NoImportStops).Boolean;
	self.setTerminalConfig(NoImportStops, true);
	self.assertTrueMsg(self.getTerminalConfig(NoImportStops).Boolean, "Global Setup - Terminal Config -&gt; Settings Tab -&gt; 'No Import Stops' should be set to true");
	
	ediEnforceVeslMatchExprt := self.getTerminalConfig(EDIEnforceVeslMatchExprt).Boolean;
	self.setTerminalConfig(EDIEnforceVeslMatchExprt, true);
	self.assertTrueMsg(self.getTerminalConfig(EDIEnforceVeslMatchExprt).Boolean, "Global Setup - Terminal Config -&gt; EDI Tab -&gt; 'Enforce Vessel Name Match for Customs EDI' should be set to true");
	
	bolDuplicateCheckPeriod := self.getTerminalConfig(BOLDuplicateCheckPeriod).Integer;
	self.setTerminalConfig(BOLDuplicateCheckPeriod, 0);
	self.assertTrueMsg(self.getTerminalConfig(BOLDuplicateCheckPeriod).Integer = 0, "Global Setup - Terminal Config -&gt; Defaults Tab -&gt; 'Bill Of Lading Duplicate Check Period' should be set to true");
	
	self.setTerminalConfig(GateInAutoBOLNumber, false);
	self.assertTrueMsg(self.getTerminalConfig(GateInAutoBOLNumber).Boolean = false, "Global Setup - Gate Configuration -&gt; Application Tab -&gt; 'Auto BOL Number' should be set to false");
	
	create systemUTHelper transient;
	systemUTHelper.setActiveProfile;
	systemUTHelper.currentMethodBeingRun := UT_TSW::tTSWDTRBOLChange;
	
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_TSW::tTSWDTRBOLChange;
	
	// get rid of stuff - block stack, bols, voyage, vessel
	self.deleteTerminalArea(BLOCKSTACK);
	self.deleteVoyage(VOYAGE);
	self.deleteVessel(VESSEL);
	
	//Create BlockStack
	blockStack := self.addBlockStack(BLOCKSTACK, 10, null);
	self.assertNotNullMsg(blockStack, "Global Setup - blockStack");
	
	//Get Operator
	operator := self.getOperator(OPERATOR);
	self.assertNotNullMsg(operator, "Global Setup - operator");
	
	//Create Vessel
	vessel := self.addVesselGeneralCargo(VESSEL, operator, 5);
	self.assertNotNullMsg(vessel, "Global Setup - vessel");
	
	//Create Voyage
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL, OPERATOR, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 2);
	self.assertNotNullMsg(voyage, "Global Setup - voyage");
	
	realStopsTable := app.myRoot.allStopsTable[STOP_ID_IMPORT_CUSTOMS];
	self.assertNotNullMsg(realStopsTable, "Global Setup - realStopsTable");
	
	//Delete Customs Action TT
	systemUTHelper.xDeleteCustomsAction(CUSTOMS_ACTION_NAME_TT, EDIKeyField_Clearance);
	app.writeLog("Deleted Customs Action: '" &amp; CUSTOMS_ACTION_NAME_TT &amp; "'", LogINFO);
	
	//Delete TSW TT STOP
	systemUTHelper.xDeleteStopsTable(STOP_ID_TSW_TT_HOLD);
	app.writeLog("Deleted Stops Table: Id:'" &amp; STOP_ID_TSW_TT_HOLD.String &amp; "' Code: '" &amp; STOP_HEADING_TT &amp; "'", LogINFO);
	
	//Create TSW TT STOP
	create intArray transient;
	create setArray transient;
	setArray.add(StopApplyExport);
	stopsTableB07 := systemUTHelper.xCreateStopsTable(STOP_ID_TSW_TT_HOLD, STOP_CODE_TT, STOP_HEADING_TT, STOP_CODE_TT, intArray, setArray, intArray);
	self.assertNotNullMsg(stopsTableB07, "Global Setup - stopsTableB07");
	app.writeLog("Created Stops Table: Id:'" &amp; STOP_ID_TSW_TT_HOLD.String &amp; "' Code: '" &amp; STOP_HEADING_TT &amp; "'", LogINFO);
	
	//Create/Update Customs Action 'TSW GC B07' (Not needed if unit tests clean up after themselves)
	realCustomsActionGC := app.myRoot.allEDIActions[CUSTOMS_ACTION_NAME_GC];
	if realCustomsActionGC = null then
		realCustomsActionGC := systemUTHelper.xCreateCustomsAction(CUSTOMS_ACTION_NAME_GC, CUSTOMS_ACTION_KEYWORD_GC, EDIKeyField_Clearance, EDIAction_Remove, null, stopsTableB07);
	else
		realCustomsActionGC := systemUTHelper.xUpdateCustomsAction(CUSTOMS_ACTION_NAME_GC, CUSTOMS_ACTION_KEYWORD_GC, EDIKeyField_Clearance, EDIAction_Remove, null, stopsTableB07);
	endif;
	self.assertNotNullMsg(realCustomsActionGC, "Global Setup - realCustomsActionGC");
	app.writeLog("Created/Updated Customs Action: '" &amp; CUSTOMS_ACTION_NAME_GC &amp; "'", LogINFO);
	
	//Create Customs Action TT
	realCustomsActionB07 := systemUTHelper.xCreateCustomsAction(CUSTOMS_ACTION_NAME_TT, CUSTOMS_ACTION_KEYWORD_TT, EDIKeyField_Clearance, EDIAction_Add, CM_EDIAction.RoleCode_TT, stopsTableB07);
	self.assertNotNullMsg(realCustomsActionB07, "Global Setup - realCustomsActionB07");
	app.writeLog("Created Customs Action: '" &amp; CUSTOMS_ACTION_NAME_TT &amp; "'", LogINFO);
	
	//Create BOL 1 with 5 cargo items
	//Generate Containers
	bolIn := self.zTSWDTRGenerateBOL(TSW_BOL, voyage, operator, terminal, ContainerStartNumber, 1, 5, terminalUTHelper, tiSet);
	
	beginTransaction;
	tiSet.copyNoDups(bolIn.allTrackedItems);
	commitTransaction;
	
	foreach ti1 in tiSet do
		self.addStopById(ti1, STOP_ID_IMPORT_CUSTOMS);
		self.move(ti1, blockStack);
	endforeach;
	
	delete tiSet;
	
	//Assert that the right number of tis are associated to the bol
	self.assertEqualMsg(bolIn.allTrackedItems.size, 5, "Global Setup - Bol ('" &amp; TSW_BOL &amp; "') has an incorrect number of tis | Expected: '5' | Actual: '" &amp; bolIn.allTrackedItems.size.String &amp; "'");
	app.writeLog("Created Bol: Number: '" &amp; TSW_BOL &amp; "' Tracked Items Assigned: '" &amp; bolIn.allTrackedItems.size.String &amp; "'", LogINFO);
	
	bolIn := self.zTSWDTRGenerateBOL(TSW_BOL, voyage, operator, terminal, ContainerStartNumber, 6, 10, terminalUTHelper, tiSet);
	
	beginTransaction;
	tiSet.copyNoDups(bolIn.allTrackedItems);
	commitTransaction;
	
	foreach ti1 in tiSet do
		self.addStopById(ti1, STOP_ID_IMPORT_CUSTOMS);
		self.move(ti1, blockStack);
	endforeach;
	
	delete tiSet;
	
	self.assertEqualMsg(bolIn.allTrackedItems.size, 10, "Global Setup - Bol ('" &amp; TSW_BOL &amp; "') has an incorrect number of tis | Expected: '10' | Actual: '" &amp; bolIn.allTrackedItems.size.String &amp; "'");
	app.writeLog("Created Bol: Number: '" &amp; TSW_BOL &amp; "' Tracked Items Assigned: '" &amp; bolIn.allTrackedItems.size.String &amp; "'", LogINFO);
	
	bolIn := self.zTSWDTRGenerateBOL(TSW_BOL, voyage, operator, terminal, ContainerStartNumber, 16, 15, terminalUTHelper, tiSet);
	
	beginTransaction;
	tiSet.copyNoDups(bolIn.allTrackedItems);
	commitTransaction;
	
	foreach ti1 in tiSet do
		self.move(ti1, blockStack);
	endforeach;
	
	delete tiSet;
	
	self.assertEqualMsg(bolIn.allTrackedItems.size, 15, "Global Setup - Bol ('" &amp; TSW_BOL &amp; "') has an incorrect number of tis | Expected: '15' | Actual: '" &amp; bolIn.allTrackedItems.size.String &amp; "'");
	app.writeLog("Created Bol: Number: '" &amp; TSW_BOL &amp; "' Tracked Items Assigned: '" &amp; bolIn.allTrackedItems.size.String &amp; "'", LogINFO);
	
	bolIn := self.zTSWDTRGenerateBOL(TSW_BOL, voyage, operator, terminal, ContainerStartNumber, 31, 20, terminalUTHelper, tiSet);
	
	beginTransaction;
	tiSet.copyNoDups(bolIn.allTrackedItems);
	commitTransaction;
	
	foreach ti1 in tiSet do
		self.addStopById(ti1, STOP_ID_IMPORT_CUSTOMS);
		self.move(ti1, blockStack);
	endforeach;
	
	delete tiSet;
	
	self.assertEqualMsg(bolIn.allTrackedItems.size, 20, "Global Setup - Bol ('" &amp; TSW_BOL &amp; "') has an incorrect number of tis | Expected: '20' | Actual: '" &amp; bolIn.allTrackedItems.size.String &amp; "'");
	app.writeLog("Created Bol: Number: '" &amp; TSW_BOL &amp; "' Tracked Items Assigned: '" &amp; bolIn.allTrackedItems.size.String &amp; "'", LogINFO);
	
	/*
	**	Test 1 Start - Test that C06 tsw message for bol verifies with no errors/warnings and loads correctly to db
	*/
	
	/*
	** Setup
	*/
	app.writeLog("Test 1: Started", LogINFO);
	// edi text - one master BOL (which JMT ignores) and 1 house BOl (but 2 house BOL segments with the same BOL number)
	ediText := self.zTSWDTRFileBOL("RIO MADEIRA", "327N", CM_EDIAction.RoleCode_TT, CUSTOMS_ACTION_KEYWORD_1, TSW_BOL, UT_PackCount, null);
	
	/*
	** Run
	*/
	ediFile := self.ediLoadFileName(ediText, EDIFileType_XML, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);
	self.assertNotNullMsg(ediFile, "Test 1 - ediFile");
	
	// should be 1 edi tracked item
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.size, 1, "Test 1 - EDI Data has incorrect number of EDI tracked items | Expected: '1' | Actual: '" &amp; ediFile.ediData.allEDITrackedItems.size.String &amp; "'");
	
	self.ediVerify(ediFile);
	self.assertIsOneOf(ediFile.fileStatus, 'Test 1 - Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, "Test 1 - Expected: '" &amp; app.getString(Loaded) &amp; "' | Actual: '" &amp; self.zGetEdiStatus(ediFile.fileStatus) &amp; "' |  Errors: " &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString);
	self.assertNoTrxErrorsOrWarnings();
	
	/*
	** Assert
	*/
	create tiSet transient;
	bolIn := terminal.getBOLInByNumberPackCount(TSW_BOL, UT_PackCount,valid);	//navsaa30 #35121
	self.assertNotNullMsg(bolIn, "Test 1 - bolIn");
	bolIn.allTrackedItems.copyNoDups(tiSet);
	// Check the cargo for import stop
	foreach ti1 in tiSet do
		// stop should have been added
		self.assertEqualMsg(not ti1.isStopSet(STOP_ID_IMPORT_CUSTOMS), true, 'Test 1 - Stop ' &amp; STOP_ID_IMPORT_CUSTOMS.display &amp; Space &amp; realStopsTable.heading.display &amp; ' does not exist for cargo ' &amp; ti1.id);
		
	endforeach;
	
	/*
	** Cleanup
	*/
	delete tiSet;
	
	app.writeLog("Test 1: Finished - PASSED", LogINFO);
	
	/*
	**	Test 1 End - Test that C06 tsw message for bol verifies with no errors/warnings and loads correctly to db
	*/
	
	
	/*
	**	Test 2 - Tests that C06 tsw message for bol fails verification as no bol with pack count exists. Plus fails load
	*/
	
	/*
	** Setup
	*/
	app.writeLog("Test 2: Started", LogINFO);
	// edi text - one master BOL (which JMT ignores) and 1 house BOl (but 2 house BOL segments with the same BOL number)
	ediText := self.zTSWDTRFileBOL("RIO MADEIRA", "327N", CM_EDIAction.RoleCode_TT, CUSTOMS_ACTION_KEYWORD_1, TSW_BOL, UT_PackCountFail, null);
	
	/*
	** Run
	*/
	ediFile := self.ediLoadFileName(ediText, EDIFileType_XML, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);
	self.assertNotNullMsg(ediFile, "Test 2 - ediFile");
	
	// should be 1 edi tracked item
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.size, 1, "Test 2 - EDI Data has incorrect number of EDI tracked items | Expected: '1' | Actual: '" &amp; ediFile.ediData.allEDITrackedItems.size.String &amp; "'");
	
	self.ediVerify(ediFile);
	self.assertIsOneOf(ediFile.fileStatus, 'Test 2 - Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	foreach error in app.myPassport.allErrorWarnings do
		if error.text = "Bol not found on voyage." then								// ### JIRA: MTN-35898 02Sep2025 NAVPW1
			bolVoyageNotFoundError := true;
		elseif error.text = "Voyage Code is not valid." then
			voyageCodeNotValidError := true;
		else
			self.logMessagePw("Did not expect warning: " &amp; error.text, LogINFO);	// ### JIRA: MTN-35898 02Sep2025 NAVPW1
		endif;
	endforeach;
	
	self.assertTrueMsg(bolVoyageNotFoundError, "Test 2 - Expected Warning: 'Bol not found on voyage.' | Actual: 'Bol was found on voyage'");	// ### JIRA: MTN-35898 02Sep2025 NAVPW1
	self.assertTrueMsg(voyageCodeNotValidError, "Test 2 - Expected Warning: 'Voyage Code is not valid.' | Actual: 'Voyage Code is valid'");		// ### JIRA: MTN-35898 02Sep2025 NAVPW1
	
	self.ediDBLoad(ediFile);
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL, "Test 2 - Expected: '" &amp; app.getString(DB_Partially_loaded) &amp; "' | Actual: '" &amp; self.zGetEdiStatus(ediFile.fileStatus) &amp; "' |  Errors: " &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString);
	
	/*
	** Assert
	*/
	create tiSet transient;
	bolIn := terminal.getBOLInByNumberPackCount(TSW_BOL, UT_PackCount,valid);	//navsaa30 #35121
	self.assertNotNullMsg(bolIn, "Test 2 - bolIn");
	bolIn.allTrackedItems.copyNoDups(tiSet);
	// Check the cargo for import stop
	foreach ti1 in tiSet do
		// stop should have been added
		self.assertEqualMsg(not ti1.isStopSet(STOP_ID_IMPORT_CUSTOMS), true, 'Test 2 - Stop ' &amp; STOP_ID_IMPORT_CUSTOMS.display &amp; Space &amp; realStopsTable.heading.display &amp; ' does not exist for cargo ' &amp; ti1.id);
		
	endforeach;
	
	/*
	** Cleanup
	*/
	delete tiSet;
	
	app.writeLog("Test 2: Finished - PASSED", LogINFO);
	
	/*
	**	Test 2 End - Tests that C06 tsw message for bol fails verification as no bol with pack count exists. Plus fails load
	*/
	
	
	/*
	**	Test 3 Start - Test that B07 tsw message for bol verifies with no errors/warnings and loads correctly to db
	*/
	
	/*
	** Setup
	*/
	app.writeLog("Test 3: Started", LogINFO);
	// edi text - one master BOL (which JMT ignores) and 1 house BOl (but 2 house BOL segments with the same BOL number)
	ediText := self.zTSWDTRFileBOL("RIO MADEIRA", "327N", CM_EDIAction.RoleCode_TT, CUSTOMS_ACTION_KEYWORD_2, TSW_BOL, UT_PackCount2, null);
	
	/*
	** Run
	*/
	ediFile := self.ediLoadFileName(ediText, EDIFileType_XML, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);
	self.assertNotNullMsg(ediFile, "Test 3 - ediFile");
	
	// should be 1 edi tracked item
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.size, 1, "Test 3 - EDI Data has incorrect number of EDI tracked items | Expected: '1' | Actual: '" &amp; ediFile.ediData.allEDITrackedItems.size.String &amp; "'");
	
	self.ediVerify(ediFile);
	self.assertIsOneOf(ediFile.fileStatus, 'Test 3 - Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, "Test 3 - Expected: '" &amp; app.getString(Loaded) &amp; "' | Actual: '" &amp; self.zGetEdiStatus(ediFile.fileStatus) &amp; "' |  Errors: " &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString);
	self.assertNoTrxErrorsOrWarnings();
	
	/*
	** Assert
	*/
	create tiSet transient;
	bolIn := terminal.getBOLInByNumberPackCount(TSW_BOL, UT_PackCount2,valid);	//navsaa30 #35121
	self.assertNotNullMsg(bolIn, "Test 3 - bolIn");
	bolIn.allTrackedItems.copyNoDups(tiSet);
	// Check the cargo for import stop
	foreach ti1 in tiSet do
		// stop should have been added
		self.assertEqualMsg(ti1.isStopSet(STOP_ID_TSW_TT_HOLD), true, 'Test 3 - Stop ' &amp; STOP_ID_TSW_TT_HOLD.display &amp; Space &amp; stopsTableB07.heading.display &amp; ' does not exist for cargo ' &amp; ti1.id);
		
	endforeach;
	
	/*
	** Cleanup
	*/
	delete tiSet;
	
	app.writeLog("Test 3: Finished - PASSED", LogINFO);
	
	/*
	**	Test 3 End - Test that B07 tsw message for bol verifies with no errors/warnings and loads correctly to db
	*/
	
	
	/*
	**	Test 4 - Tests that B07 tsw message for bol fails verification as no bol with pack count exists. Plus fails load
	*/
	
	/*
	** Setup
	*/
	app.writeLog("Test 4: Started", LogINFO);
	// edi text - one master BOL (which JMT ignores) and 1 house BOl (but 2 house BOL segments with the same BOL number)
	ediText := self.zTSWDTRFileBOL("RIO MADEIRA", "327N", CM_EDIAction.RoleCode_TT, CUSTOMS_ACTION_KEYWORD_2, TSW_BOL, UT_PackCountFail, null);
	
	/*
	** Run
	*/
	ediFile := self.ediLoadFileName(ediText, EDIFileType_XML, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);
	self.assertNotNullMsg(ediFile, "Test 4 - ediFile");
	
	// should be 1 edi tracked item
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.size, 1, "Test 4 - EDI Data has incorrect number of EDI tracked items | Expected: '1' | Actual: '" &amp; ediFile.ediData.allEDITrackedItems.size.String &amp; "'");
	
	self.ediVerify(ediFile);
	self.assertIsOneOf(ediFile.fileStatus, 'Test 4 - Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	foreach error in app.myPassport.allErrorWarnings do
		if error.text = "Bol Voyage not found." then
			bolVoyageNotFoundError := true;
		elseif error.text = "Voyage Code is not valid." then
			voyageCodeNotValidError := true;
		endif;
	endforeach;
	
	self.assertTrueMsg(bolVoyageNotFoundError, "Test 4 - Expected: 'Bol Voyage not found.' | Actual: 'Bol voyage was found'");
	self.assertTrueMsg(voyageCodeNotValidError, "Test 4 - Expected: 'Voyage Code is not valid.' | Actual: 'Voyage Code is valid'");
	
	
	self.ediDBLoad(ediFile);
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL, "Test 4 - Expected: '" &amp; app.getString(DB_Partially_loaded) &amp; "' | Actual: '" &amp; self.zGetEdiStatus(ediFile.fileStatus) &amp; "' |  Errors: " &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString);
	
	/*
	** Assert
	*/
	create tiSet transient;
	bolIn := terminal.getBOLInByNumberPackCount(TSW_BOL, UT_PackCount,valid); //navsaa30 #35121
	self.assertNotNullMsg(bolIn, "Test 4 - bolIn");
	bolIn.allTrackedItems.copyNoDups(tiSet);
	// Check the cargo for import stop
	foreach ti1 in tiSet do
		// stop should have been added
		tempStr	:= 'Test 4 - Stop ' &amp; STOP_ID_IMPORT_CUSTOMS.display &amp; Space &amp; realStopsTable.heading.display &amp; ' does not exist for cargo ' &amp; ti1.id;
		self.assertEqualMsg(not ti1.isStopSet(STOP_ID_IMPORT_CUSTOMS), true, tempStr);
		
	endforeach;
	
	/*
	** Cleanup
	*/
	delete tiSet;
	
	app.writeLog("Test 4: Finished - PASSED", LogINFO);
	
	/*
	**	Test 4 End - Tests that B07 tsw message for bol fails verification as no bol with pack count exists. Plus fails load
	*/
	
	/*
	** Global Cleanup
	*/
	app.writeLog("Global Cleanup: Started", LogINFO);
	beginTransaction;
	stopsTableB07.setPropertyValue(CM_StopsTable::isNotAvailableForEntry.name, true);
	commitTransaction;
	app.writeLog("Global Cleanup: Finished", LogINFO);
	
epilog
	delete systemUTHelper;
	delete terminalUTHelper;
	delete pxyStopsTableTemplateB07;
	delete pxyStopsTableB07;
	delete pxyCustomsActionB07;
	delete intArray;
	delete setArray;
	delete tiSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="tTSWDTRC06BBIsCoastal" id="09793c78-3c6f-4d1c-8086-5450cfd7acac">
        <source>tTSWDTRC06BBIsCoastal();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
18 December 2023	navpw1	Initial creation TFS: 61769 (61773)
04 January 2024		navpw1	TFS: 61906 (61907) - Added another test for changes made in 61906
//30/6/2025 navsaa30 MTN-35121 CPL | TSW 819 Clearance - Clarify Error Message
*/

constants
	UT_TFSNumber					: String	= "617692";
	UT_CargoPrefixId				: String 	= "UT" &amp; UT_TFSNumber;
	UT_CargoTypeAbbrev				: String	= "BBLK";
	UT_BOLNumber					: String	= "UTBOL" &amp; UT_TFSNumber;
	UT_BOLNumber2					: String	= "UTBOL" &amp; UT_TFSNumber &amp; "2";
	UT_PackCount					: Integer	= 25;
	UT_EDINameCode					: String	= "C06";
	UT_BlockStack					: String	= "UTB" &amp; UT_EDINameCode;
	UT_VesselCode					: String	= "UTBOLBB" &amp; UT_EDINameCode;
	UT_VoyageCode					: String	= "UTBB61769_" &amp; UT_EDINameCode;
	UT_OperatorCode					: String	= "UTOP";
	UT_EDIUserDefName				: String	= "TSW";
	UT_StopCode						: String	= "TSWC0";
	UT_StopId						: Integer	= 880;
	UT_StopHeading					: String	= "TSW CIDO Underbond HOLD";
	UT_StopCode_Import				: String	= "TSWC1";
	UT_StopId_Import				: Integer	= 881;
	UT_StopHeading_Import			: String	= "TSW CIDO Import HOLD";
	UT_CustomsActionName			: String	= "TSW TT " &amp; UT_EDINameCode;
	UT_CustomsActionKeyword			: String	= UT_EDINameCode;
	
vars
	blockStack						: CM_BlockStack;
	vessel							: CM_Vessel;
	voyage							: CM_Voyage;
	operator						: CM_Operator;
	terminal						: CM_Terminal;
	systemUTHelper					: UT_HelperAdmSys;
	terminalUTHelper				: UT_HelperAdmTerm;
	bolIn							: CM_BOLIn;
	tiTerminalArea					: CM_TerminalArea;
	pxyStopsTable,
	pxyStopsTableImportStop,
	realStopsTable,
	realStopsTableImportStop		: CM_StopsTable;
	pxyStopsTableTemplate,
	pxyStopsTableTemplateImportStop	: CM_StopTableTemplate;
	pxyStopCriteria					: CM_StopCriteria;
	tiSet							: CM_TISet;
	ti								: CM_TrackedItem;
	ediFile							: CM_EDIFile;
	pxyCustomsAction,
	realCustomsAction				: CM_EDIAction;
	cargoTypeSet,
	imexStatusSet					: CM_ObjectSet;
	ediText							: String;
	processAreasArr,
	setAreasArr,
	checkAreasArr					: IntegerArray;
	noImportStops,
	completedBOLUpdate,
	ediEnforceVeslMatchExprt		: Boolean;
	bolDuplicateCheckPeriod			: Integer;
	transaction						: CM_TITransaction;
	transactionCount				: Integer;
	valid 							: Integer;
begin
	/*
	** Global Setup
	*/
	self.logMessage("Global Setup: Started");
	terminal := app.myPassport.myTerminal;
	self.assertNotNullMsg(terminal, "Global Setup - terminal");
	
	noImportStops := self.getTerminalConfig(NoImportStops).Boolean;
	self.setTerminalConfig(NoImportStops, false);
	self.assertFalseMsg(self.getTerminalConfig(NoImportStops).Boolean, "Global Setup - Terminal Config -&gt; Settings Tab -&gt; 'No Import Stops' should be set to false");
	
	ediEnforceVeslMatchExprt := self.getTerminalConfig(EDIEnforceVeslMatchExprt).Boolean;
	self.setTerminalConfig(EDIEnforceVeslMatchExprt, true);
	self.assertTrueMsg(self.getTerminalConfig(EDIEnforceVeslMatchExprt).Boolean, "Global Setup - Terminal Config -&gt; EDI Tab -&gt; 'Enforce Vessel Name Match for Customs EDI' should be set to true");
	
	bolDuplicateCheckPeriod := self.getTerminalConfig(BOLDuplicateCheckPeriod).Integer;
	self.setTerminalConfig(BOLDuplicateCheckPeriod, 0);
	self.assertTrueMsg(self.getTerminalConfig(BOLDuplicateCheckPeriod).Integer = 0, "Global Setup - Terminal Config -&gt; Defaults Tab -&gt; 'Bill Of Lading Duplicate Check Period' should be set to true");
	
	create systemUTHelper transient;
	systemUTHelper.setActiveProfile;
	systemUTHelper.currentMethodBeingRun := UT_TSW::tTSWDTRC06BBIsCoastal;
	
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_TSW::tTSWDTRC06BBIsCoastal;
	
	//Delete BlockStack
	self.deleteTerminalArea(UT_BlockStack);
	self.logMessage("Deleted Blockstack: Id:'" &amp; UT_BlockStack);
	
	//Create BlockStack
	blockStack := self.addBlockStack(UT_BlockStack, 10, null);
	self.assertNotNullMsg(blockStack, "Global Setup - blockStack");
	self.logMessage("Added Blockstack: Id:'" &amp; UT_BlockStack);
	
	//Get Operator
	operator := self.getOperator(UT_OperatorCode);
	self.assertNotNullMsg(operator, "Global Setup - operator");
	self.logMessage("Found Operator: Id:'" &amp; UT_OperatorCode);
	
	//Delete Voyage
	self.deleteVoyage(UT_VoyageCode);
	self.logMessage("Deleted Voyage: Id:'" &amp; UT_VoyageCode);
	
	//Delete Vessel
	self.deleteVessel(UT_VesselCode);
	self.logMessage("Deleted Vessel: Id:'" &amp; UT_VesselCode);
	
	//Create Vessel
	vessel := self.addVesselGeneralCargo(UT_VesselCode, operator, 5);
	self.assertNotNullMsg(vessel, "Global Setup - vessel");
	self.logMessage("Added Vessel: Id:'" &amp; UT_VesselCode);
	
	//Create Voyage
	voyage := self.addVoyageWithGeneralCargoStruc(UT_VoyageCode, UT_VesselCode, UT_OperatorCode, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 2);
	self.assertNotNullMsg(voyage, "Global Setup - voyage");
	self.logMessage("Added Voyage: Id:'" &amp; UT_VoyageCode);
	
	//Delete TSW CIDO Import
	realStopsTableImportStop := self.getRoot.getStopTableForId(UT_StopId_Import);
	if realStopsTableImportStop &lt;&gt; null then
		self.deleteStopsTable(UT_StopId_Import);
		self.assertIsDeletedMsg(realStopsTableImportStop, "Global Setup - realStopsTableImportStop");
		self.logMessage("Deleted Stops Table: Id:'" &amp; UT_StopId_Import.String &amp; " Code: " &amp; UT_StopCode_Import);
	endif;
	
	//Create TSW CIDO Import
	create pxyStopsTableImportStop transient;
	pxyStopsTableImportStop.setProxy(true, UT_StopCode_Import, UT_StopHeading_Import, UT_StopCode_Import, CustomsEntryNumber, UT_StopId_Import, null, false, false, app.myRoot, null, app.myPassport.myUser.code, null);
	
	create pxyStopsTableTemplateImportStop transient;
	pxyStopsTableTemplateImportStop.setKeys(app.getMyTerminalDO_NOT_USE, pxyStopsTableImportStop);
	
	create processAreasArr transient;
	processAreasArr.add(StopProcessEDICustomImport);
	
	create setAreasArr transient;
	setAreasArr.add(StopApplyImport);
	
	create checkAreasArr transient;
	checkAreasArr.add(StopPreventDeliveryRequest);
	checkAreasArr.add(StopPreventReleaseRequest);
	checkAreasArr.add(StopPreventYardMove);
	checkAreasArr.add(StopPreventGateOut);
	
	pxyStopsTableTemplateImportStop.setProxy(checkAreasArr,
									setAreasArr,
									processAreasArr,
									null,
									false,
									false,
									false,
									false,
									false,
									false,
									true,
									true);
	
	create cargoTypeSet transient;
	cargoTypeSet.add(app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation("BBLK"));
	cargoTypeSet.add(app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation("CAR"));
	cargoTypeSet.add(app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation("CONT"));
	cargoTypeSet.add(app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation("MDF"));
	
	create pxyStopCriteria transient;
	pxyStopCriteria.createStopCriteria(cargoTypeSet, YACriteriaType_CargoType, pxyStopCriteria);
	pxyStopCriteria.setProxyBaseData(pxyStopsTableImportStop);
	
	app.myTrxCA.trxCreateStopsTable(pxyStopsTableImportStop, realStopsTableImportStop, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realStopsTableImportStop, "Global Setup - realStopsTableImportStop");
	self.logMessage("Created Stops Table: Id:'" &amp; UT_StopId_Import.String &amp; " Code: " &amp; UT_StopCode_Import);
	
	delete processAreasArr;
	delete setAreasArr;
	delete checkAreasArr;
	delete cargoTypeSet;
	
	//Delete TSW TT CIDO Underbond STOP
	realStopsTable := self.getRoot.getStopTableForId(UT_StopId);
	if realStopsTable &lt;&gt; null then
		self.deleteStopsTable(UT_StopId);
		self.assertIsDeletedMsg(realStopsTable, "Global Setup - realStopsTable");
		self.logMessage("Deleted Stops Table: Id:'" &amp; UT_StopId.String &amp; " Code: " &amp; UT_StopCode);
	endif;
	
	//Create TSW TT CIDO Underbond STOP
	create pxyStopsTable transient;
	pxyStopsTable.setProxy(true, UT_StopCode, UT_StopHeading, UT_StopCode, CustomsReference, UT_StopId, null, false, false, app.myRoot, null, app.myPassport.myUser.code, null);
	
	create pxyStopsTableTemplate transient;
	pxyStopsTableTemplate.setKeys(app.getMyTerminalDO_NOT_USE, pxyStopsTable);
	
	create processAreasArr transient;
	create setAreasArr transient;
	
	create checkAreasArr transient;
	checkAreasArr.add(StopPreventDeliveryRequest);
	checkAreasArr.add(StopPreventReleaseRequest);
	checkAreasArr.add(StopPreventYardMove);
	checkAreasArr.add(StopPreventGateOut);
	
	pxyStopsTableTemplate.setProxy(checkAreasArr,
									setAreasArr,
									processAreasArr,
									null,
									false,
									false,
									false,
									false,
									false,
									false,
									true,
									true);
	
	create cargoTypeSet transient;
	cargoTypeSet.add(app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation("BBLK"));
	cargoTypeSet.add(app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation("CAR"));
	cargoTypeSet.add(app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation("CONT"));
	cargoTypeSet.add(app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation("MDF"));
	
	create imexStatusSet transient;
	imexStatusSet.add(app.myRoot.allImexStatuses[TI_IMEX_STATUS_IMPORT]);
	
	create pxyStopCriteria transient;
	pxyStopCriteria.createStopCriteria(cargoTypeSet, YACriteriaType_CargoType, pxyStopCriteria);
	pxyStopCriteria.createStopCriteria(imexStatusSet, YACriteriaType_ImexStatus, pxyStopCriteria);
	pxyStopCriteria.createStopCriteria(CM_YADataBoolean.VALUE_TRUE, YACriteriaType_IsCoastal, pxyStopCriteria);
	pxyStopCriteria.setProxyBaseData(pxyStopsTable);
	
	app.myTrxCA.trxCreateStopsTable(pxyStopsTable, realStopsTable, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realStopsTable, "Global Setup - realStopsTable");
	self.logMessage("Created Stops Table: Id:'" &amp; UT_StopId.String &amp; " Code: " &amp; UT_StopCode);
	
	//Delete Customs Action TSW TT CIDO Underbond STOP
	realCustomsAction := app.myRoot.allEDIActions[UT_CustomsActionName];
	if realCustomsAction &lt;&gt; null then
		self.deleteEDIAction(UT_CustomsActionName, null, EDIKeyField_Clearance);
		self.assertIsDeleted(realCustomsAction);
		self.logMessage("Deleted Customs Action: Id:'" &amp; UT_CustomsActionName);
	endif;
	
	realCustomsAction := null;
	
	//Create Customs Action TSW TT CIDO Underbond STOP
	create pxyCustomsAction transient;
	pxyCustomsAction.setProxy(UT_CustomsActionName, UT_CustomsActionKeyword, EDIKeyField_Clearance, EDIAction_Add, realStopsTable, CM_EDIFileTypeXMLJMTInternal.firstInstance, null, null, null, CM_EDIAction.RoleCode_TT);
	app.myTrxCA.trxCreateEDIAction(pxyCustomsAction, realCustomsAction, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realCustomsAction, "Global Setup - realCustomsAction");
	self.logMessage("Created Customs Action: Id:'" &amp; UT_CustomsActionName);
	
	self.logMessage("Global Setup: Finished" &amp; CrLf);
	
	/*
	**	Test 1 Start - Test Role Code that is TT. Cargo is Coastal, Break-Bulk and on BOL. Should add the CIDO Underbond HOLD stop with stopId as 879
	*/
	
	/*
	** Setup
	*/
	self.logMessage("Test 1 - Started | Details: Test Role Code that is TT. Cargo is Coastal, Break-Bulk and on BOL. Should add the CIDO Underbond HOLD stop with stopId as 879");
	
	bolIn := self.zTSWDTRGenerateBBBOL(UT_CargoTypeAbbrev, UT_BOLNumber, voyage, operator, terminal, UT_CargoPrefixId, 1, 25, terminalUTHelper, tiSet);
	self.assertNotNullMsg(bolIn, "Test 1 - Setup - bolIn");
	
	beginTransaction;
	tiSet.copyNoDups(bolIn.allTrackedItems);
	commitTransaction;
	completedBOLUpdate := true;
	
	foreach ti in tiSet do
		self.move(ti, blockStack);
		tiTerminalArea := ti.myPrimaryActualLocation.myTerminalArea;
		self.assertTrueMsg(tiTerminalArea = blockStack, "Test 1 - Ti with Id: '" &amp; ti.id &amp; "' is not in correct location. Expected: '" &amp; UT_BlockStack &amp; "' | Actual: '" &amp; tiTerminalArea.id &amp; "'");
		self.assertEqualMsg(ti.totalQuantity, 50, "Test 1 - Setup - Ti with Id: '" &amp; ti.id &amp; "' ti.totalQuantity Expected: " &amp; 50.String &amp; " | Actual: " &amp; ti.totalQuantity.String);
		self.assertEqualMsg(ti.totalVolume.Real, 50000.Real, "Test 1 - Setup - Ti with Id: '" &amp; ti.id &amp; "' ti.totalVolume Expected: " &amp; 50000.String &amp; " | Actual: " &amp; ti.totalVolume.String);
		self.assertEqualMsg(ti.totalWeight, 50000.Decimal, "Test 1 - Setup - Ti with Id: '" &amp; ti.id &amp; "' ti.totalWeight Expected: " &amp; 50000.String &amp; " | Actual: " &amp; ti.totalWeight.String);
		self.assertEqualMsg(ti.getImExStatus, TI_IMEX_STATUS_IMPORT, "Test 1 - Setup - Ti with Id: '" &amp; ti.id &amp; "' ti.getImExStatus Expected: " &amp; TI_IMEX_STATUS_IMPORT.String &amp; " | Actual: " &amp; ti.getImExStatus.String);
		self.assertEqualMsg(ti.destinationPort, "NZAKL", "Test 1 - Setup - Ti with Id: '" &amp; ti.id &amp; "' ti.destinationPort Expected: " &amp; "NZAKL" &amp; " | Actual: " &amp; ti.destinationPort);
		self.assertEqualMsg(ti.loadPort, "NZAKL", "Test 1 - Setup - Ti with Id: '" &amp; ti.id &amp; "' ti.loadPort Expected: " &amp; "NZAKL" &amp; " | Actual: " &amp; ti.loadPort);
		self.assertEqualMsg(ti.dischargePort, "NZPOE", "Test 1 - Setup - Ti with Id: '" &amp; ti.id &amp; "' ti.dischargePort Expected: " &amp; "NZPOE" &amp; " | Actual: " &amp; ti.dischargePort);
	endforeach;
	
	delete tiSet;
	
	// BOl should have the same number of tis as the pack count
	self.assertEqualMsg(bolIn.allTrackedItems.size, UT_PackCount, "Test 1 - BOL has incorrect number of TIs");
	
	// edi text - different voyage and veseel but has a BOL which matches a voyage on the terminal and pack count
	ediText := self.zTSWDTRFileBOL("RIO MADEIRA", "327N", CM_EDIAction.RoleCode_TT, UT_CustomsActionKeyword, UT_BOLNumber, UT_PackCount, "NZCS");
	
	/*
	** Run
	*/
	ediFile := self.ediLoadFileName(ediText, EDIFileType_XML, UT_EDIUserDefName, UT_EDIUserDefName &amp; method.name);
	self.assertNotNullMsg(ediFile, "Test 1 - ediFile");
	
	// should be 1 edi tracked item
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.size, 1, "Test 1 - EDI Data has incorrect number of EDI tracked items | Expected: '1' | Actual: '" &amp; ediFile.ediData.allEDITrackedItems.size.String &amp; "'");
	
	self.ediVerify(ediFile);
	self.assertIsOneOf(ediFile.fileStatus, 'Test 1 - Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.logMessage("Test 1 - EDI Verified successfully");
	
	self.ediDBLoad(ediFile);
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, "Test 1 - Expected: '" &amp; app.getString(Loaded) &amp; "' | Actual: '" &amp; self.zGetEdiStatus(ediFile.fileStatus) &amp; "' |  Errors: " &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString);
	self.assertNoTrxErrorsOrWarnings();
	self.logMessage("Test 1 - EDI DB Loaded successfully");
	
	/*
	** Assert
	*/
	// Check the cargo for import stop
	create tiSet transient;
	bolIn := terminal.getBOLInByNumberPackCount(UT_BOLNumber, UT_PackCount,valid);	//navsaa30 #35121
	self.assertNotNullMsg(bolIn, "Test 1 - bolIn");
	self.logMessage("Test 1 - Found BOL on terminal. BOl Number: '" &amp; UT_BOLNumber &amp; "'");
	
	bolIn.allTrackedItems.copyNoDups(tiSet);
	// Check the cargo for import stop
	foreach ti in tiSet do
		// stop should have been added
		self.assertEqualMsg(ti.isStopSet(UT_StopId), true, "Test 1 - Stop '" &amp; UT_StopId.display &amp; Space &amp; realStopsTable.heading.display &amp; "' does not exist for cargo '" &amp; ti.id &amp; "'");
		
	endforeach;
	
	/*
	** Cleanup
	*/
	delete tiSet;
	
	self.logMessage("Test 1 - Finished - PASSED | Details: Test Role Code that is TT. Cargo is Coastal, Break-Bulk and on BOL. Should add the CIDO Underbond HOLD stop with stopId as 879" &amp; CrLf);
	
	/*
	**	Test 1 End - Test Role Code that is TT. Cargo is Coastal, Break-Bulk and on BOL. Should add the CIDO Underbond HOLD stop with stopId as 879
	*/
	
	/*
	**	Test 2 Start - No import stops on cargo items and no duplicate transaction. Test Role Code that is TT. Cargo is Coastal, Break-Bulk and on BOL. Should add the CIDO Underbond HOLD stop with stopId as 879 to all cargo items
	*/
	
	/*
	** Setup
	*/
	self.logMessage("Test 2 - Started | Details: No import stops on cargo items and no duplicate transaction. Test Role Code that is TT. Cargo is Coastal, Break-Bulk and on BOL. Should add the CIDO Underbond HOLD stop with stopId as 879 to all cargo items");
	
	self.setTerminalConfig(NoImportStops, true);
	self.assertTrueMsg(self.getTerminalConfig(NoImportStops).Boolean, "Test 2 - Terminal Config -&gt; Settings Tab -&gt; 'No Import Stops' should be set to true");
	
	bolIn := self.zTSWDTRGenerateBBBOL(UT_CargoTypeAbbrev, UT_BOLNumber2, voyage, operator, terminal, UT_CargoPrefixId, 26, 25, terminalUTHelper, tiSet);
	self.assertNotNullMsg(bolIn, "Test 2 - Setup - bolIn");
	
	beginTransaction;
	tiSet.copyNoDups(bolIn.allTrackedItems);
	commitTransaction;
	completedBOLUpdate := true;
	
	foreach ti in tiSet do
		self.move(ti, blockStack);
		tiTerminalArea := ti.myPrimaryActualLocation.myTerminalArea;
		self.assertTrueMsg(tiTerminalArea = blockStack, "Test 2 - Ti with Id: '" &amp; ti.id &amp; "' is not in correct location. Expected: '" &amp; UT_BlockStack &amp; "' | Actual: '" &amp; tiTerminalArea.id &amp; "'");
		self.assertEqualMsg(ti.totalQuantity, 50, "Test 2 - Setup - Ti with Id: '" &amp; ti.id &amp; "' ti.totalQuantity Expected: " &amp; 50.String &amp; " | Actual: " &amp; ti.totalQuantity.String);
		self.assertEqualMsg(ti.totalVolume.Real, 50000.Real, "Test 2 - Setup - Ti with Id: '" &amp; ti.id &amp; "' ti.totalVolume Expected: " &amp; 50000.String &amp; " | Actual: " &amp; ti.totalVolume.String);
		self.assertEqualMsg(ti.totalWeight, 50000.Decimal, "Test 2 - Setup - Ti with Id: '" &amp; ti.id &amp; "' ti.totalWeight Expected: " &amp; 50000.String &amp; " | Actual: " &amp; ti.totalWeight.String);
		self.assertEqualMsg(ti.getImExStatus, TI_IMEX_STATUS_IMPORT, "Test 2 - Setup - Ti with Id: '" &amp; ti.id &amp; "' ti.getImExStatus Expected: " &amp; TI_IMEX_STATUS_IMPORT.String &amp; " | Actual: " &amp; ti.getImExStatus.String);
		self.assertEqualMsg(ti.destinationPort, "NZAKL", "Test 2 - Setup - Ti with Id: '" &amp; ti.id &amp; "' ti.destinationPort Expected: " &amp; "NZAKL" &amp; " | Actual: " &amp; ti.destinationPort);
		self.assertEqualMsg(ti.loadPort, "NZAKL", "Test 2 - Setup - Ti with Id: '" &amp; ti.id &amp; "' ti.loadPort Expected: " &amp; "NZAKL" &amp; " | Actual: " &amp; ti.loadPort);
		self.assertEqualMsg(ti.dischargePort, "NZPOE", "Test 2 - Setup - Ti with Id: '" &amp; ti.id &amp; "' ti.dischargePort Expected: " &amp; "NZPOE" &amp; " | Actual: " &amp; ti.dischargePort);
	endforeach;
	
	delete tiSet;
	
	// BOl should have the same number of tis as the pack count
	self.assertEqualMsg(bolIn.allTrackedItems.size, UT_PackCount, "Test 2 - BOL has incorrect number of TIs");
	
	// edi text - different voyage and veseel but has a BOL which matches a voyage on the terminal and pack count
	ediText := self.zTSWDTRFileBOL("RIO MADEIRA", "327N", CM_EDIAction.RoleCode_TT, UT_CustomsActionKeyword, UT_BOLNumber2, UT_PackCount, "NZCS");
	
	/*
	** Run
	*/
	ediFile := self.ediLoadFileName(ediText, EDIFileType_XML, UT_EDIUserDefName, UT_EDIUserDefName &amp; method.name);
	self.assertNotNullMsg(ediFile, "Test 2 - ediFile");
	
	// should be 1 edi tracked item
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.size, 1, "Test 2 - EDI Data has incorrect number of EDI tracked items | Expected: '1' | Actual: '" &amp; ediFile.ediData.allEDITrackedItems.size.String &amp; "'");
	
	self.ediVerify(ediFile);
	self.assertIsOneOf(ediFile.fileStatus, 'Test 2 - Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.logMessage("Test 2 - EDI Verified successfully");
	
	self.ediDBLoad(ediFile);
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, "Test 2 - Expected: '" &amp; app.getString(Loaded) &amp; "' | Actual: '" &amp; self.zGetEdiStatus(ediFile.fileStatus) &amp; "' |  Errors: " &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString);
	self.logMessage("Test 2 - EDI DB Loaded successfully");
	
	/*
	** Assert
	*/
	// Check the cargo for import stop
	create tiSet transient;
	bolIn := terminal.getBOLInByNumberPackCount(UT_BOLNumber2, UT_PackCount,valid);	//navsaa30 #35121
	self.assertNotNullMsg(bolIn, "Test 2 - bolIn");
	self.logMessage("Test 2 - Found BOL on terminal. BOl Number: '" &amp; UT_BOLNumber2 &amp; "'");
	
	bolIn.allTrackedItems.copyNoDups(tiSet);
	// Check the cargo for import stop
	foreach ti in tiSet do
		// stop should have been added
		self.assertEqualMsg(ti.isStopSet(UT_StopId), true, "Test 2 - Stop '" &amp; UT_StopId.display &amp; Space &amp; realStopsTable.heading.display &amp; "' does not exist for cargo '" &amp; ti.id &amp; "'");
		
	endforeach;
	
	// Check the cargo for import stop
	foreach ti in tiSet do
		transactionCount := 0;
		// stop should have been added
		foreach transaction in ti.allTransactions do
			if transaction.type &lt;&gt; TRANS_TYPE_CUSTSTOP_CLRD then
				continue;
			endif;
			transactionCount += 1;
		endforeach;
		self.assertEqualMsg(transactionCount, 1, "Test 2 - There should only be one 'Custom Stop Cleared' transaction for cargo '" &amp; ti.id &amp; "' | Actual '" &amp; transactionCount.String &amp; "'");
		
	endforeach;
	
	/*
	** Cleanup
	*/
	delete tiSet;
	
	self.logMessage("Test 2 - Finished - PASSED | Details: No import stops on cargo items and no duplicate transaction. Test Role Code that is TT. Cargo is Coastal, Break-Bulk and on BOL. Should add the CIDO Underbond HOLD stop with stopId as 879 to all cargo items" &amp; CrLf);
	
	/*
	**	Test 2 End - No import stops on cargo items and no duplicate transaction. Test Role Code that is TT. Cargo is Coastal, Break-Bulk and on BOL. Should add the CIDO Underbond HOLD stop with stopId as 879 to all cargo items
	*/
	
	/*
	** Global Cleanup
	*/
	self.logMessage("Global Cleanup: Started");
	
	//Delete BlockStack
	self.deleteTerminalArea(UT_BlockStack);
	self.logMessage("Deleted Blockstack: Id:'" &amp; UT_BlockStack);
	
	//Delete Voyage
	self.deleteVoyage(UT_VoyageCode);
	self.logMessage("Deleted Voyage: Id:'" &amp; UT_VoyageCode);
	
	//Delete Vessel
	self.deleteVessel(UT_VesselCode);
	self.logMessage("Deleted Vessel: Id:'" &amp; UT_VesselCode);
	
	//Delete TSW CIDO Import
	realStopsTableImportStop := self.getRoot.getStopTableForId(UT_StopId_Import);
	if realStopsTableImportStop &lt;&gt; null then
		self.deleteStopsTable(UT_StopId_Import);
		self.assertIsDeletedMsg(realStopsTableImportStop, "Global Setup - realStopsTableImportStop");
		self.logMessage("Deleted Stops Table: Id:'" &amp; UT_StopId_Import.String &amp; " Code: " &amp; UT_StopCode_Import);
	endif;
	
	//Delete Customs Action TSW TT CIDO Underbond STOP
	realCustomsAction := app.myRoot.allEDIActions[UT_CustomsActionName];
	if realCustomsAction &lt;&gt; null then
		self.deleteEDIAction(UT_CustomsActionName, null, EDIKeyField_Clearance);
		self.assertIsDeleted(realCustomsAction);
		self.logMessage("Deleted Customs Action: Id:'" &amp; UT_CustomsActionName);
	endif;
	
	realCustomsAction := null;
	
	//Delete TSW TT CIDO Underbond STOP
	realStopsTable := self.getRoot.getStopTableForId(UT_StopId);
	if realStopsTable &lt;&gt; null then
		self.deleteStopsTable(UT_StopId);
		self.assertIsDeletedMsg(realStopsTable, "Global Setup - realStopsTable");
		self.logMessage("Deleted Stops Table: Id:'" &amp; UT_StopId.String &amp; " Code: " &amp; UT_StopCode);
	endif;
	
	self.logMessage("Global Cleanup: Finished");
	
epilog
	if not completedBOLUpdate then
		abortTransaction;
	endif;
	
	delete systemUTHelper;
	delete terminalUTHelper;
	delete pxyStopsTable;
	delete pxyStopsTableImportStop;
	delete pxyCustomsAction;
	delete processAreasArr;
	delete setAreasArr;
	delete checkAreasArr;
	delete cargoTypeSet;
	delete imexStatusSet;
	delete tiSet;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tTSWDTRMOTLand_1" id="b7cff55a-3a12-49a9-8764-46a838c7eda1">
        <source>tTSWDTRMOTLand_1();
/*

Purpose:			Tests an allow Mode of Transport by Land using Stops
					2
					3
					6

Parameters:			

Return Value:		

Date			Who		Reason
26 June 2023	navpw1	Initial creation TFS: 58834

*/

constants
	STATEMENT_CODE_2				: String	= '2';
	STATEMENT_CODE_3				: String	= '3';
	STATEMENT_CODE_6				: String	= '6';
	BLOCKSTACK						: String	= 'UTB' &amp; self.TFS58834;
	MASTERBOL						: String	= "PMWLQ6952";		// Master BOL
	HOUSEBOL						: String	= "TLL014121";		// House BOL
	VESSEL							: String	= 'UTBOLLND' &amp; self.TFS58834;
	VOYAGE							: String	= 'UT' &amp; self.TFS58834 &amp; "_LND";
	OPERATOR						: String	= 'UTOP';
	USER_DEF_NAME					: String	= 'TSW';
	
	CONTAINERTEST1					: String	= self.TFS58834 &amp; "-LND1";
	CONTAINERTEST2					: String	= self.TFS58834 &amp; "-LND2";
	CONTAINERTEST3					: String	= self.TFS58834 &amp; "-LND3";
	CONTAINERTEST4					: String	= self.TFS58834 &amp; "-LND4";
	CONTAINERTEST5					: String	= self.TFS58834 &amp; "-LND5";
	CONTAINERTEST6					: String	= self.TFS58834 &amp; "-LND6";
	CONTAINERTEST7					: String	= self.TFS58834 &amp; "-LND7";
	CONTAINERTEST8					: String	= self.TFS58834 &amp; "-LND8";
	CONTAINERTEST9					: String	= self.TFS58834 &amp; "-LND9";
	CONTAINERTEST10					: String	= self.TFS58834 &amp; "-LND10";
	CONTAINERTEST11					: String	= self.TFS58834 &amp; "-LND11";
	CONTAINERTEST12					: String	= self.TFS58834 &amp; "-LND12";
	BOL1							: String	= "BOL120N28100-1";
	
	STOP_CODE_SEA_HOLD				: String	= "TSWLN";
	STOP_ID_SEA_HOLD				: Integer	= 884;
	STOP_HEADING_SEA_HOLD			: String	= "TSW SEA HOLD";
	
	CUSTOMS_ACTION_NAME_2			: String	= "TSW SEA 2";
	CUSTOMS_ACTION_KEYWORD_2		: String	= "2";
	
	CUSTOMS_ACTION_NAME_3			: String	= "TSW SEA 3";
	CUSTOMS_ACTION_KEYWORD_3		: String	= "3";
	
	CUSTOMS_ACTION_NAME_6			: String	= "TSW SEA 6";
	CUSTOMS_ACTION_KEYWORD_6		: String	= "6";
	
vars
	blockStack						: CM_BlockStack;
	pxyStopsTableSeaHold,
	realStopsTableSeaHold,
	stopsTableMAF,
	stopsTableSeaHold				: CM_StopsTable;
	vessel							: CM_Vessel;
	voyage							: CM_Voyage;
	operator						: CM_Operator;
	tiSet							: CM_TISet;
	ti1,
	ti2								: CM_TrackedItem;
	ediText, tempStr				: String;
	ediFile							: CM_EDIFile;
	ediTI							: CM_EDITrackedItem;
	ediStop							: CM_EDICustomStopTI;
	found1							: Boolean;
	pxyCustomsAction2,
	realCustomsAction2,
	pxyCustomsAction3,
	realCustomsAction3,
	pxyCustomsAction6,
	realCustomsAction6				: CM_EDIAction;
	
	pxyStopsTableTemplateLH			: CM_StopTableTemplate;
	checkAreasArr,
	setAreasArr,
	processAreasArr					: IntegerArray;
	noImportStops,
	completedOk						: Boolean;
	systemUTHelper					: UT_HelperAdmSys;
	
begin
	noImportStops := self.getTerminalConfig(NoImportStops).Boolean;
	self.setTerminalConfig(NoImportStops, true);
	self.assertTrueMsg(self.getTerminalConfig(NoImportStops).Boolean, "Terminal Config -&gt; Settings Tab -&gt; 'No Import Stops' should be set to true");
	
	create systemUTHelper transient;
	systemUTHelper.setActiveProfile;
	systemUTHelper.currentMethodBeingRun := UT_TSW::tTSWDTRMOTLand_1;
	
	// get rid of stuff - block stack, bols, voyage, vessel
	self.deleteTerminalArea(BLOCKSTACK);
	self.deleteVoyage(VOYAGE);
	self.deleteVessel(VESSEL);
	
	// setup stuff 
	blockStack := self.addBlockStack(BLOCKSTACK, 10, null);
	
	//Get Operator
	operator := self.getOperator(OPERATOR);
	self.assertNotNull(operator);
	
	vessel := self.addVesselGeneralCargo(VESSEL, operator, 5);
	self.assertNotNull(vessel);
	
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL, OPERATOR, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 2);
	self.assertNotNull(voyage);
	
	//Delete TSW LAND HOLD
	stopsTableSeaHold := self.getRoot.getStopTableForId(STOP_ID_SEA_HOLD);
	if stopsTableSeaHold &lt;&gt; null then
		self.deleteStopsTable(STOP_ID_SEA_HOLD);
		self.assertIsDeletedMsg(stopsTableSeaHold, "stopsTableSeaHold");
	endif;
	
	//Get Stops Table MAF
	stopsTableMAF := self.getRoot.getStopTableForId(TI_Stop_MAF);
	
	//Create TSW LAND HOLD
	create setAreasArr transient;
	
	create checkAreasArr transient;
	checkAreasArr.add(StopPreventExport);
	
	create processAreasArr transient;
	
	systemUTHelper.opts.purge();
	systemUTHelper.opts.addAssoc(UT_OPTS_IsFull, true);
	systemUTHelper.opts.addAssoc(UT_OPTS_CheckAreas, checkAreasArr);
	systemUTHelper.opts.addAssoc(UT_OPTS_SetAreas, setAreasArr);
	systemUTHelper.opts.addAssoc(UT_OPTS_ProcessAreas, processAreasArr);
	systemUTHelper.opts.addAssoc(UT_OPTS_HoldVoyages, null);
	
	realStopsTableSeaHold := systemUTHelper.xCreateStop(STOP_ID_SEA_HOLD, STOP_CODE_SEA_HOLD, STOP_HEADING_SEA_HOLD, STOP_CODE_SEA_HOLD, false, null, false, false);
	
	systemUTHelper.opts.purge();
	
	//Delete Customs Action 2
	realCustomsAction2 := app.myRoot.allEDIActions[CUSTOMS_ACTION_NAME_2];
	if realCustomsAction2 &lt;&gt; null then
		self.deleteEDIAction(CUSTOMS_ACTION_NAME_2, null, EDIKeySegment_MOT);
		self.assertIsDeletedMsg(realCustomsAction2, "realCustomsAction2");
	endif;
	
	realCustomsAction2 := null;
	
	//Delete Customs Action 3
	realCustomsAction3 := app.myRoot.allEDIActions[CUSTOMS_ACTION_NAME_3];
	if realCustomsAction3 &lt;&gt; null then
		self.deleteEDIAction(CUSTOMS_ACTION_NAME_3, null, EDIKeySegment_MOT);
		self.assertIsDeletedMsg(realCustomsAction3, "realCustomsAction3");
	endif;
	
