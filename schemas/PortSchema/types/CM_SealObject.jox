    <JadeMethod name="getMySealTypeObj" id="1f15f935-090a-4f16-a5c6-ed6c04b5851d">
        <source>getMySealTypeObj():CM_SealType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 March 2015	cnwndl1	Initial creation	Par 35828

*/

vars

begin

	return app.myRoot.allSealTypes.getAtKey( self.sealType );

epilog

end;</source>
        <ReturnType type="CM_SealType"/>
    </JadeMethod>
    <JadeMethod name="getSealValueAsString" id="1a18832c-6fd6-4473-8482-51880c2223ce">
        <source>getSealValueAsString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 March 2015	cnwndl1	Initial creation	Par 35828

*/

vars

	token : String;
	str : String;
	
begin
	
	foreach token in self.allSealNums do
		token := token.trimWhiteSpace;
		if token = null then
			continue;
		endif;
		
		if str &lt;&gt; null then
			str := str &amp; ", " &amp; token;
		else
			str := token;
		endif;			
	endforeach;
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSimpleDescription" id="2581807c-5dfb-4fa7-9180-bb64f880e773">
        <source>getSimpleDescription():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 March 2015	cnwndl1	Initial creation

*/

vars

	str : String;

begin

	str := self.sealType &amp; " = " &amp; self.getSealValueAsString() &amp; ", " &amp; self.sealedDT.asStringJMT;
	
	return str;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTokens" id="2d8bec73-17d8-4eb3-af2c-daf90c9a1e48">
        <source>getTokens(_str : String; _tokens: StringArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 March 2015	cnwndl1	Initial creation	Par 35828

*/

constants
	Delimiters = ",";

vars
	pos: Integer;
	token: String;
	
begin
	if _str = null then	
		return;
	endif;
	
	while true do
		pos := pos + 1;
		
		if pos &gt; _str.length then
			break;
		endif;
		token := _str.scanUntil( Delimiters, pos ).trimBlanks;
		if token &lt;&gt; null then
			_tokens.add( token );
		endif;
		if pos = 0 then
			break;
		endif;
	endwhile;
	
epilog

end;</source>
        <Parameter name="_str" type="String"/>
        <Parameter name="_tokens" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="matchesValueFromUser" id="e2b4297c-ecdd-4fad-b730-a14a1fc7109e">
        <source>matchesValueFromUser( userValue : String ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 March 2015	cnwndl1	Initial creation	Par 35828

*/

vars

	theSealType : CM_SealType;
	multiSeal : Boolean;
	strArray : CnStringArray;
	pos : Integer;
	storedValue : String;
	userPos : Integer;
	
begin

	if self.allSealNums = null or self.allSealNums.isEmpty then
		// we have no value stored
		return (userValue.trimBlanks = null).Boolean;
	endif;
	
	// if we are here, we have a stored value. So if the incoming value is null, we have no match.
	if userValue = null then
		return false;
	endif;
	
	// so if we are this far thru, both sides must have a value...
	
	// is the seal type allowed to have multiple seal values
	theSealType := app.myRoot.getSealType(self.sealType);
	if theSealType &lt;&gt; null then
		multiSeal := theSealType.allowMultipleSealNums;
	endif;
			
	if not multiSeal then
		// only one value allowed, does it match.
		return (userValue = self.allSealNums.first).Boolean;
		
	else
		// multiples allowed, need to cross check values to make sure we have the same number of values, and
		// that the values match, but the values wont necessarily be in teh same order.
		// We only allow a single comma character "," as the delimiter. 
		
		// get a list of the comma delimited tokens, from the user entered value.
		strArray := userValue.cnGetTokens(",");
		if strArray.size &lt;&gt; self.allSealNums.size then
			// a different number of seal values, that's a mis match.
			return false;
		endif;
		
		// iterate thru the collection of recorded values, find teh matching one in our local users array
		// and remove it. (to make sure we don't compare to the same value twice.)
		foreach pos in 1 to self.allSealNums.size do
			storedValue := self.allSealNums[pos];
			userPos := strArray.indexOf(storedValue);
			if userPos &lt; 1 then
				// this value wasn't recorded by the user
				return false;
			endif;
			strArray.removeAt(userPos);
		endforeach;
		
		//they must have all matched.
		return true;
		
	endif;

epilog

	delete strArray;
	
end;</source>
        <Parameter name="userValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="767c3869-6603-4f75-8906-3a6537d92b82">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 March 2015	cnwndl1	Initial creation	Par 35828

*/

vars
	pxySeal : CM_SealObject;
	completedOK : Boolean;
begin
	pxySeal := inheritMethod();

	pxySeal.previousSeal := self.previousSeal;
	pxySeal.sealType := self.sealType;
	pxySeal.sealedDT := self.sealedDT;

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxySeal;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxySeal;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="2ddaefc9-7412-4a87-aaf8-ebe0b926fa21">
        <updating/>
        <source>setForCreate( _pxySealObj : CM_SealObject )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 March 2015	cnwndl1	Initial creation	Par 35828

*/

vars

	sealTypeObj : CM_SealType;
	
begin

	self.sealType := _pxySealObj.sealType;
	sealTypeObj := app.myRoot.allSealTypes[self.sealType];
	if sealTypeObj &lt;&gt; null and not sealTypeObj.isInUse then
		sealTypeObj.setIsInUse(true);
	endif;

	self.setForUpdate( _pxySealObj );
	
epilog

end;</source>
        <Parameter name="_pxySealObj" type="CM_SealObject"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="b80dd231-7757-4516-a8af-e47bf194cf5d">
        <updating/>
        <source>setForUpdate( _pxySealObj : CM_SealObject )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 March 2015	cnwndl1	Initial creation	Par 35828

*/

vars
	
begin

	self.setPreviousSeal( app.myRoot.allSealTypes[_pxySealObj.sealType], _pxySealObj.previousSeal );
	self.setSealedDT( _pxySealObj.sealedDT );
	self.allSealNums.purge();
	
	if not _pxySealObj.allSealNums.isEmpty then	
		_pxySealObj.allSealNums.copy(self.allSealNums);
	endif;
	
	self.setSealType( _pxySealObj.sealType );
	
epilog

end;</source>
        <Parameter name="_pxySealObj" type="CM_SealObject"/>
    </JadeMethod>
    <JadeMethod name="setPreviousSeal" id="fb25d5a0-bb1a-4c9f-959c-09556ca66bcf">
        <updating/>
        <source>setPreviousSeal( _sealType : CM_SealType; _value : String )updating;
/*

Purpose:			

Parameters:			

Return Value:		

/* Changes

Date		Name	TFS#		Description
============================================================================
09/03/2015	cnwndl1	Par 35828	Initial creation	
08/02/2019	jlgka1	42861		Changed Seals field size to maximum.
============================================================================*/

begin
	if _sealType &lt;&gt; null and _sealType.savePreviousSeal then
		self.previousSeal := _value;	//jlgka1 TFS 42861
	else
		self.previousSeal := null;
	endif;
end;</source>
        <Parameter name="_sealType" type="CM_SealType"/>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="4ab8f34c-587b-426e-92ab-38ba8e9a0593">
        <updating/>
        <source>setProxy(	_sealNums : String;
			_prevSeal : String;
			_sealType : String;
			_sealedDT : TimeStamp;
			_myObject : CM_Object
			
			) updating;
/*

Purpose:			

Parameters:			

Return Value:		

/* Changes

Date		Name	TFS#		Description
============================================================================
09/03/2015	cnwndl1	Par 35828	Initial creation		
08/02/2019	jlgka1	42861		Changed Seals field size to maximum.
============================================================================*/

vars

	sealType : CM_SealType;
	strArray : StringArray;

begin

	self.raiseExceptionIfNotTransient(method);
	
	self.setSealType( _sealType );
	self.setSealedDT( _sealedDT );
	
	sealType := app.myRoot.allSealTypes.getAtKey( _sealType );
	
	self.allSealNums.clear();
	if sealType &lt;&gt; null then
		if sealType.allowMultipleSealNums and _sealNums.pos(",",1) &gt; 0 then
			create strArray transient;
			self.getTokens(_sealNums, strArray);
			strArray.copy(self.allSealNums);
		else
		//	self.allSealNums.add(_sealNums[1:62]);	//jlgka1 TFS 42861
			self.allSealNums.add(_sealNums[1:2047]);	//02 Mar 2020	NDL	TFS 48530
		endif;
		
		if sealType.savePreviousSeal then
			self.setPreviousSeal( sealType, _prevSeal );
		else
			self.setPreviousSeal( null, null );
		endif;
		
	endif;
	
	//the '_myObject' portion is set in the re-implemented version of this method

epilog

	delete strArray;

end;</source>
        <Parameter name="_sealNums" type="String"/>
        <Parameter name="_prevSeal" type="String"/>
        <Parameter name="_sealType" type="String"/>
        <Parameter name="_sealedDT" type="TimeStamp"/>
        <Parameter name="_myObject" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="setSealType" id="bf31d936-55ce-49a0-b2ea-2e56d3cca319">
        <updating/>
        <source>setSealType( _value : String )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 March 2015	cnwndl1	Initial creation	Par 35828

*/

vars

begin

	self.sealType := _value;

epilog

end;</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setSealValue" id="30f9e80a-5773-4785-a70d-f13d05ce939b">
        <updating/>
        <source>setSealValue( _sealType : CM_SealType; _sealNums : String ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

/* Changes

Date		Name	TFS#		Description
============================================================================
10/03/2015	cnwndl1	Par 35828	Initial creation
08/02/2019	jlgka1	42861		Changed Seals field size to maximum.
============================================================================*/

vars

	strArray : StringArray;

begin

	self.allSealNums.clear();
	
	if _sealType.allowMultipleSealNums then
		if _sealNums.pos(",",1) &gt; 0 then
			create strArray transient;
			self.getTokens(_sealNums, strArray);
			strArray.copy(self.allSealNums);
			return;
		endif;
	endif;
		
	if _sealNums.trimBlanks &lt;&gt; null then
		self.allSealNums.add( _sealNums);	//jlgka1 TFS 42861
	endif;
	
epilog

	delete strArray;

end;</source>
        <Parameter name="_sealType" type="CM_SealType"/>
        <Parameter name="_sealNums" type="String"/>
    </JadeMethod>
    <JadeMethod name="setSealedDT" id="5c521dd0-542a-4aec-9a36-44da0d40effe">
        <updating/>
        <source>setSealedDT( _value : TimeStamp ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 March 2015	cnwndl1	Initial creation	Par 35828

*/

vars

begin

	self.sealedDT := _value;

epilog

end;</source>
        <Parameter name="_value" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="3313ad3d-0077-4700-9f18-725377c94e04">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 March 2015	cnwndl1	Initial creation

*/

vars

	size : Integer;
	baseIndex : Integer;
	index : Integer;
	checkStartAt : Integer;
	sealStr : String;

begin

	if self.sealType = null then
		app.raiseCMException(NO_Seal_type_selected,null,null);
		return;
	endif;
	
	//check for duplicates.
	size := allSealNums.size;
	if size &gt; 1 then
		foreach baseIndex in 1 to size do
			if baseIndex = size then
				//we are done
				break;
			else
				checkStartAt := baseIndex + 1;
			endif;
			sealStr := allSealNums[baseIndex];
			foreach index in checkStartAt to size do
				if sealStr = allSealNums[index] then
					app.raiseCMWarning1(Seal_value_been_inclu_multi_ti, sealStr, null, self, null );
					return;
				endif;
			endforeach;
		endforeach;
	endif;

epilog

end;</source>
    </JadeMethod>
</Class>
