<Class name="CMQF_ExportRcvdLate">
    <JadeMethod name="setFromAgent" id="f2b5eb1a-301d-47b7-a3e7-5d6639427ba7">
        <updating/>
        <source>setFromAgent(_agent : CMUI_ReportAgent input) updating;
//----------------------------------------------------------------
//	Created:	21 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	inheritMethod(_agent);
	if _agent.isRowIncluded(ETRow_OnDate) then
		self.endDate.setDate(31,12,9999);
	endif;

end;</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
