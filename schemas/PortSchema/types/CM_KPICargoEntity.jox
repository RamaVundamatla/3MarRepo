    <JadeMethod name="accumulate" id="b15269f7-a159-42b3-a53c-7af563517250">
        <updating/>
        <source>accumulate(kpi : CM_KPICargoEntity) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 December 2025	navhn30	 MTN-36753: MTN | KPI REST API - Cargo

*/

vars
	
	cargoDtl 		: CM_KPICargoDtl;
begin
	self.totalQty := (kpi.totalQty + self.totalQty);
	self.totalVolume := (kpi.totalVolume + self.totalVolume);
	self.totalWeight := (kpi.totalWeight + self.totalWeight);
	self.myCargoType := kpi.myCargoType;
	if self.myCargoType.isContainer  then	
		cargoDtl:=kpi.allKPICargoDetails[20];
		if cargoDtl &lt;&gt; null then
			self.total20:=self.total20 + cargoDtl.totalItems;
		endif;
		cargoDtl:=kpi.allKPICargoDetails[30];
		if cargoDtl &lt;&gt; null then
			self.total30:=self.total30 + cargoDtl.totalItems;
		endif;
		cargoDtl:=kpi.allKPICargoDetails[40];
		if cargoDtl &lt;&gt; null then
			self.total40:=self.total40 + cargoDtl.totalItems;
		endif;
		cargoDtl:=kpi.allKPICargoDetails[45];
		if cargoDtl &lt;&gt; null then
			self.total45:=self.total45 + cargoDtl.totalItems;
		endif;
		cargoDtl:=kpi.allKPICargoDetails[53];
		if cargoDtl &lt;&gt; null then
			self.total53:=self.total53 + cargoDtl.totalItems;
		endif;		
	endif;	
	self.totalTEU := self.getTEU();


epilog

end;</source>
        <Parameter name="kpi" type="CM_KPICargoEntity"/>
    </JadeMethod>
    <JadeMethod name="addTransaction" id="1b79fc40-5fae-44ad-bafa-62259e3d0e68">
        <updating/>
        <source>addTransaction(_tx : CM_TITransaction) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Sep 2010	cnwdap1	Initial creation
20 May 2016	cnwkpd1	TFS 2021 - Stop trying to create CM_KPICargoDtl for non-containers, as these are
					not required, and resulted in decimal overflow errors
					
*/

vars
	ti 		: CM_TrackedItem;
	isoType	: CM_ISOType;
	length	: Integer;
	kpiDtl	: CM_KPICargoDtl;
begin
	// add to collections
	ti := _tx.myTrackedItem;
	
	if self.allTransactions.includes(_tx) then // TFS 44804 to do task processing calls this code twice.
		return; // TFS 44804
	endif;

	self.allTransactions.add(_tx);
	self.allTrackedItems.addNoDuplicates(ti, false);
	
	// add to totals
	self.totalItems := self.totalItems + 1;
	
	if CM_Container.hasInstance(ti) then
		self.totalQty := self.totalQty + 1;
		self.totalTEU := self.totalTEU + ti.getNumTEU.Integer;
		length:=ti.getActualLength().Integer;
		self.totalWeight := self.totalWeight + ti.totalWeight;
	else
		length := null;
		self.totalQty := self.totalQty + _tx.totalQuantity.max(1);
		if ti.myCargoType.isBreakBulkMulti or ti.myCargoType.isBulkMulti then
			self.totalVolume := self.totalVolume + _tx.totalVolume; // ti.getMyCargoVolume;
			self.totalWeight := self.totalWeight + _tx.totalWeight;
		else
			self.totalVolume := self.totalVolume + ti.totalVolume;  //ti.getMyCargoVolume;
			self.totalWeight := self.totalWeight + ti.totalWeight;
		endif;
	endif;
	
	// TFS 2021 - only create detail for containers
	if length &lt;&gt; null then
		// create/update a KPICargoDetail object for this transaction
		kpiDtl := self.allKPICargoDetails[length];
		if kpiDtl = null then
			create kpiDtl persistent;
			kpiDtl.setForCreate(self, length);
		endif;
		kpiDtl.addTrackedItem(ti);
	endif;
	
epilog

end;</source>
        <Parameter name="_tx" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="getAllTrackedItems" id="71165e40-0b76-4522-babe-7e8d4f8ee575">
        <source>getAllTrackedItems(_contLength : Integer; _tiSet : ObjectArray input);
/*

Date		    Who			Reason
02 November 2010	cnwas3	  Initial creation
14 Mar 2011	cnwkpd1	PAR #27142 - Correct handleDeletedObject exception arming

*/
vars
	obj : Object;
	ti : CM_TrackedItem;	
	invalidTI : Boolean;
	id : String;
	
begin
	if _tiSet = null then
		return;
	endif;	
		
	on Exception do app.handleDeletedObject(exception, ti, invalidTI);
	
	if _contLength &lt;&gt; null then
		foreach ti in self.allTrackedItems do			
			if ti.CM_Container.matchesLength(_contLength) then
				_tiSet.add(ti);
			endif;
		endforeach;	
	else		
		foreach ti in self.allTrackedItems do				
			id := ti.id;
			if not invalidTI then
				_tiSet.add(ti);				
			endif;
			invalidTI := false;
		endforeach;	
	endif;
	
epilog	
		
end;</source>
        <Parameter name="_contLength" type="Integer"/>
        <Parameter name="_tiSet" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTEU" id="a7987c2e-d756-49c6-8b76-eab11affe57f">
        <source>getTEU() : Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 December 2025	navhn30	 MTN-36753: MTN | KPI REST API - Cargo

*/

vars
	ct  : CM_CargoType;
begin
	ct	:=self.myCargoType;
	
	if ct.isContainer then
		return self.getTEU20() + self.getTEU30 + self.getTEU40 + self.getTEU45 + self.getTEU53;
	else
		return self.getTEUGC();
	endif;
	
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getTEU20" id="79e34b82-a2e1-4bc1-b265-7a1b6a0eeedc">
        <source>getTEU20() : Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 December 2025	navhn30	 MTN-36753: MTN | KPI REST API - Cargo

*/

vars
	ct : CM_CargoType;
begin	
	ct:=self.myCargoType;
	if ct.isContainer then
		return self.total20 * ct.getTEUConversionValue(TEUConversionIndex20);
	endif;
	
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
