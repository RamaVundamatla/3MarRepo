<Class name="PortDumpLoadSchema" id="ec7efa3c-e33f-4c61-a21a-338956158d9d">
    <superclass name="PortSchema"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <ImplicitInverseRef name="myObjectArray" id="50e28b9c-cf44-4c6f-ac3b-1cf81fcbd960">
        <memberTypeInverse/>
        <type name="ObjectArray"/>
    </ImplicitInverseRef>
    <JadeMethod name="doDump" id="9cf89484-56b3-4bd7-a50a-b4dd8303fffc">
        <source>doDump();

vars
	js: JadeScript;
	result: Boolean;
begin
	write method.name&amp;" Started.";
	result := false;
	create js transient;
	js.exportData;
	result := true;
epilog
	if result then
		write method.name&amp;" Completed.";
	else
		write method.name&amp;" Crashed.";
	endif;
	delete js;
end;</source>
    </JadeMethod>
    <JadeMethod name="getTxnTypeFromOldClass" id="e9183275-b9ce-44db-a63c-b8b26f83d2b6">
        <source>getTxnTypeFromOldClass(_class:String):Integer;
//-----------------------------------------
//Created: May 2004 By: cnwrs1
//-----------------------------------------
vars

begin

	if _class = "CM_HMS_AddVoyageDelay"  then
		return TRANS_TYPE_AddVoyageDelay;
	elseif _class = "CM_HMS_EditVoyageDelay"  then
		return TRANS_TYPE_EditVoyageDelay;
	elseif _class = "CM_HMS_DeleteVoyageDelay"  then
		return TRANS_TYPE_DeleteVoyageDelay;
	elseif _class = "CM_HMS_AddVoyage"  then
		return TRANS_TYPE_HMSVoyageAdd;
	elseif _class = "CM_HMS_EditVoyage"  then
		return TRANS_TYPE_HMSVoyageEdit;
	elseif _class = "CM_HMS_DeleteVoyage"  then
		return TRANS_TYPE_HMSVoyageArchive;
	elseif _class = "CM_HMS_ConfirmActualMove"   then
		return TRANS_TYPE_ConfirmActualMove;
	elseif _class = "CM_HMS_ConfirmPlanMove"  then
		return TRANS_TYPE_ConfirmPlanMove;
	elseif _class = "CM_HMS_AddMovement"  then
		return TRANS_TYPE_AddMovement;
	elseif _class = "CM_HMS_EditMovement"  then
		return TRANS_TYPE_EditMovement;
	elseif _class = "CM_HMS_DeleteMovement"  then
		return TRANS_TYPE_ArchiveMovement;				
	elseif _class = "CM_HMS_EditMovementTime"  then
		return TRANS_TYPE_EditMovementTime;				
	elseif _class = "CM_HMS_ResourceBooked"  then
		return TRANS_TYPE_ResourceBooked;				
	elseif _class = "CM_HMS_ResourceCancelled"  then
		return TRANS_TYPE_ResourceCancelled;										
	endif;
	
//	app.raiseCMException1(ERR_INVALID_TRANSTYPE, _class.String, 'type', null);
	
	return null;
end;</source>
        <Parameter name="_class" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
