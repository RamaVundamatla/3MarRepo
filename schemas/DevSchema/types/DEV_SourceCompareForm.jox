    <JadeMethod name="setupForm" id="b1d8b6ec-045c-43f2-8972-50c26843d436">
        <updating/>
        <source>setupForm() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 November 2021	navpw1	Initial creation TFS: 52202

*/

vars
	type,
	remaining 			: Integer;
	comparisonRunning 	: Boolean;
	
begin
	self.centreWindow;
	self.caption := "Source Compare " &amp; app.myCnKarmaCntrl.environmentId.toUpper;
	
	if self.getTimerStatus(self.Timer_Refresh, type, remaining) then
		self.endTimer(self.Timer_Refresh);
	endif;
	
	self.beginTimer(5000, Timer_Continuous, self.Timer_Refresh);
	
	
	//Check Shared Transient/Mutex and disable menu buttons
	comparisonRunning := app.mySourceCompareRoot.isRunningComparison;
	
	self.mnuRun7DayComparison.enabled := not comparisonRunning;
	self.mnuRunFullComparison.enabled := not comparisonRunning;
	
	if comparisonRunning then
		self.mnuRun7DayComparison.caption := "Run 7 Day Comparison (Already in progress by another user)";
		self.mnuRunFullComparison.caption := "Run Full Comparison (Already in progress by another user)";
		self.slStatus.caption := "Source Comparison in progress - please wait";
		self.setTaskBarState(1);
	endif;
	
	self.frmModalDialog.height := 100;
	self.frmModalDialog.width := 400;
	self.frmModalDialog.centreWindow;
	self.frmModalDialog.top := 50;

	self.frmProgressCtr.move(0,0,self.frmModalDialog.clientWidth,self.frmModalDialog.clientHeight);
	self.lblModalMessage.move(0,10,self.frmModalDialog.width,40);
	self.lblModalMessage.alignment := Frame.Alignment_Center_Middle;
	self.lblModalInfo.move(0,60,self.frmModalDialog.width,20);
	self.lblModalInfo.alignment := Frame.Alignment_Center_Middle;
	self.pbProgressBar.move(10,40,self.frmModalDialog.width-25,self.pbProgressBar.height);
	self.pbProgressBar.height := 20;		// set in painter when able
	self.pbProgressBar.foreColor := Blue;
	self.pbProgressBar.backColor := White;
	self.pbProgressBar.thinClientUpdateInterval := 1000;
	self.pbProgressBar.showTaskBarProgress := true;
	self.lblModalMessage.visible := true;
	self.lblModalInfo.visible := true;
	self.pbProgressBar.visible := true;
	self.frmModalDialog.visible := false;
	
	if self.isGuineaPig then
		self.mnuSeparator1.visible := true;
		self.mnuResultsNew.visible := true;
	endif;
	
	if process.isPW then
		self.mnuUnitTestReportMaintanence.visible := true;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="60025620-2696-40b4-8da0-6a43603188a6">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 August 2022	navpw1	Initial creation

*/

vars
	comparisonRunning : Boolean;
	
begin
	if not eventTag = self.Timer_Refresh then
		return;
	endif;
	
	//Check Shared Transient/Mutex and disable menu buttons
	comparisonRunning := app.mySourceCompareRoot.isRunningComparison;
	
	self.mnuRun7DayComparison.enabled := not comparisonRunning;
	self.mnuRunFullComparison.enabled := not comparisonRunning;
	
	if not comparisonRunning then
		self.slStatus.caption := "";
		self.mnuRun7DayComparison.caption := "Run 7 Day Comparison";
		self.mnuRunFullComparison.caption := "Run Full Comparison";
		self.setTaskBarState(0);
	else
		self.setTaskBarState(1);
		self.slStatus.caption := "Source Comparison in progress - please wait";
		self.mnuRun7DayComparison.caption := "Run 7 Day Comparison (Already in progress by another user)";
		self.mnuRunFullComparison.caption := "Run Full Comparison (Already in progress by another user)";
	endif;
	
epilog

end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
