    <JadeMethod name="btnDeleteDelay_click" id="0f164581-8441-4854-aaf1-3979f4320b95">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDeleteDelay_click(btn: Button input) updating;
//--------------------------------------------------
// Created:	11 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	voyageDelay:		CMIF_HMS_VoyageDelay;
	msgBoxType: 			Integer;
begin 
	if not checkSecurity(PmHMSVoyageMaint,"HMS Voyage") then
		return;
	endif;	

	// voyage delay object associated with selected row
	voyageDelay := self.tblDelays.accessRow(self.tblDelays.row).itemObject.CMIF_HMS_VoyageDelay;
	if voyageDelay &lt;&gt; null then
		// Confirm deletion
		msgBoxType := MsgBox_Yes_No+MsgBox_Question_Mark_Icon+MsgBox_Default_Second;
		if app.msgBox("Delete '" &amp; voyageDelay.myDelay.description &amp; ' occuring on ' &amp; voyageDelay.startTime.date.shortFormatJMT() 
						&amp; ' : ' &amp; voyageDelay.startTime.Time.userFormat($CM_HMS_Time24Hour), "Confirm Delete", msgBoxType)=MsgBox_Return_Yes then
			// OK Clicked: Proceed with delete
			// delete movement from collection (this is automatic with inv references)	
			delete voyageDelay;
			self.loadDelayTable();
		else
			// Delete was cancelled
		endif;	
	endif;
	self.setDelayButtonState();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
