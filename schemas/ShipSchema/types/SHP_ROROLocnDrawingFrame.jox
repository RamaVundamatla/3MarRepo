    </JadeMethod>
    <JadeMethod name="doRedrawWeightsAndHeights" id="b896fd4d-2743-428d-8466-6a885b3c08f6">
        <updating/>
        <source>doRedrawWeightsAndHeights(_locnDefn : CM_ROROLocnDefnVoyage; _x,_y : Real; _colour : Integer; _width,_height : Integer) updating;
/*
Date		    Who			Reason
25 October 2011	cnwas3	  Initial creation: par 28401
*/

vars	
	textX,textY 			: Real;
	labelWidth, weight, 
	weightMax, height, 
	heightMax, 
	gap,labelHeight 		: Real;
	label 					: String;
	scrollingFrame 			: SHP_ROROScrollingFrame;	
	drawingColour			: Integer;
begin
	
	drawingColour := _colour; //cnwas3 par 28545
	
	if self.myROROLocnDrawingController.modeView = ShpDisplayMode_ColCodeLoad then
			_locnDefn.getWeightsForLocn(PLANNING_MODE, true,weight, weightMax);
	elseif self.myROROLocnDrawingController.modeView = ShpDisplayMode_Proposed then	//cnwas3 par 28545
			_locnDefn.getProposedWeightsForLocn(weight,weightMax);
	else
			_locnDefn.getWeightsForLocn(REAL_MODE, true,weight, weightMax);
	endif;
	
	weight := weight / 1000;
	weightMax := weightMax / 1000;
		
	label := weight.asStringJMTWithPrecision(0,false) &amp; "/" &amp; weightMax.asStringJMTWithPrecision(0,false) &amp; "t";
	if weight &gt; weightMax then	//cnwas3 par 28545
		drawingColour := Red;
	endif;
	
	if label = null then		
		return;
	endif;
	
	textX := _x;
	textY := _y;	
	
	scrollingFrame := self.myScrollingFrame;
	
	scrollingFrame.drawFontItalic := true;
	scrollingFrame.drawFontBold := false;		
	gap := 5;	
	scrollingFrame.drawFontSize := 9;
	while scrollingFrame.drawTextWidth(label) + gap &gt; _width do		
		scrollingFrame.drawFontSize := scrollingFrame.drawFontSize - 1;	
		if scrollingFrame.drawFontSize &lt; 7 then		
			break;
		endif;
	endwhile;
		
	labelWidth := scrollingFrame.drawTextWidth(label);	
	labelHeight := scrollingFrame.getTextHeight(label);
				
	scrollingFrame.drawTextRotation := 0;
	scrollingFrame.drawTextCharRotation := 0;				
	
	textX := textX + (_width - labelWidth)/2;	
	
	
	scrollingFrame.drawSolidRectangle(_x,_y+2,textX+1.5*labelWidth,textY+2.5*labelHeight,self.backColor);
	scrollingFrame.drawTextAt(label,textX,textY, drawingColour);	
	
	
	scrollingFrame.drawFontItalic := false;
	if self.myROROLocnDrawingController.modeView = ShpDisplayMode_Proposed then	//cnwas3 par 28545
			height := _locnDefn.getProposedHeightMetresTIs();
	elseif self.myROROLocnDrawingController.modeView = ShpDisplayMode_ColCodeLoad then
			height := _locnDefn.getHeightMetresTIs(PLANNING_MODE, true);
	else
			height := _locnDefn.getHeightMetresTIs(REAL_MODE, true);
	endif;
	heightMax := _locnDefn.getMaxHeightLimit();
		
	label := (heightMax - height).asStringJMTWithPrecision(1,false) &amp; "m";	
	if height &gt; heightMax then			//cnwas3 par 28545
		drawingColour := Red;
	else
		drawingColour := _colour;
	endif;
		
	scrollingFrame.drawFontSize := 9;	
		while scrollingFrame.drawTextWidth(label) + gap &gt; _width do		
			scrollingFrame.drawFontSize := scrollingFrame.drawFontSize - 1;	
			if scrollingFrame.drawFontSize &lt; 7 then		
				break;
			endif;
		endwhile;			
		
	textX := _x + (_width - scrollingFrame.drawTextWidth(label))/2;
	textY := textY + labelHeight;
	
	
	scrollingFrame.drawTextAt(label,textX,textY,drawingColour);
	if textY.Integer &gt; self.minDrawingHeight then
		self.minDrawingHeight := textY.Integer;
	endif;

	
epilog

end;</source>
        <Parameter name="_locnDefn" type="CM_ROROLocnDefnVoyage"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_width" type="Integer"/>
        <Parameter name="_height" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="178e9fbe-00ea-41de-ad0f-d238485cd209">
        <source>doResize();
/*
Date		    Who			Reason
26 July 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars

begin
	self.myScrollableFrame.repositionScrollBars();	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="drawLocations" id="42c3c37b-c95a-4ce7-a88a-3036862223a3">
        <updating/>
        <source>drawLocations(_locationDefns : CM_RORODeckItemByOrd1Ord2;
			_gridDict : CM_ObjectByX1Y1X2Y2Dict input;
			_containerDrawingController : SHP_ROROLocnDrawingController input) updating, protected;
// cnwjre1 Feb 2012 28859 revise drawing container locations 
vars
	x1, y1	 		: Integer;
	cellWidth,
	cellHeight		: Integer;
	startCol,
	startRow		: Integer;
	starterX,
	starterY		: Integer;
	colGap,
	rowGap			: Integer;
	iterator	: Iterator;
	locnDefn	: CM_ROROLocnDefnVoyage;
	deckItem	: CM_DeckItem;
	row, column : Integer;
	rowEnd,
	columnEnd	: Integer;
	rowFactor,
	colFactor	: Integer;
	obj			: Object;
	colDict,
	rowDict		: CM_ObjectByX1Y1X2Y2Dict;
	priorDeckItem,
	roroDeckItem	: SHP_RORODeckItem;
	invalidLocn : Boolean;
begin
	iterator := _locationDefns.createIterator();
	if iterator = null then
		return;
	endif;
	on Exception do app.handleDeletedObject(exception, locnDefn, invalidLocn);	
	
	// first pass to get bounds and create intermediate objects
	create rowDict transient;
	create colDict transient;
	startCol := 999999;
	startRow := 999999;
	while iterator.next(deckItem) do
		locnDefn  := deckItem.CM_ROROLocnDefnVoyage;

		if not locnDefn.myLayout.isVisible then // PAR 28990
			continue;
		 endif;
		 if invalidLocn then // PAR 28990
			continue;
		endif;

		 _locationDefns.getIteratorKeys(column, row, iterator);
		if not locnDefn.isVerticalOrientation then
			cellWidth := _containerDrawingController.locnDefnWidth;
			cellHeight := _containerDrawingController.locnDefnHeight;
		else
			cellWidth := _containerDrawingController.locnDefnHeight;
			cellHeight := _containerDrawingController.locnDefnWidth;
		endif;
		rowEnd := row + cellHeight - 1;
		columnEnd := column + cellWidth - 1;
		create roroDeckItem;
		roroDeckItem.myDeckItem := locnDefn;
		roroDeckItem.rowStart := row;
		roroDeckItem.rowEnd := rowEnd;
		roroDeckItem.columnStart := column;
		roroDeckItem.columnEnd := columnEnd;
		roroDeckItem.cellHeight := cellHeight;
		roroDeckItem.cellWidth := cellWidth;
		roroDeckItem.orientation := locnDefn.orientation;
		roroDeckItem.code := locnDefn.code;	// debug convenience
		rowDict.putAtKey(roroDeckItem.rowEnd, roroDeckItem.rowStart, roroDeckItem.columnStart, roroDeckItem.columnEnd, roroDeckItem);
		colDict.putAtKey(roroDeckItem.columnStart, roroDeckItem.columnEnd, roroDeckItem.rowStart, roroDeckItem.rowEnd, roroDeckItem);

		// get the start points
		if column &lt; startCol then
			startCol := column;
		endif;
		if row &lt; startRow then
			startRow := row;
		endif;
	endwhile;
	
	// set x and y based on the start points
	delete iterator;
	iterator := colDict.createIterator();
	priorDeckItem := null;
	starterX := self.leftSideMargin;
	starterY := self.leftSideMargin;
	while iterator.next(obj) do
		roroDeckItem  := obj.SHP_RORODeckItem;
		x1 := starterX + roroDeckItem.columnStart - startCol;
		y1 := starterY + roroDeckItem.rowStart - startRow;
		roroDeckItem.x1 := x1;
		roroDeckItem.y1 := y1;
	endwhile;
	
	// shrink horizontal and vertical gaps between the items down to a half gap of 12
	iterator.reset();
	while iterator.next(obj) do
		roroDeckItem  := obj.SHP_RORODeckItem;
		if priorDeckItem &lt;&gt; null then
			colGap := roroDeckItem.columnStart - priorDeckItem.columnEnd;
		endif;
		if colGap &gt; 24 then
			colFactor := colFactor + (colGap - 12);
		endif;
		roroDeckItem.x1 := roroDeckItem.x1 - colFactor;
		priorDeckItem := roroDeckItem;
	endwhile;
	
	delete iterator;
	iterator := rowDict.createIterator();
	priorDeckItem := null;
	while iterator.next(obj) do
		roroDeckItem  := obj.SHP_RORODeckItem;
		if priorDeckItem &lt;&gt; null then
			rowGap := roroDeckItem.rowStart - priorDeckItem.rowEnd;
		endif;
		if rowGap &gt; 24 then
			rowFactor := rowFactor + (rowGap - 12);
		endif;
		roroDeckItem.y1 := roroDeckItem.y1 - rowFactor;
		priorDeckItem := roroDeckItem;
	endwhile;

	// print pass
	iterator.reset();
	starterX := self.leftSideMargin;
	starterY := self.leftSideMargin;
	x1 := self.leftSideMargin;
	y1 := self.leftSideMargin;
	while iterator.next(obj) do
		roroDeckItem  := obj.SHP_RORODeckItem;
		deckItem := roroDeckItem.myDeckItem;
		locnDefn  := deckItem.CM_ROROLocnDefnVoyage;
		
		x1 := roroDeckItem.x1;
		y1 := roroDeckItem.y1;

		self.drawLocnPos(locnDefn, x1, y1, _gridDict, _containerDrawingController);

	endwhile;

	self.myScrollableFrame.resizeScrollingFrame(self.minDrawingWidth,self.minDrawingHeight + _containerDrawingController.slotHeight);
	self.myScrollableFrame.scrollTopLeft();
	self.myScrollableFrame.repositionScrollBars();
epilog
	delete iterator;
	if rowDict &lt;&gt; null then
		rowDict.purge();	// delete the SHP_RORODeckItem instances
	endif;
	delete rowDict;
	delete colDict;
end;
</source>
        <access>protected</access>
        <Parameter name="_locationDefns" type="CM_RORODeckItemByOrd1Ord2"/>
        <Parameter name="_gridDict" type="CM_ObjectByX1Y1X2Y2Dict" usage="input"/>
        <Parameter name="_containerDrawingController" type="SHP_ROROLocnDrawingController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawLocationsAndSlots" id="1a6e3d10-bcf6-4d4f-a3d8-c1c312b6ab13">
        <updating/>
        <source>drawLocationsAndSlots(_locationDefns : CM_RORODeckItemByOrd1Ord2; _x1, _y1 : Integer; 
				_gridDict : CM_ObjectByX1Y1X2Y2Dict input;
				_locnDrawingController : SHP_ROROLocnDrawingController input) updating, protected;

/*
Date		    Who			Reason
12 July 2011	cnwas3	  	Initial creation: CCMS 1035 CargoSideView form
Feb 2012		cnwjre1		Revised
*/

vars
	tmpLocnDefn,
	scanLocnDefn,
	locnDefn				: CM_ROROLocnDefnVoyage;
	slotGap,
	slotCount,
	theColWidth,
	starterX,
	starterY,
	starterYslots,
	starterYslots2,
	starterXslots,
	starterRow,
	slotY,retainNoOfSlots,
	starterColumn			: Integer;
	maxSlots				: Integer;
	rowEnd					: Integer;
	scanRow,
	scanColumn				: Integer;
	cellWidth,
	cellHeight				: Integer;
	lastOrientation,
	lastColumn,
	lastRow					: Integer;
	outputRow,
	outputColumn			: Integer;
	columnIter				: Iterator;
	iterator 				: Iterator;
	deckItem				: CM_DeckItem;
	scanDeckItem			: CM_DeckItem;
	row, column 			: Integer;
	slotDefn				: CM_ROROSlotDefn;
	slotController			: CM_ROROSlotController;
	highRow,highPrevious	: Boolean;
	alreadyDisplayed		: ObjectArray;
	roroDeckItem			: SHP_RORODeckItem;
	obj						: Object;
	obj2					: Object;
	oa						: ObjectArray;
	oa2						: ObjectArray;
	dict					: CM_ObjectByX1Y1X2Y2Dict;
	colDict					: CM_RORODeckItemByOrd1Ord2;
	invalidLocn : Boolean;
begin

	if _locationDefns = null then
		return;
	endif;

	iterator := _locationDefns.createIterator();
	if iterator = null then
		return;
	endif;
	slotGap := 1;
	colDict := self.myCargoSideViewForm.allLocnDefnsByRowCol;
	columnIter := colDict.createIterator();

	on Exception do app.handleDeletedObject(exception, locnDefn, invalidLocn);	
	
	create alreadyDisplayed transient;
	create oa transient;
	theColWidth := _locnDrawingController.slotWidth;
	starterX := _x1;
	starterY := _y1;
	starterYslots := _y1 - 15;
	starterXslots := _x1;
	starterRow := 0;
	starterColumn := 0;
	
	outputRow := 1;
	outputColumn := 0;
	while iterator.next(deckItem) do
		locnDefn  := deckItem.CM_ROROLocnDefnVoyage;
		if alreadyDisplayed.includes(locnDefn) then
			continue;
		endif;
		_locationDefns.getIteratorKeys(column, row, iterator);
		if lastRow = 0 then
			lastRow := row;
			lastColumn := column;
			lastOrientation := locnDefn.orientation;
		endif;
		if not locnDefn.isVerticalOrientation then
			rowEnd := row + _locnDrawingController.locnDefnHeight - 1;
			cellWidth := _locnDrawingController.locnDefnWidth;
			cellHeight := _locnDrawingController.locnDefnHeight;
		else
			rowEnd := row + _locnDrawingController.locnDefnWidth - 1;
			cellWidth := _locnDrawingController.locnDefnHeight;
			cellHeight := _locnDrawingController.locnDefnWidth;
		endif;
		///if locnDefn.orientation = 1 and
		if (locnDefn.orientation = ROROLocn_PortStarboard or locnDefn.orientation = ROROLocn_OOTL_PS) and	// 30173 add OOTL orientation
		   column &lt;&gt; lastColumn then
			outputRow := outputRow + 1;
			outputColumn := 0;
			lastOrientation := locnDefn.orientation;
			lastColumn := column;
		///elseif locnDefn.orientation = 2 and
		elseif (locnDefn.orientation = ROROLocn_AftForward or locnDefn.orientation = ROROLocn_OOTL_AF) and	// 30173 add OOTL orientation
		   row &lt;&gt; lastRow then
			outputRow := outputRow + 1;
			outputColumn := 0;
			lastOrientation := locnDefn.orientation;
			lastRow := row;
		elseif locnDefn.orientation &lt;&gt; lastOrientation then
			outputRow := outputRow + 1;
			outputColumn := 0;
			lastOrientation := locnDefn.orientation;
		
		endif;
		if invalidLocn then // PAR 28990
			continue;
		endif;
		outputColumn := outputColumn + 1;
		
		create roroDeckItem;
		roroDeckItem.myDeckItem := locnDefn;
		roroDeckItem.rowStart := row;
		roroDeckItem.rowEnd := rowEnd;
		roroDeckItem.cellHeight := cellHeight;
		roroDeckItem.cellWidth := cellWidth;
		roroDeckItem.orientation := locnDefn.orientation;
		roroDeckItem.code := locnDefn.code;	// debug convenience
		roroDeckItem.y1 := outputRow;
		roroDeckItem.x1 := outputColumn;
		
		oa.add(roroDeckItem);
		
		alreadyDisplayed.add(locnDefn);
		
		// horizontal cell, all other cells in the same row to be shown on the same row
		///if locnDefn.orientation = 2 then
		if locnDefn.orientation = ROROLocn_AftForward or locnDefn.orientation = ROROLocn_OOTL_AF then	// 30173 add OOTL orientation
			colDict.startKeyGtr(row, column, columnIter);
			while columnIter.next(scanDeckItem) do
				scanLocnDefn  := scanDeckItem.CM_ROROLocnDefnVoyage;
				if alreadyDisplayed.includes(scanLocnDefn) then
					continue;
				endif;
				///if scanLocnDefn.orientation &lt;&gt; 2 then
				if scanLocnDefn.orientation &lt;&gt; ROROLocn_AftForward and scanLocnDefn.orientation &lt;&gt; ROROLocn_OOTL_AF then	// 30173 add OOTL orientation
					break;
				endif;
				colDict.getIteratorKeys(scanRow, scanColumn, columnIter);
				if scanRow &lt;&gt; row then
					break;
				endif;
				outputColumn := outputColumn + 1;
		
				if not scanLocnDefn.isVerticalOrientation then
					rowEnd := row + _locnDrawingController.locnDefnHeight - 1;
					cellWidth := _locnDrawingController.locnDefnWidth;
					cellHeight := _locnDrawingController.locnDefnHeight;
				else
					rowEnd := row + _locnDrawingController.locnDefnWidth - 1;
					cellWidth := _locnDrawingController.locnDefnHeight;
					cellHeight := _locnDrawingController.locnDefnWidth;
				endif;
				create roroDeckItem;
				roroDeckItem.myDeckItem := scanLocnDefn;
				roroDeckItem.rowStart := row;
				roroDeckItem.rowEnd := rowEnd;
				roroDeckItem.cellHeight := cellHeight;
				roroDeckItem.cellWidth := cellWidth;
				roroDeckItem.orientation := scanLocnDefn.orientation;
				roroDeckItem.code := scanLocnDefn.code;
				roroDeckItem.y1 := outputRow;
				roroDeckItem.x1 := outputColumn;
		
				oa.add(roroDeckItem);
		
				alreadyDisplayed.add(scanLocnDefn);
			endwhile;
		endif;
	endwhile;

	create dict transient;
	foreach obj in oa do
		roroDeckItem  := obj.SHP_RORODeckItem;
		row := roroDeckItem.y1;
		column := roroDeckItem.x1;
		dict.putAtKey(row, column, 0, 0, roroDeckItem);
	endforeach;

	// 29627 June 2012 handle stacks of differing heights - store the max row height in RORODeckItem cellX
	delete iterator;
	iterator := dict.createIterator();
	create oa2 transient;
	while iterator.next(obj) do
		roroDeckItem := obj.SHP_RORODeckItem;
		tmpLocnDefn  := roroDeckItem.myDeckItem;
		row := roroDeckItem.y1;
		column := roroDeckItem.x1;
		retainNoOfSlots := tmpLocnDefn.allROROSlotDefnByOrdinal.size();
		
		if starterRow = 0 then
			starterRow := row;
			maxSlots := retainNoOfSlots;
		endif;

		if row &lt;&gt; starterRow then	
			foreach obj2 in oa2 do
				roroDeckItem := obj2.SHP_RORODeckItem;
				roroDeckItem.cellX := maxSlots;
			endforeach;
			starterRow := row;
			maxSlots := 0;
			oa2.clear();
		endif;
		if retainNoOfSlots &gt; maxSlots then
			maxSlots := retainNoOfSlots;
		endif;
		oa2.add(obj);
	endwhile;
	foreach obj2 in oa2 do
		roroDeckItem := obj2.SHP_RORODeckItem;
		roroDeckItem.cellX := maxSlots;
	endforeach;
	starterRow := 0;
	starterColumn := 0;
	// 29627 end 

	self.beginBatchDrawing();
	delete iterator;
	iterator := dict.createIterator();
	while iterator.next(obj) do
		roroDeckItem := obj.SHP_RORODeckItem;
		tmpLocnDefn  := roroDeckItem.myDeckItem;
		row := roroDeckItem.y1;
		column := roroDeckItem.x1;
		
		if starterRow = 0 and starterColumn = 0 then
			starterRow := row;
			starterColumn := column;
			retainNoOfSlots := tmpLocnDefn.allROROSlotDefnByOrdinal.size();
		endif;
		
		if row &lt;&gt; starterRow then
			starterRow := row;
			starterX := _x1;
			starterXslots := _x1;
			starterY := starterY + _locnDrawingController.locnDefnHeight + _locnDrawingController.interLocnSlotsHeight;
			if highRow then
				starterY := starterY + (  _locnDrawingController.locnDefnWidth - _locnDrawingController.locnDefnHeight );
			endif;
			highRow := false;
			highPrevious :=false;
			starterColumn := column;			
			starterYslots := starterYslots + ((_locnDrawingController.slotHeight + slotGap) * retainNoOfSlots) + 70; //cnwas3 par 28357
			retainNoOfSlots := tmpLocnDefn.allROROSlotDefnByOrdinal.size();
		endif;
		
		
		
		if column &lt;&gt; starterColumn then	
			
			starterXslots := starterXslots + _locnDrawingController.slotWidth + _locnDrawingController.interLocnSlotsWidth;
			starterX := starterX + _locnDrawingController.locnDefnWidth + _locnDrawingController.interLocnSlotsWidth;	
			
			if highPrevious then
				starterX := starterX - (  _locnDrawingController.locnDefnWidth - _locnDrawingController.locnDefnHeight );
			endif;
			if tmpLocnDefn.allROROSlotDefnByOrdinal.size() &gt; retainNoOfSlots then
				retainNoOfSlots := tmpLocnDefn.allROROSlotDefnByOrdinal.size();
			endif;
		endif;
		
		//if tmpLocnDefn.orientation = 1 then
		if tmpLocnDefn.orientation = ROROLocn_PortStarboard or tmpLocnDefn.orientation = ROROLocn_OOTL_PS then	// 30173 add OOTL orientation
			highRow := true;	
			highPrevious := true;
		else
			highPrevious := false;
		endif;
		if self.isSideView then				
			// 29627 June 2012 handle stacks of differing heights - use the max row height from RORODeckItem cellX
			starterYslots2 := starterYslots;
			if roroDeckItem.cellX &gt; 0 then
				maxSlots := roroDeckItem.cellX;
				slotCount := tmpLocnDefn.allROROSlotDefnByOrdinal.size;
				if slotCount &lt; maxSlots then
					starterYslots2 := starterYslots2 + ((maxSlots - slotCount) * (_locnDrawingController.slotHeight + slotGap));
				endif;
			endif;
			slotY := starterYslots2;
			// end 29627
			self.drawSlotsLabelAndWeights(tmpLocnDefn,starterXslots,starterYslots2 + 10,Black,_locnDrawingController.locnDefnWidth,_locnDrawingController.slotHeight,false);//draw the slots' labels
			slotY := slotY - (_locnDrawingController.slotHeight + slotGap) + 10 + _locnDrawingController.slotHeight;
			foreach slotDefn in tmpLocnDefn.allROROSlotDefnByOrdinal reversed do
				slotY := slotY + (_locnDrawingController.slotHeight + slotGap);
				slotController := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
				self.drawSlot(slotDefn.CM_ROROSlotDefnVoyage, slotController, starterXslots, slotY, _gridDict, _locnDrawingController);
			endforeach;
			self.drawSlotsLabelAndWeights(tmpLocnDefn,starterXslots,slotY +_locnDrawingController.slotHeight,Black,_locnDrawingController.locnDefnWidth,_locnDrawingController.slotHeight,true);//draw the slots' weights									
		else			
			self.drawLocnPos(tmpLocnDefn, starterX, starterY, _gridDict, _locnDrawingController);
		endif;	
		
	endwhile;	
	self.myScrollableFrame.resizeScrollingFrame(self.minDrawingWidth,self.minDrawingHeight + _locnDrawingController.slotHeight);
	self.myScrollableFrame.scrollTopLeft();
	self.myScrollableFrame.repositionScrollBars();
epilog
	self.endBatchDrawing();
	delete iterator;		// PAR #27874
	delete columnIter;
	delete alreadyDisplayed;
	if oa &lt;&gt; null then
		oa.purge();		// delete the SHP_RORODeckItem instances
	endif;
	delete oa;
	delete oa2;
	delete dict;
end;</source>
        <access>protected</access>
        <Parameter name="_locationDefns" type="CM_RORODeckItemByOrd1Ord2"/>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_gridDict" type="CM_ObjectByX1Y1X2Y2Dict" usage="input"/>
        <Parameter name="_locnDrawingController" type="SHP_ROROLocnDrawingController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawLocnDefnLabel" id="6c26598b-f6c3-4919-8de6-42217fadbab9">
        <updating/>
        <source>drawLocnDefnLabel(_locnDefn : CM_ROROLocnDefnVoyage; _x,_y : Real ; _colour : Integer; _width,_height : Integer) updating;
/*
Date		    Who			Reason
18 July 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	label : String;
	textX,textY : Real;
	labelWidth, labelHeight : Real;
	scrollingFrame : SHP_ROROScrollingFrame;
begin
	if _locnDefn &lt;&gt; null then
		label := _locnDefn.code;
	else
		return;
	endif;
	
	textX := _x;
	textY := _y;
	
	scrollingFrame := self.myScrollingFrame;
	
	scrollingFrame.drawFontSize := 13;
	
	while scrollingFrame.drawTextWidth(label) + 15 &gt; _width do
		scrollingFrame.drawFontSize := scrollingFrame.drawFontSize - 1;
		if scrollingFrame.drawFontSize &lt; 7 then	//cnwas3 par 28382
			break;
		endif;
	endwhile;
	
	labelWidth := scrollingFrame.drawTextWidth(label);
	labelHeight := scrollingFrame.drawTextHeight(label);
				
	scrollingFrame.drawTextRotation := 0;
	scrollingFrame.drawTextCharRotation := 0;
	
	if _locnDefn.orientation = ROROLocn_PortStarboard or
	   _locnDefn.orientation = ROROLocn_OOTL_PS then		// 29431 Apr 2012 and OOTL rotated
		scrollingFrame.drawTextRotation := 270;
		scrollingFrame.drawTextCharRotation := 270;
		textX := textX  + (_height - labelHeight)/2 + labelHeight;
		textY := textY + (_width - labelWidth)/2;
	else		
		textX := textX + (_width - labelWidth)/2;		
		textY := textY + (_height - labelHeight)/2;		
	endif;
			
	scrollingFrame.drawTextAt(label,textX,textY,_colour);
epilog

end;</source>
        <Parameter name="_locnDefn" type="CM_ROROLocnDefnVoyage"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_width" type="Integer"/>
        <Parameter name="_height" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawLocnPos" id="eecf7712-d38d-446f-91fb-d60faeaa7766">
        <updating/>
        <source>drawLocnPos(_locnDefn : CM_ROROLocnDefnVoyage; x1, y1 : Integer; 
		_gridDict : CM_ObjectByX1Y1X2Y2Dict input;
		_containerDrawingController : SHP_ROROLocnDrawingController input) updating, protected;
/*
Date		    Who			Reason
12 July 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	splitWeight,
	x2,
	y2				: Integer;
	tmpTI	: CM_TrackedItem;

begin

	if _locnDefn = null then
		app.raiseCMException1(MethodWithNullParam, '_slot', null, null);
		return;
	endif;
	
	if not _locnDefn.isVerticalOrientation then			//2 = horizontal
		x2 := x1 + _containerDrawingController.locnDefnWidth;
		y2 := y1 + _containerDrawingController.locnDefnHeight; 
	else
		x2 := x1 + _containerDrawingController.locnDefnHeight;
		y2 := y1 + _containerDrawingController.locnDefnWidth; 
	endif;
	
	_containerDrawingController.setFromLocnDefn(_locnDefn, x1, y1, x2, y2);

	_containerDrawingController.setDefaultFont(self);
	_containerDrawingController.drawCurrentObject(self);
	
	_containerDrawingController.setLabelFont(self);
	
	_gridDict.putAtKey(x1, y1, x2, y2, _locnDefn);
	
	if x2 &gt; self.minDrawingWidth then
		self.minDrawingWidth := x2;
	endif;
	if y2 &gt; self.minDrawingHeight then
		self.minDrawingHeight := y2;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_locnDefn" type="CM_ROROLocnDefnVoyage"/>
        <Parameter name="x1" type="Integer"/>
        <Parameter name="y1" type="Integer"/>
        <Parameter name="_gridDict" type="CM_ObjectByX1Y1X2Y2Dict" usage="input"/>
        <Parameter name="_containerDrawingController" type="SHP_ROROLocnDrawingController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawObject" id="d7e88445-6019-4e97-8a40-847b33e1cc13">
        <updating/>
        <source>drawObject(_obj: Object; _drawingController: CMUI_GridDrawingController input) updating;
/*
Purpose:			
Date		Who		Reason
01 August 2011	cnwab1	Initial creation
*/

vars
	x1, y1, x2, y2	: Integer;
begin

	if self.getPointsForObject(_obj, x1, y1, x2, y2) then
	
		self.drawObjectAt(_obj, x1, y1, x2, y2, _drawingController);
	else
		inheritMethod(_obj, _drawingController);

	endif;


epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_drawingController" type="CMUI_GridDrawingController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawObjectAt" id="b268ce88-0c7b-4fe1-8c4b-70a6cf704932">
        <updating/>
        <source>drawObjectAt(_obj: Object; _x1: Integer; _y1: Integer; _x2: Integer; _y2: Integer; _drawingController: CMUI_GridDrawingController input) updating;
/*
Purpose:			
Date		Who		Reason
01 August 2011	cnwab1	Initial creation
*/

vars

begin

	self.myROROLocnDrawingController.drawObjectAt(self, _obj, _x1, _y1, _x2, _y2, _drawingController);
//	inheritMethod(_obj, _x1, _y1, _x2, _y2, _drawingController);

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
        <Parameter name="_drawingController" type="CMUI_GridDrawingController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawSelf" id="ff3fd94a-0603-445a-acad-07b5907a8c25">
        <updating/>
        <source>drawSelf() updating;
/*
Date		    Who			Reason
12 July 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	tmpDrawingController	: SHP_ROROLocnDrawingController;
begin
	
	tmpDrawingController := self.myROROLocnDrawingController;
	
	self.allDrawnObjects.clear;	
	
	self.myScrollingFrame.clearGraphics();
	
	tmpDrawingController.setDefaultFont(self);

	// 28859 Dec 2011 revised Feb 2012
	if not self.isSideView then
		self.drawLocations(self.myCargoSideViewForm.myROROLocnDrawingController.allLocnDefnsByRowCol, self.allDrawnObjects, tmpDrawingController);
	else
		self.drawLocationsAndSlots(self.myCargoSideViewForm.allOrderedROROLocns, self.leftSideMargin, self.leftSideMargin, self.allDrawnObjects, tmpDrawingController);
	endif;
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="drawSlot" id="65ad8d34-61f7-4b1e-a621-8e4ddcc7d588">
        <updating/>
        <source>drawSlot(_slotDefn : CM_ROROSlotDefnVoyage; _slot : CM_ROROSlotController; _x1, y1 : Integer; 
		_gridDict : CM_ObjectByX1Y1X2Y2Dict input;
		_containerDrawingController : SHP_ROROLocnDrawingController input) updating, protected;
/*
Date		    Who			Reason
12 July 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	hadDuplicates, doDraw, is40	: Boolean;
	splitWeight,
	x1, x2, dictX2, dictX1,
	y2, fortyFootExtension			: Integer;
	tmpTI	: CM_TrackedItem;
	roroReq : CM_RORORequest;
	
	//cnwmc5 - PAR 31651
	tis : CM_TIArray;
begin

	if _slot = null then
		app.raiseCMException1(MethodWithNullParam, '_slot', null, null);
		return;
	endif;
	
	
	fortyFootExtension := (_containerDrawingController.slotWidth + ( 2 * _containerDrawingController.interLocnSlotsHeight));
	doDraw := true;
	
	x1 := _x1;
	dictX1 := x1;
	x2 := x1 + _containerDrawingController.slotWidth;
	dictX2 := x2;
	y2 := y1 + _containerDrawingController.slotHeight; 

	if _containerDrawingController.modeView = ShpDisplayMode_ColCodeLoad then
		roroReq := _slot.myRORORequestLoad;
		if roroReq &lt;&gt; null then
			if roroReq.isBackEndRequest() then
//	28939			return;
//			endif;
				
//			if roroReq &lt;&gt; null then
				doDraw := false;
			else
	//			is40 := (roroReq.getAttrIs40() or roroReq.getAttrIs30() or roroReq.getAttrIs45() or roroReq.getAttrIs53()); // PAR 30022 
				is40 := roroReq.getAttrIsNOT20(); // PAR 30253
				if is40 then // PAR 30022 
				// PAR 30022  if roroReq.getAttrIs40() then
					x1 := x1 - fortyFootExtension;
				endif;
			endif;
		else
			tmpTI := _slot.allTrackedItems.first();
			if tmpTI &lt;&gt; null and (tmpTI.isForty() or tmpTI.is30 or tmpTI.is45 or tmpTI.is53) then // PAR 30022
			/* PAR 29050
				if tmpTI.myPrimaryActualLocation &lt;&gt; _slot then // Aft
//		28939				return;
					// PAR 29050
					if tmpTI.getVoyageWLEUnactioned(false) = null then // NO Colour Coding
						//doDraw := false;
					endif;
				else
					// PAR 29050
					if tmpTI.isToBeDischargedHere()  
					and tmpTI.getVoyageWLEUnactioned(false) &lt;&gt; null then // Has Discharge CC
					else // No Discharge CC
						// x1 := x1 - fortyFootExtension;
					endif;
				endif;
				*/
			endif;
		endif;
	elseif _containerDrawingController.modeView = ShpDisplayMode_Proposed then		//cnwas3 par 28401		
		/*
		****************************
			cnwmc5 - PAR 31651
		****************************
		*/
		create tis transient;
		
		_slot.getProposedTIs(tis);
		if not tis.isEmpty then
			roroReq := _slot.myRORORequestLoad;
			tmpTI := tis.first;
			if roroReq &lt;&gt; null
			and (tmpTI.isPlannedToShip() or roroReq.isComplete) then
				if not tmpTI.is20 
				and not roroReq.isBackEndRequest() then
					x1 := x1 - fortyFootExtension;
				endif;
			else
				if not tmpTI.is20 
				and not _slot.isBackEnd(tmpTI, REAL_MODE) then
					x1 := x1 - fortyFootExtension;
				endif;
			endif;
		endif;
		
		/*roroReq := _slot.myRORORequestLoad;
		if roroReq &lt;&gt; null then
			if roroReq.isBackEndRequest() then
//		28939			return;
//			endif;
				
//			if roroReq &lt;&gt; null then
				doDraw := false;
			else
				//is40 := (roroReq.getAttrIs40() or roroReq.getAttrIs30() or roroReq.getAttrIs45() or roroReq.getAttrIs53()); // PAR 30022 
				is40 := roroReq.getAttrIsNOT20(); // PAR 30253
				if is40 then  // PAR 30022 
				 // PAR 30022  if roroReq.getAttrIs40() then
					x1 := x1 - fortyFootExtension;
				endif;
			endif;
		else // nothing being loaded
			roroReq := _slot.myRORORequestDischarge;
			if roroReq &lt;&gt; null then // it is being discharged, so draw 2 X 20 slots
				if roroReq.isBackEndRequest() then
//		28939				return;
//				endif;
				
//				if roroReq &lt;&gt; null then
					doDraw := true; // PAR 29050 draw the aft as a 20 slot
				else
					doDraw := true; // PAR 29050 draw the fwd as a 20 slot
//	29050 do not extend as there is nothing here				if roroReq.getAttrIs40() then
//						x1 := x1 - fortyFootExtension;
//					endif;
				endif;				
			else
				tmpTI := _slot.allTrackedItems.first();
				if tmpTI &lt;&gt; null and (tmpTI.isForty() or tmpTI.is30 or tmpTI.is45 or tmpTI.is53) then
					if tmpTI.myPrimaryActualLocation &lt;&gt; _slot then
//		28939					return;
						doDraw := false;

					else
						x1 := x1 - fortyFootExtension;
					endif;
				endif;
			endif;
		endif;*/
	elseif _containerDrawingController.modeView = ShpDisplayMode_ColCodeDisch then
		/*
		****************************
			cnwmc5 - PAR 31651
		****************************
		*/
		roroReq := _slot.myRORORequestDischarge;
		tmpTI := _slot.allTrackedItems.first();
		
		if _containerDrawingController.modeViewSubSub = ShpDisplayModeSub_ExportsHide then
			if roroReq &lt;&gt; null then
				if roroReq.isBackEndRequest() then
					doDraw := false;
				else
					is40 := roroReq.getAttrIsNOT20();
					if is40 then
						x1 := x1 - fortyFootExtension;
					endif;
				endif;
			elseif tmpTI &lt;&gt; null then
				if (tmpTI.isForty() or tmpTI.is30 or tmpTI.is45 or tmpTI.is53)  then // PAR 30022 
					if tmpTI.myPrimaryActualLocation &lt;&gt; _slot then // do not draw backends
						doDraw := false;
						// PAR 31073 - if the back end if for a 'hidden' 40 export then do draw the 'empty' 20
						if (tmpTI.isExport or tmpTI.isRehandle or tmpTI.isSOB) then
							doDraw := true;
						endif;
					else
						x1 := x1 - fortyFootExtension;
						// PAR 31073 - hide exports / rehandles ?
						if (tmpTI.isExport or tmpTI.isRehandle or tmpTI.isSOB) then
							x1 := x1 + fortyFootExtension; // do not draw this as a forty foot slot if we are hiding
						endif;
					endif;
				endif;
			endif;
		elseif _containerDrawingController.modeViewSubSub = ShpDisplayModeSub_ExportsShow then
			if tmpTI &lt;&gt; null then
				if (tmpTI.isForty() or tmpTI.is30 or tmpTI.is45 or tmpTI.is53) then // PAR 30022 
					if tmpTI.myPrimaryActualLocation &lt;&gt; _slot then // do not draw backends
						doDraw := false;
					else
						x1 := x1 - fortyFootExtension;
					endif;
				endif;
			endif;
		endif;
		/*
		****************************
					Was
		****************************
		roroReq := _slot.myRORORequestDischarge;
		tmpTI := _slot.allTrackedItems.first();  // PAR 31366

		if (_containerDrawingController.modeViewSubSub = ShpDisplayModeSub_ExportsHide and roroReq &lt;&gt; null)  // PAR 31366
		or (_containerDrawingController.modeViewSubSub = ShpDisplayModeSub_ExportsShow and tmpTI = null) then  // PAR 31366
			if roroReq &lt;&gt; null then
				if roroReq.isBackEndRequest() then
	//		28939			return;
	//			endif;
					
	//			if roroReq &lt;&gt; null then
					doDraw := false;
				else
	//				is40 := (roroReq.getAttrIs40() or roroReq.getAttrIs30() or roroReq.getAttrIs45() or roroReq.getAttrIs53()); // PAR 30022 
					is40 := roroReq.getAttrIsNOT20(); // PAR 30253
					if is40 then // PAR 30022 
					 // PAR 30022 if roroReq.getAttrIs40() then
						x1 := x1 - fortyFootExtension;
					endif;
				endif;
			endif;
		else
			tmpTI := _slot.allTrackedItems.first();
			if tmpTI &lt;&gt; null then
				if (tmpTI.isForty() or tmpTI.is30 or tmpTI.is45 or tmpTI.is53)  then // PAR 30022 
					if tmpTI.myPrimaryActualLocation &lt;&gt; _slot then // do not draw backends
						doDraw := false;
						// PAR 31073 - if the back end if for a 'hidden' 40 export then do draw the 'empty' 20
						if _containerDrawingController.modeView = ShpDisplayMode_ColCodeDisch and _containerDrawingController.modeViewSubSub = ShpDisplayModeSub_ExportsHide then 
							if (tmpTI.isExport or tmpTI.isRehandle or tmpTI.isSOB) then
								doDraw := true;
							endif;
						endif;
					else
						x1 := x1 - fortyFootExtension;
					
						// PAR 31073 - hide exports / rehandles ?
						if _containerDrawingController.modeView = ShpDisplayMode_ColCodeDisch and _containerDrawingController.modeViewSubSub = ShpDisplayModeSub_ExportsHide then 
							if (tmpTI.isExport or tmpTI.isRehandle or tmpTI.isSOB) then
								x1 := x1 + fortyFootExtension; // do not draw this as a forty foot slot if we are hiding
							endif;
						endif;

					endif;
				endif;
			endif;

		endif;
		*/
	elseif _containerDrawingController.modeView = ShpDisplayMode_Actual then
		tmpTI := _slot.allTrackedItems.first();
		if tmpTI &lt;&gt; null and (tmpTI.isForty() or tmpTI.is30 or tmpTI.is45 or tmpTI.is53)  then // PAR 30022 
			if tmpTI.myPrimaryActualLocation &lt;&gt; _slot then
//		28939			return;
				doDraw := false;
			else
				x1 := x1 - fortyFootExtension;
			endif;
		endif;
	endif;


	if doDraw then
		_containerDrawingController.setFromSlotDefn(_slotDefn, x1, y1, x2, y2);
		
		_containerDrawingController.setDefaultFont(self);
		_containerDrawingController.drawCurrentObject(self);
		
		// now set the font back for labels
		_containerDrawingController.setLabelFont(self);
	endif;
	on Exception do _gridDict.noDuplicatesExceptionhandler(exception, hadDuplicates); // 28747 from notification
	_gridDict.putAtKey(x1, y1, x2, y2, _slot);
	
	if doDraw then //	28939
		if x2 &gt; self.minDrawingWidth then
			self.minDrawingWidth := x2;
		endif;
		if y2 &gt; self.minDrawingHeight then
			self.minDrawingHeight := y2;
		endif;
	endif;
epilog
	//cnwmc5 - PAR 31651
	delete tis;
end;</source>
        <access>protected</access>
        <Parameter name="_slotDefn" type="CM_ROROSlotDefnVoyage"/>
        <Parameter name="_slot" type="CM_ROROSlotController"/>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="y1" type="Integer"/>
        <Parameter name="_gridDict" type="CM_ObjectByX1Y1X2Y2Dict" usage="input"/>
        <Parameter name="_containerDrawingController" type="SHP_ROROLocnDrawingController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawSlotFromNote" id="f8285452-9588-4279-81bf-ca80c180b949">
        <updating/>
        <source>drawSlotFromNote(_slotController : CM_ROROSlotController) updating;
/*
Purpose:			
Date		Who		Reason
27 September 2011	cnwab1	Initial creation
Dec 2011	cnwjre1	28747 refresh location side view form
*/

vars
	x1, y1	: Integer;
	x2, y2, fortyFootExtension	: Integer;
	theViewMode : Integer;
	theObject : Object;
	theReq : CM_RORORequest;
	theSlot : CM_ROROSlotController;
	containerDrawingController : SHP_ROROLocnDrawingController;
	tmpTI : CM_TrackedItem;
begin

	if self.getPointsForObject(_slotController, x1, y1, x2, y2) then
		
		containerDrawingController := self.myROROLocnDrawingController;
		theViewMode := containerDrawingController.modeView;
		fortyFootExtension := (containerDrawingController.slotWidth + ( 2 * containerDrawingController.interLocnSlotsHeight));
		
		// PAR 28939
		if ((x2 - x1) - 10) &gt; containerDrawingController.slotWidth then // double the normal width
		
		/* PAR 32149 WAS
			theSlot := _slotController;
			
			if theViewMode = ShpDisplayMode_ColCodeLoad then
				theReq := theSlot.myRORORequestLoad;
			elseif	 theViewMode = ShpDisplayMode_ColCodeDisch then
				theReq := theSlot.myRORORequestDischarge;
			endif;
			if theViewMode = ShpDisplayMode_ColCodeLoad 
			or theViewMode = ShpDisplayMode_ColCodeDisch then
				// the colour coding was for a non 20 so because there is no longer any CC we need to shrink it back to its 20 foot size
				// and remove it from the XY dict. In the drawing it will be re added with the new XYs
				x1 := x1 +  (containerDrawingController.slotWidth + ( 2 * containerDrawingController.interLocnSlotsHeight));
				self.allDrawnObjects.removeObjectFromDict(_slotController); 
			endif;
			// PAR 29161 - if drawing from note then the X has already been adjusted for the forty, but in the drawSlot it always adjusts, 
			if containerDrawingController.modeView = ShpDisplayMode_Actual then
				tmpTI := _slotController.allTrackedItems.first();
				if tmpTI &lt;&gt; null then
					if  (tmpTI.isForty() or tmpTI.is30 or tmpTI.is45 or tmpTI.is53) then // PAR 30022
						x1 := x1 + fortyFootExtension;
					endif;
				// we are empty but we previously had a 40 so shrink us back to normal.
				else
					x1 := x1 + fortyFootExtension;
				endif;
			endif;
			NOW */

			x1 := x1 +  (containerDrawingController.slotWidth + ( 2 * containerDrawingController.interLocnSlotsHeight));
			self.allDrawnObjects.removeObjectFromDict(_slotController); 
		endif;
		
		self.drawSlot(_slotController.mySlotDefn, _slotController, x1, y1, self.allDrawnObjects, containerDrawingController);
		
	
	endif;
epilog

end;</source>
        <Parameter name="_slotController" type="CM_ROROSlotController"/>
    </JadeMethod>
    <JadeMethod name="drawSlotsLabelAndWeights" id="dad45ef3-1947-4f21-bd45-b88b9dd20394">
        <updating/>
        <source>drawSlotsLabelAndWeights(_locnDefn : CM_ROROLocnDefnVoyage; _x,_y : Real; _colour : Integer; _width,_height : Integer;_drawWeights : Boolean) updating;
/*
Date		    Who			Reason
18 July 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars	
	textX,textY 			: Real;
	labelWidth, weight, weightMax, height, heightMax, 
	gap,labelHeight 		: Real;
	label 					: String;
	scrollingFrame 			: SHP_ROROScrollingFrame;
	drawingColour			: Integer;	//cnwas3 par 28545
	//scrollingFrame			: SHP_ROROScrollableFrame;
begin
	drawingColour := _colour; //cnwas3 par 28545
	if _drawWeights then 
		
		if self.myROROLocnDrawingController.modeView = ShpDisplayMode_ColCodeLoad then
			_locnDefn.getWeightsForLocn(PLANNING_MODE, true,weight, weightMax);
		elseif self.myROROLocnDrawingController.modeView = ShpDisplayMode_Proposed then	//cnwas3 par 28545
			_locnDefn.getProposedWeightsForLocn(weight,weightMax);
		else
			_locnDefn.getWeightsForLocn(REAL_MODE, true,weight, weightMax);
		endif;
		
		weight := weight / 1000;
		weightMax := weightMax / 1000;
		
		label := weight.asStringJMTWithPrecision(0,false) &amp; "/" &amp; weightMax.asStringJMTWithPrecision(0,false) &amp; "t";
		
		if weight &gt; weightMax then		//cnwas3 par 28545
			drawingColour := Red;
		else
			drawingColour := _colour;
		endif;
		
	else
		label := _locnDefn.code;		
	endif;
	
	if label = null then		
		return;
	endif;
	
	textX := _x;
	textY := _y;	
	
	scrollingFrame := self.myScrollingFrame;
	//scrollingFrame := self.myScrollableFrame;
	if _drawWeights then
		scrollingFrame.drawFontItalic := true;
		scrollingFrame.drawFontBold := false;
		gap := 5;
	else
		scrollingFrame.drawFontItalic := false;
		scrollingFrame.drawFontBold := true;
		gap := 10;
	endif;	
	
	if _drawWeights then
		scrollingFrame.drawFontSize := 9;	
	else	
		scrollingFrame.drawFontSize := 11;	
	endif;
	
	while scrollingFrame.drawTextWidth(label) + gap &gt; _width do		
		scrollingFrame.drawFontSize := scrollingFrame.drawFontSize - 1;	
		if scrollingFrame.drawFontSize &lt; 7 then		//cnwas3 par 28382
			break;
		endif;
	endwhile;
	
	labelWidth := scrollingFrame.drawTextWidth(label);	
	labelHeight := scrollingFrame.getTextHeight(label);
				
	scrollingFrame.drawTextRotation := 0;
	scrollingFrame.drawTextCharRotation := 0;				
	
	textX := textX + (_width - labelWidth)/2;	
	if _drawWeights then
		scrollingFrame.drawTextAt(label,textX,textY, drawingColour);
	else
		scrollingFrame.drawTextAt(label,textX,_y + (_height - labelHeight)/2, drawingColour);
	endif;
	
	//draw the stack height here
	if _drawWeights then
		scrollingFrame.drawFontItalic := false;
		if self.myROROLocnDrawingController.modeView = ShpDisplayMode_Proposed then	//cnwas3 par 28545
			height := _locnDefn.getProposedHeightMetresTIs();
		elseif self.myROROLocnDrawingController.modeView = ShpDisplayMode_ColCodeLoad then
			height := _locnDefn.getHeightMetresTIs(PLANNING_MODE, true);
		else
			height := _locnDefn.getHeightMetresTIs(REAL_MODE, true);
		endif;
		heightMax := _locnDefn.getMaxHeightLimit();
		
		label := (heightMax - height).asStringJMTWithPrecision(1,false) &amp; "m";	
		if heightMax &lt; height then			//cnwas3 par 28545
			drawingColour := Red;
		else
			drawingColour := _colour;
		endif;
		
		scrollingFrame.drawFontSize := 9;	
		while scrollingFrame.drawTextWidth(label) + gap &gt; _width do		
			scrollingFrame.drawFontSize := scrollingFrame.drawFontSize - 1;	
			if scrollingFrame.drawFontSize &lt; 7 then		//cnwas3 par 28382
				break;
			endif;
		endwhile;
		
		
		textX := _x + (_width - scrollingFrame.drawTextWidth(label))/2;
		textY := textY + labelHeight;
		scrollingFrame.drawTextAt(label,textX,textY,drawingColour);
		if textY.Integer &gt; self.minDrawingHeight then
			self.minDrawingHeight := textY.Integer;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_locnDefn" type="CM_ROROLocnDefnVoyage"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_width" type="Integer"/>
        <Parameter name="_height" type="Integer"/>
        <Parameter name="_drawWeights" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getObjectAndPointsForPosition" id="39bc5fd7-1d6b-4833-a93e-2866f8f0a6b1">
        <source>getObjectAndPointsForPosition(x: Integer; y: Integer; xy1: Point output; xy2: Point output): Object;
/*
Date		    Who			Reason
15 July 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	tmpDrawingController	: SHP_ROROLocnDrawingController;
begin

	tmpDrawingController := self.myROROLocnDrawingController;
	if tmpDrawingController = null then
		return null;
	endif;	

	return self.allDrawnObjects.findObjectInDict(x, y, xy1, xy2);

end;</source>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <Parameter name="xy1" type="Point" usage="output"/>
        <Parameter name="xy2" type="Point" usage="output"/>
        <ReturnType type="Object"/>
    </JadeMethod>
