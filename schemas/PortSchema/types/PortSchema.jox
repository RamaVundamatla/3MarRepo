	beginTransaction;
	node.userExitCode := userExitCode;
	commitTransaction;
	terminate;
end;
</source>
    </JadeMethod>
    <JadeMethod name="initJMTPatchReleaseApp" id="011f54df-ed60-4e1f-876e-e5196a2307be">
        <updating/>
        <source>initJMTPatchReleaseApp() updating;
// ---------------------------------------------------------------------------
// Created:     11 July 2001 by cnwrs2
//
// Purpose:     Initialize the patch release application
//
// Parameters:  On the command line have something like
//					endJade version=7.1.5 patch=a
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// ---------------------------------------------------------------------------
constants
	Version		: String = 'version';
	Patch		: String = 'patch';
	
vars
	releaseClass		: Class;
	newRelController	: CnEcReleaseController;
	commandLine,
	patchNumber,
	releaseClassName,
	currVersion,
	currPatch		: String;
	master				: CnEcReleaseHistoryMaster;
	result,
	loadStateSet 		: Boolean;
	paramNames,
	paramValues			: StringArray;
	numRows,
	idx					: Integer;
	userExitCode: Integer;
	file : File; //add application file for Jari
	fileMessage : String;
begin
	userExitCode := 63;
	app.initialize();
	create file transient;
	file.mode := File.Mode_Output;	// 4/3/16 cnwmp6 PAR 36286 unicode version
	file.fileName := app.myCnCntrl.logPath&amp;"\app_upgrade.log";
	if file.isAvailable then
		file.purge;
	endif;
	fileMessage := "UpgradeError";

	commandLine := self.getUserCommandLine(true);
	if commandLine &lt;&gt; null then
		app.writeLog('Parsing command line (' &amp; commandLine &amp; ')', LogINFO);
		create paramNames transient;
		create paramValues transient;
		self.parseCommandLine(commandLine, paramNames, paramValues);
		
		numRows := paramNames.size;
		foreach idx in 1 to numRows do
			if paramNames[idx] = Version then
				releaseClassName := paramValues[idx];
			elseif paramNames[idx] = Patch then
				patchNumber := paramValues[idx];
			endif;
		endforeach;
	else
		app.writeLog('Commandline is null - aborting', LogERROR);
		return;
	endif;

	if releaseClassName = null or
	   patchNumber = null then
		app.writeLog('Release class or patch not found in command line - Aborting', LogERROR);
		return;
	endif;
	app.writeLog('Running Patch Release for (' &amp; releaseClassName &amp; ' ' &amp; patchNumber &amp; ')', LogINFO);

	self.cmsBeginLoad(loadStateSet);
	sharedLock(self.myRoot);
	currVersion	:= self.myRoot.versionString;
	currPatch	:= self.myRoot.patchLevel;
	self.cmsEndLoad(loadStateSet);

	app.writeLog('Running Patch Release - current version is (' &amp; currVersion &amp; ' ' &amp; currPatch &amp; ')', LogINFO);
	
	releaseClassName.replaceChar('.', '_');
	releaseClassName := 'PortSchema_' &amp; releaseClassName;

	releaseClass := currentSchema.getClass(releaseClassName);
	
	if releaseClass = null then
		app.writeLog('Release class (' &amp; releaseClassName &amp; ') not found - Aborting', LogERROR);
		return;
	endif;

	self.cnEcInitializeBaseSchema();

	create newRelController transient;
	result := newRelController.processPatchRelease(releaseClass, patchNumber, currVersion, master);
	
	if result and app.myPassport.noErrors then
		self.myTrxUA.trxCompleteRelease(master, self.myRoot, currVersion, patchNumber, app.myPassport);
		result := self.myPassport.trxCompletedOK;
		if (not result) then
			app.writeLog('Error in updating completed release', LogERROR);
		endif;
	else
		app.writeLog('Error in processing patch release', LogINFO);
	endif;
	fileMessage := "UpgradeError";
	if result then
		userExitCode := 0;	
		fileMessage := "completedOK";
	endif;
	file.writeLine(fileMessage);
epilog
	app.cmsEndLoad(loadStateSet);				// 08/04/2011 cnwmh5 #27347
	file.close;
	delete file;
	delete newRelController;
	delete paramNames;
	delete paramValues;
	beginTransaction;
	node.userExitCode := userExitCode;
	commitTransaction;
	terminate;
end;</source>
    </JadeMethod>
    <JadeMethod name="initJMTReleaseApp" id="f6468a7a-10d9-4b45-a915-144931d2c48d">
        <updating/>
        <source>initJMTReleaseApp() updating;
// ---------------------------------------------------------------------------
// Created:     11 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	apr 2006	cnwrs1		so devschema initialize can call jmtReleaseapp with terminate etc
// 09 Jul 2008	cnwkpd1		PAR #17499 - Use app server file system so app can run thin client
// 11 Jul 2017	cnwdap1		Set user code to SUPERUSER
// 19 Sep 2019	jlgzm1		TFS 46543 app_upgrade.log created in wrong location
// ---------------------------------------------------------------------------
vars
	userExitCode: Integer;
	
begin

	userExitCode := 63;
	app.initialize();
	app.myPassport.setMyUserFromCode("SUPERUSER");

	if app.jmtReleaseApp() then
		userExitCode := 0;
	endif;
	
epilog

	beginTransaction;
	node.userExitCode := userExitCode;
	commitTransaction;
	terminate;
end;</source>
    </JadeMethod>
    <JadeMethod name="initJMTReleaseVersionApp" id="6c101959-a93c-4196-83b6-539243cc9020">
        <updating/>
        <source>initJMTReleaseVersionApp() updating;
// ---------------------------------------------------------------------------
// Created:     Feb 2008 cnwrs1
//
// Purpose:     Initialize the release version checking application
//
// Parameters:  On the command line have something like
//					endJade version=7.1.5 patch=020
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// ---------------------------------------------------------------------------
constants
	Version		: String = 'version';
	Patch		: String = 'patch';
	
vars
	releaseClass : Class;
	commandLine,
	patchNumber,
	releaseClassName,
	currVersion,
	currPatch : String;
	releaseVersion : String;
	master : CnEcReleaseHistoryMaster;
	result,
	loadStateSet : Boolean;
	paramNames,
	paramValues	: StringArray;
	numRows,
	idx	: Integer;
	userExitCode: Integer;
	file : File; //add application file for Jari
	fileMessage : String;
begin
	userExitCode := 63;
	app.initialize();
	create file transient;
	file.mode := File.Mode_Output;	// 4/3/16 cnwmp6 PAR 36286 unicode version
	file.fileName := app.myCnCntrl.logPath&amp;"\app_upgrade.log";
	if file.isAvailable then
		file.purge;
	endif;
	fileMessage := "UpgradeError";

	commandLine := self.getUserCommandLine(true);
	if commandLine &lt;&gt; null then
		app.writeLog('Parsing command line (' &amp; commandLine &amp; ')', LogINFO);
		create paramNames transient;
		create paramValues transient;
		self.parseCommandLine(commandLine, paramNames, paramValues);
		
		numRows := paramNames.size;
		foreach idx in 1 to numRows do
			if paramNames[idx] = Version then
				releaseVersion := paramValues[idx];
			elseif paramNames[idx] = Patch then
				patchNumber := paramValues[idx];
			endif;
		endforeach;
	else
		app.writeLog('Commandline is null - aborting', LogINFO);
		return;
	endif;

	if releaseClassName = null or
	   patchNumber = null then
		app.writeLog('Release class or patch not found in command line - Aborting', LogINFO);
		return;
	endif;
	app.writeLog('Checking Version Release for (' &amp; releaseVersion &amp; ' ' &amp; patchNumber &amp; ')', LogINFO);

	self.cmsBeginLoad(loadStateSet);
	sharedLock(self.myRoot);
	currVersion	:= self.myRoot.versionString;
	currPatch	:= self.myRoot.patchLevel;
	self.cmsEndLoad(loadStateSet);

	app.writeLog('Checking Version Release - current version is (' &amp; currVersion &amp; ' ' &amp; currPatch &amp; ')', LogINFO);
	releaseClassName := releaseVersion;
	releaseClassName.replaceChar('.', '_');
	releaseClassName := 'PortSchema_' &amp; releaseClassName;

	releaseClass := currentSchema.getClass(releaseClassName);
	
	if releaseClass = null then
		app.writeLog('Release class (' &amp; releaseClassName &amp; ') not found - Aborting', LogINFO);
	endif;

	if currVersion = releaseVersion then
		if currPatch = patchNumber then
			result := true;
		else
			result := false;
		endif;
	else
	endif;
	fileMessage := "UpgradeError";
	if result then
		userExitCode := 0;	
		fileMessage := "completedOK";
	endif;
	file.writeLine(fileMessage);
epilog
	app.cmsEndLoad(loadStateSet);				// 08/04/2011 cnwmh5 #27347
	file.close;
	delete file;
	delete paramNames;
	delete paramValues;
	beginTransaction;
	node.userExitCode := userExitCode;
	commitTransaction;
	terminate;
end;
</source>
    </JadeMethod>
    <JadeMethod name="initLogFile" id="800d2f38-f904-45ea-89a2-bb8b9fb91ee3">
        <updating/>
        <source>initLogFile() updating ,protected;
// ---------------------------------------------------------------------------
// Created:     15 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	8 Aug 2022 	navhl20 	ChangeRequest 52513: MTN - Correctly Log User Codes in Log Files
//	24 Aug 2022	navmd1		TFS 54648 - Removed extra app version logging now that its done in init (on the assumption that everything goes through PortSchema::initialize)
// ---------------------------------------------------------------------------
vars
	cc			: CnCntrl;
	log			: JadeLog;
	filename	: String;
	date		: Date;
	logStr		: String;
	
begin


	cc := app.myCnCntrl;

	if app.myLogFile = null then
		create log;
		log.filePath		:= cc.logPath;
		log.fileName		:= self.setLogFilename();
		log.versionFile		:= true;
		log.maxFileSize		:= cc.logFileMaxSize;
		log.formatOutput	:= false;
		log.bufferOutput	:= true;

		app.myLogFile := log;
	endif;
	
	//app.writeLog('Logfile created for user '&amp;app.getMyUserCode()&amp;'.', LogINFO); //rs may 2005 par10137		//8.8.2022 navhl20 TFS 52513
	//app.writeLog('Application version is ' &amp; app.appVersion, LogINFO);			// PAR #20144				// Called in initialize instead
	//app.writeLog('Build date is ' &amp; app.getJMTReleaseExtractTime.asStringJMT, LogINFO);						// Called in initialize instead
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initNodeRequestProcessing" id="4d9b5580-5c41-4a94-a1d2-90cc4dde6d2c">
        <updating/>
        <source>initNodeRequestProcessing(_nodeRequest : NR_NodeRequest) updating;
// ---------------------------------------------------------------------------
// Created:     03 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
02 Jul 2008	cnwkpd1	PAR #16662 - Arm exception handler instead of using isValidObject
										
*/

vars
	theNodeRequest	: NR_NodeRequest;
	invalidRequest	: Boolean;
	
begin
	theNodeRequest := _nodeRequest;
	
	if theNodeRequest = null then 		// or (not global.isValidObject(theNodeRequest)) then
		return;
	endif;

	on Exception do app.handleDeletedObject(exception, theNodeRequest, invalidRequest);		// PAR #16662
	
	theNodeRequest.actionOnTargetNode();

	// If the node request is deleted out from underneath us while we're in tran state, then we
	// will resume here, and so need to abort
	if invalidRequest then
		abortTransaction;
	endif;


epilog
	
end;</source>
        <Parameter name="_nodeRequest" type="NR_NodeRequest"/>
    </JadeMethod>
    <JadeMethod name="initPushEventsApp" id="5278285c-0abd-4076-a20a-9d6109a41945">
        <updating/>
        <source>initPushEventsApp(_initializeParam : Object) updating;

/*

Purpose:			Initialisation method for Push Events application

Parameters:			Dummy object parameter to allow jadclient run

Return Value:		Nothing


Date		Who		Reason
13 Feb 2017	cnwkpd1	TFS 3369 - Push Events application
19 Jun 2017	cnwkpd1	TFS 3369 - Add Event Stream licence
04 Sep 2017	jlgkpd1	TFS 6615 - Add Alerts for any startup issues

*/

vars
	msg				: String;
	
begin
	self.initialize();
	
	// ### JIRA 33505 03DEC2024 NAVAB1  if not app.myRoot.canDo(Mod_EventStream) then
	if not app.myRoot.canDo(Sub_EventStream) then
		msg := 'System is not licensed to run Event Stream application.' &amp; CrLf &amp; 
					'Requires Event Stream SUBSCRIPTION- terminating';
		app.writeLog(msg, LogFATAL);	//26 Nov 2019	NDL	TFS 47053
		app.createAlert(app.name &amp; ' - ' &amp; msg, true);
		terminate;
	endif;
	
	create self.myInterfaceController as CM_PushEventsController;
	self.myInterfaceController.start();
	
epilog

end;</source>
        <Parameter name="_initializeParam" type="Object"/>
    </JadeMethod>
    <JadeMethod name="initTITransClassNames" id="81941165-46a7-48c8-a1f5-615fafcfe3b6">
        <updating/>
        <source>initTITransClassNames() updating;
/*

Purpose:			Create initial collection of Transaction class names

Parameters:			None

Return Value:		None

Date		Who		Reason
???			cnwth2	Initial creation
17 Oct 2011	cnwkpd1	Transient leaks in Unit Test runner
	
*/

vars
	ccDict		: ClassNDict;
	cls			: Class;
	strObj		: CM_StringWithObject;

begin
	if self.allTITransClassNames &lt;&gt; null then
		self.allTITransClassNames.purge();
		delete self.allTITransClassNames;
	endif;
	create self.allTITransClassNames transient;

	create ccDict transient;
	CM_Transaction.getAllSubclassesAnywhere(ccDict);//includes subschema transaction classses for centreport
	
	foreach cls in ccDict do
		create strObj transient;
		strObj.string := cls.name;
		strObj.object := cls;
		self.allTITransClassNames.add(strObj);
	endforeach;

epilog
	delete ccDict;

end;


</source>
    </JadeMethod>
    <JadeMethod name="initialiseForStartAutoPlan" id="2acee0ed-cda1-4452-8b5b-430570af37e6">
        <updating/>
        <source>initialiseForStartAutoPlan(_passport : CM_Passport) updating;
// -------------------------------------------
// Created 30 May 2005 by cnwdvb1
// -------------------------------------------

// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30/10/2008	consw1		SFW1030 - Remove unused auto plan flags

vars

	terminal				: CM_Terminal;
	useOverStowNew	: Boolean;
	extraStr : String;

begin

	terminal := _passport.myTerminal;
	
	 if terminal = null then
		// Raise exception.
	//	extraStr := app.returnProcessStackAsString[1:1000];
		app.raiseCMException2(AutoPlanningYAError, null, 'terminal has not been specified' &amp; extraStr, null, null);
		return;
	endif;
	
	if self.myYAAgent = null then
		if not terminal.isAutoPlanningEnabled() then
			return;
		endif;
		
		// Is system licensed for new autoplanning
		// If not raise exception.
		// ### JIRA 33505 30DEC2024 NAVAB1 Mod_YardPlanning is now part of base module
		/*
		if not app.getMyUser.canDo(terminal, Mod_YardPlanning) then
			app.raiseCMException1(NotLicensedToPerformAction, app.getLicenseName(Mod_YardPlanning), null, null);
			return;
		endif;
		*/
		
		if terminal.isAutoPlanUseOverstowRules() then
			useOverStowNew := true;
		endif;

		create self.myYAAgent transient;
		self.myYAAgent.useOverstowRules := useOverStowNew;
	endif;

	self.myYAAgent.initialiseForTrxStart();

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="initialize" id="4e9ec82c-6217-4668-88b9-076227c3ff0d">
        <updating/>
        <source>initialize() updating;

/*

Date		Who		Reason
08 Sep 2009	cnwkpd1	PAR #20144 - Set up appVersion from CM_Root version and patch for logs and dumps
31/08/2010	cnwdad1	PAR #20064 - Initialize myLocaleInfoJMT.
07 Feb 2012	cnwkpd1	PAR #28381 - Update JSM version info correctly in managed environments
03 Apr 2012	cnwkpd1	PAR #29384 - Diagnostic code for stable collection inconsistency checks
10 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
06 Sep 2018	jlgrs1	TFS 40696 - always setup KarmaControl
19 Sep 2019	cnwrs1	TFS 46087 SFTP
16 Oct 2024 navmd1	Jira MTN-33098 Skip post-refresh stuff if a reorg is in progress
09 Oct 2025 navmd1	Jira DOMTN-285 Respond to Karmas Shutdown command if not-managed
*/

vars
	systemMode : String;
	systemModeInt 	: Integer;
	str : String;
begin
// 06 Sep 2018	jlgrs1	TFS 40696 - always setup KarmaControl
	self.setupAppVersion();			// PAR #28381
	self.cnActivateKarmaControl(Cn_Fat_Client, null, null);	//for dumps

	self.myRoot := CM_Root.firstInstance;
	if self.myRoot = null then
		self.myRoot := global.myCM_Root;
	endif;
	
	if app.myRoot = null then
		app.msgBox('System has not been initialized.  Cannot continue', 'Error', MsgBox_OK_Only);
		terminate;
	endif;
	
	self.logLevel := LogWARN;	//22 Nov 2019	NDL	TFS 47053

	self.appVersion := app.myRoot.getVersionAndPatchLevel();			// PAR #20144
	app.writeLog('Application version is ' &amp; app.appVersion, LogINFO);	//26 Nov 2019	NDL	TFS 47053
	app.writeLog('Build date is ' &amp; app.getJMTReleaseExtractTime.asStringJMT, LogINFO);	//26 Nov 2019	NDL	TFS 47053
	
	self.initializeLocaleInfo();	// cnwdad1 31/08/2010 - PAR #20064.
	self.setCurrentLocale();
	self.initializeAgents();
	
	//07 Jul 2021	NDL	TFS 51443
	if CM_DeferredChargingRoot.firstInstance = null then
		beginTransaction;
		create self.myDeferredChargingRoot persistent;
		commitTransaction;
	else
		self.myDeferredChargingRoot := CM_DeferredChargingRoot.firstInstance;	
	endif;
	
	app.writeLog('System Time Zone is ' &amp; app.systemTimeZoneID, LogINFO);	//26 Nov 2019	NDL	TFS 47053

	self.baseErrorNum := app.myRoot.baseErrorNum;
	
	// create the JSSFileManager first as this is used by the
	// general exception handler to deterimine if an exception
	// is a JSS exception.
	create self.myFileManager transient;
	
	// Deliberately done this way so as to avoid any references to
	// the security module
	create self.myCheckerObject as JSSLPublicInterface transient;
	//transient worker for HMS tidal calulations - saves creating them everywhere
	create self.myHMSRvTide transient;
	
	//epr TFS 42569 15/5/19 done before initCnCntrolForJMT because that checks systemMode
	systemMode:= self.getProfileStringServer(JMTRefreshSection,"SystemMode","99");
	if systemMode &lt;&gt; "99" then
		systemModeInt:=app.myRoot.getSystemModeFromString(systemMode);
		if app.myRoot.systemMode &lt;&gt; systemModeInt and systemModeInt &lt;&gt; CM_Root.SystemMode_Dev then
			if app.isInReorgOrVersionedState then
				app.writeLog("Reorg in progress, post-refresh changes deferred until DB changes can be made", LogERROR);
			else
				beginTransaction;
				app.myRoot.setSystemMode(systemModeInt);
				commitTransaction;
			endif;
		endif;
	endif;

	app.initCnCntrlForJMT();

//	self.isSubTerminalsLicensed		:= app.myRoot.canDo(PmSubTerminalMod);
	self.isSubTerminalsLicensed		:= true;	//07 Oct 2019	NDL	TFS 46169
	self.isCashOnlyEnabled			:= app.myRoot.canDo(Mod_Cash);	//25 Jul 2012	NDL	Par 29968
	self.isDutyDocEnabled			:= app.myRoot.canDo(Mod_DutyDoc);
	self.isVehicleBookingEnabled	:= app.myRoot.canDo(Mod_VehicleBooking);	//08 Apr 2013	NDL	Par 31278
// ### JIRA 33505 30DEC2024 NAVAB1	self.isCargoGroupEnabled		:=  app.myRoot.canDo(Mod_CargoGroup);	//11 Jun 2015	NDL	Par 36338
//	self.isSFTPEnabled := app.myRoot.canDo(PmSFTP);
	self.doNotFIlterCombos := app.myRoot.getConfig(DoNotFilterCombos ).Boolean; // ### TFS CR 55105 29DEC2022 NAVAB1
	
	app.setMyVehicleBookingRoot();	//08 Apr 2013	NDL	Par 31278
	
	self.setTranslatedStrings();
	
	if app.printer &lt;&gt; null then
		app.printer.retainCMDValues := true;//added by cnwyl1 30052006 for Par 40652
	endif;
	
	self.beginNotification(process, NR_NodeRequest.NR_NodeRequestActionEvent, Response_Continuous, 0);
	app.setCurrencySymbolDecimalPlaces(); // PAR 14894
	
	self.initBackgroundNodeProcessing();	// PAR #29384
	
	// This looks backwards, but basically, if we're NOT being managed by JSM
	// Then listen for any manual shutdown commands sent by the GitSchemaLoader app
	if not app.myCnCntrl.karmaControl then
		self.beginNotification(system, Cn_Process_Shutdown_Command, Response_Continuous, null);
	endif;
	
	//26 Nov 2019	NDL	TFS 47053 - Listen for a notification to update the log level.
	self.beginNotification(process, EVENT_APP_LOG_LEVEL, Response_Continuous, 0);
	self.beginNotification(process, EVENT_APP_LOG_LEVEL_Req, Response_Continuous, 0);	//29 Nov 2019	NDL	TFS 47053
	self.beginClassNotification( BGP_DeferredChargingController, false, EVENT_Upd_BGP_Deferred_Cont, Response_Continuous , null);	//07 Jul 2021	NDL	TFS 51443
	self.setDeferredChargesBgpRunning();	//07 Jul 2021	NDL	TFS 51443
	
	//17 Feb 2021	NDL	TFS 50488
	str := self.getProfileStringServer(MTN_Global_Settings,"CompactTransientIntervalMins","-1");
	if str.isInteger then	
		self.compactTransientIntervalMins := str.Integer;
	else
	//	We got non numeric back, leave as default
		self.compactTransientIntervalMins := -1;	
	endif;
	self.setNextCompactTime();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initializeAgents" id="10528a86-d5db-420c-aa4c-807b3938c5d1">
        <updating/>
        <source>initializeAgents() updating;
// ---------------------------------------------------------------------------
// Created:			01 May 2001 by cnwdwq1
// Purpose:			!     
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By		Reason
// ----------	----------		--------------------------------------------------
// 16/01/2002   cnwrs1          put create root and terminal at end as they rely on app.myUtility ref's
// 19/02/2002 	cnwka1			made method unprotected
// 08/05/2002	cnwka1			added query agents
// 11 Mar 2016	cnwkpd1			TFS 488 - Multi Timezone Support
// 30/03/2016   cnwmh5			TFS 1729 - Remove delete of passport
// 05/10/2022	navmd1			TFS 55088 Only create the SSO agent if we are a GUI application
// ---------------------------------------------------------------------------
vars
	
begin
	if self.alertManager = null then
		create self.alertManager transient;
	endif;
	
	if self.myProxyManager = null then
		create self.myProxyManager transient;
	endif;

	// create audit agent
	if self.myAA = null then
		create self.myAA transient;
	endif;
	
	// create model event manager
	if self.myEventManager = null then
		create self.myEventManager transient;
	endif;

	// create Utility agents
	if self.myUtilityCA = null then
		create self.myUtilityCA transient;
	endif;

	if self.myUtilityDA = null then
		create self.myUtilityDA transient;
	endif;

	if self.myUtilityUA = null then
		create self.myUtilityUA transient;
	endif;

	// create Transaction agents
	if self.myTrxCA = null then
		create self.myTrxCA  as CM_TrxControlPostCreateAgent transient;
	endif;
	//epr TFS 43260 13/2/19
	if self.myTrxDA = null then
		create self.myTrxDA as CM_TrxControlPostDeleteAgent transient;
	endif;

	if self.myTrxUA = null then
		create self.myTrxUA as CM_TrxControlPostUpdateAgent transient;
	endif;

	// create validation agetns
	if self.myValCA = null then
		create self.myValCA transient;
	endif;

	if self.myValUA = null then
		create self.myValUA transient;
	endif;

	if self.myValDA = null then
		create self.myValDA transient;
	endif;
	
	/////delete self.myPassport;
	create self.myPassport transient;
		
	if self.myQAFilter = null then
		create self.myQAFilter transient;
	endif;
	
	if self.myQASelector = null then
		create self.myQASelector transient;
	endif;
	
	if self.myQASimple = null then
		create self.myQASimple transient;
	endif;
	
	if self.myHookAgent = null then
		create self.myHookAgent transient;
	endif;
	
	if self.myTimeZoneHelper = null then
		create self.myTimeZoneHelper transient;
	endif;
	self.systemTimeZoneID := self.myTimeZoneHelper.getSystemTimeZoneID();
	
	//03 Apr 2019	NDL	TFS 44194 - CMIF_AlternateDictionary
	if self.myAlternateDict = null then
		create self.myAlternateDict transient;
	endif;
	
	//20.07.2022 navam1 #52824
	if self.mySSOAgent = null and app.applicationType = app.ApplicationType_GUI then	// TFS 55088 navmd1 05/10/2022
		create self.mySSOAgent transient;
	endif;
	
end;</source>
    </JadeMethod>
