<Class name="CMIF_BOLOutLine" id="ee998c2b-4c49-4645-9c3b-7c0fa1b4eaf8">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <PrimAttribute name="lineType" id="ec83e0c5-c68d-42e1-aade-71bc30f9e0e1">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <ImplicitInverseRef name="myCargoType" id="7e77d7e6-454c-4d49-bcd2-7dcdfb0c7d6c">
        <embedded/>
        <type name="CM_CargoType"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myProduct" id="7fff5f93-c55a-4950-8c70-2ffea2082d13">
        <embedded/>
        <type name="CM_Product"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myStockOrderLine" id="9299cde1-d56c-4391-b048-a3603547d739">
        <embedded/>
        <type name="CM_StockOrderLine"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myTrackedItem" id="f9e9ca64-b04f-45bf-b9b6-dd84f95e9680">
        <embedded/>
        <type name="CM_TrackedItem"/>
    </ImplicitInverseRef>
    <PrimAttribute name="quantityTaken" id="68fa334b-e5e7-45bb-bc51-6a5964151219">
        <embedded/>
