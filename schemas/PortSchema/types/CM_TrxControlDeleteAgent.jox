    <JadeMethod name="trxDeleteJobs" id="89574fc9-891f-406b-8cb1-83bb051997da">
        <updating/>
        <source>trxDeleteJobs(_jobs : CM_JobSet io; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     July 2009 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theJob : CM_Job;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;

	foreach theJob in _jobs discreteLock do
		app.myUtilityDA.utlDeleteJob(theJob, _passport);
	endforeach;
	if _passport.hasErrorsOrWarnings() then
		return;
	endif;

epilog		
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_jobs" type="CM_JobSet" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
