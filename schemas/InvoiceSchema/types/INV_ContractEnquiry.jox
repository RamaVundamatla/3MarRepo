    <JadeMethod name="mnuSwitchPrimary_click" id="2948ecfa-ec80-423a-a0b3-90fb7f56e6f6">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuSwitchPrimary_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 March 2024 navrv30 Initial creation - Bug 62682: FR - 54089 - Primary status - Invoice contracts

*/

vars
    primaryContract,
	otherContract : CM_InvoiceContract;
	theReturn : Integer;
	pxyConOther, pxyConPrimary : CM_InvoiceContract;
begin
	if self.tblData.allSelectedObjects.first.CM_InvoiceContract.primary then 
		primaryContract := self.tblData.allSelectedObjects.first.CM_InvoiceContract;
		otherContract := self.tblData.allSelectedObjects.last.CM_InvoiceContract;
	else
		primaryContract := self.tblData.allSelectedObjects.last.CM_InvoiceContract;
		otherContract := self.tblData.allSelectedObjects.first.CM_InvoiceContract;	
	endif;		
	
	pxyConOther := app.createUpdateProxy(otherContract).CM_InvoiceContract;
	pxyConOther.setProxy(otherContract.active,otherContract.contractId, otherContract.fromTS, otherContract.toTS, true, pxyConOther.myBusinessUnit, pxyConOther.myTerminal, otherContract.getDebtor(),otherContract.description); 
	
	pxyConPrimary := app.createUpdateProxy(primaryContract).CM_InvoiceContract;
	pxyConPrimary.setProxy(primaryContract.active,primaryContract.contractId, primaryContract.fromTS, primaryContract.toTS, false, pxyConPrimary.myBusinessUnit, pxyConPrimary.myTerminal, primaryContract.getDebtor(),primaryContract.description);
	
	while true do		
		app.myTrxUA.trxSwitchInvContracts(pxyConPrimary, pxyConOther, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			app.msgBox(app.getErrorString(Invoice_contrac_update_sucess), app.getErrorString(Message),MsgBox_OK_Only);
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Invoice_contract_update), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
		endif;
		break;
	endwhile;

epilog
	delete pxyConOther;
	delete pxyConPrimary;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setBusinessUnit" id="4645914f-fdff-48e5-b847-11721bc69adf">
