    <JadeMethod name="setForUpdate" id="7bb1ad8b-d1c7-42a0-8158-799bab2f89a3">
        <updating/>
        <source>setForUpdate( _proxy : CM_InvoiceSignoffUser ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2018	jlgndl1	Initial creation	TFS 38535

*/

vars

begin

	self.effectiveDT := _proxy.effectiveDT;
	self.myBusinessUnit := _proxy.myBusinessUnit;
	if _proxy.myUser &lt;&gt; null then
		//so we always have the details in history even if the user is deleted or set to null
		self.userID := _proxy.myUser.code;
		self.userName := _proxy.myUser.userName;
	endif;
	self.myUser := _proxy.myUser;
	self.userJobTitle := _proxy.userJobTitle.trimBlanks;

epilog

end;</source>
        <Parameter name="_proxy" type="CM_InvoiceSignoffUser"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="4b889ede-9400-4b29-9125-3e0cd585b198">
        <updating/>
        <source>setProxy(	_effectiveDT : TimeStamp;
			_businessUnit : CM_Bank;
			_user : CM_User;
			_userJobTitle : String
			) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2018	jlgndl1	Initial creation	TFS 38535

*/

vars

begin

	self.effectiveDT := _effectiveDT;
	self.myBusinessUnit := _businessUnit;
	self.myUser := _user;
	self.userJobTitle := _userJobTitle;

epilog

end;</source>
        <Parameter name="_effectiveDT" type="TimeStamp"/>
        <Parameter name="_businessUnit" type="CM_Bank"/>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_userJobTitle" type="String"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="8c509ea9-a5bf-4ff9-989d-1063f9a76628">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2018	jlgndl1	Initial creation

*/

vars

	propName	: String;
	
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if	propName = CM_InvoiceSignoffUser::myUser.name   or 
		propName = CM_InvoiceSignoffUser::myBusinessUnit.name or
		propName = CM_InvoiceSignoffUser::myChildQuantityMap.name
		then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
