    <JadeMethod name="utlCreateMenuUserReportSaved" id="67a6ae8d-77d9-4385-aa38-efbb1b5de52e">
        <updating/>
        <source>utlCreateMenuUserReportSaved(	_name,		
								_description	: String;
								_root			: CM_MenuRoot;
								_menu			: CM_MenuEntity;
								_jadeReport		: JadeReport;
								_passport 		: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     20 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	cancelSave 		: Boolean;
	userTerminal	: CM_UserTerminal;
	reportTemplate	: CM_ReportTemplate;
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	if _name = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Name', 'Name', null);
		app.raiseCMException(Input_required_field_name, 'Name', null); // cnwdb2	PAR 35364


	endif;
	
	if _jadeReport = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'JadeReport', 'JadeReport', null);
		app.raiseCMException(Input_required_field_jadeReprt, 'JadeReport', null); // cnwdb2	PAR 35364		
	endif;
	
	if _root = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'MenuRoot', 'MenuRoot', null);
		app.raiseCMException(Input_required_field_mnuRoot, 'MenuRoot', null); // cnwdb2	PAR 35364		
	endif;
	
	if _menu = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'menu', 'menu', null);
		app.raiseCMException(Input_required_field_menu, 'menu', null); // cnwdb2	PAR 35364


	endif;
	
	if _passport.myUser = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'User', 'User', null);
		app.raiseCMException(Input_required_field_Usr, 'User', null); // cnwdb2	PAR 35364


	endif;
	
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	create reportTemplate persistent;
	
	reportTemplate.setForCreateSavedReport(_name, _description, _passport.myUser, _jadeReport, _root, _menu);
	

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_root" type="CM_MenuRoot"/>
        <Parameter name="_menu" type="CM_MenuEntity"/>
        <Parameter name="_jadeReport" type="JadeReport"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateMoveMap" id="e0020cb1-0e12-4855-ba2a-1b9bf2a575e2">
        <source>utlCreateMoveMap(_proxyMoveMap:CM_MoveMap; _newMoveMap:CM_MoveMap output; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theCloned : CM_MoveMap;
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valMoveMap(_proxyMoveMap);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	if _proxyMoveMap.clonedFromId.trimBlanks &lt;&gt; null then
		theCloned := _proxyMoveMap.terminal.moveMaps[_proxyMoveMap.clonedFromId.trimBlanks];
		if theCloned &lt;&gt; null then
			_newMoveMap := theCloned.clone(_proxyMoveMap.id.trimBlanks);
		else
			create _newMoveMap persistent;
			_newMoveMap.setForCreate(_proxyMoveMap);
		endif;
	else
		create _newMoveMap persistent;
		_newMoveMap.setForCreate(_proxyMoveMap);
	endif;

end;</source>
        <Parameter name="_proxyMoveMap" type="CM_MoveMap"/>
        <Parameter name="_newMoveMap" type="CM_MoveMap" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
