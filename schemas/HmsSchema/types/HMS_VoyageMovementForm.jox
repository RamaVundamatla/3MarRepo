    <JadeMethod name="doBtnEdit" id="ead6bd33-93cc-4011-be0f-aa21e7dfef3f">
        <updating/>
        <source>doBtnEdit()updating;
//--------------------------------------------------
// Created:	06 April 2005 By: cnwgd1
//--------------------------------------------------
// 02 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

begin
	if self.myCurrentMovement = null then
		app.msgBox('Cannot perform edit as there is no movement selected.', 'Error', MsgBox_Stop_Icon  + MsgBox_OK_Only);
		self.cmbMovements.setFocus();
		return;
	endif;

	if self.myCurrentMovement.myHMSVoyageData.voyageStatus = HMS_VoyageIsLocked then
		//Voyage is locked therefore they cannot change date/times berth etc
		app.msgBox('Cannot perform edit as the movement is locked.', 'Error', MsgBox_Stop_Icon  + MsgBox_OK_Only);
		return;
	endif;

	self.myProxyMovement	:=	app.createUpdateProxy(self.myCurrentMovement).HMS_VoyageMovement;
	self.myCurrentMovement	:=	self.myProxyMovement;
	
	self.mode	:=	self.Mode_Update;

	// Populate tables with the proxy objects
	self.displayHMSResources(null);
	self.setSelectedResources();
	self.displayMvmntPilotDetails(); // TFS 44438	
	self.displayResourceUsed();
	self.setControlsForAddEdit();
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnNew" id="9d63728e-47f9-46a2-a16c-2c90083b3f92">
        <updating/>
        <source>doBtnNew()updating;
//--------------------------------------------------
// Created:	06 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpTopSheet	: Sheet;
begin

	//Can only add shift movements, therefore there must be a current movement selected
	if self.myCurrentMovement = null then
		app.msgBox(app.getErrorString(HMSCannotCreateShift), app.getErrorString(HMS_Select_Movement), MsgBox_Stop_Icon + MsgBox_OK_Only);
		return;
	endif;
	
	self.myCurrentMovement := self.myCurrentMovement.cloneMySelfAsMoveType(HMSMovementTypeShift, null, true, app.myPassport);
	
	self.myProxyMovement := self.myCurrentMovement;
			
	self.mode := self.Mode_Add;

	tmpTopSheet := self.fldMain.topSheet;
	self.cmbMovements.listIndex := -1;

	self.displayMovementDetails(); //&lt;&lt;-- clears the form					

	self.setControlsForAddEdit(); //&lt;&lt;-- also sets the defaults

	self.btnShippingAgent.enabled := self.cmbShippingAgent.listObject &lt;&gt; null;		
	self.btnShippingLine.enabled := self.cmbShippingLine.listObject &lt;&gt; null;				
	
	self.txtMoveOnDate.setFocus();
	self.fldMain.topSheet := self.shtGeneral;		

	if tmpTopSheet &lt;&gt; self.shtGeneral then
		self.doResizeTopSheet();
	endif;	
end;</source>
    </JadeMethod>
    <JadeMethod name="doCancelMovement" id="afe91c6f-a64c-47a4-b82d-44fa0634ce1b">
        <updating/>
        <source>doCancelMovement()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 November 2018	jlgndl1	Initial creation	TFS 42043

*/

vars

	cancelMovement : HMS_VoyageMovement;
	pxyCancelMove : HMS_VoyageMovement;
	pxyNewMovement : HMS_VoyageMovement;
	realNewMovement : HMS_Movement;
	woDtlForStatusChg : CM_WorkOrderVoyageDtl;
	load : Boolean;
	result : Integer;
	voyage : CM_Voyage;
	woPermitToClear : CM_WodPermitRequest;

begin

	cancelMovement := self.myCurrentMovement;
	
	if cancelMovement = null then
		return;
	endif;
	
	voyage := cancelMovement.getMyVoyage();
	
	if cancelMovement.moveType.isOneOf( HMSMovementTypeArrival, HMSMovementTypeShift, HMSMovementTypeDeparture ) then
	
		app.cmsBeginLoad(load);
		pxyCancelMove := app.createUpdateProxy( self.myCurrentMovement ).HMS_VoyageMovement;
		app.cmsEndLoad(load);
		pxyCancelMove.setPxyCancelledAttribs( pxyNewMovement, woDtlForStatusChg, woPermitToClear );
		
		while true do
		
			app.myTrxUA.trxCancelHMSMovement( pxyCancelMove, woDtlForStatusChg, woPermitToClear, pxyNewMovement, realNewMovement, app.myPassport );
			
			if app.myPassport.trxCompletedOK then
				self.clearErrorWarnings();
				self.setMyCurrentMovement( null );
				self.populateCmbMovements( voyage );
				break;
				
			else
				result := app.showErrorWarningDialog( app.getErrorString(Cancel_movement), app.myPassport, ErrWarnMode_AddUpdate+ErrWarnMode_CanAckWarnings );
				if app.myPassport.noErrors and result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			
			endif;
			
			return;
			
		endwhile;
		
	else
		return;
	endif;

epilog

	delete pxyCancelMove;
	if pxyNewMovement &lt;&gt; null and app.isValidObject( pxyNewMovement ) then
		delete pxyNewMovement;
	endif;
	app.cmsEndLoad(load);

end;</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="5e2f42e5-b816-4b17-ac6f-974d605fb425">
        <updating/>
        <source>doDelete(): Boolean updating;
//--------------------------------------------------
// Created:	06 April 2004 By: cnwgd1
//--------------------------------------------------
vars
	move : HMS_Object;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	move := self.myCurrentMovement;
	if move = null then
		return false;
	endif;
	
	if self.myCurrentMovement.moveType=HMSMovementTypeArrival or self.myCurrentMovement.moveType=HMSMovementTypeDeparture then
		// Tell user that they cannot delete a departure or arrival movement unless they delete the entire voyage
		app.msgBox(app.getErrorString(ArrDeptMoveNoDelete), app.getErrorString(MSGBOX_InvalidAction), MsgBox_OK_Only+MsgBox_Exclamation_Mark_Icon+MsgBox_Default_First);
		return false;
	elseif app.msgBox(app.getErrorString(MSGBOX_DeleteMovement) &amp; "'" &amp; self.myCurrentMovement.moveType &amp; ": " &amp; self.systemToLocalTime(self.myCurrentMovement.occursOnDTNEW).String &amp; "' ?", app.getErrorString(Confirm_Delete), MsgBox_Yes_No+MsgBox_Question_Mark_Icon+MsgBox_Default_Second)=MsgBox_Return_No then
		return false;		// 26/5/16 cnwmp6 TFS 488 - Multi timezone support
	endif;		
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteHMSObject(move, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			self.setMyCurrentMovement( null );
			return true;
		else
			theResult := app.showErrorWarningDialog('Delete Movement', app.myPassport, ErrWarnMode_Delete);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMvmntPilotDetailsDelete" id="4355cfde-aa84-47c4-9263-7661245440ab">
        <source>doMvmntPilotDetailsDelete();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

*/

vars
	theRow : Integer;
begin
	self.tblPilotLaunch.findObjectInRow(self.mnuPilotLaunchDelete.userObject, theRow);
	if theRow &gt; self.tblPilotLaunch.fixedRows then
		if self.tblPilotLaunch.accessRow(theRow).enabled then
			//OK to delete row
			self.tblPilotLaunch.removeItemObject(self.mnuPilotLaunchDelete.userObject);
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doPilotAdd" id="55cc29e4-5ad7-4652-a189-5662333cb4ce">
        <updating/>
        <source>doPilotAdd() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

*/

vars
	tmpPilot : HMS_Pilot;
	proxy : HMS_MovementPilotDetails;
begin
	if self.mode &lt;&gt; self.Mode_Update
	and self.mode &lt;&gt; self.Mode_Add then
		return;
	endif;
	
	if self.tblPilotLaunch.row &gt; self.tblPilotLaunch.fixedRows then
		if self.tblPilotLaunch.accessRow(self.tblPilotLaunch.row).enabled then
			tmpPilot := self.tblPilotLaunch.accessCell(self.tblPilotLaunch.row, self.tblPilotLaunch.getColumnByRowName(ETRow_MyPilot)).cellControl.CMUI_ComboBox.listObject.HMS_Pilot;
		endif;
	endif;

	if tmpPilot = null then // get first valid pilot for this terminal &amp; harbour
		foreach tmpPilot in app.myRoot.allPilots discreteLock where not tmpPilot.isNotAvailableForEntry
			and tmpPilot.myCurrentHarbour = self.myTerminal.myHarbour do
			break;
		endforeach;	
	endif;
	
	if tmpPilot = null then
		app.raiseCMException(Input_require_pilot_field, null, null);
		return;
	endif;
	
	create proxy transient;
	proxy.setProxy(tmpPilot, null, self.myCurrentMovement, null);
	self.addMvmntPilotDetailsToTable(proxy);
	self.tblPilotLaunch.selected := false;
	self.tblPilotLaunch.row := self.tblPilotLaunch.rows;
	self.tblPilotLaunch.column := 1;
	self.anythingChanged := true;	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryRowColumnChange" id="ef08d2a1-63ce-4448-8413-c5a5b8d9c46f">
        <updating/>
        <source>doQueryRowColumnChange(table: Table input; newRow: Integer) updating;
//--------------------------------------------------
// Created:	16 February 2005 By: cnwgd1
//--------------------------------------------------
// 09 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement
vars
	theRow,
	cols,
	idx,
	col : Integer;
begin

	theRow := table.row;

	cols := table.columns;
	col := table.column+1;
	
	if col &gt; cols then
		//end of row
		foreach idx in theRow+1 to table.rows do
			if table.accessRow(idx).enabled then
				return;
			endif;
		endforeach;				
		if table.name = "tblPilotLaunch" then // TFS 44438
			self.doPilotAdd(); // TFS 44438
		else // TFS 44438
			self.doResourceAdd();
		endif; // TFS 44438
		return;
	endif;		
	
	while col &lt;= cols do
		if table.accessCell(theRow, col).enabled then
			break;
		endif;
		if col+1 &gt; cols then
			foreach idx in theRow+1 to table.rows do
				if table.accessRow(idx).enabled then
					return;
				endif;
			endforeach;		
			//end of row
			if table.name = "tblPilotLaunch" then // TFS 44438
				self.doPilotAdd(); // TFS 44438
			else // TFS 44438
				self.doResourceAdd();
			endif; // TFS 44438
				return;
		endif;
		col := col+1;			
	endwhile;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="newRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="ae74571c-e88f-4b59-a213-bde12a2999ec">
        <updating/>
        <source>doResize() updating;
//--------------------------------------------------
// Created:	05 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpTop : Real;
begin

	tmpTop := (self.frmToolbar.height+VerticalSpacing);
	self.lblVoyage.top := tmpTop;
	self.cmbHMSVoyage.top := tmpTop;
	self.cmbMovements.top := tmpTop;
	self.lblMovements.top := tmpTop;
	self.lblReplaced.top := tmpTop;	//19 Nov 2018	NDL	TFS 42043
	tmpTop := (tmpTop+VerticalSpacing+cmbHMSVoyage.height);
	self.fldMain.top := tmpTop;

	inheritMethod();	
	
	self.doResizeTopSheet();

end;</source>
    </JadeMethod>
    <JadeMethod name="doResizeTopSheet" id="9179475a-3e8c-4471-b1e4-706803cc758d">
        <source>doResizeTopSheet()protected;
//--------------------------------------------------
// Created:	20 June 2005 By: cnwgd1
//--------------------------------------------------
vars
	topSheet : Sheet;
begin
	topSheet := self.fldMain.topSheet;

	if topSheet = self.shtCustomer then
		self.grpCustomer.centreHorizontallyInParent();
		self.grpCustomer.centreVerticallyInParent();		
	elseif topSheet = self.shtGeneral then
		self.grpGeneral.centreHorizontallyInParent();
		self.grpGeneral.centreVerticallyInParent();		
	elseif topSheet = self.shtMarineService then
		self.grpMarineService.centreHorizontallyInParent();
		self.grpMarineService.centreVerticallyInParent();										
	elseif topSheet = self.shtResources then
	elseif topSheet = self.shtTidalInfo then
		self.grpTidalInfo.centreHorizontallyInParent();
		self.grpTidalInfo.centreVerticallyInParent();		
	elseif topSheet = self.shtWharfServices then		
	endif;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResourceAdd" id="68b00d6c-dc1c-4c3e-88a9-dc678128cac1">
        <updating/>
        <source>doResourceAdd()updating;
//--------------------------------------------------
// Created:	15 February 2005 By: cnwgd1
//--------------------------------------------------
// 10/12/2014  cnwdb2	PAR 35364

vars
	tmpRsType : HMS_ResourceType;
	proxy : HMS_ResourceUsed;
begin
	if self.mode &lt;&gt; self.Mode_Update
	and self.mode &lt;&gt; self.Mode_Add then
		return;
	endif;

	if self.tblResUsed.row &gt; self.tblResUsed.fixedRows then
		if self.tblResUsed.accessRow(self.tblResUsed.row).enabled then
			tmpRsType := self.tblResUsed.accessCell(self.tblResUsed.row, self.tblResUsed.getColumnByRowName(ETRow_MyResourceType)).cellControl.CMUI_ComboBox.listObject.HMS_ResourceType;
		endif;
	endif;

	if tmpRsType = null then			
		// search for default capable of being displayed (first one). 
		foreach tmpRsType in app.myRoot.allResourceTypes discreteLock do 
			if tmpRsType.isNotAvailableForEntry or tmpRsType.isMarineService then 		
				// if either 'not available' or is a marine service then look for the next one to use. 
				continue; 
			endif;
			break; // get this far then must have Resource Type that can be displayed. 
		endforeach;
//		commented out as was returning ones that it shouldnt. 
//		tmpRsType := app.myRoot.allResourceTypes.first;
	endif;

	if tmpRsType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Resource Type', null, null);
		app.raiseCMException(Input_required_field_resorceTy, null, null); // cnwdb2	PAR 35364

		return;
	endif;
	
	create proxy transient;
	proxy.setProxy(self.myCurrentMovement.myHarbour, tmpRsType, null, null, null, null, null,false,null,null);
	self.addResourceUsedToTable(proxy);

	self.tblResUsed.selected := false;
	self.tblResUsed.row := self.tblResUsed.rows;
	self.tblResUsed.column := 1;	

	self.anythingChanged := true;			
end;</source>
    </JadeMethod>
    <JadeMethod name="doResourceClick" id="f36b87e0-dba5-4204-b33d-f00e0f5a183a">
        <source>doResourceClick();
//--------------------------------------------------
// Created:	16 February 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpCellR : JadeTableCell;
	defQty	: Real;
	tmpRes : HMS_Resource;
	cM : HMS_VoyageMovement;
begin

	tmpCellR := self.tblResUsed.accessCell(self.tblResUsed.row, self.tblResUsed.getColumnByRowName(ETRow_MyResource));
	tmpCellR.text := tmpCellR.cellControl.CMUI_ComboBox.text;

	// ### Default the number of crew to the units used IF the resource is teh Line Company's resource
	cM := self.myCurrentMovement;
	if cM.myLineCompany &lt;&gt; null
	and tmpCellR.cellControl.CMUI_ComboBox.listObject = cM.myLineCompany.getResourceForHarbourMovement(cM.myHarbour,cM.moveType) then
		defQty := self.tbxLineCrewReqd.text.Integer;
		tmpCellR := self.tblResUsed.accessCell(self.tblResUsed.row, self.tblResUsed.getColumnByRowName(ETRow_UnitsUsed));
		tmpCellR.text := defQty.String;
		tmpCellR.cellControl.TextBox.text := defQty.String;
	endif;

		
end;</source>
    </JadeMethod>
    <JadeMethod name="doResourceCopy" id="176a1c50-6b7e-4fe3-8ae5-d2a1ec159822">
        <updating/>
        <source>doResourceCopy(_fromMovement : HMS_VoyageMovement) updating;
// copy resource usage taking units but not dates 31075
vars
	usage	: HMS_ResourceUsed;
	proxy	: HMS_ResourceUsed;

begin
	foreach usage in _fromMovement.allResourceUsed do
		create proxy transient;
		proxy.setProxy(self.myCurrentMovement.myHarbour, usage.myResourceType, usage.myResource, null, null, null, usage.unitsUsed, usage.partOfContract,null,usage.myDebtor);
		self.addResourceUsedToTable(proxy);

	endforeach;

	self.tblResUsed.selected := false;
	self.tblResUsed.row := self.tblResUsed.rows;
	self.tblResUsed.column := 1;
	self.anythingChanged := true;			

end;
</source>
        <Parameter name="_fromMovement" type="HMS_VoyageMovement"/>
    </JadeMethod>
    <JadeMethod name="doResourceCopyClick" id="be51d180-8d56-4b69-b6d5-eba561846972">
        <source>doResourceCopyClick();
// 31075
constants
	MaxVoyages = 10;
vars
	arrived	: TimeStamp;
	count	: Integer;
	code	: String;
	voyage	: CM_Voyage;
	vessel	: CM_Vessel;
	priorVoyage	: CM_Voyage;
	term	: CM_Terminal;
	iter	: Iterator;
begin
	self.frmCopyResource.top := 100;
	self.frmCopyResource.left := 100;
	voyage :=self.myCurrentMovement.myHMSVoyageData.myVoyage;
	term := voyage.myTerminal;
	arrived := voyage.arrivedDT;
	code := voyage.code;
	vessel := voyage.myVessel;
	// get prior voyages (ideally this should be by arived date before code, but in practice vessel codes 
	//  are typically in arrival date sequence)
	iter := vessel.allVoyagesByTermCodeArrival.createIterator;
	vessel.allVoyagesByTermCodeArrival.startKeyGeq(term, code, arrived, iter);
	self.cmbCopyVoyage.clear();
	while iter.back(priorVoyage) do
		if priorVoyage.myVessel &lt;&gt; vessel then
			continue;
		endif;
		count := count + 1;
		if count &gt; MaxVoyages then
			break;
		endif;
		self.cmbCopyVoyage.itemObject[self.cmbCopyVoyage.addItem(priorVoyage.code &amp; '  ' &amp; priorVoyage.arrivedDT.shortCurrentLocaleFormat)] := priorVoyage;
	endwhile;
	
	if self.cmbCopyVoyage.listCount &gt; 0 then
		self.cmbCopyVoyage.listIndex := 1;
		self.cmbCopyVoyage.click(self.cmbCopyVoyage);	// set up the movement combo
	endif;
	self.cmbCopyVoyage.setFocus();
	self.frmCopyResource.visible := true;
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="doResourceDelete" id="475538a9-a80c-4867-874f-41bc05196e0c">
        <source>doResourceDelete();
//--------------------------------------------------
// Created:	15 February 2005 By: cnwgd1
//--------------------------------------------------
vars
	theRow : Integer;
begin
	self.tblResUsed.findObjectInRow(self.mnuResourceDelete.userObject, theRow);
	if theRow &gt; self.tblResUsed.fixedRows then
		if self.tblResUsed.accessRow(theRow).enabled then
			//Ok to delete row
			self.tblResUsed.removeItemObject(self.mnuResourceDelete.userObject);
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doResourceTypeClick" id="ff88ec7b-65a0-4cc7-ad9f-781be632dbe9">
        <updating/>
        <source>doResourceTypeClick()updating;
//--------------------------------------------------
// Created:	16 February 2005 By: cnwgd1
//--------------------------------------------------
vars
	theRow : Integer;
	tmpCell : JadeTableCell;
	tmpCmbRT : CMUI_ComboBox;
	tmpCmbR : CMUI_ComboResources;
	tmpTxtUnits : CMUI_TextBox;
	tmpRType : HMS_ResourceType;
	tmpRes : HMS_Resource;
	defDateTime : TimeStamp;
	defDTString, defTMString : String;
//	tmpDateBox : CMUI_DateMask;
//	tmpTimeBox : CMUI_TimeMask;
	defQty :Real;
	cM : HMS_VoyageMovement;
begin
	
	theRow  := self.tblResUsed.row;
	
	tmpCell := self.tblResUsed.accessCell(theRow, self.tblResUsed.getColumnByRowName(ETRow_MyResourceType));
	tmpCmbRT := tmpCell.cellControl.CMUI_ComboBox;
	
	tmpCell := self.tblResUsed.accessCell(theRow, self.tblResUsed.getColumnByRowName(ETRow_MyResource));
	tmpCmbR := tmpCell.cellControl.CMUI_ComboResources;
	
	tmpRType := tmpCmbRT.listObject.HMS_ResourceType;

	// ### PAR 10220 set defaults
	// ### Default the number of crew to the units used IF the resource is the Line Company's resource
	if tmpRType.allResources.size = 1 then 
		tmpRes := tmpRType.allResources.first;
		if tmpRes.isNotAvailableForEntry then 
			tmpRes := null;
		endif;
		if tmpRes &lt;&gt; null then
			cM := self.myCurrentMovement;
			if cM.myLineCompany &lt;&gt; null
			and tmpRes = cM.myLineCompany.getResourceForHarbourMovement(cM.myHarbour,cM.moveType) then
				defQty := self.tbxLineCrewReqd.text.Integer;
			endif;
		endif;
	endif;

	if tmpRType.isActionDateTimeRequired then
		defDateTime := self.systemToLocalTime(self.myCurrentMovement.occursOnDTNEW);	// 26/5/16 cnwmp6 TFS 488 - Multi timezone changes
		
		if defDateTime.isValid() then
			defDTString := defDateTime.date().shortFormatJMT();
			tmpCell := self.tblResUsed.accessCell(theRow, self.tblResUsed.getColumnByRowName(ETRow_FromDate));
			tmpCell.text := defDateTime.date().shortFormatJMT();
//rs			tmpDateBox := tmpCell.cellControl.CMUI_DateMask;
//rs			tmpDateBox.setDate(defDateTime.date);
			
			defTMString := defDateTime.time().shortFormatJMT();
			tmpCell := self.tblResUsed.accessCell(theRow, self.tblResUsed.getColumnByRowName(ETRow_FromTime));	
			tmpCell.text := defDateTime.time().shortFormatJMT();
//rs			tmpTimeBox := tmpCell.cellControl.CMUI_TimeMask;
//rs			tmpTimeBox.setTime(defDateTime.time);
		endif;
	endif;
		
//	self.myAssistant.comboBoxHMSResource(tmpCmbR, tmpRes, tmpRType, null);
	tmpCmbR.setObjectAndResourceType(tmpRes, tmpRType, self.myTerminal.myHarbour); // PAR 31709 pass in harbour
	
	tmpCell := self.tblResUsed.accessCell(theRow, self.tblResUsed.getColumnByRowName(ETRow_MyResourceType));	
//	tmpCell.text := tmpCmbRT.text &amp; Tab &amp; '' &amp; Tab &amp; ''&amp; Tab &amp; tmpRType.quantityUnits &amp; Tab &amp; '' &amp; Tab &amp; '' &amp; Tab &amp; '' &amp; Tab &amp; '';

	// ### PAR 10220
	tmpCell.text := tmpCmbRT.text &amp; Tab 
					&amp; '' &amp; Tab 
					&amp; defQty.String &amp; Tab 
					&amp; tmpRType.quantityUnits &amp; Tab 
					&amp; defDTString &amp; Tab 
					&amp; defTMString &amp; Tab 
					&amp; '' &amp; Tab 
					&amp; '';

// set decimal places for Units - Par 10249
	tmpCell := self.tblResUsed.accessCell(theRow, self.tblResUsed.getColumnByRowName(ETRow_UnitsUsed));
	tmpCell.text	:=	null;
	tmpCell.decimals	:=	tmpRType.numDecimalPlaces;
	tmpTxtUnits := tmpCell.cellControl.CMUI_TextBox;
	tmpTxtUnits.text := null;// clear old value as can cause error if changing decimals
	tmpTxtUnits.decimals := tmpRType.numDecimalPlaces;
	// ### Default the number of crew to the units used IF the resource is teh Line Company's resource, else defQty will be ZERO
	tmpCell.cellControl.TextBox.text := defQty.String;

	self.setTblResourceCells(theRow, self.tblResUsed.accessRow(theRow).itemObject.HMS_ResourceUsed, tmpRType);

	self.anythingChanged := true;

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="43d6d821-71bf-4af5-9168-e6cac3b3ea27">
        <updating/>
        <source>doSave(): Boolean updating;
//--------------------------------------------------
// Created:	06 April 2004 By: cnwgd1
//--------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
17/10/2019  jlgka1 	TFS 46888 	JMT - Graphical View - 1090 exception
============================================================================*/
vars
	result : Integer;
	theProxy : HMS_VoyageMovement;
	realMovement : HMS_Object;
begin
	
	self.validateResourceTable(); // jlgka1 TFS 46888
	
	if self.myProxyMovement = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy is null for update');
		return false;
	else
		theProxy := self.myProxyMovement;	
	endif;

	// set the proxy
	self.setPxyMovement(theProxy);
	
	while true do
		if self.mode = self.Mode_Add then
			app.myTrxCA.trxCreateHMSMovement(theProxy, realMovement, app.myPassport);
		elseif self.mode = self.Mode_Update then
			app.myTrxUA.trxUpdateHMSMovement(theProxy, app.myPassport);
		else
			app.raiseUnexpectedProgramError(class.name,	method.name, ' Invalid mode (' &amp; self.mode.String &amp; ')');
			return false;
		endif;
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Movement Maintenance', app.myPassport, ErrWarnMode_AddUpdate+ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		return false;
	endwhile;

	return true;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveProxyResourceUsedInvoice" id="23590e33-bf9c-4fb0-a70b-c91262e79d0e">
        <source>doSaveProxyResourceUsedInvoice(_pxyMovement : HMS_VoyageMovement input)protected;
//--------------------------------------------------
// Created:	February 2005 By: cnwgd1
//--------------------------------------------------
vars
	rowIdx,
	row,
	numRows : Integer;
	unitsUsed :Real;
	tmpTable : CM_DataTable;
	pxyResourceUsed,aRes : HMS_ResourceUsed;
begin
	if _pxyMovement = null then
		return;
	endif;

	// We do not show marine services so do not clear them out
	foreach aRes in _pxyMovement.allResourceUsed discreteLock  do
		if aRes.myResourceType &lt;&gt; null and aRes.myResourceType.isMarineService then
			continue;
		endif;
		_pxyMovement.allResourceUsed.remove(aRes);
	endforeach;
	
	if (not self.shtResources.visible) then
		return;
	endif;
	
	if (not app.myCurrentUserCan(self.myTerminal, Mod_Invoicing)) then
		return;
	endif;
		
	tmpTable := self.tblResUsed;
	row := tmpTable.fixedRows+1;
	numRows := tmpTable.rows;	
	
	foreach rowIdx in row to numRows do
		
		pxyResourceUsed := tmpTable.accessRow(rowIdx).itemObject.HMS_ResourceUsed;
		
		if tmpTable.accessRow(rowIdx).enabled then
			//Update 
			self.doSetProxyResourceUsed(_pxyMovement, pxyResourceUsed, rowIdx);
		endif;

		if (not _pxyMovement.allResourceUsed.includes(pxyResourceUsed)) then
			_pxyMovement.allResourceUsed.add(pxyResourceUsed);
		endif;

	endforeach;

	foreach pxyResourceUsed in _pxyMovement.allResourceUsed do
		if _pxyMovement.myLineCompany &lt;&gt; null and pxyResourceUsed.myResource &lt;&gt; null then
			if _pxyMovement.myLineCompany.getResourceForHarbourMovement(_pxyMovement.myHarbour,_pxyMovement.moveType) = pxyResourceUsed.myResource then
				if pxyResourceUsed.unitsUsed = 0 then
					unitsUsed := self.tbxLineCrewReqd.text.Integer;
					pxyResourceUsed.setPropertyValue("unitsUsed",unitsUsed);
					
				 endif; 
			endif;
		endif;
	endforeach;
	
end;</source>
        <access>protected</access>
        <Parameter name="_pxyMovement" type="HMS_VoyageMovement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doSaveProxyResourcesUsed" id="4aed547d-42a3-4b5b-b21b-c89815ce6a8f">
        <source>doSaveProxyResourcesUsed(_pxyMovement : HMS_VoyageMovement input)protected;
//--------------------------------------------------
// Created:	07 April 2004 By: cnwgd1
//--------------------------------------------------
vars
	idx,
	listCount : Integer;
	obj : Object;
	tmpResource : HMS_Resource;
	pxyResourceUsed : HMS_ResourceUsed;
begin
	if _pxyMovement = null then
		return;
	endif;

	_pxyMovement.allResourceUsed.clear();

	if (not self.shtWharfServices.visible) then
		return;
	endif;
			
	if app.myCurrentUserCan(self.myTerminal, Mod_Invoicing) then
		return;
	endif;

	listCount := self.lstWharfServices.listCount;

	idx := idx+1;
	while idx &lt;= listCount do
		if (not self.lstWharfServices.itemSelected[idx]) then
			idx := idx+1;
			continue;
		endif;
		obj := self.lstWharfServices.itemObject[idx];
		if HMS_Resource.hasInstance(obj) then
			tmpResource := obj.HMS_Resource;
			create pxyResourceUsed transient;
			_pxyMovement.allResourceUsed.add(pxyResourceUsed);
			pxyResourceUsed.setDefaultForMovement(false,tmpResource, tmpResource.myResourceType, app.myPassport);	
		elseif HMS_ResourceUsed.hasInstance(obj) then
			if (not _pxyMovement.allResourceUsed.includes(obj.HMS_ResourceUsed)) then
				_pxyMovement.allResourceUsed.add(obj.HMS_ResourceUsed);				
			endif;
		endif;
		idx := idx+1;		
	endwhile;
	
end;</source>
        <access>protected</access>
        <Parameter name="_pxyMovement" type="HMS_VoyageMovement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doSavePxyMvmntPilotDetails" id="7a0d0fcd-323b-4510-ad3b-c1f7a3f6b5b8">
        <source>doSavePxyMvmntPilotDetails(_pxyMovement : HMS_VoyageMovement input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

*/

vars
	rowIndex, row, numRows : Integer;
	proxyMvmntPilotDetails : HMS_MovementPilotDetails;
	tmpTable : CM_DataTable;
begin
	if _pxyMovement = null then
		return;
	endif;
	
	if (not self.shtMarineService.visible) then
		return;
	endif;

	tmpTable := self.tblPilotLaunch;
	row := tmpTable.fixedRows + 1;
	numRows := tmpTable.rows;
	
	foreach rowIndex in row to numRows do
		proxyMvmntPilotDetails:= tmpTable.accessRow(rowIndex).itemObject.HMS_MovementPilotDetails;
		if tmpTable.accessRow(rowIndex).enabled then
			self.doSetPxyMvmntPilotDetails(_pxyMovement, proxyMvmntPilotDetails, rowIndex);
		endif;
		if (not _pxyMovement.allMovementPilotDetails.includes(proxyMvmntPilotDetails)) then
			_pxyMovement.allMovementPilotDetails.add(proxyMvmntPilotDetails);
		endif;
	endforeach;		
end;</source>
        <Parameter name="_pxyMovement" type="HMS_VoyageMovement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doSetProxyResourceUsed" id="7e3eb758-0bad-44fe-b708-edd6342bdbeb">
        <source>doSetProxyResourceUsed(_pxyMovement : HMS_VoyageMovement; _pxyResourceUsed : HMS_ResourceUsed input; _theRow : Integer)protected;
//--------------------------------------------------
// Created:	17 February 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpTable : CM_DataTable;
	resType : HMS_ResourceType;
	resource : HMS_Resource;
	unitsUsed : Real;
	fromDateTime,
	toDateTime,
	actionDateTime : TimeStamp;
	createCharge, poc : Boolean;
	pxyVTMISTrans : HMS_VTMISTransaction;
	cM : HMS_VoyageMovement;
begin
	if self.mode &lt;&gt; self.Mode_Update
	and self.mode &lt;&gt; self.Mode_Add then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid Mode: Not in add or update mode');
		return;	
	endif;
	
	if _pxyResourceUsed = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _pxyResourceUsed');
		return;
	endif;
	
	cM :=  self.myCurrentMovement;
	
	tmpTable := self.tblResUsed;
	
	if _theRow &gt; tmpTable.rows
	or _theRow &lt;= tmpTable.fixedRows then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid table row');
	endif;
	
	_pxyResourceUsed.raiseExceptionIfNotTransient(method);

	if (not tmpTable.accessRow(_theRow).enabled) then
		//Cannot update this resource used
		return;
	endif;
	
	resType := tmpTable.accessCell(_theRow, self.colResourceType).cellControl.CMUI_ComboBox.listObject.HMS_ResourceType;
	resource := tmpTable.accessCell(_theRow, self.colResource).cellControl.CMUI_ComboBox.listObject.HMS_Resource;
	unitsUsed := tmpTable.accessCell(_theRow, self.colUnitsUsed).cellControl.CMUI_TextBox.text.asRealJMT;	// TFS 2240 done at the same time

	// TFS 41411
	if resType = null then
		if resource&lt;&gt; null then
			resType := resource.myResourceType;
		endif;
	endif;

	fromDateTime.setDate(tmpTable.accessCell(_theRow, self.colDateFrom).text.asDateJMT());		// TFS 2240 was .Date
	fromDateTime.setTime(tmpTable.accessCell(_theRow, self.colTimeFrom).text.Time);	

	toDateTime.setDate(tmpTable.accessCell(_theRow, self.colDateTo).text.asDateJMT());		// TFS 2240 was .Date
	toDateTime.setTime(tmpTable.accessCell(_theRow, self.colTimeTo).text.Time);

	if tmpTable.accessCell(_theRow, self.colCreateCharge).text = '1' then
		if _pxyResourceUsed.myVTMISTransaction = null then
			//Only create charge if it hasn't already been charged
			create pxyVTMISTrans transient;
		endif;
	elseif _pxyResourceUsed.myVTMISTransaction &lt;&gt; null then
		if _pxyResourceUsed.myVTMISTransaction.isTransient then
			delete _pxyResourceUsed.myVTMISTransaction;
		endif;
	endif;
	poc := (tmpTable.accessCell(_theRow, self.colPartOfContract).text = '1');
	
	
	_pxyResourceUsed.setProxy(_pxyMovement.myHarbour, resType, resource, pxyVTMISTrans, self.localToSystemTime(fromDateTime), self.localToSystemTime(toDateTime), unitsUsed, poc, _pxyResourceUsed.myWorkOrderVoyageDtl, _pxyResourceUsed.myDebtor);	// 26/5/16 cnwmp6 TFS 488 - Multi timezone support

end;</source>
        <access>protected</access>
        <Parameter name="_pxyMovement" type="HMS_VoyageMovement"/>
        <Parameter name="_pxyResourceUsed" type="HMS_ResourceUsed" usage="input"/>
        <Parameter name="_theRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doSetPxyMvmntPilotDetails" id="a937d175-f803-4e1b-850b-b3abc6647b4b">
        <source>doSetPxyMvmntPilotDetails(_pxyMovement : HMS_VoyageMovement; _pxyMvmntPilotDetails : HMS_MovementPilotDetails input; _theRow : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

*/

vars
	tmpTable : CM_DataTable;
	pilot : HMS_Pilot;
	pilotLaunch : HMS_PilotLaunch;	
begin
	if self.mode &lt;&gt; self.Mode_Update
	and self.mode &lt;&gt; self.Mode_Add then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid Mode: Not in add or update mode');
		return;	
	endif;

	if _pxyMvmntPilotDetails = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _pxyMvmntPilotDetails');
		return;
	endif;

	tmpTable := self.tblPilotLaunch;
	if _theRow &gt; tmpTable.rows or _theRow &lt;= tmpTable.fixedRows then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid table row');
	endif;
	_pxyMvmntPilotDetails.raiseExceptionIfNotTransient(method);
	if (not tmpTable.accessRow(_theRow).enabled) then
		//Cannot update this movement pilot details
		return;
	endif;
	
	pilot := tmpTable.accessCell(_theRow, self.colPilot).cellControl.CMUI_ComboBox.listObject.HMS_Pilot;
	pilotLaunch := tmpTable.accessCell(_theRow, self.colPilotLaunch).cellControl.CMUI_ComboBox.listObject.HMS_PilotLaunch;
	
	_pxyMvmntPilotDetails.setProxy(pilot, pilotLaunch, self.myCurrentMovement, null);
epilog

end;</source>
        <Parameter name="_pxyMovement" type="HMS_VoyageMovement"/>
        <Parameter name="_pxyMvmntPilotDetails" type="HMS_MovementPilotDetails" usage="input"/>
        <Parameter name="_theRow" type="Integer"/>
    </JadeMethod>
