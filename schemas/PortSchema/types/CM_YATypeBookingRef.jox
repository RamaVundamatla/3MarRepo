<Class name="CM_YATypeBookingRef" id="9d0049d1-86d3-4460-911e-9f642c74d0d8">
    <superclass name="CM_YACriteriaType"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="getAllCriteriaValues" id="f254dcde-cba3-4977-a3cc-399a40b78da7">
        <source>getAllCriteriaValues(_terminalObj:CM_Terminal; _allCriteriaValues: ObjectSet input; _filter : Integer; _allDependentObjs : CM_ObjectArray);
// --------------------------------------------------------------------------------
// Created:		07 March 2005 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//17 September 2013	cnwmc5	PAR 31255 - allowing dependent objects the criteria is based on.
// --------------------------------------------------------------------------------
vars
	terminalObj			: CM_Terminal;
	allBookingRefsObj	: CM_BookingRefsByRefDups;
	
begin
	terminalObj	:=	_terminalObj;
	
	if terminalObj &lt;&gt; null then
		create allBookingRefsObj transient;
		terminalObj.getAllActiveBookingRefs(allBookingRefsObj);
		allBookingRefsObj.copy(_allCriteriaValues);
	endif;
epilog
	delete allBookingRefsObj;
end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_allCriteriaValues" type="ObjectSet" usage="input"/>
        <Parameter name="_filter" type="Integer"/>
        <Parameter name="_allDependentObjs" type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaObjectForTi" id="1246bbc8-f8e8-47a6-9d88-87187d0b49f2">
        <source>getCriteriaObjectForTi(_ti : CM_TrackedItem; _criteriaObject : CM_Object output; _process : Boolean output);
//
// cnwrs1 Nov 2007 CCMS 1547
//
// for this ti return either a criteria object or the process flag
begin
	_criteriaObject	:=	_ti.myBookingRef;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_criteriaObject" type="CM_Object" usage="output"/>
        <Parameter name="_process" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaValuesForVoyage" id="8c48b3cd-b47a-41de-a9d0-347d81c0ad01">
        <source>getCriteriaValuesForVoyage(_voyage: CM_Voyage; _criteriaValues: ObjectSet input);

/*

Purpose:			Get Booking Reference values for given Voyage

Parameters:			

Return Value:		_criteriaValues populated with criteria values appropriate to voyage

Date				Who		Reason
16 December 2008	consw1	Initial creation

*/

vars

begin
	_criteriaValues.clear;
	_voyage.allBookingRefs.copy( _criteriaValues );

epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_criteriaValues" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDataDisplay" id="e5d1ad9e-e7fc-4a87-b147-a43471a4644c">
        <source>getDataDisplay(pDataObj : CM_YAData) : String;
//01 August 2008	cnwdw1
begin
	return pDataObj.CM_YADataObjects.getDataDisplay(self);
end;</source>
        <Parameter name="pDataObj" type="CM_YAData"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="7a0071c9-4536-4b5b-8c36-a3ace65eeb08">
        <source>getDisplay(dataObj : Object) : String;
//01 August 2008	cnwdw1
begin
	return dataObj.CM_BookingRef.bookingReference;
end;</source>
        <Parameter name="dataObj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getObjects" id="d7cae7e4-7857-45e8-905a-342c6d51cfad">
        <source>getObjects(objects: ObjectLongNameDict input);
//03 August 2008	cnwdw1	
// Return a dict of objects for this criteria type
vars
	terminalObj			: CM_Terminal;
	allBookingRefsObj	: CM_BookingRefsByRefDups;
	bookingRef: CM_BookingRef;
begin
	terminalObj	:=	app.getMyTerminalDO_NOT_USE();
	
	if terminalObj &lt;&gt; null then
		create allBookingRefsObj transient;
		terminalObj.getAllActiveBookingRefs(allBookingRefsObj);
		foreach bookingRef in allBookingRefsObj do
			if  objects[bookingRef.getYAIdentifier] = null then
				objects[bookingRef.getYAIdentifier] := bookingRef;
			endif;
		endforeach;
	endif;		
epilog
	delete allBookingRefsObj;
end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTypeName" id="492b464e-b6e0-42f3-9d39-7288bb251f05">
