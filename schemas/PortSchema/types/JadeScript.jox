    <JadeMethod name="amendRate1" id="1a35097e-a274-4b3b-9de2-3cf7e968faca">
        <source>amendRate1(_cmif : CMIF_CalcTypeRateHook) : Real;
vars
	theVoyage : CM_Voyage;
	theHMSData : HMS_VoyageData;
	theCalcType : CM_CalculationType;
	blockUnit : Integer;
	resourceUsed	: HMS_ResourceUsed;
	unitsUsed,value 	: Real;
	newRate : Real;
	hmsTran : HMS_VTMISTransaction;
	rateEntry : CM_RateEntry;
begin
	newRate := _cmif.origRate;
	 if not _cmif.myTransaction.isKindOf(HMS_VTMISTransaction) then
		return newRate;
	endif;
	hmsTran := _cmif.myTransaction.HMS_VTMISTransaction;

	theCalcType := app.myRoot.allCalculationTypesByCode["SCT2"];
	if theCalcType = null then
		return newRate;
	endif;
	theVoyage := hmsTran.myVoyage;
	if theVoyage = null then
		return newRate;
	endif;
	theHMSData := theVoyage.myHMSVoyageData;
	
	blockUnit := theCalcType.theCalcTypeUnit;
	
	resourceUsed := hmsTran.myResourceUsed;
	if resourceUsed &lt;&gt; null then
		
		unitsUsed := resourceUsed.unitsUsed;
		
		if blockUnit = INV_CALC_TYPE_UNITY then
			value := 1;
		elseif blockUnit = INV_CALC_TYPE_RESOURCE_QTY then
			value := resourceUsed.unitsUsed;
			if value = 0 then
				value := 1;
			endif;
		elseif blockUnit = INV_CALC_TYPE_UNIT_GRT then
			value := theHMSData.dim_GrossRegTonnes; 
		elseif blockUnit = INV_CALC_TYPE_UNIT_NRT then
			value := theHMSData.dim_NetRegTonnes;
		elseif blockUnit = INV_CALC_TYPE_UNIT_LENGTH then
			value := theHMSData.dim_LengthOverall; 
		elseif blockUnit = INV_CALC_TYPE_UNIT_BEAM then
			value := theHMSData.dim_Beam; 
		elseif blockUnit = INV_CALC_TYPE_UNIT_DEADWEIGHT then
			value := theHMSData.dim_DeadWeight;
		elseif blockUnit = INV_CALC_TYPE_UNIT_DRAFT_MID then
			value := theVoyage.draftMid;
		else // DEFAULT
			value := theHMSData.dim_GrossRegTonnes; 
		endif;
		
		newRate := (value * _cmif.origRate);
	endif;
	
	
	
	return newRate;
epilog

end;</source>
        <Parameter name="_cmif" type="CMIF_CalcTypeRateHook"/>
        <ReturnType type="Real"/>
    </JadeMethod>
