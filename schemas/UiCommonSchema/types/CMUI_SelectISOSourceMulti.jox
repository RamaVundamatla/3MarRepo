    <JadeMethod name="getSelectedObjects" id="6de3001a-587c-47f2-b48d-b4ca204a6365">
        <source>getSelectedObjects( _objArray : CM_ObjectArray io);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 December 2011	cnwrd1	Initial creation

*/

vars
	count 	: Integer;
	aTA 	: CM_TerminalArea;
	aGO 	: CM_GridObject;
begin

	//need to lop round the allSelectedTas collection checking the allSelectedGridObjects selection
	count := 1;
	//if we have a GO we add it else we add the TA.
	foreach aTA in self.allSelectedTAs do
		if self.allSelectedGridObjects &lt;&gt; null and self.allSelectedGridObjects.size &gt;= count then
			aGO := self.allSelectedGridObjects[count];
		else
			aGO := null;
		endif;
		
		if aGO = null then
			_objArray.add(aTA);
		else
			_objArray.add(aGO);
		endif;	
		count := count +1;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_objArray" type="CM_ObjectArray" usage="io"/>
    </JadeMethod>
