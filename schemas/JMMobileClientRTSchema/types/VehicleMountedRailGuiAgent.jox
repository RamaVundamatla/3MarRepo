    <JadeMethod name="findTrackedItem" id="88b1aceb-a22f-4e55-9f23-05032520a24b">
        <source>findTrackedItem(_form: JMMobileClient_BaseForm input; 
					_tiId: String; 
					_errorMsgs:  DTO_HandHeldGateErrorDict input; 
					_state: Integer output): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
16 June 2008	concms1	PAR 17123 (CCMS 1671) DCT Gdansk

*/

vars

	packageDTO 		: MobileServerRTThin::DTO_EnquiryGradingTasks;
	rtnValue		: Boolean;

begin
	create packageDTO transient;

	rtnValue := self.myVehicleMountedRAILAgent.enqTrackedItem(_tiId, packageDTO, _errorMsgs);

	if rtnValue then
		_form.loadFormFromThinClientObj (packageDTO);
	endif;

	return rtnValue;
epilog
	delete packageDTO;
end;
</source>
        <Parameter name="_form" type="JMMobileClient_BaseForm" usage="input"/>
        <Parameter name="_tiId" type="String"/>
        <Parameter name="_errorMsgs" type="MobileHandHeldThin::DTO_HandHeldGateErrorDict" usage="input"/>
        <Parameter name="_state" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
