	theStringArray.add(PicTIVoltageSingle); theIntegerArray.add(86); theColArray.add(255); theNameArray.add('Arial');
	theStringArray.add(PicTIWaterCooled); theIntegerArray.add(83); theColArray.add(15724395); theNameArray.add('Wingdings');
	theStringArray.add(PicTI_OD_H); theIntegerArray.add(241); theColArray.add(0); theNameArray.add('Wingdings');
	theStringArray.add(PicTI_OD_HL); theIntegerArray.add(235); theColArray.add(0); theNameArray.add('Wingdings');
	theStringArray.add(PicTI_OD_HLW); theIntegerArray.add(221); theColArray.add(0); theNameArray.add('Wingdings');
	theStringArray.add(PicTI_OD_HW); theIntegerArray.add(244); theColArray.add(0); theNameArray.add('Wingdings');
	theStringArray.add(PicTI_OD_L); theIntegerArray.add(245); theColArray.add(0); theNameArray.add('Wingdings');
	theStringArray.add(PicTI_OD_W); theIntegerArray.add(243); theColArray.add(0); theNameArray.add('Wingdings');
	theStringArray.add(PicTI_OD_WL); theIntegerArray.add(247); theColArray.add(0); theNameArray.add('Wingdings');
	
	// cnwjk3 CCMS 1032 15/12/2008
	theStringArray.add(PicTADoorAft); theIntegerArray.add(216); theColArray.add(16711680); theNameArray.add('Wingdings');
	theStringArray.add(PicTADoorFwd); theIntegerArray.add(215); theColArray.add(16711680); theNameArray.add('Wingdings');
	theStringArray.add(PicTATwinLiftPrev); theIntegerArray.add(33); theColArray.add(16711680); theNameArray.add('Wingdings 3');
	theStringArray.add(PicTATwinLiftNext); theIntegerArray.add(34); theColArray.add(16711680); theNameArray.add('Wingdings 3');
	theStringArray.add(PicTATwinLiftArrows); theIntegerArray.add(74); theColArray.add(16711680); theNameArray.add('Wingdings 3');
	
	theStringArray.add(PicTAShelf); theIntegerArray.add(144); theColArray.add(0); theNameArray.add('Webdings');	//27 Aug 2013	NDL	Par 32308
	theStringArray.add(PicTAAlloction); theIntegerArray.add(83); theColArray.add(0); theNameArray.add('Wingdings 2');	//27 Aug 2013	NDL	Par 32308
	theStringArray.add(PicSpecialStow); theIntegerArray.add(217); theColArray.add(0); theNameArray.add('Wingdings 2');	// PAR 34889
	theStringArray.add(PicTACrane); theIntegerArray.add(169); theColArray.add(255); theNameArray.add('Arial');	// 11/7/16 cnwmp6 TFS 1601
	
	theStringArray.add(PicTIFlatRackEndsUp); theIntegerArray.add(241); theColArray.add(0); theNameArray.add("Wingdings");	// TFS 46405
	theStringArray.add(PicTIFlatRackEndsDown); theIntegerArray.add(242); theColArray.add(0); theNameArray.add("Wingdings");	// TFS 46405
	
	foreach idx in 1 to theStringArray.size do
		if theRoot.allDrawingAttributes[theStringArray[idx].trimBlanks] = null then
			beginTransaction;
			create aDT;
			aDT.myRoot := theRoot;
			aDT.fontName := theNameArray[idx];
			aDT.fontCharacter := theIntegerArray[idx];
			aDT.code := theStringArray[idx].trimBlanks;
			aDT.colour := theColArray[idx];
			aDT.drawingAttrType := DrawingAttrType_TrackedItem;				// 7/12/17 MAP TFS7493
			commitTransaction;
		else
			aDT := theRoot.allDrawingAttributes[theStringArray[idx].trimBlanks];		// 7/12/17 MAP TFS7493
			if aDT.drawingAttrType &lt;&gt; DrawingAttrType_TrackedItem then
				beginTransaction;
				aDT.drawingAttrType := DrawingAttrType_TrackedItem;
				commitTransaction;
			endif;
		endif;
	endforeach;	
	global.beep;
	
	//TFS 7431 cnwma1  17.10.2017 

	foreach drwAttr in CM_DrawingAttribute.instances do
		if drwAttr&lt;&gt; null then
			if drwAttr.label = null then
				beginTransaction;
				if drwAttr.getLabel &lt;&gt; null then
					drwAttr.label := drwAttr.getLabel;
				else
					drwAttr.label := drwAttr.code;
				endif;
				commitTransaction;
			endif;
		endif;
	endforeach;
	//TFS 7431 cnwma1  17.10.2017
	
epilog
delete theIntegerArray;
delete theStringArray;
delete theColArray;
delete theNameArray;


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadEDIFormats" id="7dd3be71-4950-44d2-9213-92eeb1d4ab4f">
        <source>loadEDIFormats(): String protected;
//----------------------------------------------------------------
//	Created:	16 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	formatsAgent	: CM_EDIFileFormatAgent;
	rtnValue		: Boolean;
	str, rtnStr		: String;
	int				: Integer;
	countCAM,
	countEDI		: Integer;
begin
	
	//app.initialize();  //is already initialized this is just recreating the passport and clearing the user

	app.myTrxUA.trxSetupEDI(countCAM, countEDI, app.myPassport);
	
//	int := AllianceManifest + CPShipsLoadList + HapagLloydLoadlist + TollNZAdvNot + TranzRailBooking
//			+ TranzRailEmptyManifest + TranzRailLoadedManifest;

	create formatsAgent transient;

	formatsAgent.myRoot := app.myRoot;

	rtnValue := formatsAgent.trxLoadFormatsFromGlobalConsts();

	// If we have true then we will only have warnings.
	if rtnValue then
		foreach str in formatsAgent.allErrorStrings do
			rtnStr := rtnStr &amp; str &amp; CrLf;
		endforeach;
	else
		rtnStr := 'Fatal Error';
	endif;
	
epilog
	
	delete formatsAgent;
	return rtnStr;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
