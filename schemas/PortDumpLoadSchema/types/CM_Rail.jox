<Class name="CM_Rail">
    <JadeMethod name="importPLXMLReference" id="462f3cfb-f5a6-4554-a64e-fe451bde430a">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = CM_TerminalArea::myTerminal.name then
		return app.myRoot.allTerminals[_theCode];
	elseif _name = CM_TerminalArea::myType.name then
		return app.myRoot.allTerminalAreaTypes[_theCode.Integer];
	elseif _name = CM_Rail::myTransferArea.name then
		if self.myTerminal &lt;&gt; null then
			return self.myTerminal.allTerminalAreaMastersById[_theCode];
		endif;
	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</Class>
