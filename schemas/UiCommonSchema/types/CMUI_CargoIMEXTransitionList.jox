    <JadeMethod name="addToolbarControls" id="c54c91a0-58a0-49d2-b2f7-700e8f1bd642">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 September 2012	cnwer1	Initial creation SFW 1295

*/

vars
	frm				: CMUI_Toolbar;
begin	
	inheritMethod();
	frm := self.frmToolbar;

	frm.addButton(self.btnNew, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnEditItem, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);
//	frm.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);	// from TFS 2056 add an explicit refresh for after change to attributes
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	frm.positionToolbarControls();
	frm.visible := true;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
