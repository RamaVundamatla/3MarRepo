<GUIClass name="CM_ViewTable" id="837fa61f-aa5d-4878-9059-a3dbf8f84982">
    <superclass name="CM_BaseTable"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <JadeMethod name="clearAllSelected" id="05dd4a26-f545-47bc-bfb9-df6ff49fb63c">
        <source>clearAllSelected();
// ---------------------------------------------------------------------------
// Created:     06 June 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();
	self.allSelectedObjects.clear;
end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="6c9d0810-7c49-4390-9365-de0133a2a3d7">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     18 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.fixedRows 		:= 0;
	self.fixedColumns	:= 0;

	self.rows := 0;

end;</source>
    </JadeMethod>
    <JadeMethod name="keyDown" id="43b5e5f5-486c-489b-9474-1dfe66a9a93d">
        <updating/>
        <source>keyDown(table: CM_ViewTable input; keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     22 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theRow		: JadeTableRow;
	theObject	: Object;
	
begin

	inheritMethod(table, keyCode, shift);

	if table.multiSelect &lt;&gt; MultiSelect_None then
		if shift.bitAnd(2) &lt;&gt; 0 then
			self.controlKeyDown := true;
		endif;
	endif;
	
end;</source>
        <Parameter name="table" type="CM_ViewTable" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="keyUp" id="66c76d12-26aa-411d-ba5a-f281d8b9ac47">
        <updating/>
        <source>keyUp(table: CM_ViewTable input; keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     22 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(table, keyCode, shift);

	if table.multiSelect &lt;&gt; MultiSelect_None and shift.bitAnd(2) = 0 then
		self.controlKeyDown := false;
	endif;
	
end;</source>
        <Parameter name="table" type="CM_ViewTable" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="lostFocus" id="4d4ddfb0-ef6f-41d0-bd5a-0f218a306ef6">
        <updating/>
        <source>lostFocus(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:     06 June 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(table);

	if self.controlKeyDown then
		self.controlKeyDown := false;
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mouseDown" id="5c52c2e7-3b50-46e2-9377-ddc069e0a293">
        <updating/>
        <source>mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     06 June 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	inheritMethod(table, button, shift, x, y);

	if table.CM_BaseTable.multiSelect &lt;&gt; MultiSelect_None and shift.bitAnd(2) &lt;&gt; 0 then
		self.controlKeyDown := true;
	else
		self.controlKeyDown := false;
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="rowColumnChg" id="d7da5f6e-8ad8-4443-b4fa-852cb04ab3b3">
        <updating/>
        <source>rowColumnChg(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:     06 June 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theRow		: JadeTableRow;
	theObject	: Object;
	
begin
	inheritMethod(table);

	if self.selectionType = self.SelectionType_Row then
		self.selectTheCurrentRow(table);
	endif;
		
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="selectTheCurrentRow" id="4ae11c28-bcc1-4630-83b3-1be9ca027ad4">
        <source>selectTheCurrentRow(table: Table input);

vars
	theRow		: JadeTableRow;
	theObject	: Object;

begin
	theRow := table.accessRow(table.row);
	if self.controlKeyDown then
		if theRow.selected then
			theRow.selected := false;
		else
			theRow.selected := true;
		endif; 
	else
		table.clearAllSelected();
		theRow.selected := true;
	endif;
	
	// always add object from selected row into the allSelectedObjects set
	// so that the row will remain selected even if the user scrolls up/down
	theObject := theRow.itemObject;
	if theObject &lt;&gt; null then
		if theRow.selected then
			table.CM_BaseTable.allSelectedObjects.add(theObject);
		else
			table.CM_BaseTable.allSelectedObjects.remove(theObject);
		endif;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="c5bf0af9-5f37-4a79-991b-0aaf80d138ac">
        <controlMethod name="CM_BaseTable::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// ---------------------------------------------------------------------------
// Created:     20 March 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(cntrl, persistCntrl);
	
	self.setMargins();

end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
