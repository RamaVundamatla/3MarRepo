    <JadeMethod name="getFilterDebtorString" id="0ed56299-28cf-4836-963a-01e8f68c4174">
        <source>getFilterDebtorString() : String;
// reporting

vars

	str : String;
	dr : CM_Debtor;

begin

	if self.allDebtors.isEmpty then
		str := Any_String;
	else
		foreach dr in self.allDebtors do
			if str &lt;&gt; null then
				str := str &amp; "," &amp; dr.name;
			else
				str := dr.name;
			endif;
		endforeach;
	endif;
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFilterTerminalString" id="3b611e6f-e2f2-475c-9387-f7b96f175a07">
        <source>getFilterTerminalString() : String;
// reporting

vars

	str : String;
	term : CM_Terminal;

begin

	if self.allTerminals.isEmpty then
		str := Any_String;
	else
		foreach term in self.allTerminals do
			if str &lt;&gt; null then
				str := str &amp; "," &amp; term.code;
			else
				str := term.code;
			endif;
		endforeach;
	endif;
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFromDateLocalTZ" id="c41a47c8-c576-40a9-bd68-cdad79d3b6a5">
        <source>getFromDateLocalTZ() : Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2016	cnwns1	Initial creation
// 30 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	fromTS : TimeStamp;
begin
	fromTS.cnEcSetDateAndTime(self.fromDate,TimeStartOfDay);
	return self.systemToLocalTime(fromTS).date();
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getToDateLocalTZ" id="d6c54c47-dc67-47cf-b247-d97ecbe24b8d">
        <source>getToDateLocalTZ(): Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2016	cnwns1	Initial creation
// 30 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	toTS : TimeStamp;
begin
	toTS.cnEcSetDateAndTime(self.toDate,TimeStartOfDay);
	return self.systemToLocalTime(toTS).date();
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="noOutputReturned" id="93706e2e-8046-48fa-9ef8-527c684b36f5">
        <source>noOutputReturned(): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 August 2012	cnwndl1	Initial creation	Par 29968
20/05/2014	cnwjre1	CCMS 2348 financial reporting
*/

vars

begin

	if self.allCashPayments.isEmpty and
	   self.allCashReceipts.isEmpty and
	   self.allCashCredits.isEmpty  then
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDateRange" id="83df8db9-2929-4acb-b2b0-f65db9670d7f">
        <updating/>
        <source>setDateRange( _fromDate : Date; _toDate : Date ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

begin

	self.fromDate := _fromDate;
	self.toDate := _toDate;

epilog

end;</source>
        <Parameter name="_fromDate" type="Date"/>
        <Parameter name="_toDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="setResults" id="ad21d21a-589f-4637-b376-1b88f7346319">
        <updating/>
        <source>setResults( _allCashTransactions : CM_CashDict;
				_allDebtors : CM_DebtorSet;
				_allTerminals : CM_TerminalByCodeDict
			) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20/05/2014	cnwjre1	CCMS 2348 financial reporting, result is cash payments

*/

vars

begin

	self.allCashPayments.clear();
	self.allDebtors.clear();
	self.allTerminals.clear();
	
	if not _allCashTransactions.isEmpty then
		_allCashTransactions.copy( self.allCashPayments );
	endif;
	if not _allDebtors.isEmpty then
		_allDebtors.copy( self.allDebtors );
	endif;
	if not _allTerminals.isEmpty then
		_allTerminals.copy( self.allTerminals );
	endif;
	self.setPortLogo();	//26 Apr 2018	NDL	TFS 38202
	
epilog

end;</source>
        <Parameter name="_allCashTransactions" type="CM_CashDict"/>
        <Parameter name="_allDebtors" type="CM_DebtorSet"/>
        <Parameter name="_allTerminals" type="CM_TerminalByCodeDict"/>
    </JadeMethod>
</Class>
