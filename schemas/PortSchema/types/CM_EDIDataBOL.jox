    <JadeMethod name="getVesselName" id="ffdab7b9-bef2-4c38-8f17-08f9bb14706d">
        <source>getVesselName(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Oct 2022 navsj20	ChangeRequest 55084: EUP - EDI Administration Usability Requirements
*/

vars
	vCode: String;
	terminal: CM_Terminal;
	voyage: CM_Voyage;
begin
	vCode := self.getVoyageCode;
	terminal := self.getMyTerminal;
	if vCode &lt;&gt; null and terminal &lt;&gt; null then
		voyage := terminal.lookupVoyage(vCode, null, false);
		if voyage &lt;&gt; null then
			return voyage.vesselName;
		endif;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyageCode" id="6b49d12b-958d-423a-870e-1c9cda408dde">
        <source>getVoyageCode(): String;
/*

Date		Who		Reason
03 November 2015	cnwer1	Initial creation PAR 37090

*/

vars
	ediTI : CM_EDITrackedItem;
begin
	
	foreach ediTI in self.allEDITrackedItems where ediTI.isKindOf(CM_EDIBOLHdrTI) do
		return ediTI.getVoyageCode();
	endforeach;
	
	
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyageETA" id="ceeb0628-c377-481f-84a7-8142c7630f18">
        <source>getVoyageETA(): Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Oct 2022 navsj20	ChangeRequest 55084: EUP - EDI Administration Usability Requirements
*/

vars
	vCode: String;
	terminal: CM_Terminal;
	voyage: CM_Voyage;
begin
	vCode := self.getVoyageCode;
	terminal := self.getMyTerminal;
	if vCode &lt;&gt; null and terminal &lt;&gt; null then
		voyage := terminal.lookupVoyage(vCode, null, false);
		if voyage &lt;&gt; null then
			return voyage.estimatedArrivalDT.date;
		endif;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
