    <JadeMethod name="getGate" id="c69f8aed-6016-40f2-8c5f-d7e8e70004ca">
        <source>getGate(_gateName: String): CM_Gate;
//20 August 2009	cnwdw1	
//
vars
	gate					: CM_Gate;
	terminal				: CM_Terminal;
begin

	terminal := self.getTerminal();
	self.assertNotNull(terminal);
	
	gate := terminal.getGate(_gateName);
	
	if gate = null then
		gate := terminal.allGates.first;
	endif;
	
	return gate;
end;</source>
        <Parameter name="_gateName" type="String"/>
        <ReturnType type="CM_Gate"/>
    </JadeMethod>
    <JadeMethod name="getGateLane" id="d6bcd0e9-6b71-4fa6-8e1b-e1960de7583e">
        <source>getGateLane(_gateArea: CM_GateArea; _lane: Integer): CM_YardController;
//10 August 2009	cnwdw1	
//
vars
	gate : CM_Gate;
	usage : CM_GateAreaUsage;
	gateArea : CM_GateArea;
begin
	if _gateArea &lt;&gt; null then
		if _lane = 0 then
			return _gateArea.myInTransitToLocation;
		endif;
		return _gateArea.getLaneByNumber(_lane);
	endif;
	
	//epr par 22695 11/3/09
	gate:=	self.getTerminal().allGates.first;
	if gate = null then
		return null;
	endif;

	foreach usage in gate.allGateAreas_IN do
		if usage.isPGate then	
			gateArea:=usage.myGateArea;	
			return gateArea.getLaneByNumber(_lane);
		endif;
	endforeach;
	
	return null;
end;</source>
        <Parameter name="_gateArea" type="CM_GateArea"/>
        <Parameter name="_lane" type="Integer"/>
        <ReturnType type="CM_YardController"/>
    </JadeMethod>
    <JadeMethod name="getGridLocation" id="6e9a9c59-ffe4-4e09-8cba-135fc4d7ddf7">
        <source>getGridLocation(_terminalArea: CM_GridArea; _bay, _stack: Integer): CM_LocationsController;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 November 2011	cnwdw1	Initial creation
*/
vars
	row, column: Integer;
begin
	if _terminalArea.areLocationIdsColThenRow then
		column := _bay;
		row := _stack;
	else
		row := _bay;
		column := _stack;
	endif;
	return _terminalArea.allGridControllersByRowColumn[row, column];
epilog

end;</source>
        <Parameter name="_terminalArea" type="CM_GridArea"/>
        <Parameter name="_bay" type="Integer"/>
        <Parameter name="_stack" type="Integer"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
