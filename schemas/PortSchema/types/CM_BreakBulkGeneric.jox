    </JadeMethod>
    <JadeMethod name="getIsHeatTreated" id="69211123-b545-4acf-a7a2-7acd2590fdb6">
        <source>getIsHeatTreated(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2017	cnwndl1	Initial creation	TFS 3414

*/

vars

	handlingType : CM_HandlingType;
	subPalletType : CM_PalletType;
	
	invalid : Boolean;
	prod : CM_Product;
	edition : Integer;

begin

	if self.myPalletDetailsTI &lt;&gt; null then
		return self.myPalletDetailsTI.heatTreated;
	endif;
	
	//get the default ones...
	prod := self.myProduct;
	
	if prod &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, prod, invalid);
		edition := prod.edition;
		if not invalid then
			if prod.myHandlingSubType &lt;&gt; null and prod.myHandlingSubType.isPallet then
				return prod.myHandlingSubType.CM_PalletType.heatTreated;
			endif;
			
			if prod.myHandlingType &lt;&gt; null and prod.myHandlingType.isPallet then
				subPalletType := prod.myHandlingType.getDefaultSubHandlingType().CM_PalletType;
				if subPalletType &lt;&gt; null then
					return subPalletType.heatTreated;
				endif;
			endif;
		endif;
	endif;
	
	if self.myCargoType.myDefHandlingSubType &lt;&gt; null and self.myCargoType.myDefHandlingSubType.isPallet then
		subPalletType := self.myCargoType.myDefHandlingSubType.CM_PalletType;
		if subPalletType &lt;&gt; null then
			return subPalletType.heatTreated;
		endif;
	endif;
	
	return inheritMethod();

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
