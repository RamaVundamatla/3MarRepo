    <JadeMethod name="holdDrawHeight" id="d05f9ffd-276e-474c-bff4-92e42c1c1484">
        <methodInvocation>mapping</methodInvocation>
        <source>holdDrawHeight(set : Boolean; _value : Integer io) mapping;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
