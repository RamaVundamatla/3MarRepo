&lt;/JMTInternalCargoOnSite&gt;
';
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;'1'&amp;method.name);

	self.assertNotNull(ediFileObj);
