        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="numberOfDaysOld" id="2dac8e58-ce69-4e71-b3fd-c335bbf3a72c">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="numberOfDaysOldRpts" id="e93f9fa6-ec4c-47e3-b105-0408a6aa3c96">
