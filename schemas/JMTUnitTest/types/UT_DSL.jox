    <JadeMethod name="deleteContainerRange" id="2e1b3aa9-761e-4676-85af-05ee2affb252">
        <source>deleteContainerRange(_start, _end :String);
// ---------------------------------------------------------------------------
// Created:     24 May 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	range	:CM_ContRange;
begin
	range := app.myRoot.lookupContainerRange(_start);
	
	if range = null or range.lower &lt;&gt; _start or range.upper &lt;&gt; _end then
		return;
	endif;
	
	app.myTrxDA.trxDeleteContRange (range, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings ();
epilog

end;</source>
        <Parameter name="_start" type="String"/>
        <Parameter name="_end" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteCountryRegion" id="1ce6030f-ca94-4edb-9483-e8254db92a0c">
