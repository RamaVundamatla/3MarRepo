    <JadeMethod name="create" id="cfc79166-20a0-4c2a-9216-6ae5d2d960c7">
        <updating/>
        <source>create() updating;

/*
Date			Who		Reason
06 July 2009	cnwar2	Initial creation

*/
vars

begin
	self.name := SOP_TableMaintForm.Table_Boom;
	self.permissionView		:= PmAdmBoomView;	
	self.permissionMaint	:= PmAdmBoomMaint;
	self.myDataClass := CM_Boom;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="738fa312-88e1-4fd2-b372-57237df513ad">
        <updating/>
        <source>doDelete(pObj: Object io) updating;

/*
Date			Who		Reason
06 July 2009	cnwar2	Initial creation

*/
vars

begin
	app.myTrxDA.trxDeleteBoom(pObj.CM_Boom, app.myPassport);

end;</source>
        <Parameter name="pObj" type="Object" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doMnuContext1Click" id="cae8f4e3-c222-4ac9-9ca4-a4dbbd25b655">
        <updating/>
        <source>doMnuContext1Click(theMenuItem: MenuItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 February 2019	jlgndl1	Initial creation	TFS 43403

*/

vars

	boom : CM_Boom;
	userMess : String;
	debugMess : String;

begin

	inheritMethod(theMenuItem);
	
	boom := theMenuItem.userObject.CM_Boom;
	if boom &lt;&gt; null then
		boom.boomUp( userMess, debugMess );
		if debugMess &lt;&gt; null then
			app.msgBox( debugMess, "Boom Open", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		endif;
	endif;

epilog

end;</source>
        <Parameter name="theMenuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="0682026e-865f-4e26-aec3-d4c95d4daeeb">
        <updating/>
        <source>doSave(): Boolean updating;

/*
Date			Who		Reason
06 July 2009	cnwar2	Initial creation

*/
vars
	theForm 		: SOP_TableMaintForm;
	tbl				: CM_EntryTable;
	pxyBoom 		: CM_Boom;
	password : String;
	userCode : String;
	channelStr : String;
	
begin
	theForm := self.myForm;
	tbl 	:= theForm.tblInput1;
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_Boom transient;
		endif;
		if theForm.myProxyObject = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
	
	//14 Feb 2019	NDL	TFS 43403
	//By default we display "******", if they change it, catch it, otherwise replace with the current value.
	password := tbl.getValueByName(ETRow_Password).String.trimBlanks;
	if password = CM_Boom.PasswordStr then
		password := theForm.myProxyObject.CM_Boom.password;
	elseif password = "&lt;" &amp; app.getErrorString(Not_Set) &amp; "&gt;" then
		password := null;
	endif;
	userCode := tbl.getValueByName(ETRow_UserCode).String;
	if userCode &lt;&gt; null and password = null then
		app.raiseCMException(User_code_entere_passwo_requir, null, null );
		return false;
	endif;
	channelStr := tbl.getValueByName(ETRow_Channel).String;

	pxyBoom := theForm.myProxyObject.CM_Boom;
	pxyBoom.setProxy(	tbl.getValueByName(ETRow_Code).String,
						tbl.getValueByName(ETRow_Description).String,
						tbl.getValueByName(ETRow_IpAddress).String,
						tbl.getValueByName(ETRow_PortNumber).Integer,
						theForm.myTerminal,
						channelStr,	//_channel : String;	//14 Feb 2019	NDL	TFS 43403
						userCode,	//_userCode : String;	//14 Feb 2019	NDL	TFS 43403
						password	//_password : String	//14 Feb 2019	NDL	TFS 43403
						);
	
	if channelStr &lt;&gt; null and pxyBoom.channel = 0 then  // not a valid value to convert.
		app.raiseCMException( Channel_identifier_must, null, null );
		return false;
	endif;
	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateBoom(pxyBoom, theForm.myCurrentObject, app.myPassport);
	else
		app.myTrxUA.trxUpdateBoom(pxyBoom, app.myPassport);
	endif;
	
	return app.myPassport.trxCompletedOK;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCollection" id="253739fa-329c-466a-84c4-9e6f954d7ad7">
        <source>getCollection(): Collection;

/*
Date			Who		Reason
06 July 2009	cnwar2	Initial creation

*/
vars

begin
	return self.myForm.myTerminal.allBoomsByCode;
end;</source>
        <ReturnType type="Collection"/>
    </JadeMethod>
    <JadeMethod name="getEntTableDef" id="7f2330a8-bf31-4dad-9e60-7f07fb18780b">
        <source>getEntTableDef() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2014	cnwdb2	PAR #33977

*/

vars

begin
	return ETDef_Boom;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="3ad73387-f63d-42eb-a40d-4c7a3247f3c7">
        <updating/>
        <source>setControlsForAddEdit() updating;

/*
Date			Who		Reason
06 July 2009	cnwar2	Initial creation

*/
vars
	theForm 	: SOP_TableMaintForm;
	entTableRow	: EntTableRow;
	entTableDef	: EntTableDef;

begin
   	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	entTableDef := app.myController.getEntTableDef(ETDef_Boom);
	
	foreach entTableRow in entTableDef.allEntTableRows do
		theForm.tblInput1.enableRowByName(entTableRow.name);
	endforeach;
	
	if theForm.mode = theForm.Mode_Add then 
		theForm.tblInput1.clearValues;
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		theForm.tblInput1.gotFocus(theForm.tblInput1);		
	else
		self.showThumbnail(theForm.myCurrentObject.CM_Boom);
	endif;
    theForm.tblInput1.cnEcResizeContents;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="2b608839-acf0-426e-8cde-8c65a95d67b3">
        <updating/>
        <source>setCtrlsForView() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 February 2019	jlgndl1	Initial creation	TFS 43403

*/

vars

	theForm : SOP_TableMaintForm;

begin

	inheritMethod();
	
	theForm := self.myForm;
	if theForm.tblData.row &gt; theForm.tblData.fixedRows then
		theForm.mnuContext1.visible := true;
	else
		theForm.mnuContext1.visible := false;
	endif;
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupContextMenuItems" id="cc679d75-6228-4709-bbae-7fa9813e40c4">
        <updating/>
        <source>setupContextMenuItems(conwin: Window input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 February 2019	jlgndl1	Initial creation	TFS 43403

*/

vars

	tmpMenu : MenuItem;
	theForm : SOP_TableMaintForm;

begin

	inheritMethod(conwin);
	
	theForm := self.myForm;
	theForm.mnuContext1.caption	:= "Open Boom";
	if theForm.tblData.row &gt; theForm.tblData.fixedRows
	and app.getMyUser.canDo( self.myForm.myTerminal, self.permissionMaint ) 
	then
		theForm.mnuContext1.userObject := theForm.tblData.accessRow( theForm.tblData.row ).itemObject;
		theForm.mnuContext1.visible := true;
	else
		theForm.mnuContext1.userObject := null;
		theForm.mnuContext1.visible := false;
	endif;
	
	tmpMenu := theForm.cloneMenu( theForm.mnuTblVCloneDataTbl, theForm.mnuContext1, false );

epilog

end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="ab774015-e313-4aa5-b7be-833c9cbf147b">
        <updating/>
        <source>setupThumbnailDetails() updating;

/*
Date			Who		Reason
06 July 2009	cnwar2	Initial creation

*/
vars
	theForm : SOP_TableMaintForm;
begin
	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_Boom);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_IPAddress, false);

	theForm.shtTblInput1.caption := 'Boom Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_Boom);
	theForm.shtTblInput1.visible := true;
		
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="061ba526-0809-4a5c-9bbf-96eec97c0244">
        <updating/>
        <source>showThumbnail(_boom : CM_Boom) updating;

/*
Date			Who		Reason
06 July 2009	cnwar2	Initial creation

*/
vars
	theForm 	: SOP_TableMaintForm;
	entTableDef	: EntTableDef;
	entTableRow	: EntTableRow;
	
begin
	theForm := self.myForm;
	theForm.tblInput1.clearValues;
	
	entTableDef := app.myController.getEntTableDef(ETDef_Boom);
		
	foreach entTableRow in entTableDef.allEntTableRows do
		theForm.tblInput1.setValueByName(entTableRow.name, _boom.getDisplayStringForAttribute(entTableRow.name, false));
	endforeach;
	
end;</source>
        <Parameter name="_boom" type="CM_Boom"/>
    </JadeMethod>
</Class>
