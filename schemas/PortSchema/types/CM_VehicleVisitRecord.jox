    <JadeMethod name="hasGateEntityForCargoId" id="7e95d840-cd78-4214-815b-74b8e5a6d2cc">
        <source>hasGateEntityForCargoId(_id : String) : Boolean;
// -----------------------------------------------------------------------------
// Created:		01 September 2009 by consw1
//
// Purpose:		Has the given id already been entered?
//
// Parameters:	
//
// Returns:		
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	gteEntity : CMGTE_Entity;
	
begin
	if _id = null then
		return false;
	endif;

	foreach gteEntity in self.allGateEntities where gteEntity.getID() = _id do
		return true;
	endforeach;
	
	return false;
	
epilog

end;</source>
