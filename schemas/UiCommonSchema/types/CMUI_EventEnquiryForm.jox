    <JadeMethod name="setFilterValues" id="383d99fb-e69e-4290-bf9f-2948f8989db7">
        <updating/>
        <source>setFilterValues() updating;
/*
----------   ----------  --------------------------------------------------
Created:	11 July 2007 By cnwth2

Purpose:	

Changed On  Changed By  Reason
05/11/2009	cnwmh5		PAR20767 - Change so that Rolled / Split Bookings and
						Booking Discrepancy (system defined events) display
						their text correctly in the error text field
// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
----------  ----------  --------------------------------------------------
*/
vars
	eventType			: Object;
	localFiltFromDT	: TimeStamp;
	localFiltToDT	: TimeStamp;
begin
// cnwdad1 17/06/2009 - PAR #19942.
//	self.filtFromDT.setDate(self.txtDateFrom.text.trimBlanks.Date);
//	self.filtFromDT.setTime(self.txtTimeFrom.text.trimBlanks.Time);
//	self.filtToDT.setDate(self.txtDateTo.text.trimBlanks.Date);
//	self.filtToDT.setTime(self.txtTimeTo.text.trimBlanks.Time);

	localFiltFromDT.setDate(self.txtDateFrom.text.trimBlanks().asDateJMT());	// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	localFiltFromDT.setTime(self.txtTimeFrom.text.trimBlanks().asTimeJMT());	// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	localFiltToDT.setDate(self.txtDateTo.text.trimBlanks().asDateJMT());		// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	localFiltToDT.setTime(self.txtTimeTo.text.trimBlanks().asTimeJMT());		// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
																				// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.filtFromDT := self.localToSystemTime(localFiltFromDT);					// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.filtToDT	:= self.localToSystemTime(localFiltToDT);					// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	
	
	self.filtAllEventTypes.clear();
	self.filtIncludesUserEventType := false;
	self.filtIncRollSplitBookingDiscrep := false;			// 05/11/2009 cnwmh5 PAR20767
	foreach eventType in self.lstEventTypes.allSelectedObjects do
		self.filtAllEventTypes.add(eventType.CM_EventType.type);
		if eventType.CM_EventType.isUserDefined() then
			self.filtIncludesUserEventType := true;
		endif;
		// 05/11/2009 cnwmh5 PAR20767 - Start
		if eventType.CM_EventType.classNameToCreate = CMEVT_RollBooking.getName or 
				eventType.CM_EventType.classNameToCreate = CMEVT_SplitBooking.getName or
				eventType.CM_EventType.classNameToCreate = CMEVT_BookingRefDiscrep.getName then
			self.filtIncRollSplitBookingDiscrep := true;
		endif;
		// 05/11/2009 cnwmh5 PAR20767 - End
	endforeach;
	
	self.filtNeedFilterEventTypes := self.lstEventTypes.allSelectedObjects.size &lt; app.myRoot.allEventTypesByType.size;
	
	self.filtAllUsers.clear();
	if self.lstUsers.allSelectedObjects.size &gt;= app.myRoot.allUsers.size then
		self.filtNeedFilterUsers := false;
	else
		self.filtNeedFilterUsers := true;
		self.lstUsers.allSelectedObjects.copy(self.filtAllUsers);
	endif;
	self.filtIncludeNoUser := self.chkIncludeNoUser.value;
	
	self.filtAllTerminals.clear();
	self.lstTerminals.allSelectedObjects.copy(self.filtAllTerminals);
	self.filtIncludeNoTerm := self.chkIncludeNoTerm.value;

	
end;

</source>
    </JadeMethod>
