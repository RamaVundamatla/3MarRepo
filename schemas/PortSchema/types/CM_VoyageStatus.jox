    <JadeMethod name="processStatus" id="c7f77638-ea9f-4019-912b-42293e3ca3dc">
        <source>processStatus(_status : Integer; _voyage : CM_Voyage);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 09/03/2018	jlgdap1		Initial creation TFS 37427 PEL1 Voyage Status Enhancements
// 16/03/2018	jlgdap1		TFS 37540 PEL1 Voyage Statuses Pelindo 1
// 13 June 2018	jlgrs1		TFS 39013 (37190) Pelindo BGP Web Service
// 11 Oct 2021 	jlier1		TFS 51963 removed inaportnet options
// 29 Aug 2022	jlizm1		TFS 54298 EUP - Simplified Voyage Work Order Process
// 12 Apr 23023	navdap1		TFS 57362 CUX Changes to Outgoing Message Formats
vars
	et : CM_EventTransaction;
	email : CM_VoyStatusDefaultEmail;					// TFS 37540
//	emailController	: CMIF_EmailTemplateController;		// TFS 37540
	emailController	: CMIF_EmailTemplateVController;	//24 Apr 2018	NDL	TFS 38189	
	voyage : CM_Voyage;									// TFS 37540
	eventType : CM_EventType;
	now : TimeStamp;
	tmpBookingRef : CM_BookingRef;
	hasAddresses : Boolean;
	workingStatus : Integer;
	cmifEventCtrl : CMIF_VoyageEventCtrl;	//17/02/2025	navkc1 JIRA Bug MTN-33582
begin
	workingStatus := self.myProcess.getWorkingStatus(); // ### TFS CR 57138 TASK 57310 27MAR2023 NAVAB1
	if _status = workingStatus then // ### TFS CR 57138 TASK 57310 27MAR2023 NAVAB1
		self.processStatusWorking(_voyage,false); // ### TFS CR 57138 TASK 57310 27MAR2023 NAVAB1
	
	elseif (_status = Voyage_Status_Arrived or _status = Voyage_Status_EUP_Arrived) then 
		
		if _voyage.getVoyageArrivalEvent = null and _voyage.myTerminal &lt;&gt; null then
			/* //17/02/2025	navkc1 JIRA Bug MTN-33582
			et := app.createEvent(EVT_VoyageArrival, _voyage.arrivedDT, _voyage.myTerminal, app.myPassport.userCode, false, false, 0);
			if et &lt;&gt; null then
				et.CMEVT_VoyageEvent.setMyVoyage(_voyage);
				//et.createCharge(app.myPassport); 
				app.myPassport.addEventTransactionForDeferUpd(et,app.myPassport.myTerminal); // ### JIRA 33567 03DEC2024 NAVAB1
			endif;
			*/
			
			//17/02/2025	navkc1 JIRA Bug MTN-33582 - Start
			create cmifEventCtrl transient;
			cmifEventCtrl.type := EVT_VoyageArrival;
			cmifEventCtrl.dateTime := _voyage.arrivedDT;
			cmifEventCtrl.myTerminal := _voyage.myTerminal;
			cmifEventCtrl.userCode := app.myPassport.userCode;
			cmifEventCtrl.myVoyage := _voyage;
			
			et := app.createEventUsingCMIF(cmifEventCtrl);
			//17/02/2025	navkc1 JIRA Bug MTN-33582 - End
		endif;
		
		// ### TFS 55215 22Nov2022 NAVPW1
		CMIF_TrxActionTransport@createAction(_voyage, null, null, CMIF_TrxActionTransport.ProcessVoyageArrival, app.myPassport);	// TFS 57362
		// ### TFS 55215 22Nov2022 NAVPW1
		
	elseif _status = Voyage_Status_Departed or _status = Voyage_Status_EUP_Departed then
		
		if _voyage.getVoyageDepartureEvent = null and _voyage.myTerminal &lt;&gt; null then
			/* //17/02/2025	navkc1 JIRA Bug MTN-33582
			et := app.createEvent(EVT_VoyageDeparture, _voyage.departedDT, _voyage.myTerminal, app.myPassport.userCode, false, false, 0);
			if et &lt;&gt; null then
				et.CMEVT_VoyageEvent.setMyVoyage(_voyage);
				//et.createCharge(app.myPassport);
				app.myPassport.addEventTransactionForDeferUpd(et,app.myPassport.myTerminal); // ### JIRA 33567 03DEC2024 NAVAB1
			endif;
			*/
			
			//17/02/2025	navkc1 JIRA Bug MTN-33582 - Start;
			create cmifEventCtrl transient;
			cmifEventCtrl.type := EVT_VoyageDeparture;
			cmifEventCtrl.dateTime := _voyage.departedDT;
			cmifEventCtrl.myTerminal := _voyage.myTerminal;
			cmifEventCtrl.userCode := app.myPassport.userCode;
			cmifEventCtrl.myVoyage := _voyage;
			
			et := app.createEventUsingCMIF(cmifEventCtrl);
			//17/02/2025	navkc1 JIRA Bug MTN-33582 - End;
		endif;
		
		// ### TFS 55215 22Nov2022 NAVPW1
		CMIF_TrxActionTransport@createAction(_voyage, null, null, CMIF_TrxActionTransport.ProcessVoyageDeparture, app.myPassport);	// TFS 57362
		// ### TFS 55215 22Nov2022 NAVPW1
		
	//25 Jun 2018	NDL	TFS 39248
	elseif  _status = Voyage_Status_VoyageApproved then
		voyage := _voyage;
		if voyage &lt;&gt; null then
			voyage.setArriveDepartOnVoyApproval();
		endif;
		
	//02 Aug 2018	NDL	TFS 39924	
	elseif  _status = Voyage_Status_VoyCancelled or _status = Voyage_Status_EUP_Cancelled then
		voyage := _voyage;
		if voyage &lt;&gt; null and voyage.myTerminal &lt;&gt; null and voyage.myTerminal.getConfig(CloseShipReqsOnDepart).Boolean then
			voyage.closeShipRequests( app.myPassport );
			if app.myPassport.noErrors then
				foreach tmpBookingRef in voyage.allBookingRefs do
					app.myUtilityDA.utlDeleteBookingRef(tmpBookingRef, null, app.myPassport);
					if app.myPassport.hasErrors then
						break;
					endif;
				endforeach;
			endif;
		endif;
	endif;
	
	now := app.actualTimeServer;
	if _voyage.myTerminal &lt;&gt; null then
		foreach eventType in self.allEventsToCreate do
			if (_status = Voyage_Status_Arrived or _status = Voyage_Status_EUP_Arrived) and eventType.type = EVT_VoyageArrival then
				continue;
			elseif (_status = Voyage_Status_Departed or _status = Voyage_Status_EUP_Departed) and eventType.type = EVT_VoyageDeparture then
				continue;
			endif;
			
			/* //17/02/2025	navkc1 JIRA Bug MTN-33582
			et := app.createEvent(eventType.type, now, _voyage.myTerminal, app.myPassport.userCode, false, false, 0);
			if et &lt;&gt; null and et.isVoyageEvent then
				et.setMyVoyage(_voyage);
				//et.createCharge(app.myPassport);
				app.myPassport.addEventTransactionForDeferUpd(et,app.myPassport.myTerminal); // ### JIRA 33567 03DEC2024 NAVAB1
			endif;
			*/
			
			//17/02/2025	navkc1 JIRA Bug MTN-33582 - Start;
			delete cmifEventCtrl;
			create cmifEventCtrl transient;
			cmifEventCtrl.type := eventType.type;
			cmifEventCtrl.dateTime := now;
			cmifEventCtrl.myTerminal := _voyage.myTerminal;
			cmifEventCtrl.userCode := app.myPassport.userCode;
			cmifEventCtrl.myVoyage := _voyage;
			
			et := app.createEventUsingCMIF(cmifEventCtrl);
			//17/02/2025	navkc1 JIRA Bug MTN-33582 - End;
			
		endforeach;
	endif;
	
	// TFS 37540 If this status has an email template, send the appropriate email
	if self.myEmailTemplate &lt;&gt; null then
		create email transient;
		create emailController transient;
		email.setEmailController(emailController);
		email.setFromEmailTemplate(self.myEmailTemplate);
		
		emailController.setExtraAddressesFromVoyage( email, _voyage );	//24 Apr 2018	NDL	TFS 38189
		
		voyage := _voyage;
		
		hasAddresses := email.toAddresses &lt;&gt; null 
			or self.myEmailTemplate.sendtoOperatorCargo
			or self.myEmailTemplate.sendToOperatorCargoReqs 
			or self.myEmailTemplate.sendtoOperatorVoyage ;
			
		// TFS 51923 if email.toAddresses &lt;&gt; null then  TFS 51923 this meant that emails only get sent if there were emails for operators. 
		//				If you only have entered emails in the email template no email was sent.
		if hasAddresses then
			voyage.emailNotify(email, false, null);
		endif;
		// TFS 51923 endif;
	endif;
		
	self.processVoyageWorkOrders(_voyage);
epilog
	delete email;										// TFS 37540
	delete cmifEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
end;</source>
        <Parameter name="_status" type="Integer"/>
