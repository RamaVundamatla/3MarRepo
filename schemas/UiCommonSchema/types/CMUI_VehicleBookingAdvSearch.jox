    <JadeMethod name="translateForm" id="cd066e40-23c9-46f4-84ba-edd2e6dc2333">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 February 2023 08:16:19.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0025535, locale);
	btnAdd.translateCaption(Xlat_0025536, locale);
	btnDelete.translateCaption(Xlat_0025537, locale);
	btnEdit.translateCaption(Xlat_0025538, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0025539, locale);
	mnuCopyItems.translateCaption(Xlat_0025540, locale);
	mnuVbsAdvancedSearch.translateCaption(Xlat_0025541, locale);
end;</source>
    </JadeMethod>
</GUIClass>
