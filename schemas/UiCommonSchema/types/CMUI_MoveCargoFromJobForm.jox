    <JadeMethod name="displayJobDetails" id="d6ad3b16-6c82-41d6-adbf-6d07fc13bd99">
        <updating/>
        <source>displayJobDetails() updating;
// --------------------------------------------------------------------------------
// Created:		31 August 2010 by cnwjo3
//
