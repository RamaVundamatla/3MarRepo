    <JadeMethod name="convertSkinName" id="5af9edcb-0e9e-4d8a-99df-32e380ab4a5d">
        <source>convertSkinName(_name : String; _fromForm : Boolean) : String;
/*
Date		Who		Reason
20 February 2013	cnwmc5	Initial creation

*/

vars

begin
	if _fromForm then
		if _name = "JMT Blue" then
			return "JMTMetro2013";
		elseif _name = "JMT XP" then
			return "JMTxpx2006";
		elseif _name = "JMT Green" then
			return "JMTMetro2013Green";
		elseif _name = "JMT Orange" then
			return "JMTMetro2013Orange";
		elseif _name = "JMT Red" then
			return "JMTMetro2013Red";
		elseif _name = "JMT Doug" then
			return "JMTMetro2013Pink";
		elseif _name = "JMT Pirate" then
			return "JMTMetro2013Black";
		else
			return null;
		endif;
	else
		if _name = "JMTMetro2013" then
			return "JMT Blue";
		elseif _name = "JMTxpx2006" then
			return "JMT XP";
		elseif _name = "JMTMetro2013Green" then
			return "JMT Green";
		elseif _name = "JMTMetro2013Orange" then
			return "JMT Orange";
		elseif _name = "JMTMetro2013Red" then
			return "JMT Red";
		elseif _name = "JMTMetro2013Pink" then
			return "JMT Doug";
		elseif _name = "JMTMetro2013Black" then
			return "JMT Pirate";
		else
			return "None";
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_fromForm" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
