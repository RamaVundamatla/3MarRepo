<Class name="CM_HatchLidVoyage" id="f2c049ed-1e96-4165-8881-0a3f1e333a2e">
    <superclass name="CM_HatchLid"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="voyages"/>
    <ExplicitInverseRef name="myCellularVoyageStructure" id="4cf74043-5bed-4bc6-89d9-6f0133777987">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_CellularVoyageStructure"/>
        <access>readonly</access>
        <Inverse name="CM_CellularVoyageStructure::allHatchLids"/>
    </ExplicitInverseRef>
    <JadeMethod name="addBayVoyage" id="3e83a013-d06f-4916-bef0-ecb2ae627268">
        <updating/>
        <source>addBayVoyage(_bayVoyage : CM_BayVoyage) updating;
/*
------------------------------------------------------------------------
Created:			03 February 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		See Method signature above. Special comment:
Returns:			See Method signature above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars

begin
	if _bayVoyage = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_bayVoyage param', null, null);	
		return;
	endif;
	self.myCellularVoyageStructure := _bayVoyage.myCellularVoyageStructure;
	if not  self.allBays.includes(_bayVoyage) then
		self.allBays.add(_bayVoyage);
	endif;
	if _bayVoyage.myHold = null then
		return;
	endif;
	
	if not self.allHolds.includes(_bayVoyage.myHold) then
		self.allHolds.add(_bayVoyage.myHold);
	endif;
end;</source>
        <Parameter name="_bayVoyage" type="CM_BayVoyage"/>
    </JadeMethod>
    <JadeMethod name="getSide" id="57b31075-11dd-4668-b482-abe9720d8199">
        <source>getSide(): Integer;
/*
------------------------------------------------------------------------
Created:			07 October 2003 by cnwdwq1
Purpose:			Returns 1 for port, 2 for centre, or 3 for starboard.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars
//	isStarBd : Boolean;
	hatch : CM_HatchLid;
	hatches : CM_HatchLidArray;
	selfPos : Integer; 
	numHatches : Integer;
begin
	//isStarBd := self.myCellularVoyage.starboardBerthed;
	//Removed by DQ. Not sure if we need it or it has an impact.

	create hatches transient;
	if not self.allBays.isEmpty() then
		self.allBays.first.getSortedHatchLids(hatches);
	endif;
	if hatches.isEmpty then
		return null;
	endif;
	numHatches := hatches.size;
	selfPos := hatches.indexOf(self);
	if selfPos = null then
		return null;	//!!! WTF???
	endif;
	if selfPos = 1 then
		if numHatches = 1 then
			return JobSideCentre;
		else
			return JobSidePort;
		endif;
		
	elseif selfPos = 2 then
		if numHatches = 2 then
			return JobSideStarboard;
		elseif numHatches = 3 then
			return JobSideCentre;
		endif;
		
	elseif selfPos = 3 then
		return JobSideStarboard;
	else
		return null;	//God knows!
	endif;
epilog
	delete hatches;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="245e435a-413a-4761-a784-9a62219673c6">
        <updating/>
        <source>setForCreate(_proxy: SelfType;
			  _realVesselVoyage : CM_Object; 
			  _passport : CM_Passport input) updating;

vars
	
	aProxyBay, aRealBay : CM_BayVoyage;
	expectedEdition:Integer;
begin
	
	self.myCellularVoyageStructure :=_realVesselVoyage.CM_CellularVoyageStructure;
	
	// link the ordinal bays
	if self.myCellularVoyageStructure &lt;&gt; null then
		foreach aRealBay in self.myCellularVoyageStructure.allBayVoyagesByOrdinal do
			if aRealBay.ordinalBay &gt;= _proxy.ordinalStartBay  
			and aRealBay.ordinalBay &lt;= _proxy.ordinalEndBay  then
				self.addBayVoyage(aRealBay);
			endif;
		endforeach;
	endif;
	
	inheritMethod(_proxy,_realVesselVoyage,_passport);
	

end;</source>
        <Parameter name="_proxy" type="SelfType"/>
        <Parameter name="_realVesselVoyage" type="CM_Object"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="4785d384-1fa6-4975-91da-9d5d4cccbaf1">
        <updating/>
        <source>setForUpdate(_proxy: SelfType; _passport : CM_Passport input) updating;

vars
	
	aProxyBay, aRealBay : CM_Bay;
	expectedEdition:Integer;
begin
	inheritMethod(_proxy,_passport); //do not do this only update bays
	
	//------------------
	//Copy the bay defns across
	//------------------
	self.allBays.clear;
	
	// this proxy hatchlid will have a collection of proxy bays, so need to get the real bay to populate our bay collection
	foreach aProxyBay in _proxy.allBays do
		aProxyBay.pxyGetRealObjectAndEdition(aRealBay, expectedEdition);
		
		if aRealBay &lt;&gt; null then
			self.allBays.add(aRealBay);

			if not self.allHolds.includes(aRealBay.myHold) then
				self.allHolds.add(aRealBay.myHold);
			endif;
		endif;
	endforeach;
	
	aRealBay := self.allBays.first;
	if aRealBay &lt;&gt; null and aRealBay.isKindOf(CM_BayVoyage) then
		self.myCellularVoyageStructure := aRealBay.CM_BayVoyage.myCellularVoyageStructure;
	endif;
	
	

end;</source>
        <Parameter name="_proxy" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
