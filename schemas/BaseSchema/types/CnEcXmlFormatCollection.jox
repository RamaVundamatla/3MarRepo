    <JadeMethod name="createNewCopy" id="2bc2169e-eb13-40a5-882a-7e440f080fa6">
        <updating/>
        <source>createNewCopy(pNewFormatClass: CnEcXmlFormatClass): CnEcXmlFormatProperty updating;

vars
	retVal : CnEcXmlFormatCollection;
	
begin
	create retVal as currentSchema.getClass(self.class().name);
	retVal.initializeMe(self.propertyName, self.tagName, self.isShowTagData, pNewFormatClass);
	
	if self.myFormat = self.myFormatClass.myFormat then  
    	retVal.setMyFormat(pNewFormatClass.myFormat);
    else
    	retVal.setMyFormat(self.myFormat);
    endif;
    
    retVal.setIsReportSize(self.isReportSize);

	return retVal;
end;</source>
        <Parameter name="pNewFormatClass" type="CnEcXmlFormatClass"/>
        <ReturnType type="CnEcXmlFormatProperty"/>
    </JadeMethod>
    <JadeMethod name="setIsReportSize" id="05516838-7bed-42d0-99ad-68799c95fa5b">
        <updating/>
        <source>setIsReportSize(pReportSize : Boolean) updating;

begin
	self.isReportSize := pReportSize;
end;</source>
        <Parameter name="pReportSize" type="Boolean"/>
    </JadeMethod>
</Class>
