        <source>trxCreateStorageExpDtl(_pxyStoExpDtl : CM_StorageExpiryDetail input; _newStoExpDtl : CM_StorageExpiryDetail output; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/12/2023	navkc1 ChangeRequest 58261 Task 58260: Jade - COO Invoice Issues Send Email

*/

vars

begin
