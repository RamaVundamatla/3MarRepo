    <JadeMethod name="frmRemarks_mouseLeave" id="e0907b54-47e0-44bc-90c9-372a91b13321">
        <controlMethod name="CMUI_MoveableFrame::mouseLeave"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>frmRemarks_mouseLeave(frame: Frame input) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
09 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	parentWidth,
	parentHeight : Integer;
begin
	parentWidth := self.clientWidth;
	parentHeight := self.clientHeight;
	
	// ## Move Area Selector
	// ### LEFT
	if frame.left &lt; 0  then
		frame.left := 1;
	elseif (frame.clientWidth + frame.left) &gt; parentWidth then
		frame.left := parentWidth - frame.clientWidth - 10;
	endif;
	// ### TOP
	if frame.top &lt;0 then
		frame.top := 1;
	elseif (frame.clientHeight + frame.top) &gt; parentHeight then
		frame.top := parentHeight - frame.clientHeight - 10;
	endif;
epilog

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
    </JadeMethod>
