    <JadeMethod name="uncompress" id="99f29ab1-b6c2-4077-89a0-fd7953d63c63">
        <updating/>
        <source>uncompress(fileName:String) updating;
// Date			Who		Reason
// 18 Nov 2025	navpw1	JIRA: MTN-36675 Replaced removal of undocumented feature Binary.uncompress with uncompressToBinary
vars
	i:Integer;
begin
	aFile.fileName:=fileName.toLower;
	aFile.kind:=File.Kind_Binary;
	bFile.fileName:=fileName.toLower&amp;".dat";
	bFile.kind:=File.Kind_Binary;
	while not aFile.endOfFile do
		i:=aFile.readBinary(4).Integer;
		//bFile.writeBinary(aFile.readBinary(i).uncompress);
		bFile.writeBinary(aFile.readBinary(i).uncompressToBinary());	// ### JIRA: MTN-36675 18Nov2025 NAVPW1
//		bFile.writeBinary(aFile.readBinary(aFile.fileLength).uncompress);
	endwhile;
	aFile.close;
	bFile.close;
end;</source>
        <Parameter name="fileName" type="String"/>
    </JadeMethod>
</Class>
