Return Value:		


Date		Who		Reason
12 April 2010	cnwjk3	Initial creation

*/

vars

begin
	if _row &lt; self.topGridRow + self.numGridRowsFit then
		return true;
	else
		return false;
	endif;
epilog

end;</source>
