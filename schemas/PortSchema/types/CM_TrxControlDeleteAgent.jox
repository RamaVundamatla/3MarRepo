    <JadeMethod name="trxDeleteTrackedItems" id="17a26dd6-f84d-457a-9e1b-8999432a033f">
        <updating/>
        <source>trxDeleteTrackedItems(_tiSet : CM_TISet; _tisWithWarnSet : CM_TISet input; _confirmEachDelete: Boolean; _passport : CM_Passport input) updating;
//-----------------------------------------
// Created: July 2004 By: cnwgd1
//-----------------------------------------
/*
Date		Who		Reason
14/03/2025  navsp1  JIRA-34262 CUX | Deadlocks when deleting multiple prenotes through the API
*/
vars
	errorSet : CM_ErrorSet;
	alertCreated : Boolean;
	tmpTI : CM_TrackedItem;
	invalidTi : Boolean;
	terminal 	: CM_Terminal;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.myEventManager.setMultiTransactionTrx();
	app.setContinueCMExceptions(false);
	create errorSet transient;
	
	on Exception do app.handleDeletedObject(exception, tmpTI, invalidTi );	//30 May 2013	NDL	Par 31548
	terminal := app.myPassport.myTerminal;
	foreach tmpTI in _tiSet do
		invalidTi := false;
		// Start the transaction
		exclusiveLock(tmpTI);
		if invalidTi then	//30 May 2013	NDL	Par 31548
			continue;
		endif;
		
		beginTransaction;
		
		//Lock all the TI collections exactly as they appear in the passport(PortSchema::CM_Passport::updateTIsForDeferUpd)		//JIRA-34262
		//This ensures that there are no deadlocks while processing the deferred update on the other side.						//JIRA-34262
		self.exclusiveLock(terminal.allOnsiteTIsByCargoTypeId);																	//JIRA-34262			
		self.exclusiveLock(terminal.allOnsiteTIsByCargoTypeIdRev);																//JIRA-34262					
		self.exclusiveLock(terminal.allOnsiteTIsByIdCargoType);																	//JIRA-34262				
		self.exclusiveLock(terminal.allOnsiteTIsByIdCargoTypeRev);																//JIRA-34262					
		self.exclusiveLock(terminal.allOnsiteTIsByBookingRef);																	//JIRA-34262				
		self.exclusiveLock(terminal.allOnsiteTIsByAlternativeId);																//JIRA-34262	
		self.exclusiveLock(terminal.allNotifiedTIsByCargoTypeId);																//JIRA-34262		
		
		app.myUtilityDA.utlDeleteTI(tmpTI, _confirmEachDelete, _passport);
		
		if _passport.isOkToCommit(false)  then
			app.cmsCommitTransaction(_passport);
		else
			app.cmsAbortTransaction();
			if invalidTi then	//30 May 2013	NDL	Par 31548
				_passport.initialiseTransaction();
				continue;
				
			elseif _passport.hasErrors then
				app.convertErrorsWarningsToAlert('TrackedItem ' &amp; tmpTI.id &amp; ' could not be deleted', _passport.allErrorWarnings);				
				alertCreated := true;
				
			elseif _passport.hasWarnings then
				_tisWithWarnSet.add(tmpTI);
				
			endif;
			_passport.moveErrorsToSet(errorSet);
			_passport.initialiseTransaction();				
		endif;
	endforeach;

	if _passport.noErrors and (not process.isInTransactionState) then
		// Done so that finaliseActivityWithPassport will commit correctly
		beginTransaction;
	endif;
	_passport.addErrorsFromSet(errorSet);
	if alertCreated then
		app.raiseCMException1(SystemAlertCreated, 'Tracked Items for delete', null, self);
	endif;	
	
epilog
	self.finaliseActivityWithPassport(_passport);
	delete errorSet;
end;</source>
        <Parameter name="_tiSet" type="CM_TISet"/>
        <Parameter name="_tisWithWarnSet" type="CM_TISet" usage="input"/>
        <Parameter name="_confirmEachDelete" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
