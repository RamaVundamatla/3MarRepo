    <JadeMethod name="doJAA_GetJournal" id="a3148e4d-93da-43a0-aa97-ce09b30e1ec1">
        <updating/>
        <source>doJAA_GetJournal(_journalNumber : Integer) : Integer updating, protected;

/*

Purpose:		Replaces old Change Trackers openJournal	

Parameters:		journal number to get	

Return Value:	result is set by the exception handler or JAA	


Date		Who		Reason
13 May 2009	conkc1	Initial creation

*/

vars
	result              : Integer;
begin

	on Exception do doJAAhandleException(exception, result);
	
	result := myJadeAuditAccess.getJournal(journalPathName, _journalNumber, latestJournalOffset);
	return result;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_journalNumber" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doJAA_GetNextRecord" id="c1765ee8-d129-4770-9095-4cbcdc05f9c1">
        <updating/>
        <source>doJAA_GetNextRecord(_type         : Integer output;
                    _objectType   : Integer output;
					_recordOffset : Integer output;
					_timestamp    : TimeStamp output;
					_serialNumber : Decimal output;
					_transactionId: Decimal output;
					_oid          : String output;
					_classNumber  : Integer output;
					_edition      : Integer output) : Integer updating;

/*

Purpose:			Replaces old Change Trackers readJournal call

Parameters:			See JadeAduitAccess documentation

Return Value:		true if a record is returned, false if no further records in this file


Date		Who		Reason
13 May 2009	conkc1	Initial creation

*/

vars
	result : Integer;
	data   : Boolean;
begin
	data := self.myJadeAuditAccess.getNextRecord(_type, _objectType, _recordOffset, _timestamp, _serialNumber, _transactionId, _oid, _classNumber, _edition);
	//
	// If we did not get an exception
	//
	if result = 0 then
		if data = false then
			result := 3060; // end of file
		endif;
	endif;

	return result;
		
epilog

end;</source>
        <Parameter name="_type" type="Integer" usage="output"/>
        <Parameter name="_objectType" type="Integer" usage="output"/>
        <Parameter name="_recordOffset" type="Integer" usage="output"/>
        <Parameter name="_timestamp" type="TimeStamp" usage="output"/>
        <Parameter name="_serialNumber" type="Decimal" usage="output"/>
        <Parameter name="_transactionId" type="Decimal" usage="output"/>
        <Parameter name="_oid" type="String" usage="output"/>
        <Parameter name="_classNumber" type="Integer" usage="output"/>
        <Parameter name="_edition" type="Integer" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doJAAhandleException" id="7a9618c3-6835-45b5-9365-e4607eda0ab3">
        <updating/>
        <source>doJAAhandleException(_x : Exception; _result : Integer io) : Integer updating;
/*

Purpose:			To catch exception from JAA

Parameters:			Output error code in _result

Return Value:		


Date		Who		Reason
13 May 2009	conkc1	Initial creation

*/
vars

begin
	_result := _x.errorCode;
	if _x.resumable = true then
		return Ex_Resume_Next;
	else
		return Ex_Pass_Back;
	endif;
end;
</source>
        <Parameter name="_x" type="Exception"/>
        <Parameter name="_result" type="Integer" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doOpenAuditLog" id="47d1449c-c8b6-4fad-8a06-6c2d0aeb4c28">
        <updating/>
        <source>doOpenAuditLog(pFileNumber: Integer): Integer updating, protected;

vars
	result      : Integer;
	count       : Integer;
	processInfo : String;
	oldState    : String;
begin
	processInfo := process.userInfo;
	oldState    := self.myNibblerManager.state;
	while not self.tryLockForSession(self.myPersistentInstance) do
		count := count + 1;
		//	set the user and admin info on the process object for the Jade Monitor
		self.myNibblerManager.myTA.trxUpdateProcessDisplay(processInfo &amp; " - waiting on Journal #" &amp; pFileNumber.String &amp; " (" &amp; count.String &amp; ")", process.adminInfo);
		self.myNibblerManager.setState(self.myNibblerManager.myTitle &amp; " - waiting to single thread on Journal #" &amp; pFileNumber.String &amp; " (" &amp; count.String &amp; ")");
	endwhile;

	//	set the user and admin info on the process object for the Jade Monitor
	self.myNibblerManager.myTA.trxUpdateProcessDisplay(processInfo &amp; " - waiting on Journal #" &amp; pFileNumber.String, process.adminInfo);
	count := 0;
	//
	// #JAA action
	//
	result := self.doJAA_GetJournal(pFileNumber);
	
	//result := call openJournal(self.journalHandle, pFileNumber);
	//	3028 means that another process has the journal file, probably for backup
	//	so loop around waiting till it's available
	while result = 3028 do
		process.sleep(2000);
		//
		// #JAA action
		//
		result := self.doJAA_GetJournal(pFileNumber);

		//result := call openJournal(self.journalHandle, pFileNumber);
		count := count + 1;
		self.myNibblerManager.setState(self.myNibblerManager.myTitle &amp; " - waiting on Journal #" &amp; pFileNumber.String &amp; " (" &amp; count.String &amp; ")");
	endwhile;

	//	report any errors
	if result &gt; 0 then
		self.reportAuditResult(result, method.name);
		unlock(self.myPersistentInstance);
	endif;
	self.myNibblerManager.setState(oldState);
	return (result);
epilog
	//	reset the user and admin info on the process object for the Jade Monitor
	self.myNibblerManager.myTA.trxUpdateProcessDisplay(processInfo, process.adminInfo);
end;</source>
        <access>protected</access>
        <Parameter name="pFileNumber" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doOpenAuditLogSE" id="dbbfe98f-dd1c-41e0-88fb-ac1fd5345487">
        <updating/>
        <executionLocation>server</executionLocation>
        <source>doOpenAuditLogSE(pFileNumber: Integer): Integer updating, protected, serverExecution;

vars
	result      : Integer;
	count       : Integer;
	processInfo : String;
	oldState    : String;
begin
	processInfo := process.userInfo;
	oldState    := self.myNibblerManager.state;
	while not self.tryLockForSession(self.myPersistentInstance) do
		count := count + 1;
		//	set the user and admin info on the process object for the Jade Monitor
		self.myNibblerManager.myTA.trxUpdateProcessDisplay(processInfo &amp; " - waiting on Journal #" &amp; pFileNumber.String &amp; " (" &amp; count.String &amp; ")", process.adminInfo);
		self.myNibblerManager.setState(self.myNibblerManager.myTitle &amp; " - waiting to single thread on Journal #" &amp; pFileNumber.String &amp; " (" &amp; count.String &amp; ")");
	endwhile;

	//	set the user and admin info on the process object for the Jade Monitor
	self.myNibblerManager.myTA.trxUpdateProcessDisplay(processInfo &amp; " - waiting on Journal #" &amp; pFileNumber.String, process.adminInfo);
	count := 0;
	//
	// #JAA action
	//
	result := self.doJAA_GetJournal(pFileNumber);

//	result := call openJournal(self.journalHandle, pFileNumber);
	//	3028 means that another process has the journal file, probably for backup
	//	so loop around waiting till it's available
	while result = 3028 do
		process.sleep(2000);
		//
		// #JAA action
		//
		result := self.doJAA_GetJournal(pFileNumber);

//		result := call openJournal(self.journalHandle, pFileNumber);
		count := count + 1;
		self.myNibblerManager.setState(self.myNibblerManager.myTitle &amp; " - waiting on Journal #" &amp; pFileNumber.String &amp; " (" &amp; count.String &amp; ")");
	endwhile;

	//	report any errors
	if result &gt; 0 then
		self.reportAuditResult(result, method.name);
		unlock(self.myPersistentInstance);
	endif;
	self.myNibblerManager.setState(oldState);
	return (result);
epilog
	//	reset the user and admin info on the process object for the Jade Monitor
	self.myNibblerManager.myTA.trxUpdateProcessDisplay(processInfo, process.adminInfo);
end;</source>
        <access>protected</access>
        <Parameter name="pFileNumber" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doReadAuditLog" id="516ecbc1-efd3-451f-9b12-e9233ad18fa8">
        <updating/>
        <source>doReadAuditLog(pType    : Integer output; pTranId  : Decimal output;
			 pTimeStamp : TimeStamp output; pOid   : String output; 
			 pAction    : Integer output; pSequence: Decimal output): Integer protected, updating;


vars
	result : Integer;
begin
	result := doReadAuditLogActual(pType, pTranId, pTimeStamp, pOid, pAction, pSequence);
	return (result);
end;</source>
        <access>protected</access>
        <Parameter name="pType" type="Integer" usage="output"/>
        <Parameter name="pTranId" type="Decimal" usage="output"/>
        <Parameter name="pTimeStamp" type="TimeStamp" usage="output"/>
        <Parameter name="pOid" type="String" usage="output"/>
        <Parameter name="pAction" type="Integer" usage="output"/>
        <Parameter name="pSequence" type="Decimal" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doReadAuditLogActual" id="d91f35c8-6f1e-4dba-8ca6-886c17b77923">
        <updating/>
        <source>doReadAuditLogActual(pType      : Integer output; 
                     pTranId    : Decimal output;
			 		 pTimeStamp : TimeStamp output;
					 pOid       : String output;
			 		 pAction    : Integer output;
					 pSequence  : Decimal output): Integer protected, updating;
/*

Purpose:			Common method to Read Audit Log

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2009	conkc1	Initial creation

*/

vars

	_recordOffset : Integer;
	_classNumber  : Integer;
	_edition      : Integer;
	result        : Integer;

begin
	//
	// #JAA action
	//
	result := self.doJAA_GetNextRecord(pType, pAction, _recordOffset, 
	                                   pTimeStamp , pSequence, pTranId,
									   pOid, _classNumber, _edition);
//	result := call readJournal(self.journalHandle, pType, lTranId, lTimeStampStr, pOid, pAction, lSequence);

	if result &gt; 0 then
		if result = 3060 then
		//	OK, reached end of audit log
		else
			self.reportAuditResult(result, method.name);
		endif;
	else
		if pOid[1:1] = "[" then
			pOid := pOid[2:pOid.length - 2];
		endif;
	endif;

	return (result);

end;</source>
        <access>protected</access>
        <Parameter name="pType" type="Integer" usage="output"/>
        <Parameter name="pTranId" type="Decimal" usage="output"/>
        <Parameter name="pTimeStamp" type="TimeStamp" usage="output"/>
        <Parameter name="pOid" type="String" usage="output"/>
        <Parameter name="pAction" type="Integer" usage="output"/>
        <Parameter name="pSequence" type="Decimal" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doReadAuditLogSE" id="e134c778-e3bd-4187-9dae-82dc8d299375">
        <updating/>
        <executionLocation>server</executionLocation>
        <source>doReadAuditLogSE(pType      : Integer output;
                 pTranId    : Decimal output;
			 	 pTimeStamp : TimeStamp output; 
				 pOid       : String output;
			 	 pAction    : Integer output; 
				 pSequence  : Decimal output): Integer protected, updating, serverExecution;

vars
	result : Integer;
begin
	result := doReadAuditLogActual(pType, pTranId, pTimeStamp, pOid, pAction, pSequence);
	return (result);
end;</source>
        <access>protected</access>
        <Parameter name="pType" type="Integer" usage="output"/>
        <Parameter name="pTranId" type="Decimal" usage="output"/>
        <Parameter name="pTimeStamp" type="TimeStamp" usage="output"/>
