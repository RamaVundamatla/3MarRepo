    <JadeMethod name="doSave" id="de7adbe8-bedf-41ee-baef-1df0bb0d4beb">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 January 2020		jlgzm1	Initial creation TFS 47920 Event Stream Admin JMT UI
07 July 2020		NDL		TFS 49590
16 December 2024	jlizm1	MTN 19330 Events Stream restart from disabled time
*/

vars
	theForm 			: SOP_TableMaintForm;
	pxyEventStreamDef	: CM_EventStreamDefinition;
	realEventSreamDef	: CM_EventStreamDefinition;
	selectedEventTypes	: CM_EventTypeSet;
	selectedTransTypes	: CM_TransactionTypeSet;
	selectedHmsTypes	: CM_TransactionTypeSet;	//14 Jul 2020	NDL	TFS 49747
	selectedAudits		: CM_LongStringArray;
	rtnValue 			: Boolean;
	pxyESEventTypes		: CM_EventStreamEventTypeDict;
	pxyESEventType		: CM_EventStreamEventType;
	eventType			: CM_EventType;
	transType			: CM_TransactionType;
	auditNameAndType	: CM_LongString;
	wasDisabled 		: Boolean;
	sysDisabledTS 		: TimeStamp;
	enabledTS 			: TimeStamp;
	now 				: TimeStamp;
	replayForm			: SOP_ReplayEventsForm;
	keyObject 			: CM_Object;
	keyType 			: Integer;
	pos 				: Integer;
	keyObjStr 			: String;
	keyTypeStr 			: String;
	auditConfig			: CM_AuditConfig;
	
begin
	theForm := self.myForm; 
	
	create selectedEventTypes transient;
	create selectedTransTypes transient;
	create selectedHmsTypes transient;	//14 Jul 2020	NDL	TFS 49747
	create selectedAudits transient;
	create pxyESEventTypes transient;
	
	theForm.mulSelect1.getSelected(selectedEventTypes);
	theForm.mulSelect2.getSelected(selectedTransTypes);	
	theForm.mulSelect3.getSelected(selectedAudits);
	theForm.mulSelect6.getSelected(selectedHmsTypes);	//14 Jul 2020	NDL	TFS 49747
	
	foreach eventType in selectedEventTypes do
		create pxyESEventType transient;
		pxyESEventType.setProxy(eventType.name, CM_EventStreamEventType.EVENT_TYPE_EVENT, eventType, eventType.type );
		pxyESEventTypes.add(pxyESEventType);
	endforeach;
	foreach transType in selectedTransTypes do
		create pxyESEventType transient;
		pxyESEventType.setProxy(transType.description, CM_EventStreamEventType.EVENT_TYPE_TRANSACTION, transType, 0);
		pxyESEventTypes.add(pxyESEventType);
	endforeach;
	//14 Jul 2020	NDL	TFS 49747
	foreach transType in selectedHmsTypes do
		create pxyESEventType transient;
		pxyESEventType.setProxy(transType.description, CM_EventStreamEventType.EVENT_TYPE_HMS, transType, 0);
		pxyESEventTypes.add(pxyESEventType);
	endforeach;
	foreach auditNameAndType in selectedAudits do
		create pxyESEventType transient;
		keyObject := null;
		pos := auditNameAndType.string.trimBlanks.length - 6; // position the last word should start in.
		keyObjStr := auditNameAndType.string.trimBlanks[1:pos-2]; // the description for the audit config
		keyTypeStr := auditNameAndType.string.trimBlanks[pos:end]; // the action, i.e. Create, etc.
		foreach auditConfig in app.myRoot.allAuditConfigs discreteLock do
			if auditConfig.getDescription = keyObjStr then
				keyObject := auditConfig;
				break;
			endif;
		endforeach;
		if keyObject &lt;&gt; null then
			if keyTypeStr = 'Created' then
				keyType := AuditCreated;
			elseif keyTypeStr = 'Updated' then
				keyType := AuditUpdated;
			elseif keyTypeStr = 'Deleted' then
				keyType := AuditDeleted;
			endif;
		endif;
		pxyESEventType.setProxy(auditNameAndType.string, CM_EventStreamEventType.EVENT_TYPE_AUDIT, keyObject, keyType);
		pxyESEventTypes.add(pxyESEventType);
	endforeach;
	
	
	if theForm.mode = theForm.Mode_Add then
		if global.isValidObject(theForm.myProxyObject) then
			// delete and re-create as may be of wrong type
			theForm.myProxyObject.erase(NORMAL_ERASE);
		endif;

		create theForm.myProxyObject as CM_EventStreamDefinition transient;
	endif;
	
	pxyEventStreamDef := theForm.myProxyObject.CM_EventStreamDefinition;
	
	pxyEventStreamDef.setProxy( theForm.tblInput1.getValueByName(ETRow_Name).String,
								theForm.tblInput1.getValueByName(ETRow_Target).String,
								theForm.tblInput1.getValueByName(ETRow_IsActive).Boolean,
								theForm.tblInput1.getValueByName(ETRow_NumberOfRetries).Integer,
								theForm.tblInput1.getValueByName(ETRow_EmailAddress).String,
								//theForm.tblInput1.getValueByName(ETRow_Password).String);
								theForm.enteredPassword);	//25 Aug 2021	NDL	TFS 51632
	
	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateEventStreamDef(pxyEventStreamDef, theForm.myCurrentObject, pxyESEventTypes, app.myPassport);
		rtnValue := app.myPassport.trxCompletedOK;
	elseif theForm.mode = theForm.Mode_Update then
		realEventSreamDef := theForm.myCurrentObject.CM_EventStreamDefinition;
		if realEventSreamDef &lt;&gt; null then
			// check if definition had been disabled by the system
			wasDisabled := realEventSreamDef.disabledTS &lt;&gt; null;
			sysDisabledTS := realEventSreamDef.disabledTS;
		endif;
		
		app.myTrxUA.trxUpdateEventStreamDef(pxyEventStreamDef, pxyESEventTypes, app.myPassport);
		rtnValue := app.myPassport.trxCompletedOK;		
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
	endif;
	
	if theForm.mode = theForm.Mode_Update and wasDisabled and rtnValue and realEventSreamDef.isActive then
		// def has been reactivated after being systemn disabled
		// ask whether to replay events from between these times
		enabledTS := now;
		theForm.setAddUpdateTrxComplete(true);
		app.mousePointer := Window.MousePointer_Default;
		
		if app.msgBox(app.getErrorString1(Stream_disabled_replay_events, sysDisabledTS.asStringJMT) , app.getErrorString(Replay_events), MsgBox_Yes_No) = MsgBox_Return_Yes then		
			create replayForm;
			replayForm.setFromDT(sysDisabledTS.date, sysDisabledTS.time);
			replayForm.setToDT(enabledTS.date, enabledTS.time);
			replayForm.showModal();
		endif;
	endif;
	
	theForm.myProxyObject := pxyEventStreamDef;
	
	return rtnValue;

epilog
	delete selectedEventTypes;
	delete selectedTransTypes;
	delete selectedAudits;
	if pxyESEventTypes &lt;&gt; null and pxyESEventTypes.isNotEmpty then
		pxyESEventTypes.purge();
	endif;
	delete pxyESEventTypes;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCollection" id="6a409411-f3d9-47d9-aa49-f692709e348b">
        <source>getCollection(): Collection;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 January 2020		jlgzm1	Initial creation TFS 47920 Event Stream Admin JMT UI

*/

vars
	root : CM_PushEventsRoot;
begin
	root := CM_PushEventsRoot.firstInstance();
	if root &lt;&gt; null then
		return root.allEventStreamDefinitions;
	endif;
	
	app.raiseUnexpectedProgramError(class.name, method.name, "CM_PushEventsRoot singleton doesn't exist ");
	return null;
	
epilog

end;</source>
        <ReturnType type="Collection"/>
    </JadeMethod>
