<Class name="WS_ScannedCargoDetails" id="7ff6450a-4691-4c2b-ba71-29477b7ef73c">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="isMoveToFullGCArea" id="9a4b30f3-8078-4ab6-9ea4-2da128fa429c">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <ImplicitInverseRef name="scanned" id="049bd52b-f57b-4689-a92f-298041c88b35">
        <embedded/>
        <type name="WS_ScannedCargoScanned"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="summary" id="e2fe365f-41d0-4fe3-a60c-329e840de27b">
        <embedded/>
        <type name="WS_ScannedCargoSummary"/>
    </ImplicitInverseRef>
    <PrimAttribute name="targetLocation" id="3c4b6644-863f-4665-8005-38ad73007f03">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="delete" id="9c453071-5395-4fb1-bf45-ee3fca4ffedc">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 August 2023	jlier1	Initial creation 59876

*/

vars

begin
	if self.scanned &lt;&gt; null then
		delete self.scanned;
	endif;
	if self.summary &lt;&gt; null then
		delete self.summary;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="a0068be1-f40b-4e8f-9247-9cc12a68a721">
        <updating/>
        <source>setProxyFromObject(_trackedItem: CM_TrackedItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2023	navcs2	ChangeRequest 57557: [57396]: EUP - INB/MOB - New Scanning App - JADE
04 Sep 2023 jlier1  TFS 60152
21 Nov 2024 navdap1	MTN-18821 EUP* | FR 53485 - Warehouse Yard Allocation - Mobile App location selection issues
*/

vars
	lc : CM_LocationsController;
	move : CM_FutureMove;
begin
	inheritMethod(_trackedItem);
	
	create self.summary transient;
	self.summary.setProxyFromObject(_trackedItem);
	
	self.targetLocation := _trackedItem.plannedLocnId;
	if self.targetLocation = null then
		self.targetLocation:=_trackedItem.queuedLocnId;
	endif;
	
	//jlier1 TFS 59876 21/8/23
	if self.targetLocation = null and _trackedItem.myCargoGroup &lt;&gt; null then
		lc:=_trackedItem.myCargoGroup.getLastOnsiteLocation;
		if lc &lt;&gt; null then
			self.targetLocation:=lc.getFullId;
		endif;
	endif;
	
	// MTN-18821
	if not _trackedItem.allQueuedFutureMoves.isEmpty then
		move := _trackedItem.allQueuedFutureMoves.first;
	elseif not _trackedItem.allPlannedFutureMoves.isEmpty then
		move := _trackedItem.allPlannedFutureMoves.first;
	endif;
	if move &lt;&gt; null and move.isMoveToFullGCArea then
		self.isMoveToFullGCArea := move.isMoveToFullGCArea;
		self.targetLocation := move.getPrimaryLocationId();
	endif;
	// MTN-18821 end
epilog
	
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
