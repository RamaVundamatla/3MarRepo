    <JadeMethod name="reloadDataTable" id="94175a33-f44f-4912-ba05-22c473b9fee4">
        <source>reloadDataTable();
/*
Purpose:			
Return Value:		

Date			Who		Reason
18 August 2006	cnwer1	Initial creation - PAR#xxxx
18/03/2009		cnwrl1	PAR 17996 - Fix total displayed
19/03/2010		cnwcs5	par 23193 - tracked item notifications
*/
