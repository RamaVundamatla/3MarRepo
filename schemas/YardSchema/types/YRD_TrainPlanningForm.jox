    <JadeMethod name="getSDF" id="e006ae6e-4709-48c0-824c-241681be00b9">
        <source>getSDF(_railArea : CM_Rail) : CMUI_ScrollableDrawingFrame;
// ---------------------------------------------------------------------------
// Created:     June 2009
//
// Purpose:     Returns the drawing frame
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	gridAreaDockBar : Object;
	theSDF : CMUI_ScrollableDrawingFrame;

begin
	if self.isDisplayedRailAreas then
		foreach gridAreaDockBar in self.allGridAreaDockBars
		where gridAreaDockBar.YRD_RailDockBar.myRailArea = _railArea do
			theSDF := gridAreaDockBar.YRD_RailDockBar.mySDF;
			break;
		endforeach;
	else
		theSDF := self.mySDF;
	endif;
	
	return theSDF;
	
epilog

end;</source>
        <Parameter name="_railArea" type="CM_Rail"/>
        <ReturnType type="CMUI_ScrollableDrawingFrame"/>
    </JadeMethod>
    <JadeMethod name="getSelectedWagons" id="44951226-191f-42b1-8972-c9e82e8e3e8b">
        <source>getSelectedWagons( wagonColl : Collection input; _defaultWagon : CM_Wagon );
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		Returns selected wagons from the current drawing frame
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 18/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	gridArea : CMUI_GridArea;
	wagon : CM_Wagon;

begin
	wagonColl.clear();

	if self.myCurrentSDF = null then
		return;
	endif;
	
	foreach gridArea in self.myCurrentSDF.allGridAreasByRowColumn where gridArea.YRD_WagonArea.isWagonSelected() do
		wagon := gridArea.YRD_WagonArea.myWagon;
		if not wagonColl.includes(wagon) then
			wagonColl.add(wagon);
		endif;
	endforeach;
	
	if wagonColl.size &lt; 2 and _defaultWagon &lt;&gt; null then
		wagonColl.clear();
		wagonColl.add(_defaultWagon);
	endif;

epilog

end;</source>
        <Parameter name="wagonColl" type="Collection" usage="input"/>
        <Parameter name="_defaultWagon" type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="getTIFromGridPoint" id="c31e0a06-cdea-4b92-a406-7fc09ca453a0">
        <source>getTIFromGridPoint(y : Real; _gridPoint : CMUI_GridPoint) : CM_TrackedItem;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	theTI	: CM_TrackedItem;
	rtnStr	: String;
	tmpYPos	: Real;
	numTIs,
	idx		: Integer;
	lTIArray : CM_TIArray;
	lDisplayMode : Integer;
begin
	create lTIArray transient;
	
	if self.myCurrentLocation = null then
		return null;
	endif;

	lDisplayMode := self.myCurrentSDF.displayMode;

	if lDisplayMode = DISPLAY_MODE_ACTUAL then
		self.myCurrentLocation.getTIs(lTIArray, REAL_MODE, true); // PAR 27749
	elseif lDisplayMode = DISPLAY_MODE_QUEUE then
		self.myCurrentLocation.getTIs(lTIArray, QUEUE_MODE, true); // PAR 27749
	elseif lDisplayMode = DISPLAY_MODE_PLAN then
		self.myCurrentLocation.getTIs(lTIArray, PLANNING_MODE, true); // PAR 27749
	else
		self.myCurrentLocation.getTIs(lTIArray, REAL_MODE, true); // PAR 27749
	endif;
	
	if lTIArray.isEmpty then
		return null;
	endif;
	
	numTIs := lTIArray.size;
	
	foreach idx in 1 to numTIs do
		tmpYPos := _gridPoint.getYPosFromIdx(idx);
		if y &gt;= tmpYPos then
			theTI := lTIArray[idx];
			break;
		endif;
	endforeach;
	
	return theTI;
epilog
	delete lTIArray;
end;</source>
        <Parameter name="y" type="Real"/>
        <Parameter name="_gridPoint" type="CMUI_GridPoint"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getWagonAreaFromWagonObject" id="020118fc-99ac-44e7-9c78-a601c49311d7">
        <source>getWagonAreaFromWagonObject(_theWagon : CM_Wagon) : YRD_WagonArea;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		Looks for the wagon in its expected position in the grid area.
//				Returns the displayed Wagon Area if there otherwise null.
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 18/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	lastWagonArea : YRD_WagonArea;
	theWagonArea : YRD_WagonArea;
	theRow, theCol : Integer;
	theRailLine : CM_RailLine;
	theSDF : CMUI_ScrollableDrawingFrame;
begin

	if _theWagon = null then
		return null;
	endif;
	
	if self.isDisplayedTrains then
		if self.outwardsTrain then
			theRow := self.allTrains.indexOf(_theWagon.myTrainOutwards);
			theCol := _theWagon.getMyPositionTrainOutwards();
		else
			theRow := self.allTrains.indexOf(_theWagon.myTrainInwards);
			theCol := _theWagon.getMyPositionTrainInwards();
		endif;
		theSDF := self.getSDF(null);
	elseif self.isDisplayedRailAreas then
		theRailLine := _theWagon.myRailLine;
		if theRailLine = null or not self.allRailAreas.includes(theRailLine.myRailArea) then
			return null;
		endif;
		theRow := theRailLine.getMyPosition();
		theCol := _theWagon.getMyPosition();
		theSDF := self.getSDF(theRailLine.myRailArea);
	endif;

	if theRow = 0 or theCol = 0 then
		return null;
	endif;
	
	if self.flipHorizontal then
		theCol := self.getMaximumColumn(theSDF) + 1 - theCol;
	endif;

	lastWagonArea := theSDF.allGridAreasByRowColumn.last.YRD_WagonArea;

	if lastWagonArea = null or lastWagonArea.row &lt; theRow or lastWagonArea.column &lt; theCol then
		return null;
	endif;

	theWagonArea := theSDF.allGridAreasByRowColumn[theRow,theCol].YRD_WagonArea;

	if theWagonArea &lt;&gt; null and theWagonArea.myWagon = _theWagon then
		return theWagonArea;
	endif;
		
	return null;
end;</source>
        <Parameter name="_theWagon" type="CM_Wagon"/>
        <ReturnType type="YRD_WagonArea"/>
    </JadeMethod>
    <JadeMethod name="getWagonAreaFromWagonObjectWas" id="9368ebee-0d7c-406f-88b5-ccea8e17ef89">
        <source>getWagonAreaFromWagonObjectWas(_theWagon : CM_Wagon) : YRD_WagonArea;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:     Show wagons for give train
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	obj : Object;
	sdf : CMUI_ScrollableDrawingFrame;
	theWagonArea : YRD_WagonArea;
	aGridArea : CMUI_GridArea;
begin

	if _theWagon = null then
		return null;
	endif;
	
	foreach obj in self.allGridAreaDockBars do
		sdf := obj.YRD_RailDockBar.mySDF;
		foreach aGridArea in sdf.allGridAreasByRowColumn do
			theWagonArea := aGridArea.YRD_WagonArea;
			if theWagonArea.myWagon.String = _theWagon.String then
				return theWagonArea;
			endif;
		endforeach;
	endforeach;
	
	return null;
end;</source>
        <Parameter name="_theWagon" type="CM_Wagon"/>
        <ReturnType type="YRD_WagonArea"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="e89ec2f0-8d94-44be-b50a-fe1f533e4195">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:     
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theXML		: String;
	hideLegend	: Boolean;
	hideMacro	: Boolean;
	hideToolbar	: Boolean;
	
begin
	theXML := inheritMethod();

	// NOTE if these menus have a caption saying SHOW it means that the item is hidden
	hideLegend 	:= (self.mnuToggleLegend.caption = self.MNU_LEGEND_SHOW);
	hideMacro 	:= (self.mnuToggleMacro.caption = self.MNU_MACRO_SHOW);
	hideToolbar := (self.mnuToggleToolbar.caption = self.MNU_TOOLBAR_SHOW);

	theXML := theXML &amp; 
			global.formatAsXML(XML_SO,self.outwardsTrain.Integer.String) &amp;
			global.formatAsXML(XML_FH,self.flipHorizontal.Integer.String) &amp;
			global.formatAsXML(XML_ZS,self.mySDF.scaleFactor.String) &amp;
			global.formatAsXML(XML_HM,hideMacro.Integer.String) &amp;
			global.formatAsXML(XML_HT,hideToolbar.Integer.String) &amp;
			global.formatAsXML(XML_HL,hideLegend.Integer.String) &amp;
			global.formatAsXML(XML_HE,(self.dkcExtraInfo.height/self.dkcSubMain.height).String) &amp;
			global.formatAsXML(XML_WL,(self.dkbColorLegend.width/self.dkcMain.width).String);
			
	theXML := theXML &amp; self.tblTrains.getXmlStrForColumns(true);
	
	return theXML;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="56704fec-5c3d-4ef4-be14-588b9abe5b32">
        <updating/>
        <source>getXMLSettingsForSetup() updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:     
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	userWindow : CM_UserWindow;
	theXML, theXMLValue, theCaption : String;
	theRealValue : Real;
begin

	userWindow := self.myUserWindow;
	if userWindow = null then
		userWindow := app.getUserWindow(self.name, false);
		if userWindow = null then
			return;
		endif;
	endif;

	theXML := userWindow.xmlInfo;

	// Set Height of Extra Info
	theRealValue := theXML.cnEcGetTagValueOfName(XML_HE).Real;
 	if theRealValue &lt;&gt; null then
 	 	self.dkcExtraInfo.height := self.dkcSubMain.height * theRealValue;
	endif;

	// Set Width of Legend
	theRealValue := theXML.cnEcGetTagValueOfName(XML_WL).Real;
 	if theRealValue &lt;&gt; null then
 	 	self.dkbColorLegend.width := self.dkcMain.width * theRealValue;
	endif;

 	// Hide Legend
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_HL);
 	if theXMLValue &lt;&gt; null and theXMLValue.Integer.Boolean then
		self.dkbColorLegend.visible := false;
		self.mnuToggleLegend.caption := self.MNU_LEGEND_SHOW;
 	endif;

 	// Hide Macro
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_HM);
 	if theXMLValue &lt;&gt; null and theXMLValue.Integer.Boolean then
		self.dkcExtraInfo.visible := false;
		self.mnuToggleMacro.caption := self.MNU_MACRO_SHOW;
 	endif;

 	// Hide Toolbar
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_HT);
 	if theXMLValue &lt;&gt; null and theXMLValue.Integer.Boolean then
		self.mnuToggleToolbar.caption := self.MNU_TOOLBAR_SHOW;
 	endif;

	// Set Zoom
	theRealValue := theXML.cnEcGetTagValueOfName(XML_ZS).Real;
 	if theRealValue &lt;&gt; null then
 	 	self.mySDF.scaleFactor := theRealValue;
	endif;

 	// Set Flip Horizontal
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_FH);
 	if theXMLValue &lt;&gt; null and theXMLValue.Integer.Boolean then
		self.flipHorizontal := true;
 	endif;

 	// Set Show Outwards Train
	if not self.isDisplayedTrains and not self.isDisplayedRailAreas then
		theXMLValue := theXML.cnEcGetTagValueOfName(XML_SO);
		self.setDirection( theXMLValue &lt;&gt; null and theXMLValue.Integer.Boolean );
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="gridAreaMouseDownEvent" id="3d131353-4ed4-4dd9-9447-415d6b4470df">
        <updating/>
        <source>gridAreaMouseDownEvent(_button : Integer; _x, _y : Real) updating, protected;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	gridPoint	: CMUI_GridPoint; 
	lX, lY 		: Real;
	lFactor 	: Real;
	lTI 		: CM_TrackedItem;
	lc		 	: CM_LocationsController;
begin
	if self.myCurrentGridAreaFrame = null
	or self.myCurrentGridAreaFrame.myGridArea = null then
		return;
	endif;

	self.setMyCurrentSDF(self.myCurrentGridAreaFrame.myGridArea.mySDF);

	gridPoint := self.myCurrentGridAreaFrame.myGridArea.convertPositionToGridPoint(_x, _y); 

	lX := _x;
	lY := _y;
	self.myCurrentGridAreaFrame.windowToScreen(lX, lY);
	self.screenToWindow(lX, lY);

	if _button = Window.MouseButton_Left then
		self.myCurrentLocation := null;
		self.frmModeStatusBar.myFrameCaption.caption := null;
		self.gridPointChange(gridPoint, _x, _y);
		if gridPoint &lt;&gt; null then
			self.myCurrentLocation := gridPoint.myLocationsController;
		endif;
		
	elseif _button = Window.MouseButton_Right then
		if gridPoint &lt;&gt; null then
			self.myCurrentLocation := gridPoint.myLocationsController;
		endif;
	endif;
	
	self.myCurrentRailLine := self.myCurrentGridAreaFrame.myGridArea.YRD_WagonArea.myRailLine;

	if _button = 1 then
		self.origXPos := _x;
		self.origYPos := _y;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_button" type="Integer"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="gridAreaMouseMoveEvent" id="da3d7d22-def9-4f75-9a3b-12b97a062de4">
        <updating/>
        <source>gridAreaMouseMoveEvent(_button : Integer; _x, _y : Real)updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	gridPoint	: CMUI_GridPoint;
	theTI		: CM_TrackedItem;
	wle			: CM_WorkListEntry;
begin

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	if self.myCurrentGridAreaFrame = null
	or self.myCurrentGridAreaFrame.myGridArea = null then
		return;
	endif;

	if _button &lt;&gt; 1 or (not app.dragDetected(_x, _y, self.origXPos, self.origYPos)) then
		return;
	endif;

	// initiate a drag/drop
	gridPoint := self.myCurrentGridAreaFrame.myGridArea.convertPositionToGridPoint(self.origXPos, self.origYPos);
	if gridPoint = null then
		return;
	endif;

	if gridPoint.isKindOf(YRD_WagonBody) or gridPoint.isKindOf(YRD_WagonWheels) then
		self.dragWagon(gridPoint.myGridArea.YRD_WagonArea.myWagon, self.myCurrentGridAreaFrame);
		return;
	endif;

	theTI := gridPoint.getTI(self.origXPos, self.origYPos);
	if theTI = null then
		return;
	endif;

	app.myDraggedTrackedItem := theTI;
	if theTI.jobRailReceive &lt;&gt; null then
		wle := theTI.jobRailReceive.getWLEForTI(theTI);
		//01 Dec 2015	NDL	Par 36788
		if wle.status = WLE_COMPLETED then
			wle := null;
		endif;
	endif;
//	if wle &lt;&gt; null then
//		if wle.status = WLE_COMPLETED then
//			app.raiseCMException2(VB_JOB_NOT_UNACTIONED, wle.job.jobId, wle.statusString, null, null);
//			return;
//		endif;
//	endif;		
	self.dragTrackedItem(theTI, wle, self.myCurrentGridAreaFrame);
	
end;</source>
        <Parameter name="_button" type="Integer"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="gridPointChange" id="f07df9bd-5359-44f1-96a8-ca0f2aafe184">
        <updating/>
        <source>gridPointChange(_gridPoint: CMUI_GridPoint input; _x, _y : Real) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	wgnController : CM_WagonController;

begin
	if _gridPoint = null then
		self.frmModeStatusBar.myFrameCaption.caption := null;
	else
		self.frmModeStatusBar.myFrameCaption.caption := _gridPoint.getTIDetails(_x, _y);
	endif;
	
	if _gridPoint = null then
		return;
	endif;
	
	showInfoForWagonGridPoint(_gridPoint, _x, _y);
end;</source>
        <Parameter name="_gridPoint" type="CMUI_GridPoint" usage="input"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="gridPointRecieveDrop" id="24825a41-9a58-409f-bb8b-6dd8e08ccc6c">
        <updating/>
        <source>gridPointRecieveDrop(_gridPoint : CMUI_GridPoint input;_x, _y : Real) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _gridPoint = null then
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;

	self.gridPointChange(_gridPoint, _x, _y);
	self.assignTIToTransport(_gridPoint.myLocationsController);

epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_gridPoint" type="CMUI_GridPoint" usage="input"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="handleUserNotification" id="40a0b5d0-fbd2-4116-a374-21a6be8e02b1">
        <updating/>
        <source>handleUserNotification(_obj : CM_Object; _event : Integer)updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:     
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	wagon : CM_Wagon;

begin
	if _event = Rail_Clear_Rake_Event then
		self.updateRailRakeArea(_obj.CM_Rail);
		return;
	endif;

	if _event = Wagon_Delete_Event then
		self.updateWagonArea(_obj.CM_Wagon, _event);
		return;
	endif;

	if _obj = null or (not global.isValidObject(_obj)) then
		return;
	endif;
	
	if _obj.isKindOf(CM_Wagon) then
		wagon := _obj.CM_Wagon;
		self.updateWagonArea(wagon, _event);
	endif;

epilog
	endLoad;

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_event" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initFrameRake" id="ea9cf1d4-fac4-48be-8df9-fb8924412e44">
        <updating/>
        <source>initFrameRake() updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:     Initialise scrolling grid area
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	tmpRoot : CM_Root;

begin
	self.mySDF.top := 0;
	self.mySDF.scrollBars := ScrollBars_Both;
	self.mySDF.labels := ScrollBars_Vertical;
	self.mySDF.setHLabelDetails(25);
	self.mySDF.setVLabelDetails(80);
	self.mySDF.labels := ScrollBars_Both;
	self.mySDF.visible := true;
	self.mySDF.displayMode := DISPLAY_MODE_ACTUAL;
	self.mySDF.viewMode := VIEW_DESTPORT;
	self.mySDF.scaleFactor := 1.5;
	self.mySDF.caption := null;
	self.mySDF.myTerminal := self.myTerminal;
	self.mySDF.setupFrame();

	tmpRoot := app.myRoot;
	self.mySDF.picture1 := tmpRoot.getConfig(PicAvail).Binary;
	self.mySDF.picture2 := tmpRoot.getConfig(PicUnAvail).Binary;
	self.mySDF.picture3 := tmpRoot.getConfig(PicHasTLs).Binary;
	self.mySDF.picture4 := tmpRoot.getConfig(PicTLsUp).Binary;
	self.mySDF.myParentForm := self;
	
	self.dkbGridArea.setCreate( self.mySDF, self.frmDragSelect );
	self.allGridAreaDockBars.add(self.dkbGridArea);
	
	self.maxGridAreas := 1;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initTableInfo" id="ceaa1980-abb0-4a7c-beb0-f67fcbce45ad">
        <updating/>
        <source>initTableInfo() updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:     
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.tblInfo.clear;
	self.tblInfo.columns := 2;
	self.tblInfo.visible := true;
	self.tblInfo.stretchToParent := true;
	self.tblInfo.rows := 0;
	self.tblInfo.selectMode := Table.SelectMode_None;
	self.tblInfo.fixedRows := 0;
	self.tblInfo.fixedColumns := 0;
	self.tblInfo.userInputEnabled := false;
end;</source>
    </JadeMethod>
    <JadeMethod name="initTblTrainQuery" id="6b395e61-ca8c-4888-b8d3-41416bc83846">
        <source>initTblTrainQuery();
// ---------------------------------------------------------------------------
// Created:     03 June 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 17/06/2009		consw1			PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------

vars

	entTableView	: EntTableView;
	entTableDef		: EntTableDef;
	theTable		: CM_DataTable;
begin
	theTable := self.tblTrains;
	
	theTable.userInputEnabled := false;
	theTable.selectMode := CM_EntryTable.SelectMode_FixedRow;
	theTable.selectionType := CM_EntryTable.SelectionType_Row;
	theTable.multiSelect := CM_EntryTable.MultiSelect_Simple;
	theTable.rows := theTable.fixedRows;
	theTable.cnEcResizeContents();
	theTable.disallowColumnSorter := false;
	
	entTableDef := app.myController.getEntTableDef(ETDef_TrainQuery);
	if entTableDef &lt;&gt; null then
		theTable.setTblDataEntRowsFromDef(entTableDef);
	endif;
	
	theTable.readOnly := true;	
	theTable.fixedColumns := 0;
	theTable.show3D := Table.Show3D_Not3D;


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="isMultiSelect" id="d9b19e6a-adf3-4b9c-ae9c-d615307a5169">
        <source>isMultiSelect() : Boolean;
/*

Date		Who		Reason
06 May 2015	cnwer1	Initial creation PAR 36069

*/

vars
	tiArray	: CM_TIArray;
begin
	create tiArray transient;
	self.myCurrentSDF.getAllSelectedTIs(tiArray);
	return tiArray.size &gt; 1;
epilog
	delete tiArray;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="9d81810b-715f-4360-af81-4aed3b8d611d">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars

begin
	if keyCode = CMUI_Key_F3 then
		if app.isControlKeyDown()
		and not app.isAltKeyDown()
		and not app.isShiftKeyDown()
		then
			inheritMethod(keyCode, shift);
		else
			if self.frmSelectAreas.visible then
				self.showAreaSelectorEnable(false);
			else
				self.showAreaSelector();
			endif;
		endif;
		return;
	elseif keyCode = CMUI_Key_Esc then
		delete app.myMoveController;
		delete app.myWagonMoveController;
		app.myDraggedTrackedItem := null;
		app.isDragging := false;
		if self.myCurrentGridAreaFrame &lt;&gt; null then
			self.myCurrentGridAreaFrame.dragMode := self.DragMode_None;
		endif;
		self.origXPos := 0;
		self.origYPos := 0;
		return;
	elseif keyCode = J_key_A then
		if shift.isControlKeyPressed()
		and not shift.isShiftKeyPressed()
		and not shift.isAltKeyPressed() then
			self.selectAllWagons();
		endif;
	endif;
	
	inheritMethod(keyCode, shift);

epilog

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="d662cd4b-b964-48fb-ae47-604ee297bf65">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:     
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars

begin

	self.showHideToolbars(self.mnuToggleToolbar.caption = self.MNU_TOOLBAR_SHOW);

	self.dkbCargoPic.ignoreSkin := true;
	self.dkbCargoPic.backColor := White;
	self.picCargo.ignoreSkin := true;

	if self.isDisplayedTrains or self.isDisplayedRailAreas then
		self.doRefresh();
	else
		self.showAreaSelector();
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
