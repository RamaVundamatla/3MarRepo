    <JadeMethod name="getResourcesForCmbList" id="e74c7d94-74c5-4ccb-9acf-2e6fd1f4b588">
        <source>getResourcesForCmbList( _combo : ComboBox input; _harbour : HMS_Harbour ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 November 2018	jlgndl1	Initial creation	TFS 41980

*/

vars

	retStr : String;
	resource: HMS_Resource;
	index : Integer;

begin

	_combo.clear();
	_combo.sorted := true;
	foreach resource in self.allResources discreteLock do
		if _harbour &lt;&gt; null then
			if resource.myHarbour &lt;&gt; _harbour then
				continue;
			endif;
		endif;
		_combo.itemObject[ _combo.addItem( resource.description ) ] := resource;
	endforeach;

	if _combo.listCount &gt; 0 then
		foreach index in 1 to _combo.listCount do
			if retStr &lt;&gt; null then
				retStr:= retStr &amp; Tab;
			endif;
			retStr:= retStr &amp; _combo.itemText[ index ];
		endforeach;
	endif;
	
	return retStr;

epilog

end;
</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasResourceForHarbour" id="9a428926-77a2-46a7-9c55-926c0cc9905e">
        <source>hasResourceForHarbour(_harbour : HMS_Harbour ) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 June 2018	jlger1	Initial creation

*/

vars
	resource : HMS_Resource;
begin
	foreach resource in self.allResources discreteLock do
		if resource.myHarbour = _harbour then
			return true;
		endif;
		
	endforeach;
	
	return false;
epilog

end;</source>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="iconDownString" id="3060e3bc-d5a9-4de7-96b7-b80c3849ee4a">
