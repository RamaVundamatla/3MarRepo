    <JadeMethod name="handleException" id="f5308fcf-2944-4cee-b440-2977d883d89a">
        <source>handleException(ex :Exception):Integer protected;

vars

begin
	if ex.errorCode &gt; 5000 and
		ex.errorCode &lt; 5100 then
		app.msgBox ('Error ' &amp; ex.errorCode.String &amp; ' : ' &amp; ex.text, 'Error',
						MsgBox_Stop_Icon);	
		return Ex_Abort_Action;		
	endif;
	return Ex_Pass_Back;
end;</source>
        <access>protected</access>
        <Parameter name="ex" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="1e6895f0-8504-4959-ab1e-f205e25e0594">
        <updating/>
        <source>initialise(reptForm : CMUI_ReportBaseForm; _fileName : String; _orientation : Integer;
	_top, _bottom, _left, _right : Real) updating;

vars
	rel1, rel2 : Real;
	hdrFrame : Frame;
	
begin
	self.myReportForm := reptForm;
	hdrFrame := reptForm.getHeaderFrame;
	
	/*	 work out how many twips per pixel */
	rel1 := hdrFrame.width;

	hdrFrame.parent.scaleMode := Window.ScaleMode_Twip;

	rel2 := hdrFrame.width;

	hdrFrame.parent.scaleMode := Window.ScaleMode_Pixels;
	
	self.twipsPerPixel := rel2/rel1;

	self.setFileName(_fileName);
	
	self.setMargins(_orientation, _top, _bottom, _left, _right);
	
	// djc, 1 Dec 2000: Must call this last
	self.setupRTFHeader;
end;</source>
        <Parameter name="reptForm" type="CMUI_ReportBaseForm"/>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_orientation" type="Integer"/>
        <Parameter name="_top" type="Real"/>
        <Parameter name="_bottom" type="Real"/>
        <Parameter name="_left" type="Real"/>
        <Parameter name="_right" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mmToPixels" id="c1545541-3400-46e0-9505-f46c7f83962a">
        <source>mmToPixels(pMM :Real):Real protected;
/*
	Purpose   		to ...
	Parameters  	number of millimeters
	Returns			number of pixels
	Preconditions	none
	Note			...
*/
vars

begin
	return self.twipsToPixels(self.mmToTwips(pMM).Integer).Integer;
end;</source>
        <access>protected</access>
        <Parameter name="pMM" type="Real"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="mmToTwips" id="c11b4462-c147-41b0-a38d-c2031ac3160c">
        <source>mmToTwips(pMM :Real):Real protected;
/*
	Purpose   		to ...
	Parameters  	number of millimeters
	Returns			number of twips
	Preconditions	none
	Note			...
*/
vars

begin
	return pMM * self.TWIPS_PER_MM;
end;</source>
        <access>protected</access>
        <Parameter name="pMM" type="Real"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="newPage" id="ba00e949-2196-4776-9611-0141f3fda171">
        <updating/>
        <source>newPage()updating;

/*
	Purpose   		to ...
	Parameters  	none
	Returns			nothing
	Preconditions	none
	Note			...
*/
vars
	frame	:Object;
	relSpace	:Real;
begin
//	self.printFooter;
		
	self.myOutputFile.writeBinary('{\page}'.Binary);

	self.pageNumber 		:= self.pageNumber + 1;
	self.currentPosition	:= 0;
	
	self.myReportForm.updateRTFProgress('Creating RTF file', 'Page ' &amp; self.pageNumber.String);
end;</source>
    </JadeMethod>
    <JadeMethod name="pixelsToTwips" id="217a780b-d90e-4a59-9fba-54fa0b2abdea">
        <source>pixelsToTwips(pPixels :Real):Real protected;
/*
	Purpose   		to convert pixels to twips
	Parameters  	number of pixels
	Returns			number of twips
	Preconditions	none
	Note			...
*/
vars

begin
	return pPixels*self.twipsPerPixel;
end;</source>
        <access>protected</access>
        <Parameter name="pPixels" type="Real"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="printFrame" id="4d64681b-6606-4273-97a1-6a07177dbd2a">
        <updating/>
        <source>printFrame(pFrame :Frame input):Integer updating;

vars
	frame 		:Object;
	strLine		:String;
begin	
	if self.firstPage then
		//strLine := '\sectd ';
		myOutputFile.writeBinary(strLine.Binary);
		self.generateFooterRTF;
		self.firstPage := false;
		self.myReportForm.updateRTFProgress('Creating RTF file', 'Page ' &amp; self.pageNumber.String);
	endif;

	if self.currentPosition + pFrame.height + self.footerHeight &gt; self.pageHeight - JADE_FUDGE_FACTOR then
		/*	 there is not enough room to print this frame on the page */
		self.newPage;
	endif;

	if self.currentPosition = 0 then
		/*	we are starting at the top of a page */
		foreach frame in self.allHeaderFrames do
			self.generateFrameRTF(frame.Frame);		
			self.currentPosition := self.currentPosition + frame.Frame.height;
		endforeach;
	endif;

	self.generateFrameRTF(pFrame);
	
	self.currentPosition := self.currentPosition + pFrame.height;
	
	return 0;
end;</source>
        <Parameter name="pFrame" type="Frame" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setFileName" id="59e89de0-0b48-4776-91c5-869d1372ecba">
        <updating/>
        <source>setFileName(pName :String)updating;

vars

begin
	if self.fileTitle &lt;&gt; pName then
		self.fileTitle := pName;
	endif;

end;</source>
        <Parameter name="pName" type="String"/>
    </JadeMethod>
    <JadeMethod name="setFooter" id="95e4b724-bc1e-432a-8966-e2dc624bddbf">
        <updating/>
        <source>setFooter(pFrame: Frame)updating;
/*
	Purpose   		to ...
	Parameters  	none
	Returns			nothing
	Preconditions	none
	Note			...
*/
vars

begin
	if pFrame &lt;&gt; null then
		self.allFooterFrames[1] := pFrame;
		self.footerHeight		:= pFrame.height;
	else
		self.allFooterFrames.clear;
		self.footerHeight 		:= 0;
	endif;
end;</source>
        <Parameter name="pFrame" type="Frame"/>
    </JadeMethod>
    <JadeMethod name="setHeader" id="bcd926c0-332b-45f9-aa1f-0e91d66b9c3d">
        <source>setHeader(pFrame: Frame);
/*
	Purpose   		to ...
	Parameters  	none
	Returns			nothing
	Preconditions	none
	Note			...
*/
vars

begin
	if pFrame &lt;&gt; null then
		self.allHeaderFrames[1] := pFrame;
	else
		self.allHeaderFrames.clear;
	endif;
end;</source>
        <Parameter name="pFrame" type="Frame"/>
    </JadeMethod>
    <JadeMethod name="setMargins" id="7c253888-d123-4cf6-bbb3-77f0621773bd">
        <updating/>
        <source>setMargins(pOrientation: Integer; pTop: Real; pBottom: Real; pLeft: Real; pRight: Real)updating;
/*
	Purpose   		to ...
	Parameters  	none
	Returns			nothing
	Preconditions	none
	Note			...
*/
begin
	self.leftMargin		:= pLeft;
	self.rightMargin	:= pRight;
	self.topMargin		:= pTop;
	self.bottomMargin	:= pBottom;
	
	self.setOrientation(pOrientation);
end;</source>
        <Parameter name="pOrientation" type="Integer"/>
        <Parameter name="pTop" type="Real"/>
        <Parameter name="pBottom" type="Real"/>
        <Parameter name="pLeft" type="Real"/>
        <Parameter name="pRight" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setOrientation" id="2bca24f5-cb54-4f69-8ffd-4e5f72bff423">
        <updating/>
        <source>setOrientation(pOrientation: Integer)updating;
/*
	Purpose   		to ...
	Parameters  	none
	Returns			nothing
	Preconditions	none
	Note			...
*/
begin
	self.orientation	:= pOrientation;
	
	if pOrientation = Print_Portrait then
		self.paperHeight := 297;
		self.paperWidth	 := 210;
	else
		self.paperHeight := 210;
		self.paperWidth	 := 297;
	endif;
	
	self.pageHeight := self.mmToPixels(self.paperHeight - self.topMargin - self.bottomMargin);
end;</source>
        <Parameter name="pOrientation" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupRTFHeader" id="f9812224-6903-4c54-b282-55f0d963d1b2">
        <updating/>
        <source>setupRTFHeader() updating, protected;
/*
	Purpose   		to setup header part of RTF file.
	Parameters  	none
	Returns			nothing
	Preconditions	myReportForm must be set
	Note			should only be called once
*/
vars
	blnFound	:Boolean;
	intIndex	:Integer;
	output		:String;
	obj			:Object;
	objArray	:ObjectArray;
	control		:Control;
	intCount, intCol, intRow	:Integer;
	cell		:JadeTableCell;
begin
	on Exception do self.handleException(exception);

/* set missing properties to default values */
    if fileTitle = null then
		fileTitle := "c:\temp\report.rtf";
	endif;

/* set up the output RTF file */
	if self.myOutputFile &lt;&gt; null then
		if self.myOutputFile.isOpen then
			self.myOutputFile.close;
		endif;
		delete self.myOutputFile;
	endif;
	create self.myOutputFile transient;
	self.myOutputFile.fileName := fileTitle;
	self.myOutputFile.allowCreate := true;
	self.myOutputFile.allowReplace := true;
/* file kind is BINARY so we can write picture contents.  Text is written by writeBinary((&lt;text + CrLf&gt;).Binary) */	
	self.myOutputFile.kind := File.Kind_Binary;
	self.myOutputFile.mode := File.Mode_Output;	
	self.myOutputFile.open;
/* write the RTF header */
    output := "{\rtf1\ansi \deff0 {\fonttbl";
	
	/*	I use a white forecolour to force an blank underline to display */
	self.updateColourList(White);
	
	while intCount &lt; self.myReportForm.controlCount do
		intCount := intCount + 1;
		control		:= self.myReportForm.controls(intCount);
		
		if control.isKindOf(Label) then
			/* build up array of unique font names used */
			self.updateFontList(control.fontName);
			/* build up array of unique colour values used */
			self.updateColourList(control.foreColor);
			self.updateColourList(control.backColor);
		elseif control.isKindOf(Table) then
			while intRow &lt; control.Table.rows do
				intRow := intRow + 1;
				intCol := 0;
				while intCol &lt; control.Table.columns do
					intCol := intCol + 1;
					cell := control.Table.accessCell(intRow, intCol);
					self.updateColourList(cell.foreColor);
					self.updateColourList(cell.backColor);
					self.updateFontList(cell.fontName);
				endwhile;
			endwhile;
		endif;
	endwhile; 
/* write out the font and colour RTF tables	*/
	output := output &amp; "{\f0\fnil MS Sans Serif;";
	intIndex := 1;
	while intIndex &lt;= fontFamilyList.size do
		output := output &amp; "\f" &amp; intIndex.String &amp; " " &amp; fontFamilyList[intIndex] &amp; ";";
		intIndex := intIndex + 1;
	endwhile;
	output := output &amp; "}}" &amp; CrLf;
	myOutputFile.writeBinary(output.Binary);
/* write out the colour table */
	output := "{\colortbl";
	intIndex := 1;
	while intIndex &lt;= colourList.size do
		output := output &amp; self.colourToRTF(colourList[intIndex]) &amp; ";";
		intIndex := intIndex + 1;
	endwhile;
	output := output &amp; "}" &amp; CrLf;
	myOutputFile.writeBinary(output.Binary);
	output := "\psz" &amp; app.printer.documentType.String &amp; 
				"\paperh" &amp; self.mmToTwips(self.paperHeight).Integer.String &amp;
				"\paperw" &amp; self.mmToTwips(self.paperWidth).Integer.String &amp;
				"\margl" &amp; self.mmToTwips(self.leftMargin).Integer.String &amp;
				"\margr" &amp; self.mmToTwips(self.rightMargin).Integer.String &amp;
				"\margt" &amp; self.mmToTwips(self.topMargin).Integer.String &amp;
				"\margb" &amp; self.mmToTwips(self.bottomMargin).Integer.String;
	if self.orientation = Print_Landscape then
		output := output &amp; '\landscape ';
	endif;
	
	output := output &amp; CrLf;		
				
// ***	could alos write out an information group
	myOutputFile.writeBinary(output.Binary);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="startSection" id="dd2bae27-fc08-4144-9311-395a50965110">
        <updating/>
        <source>startSection() updating;

vars

begin
	myOutputFile.writeBinary("{\sect\sbknone".Binary);
	self.firstPage := true;
	self.currentPosition := 0;
end;</source>
    </JadeMethod>
    <JadeMethod name="twipsToPixels" id="7b196584-058c-4e81-b9b0-a2e5275b7c49">
        <source>twipsToPixels(pTwips :Real):Real protected;
/*
	Purpose   		to ...
	Parameters  	none
	Returns			nothing
	Preconditions	none
	Note			...
*/
vars

begin
	return pTwips/self.twipsPerPixel;
end;</source>
        <access>protected</access>
        <Parameter name="pTwips" type="Real"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="updateColourList" id="2515e2cb-b7b8-48ac-834d-1b416a9b2047">
        <source>updateColourList(pColour :Integer) protected;

vars
	intIndex	:Integer;
	blnFound	:Boolean;
begin
	intIndex := 1;
	blnFound := false;
	while intIndex &lt;= colourList.size do
		if colourList[intIndex] = pColour then
			blnFound := true;
			break;
		endif;
		intIndex := intIndex + 1;
	endwhile;
	if not blnFound then
		colourList[intIndex] := pColour;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pColour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateFontList" id="a108dd77-fb43-4ebc-aa00-a0ec442e4607">
        <source>updateFontList(pFontName :String) protected;

vars
	intIndex	:Integer;
	blnFound	:Boolean;
begin
	intIndex := 1;
	while intIndex &lt;= fontFamilyList.size do
		if fontFamilyList[intIndex] = pFontName then
			blnFound := true;
			break;
		endif;
		intIndex := intIndex + 1;
	endwhile;
	if not blnFound then
		fontFamilyList[intIndex] := pFontName;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pFontName" type="String"/>
    </JadeMethod>
</Class>
