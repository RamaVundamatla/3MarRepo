    <JadeMethod name="processDeleteForWO" id="4e77a822-e8dd-47a1-82cb-6c1a87c14ff1">
        <source>processDeleteForWO();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 Jul 2022	navcs2	Initial creation ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
17 Apr 2023 navma1  ChangeRequest 55440:[54990] EUP - Release Cargo Work Order - Enhancement
*/


vars
	wle 			: CM_WorkListEntry;
	incompleteCount : Integer;
	incompleteTISet : CM_TISet;
	ti				: CM_TrackedItem;
	wod				: CM_WorkOrderTIDtl;
begin

	create incompleteTISet transient;
	
	// here we need to see if we are a Work order job
	wod := self.myJob.myWODtl;										//17.04.2023 navma1 #55440:[54990]
	
	if wod &lt;&gt; null then
	
		foreach wle in self.allWorkListEntries do
			// if wle not complete then we need to update some work order detail stats &amp; cargo id's
			if wle.status &lt;&gt; WLE_COMPLETED then
				incompleteCount := incompleteCount +1;
				if wle.myTrackedItem &lt;&gt; null then
					incompleteTISet.addNoDuplicates(wle.myTrackedItem ,false);		//17.04.2023 navma1 #55440:[54990]
				endif;
			endif;	
		endforeach;
		
		if incompleteCount &gt; 0 then
		// now have work to do on the wod/requets		
			//if isRBT then
			// TI's are not assigned to the WOD untill the WLE is compelte so we can ignore the incompleteTISet
			// incompleteCount needs to update the request
			//self.myWORequestByType.setTotalActioned( self.myWORequestByType.totalActioned - incompleteCount  );
			//else
			//we need to update the WOD allocated count 			
			self.myJob.myWODtl.setTotalActioned( wod.totalActioned - incompleteCount);
			self.myJob.myWODtl.setTotalUnactioned( wod.totalUnactioned + incompleteCount);
			// and unaction the cargo on the WOD
				foreach ti in incompleteTISet do
					wod.setTIUnactioned( ti, false);
				endforeach;
			//endif;
		
		endif;
	endif;	

epilog
	delete incompleteTISet;
end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreateInternal" id="1de004f8-b877-4b5b-8e38-5edfd55aceb2">
        <updating/>
        <source>setForCreateInternal(_myJob: CM_Job; _packInternalJobParam: CMIF_WorkOrderJobParams) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Jan 2023 navcs2	ChangeRequest 54344:[54263] EUP - VAS Work Orders - Jobs
*/

vars

begin
	self.myJob			 	:= _myJob;
	self.totalRequested 	:= _packInternalJobParam.numberToQueue;
	self.requiredByDT 		:= _packInternalJobParam.requiredByDT;	
	self.userCode			:= app.getMyUserCode;
epilog

end;</source>
        <Parameter name="_myJob" type="CM_Job"/>
        <Parameter name="_packInternalJobParam" type="CMIF_WorkOrderJobParams"/>
    </JadeMethod>
