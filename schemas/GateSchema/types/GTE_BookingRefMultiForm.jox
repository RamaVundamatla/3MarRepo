    <JadeMethod name="selectNewBooking" id="67ffd4ae-4f3c-475b-a8c8-13aa6b9ed2c9">
        <updating/>
        <source>selectNewBooking(_obj : Object)updating;
//17 September 2009	cnwml2


vars

	rowIdx,
	colIdx	: Integer;
	
begin
	if (not self.tblData.findObjectInRow(_obj, rowIdx)) then
		// object is not in the table
		//if app.isDevelopmentSystem then
		
		//endif;
		return;
	endif;

	self.zTblDataSelectObject(_obj);
	self.zTblDataSelectRow(rowIdx);
	tblData.row := rowIdx;
	
	tblData.accessRow(rowIdx).selected := true;

	//self.tblData.allSelectedObjects.clear();
	//if (not self.tblData.allSelectedObjects.includes(_obj)) then
	//	self.tblData.allSelectedObjects.add(_obj);
	//endif;
	
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setBRItemInterfaceFromTable" id="d00cd803-d000-44de-bf73-64f8da062e5a">
        <updating/>
        <source>setBRItemInterfaceFromTable(_brItemInt : CMIF_BookingRefItem io) updating;
/*
	Created on 13 February 2008
	
	by Debby Hutchison
	
	Purpose:

*/
// adm 160310 Par 22937 remove bolType
vars
	assistant	: GTE_Assistant;
	strHumidity	: String;
	strVent : String; //par19495 cnwrs1 Apr 2009
	rVent : Real;
	strTemp, marks		: String;
	rTemp		: Real;
	obj			: Object;
//	bolType,
	id			: Integer;
	theWeight	: Decimal[14,4]; //02.2.09 cnwrd1 par #18821 
	generatorType 	: CM_GeneratorType;
begin
	assistant := self.myAssistant.GTE_Assistant;

	strHumidity := assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_Humidity).String.trimBlanks;	//Par 18359
	if strHumidity = null then
		strHumidity := NULL_HUMIDITY.String;
	endif;
	strVent := assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_Ventilation).asStringJMT();	//par19252 cnwrs1 may 2009 //Par 19495 cnwrs1 Apr 2009
	if strVent = null then
		rVent := NULL_VENTILATION;
	else
		rVent := strVent.Real;
	endif;
	strTemp := assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_CarriageTempC).String.trimBlanks;
	if strTemp = null then
		rTemp := NULL_TEMPERATURE;
	else
		rTemp := strTemp.Real;
	endif;
//	if cmbBOLType.listObject.CM_BOLType &lt;&gt; null then
//		bolType := cmbBOLType.listObject.CM_BOLType.id;
//	endif;
	
	if cmbTiType.listObject.CM_CargoBOLType &lt;&gt; null then
		id := cmbTiType.listObject.CM_CargoBOLType.id;
	endif;
	// 27492 cnwjre1 May 2011 cmbTiType is not always visible (is control for row 'Cargo Type', not in all views), use the existing value
	if id = 0 then
		if self.myCurrentObject &lt;&gt; null then
			id := self.myCurrentObject.CM_BookingRef.cargoType;
		elseif self.myProxyObject &lt;&gt; null then
			id := self.myProxyObject.CM_BookingRef.cargoType;
		endif;
	endif;

	if self.cmbGenSetType.listObject.CM_GeneratorType &lt;&gt; null then
		generatorType := self.cmbGenSetType.listObject.CM_GeneratorType;
	endif;
	
	if tblExtra.isRowVisible(ETRow_WeightTotal) then
		theWeight:=assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_WeightTotal).Decimal; //02.2.09 cnwrd1 par #18821 
	elseif tblExtra.isRowVisible(ETRow_MyWeight) then 
		theWeight:=assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_MyWeight).Decimal; //02.2.09 cnwrd1 par #18821 
	endif;
	
	if tblExtra.hasChanged then
		self.isItemsHaveChanged := true;
	endif;
	
	_brItemInt.set(		id, 
						assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_Clean).Boolean,
						assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_Commodity).String,
						assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_Description).String,
						self.lstHazardList.allSelectedObjects,	//CCMS 1203 JC - careful not to delete these with proxy
						strHumidity.Integer, // Par 18359 assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_Humidity).Integer,
						assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_Inspected).Boolean,
						assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_IsoType).String,
						assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_Quantity).Integer,
						assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_Remarks).String.trimBlanks,
						rTemp,// JC 29/01/04 assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_CarriageTempC).Real,
						rVent, //par19495 cnwrs1 apr 2009
						assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_Oxygen).Decimal,			// CCMS 1654 - slw 11/09/2008
						assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_CarbonDioxide).Decimal,	// CCMS 1654 - slw 11/09/2008
						assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_CurtainsIn).Boolean,					// CCMS 1654 - slw 11/09/2008
						assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_MyHeight).Decimal, //02.2.09 cnwrd1 par #18821 
						assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_MyLength).Decimal,//02.2.09 cnwrd1 par #18821 
						assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_MyWidth).Decimal,//02.2.09 cnwrd1 par #18821 
						assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_MyHeightString).String,
						assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_MyLengthString).String,
						assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_MyWidthString).String,
						assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_MyType).String,
						assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_ShippingMarks).String,
						assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_MyDensity).Integer,
						assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_MyVolume).Real,
						assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_MyQuantity).Integer,
						theWeight,
						assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_CubicMetres).Real,
						cmbProduct.listObject.CM_Product,
						true,
						_brItemInt.myEDIBookingRefTI, _brItemInt.rawEDIData,
						generatorType //cnwrd1 par #18220 23.2.09
						);
end;</source>
        <Parameter name="_brItemInt" type="CMIF_BookingRefItem" usage="io"/>
    </JadeMethod>
