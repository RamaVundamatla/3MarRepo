    <JadeMethod name="maintainDataExtractClass" id="60ab1788-f33e-4b1e-b075-525b74284922">
        <source>maintainDataExtractClass(_className : String; _deletedClasses : CM_DataExtractClassSet io; class : Class) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 April 2011	#cnwdz2	 

*/

vars
	dataExtractClass,
	proxyDataExtractClass,
	newDataExtractClass   : CM_DataExtractClass;	
	toDeleteProxyFields   : CM_DataExtractFieldSet;
begin
	create toDeleteProxyFields transient;
	
	//dataExtractClass := app.myRoot.allDataExtractClasses[_className];
	dataExtractClass := CM_DataExtractRoot.firstInstance.allDataExtractClasses[_className];
	if dataExtractClass = null then
		create proxyDataExtractClass as class transient;					
	else		
		_deletedClasses.removeIfPresent(dataExtractClass);
		proxyDataExtractClass := app.createUpdateProxy(dataExtractClass).CM_DataExtractClass;
		proxyDataExtractClass.allDataExtractFields.copy(toDeleteProxyFields);
	endif;

	proxyDataExtractClass.setProxy(_className);
	
	self.maintainDataExtractFields(proxyDataExtractClass, toDeleteProxyFields);	

	if proxyDataExtractClass.pxyIsProxy then
		app.myTrxUA.trxUpdateDataExtractcClass(proxyDataExtractClass, app.myPassport);
	else
		app.myTrxCA.trxCreateDataExtractClass(proxyDataExtractClass, newDataExtractClass, app.myPassport);
	endif;
epilog
	delete proxyDataExtractClass;
	delete toDeleteProxyFields;
end;</source>
        <access>protected</access>
        <Parameter name="_className" type="String"/>
        <Parameter name="_deletedClasses" type="CM_DataExtractClassSet" usage="io"/>
        <Parameter name="class" type="Class"/>
    </JadeMethod>
    <JadeMethod name="maintainDataExtractFields" id="eafb6b31-857a-4974-a3ee-5240310a738b">
        <source>maintainDataExtractFields(_proxyDataExtractClass : CM_DataExtractClass; _toDeleteProxyFields : CM_DataExtractFieldSet io) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2011	#cnwdz2	 

*/

vars
	field,
	proxyDataExtractField : CM_DataExtractField;
	fields    			  : CM_DataExtractFieldSet;
	fieldName			  : String;
begin
	create fields transient;
	
	_proxyDataExtractClass.initDataExtractFields(fields);
	
	foreach field in fields do
		fieldName := field.name;
		proxyDataExtractField := _proxyDataExtractClass.allDataExtractFields[fieldName];
		if proxyDataExtractField = null then
			_proxyDataExtractClass.pxyCreateFeature(fieldName, field);
		else
			proxyDataExtractField.setProxy(fieldName, field);
			_toDeleteProxyFields.removeIfPresent(proxyDataExtractField);
		endif;
	endforeach;
	
	foreach proxyDataExtractField in _toDeleteProxyFields do
		proxyDataExtractField.setDataExtractClass(null);
	endforeach;
	
epilog
	delete fields;
end;</source>
        <access>protected</access>
        <Parameter name="_proxyDataExtractClass" type="CM_DataExtractClass"/>
        <Parameter name="_toDeleteProxyFields" type="CM_DataExtractFieldSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="onError" id="6240e509-1d08-4b3d-b0d7-2bd84ca31f79">
        <updating/>
        <source>onError(_message : String) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 May 2011	#cnwdz2	 

*/

vars

begin
	self.errorOccurred := true;
	self.log(_message);	
epilog

end;</source>
        <Parameter name="_message" type="String"/>
    </JadeMethod>
