<GUIClass name="MenuItem">
    <JadeMethod name="isSeparatorJMT" id="67225445-c3c0-4c48-8fb5-ce68448978a0">
        <source>isSeparatorJMT() : Boolean;
// ---------------------------------------------------------------------------
// Created:     18 October 2007 by cnwrs2
//
// Purpose:     refer JADE PAR-46322
// ---------------------------------------------------------------------------
vars

begin
	if self.caption = '-' then
		// looking at instances of menuItem it appears that
		// JADE sets caption to '-' when you check the
		// separator in the painter
		return true;
	endif;
	
	return false;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
