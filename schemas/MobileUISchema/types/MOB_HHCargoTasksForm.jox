    <JadeMethod name="setupForm" id="bac632f6-c863-4304-98be-42c8cb3a7cf1">
        <updating/>
        <source>setupForm() updating, protected;
// ---------------------------------------------------------------------------
// Created:	09 January 2009 By Graeme Black cnwgb1
// Purpose:	Basic form setup
//			PNL CCMS 1658 PAR 18787
// ---------------------------------------------------------------------------
vars

	ti : CM_TrackedItem;
	
begin

	if app.myMobileCargoFindAgent = null then
		create app.myMobileCargoFindAgent transient;
	endif;
	
	ti := app.myMobileCargoFindAgent.myTrackedItemToProcess;
	if ti &lt;&gt; null then
		//returning from a specific search
		self.setMyTrackedItem(  app.myMobileCargoFindAgent.myTrackedItemToProcess );
	else
		// populated on one of the other maint forms
		self.setMyTrackedItem( self.getSessionAgent().mySelectedTI );
	endif;
	
	
	
	inheritMethod();
	//epr par 33025
	self.setupCmdButtons( 3, app.getErrorString(Edit), app.getErrorString(Cancel), BACK_BUTTON, null, null );
	self.setupControls();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupMenu" id="1ea583ba-7c1f-4bf3-a0c8-aab7efffd7e0">
        <updating/>
        <source>setupMenu() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 March 2011	cnwndl1	Initial creation	Par 27277

*/

vars

	passport : CM_Passport;
	term : CM_Terminal;
	
begin

	passport := app.myPassport;
	term := passport.myTerminal;
	
	if not app.myCurrentUserCan(term, PmHHMove) then
		self.mnuMove.visible := false;
	endif;
	if not app.myCurrentUserCan(term, PmHHGrading) then
		self.mnuGrades.visible := false;
	endif;
	if not app.myCurrentUserCan(term, PmHHMaintainStops) then
		self.mnuStops.visible := false;
	endif;
	
	self.isMenuItemsVisible := self.mnuMove.visible or
						self.mnuStops.visible or
						self.mnuGrades.visible;
							
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupTable" id="c9e3c478-f4f9-4adc-bf35-6b66436db17a">
        <source>setupTable() protected;
// ---------------------------------------------------------------------------
// Created:	19 January 2009 By Graeme Black cnwgb1
// Purpose:	Position, size and prefill the table headings
//			PNL CCMS 1658 PAR 18787
// ---------------------------------------------------------------------------
vars

	rtScreenMode	: CM_RTScreenConfig;
	
begin
	
	self.tblTasks.parentAspect:=Table.ParentAspect_StretchBoth;
	self.tblTasks.columns := 6;
	self.tblTasks.accessColumn(1).width := (self.tblTasks.width* 0.4).Integer;
	self.tblTasks.accessColumn(2).inputType := Table.InputType_CheckBox;
	self.tblTasks.accessColumn(2).alignment := Table.Alignment_Center_Top;
	self.tblTasks.accessColumn(3).inputType := Table.InputType_CheckBox;
	self.tblTasks.accessColumn(3).alignment := Table.Alignment_Center_Top;
	self.tblTasks.accessColumn(4).inputType := Table.InputType_TextBox;
	if app.isCargoGroupEnabled then	//11 Nov 2015	NDL	Par 37171
		self.tblTasks.accessColumn(5).inputType := Table.InputType_TextBox; 
	else
		self.tblTasks.accessColumn(5).visible := false;
	endif;
	self.tblTasks.accessColumn(6).visible := false;
	self.tblTasks.accessCell(1,1).text := app.getErrorString(Task);
	self.tblTasks.accessCell(1,2).text := app.getErrorString(Set_Only);
	self.tblTasks.accessCell(1,3).text := app.getErrorString(CompleteTrunc);
	self.tblTasks.accessCell(1,4).text := app.getErrorString(DateStr);
	self.tblTasks.accessCell(1,5).text := app.getErrorString(Remarks);	//11 Nov 2015	NDL	Par 37171
	self.tblTasks.accessRow(1).fontBold := true;
	self.tblTasks.selectMode := Table.SelectMode_WholeRows;
	self.tblTasks.accessSheet(1).scrollMode := Table.ScrollMode_HorzPixel_VertCell;
	//epr CCMS 1099 I know this has 1 fixed row colour for vehicle mounted apps 
	if app.myVMAgent &lt;&gt; null then
		rtScreenMode:=app.myVMAgent.getMyScreenMode();
		self.tblTasks.accessRow(1).backColor:=rtScreenMode.screenBackColour;
		self.tblTasks.accessColumn(1).backColor:=rtScreenMode.screenBackColour;
	endif;	
	
epilog
end;</source>
        <access>protected</access>
    </JadeMethod>
