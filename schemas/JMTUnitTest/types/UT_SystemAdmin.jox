    <JadeMethod name="tPort" id="051ca248-b7dd-4658-b551-a28b1215054d">
        <source>tPort();

/*

Purpose:		Create / Delete / Update port

Date			Who		Reason
15/05/2015		cnwmh5	Initial creation

*/

vars

	port						: CM_Port;
	pxyPort						: CM_Port;
	file						: File;
	
begin

	port := app.myRoot.allPorts["NZZUT"];
	if port &lt;&gt; null then
		app.myTrxDA.trxDeletePort(port, app.myPassport);
		self.assertNoTrxErrors();
		port := app.myRoot.allPorts["NZZUT"];
		self.assertNull(port);
	endif;
	
	port := app.myRoot.allPorts["NZZUX"];
	if port &lt;&gt; null then
		app.myTrxDA.trxDeletePort(port, app.myPassport);
		self.assertNoTrxErrors();
		port := app.myRoot.allPorts["NZZUX"];
		self.assertNull(port);
	endif;
	
	port := app.myRoot.allPorts["NZZUY"];
	if port &lt;&gt; null then
		app.myTrxDA.trxDeletePort(port, app.myPassport);
		self.assertNoTrxErrors();
		port := app.myRoot.allPorts["NZZUY"];
		self.assertNull(port);
	endif;
	
	create pxyPort transient;
	pxyPort.setProxy("NZZUT", "ZUT", "UNIT TEST ONLY - DO NOT USE", null, null, app.myRoot.allCountries["NZ"],
		null, null, false, true, false, false, false, false, false, false, false); 
	app.myTrxCA.trxCreatePort(pxyPort, port, app.myPassport);
	self.assertNoTrxErrors();
	self.assertNotNull(port);
	
	delete pxyPort;
	beginLoad;
	pxyPort := port.pxyCreateUpdateProxy();
	endLoad;
	pxyPort.setPropertyValue("bIsAirport", true);
	app.myTrxUA.trxUpdatePort(pxyPort, app.myPassport);
	self.assertNoTrxErrors();
	self.assertEqual(port.bIsAirport, true);
	
	delete file;
	create file transient;
	file.usePresentationFileSystem := true;
	file.fileName := "c:\temp\Ports.txt";
	if file.isAvailable() then
		file.purge();
	endif;
	file.writeLine("");
	file.writeLine("NZZUX, ZUX, UNIT TEST ONLY - DO NOT USE,NZ,0");
	file.writeLine("NZZUY, ZUY, UNIT TEST ONLY - DO NOT USE,NZ,0");
	file.close();
	file.kind := File.Kind_Unknown_Text;	// 4/3/16 cnwmp6 PAR 36286 unicode version
	app.myTrxCA.trxImportPortFromFile(file, app.myPassport);
	self.assertNoTrxErrors();
	self.assertNotNull(app.myRoot.allPorts["NZZUX"]);
	self.assertNotNull(app.myRoot.allPorts["NZZUY"]);

epilog

	delete file;
	delete pxyPort;

end;</source>
    </JadeMethod>
    <JadeMethod name="tPortGroups" id="509b95d6-bab1-48e7-af47-a4f1559fa024">
        <source>tPortGroups();
/*

Purpose:	Add Port Groups	

Date		Who		Reason
06/03/2014	cnwma1	Initial creation

*/

vars
	portGroup		: CM_PortGroup;
	portSet			: ObjectArray;
	portGroupDesc	:String;

begin
	
	// AddPorts
	create portSet transient;
	portSet.add(app.myRoot.allPortLocodes["EGSOK"]);
	portSet.add(app.myRoot.allPortLocodes["EGDAM"]);
	
	self.opts.purge();
	self.opts.addAssoc("Ports",portSet);
	
	//Create Port group
	portGroup	:= self.addPortGroup("UTMA","UnitTest PortGroup");
	self.assertNotNull(portGroup);
	
	// update PORT Group
	portGroupDesc := portGroup.description &amp; ":UP";
	self.opts.purge();
	self.opts.addAssoc("portGroupDesc", portGroupDesc);
	self.updatePortGroup(portGroup);
	self.assertEqual(portGroup.description, portGroupDesc);
	
	// Active/InActive Port Code
	
	app.myTrxUA.trxPortCodeMakeActiveInactive(portSet,false,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	

epilog
	app.myTrxUA.trxPortCodeMakeActiveInactive(portSet,true,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	delete portSet;

end;</source>
    </JadeMethod>
    <JadeMethod name="tPreventPasswordChange" id="a05a8900-18ee-4e39-bef2-63dd65f490d3">
        <source>tPreventPasswordChange();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Feb 2025	navah1	Initial creation
18 Feb 2025	navah1	Story 14660: MTN - New option to disable users from changing their own passwords
*/
constants
	UserName = "UT_NPWD";
vars
	user, 
	pxyUser	: CM_User;
	
begin 
	 
	// A user is created without password change restriction 
	self.deleteUser(UserName);
	user := self.addUser(UserName, UserName);
	self.assertNotNull(user);
	self.assertTrue(user.canChangePassword()); 
	
	// Password is changed for the user
	pxyUser := app.createUpdateProxy(user).CM_User;
	app.myTrxUA.trxUpdateUser(pxyUser,'NewPassword1', app.myPassport); 
	self.assertNoTrxErrorsOrWarnings();
	
	// User is now prevented to change password
	delete pxyUser;
	beginTransaction;
		user.setPreventPasswordChange(true);   
	commitTransaction;
	self.assertFalse(user.canChangePassword());  
	pxyUser := app.createUpdateProxy(user).CM_User;
	app.myTrxUA.trxUpdateUser(pxyUser,'NewPassword2', app.myPassport); 
	self.assertTrxErrorMsg(PasswordChangeProhibited, "The password has changed despite the restriction.");
	
	// Again, removed password change restriction.
	delete pxyUser;
	beginTransaction;
		user.setPreventPasswordChange(false);
	commitTransaction; 
	self.assertTrue(user.canChangePassword());
	pxyUser := app.createUpdateProxy(user).CM_User;
	app.myTrxUA.trxUpdateUser(pxyUser,'NewPassword3', app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog

	self.deleteUser(UserName);
	delete pxyUser; 
	
end; </source>
    </JadeMethod>
    <JadeMethod name="tPrinterDef" id="49e5c2a1-7b32-4e23-8317-a21cda64d362">
        <source>tPrinterDef();

/*

Purpose:		

Date			Who		Reason
18/06/2015		cnwmh5	Initial creation

*/

vars

	pxyPrinterDef					: CM_PrinterDef;
