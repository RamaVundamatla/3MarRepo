    <JadeMethod name="userNotify" id="a9292dd2-d0ae-4484-bd28-124225b00b3d">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
//26 January 2010	cnwml2


vars
	termEvent : Integer;
	invalidObject : Boolean;
	bolDtl : CM_BOLDtl;
begin
	on Exception do app.handleDeletedObject(exception, theObject, invalidObject);	//Par18495. For EDI action loading mode. Booking Reference can be created, deleted and re-created in on e EDI file.

	if self.myTerminal &lt;&gt; null then
		termEvent := self.myTerminal.getEventFromTerminalEvent(eventType);
	endif;
	
	if termEvent = Event_BOLAdd or termEvent = Event_BOLUpdate then
		if self.btnShowBOLItems.value then
			if termEvent = Event_BOLAdd then
				foreach bolDtl in theObject.CM_BOL.allBOLDtls do
					self.zTblDataSysNotifyCreate(Object_Create_Event, bolDtl, eventTag);
					self.selectNewBOL(bolDtl);
				endforeach;
			elseif termEvent = Event_BOLUpdate then
				foreach bolDtl in theObject.CM_BOL.allBOLDtls do
					self.zTblDataSysNotifyUpdate(Object_Update_Event, bolDtl, eventTag);
					self.selectNewBOL(bolDtl);
				endforeach;
			else
				inheritMethod(eventType, theObject, eventTag, userInfo);
			endif;
		else
			if termEvent = Event_BOLAdd then
				self.zTblDataSysNotifyCreate(Object_Create_Event, theObject, eventTag);
				self.selectNewBOL(theObject);
			elseif termEvent = Event_BOLUpdate then
				self.zTblDataSysNotifyUpdate(Object_Update_Event, theObject, eventTag);
				self.selectNewBOL(theObject);
			else
				inheritMethod(eventType, theObject, eventTag, userInfo);
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="zDoAdd" id="dfade1b2-3a3a-4f7b-81d3-d906070f70a4">
        <updating/>
        <source>zDoAdd() updating, protected;
//06 January 2010	cnwml2


vars

begin
	//+cnwml2 PAR23230
	//when the user attempts to add an item if the thumbnail is hidden
	//it will show it.
	if self.isThumbnailVisible = false then
		self.hideShowThumbnail();
	endif;


	if self.allowUpdate = false then
		return;
	endif;
	
	if self.mode &lt;&gt; Mode_View then
		//Must not be already editing an object
		return;
	endif;
	if self.myCurrentObject &lt;&gt; null then
		if self.myCurrentObject.isKindOf(CM_BOLDtl) then
			if self.myCurrentObject.CM_BOLDtl.myBOL.bolType = BOLType_Log then
				return;  //shouldn't get here
			else
				self.doAddEditBOL(true);
			endif;
		else
			if self.myCurrentObject.CM_BOL.bolType = BOLType_Log then
				return;  //shouldn't get here
			else
				self.doAddEditBOL(true);
			endif;
		endif;
	else
		self.doAddEditBOL(true);
		//app.msgBox('Cannot perform edit as there is no item selected.', 'Error', MsgBox_Stop_Icon  + MsgBox_OK_Only);
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zDoEdit" id="37b1afb2-ef54-4c71-94b5-474a5cb59d34">
        <updating/>
        <source>zDoEdit() updating, protected;
//06 January 2010	cnwml2


vars

begin
	//+cnwml2 PAR23230
	//when the user attempts to edit an item if the thumbnail is hidden
	//it will show it.
	if self.isThumbnailVisible = false then
		self.hideShowThumbnail();
	endif;

	if (self.allowUpdate = false) or
	   (self.mode &lt;&gt; Mode_View) then 
		//Must not be already editing an object
		return;
	endif;

	if self.myCurrentObject &lt;&gt; null then
		if self.myCurrentObject.isKindOf(CM_BOLDtl) then
			if self.myCurrentObject.CM_BOLDtl.myBOL.bolType = BOLType_Log then
				inheritMethod();
			else
				self.doAddEditBOL(false);
			endif;
		else
			if self.myCurrentObject.CM_BOL.bolType = BOLType_Log then
				inheritMethod();
			else
				self.doAddEditBOL(false);
			endif;
		endif;
	else
		app.msgBox('Cannot perform edit as there is no item selected.', 'Error', MsgBox_Stop_Icon  + MsgBox_OK_Only);
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zHideForViewOnly" id="d8cd662d-859d-4eb4-a7c6-986a1127a414">
        <source>zHideForViewOnly();
/*
Purpose:			
Date		Who		Reason
11 August 2016	cnwab1	Initial creation
*/

vars

begin
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mnuEdit.visible := false;
		self.mnuAdd.visible := false;
		self.mnuDelete.visible := false;
		self.mnuReconcileBOL.visible := false;
		self.btnEditTV.enabled:= false;
		self.btnNewTV.enabled:= false;
		self.btnDeleteTV.enabled:= false;
		self.btnReconciled.enabled:= false;
		self.btnShowBOLItems.enabled:= false;
	endif;

epilog

end;</source>
    </JadeMethod>
</GUIClass>
