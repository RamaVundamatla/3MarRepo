    <JadeMethod name="setUserDefinedTIForModify" id="fd4a91ed-c88e-44ff-87e7-0d1cda1d49d4">
        <updating/>
        <source>setUserDefinedTIForModify(_ediTi: CM_EDICargoTI; _terminal: CM_Terminal; _updateController: CMIF_TIUpdateController input; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2014	cnwmc5	Initial creation	CCMS 2352

*/

vars

begin
	inheritMethod(_ediTi, _terminal, _updateController, _passport);
	
	if _ediTi.isoType &lt;&gt; null then
		self.isoType := _ediTi.isoType;
	endif;
	
	if _ediTi.preSlung &lt;&gt; null then
		self.preSlung := _ediTi.preSlung;
	endif;
	
	if _ediTi.wet &lt;&gt; null then
		self.wet := _ediTi.wet;
	endif;
	
epilog

end;</source>
        <Parameter name="_ediTi" type="CM_EDICargoTI"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_updateController" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="usesISOType" id="b4357646-6941-40c5-9e83-3c8e65fdaae7">
        <source>usesISOType() : Boolean;
// ---------------------------------------------------------------------------
// Created:		17 March 2008 By Andrew Bishop cnwab1
//
// Purpose:		PAR 16016
//
// ---------------------------------------------------------------------------
vars
begin
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateCubicMetres" id="47129665-c378-466a-9a06-efa8164fc808">
        <source>validateCubicMetres(pControl: CMIF_TIUpdateController) protected;
// ---------------------------------------------------------------------------
// Created:     11 July 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 14 Jul 2011	NDL		Par 27485 - Should be checking volume NOT totalVolume.
// ---------------------------------------------------------------------------
vars

begin

	inheritMethod(pControl);

	if self.getMyTotalVolume = NULL_VOLUME then
		// Cubic metres is required for timber
	//	app.raiseCMException1(REQUIRED_FIELD, 'volume', 'volume', pControl.myUserObject);
		app.raiseCMException(Input_required_field_volume, 'volume', pControl.myUserObject); // cnwdb2	PAR 35364
	elseif (self.getMyTotalVolume &lt; 0) or (self.getMyTotalVolume &gt; 40) then
		app.raiseCMWarning1(WARN_CUBIC_METRE_RANGE, self.getMyTotalVolume.String, ETRow_Volume, pControl.myUserObject, self);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="pControl" type="CMIF_TIUpdateController"/>
    </JadeMethod>
</Class>
