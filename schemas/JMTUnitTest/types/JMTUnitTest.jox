    <JadeMethod name="initialize" id="3cb82bd6-85df-44e2-be17-7650bd28cd35">
        <updating/>
        <source>initialize() updating;
//25 September 2008	cnwdw1	
// 25 March 2025	navcs2	MTN-34411
vars
	jsr			: JadeSkinRoot;
	root		: UM_Root;
	userCode	: String;
	user		: CM_User;
	
begin
	inheritMethod();
	
	if process.sendMsg("_isBeingDebugged").Boolean then																								// 25 March 2025	navcs2	MTN-34411
		if app.checkUnitTestRunnerRunning() then																									// 25 March 2025	navcs2	MTN-34411
			app.msgBox("Unit Tests are currently running, unable to start in Debug mode", "ERROR", MsgBox_OK_Only + MsgBoxCustom_Icon_Stop);		// 25 March 2025	navcs2	MTN-34411
			terminate;																																// 25 March 2025	navcs2	MTN-34411
		endif;																																		// 25 March 2025	navcs2	MTN-34411
	endif;																																			// 25 March 2025	navcs2	MTN-34411
	
	//cnwmc5 - PAR 31051
	jsr := JadeSkinRoot.firstInstance;
	//app.setApplicationSkin(jsr.allApplicationSkins["JMTMetro2013"]);
	
	userCode := process.getUserCode();
	userCode := userCode.toUpper();
	user := app.myRoot.allUsers[userCode];
	
	if user &lt;&gt; null then
		app.setApplicationSkinByName(user.getUseAppSkinName());
	else
		app.setApplicationSkin(jsr.allApplicationSkins["JMTMetro2013"]);
	endif;
	
	if self.myMobileAgent = null then
		create self.myMobileAgent transient;
	endif;
	
// cnwdad1 31/05/2010.
	if self.myLogFile = null then
		self.initLogFile();
	endif;
	
	// 29/08/2011 cnwmh5
	if self.allCategories = null then
		create self.allCategories transient;
	endif;
	
	// 10/12/2014 cnwmh5
	if self.mySaveDataObjsToRestore = null then
		create self.mySaveDataObjsToRestore transient;
	endif;
	
	// 20/03/2013 cnwmh5
	if self.allTerminalActiveCargoMaps = null then
		create self.allTerminalActiveCargoMaps transient;
	endif;	

	self.getMasterAddress();			//cnwmc5 - 12/10/2012
	
	// 11/06/2015 cnwmh5 - Setup if not already done
	if UM_MapFilesToCompact.instances.size = 0 then
		app.setupDefaultMapFilesToCompress();
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initializeAgents" id="b979a7f8-3f82-44c2-91a0-1b4b020115b7">
