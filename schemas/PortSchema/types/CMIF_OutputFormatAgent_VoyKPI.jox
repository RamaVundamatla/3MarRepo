        <source>getContainerDetail(_length : Integer; _location : CM_Object) : ObjectArray;
/*
Purpose:			
Date		Who		Reason
18 February 2015	cnwab1	Initial creation
*/

vars

begin
	return self.allData_Containers.getAtKey(_length, _location).ObjectArray;

epilog

