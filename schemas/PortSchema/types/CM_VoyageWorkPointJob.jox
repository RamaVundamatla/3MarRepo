    <JadeMethod name="canBeIncludedOnWOO" id="56426517-7055-4bf3-b1a4-0d5a9c9456db">
        <source>canBeIncludedOnWOO(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Jul 2023	navma1	ChangeRequest 56738: EUP | Stop Including Work Order Jobs in Work order operation screen

*/

vars
	transport : Integer;
	wod		  : CM_WorkOrderTIDtl;
begin
	
	wod := self.myWODtl;
	if wod &lt;&gt; null then
		transport  := wod.getTransport();
	endif;
	
	if transport = TI_TRANSMODE_SHIP then
		return true	;
	endif;
epilog

end;</source>
