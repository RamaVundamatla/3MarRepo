<Class name="CM_PaymentMethod" id="f7c553bd-4e59-4689-ab64-b612e9e618f4">
    <superclass name="CM_Code"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cash"/>
    <PrimAttribute name="isCheque" id="d85869cd-a053-4aa2-b256-77c9d87c89e1">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="isPOS" id="dfb22461-7fb7-4fbe-9a7b-a45e0c208f6e">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myRoot" id="38ca3b21-6f73-45a5-b35f-f2808c0709e9">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Root"/>
        <access>readonly</access>
        <Inverse name="CM_Root::allPaymentMethods"/>
    </ExplicitInverseRef>
    <JadeMethod name="create" id="35b6028f-ade0-4800-933d-ae432ab53f9d">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 July 2012	cnwndl1	Initial creation	Par 29968

*/

vars

begin

	self.isCodeGroupNOTRequired := true;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="45f3b9b9-95f9-47c1-9a88-0afaf432e0d2">
        <updating/>
        <source>setForCreate(pProxy: CM_Code) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 July 2012	cnwndl1	Initial creation	Par 29968

*/

vars

begin
	self.isCheque := pProxy.CM_PaymentMethod.isCheque;
	self.isPOS := pProxy.CM_PaymentMethod.isPOS;
	inheritMethod(pProxy);
	
	self.myRoot := app.myRoot;

epilog

end;</source>
        <Parameter name="pProxy" type="CM_Code"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="6187e455-840d-4f08-aca8-e2024eb848a3">
        <updating/>
        <source>setForUpdate(_proxy: CM_Code) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 July 2012	cnwndl1	Initial creation	Par 29968

*/

vars

begin
	self.isCheque := _proxy.CM_PaymentMethod.isCheque;
	self.isPOS := _proxy.CM_PaymentMethod.isPOS;
	inheritMethod(_proxy);

epilog

end;</source>
        <Parameter name="_proxy" type="CM_Code"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="5b10ae48-994f-4a50-b85a-d36c3b7afdd7">
        <updating/>
        <source>setProxy(	_code : String;
			_description : String;
			_isCheque : Boolean;
			_isPOS : Boolean
			) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 July 2012	cnwndl1	Initial creation	Par 29968
29/07/2016 cnwma1 TFS #2447:Adding duplicate gives error
*/

vars

begin

	self.code := _code.toUpper(); //29/07/2016 cnwma1 TFS #2447
	self.description := _description;
	self.isCheque := _isCheque;
	self.isPOS := _isPOS;

epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_isCheque" type="Boolean"/>
        <Parameter name="_isPOS" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="4871e6b5-7f9d-4f87-8b06-276402866c8a">
        <source>validateForCreate();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 July 2012	cnwndl1	Initial creation	Par 29968
//01/08/2016 cnwma1 TFS #2447:Adding duplicate gives error
*/

vars
	existing : CM_PaymentMethod;
begin
	inheritMethod();
		if self.code &lt;&gt; null then
		foreach existing in app.myRoot.allPaymentMethods do  //29/07/2016 cnwma1 TFS #2447
			if existing.code.toUpper = self.code.toUpper then
				app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, 'code', null);
			endif;
		endforeach;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="2bdac82b-5a32-417e-9b18-c7b1079e231d">
        <source>validateMe() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 July 2012	cnwndl1	Initial creation	Par 29968
*/

vars

	existing : CM_PaymentMethod;

begin

	inheritMethod();
	if not self.isTransient then
		if self.code &lt;&gt; null then
			existing := app.myRoot.allPaymentMethods.getAtKey(self.code);
			if existing &lt;&gt; null and existing &lt;&gt; self then
				app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, 'code', null);
			endif;
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
