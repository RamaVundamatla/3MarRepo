    <JadeMethod name="create" id="e8d93ed2-a2a8-4499-8b9a-c65e020290e0">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//29/09/2025	navkc1 JIRA 35917 MTN | Invoice Static Data Manual Line Creation Refactor

*/

vars

begin
	self.isManual := true; // Default is true. Set it to false manually if required
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="d43ba713-9dca-4a03-bd45-6a748c328a0e">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 10 March 2023  navmv20 TFS 56128 Task 56129: UI - Manual Invoice Lines - Multi TI Invoice Line Type
vars

begin
	if  self.myInvoice = null then 
		app.raiseCMException(Invoic_null_must_provid_invoic,null,null);
	else
		if  self.myInvoice.isVoided then 
			//app.raiseCMException1(Full_Replacement_Message,"Invoice is VOID. Cannot use invoice " &amp; self.myInvoice.sequenceNum.String,null,null); //- cnwmd1, Par 20524
			app.raiseCMException1(Invoice_void_cannot_invoice, self.myInvoice.sequenceNum.String,null,null);
		//elseif  self.myInvoice.status = CM_Invoice.INVOICE_POSTED then
		elseif self.myInvoice.isPostedOrReversal then	//04 Sep 2017	NDL	TFS 6759	
			//app.raiseCMException1(Full_Replacement_Message,"Invoice is POSTED. Cannot use invoice " &amp; self.myInvoice.sequenceNum.String,null,null); //- cnwmd1, Par 20524
			app.raiseCMException1(Invoice_posted_cannot_invoice, self.myInvoice.sequenceNum.String,null,null);
//		elseif  self.myInvoice.status = CM_Invoice.INVOICE_PENDING 
//		and not self.myInvoice.isManual then 
//			app.raiseCMException1(Full_Replacement_Message,"Invoice is PENDING. Cannot use invoice " &amp; self.myInvoice.sequenceNum.String,null,null);
		endif;

	endif;
	//if  self.myInvoiceLineType = null then //10 March 2023  navmv20 TFS 56128 Task 56129
	if self.allInvoiceLineTypes = null or self.allInvoiceLineTypes.isEmpty then //10 March 2023  navmv20 TFS 56128 Task 56129
		//app.raiseCMException1(Full_Replacement_Message,"Invoice Line Type is null. You must provide an invoice Line Type.",null,null); //- cnwmd1, Par 20524
		app.raiseCMException(Invoi_line_type_null_must_prov,null,null);
	endif;
end;</source>
    </JadeMethod>
</Class>
