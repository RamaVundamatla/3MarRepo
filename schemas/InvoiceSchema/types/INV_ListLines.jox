    <JadeMethod name="btnNormal_click" id="4f17182c-0db1-4a6c-8f00-d1ebb3e2f57b">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnNormal_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	app.mousePointer := MP_HOURGLASS;
	//epr par 36958 24/6/15
	if not app.myCurrentUserCan(self.myTerminal, PmAdmInvoiceLineStatusNormal) then

		app.msgBox(app.getErrorString1(VB_SECMOVE,app.getErrorString(Invoice_line_status_normal)) ,
										app.getErrorString(INV_Invoice_Security),
										MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);

		return;
	endif;
	if self.myTerminal.allInvoiceStatusReasons.size &gt; 0 and self.myCurrentInvoiceLine &lt;&gt; null and self.myCurrentInvoiceLine.status = CM_InvoiceLine.STATUS_VOIDED then
		self.showInvoicePropFrame(ETView_InvListInvLinePropVoid); //epr par 36958 28/9/15
	else
		self.doSaveChangeStatus(CM_InvoiceLine.STATUS_NORMAL);
	endif;
	
epilog
	app.mousePointer := MP_DEFAULT;

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
