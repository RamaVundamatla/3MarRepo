    <JadeMethod name="checkExplicit" id="a837e550-2f3e-4872-85bb-59beb71bdd30">
        <source>checkExplicit(pPropertyObj : Property):Boolean protected;

// Check to ensure not (automatically maintained end) of a property relationship.
vars
	inverseObj		: ExplicitInverseRef;
	referenceObj	: Reference;
	
begin
	if pPropertyObj.isKindOf(ExplicitInverseRef) then
		inverseObj	:=	pPropertyObj.ExplicitInverseRef;
		
		if inverseObj.updateMode.Character.toHex().String = "02" then
			return true;
		endif;
	endif;
	
	if pPropertyObj.isKindOf(Reference) then
		referenceObj	:=	pPropertyObj.Reference;
		
		if referenceObj.isExclusiveObject() then
			return true;
		endif;
	endif;
	
	return false;
end;</source>
        <access>protected</access>
        <Parameter name="pPropertyObj" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="classChildCreateMethod" id="2fb6b41c-de36-48cf-97b9-2cfdc2e0fc31">
        <source>classChildCreateMethod(	pFileObj : File;
						pClassObj : Class;
						pAllClassProperties : PropertyNDict io);

// writes the specific code relating to the method 'initializeMe' that resides on the Database Class

vars
	line			: String;
	time			: Time;
	date			: Date;
	parentClassObj	: Class;
	
begin
	pFileObj.writeLine(Tab &amp; Tab &amp; parentClassObj.name &amp; " (");
	pFileObj.writeLine("__method create" &amp; pClassObj.name &amp; " =");
	line := "create" &amp; pClassObj.name &amp; "(";
	line := line &amp; self.classPropertyTypeList(pClassObj, pAllClassProperties, null);
//	line := line &amp; Tab &amp; Tab &amp; Tab &amp; "p" &amp; pClassObj.name &amp; "New :" &amp; pClassObj.name &amp; " io): String updating; ";
	line := line &amp; Tab &amp; Tab &amp; Tab &amp; "p" &amp; pClassObj.name &amp; "New :" &amp; pClassObj.name &amp; " io) updating; ";
	pFileObj.writeLine(line);
	pFileObj.writeLine("");
	pFileObj.writeLine("// This method created by JediMethodGenerator at " &amp; time.String &amp; " on " &amp; date.String);
	pFileObj.writeLine("");
	pFileObj.writeLine("vars");
	pFileObj.writeLine("");
//	pFileObj.writeLine(Tab &amp; "errorMessage" &amp; Tab &amp; ": String;");
	pFileObj.writeLine(Tab &amp; "v" &amp; pClassObj.name &amp; Tab &amp; ": " &amp; pClassObj.name &amp; ";");
	pFileObj.writeLine("");
	pFileObj.writeLine("begin");
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "// Validation");
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "create " &amp; "v" &amp; pClassObj.name);
//	pFileObj.writeLine(Tab &amp; "errorMessage := v" &amp; pClassObj.name &amp; ".initializeMe(");
	pFileObj.writeLine(Tab &amp; "v" &amp; pClassObj.name &amp; ".initializeMe(");
	pFileObj.writeLine(self.classPropertyList(pClassObj, pAllClassProperties));
	pFileObj.writeLine("");
//	pFileObj.writeLine(Tab &amp; "if errorMessage &lt;&gt; null then");
//	pFileObj.writeLine(Tab &amp; Tab &amp; "return errorMessage;");
//	pFileObj.writeLine(Tab &amp; "endif;");
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "p" &amp; pClassObj.name &amp; " := v" &amp; pClassObj.name &amp; ";");
	pFileObj.writeLine("");
	pFileObj.writeLine("");
	pFileObj.writeLine("epilog");
	pFileObj.writeLine("");
//	pFileObj.writeLine(Tab &amp; "return errorMessage;");
//	pFileObj.writeLine("");
	pFileObj.writeLine("end;");
	pFileObj.writeLine("");
	pFileObj.writeLine("__endMethod;");
	pFileObj.writeLine(Tab &amp; Tab &amp; ")");
end;</source>
        <Parameter name="pFileObj" type="File"/>
        <Parameter name="pClassObj" type="Class"/>
        <Parameter name="pAllClassProperties" type="PropertyNDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="classCreateTypeDefinition" id="a4dcca44-9774-4875-8ea2-e38383d19c3b">
        <source>classCreateTypeDefinition(	pNumber : Integer io;
							pFileObj : File io;
							pTimeStamp : String;
							pParentClassObj : Class;
							pTheClass : Class;
							pMethodName : String;
							pAllClassProperties : PropertyNDict io);

vars
	line : String;
	
begin
	self.setJadeMethodDefinition(pNumber, pFileObj, pParentClassObj, pMethodName);
	
	line	:=	pMethodName &amp;"(";
	line	:=	line &amp; self.classPropertyTypeList(pTheClass, pAllClassProperties, null);
	line	:=	line &amp; Tab &amp; Tab &amp; Tab &amp; "p" &amp; pTheClass.name &amp; "New:" &amp; pTheClass.name &amp; ";" &amp; CrLf;
	
	if line &lt;&gt; pMethodName &amp; "(" then
		line[(line.length - 2):3] := ")  ";
	else
		line	:=	line &amp; ")";
	endif;
	
	line	:=	line &amp; ": String updating, number = " &amp; pNumber.String &amp; ";";
	pFileObj.writeLine(line);
	
	self.setModifiedLine(pFileObj, pTimeStamp);
end;</source>
        <Parameter name="pNumber" type="Integer" usage="io"/>
        <Parameter name="pFileObj" type="File" usage="io"/>
        <Parameter name="pTimeStamp" type="String"/>
        <Parameter name="pParentClassObj" type="Class"/>
        <Parameter name="pTheClass" type="Class"/>
        <Parameter name="pMethodName" type="String"/>
        <Parameter name="pAllClassProperties" type="PropertyNDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="classInitializeMeMethod" id="94590cd7-e312-47c2-91d7-b45d3563e99d">
        <source>classInitializeMeMethod(pFileObj : File;
						pClassObj : Class;
						pAllClassProperties : PropertyNDict io);

// writes the specific code relating to the method 'initializeMe' that resides on the Database Class

vars
	line		: String;
	time		: Time;
	date		: Date;
	propertyObj	: Property;
	
begin
	pFileObj.writeLine(Tab &amp; Tab &amp; pClassObj.name &amp; " (");
	pFileObj.writeLine("__method initializeMe =");
	line := "initializeMe(";
	line := line &amp; self.classPropertyTypeList(pClassObj, pAllClassProperties, null);
	
	if line &lt;&gt; "initializeMe(" then
		line[(line.length - 2):3] := ")  ";
	else
		line := line &amp; ")";
	endif;
	
//	line := line &amp; ": String updating; ";
	line := line &amp; " updating; ";
	pFileObj.writeLine(line);
	pFileObj.writeLine("");
	pFileObj.writeLine("// This method created by JediMethodGenerator at " &amp; time.String &amp; " on " &amp; date.String);
	pFileObj.writeLine("");
	pFileObj.writeLine("vars");
	pFileObj.writeLine("");
//	pFileObj.writeLine(Tab &amp; "errorMessage" &amp; Tab &amp; ": String;");
//	pFileObj.writeLine("");
	pFileObj.writeLine("begin");
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "// Validation");
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "self.validateMe(");
	pFileObj.writeLine(self.classPropertyList(pClassObj, pAllClassProperties));
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "// Attributes (Non Keys)");
	pFileObj.writeLine("");
	
	foreach propertyObj in pAllClassProperties
	where not propertyObj.isKindOf(Reference) and not propertyObj.isUsedAsKey
	do
		pFileObj.writeLine(	Tab &amp; "self." &amp; propertyObj.name &amp; " := " &amp;
							Tab &amp; self.getParameterName(propertyObj) &amp; ";");
	endforeach;
	
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "// Attributes (Keys)");
	pFileObj.writeLine("");
	
	foreach propertyObj in pAllClassProperties
	where not propertyObj.isKindOf(Reference) and propertyObj.isUsedAsKey
	do
		pFileObj.writeLine(	Tab &amp; "self." &amp; propertyObj.name &amp; " := " &amp;
							Tab &amp; self.getParameterName(propertyObj) &amp; ";");
	endforeach;
	
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "// Singleton References");
	pFileObj.writeLine("");
	
	foreach propertyObj in pAllClassProperties
	where propertyObj.isKindOf(Reference) and not propertyObj.isKindOf(CollClass)
	do
		pFileObj.writeLine(	Tab &amp; "self." &amp; propertyObj.name &amp; " := " &amp;
							Tab &amp; self.getParameterName(propertyObj) &amp; ";");
	endforeach;
	
	pFileObj.writeLine("");
	pFileObj.writeLine("epilog");
	pFileObj.writeLine("");
//	pFileObj.writeLine(Tab &amp; "return errorMessage;");
//	pFileObj.writeLine("");
	pFileObj.writeLine("end;");
	pFileObj.writeLine("");
	pFileObj.writeLine("__endMethod;");
	pFileObj.writeLine(Tab &amp; Tab &amp; ")");
end;</source>
        <Parameter name="pFileObj" type="File"/>
        <Parameter name="pClassObj" type="Class"/>
        <Parameter name="pAllClassProperties" type="PropertyNDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="classMethodTypeDefinition" id="beedc5c2-95c7-4314-bcb6-3067d1647b06">
        <source>classMethodTypeDefinition(	pNumber : Integer io;
							pFileObj : File io;
							pTimeStamp : String;
							pClassObj : Class;
							pMethodName : String;
							pAllClassProperties : PropertyNDict io);

vars
	line : String;
	
begin
	self.setJadeMethodDefinition(pNumber, pFileObj, pClassObj, pMethodName);
	
	line := pMethodName &amp;"(";
	line := line &amp; self.classPropertyTypeList(pClassObj, pAllClassProperties, null);
	
	if line &lt;&gt; pMethodName &amp; "(" then
		line[(line.length - 2):3] := ")  ";
	else
		line := line &amp; ")";
	endif;
	
	line := line &amp; ": String updating, number = " &amp; pNumber.String &amp; ";";
	pFileObj.writeLine(line);
	
	self.setModifiedLine(pFileObj, pTimeStamp);
end;</source>
        <Parameter name="pNumber" type="Integer" usage="io"/>
        <Parameter name="pFileObj" type="File" usage="io"/>
        <Parameter name="pTimeStamp" type="String"/>
        <Parameter name="pClassObj" type="Class"/>
        <Parameter name="pMethodName" type="String"/>
        <Parameter name="pAllClassProperties" type="PropertyNDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="classMethodsCreate" id="ce153e77-5b7b-48f2-9111-4bba6ac46382">
        <source>classMethodsCreate(	pClassCollObj : ClassColl;
					pFileObj : File io;
					pIsReplaceExisting : Boolean;
					pIsInitializeMe : Boolean;
					pIsUpdateMe : Boolean;
					pIsValidateMe : Boolean;
					pIsCreateObject : Boolean);

vars
	classObj			: Class;
	date				: Date;
	time				: Time;
	timeStamp			: String;
	number				: Integer;
	methodName			: String;
	parentClassObj		: Class;
	modelSchemaObj		: Schema;
	allClassProperties	: PropertyNDict;
	
begin
// cnwdad1 16/04/2003 - Removed the ".ttt" from the end of the timestamp.
//	timeStamp := date.format("yyy:MM:dd:") &amp; time.format("hh:mm:ss.ttt");
	timeStamp := date.format("yyy:MM:dd:") &amp; time.format("hh:mm:ss");
	number := 1000;
	modelSchemaObj := currentSchema.getSchema(cmbTrxSchema.text);
//	foreach theModelSchema in currentSchema.withAllSuperschemas do
//		if theModelSchema.name = cmbTrxSchema.text then
//			break;
//		endif;
//	endforeach;

	create allClassProperties transient;
	
	// create the standard .scm file header stuff....
	self.writeScmHeader(pFileObj, modelSchemaObj);
	
	// create the TypeDefinitions.
	
	foreach classObj in pClassCollObj do
		self.getPropertyList(classObj, allClassProperties);
		methodName	:=	"validateMe";
		
		if pIsValidateMe and (classObj.getMethod(methodName) = null or pIsReplaceExisting) then
			self.classMethodTypeDefinition(number, pFileObj, timeStamp, classObj, methodName, allClassProperties);
			
			if classObj.getMethod(methodName) &lt;&gt; null and pIsReplaceExisting then
				txtOutcome.text := txtOutcome.text &amp; classObj.name &amp; "::" &amp; methodName &amp; " will be overwritten." &amp; CrLf;
			endif;
		endif;
		
		methodName := "initializeMe";
		
		if  pIsInitializeMe and (classObj.getMethod(methodName) = null or pIsReplaceExisting) then
			self.classMethodTypeDefinition(number, pFileObj, timeStamp, classObj, methodName, allClassProperties);
			
			if classObj.getMethod(methodName) &lt;&gt; null and pIsReplaceExisting then
				txtOutcome.text := txtOutcome.text &amp; classObj.name &amp; "::" &amp; methodName &amp; " will be overwritten." &amp; CrLf;
			endif;
		endif;
		
		methodName := "updateMe";
		
		if pIsUpdateMe and (classObj.getMethod(methodName) = null or pIsReplaceExisting) then
			self.classMethodTypeDefinition(number, pFileObj, timeStamp, classObj, methodName, allClassProperties);
			
			if classObj.getMethod(methodName) &lt;&gt; null and pIsReplaceExisting then
				txtOutcome.text := txtOutcome.text &amp; classObj.name &amp; "::" &amp; methodName &amp; " will be overwritten." &amp; CrLf;
			endif;
		endif;
		
		methodName := classObj.name.toLower &amp; "Create";
		
		if pIsCreateObject then
			parentClassObj := self.getParentClass(modelSchemaObj, classObj);
			
			if parentClassObj = null then
				txtOutcome.text := txtOutcome.text &amp; "Parent not selected, '&lt;parent&gt;Create' for '" &amp; classObj.name &amp; "' not generated." &amp; CrLf;
			endif;
		endif;
		
		if pIsCreateObject and parentClassObj &lt;&gt; null and (parentClassObj.getMethod(methodName) = null or pIsReplaceExisting) then
			self.classCreateTypeDefinition(number, pFileObj, timeStamp, parentClassObj, classObj, methodName, allClassProperties);
			
			if parentClassObj.getMethod(methodName) &lt;&gt; null and pIsReplaceExisting then
				txtOutcome.text := txtOutcome.text &amp; classObj.name &amp; "::" &amp; methodName &amp; " will be overwritten." &amp; CrLf;
			endif;
		endif;
	endforeach;

	pFileObj.writeLine("inverseDefinitions");
	pFileObj.writeLine("__methodImplementations");
	
	// create each of the methods.
	
	foreach classObj in pClassCollObj do
		self.getPropertyList(classObj, allClassProperties);
		
		// validateMe method code
		
		if pIsValidateMe and (classObj.getMethod("validateMe") = null or pIsReplaceExisting) then
			self.classValidateMeMethod(pFileObj, classObj, allClassProperties);
		endif;
		
		// initializeMe method code
		
		if pIsInitializeMe and (classObj.getMethod("initializeMe") = null or pIsReplaceExisting) then
			self.classInitializeMeMethod(pFileObj, classObj, allClassProperties);
		endif;
		
		// updateMe method code
		
		if pIsUpdateMe and (classObj.getMethod("updateMe") = null or pIsReplaceExisting) then
			self.classUpdateMeMethod(pFileObj, classObj, allClassProperties);
		endif;
		
		// &lt;Object&gt;Create method code
		
		methodName		:=	classObj.name.toLower &amp; "Create";
		parentClassObj	:=	self.getParentClass(modelSchemaObj, classObj);
		
		if pIsCreateObject and parentClassObj &lt;&gt; null and (classObj.getMethod(methodName) = null or pIsReplaceExisting) then
			self.classObjectCreateMethod(pFileObj, classObj, modelSchemaObj, allClassProperties);
		endif;															
	endforeach;
epilog
	delete allClassProperties;
end;</source>
        <Parameter name="pClassCollObj" type="ClassColl"/>
        <Parameter name="pFileObj" type="File" usage="io"/>
        <Parameter name="pIsReplaceExisting" type="Boolean"/>
        <Parameter name="pIsInitializeMe" type="Boolean"/>
        <Parameter name="pIsUpdateMe" type="Boolean"/>
        <Parameter name="pIsValidateMe" type="Boolean"/>
        <Parameter name="pIsCreateObject" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="classObjectCreateMethod" id="8393af6b-9331-4a55-83d6-c78b65c86232">
        <source>classObjectCreateMethod(pFileObj : File;
						pClassObj : Class;
						pModelSchemaObj : Schema;
						pAllClassProperties : PropertyNDict io);

// writes the specific code relating to the method '&lt;Object&gt;Create' that resides on the parent Database Class

vars
	line					: String;
	time					: Time;
	date					: Date;
	propertyObj				: Property;
	parentClassObj			: Class;
	parentClassPropertyObj	: Property;
	
begin
	parentClassObj			:=	self.getParentClass(pModelSchemaObj, pClassObj);
	parentClassPropertyObj	:=	self.getMyParentProperty(pModelSchemaObj, pClassObj);
	
	pFileObj.writeLine(Tab &amp; Tab &amp; parentClassObj.name &amp; " (");
	pFileObj.writeLine("__method " &amp; pClassObj.name.toLower &amp; "Create =");
	line := pClassObj.name.toLower &amp; "Create(";
	line := line &amp; self.classPropertyTypeList(pClassObj, pAllClassProperties, parentClassPropertyObj);
//	line := line &amp; Tab &amp; Tab &amp; Tab &amp; "p" &amp; pClassObj.name &amp; "New : " &amp; pClassObj.name &amp; " output): String updating; ";
	line := line &amp; Tab &amp; Tab &amp; Tab &amp; "p" &amp; pClassObj.name &amp; "New : " &amp; pClassObj.name &amp; " output) updating; ";
	pFileObj.writeLine(line);
	pFileObj.writeLine("");
	pFileObj.writeLine("// This method created by JediMethodGenerator at " &amp; time.String &amp; " on " &amp; date.String);
	pFileObj.writeLine("// It will create a " &amp; pClassObj.name &amp; " Object.");
	pFileObj.writeLine("");
	pFileObj.writeLine("vars");
	pFileObj.writeLine("");
//	pFileObj.writeLine(Tab &amp; "errorMessage" &amp; Tab &amp; ": String;");
	pFileObj.writeLine(Tab &amp; "v" &amp; pClassObj.name &amp; Tab &amp; ": " &amp; pClassObj.name &amp; ";");
	pFileObj.writeLine("");
	pFileObj.writeLine("begin");
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "create v" &amp; pClassObj.name &amp; ";");
	pFileObj.writeLine("");
//	line := Tab &amp; "errorMessage := v" &amp; pClassObj.name  &amp; ".initializeMe(";
	line := Tab &amp; "v" &amp; pClassObj.name  &amp; ".initializeMe(";
	
	foreach propertyObj in pAllClassProperties where not propertyObj.isKindOf(CollClass) do
		if not line = Tab &amp; "v" &amp; pClassObj.name  &amp; ".initializeMe(" then
			line := line &amp; ",";
		endif;
		
		if propertyObj = parentClassPropertyObj then
			line := line &amp; CrLf &amp; Tab &amp; Tab &amp; Tab &amp; "self";
		else
			line := line &amp; CrLf &amp; Tab &amp; Tab &amp; Tab &amp; self.getParameterName(propertyObj);
		endif;
	endforeach;
	
	line := line &amp; ");";
	pFileObj.writeLine(line);
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "p" &amp; pClassObj.name &amp; "New := " &amp; "v" &amp; pClassObj.name &amp; ";" );
	pFileObj.writeLine("");
	pFileObj.writeLine("epilog");
	pFileObj.writeLine("");
//	pFileObj.writeLine(Tab &amp; "return errorMessage;");
//	pFileObj.writeLine("");
	pFileObj.writeLine("end;");
	pFileObj.writeLine("");
	pFileObj.writeLine("__endMethod;");
	pFileObj.writeLine(Tab &amp; Tab &amp; ")");
end;</source>
        <Parameter name="pFileObj" type="File"/>
        <Parameter name="pClassObj" type="Class"/>
        <Parameter name="pModelSchemaObj" type="Schema"/>
        <Parameter name="pAllClassProperties" type="PropertyNDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="classPropertyList" id="bb4646ed-5e78-4e9d-adc6-2cee53133bbd">
        <source>classPropertyList(	pClassObj : Class;
					pAllClassProperties : PropertyNDict io) :String;

vars
	propertyObj		: Property;
	retValue		: String;
	
begin
	foreach propertyObj in pAllClassProperties where not propertyObj.isKindOf(CollClass) do
		retValue := retValue &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; self.getParameterName(propertyObj) &amp; "," &amp; CrLf;
	endforeach;
	
	if retValue.length &gt; 3 then
		retValue[(retValue.length() - 2):4] := ");  ";
	else
		retValue := ");";
	endif;
	
	return retValue;
end;</source>
        <Parameter name="pClassObj" type="Class"/>
        <Parameter name="pAllClassProperties" type="PropertyNDict" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="classPropertyTypeList" id="01ce418c-df11-46af-afda-ecf24484ea77">
        <source>classPropertyTypeList(	pClassObj : Class;
						pAllClassProperties : PropertyNDict io;
						pExcludePropertyObj : Property) :String;

vars
	propertyObj		: Property;
	retValue		: String;
	
begin
	foreach propertyObj in pAllClassProperties
	where (not propertyObj.isKindOf(CollClass) and propertyObj &lt;&gt; pExcludePropertyObj)
	do
		retValue := retValue &amp; Tab &amp; Tab &amp; Tab &amp; self.getParameterName(propertyObj) &amp; ":" &amp; propertyObj.getType.name &amp; ";" &amp; CrLf;
	endforeach;
	
	return retValue;
end;</source>
        <Parameter name="pClassObj" type="Class"/>
        <Parameter name="pAllClassProperties" type="PropertyNDict" usage="io"/>
        <Parameter name="pExcludePropertyObj" type="Property"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="classUpdateMeMethod" id="2b402e34-4c9c-495f-91e2-24d446a15316">
        <source>classUpdateMeMethod(pFileObj : File;
					pClassObj : Class;
					pAllClassProperties : PropertyNDict io);

	// writes the specific code relating to the method 'UpdateMe' that resides on the Database Class

vars
	line		: String;
	time		: Time;
	date		: Date;
	propertyObj	: Property;
	
begin
	pFileObj.writeLine(Tab &amp; Tab &amp; pClassObj.name &amp; " (");
	pFileObj.writeLine("__method updateMe =");
	line := "updateMe(";
	line := line &amp; self.classPropertyTypeList(pClassObj, pAllClassProperties, null);
	
	if line &lt;&gt; "updateMe(" then
		line[(line.length - 2):3] := ")  ";
	else
		line := line &amp; ")";
	endif;
	
//	line := line &amp; ": String updating; ";
	line := line &amp; " updating; ";
	pFileObj.writeLine(line);
	pFileObj.writeLine("");	
	pFileObj.writeLine("// This method created by JediMethodGenerator at " &amp; time.String &amp; " on " &amp; date.String);
	pFileObj.writeLine("// Please add any validation required, then delete this comment.");
	pFileObj.writeLine("");
	pFileObj.writeLine("vars");
	pFileObj.writeLine("");
//	pFileObj.writeLine(Tab &amp; "errorMessage" &amp; Tab &amp; ": String;");
//	pFileObj.writeLine("");
	pFileObj.writeLine("begin");
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "// Validation");
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "self.validateMe(");
	line := "";
	pFileObj.writeLine(self.classPropertyList(pClassObj, pAllClassProperties));
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "// Attributes (Non Keys)");
	pFileObj.writeLine("");
	
	foreach propertyObj in pAllClassProperties
	where not propertyObj.isKindOf(Reference) and not propertyObj.isUsedAsKey
	do
		pFileObj.writeLine(Tab &amp; "if self." &amp; propertyObj.name &amp; " &lt;&gt; " &amp; self.getParameterName(propertyObj) &amp; " then");
		pFileObj.writeLine(Tab &amp; Tab &amp;"self." &amp; propertyObj.name &amp; " := " &amp; Tab &amp; self.getParameterName(propertyObj) &amp; ";");
		pFileObj.writeLine(Tab &amp; "endif;");
	endforeach;
	
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "// Attributes (Keys)");
	pFileObj.writeLine("");
	
	foreach propertyObj in pAllClassProperties
	where not propertyObj.isKindOf(Reference) and propertyObj.isUsedAsKey
	do
		pFileObj.writeLine(Tab &amp; "if self." &amp; propertyObj.name &amp; " &lt;&gt; " &amp; self.getParameterName(propertyObj) &amp; " then");
		pFileObj.writeLine(Tab &amp; Tab &amp;"self." &amp; propertyObj.name &amp; " := " &amp; Tab &amp; self.getParameterName(propertyObj) &amp; ";");
		pFileObj.writeLine(Tab &amp; "endif;");
	endforeach;
	
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "// Singleton References");
	pFileObj.writeLine("");
	
	foreach propertyObj in pAllClassProperties
	where propertyObj.isKindOf(Reference) and not propertyObj.isKindOf(CollClass)
	do
		pFileObj.writeLine(Tab &amp; "if self." &amp; propertyObj.name &amp; " &lt;&gt; " &amp; self.getParameterName(propertyObj) &amp; " then");
		pFileObj.writeLine(Tab &amp; Tab &amp;"self." &amp; propertyObj.name &amp; " := " &amp; Tab &amp; self.getParameterName(propertyObj) &amp; ";");
		pFileObj.writeLine(Tab &amp; "endif;");
	endforeach;
	
	pFileObj.writeLine("");
	pFileObj.writeLine("epilog");
	pFileObj.writeLine("");
//	pFileObj.writeLine(Tab &amp; "return errorMessage;");
//	pFileObj.writeLine("");
	pFileObj.writeLine("end;");
	pFileObj.writeLine("");
	pFileObj.writeLine("__endMethod;");
	pFileObj.writeLine(Tab &amp; Tab &amp; ")");
end;</source>
        <Parameter name="pFileObj" type="File"/>
        <Parameter name="pClassObj" type="Class"/>
        <Parameter name="pAllClassProperties" type="PropertyNDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="classValidateMeMethod" id="7cb67671-5bb4-4422-b90e-e6f7ac4c6f50">
        <source>classValidateMeMethod(	pFileObj : File;
						pClassObj : Class;
						pAllClassProperties : PropertyNDict io);

// writes the specific code relating to the method 'validateMe' that resides on the Database Class

vars
	line		: String;
	time		: Time;
	date		: Date;
	propertyObj	: Property;
	
begin
	pFileObj.writeLine(Tab &amp; Tab &amp; pClassObj.name &amp; " (");
	pFileObj.writeLine("__method validateMe =");
	line := "validateMe(";
	line := line &amp; self.classPropertyTypeList(pClassObj, pAllClassProperties, null);
	
	if line &lt;&gt; "validateMe(" then
		line[(line.length - 2):3] := ")  ";
	else
		line := line &amp; ")";
	endif;
	
	line := line &amp; " updating; ";
	pFileObj.writeLine(line);
	pFileObj.writeLine("");
	pFileObj.writeLine("// This method created by JediMethodGenerator at " &amp; time.String &amp; " on " &amp; date.String);
	pFileObj.writeLine("// Please add any validation required, then delete this comment.");
	pFileObj.writeLine("");
	pFileObj.writeLine("vars");
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "errorMessage" &amp; Tab &amp; ": String;");
	pFileObj.writeLine(Tab &amp; "attribLength" &amp; Tab &amp; ": Integer;");
	pFileObj.writeLine("");
	pFileObj.writeLine("begin");
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "// Validation");
	pFileObj.writeLine("");
	
	foreach propertyObj in pAllClassProperties
	where propertyObj.getType.name = "String"
	do
		pFileObj.writeLine(Tab &amp; "attribLength := self.class.cnEcGetStringPropertyLength(" &amp; propertyObj.name &amp; ");");
		pFileObj.writeLine(Tab &amp; "if attribLength &gt; 0 and attribLength &lt; " &amp; self.getParameterName(propertyObj) &amp; ".length then");
		pFileObj.writeLine(Tab &amp; Tab &amp; "errorMessage := errorMessage &amp; " &amp; self.getParameterName(propertyObj) &amp; " &amp; ' - text too long.  ';");
		pFileObj.writeLine(Tab &amp; "endif;");
	endforeach;
	
	pFileObj.writeLine("/*");
	pFileObj.writeLine(Tab &amp; "if someValue = null then");
	pFileObj.writeLine(Tab &amp; Tab &amp; "errorMessage := errorMessage &amp; 'Some reason for the error.  ';");
	pFileObj.writeLine(Tab &amp; "endif;");
	pFileObj.writeLine("*/");
	pFileObj.writeLine("");
	pFileObj.writeLine("epilog");
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; 'if errorMessage &lt;&gt; "" then');
	//pFileObj.writeLine(Tab &amp; Tab &amp; "global.cnEcRaiseBaseException(CNEC_BASE_EXCEPTION, 'errorMessage.');");
	pFileObj.writeLine(Tab &amp; Tab &amp; "CnEcBaseException.raise_(CNEC_X_12005, errorMessage);");
	pFileObj.writeLine(Tab &amp; "endif;");
	pFileObj.writeLine("");
	pFileObj.writeLine("end;");
	pFileObj.writeLine("");
	pFileObj.writeLine("__endMethod;");
	pFileObj.writeLine(Tab &amp; Tab &amp; ")");
end;</source>
        <Parameter name="pFileObj" type="File"/>
        <Parameter name="pClassObj" type="Class"/>
        <Parameter name="pAllClassProperties" type="PropertyNDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="cmbModelSchema_click" id="250669fa-9042-4529-a3c8-54c34579681a">
