    <JadeMethod name="addBodyLine" id="cdfdd1bd-03cb-4e28-9bc7-99eb38c689ef">
        <source>addBodyLine( _tmpKPITA : CM_KPITerminalArea; _fromColOrg : Boolean; _summaryObj : CM_KPITerminalArea input; _localColl : CM_KPIByTypeCodeTS input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 June 2016	cnwndl1	Initial creation	TFS 1752

*/

vars

	line : String;
	idx : Integer;

begin

	line :=  _tmpKPITA.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
	idx := self.tblData.addItemObject(_tmpKPITA, line.trimBlanks);
	if not _fromColOrg then
		self.mySummaryLine.addToSummaryLine( _tmpKPITA, false );
		_summaryObj.addToSummaryLine( _tmpKPITA, true );
	endif;
	_localColl.add( _tmpKPITA );

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_tmpKPITA" type="CM_KPITerminalArea"/>
        <Parameter name="_fromColOrg" type="Boolean"/>
        <Parameter name="_summaryObj" type="CM_KPITerminalArea" usage="input"/>
        <Parameter name="_localColl" type="CM_KPIByTypeCodeTS" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addSubHeadingLine" id="5cf84cdb-0cbc-480c-96fa-a23e8efd9cdb">
        <updating/>
        <source>addSubHeadingLine(	_summaryObj : CM_KPITerminalArea io; _summaryLines : IntegerArray input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 June 2016	cnwndl1	Initial creation	TFS 1752

*/

vars

	dummy : CM_KPITerminalArea;
	line : String;
	idx : Integer;

begin

	create dummy transient;
	dummy.clearSummaryData(_summaryObj.terminalAreaCode);
	line :=  dummy.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
	idx := self.tblData.addItemObject(null, line.trimBlanks);
	self.tblData.accessRow(idx).fontBold := true;
	_summaryLines.add(idx);
	delete dummy;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_summaryObj" type="CM_KPITerminalArea" usage="io"/>
        <Parameter name="_summaryLines" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addSubTotalLine" id="885f9f05-dd8b-4871-8563-23908ba6f5f9">
        <updating/>
        <source>addSubTotalLine(	_summaryObj : CM_KPITerminalArea io; _summaryLines : IntegerArray input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 June 2016	cnwndl1	Initial creation	TFS 1752

*/

vars

	totalStr : String;
	line : String;
	idx : Integer;

begin

	totalStr := app.getErrorString(CM_Totals);
	_summaryObj.setTerminalAreaCode( _summaryObj.terminalAreaCode &amp; " " &amp; totalStr );
	line :=  _summaryObj.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
	idx := self.tblData.addItemObject(self.myGridSummary, line.trimBlanks);
	self.tblData.accessRow(idx).fontBold := true;
	_summaryLines.add(idx);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_summaryObj" type="CM_KPITerminalArea" usage="io"/>
        <Parameter name="_summaryLines" type="IntegerArray" usage="input"/>
    </JadeMethod>
