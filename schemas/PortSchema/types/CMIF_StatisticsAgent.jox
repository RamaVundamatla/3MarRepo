    <JadeMethod name="calcFree" id="81660e9f-e391-4bb7-9ab6-4517ab9093ce">
        <source>calcFree(_containerSize: Integer; _locations: CM_LCArray; _minHeight, _maxHeight : Integer): Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 March 2009	cnwjk3	Initial creation

*/

vars
	tiWidth,
	total, i: Integer;
	prevColumn,
	endColumn,
	nextColumn : Integer;
	maxHeight,
	prevOffset,
	offset: Integer;
	rows: ObjectArray;
	obj: Object;
	row: CM_LCArray;
	nextLC: CM_GridController;
begin
	create rows transient;
	self.splitIntoRows(_locations, rows);
	foreach obj in rows do
		row := obj.CM_LCArray;
		if not self.findStartColumnOffset(_containerSize, row, nextColumn, offset) then
			continue;
		endif;
		nextLC := row[nextColumn].CM_GridController;
		while nextLC &lt;&gt; null do
			prevColumn := nextColumn;
			prevOffset := offset;
			maxHeight := 0;
			if self.locationContainsStartOfTI(nextLC) then
				
				// TODO : Might also need to check the type of cargo here???
				tiWidth := self.getWidthOfTIForPrimaryLocation(nextLC);
				if tiWidth 	= _containerSize then
					total := total + getSpareHeight(nextLC, _minHeight, _maxHeight);
				endif;
				
				// The next time round the loop we want to start after this TI.
				self.getNextColumnAndOffset(nextLC, nextColumn, offset);
				
				// PAR 19228
				if self.columnAndOffsetUnchanged(prevColumn, nextColumn, prevOffset, offset) then
					break;
				endif;				
			else
				
				// PAR 19310
				if not self.canStartContainerAtLocation(_containerSize, nextLC, offset) then
					nextColumn := nextColumn + 1;
					if nextColumn &lt;= row.size() then
						nextLC := row[nextColumn].CM_GridController;
					else
						nextLC := null;
					endif;
					continue;
				endif;

				if self.canFitContainer(_containerSize, nextLC, nextColumn, offset, maxHeight, false, row.size()) then
					
					// PAR 19228
					if self.columnAndOffsetUnchanged(prevColumn, nextColumn, prevOffset, offset) then
						break;
					endif;				

					// We can fit the container in, but we now need to check for any strict grids that have been defined
					if offset = 0 then
						endColumn := nextColumn - 1;
					else
						endColumn := nextColumn;
					endif;
					
					// PAR 19310 
					//if self.haveSameGridTypes(prevColumn, endColumn, row) then	
						total := total + maxHeight.min(_maxHeight - _minHeight + 1);
					//else
						// Container overlaps different grids, so we need to try again, starting from the next LC in the row
						// from where the last check started
					//	nextColumn := prevColumn + 1;	
					//	offset := 0;
					//endif;
					
				else
					// Try the next LC after the one we started from
					offset := 0;
					nextColumn := prevColumn + 1;				
				endif;
			endif;
			if nextColumn &gt; 0 and nextColumn &lt;= row.size() then
				nextLC := row[nextColumn].CM_GridController;
			else
				nextLC := null;
			endif;

		endwhile;
	endforeach;
	return total;
epilog
	if rows &lt;&gt; null then
		rows.purge;
		delete rows;
	endif;
end;</source>
        <Parameter name="_containerSize" type="Integer"/>
        <Parameter name="_locations" type="CM_LCArray"/>
        <Parameter name="_minHeight" type="Integer"/>
        <Parameter name="_maxHeight" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="calcFreeOLD" id="53977a8f-8ded-4027-8e26-ec2b2c4e7ef0">
        <source>calcFreeOLD(_containerSize: Integer; _locations: CM_LCArray; _minHeight, _maxHeight : Integer): Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 March 2009	cnwjk3	Initial creation

*/

vars
	tiWidth,
	total, i: Integer;
	prevColumn,
	endColumn,
	nextColumn : Integer;
	maxHeight,
	prevOffset,
	offset: Integer;
	rows: ObjectArray;
	obj: Object;
	row: CM_LCArray;
	nextLC: CM_GridController;
begin
	create rows transient;
	self.splitIntoRows(_locations, rows);
	foreach obj in rows do
		row := obj.CM_LCArray;
		if not self.findStartColumnOffset(_containerSize, row, nextColumn, offset) then
			continue;
		endif;
		nextLC := row[nextColumn].CM_GridController;
		while nextLC &lt;&gt; null do
			prevColumn := nextColumn;
			prevOffset := offset;
			maxHeight := 0;
			if self.locationContainsStartOfTI(nextLC) then
				
				// TODO : Might also need to check the type of cargo here???
				tiWidth := self.getWidthOfTIForPrimaryLocation(nextLC);
				if tiWidth 	= _containerSize then
					total := total + getSpareHeight(nextLC, _minHeight, _maxHeight);
				endif;
				
				// The next time round the loop we want to start after this TI.
				self.getNextColumnAndOffset(nextLC, nextColumn, offset);
				
				// PAR 19228
				if self.columnAndOffsetUnchanged(prevColumn, nextColumn, prevOffset, offset) then
					break;
				endif;				
			else
				if self.canFitContainer(_containerSize, nextLC, nextColumn, offset, maxHeight, false, row.size()) then
					
					// PAR 19228
					if self.columnAndOffsetUnchanged(prevColumn, nextColumn, prevOffset, offset) then
						break;
					endif;				

					// We can fit the container in, but we now need to check for any strict grids that have been defined
					if offset = 0 then
						endColumn := nextColumn - 1;
					else
						endColumn := nextColumn;
					endif;
					
					// PAR 19310 
					//if self.haveSameGridTypes(prevColumn, endColumn, row) then	
					if nextColumn &lt;= row.size() or (nextColumn = row.size() + 1 and offset = 0)  then
						total := total + maxHeight.min(_maxHeight - _minHeight + 1);
					endif;
					//else
						// Container overlaps different grids, so we need to try again, starting from the next LC in the row
						// from where the last check started
					//	nextColumn := prevColumn + 1;	
					//	offset := 0;
					//endif;
					
				else
					// Try the next LC after the one we started from
					offset := 0;
					nextColumn := prevColumn + 1;				
				endif;
			endif;
			if nextColumn &gt; 0 and nextColumn &lt;= row.size() then
				nextLC := row[nextColumn].CM_GridController;
			else
				nextLC := null;
			endif;

		endwhile;
	endforeach;
	return total;
epilog
	if rows &lt;&gt; null then
		rows.purge;
		delete rows;
	endif;
end;</source>
        <Parameter name="_containerSize" type="Integer"/>
        <Parameter name="_locations" type="CM_LCArray"/>
        <Parameter name="_minHeight" type="Integer"/>
        <Parameter name="_maxHeight" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="calcTotals" id="002c4bc8-e410-418a-9a33-9429ab12c44a">
        <source>calcTotals(_containerSize: Integer; _locations: CM_LCArray; _minHeight, _maxHeight : Integer): Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 March 2009	cnwjk3	Initial creation

*/

vars
	total, i: Integer;
	prevColumn,
	endColumn,
	nextColumn : Integer;
	maxHeight,
	prevOffset,
	offset: Integer;
	rows: ObjectArray;
	obj: Object;
	row: CM_LCArray;
	nextLC: CM_GridController;
begin
	create rows transient;
	self.splitIntoRows(_locations, rows);
	foreach obj in rows do
		row := obj.CM_LCArray;
		if not self.findStartColumnOffset(_containerSize, row, nextColumn, offset) then
			continue;
		endif;
		nextLC := row[nextColumn].CM_GridController;
		while nextLC &lt;&gt; null do
			prevColumn := nextColumn;
			prevOffset := offset;
			maxHeight := 0;
			
			
			if not self.canStartContainerAtLocation(_containerSize, nextLC, offset) then
				nextColumn := nextColumn + 1;
				if nextColumn &lt;= row.size() then
					nextLC := row[nextColumn].CM_GridController;
				else
					nextLC := null;
				endif;
				continue;
			endif;
			
			if self.canFitContainer(_containerSize, nextLC, nextColumn, offset, maxHeight, true, row.size()) then
	
				// PAR 19228
				if self.columnAndOffsetUnchanged(prevColumn, nextColumn, prevOffset, offset) then
					break;
				endif;
			
				// We can fit the container in, but we now need to check for any strict grids that have been defined
				if offset = 0 then
					endColumn := nextColumn - 1;
				else
					endColumn := nextColumn;
				endif;
				
				// PAR 19310
				//if self.haveSameGridTypes(prevColumn, endColumn, row) then	
					total := total + maxHeight.min(_maxHeight - _minHeight + 1);
				//endif;
				//else
					// Container overlaps different grids, so we need to try again, starting from the next LC in the row
					// from where the last check started
				//	nextColumn := prevColumn + 1;	
				//	offset := 0;
				//endif;
				
				if nextColumn &lt;= row.size() then
					nextLC := row[nextColumn].CM_GridController;
				else
					nextLC := null;
				endif;
			else
				// PAR 19409
				if nextLC &lt;&gt; null and nextLC.isGap() then
					// Try the next location
					nextColumn := nextColumn + 1;
					if nextColumn &lt;= row.size() then
						nextLC := row[nextColumn].CM_GridController;
					else
						nextLC := null;
					endif;
				else
					// We couldn't fit the last one in, so there's no use trying any futher with this row.
					nextLC := null;
				endif;
			endif;
		endwhile;
	endforeach;
	return total;
epilog
	if rows &lt;&gt; null then
		rows.purge;
		delete rows;
	endif;
end;</source>
        <Parameter name="_containerSize" type="Integer"/>
        <Parameter name="_locations" type="CM_LCArray"/>
        <Parameter name="_minHeight" type="Integer"/>
        <Parameter name="_maxHeight" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="calcTotalsOLD" id="5385ec0d-4e42-4c8c-8c80-9f617401bcf8">
        <source>calcTotalsOLD(_containerSize: Integer; _locations: CM_LCArray; _minHeight, _maxHeight : Integer): Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 March 2009	cnwjk3	Initial creation

*/

vars
	total, i: Integer;
	prevColumn,
	endColumn,
	nextColumn : Integer;
	maxHeight,
	prevOffset,
	offset: Integer;
	rows: ObjectArray;
	obj: Object;
	row: CM_LCArray;
	nextLC: CM_GridController;
begin
	create rows transient;
	self.splitIntoRows(_locations, rows);
	foreach obj in rows do
		row := obj.CM_LCArray;
		if not self.findStartColumnOffset(_containerSize, row, nextColumn, offset) then
			continue;
		endif;
		nextLC := row[nextColumn].CM_GridController;
		while nextLC &lt;&gt; null do
			prevColumn := nextColumn;
			prevOffset := offset;
			
			maxHeight := 0;
			if self.canFitContainer(_containerSize, nextLC, nextColumn, offset, maxHeight, true, row.size()) then
	
				// PAR 19228
				if self.columnAndOffsetUnchanged(prevColumn, nextColumn, prevOffset, offset) then
					break;
				endif;
			
				// We can fit the container in, but we now need to check for any strict grids that have been defined
				if offset = 0 then
					endColumn := nextColumn - 1;
				else
					endColumn := nextColumn;
				endif;
				
				// PAR 19310
				//if self.haveSameGridTypes(prevColumn, endColumn, row) then	
					//total := total + maxHeight;
				if nextColumn &lt;= row.size() or (nextColumn = row.size() + 1 and offset = 0) then
					total := total + maxHeight.min(_maxHeight - _minHeight + 1);
				endif;
				//else
					// Container overlaps different grids, so we need to try again, starting from the next LC in the row
					// from where the last check started
				//	nextColumn := prevColumn + 1;	
				//	offset := 0;
				//endif;
				
				if nextColumn &lt;= row.size() then
					nextLC := row[nextColumn].CM_GridController;
				else
					nextLC := null;
				endif;
			else
				// We couldn't fit the last one in, so there's no use trying any futher with this row.
				nextLC := null;
			endif;
		endwhile;
	endforeach;
	return total;
epilog
	if rows &lt;&gt; null then
		rows.purge;
		delete rows;
	endif;
end;</source>
        <Parameter name="_containerSize" type="Integer"/>
        <Parameter name="_locations" type="CM_LCArray"/>
        <Parameter name="_minHeight" type="Integer"/>
        <Parameter name="_maxHeight" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="calcUsed" id="a6d4a914-6b62-45c1-8130-ce543eb569d1">
        <source>calcUsed(_containerSize: Integer; _locations: CM_LCArray;_minHeight, _maxHeight : Integer): Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 March 2009	cnwjk3	Initial creation

*/

vars
	tiWidth,
	total, i: Integer;
	prevColumn,
	endColumn,
	nextColumn : Integer;
	maxHeight,
	prevOffset,
	offset: Integer;
	rows: ObjectArray;
	obj: Object;
	row: CM_LCArray;
	nextLC: CM_GridController;
	verticalSpaces : Integer; //cnwjo3
begin
	create rows transient;
	self.splitIntoRows(_locations, rows);
	foreach obj in rows do
		row := obj.CM_LCArray;
		offset := 0;
		nextColumn := 1;
		nextLC := row[nextColumn].CM_GridController;
		while nextLC &lt;&gt; null do
			prevColumn := nextColumn;
			prevOffset := offset;
			maxHeight := 0;
			if self.locationContainsStartOfTI(nextLC) then
				
				// TODO : Might also need to check the type of cargo here???
				tiWidth := self.getWidthOfTIForPrimaryLocation(nextLC);
				if tiWidth 	= _containerSize then
					//total := total + getUsedHeight(nextLC);   //commented out by cnwjo3

					//cnwjo3 par 20470, when all else fails, use a loop
					foreach verticalSpaces in _minHeight to self.getUsedHeight(nextLC) do
						if verticalSpaces &lt;= _maxHeight then
							total := total + 1;
						endif;
					endforeach;
				endif;
				
				// The next time round the loop we want to start after this TI.
				self.getNextColumnAndOffset(nextLC, nextColumn, offset);
				
				// PAR 19228
				if self.columnAndOffsetUnchanged(prevColumn, nextColumn, prevOffset, offset) then
					break;
				endif;				
				
			else
				// Try the next LC after the one we started from
				offset := 0;
				nextColumn := prevColumn + 1;				
			endif;
			if nextColumn &gt; 0 and nextColumn &lt;= row.size() then
				nextLC := row[nextColumn].CM_GridController;
			else
				nextLC := null;
			endif;
		endwhile;
	endforeach;
	return total;
epilog
	if rows &lt;&gt; null then
		rows.purge;
		delete rows;
	endif;
end;</source>
        <Parameter name="_containerSize" type="Integer"/>
        <Parameter name="_locations" type="CM_LCArray"/>
        <Parameter name="_minHeight" type="Integer"/>
        <Parameter name="_maxHeight" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="canFitContainer" id="66ab4752-914d-4bcc-a202-2247b7af9664">
        <source>canFitContainer( _containerSize : Integer; _nextLC: CM_GridController io; _nextColumn, _offset, _maxHeight : Integer io; _ignoreTIs : Boolean; _maxColumn : Integer ) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 March 2009	cnwjk3	Initial creation

*/

vars
	spareSpace : Integer;
begin
	spareSpace := self.findSpace(_containerSize, _nextLC, _nextColumn, _offset, _maxHeight, _ignoreTIs, _maxColumn);
	return spareSpace = _containerSize;
epilog

end;</source>
        <Parameter name="_containerSize" type="Integer"/>
        <Parameter name="_nextLC" type="CM_GridController" usage="io"/>
        <Parameter name="_nextColumn" type="Integer" usage="io"/>
        <Parameter name="_offset" type="Integer" usage="io"/>
        <Parameter name="_maxHeight" type="Integer" usage="io"/>
        <Parameter name="_ignoreTIs" type="Boolean"/>
        <Parameter name="_maxColumn" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canStartContainerAtLocation" id="d74f0679-9e0b-4384-b913-b4ef0be8f555">
        <source>canStartContainerAtLocation(_containerSize : Integer; _lc: CM_GridController; _offset : Integer) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 April 2009	cnwjk3	PAR 19310

*/

vars
	
begin
	if not _lc.isStrictGrid() then
		return true;
	elseif _containerSize = ContainerSize_20 and _lc.is20ft then
		return _offset = 0;
	elseif _containerSize = ContainerSize_30 and _lc.is30ft then
		return _offset = _lc.offset30;
	elseif _containerSize = ContainerSize_40 and _lc.is40ft then
		return _offset = _lc.offset40;
	elseif _containerSize = ContainerSize_45 and _lc.is45ft then
		return _offset = _lc.offset45;
	elseif _containerSize = ContainerSize_53 and _lc.is53ft then
		return _offset = _lc.offset53;
	else
		return true;
	endif;
epilog

end;</source>
        <Parameter name="_containerSize" type="Integer"/>
        <Parameter name="_lc" type="CM_GridController"/>
        <Parameter name="_offset" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="columnAndOffsetUnchanged" id="1ebb703a-a128-436b-be3a-f601aa76dca0">
        <source>columnAndOffsetUnchanged(_prevColumn, _nextColumn,  _prevOffset, _offset : Integer) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 March 2009	cnwjk3	PAR 19228

This method has been added to safeguard against infinite looping during stats calculations. 
The chances are that this will never return true, but a future change to the stats code
might well cause it to.

*/

vars

begin
	if _prevColumn = _nextColumn and _prevOffset = _offset then
		return true;
	else
		return false;
	endif;
epilog

end;</source>
        <Parameter name="_prevColumn" type="Integer"/>
        <Parameter name="_nextColumn" type="Integer"/>
        <Parameter name="_prevOffset" type="Integer"/>
        <Parameter name="_offset" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findSpace" id="99cbfeaa-b96d-4543-b31d-a8d615fbca80">
        <source>findSpace( _width: Integer; _nextLC: CM_GridController io; _nextColumn, _offset, _maxHeight : Integer io; _ignoreTIs : Boolean; _maxColumn : Integer) : Integer;

/*

Purpose:			
	Calculates whether a container of a given size will fit at a given location and offset.
	NOTE that this method is not concerned with strict grids (of 30's 45's 53's etc...)
Parameters:			
	_width 		: The width of the container
	_nextLC		: The LC to start checking from
	_offset 	: The offset of the _nextLC to start checking from (E.g. 10' in from _nextLC).
				  Returns offset of the next LC where an adjacent container may be placed
	_nextColumn : Returns the column index of the next LC that can house a container to the 
				  immediate right of the container we just found space for
    _maxHeight	: Returns the maximum stack height for the space found

	Return Value:		
	
	on locating enough space, the return value will be equal to the requested space.  Also, _nextColumn and 
	_offset will indicate the position of the LC and the offset where the next container can be placed. _maxHeight
	will indicate how high the containers can be stacked for the space found.
	
	on failure, the return value will be equal to the amount of space found.  E.g. if you ask for 30' and it can only find
	25', the return value will be 25

Date		Who		Reason
03 March 2009	cnwjk3	SFW1030

*/

vars
	lcLen,
	spaceFound : Integer;
begin
	if _nextLC = null or not _nextLC.amIAvailable() or _nextLC.isGap() then
		return 0;
	endif;
	// Update the maximum height for the LC's involved in the test for space, as it is possible for each  
	if _maxHeight &gt; 0 then 
		_maxHeight := _maxHeight.min(_nextLC.getMaxStackingHeight());
	else
		_maxHeight := _nextLC.getMaxStackingHeight();
	endif;
	
	lcLen := _nextLC.myTerminalArea.locationLength.Integer;
	
	if not _ignoreTIs and self.locationContainsStartOfTI(_nextLC) then
		// There's a TI at this location	
		if _offset &gt; 0 then 
			spaceFound := lcLen - _offset + 1;
		else 
			spaceFound := lcLen - _offset;
		endif;
	
		_offset := getOffsetForLC(_nextLC);
		spaceFound := spaceFound - _offset;
		
		if _offset = 0 then
			spaceFound := 0;
		endif;
		if spaceFound = 0 then
			_offset := 0;
		endif;

		return spaceFound;
	endif;	
	
	// We got this far, so the remaining width of this LC is available	
	if _offset &gt; 0 then 
		//spaceFound := lcLen - _offset + 1;
		spaceFound := lcLen - _offset;
	else 
		spaceFound := lcLen;
	endif;
	
	if spaceFound = _width then
		// Exactly the whole width has been covered, which means we return the index of the right-adjacent LC, 
		// with an offset of zero
		_offset := 0;
		_nextColumn := _nextColumn + 1;
		return spaceFound;	
	elseif spaceFound &lt; _width then
		// We found some space, but not enough. See if the the next LC has the remaining space
		_nextColumn := _nextColumn + 1;
		// PAR 19310
		if _nextColumn &gt; _maxColumn then
			return spaceFound;
		endif;
		_nextLC := _nextLC.myNextController;
		_offset := 0;
		return spaceFound + self.findSpace(_width - spaceFound, _nextLC, _nextColumn, _offset, _maxHeight, _ignoreTIs, _maxColumn);
	else
		// We found more space than we needed. So the next controller is the current controller, offset to account for the
		// space we found.
		// PAR 19228
		//_offset := _width;
		_offset := _width + _offset;
		return _width;
	endif;
epilog
end;</source>
        <Parameter name="_width" type="Integer"/>
        <Parameter name="_nextLC" type="CM_GridController" usage="io"/>
        <Parameter name="_nextColumn" type="Integer" usage="io"/>
        <Parameter name="_offset" type="Integer" usage="io"/>
        <Parameter name="_maxHeight" type="Integer" usage="io"/>
        <Parameter name="_ignoreTIs" type="Boolean"/>
        <Parameter name="_maxColumn" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="findStartColumnOffset" id="58770f82-fa2e-4868-9689-62c9064b8ef0">
        <source>findStartColumnOffset(_containerSize : Integer; _row : CM_LCArray; _column, _offset : Integer output) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 March 2009	cnwjk3	Initial creation

*/

vars
	nextLC: CM_LocationsController;
begin
	_column := 1;
	foreach nextLC in _row do
		_offset := getOffsetForContainerSize( nextLC.CM_GridController, _containerSize );
		if _offset &lt;&gt; -1 then
			return true;
		endif;
		_column := _column + 1;
	endforeach;
	return false;
epilog

end;</source>
        <Parameter name="_containerSize" type="Integer"/>
        <Parameter name="_row" type="CM_LCArray"/>
        <Parameter name="_column" type="Integer" usage="output"/>
        <Parameter name="_offset" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getNextColumnAndOffset" id="8a8a11de-d410-4067-8fb8-0863e8deabd9">
        <source>getNextColumnAndOffset( _lc : CM_LocationsController; _nextColumn, _offset : Integer io);

/*

Purpose: If the given _lc contains a TI, this method will calculate the location and offset which represents the
         position immediately following the end of the TI.
		 _nextColumn and _offfset will be unchanged if no TI is present or the LC is not
		 the primary controller. 

Parameters:			

Return Value:		


Date		Who		Reason
09 March 2009	cnwjk3	Initial creation

*/

vars
	ti : CM_TrackedItem;
	lcLen,
	tiLen : Integer;
begin
	if self.isPrimaryLocation(_lc) then
		tiLen := self.getWidthOfTIForPrimaryLocation(_lc);
		lcLen := _lc.myTerminalArea.locationLength.Integer;
		_nextColumn := _nextColumn + ((_offset+tiLen)/lcLen).Integer;
		_offset := (_offset+tiLen) mod lcLen;
	else
		_nextColumn := -1;
	endif;
epilog

end;</source>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_nextColumn" type="Integer" usage="io"/>
        <Parameter name="_offset" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getOffsetForContainerSize" id="6cef3851-36f1-4c79-bf22-2a651fdfb78a">
        <source>getOffsetForContainerSize( _lc : CM_GridController; _containerSize : Integer) : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 March 2009	cnwjk3	PAR 19310

*/

vars

begin
	if not _lc.isStrictGrid() then
		return 0;
	elseif _lc.is20ft then
		return 0;
	elseif _lc.is30ft then 
		if  _containerSize = ContainerSize_30 then
			return _lc.offset30;
		else
			return 0;
		endif;
	elseif _lc.is40ft then
		if _containerSize = ContainerSize_40 then
			return _lc.offset40;
		else
			return 0;
		endif;
	elseif _lc.is45ft then
		if _containerSize = ContainerSize_45 then
			return _lc.offset45;
		else
			return 0;
		endif;
	elseif _lc.is53ft then 
		if _containerSize = ContainerSize_53 then
			return _lc.offset53;
		else
			return 0;
		endif;
	else
		return -1;
	endif;
epilog

end;</source>
        <Parameter name="_lc" type="CM_GridController"/>
        <Parameter name="_containerSize" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getOffsetForContainerSizeOLD" id="c1451883-eb7f-4d57-af3a-8937c408e19b">
