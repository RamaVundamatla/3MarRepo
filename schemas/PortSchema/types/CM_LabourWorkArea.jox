    <JadeMethod name="setProxy" id="d8c90a38-0b2d-43f6-910c-fddacdcd8d80">
        <updating/>
        <source>setProxy(	_code : String;
			_description : String;
			_notAvailable : Boolean;
			_allSelectedObjects : ObjectSet;
			_myTerminal : CM_Terminal
			) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 April 2014	cnwndl1	Initial creation	Par 33995

*/

vars

begin

	self.setProxyBaseData(	_code,	//_code : String;
							_description,	//_description : String;
							_notAvailable,	//_notAvailable : Boolean;
							_allSelectedObjects	//_allSelectedObjects : ObjectSet
							);
							
	self.myTerminal := _myTerminal;

epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_notAvailable" type="Boolean"/>
        <Parameter name="_allSelectedObjects" type="ObjectSet"/>
        <Parameter name="_myTerminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="validateDelete" id="ce731595-f7c7-4a0c-82d2-e6f22a757082">
        <source>validateDelete(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 April 2014	cnwndl1	Initial creation

*/

vars

	ta : CM_TerminalArea;
	go : CM_GridObject;
	lc : CM_LocationsController;
	locationControllerArray : ObjectArray;
	obj : Object;

begin

	foreach ta in self.allTerminalAreas do
		if not ta.allRestrictionsLabour.isEmpty then
			app.raiseCMWarning2( Potenti_labour_restric_place, self.code, ta.id, null, null, null);
			break;
		endif;
	endforeach;
	
	create locationControllerArray transient;
	foreach go in self.allGridObjects do
		locationControllerArray.clear();
		go.getAllLocationsControllers(locationControllerArray, false);
		if not locationControllerArray.isEmpty then
			foreach obj in locationControllerArray do
				lc := obj.CM_LocationsController;
				if not lc.hasRestrictions(LABOUR_RESTRICTION) then
					app.raiseCMWarning2( Potenti_labour_restric_place, self.code, go.getNiceName, null, null, null);
					break;
				endif;
			endforeach;
		endif;
	endforeach;
	
	foreach obj in self.allLocationsControllers do
		lc := obj.CM_LocationsController;
		if not lc.hasRestrictions(LABOUR_RESTRICTION) then
			app.raiseCMWarning2( Potenti_labour_restric_place, self.code, lc.getFullId, null, null, null);
			break;
		endif;
	endforeach;
	

epilog

	delete locationControllerArray;
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="b987a65f-e1a5-4b17-bbe5-abf2f87a42df">
        <source>validateForCreate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 April 2014	cnwndl1	Initial creation	Par 33995

*/

vars

begin
	inheritMethod();
	
	if self.myTerminal &lt;&gt; null and self.myTerminal.allLabourWorkAreas.getAtKey(self.code) &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="526ed669-3118-47fd-b323-97093358bbeb">
        <source>validateMe();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 November 2014	cnwndl1	Initial creation

*/

vars

	items : Integer;

begin

	inheritMethod();
	
	items := self.allGridObjects.size + self.allLocationsControllers.size + self.allTerminalAreas.size;

	if items &lt; 2 then
		app.raiseCMException(Work_areas_must_conta_least_lo, null, null);
		return;
	endif;
	
epilog

end;</source>
    </JadeMethod>
</Class>
