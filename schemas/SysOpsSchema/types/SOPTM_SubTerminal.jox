    <JadeMethod name="doSave" id="9cc0bd49-ba0c-47d5-8bfe-264cb800216a">
        <updating/>
        <source>doSave(): Boolean updating;

/*
----------   ----------  --------------------------------------------------
Created:	07 April 2009 By cnwdz2

Purpose:	CCMS1735: 

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/

vars
	code				: String;
	description			: String;
	type				: String;
	stType				: Integer;
	typeName			: String;
	proxySubTerminal	: CM_SubTerminal;
	errObj				: CM_Error;
	ignoreWarnings		: Boolean;
	rtnValue			: Boolean;
	lCarrier			: CM_Carrier;	
	theForm				: SOP_TableMaintForm;
	
	selectedAvailGrades : CM_MTGradeByCodeDict;	//13 Oct 2010	NDL Par 23991
	selectedToDoDescs : CM_ToDoTaskDescByCode;	//13 Oct 2010	NDL Par 23991
	
	bank : CM_Bank;	//21 Jan 2015	NDL	Par Par 35485 
	bankChanged : Boolean;	//11 May 2015	NDL	Par 36181
	msg : String;
	
begin
  	theForm := self.myForm; 

	code		:=	theForm.tblInput1.getValueByName(ETRow_Code).String;
	description	:=	theForm.tblInput1.getValueByName(ETRow_Description).String;
	typeName	:=	theForm.tblInput1.getValueByName(ETRow_TypeDesc).String;
	
	//21 Jan 2015	NDL	Par Par 35485 
	if theForm.cmbBank.listIndex &gt; 0 then
		bank :=	theForm.cmbBank.listObject.CM_Bank; 	//ETRow_Bank
	endif;
	
	type	:=	theForm.cmbSubTermType.text;
	stType	:=	app.subTerminalTypeStringToEnum(typeName);
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_SubTerminal transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
	
	create selectedAvailGrades transient;		//13 Oct 2010	NDL Par 23991
	theForm.mulSelect1.getSelected(selectedAvailGrades);		//13 Oct 2010	NDL Par 23991
	
	create selectedToDoDescs transient;		//13 Oct 2010	NDL Par 23991
	theForm.mulSelect2.getSelected(selectedToDoDescs);		//13 Oct 2010	NDL Par 23991
	
	//11 May 2015	NDL	Par 36181
	if theForm.myTerminal.getConfig(IsSubTerminalAreaDefined).Boolean then
		if theForm.myCurrentObject = null then
			bankChanged := true; 
		else
			bankChanged := bank &lt;&gt; theForm.myCurrentObject.CM_SubTerminal.getMyBank;
		endif;
	endif;
	
	proxySubTerminal := theForm.myProxyObject.CM_SubTerminal;
	proxySubTerminal.setProxy(	code,
								description,
								stType,
								theForm.myTerminal,
								bank,	//_bank	//03 Dec 2014	NDL	Par 35295
								selectedAvailGrades,	//_selectedAvailGrades : CM_MTGradeByCodeDict;	//13 Oct 2010	NDL Par 23991
								selectedToDoDescs	//_selectedToDoDescs : CM_ToDoTaskDescByCode	//13 Oct 2010	NDL Par 23991
								);

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateSubTerminal(proxySubTerminal, theForm.myCurrentObject, app.myPassport);
		rtnValue := app.myPassport.trxCompletedOK;
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateSubTerminal(proxySubTerminal, app.myPassport);
		rtnValue := app.myPassport.trxCompletedOK;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	//11 May 2015	NDL	Par 36181
	if bankChanged and rtnValue then
		//msg := "Do you want to reset the business unit attribute of effected on-site cargo now?";
		//if app.msgBox( msg, app.getErrorString(Continue), MsgBox_Yes_No ) = MsgBox_Return_Yes then
		app.myTrxUA.trxUpdSubTermForCargoItems( false, false, theForm.myCurrentObject.CM_SubTerminal.mySubTerminalAreaDef, null, app.myPassport );
		if not app.myPassport.trxCompletedOK then
			if not app.myPassport.trxCompletedOK then
				msg := app.getErrorString(Faile_reset_effec_cargo_pleas_) &amp; " '" &amp; app.getErrorString(Resync_subter_busine_unit_carg) &amp; "'";
				app.createAlert( "Sub Terminal '" &amp; theForm.myCurrentObject.CM_SubTerminal.description &amp; "' Business Unit updated - " &amp; msg, true );
				app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
			endif;
		endif;
		//endif;
	endif;
	
	return rtnValue;
	
epilog

	delete selectedAvailGrades;	//13 Oct 2010	NDL Par 23991
	delete selectedToDoDescs;	//13 Oct 2010	NDL Par 23991
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doShowAreaDefinitionForm" id="7435afa7-95dc-4396-b1bd-5542769a2de1">
        <updating/>
        <source>doShowAreaDefinitionForm( _subTerm : CM_SubTerminal ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 November 2014	cnwndl1	Initial creation	Par 35295

*/

vars

	form : SOP_TerminalAreaDefMaintForm;
	workAreaDef : CM_SubTerminalAreaDef;
	str : String;
	
begin

	create form;
	form.setMyTerminal(self.myForm.myTerminal);
	form.setMySubTerminal( _subTerm );
	
	form.showModal();
	
	//04 Dec 2014	NDL	Par 35341 - refresh the line.
	str := self.myForm.tblDataDisplayRow(self.myForm.tblData, _subTerm);
	self.myForm.tblData.setCellText( self.myForm.tblData.row, 1, str );
	
epilog

end;</source>
        <Parameter name="_subTerm" type="CM_SubTerminal"/>
    </JadeMethod>
