    <JadeMethod name="addToolbarControls" id="948a7c3b-a35b-42a1-999e-8809723ca1e1">
        <updating/>
        <source>addToolbarControls() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 November 2012	cnwjre1	Initial creation

*/

vars
	frm				: CMUI_Toolbar;
begin
	frm := self.frmToolbar;
	frm.addButton(self.btnLinesSave, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnLinesNew, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnLinesDelete, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnLinesCancel, CMUI_Toolbar.Control_Alignment_Right);
	frm.positionToolbarControls();
	frm.visible := true;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
