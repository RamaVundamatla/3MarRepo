    <JadeMethod name="initRateTable" id="0b5f12be-5174-400b-956d-5370846def3a">
        <source>initRateTable();
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	entTableDef		: EntTableDef;
	theRow			: Integer;
	theTable		: CM_DataTable;
	
begin
	self.frmRateTableFrm.move(1,self.frmRatesToolbar.clientHeight + 4,self.frmRatesOR.clientWidth - 2,
								self.frmRatesOR.height - self.frmRatesToolbar.clientHeight - 2);

