    <JadeMethod name="addToolbarControls" id="792a3d1b-351b-4d29-8d53-ae87eefc0065">
        <updating/>
        <source>addToolbarControls() updating, protected;
// --------------------------------------------------------------------------------
// Created:		28 April 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	toolbarObj	: CMUI_Toolbar;
	
begin
	inheritMethod();

	toolbarObj	:=	self.frmToolbar;
	
	toolbarObj.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	toolbarObj.addButton(self.btnDeleteYA, CMUI_Toolbar.Control_Alignment_Left);
	toolbarObj.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnDeleteYA_click" id="74b99eaf-1056-43a9-928a-96e7261a42a4">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDeleteYA_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		02 May 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin

/*write class.name &amp; '::' &amp; method.name &amp; '  parent = ' &amp; self.getFormParent.String;
self.setFormParent(app.mainForm);
self.zOrder(1);
write class.name &amp; '::' &amp; method.name &amp; '  set parent = ' &amp; self.getFormParent.String;
//self.setFormParent(null);			// cnwab1 06/05/2005.
return;
self.setFormParent(app.mainForm);			// cnwab1 06/05/2005.*/

	app.mousePointer	:=	Busy;
	
	if self.ctrlYardAlloc.doDelete() then
		self.populateYardAllocations();
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbYardAlloc_click" id="8b2db093-a966-420a-8dc9-d91541eb39dc">
        <controlMethod name="ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbYardAlloc_click(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	baseForm : CM_BaseForm;
	yardAllocationObj : CM_YardAllocation;
begin
	app.mousePointer	:=	Busy;
	self.setupYA(null);

	yardAllocationObj	:=	self.cmbYardAlloc.listObject.CM_YardAllocation;

	// ## leave this out of setupYA else you get a loop
	foreach baseForm in self.aAllCallingForms do
		baseForm.doDisplayYardAllocation(yardAllocationObj);
	endforeach;

epilog
	app.mousePointer	:=	Idle;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
