    <JadeMethod name="createProxy" id="89d3fcf6-b0a3-4d08-989a-41bd19ce9751">
        <source>createProxy(_pxyBay : CM_BayDefn);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 January 2013	cnwer1	Initial creation HAT 2189

*/

vars
	pxySlot			: CM_SlotDefnVessel;
	cellId,
	tierId		: String;
	completedOK 	: Boolean;
	wsLayout 		: WS_Layout;
begin
	
	if self.ordinalDeck = DeckOnDeck then
		cellId:=_pxyBay.allCellsOnDeckByOrdinal[self.ordinalCell].id;
		tierId:=_pxyBay.allTiersOnDeck[self.ordinalTier].id;
	else
		cellId:=_pxyBay.allCellsUnderDeckByOrdinal[self.ordinalCell].id;
		tierId:=_pxyBay.allTiersUnderDeck[self.ordinalTier].id;
	endif;
	
	create pxySlot transient;
	pxySlot.setProxy(self.ordinalCell,
					 self.ordinalDeck,
					 self.ordinalTier,
					 null, //_sequenceNumPortDis,
					 null, //_sequenceNumPortLoad,
					 null, //_sequenceNumStarDis,
					 null, //_sequenceNumStarLoad, 
					 self.voltageType, //_voltage
					 self.doors20Aft,
					 self.doors40Aft,
					 self.is40Back, //fortyFront
					 not self.is40Back and self.is40, //fortyFront
					 self.motor20Aft,
					 self.motor40Aft,
					 self.isPowered,
					 self.isReefer,
					 self.isMTOnly,
					 self.unavailable,
					 self.isWC,
					 self.isHeavy,
					 cellId,
					 tierId,
					 self.is30,
					 self.is45,
					 self.is53);
	pxySlot.setIsBackend(self.is30Back or self.is45Back or self.is53Back);
	
	if self.ordinalDeck = DeckOnDeck then
		pxySlot.setMyBay(_pxyBay, true);
		pxySlot.setCellAndTierDefn(_pxyBay.allCellsOnDeckByOrdinal[self.ordinalCell],_pxyBay.allTiersOnDeck[self.ordinalTier]);
	else
		pxySlot.setMyBay(_pxyBay, false);
		pxySlot.setCellAndTierDefn(_pxyBay.allCellsUnderDeckByOrdinal[self.ordinalCell],_pxyBay.allTiersUnderDeck[self.ordinalTier]);
	endif;
	
	foreach wsLayout in self.allLayouts discreteLock do
		wsLayout.createProxy(pxySlot);
	endforeach;
	completedOK :=true;
epilog
	if not completedOK then
		delete pxySlot;
	endif;
end;</source>
        <Parameter name="_pxyBay" type="CM_BayDefn"/>
    </JadeMethod>
    <JadeMethod name="delete" id="ee7bde18-7dc3-4d12-814c-21d3186c8cb5">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 November 2017	jlger1	Initial creation 7521

*/

vars

begin
	self.allLayouts.purge;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="e15ae3fd-2605-4d72-bd0d-7efc9f071c26">
        <updating/>
        <source>setProxyFromObject(_slot: CM_SlotDefn) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2013	cnwer1	Initial creation HAT 2189

*/

vars

begin
	inheritMethod(_slot);
	self.ordinalBay:=_slot.myBay.ordinalBay;
	self.ordinalCell:=_slot.ordinalCell;
	self.ordinalDeck:=_slot.ordinalDeck;
	self.ordinalTier:=_slot.ordinalTier;
	
	
	self.isHeavy:=_slot.heavy;
	self.isHighCubed:=_slot.highCubed;
	self.isMTOnly:=_slot.mtOnly;
	self.isPowered:=_slot.power;
	self.unavailable := _slot.unavailable; // These will be ignored in .NET i.e. they will not create a slot shape
	self.isReefer:=_slot.reefer;
	self.isWC:=_slot.watercooled;
	self.voltageType:=_slot.voltageType;
	self.doors20Aft:=_slot.doors20Aft;
	self.doors40Aft:=_slot.doors40Aft;
	self.motor20Aft:=_slot.motor20Aft;
	self.motor40Aft:=_slot.motor40Aft;
	
	//self.is20:=_slot.
	
	self.is30:=_slot.is30;
	self.is30Back:=self.is30 and _slot.isBackend;
	self.is45:=_slot.is45;
	self.is45Back:=self.is45 and _slot.isBackend;
	self.is53:=_slot.is53;
	self.is53Back:=self.is53 and _slot.isBackend;
	self.is40Back:=_slot.fortyBack;
	self.is40:=_slot.fortyBack or _slot.fortyFront;
	
	self.is20 := not self.is30 or not self.is40 or not self.is53 or not self.is40;
	
	self.setProxyLayouts(_slot);
	
epilog

end;</source>
        <Parameter name="_slot" type="CM_SlotDefn"/>
    </JadeMethod>
    <JadeMethod name="setProxyLayouts" id="3a4ec72b-16a0-42dc-8a6c-bfa83d1cb54b">
        <source>setProxyLayouts(_slot: CM_SlotDefn) protected;
/*

Date		Who		Reason
16 August 2013	cnwer1	Initial creation PAR

*/

vars
	wsLayout	: WS_Layout;
	layout 		: CM_BayItemLayout;
begin
	foreach layout in _slot.allBayItemLayouts discreteLock do
		create wsLayout transient;
		wsLayout.setProxyFromObject(layout);
		self.allLayouts.add(wsLayout);
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_slot" type="CM_SlotDefn"/>
    </JadeMethod>
</Class>
