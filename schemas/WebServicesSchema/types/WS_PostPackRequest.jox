<Class name="WS_PostPackRequest" id="c1b15980-53cc-4cc6-bc1e-cb3dc6217e5e">
    <superclass name="WS_RestRequest"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <ImplicitInverseRef name="cargo" id="b64d0e53-3d20-4c90-960e-10571c7b4eda">
        <memberTypeInverse/>
        <type name="WS_RestPackCargoChildObjArray"/>
    </ImplicitInverseRef>
    <PrimAttribute name="complete" id="64715ac6-b86a-4d64-9b73-0e7f2362b433">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <ImplicitInverseRef name="parent" id="1e261b82-6cd4-4421-9402-7623f01b9d0f">
        <embedded/>
        <type name="WS_RestPackCargoObject"/>
    </ImplicitInverseRef>
    <JadeMethod name="validateRequest" id="06f9d8e7-3459-4ce9-b916-dbd463c13668">
        <source>validateRequest(_validParentTi : CM_TrackedItem output; _validChildTis : CM_ObjectSet input): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
13 September 2024	navcs2	ChangeRequest 65967: CUX | MasterTerminalAPI - Pack and Unpack APIs

*/

vars
	parentCargo				: WS_RestPackCargoObject;
	childCargoArray			: WS_RestPackCargoChildObjArray;
	childCargoItem			: WS_RestPackCargoChildObject;
	cargoType			: CM_CargoType;
	parentCargoFound					: CM_TrackedItem;
	terminal				: CM_Terminal;
	validParent				: Boolean;
	childCMIF				: CMIF_PackingCargoChild;
begin
	terminal := app.myPassport.myTerminal;
	
	parentCargo := self.parent;
	
	validParent := true;

	// Validate Request (check for required fields)
	if parentCargo.id = null then
		app.myPassport.addErrorFull(REQUIRED_FIELD, app.getErrorString1(REQUIRED_FIELD, ParentCargoID), ETRow_Name, null, null);
		validParent := false;	
 	endif;
	
	if parentCargo.cargoTypeId = null then
		app.myPassport.addErrorFull(REQUIRED_FIELD, app.getErrorString1(REQUIRED_FIELD, ParentCargoType), ETRow_Name, null, null);
		validParent := false;
  	endif;
	
	cargoType := app.myRoot.getCargoTypeFromAbbrev(parentCargo.cargoTypeId);
	
	if cargoType = null then
		app.myPassport.addErrorFull(Cargo_speci_track_item_not_val, app.getErrorString2(Cargo_speci_track_item_not_val, parentCargo.cargoTypeId, parentCargo.id), null, null, null);
		validParent := false;
 	else
		parentCargoFound := terminal.lookupTrackedItem(parentCargo.id, cargoType.id, TI_STATE_NORMAL, null, true);
	endif;
	
	if parentCargoFound = null then 
		app.myPassport.addErrorFull(Canno_find_suita_paren_cargo_p, app.getErrorString(Canno_find_suita_paren_cargo_p), null, null, null);
		validParent := false;
	endif;
	
	if validParent then
		_validParentTi := parentCargoFound;
	else
		return false; // No point going further if we dont have parent to pack into
	endif;
	
	// CHECK THE CHILD CARGO
	childCargoArray := self.cargo;
	
	// Check we actually have some child cargo
	if childCargoArray = null or childCargoArray.isEmpty then
		app.myPassport.addErrorFull(No_Cargo_To_Pack, app.getErrorString(No_Cargo_To_Pack), null, null, null);
	endif;
	
	// Validate the child cargo items
	foreach childCargoItem in childCargoArray do			
		childCMIF := childCargoItem.validateChild(parentCargoFound);
		if childCMIF &lt;&gt; null then
			_validChildTis.add(childCMIF);
		endif;
	endforeach;

	if app.myPassport.hasErrors then
		return false;
	else
		return true;
	endif;
epilog

end;</source>
        <Parameter name="_validParentTi" type="CM_TrackedItem" usage="output"/>
        <Parameter name="_validChildTis" type="CM_ObjectSet" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
