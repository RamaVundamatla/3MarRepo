    <JadeMethod name="pxyCreateUpdateProxy" id="58da3099-f072-4f5f-bd23-b6d367f17608">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:      12 May 2003 by cnwsgp1
// ---------------------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxyTrade : CM_Trade;
	proxyPOC,realPOC : CM_PortRotation;
	completedOK		: Boolean;
begin
	proxyTrade := inheritMethod();

	self.operators.copy(proxyTrade.operators);
	
	self.allShippingLines.copy(proxyTrade.allShippingLines);
	foreach realPOC in self.allPortRotations do
		proxyPOC:=realPOC.pxyCreateUpdateProxy;
		proxyPOC.setProxy(proxyPOC.myPort,proxyTrade);
	endforeach;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyTrade;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyTrade;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setCopyToTrade" id="69166dd8-fca0-475b-a310-64a346ec267d">
        <updating/>
        <source>setCopyToTrade(
	_trade				: CM_Trade;
	_selectedPorts		: ObjectArray;
	_selectedDebtors	: ObjectArray ) updating;

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
24 June 2009		cnwrl1	Initial creation as part of PAR 19998 - Copy To Trade
12 Oct 2016	cnwkpd1	TFS 2815 - JADE 7.1.08 causeEvent changes
//16 Apr 2018	jlgrs1	TFS 38147 fixup PortRotation addition (change PortRotation add to use proxy)

*/
	
vars
	cm_PortRotation		: CM_PortRotation;
	cm_Port				: CM_Port;
	cm_Debtor			: CM_Debtor;
	cm_Operator			: CM_Operator;
	object				: Object;
	pxyRotation : CM_PortRotation;
begin
	// go through each port selected
	foreach object in _selectedPorts do : port_loop
		cm_Port	:= object.CM_Port;
		
		// skip any Ports already on this Trade as a PortRotation
		foreach cm_PortRotation in self.allPortRotations do : portRotation_loop
			if cm_PortRotation.includesPort( cm_Port ) then
				continue port_loop;
			endif;
		endforeach portRotation_loop;
		
		// if got to here then add this Port as a PortRotation to this Trade.
		create pxyRotation transient;
		pxyRotation.setProxy(cm_Port, self);
		create cm_PortRotation persistent;
		cm_PortRotation.setForCreate(pxyRotation, self);
	endforeach port_loop;
	
	// now go through each Debtor selected
	foreach object in _selectedDebtors do : debtor_loop
		cm_Debtor	:= object.CM_Debtor;
		
		// for each debtor add any operators not already on this Trade with raiseException = false.
		foreach cm_Operator in cm_Debtor.operators do : operator_loop
			self.operators.addNoDuplicates( cm_Operator, false );
		endforeach operator_loop;
	endforeach debtor_loop;
	
	// now cause an event to make sure other users Trade sheets get updated at the end of this transaction.
//	self.causeEvent( Object_Update_Event, false, self );
	self.updateObjectEdition(self);
	
epilog
	
end;
</source>
        <Parameter name="_trade" type="CM_Trade"/>
        <Parameter name="_selectedPorts" type="ObjectArray"/>
        <Parameter name="_selectedDebtors" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="ed9bbc28-ec93-4f1f-9ad3-eef79757f1bd">
        <updating/>
        <source>setForCreate(pProxyTrade : CM_Trade) updating;
// ---------------------------------------------------------------------------
// Created:      12 May 2003 by cnwsgp1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	pProxyTrade.raiseExceptionIfNotTransient(method);
	
	setForUpdate(pProxyTrade);
	self.myRoot := app.myRoot;
end;</source>
        <Parameter name="pProxyTrade" type="CM_Trade"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="1b4a88c1-3918-48c7-8956-e0418558f8e5">
        <updating/>
        <source>setForUpdate(pProxyTrade : CM_Trade) updating;
// ---------------------------------------------------------------------------
// Created:      12 May 2003 by cnwsgp1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// cnwer1		29/4/09		CCMS 1058
// MAP			4/9/17		TFS5551 don't delete/recreate operators, shipping lines, ports of call unnecessarily

// ---------------------------------------------------------------------------
vars
	pxyPOC,realPOC : CM_PortRotation;
	dict : DynaDictionary;
	iter : Iterator;
	
begin
	self.code := pProxyTrade.code.trimBlanks;
	self.description := pProxyTrade.description.trimBlanks;
	self.order := pProxyTrade.order;
	self.isNotAvailableForEntry := pProxyTrade.isNotAvailableForEntry;
	
	//self.operators.clear;
	//pProxyTrade.operators.copy(self.operators);
	self.operators.synchroniseContents(pProxyTrade.operators);		// 30/8/17 MAP TFS5551
	
	//self.allShippingLines.clear;
	//pProxyTrade.allShippingLines.copy(self.allShippingLines);
	self.allShippingLines.synchroniseContents(pProxyTrade.allShippingLines);	// 30/8/17 MAP TFS5551
	
	create dict transient;
	dict.setMembership(CM_PortRotation);
	dict.addMemberKey(CM_PortRotation::myPort.name, false, false);
	dict.endKeys(true);
	
	self.allPortRotations.copy(dict);
	
	iter := dict.createIterator();
	while iter.next(realPOC) do
		realPOC.setMyTrade(null);
	endwhile;
	
	foreach pxyPOC in pProxyTrade.allPortRotations discreteLock do
		realPOC := dict[pxyPOC.myPort].CM_PortRotation;
		if realPOC = null then
			create realPOC persistent;
			realPOC.setForCreate(pxyPOC,self);
		else
			dict.remove(realPOC);
			realPOC.setMyTrade(self);
			realPOC.setForUpdate(pxyPOC);
		endif;
	endforeach;
	
	dict.purge();
		
epilog
	delete dict;
	delete iter;
end;</source>
        <Parameter name="pProxyTrade" type="CM_Trade"/>
    </JadeMethod>
    <JadeMethod name="setMyRoot" id="74acf953-7cc8-4611-bfa7-2151236ecfd0">
        <updating/>
        <source>setMyRoot() updating;
// ---------------------------------------------------------------------------
// Created:     04 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.myRoot := app.myRoot;

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxy" id="de4ca588-cf88-4086-8ada-4411663c4509">
        <updating/>
        <source>setProxy(	_code,
			_description : String;
			_order : Integer;
			_allOperators : ObjectArray; 
			_isNotAvailableForEntry : Boolean;
			_allShippingLines : CM_ShippingLineByCodeDict) updating;
// ---------------------------------------------------------------------------
// Created:     12 May 2003 by cnwsgp1
// ---------------------------------------------------------------------------
begin
	self.raiseExceptionIfNotTransient(method);

	self.code := _code[1:10].trimBlanks;
	self.description := _description[1:30].trimBlanks;
	self.order := _order;
	//ccms 1058
	self.operators.clear;
	if _allOperators &lt;&gt; null then
		_allOperators.copy(self.operators);
	endif;
	
	self.allShippingLines.clear;
	if _allShippingLines &lt;&gt;  null then
		_allShippingLines.copy(self.allShippingLines);
	endif;
	
	self.isNotAvailableForEntry := _isNotAvailableForEntry;
	self.myRoot 		:= app.myRoot;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_order" type="Integer"/>
        <Parameter name="_allOperators" type="ObjectArray"/>
        <Parameter name="_isNotAvailableForEntry" type="Boolean"/>
        <Parameter name="_allShippingLines" type="CM_ShippingLineByCodeDict"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="239d4d2c-faf4-4b0f-b92b-e71795cd6468">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:      12 May 2003 by cnwsgp1
//29/07/2016 cnwma1 TFS #2447:Adding duplicate gives error
// ---------------------------------------------------------------------------
vars
	trade : CM_Trade;
begin
	/*if app.myRoot.allTradesByDescription[description] &lt;&gt; null then //01/08/2016 cnwma1 TFS #2446
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.description, null, null);
	endif;*/
	foreach trade in app.myRoot.allTradesByDescription do   //01/08/2016 cnwma1 TFS #2446
		if trade.description.toUpper = description.toUpper then
			app.raiseCMException1(VB_DUPLICATED_ITEM, self.description.String, null, null);
		endif;
	endforeach;
	self.validateMe;
end;


</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="97a7ebbe-578b-4fca-b427-2cd3c3fc5bcd">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:      12 May 2003 by cnwsgp1
// ---------------------------------------------------------------------------
begin
	if operators.size &gt; 0 then
		app.raiseCMException2(ObjectStillHasEntries, self.description.String, "Trade", null, null);
	endif;
end;</source>
    </JadeMethod>
