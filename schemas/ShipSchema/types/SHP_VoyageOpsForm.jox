        <updating/>
        <source>mnuCargoCreateNew_click(menuItem: MenuItem input) updating;
//----------------------------------------------------------------
//	Created:	19 April 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	lc : CM_LocationsController;
begin

	if menuItem.helpKeyword = self.tblOnship.name then
		lc := self.cmbLoadLocation.listObject.CM_LocationsController; // ONSHIP LOCATION
	elseif menuItem.helpKeyword = self.tblOnsite.name then
		lc := self.getOnsiteLocationsController(); // ONSITE LOCATION
		self.myAssistant.showCargoAddFromOnsite(self, true, 3, 160, null, null, null, null, self.myCurrentVoyage, false, lc); // TFS 3218 CNWAB1
		return;
	endif;
	
	self.myAssistant.showCargoAddFromOnship(self, true, 3, 160, null, null, null, null, self.myCurrentVoyage, false, lc); // TFS 3218 CNWAB1
		
end;</source>
