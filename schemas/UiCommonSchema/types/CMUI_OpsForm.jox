    <JadeMethod name="doBtnToolBarMouseUp" id="ffaaca0a-5b73-444d-9e54-493e502dc269">
        <updating/>
        <source>doBtnToolBarMouseUp(jadeMask: JadeMask input) updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	if jadeMask.index &lt;= VIEW_TEMPERATURE then
		self.frmModeStatusBar.myFrameCaption.caption := self.mySDF.setViewMode(jadeMask.index);
//		self.frmViewMode.caption := app.getViewModeString(jadeMask.index);
		if (not self.mySDF.allGridAreasByRowColumn.isEmpty) then
			self.mySDF.drawSelf();
		endif;
		if not self.frmLegend.displayViewModeCodes(self.mySDF.viewMode, self.mySDF.myDrawingAttrController) then
			self.frmLegend.doChangeViewMode(jadeMask.index);
		endif;
	endif;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuJob" id="f04e29d0-3415-407b-ad11-ec232dc9f461">
        <source>doBuildMnuJob(pJob : CM_Job);
//--------------------------------------------------------------
//Created: 18 March 2003 By: cnwgd1
//--------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	----------------------------------------------------------------
// 25/01/2013	cnwdap1		PAR #31018 CCMS POL 2223 added menu item to disconnect reefers
// 19/10/2022	jlizm1		TFS 54118 Assigning Releases to Wagons
vars

begin

	if pJob = null then
		return;
	endif;

	self.mnuContextTable.enabled := true;
	self.mnuQueue.visible := false;
	self.mnuSetTargetLocn.visible := false;
	self.mnuMoveIt.visible := false;
	self.mnuAssignRelWagon.visible := false; 
	self.mnuAssignRelWagon2.visible := false; 
	self.mnuWagonAssignBulk.visible := false;	//23 Feb 2017	NDL	TFS 3514
	//process.isCCMS1935; 	//12 May 2010 NDL	Otago CCMS 1935 testing... //cnwrd1 par 24169 11/6/2010
	self.mnuAssignRelWagonAndQ.visible := false;	//11 may 2010	NDL	Otago CCMS 1935 in testing...
	self.mnuAssignRelWagonAndQ2.visible := false;	//11 may 2010	NDL	Otago CCMS 1935 in testing...
	self.mnuUnAssignRelWagon.visible := false; 
	self.mnuUnAssignRelWagon2.visible := false; 
	self.mnuAssignToTBA.visible := false;
	self.mnuAdditional.visible := false;
	self.mnuSource.visible := false;		
	self.mnuDeleteCurrentEntry.visible := false;
	self.mnuTurnAround.visible := false;			
	self.mnuComplete.visible := false;
	self.mnuRebuildWLEStatus.visible := true;
	self.mnuRebuildWLEStatus.userObject := pJob;
	self.mnuAddDeliveryRequest.visible := false;
	self.mnuAddDeliveryRequest.userObject := null;

	self.mnuQueue.visible := true;
	//epr par 36229 17/7/17 removed references to RadioTelemetryEnabled 
	if pJob.status &lt;&gt; JOB_COMPLETE then	
		if pJob.allEntries.isEmpty then
			self.mnuQueueSelected.enabled := true;
			self.mnuQueueSelected.caption := "Queue " &amp; pJob.jobId;
			self.mnuQueueAll.enabled := false;
			self.mnuMoveIt.visible := true;									
		else
			self.mnuUnqueueSelected.enabled := true;
			self.mnuUnqueueSelected.caption := "Unqueue " &amp; pJob.jobId;
			self.mnuUnqueueAll.enabled := false;
			self.mnuMoveIt.visible := true;
		endif;				
	endif;

	if pJob.jobType = BOLType_Log then
		self.mnuEnquire.visible := false;
		self.mnuRemarks.visible := false;
		self.mnuRemarks.userObject := null;
		self.mnuDisconnect.visible := false;			// PAR #31018
		self.mnuDisconnect.userObject := null;			// PAR #31018
	endif;							

end;</source>
        <Parameter name="pJob" type="CM_Job"/>
    </JadeMethod>
