    <JadeMethod name="setMyVoyage" id="88c94422-5f9c-4117-a8fc-24e543439e19">
        <updating/>
        <source>setMyVoyage(_value : CM_Voyage) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
01 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	terminal : CM_Terminal;
begin


	if self.myVoyage  &lt;&gt; _value then
		terminal:=self.getMyTerminal;
		if terminal &lt;&gt; null then
			self.endNotification(self.myVoyage,terminal.getTerminalEvent(JobSheet_Update_Event));
		endif;
		
		self.myVoyage:=_value;
		terminal:=self.getMyTerminal;
		self.beginNotification(self.myVoyage,terminal.getTerminalEvent(JobSheet_Update_Event), Response_Continuous, null);
		
		if self.myTimeLineDrawController &lt;&gt; null then
			self.myTimeLineDrawController.setMyTerminal(terminal);	// 19/5/16 cnwmp6 TFS 488 - Multi timezone support
		endif;
		
		if self.myVoyageStats = null then
			create self.myVoyageStats transient;
		endif;
		self.myVoyageStats.init(self.myVoyage);	
		self.myVoyageStats.getStats(true);
	endif;

epilog

end;</source>
        <Parameter name="_value" type="CM_Voyage"/>
    </JadeMethod>
