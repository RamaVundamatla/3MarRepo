    <JadeMethod name="addToolbarControls" id="03c65f5f-85f7-42a5-8ed3-2da6eaad04b9">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:     26 May 2009 by concms1
// Purpose:     Par 19715 - Vehicle Visit Record Detail Changes
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	toolbar			: CMUI_Toolbar;
begin 
	inheritMethod();
	
	toolbar := self.frmToolbar;
	
	if app.myCurrentUserCan (self.myTerminal, PmAdmTermareadefView) then
		if self.allowAdd then
			// if they can't add there will be no buttons to add seperator after
			toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
		endif;
		
		toolbar.addButton(self.btnICAreas, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
	return;
	toolbar := self.frmToolbar;

	toolbar.addButton(self.btnNewTV, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnEditTV, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnExtraDelete, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton( self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right );

	toolbar.positionToolbarControls();
	toolbar.showCaptions := frmToolbar.showCaptions;
	toolbar.refresh();
end;
</source>
        <access>protected</access>
    </JadeMethod>
