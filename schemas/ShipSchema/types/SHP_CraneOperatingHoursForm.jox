    <JadeMethod name="handleTblDataDblClick" id="71c9db37-6469-4c62-aa31-3953104da29d">
        <updating/>
        <source>handleTblDataDblClick(_row: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 April 2012	cnwndl1	Initial creation	Par 29368 

*/

vars
	obj	: Object;
begin
	obj := tblData.accessRow(_row).itemObject;

	if CM_WorkPointOperatingHours.hasInstance(obj) then
		if self.btnEditTV.enabled = true then
			self.btnEditTV_click(self.btnEditTV);
		endif;
	endif;
end;</source>
