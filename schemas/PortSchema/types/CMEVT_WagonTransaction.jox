    <JadeMethod name="getDebtor" id="39d63910-6f9a-4b96-98ab-303d7e69bd60">
        <source>getDebtor(): CM_Debtor;
// ---------------------------------------------------------------------------
// Created:     20 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	debt : CM_Debtor;
begin
	 // ### TFS CR 56814 TASK 56813 07JUL2023 NAVAB1
	if self.myDebtor &lt;&gt; null then
		return self.myDebtor;
	endif;

	if self.myWagon &lt;&gt; null then
		debt := self.myWagon.getDebtor();
	endif;
	
	if debt = null then
		return inheritMethod();
	endif;

	return debt;
epilog

end;</source>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="getDescription" id="e1c40e40-c09a-4938-807d-0c164675271b">
        <source>getDescription() : String;
// ---------------------------------------------------------------------------
// Created:     20 May 2009 by cnwab1
//
// Changed On   		Changed By  	Reason
// ----------   		----------  	--------------------------------------------------
//24 Aug 2022 			navsj20	ChangeRequest 54281: EUP - Wagon Track Planning
//05 Dec 2024 			navma1	MTN-33567 MTN - Charges Are Not Created When adding Events
// ---------------------------------------------------------------------------

vars
	
	wagonId : String;
begin
	
	if self.myWagon &lt;&gt; null then
		wagonId :=  self.myWagon.id;
	endif;
	
	if self.type = EVT_WagonAdd then
		return app.getErrorString2(Wagon_added_train, wagonId, self.trainCode);
	elseif self.type = EVT_WagonCargoConfirmed then
		if self.inWard then
			return app.getErrorString2(Cargo_confirm_inward_wagon, self.getTIDescription(), wagonId);
		else
			return app.getErrorString2(Cargo_confirm_outward_wagon, self.getTIDescription(), wagonId );
		endif;
	elseif self.type = EVT_WagonCargoMoved then
			if self.isSwapMove then
			return app.getErrorString3(Been_swapped_from, self.getTIDescription(), self.sourceLocn, self.targetLocn);
		endif;

		return app.getErrorString3(Been_moved_from, self.getTIDescription(), wagonId, wagonId);
	elseif self.type = EVT_WagonCargoReceive then
		if self.inWard then
			return app.getErrorString2(Cargo_receive_inwards_wagon, self.getTIDescription(), wagonId);
		else
			return app.getErrorString2(Cargo_receive_outward_wagon, self.getTIDescription(), wagonId);	
		endif;
	elseif self.type = EVT_WagonCargoRelease then
		if self.inWard then
			return app.getErrorString2(Cargo_release_inwards_wagon, self.getTIDescription(), wagonId);
		else
			return app.getErrorString2(Cargo_release_outward_wagon, self.getTIDescription(), wagonId);	
		endif;
	elseif self.type = EVT_WagonConfirmed then
		return app.getErrorString1(Wagon_confirmed, wagonId);	//19 Jan 2017
	//19 Jan 2017	NDL	TFS 3198/2877
	elseif self.type = EVT_WagonConfirmedOut then
		return app.getErrorString1(Wagon_confirmed_outward, wagonId);
	elseif self.type = EVT_WagonCreate then
		return app.getErrorString1(Wagon_created, wagonId);
	elseif self.type = EVT_WagonDamaged then
		if self.getDamageDescription &lt;&gt; null then
			return app.getErrorString2(WAGON_HAS_DAMAGE, wagonId, self.getDamageDescription);
		else
			return app.getErrorString1(Wagon_damaged, wagonId);
		endif;
	elseif self.type = EVT_WagonDeparted then
		return app.getErrorString1(Wagon_departed, wagonId);
	elseif self.type = EVT_WagonMoved then
		return app.getErrorString2(Wagon_moved_from_train, wagonId, self.trainCode);
	elseif 	self.type = EVT_WagonRemove then
		return app.getErrorString2(Wagon_removed_from_train, wagonId, self.trainCode);
	elseif self.type = EVT_WagonReturned then
		return app.getErrorString1(Wagon_returned, wagonId);
	elseif self.type = EVT_WagonSealAdd then	//12 Mar 2015	NDL	Par 35828
		return self.extraDescription;
	elseif self.type = EVT_WagonSealDelete then	//12 Mar 2015	NDL	Par 35828
		return self.extraDescription;
	elseif self.type = EVT_WagonSealCheck then	//29 Jul 2015	NDL	Par 36658
		return self.getWagonSealCheckDetailsString();
	elseif self.type = EVT_WagonPlanned then
		if self.myWagon &lt;&gt; null then
			return app.getErrorString1(Wagon_planned, wagonId);
		endif;
		return null;
	elseif self.type = EVT_WagonUnplanned then
		if self.myWagon &lt;&gt; null then
			return app.getErrorString1(Wagon_unplanned, wagonId);
		endif;
		return null;
	endif;
	return inheritMethod(); // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayID" id="af4f7b99-bff8-482f-9e5e-6dcfbf67b299">
        <source>getDisplayID(): String;
//
//30 Apr 2015	cnwrs1	Par35784 - increased exclusion reason logging to include non excluded
//
vars

begin
	if self.myWagon &lt;&gt; null then
		return self.myEventType.name&amp;' '&amp;self.myWagon.id;
	else
		return inheritMethod();
	endif;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="691b52d6-e840-4cb4-b7a3-c0a3b1d6c5c0">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     21 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 08/03/2011		cnwmh5			PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
//19 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------

vars
	invalidTI : Boolean;
	tiID	 : String;
	ti		: CM_TrackedItem;
begin
	
	on Exception do app.handleDeletedObject(exception,ti,invalidTI);
	
	if _attrName = ETRow_Train  then
	/*	if self.trainCode &lt;&gt; null then
		//if self.myTrain &lt;&gt; null then
			return self.myTrain.getCodeDateString;
		else
			return null;
		endif; */
		//17 Oct 2012	NDL	Par 29281
		on Exception do app.handleDeletedObject(exception,self.myTrain,invalidTI);
		if self.myTrain &lt;&gt; null then
			return self.myTrain.getCodeDateString;
		endif;
		return self.trainCode;
	elseif _attrName = ETRow_Description then
		return self.getDescription();

	
	elseif _attrName = ETRow_WagonNumber  then
		if self.myWagon &lt;&gt; null then
			return self.myWagon.id;
		else
			return null;
		endif;
	elseif _attrName = ETRow_Id  then
		ti := self.myTrackedItem;
		if ti &lt;&gt; null then
			tiID:=ti.id;
			if invalidTI then
				return null;
			else
				return tiID;
			endif;
		else
			return null;
		endif;
	elseif _attrName = ETRow_InWard  then
		if self.inWard then
			return app.getErrorString(IN_YO);
		else
			return app.getErrorString(OUT_YO);
		endif;
	elseif _attrName = ETRow_SourceLocation then
		return self.sourceLocn;
	elseif _attrName = ETRow_TargetLocation then
		return self.targetLocn;
	endif;



	return inheritMethod(_attrName, _short);



epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="746691c9-48ec-4f36-8de4-3136c30ed822">
        <source>getExtraInfo(_dataContainer: CM_DataContainer) ;

vars
	block : CM_DataContainerBlock;
	invalidObject : Boolean;
	lString : String;
begin

	inheritMethod(_dataContainer);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Wagon_ID), DC_Label, 1, self);
	block.addNewItem(self.myWagon.id, DC_Data, 1, self);

//	if self.myTrain &lt;&gt; null then
	if self.trainCode &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Train), DC_Label, 1, self);
		block.addNewItem(self.trainCode, DC_Data, 1, self);
	endif;
	on Exception do app.handleDeletedObject(exception,self.myTrackedItem,invalidObject);
	if self.myTrackedItem &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Cargo), DC_Label, 1, self);
		block.addNewItem(self.myTrackedItem.id, DC_Data, 1, self);
	endif;

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Description), DC_Label, 1, self);
	block.addNewItem(self.getDescription(), DC_Data, 1, self);

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
