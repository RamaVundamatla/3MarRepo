    <JadeMethod name="jssIsAttribute" id="61981153-ef65-4892-8214-fbbeea899508">
        <source>jssIsAttribute() : Boolean;
// --------------------------------------------------------------------------------
// Created:		01 November 2001 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is an
