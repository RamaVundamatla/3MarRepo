<GUIClass name="CMUI_ColorPicker" id="30378688-151d-4b3d-93ab-92e85638221f">
    <superclass name="CMUI_Label"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <DbClassMap file="_usergui"/>
    <JadeMethod name="click" id="88f89ef5-76d6-4616-aa66-1a24bdc9743f">
        <controlMethod name="Label::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>click(label: Label input) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		02 March 2005 by cnwdad1
//
// Purpose:		Invokes the Color Dialog for the user to pick a color.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	colorDialogObj	: CMDColor;
	
begin
	inheritMethod(label);
	
	create colorDialogObj transient;
	
	colorDialogObj.preventFullOpen	:=	false;
	colorDialogObj.color			:=	self.backColor;

	if colorDialogObj.open() = 0 then
		self.backColor	:=	colorDialogObj.color;
	endif;
epilog
	delete colorDialogObj;
end;</source>
        <Parameter name="label" type="Label" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getColor" id="6149c669-bd65-481c-a6b4-da1aa765502e">
        <source>getColor():Integer;
// --------------------------------------------------------------------------------
// Created:		02 March 2005 by cnwdad1
//
// Purpose:		Returns the receiver's currently selected (background) color.
//
// Parameters:	None
//
// Returns:		The receiver's background color.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.backColor;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setColor" id="4fe8ed82-29c1-458d-8d47-b55c3926bca9">
        <updating/>
        <source>setColor(pColor:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		16 March 2005 by cnwdad1
//
// Purpose:		Sets the background color of the receiver.
//
// Parameters:	pColor - The background color.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.backColor	:=	pColor;
end;</source>
        <Parameter name="pColor" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="60b64a76-ac74-4e4f-bc24-2803c3e0643b">
        <controlMethod name="CMUI_Label::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// --------------------------------------------------------------------------------
// Created:		02 March 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(cntrl, persistCntrl);
	
	self.transparent	:=	false;
//	self.backColor		:=	Window.Color_Background;
	self.show3D			:=	Control.Show3D_Use3D;
	self.caption		:=	null;
	self.bubbleHelp		:=	"Click to select a color";
	self.ignoreSkin		:= true;    // 11/09/2006

end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
