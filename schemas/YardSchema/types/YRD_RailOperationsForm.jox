    <JadeMethod name="doMnuWagonAssignBulkClick" id="c6fcddc8-45c1-4f18-b9ba-c1cd74baf7d4">
        <source>doMnuWagonAssignBulkClick(menuItem: MenuItem input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Feb 2017	cnwndl1	Initial creation	TFS 3514
28 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
29 Aug 2018	JLGNS1	Bug 40008: PEN - Restrict Operator Issue - removed TFS2749
19 Oct 2022	jlizm1	TFS 54118 Assigning Releases to Wagons
27 Apr 2023	jlier1  TFS 56733 
24 Jul 2023	navma1	Bug 59261: MTN - Issues while assigning Release Rail request to work orders
*/

vars
	obj 		   	 : Object;
	resDet 		   	 : CM_ReserveDetail;
	resHead		   	 : CM_BulkRelease;
	wagon 		   	 : CM_Wagon;
	railIORake 	   	 : CM_RailJSInOutRake;
	cargoType 	   	 : CM_CargoType;
	intFaceBP 	   	 : CMIF_BuildPriority;
	tmpReq 		   	 : CMIF_Request;
	cmifObjects    	 : ObjectArray;
	hasAssignedReq 	 : Boolean;
	result 		   	 : Integer;
	ti 			   	 : CM_TrackedItem;	
	agent 		   	 : CM_RailProcessingAgent;
	resDets 	   	 : CM_ReserveDetailSet;
	resDetsArray   	 : CM_ReserveDetailArray;
	wleArray 	   	 : CM_WLEArray;
	wagonArray 	   	 : CM_WagonArray;
	carrier		   	 : CM_Carrier;
	operator	   	 : CM_Operator;
	dac			  	 : CM_DataAccessController;
	operatorStr	   	 : String;
	sch 		   	 : Schema;
	formClass, 
	assistClass    	 : Class;
	form 		   	 : Form;
	isRelAssEnhanced : Boolean;
begin

	create wagonArray transient;
	create resDetsArray transient;
	create resDets transient;
	self.getSelectedWagons(wagonArray, null);
	
	if wagonArray.isEmpty then
		return;
	endif;
	
	wagon 			 := wagonArray.first();
	railIORake 		 := wagon.getRailJSInOutRake(false);
	isRelAssEnhanced := self.myTerminal.getConfig( RailReleaseAssignEnhance ).Boolean;	//24.07.2023 navma1 #59261
	
	foreach wagon in wagonArray do
		if wagon.myTrainOutwards &lt;&gt; null then
			if railIORake &lt;&gt; wagon.getRailJSInOutRake(false) then
				// only attempt to assign releases to wagons on the same rail
				return;
			endif;
			if isRelAssEnhanced  then												     //24.07.2023 navma1 #59261
				self.getProspectWagonResDets( wagon , resDetsArray );
			else
				self.getProspectWagonResDetsOrig( wagon , resDetsArray );
			endif;
			if not resDetsArray.isEmpty then
				resDetsArray.copyNoDups(resDets);
			endif;
		endif;
	endforeach;
	
	create wleArray transient;
	create cmifObjects transient;
	
	foreach resDet in resDets do
		resHead := resDet.myReserveHeader;
		cargoType := resDet.getCargoType;
		if cargoType = null or resHead = null then
			continue;
		endif;
		
		carrier := resHead.getCarrier();
		operator := resHead.myOperator;
		if carrier &lt;&gt; null and not carrier.canCarrierAccessForOperator(operator, dac, true) then
			if operator &lt;&gt; null then
				operatorStr := operator.description;
			endif;
			app.raiseCMException2(Carri_does_not_have_acces_oper, carrier.description, operatorStr, null, null);
			return;
		endif;
		
		foreach ti in resHead.allTrackedItemsAssigned do
			operatorStr := null;
			operator := ti.myOperator;
			if carrier &lt;&gt; null and not carrier.canCarrierAccessForOperator(operator, dac, true) then
				if operator &lt;&gt; null then
					operatorStr := operator.description;
				endif;
				app.raiseCMException2(Carri_does_not_have_acces_oper, carrier.description, operatorStr, null, null);
				return;
			endif;
		endforeach;
		
		create intFaceBP transient;
		intFaceBP.allReservesToProcess.add(resDet);
		resHead.setInterfaceBP(intFaceBP, railIORake);
		cmifObjects.add(intFaceBP);
	endforeach;

	
	// Show Release Quantity Form to select release details to assign
	sch			:= rootSchema.getSchema("GateSchema");
	formClass   := sch.getClass("GTE_ReleaseQuantityForm");
	assistClass := sch.getClass("GTE_Assistant");
	
	form := app.loadForm(formClass, assistClass, false, false, false, self.myTerminal, null);
	form.sendMsgWithParams("setWagons", wagonArray);
	form.sendMsgWithParams("initialise", cmifObjects, null, false, true, self.myTerminal, form.CM_BaseForm.myAssistant);
	form.showModal();
	if form.modalResult &lt;&gt; IDOK then
		return;
	endif;
	
	foreach obj in cmifObjects do
		intFaceBP := obj.CMIF_BuildPriority;
		hasAssignedReq := false;
		foreach tmpReq in intFaceBP.allCMIFRequests do
			if tmpReq.quantityTxt &gt; 0 or tmpReq.weight &gt; 0 or tmpReq.isAnyAmount then
				hasAssignedReq := true;
				break;
			endif;
		endforeach;
		
		if not hasAssignedReq then
			continue;
		endif;	
		
		while true do
			app.myTrxUA.trxUpdateAssignBulkOutRail(intFaceBP, railIORake,self.myCurrentTrain, app.myPassport);
			if app.myPassport.trxCompletedOK then
				//02 Dec 2020	NDL	TFS 50164 - Can be multiple wles for non allows duplicates containers.
				wleArray.clear();
		
				//jlier1 TFS 56733 27/4/23 
				foreach tmpReq in intFaceBP.allCMIFRequests do
						if tmpReq.myNewJob &lt;&gt; null then
							tmpReq.myNewJob.workListEntries.copyNoDups(wleArray);
						endif;
				endforeach;
				
				if wleArray.size &gt; 0 then
				
					create agent transient;
					agent.initialise( self.myTerminal );
					agent.showWarnings := true;
					agent.doAssignReleasesToWagons( wleArray, wagonArray, false, true );
					delete agent;
				endif;
				break;
			
			else
				result := app.showErrorWarningDialog('Assign To Outward Rail', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;	
			endif;
			break;
		endwhile;
	endforeach;
	
epilog
	if cmifObjects &lt;&gt; null then							//25.07.2023 navma1 #59261
		foreach obj in cmifObjects do
			intFaceBP := obj.CMIF_BuildPriority;
			delete intFaceBP.myProxyRailJob;
			intFaceBP.allCMIFRequests.purge;
		endforeach;
	endif;
	delete wleArray;
	delete cmifObjects;
	delete resDets;
	delete resDetsArray;
	delete form;
	delete agent;
	delete wagonArray;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuWagonClick" id="ec7b5b82-fa07-4f81-8399-5089d96c28db">
        <updating/>
        <source>doMnuWagonClick(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
//write "AKB" &amp; " " &amp; class.name &amp; '::' &amp; method.name &amp; " 1. " &amp; menuItem.helpKeyword &amp; " " &amp; menuItem.index.String;
