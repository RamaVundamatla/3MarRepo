    <JadeMethod name="setProxyInterchangeArea" id="a1e73c19-ca6a-4a9a-ac2f-677bf9a4c0bb">
        <updating/>
        <source>setProxyInterchangeArea(_id :String; _comment :String; _terminal :CM_Terminal; _type, _laneCount :Integer; 
				_releasePoint, _hideFromOverview :Boolean; 
				_accessRule :Integer;	// par 24418
				_defExitGate :CM_Gate;
				_selectedTAs : CM_TerminalAreaSet input )updating;
// ---------------------------------------------------------------------------
// Created:     11 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config, par 20582 
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26/05/2010	cnwcs5		par 24292 - change _allInterchangeAreas parameter to array
// 18/06/2010	cnwcs5		par 24418 - new accessRule parameter
// ---------------------------------------------------------------------------
vars
	rows		: Integer;
	ta, taProxy	: CM_TerminalArea;
	
begin
	self.raiseExceptionIfNotTransient(method);
	
	if _laneCount = 0 then
		rows := 1;
	else
		rows := _laneCount;
	endif;
	
	self.setGridAreaProxy (_id, _comment, _type, rows, 1, 2, _releasePoint, _terminal, false, false, _hideFromOverview,
							null, false, false, false, false, false, null, null,false, false,
							null,null,null,null);	
	
	self.laneCount 						:= _laneCount;
	self.myDefaultOutGate				:= _defExitGate;
	self.vehicleMachineAccessRules		:= _accessRule;	// par 24418
	
	self.allAssociatedTerminalAreas.clear;
	
	if _selectedTAs &lt;&gt; null then
		foreach ta in _selectedTAs do
			self.allAssociatedTerminalAreas.add (ta);
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_laneCount" type="Integer"/>
        <Parameter name="_releasePoint" type="Boolean"/>
        <Parameter name="_hideFromOverview" type="Boolean"/>
        <Parameter name="_accessRule" type="Integer"/>
        <Parameter name="_defExitGate" type="CM_Gate"/>
        <Parameter name="_selectedTAs" type="CM_TerminalAreaSet" usage="input"/>
    </JadeMethod>
