    <JadeWebServicesMethod name="getLogLotForActualVoyage" id="365d8269-4967-465b-9d00-4666421f02b1">
        <source>getLogLotForActualVoyage(voyageId : String) : WS_LogLotResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 September 2008	cnwkao1	Initial creation

*/

vars
	//ut : CM_UserTerminal;
	termSet			: CM_TerminalSet;
	voyageGlobal    : CM_VoyageGlobal;
	voyage			: CM_Voyage;
	logLot			: CM_LogLot;
	multiTerminal	: Boolean;
	terminalCode,
	str				: String;
	//user	    : CM_User;
	pxyLogLot		: WS_LogLot;
	response	: WS_LogLotResponse;
	obj			: Object;
	completedOK	: Boolean;
	passport    : CM_Passport;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	
	if voyageId = null then
		completedOK := true;
		return response;
	endif;
	
	//epr TFS 5535 4/8/17 
	voyageGlobal := app.myPassport.getObjectOfTypeFromOid( voyageId,CM_VoyageGlobal).CM_VoyageGlobal;
	if voyageGlobal = null then 
		completedOK := true;
		return response;
	endif;
	
	passport := app.myPassport;
	
	create termSet transient;
	termSet.add(passport.myTerminal);
	
	multiTerminal := (termSet.size &gt; 1);
	
	foreach voyage in voyageGlobal.allVoyages discreteLock where termSet.includes(voyage.myTerminal) do
//		if (not CM_LogVoyage.hasInstance(voyage)) then
		if (voyage.myLogVoyageStructure = null) then
			continue;
		endif;
		terminalCode := voyage.myTerminal.code;
//		foreach logLot in voyage.CM_LogVoyage.allLogLots do
		foreach logLot in voyage.myLogVoyageStructure.allLogLots discreteLock do
			if multiTerminal then
				str := logLot.lotNo &amp; ' -' &amp; terminalCode;
			else
				str := logLot.lotNo;
			endif;
			
			create pxyLogLot transient;
			pxyLogLot.code := str;
			response.allLogLots.add(pxyLogLot);	
		endforeach;
	endforeach;
	
	completedOK := true;
	return response;
	
	
epilog
	delete termSet;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <wsdlName>getLogLotForActualVoyage</wsdlName>
        <Parameter name="voyageId" type="String"/>
        <ReturnType type="WS_LogLotResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getLogRows" id="30ca46e5-397f-4612-9e6b-15691c189b81">
        <source>getLogRows(_request : WS_LogRowsQueryRequest input) : WS_LogRowsResponse webService;
/*

Date		Who		Reason
05 October 2015	cnwer1	Initial creation PAR 37018
*/

vars
	completedOK : Boolean;
	response 	: WS_LogRowsResponse;
	terminalCode : String;
	logRowQuery : CMIF_LogRowQuery;
	wsLogController : WS_LogController;
	lc : CM_LocationsController;

begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmLogRowView);		// Replace with appropriate permission
	
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	

	create logRowQuery transient;
	logRowQuery.setDetails(_request.filterTerminal,
							_request.filterTerminalArea,
							_request.filterLocationID,
							_request.filterLocationOID,
							_request.filterOperator,
							_request.filterStatus,	
							_request.filterIsDocketChecked,
							_request.filterIsCheckScaled,
							_request.filterIsInspected,
							_request.filterIsFumigated,
							_request.filterAllocatedVoyageCode,
							_request.filterAllocatedVoyageOID,
							_request.filterLogSpecies,
							_request.filterLogGrade,
							_request.filterLogType,
							_request.filterLogTreatment,
							_request.filterLogLength,
							null,null,app.myPassport);
	
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	logRowQuery.doQuery(app.myPassport);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	foreach lc in logRowQuery.allFoundLCs discreteLock do
		create wsLogController transient;
		wsLogController.setProxyFromObject(lc.CM_LogController);
		wsLogController.setProxySOHLocations(lc.CM_LogController);
		response.allLogRows.add(wsLogController);
	endforeach;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
	delete logRowQuery;
end;</source>
        <Parameter name="_request" type="WS_LogRowsQueryRequest" usage="input"/>
        <ReturnType type="WS_LogRowsResponse"/>
    </JadeWebServicesMethod>
