    <JadeMethod name="validateForCreate" id="898130ee-db05-46cb-bb4a-04e5c9a3752c">
        <source>validateForCreate();
// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1

// 09/12/2014 cnwdb2 PAR 35364
vars

begin
	if self.name = null then
	//	app.raiseCMException1( REQUIRED_FIELD, app.getString( Name ), self.name, null );
		app.raiseCMException1( Input_required_field_Required, app.getString( Name ), self.name, null ); // cnwdb2	PAR 35364
	endif;

	if self.myBank &lt;&gt; null then
		if self.myBank.allSnapShotTranMaps[self.name] &lt;&gt; null then
		//	app.raiseCMException3(ERR_DUPLICATE_KEY,"Transaction map",self.name,null,null,null);
			app.raiseCMException1(Already_exists_transMap,self.name,null,null); //cnwdb2	PAR 35364
		endif;
	endif;
end;	</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="01ad0f6e-a410-46e9-8df7-5003c9873fa1">
        <source>validateForDelete();
// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1
vars

begin
	if self.myBank.myCurrentTranMapSnapShot = self then
		app.raiseCMException(ERR_TRANSMAP_ACTIVE, null, null);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="c7191ab8-58b1-439a-9764-84248e549372">
        <source>validateForUpdate();
// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1

// 09/12/2014 cnwdb2 PAR 35364

vars
	original,
	existingTM	: CM_TranMapSSSummary;
begin
	if self.name = null then
	//	app.raiseCMException1( REQUIRED_FIELD, app.getString( Name ), self.name, null );
		app.raiseCMException1( Input_required_field_Required, app.getString( Name ), self.name, null ); // cnwdb2	PAR 35364
	endif;

	if self.myBank &lt;&gt; null then
		original := self.pxyGetRealObject();
		existingTM := self.myBank.allSnapShotTranMaps[self.name];
		if existingTM &lt;&gt; null and existingTM &lt;&gt; original then
		//	app.raiseCMException3(ERR_DUPLICATE_KEY, "Transaction map", self.name, null, null, null);
			app.raiseCMException1(Already_exists_transMap,self.name,null,null); //cnwdb2	PAR 35364

		endif;
	endif;
end;</source>
    </JadeMethod>
</Class>
