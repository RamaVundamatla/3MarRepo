    <JadeMethod name="buildExtraDetail" id="e7be8080-b865-4c15-9996-ee96d30ff367">
        <source>buildExtraDetail(_logLot : CM_LogLot; _operator : CM_Operator) protected;

vars

	extraDetail 	: CMIF_ShipLogListExtra;
	species,
	grade,
	destination		: String;
	code			: CM_Code;
	disPort			: String;

begin
	if self.myFilterClass.allTerminals.isEmpty then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Terminal collection is empty');
		return;
	endif;
	self.allSpecies.clear;
	self.allGrades.clear;
	extraDetail := self.getCMIF(_logLot, _operator);
	if not extraDetail.isBuilt then
		_logLot.getSpecsForOperator(_operator, self.allSpecies, self.allGrades);
		
		foreach code in self.allSpecies do
			species := species &amp; ', ' &amp; code.description.toUpper;
		endforeach;
		foreach code in self.allGrades do
			grade := grade &amp; ', ' &amp; code.code &amp; ' GRADE';
		endforeach;
	
		if species.length &gt; 2 and grade.length &gt; 2 then
			if _logLot.myDischargePort &lt;&gt; null then
				disPort := _logLot.myDischargePort.description.toUpper;
			endif;
			extraDetail.headerTxt := 'CONSIGNMENT OF NEW ZEALAND ' &amp;
			species[3 : end] &amp; ' ' &amp; grade[3 : end] &amp; ' LOGS FROM PORT ' &amp;
//			_logLot.myLogVoyage.myTerminal.name.toUpper &amp;
			_logLot.myLogVoyageStructure.myVoyage.myTerminal.name.toUpper &amp;
//			self.myFilterClass.allTerminals.first.name.toUpper &amp;
			' NEW ZEALAND TO PORT ' &amp; disPort;

			if _logLot.myConsignee &lt;&gt; null then
				extraDetail.buyer := _logLot.myConsignee.description.toUpper;
			else
				extraDetail.buyer := null;
			endif;
			extraDetail.isBuilt := true;
//			extraDetail.loadEndDT := _logLot.myLogVoyage.loadEndDT.Date.format("dd.MM.yy");
			extraDetail.loadEndDT := _logLot.myLogVoyageStructure.myVoyage.loadEndDT.date.format("dd.MM.yy");
		else
			self.allHeaders.remove(extraDetail);
			delete extraDetail;
		endif;
	endif;
	if extraDetail &lt;&gt; null then
		extraDetail.isToPrint := true;
	endif;
		

end;</source>
        <access>protected</access>
        <Parameter name="_logLot" type="CM_LogLot"/>
        <Parameter name="_operator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="create" id="6470e026-b62f-4881-bec0-01bb7ce068a8">
        <updating/>
        <source>create() updating;

vars

begin

	create self.myFilterClass transient;

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="c0260f04-1ed6-4c42-bb7c-727a40025b28">
        <updating/>
        <source>delete() updating;

vars

begin

	delete self.myFilterClass;
	self.allHeaders.purge;

end;</source>
    </JadeMethod>
    <JadeMethod name="deleteUnusedExtraDetail" id="2640080a-dbe7-46d7-8f4a-0ba239f13aba">
        <updating/>
        <source>deleteUnusedExtraDetail() updating, protected;

vars
	iter			: Iterator;
	extraDetail 	: CMIF_ShipLogListExtra;
	temp			: ObjectArray;

begin

	create temp transient;
	self.allHeaders.copy(temp);
	iter := temp.createIterator;
	while iter.next(extraDetail) do
		if not extraDetail.isToPrint then
			self.allHeaders.remove(extraDetail);
			delete extraDetail;
		endif;
	endwhile;
	self.myCurrentExtraDetail := null;

epilog
	delete temp;
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayExtraDetail" id="06403b79-97d4-4341-b15b-3ae707072629">
        <source>displayExtraDetail(_extra : CMIF_ShipLogListExtra) protected;

vars

begin

	self.myReportRunner.lblHeading1.caption := 'Ship Number .. ' &amp; (self.myFilterClass.getMyVoyageGlobal.code &amp; ' ' &amp;
	self.myFilterClass.getMyVoyageGlobal.vesselName).toUpper &amp;
	'             Sail date .. ' &amp; _extra.loadEndDT;
		
	self.myReportRunner.lblHeading2.caption := 'Lot: ' &amp; _extra.lotNo &amp; '     Supplier: ' &amp; _extra.operator &amp;
	'         ' &amp; _extra.operatorDesc;
	self.myReportRunner.txtDetail.text	:= _extra.headerTxt;	
	self.myReportRunner.txtBuyer.text	:= _extra.buyer;	

end;</source>
        <access>protected</access>
        <Parameter name="_extra" type="CMIF_ShipLogListExtra"/>
    </JadeMethod>
    <JadeMethod name="doButtonEnabling" id="9edbfad6-929f-481b-a341-c6909f3d3a20">
        <source>doButtonEnabling() protected;

vars

begin

	if pos = 1 and self.allHeaders.size &gt; 1 then
		self.myReportRunner.btnPrev.enabled := false;
		self.myReportRunner.btnNext.enabled := true;
	elseif pos &gt; 1 and pos = self.allHeaders.size  then
		self.myReportRunner.btnPrev.enabled := true;
		self.myReportRunner.btnNext.enabled := false;
	elseif pos &gt; 1 and pos &lt; self.allHeaders.size then
		self.myReportRunner.btnPrev.enabled := true;
		self.myReportRunner.btnNext.enabled := true;
	else
		self.myReportRunner.btnPrev.enabled := false;
		self.myReportRunner.btnNext.enabled := false;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doClose" id="845c3317-175c-4001-8944-eeda10d40297">
        <updating/>
        <source>doClose() updating;

vars

begin

	self.doSave();
	self.myReportRunner.frmHeaderDtl.visible := false;

end;</source>
    </JadeMethod>
    <JadeMethod name="doNext" id="aca46a55-b434-43c9-bf7b-8fa9f29d8aa5">
        <updating/>
        <source>doNext() updating;

vars

begin

	if pos + 1 &lt;= self.allHeaders.size then
		self.doSave();
		pos := pos + 1;
		self.myCurrentExtraDetail := self.allHeaders[pos].CMIF_ShipLogListExtra;
		self.displayExtraDetail(self.myCurrentExtraDetail);
		self.doButtonEnabling();
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doPrev" id="aed00394-ef64-4340-baac-ad8d848945f5">
        <updating/>
        <source>doPrev() updating;

vars

begin

	if pos - 1 &gt; 0 then
		self.doSave();
		pos := pos - 1;
		self.myCurrentExtraDetail := self.allHeaders[pos].CMIF_ShipLogListExtra;
		self.displayExtraDetail(self.myCurrentExtraDetail);
		self.doButtonEnabling();
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doPrint" id="b6669e03-feb0-49a0-80f7-b5ce79113c09">
        <updating/>
        <source>doPrint() updating;

vars

begin
	
	self.doClose();
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="c39f37e2-a2af-45c5-8100-9b6a9349a371">
        <updating/>
        <source>doSave() updating, protected;

vars

begin

	if self.myCurrentExtraDetail &lt;&gt; null then
		self.myCurrentExtraDetail.headerTxt	:= self.myReportRunner.txtDetail.text;
		self.myCurrentExtraDetail.buyer		:= self.myReportRunner.txtBuyer.text[1:50];
	endif;
	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getCMIF" id="842dfe2f-1ea6-4c11-a5c2-713c31bc742f">
        <source>getCMIF(_logLot : CM_LogLot;  _operator : CM_Operator) : CMIF_ShipLogListExtra protected;

vars

	extraDetail : CMIF_ShipLogListExtra;
	iter		: Iterator;

begin

	iter := self.allHeaders.createIterator;
	while iter.next(extraDetail) do
		if extraDetail.lotNo = _logLot.lotNo and 
		   extraDetail.operator = _operator.code and
//		   extraDetail.myVoyage = _logLot.myLogVoyage then
		   extraDetail.myVoyage = _logLot.myLogVoyageStructure.myVoyage then
			break;
		endif;
		extraDetail := null;
	endwhile;
	if extraDetail = null then
		create extraDetail transient;
		extraDetail.lotNo			:= _logLot.lotNo;
		extraDetail.operator		:= _operator.code;
		extraDetail.operatorDesc	:= _operator.description;
//		extraDetail.myVoyage		:= _logLot.myLogVoyage;
		extraDetail.myVoyage		:= _logLot.myLogVoyageStructure.myVoyage;
		self.allHeaders.add(extraDetail);
	endif;

	return extraDetail;
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_logLot" type="CM_LogLot"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="CMIF_ShipLogListExtra"/>
    </JadeMethod>
    <JadeMethod name="getExtraDetails" id="ac2ed410-72f3-44ea-9cde-3142ee093c31">
        <updating/>
        <source>getExtraDetails(_filter : CMQF_SOHLocationLog; _error : String output): CM_ExtraDetailShipLogLst updating;

vars

	logLot	: CM_LogLot;
	string	: String;
	extra	: CM_ExtraDetailShipLogLst;

begin

	if _filter.allLogLots.size = 0 then
		_error := "A lot must be specified";
	endif;
	string := "Extra detail has not been revised";
	
	if not _filter.getMyVoyageGlobal = self.myFilterClass.getMyVoyageGlobal then
		_error := string;
	endif;

	if not _filter.myOperator = self.myFilterClass.myOperator then
		_error :=  string;
	endif;
		
	foreach logLot in _filter.allLogLots do
		if not self.myFilterClass.allLogLots.includes(logLot) then
			_error :=  string;
		endif;
	endforeach;
	
	if not self.allHeaders.size &gt; 0 then
		_error := 'No data to display';
	endif;

	create extra transient;
	self.allHeaders.copy(extra.allShipLogLstExtra);
			
	return extra;

end;</source>
        <Parameter name="_filter" type="CMQF_SOHLocationLog"/>
        <Parameter name="_error" type="String" usage="output"/>
        <ReturnType type="CM_ExtraDetailShipLogLst"/>
    </JadeMethod>
    <JadeMethod name="initFrame" id="49fbb46e-6b09-4b2c-889a-3b3d57c13cfb">
        <source>initFrame() protected;

vars

	frmHeaderDtl : CMUI_Frame;


begin

	frmHeaderDtl := self.myReportRunner.frmHeaderDtl;
	frmHeaderDtl.top := self.myReportRunner.tblParameter.top;
	frmHeaderDtl.width := self.myReportRunner.tblParameter.width;
	frmHeaderDtl.height := self.myReportRunner.tblParameter.height;
	frmHeaderDtl.left := self.myReportRunner.tblParameter.left;
	frmHeaderDtl.stretchHeight := true;
	frmHeaderDtl.stretchWidth := true;
	frmHeaderDtl.distanceFromBottom := 150;
	frmHeaderDtl.distanceFromRight := 10;
	frmHeaderDtl.zOrder(1);	
	frmHeaderDtl.visible := true;
	

	self.myReportRunner.txtDetail.left		:= 10;
	self.myReportRunner.txtDetail.top		:= 60;
	self.myReportRunner.txtDetail.stretchWidth	:= true;
	self.myReportRunner.txtDetail.stretchHeight := true;
	self.myReportRunner.txtDetail.distanceFromBottom	:= 100;
	self.myReportRunner.txtDetail.distanceFromRight 	:= 10;
	
	self.myReportRunner.txtBuyer.left			:= 102;
	self.myReportRunner.txtBuyer.lockBottom 	:= true;
	self.myReportRunner.txtBuyer.stretchWidth	:= true;
	self.myReportRunner.txtBuyer.height			:= 20;	
	self.myReportRunner.txtBuyer.distanceFromBottom	:= 50;
	self.myReportRunner.txtBuyer.distanceFromRight 	:= 10;
	
	self.myReportRunner.lblHeading1.left 	:= 10;
	self.myReportRunner.lblHeading1.height  := 20;
	self.myReportRunner.lblHeading1.top 	:= 10;
	self.myReportRunner.lblHeading1.width 	:= self.myReportRunner.tblParameter.width - 20;
	
	self.myReportRunner.lblHeading2.left 	:= 10;
	self.myReportRunner.lblHeading2.height  := 20;
	self.myReportRunner.lblHeading2.top 	:= 32;
	self.myReportRunner.lblHeading2.width 	:= self.myReportRunner.tblParameter.width - 20;
	
	//self.myReportRunner.lblHeading3.top 	:= 60;
//	self.myReportRunner.lblHeading3.left 	:= 10;
//	self.myReportRunner.lblHeading3.height  := 20;
//	self.myReportRunner.lblHeading3.width 	:= 90;
	self.myReportRunner.lblHeading3.visible := false;
	
	self.myReportRunner.lblHeading4.left 	:= 10;
	self.myReportRunner.lblHeading4.height  := 20;
	self.myReportRunner.lblHeading4.width 	:= 90;
	self.myReportRunner.lblHeading4.lockBottom := true;
	self.myReportRunner.lblHeading4.distanceFromBottom := 50;
	
	frmHeaderDtl.repositionAfterResize();
	frmHeaderDtl.cnEcResizeContents();
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadData" id="38e81981-07dd-4384-a671-892d592ac826">
        <updating/>
        <source>loadData() updating, protected;

vars

	allOperators	: CM_OperatorSet;
	logLot			: CM_LogLot;
	operator		: CM_Operator;
	logLotCol		: CM_LogLotByLotNoDict;
begin

	pos := 1;
	self.resetPrintStatus();
	create allOperators transient;
	create logLotCol transient;
	
	//added by cnwyl1 for par 15687
	foreach logLot in self.myFilterClass.allLogLots do


		//if not logLotCol.includesKey(logLot.lotNo) then // cnwrd1 par #18726 22.1.09
			logLotCol.add(logLot);
		//endif; // cnwrd1 par #18726 22.1.09
		
	endforeach;
	
	//foreach logLot in self.myFilterClass.allLogLots do
	foreach logLot in logLotCol do
		allOperators.clear;
		if self.myFilterClass.myOperator &lt;&gt; null then
			allOperators.add(self.myFilterClass.myOperator);
		else
			logLot.getAllOperators(allOperators);
		endif;
		foreach operator in allOperators do
			self.buildExtraDetail(logLot, operator);
		endforeach;
	endforeach;
	self.deleteUnusedExtraDetail();
	self.doButtonEnabling();
	if self.allHeaders.size &gt; 0 then
		self.myCurrentExtraDetail := self.allHeaders.first.CMIF_ShipLogListExtra;
		self.displayExtraDetail(self.allHeaders.first.CMIF_ShipLogListExtra);
	endif;

epilog
	delete allOperators;
	delete logLotCol;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resetPrintStatus" id="e368f7f3-03c3-4de8-8214-8c6111c60c79">
        <source>resetPrintStatus() protected;

vars
	
	iter 	: Iterator;
	extra	: CMIF_ShipLogListExtra;

begin

	iter := self.allHeaders.createIterator;
	while iter.next(extra) do
		extra.isToPrint := false;
	endwhile;

	self.myReportRunner.lblHeading2.caption := null;
	self.myReportRunner.txtDetail.text := null;
	self.myReportRunner.txtBuyer.text := null;
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="run" id="6ea9fca1-0973-45ec-8f19-eedf683a74a2">
        <updating/>
        <source>run(_fromPrint : Boolean) updating;

vars

begin

	if _fromPrint and self.allHeaders.size &gt; 0 then
		return;
	endif;

	self.myFilterClass.clear();
	self.myFilterClass.setFromAgent(self.myReportRunner.myReportAgent);
	if self.myFilterClass.getMyVoyageGlobal &lt;&gt; null then
		self.initFrame();
/*		self.myReportRunner.lblHeading1.caption := 'Ship Number .. ' &amp; (self.myFilterClass.myVoyageGlobal.code &amp; ' ' &amp;
		self.myFilterClass.myVoyageGlobal.vesselName).toUpper &amp;
		'             Sail date .. ' &amp; self.myFilterClass.myVoyageGlobal.loadEndDT.Date.format("dd.MM.yy");*/
		self.loadData();
	endif;
	
end;</source>
        <Parameter name="_fromPrint" type="Boolean"/>
    </JadeMethod>
</Class>
