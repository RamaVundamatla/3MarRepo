vars
	cap : String;
begin

	if self.updateMode = self.Mode_Add then
		cap := app.getErrorString(Request_internal_move);
	else
		cap := app.getErrorString(Edit_move_job);
	endif;

	
	self.setCaption(cap);
epilog

end;</source>
