    <JadeMethod name="btnDoFilter_click" id="abc251eb-6299-4330-953e-30a9150023a8">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDoFilter_click(btn: Button input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 20/10/2020	jlgdap1		Initial creation TFS 50193 PRP VBS Error: 14025 Maximum Number of ListBox entries exceeded
//
vars
	regNumber : String;
	vehicle, filterVehicle : CM_Vehicle;

begin
	regNumber := self.txtVehicle.text.trimBlanks;
	if regNumber = Any_String.toUpper then
		self.myFilterVehicle := null;
	elseif regNumber &lt;&gt; null then
		if self.myFilterVehicle = null or self.myFilterVehicle.regNumber &lt;&gt; regNumber then
			if self.myFilterDriver &lt;&gt; null then
				foreach vehicle in self.myFilterDriver.allVehicleMachines discreteLock do
					if vehicle.regNumber = regNumber then
						filterVehicle := vehicle;
						break;
					endif;
				endforeach;
			else
				filterVehicle := self.myTerminal.vehicles[regNumber, null];
			endif;
			self.myFilterVehicle := filterVehicle;
		endif;
	endif;
	self.doRefreshBookings();
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
