// cnwrs1 CCMS 1882 03 June 2010
//
vars
//	ediBookRefTIObj	: CM_EDIBookingRefTI;
//	tmpStr : String;
begin
//	ediBookRefTIObj	:=	self.getEDIBookingRefTI();
//	if ediBookRefTIObj &lt;&gt; null then
//		tmpStr	:=	ediBookRefTIObj.commodityDescription;
//	endif;
	return self.ediCommodityDescription;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEarliestReceivalTSLocalTZ" id="fc707267-2f58-4298-931c-d133492cb45a">
        <source>getEarliestReceivalTSLocalTZ() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2016	cnwns1	Initial creation
