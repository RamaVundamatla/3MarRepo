    <JadeMethod name="clearEditControls" id="863dc669-89f5-4ddf-ac62-93a38710e1eb">
        <updating/>
        <source>clearEditControls() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/07/2013	cnwndl1	Initial creation	Par 31965
27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
*/

vars

begin

	delete self.myProxyObject;	// delete any pre-existing proxy.

	self.lblHoldNum.enabled := false;
	self.txtHoldNum.enabled := false;
	self.txtHoldNum.text := null;
	self.lblLocationNum.enabled := false;
	self.txtLocationNum.enabled := false;
	self.txtLocationNum.text := null;
	self.lblLocationName.enabled := false;
	self.txtLocationName.enabled := false;
	self.txtLocationName.text := null;
	self.lblIsOnDeck.enabled := false;						// PAR #36766
	self.chkIsOnDeck.enabled := false;						// PAR #36766
	self.chkIsOnDeck.value := false;						// PAR #36766
	self.lblMaxWeight.enabled := false;						// PAR #36766
	self.txtMaxWeight.enabled := false;						// PAR #36766
	self.txtMaxWeight.text := null;							// PAR #36766
	self.lblMaxVolume.enabled := false;						// 19/7/16 cnwmp6 TFS 1601
	self.txtMaxVolume.enabled := false;						// 19/7/16 cnwmp6 TFS 1601
	self.txtMaxVolume.text := null;							// 19/7/16 cnwmp6 TFS 1601
	self.lblMaxHeight.enabled := false;	//07 Feb 2017	NDL	TFS 3216					
	self.txtMaxHeight.enabled := false;	//07 Feb 2017	NDL	TFS 3216					
	self.txtMaxHeight.text := null;	//07 Feb 2017	NDL	TFS 3216	
	self.lblOnShipCrane.enabled := false;					// 12/7/16 cnwmp6 TFS 1601
	self.cmbOnShipCrane.enabled := false;					// 12/7/16 cnwmp6 TFS 1601
	self.cmbOnShipCrane.listIndex := 1;						// 12/7/16 cnwmp6 TFS 1601
	self.tblItems.enabled := true;

	self.tblItems.selectMode := Table.SelectMode_None;
	
	self.btnDelete.enabled := false;
	self.btnSave.enabled := false;
	self.btnSort.enabled := not self.btnSave.enabled;	//03 Feb 2017	NDL	TFS 3216/3047
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
