    <JadeMethod name="translateForm" id="b96ea50c-46cb-42d6-a807-f2b58399bece">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 16 November 2023 15:54:53.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019407, locale);
	grpResourceGroups.translateCaption(Xlat_0026571, locale);
	lblAutoActions.translateCaption(Xlat_0021317, locale);
	lblCopies.translateCaption(Xlat_0023153, locale);
	lblMoveComplete.translateCaption(Xlat_0021318, locale);
	lblMoveCreate.translateCaption(Xlat_0021319, locale);
	lblPrinter.translateCaption(Xlat_0023154, locale);
end;</source>
    </JadeMethod>
