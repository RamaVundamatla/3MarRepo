    <ImplicitInverseRef name="myCalendar" id="7bac12d6-bfb5-442c-a6ba-be1043f54b59">
        <embedded/>
        <type name="CM_Calendar"/>
    </ImplicitInverseRef>
    <JadeMethod name="displayEntry" id="0e123091-a993-4689-9cb8-d8b7f6fb9b02">
        <controlMethod name="ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>displayEntry(combobox: ComboBox input; _calendarYear: CM_CalendarYear; lstIndex: Integer): String updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:     31 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	if _calendarYear = null then 
		return null;
	endif;

	return _calendarYear.year.String;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="_calendarYear" type="CM_CalendarYear"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCollectionJMT" id="86a71a13-913f-4b3a-96ff-c4ae451a5f3d">
        <source>getCollectionJMT(): Collection protected;
// ---------------------------------------------------------------------------
// Created:     31 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.myCalendar &lt;&gt; null then 
		return self.myCalendar.allCalendarYears;
	else
		return null;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Collection"/>
    </JadeMethod>
