    <JadeMethod name="setPrinterDocumentType" id="24305844-2664-4d5e-863d-6586868fd81b">
        <executionLocation>client</executionLocation>
        <source>setPrinterDocumentType(_closePrinter : Boolean) clientExecution;
/*

Purpose:			


Return Value:		


Date		Who		Reason
06 May 2008	cnwer1	Initial creation - PAR#16671
17/01/2011	cnwmh5	#26743 - Jade returns an error if you try to set the document type to Print_Custom_Paper (256).  
					This method has been changed so that if the default printers document type is Print_Custom_Paper then
					it sets it to the Jade default of Print_A4.
07/04/2021	navmd1	Make this method clientExection (as Printer methods can only be executed on a client node. From JADE 2018 onwards, they are all marked as clientExecution anyway)
					So I stop crashing the RAP when I mark a script as serverExecution!
*/
vars
	errorNumber : Integer;
	errorText 	: String;
	docType 	: Integer;
begin
	on Exception do app.alertExceptionHandler(exception, null, 'Initializing app.printer document type', errorNumber, errorText, false, false);
	
	if app.printer &lt;&gt; null and app.printer.getPrinterName &lt;&gt; null then //par 15837 cnwrs1 Feb 2008 apps with printer were failing
		
		//epr par 28246 26/9/11 was setting the docType back to the printer default we don't want to do this because it
		// stops the user from changing the paper size
		docType :=app.printer.documentType;
		if docType = Print_Custom_Paper then
			docType := Print_A4;
		endif;
		app.printer.documentType := docType;
		if _closePrinter then
			app.printer.close;
		else
			app.printer.abort;
		endif;
		// 17/01/2011 cnwmh5 #26743 - End
	endif;
	
epilog

end;</source>
        <Parameter name="_closePrinter" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setSpecial" id="22228033-d683-43a0-b4b8-e9560f448d53">
        <updating/>
        <source>setSpecial(_num: Any) updating;
// ---------------------------------------------------------------------------
// Created:     18 April 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	idx		: Integer;
	tmpForm	: Form;

begin
	inheritMethod(_num);

	// need to reset the CM_BaseForm menus to enable the
	// special user functions
	
	// Background apps fell over. XML agent especially
	if	app.isBackGroundApp or // Par 12820
		app.applicationType = Application.ApplicationType_Non_GUI then
		return;
	endif;
	
	foreach idx in 1 to app.formsCount do
		tmpForm := app.forms(idx);
		if (not tmpForm.visible) then
			continue;
		endif;
		if (not CM_BaseForm.hasInstance(tmpForm)) then
			continue;
		endif;
		tmpForm.CM_BaseForm.setMenus();
	endforeach;

end;</source>
        <Parameter name="_num" type="Any"/>
    </JadeMethod>
    <JadeMethod name="setStatusLineCaption" id="511d2d5a-683c-49af-af63-6613d4cb2a1d">
        <source>setStatusLineCaption(pMsg: String);
// ---------------------------------------------------------------------------
// Created:     12 March 2001 by cnwrs2
//
// Purpose:     Displays the message on the status line.  Should be overridden
//				at sub-schema level for application specific
//
// Parameters:  The message to display on the status line.
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if app.mainForm &lt;&gt; null then
