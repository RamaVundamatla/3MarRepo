begin

	tmpStr := self.mainExtraGetValue(pTblMain, pTblExtra, pFieldName).String;
	if tmpStr.trimRight = null then
		pIntFaceObject.setPropertyValue(pFieldName, pNullValue);
	else
		pIntFaceObject.setPropertyValue(pFieldName, tmpStr.Integer);
	endif;

end;</source>
