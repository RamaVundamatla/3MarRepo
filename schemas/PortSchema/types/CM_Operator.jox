    <JadeMethod name="getAllLocationRestrictions" id="22e4a55b-b77e-4b02-acd5-3d3a70617840">
        <source>getAllLocationRestrictions():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 January 2014	cnwndl1	Initial creation	Par 33264

*/

vars

	restrict : CM_Restriction;
	str : String;

begin

	foreach restrict in self.allLocationRestrictions do
		if not restrict.isKindOf( CM_LocationRestriction ) then
			continue;
		endif;
		if str &lt;&gt; null then
			str := str &amp; ",";
		endif;
		str := str &amp; restrict.CM_LocationRestriction.id;
	endforeach;
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
