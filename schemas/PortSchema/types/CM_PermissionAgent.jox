    <JadeMethod name="getMaxConstValue" id="fb9ae3ac-d536-40e5-abe3-f09d48321c02">
        <source>getMaxConstValue() : Integer;
// ---------------------------------------------------------------------------
// Created:     05 April 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	permObj	: CM_PermissionObject;
begin

	permObj := self.allPermissionsByConstValue.last;
	if permObj = null then
		return 0;
	endif;
	return permObj.constValue;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMaxModuleNumber" id="13979b1b-1504-472c-971c-3e3d3f782a43">
        <source>getMaxModuleNumber():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 June 2020	jlgndl1	Initial creation	TFS 49569

*/

vars

	category : ConstantCategory;
	constant : Constant;
	permObj : CM_PermissionObject;
	permType : Integer;
	permValue : Integer;
	maxNumber: Integer;

begin

	category := currentSchema.getCategory(XLAT_Permissions);
	
	foreach constant in category.getConstants do
		create permObj transient;
		permObj.setFromXML(constant);
		permType := permObj.permType;
		if permType = 2 or permType = 4 then	//PermType_Special or PermType_Subscriptions
			permValue := permObj.constValue.Integer;
			if permValue &gt; maxNumber then
				maxNumber := permValue;
			endif;
		endif;
		delete permObj;
	endforeach;
	
	return maxNumber;

epilog

	delete permObj;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getPermDictWithoutNumbers" id="7f39dd9f-9ade-4518-837c-268b893e2752">
        <source>getPermDictWithoutNumbers(_permDict : Collection input; _skipInternal : Boolean);
// ---------------------------------------------------------------------------
// Created:     22 November 2004 by cnwrs2
//
// Purpose:     Returns the dict passed in populated with the
//				license permission without the constants used
//				for determining number of terminals
// ---------------------------------------------------------------------------
vars
	permObj		: CM_PermissionObject;
	tmpValue	: Integer;

begin

	_permDict.clear;
	foreach permObj in self.allPermissionsByName do
		tmpValue := permObj.constValue;
		if tmpValue = Mod_BaseView or
		   tmpValue = PmNum01 or
		   tmpValue = PmNum02 or
		   tmpValue = PmNum03 or
		   tmpValue = PmNum04 or
		   tmpValue = PmNum05 or
		   tmpValue = PmNum06 or
		   tmpValue = PmNum07 or
		   tmpValue = PmNum08 or
		   tmpValue = PmNum09 or
		   tmpValue = PmNum10 then
			continue;
		endif;
		if _skipInternal then	//09 Oct 2019	NDL	TFS 46169
			if tmpValue = PmSite or
				tmpValue = PmAdmInternal then
				continue;
			endif;
		endif;
		_permDict.add(permObj);
	endforeach;

end;</source>
        <Parameter name="_permDict" type="Collection" usage="input"/>
        <Parameter name="_skipInternal" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getPermNumbersForType" id="d144660b-53e1-4c77-94d6-e5e764961edf">
        <source>getPermNumbersForType(_type : Integer; _intArray : IntegerArray input);
// ---------------------------------------------------------------------------
// Created:     26 February 2003 by cnwrs2
//
// Purpose:     Where _type is 	0 = PermType_Terminal	- Terminal Permission
//								1 = PermType_System		- System Permission
//								2 = PermType_Special	- licensing
//
// ---------------------------------------------------------------------------
vars
	permObj : CM_PermissionObject;
	
begin

	_intArray.clear;
	
	foreach permObj in self.allPermissionsByConstValue do
		if permObj.permType = _type then
			_intArray.add(permObj.constValue);
		endif;
	endforeach;

end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_intArray" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getPermissionValues" id="d3334a32-64c3-44fc-aa0f-f7f5ff44eeca">
        <source>getPermissionValues(_permissions : BooleanArray input; _isSystemPerm, _isInternalOnly : Boolean);
// ---------------------------------------------------------------------------
// Created:     20 February 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	permObj : CM_PermissionObject;
	
begin
	_permissions.clear;
	foreach permObj in self.allPermissionsByConstValue do
		if permObj.isInternal and (not _isInternalOnly) then
			_permissions[permObj.constValue] := false;
		else
			if _isSystemPerm and permObj.isSystemPermission or
			   (not _isSystemPerm and not permObj.isSystemPermission) then 
				_permissions[permObj.constValue] := permObj.permValue;
			else
				_permissions[permObj.constValue] := false;
			endif;
		endif;
	endforeach;

end;</source>
        <Parameter name="_permissions" type="BooleanArray" usage="input"/>
        <Parameter name="_isSystemPerm" type="Boolean"/>
        <Parameter name="_isInternalOnly" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getPermissionsForFilter" id="bc66c726-868a-415c-9ce4-cb75cb6b34ff">
        <source>getPermissionsForFilter(_collection : Collection input; 
						_filter: String; 
						_context : Integer );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 January 2018	jlger1	Initial creation 36402
05 Feb 2021	NDL	TFS 50757

*/

vars
	iter : Iterator;
	permission : CM_PermissionObject;
	filterToUpper : String;
begin
	if _context = 0 or _context &gt; FilterText then
		return;
	endif;
	if _collection = null then
		return;
	endif;
	if _filter = null then
		return;
	endif;
	iter := self.allPermsByCategoryDescrName.createIterator();	
	while iter.next(permission) do
		if _context = FilterHandHeld then
			if permission.allHandheldApps.includes(_filter) then
				_collection.add(permission);
			endif;
		elseif _context = FilterMobileApps then
			if permission.allMobileApps.includes(_filter) then
				_collection.add(permission);
			endif;
		elseif _context = FilterWebservices then
			if permission.allWebservices.includes(_filter) then
				_collection.add(permission);
			endif;
		elseif _context = FilterText then	//05 Feb 2021	NDL	TFS 50757
			//exact match on constant name and window name
			if permission.constName = _filter
			or permission.windowClass = _filter
			then
				_collection.add(permission);
				continue;
			endif;
			//partial and case insensitive match on other fields
			filterToUpper := _filter.toUpper;
			if permission.description.toUpper.pos(filterToUpper,1) &gt; 0
			or permission.explanation.toUpper.pos(filterToUpper,1) &gt; 0
			or permission.heading.toUpper.pos(filterToUpper,1) &gt; 0
			then
				_collection.add(permission);
				continue;
			endif;
		endif;
		
	
	endwhile;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_filter" type="String"/>
        <Parameter name="_context" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSpecificPermissionsToRemove" id="b698330c-f9b1-4a6e-a6e5-476548546b81">
        <source>getSpecificPermissionsToRemove(	_menuPermissions	: IntegerArray input;
								_permissions		: IntegerArray input);
								
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Sep 2012	cnwpjs1	Initial creation  PAr #30391
14 May 2013 cnwpjs1 PAr # 31475

*/

vars

begin


	// if root has not been setup then called via an app not currently relevant to
	// this process

	if app.myRoot = null then 
		return;
	endif;

	_permissions.add(PmMobDeliveryDispatchAppOnly);		// TFS 63668 hack for release 04 - exclude this for EVERYONE
	
	if app.myRoot.isClientJadeMaster then
		return;
	endif;

	//*** PORT OTAGO ONLY ***
	if  not app.myRoot.isClientPortOtago then
	
		// Container and hatch summery 
		_menuPermissions.add(PmAdmCandhsummaryView);
		
		_permissions.add(PmAdmCandhsummaryView);
		_permissions.add(PmAdmCandhsummaryMaint);	//03 Jan 2019	NDL	TFS 42729
		
	endif;
	
	
	// 31475 - allow for all users again
	/*
	//*** PORT NELSON ONLY ***
	if  not app.myRoot.isClientPortNelson then
	
		// TBA List
		_menuPermissions.add(PmAdmTbalistView);
		
		_permissions.add(PmAdmTbalistView);
		_permissions.add(PmAdmTbalistMaint);
	//	permissions.add(PmAdmTbainputView);	// ??
	//	permissions.add(PmAdmTbainputMaint); // ??
	
	endif;
	*/
	
epilog

end;</source>
        <Parameter name="_menuPermissions" type="IntegerArray" usage="input"/>
        <Parameter name="_permissions" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="isSystemPermission" id="6632e3bd-cc67-478a-910a-ef3c924c771b">
        <source>isSystemPermission(_idx : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:     21 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	permObj	: CM_PermissionObject;

begin

	permObj := self.allPermissionsByConstValue[_idx];
	if permObj = null then
		return false;
	endif;
	
	return permObj.isSystemPermission;

end;</source>
        <Parameter name="_idx" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populatePermissionDict" id="abae48be-9afa-477d-be34-0a19b9b5fd9c">
        <source>populatePermissionDict(_format, _checkChild : Boolean; _context : Integer );
// ---------------------------------------------------------------------------
// Created:     20 May 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  _format - true = types PermType_Terminal and PermType_System
//						- false = type PermType_Special
//				wording deliberately kept vague for security
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26 Sep 12	cnwpjs1		PAr # 30391 Voyage Rationlisation
// ---------------------------------------------------------------------------
vars
	category 	: ConstantCategory;
	constant 	: Constant;
	permObj 	: CM_PermissionObject;
	permCategory	: String;
	tmpUser		: CM_User;
	tmpChildValue	: Integer;
	tmpCanDo,
	inLS : Boolean;
	menuPermissions	: IntegerArray;
	permissions		: IntegerArray;
	
begin
	app.cmsBeginLoad(inLS);
	
	tmpUser := app.getMyUser();
	
	// ar # 30391
	create menuPermissions transient;
	create permissions transient;
	getSpecificPermissionsToRemove(menuPermissions,permissions);
	
	category := currentSchema.getCategory(XLAT_Permissions);		

	foreach constant in category.getConstants do
		create permObj transient;
		permObj.setFromXML(constant);

	//	if _context &lt; 1 and _format and permObj.permType = 2 then				// show PermType_Terminal and PermType_Special
		if _context &lt; 1 and _format and permObj.permType &gt;= 2 then	//09 July 2020	NDL	TFS 49569
			delete permObj; 
			continue;
		// ### JIRA 33501 04DEC2024 NAVAB1
		elseif _context = 55 then 
			if (not _format) and not permObj.permType.isOneOf(2,4) then		// show PermType_Special 
				delete permObj;  
				continue; 
			endif; 
			// ### JIRA 33501 04DEC2024 NAVAB1 - hide unwanted modules
			if permObj.constValue = PmHMSResource 
			or permObj.constValue = Mod_EventStream then
				delete permObj;  
				continue; 
			endif; 
		elseif _context &lt; 1 and (not _format) and permObj.permType &lt;&gt; 2 then		// show PermType_Special
			delete permObj; 
			continue;
			
		elseif _context &gt; 0 and permObj.permType &lt;&gt; _context then	//16 Jun 2020	NDL	TFS 49569
			delete permObj; 
			continue;
		//Par # 30391 remove those not valid for this site
		elseif permissions.includes(permObj.constValue) then
			delete permObj;
			continue;
		endif;
	
			
		if tmpUser &lt;&gt; null and _format and _checkChild then
			// remove the permissions that the user is not licensed to see
			tmpCanDo := false;
			foreach tmpChildValue in permObj.allChildValues do
				
				if tmpUser.canDo(null, tmpChildValue) then
					tmpCanDo := true;
					break;
				endif;
			endforeach;
			
			if (not tmpCanDo) then
				delete permObj; 
				continue;
			endif;
		endif;

		permObj.myPermissionAgent := self;
		
		permCategory := permObj.category;
		if permCategory &lt;&gt; null then
			if permObj.isSystemPermission then
				if (not self.allSystemCategories.includes(permCategory)) then
					self.allSystemCategories.add(permCategory);
				endif;
			else
				if (not self.allTerminalCategories.includes(permCategory)) then
					self.allTerminalCategories.add(permCategory);
				endif;
			endif;
		endif;
	endforeach;	
	
epilog

	delete menuPermissions;
	delete permissions;
	app.cmsEndLoad(inLS);
end;</source>
        <Parameter name="_format" type="Boolean"/>
        <Parameter name="_checkChild" type="Boolean"/>
        <Parameter name="_context" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setAllPermissionValues" id="a774107a-9c57-4f01-acbb-1d14c53bd415">
        <source>setAllPermissionValues(_value : Boolean);
// ---------------------------------------------------------------------------
// Created:     20 February 2003 by cnwrs2
//
// Purpose:
// 30 September 2022	navkc1	Initial creation - ChangeRequest #54463: MTN - Subscription License, New Feature Support Phase 1
// 16 Deceomber 2022	navkc1	Bug 55872: MTN - Advanced Maintenance permission not working on deployment
// 22 January 2023		jlizm1	TFS 62072 Advanced damage license changes
// ---------------------------------------------------------------------------
vars
	permObj : CM_PermissionObject;
	obj		: Object;
	tmpChildValue	: Integer;
	tmpPermValue,
	tmpValue	: Boolean;
begin

	obj := app.myCheckerObject;

	if obj = null then
		tmpValue := false;
	else
		tmpValue := _value;
	endif;

	foreach permObj in self.allPermissionsByConstValue do
		if tmpValue then
			// need to check that permission is licensed.
			if app.isConverting then
				permObj.permValue := true;
			else
				if permObj.constValue &gt; Mod_BaseView then
					
					//permObj.permValue := obj.sendMsgWithParams('isLicensed', app.myRoot.licenseName, 'JMT', permObj.constValue).Boolean;
					//need to use the sys/terminal combined value
					permObj.permValue := app.myRoot.canDo(permObj.constValue);
				else
					//tmpPermValue := obj.sendMsgWithParams('isLicensed', app.myRoot.licenseName, 'JMT', permObj.childValue - PmAdmBaseView).Boolean;
					tmpPermValue := false;
					foreach tmpChildValue in permObj.allChildValues do
						//tmpPermValue := obj.sendMsgWithParams('isLicensed', app.myRoot.licenseName, 'JMT', tmpChildValue - PmAdmBaseView).Boolean;
						//need to use the sys/terminal combined value
						tmpPermValue := app.myRoot.canDo(tmpChildValue);
						if tmpPermValue then
							break;
						endif;
					endforeach;
					
					permObj.permValue := tmpPermValue;
				endif;
			endif;
			
		else
			//permObj.permValue := tmpValue;
			permObj.permValue := false;
		endif;
	endforeach;
	
	
end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setInvoiceStatuses" id="aec2f981-6637-4938-b670-f82e79f56dc2">
        <source>setInvoiceStatuses(_terminal : CM_Terminal);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2019	jlgab1	Initial creation

*/

vars

	user : CM_User;
	userTerm : CM_UserTerminal;
	invStatus : CM_InvoiceStatus;
begin
	self.allInvoiceStatusesMaint.clear;
	
	user := app.getMyUser();
	if user = null then
		return;
	endif;
		
	userTerm := user.getUserTerminal(_terminal);
	if userTerm = null then
		return;
	endif;
	
	if userTerm.mySecurityRole = null then
		return;
	endif;
	
	userTerm.mySecurityRole.allInvoiceStatusesMaint.copyNoDuplicates( self.allInvoiceStatusesMaint, false);



epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setPermissionValuesFromRole" id="627c6cc2-6c07-4459-af04-4c95a1c7a9e2">
        <source>setPermissionValuesFromRole(_role, _parentRole : CM_SecurityRole);
// ---------------------------------------------------------------------------
// Created:     20 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	permObj			: CM_PermissionObject;
	permCategory	: String;
	tmpValue		: Boolean;
	ls : Boolean;
begin

	self.allSystemCategoriesForRole.clear;
	self.allTerminalCategoriesForRole.clear;
	
	app.cmsBeginLoad(ls);
	
	foreach permObj in self.allPermissionsByConstValue do
	
		permObj.permValue := (_role &lt;&gt; null) and 
							(permObj.constValue &lt;= _role.permissions.size) and 
							(_role.permissions[permObj.constValue]);


		tmpValue := (_parentRole &lt;&gt; null) and 
					(permObj.constValue &lt;= _parentRole.permissions.size) and 
					(_parentRole.permissions[permObj.constValue]);

		if (not tmpValue) then
		   	continue;
		endif;

		permCategory := permObj.category;
		if permCategory &lt;&gt; null then
			if permObj.isSystemPermission then
				if (not self.allSystemCategoriesForRole.includes(permCategory)) then
					self.allSystemCategoriesForRole.add(permCategory);
				endif;
			else
				if (not self.allTerminalCategoriesForRole.includes(permCategory)) then
					self.allTerminalCategoriesForRole.add(permCategory);
				endif;
			endif;
		endif;
	endforeach;
epilog
	app.cmsEndLoad(ls);
end;</source>
        <Parameter name="_role" type="CM_SecurityRole"/>
        <Parameter name="_parentRole" type="CM_SecurityRole"/>
    </JadeMethod>
    <JadeMethod name="showPermDetails" id="faa75adf-be54-4d14-8b34-53af97b7e284">
        <source>showPermDetails(_caption : String; _permsToShow : IntegerArray; _user : CM_User; _terminal : CM_Terminal);
// ---------------------------------------------------------------------------
// Created:     12 March 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	permsDict	: CM_PermissionObjectByNameDict;
	permObj		: CM_PermissionObject;
	idx			: Integer;
	str			: String;
	permsForm	: CMS_ViewPermissions;

begin

	app.mousePointer := Window.MousePointer_HourGlass;

	if self.allPermissionsByConstValue.isEmpty then
		self.populatePermissionDict(true, true, 0);
	endif;

	create permsDict transient;
	
	foreach idx in _permsToShow do
		permObj := self.allPermissionsByConstValue[idx];
		if permObj &lt;&gt; null and (not permsDict.includes(permObj)) then
// TFS 2198			if _user.canDo(_terminal, permObj.constValue) then
				permsDict.add(permObj);
//			endif;
		endif;
	endforeach;

	
	if permsDict.isEmpty then
		str := 'No permissions to show';
		app.msgBox(str, XLAT_Permissions, MsgBox_OK_Only);
	else
		create permsForm transient;
		permsForm.setMyTerminal(app.getMyTerminalDO_NOT_USE());
		permsForm.init(_caption, permsDict, self);// TFS 39618 
		app.mousePointer := Window.MousePointer_Default;
		permsForm.showModal();
	endif;
	
epilog
	delete permsDict;
	delete permsForm;
	app.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="_caption" type="String"/>
        <Parameter name="_permsToShow" type="IntegerArray"/>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="trxSaveDataToGlobalConstants" id="d05c47e7-870c-4f7b-a5f3-712cdfde784f">
        <source>trxSaveDataToGlobalConstants(_permObj : CM_PermissionObject);
// ---------------------------------------------------------------------------
// Created:     20 May 2002 by cnwth2
//
// Purpose:		Add a single permission constant to the system if adding otherwise if constant already exists     
//						just change the text. 						
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	baseScm 	: Schema;
	category 	: ConstantCategory;
	const 		: Constant;
	constDict	: ConstantNDict;
	constName,
	rtnStr,
	constantStr	: String;
	result			: Integer;	

begin
	
	category := currentSchema.getCategory(XLAT_Permissions);		
	constDict := category.getConstants();

	constName := _permObj.constName;
	const := constDict[constName];
	if const &lt;&gt; null then
		app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '  updating constant text for ' &amp; constName);	   	
		beginTransaction;
		const.setText(_permObj.constText);

		// RBarr 1/9/2006 Localisation changes - update translatable text object for edited permission
		_permObj.createTranslatableTextItem;

		commitTransaction;
		return;
	endif;
	
	constantStr := constantStr &amp; CrLf &amp; 
		Tab &amp; _permObj.constName &amp; ':' &amp; Tab &amp; "Integer = " &amp; _permObj.constValue.String &amp; ";" &amp; CrLf &amp;
		Tab &amp; 'documentationText' &amp; CrLf &amp;
		'`' &amp;  _permObj.constText &amp; '`' &amp; CrLf &amp; CrLf;

	app.writeStatement(constantStr &amp; class.name &amp; '::' &amp; method.name &amp; '  New constant created : (' &amp; constName &amp; ')');

	app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '  attempting to load missing global constants');	   	
	result := global.addConstantsServer(XLAT_Permissions, constantStr, rtnStr);

	if result &lt;&gt; 0 then
		app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' ERROR in loading new global constants (' &amp; result.String &amp; ')');
		app.writeStatement( rtnStr);
		app.writeStatement( '&lt;end of error text&gt;');
		app.msgBox('!!Data Not Saved!!', '!!Error!!', MsgBox_OK_Only);
	else
//		app.msgBox('Data Saved', '', MsgBox_OK_Only);
		app.writeStatement( rtnStr &amp; class.name &amp; '::' &amp; method.name &amp; '  load of missing global constants appears to be successful');	   	
	endif;

	// RBarr 1/9/2006 Localisation changes - create a translatable text object for new permission
	beginTransaction;
	_permObj.createTranslatableTextItem;
	commitTransaction;

	
end;</source>
        <Parameter name="_permObj" type="CM_PermissionObject"/>
    </JadeMethod>
    <JadeMethod name="updateWebserviceHandheldRefs" id="c275199a-2706-4879-86c0-09d9b586c0c1">
        <source>updateWebserviceHandheldRefs();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 January 2018	jlger1	Initial creation 36402

*/

vars
	permission : CM_PermissionObject;
	hasRefs : Boolean;
begin
	foreach permission in self.allPermissionsByName discreteLock do

		if permission.myConstant = null then
			continue;
		endif;
		hasRefs :=permission.updateWebserviceHandheldRefs;
		beginTransaction;
			if hasRefs then
				permission.myConstant.setText(permission.outputAsXML);
			else
			//	permission.myConstant.setText(null);
			endif;
		commitTransaction;
	endforeach;
epilog

end;</source>
    </JadeMethod>
