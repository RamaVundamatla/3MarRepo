    <JadeMethod name="utlUpdateMachineNextQueue" id="42fdc2b2-cad2-44fe-abc3-671d623fb5cb">
        <source>utlUpdateMachineNextQueue(_proxyMachine : CM_Machine; _nextQueue : CM_RadioTelemetryQueue;_passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 September 2009	cnwer1	Initial creation PAR#20739

*/

vars
	realMachine : CM_Machine;
	expectedEdition : Integer;
	terminal : CM_Terminal;
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);

	_proxyMachine.pxyGetRealObjectAndEdition(realMachine, expectedEdition);
	
	if realMachine = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Machine.name, null, null);
		return;
	endif;

	if _nextQueue &lt;&gt; null then
		app.myValUA.valMachineQueue(_proxyMachine, _nextQueue);
	endif;
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);
	
	exclusiveLock(realMachine);
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realMachine, true);
	endif;
	
	realMachine.setMyNextPrimaryQueue(_nextQueue);
	
	terminal := realMachine.myTerminal;
	if terminal &lt;&gt; null then
		realMachine.causeEvent(terminal.getTerminalEvent(RTMachine_Update_Event), false, null);
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realMachine, false);
	endif;
epilog

end;</source>
        <Parameter name="_proxyMachine" type="CM_Machine"/>
        <Parameter name="_nextQueue" type="CM_RadioTelemetryQueue"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
