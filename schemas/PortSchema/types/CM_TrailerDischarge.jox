    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="26bf26d9-d1de-4a3a-a4b1-274aa2edeb9d">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_TITransactionController; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 November 2020	jlgndl1	Initial creation

*/

vars

begin

	inheritMethod(_tiTransCntrl, _passport);
	
	if _tiTransCntrl.myVVR &lt;&gt; null then
		self.trailerTypeCode := _tiTransCntrl.myVVR.getTrailerTypeCode( self );
	endif; 

epilog

end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setOtherTrackedItem" id="9fed3ed6-ed5d-42cc-91d1-97349187e521">
        <updating/>
        <source>setOtherTrackedItem(pTI: CM_TrackedItem) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 09 February 2024
TFS#		: 62215
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
begin
	self.otherTrackedItemID := pTI.id;
end;</source>
        <Parameter name="pTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setTrailerTypeCode" id="ef1621a7-e388-4bbb-a8a7-e9fc58361f93">
