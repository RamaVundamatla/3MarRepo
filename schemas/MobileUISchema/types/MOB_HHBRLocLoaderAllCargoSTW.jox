    </JadeMethod>
    <JadeMethod name="showWeights" id="b6cc1c32-9a5a-4416-abef-7ec8eec6097f">
        <source>showWeights();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2014	cnwndl1	Initial creation	Par 34717 / CCMS 2384

*/

vars

	ti : CM_TrackedItem;
	weight : Decimal[14,4];
	totWeight : Decimal[18,4];
	maxWeightToLoad : Decimal[18,4];
	count : Integer;
	releaseCount : Integer;

begin
	
	if self.myTargetLocation = null then
		lblWeightValue.caption := app.getErrorString(CM_Load_Weight).trimBlanks() &amp; ": ";
		lblCountValue.caption := app.getErrorString(Count) &amp; ": ";
	else
		
		count := self.getQuantityLoaded( totWeight );	//26 Jan 2017	NDL	TFS 3198/2877
		
		lblWeightValue.caption := app.getErrorString(CM_Load_Weight).trimBlanks() &amp; ": " &amp; self.myMobileDataAgent.getMeasureConvertedForDisplay(null,Type_Weight,totWeight) &amp; self.myMobileDataAgent.getMeasureLabelUnit(null,Type_Weight);
		lblCountValue.caption := app.getErrorString(Count) &amp; ": " &amp; count.String;
		
		releaseCount := self.getQuantityToLoad( maxWeightToLoad );
		if releaseCount &gt; 0 then
			lblCountValue.caption := lblCountValue.caption &amp; "/" &amp; releaseCount.String;
		else
			lblCountValue.caption := lblCountValue.caption &amp; "/" &amp; count.String;
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="4321b5ff-2e2b-4ab4-9985-fa1c165a099f">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 March 2019 19:48:43.
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023407, locale);
	btnDocActsLoaded.translateCaption(Xlat_0023409, locale);
	btnDocActsToLoad.translateCaption(Xlat_0023408, locale);
	lblCargoId.translateCaption(Xlat_0023410, locale);
	lblCountValue.translateCaption(Xlat_0023411, locale);
	lblWeightValue.translateCaption(Xlat_0023412, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtCargoId_change" id="633020e2-7ebe-459f-89fe-46b8b1757238">
        <controlMethod name="TextBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_change(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 August 2014	cnwndl1	Initial creation	Par 34717 / CCMS 2384

*/

vars

begin

	//08 Jul 2016	NDL	TFS 2275
	if self.convertedCargoId &lt;&gt; txtCargoId.text then
		self.convertCargoIdForSearch(	txtCargoId.text.toUpper,	//_rawId: String;
										0,	//_cargoType : Integer;
										0,	//_imex : Integer;
										null,	//_voyage : CM_Voyage;
										self.convertedCargoId,	//_convertedCargoId: String output;
										self.convertedAltId	//_convertedAltId: String output
										);
		//txtCargoId.text := self.convertedCargoId;
		self.txtCargoId.text := self.convertedAltId;	//08 Aug 2016	NDL	TFS 2567 - Is used for both cargo id and alternate id, don't truncate to 20
	
	endif;

	self.doFindCargoButton();
	
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtCargoId_gotFocus" id="4fd4997d-3f71-460d-b264-7a841eae563e">
