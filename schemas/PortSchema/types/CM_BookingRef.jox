Parameters:			

Return Value:		

Date		Who		Reason
04 Nov 2020	cnwma1	ChangeRequest 50112: ASPA - GCI Stevedores
29 Jun 2022	navdap1	TFS 53362 EUP Master Data Interface Customers Between TOS and ERP
*/

vars

begin
	if self.myStevedore &lt;&gt; null then
		if app.myRoot.getConfig(ComboByNameStevedore).Boolean then	// TFS 53362
			return self.myStevedore.description;					// TFS 53362
