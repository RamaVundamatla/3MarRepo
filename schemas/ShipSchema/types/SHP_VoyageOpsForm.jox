    <JadeMethod name="doSetRowToDisplayPerTable" id="7fa899c7-4327-4757-8c20-b87da979aff2">
        <updating/>
        <source>doSetRowToDisplayPerTable() updating;
/*

Purpose:			
		This method is called to set the number of rows to display per table
		Set the table sorting to "ID (ascending) only" when we are limiting number of rows
		Reset the table sorting when we are not limiting number of rows.
		
Parameters:			

Return Value:		

Date		Who		Reason
09 December 2022	navkc1	Initial creation ChangeRequest 55409: MTN - Voyage Ops Form - Pagination of tables

*/

vars
	rowsEntered,
	tblFixedRow, idCol	: Integer;
	msg					: String;
	table				: CM_FilterTable;
	tables				: ObjectArray;
	entDef				: EntTableDef;
	entRow				: EntTableRow;
	col					: JadeTableColumn;
	
begin
	
	create tables transient;
	
	tables.add(self.tblOnship);
	tables.add(self.tblOnsite);
	tables.add(self.tblOffsite);
	tables.add(self.tblPreNote);
	
	// We don't want to limit number of rows
	if not self.performLimitNumOfRow then 
		
		self.numOfRowsPerTable := Cn_Max_Table_Rows;
		
		// Go through each table and reset the column sorting
		foreach table in tables as CM_FilterTable do
			tblFixedRow := table.fixedRows;
			
			// If the ID column is blank, remove it. (This happens when user click on "Limit number of rows" checkbox (which added ID column), changed their mind and undo it)
			if table.getColumnByRowName(ETRow_Id) &lt;&gt; null and table.rows - tblFixedRow &gt; 0 then
				idCol := table.getColumnByRowName(ETRow_Id);
				table.accessCell(tblFixedRow + 1, idCol);
				if table.accessedCell.text = null then
					table.deleteColumn(idCol);
					table.allTblDataEntRows.removeAt(idCol);
					table.allTblDataColHeadings.removeAt(idCol);
					table.allTblDataColInputTypes.removeAt(idCol);
					table.allTblDataColPropertyNames.removeAt(idCol);
				endif;
			endif;
			
			table.setSortColumnsForMaxNumCols();
			// Colour table again after sorting to make sure they are correct
			self.colourTableRows(table);
		endforeach;
		return;
	endif;
	
	rowsEntered := self.txtNumOfRow.text.Integer;
	
	// We want to limit number of rows
	if rowsEntered &gt; Cn_Max_Table_Rows then
		msg := "Number of rows cannot exceed 32000. It has been set to 32000.";
		app.msgBox( msg, app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		self.txtNumOfRow.text := Cn_Max_Table_Rows.String;
		self.numOfRowsPerTable := Cn_Max_Table_Rows;
	elseif rowsEntered = null then
		msg := "Number of rows cannot be blank/zero. It has been set to 250";
		app.msgBox( msg, app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		self.numOfRowsPerTable := 250;
		self.txtNumOfRow.text := "250";
	else
		self.numOfRowsPerTable := rowsEntered;
	endif;	
	
	// Clear table sorting and set the to ID (ascending) only
	foreach table in tables as CM_FilterTable do
		table.clearSort();
		
		// If the ID column is blank, remove it. (This happens when user click on "Limit number of rows" checkbox (which added ID column), changed their mind and uncheck it)
		if table.getColumnByRowName(ETRow_Id) = null then
			self.doAddSortIdColumn(table);
		else
			table.sortColumn[1] := table.getColumnByRowName(ETRow_Id);
			table.sortAsc[1] 	:= true;
		endif;
	endforeach;
	
epilog
	delete tables;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSetTransitStatus" id="f4bd3ea8-30fe-4dae-a709-47ac63bfadf8">
        <updating/>
        <source>doSetTransitStatus(_status : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	pxyTI, aTI : CM_TrackedItem;
	theReturn : Integer;
	theTIs : ObjectArray;
	anObj : Object;
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	theTIs := self.tblOnship.allSelectedObjects;
	
	if theTIs.isEmpty  then
		app.msgBox("Please select OnShip cargo to set the transit status on.","Set Transit Status",MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		
		return;
	endif;
	
	foreach anObj in theTIs do : outerLoop
		if anObj = null then
			continue;
		endif;
		delete pxyTI;
		pxyTI := app.createUpdateProxy(anObj.CM_TrackedItem).CM_TrackedItem;
		
		while true do
			app.myTrxUA.trxUpdateTITransitStatus(pxyTI,_status,app.myPassport);
			if not app.myPassport.trxCompletedOK then
				theReturn := app.showErrorWarningDialog("Transit Status Change", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				return;
			endif;
			break;
		endwhile;
	endforeach;

	global.beep;
	
epilog
	app.mousePointer := Window.MousePointer_Default;
	delete pxyTI;
end;</source>
        <Parameter name="_status" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doShowBulkYAForm" id="43bc14a8-a0fd-4c17-9963-4ef1ef109247">
        <source>doShowBulkYAForm(_cntrl : CM_BaseTable; _imex : Integer);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27/08/2025	navdap1		Initial creation MTN-35615 ENS | Bulk Creation of Yard Allocations
//
vars
	selectedTableObjs : ObjectArray;
	obj : Object;
	ti : CM_TrackedItem;
	selectedTIs : CM_TISet;
	bulkYAForm : CMUI_BulkYardAllocations;
	imexStatus : CM_IMEXStatus;
	imexCode : Integer;
	imexDesc : String;

begin
	// What's our imex status?
	if _imex &lt;&gt; null then
		imexStatus := app.myRoot.allImexStatuses[_imex];
		if imexStatus &lt;&gt; null then
			imexCode := imexStatus.code;
			imexDesc := imexStatus.description;
		else
			// No Imex? Don't know what to do
			return;
		endif;
	else
		return;
	endif;
	
	// Now sort out the selected TIs - if any of the selected TIs don't have the appropriate imex status, ignore it
	create selectedTIs transient;
	selectedTableObjs := _cntrl.allSelectedObjects;
	foreach obj in selectedTableObjs do
		ti := obj.CM_TrackedItem;
		if ti.getImExStatus &lt;&gt; imexCode then
			continue;
		endif;
		
		if ti.isCargoGroupItem then
			ti.CM_CargoGroup.allAssignedTrackedItems.copy(selectedTIs);
		else
			selectedTIs.add(ti);
		endif;
	endforeach;
	
	// Nothing selected, or nothing of the appropriate imex status? Just return
	if selectedTIs.isEmpty then
		app.raiseCMException1(No_Cargo_For_Imex_Status, imexDesc, null, null);
		return;
	endif;
	
	bulkYAForm := app.loadForm(CMUI_BulkYardAllocations, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_BulkYardAllocations;
	if bulkYAForm = null then
		return;
	endif;
	
	selectedTIs.copy(bulkYAForm.allTrackedItems);
	bulkYAForm.myImexStatus := imexStatus;
	bulkYAForm.myVoyage := self.myCurrentVoyage;
	bulkYAForm.setParentForm(self);
	bulkYAForm.show();
	
epilog
	delete selectedTIs;
end;</source>
        <Parameter name="_cntrl" type="CM_BaseTable"/>
        <Parameter name="_imex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doSingleTaskComplete" id="63bec248-cf62-4538-8dd8-9d6a83a81004">
        <source>doSingleTaskComplete(	_task : CM_RTQueueTask input;
						_completeAll,
						_completePickupAndSetdown : Boolean;
						_taskMachine,
						_imv : CM_Machine input;
						_moveQuantity : Integer;
						_moveWeight : Decimal) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/01/2015	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394 Voyage Rationalisation
//
vars
	theEntry 	: CM_RTQueueEntry;
	invalidObj 	: Boolean;
	edition,
	result 		: Integer;

begin
	app.mousePointer := MousePointer_HourGlass;
	
	on Exception do app.handleDeletedObject(exception,_task,invalidObj);

	edition:=_task.edition;
	
	if invalidObj then 
		return;
	endif;
	
	// Task can be deleted during process.
	while true do
		app.myTrxUA.trxCompleteRTQueueEntry(_task,_completeAll,_completePickupAndSetdown,_taskMachine,_imv,_moveQuantity, _moveWeight, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog('Complete RT Entry', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			else
				break;
			endif;
		endif;
	endwhile;

epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
        <Parameter name="_task" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_completeAll" type="Boolean"/>
        <Parameter name="_completePickupAndSetdown" type="Boolean"/>
        <Parameter name="_taskMachine" type="CM_Machine" usage="input"/>
        <Parameter name="_imv" type="CM_Machine" usage="input"/>
        <Parameter name="_moveQuantity" type="Integer"/>
        <Parameter name="_moveWeight" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="doStateHorizontal" id="32c557b7-f872-4096-96b9-2cfa2ebca8d5">
        <updating/>
        <source>doStateHorizontal() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 09/12/2014	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394
//
vars

begin
	self.doStateNormal();
	
	// make the "bottom" container invisible so the "top" container defaults to the top position
	self.dkcBottom.visible := false;
	
	// set the alignment on the children
	self.dkcTop.allowDocking := self.dkcTop.AllowDocking_AllHorizontal;
	self.dkcOnShip.alignContainer := self.dkcTop.AlignContainer_AllHorizontal;
	self.dkcOnTerminal.alignContainer := self.dkcTop.AlignContainer_AllHorizontal;
	self.dkcBottom.allowDocking := self.dkcBottom.AllowDocking_AllHorizontal;
	self.dkcOffSite.alignContainer := self.dkcBottom.AlignContainer_AllHorizontal;
	self.dkcPreNotes.alignContainer := self.dkcBottom.AlignContainer_AllHorizontal;
	
	// set the "top" container to the top of the form
	self.dkcTop.top := 0;
	
	// set the children to the correct positions
	self.dkcOnShip.top := 0;
	self.dkcOnTerminal.top := self.dkcTop.clientHeight / 2;
	self.dkcOffSite.top := 0;
	self.dkcPreNotes.top := self.dkcBottom.clientHeight / 2;
	
	// then set the "bottom" container to the bottom of the form and make it visible again
	self.dkcBottom.top := self.dkcMain.height / 2;
	self.dkcBottom.visible := true;
	
	self.doResize();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doStateNormal" id="5920a458-088d-4ae7-aee8-9e2396f64848">
        <updating/>
        <source>doStateNormal() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 09/12/2014	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394
//
vars

begin
	// make the main top container vsible again, if undocking all their children had made them hidden
	// make the bottom container invisible, so that the top container ends up at the top again
	self.dkcTop.visible := true;
	self.dkcBottom.visible := false;
	
	// re-parent any floating windows to re-dock them
	self.dkcOnShip.parent := self.dkcTop;
	self.dkcOnTerminal.parent := self.dkcTop;
	self.dkcOffSite.parent := self.dkcBottom;
	self.dkcPreNotes.parent := self.dkcBottom;
	
	// reposition the top container at the top
	self.dkcTop.top := 0;
	
	// reset the alignment on teh children to vertical
	self.dkcOnShip.alignContainer := self.dkcTop.AlignContainer_AllVertical;
	self.dkcOnTerminal.alignContainer := self.dkcTop.AlignContainer_AllVertical;
	self.dkcOffSite.alignContainer := self.dkcTop.AlignContainer_AllVertical;
	self.dkcPreNotes.alignContainer := self.dkcTop.AlignContainer_AllVertical;
	
	// and the alignment on the parents to horizontal 
	self.dkcTop.alignContainer := self.dkcTop.AlignContainer_AllHorizontal;
	self.dkcBottom.alignContainer := self.dkcBottom.AlignContainer_AllHorizontal;
	
	// reposition the children to their default widths
	self.dkcOnShip.left := 0;
	self.dkcOnTerminal.left := self.dkcTop.width / 2;
	self.dkcOffSite.left := 0;
	self.dkcPreNotes.left := self.dkcBottom.width / 2;
	
	// set the top position of teh main bottom container, and make it visible again
	self.dkcBottom.top := self.dkcMain.clientHeight / 2;
	self.dkcBottom.visible := true;
	
	self.doResize();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doStateVertical" id="a1982254-a234-43a5-b257-ba6f82f1ab9b">
        <updating/>
        <source>doStateVertical() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 09/12/2014	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394
//
vars

begin
	self.doStateNormal();
	
	// make the "bottom" container invisible so that the "top" container adopts the left-most position
	self.dkcBottom.visible := false;
	
	self.dkcBottom.allowDocking := self.dkcBottom.AllowDocking_AllVertical;
	self.dkcBottom.alignContainer := self.dkcBottom.AlignContainer_AllVertical;
	
	self.dkcTop.allowDocking := self.dkcTop.AllowDocking_AllVertical;
	self.dkcTop.alignContainer := self.dkcTop.AlignContainer_AllVertical;
	
	// set the "top" container to the left-most position
	self.dkcTop.left := 0;
	
	// set the "bottom" container to the right-most position, and make it visible again
	self.dkcBottom.left := self.dkcMain.width / 2;
	self.dkcBottom.visible := true;
	
	self.doResize();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTableClickNext" id="747b6f05-9afa-42ad-bb83-6039602a0a13">
        <updating/>
        <source>doTableClickNext(_btn: CMUI_NextPrevButton; _table: CM_FilterTable) updating;
/*

Purpose:			
		This method identifies the last item on the table and load the previous # of items defined
		NB. The table must be sorted by ID ascending
Parameters:			

Return Value:		

Date		Who		Reason
12 Dec 2022	navkc1	Initial creation ChangeRequest 55409: MTN - Voyage Ops Form - Pagination of tables
24/02/2024 	navcs2 	MTN-29368 EUP | Transaction Instrumentation - Voyage Discharge
14 Jan 2026 navhl20 Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
*/

vars
	ti				: CM_TrackedItem;
	table			: CM_FilterTable;
	voyage			: CM_Voyage;
	cmifMonitor 	: CMIF_Monitor;
	passport 		: CM_Passport;
	progressStr		: String;
begin
	on Exception do self.handleExceptionVoyage(exception, voyage);
	
	voyage := self.myCurrentVoyage;
	
	if voyage &lt;&gt; null then
		voyage.fetchLatest();
	endif;
	
	if voyage = null then
		return;
	endif;
	
	table := _table;
	
	ti := table.accessRow(table.rows).itemObject.CM_TrackedItem;
	
	passport := app.myPassport;
	
	if passport.myCMIFMonitor = null then
		create cmifMonitor transient;
		cmifMonitor.myParent := self;
		passport.setMyCMIFMonitor(cmifMonitor);
	endif;
	
	self.modalDialogReturnValue := self.ModalDialogReturn_Null;	
	self.modalDialogShow(null, null , null, null, app.getErrorString1(Loading_voyage, voyage.code),  'Please Wait....');
	self.pbProgressBar.visible := false;
	
	if table = self.tblOnship then
		progressStr := app.getErrorString(Loading_onship_cargo);
		cmifMonitor.updateProgress(progressStr, 1, 1);
		self.loadOnShipTable(ti, true);
	elseif table = self.tblOnsite then
		progressStr := app.getErrorString(Loading_onsite_cargo);
		cmifMonitor.updateProgress(progressStr, 1, 1);
		self.loadOnsiteTable(ti, true);
	elseif table = self.tblOffsite then
		progressStr := app.getErrorString(Loading_offsite_cargo);
		cmifMonitor.updateProgress(progressStr, 1, 1);
		self.loadOffsiteTable(ti, true);
	elseif table = self.tblPreNote then
		progressStr := app.getErrorString(Loading_prenotified_cargo);
		cmifMonitor.updateProgress(progressStr, 1, 1);
		self.loadPreNoteTable(ti, true);
	endif;
	
	self.updateStatusBarCounts(false, table);
	
epilog
	delete cmifMonitor;
	app.myPassport.setMyCMIFMonitor(null);
	self.frmModalDialog.visible := false;
	app.mousePointer := self.MousePointer_Default;
end;</source>
        <Parameter name="_btn" type="CMUI_NextPrevButton"/>
        <Parameter name="_table" type="CM_FilterTable"/>
    </JadeMethod>
    <JadeMethod name="doTableClickPrev" id="d122dd1f-1534-4560-9913-d08a1f804677">
        <updating/>
        <source>doTableClickPrev(_btn: CMUI_NextPrevButton; _table: CM_FilterTable) updating;
/*

Purpose:			
		This method identifies the last item on the table and load the next # of items defined
		NB. The table must be sorted by ID ascending
		
Parameters:			

Return Value:		

Date		Who		Reason
12 Dec 2022	navkc1	Initial creation ChangeRequest 55409: MTN - Voyage Ops Form - Pagination of tables
24/02/2024 	navcs2 	MTN-29368 EUP | Transaction Instrumentation - Voyage Discharge
14 Jan 2026 navhl20 Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
*/

vars
	ti				: CM_TrackedItem;
	table			: CM_FilterTable;
	voyage			: CM_Voyage;
	cmifMonitor 	: CMIF_Monitor;
	passport 		: CM_Passport;
	progressStr		: String;
begin
	on Exception do self.handleExceptionVoyage(exception, voyage);
	
	voyage := self.myCurrentVoyage;
	
	if voyage &lt;&gt; null then
		voyage.fetchLatest();
	endif;
	
	if voyage = null then
		return;
	endif;
	
	table := _table;
	
	ti := table.accessRow(table.fixedRows + 1).itemObject.CM_TrackedItem;
	
	passport := app.myPassport;
	
	if passport.myCMIFMonitor = null then
		create cmifMonitor transient;
		cmifMonitor.myParent := self;
		passport.setMyCMIFMonitor(cmifMonitor);
	endif;
	
	self.modalDialogReturnValue := self.ModalDialogReturn_Null;	
	self.modalDialogShow(null, null , null, null, app.getErrorString1(Loading_voyage, self.myCurrentVoyage.code),  'Please Wait....');
	self.pbProgressBar.visible := false;
	
	if table = self.tblOnship then
		progressStr := app.getErrorString(Loading_onship_cargo);
		cmifMonitor.updateProgress(progressStr, 1, 1);
		self.loadOnShipTable(ti, false);
	elseif table = self.tblOnsite then
		progressStr := app.getErrorString(Loading_onsite_cargo);
		cmifMonitor.updateProgress(progressStr, 1, 1);
		self.loadOnsiteTable(ti, false);
	elseif table = self.tblOffsite then
		progressStr := app.getErrorString(Loading_offsite_cargo);
		cmifMonitor.updateProgress(progressStr, 1, 1);
		self.loadOffsiteTable(ti, false);
	elseif table = self.tblPreNote then
		progressStr := app.getErrorString(Loading_prenotified_cargo);
		cmifMonitor.updateProgress(progressStr, 1, 1);
		self.loadPreNoteTable(ti, false);
	endif;
	
	self.updateStatusBarCounts(false, table);
	
epilog
	delete cmifMonitor;
	app.myPassport.setMyCMIFMonitor(null);
	self.frmModalDialog.visible := false;
	app.mousePointer := self.MousePointer_Default;
end;</source>
