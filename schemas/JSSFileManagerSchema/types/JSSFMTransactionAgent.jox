    <DbClassMap file="jssfm_default"/>
    <JadeMethod name="trxCreateBackgroundCopy" id="188f5962-e824-4b33-a0c1-674d08fb9885">
        <source>trxCreateBackgroundCopy(pComputerName:String;
						pSourceNode:String;
						pTargetNode:String;
						pTheRoot:JSSFMRoot;
						pTheBackgroundCopy:JSSFMBackgroundCopy output);
// --------------------------------------------------------------------------------
// Created:		17 September 2002 by cnwdad2
//
// Purpose:		Creates a new Background Copy object.
//
// Parameters:	pComputerName - The name of the workstation.
//				pTheRoot - The owner of the User Profile object.
//				pTheBackgroundCopy - An output parameter for the new Background Copy object.
//
// Returns:		The newly created Background Copy object as an output parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theBackgroundCopy	: JSSFMBackgroundCopy;
	
begin
	self.checkTransactionState();
	
	if self.isDoTransactionState then
		on Exception do self.xHandlerCommon(exception);
	endif;
	
	beginTransaction;
	
	theBackgroundCopy	:=	pTheRoot.createBackgroundCopy(pComputerName, pSourceNode, pTargetNode);
	
	commitTransaction;
	
	pTheBackgroundCopy	:=	theBackgroundCopy;
end;</source>
        <Parameter name="pComputerName" type="String"/>
        <Parameter name="pSourceNode" type="String"/>
        <Parameter name="pTargetNode" type="String"/>
        <Parameter name="pTheRoot" type="JSSFMRoot"/>
        <Parameter name="pTheBackgroundCopy" type="JSSFMBackgroundCopy" usage="output"/>
    </JadeMethod>
    <JadeMethod name="trxCreatePasteFile" id="dac36b87-1ac9-4691-acfe-2a51e1f1a1a9">
        <source>trxCreatePasteFile(	pSourcePath:String;
					pTargetPath:String;
					pNodeOptions:Integer;
					pIsFolder:Boolean;
					pIsCutAndPaste:Boolean;
					pIsSourceUnix:Boolean;
					pIsTargetUnix:Boolean;
					pTheCopy:JSSFMBackgroundCopy;
					pThePasteFile:JSSFMPasteFile output);
// --------------------------------------------------------------------------------
// Created:		17 September 2002 by cnwdad2
//
// Purpose:		Creates a new Paste File object.
//
// Parameters:	pSourcePath - The source path of the files/directories to copy.
//				pTargetPath - The target path of the files/directories to copy.
//				pNodeOptions - The flags to identify the source/target nodes.
//				pIsCutAndPaste - If true, then the original file(s) will be deleted
//					after being copied.
//				pTheCopy - The parent background copy object.
//				pThePasteFile - The newly created paste file object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	thePasteFile	: JSSFMPasteFile;
	
begin
	self.checkTransactionState();
	
	if self.isDoTransactionState then
		on Exception do self.xHandlerCommon(exception);
	endif;
	
	beginTransaction;
	
	thePasteFile	:=	pTheCopy.createPasteFile(	pSourcePath,
													pTargetPath,
													pNodeOptions,
													pIsFolder,
													pIsCutAndPaste,
													pIsSourceUnix,
													pIsTargetUnix);
	
	commitTransaction;
	
	pThePasteFile	:=	thePasteFile;
end;</source>
        <Parameter name="pSourcePath" type="String"/>
        <Parameter name="pTargetPath" type="String"/>
        <Parameter name="pNodeOptions" type="Integer"/>
        <Parameter name="pIsFolder" type="Boolean"/>
        <Parameter name="pIsCutAndPaste" type="Boolean"/>
        <Parameter name="pIsSourceUnix" type="Boolean"/>
        <Parameter name="pIsTargetUnix" type="Boolean"/>
        <Parameter name="pTheCopy" type="JSSFMBackgroundCopy"/>
        <Parameter name="pThePasteFile" type="JSSFMPasteFile" usage="output"/>
    </JadeMethod>
    <JadeMethod name="trxCreateUserProfile" id="89419a3d-f667-4612-a882-99e6e5772363">
        <source>trxCreateUserProfile(	pComputerName:String;
						pWindowState:Integer;
						pWindowLeft:Real;
						pWindowTop:Real;
						pWindowWidth:Real;
						pWindowHeight:Real;
						pTheRoot:JSSFMRoot;
						pTheUserProfile:JSSFMUserProfile output);
// --------------------------------------------------------------------------------
// Created:		15 July 2002 by cnwdad1
//
// Purpose:		Creates a new User Profile object, updated with the window settings.
//
// Parameters:	pComputerName - The name of the workstation.
//				pWindowState - The current state of the window.
//				pWindowLeft - The coordinate of the window's left border.
//				pWindowTop - The coordinate of the window's top border.
//				pWindowWidth - The width of the window.
//				pWindowHeight - The height of the window.
//				pTheRoot - The owner of the User Profile object.
//				pTheUserProfile - An output parameter for the new User Profile object.
//
// Returns:		The newly created User Profile object as an output parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theNewUserProfile	: JSSFMUserProfile;
	
begin
	self.checkTransactionState();
	
	if self.isDoTransactionState then
		on Exception do self.xHandlerCommon(exception);
	endif;
	
	beginTransaction;
	
	theNewUserProfile	:=	pTheRoot.createUserProfile(	pComputerName,
														pWindowState,
														pWindowLeft,
														pWindowTop,
														pWindowWidth,
														pWindowHeight);
	
	commitTransaction;
	
	pTheUserProfile	:=	theNewUserProfile;
end;</source>
        <Parameter name="pComputerName" type="String"/>
        <Parameter name="pWindowState" type="Integer"/>
        <Parameter name="pWindowLeft" type="Real"/>
        <Parameter name="pWindowTop" type="Real"/>
        <Parameter name="pWindowWidth" type="Real"/>
        <Parameter name="pWindowHeight" type="Real"/>
        <Parameter name="pTheRoot" type="JSSFMRoot"/>
        <Parameter name="pTheUserProfile" type="JSSFMUserProfile" usage="output"/>
    </JadeMethod>
    <JadeMethod name="trxDeleteBackgroundCopy" id="8cd9ce3a-27c6-41a6-96b0-0f743d79707f">
        <source>trxDeleteBackgroundCopy(pTheBackgroundCopy:JSSFMBackgroundCopy io);
// --------------------------------------------------------------------------------
// Created:		17 September 2002 by cnwdad2
//
// Purpose:		Deletes the Background Copy for the specified computer name.
//
// Parameters:	pComputerName - The name of the workstation.
//				pTheRoot - The owner of all User Profile objects.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.checkTransactionState();
	
	if self.isDoTransactionState then
		on Exception do self.xHandlerCommon(exception);
	endif;
	
	beginTransaction;
	
	delete pTheBackgroundCopy;
	
	commitTransaction;
end;</source>
        <Parameter name="pTheBackgroundCopy" type="JSSFMBackgroundCopy" usage="io"/>
    </JadeMethod>
    <JadeMethod name="trxDeletePasteFile" id="0b850aed-0975-48dc-8d63-eaaed343abc3">
        <source>trxDeletePasteFile(pThePasteFile:JSSFMPasteFile io);
// --------------------------------------------------------------------------------
// Created:		17 September 2002 by cnwdad2
//
// Purpose:		Deletes a Paste File object.
//
// Parameters:	pThePasteFile - The Paste File object to delete.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.checkTransactionState();
	
	if self.isDoTransactionState then
		on Exception do self.xHandlerCommon(exception);
	endif;
	
	beginTransaction;
	
	delete pThePasteFile;
	
	commitTransaction;
end;</source>
        <Parameter name="pThePasteFile" type="JSSFMPasteFile" usage="io"/>
    </JadeMethod>
    <JadeMethod name="trxDeleteUserProfile" id="d5856558-d02e-48ae-b95d-0866ea12dfdc">
        <source>trxDeleteUserProfile(pComputerName:String; pTheRoot:JSSFMRoot);
// --------------------------------------------------------------------------------
// Created:		15 July 2002 by cnwdad1
//
// Purpose:		Deletes the User Profile for the specified computer name.
//
// Parameters:	pComputerName - The name of the workstation.
//				pTheRoot - The owner of all User Profile objects.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theUserProfile	: JSSFMUserProfile;
	
begin
	self.checkTransactionState();
	
	if self.isDoTransactionState then
		on Exception do self.xHandlerCommon(exception);
	endif;
	
	theUserProfile	:=	pTheRoot.allUserProfiles.getAtKey(pComputerName);
	
	if theUserProfile &lt;&gt; null then
		beginTransaction;
		
		delete theUserProfile;
		
		commitTransaction;
	endif;
end;</source>
        <Parameter name="pComputerName" type="String"/>
        <Parameter name="pTheRoot" type="JSSFMRoot"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateUserProfile" id="90064e8c-2b55-4855-8dcf-71830090ed6a">
        <source>trxUpdateUserProfile(	pComputerName:String;
						pWindowState:Integer;
						pWindowLeft:Real;
						pWindowTop:Real;
						pWindowWidth:Real;
						pWindowHeight:Real;
						pTheRoot:JSSFMRoot);
// --------------------------------------------------------------------------------
// Created:		15 July 2002 by cnwdad1
//
// Purpose:		Updates a User Profile object with the window settings.
//
// Parameters:	pComputerName - The name of the workstation.
//				pWindowState - The current state of the window.
//				pWindowLeft - The coordinate of the window's left border.
//				pWindowTop - The coordinate of the window's top border.
//				pWindowWidth - The width of the window.
//				pWindowHeight - The height of the window.
//				pTheRoot - The owner of the User Profile object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theUserProfile	: JSSFMUserProfile;
	
begin
	self.checkTransactionState();
	
	if self.isDoTransactionState then
		on Exception do self.xHandlerCommon(exception);
	endif;
	
	theUserProfile	:=	pTheRoot.allUserProfiles.getAtKey(pComputerName);
	
	if theUserProfile = null then
		self.trxCreateUserProfile(	pComputerName,
									pWindowState,
									pWindowLeft,
									pWindowTop,
									pWindowWidth,
									pWindowHeight,
									pTheRoot,
									theUserProfile);
	else
		exclusiveLock(theUserProfile);
		
		beginTransaction;
		
		theUserProfile.updateMe(	pComputerName,
									pWindowState,
									pWindowLeft,
									pWindowTop,
									pWindowWidth,
									pWindowHeight,
									pTheRoot);
		
		commitTransaction;
	endif;
end;</source>
        <Parameter name="pComputerName" type="String"/>
        <Parameter name="pWindowState" type="Integer"/>
        <Parameter name="pWindowLeft" type="Real"/>
        <Parameter name="pWindowTop" type="Real"/>
        <Parameter name="pWindowWidth" type="Real"/>
        <Parameter name="pWindowHeight" type="Real"/>
        <Parameter name="pTheRoot" type="JSSFMRoot"/>
    </JadeMethod>
</Class>
