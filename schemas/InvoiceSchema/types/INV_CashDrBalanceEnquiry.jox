    <JadeMethod name="doMnuContextBuild" id="24dd0035-e595-48a2-8633-efafcd19cf26">
        <source>doMnuContextBuild(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 August 2012	cnwndl1	Initial creation

*/

vars

	drTerm : CM_DebtorTerminal;

begin

	self.mnuInspect.visible := false;

	drTerm :=  table.accessRow(table.row).itemObject.CM_DebtorTerminal;
	if not app.isValidObject(drTerm) then
		return false;
	endif;
	
	self.mnuInspect.userObject := drTerm;
	
	if app.isAllowedToInspect then
		self.mnuInspect.visible := true;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="da5e0a0e-23b0-438f-bf9c-52e19ad507a0">
        <updating/>
        <source>doResize() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	newHeight : Integer;

begin

	inheritMethod();
	
	self.frmMain.move(5,self.frmToolbar.clientHeight + 5,self.clientWidth - 10,self.clientHeight - 10 - self.frmToolbar.clientHeight);
	
	newHeight := self.lblSearchCrit.getTextHeight( self.lblSearchCrit.caption );
	
	self.lblSearchCrit.move(	self.tblCash.left, //left
								0,//top
								self.clientWidth - 10,//width
								newHeight //heigth
								);
	
	self.frmTables.move(	self.frmTables.left, //left
							newHeight,//top
							self.frmTables.width,//width
							self.frmMain.height - self.frmToolbar.clientHeight - newHeight - 5 //heigth
							); 
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSearch" id="0863ba1e-fc54-4678-bed9-ef88c97575d1">
        <updating/>
        <source>doSearch() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 August 2012	cnwndl1	Initial creation

*/

vars

	selectedDr : CM_Debtor;
	dr : CM_Debtor;
	selectedTerm : CM_Terminal;
	drTerm : CM_DebtorTerminal;
	terms : CM_TerminalByCodeDict;
	includeSummary : Boolean;
	includeDetail : Boolean;
	msg : String;
	allDrTerms : ObjectArray;
	index : Integer;
	
begin

	includeSummary := self.chkSummary.value;
	includeDetail := self.chkDetail.value;
	
	if not includeSummary and not includeDetail then
		msg := app.getErrorString(DetailOrSummary);
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		return;
	endif;

	app.mousePointer := MousePointer_HourGlass;

	self.tblCash.rows := self.tblCash.fixedRows;
	
	selectedDr := self.cmbDebtors.listObject.CM_Debtor;
	selectedTerm := self.cmbTerminals.listObject.CM_Terminal;
	
	create allDrTerms transient;
	create terms transient;
	app.getMyUser.getTerminals(terms);
	
	if selectedDr &lt;&gt; null then
		if selectedTerm &lt;&gt; null then
			// show a specific Debtor / terminal combination
			drTerm := selectedTerm.allDebtorTerminals.getAtKey( selectedDr );
			// from 33688 testing, it may not exist
			if drTerm &lt;&gt; null then
				allDrTerms.add ( drTerm );
			endif;
		else
			//show all terminals for a specififc debtor
			if not selectedDr.allDebtorTerminals.isEmpty then
				selectedDr.allDebtorTerminals.copy( allDrTerms );
			endif;
		endif;
		self.addTableData( allDrTerms, includeDetail, includeSummary );
		
	elseif selectedTerm &lt;&gt; null then
		//show all debtors for a specified terminal
		if not selectedTerm.allDebtorTerminals.isEmpty then
			selectedTerm.allDebtorTerminals.copy( allDrTerms );
			self.addTableData( allDrTerms, includeDetail, includeSummary );
		endif;
		
	else
		//Show all
		foreach index in 1 to self.cmbDebtors.listCount do
			dr := self.cmbDebtors.itemObject[index].CM_Debtor;
			if dr &lt;&gt; null then
				allDrTerms.clear();
				if not dr.allDebtorTerminals.isEmpty then
					dr.allDebtorTerminals.copy( allDrTerms );
					self.addTableData( allDrTerms, includeDetail, includeSummary );
				endif;
			endif;
		endforeach;
		
	endif;
	
	self.setSearchCriteriaLabel();
	self.hideSearchFrame;

epilog

	delete terms;
	delete allDrTerms;

	app.mousePointer := MousePointer_Default;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="7a64e4e1-a765-41b4-9099-82ac3d09902d">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 August 2012	cnwndl1	Initial creation

*/

vars

	str : String;

begin

	str	:=	inheritMethod();
	
	str := str &amp; global.formatAsXML( self.chkSummary.name, self.chkSummary.value.String);
	str := str &amp; global.formatAsXML( self.chkDetail.name, self.chkDetail.value.String);
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handlePrintTableRowException" id="470a2f23-08d7-4b36-b63f-7e32c99dae64">
        <source>handlePrintTableRowException(_exc : Exception) : Integer protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 August 2012	cnwndl1	Initial creation	Par 29968

*/

constants

	InvalidNumberOfRows		= 14049;
	InvalidTableRow			= 14051;
	
vars

begin

	if _exc.errorCode = InvalidNumberOfRows or
	   _exc.errorCode = InvalidTableRow then
		app.msgBox(app.getErrorString(ERR_MAX_TABLE_ROW_EXCEEDED), 'Error', MsgBox_OK_Only + MsgBox_Stop_Icon);
		return Ex_Abort_Action;
	endif;
	
	// Not our exception
	return Ex_Pass_Back;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
