<Class name="CMQF_VoyageTransaction" id="7d5da641-159c-4a59-bd51-0de39619bda7">
    <superclass name="CMQF_Transactions"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="filterObjects" id="58038087-5226-490d-908e-e5d0a572f84f">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     27 July 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	startTS,
	endTS				: TimeStamp;
	txnType				: Integer;
	voyage				: CM_Voyage;

begin
	voyage := self.getMyVoyage;
	if voyage = null then
		return;
	endif;
	
	self.initFields();
	
	if (not self.startDate.isValid) then
		self.startDate := '01/01/0001'.asDateJMT;
	endif;
	startTS.setDate(self.startDate);
	startTS.setTime('00:00:00:000'.Time);
	
	if (not self.endDate.isValid) then
		endTS.setDate(app.actualTimeServer.date);
	endif;
	endTS.setTime('23:59:59:999'.Time);
	
	foreach txnType in self.allTxnTypes do
		voyage.getTITxns(txnType, startTS, endTS, true, 'checkStatusIncludesObject', self, _collection);
	endforeach;
	
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="8bbec5f3-b0ad-4043-9ca9-7c6da1158396">
        <updating/>
        <source>includesObject(_trx: CM_TITransaction; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     30 July 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	rtnValue			: Boolean;
begin
	rtnValue := inheritMethod(_trx, _passport, _breakOut);
	
	if _trx.mySnapShot = null 
	or _trx.deleted then
		return false;
	endif;
	
	if _trx.mySnapShot.CM_TISnapShot.transitStatus = TI_TransitStatusDLR or
	   _trx.mySnapShot.CM_TISnapShot.transitStatus = TI_TransitStatusSOB then //sob should never happen for receive txns
		return false;
	endif;
	
	return rtnValue;
	
end;</source>
        <access>protected</access>
        <Parameter name="_trx" type="CM_TITransaction"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
