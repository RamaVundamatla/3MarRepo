    <JadeMethod name="getOnboardPlannedCargo" id="9c95124a-3dc9-473f-a16b-3bff5a13776d">
        <source>getOnboardPlannedCargo(): String;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 18 March 2024
TFS#		: 62840
Function	: Moved from getDisplayStringForAttribute

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	locationController	: CM_LocationsController;
	trackedItem			: CM_TrackedItem;
	tmpStr				: String;
	futureMove 			: CM_FutureMove;
	plannedCargoId		: String;
    failedDAC           : CM_DataAccessController;       //JIRA-34864 
begin
	foreach locationController in self.allLCs do
		foreach futureMove in locationController.allPlannedFutureMoves do
			if futureMove.CM_FutureMovePlanned.myTrackedItem = null then
				continue;
			endif;
			trackedItem:=futureMove.CM_FutureMovePlanned.myTrackedItem;
            if not trackedItem.canUserAccessSelf(null, failedDAC, app.myPassport) then  //JIRA-34864 
                continue;                                                               //JIRA-34864
            endif;                                                                      //JIRA-34864
			if tmpStr = null then
				tmpStr := trackedItem.id;
			else
				tmpStr := tmpStr &amp; ', ' &amp; trackedItem.id;
			endif;
			
			if trackedItem.isKindOf( CM_TILC ) then // a stack of trailers
				plannedCargoId := trackedItem.getOnboardPlannedCargo();
				if plannedCargoId &lt;&gt; null then
					tmpStr := tmpStr &amp; ', ' &amp; plannedCargoId;
				endif;
			endif;
		endforeach;
	endforeach;
	return tmpStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOnboardQuantity" id="7781cbe9-ef04-41f1-b5dd-8502dd774dfa">
