    <JadeMethod name="getCCDischargeLayer" id="962ab579-d156-4aac-b488-7fa3c5778958">
        <source>getCCDischargeLayer() : CM_DeckLayerLayout;
/*
Purpose:			
Date		Who		Reason
13 June 2011	cnwab1	Initial creation
*/

vars
	pxyCC, realCC : CM_DeckLayerLayout;
	found : Boolean;
begin
	foreach realCC in self.allDeckLayerLayouts discreteLock where realCC.type = ROROLayerType_CCDischarge do
		return realCC;
	endforeach;

	create pxyCC transient;
	pxyCC.setProxy("Discharge CC", "", "", self,true,ROROLayerType_CCDischarge);
	
	if process.isInTransactionState then // PAR 28330
		app.myUtilityCA.utlCreateDeckLayerLayout(pxyCC, realCC, true, app.myPassport); // PAR 28330
	else
		app.myTrxCA.trxCreateDeckLayerLayout(pxyCC, realCC, true, app.myPassport); // PAR 28330
	endif;
	
	if (app.myPassport.hasWarnings and not app.myPassport.warningsAcknowledged) 
	or app.myPassport.hasErrors() then
		return null;
	endif;
	
// PAR 28330			self.moveLayerToTop(realCC); // make it draw as the top layer
	
	return realCC;
epilog
	delete pxyCC;
end;</source>
        <ReturnType type="CM_DeckLayerLayout"/>
    </JadeMethod>
