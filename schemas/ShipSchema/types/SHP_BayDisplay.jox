    <JadeMethod name="createProxyBay" id="fc41b254-7734-430a-ba7e-2af43534566b">
        <updating/>
        <source>createProxyBay() updating;
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
vars

begin
	if self.myBay = null then
		return;
	endif;
	beginLoad;
	self.myProxyBay :=self.myBay.pxyCreateUpdateProxy;
epilog
	endLoad;
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="d3538d26-83ee-42b4-8352-2cbfda5a4772">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 May 2009	cnwer1	Initial creation

*/

vars

begin
	if self.myProxyBay &lt;&gt; null then
			//for testing
		if self.myProxyBay.myHold.isTransient then
			delete  self.myProxyBay.myHold;
		endif;
		delete self.myProxyBay;
	endif;
epilog

end;</source>
    </JadeMethod>
