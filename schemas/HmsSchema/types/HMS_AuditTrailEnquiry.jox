    <JadeMethod name="tblResults_dblClick" id="5372d0c4-7bd4-4f34-aec4-4d1a7975021c">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblResults_dblClick(table: Table input) updating;
//--------------------------------------------------
// Created:	16 September 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	if table.row = 1
	and table.rows &gt; 1 then
		// Resort column
		table.CM_DataTable.resortTableByColumn(table.column);
		table.CM_DataTable.colourRows(self.colorRow1, self.colorRow2);
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblResults_rowColumnChg" id="df501702-f96e-4ac7-9a2a-c32ae434fcd3">
        <controlMethod name="CM_DataTable::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblResults_rowColumnChg(table: Table input) updating;
//--------------------------------------------------
// Created:	16 September 2004 By: cnwgd1
//--------------------------------------------------
vars
	transaction : HMS_Transaction;
begin

	if table.row &lt;= table.fixedRows then
		return;
	endif;
	
	transaction := table.accessRow(table.row).itemObject.HMS_Transaction;
	// Update details table
	if transaction &lt;&gt; null then
  		self.updateDetailsTable(transaction);
	endif;
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="b0d2eff8-ec93-4c5a-8738-e24b91b9d78c">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0005818, locale);
	btnExportCSVTV.translateCaption(Xlat_0005819, locale);
	btnFind.translateBubbleHelp(Xlat_0001407, locale);
	btnFind.translateCaption(Xlat_0001408, locale);
	gbxAuditDetails.translateCaption(Xlat_0001393, locale);
	gbxAuditView.translateCaption(Xlat_0001397, locale);
	lblAnd.translateCaption(Xlat_0001409, locale);
	lblAtAfter.translateCaption(Xlat_0001404, locale);
	lblAtBefore.translateCaption(Xlat_0001400, locale);
	lblAtBetwnA.translateCaption(Xlat_0001402, locale);
	lblAtBetwnB.translateCaption(Xlat_0001401, locale);
	lblAuditView.translateCaption(Xlat_0001398, locale);
	lblFilterApplied.translateCaption(Xlat_0001410, locale);
	lblFilterAvailab.translateCaption(Xlat_0001411, locale);
	lblFilterTitle.translateCaption(Xlat_0001395, locale);
	mnuColumnOrganizer.translateCaption(Xlat_0005820, locale);
	mnuContextTable.translateCaption(Xlat_0005821, locale);
	optLoggedAfter.translateCaption(Xlat_0001396, locale);
	optLoggedBefore.translateCaption(Xlat_0001394, locale);
	optLoggedBetween.translateCaption(Xlat_0001412, locale);
	shtCriteria.translateCaption(Xlat_0001403, locale);
	shtDateRange.translateCaption(Xlat_0001399, locale);
	shtFilters.translateCaption(Xlat_0001405, locale);
	shtResults.translateCaption(Xlat_0001406, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="updateAppliedList" id="4bf255f1-f92e-40ae-96ee-bea8e6d82b89">
        <updating/>
        <source>updateAppliedList() updating;

vars
	count:	Integer;
	obj:	Object;
begin
 	// This method re-builds the applied filters list everytime the user makes a selection in the 
 	// filter available list 

 	// Clear list
 	lbxFiltersApplied.clear;

 	count:=1;
 	while count&lt;=lbxFiltersAvail.listCount do
 		if lbxFiltersAvail.itemLevel[count]=1 then
 			// Heading - add this
 			lbxFiltersApplied.addItem(lbxFiltersAvail.itemText[count]);
 			lbxFiltersApplied.itemPicture[lbxFiltersApplied.newIndex]:=lbxFiltersAvail.itemPicture[count];
 		elseif lbxFiltersAvail.itemSelected[count]=true then
 			// Selected item - add this
 			lbxFiltersApplied.addItem(lbxFiltersAvail.itemText[count]);
 			lbxFiltersApplied.itemObject[lbxFiltersApplied.newIndex]:=lbxFiltersAvail.itemObject[count];
 			lbxFiltersApplied.itemLevel[lbxFiltersApplied.newIndex]:=2;
 			lbxFiltersApplied.itemExpanded[lbxFiltersApplied.newIndex]:=true;
 			lbxFiltersApplied.itemData[lbxFiltersApplied.newIndex]:=lbxFiltersAvail.itemData[count];		
 		endif;
 		count:=count+1;
 	endwhile;		

end;</source>
    </JadeMethod>
    <JadeMethod name="updateDetailsTable" id="399192d7-215b-496f-987b-c740d51e5be0">
        <updating/>
        <source>updateDetailsTable(transaction : HMS_Transaction) updating;

vars
	propertyChange : HMS_PropertyChange;
	tmpStr : String;
begin
	// This method updates the details table for the selected transaction
	self.tblDetails.rows := tblDetails.fixedRows;
		
	foreach propertyChange in transaction.allPropertyChanges do
		tmpStr := propertyChange.getAttributeStringForDefArray(self.tblDetails.allTblDataEntRows);
		self.tblDetails.addItemObject(propertyChange, tmpStr);
	endforeach;

	self.tblDetails.colourRows(self.colorRow1, self.colorRow2);
end;</source>
        <Parameter name="transaction" type="HMS_Transaction"/>
    </JadeMethod>
</GUIClass>
