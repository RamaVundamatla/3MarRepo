    <JadeMethod name="getAllPaths" id="7d7693bd-9c72-4701-853f-746208de753d">
        <source>getAllPaths(_child : CM_FinancialObject; _paths : HugeStringArray input; _items : ObjectArray input);
// 32311 return the path text and tran map item for each tran map entry, other than the entered one in _child, at the same level
vars
	broker		: CM_TransServiceBroker;
begin
	if _child.isKindOf(CM_TransServiceBroker) then
		_paths.add(self.getPath());
		_items.add(self);
		return;
	endif;

	foreach broker in self.allTransServiceBrokersByType do
		broker.getAllPaths(_child, _paths, _items);
	endforeach;

end;</source>
        <Parameter name="_child" type="CM_FinancialObject"/>
        <Parameter name="_paths" type="HugeStringArray" usage="input"/>
        <Parameter name="_items" type="ObjectArray" usage="input"/>
    </JadeMethod>
