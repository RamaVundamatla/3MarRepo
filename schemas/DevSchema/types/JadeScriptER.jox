    <JadeMethod name="fixupMTN35572" id="a5f04e2b-939d-4e2c-bb0d-87f7eabc4fa7">
        <source>fixupMTN35572();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 November 2025	jlier1	Initial creation 35572

*/

vars
	terminal : CM_Terminal;
	terminalCode : String;
	cargoType : CM_CargoType;
	iter : Iterator;
	ti : CM_TrackedItem;
	fixCound : Integer;
begin
	terminalCode:="T1"; //PUT IN THE CORRECT TERMINAL CODE
	terminal:=app.myRoot.allTerminals[terminalCode];
	
	if terminal = null then
		app.msgBox("Terminal not found - enter valid terminal code", "ERROR", MsgBox_OK_Only);
		return;
	endif;
	
	cargoType :=app.myRoot.allCargoTypesById[TI_CargoType_LCL];
	if cargoType = null or not cargoType.allTerminals.includes(terminal) then
		return;
	endif;
	
	//fixing child LCL cargo that is merged
	iter:=terminal.allOnsiteTIsByCargoTypeId.createIterator;
	terminal.allOnsiteTIsByCargoTypeId.startKeyGeq(TI_CargoType_LCL,null,iter);
	while iter.next(ti) do
		if not ti.cargoType = TI_CargoType_LCL then
			break;
		endif;
		if not ti.isChild then
			continue;
		endif;

		if  ti.hasBeenMerged then
			//SHOULD NOT BE IN THIS COLLECTION
			beginTransaction;
				ti.sendMsg(CM_TrackedItem::nullAllTerminalRefs.name);	
				ti.sendMsg(CM_TrackedItem::nullAllOperatorTerminalRefs.name);
				ti.sendMsg(CM_TrackedItem::nullAllVoyageRefs.name);
			commitTransaction;
			fixCound:=fixCound +1;
		endif;
	endwhile;
	
	app.msgBox("Fixed " &amp; fixCound.asStringJMT, "Fixed", MsgBox_OK_Only);
epilog	
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="getCamXMLOutput" id="6d3fb86b-3e01-424c-96f1-5670f86a64fa">
        <source>getCamXMLOutput();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 January 2026	jlier1	Initial creation

*/

vars
	cp : CM_CamProtocol;
begin

	foreach cp in CM_CamProtocol.instances where cp.transferFileFormat = CM_CamProtocol.Output_XML do
		write cp.code &amp; Tab &amp; cp.camGroup.terminal.code;
		
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getPerfCargoDisplayString" id="f39ca213-a2cf-409e-8873-2ede5f2b4c67">
        <source>getPerfCargoDisplayString();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2025	jlier1	Initial creation

*/

vars
	pxyTI,
	cargo 					: CM_TrackedItem;
	extraParams				: CMIF_TIUpdateExtraParams;
	txnControllerDict		: CMIF_TITxnContrlrByTypeDTDict;
	profiler       			: JadeProfiler;
	tmpClass				: Class;
	startTM					: Decimal[19,0];
	coll : ObjectSet;
	iter, iter2 : Iterator;
	obj : Object;
	entDef : EntTableDef;
	theDataLine : String;
	allEntTableRows : EntTableRowArray;
	allTransientRows : ObjectSet;
	allRows, removeRows : EntTableRowArray;
	row : EntTableRow;
	proxyRow : EntTableRowProxy;
	measure : CM_MeasurementType;
	idx : Integer;
	controlPrefix, rowName, rowHeading : String;
	inserted : Boolean;
begin
	
	app.initialize;
	app.myPassport.setMyUserFromCode("JLIER1");
	
	cargo:="2367.55067880".asOid.CM_TrackedItem;
	
	app.myPassport.setMyTerminal(cargo.myTerminal);
	
	app.myPassport.getTIAuditController();
	
	create coll transient;
	coll.add("2367.729686".asOid.CM_TrackedItem);
	coll.add("2367.729687".asOid.CM_TrackedItem);
	coll.add("2367.729688".asOid.CM_TrackedItem);
	coll.add("2367.729689".asOid.CM_TrackedItem);
	coll.add("2367.729690".asOid.CM_TrackedItem);
	coll.add("2367.729691".asOid.CM_TrackedItem);
	coll.add("2367.729692".asOid.CM_TrackedItem);
	coll.add("2367.729693".asOid.CM_TrackedItem);
	coll.add("2367.729694".asOid.CM_TrackedItem);
	coll.add("2367.729695".asOid.CM_TrackedItem);
	coll.add("2367.729696".asOid.CM_TrackedItem);
	coll.add("2367.729697".asOid.CM_TrackedItem);
	coll.add("2367.729698".asOid.CM_TrackedItem);
	coll.add("2367.729699".asOid.CM_TrackedItem);
	coll.add("2367.729700".asOid.CM_TrackedItem);
	coll.add("2367.729702".asOid.CM_TrackedItem);
	coll.add("2367.11793463".asOid.CM_TrackedItem);
	coll.add("2367.13290130".asOid.CM_TrackedItem);
	coll.add("2367.13290131".asOid.CM_TrackedItem);
	coll.add("2367.19126053".asOid.CM_TrackedItem);
	coll.add("2367.19972625".asOid.CM_TrackedItem);
	coll.add("2367.10437719".asOid.CM_TrackedItem);
	coll.add("2367.10437720".asOid.CM_TrackedItem);
	coll.add("2367.38704094".asOid.CM_TrackedItem);
	coll.add("2367.38704095".asOid.CM_TrackedItem);
	
	app.createMyController(CMUI_Controller);
	
	create allEntTableRows transient;
	create allTransientRows transient;
	create removeRows transient;
	create allRows transient;
	entDef := app.myController.getEntTableDef(ETDef_CargoEnqDefaultData);
	entDef.allEntTableRows.copy(allEntTableRows);
	
	create removeRows transient;
	create allRows transient;
	allEntTableRows.copy(allRows);
	foreach row in allEntTableRows where row.measurementType &lt;&gt; null do
		idx := allRows.indexOf(row);
		inserted := false;
		foreach measure in app.myRoot.allMeasurementTypesByShortName discreteLock where measure.measurementType = row.measurementType do
			if not measure.isDisplay or not measure.isAvailableForEntry then
				continue;
			endif;
			app.getRowHeadingFromMeasure(row, measure, controlPrefix, rowName, rowHeading);
			// 35440 use the cargo type attribute heading
			/*alteredHeaderName := self.getCargoTypeAttrHeading(row.name);
			if alteredHeaderName &lt;&gt; null then
				rowName := alteredHeaderName &amp; " " &amp; measure.shortName;
			endif;*/
			create proxyRow transient;
			if measure.isDefault then															//cnwmc5 - 4 September 2014 - PAR 34533
				proxyRow.setBasicDetails(rowHeading, rowName, row.inputType, true);				//cnwmc5 - 4 September 2014 - PAR 34533
			else																				//cnwmc5 - 4 September 2014 - PAR 34533
				proxyRow.setBasicDetails(rowHeading, rowName, Table.InputType_None, true);		//cnwmc5 - 4 September 2014 - PAR 34533
			endif;		
			allTransientRows.add(proxyRow);
			allRows.insert(idx, proxyRow);
			inserted := true;
		endforeach;
		// and remove this row
		if inserted then
			removeRows.add(row);
		endif;
	endforeach;
	
	foreach row in removeRows do
		allRows.remove(row);
	endforeach;
	
	//self.deleteEntTableRowProxy();
	allEntTableRows.clear;
	allRows.copy(allEntTableRows);
	
	
	
	
	app.myRoot.startJadeProfiler(profiler,method.getNiceName() ,20,false,'ER',startTM);
	
	iter := coll.createIterator();	
	while(iter.next(obj)) do
		theDataLine := obj.getAttributeStringForDefArray(allRows);
		write theDataLine;
	endwhile;
	
	
	app.myRoot.stopJadeProfiler(profiler,startTM);
epilog
	delete coll;
	delete iter;
	delete iter2;
	delete allEntTableRows;
	delete allRows;
	delete removeRows;
	if allTransientRows &lt;&gt; null then
		allTransientRows.purge;
		delete allTransientRows;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="getPerfomanceCargoUpdate" id="f0e711ed-37ba-499e-8cdb-60f7747a8073">
        <source>getPerfomanceCargoUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 April 2025	jlier1	Initial creation

*/

vars
pxyTI,
	cargo 					: CM_TrackedItem;
	extraParams				: CMIF_TIUpdateExtraParams;
	txnControllerDict		: CMIF_TITxnContrlrByTypeDTDict;
	profiler       			: JadeProfiler;
	tmpClass				: Class;
	startTM					: Decimal[19,0];
begin
	
	app.initialize;
	app.myPassport.setMyUserFromCode("JLIER1");
	
	cargo:="2367.55067880".asOid.CM_TrackedItem;
	
	app.myPassport.setMyTerminal(cargo.myTerminal);
	
	app.myPassport.getTIAuditController();

	beginLoad;
		pxyTI:=cargo.pxyCreateUpdateProxy();
	endLoad;
	
	app.myRoot.startJadeProfiler(profiler,method.getNiceName() ,20,false,'ER',startTM);
	create txnControllerDict transient;
	create extraParams transient;
	app.myTrxUA.trxUpdateTIandExtraInfo(pxyTI, 
										TI_UPDMODE_NORMAL, 
										extraParams,
										txnControllerDict, 
										null, //comment field
										app.myPassport);	
										
	app.myRoot.stopJadeProfiler(profiler,startTM);
epilog
	delete txnControllerDict;
	delete extraParams;
	delete pxyTI;
end;</source>
    </JadeMethod>
    <JadeMethod name="testDirectorTask" id="2cd48fad-03b5-483d-a5f2-84f7e4d0fcbe">
        <source>testDirectorTask();
/*

