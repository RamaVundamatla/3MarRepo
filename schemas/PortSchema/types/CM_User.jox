    <JadeMethod name="checkSysMenuAgainstPermissions" id="27726a4b-23ec-4d28-b49f-036a7fb4ddef">
        <source>checkSysMenuAgainstPermissions(_resetPictures : Boolean);
// ---------------------------------------------------------------------------
// Created:     18 February 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	newUserItem,
	userItem		: CM_MenuUserItem;
	userSysItem,
	sysItem			: CM_MenuItem;
	sysDtl			: CM_MenuDtl;
	sysDict			: CM_MenuItemByTypeMenuIdDict;
	//term			: CM_Terminal;
	tmpCanDo,
	isSiteLicense,
	isLicensed,
	found			: Boolean;
	hdrSet			: CM_MenuEntitySet;
	tmpMenuRoot		: CM_MenuRootForUser;
	licenseNum		: Integer;
	tmpRoot			: CM_Root;
begin
	
	tmpRoot := app.myRoot;
	isSiteLicense := tmpRoot.canDo(PmSite);
	tmpMenuRoot := self.myMenuRootForSysEntities;
	
	if tmpMenuRoot = null then
		return;
	endif;
	
	create hdrSet transient;

	//delete items for which we no longer have permission
	foreach userItem in tmpMenuRoot.allMenuUserItemsWithAMenuItem do
		if (not CM_MenuUserDtl.hasInstance(userItem)) then
			continue;
		endif;
		
		sysItem := userItem.CM_MenuUserDtl.myMenuDtl;
		if sysItem = null then
			delete userItem;
			continue;
		endif;
		
		if _resetPictures then
			userItem.resetPictures();
		endif;
		
		if CM_MenuDtlNav.hasInstance(sysItem) and 
		   (not sysItem.CM_MenuDtlNav.allChildValues.isEmpty) then
			isLicensed := false;
			
			foreach licenseNum in sysItem.CM_MenuDtlNav.allChildValues do
				if tmpRoot.canDo(licenseNum) then
					isLicensed := true;
					break;
				endif;
			endforeach;
			
			if (not isLicensed) then 
				delete userItem;
				continue;
			endif;
			
			/*
			licenseNum := sysItem.CM_MenuDtlNav.childValue;

			if licenseNum &gt; 0 then
				if (not tmpRoot.canDo(licenseNum)) then
					delete userItem;
					continue;
				endif;
			endif;
			*/
		endif;
		
		if (not self.canDo(null, sysItem.constantValue)) then
			delete userItem;
			continue;
		endif;
	endforeach;
	
	sysDict := app.myRoot.myMenuRootForSysEntities.allMenuItems;
	//add items for which we now have permission, but did not previously
	foreach sysItem in sysDict do
		if (not CM_MenuDtl.hasInstance(sysItem)) then
			continue;
		endif;
		
//		licenseNum := sysItem.CM_MenuDtlNav.childValue;
//		if licenseNum &gt; 0 then
//			if (not tmpRoot.canDo(licenseNum)) then
//				continue;
//			endif;
//		endif;
		// set to true as if allChildValues is empty then
		// assume that is licensed
		isLicensed := true;
		
		foreach licenseNum in sysItem.CM_MenuDtlNav.allChildValues do
			// only really need to do this on first time
			isLicensed := false;
			if tmpRoot.canDo(licenseNum) then
				isLicensed := true;
				break;
			endif;
		endforeach;
		
		if (not isLicensed) then 
			continue;
		endif;

		if (not self.canDo(null, sysItem.constantValue)) then
			continue;
		endif;
		
		found := false;
		foreach userItem in self.myMenuRootForSysEntities.allMenuUserItemsWithAMenuItem do : userLoop
			if (not CM_MenuUserDtl.hasInstance(userItem)) then
				continue;
			endif;
			
			userSysItem := userItem.CM_MenuUserDtl.myMenuDtl;
			if userSysItem = sysItem then
				found := true;
				break userLoop;
			endif;
		endforeach;

		if (not found) then
			sysItem.CM_MenuDtl.addToUserMenuRoot(self.myMenuRootForSysEntities);	
		endif;
	endforeach;
	
	//delete headers that have no children
	foreach userItem in self.myMenuRootForSysEntities.allMenuUserItemsWithAMenuItem do
		if (not CM_MenuUserHdr.hasInstance(userItem)) then
			continue;
		endif;
		
		if userItem.CM_MenuUserHdr.allChildren.isEmpty then
			hdrSet.add(userItem);
		endif;
	endforeach;
	
	hdrSet.purge();
	
epilog
	delete hdrSet;
end;</source>
        <Parameter name="_resetPictures" type="Boolean"/>
    </JadeMethod>
