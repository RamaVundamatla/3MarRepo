    <JadeMethod name="addDebtorTypes" id="de1d41ee-d8a2-4d72-875b-21d65ae71bff">
        <updating/>
        <source>addDebtorTypes() protected, updating;
/*
Purpose:			
Setup entTblRows for user-defined debtor types - #17010/CCMS1047

Date			Who		Reason
16 July 2008	cnwar2	Initial creation
*/

vars
	debtorType : CM_DebtorType;
	
begin
	foreach debtorType in app.myRoot.allDebtorTypes discreteLock where not debtorType.isNotAvailableForEntry do
		if not debtorType.allDebtors.isEmpty then
			self.zAddTransientEntTblRow(debtorType.description, ETRow_DebtorTypes &amp; Tab &amp; debtorType.code, Table.InputType_None);
		endif;
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addDebtorTypesToProxy" id="24368608-3e60-4853-a61a-252c24dcf4f7">
        <updating/>
        <source>addDebtorTypesToProxy(_proxy : CM_Object input) updating;
// ---------------------------------------------------------------------------
// Created:	29 July 2008 By Graeme Black cnwgb1
// Purpose:Adds the Debtor Type dictionary to a proxy object	
//         Added for PAR 17591 BulkEdit of a Debtor type field (From PAR 16666)
// ---------------------------------------------------------------------------
vars
	realTI: CM_TrackedItem;
	proxyTI: CM_TrackedItem;
begin
	realTI := self.myCurrentObject.CM_TrackedItem;
	proxyTI := _proxy.CM_TrackedItem;
	proxyTI.allDebtorsByType.clear();
	realTI.allDebtorsByType.copy(proxyTI.allDebtorsByType);
epilog
end;</source>
        <Parameter name="_proxy" type="CM_Object" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addObjectsToTable" id="7405f5f9-a671-4324-b99a-fb401194c916">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
// ---------------------------------------------------------------------------
// Created:     22 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
7.5.2010 	cnwrd	To allow search on multiple cargo id's , par 24107
*/

constants
	NumberToCount = 300;
vars
	breakOut		: Boolean;
	tiID 			: String;
	tiSet			: CM_TISet;
	ti				: CM_TrackedItem;
	numProc			: Integer;
	invalidObject	: Boolean;
	bolSet			: CM_BOLSet;
begin
	//epr TFS 47132 27/12/19
	if self.useSelectorTable then

		//jlier TFS 53454 27/5/22
		self.doSelectorSearch(_numItems,breakOut);	
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception, ti, invalidObject);			// 16/11/2009 cnwmh5 PAR19413
	
	create tiSet transient;
	create bolSet transient;	//26 Jan 2015	NDL	Par 33111
	
	if self.myFilterIDList.size = 0 then
		self.addObjectsToTableSub( null, _numItems, tiSet, bolSet, breakOut);
	else
		foreach tiID in self.myFilterIDList do
		
		self.addObjectsToTableSub( tiID, _numItems, tiSet, bolSet, breakOut);
		
		if breakOut then
			break;
		endif;
		endforeach;
	endif;
	
	beginLoad;
	foreach ti in tiSet do
		if numProc = NumberToCount then
			endLoad;
			beginLoad;
			numProc := 0;
		endif;
		numProc := numProc +1;
		
		// 11/11/2009 cnwmh5 PAR19413
		//if ti &lt;&gt; null and ti.isValid then//added by cnwyl1 for par15723
		if ti &lt;&gt; null then
			if self.includeObjectTI(ti, _numItems, breakOut) then
				//cnwyl1 - 24072006
				self.addObjectToTable(ti, _numItems, breakOut);
			endif;
		endif;
		if breakOut then
			break;
		endif;
	endforeach;
	endLoad;

	return;
	
epilog
	endLoad; //just in case
	delete tiSet;
	delete bolSet;

end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addObjectsToTableSub" id="69e91c45-7266-4724-8490-e31ea1efb712">
        <updating/>
        <source>addObjectsToTableSub( _tiID : String ; _numItems: Integer io; _tiSet : CM_TISet io; _bolSet : CM_BOLSet io; _breakOut : Boolean io) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07/05/2010	cnwrd1	Initial creation
par 24107 to allow search on multiple cargo ID's this is what addObjectsToTable was now called for each string token.
27/05/2010	cnwdap1	CCMS 1116 Thanship changes - filterVoyage needs to show tranships
09/12/2013	cnwmh5 	PAR 28731 - Reinstate delete of tiSet in epilog
30 Jan 2014	NDL	Par 33347 - convert to use selector query search and cull out the old code.
*/


constants

vars

	tmpCargoType 	: Integer;
	ti				: CM_TrackedItem;
	tiSet			: CM_TISet;
	brXref			: CM_TerminalTIsByBR;
	invalidObject	: Boolean;				// 11/11/2009 cnwmh5 PAR19413
	
begin
	//epr TFS 47132 30/12/19
	if self.useSelectorTable then
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception, ti, invalidObject);			// 16/11/2009 cnwmh5 PAR19413
	
	self.btnPrintList.enabled := true;
	self.btnExportCSVTV.enabled := true;
	tmpCargoType := self.filterCargoTypeId;

	endLoad;
	beginLoad;

	if app.cargoBOLTypeIsBOLType(tmpCargoType) then
		self.getBOLsForTable(_numItems, _tiID, _bolSet);
		return;
	endif;
	
	create tiSet transient;
	
	// PAR #20398 - If a Booking Ref number has been selected, and the Terminal has a completed
	// Booking Ref cross reference, then use this
	if self.filterBookingRef &lt;&gt; null then
		brXref := self.myTerminal.getBookingRefXref();
		if brXref &lt;&gt; null and brXref.xrefComplete then
			endLoad;
			self.getTIsUsingBookingRefXref(brXref, _numItems, _tiSet);
			return;
		endif;
	endif;
	
	//30 Jan 2014	NDL	Par 33347
	if self.doSearchUsingSelector( _tiID, _numItems, _tiSet ) then
		return;
	endif;

epilog
	endLoad;
	delete tiSet;										// 09/12/2013 cnwmh5 Reinstate

end;</source>
        <Parameter name="_tiID" type="String"/>
        <Parameter name="_numItems" type="Integer" usage="io"/>
        <Parameter name="_tiSet" type="CM_TISet" usage="io"/>
        <Parameter name="_bolSet" type="CM_BOLSet" usage="io"/>
        <Parameter name="_breakOut" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addOperatorToProxy" id="88df6931-bae8-45d0-ad32-74c3c00d57c2">
        <updating/>
        <source>addOperatorToProxy(_proxy : CM_Object input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2015	cnwma1	 PAR #36719 Bulk Edit "only if original value matches
*/

vars
	realTI: CM_TrackedItem;
	proxyTI: CM_TrackedItem;
begin
	realTI := self.myCurrentObject.CM_TrackedItem;
	proxyTI := _proxy.CM_TrackedItem;
	proxyTI.setMyOperator(realTI.myOperator);
	proxyTI.setMyVoyage(realTI.myVoyage,app.myPassport);
epilog
end;</source>
        <Parameter name="_proxy" type="CM_Object" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="c45f586f-7dab-49a6-9013-dac051757ace">
        <source>addToolbarControls() protected;
// ---------------------------------------------------------------------------
// Created:     19 August 2003 by cnwrs2
// 04 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
// Purpose:     
//
// Changed On  	Changed By  Reason
// 30/05/2025	jlizm1		MTN 34728 Handle notifications cargo enquiry
// ---------------------------------------------------------------------------
vars
	toolbar	: CMUI_Toolbar;
	btnIdx : Integer;
begin
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnNotifications, CMUI_Toolbar.Control_Alignment_Right);
	self.btnNotifications.visible := true;
	
	inheritMethod();

	if self.allowSearch then
		toolbar.addButtonAt(self.btnPrintList, 2, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	// cnwrl1 11/02/2009 CCMS SFW 1047
	if self.bAllowSummaryDefn then
		toolbar.addSeperator( CMUI_Toolbar.Control_Alignment_Left );
		toolbar.addButton(self.btnSummariseAll, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	if self.canAccessTransactions then
		toolbar.addButton(self.btnTransactions, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnViewDiscrep, CMUI_Toolbar.Control_Alignment_Left);
		btnViewDiscrep.bubbleHelp := app.getErrorString(Show_booking_referen_discrep);
	endif;
	
	if self.canAccessMoveIt then
		toolbar.addButton(self.btnMoveIt, CMUI_Toolbar.Control_Alignment_Left);	
	endif;

	if self.canUpdate  then
		// do not allow tranships for voyage commodity planning (as complex enough already! - RJS)
		//epr 11/3/14 removing voyage commodity planning as part of bulk CCMS 1366
		toolbar.addButton(self.btnTranship, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
	
	//1/12/2009 cnwdz2 par21808
	if app.getMyUser().canDo(self.myTerminal, self.permissionView) then
		toolbar.addButton(self.btnPhotos, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	toolbar.addSeperator( CMUI_Toolbar.Control_Alignment_Left );	//04.10.2022 navtnr20 TFS 54967
	toolbar.addButton(self.btnInstruction, CMUI_Toolbar.Control_Alignment_Left);	//04.10.2022 navtnr20 TFS 54967
	toolbar := self.frmSearchToolbar;
	btnIdx:=3;
	
	// advanced search
	toolbar.addSeperatorAt(btnIdx, CMUI_Toolbar.Control_Alignment_Left);
	btnIdx:=btnIdx +1;
	if app.getMyUser().canDo(self.myTerminal, PmAdmSelectorView) then
		toolbar.addButtonAt(self.btnSelector, btnIdx, CMUI_Toolbar.Control_Alignment_Left);
		btnIdx:=btnIdx +1;
	endif;
	toolbar.addButtonAt(self.btnFilterVoyages, btnIdx, CMUI_Toolbar.Control_Alignment_Left);
	btnIdx:=btnIdx +1;
	toolbar.addSeperatorAt(btnIdx, CMUI_Toolbar.Control_Alignment_Left);

	//epr TFS 47132 13/12/19
	if  self.cmbSelector.listCount &gt; 1 then	
		toolbar.addFrame(self.frmToolbarCombos, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
	if toolbar.showCaptions then 
		// PAR 8605
		//cnwsh3 - 03/04/2006 Add local Constant as found there is another place where this is set.  Changed from 380 to 395 for 7.4.2 font changes.
		self.frmSearch.width := CargoEnqSearchWidthWithCaption; 
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="adjustSearcherHeight" id="37daae3f-4a4f-47fb-9ab4-b1342d754c96">
        <source>adjustSearcherHeight();

/*

Purpose:			

Parameters:			

Return Value:		



Date		Who		Reason
3 Sep 2008	cnwdz2	Par17808 adjust the searcher's height.

*/

vars

begin

	//epr TFS 47132 30/12/19
	self.tblSearch.optimiseHeadingColumn;
	self.tblSearch.adjustHeight(self.clientHeight);
	self.frmSearch.height := tblSearch.height + tblSearch.top + 15;
	
	self.sptDataFilter.cnEcResizeContents;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="allowUpdate" id="1cad6876-e837-4f8e-9f70-f2ee4626dbd5">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>allowUpdate(set: Boolean; _value: Boolean io) updating, mapping;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 July 2016	cnwer1	Initial creation TFS 2336

*/

vars

begin
	if set then
		inheritMethod(set, _value);
	else
		if self.allowUpdate then
			_value:=self.allowUpdate;
		else
			if self.myCurrentObject &lt;&gt; null
			and self.myCurrentObject.isKindOf(CM_TrackedItem) 
			and self.myCurrentObject.CM_TrackedItem.isPreNote then
				_value:= app.getMyUser.canDo(self.myTerminal, PmGtePreNoteMaint);
			else
				_value :=false;
			endif;
		endif;	
	endif;
	
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="allowsTableFilters" id="14eb1b3f-02fe-453a-b12e-06ea1d81b082">
        <source>allowsTableFilters(_table: Table): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 December 2011	cnwndl1	Initial creation	Par 28889

*/

vars

begin

	return _table = self.tblData;

epilog

end;</source>
        <Parameter name="_table" type="Table"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="altIdFilterIsMatch" id="c251b8c8-f995-47c9-9f3f-633fa6a3bfc8">
        <source>altIdFilterIsMatch(testId : String) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2013	cnwndl1	Initial creation

*/

vars
	
begin
	//1: No filter applies
	if self.filterAltId = null then
		return true;
	endif;
	
	//2: Exact match
	if self.filterAltId = testId then
		return true;
	endif;
		
	//3: filterId is a substring of testId (eg first  few characters)
	if testId.startsWith(self.filterAltId) then	
		return true;
	endif;
						
	return false;
	
epilog 
	
end;</source>
        <Parameter name="testId" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="applyColumnFilter" id="721283e9-97b4-4c8d-90dc-8b2555c6e895">
        <updating/>
        <source>applyColumnFilter(_table: CM_DataTable io):Integer updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 December 2011	cnwndl1	Initial creation	Par 28889

*/

vars

	visibleCount : Integer;

begin
	
	if _table &lt;&gt; null then
		if _table.allowsColumnFilters then
			visibleCount := _table.applyColumnFilter( self.allColumnFilters );
		endif;
	endif;
	
	return visibleCount;

epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="applyDataTblColSecurity" id="52becd1e-b4cb-4834-b3ce-73b7b6403b1e">
        <source>applyDataTblColSecurity();
/*
Date		Who		Reason
18 November 2008	cnwrd1	Initial creation
cnwrd1 10.11.08 CCMS JMT 1743/1764 
05/09/2012	cnwcs5	par 30172 - small local variable tweaks
*/

vars
	user			: CM_User;
	terminal		: CM_Terminal;
	viewOpImpPin, 
	viewOpExpNo 	: Boolean;	  
	table			: CM_DataTable;
begin
	user			:= app.getMyUser;
	terminal		:= self.myTerminal;
	table			:= self.tblData;
	viewOpImpPin 	:= user.canDo(terminal, PmAdmOpImpReleasePinView) or user.canDo(terminal, PmAdmOpImpReleasePinEdit);//25 Jan 2011	NDL	Par 26802
	viewOpExpNo 	:= user.canDo(terminal, PmAdmOpExpReleaseNumEdit);
	
	if viewOpExpNo then
		table.showColumnByColName(ETRow_ExportReleaseNumber);
	else
		table.hideColumnByColName(ETRow_ExportReleaseNumber);
	endif;
	
	if viewOpImpPin then
		table.showColumnByColName(ETRow_ImportReleasePIN);
	else
		table.hideColumnByColName(ETRow_ImportReleasePIN);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="armNotesForObject" id="167eda72-11e4-452d-9d97-2862d60db299">
        <source>armNotesForObject(_obj: Object);
//--------------------------------------------------
// Created:	02 July 2004 By: cnwgd1
//--------------------------------------------------
vars
	tmpTI : CM_TrackedItem;
	tmpBOL : CM_BOL;
begin
	inheritMethod(_obj);
	
	if CM_BOL.hasInstance(_obj) then
		tmpBOL := _obj.CM_BOL;
		self.beginNotification(tmpBOL, self.myTerminal.getTerminalEvent(BOL_Update_Event), Response_Continuous, 0);
		foreach tmpTI in tmpBOL.allTrackedItems do
			self.beginNotification(tmpTI, Any_System_Event, Response_Continuous, 0);
		endforeach;
	endif;
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="btnArgFindClose_click" id="ea8167b9-3114-4612-8dcb-93392825c946">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnArgFindClose_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2019	jlger1	Initial creation

*/

vars
	tmpProp : CM_QueryProperty;
	critLine : CM_SelectorCriteriaLine;
begin
	critLine:=self.frmTblArgument.userObject.CM_SelectorCriteriaLine;
	if critLine &lt;&gt; null then
		critLine.myQueryProperty.setValuesFromList(tblArgument, critLine.myQueryOperator);
		self.tblSearch.accessedCell.text:=critLine.myQueryOperator.getSearchValueStr(critLine.myQueryProperty);
	endif;
	
	self.frmTblArgument.visible := false;
	self.sptMain.enabled := true;
	self.frmTblArgument.userObject:=null;
epilog

	delete tmpProp;


end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnArgFind_click" id="df486501-c41e-453a-83f6-c853d6a74c84">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnArgFind_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 November 2019	jlger1	Initial creation 47132

*/

vars
	critLine : CM_SelectorCriteriaLine;
begin
	critLine:= self.tblSearch.accessedCell.itemObject.CM_SelectorCriteriaLine;
	if critLine = null then
		return;
	endif;
	self.frmTblArgument.userObject:=critLine;
	critLine.myQueryProperty.setListValues(self.tblArgument, self.myCriteriaLineHolder, critLine.myQueryOperator, app.myPassport);
	self.tblArgument.enabled := not (critLine.isUnavailableAtRunTime);
	
	self.frmTblArgument.left := ( self.clientWidth - self.frmTblArgument.width ) / 2;
	self.frmTblArgument.top := ( self.clientHeight - self.frmTblArgument.height ) / 2;

	self.frmTblArgument.visible := true;
	self.txtArgFind.text := null;
	self.sptMain.enabled := false;
	
	self.frmTblArgument.zOrder(1);
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnBlkEdtCancel_click" id="f7d1c40e-78ba-4b92-89ff-cad1644ddf23">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnBlkEdtCancel_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     03 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.showHideBulkEditChanges(false);

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnBlkEdtOK_click" id="ccd00986-6a3e-4722-b747-36535e6bccae">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnBlkEdtOK_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     03 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 29/09/2022	jlizm1		TFS 54702 CUX MAFI Auto Queueing
vars
	ti				  : CM_TrackedItem;			// TFS 54702
	disport 		  : CM_Port;				// TFS 54702
	voyage 			  : CM_Voyage;				// TFS 54702
	voyageChangedMAFI : Boolean;				// TFS 54702
	obj				  : Object;
begin
	voyage  := self.cmbVoyage.listObject.CM_Voyage;	// TFS 54702
	disport := self.cmbDisPort.listObject.CM_Port;	// TFS 54702
	obj	    := self.myCurrentObject;
	
	if obj &lt;&gt; null and obj.isKindOf(CM_TrackedItem) then	// TFS 54702
		ti := obj.CM_TrackedItem;							// TFS 54702
		if ti.isOnMAFI and (ti.myVoyage &lt;&gt; voyage or ti.dischargePort &lt;&gt; disport.description) then	// TFS 54702
			voyageChangedMAFI := true;				// TFS 54702	
		endif;
	endif;
	
	self.showHideBulkEditChanges(false);
	self.zDoSave();

	if voyageChangedMAFI then		// TFS 54702
		self.doQueueCargoOffMAFI();	// TFS 54702
	endif;
	
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnFilterVoyages_click" id="4bbf7a1a-1c41-431a-a293-cedd73a3bbeb">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnFilterVoyages_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     07 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	app.mousePointer := Busy; //cnwrs1 par15258 nov 2007
	self.setIncludeAllVoyagesInFilter((not self.includeArchivedVoyages));
epilog
	app.mousePointer := Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnInstruction_click" id="b01bb786-af3c-468c-a8a9-5d88534fd0c0">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnInstruction_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions

*/

vars

begin
	self.myAssistant.showInstructionEntryForm(self.tblData.allSelectedObjects.first.CM_Object,self);
epilog

