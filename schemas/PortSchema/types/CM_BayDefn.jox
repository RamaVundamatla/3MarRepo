    <JadeMethod name="isImported" id="5fd98983-ffa7-4661-8dce-16e12367f23d">
        <source>isImported(): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 April 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars

begin
	if self.myVesselCellular = null then
		return false;
	endif;
	
	return self.myVesselCellular.isImported;

epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="bfcb3f12-0730-4444-9518-767a86d7c004">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------

vars
	theProxyMe : SelfType;
	completedOK		: Boolean;
begin
	theProxyMe :=  inheritMethod();

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return theProxyMe;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete theProxyMe;
	endif;	
	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="removeHatchLid" id="69eb54a7-be8a-4708-ac76-60d2e2ac361b">
        <source>removeHatchLid(_hatchLid : CM_HatchLidVessel input);
// ---------------------------------------------------------------------------
// Created:     21 March 2002 by cnwdwq1
//
// Purpose:     redundant in v 7 ? hatch lids should look after them selves
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	exclusiveLock(self);
	if 	self.allHatchLids.includes(_hatchLid) = false then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Hatchlid does not exist in coll');
		return;
	endif;
	_hatchLid.CM_HatchLidVessel.erase(NORMAL_ERASE);
end;</source>
        <Parameter name="_hatchLid" type="CM_HatchLidVessel" usage="input"/>
    </JadeMethod>
    <JadeMethod name="resetFortyAttrib" id="bf76a7eb-1d81-4ec3-83db-9e7cd5da365b">
        <updating/>
        <source>resetFortyAttrib(_newAttrib: Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     Simply rips through and sets the 40' attribute to the supplied value in all slotDefns
//				for this bay. Called from setBayType DQ.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	slotDefnVesse:CM_SlotDefnVessel;
	slotDefn : CM_SlotDefn;
begin

	//-----------------------
	// Check the parameter
	//-----------------------
	if _newAttrib &lt; FORTYFOOT_FRONT or
	   _newAttrib &gt; FORTYFOOT_BOTH then
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_INVALID_BAYTYPE, null, null);
		return;
	endif;

	foreach slotDefn in self.allSlotsByOrdinal do
		if _newAttrib = FORTYFOOT_FRONT then
			slotDefn.CM_SlotDefnVessel.setFortyFoot(false);

		elseif _newAttrib = FORTYFOOT_BACK then
			slotDefn.CM_SlotDefnVessel.setFortyFoot(true);

		else //( *pAttrib == FORTYFOOT_BOTH)
			slotDefn.CM_SlotDefnVessel.setFortyFoot(false);
		endif;
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_newAttrib" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="4e455dad-6210-4f4e-9529-af12e9b8588e">
        <updating/>
        <source>setForCreate(_proxyBayDefn:CM_BayDefn; _realVesselVoyage : CM_Object; _passport : CM_Passport input) updating; //, serverExecution;
// ---------------------------------------------------------------------------
// Created:     16 January 2002 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 19/02/2021	navmd1		TFS 49052 MACS3 Vessel Library API
// ---------------------------------------------------------------------------

vars

begin

	_proxyBayDefn.raiseExceptionIfNotTransient(method);

	// the ID and ORDINAL  need to be set here, so that the collections by labels and ordinal are correct
	//  otherwise when we link the bays and slots this bay on the end is put at the front.
	self.id := _proxyBayDefn.id;
	self.ordinalBay := _proxyBayDefn.ordinalBay;
	
	// The 40 ID and can handle flags also need to be set here, so collections by lables update correctly.
	self.idBay40 := _proxyBayDefn.idBay40;
	self.fortyFootBay := _proxyBayDefn.fortyFootBay;
	self.fortyFiveFootBay := _proxyBayDefn.fortyFiveFootBay;
	
	self.setMyVessel(_realVesselVoyage.CM_CellularVesselStructure);
	
	self.clonedFromBay := _proxyBayDefn.clonedFromBay;
	// use the proxy hold's ordinal to get the matching, by ordinal, real hold
	if _proxyBayDefn.myHold &lt;&gt; null then
		self.myHold := self.myVesselCellular.allHolds[_proxyBayDefn.myHold.ordinalHold];
	endif;
	
	inheritMethod(_proxyBayDefn, _realVesselVoyage, _passport);
	
end;</source>
        <Parameter name="_proxyBayDefn" type="CM_BayDefn"/>
        <Parameter name="_realVesselVoyage" type="CM_Object"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForDelete" id="bf7acd7e-b09c-4f8f-afd2-f43d062def2d">
        <updating/>
        <source>setForDelete() updating;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
begin
	inheritMethod();

	delete self;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="19c86c3f-47f1-48ac-bf04-bbeb23748e1c">
        <updating/>
        <source>setForUpdate(_proxy:SelfType; _passport : CM_Passport input) updating; //, serverExecution;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
begin

	// ################
	if (self.fortyFootBay &lt;&gt; _proxy.fortyFootBay) or (self.fortyFiveFootBay &lt;&gt; _proxy.fortyFiveFootBay) then
		self.setMyVessel(self.myVesselCellular);
	endif;
	self.clonedFromBay := _proxy.clonedFromBay;
	// use the proxy hold's ordinal to get the matching, by ordinal, real hold
	if _proxy.myHold &lt;&gt; null then
		self.myHold := self.myVesselCellular.allHolds[_proxy.myHold.ordinalHold];
	endif;
	
	inheritMethod(_proxy, _passport );
	
end;</source>
        <Parameter name="_proxy" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateSlots" id="edb6b5ba-d074-4fa9-b206-a679d59a17f5">
        <updating/>
        <source>setForUpdateSlots(_iCreatedCellsTeirs: Boolean; _proxy: SelfType; _passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		April 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin
	//epr TFS 2759 13/12/16 always update any existing slots
	inheritMethod(_iCreatedCellsTeirs, _proxy, _passport);
	
	/*
	if _iCreatedCellsTeirs then
		
		self.createSlots(); 
		//epr par 34819 removed createSlots purges and re creates all slots this is uncessary
		//self.setForUpdateSlotsNewTierCell(_iCreatedCellsTeirs, _proxy, _passport);
	else
		inheritMethod(_iCreatedCellsTeirs, _proxy, _passport);
	
	endif;*/
epilog 
end;</source>
        <Parameter name="_iCreatedCellsTeirs" type="Boolean"/>
        <Parameter name="_proxy" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateSlotsNewTierCell" id="d9a89250-1d4a-40b2-821d-d05bd98932c6">
        <updating/>
        <source>setForUpdateSlotsNewTierCell(_iCreatedCellsTeirs: Boolean; _proxy: SelfType; _passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		April 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	pxyBay : SelfType;
	pxySlot, aSlot : CM_SlotDefn;
	newODC, newODT,newUDC, newUDT, oD, oC, oT : Integer;
	aTier : CM_TierDefn;
	aCell : CM_CellDefn;
	tmpDict : CM_SlotDefnByDeckCellTier;
begin

	if not _iCreatedCellsTeirs then
		return;
	endif;
	
	
	foreach aTier in self.allTiersOnDeck do
		if aTier.pxyGetProxyObject = null then
			newODT := aTier.ordinal;
			break;
		endif;
	endforeach;
	foreach aTier in self.allTiersUnderDeck do
		if aTier.pxyGetProxyObject = null then
			newUDT := aTier.ordinal;
			break;
		endif;
	endforeach;
	
	foreach aCell in self.allCellsOnDeck do
		if aCell.pxyGetProxyObject = null then
			newODC := aCell.ordinal;
			break;
		endif;
	endforeach;
	foreach aCell in self.allCellsUnderDeck do
		if aCell.pxyGetProxyObject = null then
			newUDC := aCell.ordinal;
			break;
		endif;
	endforeach;
	
	pxyBay := self.pxyGetProxyObject();
	if pxyBay &lt;&gt; null then
		create tmpDict transient;
		pxyBay.allSlotsOnDeck.copy(tmpDict);
		foreach pxySlot in tmpDict reversed do
			oD := pxySlot.ordinalDeck;
			oC := pxySlot.ordinalCell;
			oT := pxySlot.ordinalTier;
			
			if newODC &gt; 0 and oC &gt;= newODC then
				oC := oC + 1;
				pxySlot.setForUpdateOrdinals(oD,oC,oT);
			endif;
			if newODT &gt; 0 and oT &gt;= newODT then
				oT := oT + 1;
				pxySlot.setForUpdateOrdinals(oD,oC,oT);
			endif;
			aCell := self.allCellsOnDeckByOrdinal[oC];
			aTier := self.allTiersOnDeck[oT];
			
			if aCell = null or aTier = null then
				continue;
			endif;
			pxySlot.setProxyCellTierID(aCell.id,aTier.id);
			
			
			aSlot := self.allSlotsByOrdinal[oD, oC, oT];
			if aSlot &lt;&gt; null then
				aSlot.setForUpdate(pxySlot,_passport);
			endif;
		endforeach;
		tmpDict.clear;
		pxyBay.allSlotsUnderDeck.copy(tmpDict);
		foreach pxySlot in tmpDict reversed do
			oD := pxySlot.ordinalDeck;
			oC := pxySlot.ordinalCell;
			oT := pxySlot.ordinalTier;
			
			if newUDC &gt; 0 and oC &gt;= newUDC then
				oC := oC + 1;
				pxySlot.setForUpdateOrdinals(oD,oC,oT);
			endif;
			if newUDT &gt; 0 and oT &gt;= newUDT then
				oT := oT + 1;
				pxySlot.setForUpdateOrdinals(oD,oC,oT);
			endif;
			
			aCell := self.allCellsUnderDeckByOrdinal[oC];
			aTier := self.allTiersUnderDeck[oT];
			if aCell = null or aTier = null then
				continue;
			endif;
			pxySlot.setProxyCellTierID(aCell.id,aTier.id);

			aSlot := self.allSlotsByOrdinal[oD,oC, oT];
			if aSlot &lt;&gt; null then
				aSlot.setForUpdate(pxySlot,_passport);
			endif;
		endforeach;
	endif;
epilog 
	delete tmpDict;
end;</source>
        <Parameter name="_iCreatedCellsTeirs" type="Boolean"/>
        <Parameter name="_proxy" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setIdBay40" id="c7708a1a-efe6-4aa7-b011-8c15231925b2">
        <updating/>
        <source>setIdBay40( _id40: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 February 2013	cnwer1	Initial creation HAT 2189

*/

vars

begin
	inheritMethod( _id40);
	if self.idBay40 &lt;&gt; null and self.canHandle4045() and self.my40VesselCellular = null then
		self.my40VesselCellular:=self.myVesselCellular;
	elseif self.idBay40 = null and self.my40VesselCellular &lt;&gt; null then
		self.my40VesselCellular:=null;
	endif;

epilog

end;</source>
        <Parameter name="_id40" type="String"/>
    </JadeMethod>
    <JadeMethod name="setMyVessel" id="b867dabb-e407-4b62-8c95-270a42f40692">
        <updating/>
        <source>setMyVessel(_vessel:CM_CellularVesselStructure) updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     called from vessel create to connect the bay to the vessel
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.myVesselCellular := _vessel;
	if self.canHandle4045() and self.idBay40 &lt;&gt; null then //only include first 20' section
		self.my40VesselCellular := _vessel;
	else
		self.my40VesselCellular := null;
	endif;
end;</source>
        <Parameter name="_vessel" type="CM_CellularVesselStructure"/>
    </JadeMethod>
    <JadeMethod name="setProxyBay" id="782668f4-4ea6-4a85-854a-60c40a943123">
        <updating/>
        <source>setProxyBay(_id,_idBay40,_clonedFromBay,_lashFromTier,_unlashFromTier,_remarks:String;
		_ordinalBay,_bayType,_maxPileWeight20IB,_maxPileWeight20OB,_maxPileWeight40IB,_maxPileWeight40OB,_maxPileWeightUD,_numOfPlugs,_ordinalHold:Integer;
		_athwartships,_fortyFootBay,_fortyFootOnly,_useCellTierODSequencing,_useCellTierUDSequencing:Boolean;
		_useCellTierODSequencing40,_useCellTierUDSequencing40,_isTwinLiftOD,_isTwinLiftUD:Boolean;
		_myVessel:CM_CellularVesselStructure;_theHold : CM_Hold; _osCrane : Integer; _fortyFiveFootBay,_fortyFiveFootOnly: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     12 June 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	self.setProxy(_id,_idBay40,_lashFromTier,_unlashFromTier,_remarks,_ordinalBay,_bayType,
		_maxPileWeight20IB,_maxPileWeight20OB,_maxPileWeight40IB,_maxPileWeight40OB,_maxPileWeightUD,_numOfPlugs,_ordinalHold,
		_athwartships,_fortyFootBay,_fortyFootOnly,_useCellTierODSequencing,_useCellTierUDSequencing, _useCellTierODSequencing40,_useCellTierUDSequencing40,_isTwinLiftOD,_isTwinLiftUD,
		_theHold, _fortyFiveFootBay,_fortyFiveFootOnly );
		
	self.clonedFromBay := _clonedFromBay;
	self.myVesselCellular := _myVessel;
	self.onShipCrane := _osCrane;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_idBay40" type="String"/>
        <Parameter name="_clonedFromBay" type="String"/>
        <Parameter name="_lashFromTier" type="String"/>
        <Parameter name="_unlashFromTier" type="String"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_ordinalBay" type="Integer"/>
        <Parameter name="_bayType" type="Integer"/>
        <Parameter name="_maxPileWeight20IB" type="Integer"/>
        <Parameter name="_maxPileWeight20OB" type="Integer"/>
        <Parameter name="_maxPileWeight40IB" type="Integer"/>
        <Parameter name="_maxPileWeight40OB" type="Integer"/>
        <Parameter name="_maxPileWeightUD" type="Integer"/>
        <Parameter name="_numOfPlugs" type="Integer"/>
        <Parameter name="_ordinalHold" type="Integer"/>
        <Parameter name="_athwartships" type="Boolean"/>
        <Parameter name="_fortyFootBay" type="Boolean"/>
        <Parameter name="_fortyFootOnly" type="Boolean"/>
        <Parameter name="_useCellTierODSequencing" type="Boolean"/>
        <Parameter name="_useCellTierUDSequencing" type="Boolean"/>
        <Parameter name="_useCellTierODSequencing40" type="Boolean"/>
        <Parameter name="_useCellTierUDSequencing40" type="Boolean"/>
        <Parameter name="_isTwinLiftOD" type="Boolean"/>
        <Parameter name="_isTwinLiftUD" type="Boolean"/>
        <Parameter name="_myVessel" type="CM_CellularVesselStructure"/>
        <Parameter name="_theHold" type="CM_Hold"/>
        <Parameter name="_osCrane" type="Integer"/>
        <Parameter name="_fortyFiveFootBay" type="Boolean"/>
