        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="c6c3346f-97ad-4fea-ae48-79c5ad5a4f57">
        <source>validateForUpdate(_realController: CM_LocationsController; _passport: CM_Passport input);

vars
	rowController	: CM_RowController;
	iterator		: Iterator;
	
	bolExtLogIn : CM_BOLExtLogIn;
	bolIn : CM_BOLIn;
	logController : CM_LogController;
	dockets : StringArray;
	docket : String;
	message : String;
	checkTISize	: Boolean;			// 13/05/2010 cnwmh5 #23957
begin
	inheritMethod(_realController, _passport);
	
	self.validateID();
	
	// 13/05/2010 cnwmh5 #23957 - Start
	checkTISize := false;
	if _realController.isKindOf(CM_LogController) then
		if self.myLocationRestriction.getRestrictionAsString() &lt;&gt; 
				_realController.CM_LogController.myLocationRestriction.getRestrictionAsString() then
			checkTISize := true;
		endif;
	endif;
	// 13/05/2010 cnwmh5 #23957 - End
	
	
	//cnwjo3 par 19812
	//if _realController.allTrackedItems.size &gt; 0 then
	if _realController.allTrackedItems.size &gt; 0 and checkTISize then			// 13/05/2010 cnwmh5 #23957
		app.raiseCMWarning2(ERR_LOG_ROW_HAS_TI, self.id, _realController.allTrackedItems.size.String,null,null,null);
	endif;
	
	//par 19812 cnwjo3   **** starts ****
	create dockets transient;

	//this foreach loop identifies any Log Dockets that have been
	//planned to the log row area we are updating
	//don't worry about verifying that the log docket may or may not fit
	//just throw warning up to inform user that there are dockets going to this location
	foreach bolExtLogIn in self.myTerminal.allLogBOLsUnmatched do
		if bolExtLogIn.myBOL &lt;&gt; null then
			if bolExtLogIn.myBOL.isKindOf(CM_BOLIn) then  //should be a BOLIn, don't need space for BOLOuts
				bolIn := bolExtLogIn.myBOL.CM_BOLIn;
				if bolIn.myPlannedLocation &lt;&gt; null then
					if bolIn.myPlannedLocation.isKindOf(CM_LogController) then  //make sure we are moving log into Log Area
						logController := bolIn.myPlannedLocation.CM_LogController;
						if logController = _realController then
							dockets.add(bolIn.number.asStringJMT());
						endif;
					endif;
				endif;
			endif;
		endif;
	endforeach;
	
	//display message with docket information
	if dockets.size &gt; 0 then
		foreach docket in dockets do
			message := message &amp; docket &amp; ", ";
		endforeach;
		message := message[1:message.length-2];  //cut off last comma+space
		
		app.raiseCMWarning2(ERR_LOG_ROW_HAS_DOCKETS, self.id, message,null,null,null);
	endif;
	//par 19812 cnwjo3   **** ends ****
	
epilog
	delete dockets;
end;</source>
        <Parameter name="_realController" type="CM_LocationsController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateID" id="83144b66-9f9f-4acb-8fe4-1318eee388f8">
        <source>validateID();
// ---------------------------------------------------------------------------
// Created:     06 June 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	logController	: CM_LogController;
	iterator		: Iterator;
begin
	
	
	if self.status = LC_Status_PhysicallyEmpty then
		iterator := self.myTerminalArea.CM_LogArea.allEmptyLogControllers.createIterator;
		while iterator.next(logController) do
			if logController = self.pxyGetRealObject() then//par 14739
				continue;
			endif;
			if logController.id = self.id then			
				app.raiseCMException2(ERR_LOG_ROW_EXISTS, self.id, self.getStatusDescription(), null, null);
			endif;
		endwhile;	

	elseif self.status = LC_Status_Open or self.status = LC_Status_Closed then
		logController := self.myTerminalArea.CM_LogArea.allRowControllersById[self.id].CM_LogController;
		if logController &lt;&gt; null and logController &lt;&gt; self.pxyGetRealObject() then//14739
			app.raiseCMException2(ERR_LOG_ROW_EXISTS, self.id, self.getStatusDescription(), null, null);
		endif;//par14276
		return;
	else
		return;
	endif;

epilog
	delete iterator;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateMoveForInspectFumigate" id="52b5164a-3ae9-4d0e-9e1f-b32b4d271776">
        <source>validateMoveForInspectFumigate(_ti: CM_TrackedItem) : Boolean;
/* ---------------------------------------------------------------------------
Created:	16 September 2009	by cnwvu1

Purpose:	ccms1107 / PAR 20627
			When move an uninspected (unfumigated) log to 
			an inspected (fumigated) log row, 
			the log row to be changed to uninspected (unfumigated).
			Moreover, all logs in this row are to be changed to uninspected (unfumigated) status.
			A warning message for a user to be organised.
   
Change Date		Who			Reason
-----------		--------	--------------------------------------------------
20/08/2021		navdap1		TFS 51710 C3 Reject Logs being reinstated by move
------------------------------------------------------------------------------*/
vars
	locationIsInspected,
	locationIsFumigated,
	tiIsInspected,
	tiIsFumigated	: Boolean;
	isWarning		: Boolean;
	
begin
	// TFS 51710 if log has been rejected, don't bother with any of this checking
	if _ti.isRejected then
		return true;
	endif;

	//------------------------------------------------------------------
	//		This is validation for Inspefcted and Fumigated status
	//		to be changed for either a log row or a log
	//------------------------------------------------------------------
	
	locationIsInspected := self.isInspected;
	locationIsFumigated := self.isFumigated;
	tiIsInspected	:= _ti.getIsInspected();
	tiIsFumigated	:= _ti.getIsFumigated();
	
	// when log row is not inspected and not fumigated, the log row will not be changed
	// i.e. row inspect and fumigate status is not changed.  
	// If the log is Inspected and fumigated, it'ss status will be changed later, when moved in
	if (not locationIsInspected) and (not locationIsFumigated) and (not tiIsInspected) and (not tiIsFumigated) then
		return true;
	endif;

	
	//----------------------------------------------------------------------
	//				CREATING A WARNING WHEN LOG ROW TO BE CHANGED
	//----------------------------------------------------------------------
	
	if (locationIsInspected and (not tiIsInspected)) and
	   (locationIsFumigated and (not tiIsFumigated)) then
		app.raiseCMWarning2(WARN_moveLogToRowInspectFumig, _ti.id, self.getFullId, null, null, self);
		isWarning := true;
		
	elseif (locationIsInspected and (not tiIsInspected)) then
		app.raiseCMWarning2(WARN_moveLogToRowInspected, _ti.id, self.getFullId, null, null, self);
		isWarning := true;
		
	elseif (locationIsFumigated and (not tiIsFumigated)) then
		app.raiseCMWarning2(WARN_moveLogToRowFumigated, _ti.id, self.getFullId, null, null, self);
		isWarning := true;
	endif;
	
	
	//----------------------------------------------------------------------
	//				CREATING A WARNING WHEN A LOG TO BE CHANGED
	//----------------------------------------------------------------------
	if ((not locationIsInspected) and tiIsInspected) and
	   ((not locationIsFumigated) and tiIsFumigated) then
		app.raiseCMWarning2(WARN_moveInspectFumigLogToRow, _ti.id, self.getFullId, null, null, self);
		isWarning := true;
		
	elseif ((not locationIsInspected) and tiIsInspected) then
		app.raiseCMWarning2(WARN_moveInspectedLogToRow, _ti.id, self.getFullId, null, null, self);
		isWarning := true;
		
	elseif ((not locationIsFumigated) and tiIsFumigated) then
		app.raiseCMWarning2(WARN_moveFumigatedLogToRow, _ti.id, self.getFullId, null, null, self);
		isWarning := true;
	endif;
	
	if isWarning then
		return false;
	endif;
	
	
	return true;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateMoveTo" id="5931a4e3-8455-48b1-a63c-02b2961b42f1">
        <source>validateMoveTo(_control: CMIF_MoveController input);
/* ---------------------------------------------------------------------------
Created:     16 September 2009 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	ti	: CM_TrackedItem;
	
begin

	inheritMethod(_control);

	
	ti := _control.myTrackedItem;
	if not self.validateMoveForInspectFumigate(ti) then
		return;	// we have a warning so no need to check further
	endif;
	
epilog

end;</source>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
</Class>
