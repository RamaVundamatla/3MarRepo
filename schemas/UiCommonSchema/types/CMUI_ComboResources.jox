    <ImplicitInverseRef name="allTempResources" id="eed7dbcd-edd6-4369-afe7-45cdbbe5302c">
        <memberTypeInverse/>
        <type name="HMS_ResourcesByCodeHarbourDict"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myHarbour" id="71a7eeac-2791-4706-a197-efa719fa7f1b">
        <embedded/>
        <type name="HMS_Harbour"/>
    </ImplicitInverseRef>
