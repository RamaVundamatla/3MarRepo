    <JadeMethod name="getMeasurementStringForAttrib" id="eadb39c5-3ec7-40c7-a75b-e6e464ce6d14">
        <source>getMeasurementStringForAttrib(_attrName: String; _measureType: String; _short: Boolean): String;
/*
Purpose:			

Parameters:			

Return Value:		

Changed On	By			Reason
----------	--------	-----------------------------------------------------
19/04/2013	cnwdap1		Initial creation PAR #31155 CCNS SFW 1321 Imperial Measurements
*/
vars

begin
	if _attrName = ETRow_UnsplitVolume then
		return app.convertMeasurementForDisplay(_measureType, self.unsplitVolume);
	elseif _attrName = ETRow_UnsplitWeight then
		return app.convertMeasurementForDisplay(_measureType, self.unsplitWeight);
	elseif _attrName = ETRow_Diameter then
		//return app.convertMeasurementForDisplay(_measureType, self.diameter);
		return app.convertMeasurementForDisplay(_measureType, self.getDiameter().Decimal); 		// ### TFS 54021 29June2022 NAVPW1
	elseif _attrName = ETRow_RollingLength then
		//return app.convertMeasurementForDisplay(_measureType, self.rollingLength);
		return app.convertMeasurementForDisplay(_measureType, self.getRollingLength.Decimal);	// ### TFS 54021 29June2022 NAVPW1
	endif;
	
	return inheritMethod(_attrName, _measureType, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_measureType" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMergeTransaction" id="e3c33faa-1031-4778-a1b2-563e3e07cc61">
        <source>getMergeTransaction() : CM_TITransaction;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2013	cnwer1	Initial creation CCMS DPH 2274

*/

vars
	tiTransaction	: CM_TITransaction;
	mergeTransaction : CM_Merge;
begin
	if not self.hasBeenMerged then
		return null;
	endif;
	
	foreach tiTransaction in self.allTransactions reversed do 
		if tiTransaction.isKindOf(CM_Merge) then
			mergeTransaction:=tiTransaction.CM_Merge;
			break;
		endif;
	endforeach;
	
	return mergeTransaction;

epilog

end;</source>
        <ReturnType type="CM_TITransaction"/>
    </JadeMethod>
