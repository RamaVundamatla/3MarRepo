    <JadeMethod name="setForm" id="6c107f6f-e838-4ee0-a408-14a34d6a340e">
        <updating/>
        <source>setForm(pFormObj:Form) updating;
// --------------------------------------------------------------------------------
// Created:		12 December 2005 by cnwdad1
//
// Purpose:		Sets a reference on the receiver to the form who's controls we want
//				to show in the hierarchy.
//
// Parameters:	pFormObj - A reference to the form object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aMyForm	:=	pFormObj;
end;</source>
        <Parameter name="pFormObj" type="Form"/>
    </JadeMethod>
    <JadeMethod name="showFormContents" id="adb8f297-2619-45d2-8842-5211514de2f3">
        <updating/>
        <source>showFormContents() updating, protected;
// --------------------------------------------------------------------------------
// Created:		12 December 2005 by cnwdad1
//
// Purpose:		Populates an hierarchical listbox with all of the controls on the
//				form, who's reference has been set on the receiver.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 28/02/2007	cnwdad1		Changed to also show the form's menus.
// --------------------------------------------------------------------------------
vars
	controlObj			: Control;
	menuObj				: MenuItem;
	allChildControls	: CnEcControlArray;
	
begin
	lstControls.clear();
	self.tableInitialize();
	
	if mnuFuncShowProperties.checked then
		self.listAddWindowProperties(self.aMyForm, 1);
	endif;
	
	create allChildControls transient;
	self.aMyForm.cnEcGetAllChildControls(allChildControls, false);
	
	foreach controlObj in allChildControls do
		if not controlObj.visible and mnuFuncHideInvisible.checked then
			continue;
		endif;
		
		if not controlObj.enabled and mnuFuncHideDisabled.checked then
			continue;
		endif;
		
		self.listAddChildControl(controlObj, 1);
	endforeach;
	
	foreach menuObj in self.aMyForm.menuList do
		if not menuObj.visible and mnuFuncHideInvisible.checked then
			continue;
		endif;
		
		if not menuObj.enabled and mnuFuncHideDisabled.checked then
			continue;
		endif;
		
		self.listAddMenu(menuObj, menuObj.level);
	endforeach;
	
	self.caption	:=	"Form Contents: " &amp; self.aMyForm.cnEcGetDescription();
epilog
	delete allChildControls;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="tableInitialize" id="095edb42-deb7-46f0-b603-0ed7fcee3fe6">
        <source>tableInitialize() protected;
// --------------------------------------------------------------------------------
// Created:		16 December 2005 by cnwdad1
//
// Purpose:		Initializes the table of controls.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableObj	: Table;
	columnObj	: JadeTableColumn;
	
begin
	tableObj			:=	tblControls;
	tableObj.rows		:=	0;
	tableObj.partialTextIndication	:=	true;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="tableShowDetails" id="709ecc4d-5258-46d6-8246-2f84d71911bc">
        <source>tableShowDetails(pObject:Object) protected;
// --------------------------------------------------------------------------------
// Created:		17 December 2005 by cnwdad1
//
// Purpose:		Populates the table with control (and property) details.
//
// Parameters:	pObject - A reference to the control/property object who's details
//					are to be loaded into the table.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 28/02/2007	cnwdad1		Changed to also handle Menus.
// 06/08/2007	cnwdad1		Added the "enabled" and "visible" attributes for controls.
// --------------------------------------------------------------------------------
vars
	tableObj		: Table;
	allProperties	: CnEcArray;
	elementObj		: CnEcArrayObject;
	displayValue	: String;
	propertyObj		: Property;
	controlObj		: Control;
	menuObj			: MenuItem;
	tableRowObj		: JadeTableRow;
	tableCellObj	: JadeTableCell;
	rowPointer		: Integer;
	captionText		: String;
	
begin
	tableObj	:=	tblControls;
	self.tableInitialize();
	
	if pObject.isKindOf(Property) then
		propertyObj	:=	pObject.Property;
		create allProperties transient;
		pObject.Property.cnEcGetDetails(self.getPropertyOwner(pObject.Property), allProperties);
		
		foreach elementObj in allProperties do
			tableObj.addItem(elementObj.stringValue);
		endforeach;
		
	elseif pObject.isKindOf(Control) then
		controlObj	:=	pObject.Control;
		
		rowPointer				:=	tableObj.addItem(null);
		tableRowObj				:=	tableObj.accessRow(rowPointer);
		tableRowObj.alignment	:=	Table.Alignment_Center;
		tableRowObj.height		:=	tableRowObj.height * 2;
		tableCellObj			:=	tableObj.accessCell(rowPointer, 1);
		tableCellObj.mergeCells	:=	Table.MergeCells_Merge;
		tableCellObj.picture	:=	self.getClassIcon(pObject.class);

		displayValue	:=	"Type" &amp; Tab &amp; controlObj.class.name;
		tableObj.addItem(displayValue);
		displayValue	:=	"Superclass" &amp; Tab &amp; controlObj.class.getSuperclass().name;
		tableObj.addItem(displayValue);
		displayValue	:=	"Parent" &amp; Tab &amp; controlObj.parent.name;
		tableObj.addItem(displayValue);
		displayValue	:=	 "Schema" &amp; Tab &amp; controlObj.class.rootType().schema.name;
		tableObj.addItem(displayValue);
		displayValue	:=	"Enabled" &amp; Tab &amp; controlObj.enabled.cnEcGetYesNo();
		tableObj.addItem(displayValue);
		displayValue	:=	"Visible" &amp; Tab &amp; controlObj.visible.cnEcGetYesNo();
		tableObj.addItem(displayValue);
		displayValue	:=	"Tab Index" &amp; Tab &amp; controlObj.tabIndex.cnEcNumberFormat();
		tableObj.addItem(displayValue);
		displayValue	:=	"Tab Stop" &amp; Tab &amp; controlObj.tabStop.cnEcGetYesNo();
		tableObj.addItem(displayValue);
		displayValue	:=	"Back Color" &amp; Tab &amp; controlObj.backColor.String;
		tableObj.addItem(displayValue);
		displayValue	:=	"Fore Color" &amp; Tab &amp; controlObj.foreColor.String;
		tableObj.addItem(displayValue);
		displayValue	:=	"Font Name" &amp; Tab &amp; controlObj.fontName;
		tableObj.addItem(displayValue);
		displayValue	:=	"Font Bold" &amp; Tab &amp; controlObj.fontBold.cnEcGetYesNo();
		tableObj.addItem(displayValue);
		displayValue	:=	"Font Italic" &amp; Tab &amp; controlObj.fontItalic.cnEcGetYesNo();
		tableObj.addItem(displayValue);
		displayValue	:=	"Font Size" &amp; Tab &amp; controlObj.fontSize.String;
		tableObj.addItem(displayValue);
		displayValue	:=	"Font Strike Thru" &amp; Tab &amp; controlObj.fontStrikethru.cnEcGetYesNo();
		tableObj.addItem(displayValue);
		displayValue	:=	"Font Underline" &amp; Tab &amp; controlObj.fontUnderline.cnEcGetYesNo();
		tableObj.addItem(displayValue);
		displayValue	:=	"Form" &amp; Tab &amp; controlObj.form.name;
		tableObj.addItem(displayValue);
		displayValue	:=	"Ignore Skin" &amp; Tab &amp; controlObj.ignoreSkin.cnEcGetYesNo();
		tableObj.addItem(displayValue);
		displayValue	:=	"Parent Aspect" &amp; Tab &amp; controlObj.parentAspect.String;
		tableObj.addItem(displayValue);
		displayValue	:=	"Left" &amp; Tab &amp; controlObj.left.String;
		tableObj.addItem(displayValue);
		displayValue	:=	"Top" &amp; Tab &amp; controlObj.top.String;
		tableObj.addItem(displayValue);
		displayValue	:=	"Width" &amp; Tab &amp; controlObj.width.String;
		tableObj.addItem(displayValue);
		displayValue	:=	"Height" &amp; Tab &amp; controlObj.height.String;
		tableObj.addItem(displayValue);
		
		captionText	:=	controlObj.cnEcGetCaption();
		
		if captionText &lt;&gt; null then
			displayValue	:=	"Caption" &amp; Tab &amp; captionText;
			tableObj.addItem(displayValue);
		else
			captionText		:=	controlObj.cnEcGetText();
			
			if captionText &lt;&gt; null then
				displayValue	:=	"Text" &amp; Tab &amp; captionText;
				tableObj.addItem(displayValue);
			endif;
		endif;
		
		displayValue	:=	"Bubble Help" &amp; Tab &amp; controlObj.bubbleHelp;
		tableObj.addItem(displayValue);
		
	elseif pObject.isKindOf(MenuItem) then
		menuObj	:=	pObject.MenuItem;
		
		rowPointer				:=	tableObj.addItem(null);
		tableRowObj				:=	tableObj.accessRow(rowPointer);
		tableRowObj.alignment	:=	Table.Alignment_Center;
		tableRowObj.height		:=	tableRowObj.height * 2;
		tableCellObj			:=	tableObj.accessCell(rowPointer, 1);
		tableCellObj.mergeCells	:=	Table.MergeCells_Merge;
		tableCellObj.picture	:=	self.getClassIcon(pObject.class);
		
		displayValue	:=	"Caption" &amp; Tab &amp; menuObj.caption;
		tableObj.addItem(displayValue);
		displayValue	:=	"Checked" &amp; Tab &amp; menuObj.checked.cnEcGetYesNo();
		tableObj.addItem(displayValue);
		displayValue	:=	"Enabled" &amp; Tab &amp; menuObj.enabled.cnEcGetYesNo();
		tableObj.addItem(displayValue);
		displayValue	:=	"Visible" &amp; Tab &amp; menuObj.visible.cnEcGetYesNo();
		tableObj.addItem(displayValue);
		displayValue	:=	"Web File Name" &amp; Tab &amp; menuObj.webFileName;
		tableObj.addItem(displayValue);
		displayValue	:=	"Index" &amp; Tab &amp; menuObj.index.String;
		tableObj.addItem(displayValue);
		displayValue	:=	"Level" &amp; Tab &amp; menuObj.level.String;
		tableObj.addItem(displayValue);
		displayValue	:=	"Has Sub Menu(s)" &amp; Tab &amp; menuObj.hasSubMenu.cnEcGetYesNo();
		tableObj.addItem(displayValue);
		
		if menuObj.picture &lt;&gt; null then
			rowPointer	:=	tableObj.addItem("Picture");
			tableObj.accessCell(rowPointer, 2).picture	:=	menuObj.picture;
		endif;
	endif;
epilog
	delete allProperties;
end;</source>
        <access>protected</access>
        <Parameter name="pObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="tblControls_contextMenu" id="23d85743-890b-454b-bff8-543c273967e2">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblControls_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		16 December 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	actualXPos	: Real;
	actualYPos	: Real;
	
begin
	actualXPos	:=	x;
	actualYPos	:=	y;
	
	if lstControls.listIndex = CNEC_NULL_INDEX then
		mnuFuncInspectBase.enabled	:=	false;
		mnuFuncInspectJade.enabled	:=	false;
	else
		mnuFuncInspectBase.enabled	:=	true;
		mnuFuncInspectJade.enabled	:=	true;
	endif;
	
	self.cnEcGetRelativePosition(table, actualXPos, actualYPos);
	popupMenu(mnuFunc, actualXPos.Integer, actualYPos.Integer);
	
	return false;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
