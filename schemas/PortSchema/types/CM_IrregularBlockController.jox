    <JadeMethod name="setForCreate" id="8ebe41eb-c163-41ab-b736-af7c8d0e1748">
        <updating/>
        <source>setForCreate(controllerProxy : CM_IrregularBlockController; terminalArea : CM_TerminalArea) updating;
begin
	controllerProxy.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);
	inheritMethod(controllerProxy, terminalArea);
	
	self.setForUpdate(controllerProxy, terminalArea);
end;</source>
        <Parameter name="controllerProxy" type="CM_IrregularBlockController"/>
        <Parameter name="terminalArea" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="1c544dd2-6f55-4888-be5a-575616bd7ad6">
        <updating/>
        <source>setForUpdate(controllerProxy : CM_IrregularBlockController; pTerminalArea : CM_TerminalArea) updating;

vars
	shelfProxy : CM_IrregularBlockController;
	realShelf : CM_IrregularBlockController;
begin
	self.ident := controllerProxy.ident;
	self.region.clear();
	self.region.add(controllerProxy.region.first);
	self.region.add(controllerProxy.region.last);
	
	//21 Aug 2013	NDL	Par 32308
	self.colour := controllerProxy.colour;
	self.defaultCapacity := controllerProxy.defaultCapacity;

	self.locationType := controllerProxy.locationType;
	if self.locationType = 0 then
		self.locationType := GC_GroundLocation;
	endif;
	self.maximumWeight := controllerProxy.maximumWeight;
	self.myAssociatedInterchangeArea := controllerProxy.myAssociatedInterchangeArea;
	self.locationOrdinal := controllerProxy.locationOrdinal;
	
	foreach realShelf in self.allSubLocations do
		shelfProxy := controllerProxy.allSubLocations.getAtKey( realShelf.locationOrdinal ).CM_RackShelfController;
		if shelfProxy = null then
			//It should be deleted
			// PAR 32886 delete realShelf;
			realShelf.erase(NORMAL_ERASE);
		endif;
	endforeach;
	
	foreach shelfProxy in controllerProxy.allSubLocations do
		realShelf := self.allSubLocations.getAtKey( shelfProxy.locationOrdinal ).CM_RackShelfController;
		if realShelf = null then
			create realShelf as CM_RackShelfController persistent;
			realShelf.setForCreate( shelfProxy, null );
		else
			realShelf.setForUpdate( shelfProxy, null );
		endif;
		realShelf.CM_RackShelfController.setMyLocation(self);
	endforeach;
	
end;</source>
        <Parameter name="controllerProxy" type="CM_IrregularBlockController"/>
        <Parameter name="pTerminalArea" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateFromYA" id="0331f458-d9b9-44fb-8ef4-5e2c4d4cb0af">
        <updating/>
        <source>setForUpdateFromYA(_actualYA: CM_YardAllocation input) updating;
/*
Purpose:			
Date		Who		Reason
09 September 2013	cnwab1	Initial creation
*/

vars

begin
	inheritMethod(_actualYA);
	
	if _actualYA.projectedGC = 0 and self.maxCapacity &lt;&gt; 0 then 
		return;
	endif;
	
	self.setYAMaxCapacity(  _actualYA.projectedGC.Integer );

/*	if _actualYA.projected53 = 0 and self.maxCapacity &lt;&gt; 0 then // All Ready Set do not set to maxCapacity 0
		return;
	endif;
	
	self.setYAMaxCapacity(  _actualYA.projected53 );	//22 Jul 2020	NDL	TFS 49775 */
		
epilog

end;</source>
        <Parameter name="_actualYA" type="CM_YardAllocation" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setHazardLocationsForMode" id="ddff1dbe-8286-4dd0-822b-519647890460">
        <updating/>
        <source>setHazardLocationsForMode(_ti: CM_TrackedItem; _mode: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 July 2015	cnwndl1	Initial creation	Par 36660

*/

vars
	vertSpan,
	horzSpan,
	depthSpan			: Integer;
	notSameArea			: Boolean;
	lc					: CM_LocationsController;
	tiCol : CM_TISet;
	tmpStr : String;
begin
	if _ti = null or (not _ti.isHazardous) then
		return;
	endif;
	
	if _mode = REAL_MODE then
		lc := _ti.myPrimaryActualLocation;
		tmpStr := "actual";
	elseif _mode = PLANNING_MODE then
		lc := _ti.myPrimaryPlannedLocation;
		tmpStr := "planned";
	elseif _mode = QUEUE_MODE then
		lc := _ti.myPrimaryQueuedLocation;
		tmpStr := "queued";
	endif;

	if self &lt;&gt; lc then
		app.raiseUnexpectedProgramError(class.name, method.name, 'self. does not equal the TIs primary ' &amp; tmpStr &amp; ' location (' &amp; self.String &amp; ')');
		return;
	endif;
	
	_ti.getLargestHazardArea(self.getHazardSegregationRuleType(), vertSpan, horzSpan, depthSpan, notSameArea);
	
	if notSameArea then
		if _mode = REAL_MODE then
			if (not self.allHazardousTIs.includes(_ti)) then
				self.allHazardousTIs.add(_ti);
			endif;		
		elseif _mode = QUEUE_MODE then
			if (not self.allHazardousTIsQueued.includes(_ti)) then
				self.allHazardousTIsQueued.add(_ti);
			endif;		
		elseif _mode = PLANNING_MODE then
			if (not self.allHazardousTIsPlanned.includes(_ti)) then
				self.allHazardousTIsPlanned.add(_ti);
			endif;		
		endif;
	endif;
	
epilog

end;


</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
