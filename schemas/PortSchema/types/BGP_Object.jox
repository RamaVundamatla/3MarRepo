    <JadeMethod name="canDelete" id="38c37234-ec7f-4546-b7cd-1e2298b66fa9">
        <source>canDelete(_compareDate, _today : Date; _numberOfDaysOld : Integer) : Boolean protected;
// -------------------------------------------
// Created 17 December 2003 by cnwdvb1
vars

	theDate : Date;

begin

	if _numberOfDaysOld = 0 then
		return true;
	endif;
	
	if _compareDate.isValid then
		theDate := _compareDate + _numberOfDaysOld;
		if theDate.isValid and theDate &lt;= _today then
			return true;
		endif; 
	endif;
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_compareDate" type="Date"/>
        <Parameter name="_today" type="Date"/>
        <Parameter name="_numberOfDaysOld" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createBGPUser" id="f16b5e7b-1bab-4ad8-bf29-4ba700369257">
        <source>createBGPUser() : CM_User;
// -------------------------------------------
// Created 08 September 2003 by cnwdvb1
// -------------------------------------------
constants

	BGP_USER = 'BGPUSER';
vars

	sysSecurityRole	: CM_SecurityRoleSystem;
	secRole			: CM_SecurityRoleTerminal;
	realUser,
	proxyUser		: CM_User;
	daSet			: CM_DataAccessControllerSet;
	pxyUserTerm		: CM_UserTerminal;
	terminal		: CM_Terminal;
	organisation	: CM_Organisation;
	msg : String;
begin

	realUser := app.myRoot.allUsers[BGP_USER];
	if realUser &lt;&gt; null then
		return realUser;
	endif;
	//get the system security role for user
	sysSecurityRole := app.myRoot.allRoles['System Root'].CM_SecurityRoleSystem;
	if sysSecurityRole = null then
		return null;
	endif;
	secRole := app.myRoot.allRoles['Terminal Root'].CM_SecurityRoleTerminal;
	if secRole = null then
		return null;
	endif;
	
	organisation := app.myRoot.allOrganisations.first;
	if organisation = null then
		return null;
	endif;

	create proxyUser as CM_User transient;	
	create daSet transient;
	proxyUser.setProxy(	BGP_USER, 
						BGP_USER,
						EnabledNormalUser,
						organisation,
						app.myRoot,
						true, //'password',theForm.tblInput1.getValueByName(ETRow_PersistentPassword).Boolean,
						false, false,false,null,//theForm.tblInput1.getValueByName(ETRow_RadioTelemetryOnly).Boolean,
						daSet, sysSecurityRole, null,app.myRoot.allEmailEntities,
						null, null,
						app.myRoot.getDefaultLocale(true), false, false); //cnwrs1 Par 23153 11 Mar 2010

	foreach terminal in app.myRoot.allTerminals do
		pxyUserTerm := proxyUser.getUserTerminal(terminal);
		if pxyUserTerm = null then
			create pxyUserTerm transient;
		endif;
		pxyUserTerm.setForProxy(terminal, proxyUser, secRole, null, null, null);
	endforeach;

	app.myTrxCA.trxCreateUser(proxyUser, 'Pa55word_', realUser, app.myPassport);
	if not app.myPassport.trxCompletedOK then
		msg := 'Create BGPuser failed';
		app.writeStatement(msg);
		app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		return null;
	endif;

	return realUser;
epilog
	delete proxyUser;
	delete daSet;
end;</source>
        <ReturnType type="CM_User"/>
    </JadeMethod>
    <JadeMethod name="defaultSetup" id="2cbe0ab5-6618-498d-823f-decf4d81901e">
        <source>defaultSetup(_cmif : CMIF_BGPManagerChildren) : BGP_ControllersByNameDict protected;
// -------------------------------------------
// Created 08 September 2003 by cnwdvb1
// -------------------------------------------
vars

	manager : BGP_Manager;

begin

	if _cmif &lt;&gt; null then		
		app.myTrxCA.trxCreateBGPManager(manager, _cmif, app.myPassport);
	endif;	

	if app.myPassport.trxCompletedOK then
		return manager.allBGPControllers;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_cmif" type="CMIF_BGPManagerChildren"/>
        <ReturnType type="BGP_ControllersByNameDict"/>
    </JadeMethod>
