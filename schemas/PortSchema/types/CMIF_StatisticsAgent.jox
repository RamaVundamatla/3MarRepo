    <JadeMethod name="getOffsetForLC" id="3c618de2-cc2a-436e-a744-dc4872f6f076">
        <source>getOffsetForLC( _lc : CM_LocationsController ): Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 March 2009	cnwjk3	Initial creation

*/

vars

begin
	/*
	if _lc.is30ft then 
		return _lc.offset30;
	elseif _lc.is40ft then
		return _lc.offset40;
	elseif _lc.is45ft then
		return _lc.offset45;
	elseif _lc.is53ft then
		return _lc.offset53;
	else
		return _lc.offsetFlexi;
	endif;		
	*/
	// offsetFlexi always reflects the value of a strict grid offset
	return _lc.offsetFlexi;

epilog

