    <JadeMethod name="getOnSiteOnShipQuantity" id="5e6ccb82-4149-44a0-a0e3-25d450f7a88d">
        <source>getOnSiteOnShipQuantity() : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2023 navmv20 Bug 59697: EUP - Change of Ownership Cargo Review - Able to create COO for Offsite Cargo
24/03/2025	navkc1 JIRA Story MTN-34256: MTN | Cargo Group Details for non Euroports Clients
*/

vars
	ti : CM_TrackedItem;
	totalQuantity : Integer;
	cargoGroupDtl : CM_CargoGroupDetail;
begin

	//24/03/2025	navkc1 JIRA Story MTN-34256
	if self.allCargoGroupDetails.isEmpty() then
		foreach ti in self.allAssignedTrackedItems discreteLock do
			if ti.site = TI_SITE_ONSITE or ti.site = TI_SITE_ONSHIP then
				totalQuantity += ti.totalQuantity;
			endif;
		endforeach;
	else
		foreach cargoGroupDtl in self.allCargoGroupDetails do
			if cargoGroupDtl.site = TI_SITE_ONSITE or cargoGroupDtl.site = TI_SITE_ONSHIP then
				totalQuantity := totalQuantity + cargoGroupDtl.totalQuantity;
			endif;
		endforeach;
	endif;
	
	return totalQuantity;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getOnSiteOnShipTIs" id="1a01b31f-6aba-4873-ac79-a5b4bd05a552">
        <source>getOnSiteOnShipTIs(_tiSet : CM_TISet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2023 navmv20 Bug 59697: EUP - Change of Ownership Cargo Review - Able to create COO for Offsite Cargo
24/03/2025	navkc1 JIRA Story MTN-34256: MTN | Cargo Group Details for non Euroports Clients
*/

vars
	ti : CM_TrackedItem;
	tiSet,
	tiSetOnShip : CM_TISet;
	dict : CM_CargoGroupDtlBySiteCargoGrp;
	cgDtl : CM_CargoGroupDetail;
begin
	//create tiSet transient; //24/03/2025	navkc1 JIRA Story MTN-34256 - Fix transient leak
	
	//24/03/2025	navkc1 JIRA Story MTN-34256
	if self.allCargoGroupDetails.isEmpty() then
		foreach ti in self.allAssignedTrackedItems discreteLock do
			if ti.site = TI_SITE_ONSITE or ti.site = TI_SITE_ONSHIP then
				_tiSet.addNoDuplicates(ti, false);
			endif;
		endforeach;
	else
		foreach cgDtl in self.allCargoGroupDetails do
			if cgDtl.site = TI_SITE_ONSITE or cgDtl.site = TI_SITE_ONSHIP then
				//cgDtl.allAssignedTrackedItems.copy(tiSet);
				cgDtl.allAssignedTrackedItems.copy(_tiSet); //24/03/2025	navkc1 JIRA Story MTN-34256 - fix transient leak
			endif;
		endforeach;
	endif;
	
	//return tiSet;//24/03/2025	navkc1 JIRA Story MTN-34256 fix transient leak
epilog

end;</source>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
    </JadeMethod>
