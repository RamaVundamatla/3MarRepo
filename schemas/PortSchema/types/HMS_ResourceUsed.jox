    <JadeMethod name="setVoyageInvoiceStatus" id="350152fc-2583-4b28-9490-30ec12b6a427">
        <updating/>
        <source>setVoyageInvoiceStatus() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/08/2012	cnwdap1	Initial creation PAR #29111
*/
vars
	movement	: HMS_VoyageMovement;
	hmsVoyage	: HMS_VoyageData;
	voyage		: CM_Voyage;
begin
	movement := self.myVoyageMovement;
	if movement &lt;&gt; null then
		hmsVoyage := movement.myHMSVoyageData;
		if hmsVoyage &lt;&gt; null then
			voyage := hmsVoyage.myVoyage;
			if voyage &lt;&gt; null and voyage.statusInvoice = Voyage_Invoice_Status_FullGen then
				voyage.setInvoiceStatus(Voyage_Invoice_Status_PartGen);
			endif;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="3171d55d-03f0-4ed9-9609-f760d3a59be8">
        <source>validateForUpdate(_passport: CM_Passport input);
//--------------------------------------------------
// Created:	17 February 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(_passport);

	//Check for all invoice data
	self.validateInvoiceData(_passport);

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateInvoiceData" id="3f41d415-cc2c-49e5-9452-b02dfc15caba">
        <source>validateInvoiceData(_passport: CM_Passport input);
//--------------------------------------------------
// Created:	17 February 2005 By: cnwgd1
//--------------------------------------------------
vars
	msgStr : String;
	tmpResourceType : HMS_ResourceType;
	realObj : HMS_ResourceUsed;
	hmsRO :	HMS_ResourceForObject;
	debtor : CM_DebtorNode;
begin
	if self.myVTMISTransaction &lt;&gt; null then

		if self.myVTMISTransaction.isTransient then
			//They are attempting to create a charge
			//Resource must be set when creating charge
			if self.myResource = null then
				//The resource has not been set yet
				app.raiseCMException3(ERR_RESOURCE_REQUIRES_INFO, self.myResourceType.description, " The resource needs to be specified in Movement Maintenance.",null,null, null);
			endif;
					
			realObj := self.pxyGetRealObject();
			if realObj &lt;&gt; null then
				if realObj.myVTMISTransaction &lt;&gt; null then
					app.raiseCMException3(ERR_RESOURCE_HAS_TRAN, realObj.myResource.description,
										realObj.myVTMISTransaction.transactionDT.String,
										" It was created by '" &amp; realObj.myVTMISTransaction.userCode &amp; "'", null, null);
				endif;
			endif;
			
			debtor := self.myVoyageMovement.myHMSVoyageData.myVoyage.myDebtor;
			
			if debtor = null then
			//	app.raiseCMException1(REQUIRED_FIELD, 'voyage ' &amp; self.myVoyageMovement.getDisplayString() &amp; ' Debtor', null, null);	
				app.raiseCMException1(Input_required_field_voyDebt, self.myVoyageMovement.getDisplayString() , null, null) ; // cnwdb2	PAR 35364
			else				
				if debtor.isSuspended then
					app.raiseCMException1(Debtor_suspended, debtor.name , null, null);		//cnwrd1 par 23824	29.07.2010			
				endif;			
			endif;

		else
			//Persistent transaction won't be updated
		endif;
	endif;
	
	tmpResourceType := self.myResourceType;

	if tmpResourceType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Resource Type', null, null); 
		app.raiseCMException(Input_required_field_resorceTy, null, null); // cnwdb2	PAR 35364
	elseif self.myResource = null then // PAR 10133
	//	app.raiseCMException1(REQUIRED_FIELD, 'Resource, for Resource Type ' &amp; tmpResourceType.description, null, null);// PAR 10133
		app.raiseCMException1(Input_required_field_resForRes, tmpResourceType.description, null, null); // cnwdb2	PAR 35364
	endif;
	
	if _passport.hasErrors() then
		return;
	endif;

	msgStr := 'Resource Type ' &amp; tmpResourceType.description;
		
	if tmpResourceType.isFromToDateTimeRequired then
		if (not self.fromDateTime.isValid) then
		//	app.raiseCMException1(REQUIRED_FIELD, msgStr &amp; ' From Date', null, null);		
			app.raiseCMException1(Input_required_field_frmDate, msgStr, null, null);		 // cnwdb2	PAR 35364
		endif;
		if (not self.toDateTime.isValid) then
		//	app.raiseCMException1(REQUIRED_FIELD, msgStr &amp; ' To Date', null, null);		
			app.raiseCMException1(Input_required_field_toDate, msgStr , null, null);		 // cnwdb2	PAR 35364
		endif;
		if _passport.noErrors() then
 			if self.fromDateTime &gt; self.toDateTime then
				app.raiseCMException1(AutoScheduleDateError, msgStr &amp; ' to date/time must be after the from date/time', null, null);
			endif;		
		endif;		
	elseif tmpResourceType.isActionDateTimeRequired then
		if (not self.fromDateTime.isValid) then
		//	app.raiseCMException1(REQUIRED_FIELD, msgStr &amp; ' From Date', null, null);		
			app.raiseCMException1(Input_required_field_frmDate, msgStr , null, null); // cnwdb2	PAR 35364
		endif;	
	endif;	

	if tmpResourceType.isQuantityRequired then
		if self.unitsUsed &lt;= 0 then
			foreach hmsRO in  self.myResource.allHMSObjectsWithResources discreteLock do
				if hmsRO.isKindOf(HMS_ResourceForLineCompany) then
					msgStr := "'Number Of Line Crew Required'. (" &amp; msgStr &amp; ")";
					break;
				endif;
			endforeach;
			
		//	app.raiseCMException1(REQUIRED_FIELD, msgStr &amp; ' Units Used', null, null);	
			app.raiseCMException1(Input_required_field_untsUsed, msgStr, null, null); // cnwdb2	PAR 35364


		endif;	
	endif;
	

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="47d9ee80-115a-4001-9120-09a3a008e3d3">
        <source>validateMe(_passport: CM_Passport input);
//--------------------------------------------------
// Created:	16 February 2005 By: cnwgd1
//--------------------------------------------------
vars
	wharfForMove,
	wharfForRes : HMS_Wharf;
begin
	inheritMethod(_passport);
	if self.myResourceType = null then
		//The resource has not been set yet
	//	app.raiseCMException1(REQUIRED_FIELD, 'Resource Type', null, null);
		app.raiseCMException(Input_required_field_resorceTy, null, null); // cnwdb2	PAR 35364
	endif;

	if self.myHarbour = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Harbour', null, null);
		app.raiseCMException(Input_required_field_harbour, null, null); // cnwdb2	PAR 35364
	endif;	

	if self.myVoyageMovement = null
	and self.myVoyageMovementArchive = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Movement', null, null);
		app.raiseCMException(Input_required_field_movement, null, null); // cnwdb2	PAR 35364
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
				
	if self.myResource &lt;&gt; null then
		wharfForRes := self.myResource.myWharf;
		if wharfForRes &lt;&gt; null then
			if self.myVoyageMovement.getMyBerth &lt;&gt; null then
				wharfForMove := self.myVoyageMovement.getMyBerth.myWharf;
			endif;
			if wharfForMove &lt;&gt; null then
				if wharfForMove &lt;&gt; wharfForRes then
					//resource is assigned to a wharf but it's not the wharf the vessel is berthed at
					app.raiseCMWarning4(HMSResourceWharfMismatch, self.myResource.description, wharfForRes.description, self.myVoyageMovement.getDisplayString, wharfForMove.description, null, null, self);
				endif;
			endif;
		endif;
	endif;
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
