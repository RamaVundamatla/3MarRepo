    <JadeMethod name="isIdle" id="341924ff-2901-4984-8dbb-8b09d32f21e8">
        <source>isIdle() : Boolean;

vars

begin
	self.logMessage(LOG_FULL, "isIdle " &amp; self.getTaskDisplay);
	return self.myTask = null or self.myTask.isCompleted;
epilog

