    <JadeMethod name="translateForm" id="7daba44b-c2f8-470a-98d3-966552537d42">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 26 January 2023 14:28:31.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0025390, locale);
	btnAudits.translateCaption(Xlat_0025391, locale);
	btnClose.translateCaption(Xlat_0025392, locale);
	btnNew.translateCaption(Xlat_0025393, locale);
	btnRemove.translateCaption(Xlat_0025394, locale);
	btnUpdate.translateCaption(Xlat_0025395, locale);
	lblBusinessUnit.translateCaption(Xlat_0025396, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0025397, locale);
	mnuContextMenu.translateCaption(Xlat_0025398, locale);
end;</source>
    </JadeMethod>
