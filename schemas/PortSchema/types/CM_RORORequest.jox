    <JadeMethod name="setFromTI" id="c5ce4538-ecf9-4456-b3aa-2b46fd55fc37">
        <updating/>
        <source>setFromTI(_theTI : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		Used for default discharge colour coding - can be called on
//				proxy or persistent requests
// ---------------------------------------------------------------------------
vars
	workedDT 				: TimeStamp;
	aComm 					: CM_Commodity;
	aPortCode, tmpAllocDesc : String;
	voy 					: CM_Voyage;
	existingAlloc, newAlloc : CM_VoyageAllocation;
	cargoType 				: CM_CargoType; //cnwas3 PAR 24273
	commodityGroup 			: CM_CommodityGroup; //cnwas3 PAR 24273
begin
	voy := self.getVoyage();
	
	create newAlloc transient;
	if self.isLoad then
		newAlloc.setFromTIForRORO(self, _theTI,TI_IMEX_STATUS_EXPORT);
	else
		newAlloc.setFromTIForRORO(self, _theTI,TI_IMEX_STATUS_IMPORT);
	endif;
	newAlloc.removeNonconfigCriteria(voy);

	tmpAllocDesc := newAlloc.getDefaultDescription(); // allocation.setFromTI() will build the criteria, so this will result in a meaningful description;
	newAlloc.setProxy(tmpAllocDesc,
						tmpAllocDesc,
						null,
						YAFillOption_InOrder,
						YAFillOption_InOrder,
						YAExpiryType_Never,
						null,
						newAlloc.getDefaultColour,// allocation.setFromTI() should have set the dishargePort so this call should set a good colour
						null,  //cnwjo3 par 24145
						YAOverlap_Never,//allow others
						YANoLocation_Continue,
						null,
						0, //priority adjustment
						false,
						false,
						null,
						null,
						true,
						self.myTerminal);
	existingAlloc := voy.getAllocationWithSameCriteria(newAlloc);
	
	if existingAlloc = null then
		app.myUtilityUA.utlUpdateVoyageAlloc(false,voy, newAlloc,existingAlloc,app.myPassport);
		existingAlloc := voy.getAllocationWithSameCriteria(newAlloc);
	else
		app.myEventManager.createSingleObjInfoNoteEvt(voy,self.myTerminal.getTerminalEvent(EVENT_VOY_ALLOC_UPDATE),existingAlloc);
	endif;
	self.allAllocations.add(existingAlloc); 

epilog
	delete newAlloc; // not needed

end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setMyLC" id="0ebb71c4-b914-4c97-b9e6-0036bc0bc51f">
