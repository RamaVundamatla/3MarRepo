    <JadeMethod name="myCargoType" id="464bb0f5-fff6-481d-81c4-c06e5e51ca5e">
        <methodInvocation>mapping</methodInvocation>
        <source>myCargoType(set: Boolean; _value: CM_CargoType io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 August 2014	cnwndl1	Initial creation	CCMS Penn 2399

*/

vars

begin

	if _value = null then
		if self.myTrackedItem &lt;&gt; null then
			_value := self.myTrackedItem.myCargoType;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_CargoType" usage="io"/>
    </JadeMethod>
    <JadeMethod name="populateMe" id="c21f280a-4c8e-4b1f-bc8c-8412c463e0b1">
