<Class name="CMIF_MoveQuantityTI" id="f37e5cd3-3608-436f-b37d-6702ab07e672">
    <superclass name="CMIF_TIObject"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmsmap"/>
    <PrimAttribute name="moveQuantity" id="2707008d-df37-4abd-9522-6ff447f44187">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="moveWeight" id="bd804791-10bb-44b7-83d4-e3c575fee519">
        <precision>12</precision>
        <embedded/>
        <type name="Decimal"/>
    </PrimAttribute>
    <ImplicitInverseRef name="myTI" id="b5fd3558-7bda-4ef3-90f4-5c20ecdb7b63">
        <embedded/>
        <type name="CM_TrackedItem"/>
    </ImplicitInverseRef>
    <JadeMethod name="getDisplayStringForAttribute" id="b6a2742a-e7c3-46c4-92aa-203f425c08ec">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2025	navcs2	MTN-35846  Dev - Returning of Lot Based Cargo | PortSchema Changes
*/

vars

begin
	if _attrName = ETRow_TotalQuantity then
		return self.moveQuantity.String;
	elseif _attrName = ETRow_Weight then
		return self.moveWeight.String;
	else
		return self.myTI.getDisplayStringForAttribute(_attrName, _short);
	endif; 
	
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
