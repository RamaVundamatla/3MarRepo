    <JadeMethod name="getWagons" id="66fe5d07-5607-4c4d-ac07-e47c05140525">
        <source>getWagons(discharge : Boolean; load : Boolean):CM_WagonSet;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 April 2017	cnwsc8	Initial creation. Moved up from MobileUISchema for web service visibility

*/

vars
	wagons : CM_WagonSet;
	wagon  : CM_Wagon;
begin
	create wagons transient;
	
	if discharge then
		foreach wagon in self.allWagonsByIdInward do
			if not wagon.confirmed or wagon.confirmedOutwards then
				continue;
			endif;
			wagons.addNoDuplicates(wagon,false);
		endforeach;
	elseif load then
		foreach wagon in self.allWagonsByIdOutward do
			if not wagon.confirmed or wagon.confirmedOutwards then
				continue;
			endif;
			wagons.addNoDuplicates(wagon,false);
		endforeach;
	else
		foreach wagon in self.allWagonsByIdInward do
			if not wagon.confirmed or wagon.confirmedOutwards then
				continue;
			endif;
			wagons.addNoDuplicates(wagon,false);
		endforeach;
		foreach wagon in self.allWagonsByIdOutward do
			if not wagon.confirmed or wagon.confirmedOutwards then
				continue;
			endif;
			wagons.addNoDuplicates(wagon,false);
		endforeach;
	endif;
	return wagons;
epilog

end;</source>
        <Parameter name="discharge" type="Boolean"/>
        <Parameter name="load" type="Boolean"/>
        <ReturnType type="CM_WagonSet"/>
    </JadeMethod>
