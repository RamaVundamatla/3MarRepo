    </JadeMethod>
    <JadeMethod name="createJMTControlTable" id="f69e7970-788c-424a-a524-92a128a00053">
        <updating/>
        <source>createJMTControlTable() updating;
/*
Purpose:			Creates SQL table for Control

Parameters:			

Return Value:		

Date			Who		Reason
27 May 2010		conkc1	Initial creation

PAR 24641
*/
constants

vars

	createTableString : String;
	dropTableString   : String;

begin
	
	dropTableString   := self.buildDropTableString(ControlTableName);
	createTableString := self.buildJMTControlTableString(ControlTableName);
