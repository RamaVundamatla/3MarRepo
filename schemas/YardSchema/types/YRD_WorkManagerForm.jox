    <JadeMethod name="displayTask" id="e3a9cf90-ffe6-4b96-bbf5-4fcaf9063437">
        <source>displayTask( _obj : Object ) : String;
// -----------------------------------------------------------------------------
// Created:		20 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 29 Sep 2021 navma1 		ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
// 08.02.2023	navcs2		ChangeRequest 56318:[56319] EUP - Enable ToDo Work Order job on Yard Operation Screen
// -----------------------------------------------------------------------------

vars
	woType : CM_WorkOrderDetailType;
begin

	if _obj = CM_WodMove then
		woType := app.myRoot.allWorkOrderTaskTypes[WorkOrderMode_Cargo,WO_TASK_MOVE];
		return 		woType.description;		     											//29.09.2021 navma1 #51925 
	elseif _obj = CM_WodPack then
		woType := app.myRoot.allWorkOrderTaskTypes[WorkOrderMode_Cargo,WO_TASK_PACK];
		return 		woType.description;		     											//29.09.2021 navma1 #51925 
	elseif _obj = CM_WodUnpack then
		woType := app.myRoot.allWorkOrderTaskTypes[WorkOrderMode_Cargo,WO_TASK_UNPACK];
		return 		woType.description;		     											//29.09.2021 navma1 #51925 
	elseif _obj = CM_WorkOrderToDoDtl then
		return 		_obj.CM_WorkOrderToDoDtl.getDisplayString(true);		     			// 08.02.2023 navcs2 56318:[56319]
	endif;

	return _obj.CM_ToDoTaskDesc.description;
	
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doMnuShowWorkOrder" id="1546d1a6-3cd6-4ec4-b87b-4af2503d095f">
        <source>doMnuShowWorkOrder( menuItem: MenuItem );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21/01/2010	cnwrd1	Initial creation
17/05/2018	jlgdap1	TFS 38560 PEL1 Voyage Work Orders
*/

vars

	woForm : YRD_TaskJobMaintForm;
	workOrder : CM_WorkOrder;
	task : CM_WorkOrderDtl;
	selObj : Object;
begin
	selObj := menuItem.userObject;
	
	if selObj = null then
		return;
	endif;

	if selObj.isKindOf(CM_WorkOrder) then
		workOrder := selObj.CM_WorkOrder;
	else
		app.raiseUnexpectedProgramError(self.class.name, method.name, "unexpected class type");
	endif;



	app.mousePointer := MousePointer_HourGlass;
	
	woForm := app.getForm(YRD_TaskJobMaintForm.name).YRD_TaskJobMaintForm;
	if woForm = null then
		woForm := app.loadForm(YRD_TaskJobMaintForm, YRD_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).YRD_TaskJobMaintForm;
	endif;
	
	if woForm = null then
		return;
	endif;
	
	woForm.centreWindow;
	woForm.setMyTerminal(self.myTerminal);
	//woForm.initialiseForm(workOrder, YRD_TaskJobMaintForm.Mode_Update);								// TFS 38560
	woForm.initialiseForm(workOrder, YRD_TaskJobMaintForm.Mode_Update, workOrder.getWorkOrderMode,null);		// TFS 38560
	woForm.show;
		
	
epilog
	app.mousePointer := MousePointer_Default;
end;
</source>
        <Parameter name="menuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doMnuShowWorkOrderSchedule" id="80710332-d350-4cd4-82af-d3ca0bb87e6c">
        <source>doMnuShowWorkOrderSchedule( menuItem: MenuItem  );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 January 2010	cnwrd1	Initial creation

*/

vars
	scheduleForm 		: YRD_WorkOrderScheduleForm;
	workOrder	 	: CM_WorkOrder;	
	selObj 			: Object;
begin
	selObj := menuItem.userObject;
	

		
	if selObj.isKindOf(CM_WorkOrder) then
		workOrder := selObj.CM_WorkOrder;
	else
		app.raiseUnexpectedProgramError(self.class.name, method.name, "unexpected class type");
	endif;
		

	app.mousePointer := MousePointer_HourGlass;
	
//	scheduleForm := app.getForm(YRD_WorkOrderScheduleForm.name).YRD_WorkOrderScheduleForm;
	//if scheduleForm = null then
		scheduleForm := app.loadForm(YRD_WorkOrderScheduleForm, YRD_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).YRD_WorkOrderScheduleForm;
	//endif;
	
	if scheduleForm = null then
		return;
	endif;
	
	scheduleForm.centreWindow;
	scheduleForm.setMyTerminal(self.myTerminal);
	//taskForm.initialise(workOrder, YRD_TaskJobSourceForm.Mode_Update, workOrder.getProxyTask(task));
	scheduleForm.set( workOrder );
	scheduleForm.show;
	
	
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="menuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doQuery" id="e3da29ad-e88d-4ce9-bf66-6c23eeedbc5a">
        <updating/>
        <source>doQuery() updating;
// -----------------------------------------------------------------------------
// Created:		20 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars

begin
	self.filterDateFrom := self.mskDateFrom.getDate();
	self.filterDateTo := self.mskDateTo.getDate();
	self.filterWorkOrderId := self.txtWorkOrderId.text;
	//self.filterOrganisation := self.cmbOrganisation.listObject.CM_Organisation;

	self.allTaskTypesFiltered.clear();
	self.mltTasks.getSelected(self.allTaskTypesFiltered);

	self.filterSet := true;
	
	self.doRefresh();
	self.showSearcher(true);
	
epilog

end;</source>
