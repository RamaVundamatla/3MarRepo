    <JadeMethod name="getDisplayStringForAttribute" id="6869e169-303a-4e20-a63a-267fb4d4c0fb">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/* ---------------------------------------------------------------------------
Created:	12 August 2008	by cnwvu1

Purpose:	
    
Change Date		Who		Reason
07/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
12/03/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
27/02/2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers
20/06/2022	navdap1	TFS 53362 EUP Master Data interface customers between TOS and ERP
------------------------------------------------------------------------------*/
vars
	returnVal		: String;
	invalidLoc		: Boolean;
	tmpStr : String;
	invalidOperatorNew : Boolean;
	operatorNew		: CM_Operator;
	type 			: String;					// PAR #31155
	row				: String;					// PAR #31155
	value			: Decimal [23,10];			// PAR #31155
begin
	
	if _attrName = ETRow_Operator then
		operatorNew := self.myOperatorNew;
		if operatorNew &lt;&gt; null then
			//07/02/2011 cnwdz2 26874 start
			on Exception do app.handleDeletedObject(exception, operatorNew, invalidOperatorNew);
			tmpStr :=  operatorNew.getDisplayDetails(app.myRoot.getConfig(ComboByNameOperator).Boolean);	// TFS 53362
			if invalidOperatorNew then
				return null;
			endif;
			return tmpStr; 			
		else
			return null;
		endif;
	
	elseif _attrName = ETRow_IsoType then
		return self.isoType;
	elseif _attrName = ETRow_GeneratorType then
		if self.myGeneratorType &lt;&gt; null then
			return self.myGeneratorType.getDisplayDetails(false);
		else
			return null;
		endif;
	elseif _attrName = ETRow_Attachment then  //27.02.2018 cnwma1 ChangeRequest #36813
	
		if self.allTIMasterAttachers.isNotEmpty then
			return self.allTIMasterAttachers.listString (", " ,CM_TIMaster::id.name);
		else
			return null;
		endif;
	elseif _attrName.isMeasurementType then											// PAR #31155
		_attrName.getRowNameMeasureType(row, type);									// PAR #31155
		return self.getMeasurementStringForAttrib(row, type, _short);				// PAR #31155
	else
		return inheritMethod(_attrName, _short);
		
	endif;


end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
