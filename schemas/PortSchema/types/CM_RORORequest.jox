    <JadeMethod name="getDisplayStringForAttribute" id="0c64bb06-b4d8-4c40-ac0f-0bb1e6c26812">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 January 2013	cnwrd1	Initial creation

*/

vars
	str			: String;
	isoType 	: CM_ISOType;
	isoGroup 	: CM_ISOTypeGroup;
	cargoType	: CM_CargoType;
	dischargePort : CM_Port;
begin

	if _attrName = ETRow_Id then
	
		// this section added by cnwrd1 par 24522 29.6.2010
		if self.myBulkReleaseReserveDetail = null then // should be a slot request by type but...
			return inheritMethod(_attrName, _short);
		endif;
		
		str := self.getDisplayStringForAttribute(ETRow_OperatorCode, _short);
		
		cargoType := self.myBulkReleaseReserveDetail.getCargoType();
		if cargoType &lt;&gt; null then
			return str &amp; ' ' &amp; cargoType.abbreviation;
		endif;
		
		return str;
		
	else
		return inheritMethod(_attrName, _short);
	endif;

end;

</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFirstUnplannedTI" id="a6ef31b6-9d69-4e6b-8fad-02b4ed1a73b5">
        <source>getFirstUnplannedTI() : CM_TrackedItem;
/*
Purpose:			
Date		Who		Reason
11 October 2011	cnwab1	Initial creation
*/

vars
	wle : CM_WorkListEntry;
	ti : CM_TrackedItem;
begin

	foreach wle in self.allWorkListEntries discreteLock do
		ti := wle.myTrackedItem ;
		if ti &lt;&gt; null 
		and ti.myPrimaryPlannedLocation = null then
			return ti;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getId" id="72b85d5a-b24b-420f-bff6-0b3a1c9eeb0d">
        <source>getId(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 January 2013	cnwrd1	Initial creation
// 11/10/2022	navkc1	Bug 54935: MSL - Roro planning - Slow on big decks/large vessels
*/

vars
	voyAllocation : CM_VoyageAllocation; // 11/10/2022	navkc1	#54935
begin
	voyAllocation := self.getFirstAllocation();  // 11/10/2022	navkc1	#54935
	if voyAllocation &lt;&gt; null then
		return voyAllocation.code;  // 11/10/2022	navkc1	#54935
	endif;

	return inheritMethod;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLC" id="2cf24807-e58d-4608-bda3-9310c72fccd9">
        <source>getLC(): CM_LocationsController;
/*
Purpose:			
Date		Who		Reason
31 August 2011	cnwab1	Initial creation
*/

vars

	lc :CM_LocationsController;
	id : String;
	invalidObj : Boolean;
begin
	on Exception do app.handleDeletedObject(exception,lc,invalidObj);
	
	lc:= self.myROROController;
	if lc &lt;&gt; null then
		id := lc.ident;
	endif;
	
	if invalidObj then
		return null;
	endif;
	
	return self.myROROController;

epilog

end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
