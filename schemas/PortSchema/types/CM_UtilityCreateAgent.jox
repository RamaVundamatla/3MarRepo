    <JadeMethod name="utlCreateAS400Log" id="c40caa39-6cc0-4ba0-9783-a358728de66b">
        <source>utlCreateAS400Log(_line	: String; _fileLoad : CM_AS400FileLoad;
				_passport : CM_Passport input);

vars
