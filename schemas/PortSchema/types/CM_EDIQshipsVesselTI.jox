/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2024	navsp1	Initial creation TFS ChangeRequest 63842: NSW | OnePort Integration Dev

*/

vars

begin
	self.shippingLine	 := _value;
epilog

end;</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
