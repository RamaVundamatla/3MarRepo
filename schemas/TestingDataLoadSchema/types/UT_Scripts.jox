    <JadeMethod name="deleteContainer" id="f215ecc9-364a-41ae-b989-118b59e01d4a">
        <source>deleteContainer(id: String);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars
	ti		: CM_TrackedItem;	
	root	: CM_Root;
	job 	: CM_RailJob;
	
begin
	root := CM_Root.firstInstance;
	ti := self.getTerminal.lookupTrackedItem(id, TI_CargoType_Container, TI_STATE_UNDEFINED, null, false);
	if ti &lt;&gt; null then
		beginTransaction;
		if ti.jobRailReceive &lt;&gt; null then
			job := ti.jobRailReceive;
			delete job;
		endif;
		if ti.jobRailRelease &lt;&gt; null then
			job := ti.jobRailRelease;
			delete job;
		endif;
		commitTransaction;
	endif;


	inheritMethod(id);

epilog

end;</source>
        <Parameter name="id" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteTIResetScript" id="703fb82f-b225-4da4-ad45-eeb5c3443bed">
        <source>deleteTIResetScript(tisToDelete : StringArray; terminal : CM_Terminal);
/*

Purpose:	Delete tracked item(s)	

Parameters:			

Return Value:		

Date		Who		Reason
23/07/2021	navmh5	Initial creation

*/
vars
	
	ti						: Object;
	
	tiSet					: CM_TISet;

	trackedItemId			: String;

begin

	create tiSet transient;
	
	foreach trackedItemId in tisToDelete do
		
		tiSet.clear();
		terminal.lookupAllTIsOfIdCargoType(trackedItemId, null, tiSet, false, false, null);
		
		if tiSet.isEmpty and trackedItemId.pos(".",1) &gt; 0 then
			ti := trackedItemId.asOid;
			if ti &lt;&gt; null and CM_TrackedItem.hasInstance(ti) then
				tiSet.add( ti.CM_TrackedItem );
			endif;
		endif;
		
		if not tiSet.isEmpty then
			self.deleteTrackedItem(tiSet.first, false);
		endif;	
		
	endforeach;
	
epilog

	delete tiSet;

end;
</source>
        <Parameter name="tisToDelete" type="StringArray"/>
        <Parameter name="terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="deleteTerminalAreas_ReeferApp_54899" id="a90ff2de-250e-46be-8229-1201182f4445">
        <source>deleteTerminalAreas_ReeferApp_54899();

vars

	terminalAreaArray				: StringArray;
	
	terminalArea					: String;

begin

	create terminalAreaArray transient;
	terminalAreaArray.add("RA1");
	terminalAreaArray.add("RA2");
	terminalAreaArray.add("RA3");
	terminalAreaArray.add("RA4");
	terminalAreaArray.add("RA5");

	foreach terminalArea in terminalAreaArray do
	
		self.deleteTerminalArea(terminalArea);
	
	endforeach;
	

epilog

	delete terminalAreaArray;

end;
</source>
    </JadeMethod>
    <JadeMethod name="planQueueTiToWagon" id="81996101-3268-454f-8524-3e15d62afea5">
        <source>planQueueTiToWagon(_ti: CM_TrackedItem; _destination: Any; _moveMode : Integer);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars
	moveController	: CMIF_MoveController;
	destination: CM_LocationsController;
	expectErrors : Boolean;
begin

	expectErrors := self.opts.bool("ExpectErrors");
	
	if _destination.isKindOf(CM_LocationsController) then
		destination := _destination.CM_LocationsController;
	elseif _destination.isKindOf(CM_TerminalArea) then
		destination := _destination.CM_TerminalArea.allLocationsControllers.first;
	endif;

	create moveController transient;
	moveController.setMyTrackedItem(_ti);
	moveController.setMyToPrimaryLocation(destination);
	moveController.setMoveMode(_moveMode);
	//moveController.isForcedMove := true;

	app.myTrxUA.trxMoveTrackedItemNewRailJob(moveController, app.myPassport);
	if not expectErrors then
		self.assertNoTrxErrorsOrWarnings();
	endif;

epilog
	delete moveController;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_destination" type="Any"/>
        <Parameter name="_moveMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="resetData_37075" id="7e3f00bf-4622-4acb-9577-3e6966e6e200">
        <source>resetData_37075();
/*

Purpose:	Reset 37075	

Date		Who		Reason
12/10/2021	navmh5	Initial creation

*/
vars
	
	terminal				: CM_Terminal;
	passportTerm 			: CM_Terminal;
	yardJob					: CM_YardInternalJob;
	obj						: CM_Object;
	
	yardJobSet				: CM_JobSet;
	
begin
	
	app.initialize();
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	create yardJobSet transient;
	foreach yardJob in CM_YardInternalJob.instances discreteLock where yardJob.jobId = "MKBS01-&gt;Unknown 1" and 
			yardJob.allRequests.first.getSourceLocationID() = "MKBS01" and yardJob.allRequests.first.getTargetLocationID() = "MKSS01" do
		yardJobSet.add(yardJob);
	endforeach;
	
	/*
	foreach obj in yardJobSet do
		yardJob := obj.CM_YardInternalJob;
		write yardJob.String &amp; Tab &amp; yardJob.jobId &amp; Tab &amp; yardJob.allRequests.first.getSourceLocationID() &amp; Tab &amp; 
			yardJob.allRequests.first.getTargetLocationID();
	endforeach;
	*/
	
	app.myTrxDA.trxDeleteJobs(yardJobSet, app.myPassport);
	
epilog

	app.myPassport.setMyTerminal(passportTerm);
	delete yardJobSet;

end;</source>
    </JadeMethod>
    <JadeMethod name="resetData_37111" id="5d4cfb6d-302d-48e0-81f1-cc94aed74ab8">
        <source>resetData_37111();
/*

Purpose:	Reset 37392		

Date		Who		Reason
17/01/2022	navmh5	Initial creation

*/
constants
	VechileID				: String = "37111";

vars
	
	terminal				: CM_Terminal;
	vvr						: CM_VehicleVisitRecord;
	vehicle					: CM_Vehicle;
	passportTerm 			: CM_Terminal;
	
begin
	
	app.initialize();
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	vehicle := self.getVehicle(VechileID);
	if vehicle = null then
		app.writeLog("Unable to find vehicle " &amp; VechileID, LogINFO);
		return;
	endif;
	
	foreach vvr in vehicle.visitRecords discreteLock do
		
		if vvr.timeOut &lt;&gt; null then
			continue;
		endif;
		
		self.deleteVVR(vvr);
		
	endforeach;

	
epilog

	app.myPassport.setMyTerminal(passportTerm);

end;</source>
    </JadeMethod>
    <JadeMethod name="resetData_37170" id="e20ad1dc-cf48-4003-b2d3-b7397153ce0f">
        <source>resetData_37170();
/*

Purpose:	Reset 37392		

Date		Who		Reason
19/05/2022	navmh5	Initial creation

*/
vars
	
	terminal				: CM_Terminal;
	vvr						: CM_VehicleVisitRecord;
	passportTerm 			: CM_Terminal;
	
begin
	
	app.initialize();
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	foreach vvr in CM_VehicleVisitRecord.instances discreteLock where vvr.regNumber = "37170" and vvr.timeOut = null do
		break;
	endforeach;
	
	if vvr &lt;&gt; null then
		self.ignoreTrxWarnings(true); 
		app.myTrxUA.trxUpdateVVRCancel(vvr, "Last Test Run Failed", app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
epilog

	app.myPassport.setMyTerminal(passportTerm);

end;</source>
    </JadeMethod>
    <JadeMethod name="resetData_37172" id="fc4342b9-24ad-45ac-9e6d-b1b72bdfdd55">
        <source>resetData_37172();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 July 2020	jlgmh5	Initial creation

*/

constants

	VehicleID				: String = "37172";
	ReleaseRequestID		: String = "JLGRRROAD37172A01";


vars

	terminal				: CM_Terminal;
	iMove					: CM_InterTerminalMove;
	iConfig					: CM_InterTerminalConfig;
	ti						: Object;

	tisToDelete				: StringArray;
	tiSet					: CM_TISet;

	trackedItemId			: String;
				
	
begin

	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// delete the vehicle
	self.deleteVehicle(VehicleID);
	
	// delete the release request
	self.deleteReleaseRequest(ReleaseRequestID);
		
	// delete the tracked items
	create tisToDelete transient;
	tisToDelete.add("JLG37172A01");
	
	create tiSet transient;
	
	foreach trackedItemId in tisToDelete do
		
		tiSet.clear();
		terminal.lookupAllTIsOfIdCargoType(trackedItemId, null, tiSet, false, false, null);
		
		if tiSet.isEmpty and trackedItemId.pos(".",1) &gt; 0 then
			ti := trackedItemId.asOid;
			if ti &lt;&gt; null and CM_TrackedItem.hasInstance(ti) then
				tiSet.add( ti.CM_TrackedItem );
			endif;
		endif;
		
		if not tiSet.isEmpty then
			self.deleteTrackedItem(tiSet.first, false);
		endif;	
		
	endforeach;

epilog

	delete tisToDelete;
	delete tiSet;
	
end;
</source>
    </JadeMethod>
