    <JadeMethod name="intersectsPolygon" id="63769b76-83f6-4f8a-864d-61e3aaa1e97a">
        <source>intersectsPolygon( _polygonB : PointArray input; _ignoreEdge : Boolean) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 January 2012	cnwer1	Initial creation PAR 29079

*/

vars
	i : Integer;
	iter, iter2 : Iterator;
	a, b, 
	c, d,
	thisPoint ,
	polygonBPoint: Point;
	allInside : Boolean;
begin
	allInside:= false;
	// check if all points of polygon B are inside this polygon first 
	iter:=_polygonB.createIterator;
	i := 1;
	while iter.next(thisPoint) do
		if thisPoint.insidePolygon(self) then
			if i = 1 then
				allInside:=true;
			else
				allInside := allInside and true;
			endif;
		else
			if i = 1 then
				allInside:=false;
			else
				allInside := allInside and false;
			endif;
		endif;
		i:=i+1;
	endwhile;
	
	if allInside then
		return true;
	endif;
		
	
	delete iter;
	
	if not _ignoreEdge then
		// iterate through all the edges checking if they intersect with the edge from they other polygon
		iter := self.createIterator;
		while iter.next(thisPoint) do
			if a = null then
				a := thisPoint;
				continue;
			endif;
			
			b := thisPoint;
			
			delete iter2;
			iter2 :=_polygonB.createIterator;
			while iter2.next(polygonBPoint) do
				if c  = null then
					c := polygonBPoint;
					continue;
				endif;
				
				d := polygonBPoint;
				
				if self.edgeIntersection(a,b,c,d) then
					return true;
				endif;
				c := polygonBPoint;
			endwhile;
					
			a := thisPoint;
		endwhile;
	endif;
	
	return false;
epilog
	delete iter;
	delete iter2;
end;</source>
        <Parameter name="_polygonB" type="PointArray" usage="input"/>
        <Parameter name="_ignoreEdge" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="intersectsPolygonOther" id="5bfb8c7f-1b4f-4fb1-8a80-e9b0a4f06bfd">
        <source>intersectsPolygonOther( _polygonB : PointArray input) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 January 2012	cnwer1	Initial creation PAR 29079

*/

vars
	i : Integer;
	iter, iter2 : Iterator;
	a, b, 
	c, d,
	thisPoint ,
	polygonBPoint: Point;
	allInside : Boolean;
begin
	allInside:= false;
	// check if all points of polygon B are inside this polygon first 
	iter:=_polygonB.createIterator;
	i := 1;
	while iter.next(thisPoint) do
		if thisPoint.insidePolygon(self) then
			if i = 1 then
				allInside:=true;
			else
				allInside := allInside and true;
			endif;
		else
			if i = 1 then
				allInside:=false;
			else
				allInside := allInside and false;
			endif;
		endif;
		i:=i+1;
	endwhile;
	
	if allInside then
		return true;
	endif;
	
	return false;
epilog
	delete iter;
	delete iter2;
end;</source>
        <Parameter name="_polygonB" type="PointArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isInIntersection" id="4dc78b26-10d1-47d7-91e5-8749bea1a8e8">
        <source>isInIntersection(x, y, x0, y0, x1, y1 : Integer) : Boolean protected;
/*
 ------------------------------------------------------------------------
Created:			20 November 2002 by cnwdwq1
Purpose:			Determine if the line (0,y)-(x,y) intersects (x0,y0)-(x1,y1)
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	a  : Real;
	xi, b: Integer;
begin

	// test for intersection
	// NB the &lt;= and &gt;= are highly significant see the comment above.

	// y0 and y1 are either side of y
// AKB2005DEC changed this. Removed '='. If the polygon is a rectangle that is 'square' on the screen the equals was making this pick up polygons away from the actual X,Y
// WAS	if   ( ((y0 &gt;= y) and (y1 &lt; y) ) or ( (y1 &gt; y)  and (y0 &lt;= y) ) ) 
	if   ( ((y0 &gt; y) and (y1 &lt; y) ) or ( (y1 &gt; y)  and (y0 &lt; y) ) ) then
		// if an x value on (x0,y0) to (x1,y1) lies in the range x to 0.
		if ( (x0 &lt;= x) or (x1 &lt; x) ) then
			// find X intercept
			a := ((y-y0) ).Real / (y1-y0);

// PAR 27749 WAS JULY 2011 AKB			xi :=  ((a*(x1-x0) +0.5).Integer) +x0;
			b :=(a*(x1-x0)).roundedUp();
			xi :=  b +x0;
			if xi &lt;= x then
				return true;
			endif;
		endif;
	endif;
	return false;
end;</source>
        <access>protected</access>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <Parameter name="x0" type="Integer"/>
        <Parameter name="y0" type="Integer"/>
        <Parameter name="x1" type="Integer"/>
        <Parameter name="y1" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isInIntersectionTEST" id="5e2221c2-61f5-4a73-8ad3-7a1fe9b09b42">
        <source>isInIntersectionTEST(x, y, x0, y0, x1, y1 : Integer; _code : String) : Boolean protected;
/*
 ------------------------------------------------------------------------
Created:			20 November 2002 by cnwdwq1
Purpose:			Determine if the line (0,y)-(x,y) intersects (x0,y0)-(x1,y1)
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	a  : Real;
	xi, b: Integer;
begin

	// test for intersection
	// NB the &lt;= and &gt;= are highly significant see the comment above.
if  _code = "D6141" or _code = "D6140" then
	app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 0. CODE: ' &amp; _code );
endif;
	// y0 and y1 are either side of y
// AKB2005DEC changed this. Removed '='. If the polygon is a rectangle that is 'square' on the screen the equals was making this pick up polygons away from the actual X,Y
// WAS	if   ( ((y0 &gt;= y) and (y1 &lt; y) ) or ( (y1 &gt; y)  and (y0 &lt;= y) ) ) 
	if   ( ((y0 &gt; y) and (y1 &lt; y) ) 
	or ( (y1 &gt; y)  and (y0 &lt; y) ) ) then
		// if an x value on (x0,y0) to (x1,y1) lies in the range x to 0.
if  _code = "D6141" or _code = "D6140" then
	app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1. CODE: ' &amp; _code &amp; '       TRUE X: ' &amp; x.String &amp; " Y: " &amp; y.String &amp; "      X0: " &amp;  x0.String &amp; " Y0: " &amp;  y0.String &amp; "      X1: " &amp;  x1.String &amp; " Y1: " &amp;  y1.String  &amp; " xi: " &amp; xi.String);
endif;
		if ( (x0 &lt;= x) or (x1 &lt; x) ) then
if  _code = "D6141" or _code = "D6140" then
	app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 2. TRUE X: ' &amp; x.String &amp; " Y: " &amp; y.String &amp; "      X0: " &amp;  x0.String &amp; " Y0: " &amp;  y0.String &amp; "      X1: " &amp;  x1.String &amp; " Y1: " &amp;  y1.String  &amp; " xi: " &amp; xi.String);
endif;
			// find X intercept
			a := ((y-y0) ).Real / (y1-y0);

// PAR 27749 WAS JULY 2011 AKB			xi :=  ((a*(x1-x0) +0.5).Integer) +x0;
			b :=(a*(x1-x0)).roundedUp();
			xi :=  b +x0;
			if xi &lt;= x then
if  _code = "D6141" or _code = "D6140" then
	app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 3. TRUE X: ' &amp; x.String &amp; " Y: " &amp; y.String &amp; "      X0: " &amp;  x0.String &amp; " Y0: " &amp;  y0.String &amp; "      X1: " &amp;  x1.String &amp; " Y1: " &amp;  y1.String  &amp; " xi: " &amp; xi.String);
endif;
				return true;
			endif;
		endif;
	endif;
if  _code = "D6141" or _code = "D6140" then
	app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 4. FALSE ' &amp; x.String &amp; " " &amp; y.String &amp; " " &amp;  x0.String &amp; " " &amp;  y0.String &amp; " " &amp;  x1.String &amp; " " &amp;  y1.String  );
endif;
	return false;
end;</source>
        <access>protected</access>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <Parameter name="x0" type="Integer"/>
        <Parameter name="y0" type="Integer"/>
        <Parameter name="x1" type="Integer"/>
        <Parameter name="y1" type="Integer"/>
        <Parameter name="_code" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isPointInPolygon" id="af5878d4-004e-4043-bbc4-ff3d19f93650">
        <source>isPointInPolygon(x, y : Integer; _scale : Real) : Boolean;
/*
 ------------------------------------------------------------------------
Created:			20 November 2002 by cnwdwq1
Purpose:			Determine if the given point is within the polygon.
							Draw an imaginary line from (x,y) to (0,y) ie parallel to xaxis
							check each side of the polygon for intersection
							if the number of intersections is odd (x,y) is inside else outside
							if the imaginary line passes through a vertex of the polygon it
							only counts as intersecting with one side
							Converted from C++
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
29 June 2016	cnwmc5			Re-wrote this method to test more accurately when clicking on lines
								See TFS 2214
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars
	realPoint,
	point,
	otherPoint,
	testPoint	: Point;
	
	result 		: Boolean;
	i, j		: Integer;
	
begin
	
	testPoint.setX(x);
	testPoint.setY(y);
	
	result := false;
	i := 1;
	j := self.size;
	
	foreach realPoint in self do
		point.setX((realPoint.x * _scale).Integer);
		point.setY((realPoint.y * _scale).Integer);
		otherPoint.setX((self[j].x * _scale).Integer);
		otherPoint.setY((self[j].y * _scale).Integer);
		
		if (point.y &lt; testPoint.y and otherPoint.y &gt;= testPoint.y) or (otherPoint.y &lt; testPoint.y and point.y &gt;= testPoint.y) then
			if point.x + (testPoint.y - point.y) / (otherPoint.y - point.y) * (otherPoint.x - point.x) &lt; testPoint.x then
				result := not result;
			endif;
		endif;
		
		j := i;
		i := i + 1;
	endforeach;
	
	return result;
	
epilog
	
end;


/*
vars
	x0, y0, xOrg, yOrg : Integer;
	point : Point;
	numIntersections, tmpResult : Integer;
begin

	if self.isEmpty then
		return false;
	endif;
	xOrg := (self.first.x * _scale).Integer;
	yOrg := (self.first.y * _scale).Integer;
	x0 := xOrg;
	y0 := yOrg;

	foreach point in self do
		if self.isInIntersection( x, y, x0, y0, (point.x * _scale).Integer, (point.y * _scale).Integer) then
			numIntersections := numIntersections + 1;
		endif;
		x0 := (point.x * _scale).Integer;
		y0 := (point.y * _scale).Integer;
	endforeach;

	//close the polygon
	if self.isInIntersection( x, y, x0, y0, xOrg, yOrg ) then
		numIntersections := numIntersections + 1;
	endif;

	tmpResult := numIntersections mod 2;
	return (tmpResult &lt;&gt; 0);

end;
*/</source>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <Parameter name="_scale" type="Real"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isPointInPolygonTEST" id="b2e12d28-5434-480a-a30f-55c81c4949e4">
        <source>isPointInPolygonTEST(x, y : Integer; _scale : Real; _code : String) : Boolean;
/*
 ------------------------------------------------------------------------
Created:			20 November 2002 by cnwdwq1
Purpose:			Determine if the given point is within the polygon.
							Draw an imaginary line from (x,y) to (0,y) ie parallel to xaxis
							check each side of the polygon for intersection
							if the number of intersections is odd (x,y) is inside else outside
							if the imaginary line passes through a vertex of the polygon it
							only counts as intersecting with one side
							Converted from C++
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	x0, y0, xOrg, yOrg : Integer;
	point : Point;
	numIntersections, tmpResult : Integer;
begin
if  _code = "D6141" then
	app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1.' );
endif;

	if self.isEmpty then
		return false;
	endif;
	xOrg := (self.first.x * _scale).Integer;
	yOrg := (self.first.y * _scale).Integer;
	x0 := xOrg;
	y0 := yOrg;

	foreach point in self do
		if self.isInIntersectionTEST( x, y, x0, y0, (point.x * _scale).Integer, (point.y * _scale).Integer,_code) then
			numIntersections := numIntersections + 1;
		endif;
		x0 := (point.x * _scale).Integer;
		y0 := (point.y * _scale).Integer;
	endforeach;

	//close the polygon
	if self.isInIntersectionTEST( x, y, x0, y0, xOrg, yOrg,_code ) then
		numIntersections := numIntersections + 1;
	endif;

	tmpResult := numIntersections mod 2;
	return (tmpResult &lt;&gt; 0);

end;</source>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <Parameter name="_scale" type="Real"/>
        <Parameter name="_code" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isPointInRectangleBLTR" id="f7256915-f687-47eb-8064-de5dd6bdbf37">
        <source>isPointInRectangleBLTR(x, y : Integer) : Boolean;
/*
Purpose: Assumes that self is a polygon that is a rectangle, that is 'square' or 'plumb' to the screen
Date				Who			Reason
JULY 2011		CNWAB1		Initial creation
*/


vars
	point1, point2 : Point;
begin

	if self.isEmpty then

		return false;
	endif;
	
	point1 := self[1]; // Corner 1 - bottom left
	point2 := self[3]; // Corner 2 - top right

	return (x &gt;= point1.x and x &lt;= point2.x)	and (y &lt;= point1.y and y &gt;= point2.y);
	


end;</source>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isPointInRectangleTLBR" id="8a9c174e-b688-415b-82a1-de6beb373021">
        <source>isPointInRectangleTLBR(x, y : Integer) : Boolean;
/*
Purpose: Assumes that self is a polygon that is a rectangle, that is 'square' or 'plumb' to the screen
Date				Who			Reason
JULY 2011		CNWAB1		Initial creation
*/


vars
	point1, point2 : Point;
begin

	if self.isEmpty then
		return false;
	endif;
	
	point1 := self[1]; // Corner 1 - top left
	point2 := self[3]; // Corner 2 - bottom right

	return (x &gt;= point1.x and x &lt;= point2.x)	and (y &gt;= point1.y and y &lt;= point2.y);
	


end;</source>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="movePolygon" id="75195cab-beee-4e67-b073-77e148182de7">
        <source>movePolygon(_left : Integer; _top : Integer) : PointArray;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		move all the points by the left and top params
// ---------------------------------------------------------------------------
vars
	tmpPoints : PointArray;
	pntX, pntY : Integer;
	aPoint,tmpPoint : Point;
begin
	create tmpPoints transient;

	foreach aPoint in self do
		tmpPoint.set((aPoint.x + _left).Integer,(aPoint.y + _top).Integer);
		tmpPoints.add(tmpPoint);
	endforeach;
	return tmpPoints;
end;</source>
        <Parameter name="_left" type="Integer"/>
        <Parameter name="_top" type="Integer"/>
        <ReturnType type="PointArray"/>
    </JadeMethod>
    <JadeMethod name="populateRealArray" id="0da1c817-1621-44a2-a809-804266ce6242">
        <source>populateRealArray(_realArray: RealArray input; _scale : Decimal);
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		The DrawPolygon command uses a RealArray, but we store Points in PointArrays.
//
// ---------------------------------------------------------------------------

vars
	pntX, pntY,idx : Integer;
	scale : Decimal[6,2];
	aPoint : Point;
begin
	if _realArray = null then
 		return;
 	endif;
 	
	scale := _scale;
	
	foreach aPoint in self do
	
		
		_realArray.add(aPoint.x * scale);
		_realArray.add(aPoint.y * scale);
		idx := idx + 1;
		
		/* PAR 30294
		// a bug in the drawPolygon command means that 64 points, 128 Reals, is the maximum. 
		// If this blows it takes out the appServer! - fixed in V6 of Jade.
		if idx = 64 then 
		
		*/
		if idx = 500 then // PAR 30294 - increased to stop looping, just in case.
			break;
		endif;
	endforeach;
end;</source>
        <Parameter name="_realArray" type="RealArray" usage="input"/>
        <Parameter name="_scale" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="splitPolygon" id="f6120884-3983-4395-ba50-3f71fd6dbe7e">
        <lockReceiver/>
        <updating/>
        <source>splitPolygon(_rows : Integer; _columns : Integer; _theRectangles : ObjectArray input) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		pass in a polygon (self), that must be a rectangle, and number of rows and columns.
//				pass out an array of PointArrays, 1 for each row/column intersection
// ---------------------------------------------------------------------------
vars
	theWidth, theHeight, pntX1, pntX2, pntY1, pntY2, idx, tmpX,tmpY : Integer;
	point1, point2, tmpPoint : Point;
	theXs , theYs : IntegerArray;
begin
	if self.size &lt; 5 then
		return;
	endif;
	// NOTE it is assumed that the rectangle starts drawing at top left hand corner,
	// so the first and second point  give us the width and the second and third point give us the height
	
	point1 := self[1];
	point2 := self[2];
	
	pntX1 := point1.x;
	pntY1 := point1.y;

	pntX2 := point2.x;
	pntY2 := point2.y;
	
	// the width/height of each line along the first side
	theWidth := (((pntX2 - pntX1) / _rows) + pntX1).Integer;
	theHeight := (((pntY2 - pntY1) / _columns) + pntY1).Integer;
	
	// move along the first side and work out each point
	theXs.add(pntX1);
	foreach idx in 1 to _rows do
		tmpX := (pntX1 + (theWidth * idx)).Integer;
		theXs.add(tmpX);
	endforeach;

	theYs.add(pntY1);
	foreach idx in 1 to _columns do
		tmpY := (pntY1 + (theHeight * idx)).Integer;
		theYs.add(tmpY);
	endforeach;

end;</source>
        <Parameter name="_rows" type="Integer"/>
        <Parameter name="_columns" type="Integer"/>
        <Parameter name="_theRectangles" type="ObjectArray" usage="input"/>
    </JadeMethod>
</CollClass>
