    <JadeMethod name="getDisplayStringForAttribute" id="5c71a019-927b-4e9b-a71d-c6beb890150f">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	
	if _attrName  = ETRow_QualifyingRemarks then
		return self.clearingRemarks;
	elseif _attrName = ETRow_QualifyingUser then
		return self.clearingUserId;
	elseif _attrName = ETRow_QualifyingDT then
		return self.systemToLocalTime(self.clearedDateTime).asStringJMT;	// 5/5/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_StatusChangeReason then
		return self.clearingRemarks;
	elseif _attrName = ETRow_StatusChangeReasonCode then
		return self.statusChangeReasonCode;
	endif;
	
	return "Unknown";

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="415e1d0f-fdd1-46b0-800a-69e3e903d9c0">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	block : CM_DataContainerBlock;
	ts: TimeStamp;

begin
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Sequence_Number), DC_Label, 1, self);
	block.addNewItem(self.sequenceNum.String, DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Remarks_GC), DC_Label, 1, self);
	block.addNewItem(self.getDetails, DC_Data, 1, self);


	if self.clearedDateTime &lt;&gt; null then
		ts := self.systemToLocalTime(self.clearedDateTime);	// 23/5/16 cnwmp6 TFS 488 - Multi timezone support
	
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Qualifying_Date), DC_Label, 1, self);
		block.addNewItem(ts.date.shortFormatJMT() &amp; " " &amp; ts.time.currentLocaleFormatJMT(), DC_Data, 1, self);	// 23/5/16 cnwmp6 TFS 488 - Multi timezone support

		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Qualifying_User), DC_Label, 1, self);
		block.addNewItem(self.clearingUserId, DC_Data, 1, self);

		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Qualifying_Remarks), DC_Label, 1, self);
		block.addNewItem(self.clearingRemarks, DC_Data, 1, self);
	endif;

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
