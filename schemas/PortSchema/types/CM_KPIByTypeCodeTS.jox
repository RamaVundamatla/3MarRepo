<CollClass name="CM_KPIByTypeCodeTS" id="37289c94-4b3b-4ec0-b3e8-ec07afe2925c">
    <duplicatesAllowed/>
    <loadFactor>66</loadFactor>
    <memberType name="CM_KPI"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="statistic"/>
    <MemberKey>
        <property name="CM_KPI::type"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_KPI::code"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_KPI::dateTime"/>
    </MemberKey>
    <JadeMethod name="getKPIByType" id="55d63cec-0c44-4a74-8398-351e5fe4e6d5">
        <source>getKPIByType(_type :Integer; _coll :ObjectArray input);
/*
Date		Who		Reason
02 August 2011	cnwcs5	Initial creation - CCMS MES 1033 
*/
vars
	iter	:Iterator;
	kpi		:CM_KPI;
begin
	iter := self.createIterator;
	
	self.startKeyGeq (_type, null, null, iter);
	
	while iter.next (kpi) do
		if kpi.type &lt;&gt; _type then
			break;
		endif;
		
		_coll.add (kpi);
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_coll" type="ObjectArray" usage="input"/>
    </JadeMethod>
</CollClass>
