    <JadeMethod name="getOverunderDisplay" id="cbd88dd1-6227-4e02-a830-e77014c887e7">
        <source>getOverunderDisplay() : String;
/*

Date		Who		Reason
26 September 2014	cnwer1	Initial creation PAR

*/

vars
	overUnder : String;
	count 	: Decimal[14,4];
begin
	if self.isBulkMulti then
		count:=self.getOverunderWeight();
		overUnder:= self.myCargoType.getBulkTrackByDisplayForWeight(count,self.getDensity,true);
	else
		count:=self.getOverunderCount();
		overUnder:=count.Integer.asStringJMT;
	endif;
	
	if count &gt; 0 then	
		return "+" &amp; overUnder;	
	elseif count = 0 then
		return null;
	else
		return overUnder;
	endif;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
