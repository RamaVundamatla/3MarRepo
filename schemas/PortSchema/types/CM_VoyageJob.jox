    <JadeMethod name="isSOB" id="5099e32a-3126-46db-886b-96803deb8df1">
        <source>isSOB() : Boolean;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
