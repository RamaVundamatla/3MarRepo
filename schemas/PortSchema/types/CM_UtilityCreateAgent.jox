    <JadeMethod name="utlCreateDelay" id="3122ea15-16b6-4c08-b2bd-992f09b0ad18">
        <updating/>
        <source>utlCreateDelay(_proxy : CM_Delay; _realDelay : CM_Delay output; _passport : CM_Passport input ) updating;
/*
----------   ----------  --------------------------------------------------
Created:	13 February 2007 By cnwmo1

Changed On  Changed By  Reason

08/11/2012	cnwcs5		par 30519 - add notifications/change parameter usage
21 Sep 2020 cnwma1 		ChangeRequest 49906: MTN - Ops View External Webservice
----------  ----------  --------------------------------------------------
*/
vars
	delay	: CM_Delay;
	voyage	: CM_Voyage;
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valDelay(_proxy);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	create delay persistent;
	
	delay.setForCreate(_proxy);
		
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(delay);
		
		// par 30519 - if the delay os for a voyage then cause a notification event
		voyage := delay.myVoyage;
		
		if voyage &lt;&gt; null then
			//21.09.2020 cnwma1 TFS #49906
			if _passport.isOpsViewEnabled(delay.myTerminal) then
				delay.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,
											  BGP_OpsViewWSRequest.OPS_TYPE_DELAY,
											  delay);
			endif;
			//21.09.2020 cnwma1 TFS #49906
			voyage.causeEvent (voyage.myTerminal.getTerminalEvent (EVENT_DELAY_CREATE), false, delay);
		endif;
	endif;	
	
	_realDelay := delay;

end;
</source>
        <Parameter name="_proxy" type="CM_Delay"/>
        <Parameter name="_realDelay" type="CM_Delay" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateDelayType" id="86f64893-a855-45d7-a4b4-9731ac0cc420">
        <source>utlCreateDelayType(pProxyDelayType :CM_DelayType; pNewDelayType:CM_DelayType output;
				_passport : CM_Passport input);
/*
----------   ----------  --------------------------------------------------
Created:	31 January 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
21 Sep 2020  cnwma1      ChangeRequest 49906: MTN - Ops View External Webservice	
----------   ----------  --------------------------------------------------
*/
vars
	cancelSave : Boolean;
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valDelayType(pProxyDelayType);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	app.setContinueCMExceptions(false);

	create pNewDelayType persistent;
	pNewDelayType.setForCreate(pProxyDelayType);
	
	
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(pNewDelayType);
	endif;	
	
	//21.09.2020 cnwma1 TFS #49906
	if _passport.noErrors then
		if _passport.isOpsViewEnabled(null) then
			pNewDelayType.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,
												  BGP_OpsViewWSRequest.OPS_TYPE_DELAYTYPE,
												  pNewDelayType);
        endif;
	endif;
	//21.09.2020 cnwma1 TFS #49906
end;
</source>
        <Parameter name="pProxyDelayType" type="CM_DelayType"/>
        <Parameter name="pNewDelayType" type="CM_DelayType" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
