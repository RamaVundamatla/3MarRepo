    <JadeMethod name="validateForCreate" id="8793e781-11bc-4a0f-8386-9a98f5a7c825">
        <source>validateForCreate();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 July 2009	cnwrd1	Initial creation
11 Oct 2021 	jlier1			TFS 51963 removed inaportnet
*/

vars
	dtl : CM_WorkOrderDtl;
begin
	
	// check if we have an ID yet if so is it valid
	
	if self.id &lt;&gt; null and  self.myTerminal.allWorkOrders[self.id] &lt;&gt; null then
		app.raiseCMException1(WorkOrder_ID_already_exists, self.id, null, null);
	endif;

	//epr TFS 41267 24/10/18
	
	if self.allWoDtls.size = 0 then		

		app.raiseCMException(Work_order_no_tasks, null, null);

	endif;

	foreach dtl in self.allWoDtls do
		dtl.validateForCreate();
	endforeach;
	
	if self.taskStatus = WO_STATUS_APPROVED then
		self.validateForApproval();
	endif;
epilog

end;</source>
    </JadeMethod>
