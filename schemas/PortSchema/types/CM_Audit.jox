    <JadeMethod name="addUnauditedFO" id="5eeac075-7e90-444f-b611-c3cfa6e95d66">
        <source>addUnauditedFO(_financialObject: CM_FinancialObject);

vars

begin
	// if this object has already been audited then remove it from the audited list
	if auditedFOs.includes(_financialObject) then
		auditedFOs.remove(_financialObject);
	endif;
	if _financialObject.unqualifiedAudits[self.sequenceNum] = null then // PAR 15036 added
		if not unauditedFOs.includes(_financialObject) then
			unauditedFOs.add(_financialObject);
		endif;
	endif;
end;</source>
        <Parameter name="_financialObject" type="CM_FinancialObject"/>
    </JadeMethod>
