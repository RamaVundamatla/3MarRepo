	//self.cmb_Customer.addItem('Sjursřya Container Terminal');			// TFS 38497 - Now Salerno Container Terminal
	self.cmb_Customer.addItem('South Port');
	self.cmb_Customer.addItem('Steinweg - Oman');
	self.cmb_Customer.addItem('Steinweg - Rotterdam');
	self.cmb_Customer.addItem('Tradepoint Atlantic');
	
	self.cmb_Topic.clear();
	self.cmb_Topic.addItem('Automatic planning');
	self.cmb_Topic.addItem('Background Apps');
	self.cmb_Topic.addItem('Backup');
	self.cmb_Topic.addItem('Bookings');
	self.cmb_Topic.addItem('Cargo Enquiry/Edit');
