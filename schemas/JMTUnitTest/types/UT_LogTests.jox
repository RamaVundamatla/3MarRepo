    <JadeMethod name="logConsignorTest" id="839e42f1-4238-406c-aeb6-a68a582d2fef">
        <source>logConsignorTest();
//	27 January 2011	cnwvu1
//	ccms 1116, #26786Consignor on a BOL and on the corresponding logs should be the same unconditionaly.

vars
	consignorOld,
	consignorNew: String;
	con			: CM_ConsigneeConsignor;
	bolIn		: CM_BOLIn;
	
begin

	self.createLocationForLogModuleTest(self.LocationConsignorTest);
	self.createBOLInLogsForLogModuleTst(self.LocationConsignorTest, self.BOLInNumber_ConsignorTest,  self.BOLInNumber_ConsignorTest[1:6] &amp; "LOG", 10);

	// getting an "old" consignor and checking for all lgs shold eb the same
	bolIn	:= self.getBOLIn( self.BOLInNumber_ConsignorTest, self.OperatorCode );
	consignorOld := bolIn.consignor;

	// getting a new consignor
	foreach con in app.myRoot.allConsigneeConsignors do
		if con.isConsignor and con.code &lt;&gt; consignorOld then
			consignorNew := con.code;
			break;
		endif;
	endforeach;
	self.assertTrueMsg(consignorNew &lt;&gt; null, "New consignor not found.");

	self.logConsignorTestCompare(consignorOld);
	
	self.logConsignorChangeForDocket(consignorNew);	//set a new consignor for log docket
	
	self.logConsignorTestCompare(consignorNew);

end;</source>
    </JadeMethod>
    <JadeMethod name="logConsignorTestCompare" id="8fcdebe2-71da-453c-887d-aa958024452f">
        <source>logConsignorTestCompare(_consignorCode: String);
//	28 January 2011	cnwvu1

vars
	bolIn	: CM_BOLIn;
	ti		: CM_TrackedItem;
	
begin

	bolIn	:= self.getBOLIn( self.BOLInNumber_ConsignorTest, self.OperatorCode );
	
	self.assertTrueMsg(bolIn.consignor = _consignorCode, "Test consignor " &amp; _consignorCode &amp; " is different for log docket " &amp; bolIn.number &amp; " with consignor " &amp; bolIn.consignor);
	
	foreach ti in bolIn.allTrackedItems do
		self.assertTrueMsg(ti.consignor = _consignorCode, "Test consignor " &amp; _consignorCode &amp; " is different for log " &amp; ti.id &amp; " with consignor " &amp; ti.consignor);
	endforeach;
	
end;</source>
        <Parameter name="_consignorCode" type="String"/>
    </JadeMethod>
