    <JadeMethod name="myCargoType" id="19cdc968-cbd3-4ca8-8f6b-e362ad7e5a11">
        <methodInvocation>mapping</methodInvocation>
        <source>myCargoType(set: Boolean; _value: CM_CargoType io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2014	cnwndl1	Initial creation	Par 35008

*/

vars

begin
	
	if _value = null then
		if self.myReserveSelection &lt;&gt; null then
			_value := self.myReserveSelection.getCargoType;
		endif;
	endif;
	if _value = null then
		if self.myRequest &lt;&gt; null then
			_value := self.myRequest.getCargoType;
		endif;
	endif;

epilog

end;</source>
