    <JadeMethod name="doResize" id="ed26f28d-4077-4f59-8075-1fe366f5f865">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:     15 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();
	//splitters
	splMain.cnEcResizeContents();

	//fldTreeView
	self.shtListPorts.width := self.fldTreeView.width - 1;
	self.shtListPorts.height := self.fldTreeView.height - 15;
	self.shtListSuppliers.width := self.shtListPorts.width;
	self.shtListSuppliers.height := self.shtListPorts.height;
	self.lstPorts.width := self.shtListSuppliers.width - 2;//par 13444
	self.lstPorts.height := self.shtListSuppliers.height - 1;
	self.lstSuppliers.width := self.shtListSuppliers.width - 1;
	self.lstSuppliers.height := self.shtListSuppliers.height - 1;
	
	//Do the sheets
	self.setupVisibleSheet();

end;</source>
    </JadeMethod>
    <JadeMethod name="editName" id="a83d6751-8558-4fdc-9b39-1704d3ea44e5">
        <updating/>
        <source>editName() updating;
// CCMS 1124 vessel name is maintained separately
vars
	code,
	imo		: String;
	form	: LOG_VesselNameEdit;
begin
	code := self.tblVoyageAdmin.getValueByName(ETRow_IMO).String.trimBlanks();
	if code = null then
		return;
	endif;

	create form transient;
	form.imo := code[1:7];

	form.centreWindow();
	form.showModal;
	
	if form.vesselName &lt;&gt; null then
		self.tblVoyageAdmin.setValueByName(ETRow_VesselName, form.vesselName);
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="findBerth" id="630e3c9d-04f4-4e6a-8250-bda3c2991d49">
        <source>findBerth(_terminal : CM_Terminal; _value : String) : HMS_Berth protected;
// CCMS 1124 find berth from combo text
vars
	harbour		: HMS_Harbour;
	wharf		: HMS_Wharf;
	berth		: HMS_Berth;
	
begin
	
	harbour := _terminal.myHarbour;
	if harbour &lt;&gt; null then
		wharf := harbour.allWharves.first;
		if wharf &lt;&gt; null then
			foreach berth in wharf.allBerths do
				if berth.code = _value then
					return berth;
				endif;
			endforeach;
		endif;
	endif;
	
	return null;
end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_value" type="String"/>
        <ReturnType type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="findVesselName" id="d2482d57-c6ae-450d-b8d0-cb0d44cd67a8">
        <source>findVesselName(_code : String) : String protected;
// CCMS 1124 use the IMO value to find a vessel name without using CM_Vessels for logs
//  CM_CurrencyCode is used to hold the IMO and vessel name.
vars
	code	: CM_CurrencyCode;
begin
	code := app.myRoot.allCurrencyCodes[_code];

	if code = null then
		return null;
	else
		return code.description;
	endif;
end;
</source>
        <access>protected</access>
        <Parameter name="_code" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
