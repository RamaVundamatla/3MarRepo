end;</source>
        <Parameter name="cmd" type="String"/>
        <Parameter name="cmdLog" type="String"/>
    </JadeMethod>
    <JadeMethod name="doPerfMonLog" id="de646897-ea66-4e2a-a0f2-8409034f0c8c">
        <updating/>
        <source>doPerfMonLog(sess,eventType:Integer) updating;

vars
	logDir,cmdLog,comp,cmdLogAdditional:String;
	ff:FileFolder;
	i,interval:Integer;
begin
	myBmkControl:=global.allBmkControls[sess];
	/*if myBmkControl.owner &lt;&gt; "cnwjhp1" or myBmkControl.owner &lt;&gt; "cnwjbl5"  then
		global.causeEvent(Bmk_Result, true, method.qualifiedName&amp;" PerfMonLogs disabled for stdruns");
		return;
	endif;
	*/
	if myBmkControl.owner = userCode then
		targetSession:=sess;
		setInfo_Creator;
    
		create ff;
		if myBmkControl.rapHost = computerName then  // I am the rap machine CreatorCreator
			logDir:=app.getProfileString(myBmkControl.iniFileName, "JadeLog", "LogDirectory", "c:\temp");
			ff.fileName:=app.getJadeInstallDir&amp;"\PerfMonLogs";
			ff.make;
			app.logMessage("session="&amp;sess.String&amp;", logdir="&amp;logDir);

		elseif copies &gt; 0 or copies = -99 then  // I am a client machine CreatorCreator or special include
			logDir:=app.getJadeInstallDir&amp;"\PerfMonLogs";
		else
			return;
		endif;

		ff.fileName:=logDir;
		ff.make;

		cmdLog:=' &gt;&gt; '&amp;logDir&amp;'\cmd.log';
		if eventType = Bmk0_Start_PerfMonLog then
			// first clear any running perfmons
			doCmd('logman stop JBLPerf', cmdLog);
			//doCmd('logman delete counter JBLPerf', cmdLog); // Counter Doesn't work on 2008
			doCmd('logman delete JBLPerf', cmdLog);  
			process.sleep(500);
			
			foreach i in 1 to (myBmkControl.appServers) do : outer
				cmdLogAdditional := cmdLogAdditional&amp;' "\Process(Jadapp#' &amp; i.String &amp; ')\Virtual Bytes Peak"';
				cmdLogAdditional := cmdLogAdditional&amp;' "\Process(Jadapp#' &amp; i.String &amp; ')\Working Set"';
				cmdLogAdditional := cmdLogAdditional&amp;' "\Process(Jadapp#' &amp; i.String &amp; ')\% Processor Time"';
				cmdLogAdditional := cmdLogAdditional&amp;' "\Process(Jadapp#' &amp; i.String &amp; ')\ID Process"';
				// Quick Hack to limit size of counter so it will start on Windows 2008
				
				if i &gt; 4 then break outer;
				endif;
			endforeach;
			interval:=15;
			/*if myBmkControl.owner = 'cnwjhp1' then
				cmdLogAdditional := cmdLogAdditional
						&amp;' "\LogicalDisk(V:)\% Disk Read Time"'
						&amp;' "\LogicalDisk(V:)\% Disk Write Time"';
			endif;/**/
			//if myBmkControl.product = 'skiiiiiiiiiiidemo' and myBmkControl.rapHost = "cnwchcs46" then
			cmdLogAdditional := 
					  ' "\LogicalDisk(T:)\Avg. Disk sec/Read"'
					&amp;' "\LogicalDisk(T:)\Avg. Disk sec/Write"'
					&amp;' "\LogicalDisk(T:)\Disk Reads/sec"'
					&amp;' "\LogicalDisk(T:)\Disk Writes/sec"'
					&amp;' "\LogicalDisk(T:)\Avg. Disk Bytes/Read"'
					&amp;' "\LogicalDisk(U:)\Avg. Disk sec/Read"'
					&amp;' "\LogicalDisk(U:)\Avg. Disk sec/Write"'
					&amp;cmdLogAdditional;
			//endif;
			if myBmkControl.session = 6 then  // special for kairos testing
				cmdLogAdditional := cmdLogAdditional&amp;' "\Process(w3wp)\Working Set"';
				cmdLogAdditional := cmdLogAdditional&amp;' "\Process(w3wp#1)\Working Set"';
				cmdLogAdditional := cmdLogAdditional&amp;' "\Process(w3wp)\% Processor Time"';
				cmdLogAdditional := cmdLogAdditional&amp;' "\Process(w3wp#1)\% Processor Time"';
			endif;
							
			doCmd('logman create counter JBLPerf'
					&amp;' -o '&amp;logDir&amp;'\'&amp;computerName.asAbbrevHost&amp;'_PerfMonLog -si '&amp;interval.String&amp;' -f csv -v mmddhhmm -c'
					&amp;' "\Processor(_Total)\% Processor Time"'
					&amp;' "\LogicalDisk(C:)\% Disk Read Time"'
					&amp;' "\LogicalDisk(C:)\% Disk Write Time"'
					&amp;' "\LogicalDisk(T:)\% Disk Read Time"'
					&amp;' "\LogicalDisk(T:)\% Disk Write Time"'
					&amp;' "\LogicalDisk(T:)\Avg. Disk Read Queue Length"'
					&amp;' "\LogicalDisk(T:)\Avg. Disk Write Queue Length"'
					&amp;' "\LogicalDisk(U:)\% Disk Read Time"'
					&amp;' "\LogicalDisk(U:)\% Disk Write Time"'
					&amp;' "\LogicalDisk(U:)\Avg. Disk Read Queue Length"'
					&amp;' "\LogicalDisk(U:)\Avg. Disk Write Queue Length"'
					&amp;' "\Memory\Available MBytes"'
					&amp;' "\Cache\Copy Read Hits %"'
					&amp;' "\Cache\Copy Reads/sec"'
					&amp;' "\Process(_Total)\Virtual Bytes Peak"'
					&amp;' "\Process(Jadrap)\% Processor Time"'
					&amp;' "\Process(Jadrap)\Virtual Bytes Peak"'
					&amp;' "\Process(Jadrap)\Virtual Bytes"'
					&amp;' "\Process(Jadrap)\Working Set"'
					&amp;' "\Process(Jadrap)\ID Process"'
					&amp;' "\Process(Jadrap#1)\Virtual Bytes Peak"'
					&amp;' "\Process(Jadrap#1)\% Processor Time"'
					&amp;' "\Process(Jadrap#1)\ID Process"' 
					&amp;' "\Process(Jadapp)\Virtual Bytes Peak"'
					&amp;' "\Process(Jadapp)\Working Set"'
					&amp;' "\Process(Jadapp)\% Processor Time"'
					&amp;' "\Process(Jadapp)\ID Process"' 
					&amp;' "\System\Context Switches/sec"'
					&amp;cmdLogAdditional
					,cmdLog);
			doCmd('logman start JBLPerf', cmdLog);
			global.causeEvent(Bmk0_Start_PerfMonLog*-1, true, sess);

		elseif eventType = Bmk0_Stop_PerfMonLog then
			doCmd('logman stop JBLPerf', cmdLog);
			doCmd('logman delete JBLPerf', cmdLog);
			if (copies &gt; 0 or copies = -99) and myBmkControl.rapHost &lt;&gt; computerName then  // I am a client machine CreatorCreator
				doCmd('move '&amp;logDir&amp;'\*perfmonlog* \\'&amp;myBmkControl.rapHost&amp;'\c$'&amp;PerfMonLogsFolder, cmdLog);
			endif;
			global.causeEvent(Bmk0_Stop_PerfMonLog*-1, true, sess);
		endif;
	endif;
epilog
	delete ff;
end;</source>
        <Parameter name="sess" type="Integer"/>
        <Parameter name="eventType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="fixEnvid" id="01e77821-138c-4a5d-8afc-a2e87531b133">
        <updating/>
        <source>fixEnvid(sess:Integer) updating;

vars

	fIniOld, fIniNew, fVerInfo : File;
	ff : FileFolder;
	s, newVersion, oldVersion, newEnvid, oldEnvid, serverFolder, path, cmd : String;
	files, folders, i, j :Integer;
	
begin
	myBmkControl:=global.allBmkControls[sess];
	if myBmkControl.rapHost = computerName and myBmkControl.owner = userCode then
		oldEnvid := myBmkControl.envid;  //jdin7010
		oldVersion := oldEnvid[5:end]; //7010 
		
		//get runid
		path:=myBmkControl.binFolder;
		cmd:=path&amp;'\jverinfo.exe';
		node.createExternalProcess(path,cmd,null,null,true,true,j);
		create fVerInfo;	
		fVerInfo.mode:=File.Mode_Input;
		fVerInfo.fileName:=path&amp;"\versioninfo.txt";
		if not fVerInfo.isAvailable then
			global.causeEvent(Bmk_Result, true, "versioninfo was not found - wrong env name?");
			return;
		endif;
		while not fVerInfo.endOfFile do
			s:=fVerInfo.readLine;
			if s[1:8]="jade.exe" then
				i := 12;
				newVersion:=s.scanUntil(".",i).trimBlanks;
				i:=i+1;
				newVersion:=newVersion &amp; s.scanUntil(".",i);
				i:=i+1;
				newVersion:=newVersion &amp; s.scanUntil(".",i);
			endif;
		endwhile;
		fVerInfo.close;
		global.causeEvent(Bmk_Result, true, "runid =" &amp; newVersion);
		//runid := "7107";         //7107 
		newEnvid := oldEnvid.replace(oldVersion, newVersion);   //jdin7107
		serverFolder := myBmkControl.binFolder.replace("c_bin", "");
		
		//modify the ini file 
		create fIniOld;
		create fIniNew;
		fIniOld.mode := File.Mode_Input;
		fIniNew.mode := File.Mode_Output;
		fIniOld.fileName := myBmkControl.iniFileName;
		fIniNew.fileName := myBmkControl.iniFileName.replace(oldEnvid &amp; ".ini", newEnvid &amp; ".ini");
		s := fIniOld.readString(fIniOld.fileLength).replace(oldEnvid, newEnvid);
		fIniNew.writeString(s);	
		fIniOld.purge;	
		fIniNew.close;
		
		//delete folders that are not used 
		app.housekeepingRemoveDir(serverFolder &amp; "c_system_70", files, folders, -2, true);
		app.housekeepingRemoveDir(serverFolder &amp; "logs", files, folders, -2, true);
		app.housekeepingRemoveDir(serverFolder &amp; "documentation", files, folders, -2, true);
		app.housekeepingRemoveDir(serverFolder &amp; "include", files, folders, -2, true);
		app.housekeepingRemoveDir(serverFolder &amp; "library", files, folders, -2, true);
		app.housekeepingRemoveDir(serverFolder &amp; "reportwriter", files, folders, -2, true);
		app.housekeepingRemoveDir(serverFolder &amp; "upgradeFiles", files, folders, -2, true);
		app.housekeepingRemoveDir(serverFolder &amp; "wsdl", files, folders, -2, true);
		app.housekeepingRemoveDir(serverFolder &amp; "i686-msoft-win32-ansi", files, folders, -2, true);
		app.housekeepingRemoveDir(serverFolder &amp; "x64-msoft-win64-ansi", files, folders, -2, true);
		app.housekeepingRemoveDir(serverFolder &amp; "i686-msoft-win32-unicode", files, folders, -2, true);
		app.housekeepingRemoveDir(serverFolder &amp; "x64-msoft-win64-unicode", files, folders, -2, true);
		
		//rename the enviroment folder
		create ff;
		ff.fileName := myBmkControl.binFolder.replace("\server\c_bin", "");
		ff.rename(ff.fileName.replace(oldEnvid, newEnvid));
		
		app.setSession(sess, myBmkControl.binFolder[1], newEnvid, null, myBmkControl.controlPort, myBmkControl.product, myBmkControl.rapHost, myBmkControl.appServers);
	endif;
epilog
	delete fIniOld;
	delete fIniNew;
	delete fVerInfo;
	delete ff;
end;

</source>
        <Parameter name="sess" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="iAmTheFirst" id="14e02654-ec08-4e77-80c6-e26b9fa267b0">
        <source>iAmTheFirst():Boolean;
//	am I the first CreatorCreator on this machine with my usercode? This supports multiple sessions on one machine.
vars
	proc:Process;
begin
	if process.getUserCode &lt;&gt; "cnwjhp1" then
		return true;
	endif;
	
	foreach proc in Process.instances do
		if getInstanceIdForObject(proc) &lt; getInstanceIdForObject(process) then
			if proc.persistentApp = process.persistentApp and proc.userInfo = process.userInfo and proc.getUserCode = process.getUserCode then
				return false;
			endif;
		else
			break;
		endif;
	endforeach;
	return true;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="saveLogFiles" id="dea72124-935b-44a2-b642-fb243a836554">
        <updating/>
        <source>saveLogFiles(sess:Integer) updating;

vars
	s,t,runLetter,folderSuffix,resultsFolder,localResultsFolder,realRunid, folderprefix:String;
	b:Binary;
	i,j,fileCount:Integer;
	ff:FileFolder;  fn:FileNode;  f,g:File;
	aa:Analysis;
begin
	myBmkControl:=global.allBmkControls[sess];
	app.logMessage("Diag log files for product "&amp;myBmkControl.product );
	if myBmkControl.product = "mtl" then 
		folderprefix := MTLResultsFolder;
	else 
		
		folderprefix := OtherResultsFolder;
	endif;
	
	if myBmkControl.rapHost = computerName and myBmkControl.owner = userCode then
		app.logMessage("saving log files for session "&amp;sess.String );
		create ff;
		create f;
		create g;
		f.mode:=File.Mode_Input;
		//f.shareMode:=File.Share_Read;  // "optimisation" for static files
		f.shareMode:=File.Share_ReadWrite;  // read it whether someone has it open output or not
		g.mode:=File.Mode_Output;
		f.kind:=File.Kind_Binary;
		g.kind:=File.Kind_Binary;
		f.usePresentationFileSystem:=true;
		g.usePresentationFileSystem:=true;
	   
		// ensure BenchmarkResults folder exists
		resultsFolder:=folderprefix&amp;"\BenchMarkResults";
		ff.fileName:=resultsFolder;
		ff.usePresentationFileSystem:=true;
		if not ff.isAvailable then
			global.causeEvent(Bmk_Result, true, "cannot access folder "&amp;resultsFolder);
			app.logMessage("cannot access folder "&amp;resultsFolder);
			global.beep;
			return;
		endif;
		
		// assign run letter and create subfolder
		if myBmkControl.runid.cnContains("\") then  // allow folder name assignment externally
			folderSuffix:=myBmkControl.product&amp;"\"&amp;myBmkControl.runid;
			realRunid:=myBmkControl.runid[myBmkControl.runid.reversePos("\")+1:end];
		else
			folderSuffix:=myBmkControl.product&amp;"\"&amp;app.actualTimeAppServer.date.format("yyyyMMdd")&amp;"_"&amp;myBmkControl.rapHost.asAbbrevHost&amp;"\"&amp;myBmkControl.runid;
			realRunid:=myBmkControl.runid;
		endif;
		resultsFolder:=folderprefix&amp;"\BenchMarkResults\"&amp;folderSuffix;
		localResultsFolder:=app.dbPath[1:3]&amp;"BenchMarkResults\"&amp;folderSuffix;
		//foreach i in 0 to 25 do
		foreach i in 0 to 259 do  // allow for more than 26 in a day - prefixes are a-z, 1a-1z, 2a-2z etc
			//runLetter:=('a'.Integer+i).Character;
			runLetter:="";
			if i &gt; 25 then
				runLetter:=(i div 26).String;
			endif;
			runLetter:=runLetter&amp;('a'.Integer+(i mod 26)).Character;
			ff.fileName:=resultsFolder&amp;runLetter;
			ff.usePresentationFileSystem:=true;
			if not ff.isAvailable then
				ff.make;
				resultsFolder:=resultsFolder&amp;runLetter;
//				global.causeEvent(Bmk_Result, true, "made "&amp;localResultsFolder);
				localResultsFolder:=localResultsFolder&amp;runLetter;
				ff.fileName:=localResultsFolder;
				ff.usePresentationFileSystem:=false;
				if not ff.isAvailable then
					ff.make;
				endif;
				break;
			endif;
		endforeach;

		ff.fileName:=app.getProfileString(myBmkControl.iniFileName, "JadeLog", "LogDirectory", "c:\");
		ff.usePresentationFileSystem:=f.usePresentationFileSystem;
		foreach fn in ff.files where fn.isKindOf(File) do
			if fn.name.cnContains("cn_tranlog_") and fn.name.cnContains(".csv") 
			and not fn.name.cnContains("_stats.csv") then
//			or fn.name = "BmkTrans.log" then
				global.causeEvent(Bmk_Result, true, "analysing "&amp;fn.fileName);
				app.logMessage("analysing "&amp;fn.fileName&amp; " for "&amp;sess.String);
				create aa;
				aa.inFile.fileName:=fn.fileName;
				aa.inFile.usePresentationFileSystem:=f.usePresentationFileSystem;
				aa.analyseTranLog;
				delete aa;
			endif;
		endforeach;

		doCmd('move c:'&amp;PerfMonLogsFolder&amp;'\*perfmonlog* '&amp;ff.fileName, ' &gt;&gt; '&amp;ff.fileName&amp;'\cmd.log');
		
		// copy all the files
		foreach fn in ff.files where fn.isKindOf(File) do
			s:=fn.name[fn.name.length-3:4];
			if s = ".tmp" then
				continue;
			endif;
			f.fileName:=fn.fileName;
			if f.tryOpen = false then
				global.causeEvent(Bmk_Result, true, "can't open file: "&amp;f.fileName);
				app.logMessage("can't open file: "&amp;f.fileName);
				continue;
			endif;

//			copyFile(f, g, false,  resultsFolder&amp;"\"&amp;realRunid&amp;runLetter&amp;"_"&amp;fn.name);
			copyFile(f, g, true,  resultsFolder&amp;"\"&amp;realRunid&amp;runLetter&amp;"_"&amp;fn.name);
			copyFile(f, g, false, localResultsFolder&amp;"\"&amp;realRunid&amp;runLetter&amp;"_"&amp;fn.name);
			global.causeEvent(Bmk_Result, true, "created "&amp;g.fileName);
			fileCount:=fileCount+1;
		endforeach;
		
		// run versioninfo and grab the file
		showJadeVersion(sess);
		s:=myBmkControl.binFolder&amp;"\versioninfo.txt";
		f.fileName:=s;
		t:="\"&amp;realRunid&amp;runLetter&amp;"_"&amp;s[s.reversePos("\")+1:end];
		copyFile(f, g, true,  resultsFolder&amp;t);
		copyFile(f, g, false, localResultsFolder&amp;t);
		global.causeEvent(Bmk_Result, true, "created "&amp;g.fileName);
		
		// grab .ini file too
		s:=myBmkControl.iniFileName;
		f.fileName:=s;
		t:="\"&amp;realRunid&amp;runLetter&amp;"_"&amp;s[s.reversePos("\")+1:end];
//		copyFile(f, g, false,  resultsFolder&amp;t);
		copyFile(f, g, true,  resultsFolder&amp;t);
		copyFile(f, g, false, localResultsFolder&amp;t);
		global.causeEvent(Bmk_Result, true, "created "&amp;g.fileName);

		s:=fileCount.String&amp;" files copied from "&amp;ff.fileName&amp;" to "&amp;localResultsFolder;
		app.logMessage(s &amp; " for "&amp;sess.String);
		global.causeEvent(Bmk_Result, true, s);
		app.logMessage(s);
		
		t:="\";
		//Add the file so its available for emailing
		writeSummaryGeneratorInfo(resultsFolder&amp;t);
	
		app.logMessage("finished saving log files for session "&amp;sess.String);
		global.causeEvent(Bmk0_Save_Log_Files*-1, true, sess);
	endif;
epilog
	delete ff;
	delete f;
	delete g;
	delete aa;
end;</source>
        <Parameter name="sess" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setAppSequenceId" id="8e9c8068-dab1-441c-a89a-0dd4ea078096">
        <updating/>
        <source>setAppSequenceId(myproc:Process) updating;
//	among all running apps of the same name, which one am I?
vars
	proc:Process;
begin
	appSequenceId:=0;
	foreach proc in Process.instances do
		//if myproc.persistentApp.name &lt;&gt; "CreatorCreator" and getInstanceIdForObject(proc) &gt;= getInstanceIdForObject(myproc) then
		if getInstanceIdForObject(proc) &gt;= getInstanceIdForObject(myproc) then  // no longer need CreatorCreator to check all instances
			break;
		endif;
		if proc.persistentApp.name = myproc.persistentApp.name then
			if myproc.persistentApp.name =  "CreatorCreator" 
				and proc.getUserCode = userCode      // count same usercode only
				and getInstanceIdForObject(proc) &lt; getInstanceIdForObject(myproc)  // allow for multiple sessions per machine
			or myproc.persistentApp.name &lt;&gt; "CreatorCreator" and getInstanceIdForObject(proc) &lt; getInstanceIdForObject(myproc) then
				appSequenceId:=appSequenceId+1;
			endif;
		endif;
	endforeach;
end;
</source>
        <Parameter name="myproc" type="Process"/>
    </JadeMethod>
    <JadeMethod name="setAutoDownLoad" id="8e6cec74-c5b7-4025-8984-4935905a7c9c">
        <source>setAutoDownLoad(iniFile:String);

begin
	app.setProfileString(iniFile, "JadeThinClient", "AutomaticDownLoad", "true");
	app.setProfileString(iniFile, "JadeThinClient", "AskToDownload",     "false");
	app.setProfileString(iniFile, "JadeThinClient", "AskToPreDownload",  "false");
end;</source>
        <Parameter name="iniFile" type="String"/>
    </JadeMethod>
    <JadeMethod name="setInfo" id="57fb20a2-4b33-4eb3-b45c-0556085d92b7">
        <updating/>
        <source>setInfo() updating;
//	Set class variables depending on client and server computer names.
//	If you add products in here, be sure to modify SysAdmin::getProducts also.
//	Note that all products starting with "sk" are reserved for skidemo derivatives.
begin
	copies:=-1;
	host:=myBmkControl.appServerHost;
	if host.toLower = 'cnwchcc46' and (computerName[1:7] = 'cnwchcs' or computerName[1:7] = 'jblchcs') then
		host:='cnwchcs46';
	elseif host.toLower = 'jblchcs6' then
		host:='jblchcs6.jbl';
	endif;

	if     myBmkControl.envid = 'jblpcre' or myBmkControl.envid = 'Creator' or myBmkControl.envid = 'CreDev' then setInfo_Creator;
	elseif myBmkControl.product = 'JCC' then			setInfo_jcc;
	elseif myBmkControl.product = 'JCC2' then		setInfo_jcc2;
	elseif myBmkControl.product = 'CMIS' then  		setInfo_cmis;
	elseif myBmkControl.product = 'CMIS2' then  	setInfo_cmis2;
	elseif myBmkControl.product = 'CMIS3' then  	setInfo_cmis3;
	elseif myBmkControl.product = 'CMIS4' then  	setInfo_cmis4;
	elseif myBmkControl.product = 'CMISCON' then  setInfo_cmiscontops;
	elseif myBmkControl.product = 'mumbai' then	setInfo_mumbai;
	elseif myBmkControl.product = 'muu' then		setInfo_mumbai;
	elseif myBmkControl.product = 'skidemo' then	setInfo_skidemo;
	elseif myBmkControl.product = 'skl' then		setInfo_skl;
	elseif myBmkControl.product = 'slu' then		setInfo_slu;
	elseif myBmkControl.product = 'sku' then		setInfo_sku;
	elseif myBmkControl.product = 'ski2' then		setInfo_skidemo2;
	elseif myBmkControl.product = 'ews' then		setInfo_ews;
	elseif myBmkControl.product = 'mtl' then		setInfo_mtl;
	elseif myBmkControl.product = 'JMT' then		setInfo_jmt;
	elseif myBmkControl.product = 'jmt2' then		setInfo_jmt2;
	elseif myBmkControl.product = 'JadeStar' then	setInfo_jadestar;
	elseif myBmkControl.product = 'JStar2' then		setInfo_jadestar2;
	elseif myBmkControl.product = 'Jasper' then		setInfo_jasper;
	elseif myBmkControl.product = 'JasperTest' then	setInfo_jasperTest;
	elseif myBmkControl.product = 'sms' then		setInfo_sms;
	elseif myBmkControl.product = 'tpca' then		setInfo_tpca;
	elseif myBmkControl.product = 'tui' then		setInfo_tui;
	elseif myBmkControl.product = 'boms' then	setInfo_boms;
	elseif myBmkControl.product = 'Autodino' then	setInfo_autodino;
	elseif myBmkControl.product = 'StartStopTest' then	setInfo_sst;
	elseif myBmkControl.product = 'ncs' then	setInfo_ncs;
	else
		copies:=1;
		port:=myBmkControl.bmkBasePort.Integer+(appSequenceId mod myBmkControl.appServers);
//		port:=myBmkControl.bmkBasePort.Integer;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setInfo_Creator" id="e49af907-0831-4424-8c27-22099858a039">
        <updating/>
        <source>setInfo_Creator() updating;

vars
	bc:BmkControlSession;
begin
	copies:=0;
	port:=app.getProfileStringAppServer(app.getIniFileNameAppServer,"JBL","AppServerPort","0").Integer;
	if targetSession &lt; 1 then
		return;
	endif;
	bc:=global.allBmkControls[targetSession];
	if bc.owner &lt;&gt; userCode then
		return;
	endif;
	
	if bc.owner = 'cnwjhp1' /*or bc.owner = 'cnwjbl6' and bc.product = "CMIS3"/**/ then
		copies:=-1;
		if      computerName='cnwjhp1a' then		copies:=-1; //bc.appServers;
		elseif computerName=bc.rapHost then 	copies:=-1; //bc.appServers;
		//elseif computerName='cnwchcs119' then 	copies:=1; //bc.appServers;
		//elseif computerName='cnwchcs55' then 	copies:=-1; //bc.appServers;
		/*elseif targetSession = 7 and computerName.serverNumber &gt;= 25 and computerName.serverNumber &lt;= 1155 then  //copies:=30; //bc.appServers;
			if      bc.product = "CMIS3" then		copies:=30;
			elseif bc.product = "CMIS4" then	copies:=1;
			endif;/**/
		//elseif targetSession = 8 and computerName.serverNumber &gt;= 127 then 	copies:=30; //bc.appServers;
		else  // standard stuff
		
			if      bc.product = "JCC" then		copies:=4;
			elseif bc.product = "Autodino" then	copies:=1;
			elseif bc.product = "CMIS" then		copies:=15;
			elseif bc.product = "CMIS3" then		copies:=25;
			elseif bc.product = "mumbai" then	copies:=bc.appServers;
			elseif bc.product = "muu" then		copies:=bc.appServers;
			elseif bc.product[1:2] = "sk" then	copies:=10;
			elseif bc.product[1:2] = "sl" then	copies:=10;
			elseif bc.product = "JadeStar" then	copies:=12;
			//elseif bc.product = "Jasper" then		copies:=6;  // original bmk
			elseif bc.product = "Jasper" then		copies:=13;
			//elseif bc.product = "mtl" then			copies:=22;
			elseif bc.product = "mtl" then
				//if appSequenceId = 0 then copies:=12;
				if appSequenceId &lt;= 3 then copies:=6;  // if you start the server before the clients, add 1 to appSequenceId
				else copies:=49;
				endif;
			elseif bc.product = "sms" then		copies:=10;
			elseif bc.product = "sst" then			copies:=20;
			elseif bc.product = "tpca" then		copies:=2;
			elseif bc.product = "tui" then			copies:=70;
			elseif bc.product[1:2].toLower = "jm" then
				//if computerName='cnwchcs122' then copies:=5; endif;
				//if computerName='cnwchcs131' then copies:=4; endif;
				if computerName='cnwchcs134' then copies:=7; endif;
				if computerName='cnwchcs136' then copies:=6; endif;
			endif; /**/
		endif;
			
	elseif bc.owner = 'cnwmjw1' then
		copies:=-1;
		if     computerName='cnwmjw1b'	then	copies:=1;
		elseif computerName='cnwchcs36'	then	copies:=-1;
		elseif computerName='cnwchcs55'	then	copies:=-1;
		elseif computerName='cnwchcs122'	then	copies:=20;
		elseif computerName='cnwchcs131'	then	copies:=20;
		elseif computerName='cnwchcs128'	then	copies:=-1;
		elseif computerName='cnwchcs131'	then	copies:=1;
		elseif computerName='cnwchcs134'	then	copies:=1;
		elseif computerName='cnwchcs136'	then	copies:=20;

		elseif computerName='cnwchcs130' and bc.rapHost='cnwchcs130' then copies:=bc.appServers;
		
		else  // standard stuff
			if      bc.product = "JCC" then		copies:=4; 
			elseif bc.product = "Autodino" then	copies:=1;
			elseif bc.product = "CMIS" then		copies:=15;
			elseif bc.product = "CMIS3" then		copies:=40;
			elseif bc.product = "mumbai" then	copies:=bc.appServers;
			elseif bc.product = "muu" then		copies:=bc.appServers;
			elseif bc.product[1:2] = "sk" then	copies:=10;
			elseif bc.product[1:2] = "sl" then	copies:=10;
			elseif bc.product = "JadeStar" then	copies:=12;
			elseif bc.product = "Jasper" then		copies:=6;
			//elseif bc.product = "mtl" then			copies:=22;
			elseif bc.product = "mtl" then
				//if appSequenceId = 0 then copies:=12;
				if appSequenceId &lt;= 2 then copies:=6;
				else copies:=49;
				endif;
			elseif bc.product = "sms" then		copies:=10;
			elseif bc.product = "sst" then			copies:=20;
			elseif bc.product = "tui" then			copies:=70;
			elseif bc.product[1:2].toLower = "jm" then
				//if computerName='cnwchcs122' then copies:=5; endif;
				//if computerName='cnwchcs131' then copies:=4; endif;
				if computerName='cnwchcs134' then copies:=7; endif;
				if computerName='cnwchcs136' then copies:=6; endif;
			endif;
		endif;	
	
	elseif bc.owner[1:6] = 'cnwjbl' and targetSession &gt;= 25 then  // for automated stdruns
		copies:=-1;
		//if     computerName='cnwchcs36' or computerName='cnwchcs46' or computerName='cnwchcs54' or computerName='cnwchcs55' or computerName='cnwchcs25' then copies:=-1;
		if computerName=bc.rapHost then copies:=-1;
		else
			if     bc.product = "JCC" then			copies:=4; // WAS 4
			elseif bc.product = "CMIS" then		copies:=15;
			elseif bc.product = "Autodino" then	copies:=1;
			elseif bc.product = "expressdino" then	copies:=1;
			elseif bc.product = "mumbai" then	copies:=bc.appServers;
			elseif bc.product = "muu" then		copies:=bc.appServers;
			elseif bc.product = "ncs" then		copies:=bc.appServers;
			elseif bc.product[1:2] = "sk" then	copies:=10;
			//elseif bc.product[1:2] = "sl" then	copies:=10;
			elseif bc.product[1:2] = "sl" then	copies:=40;
			elseif bc.product = "JadeStar" then	copies:=12;
			//elseif bc.product = "Jasper" then		copies:=6;  // original bmk
			elseif bc.product = "Jasper" then		copies:=13;
			elseif bc.product = "mtl" then
				//if appSequenceId = 0 then copies:=12;
				if appSequenceId &lt;= 2 then copies:=6;
				else copies:=49;
				endif;
			elseif bc.product = "JMT" then		//copies:=9;
				if appSequenceId = 0 then copies:=5;
				else copies:=4;
				endif;
			elseif bc.product = "StartStopTest" then copies:=10;
			endif;
		endif;
	
	elseif bc.owner = 'cnwjbl6' then  // for MTL runs
		copies:=-1;
		if     computerName='cnwchcs55' or computerName='cnwchcs25' then copies:=-1;
		else
			if bc.product = "mtl" then
				//if appSequenceId = 0 then copies:=12;
				if appSequenceId &lt;= 2 then copies:=6;
				else copies:=49;
				endif;
			else
			
			endif;
		endif;
		
	//elseif bc.owner = 'cnwjbl1' then  // for screwing around
	elseif bc.owner[1:6] = 'cnwjbl' then  // for screwing around
		copies:=-1;
		if     computerName='cnwmjw1b'	then	copies:=0;
		elseif computerName='cnwchcs4'	then	copies:=1;
		elseif computerName='cnwchcs55'	then	copies:=1;
		//elseif computerName='cnwchcs116'	then	copies:=1;
	  	//elseif computerName='cnwchcs119' then	copies:=1;
		elseif computerName &gt;= 'cnwchcs116'	and computerName &lt;= 'cnwchcs157' then
			if     bc.product = "JCC" then		
				if computerName = 'cnwchcs130' then	copies:=0;
				else							copies:=4;
				endif;
			elseif bc.product = "CMIS" then		copies:=15;
			elseif bc.product = "Autodino" then		copies:=1;
			elseif bc.product = "mumbai" then	copies:=bc.appServers;
			elseif bc.product = "ncs" then		copies:=bc.appServers;
			elseif bc.product = "skidemo" then	copies:=20;
			elseif bc.product = "JadeStar" then	copies:=12;
			elseif bc.product = "StartStopTest" then copies:=10;
			elseif bc.product = "Jasper" then	copies:=6;
			elseif bc.product = "mtl" then
				//if appSequenceId = 0 then copies:=12;
				if appSequenceId &lt;= 2 then copies:=6;
				else copies:=49;
				endif;
			elseif bc.product = "JMT" then
				if computerName = 'cnwchcs134' then	copies:=5;
				else							copies:=4;
				endif;
			endif;
		endif;
	
	elseif bc.owner[1:6] = 'cnwjbl' then  // for screwing around
		copies :=-1;
		if     computerName='cnwchcs131' then	copies:=-1;
		elseif bc.product = "mtl" then
				//if appSequenceId = 0 then copies:=12;
				if appSequenceId &lt;= 2 then copies:=6;
				else copies:=49;
				endif;
		elseif computerName &gt;= 'cnwchcs116'	and computerName &lt;= 'cnwchcs157' then
			if     bc.product = "JCC" then		copies:=4;
			elseif bc.product = "Autodino" then		copies:=1;
			elseif bc.product = "CMIS" then		copies:=15;
			elseif bc.product = "mumbai" then	copies:=bc.appServers;
			elseif bc.product = "ncs" then		copies:=bc.appServers;
			elseif bc.product = "skidemo" then	copies:=4;
			elseif bc.product = "JadeStar" then	copies:=12;
			elseif bc.product = "Jasper" then	copies:=6;
			elseif bc.product = "JMT" then copies:=5;
			elseif bc.product = "StartStopTest" then copies:=10;
			endif;
		endif;
	endif;
/*
		elseif bc.rapHost='cnwchcs54' and bc.session=1 and computerName.serverNumber = 131 then 	copies:=bc.appServers;
		elseif bc.rapHost='cnwchcs54' and bc.session=2 and computerName.serverNumber = 122 then 	copies:=bc.appServers;
*/
end;</source>
    </JadeMethod>
    <JadeMethod name="setInfo_autodino" id="79ae8c88-16f6-4db3-a70b-725846f6966b">
        <updating/>
        <source>setInfo_autodino() updating;
//	set profile name to be used for each Creator
//	to set profile name per copy of a Creator, modify startApp
begin
	copies:=1;
	//profile:='AutoDino1';
	profile:='BasicPerf';
	port:=myBmkControl.bmkBasePort.Integer;
end;</source>
    </JadeMethod>
    <JadeMethod name="setInfo_boms" id="26468b9b-76a2-4b7c-a561-94d956510226">
        <updating/>
        <source>setInfo_boms() updating;

begin
	copies:=0;
	port:=myBmkControl.bmkBasePort.Integer;  // same for all benchmark db's

	copies:=1;
	port:=port+(appSequenceId div  5);  //  5 users per appserver - 30 user test
	profType:=(appSequenceId mod 2);
	if      profType = 0 then profile:='AuditSearch';
	elseif profType = 1 then profile:='TrainSearch';
	endif;
//	profile:='AddPersonToCN';
end;</source>
    </JadeMethod>
    <JadeMethod name="setInfo_cmis" id="f19459e6-b222-4f1c-b359-82822b4890f7">
        <updating/>
        <source>setInfo_cmis() updating;
//	set profile name to be used for each Creator
//	to set profile name per copy of a Creator, modify startApp
begin
	copies:=0;
	port:=myBmkControl.bmkBasePort.Integer;  // same for all benchmark db's

	if myBmkControl.owner[1:6] = 'cnwjbl' then
		copies:=1;
		port:=port+(appSequenceId mod myBmkControl.appServers);  // distrubute evenly across appServers
	else
		copies:=1;
		port:=port+(appSequenceId div  5);  //  5 users per appserver - 30 user test
//		port:=port+(appSequenceId div 10);  // 10 users per appserver - 60 user test
//		port:=port+(appSequenceId mod myBmkControl.appServers);  // distrubute evenly across appServers
	endif;
	profType:=(appSequenceId mod 5);
	if     profType = 0 then profile:='SearchCN';
	elseif profType = 1 then profile:='SearchVehicle';
	elseif profType = 2 then profile:='AddCN';
	elseif profType = 3 then profile:='AddPersonToCN';
	elseif profType = 4 then profile:='AddVehicleToCN';
	endif;
	
	if myBmkControl.owner = 'cnwjhp1' and myBmkControl.runid = 'special' then
		if     appSequenceId.isOdd then	profile:='AddCN';
		else 										profile:='AddPersonToCN';
		endif;
	endif;
//	profile:='AddPersonToCN';
end;</source>
    </JadeMethod>
    <JadeMethod name="setInfo_cmis2" id="245e76c6-2681-4a50-a784-c44922a07757">
        <updating/>
        <source>setInfo_cmis2() updating;
//	set profile name to be used for each Creator
//	to set profile name per copy of a Creator, modify startApp
begin
	copies:=0;
	port:=myBmkControl.bmkBasePort.Integer;  // same for all benchmark db's
	
	// Do it like this if you want multiple profiles on each client machine.
	// Use multiple creators per client machine, one per profile.
	if     computerName='cnwchcs46'
	or     computerName='cnwchcs122'
	or     computerName='cnwchcs124'
	or     computerName='cnwchcs128'
	or     computerName='cnwchcs131'
	or     computerName='cnwchcs134'
	or     computerName='cnwchcs136'
	then
		copies:=5;
//		port:=port+(appSequenceId div  5);  //  5 users per appserver - 30 user test
//		port:=port+(appSequenceId div 10);  // 10 users per appserver - 60 user test
		port:=port+(appSequenceId mod myBmkControl.appServers);  // distrubute evenly across appServers
		profType:=(appSequenceId mod 5);
//		profType:=(appSequenceId mod 2)+1;
		if     profType = 0 then profile:='SearchCN';
		elseif profType = 1 then profile:='SearchVehicle';
		elseif profType = 2 then profile:='AddCN';
		elseif profType = 3 then profile:='AddPersonToCN';
		elseif profType = 4 then profile:='AddVehicleToCN';
		endif;
//		profile:='AddPersonToCN';
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setInfo_cmis3" id="e47d8be6-da95-4b66-b78b-f834b5576504">
        <updating/>
        <source>setInfo_cmis3() updating;
//	one driver per creator (cmis4 is one creator, multiple copies)
//	use this for 300 or 600 users
vars
	totalUsers,usersPerAppServer,numSearchVehicleWithAttr:Integer;
begin
	totalUsers:=50;  // important to set this correctly
	numSearchVehicleWithAttr:=2;  // set to 0 if not using the new soft attributes profile

	copies:=1;
	port:=myBmkControl.bmkBasePort.Integer;
	usersPerAppServer:=totalUsers div myBmkControl.appServers;
	if totalUsers mod myBmkControl.appServers &lt;&gt; 0 then
		usersPerAppServer:=usersPerAppServer+1;
	endif;
	port:=port+(appSequenceId div usersPerAppServer);
	//port:=port+(appSequenceId mod myBmkControl.appServers);  //  spread evenly over appservers
	profType:=(appSequenceId mod 8);
	if      profType = 0 then profile:='AddCN';
	elseif profType = 1 then profile:='AddCompoundImageToCN';
	elseif profType = 2 then profile:='AddPersonToCN';
	elseif profType = 3 then profile:='SearchVehicle';         //port:=myBmkControl.bmkBasePort.Integer+4;
	elseif profType = 4 then profile:='AddSearchWarrant';
	elseif profType = 5 then profile:='AddVehicleToCN';
	elseif profType = 6 then profile:='SearchCN';
	elseif profType = 7 then profile:='multiSearchesAndAddToCN';
	endif;
	if appSequenceId &lt; numSearchVehicleWithAttr then profile:='searchVehicleWithAttr'; endif;
	/*if    appSequenceId mod usersPerAppServer = 0  // first one per appserver
	and appSequenceId div usersPerAppServer &lt; numSearchVehicleWithAttr then
		profile:='searchVehicleWithAttr';
	endif;/**/
	//port:=port+(appSequenceId div  1);
	//profile:='searchPersonWithAttr';  // if profType.isOdd then profile:='AddCN'; endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setInfo_cmis4" id="70ea4ab1-4c51-4145-b464-5178c301d0ae">
        <updating/>
        <source>setInfo_cmis4() updating;
//	one creator, multiple copies (cmis3 is one driver per creator)
//	use this for more than 600 users
//	profile allocation is in startApp
vars
	totalUsers,usersPerAppServer,numSearchVehicleWithAttr:Integer;
	fiftyUserMode:Boolean;
begin
	//totalUsers:=50;  // important to set this correctly
	//numSearchVehicleWithAttr:=0;  // set to 0 if not using the new soft attributes profile

	//copies:=100;  // ensure CreatorCreators is set to 1!
	fiftyUserMode:=true;  // preliminary tests for the 2500 runs
	profile:='various';
	port:=0;
	if      computerName='cnwchcs86'  and (fiftyUserMode or appSequenceId.isOdd) then copies:=10;
	elseif computerName='cnwchcs120' and (fiftyUserMode or appSequenceId.isOdd) then copies:=10;
	elseif computerName='cnwchcs157' and (fiftyUserMode or appSequenceId.isOdd) then copies:=10;
	elseif computerName='cnwchcs300' and (fiftyUserMode or appSequenceId.isOdd) then copies:=10;
	elseif computerName='cnwchcs301' and (fiftyUserMode or appSequenceId.isOdd) then copies:=10;
	elseif computerName='cnwchcs124'  then copies:=75; profile:='LightUser';
	else
		copies:=100;  // ensure CreatorCreators is set to 1!
		profile:='LightUser';
	endif;
	//if appSequenceId &lt; 0 then copies:=10; else copies:=100; profile:='LightUser'; endif;  // override for testing
	if profile = 'LightUser' then
		//host:='cnwchcs131';
		if      computerName='cnwchcs124'  then port:=51750;
		elseif computerName='cnwchcs36'  then port:=51751;
