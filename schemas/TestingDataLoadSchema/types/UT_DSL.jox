    <JadeMethod name="addRTDevice" id="d19fd8de-6232-407a-887e-fed66c65e924">
        <source>addRTDevice(_type: String;
			_id,
			_model,
			_computerName	: String;
			_machine 		: CM_Machine; // only for CM_RTDeviceVehicleMount
			_isPasswordCompulsory,
			_useSerialConnection 	: Boolean;
			_useLocalTCPConnection : Boolean) : CM_RadioTelemetryDevice;
//09 September 2010	by cnwvu1
//17/08/2016 cnwrh7	TFS	2501

vars
	pxyRTDevice,	newRTDevice		: CM_RadioTelemetryDevice;
	
begin

	self.deleteRTDevice(_id);

	if _type = RTDevice_HandHeld then
		create pxyRTDevice as CM_RTDeviceHandHeld transient;
		pxyRTDevice.CM_RTDeviceHandHeld.setProxyForHandHeld(_id, self.getTerminal.radioTelemetry, _model, _computerName, _isPasswordCompulsory, _useSerialConnection, _useLocalTCPConnection, 0, null); 	// +17/08/2016 cnwrh7	TFS	2501
		
	elseif _type = RTDevice_Scanner then
		create pxyRTDevice as CM_RTDeviceScanner transient;
		pxyRTDevice.CM_RTDeviceScanner.setProxyForScanner(_id, self.getTerminal.radioTelemetry, _model, _computerName, _useSerialConnection, _useLocalTCPConnection, 0);	//+ 17/08/2016 cnwrh7	TFS	2501
		
	elseif _type = RTDevice_Vehicle then
		create pxyRTDevice as CM_RTDeviceVehicleMount transient;
		pxyRTDevice.CM_RTDeviceVehicleMount.setProxyForVehicleMount(_id, self.getTerminal.radioTelemetry, _machine, _model, _computerName, _useSerialConnection,_useLocalTCPConnection);	// +17/08/2016 cnwrh7	TFS	2501
		
	endif;
	
	if self.opts.includesKey("RTDevice_ComputerName") then											// 28/07/2011 cnwmh5
		pxyRTDevice.setPropertyValue('computerName', self.opts.str("RTDevice_ComputerName"));
	endif;

	app.myTrxCA.trxCreateRTDevice(pxyRTDevice, newRTDevice, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();

	return newRTDevice;
	
epilog
	delete pxyRTDevice;
	
end;</source>
        <Parameter name="_type" type="String"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_model" type="String"/>
        <Parameter name="_computerName" type="String"/>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_isPasswordCompulsory" type="Boolean"/>
        <Parameter name="_useSerialConnection" type="Boolean"/>
        <Parameter name="_useLocalTCPConnection" type="Boolean"/>
        <ReturnType type="CM_RadioTelemetryDevice"/>
    </JadeMethod>
    <JadeMethod name="addRTGArea" id="6095b95e-fa36-4ea1-b0eb-044bdd0d703e">
        <source>addRTGArea(_name: String; _rows,_stacks,_tiers: Integer): CM_RTGArea;
//01 September 2008	cnwdw1	 
// 24/08/2011	cnwmh5	Change so uses opts for use40ftIds
vars
	pxyCMIFTerminalArea: CMIF_RTGArea;
	realTA 		: CM_TerminalAreaMaster;
	pxyRTGArea: CM_RTGArea;
	pDO: CM_YADeckingOptionsTA;
	pxyGridRow: CM_RTGRow;
	pxyGridCol: CM_RTGColumn;
	pxyStackCntrl: CM_RTGController;
	row, column: Integer;
	label: String;
	
	pxyTA				: CM_TerminalAreaMaster;
	use40ftIds			: Boolean;
	
begin
	create pxyRTGArea transient;
	
	use40ftIds := self.opts.bool("use40ftIds");			// 26/08/2011 cnwmh5
	
	pxyRTGArea.setIsEmpty(true);
	pxyRTGArea.setGridAreaProxy(_name, 
					"",
					TA_TYPE_RTG,
					_rows,
					_stacks,
					_tiers,
					true, 
					self.getTerminal,
					false,
					false,
					false,
					0,
					 false, false, false, false, false, null,null, use40ftIds, false,
					 null,null,null,null);
	
	create pDO transient;
	pDO.setProxy(false, true, pxyRTGArea);
	pDO.setProxyRules(DeckingRule_Default, DeckingRule_Default);
	
	foreach row in 1 to _rows do
		label := row.stringWithLeadingZeros(2);
		create pxyGridRow transient;
		pxyGridRow.setForProxy(row, label, pxyRTGArea);
		foreach column in 1 to _stacks do
			label := column.stringWithLeadingZeros(4);
			pxyGridCol := pxyRTGArea.allGridColumns[column].CM_RTGColumn;
			if pxyGridCol = null then
				create pxyGridCol transient;
				pxyGridCol.setForProxy(column, label, pxyRTGArea);
			endif;
			
			create pxyStackCntrl transient;
			pxyStackCntrl.setForProxy(PAD_AVAILABLE, 
							NORMAL_USE, 
							pxyGridRow.row, 
							pxyGridCol.column,
							pxyGridRow.label &amp; pxyGridCol.label,
							2,
							false,
							false,
							null,
							pxyRTGArea, false,null, false, null, false, null);
	

			/*pxyStackCntrl.setForProxyGridController(pxyGridRow.label &amp; pxyGridCol.label, 
								pxyGridCol,
								pxyGridRow,
								2);*/

		endforeach;
	endforeach;
	
	pxyRTGArea.setProxyGantryICAreas(pxyRTGArea, CM_RTGArea.ICPosition_BeforeRow1);

	// 26/08/2011 cnwmh5
	pxyTA := pxyRTGArea;
	// only do this if use40ftIds is set as returns correct location but slightly different format
	if use40ftIds then
		create pxyCMIFTerminalArea transient;
		pxyCMIFTerminalArea.numRows :=  _rows;
		pxyCMIFTerminalArea.numColumns := _stacks;
		pxyCMIFTerminalArea.myPxyTerminalAreaMaster := pxyRTGArea;
		pxyCMIFTerminalArea.startNumColumn := 1;
		pxyCMIFTerminalArea.startNumRow := 1;
		pxyCMIFTerminalArea.labelLengthCol := 4;
		pxyCMIFTerminalArea.labelLengthRow := 4;
		pxyCMIFTerminalArea.use40ftIds := use40ftIds;
		pxyCMIFTerminalArea.createProxyStructure();
		pxyTA := pxyCMIFTerminalArea.myPxyTerminalAreaMaster;
	endif;		
	
	app.myTrxCA.trxCreateTerminalArea(pxyTA, realTA, app.myPassport);				// 26/08/2011 cnwmh5
	self.assertNoTrxErrorsOrWarnings();

	return realTA.CM_RTGArea;
	
epilog

//	pxyCMIFTerminalArea.myPxyTerminalAreaMaster.inspectModal();
	if pxyRTGArea &lt;&gt; null then	// 22/11/2011 cnwmh5 - Added so if error occurs before created that is returned not 1090 from .erase
		pxyRTGArea.erase(0);	//12 Jan 2011	NDL Leaking transients	 must use erase, delete incomplete...
	endif;
	delete pxyCMIFTerminalArea;
	
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_rows" type="Integer"/>
        <Parameter name="_stacks" type="Integer"/>
        <Parameter name="_tiers" type="Integer"/>
        <ReturnType type="CM_RTGArea"/>
    </JadeMethod>
    <JadeMethod name="addRTGAreaFromProxy" id="1428c9ab-e643-43a2-8ea3-b7c809ffee54">
        <source>addRTGAreaFromProxy(pxyRTGArea: CM_RTGArea; _rows,_stacks: Integer): CM_RTGArea;
//01 September 2008	cnwdw1	 
//
vars
	pxyCMIFTerminalArea: CMIF_RTGArea;
	realTA		: CM_TerminalAreaMaster;
	pDO: CM_YADeckingOptionsTA;
begin
	create pDO transient;
	pDO.setProxy(false, true, pxyRTGArea);
	pDO.setProxyRules(DeckingRule_Default, DeckingRule_Default);
	
	create pxyCMIFTerminalArea transient;
	pxyCMIFTerminalArea.numRows :=  _rows;
	pxyCMIFTerminalArea.numColumns := _stacks;
	pxyCMIFTerminalArea.myPxyTerminalAreaMaster := pxyRTGArea;
	pxyCMIFTerminalArea.startNumColumn := 1;
	pxyCMIFTerminalArea.startNumRow := 1;
	pxyCMIFTerminalArea.labelLengthCol := 4;
	pxyCMIFTerminalArea.labelLengthRow := 4;
	pxyCMIFTerminalArea.createProxyStructure();
	
	app.myTrxCA.trxCreateTerminalArea(pxyCMIFTerminalArea.myPxyTerminalAreaMaster,realTA,  app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());

	return realTA.CM_RTGArea;
epilog
	delete pxyCMIFTerminalArea;
end;</source>
        <Parameter name="pxyRTGArea" type="CM_RTGArea"/>
        <Parameter name="_rows" type="Integer"/>
        <Parameter name="_stacks" type="Integer"/>
        <ReturnType type="CM_RTGArea"/>
    </JadeMethod>
    <JadeMethod name="addRailArea" id="98e794b2-b0f6-4988-9d9c-71be5c83c58f">
        <source>addRailArea(_id : String; _numLines, _numPositions : Integer) : CM_Rail ;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 July 2009	cnwmd1	Initial creation

*/

vars
	pxyRail : CM_Rail; //Rail Area
	pDO: CM_YADeckingOptionsTA;
	realTA 	: CM_TerminalAreaMaster;
begin
	create pxyRail transient;
	pxyRail.setProxy(_id,
						null,
						TA_TYPE_RAILWAY_TRACK,
						_numLines,
						_numPositions,
						null,
						false,
						false,
						false,
						false,
						app.myPassport.myTerminal,
						false,
						false,
						null,null,null);
					
	create pDO transient;
	pDO.setProxy(false, true, pxyRail);
	pDO.setProxyRules(DeckingRule_Default, DeckingRule_Default);
							
	app.myTrxCA.trxCreateTerminalArea(pxyRail,realTA,  app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());

	return realTA.CM_Rail;					
						
epilog

	delete pDO;

	if pxyRail &lt;&gt; null and pxyRail.myLayoutGraphic &lt;&gt; null then
//write pxyRail.myTransferArea;
		delete pxyRail.myLayoutGraphic;
	endif;
	delete pxyRail;

	//delete pDO;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_numLines" type="Integer"/>
        <Parameter name="_numPositions" type="Integer"/>
        <ReturnType type="CM_Rail"/>
    </JadeMethod>
    <JadeMethod name="addRailPreNote" id="8c549d10-59b4-4a15-90e2-fad2959f055c">
        <source>addRailPreNote( _wagonId : String; _wagonClassId : String; _id: String ) : CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 October 2014	cnwndl1	Initial creation	Par 35040

*/

vars
	ifArray: CMIF_TIObjectArray;
	ifPreNote: CMIF_PreNote;
	verify : Boolean;
	term : CM_Terminal;
begin

	term := self.getTerminal;
	
	create ifArray transient;
	create ifPreNote transient;	
	ifPreNote.id := _id;
	ifPreNote.myTerminal := term;
	
	ifPreNote.cargoType := TI_CargoType_Container;
	if self.opts.includesKey("CargoType") then
		ifPreNote.cargoType := self.opts.int("CargoType");
	endif;
	
	if ifPreNote.cargoType = TI_CargoType_Container then
		if self.opts.includesKey("ISOType") then
			ifPreNote.isoType := self.opts.str("ISOType");
		else
			ifPreNote.isoType := "2200";
		endif;
	endif;
	ifPreNote.commodity := term.getDefaultEmptyCommodity;	
	
	ifPreNote.imExStatus := getRoot.allImexStatuses[TI_IMEX_STATUS_STORAGE];
	ifPreNote.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	ifPreNote.weightTotal := 4000;
	ifPreNote.voyageCode := term.getNullVoyage.code;

	ifPreNote.transportMode := TI_TRANSMODE_RAIL_STR;

	ifPreNote.directDelivery := self.opts.bool("DD");
	
	ifPreNote.wagon := _wagonId;
	if _wagonClassId &lt;&gt; null then
		ifPreNote.myWagonClass := getRoot.allWagonClasses.getAtKey(_wagonClassId);
	endif;

	ifArray.add(ifPreNote);
	
	verify := self.opts.bool("Verify");
	if not verify then
		self.ignoreTrxWarnings(true);

	endif;
	app.myTrxCA.trxCreatePreNotes(ifArray, verify, app.myPassport);
	if not verify then
		self.assertNoTrxErrorsOrWarnings;
	endif;
	return ifPreNote.myPersistentTrackedItem;
	
epilog

	delete ifArray;
	delete ifPreNote;
	
	app.myEventManager.dispatchAllEvents;

end;</source>
        <Parameter name="_wagonId" type="String"/>
        <Parameter name="_wagonClassId" type="String"/>
        <Parameter name="_id" type="String"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addReceiveTransArea" id="cd3c3171-6d8a-4f60-9783-c643f786b123">
        <source>addReceiveTransArea(_name: String; _max: Integer; _icArea :Any): CM_BlockStack;
// 20/1102/14	cnwdap1
// PAR #35236

vars
	pxyBlockStack	: CM_BlockStack;
	realTA 			: CM_TerminalAreaMaster;
	pDO				: CM_YADeckingOptionsTA;
	icArray 		: CM_InterchangeAreaArray;
	
begin
	self.deleteTerminalArea(_name);
	if _icArea &lt;&gt; null  then
		create icArray transient;
		if _icArea.isKindOf (CM_InterchangeArea) then
			icArray.add(_icArea.CM_InterchangeArea);
		elseif _icArea.isKindOf (ObjectArray) then
			_icArea.ObjectArray.copy (icArray);
		endif;
	endif;
	create pxyBlockStack transient;
	pxyBlockStack.setProxy(_name, 
					"",
					TA_TYPE_RECTRANS, 
					_max,
					5,
					5,
					false,
					"", 
					_max,
					true, 
					null,
					self.getTerminal,
					false,
					false,
					false,
					false,
					false,
					icArray,
					null,
					false
					);
	create pDO transient;
	pDO.setProxy(false, true, pxyBlockStack);
	pDO.setProxyRules(DeckingRule_Default, DeckingRule_Default);

	if self.opts.includesKey("ActAsReleasePoint") then
		pxyBlockStack.setPropertyValue(CM_BlockStack::actAsReleasePoint.name, self.opts.int("ActAsReleasePoint"));
	endif;
	
	if self.opts.includesKey("StockControlled") then
		pxyBlockStack.setPropertyValue(CM_BlockStack::isStockControlled.name, self.opts.bool("StockControlled"));
	endif;
	
	if self.opts.includesKey("Comment") then
		pxyBlockStack.setPropertyValue(CM_BlockStack::comment.name, self.opts.str("Comment"));
	endif;
	
	if self.opts.includesKey("DefaultYIC") then
		pxyBlockStack.setPropertyValue(CM_BlockStack::myDefaultInterchangeArea.name, self.opts.obj("DefaultYIC").CM_YardInterchangeArea);
	endif;
	
	app.myTrxCA.trxCreateTerminalArea(pxyBlockStack, realTA, app.myPassport);
	if not self.opts.includesKey("ExpectErrors") then
		self.assertNoTrxErrorsOrWarnings();
	endif;

	if realTA = null then
		return null;
	else
		return realTA.CM_BlockStack;
	endif;
epilog
	delete pxyBlockStack;		//+cnwml2 MSL CCMS 1012  pDo gets deleted when deleting pxyBlockStack
	//delete pDO;
	delete icArray;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_max" type="Integer"/>
        <Parameter name="_icArea" type="Any"/>
        <ReturnType type="CM_BlockStack"/>
    </JadeMethod>
    <JadeMethod name="addReleaseById" id="8cb41110-ef4f-4d17-aa2f-b39a66e60892">
        <source>addReleaseById(_releaseNumber: String; _releaseType: Integer; _cargo: Any): CM_BulkRelease;
/* Changes

Date		Name	TFS#			Description
============================================================================
23/12/2008	cnwdw1	
23/04/2012	cnwcs5	CCMS POL 2172 
					/ par 29480  	coparn release updates
24/10/2012	cnwmh5	#30539  		Update to allow Allow Cargo On Multiple Releases to be set
12/05/2016	cnwns1	TFS 488 		Multi Timezone Support
24/01/2019	jlgka1	41708			As a result of the changes in the CM_BulkRelease.setProxy
									we also need to add myBOLIn here.
============================================================================*/							
vars
	release: CM_BulkRelease;
	pxyReleaseRequest: CM_BulkRelease;
	pxyReserveTI: CM_ReserveTI;
	fullRelease: Boolean;
	ta: CM_TerminalArea;
	number: Integer;
	voyage: CM_Voyage;
	voyageCode: String;
	cargo: CM_TrackedItem;
	delReasonCode	:Integer;
	delReasonDesc	:String;
	delRelRemarks   : String;
	allowMultiReleases : Boolean;
	consigneeCode: String;
begin
	deleteReleaseRequest(_releaseNumber);
	
	fullRelease := self.opts.bool("FullRelease");
	ta := self.opts.obj("TerminalArea").CM_TerminalArea;
	number := self.opts.int("Number");
	if number = 0 then
		number := 1;
	endif;
	
	voyage := self.opts.obj("Voyage").CM_Voyage;
	if voyage &lt;&gt; null then
		voyageCode := voyage.code;
	endif;
	
	delReasonCode := self.opts.int ("DeliveryReleaseReason");
	
	allowMultiReleases := self.opts.bool("AllowCargoMultipleReleases");					// 24/10/2012 cnwmh5 #30539
	
	if delReasonCode &lt;&gt; null then
		delReasonDesc := app.deliveryReasonEnumToString (delReasonCode);
	endif;
	
	if self.opts.includesKey("RelRemarks") then    //cnwma1 30/10/2014 PAR #35088
	delRelRemarks := self.opts.str("RelRemarks");
	else
	delRelRemarks:= null;
	endif;
	
	if self.opts.includesKey("consigneeCode") then    // cnwmk3 11/03/2016 for UT_Gate: tUpdateConsignee
	consigneeCode := self.opts.str("consigneeCode");
	else
	consigneeCode:= null;
	endif;
	
	create pxyReleaseRequest transient;
	pxyReleaseRequest.setProxy(_releaseNumber,
								_releaseType,
								false,
								BR_ACTIVE,
								null,
								null,
								self.getProfileStr(UT_Profile.P_CARRIER),
								delRelRemarks,// Remarks						// 24/10/2012 cnwmh5 #30539
								consigneeCode,
								null,
								null,
								null,
								null,//consign voyage
								app.actualTimeServer(),		// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
								null, //today,		// cnwdad1 30/05/2007 - PAR #14132: Do not default required date to today.
								delReasonCode,
								delReasonDesc,
								null,
								null, //door dir
								null,
								self.opts.obj("Booking").CM_BookingRef,
								self.getTerminal().getDefaultPort,//load port
								null,//_destinationPort
								null,
								null,//freightForwarder
								null,
								self.getTerminal(),
								self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),
								null,
								voyage,//voyage
								null,//bank
// TFS 2686								false,
								fullRelease,
								null,null,null,
								self.getTerminal().getDefaultSubTerminalForRel(_releaseType),
								null, // subterm target//cnwrd1 par 23219 17.3.2010
								null, 	//_assignedTrain : CM_Train
								allowMultiReleases,							// 24/10/2012 cnwmh5 #30539
								null,				// cnwrl1 19/02/2010 PAR 22393
								false,				// cnwrl1 19/02/2010 PAR 22393
								false, false,				// May 2011 cnwjre1 27097 POL CCMS 2043
								false, 	// par 29480 april 2012
								null,	// CCMS POL 2122 / PAR 28696 cnwrs1
								null,
								null,	// jlgka1 TFS 41708
								null	// ### TFS 53953 27June2022 NAVPW1
								);
	if _cargo.isKindOf(CM_TrackedItem) then
		create pxyReserveTI transient;
		pxyReserveTI.setMyHeader(pxyReleaseRequest);
		pxyReserveTI.allTrackedItems.add(_cargo.CM_TrackedItem);
		if self.opts.int("TotalRequested") &gt; 0 and _cargo.isKindOf(CM_BreakBulkGeneric) then
			pxyReserveTI.setTotalRequested(self.opts.int("TotalRequested"));
		endif;
	else
		foreach cargo in _cargo.CM_TISet do
			create pxyReserveTI transient;
			pxyReserveTI.setMyHeader(pxyReleaseRequest);
			pxyReserveTI.allTrackedItems.add(cargo.CM_TrackedItem);
			pxyReleaseRequest.allTrackedItemsAssigned.add(cargo.CM_TrackedItem);
			if self.opts.int("TotalRequested") &gt; 0 and cargo.isKindOf(CM_BreakBulkGeneric) then
				pxyReserveTI.setTotalRequested(self.opts.int("TotalRequested"));
			endif;
		endforeach;
	endif;
	
	if opts.bool("CreateDeliveryRequest") then 					
		pxyReleaseRequest.createRequests();
	endif;	
	
	app.myTrxCA.trxCreateBulkRelease(pxyReleaseRequest, release,null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	return release;
epilog
	delete pxyReleaseRequest;
end;</source>
        <Parameter name="_releaseNumber" type="String"/>
        <Parameter name="_releaseType" type="Integer"/>
        <Parameter name="_cargo" type="Any"/>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="addReleaseByTypeRequest" id="3f00aa53-8384-4057-b817-026ecdd4cf97">
        <source>addReleaseByTypeRequest(_releaseNumber: String; _releaseType: Integer; _cargoType: Integer; _isoCode: String): CM_BulkRelease;
//23 December 2008	cnwdw1	
vars
begin
	///self.opts.purge;								// 23/06/2015 cnwmh5
	self.opts.addAssoc("ISOType", _isoCode);
	return self.addReleaseByTypeRequestOpts(_releaseNumber, _releaseType, _cargoType);
epilog
end;</source>
        <Parameter name="_releaseNumber" type="String"/>
        <Parameter name="_releaseType" type="Integer"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_isoCode" type="String"/>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="addReleaseByTypeRequestOpts" id="e04551e7-9be6-42ac-bf5a-8225707b5948">
        <source>addReleaseByTypeRequestOpts(_releaseNumber: String; _releaseType: Integer; _cargoType: Integer): CM_BulkRelease;
/*//23 December 2008	cnwdw1	
// Opts :- ISoType -&gt; string
// Opts :- ISOGroup -&gt; string
// Opts :- BookingItem
// Opts :- Product
// Opts :- Number
// Opts :- Train
// Opts :- CreateDeliveryRequest

/* Changes

Date		Name	TFS#			Description
============================================================================
12/08/2011	cnwmh5					Change to use UT_UnitTest's opts rather than passing it
23/04/2012	cnwcs5	CCMS POL 2172 
					/ par 29480  	coparn release updates
06/05/2012	cnwcs5					add consignor/consignee
09/09/2014	cnwrs1	CCMS 2351 		att Sequence to Release request 
20/11/2014	cnwdap1	PAR #35236 		set iso group on bulk release if supplied
01/07/2015	cnwma1	PAR #36555 
					CCMS 2509 TFS 	Multi-location selection for MTs for vessel release
12/05/2016	cnwns1	TFS 488  		Multi Timezone Support
24/01/2019	jlgka1	41708			As a result of the changes in the CM_BulkRelease.setProxy
									we also need to add myBOLIn here.
//19/07/2022	navtnr20	ChangeRequest 53974: EUP - OUT - Additional Fields on Release Line Level
28 June 2023 navmv20 CR 58410 Task 58411: UI - Cargo Review - Release Request	
6/12/2023	navcs2	ChangeRequest 57537: EUP | Release Request By Type - with Weight															
============================================================================*/							
vars
	release: CM_BulkRelease;
	pxyReleaseRequest: CM_BulkRelease;
	pxyReserveSelection, pxyReserveSelection2: CM_ReserveSelection;
	pxyDeliveryRequest :CM_DeliveryRequest;
	isoType: CM_ISOType;
	isoGroup, isoGroup2: CM_ISOTypeGroup;
	fullRelease: Boolean;
	canBeHiLoCube : Boolean;
	ta: CM_TerminalArea;
	number: Integer;
	voyage: CM_Voyage;
	voyageCode: String;
	operator : CM_Operator;
	grade : CM_MTGrade;
	availGrades : IntegerArray;
	carrierId : String;
	consignor, consignee	:String;
	matchYACriteria : CM_ReleaseByTypeCriteria;
	delRequest : CM_DeliveryRequest;
	reserveSel : CM_ReserveSelection;
	allTermAreaDict: CM_TAByIdDict;
	doDelete : Boolean;
	weightSelection : Decimal[14,4];
	tempWeightSelection : Decimal[14,4];
	measurementType : CM_MeasurementType;
	unit 			: String;
	product			: CM_Product;
	productObj		: Any;
	delivReasonCode : Integer;
	deliveryReason  : String;
begin

	doDelete := true;
	if opts.includesKey("NoDelete") then
		doDelete := not self.opts.bool("NoDelete");
	endif;
	if doDelete then
		self.deleteReleaseRequest(_releaseNumber);
	endif;
	
	fullRelease := self.opts.bool("FullRelease");
	canBeHiLoCube := self.opts.bool("CanBeHiLoCube");
	isoType := app.myRoot.allISOTypes[self.opts.str("ISOType")];
	isoGroup := app.myRoot.allISOTypeGroups[self.opts.str("ISOGroup")];
	isoGroup2 := app.myRoot.allISOTypeGroups[self.opts.str("ISOGroup2")];
	ta := self.opts.obj("TerminalArea").CM_TerminalArea;
	create allTermAreaDict transient;
	if ta &lt;&gt; null then
		allTermAreaDict.add(ta);
	endif;
	number := self.opts.int("Number");
	if number = 0 then
		number := 1;
	endif;
	
	voyage := self.opts.obj("Voyage").CM_Voyage;
	if voyage &lt;&gt; null then
		voyageCode := voyage.code;
	endif;
	
	operator := self.opts.obj("Operator").CM_Operator; 
	if operator = null then
		operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	endif;	
	
	grade := self.opts.obj("Grade").CM_MTGrade;
	if grade &lt;&gt; null then
		create availGrades transient;
		availGrades.add(grade.code);
	endif;
	
	carrierId := self.getProfileStr(UT_Profile.P_CARRIER);			// 08/11/2011 cnwmh5
	if self.opts.includesKey("Carrier") then
		carrierId := self.opts.obj("Carrier").CM_Carrier.code;
	endif;
	
	if opts.includesKey(UTTI_Consignee) then
		consignee := opts.str(UTTI_Consignee);
	endif;
	if opts.includesKey(UTTI_Consignor) then
		consignor := opts.str(UTTI_Consignor);
	endif;
	
	if opts.includesKey("DeliveryReasonCode") then
		delivReasonCode := opts.int("DeliveryReasonCode");
	endif;
	
	if opts.includesKey("DeliveryReason") then
		deliveryReason := opts.str("DeliveryReason");
	endif;
	
	//18 Jun 2015	NDL	Par 36338
	if opts.includesKey(ETRow_SetCriteria) then
		matchYACriteria := self.opts.obj(ETRow_SetCriteria).CM_ReleaseByTypeCriteria;
	endif;
	
	create pxyReleaseRequest transient;
	pxyReleaseRequest.setProxy(_releaseNumber,
								_releaseType,
								true,
								BR_ACTIVE,
								null,
								null,
								//self.getProfileStr(UT_Profile.P_CARRIER),
								carrierId,
								null,
								consignee,
								null,
								consignor,
								null,
								null,//consign voyage
								app.actualTimeServer(),		// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
								null, //today,		// cnwdad1 30/05/2007 - PAR #14132: Do not default required date to today.
								delivReasonCode,
								deliveryReason,
								null,
								null, //door dir
								null,
								self.opts.obj("Booking").CM_BookingRef,
								self.getTerminal().getDefaultPort,//load port
								null,//_destinationPort
								self.opts.obj("DischargePort").CM_Port,
								null,//freightForwarder
								null,
								self.getTerminal(),
								operator,
								null,
								voyage,//voyage
								null,//bank
// TFS 2686								false,
								fullRelease,
								null,null,null,
								self.getTerminal().getDefaultSubTerminalForRel(_releaseType),
								null, // subterm target//cnwrd1 par 23219 17.3.2010
								self.opts.obj("Train").CM_Train, 	//_assignedTrain : CM_Train
								false,
								null,				// cnwrl1 19/02/2010 PAR 22393
								false,				// cnwrl1 19/02/2010 PAR 22393
								canBeHiLoCube, false,				// May 2011 cnwjre1 27097 POL CCMS 2043
								false, // par 29480 April 2012
								null, 	//CCMS POL 2122 / PAR 28696 cnwrs1
								null,
								null,	//jlgka1 TFS 41708
								null	// ### TFS 53953 27June2022 NAVPW1
								);
								
	if isoGroup &lt;&gt; null then															// PAR #35236
		pxyReleaseRequest.setPropertyValue(CM_BulkRelease::myISOGroup.name, isoGroup);	// PAR #35236
	endif;																				// PAR #35236
	
	
	if self.opts.includesKey("WeightSelection") then						// 18/03/2016 cnwmh5
		weightSelection := self.opts.dec("WeightSelection");
	endif;
	
	if self.opts.includesKey("MeasurementType")then							// 18/03/2016 cnwmh5
		measurementType := self.opts.obj("MeasurementType").CM_MeasurementType;
		weightSelection := app.convertMeasurementForStorage(measurementType.shortName, weightSelection);
	endif;
	
	create pxyReserveSelection transient;
	pxyReserveSelection.setMyHeader(pxyReleaseRequest);
	pxyReserveSelection.setPxyDefaults();
	
	// 13/03/2018 jlgmh5
	product := self.opts.obj("Product").CM_Product;
	if self.opts.includesKey("ProductStr") then
		product := app.myRoot.allCargoTypesById[_cargoType].getProductFromCode(self.opts.str("ProductStr"));
	endif;

	pxyReserveSelection.setProxy(0, 
								app.myRoot.allCargoTypesById[_cargoType],
								self.opts.obj("BookingItem").CM_BookingRefItem,
								isoType,
								isoGroup,
								product,
								null,
								null,
								number,
								availGrades, //avail grades
								null,//clean
								null, //iso check
								false, //heavy rated
								null, //mask ids
								0,
								self.opts.str("Colour"),
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								weightSelection,					// 18/03/2016 cnwmh5  null,
								null,
								self.opts.str("Mark"),
								null,
								null,
								//ta,					// 01/07/2015 cnwma1 PAR #36555
								allTermAreaDict,		 // 01/07/2015 cnwma1 PAR #36555
								self.opts.obj("BOL").CM_BOLIn,
								self.opts.bool("BestPick"),
								null,
								null,null,null,null,null,false,false,null,null,null,null,null,null,null,null,
								null,	// ### TFS 53953 11July2022 NAVPW1
								null,null,  //12-07-2022 navtnr20 53974
								null,	//28/06/2023 navmv20 CR 58410 Task 58411
								false,	// 6/12/2023 navcs2 ChangeRequest 57537
								false,	//19/02/2023	navkc1 CR 60078 Task 62450
								null,	//24/04/2025	navrv30	MTN 34319
								null);
								
	//18 Jun 2015	NDL	Par 36338
	if matchYACriteria &lt;&gt; null then
		matchYACriteria.setProxyBaseData(pxyReserveSelection);
	endif;

    if isoGroup2 &lt;&gt; null then
		/// Create a second release item sane as first but for isogroup
		create pxyReserveSelection2 transient;
		pxyReserveSelection2.setMyHeader(pxyReleaseRequest);
		pxyReserveSelection2.setPxyDefaults();
		
		pxyReserveSelection2.setProxy(0, 
								app.myRoot.allCargoTypesById[_cargoType],
								self.opts.obj("BookingItem").CM_BookingRefItem,
								isoType,
								isoGroup2,
								self.opts.obj("Product").CM_Product,
								null,
								null,
								number,
								availGrades, //avail grades
								null,//clean
								null, //iso check
								false, //heavy rated
								null, //mask ids
								0,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								//ta, 				// 01/07/2015 cnwma1 PAR #36555
								allTermAreaDict,    // 01/07/2015 cnwma1 PAR #36555
								self.opts.obj("BOL").CM_BOLIn,
								self.opts.bool("BestPick"),
								null,
								null,null,null,null,null,false,false,null,null,null,null,null,null,null,null,
								null,	// ### TFS 53953 11July2022 NAVPW1
								null,null,
								null, //28/06/2023 navmv20 CR 58410 Task 58411
								false,
								false, //19/02/2023	navkc1 CR 60078 Task 62450
								null,	//24/04/2025	navrv30	MTN 34319
								null);

	endif;
	
	if opts.bool("CreateDeliveryRequest") then							
		pxyDeliveryRequest := pxyReleaseRequest.createRequests();
		if not fullRelease then
			pxyDeliveryRequest.setMTCommodity();
		endif;
	endif;	
	
	app.myTrxCA.trxCreateBulkRelease(pxyReleaseRequest, release,null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	//18 Jun 2015	NDL	Par 36338
	if matchYACriteria &lt;&gt; null then
		delRequest := release.requests.first.CM_DeliveryRequest;
		reserveSel := release.allReserveDetails.first.CM_ReserveSelection;
		if delRequest &lt;&gt; null then
			beginTransaction;
			delRequest.setReserveDetail( reserveSel ); 
			commitTransaction;
		endif;
	endif;
			
	return release;
epilog
	delete pxyReleaseRequest;
	delete availGrades;
	delete allTermAreaDict;
end;</source>
        <Parameter name="_releaseNumber" type="String"/>
        <Parameter name="_releaseType" type="Integer"/>
        <Parameter name="_cargoType" type="Integer"/>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="addReleaseRequest" id="aca009b5-ee62-4891-9bd8-776408158d88">
        <source>addReleaseRequest(_releaseNumber : String; _releaseType : Integer; _operator : String; _pxyReleaseRequest : CM_BulkRelease io): CM_BulkRelease;
/*

Purpose:	Create a Release Request		

/* Changes

Date		Name	TFS#	Description
============================================================================
15/11/2017	jlgmh5			Initial creation	
24/01/2019	jlgka1	41708	As a result of the changes in the CM_BulkRelease.setProxy
							we also need to add myBOLIn here.
============================================================================*/

vars

	release							: CM_BulkRelease;
	operator						: CM_Operator;
	voyage							: CM_Voyage;
	pxyDeliveryRequest 				: CM_DeliveryRequest;
	matchYACriteria 				: CM_ReleaseByTypeCriteria;
	delRequest 						: CM_DeliveryRequest;
	reserveSel 						: CM_ReserveSelection;
	dischargePort					: CM_Port;
	ti								: CM_TrackedItem;
	
	tokens							: StringArray;
	
	doDelete						: Boolean;
	carrierId						: String;
	consignor						: String;
	consignee	       				: String;
	fullRelease						: Boolean;
	canBeHiLoCube					: Boolean;
	releaseByType					: Boolean;
	allowMultipleReleases			: Boolean;
	tiId							: String;
	
begin

	doDelete := true;
	if opts.includesKey("NoDelete") then
		doDelete := not self.opts.bool("NoDelete");
	endif;
	if doDelete then
		self.deleteReleaseRequest(_releaseNumber);
	endif;
	
	carrierId := self.getProfileStr(UT_Profile.P_CARRIER);			// 08/11/2011 cnwmh5
	if self.opts.includesKey("Carrier") then
		carrierId := self.opts.obj("Carrier").CM_Carrier.code;
	endif;
	
	if opts.includesKey(UTTI_Consignee) then
		consignee := opts.str(UTTI_Consignee);
	endif;
	if opts.includesKey(UTTI_Consignor) then
		consignor := opts.str(UTTI_Consignor);
	endif;
	
	///operator := self.opts.obj("Operator").CM_Operator; 
	///if operator = null then
	///	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	///endif;
	if _operator &lt;&gt; null then
		operator := self.getOperator(_operator).CM_Operator;
	else
		operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	endif;
	
	if opts.includesKey(ETRow_SetCriteria) then
		matchYACriteria := self.opts.obj(ETRow_SetCriteria).CM_ReleaseByTypeCriteria;
	endif;
	
	///voyage := self.opts.obj("Voyage").CM_Voyage;
	if self.opts.includesKey("Voyage") then
		voyage := self.getVoyage(self.opts.str("Voyage"));
	endif;
	
	canBeHiLoCube := self.opts.bool("CanBeHiLoCube");
	
	if self.opts.includesKey("DischargePort") then
		dischargePort := app.myRoot.allPorts[self.opts.str("DischargePort")].CM_Port;
	endif;
	
	fullRelease := (not self.opts.includesKey("EmptiesOnly")).Boolean;
	
	allowMultipleReleases := self.opts.includesKey("AllowMultipleReleases").Boolean;
	
	_pxyReleaseRequest.setProxy(_releaseNumber,
								_releaseType,
								self.opts.includesKey("ReleaseByType").Boolean,
								BR_ACTIVE,
								null,
								null,
								//self.getProfileStr(UT_Profile.P_CARRIER),
								carrierId,
								null,
								consignee,
								null,
								consignor,
								null,
								null,//consign voyage
								app.actualTimeServer(),		// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
								null, //today,		// cnwdad1 30/05/2007 - PAR #14132: Do not default required date to today.
								null,
								null,
								null,
								null, //door dir
								null,
								self.opts.obj("Booking").CM_BookingRef,
								self.getTerminal().getDefaultPort,//load port
								null,//_destinationPort
								dischargePort,
								null,//freightForwarder
								null,
								self.getTerminal(),
								operator,
								null,
								voyage,//voyage
								null,//bank
// TFS 2686								false,
								fullRelease,
								null,null,null,
								self.getTerminal().getDefaultSubTerminalForRel(_releaseType),
								null, // subterm target//cnwrd1 par 23219 17.3.2010
								self.opts.obj("Train").CM_Train, 	//_assignedTrain : CM_Train
								allowMultipleReleases,
								null,				// cnwrl1 19/02/2010 PAR 22393
								false,				// cnwrl1 19/02/2010 PAR 22393
								canBeHiLoCube, false,				// May 2011 cnwjre1 27097 POL CCMS 2043
								false, // par 29480 April 2012
								null, 	//CCMS POL 2122 / PAR 28696 cnwrs1
								null,
								null,	//jlgka1 TFS 41708
								null	// ### TFS 53953 27June2022 NAVPW1
								);
								
	if opts.bool("CreateDeliveryRequest") then							
		pxyDeliveryRequest := _pxyReleaseRequest.createRequests();
		if not fullRelease then
			pxyDeliveryRequest.setMTCommodity();
		endif;
	endif;	
	
	app.myTrxCA.trxCreateBulkRelease(_pxyReleaseRequest, release,null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	//18 Jun 2015	NDL	Par 36338
	if matchYACriteria &lt;&gt; null then
		delRequest := release.requests.first.CM_DeliveryRequest;
		reserveSel := release.allReserveDetails.first.CM_ReserveSelection;
		if delRequest &lt;&gt; null then
			beginTransaction;
			delRequest.setReserveDetail( reserveSel ); 
			commitTransaction;
		endif;
	endif;
	
	// 27/03/2017 jlgmh5
	if self.opts.includesKey("releaseAssignCargo") then
		create tokens transient;
		tiId := self.opts.str("releaseAssignCargo");
		tiId.getTokensForDelimiter(";", tokens);
		foreach tiId in tokens do
			ti := self.getTrackedItem(tiId);
			self.releaseAssignCargo(release, null, ti);
		endforeach;	
	endif;
			
	return release;
								
epilog

	delete tokens;

end;
</source>
        <Parameter name="_releaseNumber" type="String"/>
        <Parameter name="_releaseType" type="Integer"/>
        <Parameter name="_operator" type="String"/>
        <Parameter name="_pxyReleaseRequest" type="CM_BulkRelease" usage="io"/>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
