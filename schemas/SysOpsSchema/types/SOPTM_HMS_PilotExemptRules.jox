    <JadeMethod name="doSave" id="0eb67754-a6a9-4004-90b9-c5a3edd79661">
        <updating/>
        <source>doSave(): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2012	cnwndl1	Initial creation

*/

vars

	theForm : SOP_HMS_TableMaintForm;
	pxyExemptRule : HMS_PilotExemptionRule;
	
	criteria : Integer;
	isActive : Boolean;
	operator : Integer;
	value : Decimal [12,2];
	ruleName : String;
	harbour : HMS_Harbour;

begin

	theForm := self.myForm.SOP_HMS_TableMaintForm;
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as HMS_PilotExemptionRule transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy is null for update');
			return false;
		endif;
	endif;
	
	pxyExemptRule := theForm.myProxyObject.HMS_PilotExemptionRule;
	
	harbour := theForm.myHarbour;
	if theForm.cmbCriteria.listIndex &gt; 0 then
		criteria := theForm.cmbCriteria.itemData[ theForm.cmbCriteria.listIndex ];
	endif;
	if theForm.cmbOperator.listIndex &gt; 0 then
		operator := theForm.cmbOperator.itemData[ theForm.cmbOperator.listIndex ];
	endif;
	isActive := theForm.tblInput1.getValueByName(ETRow_IsActive).Boolean;
	value := theForm.tblInput1.getValueByName(ETRow_Value).Decimal;
	ruleName := theForm.tblInput1.getValueByName(ETRow_RuleName).String;
	
	pxyExemptRule.setProxy(	criteria,	//_criteria : Integer;
							isActive,	//_isActive : Boolean;
							operator,	//_operator : Integer;
							value,	//_value : Decimal;
							ruleName,	//_ruleName : String;
							harbour	//_myHarbour : HMS_Harbour
							);

	
	//Are we adding or updating
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateHMSObject(pxyExemptRule, theForm.myCurrentObject, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateHMSObject(pxyExemptRule, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name,
										method.name, 
										'  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
		
	return app.myPassport.trxCompletedOK;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCollection" id="20b07d0f-7f23-4b35-b269-d95e09359dd5">
        <source>getCollection(): Collection;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 April 2012	cnwndl1	Initial creation	Par 29496

*/

vars
	
	theForm : SOP_HMS_TableMaintForm;
	harbour : HMS_Harbour;

begin

	theForm := self.myForm.SOP_HMS_TableMaintForm;
	harbour := theForm.myHarbour;
	if harbour &lt;&gt; null then
		return harbour.allPilotExemptionRules;
	endif;

	return null;

epilog

end;</source>
        <ReturnType type="Collection"/>
    </JadeMethod>
