    <JadeMethod name="deleteObjectsFromCargoIDTable" id="8b550c3d-cc70-4662-8ef5-8bb1f07aa8f5">
        <updating/>
        <source>deleteObjectsFromCargoIDTable()updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 May 2009	#cnwdz2	 ccms1801

*/

vars
	tbl 			: CM_MobTable;
	selObject	    : Object;
	selObjects 		: ObjectArray;
	row,
	result 			: Integer;
	
begin
	tbl := self.getMainTable();
	if tbl = null then
		app.msgBox(app.getErrorString(Function_Key_Not_Used), '', MsgBox_OK_Only);
		return;
	endif;
	
	if not tbl.selected then
		app.msgBox(app.getErrorString(Remove_Nothing_Selected), '', MsgBox_OK_Only);
		return;
	endif;
	
	create selObjects transient;
	tbl.getAllSelectedObjects(selObjects);
	
	if selObjects.size &lt; 1 then
		app.msgBox(app.getErrorString(Remove_Nothing_Selected), '', MsgBox_OK_Only);
		return;
	endif;
	
	result := app.msgBox(app.getErrorString(Remove_selected_items), '', MsgBox_Yes_No);
	
	if result = MsgBox_Return_Yes then
		foreach selObject in selObjects do
			self.deleteObjectFromTable(selObject);
		endforeach;
	endif;
epilog
	delete selObjects;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCargoListSort" id="5943fa6d-576d-42b0-9440-d62104883c75">
        <updating/>
        <source>doCargoListSort() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 May 2009	#cnwdz2	 ccms1801

*/

vars

begin
	if self.tbl_CargoIDs.row = 1 then
		if not self.cargoListSorted then
			self.tbl_CargoIDs.sortColumn[1]	:= 1;
			self.tbl_CargoIDs.sortAsc[1]		:= true;
			
			self.tbl_CargoIDs.resort();
			self.cargoListSorted := true;
		else
			self.loadCargoIDsTbl(self.tbl_CargoIDs);
			self.cargoListSorted := false;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doEnableControls" id="b66c0790-2628-493f-8a94-3679bbf2a739">
        <source>doEnableControls() protected;
// --------------------------------------------------------------------------------
// Created:		02 July 2008 by cnwdad1
//
// Purpose:		Enables or disables controls based upon the current state of the form.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	sheetObj	: Sheet;
	
begin
	sheetObj	:=	fld_RequestForm.topSheet;
	
	if sheetObj = sht_CargoID then
		btn_Complete.enabled	:=	true;
		btn_Details.enabled		:=	false;
		
	elseif sheetObj = sht_Request then
		btn_Complete.enabled	:=	false;
		btn_Details.enabled		:=	tbl_PackingRqst.cnEcIsValidRow(tbl_PackingRqst.row);
		
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
