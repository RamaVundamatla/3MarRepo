    <JadeMethod name="addInterchangeArea" id="d5c4bf8d-d222-46aa-bfd3-c97acf3f18f6">
        <source>addInterchangeArea(_id : String; _selectedTerminalAreas: CM_TerminalAreaSet input) : CM_YardInterchangeArea;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 March 2011	cnwer1	Initial creation

*/

vars
	proxy			: CM_YardInterchangeArea;
	realTA 			: CM_TerminalAreaMaster;
begin

	self.deleteTerminalArea(_id);
	create proxy transient;
			
	proxy.setIsEmpty(true);
	proxy.pxyCreateNewLane (true);
	proxy.setProxy(_id, null, self.getTerminal, false, false, CM_InterchangeArea.Access_VehicleMachines, null,  _selectedTerminalAreas,0);
	
	if self.opts.includesKey("ActAsReleasePoint") then
		proxy.setPropertyValue(CM_YardInterchangeArea::actAsReleasePoint.name, self.opts.int("ActAsReleasePoint"));
	endif;
	
	if self.opts.includesKey("HideOverview") then
		proxy.setPropertyValue(CM_YardInterchangeArea::hideFromOverView.name, self.opts.bool("HideOverview"));
	endif;	
	
	app.myTrxCA.trxCreateTerminalArea(proxy, realTA, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());

	return realTA.CM_YardInterchangeArea;
	
epilog
	delete proxy;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_selectedTerminalAreas" type="CM_TerminalAreaSet" usage="input"/>
        <ReturnType type="CM_YardInterchangeArea"/>
    </JadeMethod>
    <JadeMethod name="addInvTypeAddedCharges" id="cfa2342a-07b2-411e-8373-e67951495f92">
        <source>addInvTypeAddedCharges(	_invType : CM_InvoiceDesc input;
						_rangeStart : Real;
						_rangeEnd : Real;
						_dr : CM_Debtor;
						_surInvLineTypeSet : CM_InvoiceLineDescSet input
						):CM_InvTypeAdditionalCharges;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 April 2018	jlgndl1	Initial creation TFS 37822

*/

vars

	surchargeExempt : CM_InvoiceTypeSurchargeExempt;

	proxy : CM_InvTypeAdditionalCharges;
	real : CM_InvTypeAdditionalCharges;

begin

	surchargeExempt := _invType.mySurchargeAndExemptions;
	if surchargeExempt = null then
		surchargeExempt := addInvTypeSurchargeExempt( _invType, 0, null, null );
	endif;

	if surchargeExempt &lt;&gt; null then
	
		create proxy transient;
		proxy.setProxy(	_surInvLineTypeSet,	//_allAdditionalInvTypes : CM_InvoiceLineDescSet input;
						_dr,	//_myDebtor : CM_Debtor;
						surchargeExempt,	//_mySurchargeExemption : CM_InvoiceTypeSurchargeExempt;
						_rangeStart,	//_rangeStart : Real;
						_rangeEnd	//_rangeEnd : Real
						);
						
		app.myTrxCA.trxCreateInvTypeAddedFees( proxy, real, app.myPassport );
	
	endif;
	
	return real;

epilog

	delete proxy;

end;</source>
        <Parameter name="_invType" type="CM_InvoiceDesc" usage="input"/>
        <Parameter name="_rangeStart" type="Real"/>
        <Parameter name="_rangeEnd" type="Real"/>
        <Parameter name="_dr" type="CM_Debtor"/>
        <Parameter name="_surInvLineTypeSet" type="CM_InvoiceLineDescSet" usage="input"/>
        <ReturnType type="CM_InvTypeAdditionalCharges"/>
    </JadeMethod>
    <JadeMethod name="addInvTypeCargoTypeSurchgRate" id="823bdb23-7b0a-4bd7-a887-c14490c8ccd4">
        <source>addInvTypeCargoTypeSurchgRate(	_invType				: CM_InvoiceDesc input;
								_surchargeRate			: Decimal; 
								_cargoType				: CM_CargoType;
								_cargoSubType			: CM_Product;
								_commodity				: CM_Commodity;
								_allSelectedInvLineDescs: CM_InvoiceLineDescSet;
								_surInvLineType			: CM_InvoiceLineDesc
								):CM_InvTypeCargoSurcharge;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 April 2018		jlgndl1	Initial creation TFS 37822
15 September 2022 	navpw1 	TFS 54565 (54385) - EUP - Inv Config - Invoice Surcharges

*/

vars
	surchargeExempt	: CM_InvoiceTypeSurchargeExempt;
	proxy,
	real			: CM_InvTypeCargoSurcharge;

begin
	surchargeExempt := _invType.mySurchargeAndExemptions;
	if surchargeExempt = null then
		surchargeExempt := addInvTypeSurchargeExempt( _invType, 0, null, null );
	endif;
	
	if surchargeExempt &lt;&gt; null then
		create proxy transient;
		proxy.setProxy(	_cargoType,					//_cargoType				: CM_CargoType;
						surchargeExempt,			//_mySurAndExempt			: CM_InvoiceTypeSurchargeExempt;
						_surInvLineType,			//_mySurInvLineType			: CM_InvoiceLineDesc;
						_surchargeRate,				//_surchargeRate			: Decimal;
						_cargoSubType,				//_cargoSubType				: CM_Product;
						_commodity,					//_commodity				: CM_Commodity;
						_allSelectedInvLineDescs	//_allSelectedInvLineDescs	: CM_InvoiceLineDescSet
						);
		app.myTrxCA.trxCreateCargoTypeSurRate( proxy, real, app.myPassport );
		
	endif;
	
	return real;
	
epilog
	delete proxy;
	
end;</source>
        <Parameter name="_invType" type="CM_InvoiceDesc" usage="input"/>
        <Parameter name="_surchargeRate" type="Decimal"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_cargoSubType" type="CM_Product"/>
        <Parameter name="_commodity" type="CM_Commodity"/>
