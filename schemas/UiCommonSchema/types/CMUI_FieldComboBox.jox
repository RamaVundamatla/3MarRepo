    <JadeMethod name="setIndex" id="5e0451e9-665b-4215-8513-d5c5e1c7c30d">
        <source>setIndex(_index:Integer);
// --------------------------------------------------------------------------------
// Created:		21 February 2006 by cnwdad1
//
// Purpose:		Sets the index of the combobox.
//
// Parameters:	_index - The new combobox index.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if _index &gt; 0 and _index &lt;= self.myComboBox.listCount() then
		self.myComboBox.cnEcSet(_index);// listIndex	:=	_index;
	endif;
end;</source>
        <Parameter name="_index" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setIsEnabled" id="bd6e0013-32e6-478b-9a99-b778ea7012e0">
        <updating/>
        <source>setIsEnabled(_isEnabled: Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		01 March 2006 by cnwdad1
//
// Purpose:		Refer to the superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myComboBox.enabled	:=	_isEnabled;
end;</source>
        <Parameter name="_isEnabled" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setItemEnabled" id="206ad988-37a4-4b41-a1af-6ad84df7a5f8">
        <source>setItemEnabled( _index : Integer; _isEnabled : Boolean );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 August 2021	navndl1	Initial creation	TFS 51771

*/

vars

begin

	if self.myComboBox = null then
		return;
	endif;
	if self.myComboBox.listCount &lt; _index or _index &lt; 1 then
		return;
	endif;
	
	self.myComboBox.itemEnabled[ _index ] := _isEnabled;

epilog

end;</source>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_isEnabled" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setListWidth" id="0af2472b-5d62-48f9-826c-c1798d08e1cf">
        <source>setListWidth(_width: Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 November 2019	jlgmp6	Initial creation	TFS46955

*/

vars
	combo: CMUI_FieldComboBoxControl;
begin
	combo := self.myComboBox;
	if combo &lt;&gt; null and _width &lt;&gt; 0 then
		combo.listWidth := _width;
	endif;
epilog

end;</source>
        <Parameter name="_width" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setTabOrder" id="20a00c61-b09d-438f-9f67-aead7983fc2a">
        <source>setTabOrder(_tabOrder: Integer):Integer;
// --------------------------------------------------------------------------------
// Created:		27 February 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tabOrder	: Integer;
	
begin
	tabOrder	:=	inheritMethod(_tabOrder);
	tabOrder	:=	tabOrder + 1;
	self.myComboBox.tabIndex	:=	tabOrder;
	
	return tabOrder;
end;</source>
        <Parameter name="_tabOrder" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setValue" id="5ed854ab-6236-4379-b5e3-e50a0e3ebe41">
        <updating/>
        <source>setValue(_value: Any) updating;
// --------------------------------------------------------------------------------
// Created:		22 February 2006 by cnwdad1
//
// Purpose:		Sets the receiver's field value.
//
// Parameters:	_value - The field value to set.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.setForText(_value.String);
end;</source>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="setWidths" id="026eaa3c-c7a8-4282-ae1e-9bc7d069673d">
        <updating/>
        <source>setWidths(_controlWidth: Integer; _labelWidth: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 July 2009	cnwdap1	Initial creation

*/

vars

begin
	inheritMethod(_controlWidth, _labelWidth);
	self.myComboBox.width	:= _controlWidth;
	self.myComboBox.left	:= self.width - _controlWidth;
epilog

end;</source>
        <Parameter name="_controlWidth" type="Integer"/>
        <Parameter name="_labelWidth" type="Integer"/>
    </JadeMethod>
