    <JadeMethod name="includeObject" id="6366ea96-f1ef-42fd-b664-039bb5108bbb">
        <updating/>
        <source>includeObject(_obj: Object; passport : CM_Passport): Boolean updating;
//--------------------------------------------------------------
//Created: 01 May 2002 By: cnwgd1
//--------------------------------------------------------------
// Changed on	By			Reason
// ----------	----------	----------------------------------------------------------
// 11/08/2011	cnwdap1		PAR #27972 Bulk release type no longer translatable, replaced by string constants
// 24/11/2011	cnwcs5		CCMS POL 2122 / PAR 28696 - FILTER USING NEEDS REVIEW
// 16/02/2012	cnwcs5		CCMS POL 2151 / par 29137 - stop refresh after set status/set type
// 23/04/2012	cnwcs5		CCMS POL 2172 / par 29480 - stop EDI updates added
// 11/07/2018		jlgrh7 TFS #39309  Release Request Search based on data access group
vars
	br													: CM_BulkRelease;
	carrier 											: CM_Carrier;
	filterISOGrp								: CM_ISOTypeGroup;
	tmpConsignee							: CM_ConsigneeConsignor;
	failedDAC  									: CM_DataAccessController;
	bookRef										: CM_BookingRef;
	tmpCustomAgent					: CM_CustomsAgent;				//+TFS39309
	tmpConsignor							: CM_ConsigneeConsignor;	//+TFS39309
	tmpFreiForwarder 					: CM_ConsigneeConsignor; 	//+TFS39309
	typeDescr		: String;
	avaGrades		: IntegerArray;
	
begin
		
	if (not CM_BulkRelease.hasInstance(_obj)) or _obj = null or
	   (not app.isValidObject(_obj)) then //par 15326
		return false;
	endif;

	br := _obj.CM_BulkRelease;
	
	if not self.ignoreFilterStatus then	// par 29137
		/*	Par15639 - if the status of the current selected CM_BulkRelease does not match the viewStatusMode 
						displayed on the form  then remove it from the table.	*/
		if not self.matchStatusStringtoInteger(br.status) then 
			return false;
		endif;
	endif;								// par 29137
	
	if br.myTerminal &lt;&gt; self.myTerminal then 
		return false;
	endif;

	if self.myFilterBulkRelease &lt;&gt; null and br &lt;&gt; self.myFilterBulkRelease then
		return false;
	endif;
	
	//th2 01/08/2007 for PAR 14505 - road releases displaying in active rail release screen
	if br.type = null then
		return false;
	endif;
	
	if not self.ignoreFilterType then													// par 29137
		typeDescr := br.getTypeDescription();
	
		if self.typeMode &lt;&gt; BR_TYPE_ALL_STR and self.typeMode &lt;&gt; typeDescr then			// PAR #27972
			return false;
		endif;
	endif;																				// par 29137
	
	if self.myFilterOperator &lt;&gt; null and self.myFilterOperator &lt;&gt; br.myOperator then
		if br.myOperator &lt;&gt; null then
			return false;
		else
			if not br.myOperatorGroup.allOperators.includes(self.myFilterOperator) then
				return false;
			endif;
		endif;
	endif;

	if (self.filterCarrierCode &lt;&gt; null and br.carrierId.trimRight &lt;&gt; self.filterCarrierCode) or
	   (self.filterConsignorCode &lt;&gt; null and br.consigneeCode.trimRight &lt;&gt; self.filterConsignorCode) then
	   	return false;
	endif;

	if  (self.myFilterFreightForwarder &lt;&gt; null and br.myFreightForwarder &lt;&gt; self.myFilterFreightForwarder) then
		return false;
	endif;
	
	//th2 for PAR 15072 -Business Unit field is also required as a search field in Release Request maint
	if self.filtBusinessUnitCode &lt;&gt; null then
		if br.myBusinessUnit = null or br.myBusinessUnit.code &lt;&gt; self.filtBusinessUnitCode then
			return false;
		endif;
	endif;
	
	
	// PAR 13466
	tmpConsignee := br.getConsignee();
	if tmpConsignee &lt;&gt; null and (not tmpConsignee.canUserAccessSelf(null, failedDAC,  passport)) then
		return false;
	endif;
	
	tmpConsignor := br.getConsignor();																							//+TFS39309 Add Consignor Filter
	if tmpConsignor &lt;&gt; null and (not tmpConsignor.canUserAccessSelf(null, failedDAC,  passport)) then
		return false;
	endif;
	
	tmpCustomAgent := br.getCustomAgent();																			   //+TFS39309 Add CustomAgent Filter
	if tmpCustomAgent &lt;&gt; null and (not tmpCustomAgent.canUserAccessSelf(null, failedDAC,  passport)) then
		return false;
	endif;
	
	tmpFreiForwarder := br.getFreiForwarder();																			//+TFS39309 Add FreightForwarder Filter
	if tmpFreiForwarder &lt;&gt; null and (not tmpFreiForwarder.canUserAccessSelf(null, failedDAC,  passport)) then
		return false;
	endif;
	
	
	if br.myOperator &lt;&gt; null then
		if (not br.myOperator.canUserAccessSelf(null, failedDAC, passport)) then
			return false;
		endif;
	elseif br.myOperatorGroup &lt;&gt; null then
		if (not br.myOperatorGroup.canUserAccessSelf(null, failedDAC, passport)) then
			return false;
		endif;
	endif;

	if br.carrierId &lt;&gt; null then
		carrier := app.myRoot.allCarriers[br.carrierId];
		if carrier &lt;&gt; null then
			if (not carrier.canUserAccessSelf(null, failedDAC, passport)) then
				return false;
			endif;
		endif;
	endif;
	
	if self.filterTimeRequireFrom.isValid then
		if br.dateEstimatedRequired.time &lt; self.filterTimeRequireFrom then
			return false;
		endif;
	endif;
	
	if self.filterTimeFrom.isValid then
		if br.createdTime.time &lt; self.filterTimeFrom then
			return false;
		endif;
	endif;
	
	if self.filterDateRequireFrom.isValid then
		if br.dateEstimatedRequired.date &lt; self.filterDateRequireFrom then
			return false;
		endif;
	endif;
	
	if self.filterDateFrom.isValid then
		if br.dateRequested.date &lt; self.filterDateFrom then
			return false;
		endif;
	endif;
	
	if self.filterAvGrade &lt;&gt; -1 then			// cnwmc5 - 27 May 2016 - TFS 2044
		avaGrades := br.getAllAvailabilityGrades();
		if avaGrades = null or avaGrades.isEmpty then
			return false;
		elseif not avaGrades.includes(self.filterAvGrade) then
			return false;
		endif;
	endif;

	filterISOGrp := self.cmbISOGroup.listObject.CM_ISOTypeGroup;
	
	if filterISOGrp &lt;&gt; null then	//13 Jul 2011	NDL	Par 27642 - 
		if not br.includesReserveWithIsoGroup( filterISOGrp ) then
			return false;
		endif;
	endif;

	if self.filterBooking &gt; FilterBooking_All then	
		//	Filtering by All, With Booking and Without Boooking. PAR 20296 Sep 2009
		bookRef := br.myBookingRefStock;
		
		if self.filterBooking = FilterBooking_With then	
			// to be included bulk releases with corresponding enhanced booking
			if bookRef = null or bookRef.isStockBookingRef then 
				// we are interested in bookings created in Enhanced Booking screen
				return false;
			endif;
		else	// this is = FilterBooking_Without - to be included bulk releases without corresponding enhanced booking
			if bookRef &lt;&gt; null and not bookRef.isStockBookingRef then
				return false;
			endif;
		endif;
	endif;

	// par 28969 - filtering by needs review
	if self.filterNeedsReview &lt;&gt; self.FILTER_ALL then
		if self.filterNeedsReview = self.FILTER_YES and not br.needsReview then
			// most likely they will be wanting to find those needing review 
			return false;
		elseif self.filterNeedsReview = self.FILTER_NO and br.needsReview then
			// filtering by those Not needing review and this one does.
			return false;
		endif;
	endif;
	
	// par 29480 - filtering by Stop EDI Updates
	if self.filterBlockEDIUpdates &lt;&gt; self.FILTER_ALL then
		if self.filterBlockEDIUpdates = self.FILTER_YES and not br.blockEDIUpdates then		// par 29481 May 2012
			// most likely they will be wanting to find those with Stop EDI Updates set
			return false;
		elseif self.filterBlockEDIUpdates = self.FILTER_NO and br.blockEDIUpdates then		// par 29481 May 2012
			// filtering by those without STOP EDI Updates set this one does.
			return false;
		endif;
	endif;
	
	return true;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initDataTable" id="70ef63b4-28ba-4645-9012-725050fc6ddd">
        <updating/>
        <source>initDataTable() updating;
// ---------------------------------------------------------------------------
// Created:     08 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 07/02/2012	cnwcs5		par 28756 - refactoring
// ---------------------------------------------------------------------------
vars
	table	:CM_DataTable;	
begin
	table := self.tblData;
	
	self.setTblDataEntRows(ETDef_MTReleaseDataTable);
	
	self.allowMultiSelectDelete := self.allowUpdate;
	
	if not self.myTerminal.isSubTerminalsOn() then
		self.hideThumbnailRow (self.tblThumb, ETRow_MySubTerminal, app.myController.getEntTableDef(ETDef_MTReleaseThumb), app.myCurrentLocale);
		
		table.hideColumnByColPropertyName(ETRow_MySubTerminal);
	endif;
	
	//23 Oct 2014	NDL	Par 35008
	if not app.isVehicleBookingEnabled then
		self.tblData.hideColumnByColName(ETRow_VehicleBookingSlots);
	endif;
	
	self.columnPinNo := table.getColumnByRowName(ETRow_MyPinNo);			
		
end;</source>
    </JadeMethod>
    <JadeMethod name="initFilterTable" id="549eb6b5-3243-4d08-bab1-1ee2f4f0bff3">
        <updating/>
        <source>initFilterTable() updating;
// ---------------------------------------------------------------------------
// Created:     08 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24/11/2011	cnwcs5		CCMS POL 2122 / par 28696 - needs review added
// 23/04/2012	cnwcs5		CCMS POL 2172 / par 29480 - stop EDI updates added
// 17/01/2019	jlgzm1		TFS41961 getting 14025 when too many release requests
// ---------------------------------------------------------------------------
vars
	entTableDef	: EntTableDef;
	table		: CM_EntryTable;
	assistant	: CMUI_Assistant;
	reachedMaxSize : Boolean;
begin
	on Exception do app.handleUE14025(exception, reachedMaxSize);
	
	table 		:= tblSearch;
	assistant	:= self.myAssistant;
	entTableDef := app.myController.getEntTableDef(ETDef_MTReleaseFind);
	
	if entTableDef &lt;&gt; null then
		table.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
		table.adjustHeight(200);
		
		if (not self.myTerminal.getConfig(GateRelNoSearchText).Boolean) then
			//fill release number search box
			assistant.comboBoxBulkRelByTypeStatus(cmbBulkRelease, self.cmbType.text, self.cmbView.text, null);
			//if oversize, switch combobox to textbox
			if reachedMaxSize then
				self.relNoSearchByText := true;
				table.hideRowByName(ETRow_ReleaseNoCmb, false);
			else
				self.relNoSearchByText := false;
				table.hideRowByName(ETRow_FiltReleaseNo, false);
			endif;
		else
			self.relNoSearchByText := true;
			table.hideRowByName(ETRow_ReleaseNoCmb, false);
		endif;
		
		assistant.comboBoxCarrierTransportMode(cmbFiltCarrier, null,self.cmbType.text);//+ cnwas3 par 24344
		assistant.comboBoxConsignor(cmbFiltConsignee, null, CONSIGNOR);
		assistant.comboBoxConsignor(cmbFiltFrghtFwdr, null,FREIGHT_FORWARDER);
		assistant.comboBoxOperator(cmbFiltOperator, null, null);
		
		if (not self.permissionMaint = PmGteEmptyReleaseMaintAll) then
			table.hideRowByName(ETRow_FilterPIN, false);
		endif;

		assistant.comboBoxBulkRelFilterBooking(cmbFiltBooking, FilterBooking_All);	// PAR 20296 Sep 2009
		// set up Needs Review (All/Yes/No)
		assistant.comboBoxYesNoAll_Translated (self.cmbFiltNeedsRev);				// par 28696
		// set up Stop EDi updates (All/Yes/No)
		assistant.comboBoxYesNoAll_Translated (self.cmbFiltStopEDIUp);				// par 29480
		
		self.setFilterDefaults;	// par 29480
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntTableDef EmptyReleaseFind not found');
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="initForm" id="5b65c928-ec89-457c-b5e1-2c6b166f1a14">
        <updating/>
        <source>initForm() updating;
// ---------------------------------------------------------------------------
// Created:     19 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 15/02/2010	cnwcs5		ccms 1925 / par 22295
// 22/11/2011	cnwcs5		CCMS POL 2122 / par 28696 - new type unknown
// 14/12/2011	cnwcs5		par 28756 - set allowNext to false
// 07/02/2012	cnwcs5		par 28756 - refactoring
// 07/01/2015	cnwadp1		PAR #35397 CCMS SFW 1394 Voyage Rationalisation
// ---------------------------------------------------------------------------
vars
	now 		: TimeStamp;
	terminal	: CM_Terminal;		// par 28696
	assistant	: CMUI_Assistant;	// par 28696
begin
	terminal 	:= self.myTerminal;
	assistant	:= self.myAssistant;
	
	self.canArchive 	:= app.myCurrentUserCan(terminal, PmGteMTReleaseArchive);
	self.canSummarise 	:= app.myCurrentUserCan(terminal, PmSummaryDefView );	// 15/02/2010 cnwcs5 ccms 1925 / par 22295
	self.canViewRail 	:= app.myCurrentUserCan(terminal, PmGteMTReleaseViewRail);
	self.canViewRoad 	:= app.myCurrentUserCan(terminal, PmGteMTReleaseViewRd);
	self.canViewPacking := app.myCurrentUserCan(terminal, PmGteMTReleaseViewGen);
	self.canViewShip 	:= app.myCurrentUserCan(terminal, PmGteMTReleaseViewShip);
	self.canViewUnknown	:= app.myCurrentUserCan(terminal, PmGteMTReleaseViewUnknown);	// par 28696

	self.allowPrint  			:= true;
	self.allowExportCSV			:= true;
	self.allowMultiSelectDelete := self.allowDelete;	
	self.allowMultiSelectEdit 	:= false;		
	self.allowNext				:= false;			// cnwcs5 par 28756
	self.allowHideThumbnail 	:= true;
	self.btnEditStatus.enabled	:= self.canArchive;	// cnwrl1 24/07/2009 PAR 20349
	self.useTblDataContextMenu 	:= true;
	self.useNumRowsShown		:= true;
	
	sptMain.top := lblView.top + lblView.height + 10;
	
	self.doCmbViewBuild();

	// always include ALL - we will filter out any they don't have access to
	assistant.comboBoxReleaseType(self.cmbType, self.canViewRoad, self.canViewRail, self.canViewPacking, self.canViewShip, self.canViewUnknown, true); 		// par 28696
	
	self.setNavigatorHeading(self.viewStatusMode);
	self.cmbMTGrade.initialise(false);
	
	self.myAssistant.comboBoxVoyageCurrent(	cmbFiltVoyage,		// PAR #35397
											null,				// PAR #35397
											true,				// PAR #35397
											false,				// PAR #35397
											false,				// PAR #35397
											true,				// PAR #35397
											true,				// PAR #35397
											true,				// PAR #35397
											true,				// PAR #35397
											false,				// PAR #35397
											false);				// PAR #35397

	assistant.comboBoxISOTypeGroup(self.cmbISOGroup,null);
	self.getXMLSettingsForSetup();

	self.btnFullReq.bubbleHelp 	:= app.getErrorString(GTE_Show_Full_Request_Details);
	self.tblThumb.bubbleHelp 	:= app.getErrorString(Double_Click_Thumb);

	self.checkBulkReleaseIterator	 := terminal.allBulkReleasesByCodeDate.createIterator();
	
	// CCMS 1412	
	if app.myCurrentUserCan(terminal, PmGteEmptyReleaseMaintAll) then
		// can only generate pin if user has both of these permissions
		self.allowGeneratePin := app.myCurrentUserCan(terminal, PmGteGeneratePinNoBR);
	endif;
	
	//cnwjo3 par 22398.  Problem solvered.
	self.sptDataFilter.height:=1000;
	
	self.setEnableObjects();	

end;</source>
    </JadeMethod>
    <JadeMethod name="loadCmbReport" id="723cf087-6f34-451b-93b9-28c62fd96d23">
        <source>loadCmbReport() protected;
/*
----------   ----------  --------------------------------------------------
Created:	30 January 2007 By cnwth2

Purpose:	

Changed On	Changed By	Reason
----------	----------	--------------------------------------------------
16 Mar 2010	consw1		PAR #22886 - Leaking report transients
*/
vars
	transientRep 		: JadeReportWriterReport;
	reportManager		: JadeReportWriterManager;
	folders 			: HugeStringArray;
	names 				: StringArray;
	viewName,
	reportName			: String;
	cmb					: CMUI_ComboBox;
	
begin
	self.clearCmbReport();
	cmb := self.cmbReport;
	cmb.sorted := true;		// 24/09/2014 cnwar2 #32579
	
	create folders transient;
	create names transient;
	create reportManager transient;
	
	reportManager.getAllReportNames(folders, names);
	
	foreach reportName in names do
		transientRep := reportManager.getReport(reportName);
		viewName := transientRep.getReportingViewName();
		if viewName = CM_MTReportView then
			cmb.itemObject[cmb.addItem(reportName)]:= transientRep;
			transientRep := null;
		else
			delete transientRep;
		endif;
	endforeach;
	
epilog
	delete transientRep;
	delete reportManager;
	delete names;
	delete folders;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="matchStatusStringtoInteger" id="1ff6cc09-3241-4212-b053-c7c44dc91b57">
        <source>matchStatusStringtoInteger(status : Integer):Boolean protected;

/*

Purpose: checking if the given status (Integer) matches viewStatusMode (String) displayed on the form.

Parameters:			

Return Value:		


	Date		Who		Reason
23 July 2008	#cnwdz2	 Par 15639
01 Decmeber 2008 cnwsh3  PAR18569 Need to include filtering for combinations of status settings.
11 August 2011	 cnwdap1 PAR #27972 Bulk release type no longer translatable, replaced by string constants
*/

vars

begin
	if self.viewStatusMode = BR_PENDING_STRING then
		return status = BR_PENDING;
		
	elseif self.viewStatusMode = BR_COMPLETE_STRING then
		return status = BR_COMPLETE;
		
	elseif self.viewStatusMode = BR_ARCHIVE_STRING then 
	    return status = BR_ARCHIVE;
		
	elseif self.viewStatusMode = BR_ACTIVE_STRING then
		return status  = BR_ACTIVE;
		
	elseif self.viewStatusMode.cnContains(BR_ACTIVE_STRING) and //PAR18569
		   self.viewStatusMode.cnContains(BR_PENDING_STRING) then
		return (status = BR_ACTIVE or status = BR_PENDING);
		
	elseif self.viewStatusMode = BR_TYPE_ALL_STR then								// PAR #27972
		return true;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="status" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
