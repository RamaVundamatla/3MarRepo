    </PrimAttribute>
    <JadeMethod name="buildTagBody" id="973d275f-a85b-4d2b-8d7b-0fae995fe802">
        <source>buildTagBody(): String protected;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	htmlString	: String;

begin
	if self.tableAlign &lt;&gt; null then
		htmlString	:=	htmlString &amp; ' ALIGN="' &amp; self.tableAlign &amp; '"';
	endif;

	if self.tableBackColor &lt;&gt; null then
		htmlString	:=	htmlString &amp; ' BGCOLOR="' &amp; self.tableBackColor &amp; '"';
	endif;

	if self.tableBackSource &lt;&gt; null then
		htmlString	:=	htmlString &amp; ' BACKGROUND="' &amp; self.tableBackSource &amp; '"';
	endif;

	if self.tableBorderColor &lt;&gt; null then
		htmlString	:=	htmlString &amp; ' BORDERCOLOR="' &amp; self.tableBorderColor &amp; '"';
	endif;

	if self.tableBorderColorDark &lt;&gt; null then
		htmlString	:=	htmlString &amp; ' BORDERCOLORDARK="' &amp; self.tableBorderColorDark &amp; '"';
	endif;

	if self.tableBorderColorLight &lt;&gt; null then
		htmlString	:=	htmlString &amp; ' BORDERCOLORLIGHT="' &amp; self.tableBorderColorLight &amp; '"';
	endif;

	if self.tableHeight &lt;&gt; null then
		htmlString	:=	htmlString &amp; ' HEIGHT="' &amp; self.tableHeight &amp; '"';
	endif;

	if self.tableStyleSheet &lt;&gt; null then
		htmlString	:=	htmlString &amp; ' STYLE="' &amp; self.tableStyleSheet &amp; '"';
	endif;

	if self.tableHeight &lt;&gt; null then
		htmlString	:=	htmlString &amp; ' HEIGHT="' &amp; self.tableHeight &amp; '"';
	endif;
	
	htmlString	:=	htmlString &amp; inheritMethod();
	
	return htmlString;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isValidAlign" id="0bfa90f4-9466-4b85-a0c8-da3591586ce0">
        <source>isValidAlign(pAlign:String):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		29 April 2000 by cnwdad1
//
// Purpose:		Validates the receiver's alignment setting.
//
// Parameters:	pAlign - The receiver's alignment setting.
//
// Returns:		True if the alignment setting is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pAlign = self.ALIGN_LEFT
	or pAlign = self.ALIGN_CENTER
	or pAlign = self.ALIGN_RIGHT
	then
		return true;
	else
		CnEcBaseHtmlException.raise_(CNEC_X_22000, '"' &amp; pAlign &amp; '" is not a valid Table element tag alignment');
	endif;

	return false;
end;</source>
        <access>protected</access>
        <Parameter name="pAlign" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTableAlign" id="bbbb0b40-dfb9-4671-8dfe-6449e70d32a1">
        <updating/>
        <source>setTableAlign(pAlign:String) updating;
// --------------------------------------------------------------------------------
// Created:		02 May 2000 by cnwdad2
//
// Purpose:		Set the receiver's alignment setting.
//
// Parameters:	pAlign - The alignment setting.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isValidAlign(pAlign) then
		self.tableAlign	:=	pAlign;
	endif;
end;</source>
        <Parameter name="pAlign" type="String"/>
    </JadeMethod>
</Class>
