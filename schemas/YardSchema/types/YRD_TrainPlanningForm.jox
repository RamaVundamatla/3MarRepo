    <JadeMethod name="doRefresh" id="c40e1b8b-a11b-449e-a39f-bd8de697785f">
        <updating/>
        <source>doRefresh() updating, protected;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:     
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	dockBar : YRD_RailDockBar;
	idx, max : Integer;
	iter : Iterator;
	railArea : CM_Rail;
	resizeBars : Boolean;
	
begin
	self.mousePointer := Window.MousePointer_Default;

	inheritMethod();

	self.allWagons.clear;
	self.setMyCurrentSDF(null);
	self.frmColLegendTIs.myLegendTable.rows := 0;
	self.tblInfo.rows := 0;
	self.doNotableClear();
	self.setStatusBarCaption();

	//  Rail areas are displayed in separate frames.
	//  Get the right number of dock bars.

	if self.isDisplayedRailAreas then
		iter := self.allRailAreas.createIterator();
		max := self.allRailAreas.size;
	else
		max := 1;
	endif;

	if max &lt; self.maxGridAreas then
		foreach idx in max + 1 to maxGridAreas reversed do
			dockBar := self.allGridAreaDockBars[idx].YRD_RailDockBar;
			if dockBar.visible then
				resizeBars := true;
			endif;
			dockBar.setVisible(false);
			dockBar.setRailArea(null);
			self.removeDynamicGridAreaFrames(dockBar.mySDF);
		endforeach;
	else
		while max &gt; self.maxGridAreas do
			self.makeFrameRake();
			resizeBars := true;
		endwhile;
	endif;
		
	//  Show the trains / rail areas

	foreach idx in 1 to max reversed do
		dockBar := self.allGridAreaDockBars[idx].YRD_RailDockBar;
		if self.isDisplayedRailAreas then
			iter.next(railArea);
		endif;
		dockBar.setRailArea(railArea);
		if not dockBar.visible then
			resizeBars := true;
		endif;
		dockBar.setVisible(true);
	endforeach;
		
	foreach idx in 1 to max reversed do
		dockBar := self.allGridAreaDockBars[idx].YRD_RailDockBar;
		if resizeBars then
			dockBar.height := self.dkcGridArea.height / max;
		endif;
		self.showGridArea(dockBar.myRailArea);
		dockBar.mySDF.changeBackColor(self.myTerminal.getConfig(DefYardBackColUnselected).Integer);
		if self.isDisplayedTrains or self.isDisplayedRailAreas then
			if not self.frmColLegendTIs.displayViewModeCodes(self.mySDF.viewMode, dockBar.mySDF.myDrawingAttrController) then
				self.frmColLegendTIs.doChangeViewMode(self.mySDF.viewMode);
			endif;
		endif;
	endforeach;

	self.setMyCurrentSDF(self.mySDF);
	
	self.setNavigator();

epilog
	delete iter;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="cd6f840b-e5e7-4639-8aac-2df5a8b82622">
