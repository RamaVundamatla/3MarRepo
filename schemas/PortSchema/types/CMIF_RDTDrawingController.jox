    <JadeMethod name="setHighlightLCs" id="419d9ba0-2de6-47bc-b346-7c53ec1f1050">
        <source>setHighlightLCs( _tiSet : ObjectSet; _mode : Integer);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 May 2010	cnwjk3	Initial creation

*/

vars
	obj 	: Object;
	ti 		: CM_TrackedItem;
	lc		: CM_GridController;
	key		: String;
	height	: Integer;
begin
	if _tiSet &lt;&gt; null then 
		self.allDirectorTaskTIs.clear();
		_tiSet.copy(self.allDirectorTaskTIs);
	else
		// we are refreshing how the LCs are keyed into the collection.  This will be the result of a switch of view mode
		// between top-dow, face and end.
	
	endif;

	self.allHighlightLCsByID.clear();
	
	foreach obj in self.allDirectorTaskTIs do
		if not obj.isKindOf(CM_TrackedItem) then
			continue;
		endif;
		
		ti := obj.CM_TrackedItem;
	
		if not ti.myPrimaryActualLocation.isKindOf(CM_GridController) then
			continue;
		endif;

		lc := ti.myPrimaryActualLocation.CM_GridController;
		
		if _mode = CMIF_RDTDrawElement.MODE_FACE or _mode = CMIF_RDTDrawElement.MODE_END then
			// A gridded side view, so we need to include the height of the TI in the key
			height := lc.getActualStackPositionOfTI(ti); 
		endif;
		
			
		key := self.genHighlightedLCKey(lc, height);
		
		
		//write "selected lc key: " &amp; key;
		
		if not self.allHighlightLCsByID.includesKey(key) then
			self.allHighlightLCsByID[key] := lc;
		endif;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_tiSet" type="ObjectSet"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
