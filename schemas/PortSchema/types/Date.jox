    <JadeMethod name="differenceInMonths" id="f2945ec2-c414-48b5-b67d-1a668b3f7b58">
        <source>differenceInMonths(_dateTo : Date) : Integer;
/*

Date		    Who			Reason
08 November 2010	cnwas3	  Returns the absolute difference between the two dates, in months.

Example : the difference between 31st of July and 1st of August is 1 month. The same for the difference between 1st of July and 1st of August.

This is NOT meant to display the intervals of 30/31 days between two dates!

*/

vars
	dateTo,dateFrom : Date;
	years,months 			: Integer;
begin
	if self &gt; _dateTo then
		dateTo := self;
		dateFrom := _dateTo;
	else
		dateTo := _dateTo;
		dateFrom := self;
	endif;
		
	years := dateTo.year - dateFrom.year;
	months := dateTo.month - dateFrom.month;
	if months &lt; 0 then 
		years := years - 1;
		months := 12 + months;
	endif;	
	
	months := months + 12 * years;	
	
	return months;
epilog

end;</source>
        <Parameter name="_dateTo" type="Date"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
