    <JadeMethod name="doCreateUnload" id="6a9af7d1-a2e6-455b-bcab-fda45f2c5e6b">
        <updating/>
        <source>doCreateUnload() : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 February 2010	cnwrd1	Initial creation
29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
*/


vars
	pProxyInterTermMove : CM_InterTerminalMove;
	pNewInterTermMove   : CM_InterTerminalMove;
	tmpFoundLC			: CM_LocationsController;
	result              : Integer;
	easyGateController : CMIF_EasyGateController;
	term : CM_Terminal;
	interTermJob : CM_InterTermVehicleJob;
	interMove : CM_InterTerminalMove;
	truck : CM_Vehicle;
begin

// have the ITJ and ITM
// create easygate controller and run trxcreateeasygatein
		interMove := self.myCurrentInterTerminalMove;
		
		if not self.findLocationToMoveTo( tmpFoundLC ) then
			return false;
		endif;

		pProxyInterTermMove := app.createUpdateProxy(interMove).CM_InterTerminalMove;	// create update proxy
	//	pProxyInterTermMove.setStatus( ITT_UNLOADING ); //set to unloading
		pProxyInterTermMove.setMyTargetLC( tmpFoundLC );  //and set the target location
		
		while true do
			app.myTrxUA.trxUpdateInterTerminalMove(  pProxyInterTermMove , app.myPassport );  // update the move
			if app.myPassport.trxCompletedOK then
				app.myPassport.clearErrorsWarnings();
				break;
			else
				//If there were warnings, give the user a chance to see them. If there are no errors they may decide to acknowledge
				//them and update anyway.
				result := app.showErrorWarningDialog(app.getErrorString(Load), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				else
					return false;
				endif;
			endif;
		endwhile;
		

	// now do the move process
	create easyGateController transient;
	
	term := self.myTargetTerminal;
	easyGateController.myTerminal := term;
	easyGateController.driver := self.txtDriver.text;
	
	truck := self.myTerminal.vehicles[self.myInterTermVehicleJob.vehicleID, self.myInterTermVehicleJob.state];
	
	interTermJob := self.myInterTermVehicleJob;
	easyGateController.myInterTermVehicleJob := interTermJob;
	
	easyGateController.allMovesForOffloading.add( interMove );  //add the move to the controller for unloading
	/*	
	foreach interMove in interTermJob.allInterTerminalMoves do
		if interMove.status &lt;&gt; ITT_UNLOADING then
			// not one we are in the process of unloading
			continue;
		endif;
		if interMove.myTargetTerminal &lt;&gt; term then
			// not one unloaded at this terminal
			continue;
		endif;
	
	endforeach;
	*/

	while true do
		app.myTrxCA.trxCreateEasyGateIn( easyGateController, app.myPassport ); 
		if app.myPassport.trxCompletedOK then
			app.myPassport.clearErrorsWarnings();
			return true;
		else
			//If there were warnings, give the user a chance to see them. If there are no errors they may decide to acknowledge
			//them and update anyway.
			result := app.showErrorWarningDialog(app.getErrorString(Inter_Terminal_Transfer), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return false;
	endwhile;
		
	
	return false;
epilog
	delete pProxyInterTermMove;
	delete easyGateController;
end;

</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLoadTargetTerminal" id="90cf5539-26d8-4835-be8c-18b6f6cfb328">
        <source>doLoadTargetTerminal();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 February 2010	cnwrd1	Initial creation

*/

vars
	index    : Integer;
	userTerm : CM_UserTerminal;
begin

	foreach userTerm in app.getMyUser.allUserTerminals do
		index := self.cmbTargetTerm.addItem(userTerm.myTerminal.code);
		self.cmbTargetTerm.itemObject[index] := userTerm.myTerminal;
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="a760642d-660a-4a75-8620-148b65118610">
        <updating/>
        <source>doOK() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
