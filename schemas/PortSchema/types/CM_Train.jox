    <JadeMethod name="getCodeDateString" id="22a1f098-082d-4127-b6dc-d6a855c36687">
        <source>getCodeDateString() : String;
// ---------------------------------------------------------------------------
// Created:     11 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
//19 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support

vars
	str : String;
begin

	str := self.code &amp; " " &amp; self.systemToLocalTime(self.scheduledArrivalDT).asStringJMT();
	if self.isDeparted then
		str := str &amp; ' (' &amp; app.getErrorString(Departed)&amp; ')';
	endif;

	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getConfirmedStatus" id="7bce956c-8a0a-48b6-b1fa-712c2b721dce">
        <source>getConfirmedStatus(_inward : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:     June 2009 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	wagon 	: CM_Wagon;
	confirmTot, confirmSize : Integer;
	hasArrived : Boolean;
	extra : String;
begin
	if self.isDeparted() then
		return app.getErrorString(Departed);
	endif;
	
	if _inward then
		foreach wagon in self.allWagonsByIdInward discreteLock do
			confirmSize := confirmSize + 1;
			if wagon.confirmed then
				confirmTot := confirmTot + 1;
			endif;
		endforeach;
	else
		foreach wagon in self.allWagonsByIdOutward discreteLock do
			confirmSize := confirmSize + 1;
			if wagon.confirmed then
				confirmTot := confirmTot + 1;
			endif;
		endforeach;
	endif;
	
	
	if confirmSize = 0 then
		return app.getErrorString(WagonsNone) &amp; extra;
	elseif self.arrivalDT.isValid() then
	
		
		if confirmTot = confirmSize then
			if self.isBeingWorked() then
				return app.getErrorString(TRAIN_STATUS_Being_worked); 
			endif;
			return app.getErrorString(TRAIN_STATUS_Arrived_confirmed);
		elseif confirmTot = 0 then
			return app.getErrorString(TRAIN_STATUS_Arrived_Uncon); 
		else
			return app.getErrorString(TRAIN_STATUS_Arrived_part_con); 
		endif;
	
	else
		if self.isBeingWorked() then
			return app.getErrorString(TRAIN_STATUS_Being_worked);
		endif;
		return app.getErrorString(TRAIN_STATUS_Pending_arrival);
	endif;
	

end;



</source>
        <Parameter name="_inward" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getContainersByLength" id="8a884405-e477-43c2-994e-02eac0b64cbf">
        <source>getContainersByLength(_isInward : Boolean; _length : Integer; _isEmpty : Boolean; _emptyFull: Boolean):Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 Nov 2009	cnwas3	Initial creation CCMS MSL 1013
18 Mar 2024	navma1	Bug 62975: EUP - 1308 Error During EUP performance test
*/

vars
	invalidTI 	: Boolean;
	wag 		: CM_Wagon;
	total 		: Integer;
	tiArray 	: CM_TIArray;
	ti 			: CM_TrackedItem;
	wagonArr	: CM_WagonArray;
begin	
	on Exception do app.handleDeletedObject(exception, ti, invalidTI);

	create tiArray transient;
	
	create wagonArr transient;
	
	if _isInward then
		
		self.allWagonsByOrderInward.tryCopy(wagonArr);							//18.03.2024 navma1 #62975
		
		//foreach wag in self.allWagonsByOrderInward discreteLock do			//18.03.2024 navma1 #62975
		foreach wag in wagonArr discreteLock do									//18.03.2024 navma1 #62975
			if not wag.canHandleISOContainer then								//18.03.2024 navma1 #62975
				continue;
			endif;
			wag.getAllTrackedItems(_isInward,tiArray,wag.confirmed);
		endforeach;
	else
		
		self.allWagonsByOrderOutward.tryCopy(wagonArr);						    //18.03.2024 navma1 #62975
		
		//foreach wag in self.allWagonsByOrderOutward discreteLock do		    //18.03.2024 navma1 #62975
		foreach wag in wagonArr discreteLock do								    //18.03.2024 navma1 #62975
			if not wag.canHandleISOContainer then							    //18.03.2024 navma1 #62975
				continue;
			endif;
			wag.getAllTrackedItems(_isInward,tiArray,wag.confirmedOutwards);
		endforeach;
	endif;
	
	total :=0;
	
	if _emptyFull then
		foreach ti in tiArray where 
		(ti.isContainer() and ti.getActualLength()=_length) do
					total := total+1;
		endforeach;
	else
		foreach ti in tiArray where 
		(ti.isContainer() and ti.getActualLength()=_length and ti.isEmpty()=_isEmpty) do
			total := total+1;
		endforeach;
	endif;
	
	return total;
epilog
	delete tiArray;
	delete wagonArr;															//18.03.2024 navma1 #62975
end;</source>
        <Parameter name="_isInward" type="Boolean"/>
        <Parameter name="_length" type="Integer"/>
        <Parameter name="_isEmpty" type="Boolean"/>
        <Parameter name="_emptyFull" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCustomStatus" id="85e41179-7f11-4ecd-96c3-b1ae27647d7a">
        <source>getCustomStatus() :String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/09/2023	navkc1	CR 60428 Task 60701: UI - Customs Status on Transport UI

*/

vars
	
	ti		: CM_TrackedItem;
	messStr,
	str		: String;
	tis		: CM_TIArray;
	
begin
	
	create tis transient;
	
	self.getAllTrackedItems(true, tis);
	self.getAllTrackedItems(false, tis);
	
	foreach ti in tis do
		
		str := ti.getCustomsStatus();
		
		if str = null then
			continue;
		endif;
		
		/*
		if messStr = null then
			messStr := str;
		elseif messStr.pos(str, 1) = 0 then
			messStr := messStr &amp; "," &amp; str;
		endif;
		*/
		
		messStr.addStringToList(str, ","); //04/04/2025	navkc1 JIRA Story MTN-33940
	endforeach;
	
	return messStr;
epilog
	delete tis;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDebtor" id="bc9373c5-6cfe-4321-8c88-5e4112bdc5af">
