    <JadeMethod name="validateForUpdate" id="95c880de-e50e-43bf-8749-5a3d42cf01fa">
        <source>validateForUpdate();
//
// 11 June 2018	jlgrs1	TFS 39013 (37190) Pelindo BGP Web Service
//
vars
	existing : CM_ExternalWebServiceDef;
	realMe : CM_ExternalWebServiceDef;
begin
	if self.name &lt;&gt; null then
		if self.isTransient then
			realMe := self.pxyGetRealObject();
		else
			realMe := self;
		endif;
		existing := app.myRoot.allExternalWebServices.getAtKey(self.name);
		if existing &lt;&gt; null and 
		   realMe &lt;&gt; null and 
		   realMe &lt;&gt; existing then
			app.raiseCMException1(Entity_with_already_exists, self.name, app.getString(Name), null);
		endif;
	endif;
	
	self.validateMe();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="8607c830-6d76-4c41-b5d0-329a598c1b32">
        <source>validateMe() protected;
//
// 11 June 2018	jlgrs1	TFS 39013 (37190) Pelindo BGP Web Service
// 17 Dec  2024 navsp1  MTN-33550 MTN - 1-Stop EWS - Auth-Key is a required field but no validation
vars

begin
	if self.name = null then
		app.raiseCMException1(Input_required_field_Required, app.getString(Name), self.name, null);
	endif;
	if self.baseEndpoint = null and not self.isAgGatewayServiceDef() then																		//navra1 - MTN-34782 - 15th July 2025
		app.raiseCMException1(Input_required_field_Required, app.getString(Base_point), self.baseEndpoint, null);
	endif;
	if self.is1StopVBS then																												//MTN-33550
		if self.CM_1StopVBSWebServiceDef.authKey = null then																			//MTN-33550
			app.raiseCMException1(Input_required_field_Required, app.getString(Authkey), self.CM_1StopVBSWebServiceDef.authKey, null);	//MTN-33550
		endif;																															//MTN-33550
	endif;																																//MTN-33550
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
