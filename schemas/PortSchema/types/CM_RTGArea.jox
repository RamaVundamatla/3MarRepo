    <JadeMethod name="setForCreate" id="19b4ad42-89ca-4e3e-bb5a-2fc8f1bc7f2d">
        <updating/>
        <source>setForCreate(_proxy: CM_RTGArea input; _passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		01 February 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	//app.raiseCMException1(Err_Unexpected_Program_Error,"Emmet working on this can not create RTGs in the meantime - sorry",null,null);
	//cnwer1 par 17760 19/8/08 removed groupAreaSequence stuff
	inheritMethod(_proxy, _passport);

end;</source>
        <Parameter name="_proxy" type="CM_RTGArea" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="b96be287-47c6-4aef-bdc4-bfc080d2a78b">
        <updating/>
        <source>setForUpdate(_proxy :CM_RTGArea) updating;
//setForUpdate(pProxy: CM_GridArea) updating;
/*
----------   ----------  --------------------------------------------------
Created:	10 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	//app.raiseCMException1(Err_Unexpected_Program_Error,"Emmet working on this can not update RTGs in the meantime - sorry",null,null);
	inheritMethod(_proxy);
	
	//epr CCMS 1076 19/8/09
	self.setForUpdateGantryICAreas(_proxy);
	self.setForUpdateRTGLane(_proxy);
	
	
end;</source>
        <Parameter name="_proxy" type="CM_RTGArea"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateGantryICAreas" id="b052d77e-037b-4099-8e4c-f553044b13d6">
        <source>setForUpdateGantryICAreas(_proxy : CM_RTGArea);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 Aug 2009	cnwer1	Initial creation
12 Dec 2011	cnwer1	PAR 28714 - Update of RTG areas was clearing the interchange areas allowedMachines coll
27 Apr 2012	cnwkpd1	PAR #29471 - Prevent proxy machine leaks by changing TA proxy not to proxy machines

*/

vars
	pxyInterchangeArea,
	realICArea: CM_InterchangeArea;
	pxyGantryICArea,
	realGantryICArea: CM_GantryInterchangeArea;
	allGantryAreasToErase: CM_InterchangeAreaSet;
//	proxyMachines : CM_MachineSet;
begin
	
	//need to make sure there is a proxy link at this stage
	if _proxy.pxyGetRealObject = null then
		app.myProxyManager.createProxyLink(self,_proxy);
	endif;
	
	create allGantryAreasToErase transient;
	self.allAssociatedInterchangeAreas.copy(allGantryAreasToErase);
	
//	create proxyMachines transient;
	
	foreach pxyInterchangeArea in _proxy.allAssociatedInterchangeAreas do
		pxyGantryICArea:=pxyInterchangeArea.CM_GantryInterchangeArea;
		//if rtgColumns have just been created there won't be a proxy link which is needed
		realGantryICArea:= app.myProxyManager.getRealObject( pxyGantryICArea).CM_GantryInterchangeArea;
		if realGantryICArea = null then
			create realGantryICArea persistent;
		else
		// epr par 28714 13/12/11
			pxyGantryICArea.updateMachines(realGantryICArea.allowedMachines);
			
//			pxyGantryICArea.allowedMachines.copy(proxyMachines);
			
			allGantryAreasToErase.remove(realGantryICArea);
		endif;
		realGantryICArea.setForCreate(pxyGantryICArea,app.myPassport);
		if not self.allAssociatedInterchangeAreas.includes(realGantryICArea) then
			self.allAssociatedInterchangeAreas.add(realGantryICArea);
		endif;
	endforeach;
	
	foreach realICArea in allGantryAreasToErase do
		realICArea.erase(NORMAL_ERASE);
	endforeach;
	
epilog

	delete allGantryAreasToErase;
//	proxyMachines.purge;
//	delete proxyMachines;

end;</source>
        <Parameter name="_proxy" type="CM_RTGArea"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateInUse" id="8d6bff87-373d-4fe0-8aa1-4d7c06cc9345">
        <updating/>
        <source>setForUpdateInUse(_proxy: CM_RTGArea; _passport: CM_Passport input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	17 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
// cnwcs5	21/07/2009	ccms 1061 - change method signature to use procy instead of controller
*/
vars
begin
	//app.raiseCMException1(Err_Unexpected_Program_Error,"Emmet working on this can not update RTGs in the meantime - sorry",null,null);
	inheritMethod(_proxy, _passport);
	
	//epr CCMS 1076 19/8/09
	self.setForUpdateGantryICAreas(_proxy);
	self.setForUpdateRTGLane(_proxy);
end;


</source>
        <Parameter name="_proxy" type="CM_RTGArea"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateRTGLane" id="a4101f8d-e63c-4608-ac2a-c17b32ca5478">
        <updating/>
        <source>setForUpdateRTGLane(_proxy : CM_RTGArea) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 August 2009	cnwer1	Initial creation

*/

vars	
	pxyRTGLane,
	realRTGLane : CM_RTGLane;
	indexOfTA : Integer;
begin
	if self.allTerminalAreaGroups.size &gt; 0 then
		self.allTerminalAreaGroups.first.CM_RTGLane.allTAsByTypeId.remove(self);
	endif;
	
	pxyRTGLane :=_proxy.allTerminalAreaGroups.first.CM_RTGLane;
	if pxyRTGLane = null then
		return;
	endif;
	indexOfTA:=pxyRTGLane.allTAsByTypeId.indexOf(_proxy);
	realRTGLane:=pxyRTGLane.pxyGetRealObject.CM_RTGLane;
	
	if realRTGLane &lt;&gt;  null then
		if indexOfTA &gt; realRTGLane.allTAsByTypeId.size then
			realRTGLane.allTAsByTypeId.add(self);
		else
			realRTGLane.allTAsByTypeId.insert(indexOfTA,self);
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_proxy" type="CM_RTGArea"/>
    </JadeMethod>
    <JadeMethod name="setGridObjectsForDecking" id="3a721224-9419-4f41-9a05-2013bb566677">
        <source>setGridObjectsForDecking(_passport: CM_Passport input);
/*
----------   ----------  --------------------------------------------------
Created:	11 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	gridRow : CM_GridObject;
	pDO		: CM_YADeckingOptionsRow;
begin

	foreach gridRow in self.allGridRowsByLabel do
		if gridRow.myDeckingOptions = null then
			create pDO transient;
			pDO.setProxy(false, true, gridRow);
			pDO.setProxyRules(DeckingRule_Default, DeckingRule_Default);
		else
			pDO := gridRow.myDeckingOptions.pxyCreateUpdateProxy;
			pDO.allYALocationCellsIn.clear;
			pDO.allYALocationCellsOut.clear;
		endif;
		
		//update it
		app.myUtilityUA.utlUpdateDeckOptionsApplyRules(pDO, DeckingLevel_Row, _passport);
		
		if app.isValidObject(pDO) then		// OK, this is transient
			delete pDO;
		endif;
		
		if _passport.hasErrors then
			return;
		endif;
		
	endforeach;	 

epilog
	if app.isValidObject(pDO) then		// OK, this is transient
		delete pDO;
	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyGantryICAreas" id="ae507843-750a-4cf9-92ef-43ff4078ada3">
        <source>setProxyGantryICAreas(_proxy : CM_RTGArea input; _interchangePosition : Integer );
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 August 2009	cnwer1	Initial creation

*/

vars
	newICId : String;
	n  : Integer;
begin
	
	n:= 13 - self.id.length;
		
	if _interchangePosition = self.ICPosition_NoSides then
		return;
	elseif _interchangePosition = self.ICPosition_BeforeRow1 then
		newICId:="IC1_"[1:n] &amp; self.id;
		self.setProxySideICArea(_proxy,ICPosition_BeforeRow1,newICId);
	elseif _interchangePosition = self.ICPosition_AfterLastRow then
		newICId:="ICN_"[1:n] &amp; self.id;
		self.setProxySideICArea(_proxy,ICPosition_AfterLastRow,newICId);
	elseif _interchangePosition = self.ICPosition_BothSides then
		newICId:="IC1_"[1:n] &amp; self.id;
		self.setProxySideICArea(_proxy,ICPosition_BeforeRow1,newICId);
		newICId:="ICN_"[1:n] &amp; self.id;
		self.setProxySideICArea(_proxy,ICPosition_AfterLastRow,newICId);
	endif;
epilog

end;</source>
        <Parameter name="_proxy" type="CM_RTGArea" usage="input"/>
        <Parameter name="_interchangePosition" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setProxySideICArea" id="339c223a-df13-4862-ba37-3e4773258e73">
        <source>setProxySideICArea(_proxyRTG : CM_RTGArea input;
					_position : Integer;
					_newId : String);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 Jul 2009	cnwer1	Initial creation
01 Feb 2010 cnwer1	PAR 22223
*/

vars
	pxyGantryICArea,
	realICArea 		: CM_GantryInterchangeArea;
	pxyGantryRow 	: CM_GantryICRow;
	pxyGantryColumn,
	realGantryColumn : CM_GantryICColumn;
	pxyGantryLC 	: CM_GantryICAreaLaneController;
	lcLabel 	: String;
	gridColumn 		: CM_GridColumn;
	realRTGColumn,
 	pxyRTGColumn : CM_RTGColumn;
	theICType : Integer;
	realRTGArea : CM_RTGArea;
	pxysToDelete : ObjectArray;
begin

	if self.type = TA_TYPE_RTG then
		theICType :=TA_TYPE_RTG_INTERCHANGE;
	elseif self.type = TA_TYPE_RMG then
		theICType :=TA_TYPE_RMG_INTERCHANGE;
	endif;
	realRTGArea:=self.pxyGetRealObject;
	if realRTGArea &lt;&gt; null then
		realICArea:=realRTGArea.getInterchangeAreaForPosition(_position);
	endif;
	if realICArea &lt;&gt; null then
		pxyGantryICArea:=realICArea.pxyCreateUpdateProxy.CM_GantryInterchangeArea;
	else
		//create 1 row with many columns
		create pxyGantryICArea transient;
	endif;
	//if realICArea = null then
		
		//can't be the same
	pxyGantryICArea.setGridAreaProxy(_newId,null, theICType,
			1,
			self.numberOfColumns,
			1,
			false,
			self.myTerminal,
			false,
			false,
			true,
			null,
	
			false, false,
			false, false, false, null,null, _proxyRTG.use40ftIds, _proxyRTG.useSideAccessRules,
			null,null,null,null);

//	 false) ;
	pxyGantryICArea.setInterchangePosition(_position);
	
	if realICArea = null or realICArea.allGridRows.size = 0 then
		// the row
		create pxyGantryRow transient;
		
		
	else
		pxyGantryRow:=realICArea.allGridRows.first.pxyGetProxyObject.CM_GantryICRow;
		if pxyGantryRow = null then
			pxyGantryRow:=realICArea.allGridRows.first.pxyCreateUpdateProxy.CM_GantryICRow;
		endif;
	endif;
	pxyGantryRow.setForProxy(1,"01",pxyGantryICArea);
	
	create pxysToDelete transient;
	pxyGantryICArea.allGridColumns.copy(pxysToDelete);
	pxysToDelete.purge;
	foreach gridColumn in _proxyRTG.allGridColumns do
		
		pxyRTGColumn:=gridColumn.CM_RTGColumn;
		realRTGColumn:=pxyRTGColumn.pxyGetRealObject;
		
		
		if realRTGColumn &lt;&gt; null then
			if _position = self.ICPosition_BeforeRow1 then
				realGantryColumn:=realRTGColumn.myTopGantryICColumn;
			elseif _position = self.ICPosition_AfterLastRow then
				realGantryColumn:=realRTGColumn.myBottomGantryICColumn;
			endif;
		else
			realGantryColumn := null; // adm 050710 23342
		endif; 
		
		if realGantryColumn = null then 
			
			create pxyGantryColumn transient;
		else
			pxyGantryColumn:=realGantryColumn.pxyGetProxyObject;
			if pxyGantryColumn = null then
				pxyGantryColumn:=realGantryColumn.pxyCreateUpdateProxy;
			endif;
		endif; 
	
		pxyGantryColumn.setForProxy(gridColumn.column,gridColumn.label,pxyGantryICArea);
		if pxysToDelete.includes(pxyGantryColumn) then
			pxysToDelete.remove(pxyGantryColumn);
		endif;
		
		create pxyGantryLC transient;
		pxyGantryLC.setGridAreaForProxy(pxyGantryICArea, 1, pxyGantryColumn.column, null, 2);
				
		lcLabel:=pxyGantryRow.label &amp; pxyGantryColumn.label;
		//Location controllers
		
		pxyGantryLC.setForProxy(PAD_USER_UNAVAILABLE, 
							UNAVAILABLE_USE, 
							pxyGantryRow.row, 
							pxyGantryColumn.column,
							lcLabel,
							2,
							false,
							false,
							null,
							pxyGantryICArea, false, null, false, null, false, null);
		
	endforeach;

	_proxyRTG.allAssociatedInterchangeAreas.add(pxyGantryICArea);
	
	
epilog
	pxysToDelete.purge;
	delete pxysToDelete;

end;</source>
        <Parameter name="_proxyRTG" type="CM_RTGArea" usage="input"/>
        <Parameter name="_position" type="Integer"/>
        <Parameter name="_newId" type="String"/>
    </JadeMethod>
    <JadeMethod name="testHeightAccess" id="090dfc3d-fb28-4b0e-b34b-73500c03c012">
        <source>testHeightAccess(_autoMovePlan: CMIF_AutoMovePlan input; _lc : CM_LocationsController): Boolean;
//	Apr 2011	cnwjre1	par 27198 test RMG max height 
vars
	lHeight	: Real;
	ti : CM_TrackedItem;
begin
	ti := _autoMovePlan.myTrackedItem;
	lHeight := self.maxHeight;
	if lHeight &gt; 0 then
		// canAccessHeight was written for forklifts so checks this container against the current top of the stack
		//  for an RMG need to measure the top including this container, so subtract the container height from the total
		lHeight := lHeight - ti.getActualHeight();
		if not _lc.canAccessHeight(lHeight, _autoMovePlan.moveMode) then
			return false;
		endif;
	endif;

	return true;

end;</source>
        <Parameter name="_autoMovePlan" type="CMIF_AutoMovePlan" usage="input"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testIfFull" id="78d54748-869b-4822-b8f0-1147f40ff354">
        <source>testIfFull(_autoMovePlan: CMIF_AutoMovePlan input; _lc : CM_LocationsController): Boolean;
// ---------------------------------------------------------------------------
// Created:		29 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	numPlanTIs	:	Integer;
	numRealTIs	:	Integer;
	accessLocn,
	numQueueTIs	:	Integer;
	locnId : String;
begin

	numRealTIs	:= _lc.numTIs;
	numPlanTIs	:= _lc.numPlannedTIs;
	numQueueTIs	:= _lc.numQueuedTIs;
	locnId	:= _lc.getFullId();
	
	//Always check for actual TI's in area 1st
	if _autoMovePlan.iteration &lt;= numRealTIs then
		//_autoMovePlan.addVerboseLogEntry("Position " &amp; _autoMovePlan.iteration.String &amp; " of " &amp; locnId &amp; " is occupied.", IsForLogging); //- cnwmd1, Par 20524
		_autoMovePlan.addVerboseLogEntry(app.getErrorString2(Position_occupied, _autoMovePlan.iteration.String, locnId),IsForLogging, Position_occupied);
		_autoMovePlan.updateController(null);	//The height is full
		return false;
	endif;
	//Now, check for planned TIs
	if _autoMovePlan.iteration &lt;= numPlanTIs then
		if numPlanTIs &gt; 0 then	
			//Irrespective of where we are trying to go, if there is something planned
			//here. skip it.
			//_autoMovePlan.addVerboseLogEntry(locnId &amp; " has a planned TI in it, skipping.", IsForLogging); //- cnwmd1, Par 20524
			_autoMovePlan.addVerboseLogEntry(app.getErrorString1(Planned_skipping,locnId), IsForLogging, Planned_skipping);
			_autoMovePlan.updateController(null);
			return false;
		endif;
	endif;

	return inheritMethod(_autoMovePlan, _lc);

end;</source>
        <Parameter name="_autoMovePlan" type="CMIF_AutoMovePlan" usage="input"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testIfRequirePower" id="36dcd7dc-607e-4a70-8ae8-14f3d90b4927">
        <source>testIfRequirePower(_autoMovePlan: CMIF_AutoMovePlan input; _lc: CM_LocationsController): Boolean;
// ---------------------------------------------------------------------------
// Created:		29 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	yc, nextYC : CM_YardController;
	locnId : String;
begin
	if not  _lc.isKindOf(CM_YardController) then
		return false;
	endif;
	
	yc := _lc.CM_YardController;
	locnId := yc.getFullId();
	
	if yc.power = false then
		if not _autoMovePlan.testAnyHavePower() then // PAR 18682 CCMS SFW 1055
			//No power!
			//_autoMovePlan.addVerboseLogEntry(locnId &amp; " has no Power available.", IsWarning); //- cnwmd1, Par 20524
			_autoMovePlan.addVerboseLogEntry(app.getErrorString1(Power_available,locnId), IsWarning, Power_available);
		endif;
	endif;
	if yc.powerDamaged = true then
		if not _autoMovePlan.testAnyHavePower() then // PAR 18682 CCMS SFW 1055
			//No power!
			//_autoMovePlan.addVerboseLogEntry(locnId &amp; ": Power is damaged.", IsWarning); //- cnwmd1, Par 20524
			_autoMovePlan.addVerboseLogEntry(app.getErrorString1(Power_damaged,locnId), IsWarning, Power_damaged);
		endif;
	endif;
	
	return inheritMethod(_autoMovePlan, _lc);

end;</source>
        <Parameter name="_autoMovePlan" type="CMIF_AutoMovePlan" usage="input"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testIfRequirePowerYA" id="910f6448-7f1e-4f1c-97d5-505c5cd5fad7">
        <source>testIfRequirePowerYA(_yaAgent : CM_YAAutoplanAgent input; _lc: CM_LocationsController): Boolean;
// ---------------------------------------------------------------------------
// Created:		29 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	yc : CM_YardController;
	locnId : String;
begin
	if not  _lc.isKindOf(CM_YardController) then
		return false;
	endif;
	
	yc := _lc.CM_YardController;
	locnId := yc.getFullId();

	if yc.power = false then
		//No power!
		_yaAgent.addLogEntry(AP_Log_YA_Default,locnId &amp; " has no Power available.", true);
		return true;
	endif;
	if yc.powerDamaged = true then
		//No power!
		_yaAgent.addLogEntry(AP_Log_YA_Default,locnId &amp; ": Power is damaged.", true);
		return true;
	endif;
	
	return inheritMethod(_yaAgent, _lc);

end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testLocationsForOverstow" id="4ef09d2f-ed46-49a6-a3af-f3dbd5933a6a">
        <source>testLocationsForOverstow(_yaAgent : CM_YAAutoplanAgent input) : Boolean;
// -------------------------------------------
// Created 15 September 2005 by cnwdvb1
// -------------------------------------------
vars

	ti 					: CM_TrackedItem;
	previousController,
	nextController,
	controller			: CM_GridController;
	nextRow,
	prevRow,
	row					: CM_GridRow;
	iterNext,
	iterPrev			: Iterator;
	stopNext,
	stopPrev			: Boolean;

begin

	ti := _yaAgent.getMyCurrentTrackedItem();
	
	// Where is this ti currently situated. 
	controller := ti.getPrimaryLocation(REAL_MODE).CM_GridController;
	
	// Which row.
	row 	:= controller.myGridRow;
	
	// Set next and previous pointers to starting point.
	nextController		:= controller;
	previousController	:= controller;
	
	// Do the following 8,6,4,2,xxx,1,3,5,7
	// Don't bother checking for free spaces as we are moving within the same row.
	while true do
		// Get next controller.
		if nextController &lt;&gt; null then
			nextController := nextController.getMyNextController(CM_StackController);
		endif;
		
		// Do we have a next controller to evaluate and is it suitable.
		if nextController &lt;&gt; null and nextController.testForOverstowYA(_yaAgent, nextController.myGridRow) then
			return true;
		else
			// Get previous controller.
			if previousController &lt;&gt; null then
				previousController := previousController.getMyPreviousController(CM_StackController);
			endif;
			
			// Is previous controller suitable?
			if previousController &lt;&gt; null and previousController.testForOverstowYA(_yaAgent, previousController.myGridRow) then
				return true;
			endif;
		endif;
		// Nothing more to check so stop.
		if nextController = null and previousController = null then
			break;
		endif;
	endwhile;
	
	// We have reached the end of the row so can't have found a ground position.
	// Any last resorts?
	if not _yaAgent.myCurrentCMIFYAAutoPlan.allLCsLastResort.isEmpty() then
		return true;
	endif;
	
	// Moving on from first row. Rules change.
	iterNext := self.allGridRows.createIterator();
	iterPrev := self.allGridRows.createIterator();
	
	// Set start points.
	iterNext.startAtObject(row);
	iterPrev.startAtObject(row);
	
	// Increment pointers.
	stopNext := not iterNext.next(nextRow);
	stopPrev := not iterPrev.back(prevRow);

	// Now it's time for alternate ascending rows and descending rows with ascending columns.
	while true do : outerLoop
		if not stopNext and iterNext.next(nextRow) then
			// Move through each controller in the row.
			if nextRow.testForFreeSpaceYA(_yaAgent) then
				foreach nextController in nextRow.allControllersByColumn discreteLock do
			 		if nextController.testForOverstowYA(_yaAgent, nextController.myGridRow) then
			 			return true;
			 		endif;
			 	endforeach;
			endif;
		else
			// We get here if we have no more rows to process.
			if stopPrev then
				// All finished so break.
		 		break;
		 	endif;
		 	stopNext := true;
		endif;
		
		// We have reached the end of the row so can't have found a ground position.
		// Any last resorts? 
		if not _yaAgent.myCurrentCMIFYAAutoPlan.allLCsLastResort.isEmpty() then
			return true;
		endif;
	
		// Looking through previous row.			 
		if not stopPrev and iterPrev.back(prevRow) then
			// Move through each controller in row.
			if prevRow.testForFreeSpaceYA(_yaAgent) then
				foreach previousController in prevRow.allControllersByColumn discreteLock do
					if previousController.testForOverstowYA(_yaAgent, previousController.myGridRow) then
				 		return true;
				 	endif;
				endforeach;
			endif;
		else
			// We get here if we have no more rows to process.
			if stopNext then
				// All finished so break.
				break;
			endif;
			stopPrev := true;
		endif;
		
		// We have reached the end of the row so can't have found a ground position.
		// Any last resorts? 
		if not _yaAgent.myCurrentCMIFYAAutoPlan.allLCsLastResort.isEmpty() then
			return true;
		endif;
	endwhile;
	
	// We have reached the end of the row so can't have found a ground position.
	// Any last resorts? 
	if not _yaAgent.myCurrentCMIFYAAutoPlan.allLCsLastResort.isEmpty() then
		return true;
	endif;
	_yaAgent.addLogEntry(AP_Log_YA_Default,'Failed to find suitable overstow location', false);
	_yaAgent.setHadError(true);
	return false;

epilog

	delete iterPrev;
	delete iterNext;

end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="f034a8e1-d9a4-43fa-9bd5-5a442cfff84f">
        <source>validateForCreate();
/*
----------  ----------  --------------------------------------------------
Created:	15 August 2006 By cnwth2

Purpose:	

Changed On  Changed By  Reason
	
----------  ----------  --------------------------------------------------
27/10/2009	cnwdad1		Added check for RMG license for PAR #21482.
