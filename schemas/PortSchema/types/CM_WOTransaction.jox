    <JadeMethod name="myToDoTask" id="a77478c9-fe1d-49c2-85ae-be914bc904ef">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>myToDoTask(set : Boolean; _value : CM_ToDoTask io) mapping, updating;
/*
Purpose:			

Date		Who		Reason
12 June 2023	navab1	 CR 54345 TASK 54267 
*/

vars

	isInvalid : Boolean;
	type : Integer;
	toDoTask	: CM_ToDoTask;	
begin
	if set then
		self.myToDoTask := _value;
	else
		toDoTask := self.myToDoTask;
		if toDoTask = null then
			_value := null;
		else
			on Exception do app.handleDeletedObject(exception, toDoTask, isInvalid);
			type := toDoTask.toDoTaskDescCode;
			if not isInvalid then
				_value := toDoTask;
			else
				_value := null;
			endif;
		endif;
	endif;
epilog
end;
</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_ToDoTask" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setBaseAttributes" id="466007c5-43ed-4b56-bed0-bfbedb36a9de">
        <updating/>
        <source>setBaseAttributes( _dateTime   : TimeStamp; 
					_workOrder : CM_WorkOrder;
					_type      : Integer;
					_term 	   : CM_Terminal) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 Jun 2010	cnwrd1	Initial creation
12 Jan 2023	navma1  ChangeRequest 56141:[56147] EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
18 Oct 2024	navnk30	JIRA 19927: EUP - Error 1081 When using Rail Lander
19 May 2025 nama1	34853 MTN - 1081 Error CM_WOTransByTypeDateTime When Approving Work Orders
*/

vars

begin
	self.dateTime	     := _dateTime;
	self.type 	 	     := _type;	
	self.userCode	     := app.getMyUserCode;  			   //12.01.2023 navma1 56141:[56147]
	//self.myTerminal    := _term; 							   //18.10.2024 navnk30 JIRA 19927 //19.05.2025 navma1 #34853
	if not app.myPassport.useWOTransactionDeferUpdate then	   //18.10.2024 navnk30 JIRA 19927
		self.myTerminal  := _term;
	else
		app.myPassport.addWOTransactionForDeferUpd(self);
	endif;
	
	self.setMyWorkOrder( _workOrder);	
	
epilog

end;</source>
        <Parameter name="_dateTime" type="TimeStamp"/>
        <Parameter name="_workOrder" type="CM_WorkOrder"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_term" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setDateTime" id="2054bee3-cb73-4518-9a3b-1215f46cfff1">
        <updating/>
        <source>setDateTime(_dateTime : TimeStamp) updating;
/*
Purpose:			

Date		Who		Reason
18 March 2024	navab1	CR 62818 TASK 62821
*/

vars

begin
	if _dateTime.isValid() then
		self.dateTime := _dateTime;
	endif;
epilog

end;</source>
        <Parameter name="_dateTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateResync" id="f4430305-42d3-4335-ae7e-031ed74c3e96">
        <updating/>
        <source>setForUpdateResync(_controller:CMIF_TiTransactionResync; _passport : CM_Passport input) updating;
/*
Purpose:		TFS 39237	
Date			Who			Reason
JUNE 2018		CNWAB1		Initial creation
23 Oct 2024 	navlw1 		JIRA-33107: Invoice Logging Use Levels
*/

vars
	bu : CM_Bank;
begin
	
	bu := self.getMyBank();
	
	if bu = null then
		app.invLog("No business unit, no charge", LogINFO.String);
		return;
	endif;
	
	 // ### JIRA 35228 11JUL2025 NAVAB1
	if self.myTerminal &lt;&gt; null
	and not self.myTerminal.getConfig(FinancialsEnabled).Boolean then
			app.invLog("Financials Are Not Enabled, No Charging Will Occur",LogTRACE.String); // navlw1 #JIRA-33692  
		return;
	endif;
	
	bu.createChargeWOResync(self);
end;</source>
        <Parameter name="_controller" type="CMIF_TiTransactionResync"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyTerminal" id="bc409787-ccb5-47c3-83ce-1dd85b7e5501">
        <updating/>
        <source>setMyTerminal(_terminal	: CM_Terminal) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Oct 2024	navnk30	JIRA 19927: EUP - Error 1081 When using Rail Lander

*/

vars

begin
	self.myTerminal := _terminal;
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setMyWodtl" id="9324618d-b786-4abf-bc57-5bb3cdf6f029">
        <updating/>
        <source>setMyWodtl(_woTIDtl: CM_WorkOrderDtl) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Oct 2022	navcs2	ChangeRequest 56633:[56211] EUP - VAS Work Order Transactions
14 Mar 2023 navma1  ChangeRequest 56633:[56211] EUP - VAS Work Order Transactions
*/

vars

begin
	self.myWorkOrderDetail := _woTIDtl;
	
	if _woTIDtl.isKindOf(CM_WorkOrderToDoDtl) then							//14.03.2023 navma1 #56633:[56211]
		self.noCharge := _woTIDtl.CM_WorkOrderToDoDtl.noCharge;
	elseif _woTIDtl.isKindOf(CM_WodToDo) then
		self.noCharge := _woTIDtl.CM_WodToDo.noCharge;
	endif;

	if self.myWorkOrderDetail &lt;&gt; null then // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		self.setContractId(self.myWorkOrderDetail.contractId); // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
	endif;

epilog

end;</source>
        <Parameter name="_woTIDtl" type="CM_WorkOrderDtl"/>
    </JadeMethod>
    <JadeMethod name="setMyWorkOrder" id="5623162c-9e1b-4b22-a75e-89d5a908f5a7">
        <updating/>
        <source>setMyWorkOrder( _workOrder : CM_WorkOrder) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 Jun 2010	cnwrd1	Initial creation
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
*/

vars

	tmpDT			: TimeStamp;
	tmpOrderNo		: Integer;
	transDict		: CM_WOTransactByDateOrderNoDict;
	
begin

	if _workOrder = null then
		return;
	endif;
	transDict   := _workOrder.allTransactions;
	tmpDT		:= self.dateTime;
	tmpOrderNo	:= self.orderNo;
	
	while transDict.includesKey(tmpDT, tmpOrderNo) do
		// need to update orderNo
		tmpOrderNo := tmpOrderNo + 1;
	endwhile;
	
	self.orderNo     := tmpOrderNo;
	self.myWorkOrder := _workOrder;	
epilog

end;</source>
        <Parameter name="_workOrder" type="CM_WorkOrder"/>
    </JadeMethod>
