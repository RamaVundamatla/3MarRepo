    <JadeMethod name="isCargoType_Match" id="596aa4e0-1bdb-4b04-8700-4485118aa807">
        <source>isCargoType_Match(_yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created 26 May 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	// Return true because cargo type is not being used.
	if self.myCargoType = null then
		return true;
	endif;
	
	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	// Do we have a match?
	return _yaData.matches(self.myCargoType);

end;</source>
