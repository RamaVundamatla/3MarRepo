    <JadeMethod name="deleteCurrentJobEntry" id="d690e26a-4622-4d3c-a502-8a940442bbd7">
        <updating/>
        <source>deleteCurrentJobEntry(_reason : String) updating;
//--------------------------------------------------------------
//
// Created:     09 December 2016 by cnwns1
//--------------------------------------------------------------
//Confirm deletion of the current WLE for the RoadJob
//We have to do a number of things here..
//If the job is a receipt of a TI, we have to MOVE the TI to the LOGICAL delete
//area of the system, &amp; adjust the roadJob etc accordingly,
//If the job is a release, we simply amend the request etc.
//18/10/17 jlgns1 TFS 7115 PKT - Vehicle visit dispute occurs at GATE OUT
vars
	result		: Integer;
	wleArray 	: CM_WLEArray;
	wle			: CM_WorkListEntry;
		
begin
    	
	create wleArray transient;
	self.myBulkGateAgent.myRealVVR.vehicle.allRoadJobs.first.workListEntries.copy(wleArray ); 	
	if wleArray.isEmpty then
		return;
	endif;
	
	foreach wle in wleArray discreteLock do
		while true do
			app.myTrxDA.trxDeleteJobEntry(wle, _reason, app.myPassport); 
			if app.myPassport.trxCompletedOK then
				break;
			else
				result := app.showErrorWarningDialog(app.getErrorString(XLAT_Road_operations), app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			break;
		endwhile;
	endforeach;

epilog
	delete wleArray;
	
end;</source>
        <Parameter name="_reason" type="String"/>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="299ca0e5-53ec-4408-a79a-37447b222b9e">
        <updating/>
        <source>doBaseFormSave() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 December 2017	jlgndl1	Initial creation	TFS 7993	- Picked up by ALT + S

*/

vars

begin
	self.doSave();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBtnCancelClick" id="3f842f7f-b12c-4811-871f-5d8e7f9b94b4">
        <updating/>
        <source>doBtnCancelClick() updating;
// ---------------------------------------------------------------------------
//
// Created:     09 December 2016 by cnwns1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//18/10/17 jlgns1 TFS 7115 PKT - Vehicle visit dispute occurs at GATE OUT
// ---------------------------------------------------------------------------

vars
	vehicle:CM_Vehicle;
	form:	GTE_VehicleTurnaroundReason;
	result:	Integer;
	realVVR : CM_VehicleVisitRecord;
begin
	

	if not app.myCurrentUserCan(self.myTerminal, PmGteBulkInMaint) then
		return;
	endif;
	
	realVVR := self.myBulkGateAgent.myRealVVR;
	
	if realVVR &lt;&gt; null  then
		form := app.loadForm(GTE_VehicleTurnaroundReason, 
								GTE_Assistant, 
								false, false, true, 
								self.myTerminal, null).GTE_VehicleTurnaroundReason;
		result := form.showModal();
		if result = IDOK then
			if realVVR.myRoadJob = null and realVVR.isUpdatable and not realVVR.isCancelled then		
				self.doVehicleVisitCancel(form.txtReason.text);
			else	
				if  realVVR.status = CM_VehicleVisitRecord.Status_Unverified then
					if realVVR.myRoadJob = null then
							
						self.doUpdateChangeStatus();
					else
						self.deleteCurrentJobEntry(form.txtReason.text);
					endif;
				endif;
			endif;
		else
			return;
		endif;	
	endif;
	
	self.clearForm();
	self.txtRegno.setFocus();		

epilog
	app.mousePointer := MousePointer_Default;  	
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnGetWeightClick" id="95d0427e-e59e-470d-90ff-de72b8bcfaa9">
        <source>doBtnGetWeightClick();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 March 2017	cnwns1	Initial creation
19 April 2018	jlgns1 Bug 38134: PKT - Weight Discrepancy
*/

vars
	newWeight 		: Decimal[16,4];
	hasTimedOut 	: Boolean;		//Bug 38134
	timeOutSeconds 	: Integer;		//Bug 38134
	
begin
	
	timeOutSeconds := self.myBulkGateAgent.myWeighBridge.timeOutSeconds;											//Bug 38134
		
	newWeight :=self.myWeightInterfaceController.getLatestWeight(app.actualTimeServer, hasTimedOut,timeOutSeconds);	//Bug 38134
	
	self.lblWeighbridgeMessage.caption := self.myWeightInterfaceController.latestReturnValue &amp; self.myWeightInterfaceController.latestWeightSetAt.time.formatAsHHMMSSmmm;	//Bug 38134
	
	self.txtWeightIN.setValue(newWeight);
	
	self.myBulkGateAgent.setRetrievedWeight(newWeight);
	
	self.setWeighbridgeLabel(hasTimedOut);																			//Bug 38134
		
epilog

end;</source>
    </JadeMethod>
