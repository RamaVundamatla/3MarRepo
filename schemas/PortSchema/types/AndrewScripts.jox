        <source>tfs50421SaveMenuEntityPicsToDB();
/*
Purpose:	Saves all icons used by menu entities adn HMS resource types to DB (Root config)	

			Run this first, before running tfs50421UpdateMenuEntities and tfs50421UpdateResourceTypes

Date		Who		Reason
