<Class name="WS_RestCargoParentObject" id="20bda93c-d419-4ad1-af47-452d16177d06">
    <superclass name="WS_RestCargoObject"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="restwebservice"/>
    <ImplicitInverseRef name="childCargo" id="8629a6aa-076c-41c4-98aa-c9894d7c977d">
        <memberTypeInverse/>
        <type name="WS_RestCargoArray"/>
    </ImplicitInverseRef>
    <JadeMethod name="delete" id="9f557e9b-1ccd-476c-b6a5-f9971fcf8a82">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
22 July 2024		navmd1	Initial creation TFS 65034 Make sure we tidy up after ourselves!

*/

vars

begin
	self.childCargo.purge();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCargoTranslations" id="3417a97e-48ab-4732-a4da-08b8da3a5916">
        <updating/>
        <source>doCargoTranslations(_scopeOperator: String; _inward: Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
04 July 2024		navmd1	Initial creation TFS 65034

*/

vars
	cargo	: WS_RestCargoObject;
begin
	// Translate us
	inheritMethod(_scopeOperator, _inward);
	
	// Then Translate each child cargo
	foreach cargo in self.childCargo do
		cargo.doCargoTranslations(_scopeOperator, _inward);
	endforeach;

epilog

end;</source>
        <Parameter name="_scopeOperator" type="String"/>
        <Parameter name="_inward" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateRequest" id="02331b12-4a10-4668-b2e3-b95084ed6b72">
        <source>validateRequest(_isChild : Boolean ; _isPost : Boolean) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
20 June 2024		navmd1	Initial creation TFS 64176 Move common Cargo validation to one method
09 July 2024		navdap1	TFS 64390 CUX - Stowage Position Error when creating onship cargo via POST /Cargo
11 Sept 2024		navhn30 Bug 65980: CUX | PUT /cargo locationId should be read only
*/

vars
	wsChildCargo			: WS_RestCargoObject;
begin
	
	if not inheritMethod(_isChild, _isPost) then	// 11.09.24	 navhn30	TFS 65980
		return false;
	endif;
	
	foreach wsChildCargo in self.childCargo do
		if not wsChildCargo.validateRequest(true,_isPost) then	// 11.09.24	 navhn30	TFS 65980
			return false;
		endif;
	endforeach;
	
	return true;
epilog

end;</source>
        <Parameter name="_isChild" type="Boolean"/>
        <Parameter name="_isPost" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
