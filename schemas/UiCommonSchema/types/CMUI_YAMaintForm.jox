    <JadeMethod name="translateForm" id="a1d93833-bf51-498a-b231-af0287156046">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 21 September 2022 10:08:02.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0010257, locale);
	btnAddLocation.translateCaption(Xlat_0010258, locale);
	btnCancel.translateCaption(Xlat_0010259, locale);
	btnDelLocation.translateCaption(Xlat_0010260, locale);
	btnDelete.translateCaption(Xlat_0025088, locale);
