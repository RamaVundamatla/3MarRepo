    <JadeMethod name="tblData_click" id="51870cc0-ab2b-4733-a06e-bde01e3d3ef4">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_click(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2017	jlgab1	Initial creation
28 May 2024	navnk30	ChangeRequest 63897: Jade - Invoice Cargo Allocation Audits

*/

vars

begin

	
	self.myCurrentAllocation := table.accessRow(table.row).itemObject.CM_InvoiceAllocation; // ### TFS 51219 25MAY2021 NAVAB1
	self.btnViewAudit.enabled := table.row &gt; table.fixedRows and table.row &lt;= table.rows;	//28.05.2024 navnk30 #63897

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblData_dblClick" id="ce46fdba-e98b-449a-955a-585cbfed1053">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_dblClick(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 August 2017	jlgab1	Initial creation

*/

vars
begin
	if table.row &gt; table.fixedRows then
		return;
	endif;

	table.sortColumn[1] := table.column;
	table.sortAsc[1] := not table.sortAsc[1] ;
	if table.column = 3 then // TFS 7496 priority is a number
		table.sortType[1]   := table.SortType_Numeric; // TFS 7496
	else
		table.sortType[1]   := table.SortType_Alpha; // TFS 7496
	endif;
	table.resort;
	
	
	

	
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
