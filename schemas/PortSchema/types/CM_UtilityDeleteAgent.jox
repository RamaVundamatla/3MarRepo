/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2023 navhl20	ChangeRequest 57766:[57767] EUP - Delivery Dispatch – Define Job Sheet
31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
*/

vars

begin
	
	if not self.exclusiveLockObjectToDelete(_workPointJobSheet) then
	    return;
	endif;
	
	_workPointJobSheet.validateForDelete();
	
	if not _passport.noErrors then
		return;
	endif;

	if _passport.noErrors then
		_workPointJobSheet.causeEvent(_workPointJobSheet.myTerminal.getTerminalEvent(Event_JobSheet_WP_Delete), false, null);
		_workPointJobSheet.erase(NORMAL_ERASE);
	endif;
epilog

end;</source>
