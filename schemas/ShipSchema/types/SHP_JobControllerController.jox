    <JadeMethod name="setupScrollableMain" id="9bc81709-9fe0-4db6-a0ec-3671ea4ce176">
        <source>setupScrollableMain();
/*

Purpose:			


Return Value:		


Date		Who		Reason
19 December 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	frameObj : CMUI_ScrollableFrame;
begin
	frameObj:=self.frmScrollableMain;
	frameObj.left:=0;
	frameObj.top:=top; //frmToolbar.height + self.frmCranes.clientHeight;
	frameObj.width:=width;//self.clientWidth;
	frameObj.height:=height; //self.clientWindowHeight - frmToolbar.height - self.frmCranes.clientHeight;
	frameObj.parentAspect:=Control.ParentAspect_StretchBoth;
	frameObj.ignoreSkin:=true;
	
	frameObj.setScrollingFrame(self.frmScrollingMain);
	frmScrollingMain.zOrder(1);

	frameObj.myHLabels.zOrder(1);
	frameObj.myVLabels.zOrder(1);
	frameObj.setBottomLabelMargin(0);
	frameObj.setLeftLabelMargin(0);
	frameObj.labels	:=	CM_BaseForm.ScrollBars_Both;
	frameObj.setVLabelDetails(40,false);
	frameObj.setHLabelDetails(40,true);
	frameObj.zOrder(0);

	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupTimeLineFrame" id="990fa62f-cf43-4b14-b46c-4c304b49013f">
        <updating/>
        <source>setupTimeLineFrame(_zoom : Real)  : Boolean updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
19 December 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	hLabelsFrm : CMUI_ScrollableLabelsFrame;
	startTime,endTime : TimeStamp;
	screenSize : Real;
begin
	hLabelsFrm:=self.getTimeLineLabelFrame();
	hLabelsFrm.drawMode 		:= hLabelsFrm.DrawMode_Copy;
	hLabelsFrm.drawFontName	:= 'Arial';	
	hLabelsFrm.drawFontSize	:= 8;
	hLabelsFrm.borderStyle	:= hLabelsFrm.BorderStyle_Single;	
	
	startTime:=self.getTimeScaleStartTime;//self.getStartTime;

	endTime:=self.voyageEndTime;
	
	if self.myTimeLineDrawController &lt;&gt; null then
		delete self.myTimeLineDrawController;
	endif;
	
	//cnwjo3 par 23366
	//screenSize:=self.width - self.getVoyageOverviewLabelFrame.width;
	screenSize:=self.width - self.getVoyageOverviewLabelFrame.clientWidth;
	
	if self.voyageZoom &lt;&gt; 0 then
		screenSize:=screenSize;//app.getVerticalScrollbarWidth;
	endif;
	create self.myTimeLineDrawController transient;
	self.myTimeLineDrawController.setMyTerminal(self.getMyTerminal());	// 19/5/16 cnwmp6 TFS 488 - Multi timezone support
	return self.myTimeLineDrawController.initControl(hLabelsFrm,startTime,endTime,10,_zoom,screenSize.Integer);
	
epilog

end;</source>
        <Parameter name="_zoom" type="Real"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupVoyageFrame" id="7343192e-bdaa-4dd7-abf4-3784547483ab">
        <updating/>
        <source>setupVoyageFrame() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
19 December 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	vLabelsFrm : CMUI_ScrollableLabelsFrame;
	screenHeight, offsetTop : Real;
	picAft,
	picFore,
	picBridge,
	picSide: Picture;
	startFromTop : Boolean;
begin
	vLabelsFrm:=self.getVoyageOverviewLabelFrame;
	vLabelsFrm.drawMode 		:= vLabelsFrm.DrawMode_Copy;
	vLabelsFrm.drawFontName	:= 'Arial';	
	vLabelsFrm.drawFontSize	:= 8;
	vLabelsFrm.borderStyle	:= vLabelsFrm.BorderStyle_Single;	
	vLabelsFrm.setEventMapping(Frame::contextMenu.name,SHP_JobControllerForm::vLabelsFrame_contextMenu.name);
	if self.myVoyageDrawController &lt;&gt; null then
		delete self.myVoyageDrawController;
	endif;
	
	screenHeight:=self.frmScrollableMain.height - 25;
	
	create myVoyageDrawController transient;
	
	//startFromTop
	startFromTop:=self.myVoyage.starboardBerthed;
	if self.flipVertical then
		startFromTop:=not startFromTop;
	endif;
	
	if  startFromTop then
		picAft:=self.myForm.picAftTop;
		picFore:=self.myForm.picForeTop;
		picBridge:=self.myForm.picBridgeTop;
		picSide:=self.myForm.picSideTop;
		offsetTop:=self.myForm.tblCranes.height - picFore.pictureHeight;
	
	else
		picAft:=self.myForm.picAftBtm;
		picFore:=self.myForm.picForeBtm;
		picBridge:=self.myForm.picBridgeBtm;
		picSide:=self.myForm.picSideBtm;
		offsetTop:=self.myForm.tblCranes.height - picAft.pictureHeight;
	endif;
	if offsetTop &lt; 0 then
		offsetTop:=0;
	endif;
	
	if self.isForPrinting then
		picAft:=picAft.loadControl(self.myForm.controlCount).Picture;
		picFore:=picFore.loadControl(self.myForm.controlCount).Picture;
		picBridge:=picBridge.loadControl(self.myForm.controlCount).Picture;
		picSide:=picSide.loadControl(self.myForm.controlCount).Picture;
	else
	
		self.myForm.picAftTop.visible:=startFromTop;
		self.myForm.picForeTop.visible:=startFromTop;
		self.myForm.picBridgeTop.visible:=startFromTop;
		self.myForm.picAftBtm.visible:=not startFromTop;
		self.myForm.picForeBtm.visible:=not startFromTop;
		self.myForm.picBridgeBtm.visible:=not startFromTop;
		self.myForm.picSideBtm.visible:=not startFromTop;
		self.myForm.picSideTop.visible:= startFromTop;
	endif;
	myVoyageDrawController.initControl(vLabelsFrm,self.myVoyage,self.voyageZoom,screenHeight,self.flipVertical,
										picAft,
										picFore,
										picBridge,
										picSide, offsetTop);
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="startNotification" id="e735bdf8-a2dc-43bf-8630-2fb9ef0778e8">
        <source>startNotification();
/*

Purpose:			


Return Value:		


Date		Who		Reason
01 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	terminal : CM_Terminal;
begin
	terminal:=self.getMyTerminal;
	if terminal = null then
		return;
	endif;
	self.beginNotification(self.myVoyage,terminal.getTerminalEvent(JobSheet_Update_Event), Response_Continuous, null);
		
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="df644c2e-b5aa-4a7d-88a3-61e88ff08c20">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
01 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	//cnwjo3 par 23366
	//if not self.hasChanged then
	//cnwjo3 par 25663.  Even though nothing has changed we still need to draw the time scales
	//and this may cause the jobs estimated time to stretch.  So might as well refresh everything at this point
	
	/* hasChanged is referring to the user editing the jobs i.e. dragging jobs order or cranes so if the user is in the process of updating the voyage do not refresh and wipe
		the changes
		other wise we are refreshing when the time scale changes i.e. it will be the gap on time scale could be 1 min or greater
	*/
	if not self.hasChanged then
		self.doRefresh();
	endif;
epilog

end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateAddRemoveDictsForJob" id="7f1a6c1d-97f8-4de1-a0c3-6531396435bc">
        <source>updateAddRemoveDictsForJob( _addDict,
							_removeDict :  CMUI_ObjectByRealX1Y1X2Y2Dict input;
							_voyageJob : CM_VoyageJob input;
							_addX1, _addY1, _addX2, _addY2 : Real;
							_addZ : Integer;
							_remX1, _remY1, _remX2, _remY2: Real;
							_remZ : Integer;
							_oldY : Real
							 ) : Boolean;
/*

Purpose:			


Return Value:		


Date		Who		Reason
19 January 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	crane : CM_Crane;
	jobCraneDrawController : SHP_CraneJobDrawingController;
	jobStartTime,
	jobEndTime: TimeStamp;
	allNewJobDrawControllers : SHP_CraneJobDrawControllerDict;
	oldY : Real;
	allMoveJobs : CM_VoyageJobArray;
begin
	crane := _voyageJob.getJobCrane();
	jobStartTime:=self.myTimeLineDrawController.getTimeForX(_addX1);
	jobEndTime:=self.myTimeLineDrawController.getTimeForX(_addX2);
	create allNewJobDrawControllers transient;
	//check there that adding this obj here does not clash with other cranes
	foreach jobCraneDrawController in allJobDrawControllers do
		//if the crane is out own crane skip
		if jobCraneDrawController.crane = crane then
			continue;
		endif;
		allNewJobDrawControllers.add(jobCraneDrawController);
	endforeach;

	if _oldY &lt;&gt; null then
		oldY:=_oldY;
	else
		oldY := _remY1;
	endif;
	if not self.checkClashesInXYDictNew(allNewJobDrawControllers,_addX1, _addY1, _addX2, _addY2,oldY,_voyageJob,crane,jobStartTime,jobEndTime) then
		return false;
	endif;
	
	if _addDict.getAtKey(_addX1, _addY1, _addX2, _addY2,_addZ) = null then
		_addDict.putAtKey(_addX1, _addY1, _addX2, _addY2,_addZ,_voyageJob);
	endif;
	if _removeDict.getAtKey(_remX1, _remY1, _remX2, _remY2,_remZ) =  null then
		_removeDict.putAtKey(_remX1, _remY1, _remX2, _remY2,_remZ,_voyageJob);
	endif;
	return true;
epilog
	delete allNewJobDrawControllers;
end;</source>
        <Parameter name="_addDict" type="CMUI_ObjectByRealX1Y1X2Y2Dict" usage="input"/>
        <Parameter name="_removeDict" type="CMUI_ObjectByRealX1Y1X2Y2Dict" usage="input"/>
        <Parameter name="_voyageJob" type="CM_VoyageJob" usage="input"/>
        <Parameter name="_addX1" type="Real"/>
        <Parameter name="_addY1" type="Real"/>
        <Parameter name="_addX2" type="Real"/>
        <Parameter name="_addY2" type="Real"/>
        <Parameter name="_addZ" type="Integer"/>
        <Parameter name="_remX1" type="Real"/>
        <Parameter name="_remY1" type="Real"/>
        <Parameter name="_remX2" type="Real"/>
        <Parameter name="_remY2" type="Real"/>
        <Parameter name="_remZ" type="Integer"/>
        <Parameter name="_oldY" type="Real"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="userNotification" id="5dc944d7-c6e2-4170-9748-a2f979038711">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
01 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

	event : Integer;
	pObj 	: CM_Object;
	terminal : CM_Terminal;
begin
	terminal:=self.getMyTerminal;
	event := terminal.getEventFromTerminalEvent(eventType);
	
	pObj:=userInfo.CM_Object;
	//cnwjo3 par 23366
	//if event = JobSheet_Update_Event and pObj.isKindOf(CM_Voyage) then
	if event = JobSheet_Update_Event then
		if pObj.isKindOf(CM_Voyage) or pObj.isKindOf(CM_VoyageJobSheet) then
			//if self.mySelectedJobDrawConroller 
			self.drawVoyage();
		endif;
	endif;

epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validateDropToObject" id="51228d6d-960c-4b24-95e6-ccddbff298a4">
        <source>validateDropToObject(_toObject, _moveObject : Object;_before: Boolean) : Boolean;
/*

Purpose:			


Return Value:		


Date		Who		Reason
09 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	msg : String;
begin
	if _moveObject  = null then
		msg:="Your move job is null";
		app.msgBox(msg ,"Invalid drag drop"  ,MsgBox_OK_Only);
		return false;
	else
		if _moveObject.isKindOf(CM_VoyageJob) then
			if _moveObject.CM_VoyageJob.actualStartTs &lt;&gt; null then
				app.msgBox("You can't move a job that has started.", "Invalid drag drop",MsgBox_OK_Only);
				return false;
			endif;
		endif;
	endif;
	if _toObject = null then
		msg:="Your destination job is null";
		if _moveObject &lt;&gt; null then
			msg:=msg &amp; " for job " &amp; _moveObject.CM_Job.id;
		endif;
		app.msgBox(msg ,"Invalid drag drop"  ,MsgBox_OK_Only);
		return false;
	endif;
	
	if _toObject.isKindOf(CM_Delay) then
		app.msgBox("You can't drop a job on a delay", "Invalid drag drop",MsgBox_OK_Only);
		return false;
	elseif _toObject.isKindOf(CM_VoyageJob) and _before then
		if _toObject.CM_VoyageJob.actualStartTs &lt;&gt; null then
			app.msgBox("You can't move to a job that has started", "Invalid drag drop",MsgBox_OK_Only);
			return false;
		endif;
	endif;
	
	if _toObject = _moveObject then
		app.msgBox("You destination job is the same as the source job" ,"Invalid drag drop"  ,MsgBox_OK_Only);
		return false;
	endif;

	return true;
epilog

end;</source>
        <Parameter name="_toObject" type="Object"/>
        <Parameter name="_moveObject" type="Object"/>
        <Parameter name="_before" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
