    <JadeMethod name="mnuRebuildStats_click" id="5c3d2c5c-6cf8-483a-be96-922594511831">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuRebuildStats_click(menuItem: MenuItem input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 January 2009	cnwjk3	SFW1030
10 June 2009	conkc1 - catch and show errors

*/

begin
	self.mousePointer	:=	Busy;
	self.doRebuildStats(self.getSelectedYAM());
	//
	// Check for errors and show them - normally Lock or Deadlock
	//
	if not app.myPassport.trxCompletedOK then
		app.showErrorWarningDialog(app.getErrorString(Rebuild_stats), app.myPassport, ErrWarnMode_Update);
	endif;	
epilog
	self.mousePointer	:=	Idle;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
