vars
	
begin

	dkcStage.height:=(self.dkcStageBase.clientHeight - dkcMacro.clientHeight );
	dkbStage.visible:=false;
	dkbStage.ignoreSkin:=true;
	

	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupOpenedFromSatelliteView" id="33ba4e2e-e130-4ae1-b828-b15ddf6b282f">
        <source>setupOpenedFromSatelliteView() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 February 2010	cnwer1	Initial creation

*/

vars

begin
	if not self.openedFromSatelliteView then
		return;
	endif;
	//show the Yard Area and Macro
	if not self.chkPrefYard.value then
		self.chkPrefYard.value:=true;
		self.chkPrefYard.click(self.chkPrefYard);
	endif;
	
	if not self.chkPrefMacro.value then
		self.chkPrefMacro.value:=true;
		self.chkPrefMacro.click(self.chkPrefMacro);
	endif;
	
	//hide the other areas and the vehicle view
	if self.chkPrefPreGate.value then
		self.chkPrefPreGate.value:=false;
		self.chkPrefPreGate.click(self.chkPrefPreGate);
	endif;
	
	if self.chkPrefIn.value then
		self.chkPrefIn.value:=false;
		self.chkPrefIn.click(self.chkPrefIn);
	endif;
	
	if self.chkPrefOut.value then
		self.chkPrefOut.value:=false;
		self.chkPrefOut.click(self.chkPrefOut);
	endif;
	
	if self.chkPrefTree.value then
		self.chkPrefTree.value:=false;
		self.chkPrefTree.click(self.chkPrefTree);
	endif;
	
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupOperators" id="6526e85c-13e2-422a-95e8-78d71b9fe48b">
        <updating/>
        <source>setupOperators() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 February 2022	navlw1	Initial creation TFS# 52768

*/

vars
	root		: CM_Root;
	operator 	: CM_Operator;
begin
	//3 Feb 2022 navlw1 TFS# 52768
	if self.allOperators.isEmpty then
		root := app.myRoot;
		foreach operator in root.allOperators do
			self.allOperators.add(operator);
		endforeach;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupSearchFrame" id="56dbdc25-5b63-4ab6-bfb4-929f025356e6">
        <source>setupSearchFrame()protected;
// ---------------------------------------------------------------------------
// Created:     24 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17 Jan 2022	navlw1		TFS# 52455 Filter Option Vehicle Tree in Road Operations
// ---------------------------------------------------------------------------
vars
	gate	:CM_Gate;
	int		:Integer;
	dict	:CM_TAByTypeIdDict;
	iter	:Iterator;
	area	:CM_InterchangeArea;
begin
	lstGates_Select.clear;
	lstGates_Avail.clear;
	
	self.setupSearchFrame_gates;
	self.setupSearchFrame_selectedGates(); // 17 Jan 2022 navlw1 TFS#52455
	
	lstICAreas_Sel.clear;
	lstICAreas_Avail.clear;
	
	dict	:= self.myTerminal.allTerminalAreasByTypeId;
	iter 	:= dict.createIterator;
	
	self.setupSearchFrame_icAreas (dict, iter, TA_TYPE_YARD_INTERCHANGE);
	self.setupSearchFrame_icAreas (dict, iter, TA_TYPE_RTG_INTERCHANGE);
	self.setupSearchFrame_icAreas (dict, iter, TA_TYPE_RMG_INTERCHANGE);
	
	self.setupSearchFrame_icAreas (dict, iter, TA_TYPE_WORKPOINT_INTERCHANGE);	//31 Jan 2013	NDL	Par 31102
	self.setupSearchFrame_icAreas (dict, iter, TA_TYPE_CRANE_TRANS);	//31 Jan 2013	NDL	Par 31102
	
	self.setupSearchFrame_selIcAreas(); // 12 Jan 2022 navlw1 TFS#52455
	
	lstOperators_Avail.clear; // 17 Jan 2022 navlw1 TFS#52455
	lstOperators_Sel.clear; // 17 Jan 2022 navlw1 TFS#52455
	self.setupSearchFrame_operators(); // 17 Jan 2022 navlw1 TFS#52455
	self.setupSearchFrame_selOperators(); // 17 Jan 2022 navlw1 TFS#52455
	
	// disable buttons till something selected
	btnGate_Add.enabled			:= false;
	btnGate_Remove.enabled		:= false;
	btnICArea_Add.enabled		:= false;
	btnICArea_Remove.enabled	:= false;
epilog
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupSearchFrame_gates" id="8ca7a257-6417-4aea-987c-a010cd7631fc">
        <source>setupSearchFrame_gates() protected;
// ---------------------------------------------------------------------------
// Created:     24 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17 Jan 2022 	NAVLW 		TFS# 52455 Filter Option Vehicle Tree in Road Operations
// ---------------------------------------------------------------------------
vars
	gate	:CM_Gate;
	int		:Integer;
begin
	foreach gate in self.myTerminal.allGates do
		// 17 Jan 2022 NAVLW TFS# 52455
		// set up available gates that have not been selected
		if not self.allGates.includes (gate) then
			int := lstGates_Avail.addItem (gate.name);
			lstGates_Avail.itemObject[int] := gate;
		endif;
	endforeach;
	
	//old code commented by NAVLW1 17 Jan 2022
	/*
	if self.allGates.includes (gate) then
		// selected
		int := lstGates_Select.addItem (gate.name);
		
		lstGates_Select.itemObject[int] := gate;
	else
		// not selected
		int := lstGates_Avail.addItem (gate.name);
		
		lstGates_Avail.itemObject[int] := gate;
	endif;
	*/
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupSearchFrame_icAreas" id="48a6c34e-99ef-4690-b0e0-ddfdd806aa24">
        <source>setupSearchFrame_icAreas(_dict :CM_TAByTypeIdDict; _iter :Iterator input; _type :Integer)protected;
// ---------------------------------------------------------------------------
// Created:     24 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12 Jan 2022	navlw1		TFS# 52455 Filter option vehicle tree
//20 july 2022  navhl20 	TFS 53058  MTN - Job List in Road Operations screen not filtered out by Gate
// ---------------------------------------------------------------------------
vars
	area	:CM_TerminalArea;
	int		:Integer;
begin
	_dict.startKeyGeq (_type, null, _iter);
	
	while _iter.next (area) do
		//if area.type &lt;&gt; _type or  not area.isInterchangeArea then
		if area.type &lt;&gt; _type or ( _type &lt;&gt; TA_TYPE_CRANE_TRANS and not area.isInterchangeArea ) then	//31 Jan 2013	NDL	Par 31102
			break;
		endif;
		
	//	if self.allInterchangeAreas.includes (area.CM_InterchangeArea) then
		/*navlw1 commented this out incase we need it in the future TFS# 52455
		if self.allInterchangeAreas.includes(area) then	//31 Jan 2013	NDL	Par 31102
			//changed to getNiceName because gantry interchange want there parents id;
			int := lstICAreas_Sel.addItem (area.getDisplayName(true));
			
			lstICAreas_Sel.itemObject[int] := area;
		else
			//changed to getNiceName because gantry interchange want there parents id;
			int := lstICAreas_Avail.addItem (area.getDisplayName(true));
			
			lstICAreas_Avail.itemObject[int] := area;
		endif;
		*/
		//navlw1 TFS# 52455 only need to populate the availble due to now we can order the areas
		if not self.allInterchangeAreas.includes(area) then
			int := lstICAreas_Avail.addItem (area.getDisplayName(true));
			lstICAreas_Avail.itemObject[int] := area;
		endif;
	endwhile;
	lstICAreas_Avail.sorted := true;		//20 july 2022 navhl20 TFS 53058
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_dict" type="CM_TAByTypeIdDict"/>
        <Parameter name="_iter" type="Iterator" usage="input"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupSearchFrame_operators" id="94bc8c6b-cc6a-42b0-b5df-c21e0599f168">
        <source>setupSearchFrame_operators() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 January 2022	navlw1	Initial creation TFS# 52455
27/07/2022 navmv20 Bug 54200: EUP - Lists showing Operator/Stevedore codes rather than Name
*/

vars
	operator 	: CM_Operator;
	int			: Integer;
	root		: CM_Root;
begin
	root := app.myRoot;
	foreach operator in root.allOperators discreteLock do
		if not operator.isNotAvailableForEntry then
			if not self.allOperators.includes(operator) then	
				// 27/07/2022 navgm20 TFS 54200 -start
				if app.myRoot.getConfig(ComboByNameOperator).Boolean then    
					int := lstOperators_Avail.addItem (operator.description);
				else                                                       
					int := lstOperators_Avail.addItem (operator.code); 
				endif;     
				// 27/07/2022 navgm20 TFS 54200 -end 
				//int := lstOperators_Avail.addItem (operator.code); //27/07/2022 navgm20 TFS 54200
				lstOperators_Avail.itemObject[int] := operator;
			endif;
		endif;
	endforeach;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupSearchFrame_selIcAreas" id="fcc75809-04d5-455f-a87c-5d9e5d0f5318">
        <source>setupSearchFrame_selIcAreas() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 January 2022	navlw1	Initial creation TFS# 52455
20 july 2022    navhl20 TFS 53058  MTN - Job List in Road Operations screen not filtered out by Gate

*/

vars
	area	:CM_TerminalArea;
	int		:Integer;
begin
	foreach area in self.allInterchangeAreas do
		int := lstICAreas_Sel.addItem (area.getDisplayName(true));
		lstICAreas_Sel.itemObject[int] := area;
	endforeach;
	lstICAreas_Sel.sorted := true;		//20 july 2022 navhl20 TFS 53058
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupSearchFrame_selOperators" id="1a492f9e-f82d-4cfe-bd09-a5d8b79bd787">
        <source>setupSearchFrame_selOperators() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 January 2022	navlw1	Initial creation TFS# 52455
27/07/2022 navmv20 Bug 54200: EUP - Lists showing Operator/Stevedore codes rather than Name
*/

vars
	operator 	: CM_Operator;
	int 		: Integer;
begin
	foreach operator in self.allOperators do
		//27/07/2022 navmv20 TFS 54200 - start
		if app.myRoot.getConfig(ComboByNameOperator).Boolean then   
            int := lstOperators_Sel.addItem (operator.description);
		else
			int := lstOperators_Sel.addItem (operator.code);
        endif; 
		//27/07/2022 navmv20 TFS 54200 - end
		//int := lstOperators_Sel.addItem (operator.code); //27/07/2022 navmv20 TFS 54200
		lstOperators_Sel.itemObject[int] := operator;
	endforeach;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupSearchFrame_selectedGates" id="2bfc7d65-f7ff-4a02-9d48-4a7be93efafc">
        <source>setupSearchFrame_selectedGates() protected;
/*

Purpose: Populates the selected gates using the order from all gates collection
Parameters:			

Return Value:		

Date		Who		Reason
17 January 2022	navlw1	Initial creation TFS# 52455

*/

vars
	gate	:CM_Gate;
	int		:Integer;
begin
	// 17 Jan 2022 NAVLW1 TFS# 52455
	foreach gate in self.allGates do
		int := lstGates_Select.addItem (gate.name);
		lstGates_Select.itemObject[int] := gate;
	endforeach;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupTerminalAreas" id="255f3b15-f431-4e96-a941-cbd5d8c1c16b">
        <updating/>
        <source>setupTerminalAreas() updating, protected;
// ---------------------------------------------------------------------------
// Created:     24 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//10/06/2022 	navhl20 TFS 53058 MTN - Job List in Road Operations screen not filtered out by Gate
// ---------------------------------------------------------------------------
vars
	
begin
	//self.myRoadOpController.changeTerminalAreas(self.allGates, self.allInterchangeAreas);		//10/06/2022 	navhl20 TFS 53058
	self.myRoadOpController.changeTerminalAreas(self.allGates, self.allInterchangeAreas, self.allOperators);		//10/06/2022 	navhl20 TFS 53058
	
	if (not self.timerRefreshActive) then
		self.beginTimerForRefresh();
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupVehiclesDock" id="6252046c-3870-4d30-ab5a-46d198b53161">
        <source>setupVehiclesDock()protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
10 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	zWidth : Real;
	mWidth : Real;
begin
	zWidth:=self.dkcMain.clientWidth;
	mWidth:=zWidth * .20;
	
	self.dkcVehicles.parentAspect:=Frame.ParentAspect_StretchBoth;
	self.dkcVehicles.top:=self.dkcMain.top;
	self.dkcVehicles.left:=self.dkcMain.left;
	self.dkcVehicles.width:=mWidth;
	self.dkb_Vehicles.height:=self.dkcMain.height;
	self.dkb_Vehicles.parentAspect:=Frame.ParentAspect_StretchBoth;
	self.dkb_Vehicles.top:=self.dkcVehicles.top;
	self.dkb_Vehicles.left:=self.dkcVehicles.left;
	self.dkb_Vehicles.width:=self.dkcVehicles.clientWidth;
	self.dkb_Vehicles.height:=self.dkcVehicles.clientHeight;
	self.dkb_Vehicles.floatingStyle:=JadeDockBar.FloatingStyle_None;
	self.dkb_Vehicles.drawGrip:=JadeDockBase.DrawGripBar_None;
	self.lstJobs.parentAspect:=Frame.ParentAspect_StretchBoth;
	self.lstJobs.left:=self.dkb_Vehicles.left;
	self.lstJobs.top:=self.dkb_Vehicles.top;
	self.lstJobs.height:=self.dkb_Vehicles.height - app.getVerticalScrollbarWidth;
	self.lstJobs.width:=self.dkb_Vehicles.width - app.getVerticalScrollbarWidth;
	
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showAdditionalInformationForm" id="11ffe2ca-2744-45d4-b7e3-5b8cdc6a7e82">
        <source>showAdditionalInformationForm()protected;
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//22/11/2017 	cnwma1 		TFS #7828 QNS - System buffering
// ---------------------------------------------------------------------------

vars

	lAdditionalInfo	: CMUI_AdditionalInfo;
	lRailLine	: Object;
begin

	if self.myCurrentWLE = null or
	   (not self.myCurrentWLE.myRequest.isKindOf(CM_DeliveryRequest)) then
		return;
	endif;
	
	lAdditionalInfo := app.loadForm(CMUI_AdditionalInfo, CMUI_Assistant, false, false, true, self.myTerminal, self.myMasterMenuAction).CMUI_AdditionalInfo;
	// Update the navigator
	self.setNavigatorHeading(lAdditionalInfo.caption); 
	lAdditionalInfo.centreWindow;
	// cnwsb1 14 May 2003 - CM_BaseForm::showModal() now sets isModal:
	// lAdditionalInfo.isModal := true;
	lAdditionalInfo.myDeliveryRequest := self.myCurrentWLE.myRequest.CM_DeliveryRequest;
	lAdditionalInfo.setMyTerminal(self.myTerminal);

	lAdditionalInfo.showModal;
	if self.dkbMacro.visible then	                    //22/11/2017 cnwma1 TFS #7828
		self.displayExtraInfoForObj(self.myCurrentWLE);
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
