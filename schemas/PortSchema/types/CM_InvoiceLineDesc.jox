    <JadeMethod name="getChargeByUnits" id="bed739ce-0002-4cd0-934d-b4524384e66d">
        <source>getChargeByUnits() : Integer;
/* 24024 prior to this change, the chargeByUnits value was used as the units value in invoicing.
  Following the addition of the myCalculationType property, the units value is now got from this.
  If myCalculationType is null, the chargeByUnits property value is returned, otherwise myCalculationType is used.
*/
vars
	units	: Integer;
	calcType	: CM_CalculationType;
begin
	calcType := self.myCalculationType;
	if calcType = null then
		units := self.chargeByUnits;
	else
		units := calcType.calculationType;
	endif;
	return units;
end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getChargeByUnitsComboIndex" id="5e84545f-6dfd-480f-b91c-7f3f4a96cf13">
        <source>getChargeByUnitsComboIndex() : Integer;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	// ### NOT USED, these are objects now

	
	
	
	
	
	
	
	
	
	
	
	
	
	
begin
	if self.chargeByUnits = INV_CALC_TYPE_UNITY then
		return 1;
	elseif self.chargeByUnits = INV_CALC_TYPE_QUANTITY then
		return 2;
	elseif self.chargeByUnits = INV_CALC_TYPE_TRANSQUANTITY then
		return 3;
	elseif self.chargeByUnits = INV_CALC_TYPE_VOLUME then
		return 4;
	elseif self.chargeByUnits = INV_CALC_TYPE_WEIGHT then
		return 5;
	elseif self.chargeByUnits = INV_CALC_TYPE_REVENUE_TONS then
		return 6;
	elseif self.chargeByUnits = INV_CALC_TYPE_DAYS_SINCE_RECVL then
		return 7;
	elseif self.chargeByUnits = INV_CALC_TYPE_DAYS_ONSITE_AT then
		return 8;
	elseif self.chargeByUnits = INV_CALC_TYPE_WEIGHT_TON then
		return 9;
	elseif self.chargeByUnits = INV_CALC_TYPE_DAYS_CONNECTED then
		return 10;
	elseif self.chargeByUnits = INV_CALC_TYPE_DAYS_WEIGHT then
		return 11;
	elseif self.chargeByUnits = INV_CALC_TYPE_DAYS_VOLUME then
		return 12;
	endif;
	
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getChargeByUnitsString" id="7e37dd8f-1967-4e05-9650-df3e6e6de8e1">
        <source>getChargeByUnitsString() : String;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		NOT USED. Use method on APP.
//
// ---------------------------------------------------------------------------

vars
	// ### NOT USED, these are objects now
	
begin
	if self.chargeByUnits = INV_CALC_TYPE_UNITY then
		return app.getErrorString(CM_Unity);
	elseif self.chargeByUnits = INV_CALC_TYPE_QUANTITY then
		return app.getErrorString(CM_Cargo_Quantity);
	elseif self.chargeByUnits = INV_CALC_TYPE_TRANSQUANTITY then
		return app.getErrorString(CM_Transaction_Quantity);
	elseif self.chargeByUnits = INV_CALC_TYPE_VOLUME then
		return app.getErrorString(CM_Cargo_Volume);
	elseif self.chargeByUnits = INV_CALC_TYPE_WEIGHT then
		return app.getErrorString(CM_Cargo_Weight);
	elseif self.chargeByUnits = INV_CALC_TYPE_REVENUE_TONS then
		return app.getErrorString(CM_Revenue_Tons);
	elseif self.chargeByUnits =  INV_CALC_TYPE_DAYS_SINCE_RECVL then
		return app.getErrorString(CM_Days_Since_Recieval);
	elseif self.chargeByUnits = INV_CALC_TYPE_DAYS_ONSITE_AT then
		if self.bank &lt;&gt; null then		// 35872
			return app.getErrorString(CM_Days_Onsite_At) &amp; self.bank.onsiteStorageChargeTime.String;
		else
			return app.getErrorString(CM_Days_Onsite_At) ;
		endif;
	elseif self.chargeByUnits = INV_CALC_TYPE_WEIGHT_TON then
		return app.getErrorString(CM_Cargo_Weight_Tons);
	elseif self.chargeByUnits = INV_CALC_TYPE_DAYS_CONNECTED then
		return app.getErrorString(CM_Days_Connected);
	elseif self.chargeByUnits = INV_CALC_TYPE_DAYS_WEIGHT then
		return 'Days Onsite by Weight';
	elseif self.chargeByUnits = INV_CALC_TYPE_DAYS_VOLUME then
		return 'Days Onsite by Volume';
	endif;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getComboDescription" id="56acd0e8-aa25-4807-b286-310bed005894">
        <source>getComboDescription() : String;
/*
Purpose:			

Date		Who		Reason
31 Aug 2023	navab1	BUG 59913
09 Feb 2024 navbs1  ChangeRequest 62429: LNX - Remove Transaction Group prefix in Invoice Line Type
*/

vars
	invoiceProcess : CM_InvoiceProcess;
begin
	invoiceProcess := self.bank.myInvoiceProcess;
	if invoiceProcess &lt;&gt; null and invoiceProcess.isLinxProcess then  	//09.02.2024 navbs1 #62429
		return self.narration;
	endif;
	
	if self.isVoyageCalcType then
		return "HMS - " 		&amp; self.narration;
	elseif self.isCargoCalcType then
			return "Cargo - " 	&amp; self.narration;
	elseif self.isInventoryCalcType then
		return "Inventory - " 	&amp; self.narration;
	elseif self.isEventCalcType then
			return "Event - " 	&amp; self.narration;
	elseif self.isWorkOrderLine then // ### TFS 59913 15SEP2023 NAVAB1 and not self.isStandardWorkOrder() then
		return "Work Order - " 	&amp; self.narration; 
	elseif self.isBolCalcType then
			return "BOL - "    	&amp; self.narration;
	endif;

	return self.narration;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDILDForDebtor" id="4e5e4a33-588b-4193-983c-57f98afb1eee">
        <source>getDILDForDebtor(_debtor : CM_Debtor) : CM_DebtorInvoiceLineDesc;

vars
	aDILD : CM_DebtorInvoiceLineDesc;
	aILD : CM_InvoiceLineDesc;
begin

	if self.allConsolidatedDebtorInvLineD.isEmpty or _debtor = null then
		return null;
	else
		foreach aILD in self.allConsolidatedDebtorInvLineD do
			aDILD := aILD.CM_DebtorInvoiceLineDesc;
			if aDILD.allConsolidatingDebtor.includes(_debtor) then
				return aDILD;
			endif;
		endforeach;
	endif;
	
	return null;
end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <ReturnType type="CM_DebtorInvoiceLineDesc"/>
    </JadeMethod>
    <JadeMethod name="getDebtorFromLocationEvent" id="7f6f8ec0-0e52-4b79-a1e9-5dff9b90f44e">
        <source>getDebtorFromLocationEvent(_theTran : CMEVT_LocationActivity; _deriveDebtorTypeFrom : CM_DebtorType) : CM_Debtor;
/*
Purpose:			

Date		Who		Reason
18JUN2021	NAVAB1	TFS 51219
01.06.2022 navak20	ChangeRequest 53195: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - Portschema
*/

vars
	debtor			: CM_Debtor;
	chargeableBusinessUnit : CM_Bank;
	tmpCode,
	lMessageText	: String;
	tmpConsigneeOr	: CM_ConsigneeConsignor;
	tmpVoyage		: CM_Voyage;
	tmpOperator		: CM_Operator;
	custAgent 		: CM_CustomsAgent;
	tmpCarrier		: CM_Carrier;
	debtorTypeCode  : String;
	debtorType		: CM_DebtorType;
	tmpPoolParty	: CM_MTPoolingParty;					// TFS 3042
	opTerm 			: CM_OperatorTerminal;					// TFS 3042
	tmpStevedore 	: CM_Stevedore;							// TFS 44554
	tmpShipLine		: CM_ShippingLine;						// TSF 53195
begin
	if _deriveDebtorTypeFrom &lt;&gt; null then
		debtorType := _deriveDebtorTypeFrom;
	else
		debtorType := self.myDebtorType;
	endif;

	if debtorType &lt;&gt; null then
		debtorTypeCode := debtorType.code;
		
		if debtorTypeCode = CM_DebtorType.DT_CARGO_OPERATOR then
			tmpCode := _theTran.operatorCode;
			if tmpCode &lt;&gt; null then
				tmpOperator := app.myRoot.allOperators[tmpCode];
				if tmpOperator &lt;&gt; null then
					//Check for Mappings
					debtorType := self.bank.getDebtorTypeFromMapInventory( self, tmpOperator, _theTran );
					if debtorType = null then // no charge mappings so carry on
						debtor := tmpOperator.debtor;
					else
						debtor := self.getDebtorFromTypeInventory(debtorType, _theTran);
					endif;
				endif;
			endif;
		elseif debtorTypeCode = CM_DebtorType.DT_CONSIGNEE then
			tmpCode := _theTran.consignee;
			if tmpCode &lt;&gt; null then
				tmpConsigneeOr := app.myRoot.allConsigneeConsignors[tmpCode];
				if tmpConsigneeOr &lt;&gt; null then
					debtorType := self.bank.getDebtorTypeFromMapInventory( self, tmpConsigneeOr, _theTran ); 
					if debtorType = null then // no charge mappings so carry on
						debtor := tmpConsigneeOr.debtor;
					else
						debtor := self.getDebtorFromTypeInventory(debtorType, _theTran);
					endif;
				endif;
			endif;
		elseif debtorTypeCode = CM_DebtorType.DT_CONSIGNOR then
			tmpCode := _theTran.consignor;
			if tmpCode &lt;&gt; null then
				tmpConsigneeOr := app.myRoot.allConsigneeConsignors[tmpCode];
				if tmpConsigneeOr &lt;&gt; null then
					debtorType := self.bank.getDebtorTypeFromMapInventory( self, tmpConsigneeOr, _theTran ); 
					if debtorType = null then // no charge mappings so carry on
						debtor := tmpConsigneeOr.debtor;
					else
						debtor := self.getDebtorFromTypeInventory(debtorType, _theTran);
					endif;
				endif;
			endif;

		elseif debtorTypeCode = CM_DebtorType.DT_SHIP_OPERATOR then
			tmpVoyage := _theTran.getMyVoyage();
			if tmpVoyage &lt;&gt; null then 
				tmpOperator := tmpVoyage.myOperator;
				if tmpOperator &lt;&gt; null then 
					debtorType := self.bank.getDebtorTypeFromMapInventory( self, tmpOperator, _theTran ); 
					if debtorType = null then // no charge mappings so carry on
						debtor := tmpOperator.debtor;
					else
						debtor := self.getDebtorFromTypeInventory(debtorType, _theTran);
					endif;
				endif;
			endif;
		elseif debtorTypeCode = CM_DebtorType.DT_CARRIER then
			tmpCode := _theTran.carrierCode;
			if tmpCode &lt;&gt; null then
				tmpCarrier := app.myRoot.allCarriers[tmpCode];
				if tmpCarrier &lt;&gt; null then
					debtorType := self.bank.getDebtorTypeFromMapInventory( self, tmpCarrier, _theTran ); 
					if debtorType = null then // no charge mappings so carry on
						debtor := tmpCarrier.myDebtor;
					else
						debtor := self.getDebtorFromTypeInventory(debtorType, _theTran);
					endif;
				endif;
			endif;
			

		elseif debtorTypeCode = CM_DebtorType.DT_STEVEDORE_RECEIVE then 
			tmpCode := _theTran.stevedoreCode;
			if tmpCode &lt;&gt; null then
				tmpStevedore := app.myRoot.allStevedores[tmpCode];
			endif;
			if tmpStevedore &lt;&gt; null then
				debtorType := self.bank.getDebtorTypeFromMapInventory( self, tmpStevedore, _theTran ); 
				if debtorType = null then 
					debtor := tmpStevedore.myDebtor;
				else
					debtor := self.getDebtorFromTypeInventory(debtorType, _theTran);
				endif;
			endif;
		elseif debtorTypeCode = CM_DebtorType.DT_STEVEDORE_RELEASE then 
			tmpCode := _theTran.stevedoreCode;
			if tmpCode &lt;&gt; null then
				tmpStevedore := app.myRoot.allStevedores[tmpCode];
			endif;
			if tmpStevedore &lt;&gt; null then
				debtorType := self.bank.getDebtorTypeFromMapInventory( self, tmpStevedore, _theTran ); 
				if debtorType = null then 
					debtor := tmpStevedore.myDebtor;
				else
					debtor := self.getDebtorFromTypeInventory(debtorType, _theTran);
				endif;
			endif;
		endif;
		
		// 01.06.2022 navak20 TFS 53195 Start 
		elseif debtorTypeCode = CM_DebtorType.DT_SHIPPING_LINE then 
			//tmpCode := _theTran.myTrackedItem.getShippingLineCode();
			//if tmpCode &lt;&gt; null then
			tmpShipLine := _theTran.myTrackedItem.myShippingLine;		// 14.07.2022 navsrk20 53195
			//endif;
			if tmpShipLine &lt;&gt; null then
				debtorType := self.bank.getDebtorTypeFromMapInventory( self, tmpShipLine, _theTran ); 
				if debtorType = null then 
					debtor := tmpShipLine.myDebtor;
				else
					debtor := self.getDebtorFromTypeInventory(debtorType, _theTran);
				endif;
			endif;
			
		elseif debtorTypeCode = CM_DebtorType.DT_SHIPPING_LINE_DESC then 
			//tmpCode := _theTran.myTrackedItem.getShippingLineCode();
			//if tmpCode &lt;&gt; null then
			tmpShipLine := _theTran.myTrackedItem.myShippingLine;		// 14.07.2022 navsrk20 53195
			//endif;
			if tmpShipLine &lt;&gt; null then
				debtorType := self.bank.getDebtorTypeFromMapInventory( self, tmpShipLine, _theTran ); 
				if debtorType = null then 
					debtor := tmpShipLine.myDebtor;
				else
					debtor := self.getDebtorFromTypeInventory(debtorType, _theTran);
				endif;
			endif;
		//TFS 53195 end
	endif;
	
	if debtor = null then	
		debtor := app.myRoot.getDefaultDebtor( _theTran.myTerminal );
	endif;

	return debtor;
end;</source>
        <Parameter name="_theTran" type="CMEVT_LocationActivity"/>
        <Parameter name="_deriveDebtorTypeFrom" type="CM_DebtorType"/>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="getDebtorFromTI" id="c6984059-b22a-473a-b6dc-97a6fdc79320">
        <source>getDebtorFromTI(_theTI: CM_TrackedItem; _deriveDebtorTypeFrom : CM_DebtorType) : CM_Debtor;
// Modified cnwgb1 28 May 2008 to use DebtorTypes PAR16666
// Modified cnwgb1 22 October 2008 to use Charge Mappings PAR18186
// Oct 2012 CCMS 1295 add storage config debtor type as parameter
// Modified cnwdap1 16 May 2017 TFS 3042 to return correct debtor for Empty Pool Party debtor type
// Modified jlgdap1 06 Jun 2019 TFS 44554 AAT Stevedore Data Access
// 04 Nov 2020 cnwma1 ChangeRequest 50112: ASPA - GCI Stevedores
//01.06.2022 navak20	ChangeRequest 53195: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - Portschema
vars
	debtor			: CM_Debtor;
	chargeableBusinessUnit : CM_Bank;
	tmpCode,
	lMessageText	: String;
	tmpConsigneeOr	: CM_ConsigneeConsignor;
	tmpVoyage		: CM_Voyage;
	tmpOperator		: CM_Operator;
	custAgent 		: CM_CustomsAgent;
	tmpCarrier		: CM_Carrier;
	debtorTypeCode  : String;
	debtorType		: CM_DebtorType;
	tmpPoolParty	: CM_MTPoolingParty;					// TFS 3042
	opTerm 			: CM_OperatorTerminal;					// TFS 3042
	tmpStevedore 	: CM_Stevedore;							// TFS 44554
	tmpShipLine		: CM_ShippingLine;						// TFS 53195
	cooHeader : CM_OwnershipChange;
begin
	if _deriveDebtorTypeFrom &lt;&gt; null then
		debtorType := _deriveDebtorTypeFrom;
	else
		debtorType := self.myDebtorType;
	endif;

	if debtorType &lt;&gt; null then
		debtorTypeCode := debtorType.code;
		
		if debtorTypeCode = CM_DebtorType.DT_CARGO_OPERATOR  then 
			tmpCode := _theTI.operatorCode;
			if tmpCode &lt;&gt; null then
				tmpOperator := app.myRoot.allOperators[tmpCode];
				if tmpOperator &lt;&gt; null then
					//Check for Mappings
					debtorType := self.bank.getDebtorTypeFromMapTI( self, tmpOperator, _theTI );
					if debtorType = null then // no charge mappings so carry on
						debtor := tmpOperator.debtor;
					else
						debtor := self.getDebtorFromTypeTI(debtorType, _theTI);
					endif;
				endif;
			endif;
		elseif debtorTypeCode = CM_DebtorType.DT_CONSIGNEE then
			tmpCode := _theTI.consignee;
			if tmpCode &lt;&gt; null then
				tmpConsigneeOr := app.myRoot.allConsigneeConsignors[tmpCode];
				if tmpConsigneeOr &lt;&gt; null then
					debtorType := self.bank.getDebtorTypeFromMapTI( self, tmpConsigneeOr, _theTI ); 
					if debtorType = null then // no charge mappings so carry on
						debtor := tmpConsigneeOr.debtor;
					else
						debtor := self.getDebtorFromTypeTI(debtorType, _theTI);
					endif;
				endif;
			endif;
		elseif debtorTypeCode = CM_DebtorType.DT_CONSIGNOR then
			tmpCode := _theTI.consignor;
			if tmpCode &lt;&gt; null then
				tmpConsigneeOr := app.myRoot.allConsigneeConsignors[tmpCode];
				if tmpConsigneeOr &lt;&gt; null then
					debtorType := self.bank.getDebtorTypeFromMapTI( self, tmpConsigneeOr, _theTI ); 
					if debtorType = null then // no charge mappings so carry on
						debtor := tmpConsigneeOr.debtor;
					else
						debtor := self.getDebtorFromTypeTI(debtorType, _theTI);
					endif;
				endif;
			endif;
		elseif debtorTypeCode = CM_DebtorType.DT_FREIGHT_FORWARDER then
			tmpCode := _theTI.freightForwarderCode;
			if tmpCode &lt;&gt; null then
				tmpConsigneeOr := app.myRoot.allConsigneeConsignors[tmpCode];
				if tmpConsigneeOr &lt;&gt; null then
					debtorType := self.bank.getDebtorTypeFromMapTI( self, tmpConsigneeOr, _theTI ); 
					if debtorType = null then // no charge mappings so carry on
						debtor := tmpConsigneeOr.debtor;
					else
						debtor := self.getDebtorFromTypeTI(debtorType, _theTI);
					endif;
				endif;
			endif;
		elseif debtorTypeCode = CM_DebtorType.DT_SHIP_OPERATOR then
			tmpVoyage := _theTI.myVoyage;
			if tmpVoyage &lt;&gt; null then 
				tmpOperator := tmpVoyage.myOperator;
				if tmpOperator &lt;&gt; null then 
					debtorType := self.bank.getDebtorTypeFromMapTI( self, tmpOperator, _theTI ); 
					if debtorType = null then // no charge mappings so carry on
						debtor := tmpOperator.debtor;
					else
						debtor := self.getDebtorFromTypeTI(debtorType, _theTI);
					endif;
				endif;
			endif;
		elseif debtorTypeCode = CM_DebtorType.DT_BUSINESS_UNIT then
			chargeableBusinessUnit := _theTI.companyOid;
			if chargeableBusinessUnit &lt;&gt; null then
				debtorType := self.bank.getDebtorTypeFromMapTI( self, chargeableBusinessUnit, _theTI ); 
				if debtorType = null then // no charge mappings so carry on
					debtor := chargeableBusinessUnit.businessUnitDebtor;
				else
					debtor := self.getDebtorFromTypeTI(debtorType, _theTI);
				endif;
			endif;
		elseif debtorTypeCode = CM_DebtorType.DT_CUSTOMS_AGENT then
			custAgent := _theTI.myCustomsAgent;
			if custAgent &lt;&gt; null then
				debtorType := self.bank.getDebtorTypeFromMapTI( self, custAgent, _theTI ); 
				if debtorType = null then // no charge mappings so carry on
					debtor := custAgent.myDebtor;
				else
					debtor := self.getDebtorFromTypeTI(debtorType, _theTI);
				endif;
			endif;
			// 24094 add carrier
		elseif debtorTypeCode = CM_DebtorType.DT_CARRIER then
			 // ### TFS CR 55644 TASK 55684 12JAN2023 NAVAB1 tmpCode := _theTI.freightForwarderCode;
			tmpCode := _theTI.carrier;  // ### TFS CR 55644 TASK 55684 12JAN2023 NAVAB1
			if tmpCode &lt;&gt; null then
				tmpCarrier := app.myRoot.allCarriers[tmpCode];
				if tmpCarrier &lt;&gt; null then
					debtorType := self.bank.getDebtorTypeFromMapTI( self, tmpCarrier, _theTI ); 
					if debtorType = null then // no charge mappings so carry on
						debtor := tmpCarrier.myDebtor;
					else
						debtor := self.getDebtorFromTypeTI(debtorType, _theTI);
					endif;
				endif;
			endif;
			
		elseif debtorTypeCode = CM_DebtorType.DT_EMPTY_POOL_PARTY then							// TFS 3042
			tmpCode := _theTI.myPoolingPartyCode;												// TFS 3042
			if tmpCode &lt;&gt; null then																// TFS 3042
				tmpPoolParty := _theTI.myTerminal.allMTPoolingParties[tmpCode];					// TFS 3042
				if tmpPoolParty &lt;&gt; null then													// TFS 3042
					tmpCode := _theTI.operatorCode;												// TFS 3042
					foreach opTerm in tmpPoolParty.allOperatorTerminals do						// TFS 3042
						if opTerm.myTerminal &lt;&gt; _theTI.myTerminal or opTerm.myOperator.code &lt;&gt; tmpCode then	// TFS 3042
							continue;															// TFS 3042
						endif;																	// TFS 3042
						if not opTerm.myOperator.debtor.isRDT then								// TFS 3042
							debtor := opTerm.myOperator.debtor;									// TFS 3042
						endif;																	// TFS 3042
					endforeach;																	// TFS 3042
				endif;																			// TFS 3042
			endif;																				// TFS 3042
			if debtor = null then																// TFS 3042
				debtorType := app.myRoot.allDebtorTypes[CM_DebtorType.DT_EMPTY_POOL_PARTY];		// TFS 3042
				debtor := self.getDebtorFromTypeTI(debtorType, _theTI);							// TFS 3042
			endif;																				// TFS 3042
			
		// TFS 44554 Stevedore
		elseif debtorTypeCode = CM_DebtorType.DT_STEVEDORE_VOYAGE then
			tmpStevedore := _theTI.getStevedore;
			if tmpStevedore &lt;&gt; null then
				debtorType := self.bank.getDebtorTypeFromMapTI( self, tmpStevedore, _theTI ); 
				if debtorType = null then // no charge mappings so carry on
					debtor := tmpStevedore.myDebtor;
				else
					debtor := self.getDebtorFromTypeTI(debtorType, _theTI);
				endif;
			endif;
		// TFS 44554 end
		elseif debtorTypeCode = CM_DebtorType.DT_STEVEDORE_RECEIVE then                      //04.11.2020 cnwma1 TFS #50112
			tmpStevedore := _theTI.getStevedoreReceive;
			if tmpStevedore &lt;&gt; null then
				debtorType := self.bank.getDebtorTypeFromMapTI( self, tmpStevedore, _theTI ); 
				if debtorType = null then 
					debtor := tmpStevedore.myDebtor;
				else
					debtor := self.getDebtorFromTypeTI(debtorType, _theTI);
				endif;
			endif;
		elseif debtorTypeCode = CM_DebtorType.DT_STEVEDORE_RELEASE then                      //04.11.2020 cnwma1 TFS #50112
			tmpStevedore := _theTI.getStevedoreRelease;
			if tmpStevedore &lt;&gt; null then
				debtorType := self.bank.getDebtorTypeFromMapTI( self, tmpStevedore, _theTI ); 
				if debtorType = null then 
					debtor := tmpStevedore.myDebtor;
				else
					debtor := self.getDebtorFromTypeTI(debtorType, _theTI);
				endif;
			endif;
		
		// 01.06.2022 navak20 TFS 53195 Start 
		elseif debtorTypeCode = CM_DebtorType.DT_SHIPPING_LINE then                      
			tmpShipLine := _theTI.myShippingLine;
			if tmpShipLine &lt;&gt; null then
				debtorType := self.bank.getDebtorTypeFromMapTI( self, tmpShipLine, _theTI ); 
				if debtorType = null then 
					debtor := tmpShipLine.myDebtor;
				else
					debtor := self.getDebtorFromTypeTI(debtorType, _theTI);
				endif;
			endif;
		
		elseif debtorTypeCode = CM_DebtorType.DT_SHIPPING_LINE_DESC then                      
			tmpShipLine := _theTI.myShippingLine;
			if tmpShipLine &lt;&gt; null then
				debtorType := self.bank.getDebtorTypeFromMapTI( self, tmpShipLine, _theTI ); 
				if debtorType = null then 
					debtor := tmpShipLine.myDebtor;
				else
					debtor := self.getDebtorFromTypeTI(debtorType, _theTI);
				endif;
			endif;
		//TFS 53195 End
		else
			// User Defined Debtor Type
			debtor := _theTI.allDebtorsByType[debtorTypeCode];
		endif;
		
	endif;
	
	if debtor = null then	
		debtor := app.myRoot.getDefaultDebtor( _theTI.myTerminal );	//14 Sep 2012	NDL	Par 30375
	endif;

	return debtor;
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_deriveDebtorTypeFrom" type="CM_DebtorType"/>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="getDebtorFromTIForCOO" id="f7c0fef7-3827-4f89-96cd-9755fc5f553c">
        <source>getDebtorFromTIForCOO(_theTI: CM_TrackedItem; _deriveDebtorTypeFrom : CM_DebtorType; _date : TimeStamp) : CM_Debtor;
/*
Purpose - 	
Who - NAVAB1
Date - 06AUG2024
ADO - CR 64873 TASK 65509
*/

vars
	debtor			: CM_Debtor;
	tmpCode	: String;
	tmpOperator		: CM_Operator;
	debtorTypeCode  : String;
	debtorType		: CM_DebtorType;
	cooHeader : CM_OwnershipChange;
begin
	if _deriveDebtorTypeFrom &lt;&gt; null then
		debtorType := _deriveDebtorTypeFrom;
	else
		debtorType := self.myDebtorType;
	endif;

	if debtorType &lt;&gt; null then
		debtorTypeCode := debtorType.code;
		
		if debtorTypeCode = CM_DebtorType.DT_COO_OPERATOR_NEW then
			
			cooHeader := _theTI.getCOOForDate(_date);
			if cooHeader &lt;&gt; null and cooHeader.myOperatorNew &lt;&gt; null then
				tmpCode := cooHeader.myOperatorNew.code;
				if tmpCode &lt;&gt; null then
					tmpOperator := app.myRoot.allOperators[tmpCode];
					if tmpOperator &lt;&gt; null then
						//Check for Mappings
						debtorType := self.bank.getDebtorTypeFromMapTI( self, tmpOperator, _theTI );
						if debtorType = null then // no charge mappings so carry on
							debtor := tmpOperator.debtor;
						else
							debtor := self.getDebtorFromTypeTI(debtorType, _theTI);
						endif;
					endif;
				endif;
			endif;
		elseif debtorTypeCode = CM_DebtorType.DT_COO_OPERATOR_OLD  then
			cooHeader := _theTI.getCOOForDate(_date);
			if cooHeader &lt;&gt; null and cooHeader.myOperatorOld &lt;&gt; null then
				tmpCode := cooHeader.myOperatorOld.code;
				if tmpCode &lt;&gt; null then
					tmpOperator := app.myRoot.allOperators[tmpCode];
					if tmpOperator &lt;&gt; null then
						//Check for Mappings
						debtorType := self.bank.getDebtorTypeFromMapTI( self, tmpOperator, _theTI );
						if debtorType = null then // no charge mappings so carry on
							debtor := tmpOperator.debtor;
						else
							debtor := self.getDebtorFromTypeTI(debtorType, _theTI);
						endif;
					endif;
				endif;
			endif;
		else
			return self.getDebtorFromTI(_theTI, _deriveDebtorTypeFrom);
		endif;
	else
		return self.getDebtorFromTI(_theTI, _deriveDebtorTypeFrom);
	endif;
	
	if debtor = null then	
		debtor := app.myRoot.getDefaultDebtor( _theTI.myTerminal );	//14 Sep 2012	NDL	Par 30375
	endif;

	return debtor;
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_deriveDebtorTypeFrom" type="CM_DebtorType"/>
        <Parameter name="_date" type="TimeStamp"/>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="getDebtorFromTransaction" id="3ab82de1-95cb-4760-94fe-b33420909d11">
        <source>getDebtorFromTransaction(transaction: CM_TITransaction) : CM_Debtor;
/*
Changes
		PAR 16898 - RJS June 2008 - change for FF now on transaction.
		13/01/2017	cnwdap1		TFS 3042 SNO Empty Container Pool Management - new debtor type "Empty Pool Party"
		07/06/2019	jlgdap1		TFS 44554 AAT Stevedore Data Access
		04 Nov 2020 cnwma1 		ChangeRequest 50112: ASPA - GCI Stevedores
		01.06.2022 navak20	ChangeRequest 53195: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - Portschema
		23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
		25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	doLog					: Boolean;
	debtor					: CM_Debtor;
	chargeableBusinessUnit  : CM_Bank;
	tmpCode,
	lMessageText			: String;
	tmpConsigneeOr			: CM_ConsigneeConsignor;
	tmpVoyage			    : CM_Voyage;
	tranOperator, 
	tmpOperator			    : CM_Operator;
	tmpCA 					: CM_CustomsAgent;
	tmpCarrier				: CM_Carrier;
	myDebtorTypeCode 		: String;
	deriveDebtorTypeFrom	: CM_DebtorType;
	debtorType 				: CM_DebtorType;
	tmpPoolParty 			: CM_MTPoolingParty;				// TFS 3042
	opTerm 					: CM_OperatorTerminal;				// TFS 3042
	tmpStevedore 			: CM_Stevedore;						// TFS 44554
	tmpShipLine				: CM_ShippingLine;					// TFS 53195

begin

	doLog :=  app.canLogExtraDetail();				 //27.02.2025 navah1	#34141
	tmpCode := transaction.operatorCode;
	if tmpCode &lt;&gt; null then
		tranOperator := app.myRoot.allOperators[tmpCode];
	endif;
	
	deriveDebtorTypeFrom := self.myDebtorType;
	if deriveDebtorTypeFrom &lt;&gt; null then
		myDebtorTypeCode := deriveDebtorTypeFrom.code;
	
		if myDebtorTypeCode = CM_DebtorType.DT_CARGO_OPERATOR then
			lMessageText := "Debtor for Cargo Operator Charge";
			tmpCode := transaction.operatorCode;
			if tmpCode &lt;&gt; null then
				tmpOperator := app.myRoot.allOperators[tmpCode];
				if tmpOperator &lt;&gt; null then
					// ### Check for any mappings
					debtorType := self.bank.getDebtorTypeFromMapTrans( self, tmpOperator, transaction ); // PAR 17557
					if debtorType = null then // no charge mappings so carry on
						debtor := tmpOperator.debtor;
						if doLog and debtor &lt;&gt; null then
							app.invLog(lMessageText &amp; " " &amp; debtor.name, LogTRACE.String);
						endif;
					else
						debtor := self.getDebtorFromTypeTransaction(debtorType, transaction);
					endif;
				endif;
			endif;
	
		elseif myDebtorTypeCode = CM_DebtorType.DT_CONSIGNEE then
			lMessageText := "Debtor for Consignee Charge";
			tmpCode := transaction.consignee;
			if tmpCode &lt;&gt; null then
				tmpConsigneeOr := app.myRoot.allConsigneeConsignors[tmpCode];
				if tmpConsigneeOr &lt;&gt; null then
					// ### Check for any mappings
					debtorType := self.bank.getDebtorTypeFromMapTrans( self, tmpConsigneeOr, transaction ); // PAR 17557
					if debtorType = null then // no charge mappings so carry on
						debtor := tmpConsigneeOr.debtor;
						if doLog and debtor &lt;&gt; null then
							app.invLog(lMessageText &amp; " " &amp; debtor.name, LogTRACE.String);
						endif;
					else
						debtor := self.getDebtorFromTypeTransaction(debtorType, transaction);
					endif;
				endif;
			endif;
	
		elseif myDebtorTypeCode = CM_DebtorType.DT_CONSIGNOR then
			lMessageText := "Debtor for Consignor Charge";
			tmpCode := transaction.consignor;
			if tmpCode &lt;&gt; null then
				tmpConsigneeOr := app.myRoot.allConsigneeConsignors[tmpCode];
				if tmpConsigneeOr &lt;&gt; null then
					// ### Check for any mappings
					debtorType := self.bank.getDebtorTypeFromMapTrans( self, tmpConsigneeOr, transaction ); // PAR 17557
					if debtorType = null then // no charge mappings so carry on
						debtor := tmpConsigneeOr.debtor;
						if doLog and debtor &lt;&gt; null then
							app.invLog(lMessageText &amp; " " &amp; debtor.name, LogTRACE.String);
						endif;
					else
						debtor := self.getDebtorFromTypeTransaction(debtorType, transaction);
					endif;
				endif;
			endif;
			
		elseif myDebtorTypeCode = CM_DebtorType.DT_SHIP_OPERATOR then
			lMessageText := "Debtor for Ship Operator Charge";
			tmpVoyage := transaction.getVoyage();
			if tmpVoyage &lt;&gt; null then // AKB October 2001 - PAR 1518.
				tmpOperator := tmpVoyage.myOperator;
				if tmpOperator &lt;&gt; null then // AKB October 2001 - PAR 1518.
					// ### Check for any mappings
					debtorType := self.bank.getDebtorTypeFromMapTrans( self, tmpOperator, transaction ); // PAR 17557
					if debtorType = null then // no charge mappings so carry on
						debtor := tmpOperator.debtor;
						if doLog and debtor &lt;&gt; null then
							app.invLog(lMessageText &amp; " " &amp; debtor.name, LogTRACE.String);
						endif;
					else
						debtor := self.getDebtorFromTypeTransaction(debtorType, transaction);
					endif;
				endif;
			endif;
		elseif myDebtorTypeCode = CM_DebtorType.DT_BUSINESS_UNIT then
			lMessageText := "Debtor for Business Unit Charge";
			chargeableBusinessUnit := transaction.getChargeableBusinessUnit;
			if chargeableBusinessUnit &lt;&gt; null then
				// ### Check for any mappings
				debtorType := self.bank.getDebtorTypeFromMapTrans( self, tmpOperator, transaction ); // PAR 17557
				if debtorType = null then // no charge mappings so carry on
					debtor := chargeableBusinessUnit.businessUnitDebtor;
					if doLog and debtor &lt;&gt; null then
						app.invLog(lMessageText &amp; " " &amp; debtor.name, LogTRACE.String);
					endif;
				else
					debtor := self.getDebtorFromTypeTransaction(debtorType, transaction);
				endif;
			endif;
	
		elseif myDebtorTypeCode = CM_DebtorType.DT_FREIGHT_FORWARDER then
			lMessageText := "Debtor for Freight Forwarder Charge";
			// PAR 16898 - RJS June 2008 - now that transaction has the
			// FF we can get from there
			tmpCode := transaction.freightForwarderCode;
			if tmpCode &lt;&gt; null then
				tmpConsigneeOr := app.myRoot.allConsigneeConsignors[tmpCode];
				if tmpConsigneeOr &lt;&gt; null then
					// ### Check for any mappings
					debtorType := self.bank.getDebtorTypeFromMapTrans( self, tmpConsigneeOr, transaction ); // PAR 17557
					if debtorType = null then // no charge mappings so carry on
						debtor := tmpConsigneeOr.debtor;
						if doLog and debtor &lt;&gt; null then
							app.invLog(lMessageText &amp; " " &amp; debtor.name, LogTRACE.String);
						endif;
					else
						debtor := self.getDebtorFromTypeTransaction(debtorType, transaction);
					endif;
				endif;
			endif;
		elseif myDebtorTypeCode = CM_DebtorType.DT_CUSTOMS_AGENT then
			lMessageText := "Debtor for Customs Agent Charge";
			tmpCode := transaction.customsAgentCode;
			if tmpCode &lt;&gt; null then
				tmpCA := app.myRoot.allCustomsAgents[tmpCode];
				if tmpCA &lt;&gt; null then
					// ### Check for any mappings
					debtorType := self.bank.getDebtorTypeFromMapTrans( self, tmpCA, transaction ); // PAR 17557
					if debtorType = null then // no charge mappings so carry on
						debtor := tmpCA.myDebtor;
						if doLog and debtor &lt;&gt; null then
							app.invLog(lMessageText &amp; " " &amp; debtor.name, LogTRACE.String);
						endif;
					else
						debtor := self.getDebtorFromTypeTransaction(debtorType, transaction);
					endif;
				endif;
			endif;
			// 24094 add carrier
		elseif myDebtorTypeCode = CM_DebtorType.DT_CARRIER then
			lMessageText := "Debtor for Carrier Charge";
			if transaction.myTrackedItem &lt;&gt; null then
				tmpCode := transaction.myTrackedItem.carrier;
				if tmpCode &lt;&gt; null then
					tmpCarrier := app.myRoot.allCarriers[tmpCode];
					if tmpCarrier &lt;&gt; null then
						// ### Check for any mappings
						debtorType := self.bank.getDebtorTypeFromMapTrans( self, tmpCarrier, transaction );
						if debtorType = null then // no charge mappings so carry on
							debtor := tmpCarrier.myDebtor;
							if doLog and debtor &lt;&gt; null then
								app.invLog(lMessageText &amp; " " &amp; debtor.name, LogTRACE.String);
							endif;
						else
							debtor := self.getDebtorFromTypeTransaction(debtorType, transaction);
						endif;
					endif;
				endif;
			endif;
			
		elseif myDebtorTypeCode = CM_DebtorType.DT_EMPTY_POOL_PARTY then						// TFS 3042
			lMessageText := "Debtor for Empty Pool Party";										// TFS 3042
			if transaction.myTrackedItem &lt;&gt; null then											// TFS 3042
				tmpCode := transaction.myTrackedItem.myPoolingPartyCode;						// TFS 3042
				if tmpCode &lt;&gt; null then															// TFS 3042
					tmpPoolParty := transaction.myTrackedItem.myTerminal.allMTPoolingParties[tmpCode];	// TFS 3042
					if tmpPoolParty &lt;&gt; null then												// TFS 3042
						tmpCode := transaction.myTrackedItem.operatorCode;						// TFS 3042
						foreach opTerm in tmpPoolParty.allOperatorTerminals do					// TFS 3042
							if opTerm.myTerminal &lt;&gt; transaction.myTrackedItem.myTerminal or opTerm.myOperator.code &lt;&gt; tmpCode then	// TFS 3042
								continue;														// TFS 3042
							endif;																// TFS 3042
							if opTerm.myOperator.debtor &lt;&gt; null then							// TFS 3042
								if not opTerm.myOperator.debtor.isRDT then						// TFS 3042
									debtor := opTerm.myOperator.debtor;							// TFS 3042
								endif;															// TFS 3042
							endif;																// TFS 3042
						endforeach;																// TFS 3042
					endif;																		// TFS 3042
				endif;																			// TFS 3042
			endif;																				// TFS 3042
			if debtor = null then																// TFS 3042
				debtorType := app.myRoot.allDebtorTypes[CM_DebtorType.DT_EMPTY_POOL_PARTY];		// TFS 3042
				debtor := self.getDebtorFromTypeTransaction(debtorType, transaction);			// TFS 3042
			endif;																				// TFS 3042
		
		// TFS 44554 Stevedore
		elseif myDebtorTypeCode = CM_DebtorType.DT_STEVEDORE_VOYAGE then
			lMessageText := "Debtor for Stevedore for Voyage Charge";        //04.11.2020 cnwma1 TFS #50112
			tmpCode := transaction.stevedoreCode;
			if tmpCode &lt;&gt; null then
				tmpStevedore := app.myRoot.allStevedores[tmpCode];
				if tmpStevedore &lt;&gt; null then
					// ### Check for any mappings
					debtorType := self.bank.getDebtorTypeFromMapTrans( self, tmpStevedore, transaction );
					if debtorType = null then // no charge mappings so carry on
						debtor := tmpStevedore.myDebtor;
						if doLog and debtor &lt;&gt; null then
							app.invLog(lMessageText &amp; " " &amp; debtor.name, LogTRACE.String);
						endif;
					else
						debtor := self.getDebtorFromTypeTransaction(debtorType, transaction);
					endif;
				endif;
			endif;
		// TFS 44554 end
		elseif myDebtorTypeCode = CM_DebtorType.DT_STEVEDORE_RECEIVE then  //04.11.2020 cnwma1 TFS #50112
			lMessageText := "Debtor for Stevedore for Receive Charge";
			tmpCode := transaction.stevedoreCode;
			if tmpCode &lt;&gt; null then
				tmpStevedore := app.myRoot.allStevedores[tmpCode];
				if tmpStevedore &lt;&gt; null then
					// ### Check for any mappings
					debtorType := self.bank.getDebtorTypeFromMapTrans( self, tmpStevedore, transaction );
					if debtorType = null then // no charge mappings so carry on
						debtor := tmpStevedore.myDebtor;
						if doLog and debtor &lt;&gt; null then
							app.invLog(lMessageText &amp; " " &amp; debtor.name, LogTRACE.String);
						endif;
					else
						debtor := self.getDebtorFromTypeTransaction(debtorType, transaction);
					endif;
				endif;
			endif;
		elseif myDebtorTypeCode = CM_DebtorType.DT_STEVEDORE_RELEASE then    //04.11.2020 cnwma1 TFS #50112
			lMessageText := "Debtor for Stevedore for Release Charge";
			tmpCode := transaction.stevedoreCode;
			if tmpCode &lt;&gt; null then
				tmpStevedore := app.myRoot.allStevedores[tmpCode];
				if tmpStevedore &lt;&gt; null then
					// ### Check for any mappings
					debtorType := self.bank.getDebtorTypeFromMapTrans( self, tmpStevedore, transaction );
					if debtorType = null then // no charge mappings so carry on
						debtor := tmpStevedore.myDebtor;
						if doLog and debtor &lt;&gt; null then
							app.invLog(lMessageText &amp; " " &amp; debtor.name, LogTRACE.String);
						endif;
					else
						debtor := self.getDebtorFromTypeTransaction(debtorType, transaction);
					endif;
				endif;
			endif;
			
		// 01.06.2022 navak20 TFS 53195 Start 
		elseif myDebtorTypeCode = CM_DebtorType.DT_SHIPPING_LINE   
		or myDebtorTypeCode = CM_DebtorType.DT_SHIPPING_LINE_DESC then   // ### TFS BUG 56663 23FEB2023 NAVAB1
		
			lMessageText := "Debtor for Shipping Line";
			/*
			tmpCode := transaction.shippingLineCode;
			if tmpCode &lt;&gt; null then
				tmpShipLine := app.myRoot.allShippingLines[tmpCode];
				if tmpShipLine &lt;&gt; null then
					// ### Check for any mappings
					debtorType := self.bank.getDebtorTypeFromMapTrans( self, tmpShipLine, transaction );
					if debtorType = null then // no charge mappings so carry on
						debtor := tmpShipLine.myDebtor;
						if doLog and debtor &lt;&gt; null then
							app.invLog(lMessageText &amp; " " &amp; debtor.name);
						endif;
					else
						debtor := self.getDebtorFromTypeTransaction(debtorType, transaction);
					endif;
				endif;
			endif;
			*/
			tmpShipLine := transaction.getShippingLineObject();
			if tmpShipLine &lt;&gt; null then
				// ### Check for any mappings
				debtorType := self.bank.getDebtorTypeFromMapTrans( self, tmpShipLine, transaction );
				if debtorType = null then // no charge mappings so carry on
					debtor := tmpShipLine.myDebtor;
					if doLog and debtor &lt;&gt; null then
						app.invLog(lMessageText &amp; " " &amp; debtor.name, LogTRACE.String);
					endif;
				else
					debtor := self.getDebtorFromTypeTransaction(debtorType, transaction);
				endif;
			endif;
			
		/*
			
		elseif myDebtorTypeCode = CM_DebtorType.DT_SHIPPING_LINE_DESC then  
			lMessageText := "Debtor for Shipping Line Description";
			tmpCode := transaction.shippingLineCode;
			if tmpCode &lt;&gt; null then
				tmpShipLine := app.myRoot.allShippingLines[tmpCode];
				if tmpShipLine &lt;&gt; null then
					// ### Check for any mappings
					debtorType := self.bank.getDebtorTypeFromMapTrans( self, tmpShipLine, transaction );
					if debtorType = null then // no charge mappings so carry on
						debtor := tmpShipLine.myDebtor;
						if doLog and debtor &lt;&gt; null then
							app.invLog(lMessageText &amp; " " &amp; debtor.name);
						endif;
					else
						debtor := self.getDebtorFromTypeTransaction(debtorType, transaction);
					endif;
				endif;
			endif;
			*/
		// TFS 53195 End
		else
			debtorType := deriveDebtorTypeFrom;
			
			//User defined debtor type
			lMessageText := "Debtor for" &amp; debtorType.description;
			debtor := transaction.allDebtorsByType[myDebtorTypeCode];
			if debtor &lt;&gt; null then
				debtorType := self.bank.getDebtorTypeFromMapTrans( self, debtor, transaction ); // PAR 17557
				if debtorType &lt;&gt; null then // no charge mappings so carry on
					debtor := self.getDebtorFromTypeTransaction(debtorType, transaction);
				endif;
			else
				debtor := debtorType.myDefaultDebtor;	// 19/01/2012 cnwar2 #28973
			endif;
		endif;
	
	endif;
	
	if debtor &lt;&gt; null then
		if debtor.isSuspended then
			if doLog and debtor &lt;&gt; null then
				app.invLog(debtor.name &amp; " is suspended, not used", LogTRACE.String);
			endif;
			debtor := null;
		endif;
	endif;
	
	if debtor = null then	
		debtor := self.getDefaultDebtorFromTran(doLog,transaction);
	endif;

	return debtor;
end;</source>
        <Parameter name="transaction" type="CM_TITransaction"/>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="getDebtorFromTypeInventory" id="65dcb445-670b-42aa-98f0-02bb3cd95a04">
        <source>getDebtorFromTypeInventory(_debtorType : CM_DebtorType; transaction: CMEVT_LocationActivity) : CM_Debtor;
/*
Purpose:			

31MAY2021	NAVAB1	TFS 51219
01.06.2022 navak20	ChangeRequest 53195: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - Portschema
*/

vars
	debtor			: CM_Debtor;
	chargeableBusinessUnit: CM_Bank;
	tmpCode,
	lMessageText	: String;
	tmpTerminal		: CM_Terminal;
	tmpConsigneeOr	: CM_ConsigneeConsignor;
	tmpVoyage		: CM_Voyage;
	tmpOperator		: CM_Operator;
	tmpCA 			: CM_CustomsAgent;
	tmpCarrier		: CM_Carrier;
	chargeType 		: Integer;
	tmpPoolParty 	: CM_MTPoolingParty;			// TFS 3042
	opTerm 			: CM_OperatorTerminal;			// TFS 3042
	tmpStevedore	: CM_Stevedore;					// TFS 44554
	tmpShipLine		: CM_ShippingLine;				// TFS 53195
begin
	
	if _debtorType.code = CM_DebtorType.DT_CARGO_OPERATOR then
		tmpCode := transaction.operatorCode;
		if tmpCode &lt;&gt; null then
			tmpOperator := app.myRoot.allOperators[tmpCode];
		endif;
		if tmpOperator &lt;&gt; null then
			debtor := tmpOperator.debtor;
		endif;

	elseif _debtorType.code = CM_DebtorType.DT_CONSIGNEE then
		tmpCode := transaction.consignee;
		if tmpCode &lt;&gt; null then
			tmpConsigneeOr := app.myRoot.allConsigneeConsignors[tmpCode];
			if tmpConsigneeOr &lt;&gt; null then
				debtor := tmpConsigneeOr.debtor;
			endif;
		endif;

	elseif _debtorType.code = CM_DebtorType.DT_CONSIGNOR then
		tmpCode := transaction.consignor;
		if tmpCode &lt;&gt; null then
			tmpConsigneeOr := app.myRoot.allConsigneeConsignors[tmpCode];
			if tmpConsigneeOr &lt;&gt; null then
				debtor := tmpConsigneeOr.debtor;
			endif;
		endif;
		
	elseif _debtorType.code = CM_DebtorType.DT_SHIP_OPERATOR then
		tmpVoyage := transaction.getVoyage();
		if tmpVoyage &lt;&gt; null then // AKB October 2001 - PAR 1518.
			tmpOperator := tmpVoyage.myOperator;
			if tmpOperator &lt;&gt; null then // AKB October 2001 - PAR 1518.
				debtor := tmpOperator.debtor;
			endif;
		endif;

	elseif _debtorType.code = CM_DebtorType.DT_CARRIER then
		if transaction.myTrackedItem &lt;&gt; null then
			tmpCode := transaction.myTrackedItem.carrier;
			if tmpCode &lt;&gt; null then
				tmpCarrier := app.myRoot.allCarriers[tmpCode];
				if tmpCarrier &lt;&gt; null then
					debtor := tmpCarrier.myDebtor;
				endif;
			endif;
		endif;

	elseif _debtorType.code = CM_DebtorType.DT_STEVEDORE_RECEIVE or 
		   _debtorType.code = CM_DebtorType.DT_STEVEDORE_RELEASE then 
		tmpCode := transaction.stevedoreCode;
		if tmpCode &lt;&gt; null then
			tmpStevedore := app.myRoot.allStevedores[tmpCode];
			if tmpStevedore &lt;&gt; null then
				debtor := tmpStevedore.myDebtor;
			endif;
		endif;
	
	// 01.06.2022 navak20 TFS 53195 Start 
	elseif _debtorType.code = CM_DebtorType.DT_SHIPPING_LINE or 
		   _debtorType.code = CM_DebtorType.DT_SHIPPING_LINE_DESC then 
		//tmpCode := transaction.myTrackedItem.getShippingLineCode();	// 13/07/2022 navgm20 tfs 53195
		//if tmpCode &lt;&gt; null then
			tmpShipLine := transaction.myTrackedItem.myShippingLine;		
			if tmpShipLine &lt;&gt; null then
				debtor := tmpShipLine.myDebtor;
			endif;
		//endif; 
	// TFS 53195 End

	endif;

	return debtor;
end;</source>
        <Parameter name="_debtorType" type="CM_DebtorType"/>
        <Parameter name="transaction" type="CMEVT_LocationActivity"/>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="getDebtorFromTypeTI" id="7400b6d2-a854-4f77-a2df-c0d6ca59a985">
        <source>getDebtorFromTypeTI( _debtorType : CM_DebtorType; _trackedItem : CM_TrackedItem): CM_Debtor;
// ---------------------------------------------------------------------------
// Created:	22 October 2008 By Graeme Black cnwgb1
// Purpose:	Get the debtor for a particular debtor type on a Tracked Item
// Added for PAR 18186
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 16/05/2017	cnwdap1		TFS 3042 Empty Pool Party Invoicing
// 05/06/20149	jlgdap1		TFS 44554 AAT StevedoreD Data Access
// 04 Nov 2020  cnwma1 		ChangeRequest 50112: ASPA - GCI Stevedores
//01.06.2022	 navak20	ChangeRequest 53195: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - Portschema
// ---------------------------------------------------------------------------
vars
	chargeableBusinessUnit: CM_Bank;
	tmpCode: 				String;
	tmpConsigneeOr: 		CM_ConsigneeConsignor;
	tmpVoyage: 				CM_Voyage;
	tmpOperator: 			CM_Operator;
	tmpCA: 					CM_CustomsAgent;
	tmpCarrier:				CM_Carrier;
	debtor: 				CM_Debtor;
	tmpPoolParty:			CM_MTPoolingParty;				// TFS 3042
	opTerm:					CM_OperatorTerminal;			// TFS 3042
	tmpStevedore:			CM_Stevedore;					// TFs 44554
	tmpShipLine			: CM_ShippingLine;					// TFS 53195
begin
	
	if _debtorType.code = CM_DebtorType.DT_CARGO_OPERATOR then
		tmpCode := _trackedItem.operatorCode;
		if tmpCode &lt;&gt; null then
			tmpOperator := app.myRoot.allOperators[tmpCode];
		endif;
		if tmpOperator &lt;&gt; null then
			debtor := tmpOperator.debtor;
		endif;

	elseif _debtorType.code = CM_DebtorType.DT_CONSIGNEE then
		tmpCode := _trackedItem.consignee;
		if tmpCode &lt;&gt; null then
			tmpConsigneeOr := app.myRoot.allConsigneeConsignors[tmpCode];
			if tmpConsigneeOr &lt;&gt; null then
				debtor := tmpConsigneeOr.debtor;
			endif;
		endif;

	elseif _debtorType.code = CM_DebtorType.DT_CONSIGNOR then
		tmpCode := _trackedItem.consignor;
		if tmpCode &lt;&gt; null then
			tmpConsigneeOr := app.myRoot.allConsigneeConsignors[tmpCode];
			if tmpConsigneeOr &lt;&gt; null then
				debtor := tmpConsigneeOr.debtor;
			endif;
		endif;
		
	elseif _debtorType.code = CM_DebtorType.DT_SHIP_OPERATOR then
		tmpVoyage := _trackedItem.myVoyage;
		if tmpVoyage &lt;&gt; null then
			tmpOperator := tmpVoyage.myOperator;
			if tmpOperator &lt;&gt; null then
				debtor := tmpOperator.debtor;
			endif;
		endif;
		
	elseif _debtorType.code = CM_DebtorType.DT_BUSINESS_UNIT then
		chargeableBusinessUnit := _trackedItem.companyOid;
		if chargeableBusinessUnit &lt;&gt; null then
			debtor := chargeableBusinessUnit.businessUnitDebtor;
		endif;

	elseif _debtorType.code = CM_DebtorType.DT_FREIGHT_FORWARDER then
		tmpCode := _trackedItem.freightForwarderCode;
		if tmpCode &lt;&gt; null then
			tmpConsigneeOr := app.myRoot.allConsigneeConsignors[tmpCode];
			if tmpConsigneeOr &lt;&gt; null then
				debtor := tmpConsigneeOr.debtor;
			endif;
		endif;

	elseif _debtorType.code = CM_DebtorType.DT_CUSTOMS_AGENT then
		tmpCA := _trackedItem.myCustomsAgent;
		if tmpCA &lt;&gt; null then
			debtor := tmpCA.myDebtor;
		endif;
		
		// 24094 add carrier
	elseif _debtorType.code = CM_DebtorType.DT_CARRIER then
		tmpCode := _trackedItem.carrier;
		if tmpCode &lt;&gt; null then
			tmpCarrier := app.myRoot.allCarriers[tmpCode];
			if tmpCarrier &lt;&gt; null then
				debtor := tmpCarrier.myDebtor;
			endif;
		endif;
		
	elseif _debtorType.code = CM_DebtorType.DT_EMPTY_POOL_PARTY then					// TFS 3042
		tmpCode := _trackedItem.myPoolingPartyCode;										// TFS 3042
		if tmpCode &lt;&gt; null then															// TFS 3042
			tmpPoolParty := _trackedItem.myTerminal.allMTPoolingParties[tmpCode];		// TFS 3042
			if tmpPoolParty &lt;&gt; null then												// TFS 3042
				tmpCode := _trackedItem.operatorCode;									// TFS 3042
				foreach opTerm in tmpPoolParty.allOperatorTerminals do					// TFS 3042
					if opTerm.myTerminal &lt;&gt; _trackedItem.myTerminal or opTerm.myOperator.code &lt;&gt; tmpCode then	// TFS 3042
						continue;														// TFS 3042
					endif;																// TFS 3042
					if not opTerm.myOperator.debtor.isRDT then							// TFS 3042
						debtor := opTerm.myOperator.debtor;								// TFS 3042
					endif;																// TFS 3042
				endforeach;																// TFS 3042
			endif;																		// TFS 3042
		endif;																			// TFS 3042
		if debtor = null then															// TFS 3042
			debtor := _debtorType.myDefaultDebtor;										// TFS 3042
		endif;																			// TFS 3042
	
	// TFS 44554 Stevedore
	elseif _debtorType.code = CM_DebtorType.DT_STEVEDORE_VOYAGE then
		tmpStevedore := _trackedItem.getStevedore;
		if tmpStevedore &lt;&gt; null then
			debtor := tmpStevedore.myDebtor;
		endif;
	// TFS 44554 end
	elseif _debtorType.code = CM_DebtorType.DT_STEVEDORE_RECEIVE then   //04.11.2020 cnwma1 TFS #50112
		tmpStevedore := _trackedItem.getStevedoreReceive;
		if tmpStevedore &lt;&gt; null then
			debtor := tmpStevedore.myDebtor;
		endif;
	elseif _debtorType.code = CM_DebtorType.DT_STEVEDORE_RELEASE then  //04.11.2020 cnwma1 TFS #50112
		tmpStevedore := _trackedItem.getStevedoreRelease;
		if tmpStevedore &lt;&gt; null then
			debtor := tmpStevedore.myDebtor;
		endif;
	
	// 01.06.2022 navak20 TFS 53195 Start 
	elseif _debtorType.code = CM_DebtorType.DT_SHIPPING_LINE then
		tmpShipLine := _trackedItem.myShippingLine;
		if tmpShipLine &lt;&gt; null then
			debtor := tmpShipLine.myDebtor;
		endif;
		
	elseif _debtorType.code = CM_DebtorType.DT_SHIPPING_LINE_DESC then
		tmpShipLine := _trackedItem.myShippingLine;
		if tmpShipLine &lt;&gt; null then
			debtor := tmpShipLine.myDebtor;
		endif;
	// TFS 53195 End
	else
		//User defined Debtor Type
		debtor := _trackedItem.allDebtorsByType[_debtorType.code];
		if debtor = null then
			debtor := _debtorType.myDefaultDebtor;
		endif;
	endif;
	
	return debtor;
end;</source>
        <Parameter name="_debtorType" type="CM_DebtorType"/>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="getDebtorFromTypeTransaction" id="dc264c46-cf29-4985-884c-9fbe7b264846">
        <source>getDebtorFromTypeTransaction(_debtorType : CM_DebtorType; transaction: CM_TITransaction) : CM_Debtor;
/*
Changes
		PAR 16898 - RJS June 2008 - change for FF now on transaction.
		TFS 3042	DMP 16/05/2017 Derive Debtor for Empty Pool Party debtor type
		TFS 44554	DMP 05/06/2019 AAT Stevedore Data Access
		04 Nov 2020 cnwma1 ChangeRequest 50112: ASPA - GCI Stevedores
		01.06.2022 navak20	ChangeRequest 53195: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - Portschema
*/

vars
	debtor			: CM_Debtor;
	chargeableBusinessUnit: CM_Bank;
	tmpCode,
	lMessageText	: String;
	tmpTerminal		: CM_Terminal;
	tmpConsigneeOr	: CM_ConsigneeConsignor;
	tmpVoyage		: CM_Voyage;
	tmpOperator		: CM_Operator;
	tmpCA 			: CM_CustomsAgent;
	tmpCarrier		: CM_Carrier;
	chargeType 		: Integer;
	tmpPoolParty 	: CM_MTPoolingParty;			// TFS 3042
	opTerm 			: CM_OperatorTerminal;			// TFS 3042
	tmpStevedore	: CM_Stevedore;					// TFS 44554
	tmpShipLine		: CM_ShippingLine;				// TFS 53195
begin
	
	if _debtorType.code = CM_DebtorType.DT_CARGO_OPERATOR then
		tmpCode := transaction.operatorCode;
		if tmpCode &lt;&gt; null then
			tmpOperator := app.myRoot.allOperators[tmpCode];
		endif;
		if tmpOperator &lt;&gt; null then
			debtor := tmpOperator.debtor;
		endif;

	elseif _debtorType.code = CM_DebtorType.DT_CONSIGNEE then
		tmpCode := transaction.consignee;
		if tmpCode &lt;&gt; null then
			tmpConsigneeOr := app.myRoot.allConsigneeConsignors[tmpCode];
			if tmpConsigneeOr &lt;&gt; null then
				debtor := tmpConsigneeOr.debtor;
			endif;
		endif;

	elseif _debtorType.code = CM_DebtorType.DT_CONSIGNOR then
		tmpCode := transaction.consignor;
		if tmpCode &lt;&gt; null then
			tmpConsigneeOr := app.myRoot.allConsigneeConsignors[tmpCode];
			if tmpConsigneeOr &lt;&gt; null then
				debtor := tmpConsigneeOr.debtor;
			endif;
		endif;
		
	elseif _debtorType.code = CM_DebtorType.DT_SHIP_OPERATOR then
		tmpVoyage := transaction.getVoyage();
		if tmpVoyage &lt;&gt; null then // AKB October 2001 - PAR 1518.
			tmpOperator := tmpVoyage.myOperator;
			if tmpOperator &lt;&gt; null then // AKB October 2001 - PAR 1518.
				debtor := tmpOperator.debtor;
			endif;
		endif;
	elseif _debtorType.code = CM_DebtorType.DT_BUSINESS_UNIT then
		chargeableBusinessUnit := transaction.getChargeableBusinessUnit;
		if chargeableBusinessUnit &lt;&gt; null then
			debtor := transaction.getChargeableBusinessUnit.businessUnitDebtor;
		endif;

	elseif _debtorType.code = CM_DebtorType.DT_FREIGHT_FORWARDER then
		// PAR 16898 - RJS June 2008 - now FF on transaction get from there
		tmpCode := transaction.freightForwarderCode;
		//tmpCode := transaction.myTrackedItem.freightForwarderCode;
		
		if tmpCode &lt;&gt; null then
			tmpConsigneeOr := app.myRoot.allConsigneeConsignors[tmpCode];
			if tmpConsigneeOr &lt;&gt; null then
				debtor := tmpConsigneeOr.debtor;
			endif;
		endif;
	elseif _debtorType.code = CM_DebtorType.DT_CUSTOMS_AGENT then
		tmpCode := transaction.customsAgentCode;
		if tmpCode &lt;&gt; null then
			tmpCA := app.myRoot.allCustomsAgents[tmpCode];
			if tmpCA &lt;&gt; null then
				debtor := tmpCA.myDebtor;
			endif;
		endif;
		// 24094 add carrier
	elseif _debtorType.code = CM_DebtorType.DT_CARRIER then
		if transaction.myTrackedItem &lt;&gt; null then
			tmpCode := transaction.myTrackedItem.carrier;
			if tmpCode &lt;&gt; null then
				tmpCarrier := app.myRoot.allCarriers[tmpCode];
				if tmpCarrier &lt;&gt; null then
					debtor := tmpCarrier.myDebtor;
				endif;
			endif;
		endif;
		
	elseif _debtorType.code = CM_DebtorType.DT_EMPTY_POOL_PARTY then									// TFS 3042
		if transaction.myTrackedItem &lt;&gt; null then														// TFS 3042
			tmpCode := transaction.myTrackedItem.operatorCode;											// TFS 3042
			if tmpCode &lt;&gt; null then																		// TFS 3042
				tmpPoolParty := transaction.myTrackedItem.myTerminal.allMTPoolingParties[tmpCode];		// TFS 3042
				if tmpPoolParty &lt;&gt; null then															// TFS 3042
					tmpCode := transaction.myTrackedItem.operatorCode;									// TFS 3042
					foreach opTerm in tmpPoolParty.allOperatorTerminals do								// TFS 3042
						if opTerm.myTerminal &lt;&gt; transaction.myTrackedItem.myTerminal or opTerm.myOperator.code &lt;&gt; tmpCode then	// TFS 3042
							continue;																	// TFS 3042
						endif;																			// TFS 3042
						if not opTerm.myOperator.debtor.isRDT then										// TFS 3042
							debtor := opTerm.myOperator.debtor;											// TFS 3042
						endif;																			// TFS 3042
					endforeach;																			// TFS 3042
				endif;																					// TFS 3042
			endif;																						// TFS 3042
		endif;																							// TFS 3042
		if debtor = null then																			// TFS 3042
			debtor := _debtorType.myDefaultDebtor;														// TFS 3042
		endif;																							// TFS 3042
		
	// TFS 44554 Stevedore
	elseif _debtorType.code = CM_DebtorType.DT_STEVEDORE_VOYAGE  or 
		   _debtorType.code = CM_DebtorType.DT_STEVEDORE_RECEIVE or    //04.11.2020 cnwma1 TFS #50112
		   _debtorType.code = CM_DebtorType.DT_STEVEDORE_RELEASE then  //04.11.2020 cnwma1 TFS #50112
		tmpCode := transaction.stevedoreCode;
		if tmpCode &lt;&gt; null then
			tmpStevedore := app.myRoot.allStevedores[tmpCode];
			if tmpStevedore &lt;&gt; null then
				debtor := tmpStevedore.myDebtor;
			endif;
		endif;
	// TFS 44554 end
	
	// 01.06.2022 navak20 TFS 53195 Start
	elseif _debtorType.code = CM_DebtorType.DT_SHIPPING_LINE  or 
		   _debtorType.code = CM_DebtorType.DT_SHIPPING_LINE_DESC then
		//tmpCode := transaction.myTrackedItem.getShippingLineCode(); //13/07/2022 navgm20 tfs 53195
		//if tmpCode &lt;&gt; null then
 // ### TFS BUG 56663 23FEB2023 NAVAB1			tmpShipLine := transaction.myTrackedItem.myShippingLine;		// 14.07.2022 navsrk20 53195
			tmpShipLine := transaction.getShippingLineObject(); // ### TFS BUG 56663 23FEB2023 NAVAB1
			if tmpShipLine &lt;&gt; null then
				debtor := tmpShipLine.myDebtor;
			endif;
		//endif;
	// TFS 53195 end
	
	else
		//User defined Debtor Type
		debtor := transaction.allDebtorsByType[_debtorType.code];
		if debtor = null then
			debtor := _debtorType.myDefaultDebtor;
		endif;
	endif;

	return debtor;
end;</source>
        <Parameter name="_debtorType" type="CM_DebtorType"/>
        <Parameter name="transaction" type="CM_TITransaction"/>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="getDebtorInvLineType" id="cca7d9dc-1c36-4749-bae3-2d254bc8e872">
        <source>getDebtorInvLineType(_debtor : CM_Debtor) : CM_DebtorInvLineType;
// 28218 CCMS 2120 Oct 2011 electronic invoicing
vars
	dilt	: CM_DebtorInvLineType;
begin
	dilt := self.allDebtorInvLineTypes[_debtor];
	return dilt;
end;
</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <ReturnType type="CM_DebtorInvLineType"/>
    </JadeMethod>
    <JadeMethod name="getDefaultDebtorFromTran" id="e6c58afe-d711-4758-8217-02b20c53a0fd">
        <source>getDefaultDebtorFromTran(doLog : Boolean; _transaction : CM_Transaction) : CM_Debtor;
/*
Purpose:			
Date		Who		Reason
15 May 2012	cnwab1	Initial creation
23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	tmpTerminal : CM_Terminal;
	debtor : CM_Debtor;
	canLogExtra	: Boolean;	//27.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141 
	tmpTerminal := _transaction.getMyTerminal();
	debtor := tmpTerminal.getConfig(DefDebtor).CM_Debtor;
	if doLog and debtor &lt;&gt; null then
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog("Default debtor for terminal " &amp; debtor.name, LogINFO.String);
		endif;
	endif;
	if debtor = null then
		debtor := app.myRoot.myRootCompany.debtors["RDT"];
		if doLog and debtor &lt;&gt; null then
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog("RDT debtor " &amp; debtor.name, LogINFO.String);
			endif;
		endif;
	endif;

	return debtor;

epilog

end;</source>
        <Parameter name="doLog" type="Boolean"/>
        <Parameter name="_transaction" type="CM_Transaction"/>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="getDescriptionWithTerminalStr" id="9938e706-1832-430a-9a3f-1135f87fb79d">
        <source>getDescriptionWithTerminalStr() : String;
//	CCMS 2348 Financial Reporting
vars
	
begin
	if self.bank = null or 
	   self.bank.terminal = null then
		return self.narration;
	endif;
	
	return self.narration &amp; " (" &amp; self.bank.getTerminalCode() &amp; ")";
epilog
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="40cdbd36-b053-48df-9e12-1ccbeb0ecdde">
        <source>getDisplayDetails(_short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     Aug 2004	cnwrs1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------

vars

begin
	if _short then
		return self.narration[1:10];
	else
		return self.narration;
	endif;
end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="0c4349a0-18bd-4cc2-89fa-9d8d8701dd9b">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 17/09/2015	cnwdap1		PAR #36909 CCMS ADP 2537 New attributes
// 28/10/2021   navma1 		ChangeRequest 52163: SAL - Unicode Arabic Support Business Requirements
// 31 Jan 2023 	navvt20     TFS 56132 Task 56134: UI - Invoice Line Type - UOM
vars
	hasHook	: Boolean;
	calcType	: CM_CalculationType;
begin
	if _attrName = ETRow_NumServices  then
		return self.services.size.asStringJMT;
	elseif _attrName = ETRow_NumMappings then
		return self.getNumMappings().asStringJMT;
	elseif _attrName = ETRow_CurrConvNotReq // TFS 41484
		or _attrName = ETRow_CurrConvNotReqDisp then
		return self.currencyConversionNotRequired.getYesNo();
	elseif _attrName = ETRow_InvoiceTypeCode  then
		if self.invoiceType = null then
			return null;
		else
			return self.invoiceType.description;
		endif;
	elseif _attrName = ETRow_Narration200 then		//28.10.2021 navma1 #52163
		return self.narration;
	elseif _attrName = ETRow_Service then
		return self.getServicesDesc(false)[1:250];	// TFS 2074 use "," delimiters so can use the table export
	elseif _attrName = ETRow_PrintOrder  then
		return self.printingOrder.String;
	elseif _attrName = ETRow_Charges  then
		return self.getChargeByDebtorType(); 
	elseif _attrName = ETRow_UnitNarration then
		return self.unitNarration;
	elseif _attrName = ETRow_PrintTIs or
		   _attrName = ETRow_PrintTIsDisp then
		return self.bPrintTrackedItems.getYesNo();
	elseif _attrName = ETRow_OneLinePerFP or
		   _attrName = ETRow_OneLinePerFPDisp then
		return self.bOneLinePerFinancialPeriod.getYesNo();
	elseif _attrName = ETRow_Unity then
	// 24024 CCMS 1151 Aug 2010 cnwjre1 user hook code for invoice quantity and rate
		calcType := self.myCalculationType;
		if calcType = null then
			return app.getInvoiceCalcTypeLabel(self.chargeByUnits,true);
		else
			 // PAR 30428
			if calcType.isStandardCargo() then
				return app.getInvoiceCalcTypeLabel(calcType.calculationType,true); // PAR 30428
			else
				return calcType.description;
			endif;
		endif;
	elseif _attrName = ETRow_QuantityHookCode then
		return app.getErrorString(Doubleclick_view);
	elseif _attrName = ETRow_HasQtyHookCode then
		calcType := self.myCalculationType;
		if calcType &lt;&gt; null and
		   calcType.myHookCodeQuantity &lt;&gt; null then
			hasHook := true;
		endif;
		return hasHook.getYes();
	elseif _attrName = ETRow_IsNotAvailableForEntryCk then
		return self.isNotAvailableForEntry.getYesNo();
		
	elseif _attrName = ETRow_MinimumChargeAmount then							// PAR #36909
		if self.minimumChargeAmount &lt;&gt; null then								// PAR #36909
			return self.minimumChargeAmount.asStringJMT;						// PAR #36909
		else																	// PAR #36909
			return null;														// PAR #36909
		endif;																	// PAR #36909
	elseif _attrName = ETRow_MinimumChargeGroupBy then							// PAR #36909
		if self.minimumChargeGroupBy = self.GROUP_BY_NONE then					// PAR #36909
			return app.getErrorString(None);									// PAR #36909
		elseif self.minimumChargeGroupBy = self.GROUP_BY_INVOICE then			// PAR #36909
			return app.getErrorString(Invoice);									// PAR #36909
		elseif self.minimumChargeGroupBy = self.GROUP_BY_INVOICELINE then		// PAR #36909
			return app.getErrorString(Invoice_line);							// PAR #36909
		else																	// PAR #36909
			return null;														// PAR #36909
		endif;																	// PAR #36909
	elseif _attrName = ETRow_MinimumChargeLineType then							// PAR #36909
		if self.minimumChargeInvoiceLineType &lt;&gt; null then						// PAR #36909
			return self.minimumChargeInvoiceLineType.narration;					// PAR #36909
		else																	// PAR #36909
			return null;														// PAR #36909
		endif;																	// PAR #36909
		
	elseif _attrName = ETRow_TaxAlwaysCharged then	//07 May 2019	NDL	TFS 44651
		return self.taxAlwaysCharged.String;
	elseif _attrName = ETRow_ExternalReference1 then //30/3/22 jlier1	TFS 53286
		return self.externalReference1;
	// Start 31 Jan 2023 navvt20 TFS 56134
	elseif _attrName = ETRow_Uom then
	    if self.myUOM&lt;&gt; null then 
			return self.myUOM.description;
		endif;
	// End 31 Jan 2023 navvt20 TFS 56134
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceType" id="7b9e9b62-0346-4c61-b5c0-f6d7cc832b7b">
        <source>getInvoiceType(_debtor : CM_Debtor) : CM_InvoiceDesc;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
//	Date		Who		Reason
//	23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
//	25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
vars
	aMapping : CM_InvoiceLineDescMapping;
	invType  : CM_InvoiceDesc;
	invalid 	: Boolean;
	canLogExtra	: Boolean;	//27.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141 

	on Exception do app.handleDeletedObject(exception,invType,invalid);
	
	foreach aMapping in self.allInvoiceTypeMappingsByDebtor do
		invType:=aMapping.myInvoiceType;
		if aMapping.myDebtor = _debtor and invType &lt;&gt; null  then
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog("Invoice type from Line Mapping " &amp; invType.description, LogTRACE.String);
			endif;
			return invType;
		endif;
	endforeach;

	if self.invoiceType &lt;&gt; null then
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog("Invoice type '" &amp; self.invoiceType.description &amp; "' from Line Type " &amp; self.narration, LogTRACE.String);  // ### TFS 2682
		endif;
	endif;
	
	return self.invoiceType; // if not mapped use the actual one
end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <ReturnType type="CM_InvoiceDesc"/>
    </JadeMethod>
    <JadeMethod name="getMinimumChargeGroupByAsStr" id="32d091f5-abcd-4863-a284-070d406a580b">
        <source>getMinimumChargeGroupByAsStr() : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 29/09/2015	cnwdap1		Initial creation PAR #36909 CCMS ADP 2537 Minimum Charge changes
//
vars

begin
	if self.minimumChargeGroupBy = self.GROUP_BY_NONE then
		return app.getErrorString(None);
	elseif self.minimumChargeGroupBy = self.GROUP_BY_INVOICE then
		return app.getErrorString(Invoice);
	elseif self.minimumChargeGroupBy = self.GROUP_BY_INVOICELINE then
		return app.getErrorString(Invoice_line);
	else
		return null;
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMinimumChargeGroupByFromStr" id="170ee7ca-4890-42f2-8965-3a8feb71dfe5">
        <source>getMinimumChargeGroupByFromStr(_str : String) : Integer;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/09/2015	cnwdap1		Initial creation PAR #36909 CCMS ADP 2537 Minimum Charge changes
//
vars

begin
	if _str = app.getErrorString(None) then
		return self.GROUP_BY_NONE;
	elseif _str = app.getErrorString(Invoice) then
		return self.GROUP_BY_INVOICE;
	elseif _str = app.getErrorString(Invoice_line) then
		return self.GROUP_BY_INVOICELINE;
	else
		return null;
	endif;
epilog

end;</source>
        <Parameter name="_str" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMinumumChargeDetailsUsed" id="182740ab-7888-4339-bd35-1fe179478f53">
        <source>getMinumumChargeDetailsUsed(_minimumType : CM_InvoiceLineDesc output;
							_minimumCharge : Decimal output;
							_isGroup : Boolean output);
/*

Date		Who		Reason
18 January 2017	cnwer1	Initial creation TFS 2903 now that we have minumum charges on the group get the 
						one that will be used i.e will me group if has one other wise self

*/

vars

begin
	if self.group &lt;&gt; null and self.group.myMinimumChargeInvoiceLineType &lt;&gt; null then
		_minimumType:=self.group.myMinimumChargeInvoiceLineType;
		_minimumCharge :=self.group.minimumChargeAmount;
		_isGroup	:= true;
	else
		_isGroup:=false;
		if self.minimumChargeInvoiceLineType &lt;&gt; null then
			_minimumType:=self.minimumChargeInvoiceLineType;
			_minimumCharge := self.minimumChargeAmount;
			
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_minimumType" type="CM_InvoiceLineDesc" usage="output"/>
        <Parameter name="_minimumCharge" type="Decimal" usage="output"/>
        <Parameter name="_isGroup" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getNumMappings" id="af7239a5-0a8f-4f6d-af0c-698fcf4188ad">
        <source>getNumMappings() : Integer;
/* ---------------------------------------------------------------------------
Created:     17 June 2008 by cnwrs2

Purpose:     PAR 17133 - return the number of mappings this invoice line has on the
			 Transaction Map
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars

	iter01 : Iterator;
	qtyMap : CM_QuantityRangeMap;
	oArray : ObjectArray;
	idx : Integer;
begin

/*
	create oArray transient;
	CM_QuantityRangeMap.allInstances(oArray,0,false);
	iter01 := oArray.createIterator;
	qtyMap := CM_QuantityRangeMap.firstInstance;
	iter01.startAtObject(qtyMap);
	
	while iter01.next(qtyMap) do
		if qtyMap.allInvoiceLineMaps.includes(self) then
			idx := idx + qtyMap.getNumberOfMappingsForLineType(self);
			if idx &gt; 0 then
				return 1;
			endif;
		endif;
	endwhile;
*/
	return 0;
	//return self.serviceBrokers.size;  this is not used anymore
	
	
	
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getPaymentType" id="edc34800-3be1-4d92-9263-685c9370bc23">
        <source>getPaymentType( _debtor : CM_Debtor ):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 October 2018	jlgndl1	Initial creation	TFS 41281

*/

vars

	bank : CM_Bank;
	terminal : CM_Terminal;
	paymentType : Integer;
	service : CM_Service;
	paymentTypeMapping : CM_ServicePayTypeMapping;

begin

	service := self.services.first;
	if service &lt;&gt; null then
		bank := service.bank;
		if bank &lt;&gt; null then
			terminal := bank.terminal;
		endif;
	endif;

	if _debtor &lt;&gt; null and terminal &lt;&gt; null then
		paymentType := _debtor.getDefaultPaymentType( terminal );
	else
		paymentType := 0;
	endif;

	if service &lt;&gt; null and bank &lt;&gt; null and _debtor &lt;&gt; null then
		paymentTypeMapping := bank.getServicePayTypeMapping( service, _debtor, true );	 // this debtor or otherwise the default debtor.
		if paymentTypeMapping &lt;&gt; null then
			paymentType := paymentTypeMapping.paymentType;
		endif;
	endif;
	
	return paymentType;

epilog

end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getServicesDesc" id="b9896356-2aa9-48b7-812a-686850310836">
        <source>getServicesDesc(_cr : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:		07 July 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aStr : String;
	aService : CM_Service;
begin

	foreach aService in self.services do
		if aStr = null then
			aStr := aService.name;
		else
			if _cr then
				aStr := aStr &amp; Cr &amp; aService.name;
			else
				aStr := aStr &amp; ", " &amp; aService.name;
			endif;
		endif;
	endforeach;
	return aStr;
end;</source>
        <Parameter name="_cr" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTaxCode" id="a30424e2-141b-4f73-ae48-9e77e555b10f">
        <source>getTaxCode(_description: Boolean) : String;
/*
Purpose:			
Date		Who		Reason
05 August 2015	cnwab1	Initial creation
3/11/17		MAP		Description option
*/

vars
	taxCode : String;
	theBank : CM_Bank;
	service : CM_Service;
begin
	theBank := self.getBank();
	
	service := self.services.first;
	if service &lt;&gt; null then
		taxCode := service.getTaxCode(_description);
	else
		taxCode := theBank.parentCompany.taxNarration;
	endif;
	
	
	return taxCode;
end;</source>
        <Parameter name="_description" type="Boolean"/>
        <ReturnType type="String"/>
