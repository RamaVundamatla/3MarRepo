    <JadeMethod name="updateTruckLayoutFrame" id="dd94ef50-d825-40cf-9883-04e5782f986a">
        <source>updateTruckLayoutFrame( gte : CMGTE_Entity input) protected;
/*

Date		Who		Reason
16 July 2014	cnwer1	Initial creation PAR CCMS 1386 ROB gate changes

*/

vars
	releaseROB : CMGTE_Entity;
begin
	if gte = null then
		return;
	endif;
	
	if gte.myParent &lt;&gt; null then
		return;
	endif;
	
	if not gte.isContainer then
		return;
	endif;
	
	if gte.isReceipt then
	//	if not gte.isKindOf(CMGTE_Container) then
		///	return;
	//	endif;
		self.myTrkFlexiLayIn.setContainer(1,gte.getID(),  self.myTrkFlexiLayIn.myDoorsCheckBox.value, gte);
		releaseROB:=gte.CMGTE_Receival.getReleaseROBGateEntity;
		if releaseROB &lt;&gt; null then
			self.myTrkFlexiLayOut.setContainer(1,releaseROB.getID(),  self.myTrkFlexiLayOut.myDoorsCheckBox.value, releaseROB);
		endif;
	else				
		self.myTrkFlexiLayOut.setContainer(1,gte.getID(),  self.myTrkFlexiLayOut.myDoorsCheckBox.value, gte);			
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="gte" type="CMGTE_Entity" usage="input"/>
    </JadeMethod>
