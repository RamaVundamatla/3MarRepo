    <JadeMethod name="cloneReferences" id="ca16cd2f-0f43-4250-b3b8-10ab8cc92800">
        <updating/>
        <source>cloneReferences(_obj: CMQF_SOHLocation; _transient: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     18 October 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	oldSOHReporter,
	newSOHReporter	: CMIF_SOHReporter;
	edition : Integer;	//18 July 2016	NDL	TFS 2329
	invalid : Boolean;	//18 July 2016	NDL	TFS 2329

begin
	inheritMethod(_obj, _transient);
	
	on Exception do app.handleDeletedObject( exception, oldSOHReporter, invalid );	//18 July 2016	NDL	TFS 2329
	
	foreach oldSOHReporter in _obj.allSOHReporters discreteLock do
	
		//18 July 2016	NDL	TFS 2329
		invalid := false;
		edition := oldSOHReporter.edition;
		if invalid then
			continue;
		endif;
		
		newSOHReporter := oldSOHReporter.cloneSelf(self.isTransient);
		newSOHReporter.cloneReferences(oldSOHReporter);
		self.allSOHReporters.add(newSOHReporter);
	endforeach;

end;</source>
        <Parameter name="_obj" type="CMQF_SOHLocation"/>
        <Parameter name="_transient" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="delete" id="39ff5ca8-40fd-4af0-8393-d9705e85dff2">
        <updating/>
        <source>delete() updating;
// ---------------------------------------------------------------------------
// Created:     12 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if not self.isTransient then
		//it's a persistent template object, else the transient SOH reporters 
		//get copy onto the jrwTransient, which will purge them apon deletion
		self.allSOHReporters.purge();
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="34463291-0fd8-4ff5-9180-52a8a44950dc">
        <source>getDisplayStringForAttribute(_attrName: String; _getCalculatedDate : Boolean): String;
// ---------------------------------------------------------------------------
// Created:     19/07/2010 cnwdz2	
//
// Purpose:     PAR24513 extend the current existing getDisplayStringForAttribute method to return an object's oid.		 
// ----------   ----------  --------------------------------------------------
vars
	oid : String;
begin
	return self.getOIDAndDescForAttribute(_attrName, _getCalculatedDate, oid);
/*
	if _attrName = ETRow_VoyageAllocated then //18/05/2009 cnwdz2 par19257 changed ETRow_Voyage to ETRow_VoyageAllocated
		if self.myVoyageGlobalAllocated &lt;&gt; null then
			return self.myVoyageGlobalAllocated.code;
		else
			return Any_String;
		endif;
	elseif _attrName = ETRow_VoyageActual then
		if self.myVoyageGlobal &lt;&gt; null then
			return self.myVoyageGlobal.code;
		else
			return Any_String;
		endif;
	
	endif;
	
	return inheritMethod(_attrName, _getCalculatedDate);

*/
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyVoyageGlobal" id="2b1083ab-a2a7-4c01-9d8d-2d0b74fc6dad">
        <source>getMyVoyageGlobal():CM_VoyageGlobal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

	object : CM_VoyageGlobal;
	edition : Integer;
	invalidObj : Boolean;

begin

	object := self.myVoyageGlobal;

	if object = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, object, invalidObj );
	edition := object.edition;
	
	if invalidObj then
		return null;
	endif;
	
	return object;

epilog

end;</source>
        <ReturnType type="CM_VoyageGlobal"/>
    </JadeMethod>
    <JadeMethod name="getMyVoyageGlobalAllocated" id="6cca771f-cc07-4aa8-974d-4362b3df63dd">
