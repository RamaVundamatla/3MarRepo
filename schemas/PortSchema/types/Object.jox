    <JadeMethod name="ndlDebug" id="a26cdd58-23b7-4ca7-9983-f7caf811d595">
        <source>ndlDebug( writeToo : Boolean; addData : String );

/*

Purpose:			
				useful in the likes of 'Teklogix' when debugging, where process debug
				and write are no use.....
				Creates an Alert that contains detail of what teh object looks
				like at the point in time that the method was called.
				Lists each property value...
Parameters:			

Return Value:		


Date		Who		Reason
30 January 2012	cnwndl1	Initial creation

*/

vars

	str : String;
	alert	: CM_SystemAlert;
	props : PropertyNDict;
	prop : Property;
	

begin

	process.isNDLref;

	str := method.qualifiedName &amp; " debug of " &amp; self.String;
	if writeToo then
		write str;
	endif;
	
	create alert transient;
	alert.details := str;
	
	if addData &lt;&gt; null then
		alert.addLogEntry(addData);
		if writeToo then
			write addData;
		endif;
	endif;
	
	create props transient;
	self.class.getPropertiesAllSuperclass(props);
	foreach prop in props  do
		str := "'" &amp; prop.name &amp; "' = '" &amp; self.getPropertyValue(prop.name).String &amp; "'";
		alert.addLogEntry(str);
		if writeToo then
			write str;
		endif;
	endforeach;
	alert.setSeverity(SEVERE_ERROR);
	alert.add;
	
	app.commitAlert();
	

epilog

	delete props;
	
end;</source>
        <Parameter name="writeToo" type="Boolean"/>
        <Parameter name="addData" type="String"/>
    </JadeMethod>
    <JadeMethod name="outputConfig" id="69c56bad-1689-463f-903a-0b41d2c8e262">
        <source>outputConfig(_file: File; _objArray:ObjectArray io; _exportReferences, _exportCollections, _outputEndTag : Boolean);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 April 2009	cnwjk3	Initial creation

*/

vars
	property	: Property;
	propColl	: PropertyNDict;
	object		: Object;
	char		: Character;
	str, message: String;
	boolean		: Boolean;
	int: Integer;
	time: Time;
begin

	// check if we have already been called. if so bugger off. 
	if _objArray.includes(self) then
		return;
	else
		_objArray.add(self);
	endif;
	create propColl transient;
	self.class.getPropertiesAllSuperclass(propColl);
	_file.writeLine("&lt;" &amp; self.class.name &amp; "&gt;");
	_file.writeLine("&lt;" &amp; self.class.name &amp; "Attributes&gt;");
	
	foreach property in propColl do
		if (not property.isKindOf(Attribute)) or
		   (property.virtual) or 
		   outputConfigAttrIgnoreXML(property.getName) then
			continue;
		endif;
		message := null;
		if property.type = StringArray then
			foreach str in self.getPropertyValue(property.getName).StringArray do
				message := message &amp; str &amp; ':';
			endforeach;
			message := message[1: message.length -1];
			_file.writeLine("&lt;"&amp;property.getName&amp;"&gt;"&amp;message&amp;"&lt;/"&amp;property.getName&amp;"&gt;");
		elseif property.type = CM_IntegerArray then
			foreach int in self.getPropertyValue(property.getName).CM_IntegerArray do
				message := message &amp; int.String &amp; ':';
			endforeach;
			message := message[1: message.length -1];
			_file.writeLine("&lt;"&amp;property.getName&amp;"&gt;"&amp;message&amp;"&lt;/"&amp;property.getName&amp;"&gt;");
		
		elseif property.type = CharacterArray then
			foreach char in self.getPropertyValue(property.getName).CharacterArray do
				message := message &amp; char.String &amp; ':';
			endforeach;
			message := message[1: message.length -1];
			_file.writeLine("&lt;"&amp;property.getName&amp;"&gt;"&amp;message&amp;"&lt;/"&amp;property.getName&amp;"&gt;");
			
			
		elseif property.type = IntegerArray then
			foreach int in self.getPropertyValue(property.getName).IntegerArray do
				message := message &amp; int.String &amp; ':';
			endforeach;
			message := message[1: message.length -1];
			_file.writeLine("&lt;"&amp;property.getName&amp;"&gt;"&amp;message&amp;"&lt;/"&amp;property.getName&amp;"&gt;");
		elseif property.type = TimeArray then
			foreach time in self.getPropertyValue(property.getName).TimeArray do
				message := message &amp; time.String &amp; ':';
			endforeach;
			message := message[1: message.length -1];
			_file.writeLine("&lt;"&amp;property.getName&amp;"&gt;"&amp;message&amp;"&lt;/"&amp;property.getName&amp;"&gt;");
		elseif property.type = BooleanArray then
			foreach boolean in self.getPropertyValue(property.getName).BooleanArray do
				message := message &amp; boolean.String &amp; ':';
			endforeach;
			message := message[1: message.length -1];
			_file.writeLine("&lt;"&amp;property.getName&amp;"&gt;"&amp;message&amp;"&lt;/"&amp;property.getName&amp;"&gt;");
		else
			_file.writeLine("&lt;"&amp;property.getName&amp;"&gt;"&amp;self.getPropertyValue(property.getName).String.trimBlanks&amp;"&lt;/"&amp;property.getName&amp;"&gt;");
		endif;
	endforeach;
	_file.writeLine("&lt;/" &amp; self.class.name &amp; "Attributes&gt;");
	
	if _exportReferences then
		_file.writeLine('&lt;' &amp; self.class.name &amp; 'References&gt;');
		self.outputConfigReferencesXML(_file, _objArray);
		_file.writeLine('&lt;/' &amp; self.class.name &amp; 'References&gt;');
	endif;
	
	if _exportCollections then
		_file.writeLine('&lt;' &amp; self.class.name &amp; 'Collections&gt;');
		self.outputConfigCollectionsXML(_file, _objArray);
		_file.writeLine('&lt;/' &amp; self.class.name &amp; 'Collections&gt;');
	endif;
	
	if _outputEndTag then
		_file.writeLine("&lt;/"&amp;self.class.name&amp;"&gt;");
	endif;
epilog
	delete propColl;
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
        <Parameter name="_exportReferences" type="Boolean"/>
        <Parameter name="_exportCollections" type="Boolean"/>
        <Parameter name="_outputEndTag" type="Boolean"/>
    </JadeMethod>
