    <JadeMethod name="getAllCriteriaValues" id="5dcef7bc-cc7e-419e-8721-980bc7db0339">
        <source>getAllCriteriaValues(_terminalObj:CM_Terminal; _allCriteriaValues: ObjectSet input; _filter : Integer; _allDependentObjs : CM_ObjectArray);
// --------------------------------------------------------------------------------
// Created:		07 March 2005 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//17 September 2013	cnwmc5	PAR 31255 - allowing dependent objects the criteria is based on.
// --------------------------------------------------------------------------------
begin
	app.myRoot.allWeightRanges.copy(_allCriteriaValues);
end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_allCriteriaValues" type="ObjectSet" usage="input"/>
        <Parameter name="_filter" type="Integer"/>
        <Parameter name="_allDependentObjs" type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaObjectForTi" id="c511c970-0c9c-4de4-8bb9-d0ede0e22ad3">
        <source>getCriteriaObjectForTi(_ti: CM_TrackedItem; _criteriaObject: CM_Object output; _process: Boolean output);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 January 2014	cnwndl1	Initial creation	Par 32310
	We need to find the weight range this would equate to.
	Check for ranges using the default weight measurement type first.

*/

vars

	defaultMeasureType : CM_MeasurementType;
	startObject : CM_WeightRange;
	weightInKgs : Decimal [14,4];
	weightInUnits : Decimal [16,4];
	iter : Iterator;
	weightRange : CM_WeightRange;
	measureType : CM_MeasurementType;

begin

	weightInKgs := _ti.totalWeight;	
	iter := app.myRoot.allWeightRanges.createIterator;
	
	defaultMeasureType := _ti.getDefaultMeasurementForType( Type_Weight );
	if defaultMeasureType &lt;&gt; null then
		//try to find one in the default weight type for this ti
		startObject := app.myRoot.allWeightRanges.getAtKeyGeq( defaultMeasureType, null );
		if startObject &lt;&gt; null then 
			iter.startAtObject(startObject);
			while iter.next( weightRange ) do
				if weightRange.myMeasurementType &lt;&gt; defaultMeasureType then
					//finished with default type
					break;
				endif;
				if weightRange.myMeasurementType.shortName = "kg" then
					// no need to convert, this is how it is stored...
					weightInUnits := weightInKgs;
				else
					measureType := weightRange.myMeasurementType;
					weightInUnits := (weightInKgs / measureType.conversionRate).roundedTo(measureType.getDecimalPrecision);
				endif;
				
				if weightRange.lower &lt;= weightInUnits and weightInUnits &lt;= weightRange.upper then
					_criteriaObject := weightRange;
					return;
				endif;
				
			endwhile;
		
			delete iter;
			iter := app.myRoot.allWeightRanges.createIterator;
		endif;
	endif;
	
	//Ok so just use any old measurement type we find
	while iter.next( weightRange ) do
		if weightRange.myMeasurementType = defaultMeasureType then
			//already done these
			continue;
		endif;
		if weightRange.myMeasurementType.shortName = "kg" then
			weightInUnits := weightInKgs;
		else
			measureType := weightRange.myMeasurementType;
			weightInUnits := (weightInKgs / measureType.conversionRate).roundedTo(measureType.getDecimalPrecision);
		endif;
		
		if weightRange.lower &lt;= weightInUnits and weightInUnits &lt;= weightRange.upper then
			_criteriaObject := weightRange;
			return;
		endif;
		
	endwhile;

	return;

epilog

	delete iter;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_criteriaObject" type="CM_Object" usage="output"/>
        <Parameter name="_process" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaValueForTi" id="fb28dae5-3a67-4358-a9a0-5f77b953391e">
        <source>getCriteriaValueForTi(_ti: CM_TrackedItem; _criteriaValue: Any output);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/11/2010	cnwdap1	Initial creation PAR #26184
*/
vars

//	defaultMeasureType : CM_MeasurementType;
//	weightInKgs : Decimal [14,4];

begin
	//_criteriaValue := _ti.weightCargo;
	
	_criteriaValue := 0;	//28 Feb 2014	NDL	Par 33607 This should only be object based, never return a value
	return;
	
/*	//07 Jan 2014	NDL	Par 32310
	weightInKgs := _ti.totalWeight;
	_criteriaValue := weightInKgs.asStringJMT();
	
	if weightInKgs = 0 then
		// no value, just return.
		return;
	endif;
	
	defaultMeasureType := _ti.getDefaultMeasurementForType( Type_Weight );
	if defaultMeasureType = null then
		//Not using measurement types, just return
		return;
	endif;
	
	_criteriaValue := defaultMeasureType.convertMeasurementForDisplay( weightInKgs );
	
	*/

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_criteriaValue" type="Any" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getDataDisplay" id="4a6a7185-1a51-418d-94e8-2dca7f2ece10">
        <source>getDataDisplay(pDataObj: CM_YAData): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 August 2008	cnwdw1
30 July 2024	navrv30	Bug 64703: FR | 53383 - Release Request by Type - Cargo Group - Measurement Type

*/

vars
	measureType	: CM_MeasurementType;
	valueStr : String;
begin
	measureType := app.getDefaultMeasurementForType(Type_Weight);
	valueStr := pDataObj.getDataValue().String;
	if measureType &lt;&gt; null and valueStr &lt;&gt; null then
			valueStr := app.convertMeasurementForDisplay(measureType.shortName, valueStr.Decimal);
			return valueStr &amp; " " &amp; measureType.shortName;
	endif;
	return valueStr;
epilog

end;</source>
        <Parameter name="pDataObj" type="CM_YAData"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="1e3cb712-55a8-46b8-97af-aa0b4e187bec">
        <source>getDisplay(dataObj : Object) : String;
//01 August 2008	cnwdw1
begin
	return dataObj.CM_WeightRange.getYADisplay();
end;</source>
        <Parameter name="dataObj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getObjects" id="79308041-3657-4822-bddb-fa6c16ac2476">
        <source>getObjects(objects: ObjectLongNameDict input);

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
18 December 2008	consw1	Initial creation

*/

vars
	wr : CM_WeightRange;
	
begin
	foreach wr in app.myRoot.allWeightRanges do
		objects[wr.getYAIdentifier] := wr;
	endforeach;

epilog

end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
