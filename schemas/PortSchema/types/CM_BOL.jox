    <JadeMethod name="getEarliestScalingStartTs" id="224c6b7b-404f-43bf-a328-fc60a6e7e99e">
        <source>getEarliestScalingStartTs() : TimeStamp;

vars

	trns		: CM_BOLTransaction;
	scalerTrns	: CM_BOLInScalerTransaction;
	ts			: TimeStamp;

begin

	// Go through transactions because dictionary is ordered by when transaction
	// was created not scaler times.
	ts := null;
	foreach trns in self.allBOLTransactions do
		if trns.type = TRANS_TYPE_BOLIN_SCALER then
			scalerTrns := trns.CM_BOLInScalerTransaction;
			if scalerTrns.scalingStartTime &lt; ts or ts = null then
				ts := scalerTrns.scalingStartTime;
			endif;
		endif;
	endforeach;
	return ts;

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getEarliestSclngStartTsLocTZ" id="84eaeef0-07bc-41ae-9ee1-2e3227bf5359">
        <source>getEarliestSclngStartTsLocTZ():TimeStamp;
/*

Purpose:			Return the local timezone version of the receiver's dateTime (for JRW)

Parameters:			None

Return Value:		

Date		Who		Reason
19 May 2016	cnwns1	TFS 488 - Multi Timezone Support

*/

vars
	
begin

	return self.systemToLocalTime(self.getEarliestScalingStartTs());
	
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getEmptyBOLDiscrepancyValue" id="6375e29e-b573-482e-9564-48261923e2c2">
        <source>getEmptyBOLDiscrepancyValue( _qty : Integer output; _weight : Decimal output ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 January 2018	jlgndl1	Initial creation	TFS 8165

*/

vars

	bolTrx : CM_BOLTransaction;
	bolTfr : CM_BOLTransferTransaction;
	iter : Iterator;

	ti : CM_TrackedItem;
	invalidTi : Boolean;
	edition : Integer;
//	cargoType : CM_CargoType;
	
	multiplier : Integer;
	bolWt : Real;
	bolQty : Integer;
	
begin
	
	on Exception do app.handleDeletedObject( exception, ti, invalidTi );
	
	iter := self.allBOLTransactions.createIterator;
	while iter.next( bolTrx ) do
		if bolTrx.type &lt;&gt; TRANS_TYPE_BOL_TRANSFER then
			continue;
		endif;
		
		bolTfr := bolTrx.CM_BOLTransferTransaction;
		
		//16 Jan 2018	NDL	TFS 36657
		if bolTfr.fromBolNumber.trimBlanks = null or bolTfr.toBolNumber.trimBlanks = null then
			// and simple assign or unassign, we only want transfers.
			continue;
		endif;
		
		ti := bolTfr.myTrackedItem;
		if ti = null then
			continue;
		endif;
		invalidTi := false;
		edition := ti.edition;
		if invalidTi then
			continue;
		endif;
		
		if ti.isContainer then
			//ignore containers
			continue;
		endif;
		
		if ti.isChild and ti.myParent.isContainer then
			//ignore things in containers...
			continue;
		endif;
		
		if not ti.isDischargedFromCurrentVoyage() then
			continue;
		endif;
		
	//	cargoType := ti.myCargoType;
		
		if bolTfr.isTransferIn then
			multiplier := -1;
		else
			multiplier := 1;
		endif;
		
	//	if cargoType.isBulkByVolume
	//	or cargoType.isBulkByWeight
	//	then
			bolWt := bolTfr.weight * multiplier;
			_weight := _weight + bolWt;
	//	else
			bolQty := bolTfr.quantity * multiplier;
			_qty := _qty + bolQty;
	//	endif;
		
	endwhile;
	
	return _weight &lt;&gt; 0 or _qty &lt;&gt; 0;

epilog

	delete iter;

end;</source>
        <Parameter name="_qty" type="Integer" usage="output"/>
        <Parameter name="_weight" type="Decimal" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getExtensionClass" id="b5a6a402-40f4-46fb-ae37-c339cd79d920">
        <source>getExtensionClass() : Class;
// ---------------------------------------------------------------------------
// Created:     25 June 2002 by cnwrs2
//
// Purpose:     Get class from CM_BOLType eventually but encapsulate here for now
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	extClass	: Class;
	
begin

	if self.bolType = BOLType_Log then
		if self.isReleaseDocket then
			extClass := CM_BOLExtLogOut;
		else
			extClass := CM_BOLExtLogIn;
		endif;
	else
		extClass := null;
	endif;

	return extClass;

end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="b81ba436-3ebd-4e05-ab9f-e0830dd509de">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
//--------------------------------------------------
// Created:	10 February 2006 By: cnwgd1
//--------------------------------------------------
// 24 June 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	block : CM_DataContainerBlock;
	dateTimeLocal : TimeStamp;
begin
	
	inheritMethod(_dataContainer);

	block := _dataContainer.addNewBlock;
	block.addNewItem('Date', DC_Label, 1, self);
	dateTimeLocal := self.systemToLocalTime(self.dateTime);// 24 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	block.addNewItem(dateTimeLocal.shortCurrentLocaleFormat(), DC_Data, 1, self);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem('BOL Type', DC_Label, 1, self);
	block.addNewItem(self.bolTypeDesc, DC_Data, 1, self);
	
	if self.myConsignor &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem('Consignor', DC_Label, 1, self);
		block.addNewItem(self.myConsignor.description, DC_Data, 1, self);
	endif;

	if self.myConsignee &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem('Consignee', DC_Label, 1, self);
		block.addNewItem(self.myConsignee.description, DC_Data, 1, self);
	endif;

	block := _dataContainer.addNewBlock;
	block.addNewItem('Port of Loading', DC_Label, 1, self);
	block.addNewItem(self.loadPortCode, DC_Data, 1, self);	

	if self.myOperator &lt;&gt; null then										// 15/10/2010 cnwmh5 #26057
		block := _dataContainer.addNewBlock;
		block.addNewItem('Shipper', DC_Label, 1, self);
		block.addNewItem(self.myOperator.description, DC_Data, 1, self);
	endif;

	if self.myPlannedLocation &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem('Planned Location', DC_Label, 1, self);
		block.addNewItem(self.myPlannedLocation.getFullId(), DC_Data, 1, self);
	endif;

	block := _dataContainer.addNewBlock;
	block.addNewItem('Quantity', DC_Label, 1, self);
	block.addNewItem(self.numTIs.String, DC_Data, 1, self);			

	block := _dataContainer.addNewBlock;
	block.addNewItem('Transport Mode', DC_Label, 1, self);
	block.addNewItem(app.transModeToString(self.transportMode), DC_Data, 1, self);			
	
	block := _dataContainer.addNewBlock;
	block.addNewItem('Truck Number', DC_Label, 1, self);
	block.addNewItem(self.truckNumber, DC_Data, 1, self);				

	block := _dataContainer.addNewBlock;
	block.addNewItem('Trailer Number', DC_Label, 1, self);
	block.addNewItem(self.trailerNumber, DC_Data, 1, self);						

	block := _dataContainer.addNewBlock;
	block.addNewItem('Gross Weight Tonnes', DC_Label, 1, self);
	block.addNewItem(self.weightGrossTonnes.String, DC_Data, 1, self);							
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getFirstTICargoTypeId" id="7f728c3f-a431-497b-957f-e97abd6f3c3b">
