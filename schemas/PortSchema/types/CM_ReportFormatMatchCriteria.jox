    <JadeMethod name="pxyCreateUpdateProxy" id="7dd43109-a7b8-4681-b9a2-f3bf3efe8d83">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 January 2019	jlgndl1	Initial creation

*/

vars

	pxyObjMatchCrit : CM_ReportFormatMatchCriteria;
	completedOK : Boolean;

begin
	pxyObjMatchCrit := inheritMethod();
	
	pxyObjMatchCrit.myPrinter := self.myPrinter;

	completedOK := true;
	
	return pxyObjMatchCrit;

epilog

	if not completedOK then
		delete pxyObjMatchCrit;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
