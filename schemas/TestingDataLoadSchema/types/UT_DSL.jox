    <JadeMethod name="updateGate" id="629baa6e-9728-4d3b-bf3f-f09bbd7a1148">
        <source>updateGate(_gate : Any);

/*

Purpose:		Update the Gate Details

Date			Who		Reason
04/02/2014		cnwmh5	Initial creation

*/

vars

	pxyGate					: CM_Gate;
	gate					: CM_Gate;
	obj						: Object;
	
	objArray				: ObjectArray;

begin

	self.assertNotNull(_gate);

	if _gate.isKindOf(String) then
		gate := self.getGate(_gate.String);
		self.assertNotNull(gate);
	elseif _gate.isKindOf(CM_Gate) then
		gate := _gate.CM_Gate;
	endif;

	beginLoad;
	pxyGate := gate.pxyCreateUpdateProxy();
	endLoad;
	
	if opts.includesKey("SealCheckRelease") then
		pxyGate.setSealCheckRelease(opts.int("SealCheckRelease"));
	endif;
	
	app.myTrxUA.trxUpdateGate(pxyGate, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog
	
	create objArray transient;
	pxyGate.allGateAreas_IN.copy(objArray);
	pxyGate.allGateAreas_OUT.copy(objArray);
	foreach obj in objArray do
		obj.CM_GateAreaUsage.erase(NORMAL_ERASE);
	endforeach;
	delete objArray;
	delete pxyGate;

end;</source>
        <Parameter name="_gate" type="Any"/>
    </JadeMethod>
