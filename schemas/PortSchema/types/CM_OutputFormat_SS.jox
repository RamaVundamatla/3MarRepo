    <JadeMethod name="setForCreate" id="df208fad-ffab-4b09-88f0-a890bc1fb688">
        <updating/>
        <source>setForCreate(_proxy: SelfType) updating;
// ---------------------------------------------------------------------------
// Created:     15 December 2009 by cnwcs5
// Purpose:     CCMS 1023 - snapshot summaries
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_proxy);
	// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1
	self.myBankToCharge := _proxy.myBankToCharge;
	self.mySelectorQuery := _proxy.mySelectorQuery;
	self.setMyCM_Root( app.myRoot );
epilog

end;</source>
        <Parameter name="_proxy" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="f3a937ac-dfbb-4e1c-83a9-651ebe6a02dc">
        <updating/>
        <source>setForUpdate(_proxy: CM_OutputFormat_SS) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 December 2009	cnwndl1	Initial creation	CCMS 1023
Oct 2010	cnwjre1	CCMS 1043 Snapshot Summary Invoicing

*/

vars
	heading	: String;
	headingArray	: StringArray;
	index	: Integer;
	grouping, pxyGrouping		:CM_XTABGrouping;
	field, pxyField	:CM_XTABField;
	ssb		: CM_SnapShotServiceBroker;
	ia		: CM_InvoiceAllocation;
	ya		: CM_YardAllocation;
begin
	self.raiseExceptionIfTransient (method);
	
	self.exclusiveLock (self);
	
	inheritMethod (_proxy);
	
	self.mode := _proxy.mode;
	self.type := _proxy.type;
	// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1
	self.myBankToCharge := _proxy.myBankToCharge;
	self.mySelectorQuery := _proxy.mySelectorQuery;
	// save off all field usage in summary snapshots
	create headingArray transient;
	foreach ssb in self.allServiceBrokers do
		foreach ya in ssb.allInvoiceAllocations do
			ia := ya.CM_InvoiceAllocation;
			headingArray.add(ia.myQuantityMap.mySnapShotQuantityType.heading);
		endforeach;
	endforeach;

	// clear out all current children and re-create them later
	self.allFields.purge;
	self.allGroupings.purge;
	
	
	// create fields
	foreach pxyField in _proxy.allFields do
		field := pxyField.cloneSelf (false);
		self.allFields.add (field);
	endforeach;
	// restore field usage in summary snapshots
	foreach ssb in self.allServiceBrokers do
		foreach ya in ssb.allInvoiceAllocations do
			ia := ya.CM_InvoiceAllocation;
			index := index + 1;
			heading := headingArray[index];
			foreach field in self.allFields do
				if field.heading = heading then
					break;
				endif;
			endforeach;
			// use the last one if no match - arbitrary decision ***
			ia.myQuantityMap.setAllocationDetails(ia, field);
		endforeach;
	endforeach;
	
	// create groupings
	foreach pxyGrouping in _proxy.allGroupings do
		grouping := pxyGrouping.cloneSelf (false);
		self.allGroupings.add (grouping);
	endforeach;
	
	// cause the required user notification immediately
	self.causeEvent( EVENT_SummaryTable_Update, false, process.userCode );
	
epilog
	delete headingArray;
end;</source>
        <Parameter name="_proxy" type="CM_OutputFormat_SS"/>
    </JadeMethod>
