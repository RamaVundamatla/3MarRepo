    <JadeMethod name="validateMe" id="1f774f81-310f-4786-be95-5257e54e1a03">
        <source>validateMe() protected;
/*

Purpose:			Validates that data sets have been set properly. Used for both create and update

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
04 April 2022	navpw1	Initial creation TFS: 52773

*/

vars
	missingTruckInfo,
	missingDriverInfo,
	weightInfoMissing,
	cargoMissing,
	chassisInfoMissing	: Boolean;
	cargoItem			: CM_CargoScanRecordData;
	
begin
	// If we have Truck data, then at least the rego OR bat number is mandatory
	if self.licenseNumber = "" and self.batNumber = "" then
		missingTruckInfo := true;
	endif;
	
	// If we have Driver data, then at least the code or name is mandatory
	if self.driverCode = "" and self.driverName = "" then
		missingDriverInfo := true;
	endif;
	
	// if we have Weight data, then the scaleWeight is mandatory
	if self.scaleWeight = 0 then
		weightInfoMissing := true;
	endif;
	
	// If we have Cargo data, then at least the id and type are mandatory
	if self.allCargoItems.size = 0 then
		cargoMissing := true;
	else
		foreach cargoItem in self.allCargoItems as CM_CargoScanRecordData do			
			if cargoItem.id = "" or cargoItem.type = "" then
				cargoMissing := true;
				break;
			endif;
		endforeach;
	endif;
	
	// If we have Chassis data, then the id is mandatory
	if self.chassisId = "" then
		chassisInfoMissing := true;
	endif;
	
	// If we have *nothing* then complain!
	if missingTruckInfo and missingDriverInfo and weightInfoMissing and cargoMissing and chassisInfoMissing then
		app.raiseCMException(Data_Sets_Missing, null, null);
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
