<CollClass name="DecimalArray">
    <JadeMethod name="jssDoSort" id="5846d610-1325-4ba2-8bc7-ba35ed8cca3f">
        <lockReceiver/>
        <updating/>
        <source>jssDoSort(pTheSorter : JSSSorter) lockReceiver, updating, protected;
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Purpose:		Refer to method implementation on the Array class.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	arrayPointer	: Integer;
	decimalValue	: Decimal[23,2];
	theSortKey		: Object;
	anyValue		: Any;

begin
	foreach decimalValue in self do
		pTheSorter.addValue(decimalValue);
	endforeach;
	
	self.purge();
	
	foreach theSortKey in pTheSorter.mySortColl do
		self.add(theSortKey.JSSSortKey.getValue().Decimal);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pTheSorter" type="JSSSorter"/>
    </JadeMethod>
</CollClass>
