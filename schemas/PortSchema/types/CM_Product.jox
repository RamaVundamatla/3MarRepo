    <JadeMethod name="getCargoSubTypeGroupCode" id="4d3319fa-aa16-43ea-9f88-47c984ae0fc4">
        <source>getCargoSubTypeGroupCode() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
25 March 2022		jlizm1	Initial creation TFS 53082 GPHA Additional Fields in SQL Data Extracts

*/

vars

	productGroup 	: CM_ProductGroup;
	invalid 		: Boolean;
	
begin
	
	productGroup := self.myProductGroup;
	
	if productGroup = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject(exception, productGroup, invalid);
	productGroup.edition();
	if invalid then
		return null;
	endif;
	
	return productGroup.code;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
