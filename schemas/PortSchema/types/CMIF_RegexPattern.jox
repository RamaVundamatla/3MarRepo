    <JadeMethod name="replaceAll" id="0e05d9fb-23f8-45c6-933f-67b6c1a34a95">
        <source>replaceAll(_text: String io);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 January 2024		navmd1	Initial creation TFS 57278 Refactor string manipulation post JADE2022

*/

vars

begin
	_text := self.myRegexPattern.replaceAll(_text, self.replacementText);
epilog

end;</source>
