    <JadeMethod name="moveTrackedItemsSource" id="4d14c059-8d93-4f56-a27a-e3e553a4beb1">
        <updating/>
        <source>moveTrackedItemsSource(_table: CM_DataTable) updating;
// ---------------------------------------------------------------------------
// Created:		07 September 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	moveController	: CMIF_MoveController;
	result	: Integer;
	anLC : CM_LocationsController;
	aSC : CM_SlotController;
	aRC : CM_VoyageROROController;
	aJob : CM_Job;
begin
	
	self.mousePointer := Window.MousePointer_HourGlass;
	if app.myMoveController = null then
		return;
	endif;
	
	moveController := app.myMoveController;
	
	foreach anLC in 	moveController.allToLocations do
		if anLC.isKindOf(CM_SlotController) then
			aSC := anLC.CM_SlotController;
			if aSC.mySlotRequestLoad &lt;&gt; null then
				if aSC.mySlotRequestLoad.myJob &lt;&gt; aJob and aJob &lt;&gt; null then
					app.msgBox("Bulk Planning must be for same job","Bulk Plan Issue", MsgBox_Exclamation_Mark_Icon);
					return;
				endif;
				aJob := aSC.mySlotRequestLoad.myJob;
				if aJob = null then
					app.msgBox("Bulk Planning must be for colour coding that is in a job","Bulk Plan Issue", MsgBox_Exclamation_Mark_Icon);
					return;
				endif;
			else
				app.msgBox("Bulk Planning must be for slots that have colour coding that are in a job","Bulk Plan Issue", MsgBox_Exclamation_Mark_Icon);
				return;
			
			endif;
		elseif anLC.isKindOf(CM_VoyageROROController) then
			aRC := anLC.CM_VoyageROROController;
			if aRC.myRORORequestLoad &lt;&gt; null then
				if aRC.myRORORequestLoad.myJob &lt;&gt; aJob and aJob &lt;&gt; null then
					app.msgBox("Bulk Planning must be for same job","Bulk Plan Issue", MsgBox_Exclamation_Mark_Icon);
					return;
				endif;
				aJob := aRC.myRORORequestLoad.myJob;
				if aJob = null then
					app.msgBox("Bulk Planning must be for colour coding that is in a job","Bulk Plan Issue", MsgBox_Exclamation_Mark_Icon);
					return;
				endif;
			else
				app.msgBox("Bulk Planning must be for slots that have colour coding that are in a job","Bulk Plan Issue", MsgBox_Exclamation_Mark_Icon);
				return;
			
			endif;
		endif;
	endforeach;



	inheritMethod(_table);
epilog
	self.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="_table" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="quitSummaryMode" id="0dfaa5c9-f961-4369-8009-b9d1e9447fe6">
        <updating/>
        <source>quitSummaryMode()updating;
//----------------------------------------------------------------
//	Created:	27 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------


// 25 Jan 2012	NDL	Par 25297
vars

begin
	
	self.statusStub := "";

	self.frmStatLine.caption := " Selected: 0";

	self.btnQuitSmmryMode.helpKeyword := "";
	
	self.btnQuitSmmryMode.enabled := false;
	self.mode := self.Mode_Enquire;
	self.updateShtCaptions();
	self.doFldMainClick();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="removeSRFromSummary" id="764b2f32-3014-4e75-8e1b-8f362b839217">
        <updating/>
        <source>removeSRFromSummary(_req: CM_Request) updating, protected;
//----------------------------------------------------------------
//	Created:	29 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	sumDict				: CMIF_LoadListSumByImexDischISO;
	sumObjectOld,
	sumObject			: CMIF_LoadListSummaryObject;
	deleteSum			: Boolean;
begin
	//remove the SR

	if self.mySummaryReport = null 
	or self.mySummaryReport.allGroupedObjects.isEmpty then
		return;
	endif;
	
	create sumDict transient;	//think about keeping this on the form

	self.mySummaryReport.allGroupedObjects.copy(sumDict);
	
	//search for it (also see if old sumObj is still required)
	foreach sumObject in sumDict do
		if sumObject.allLoadRequests.includes(_req) then
			deleteSum := (sumObject.allTrackedItems.size = 1) and (sumObject.allLoadRequests.isEmpty); 
			sumObjectOld := sumObject;
			break;	
		endif;
	endforeach;
	
	if sumObjectOld &lt;&gt; null then
		//ti does not belong here
		sumObjectOld.allLoadRequests.remove(_req);
		sumObjectOld.redoTotalsForSR;
	endif;

epilog
	delete sumDict;
end;</source>
        <access>protected</access>
        <Parameter name="_req" type="CM_Request"/>
    </JadeMethod>
    <JadeMethod name="resetSummaryCriteria" id="a989849a-a33d-4aeb-9082-16f1a9ced83d">
        <source>resetSummaryCriteria();
//----------------------------------------------------------------
//	Created:	29 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	filter	: CMQF_VoyageLoadListSummary;
begin

	filter := self.mySummaryFilter;
	
	filter.allCargoTypes.clear;
	filter.allOperators.clear;
	filter.allPortsDischarge.clear;

	filter.setMyVoyage ( self.myCurrentVoyage );
	self.lstCargoTypes.allSelectedObjects.copy(filter.allCargoTypes);
	self.lstOperators.allSelectedObjects.copy(filter.allOperators);
	self.lstPorts.allSelectedObjects.copy(filter.allPortsDischarge);

end;</source>
    </JadeMethod>
    <JadeMethod name="resortTableObjects" id="b4ec6352-d7b6-453c-b3cf-9de39e812fe9">
        <updating/>
        <source>resortTableObjects(_theTable: CM_DataTable input) updating;
//--------------------------------------------------
// Created:	09 September 2005 By: cnwgd1
//--------------------------------------------------
vars
	numRows,
	idx : Integer;
	obj : Object;
begin

	_theTable.initTableObjectsDynaDict(CM_TrackedItem, _theTable.myEntTableDef.allEntTableRows.size);
	
	idx := _theTable.fixedRows;
	_theTable.rows := idx;

	foreach obj in _theTable.allTableObjects do
		if CM_TrackedItem.hasInstance(obj) then
			self.doQueryAddItem(_theTable, 0, obj.CM_TrackedItem, null);
		endif;
	endforeach;

	self.doTblDataRenumberItems(_theTable, 0);
	
	if global.isValidObject(self.myCurrentTrackedItem) then
		_theTable.selectObject(self.myCurrentTrackedItem, false);
	else
		self.myCurrentTrackedItem := null;
	endif;
		
end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="selectAll" id="f40b016e-813c-4971-b338-e4259cee10cb">
        <source>selectAll();
// ---------------------------------------------------------------------------
// Created:		19 September 2005  By Andrew Bishop cnwab1
//
// Purpose:		selects all the items in a TABLE
//
// ---------------------------------------------------------------------------

vars
	theTable : CM_DataTable;
begin
	if self.fldMain.topSheet = self.shtNonplanned then
		theTable := self.tblData;
	elseif self.fldMain.topSheet = self.shtPlanned then
		theTable := self.tblPlanned;
	elseif self.fldMain.topSheet = self.shtDLR then
		theTable := self.tblDLR;
	elseif self.fldMain.topSheet = self.shtTranship then
		theTable := self.tblTranShip;
	elseif self.fldMain.topSheet = self.shtTBA then // TFS 45590
		theTable := self.tblTBA;
	elseif self.fldMain.topSheet = self.shtSummary then
		theTable := self.tblSummary;
	elseif self.fldMain.topSheet = self.shtAll then
		theTable := self.tblAll;
	endif;

//	if theTable.allSelectedObjects.size &lt;&gt; (theTable.rows - theTable.fixedRows).Integer then  PAR 11045
	if self.mnuContextSelectAll.caption = app.getErrorString(SelectAll) then
		if self.fldMain.topSheet = self.shtSummary then
			self.selectAllSummary();
		else
			theTable.selectAll();
		endif;
		
		
		self.btnSelectAllTIs.bubbleHelp := app.getErrorString(SHP_UnSelect_Al);
		self.mnuContextSelectAll.caption := app.getErrorString(SHP_UnSelect_Al);
	else
		//theTable.deselectAll(); AER 17821
		self.btnSelectAllTIs.bubbleHelp := app.getErrorString(SelectAll);
		self.mnuContextSelectAll.caption := app.getErrorString(SelectAll);
	endif;

	//update the status caption
	self.frmStatLine.caption := self.statusStub &amp; " " &amp; app.getErrorString(SHP_Selected) &amp; self.tblData.allSelectedObjects.size.asStringJMT;

end;</source>
    </JadeMethod>
    <JadeMethod name="selectAllSummary" id="339a9237-408e-419a-997d-5b614a0c352e">
        <source>selectAllSummary();
// ---------------------------------------------------------------------------
// Created:		23 February 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theTable : CM_DataTable;
	numRows,
	rowIdx		: Integer;
	jRow		: JadeTableRow;
begin
	theTable := self.tblSummary;
	numRows := theTable.rows;
	theTable.allSelectedObjects.clear();

	foreach rowIdx in theTable.fixedRows to numRows do
		jRow := theTable.accessRow(rowIdx);
		if not jRow.visible then
			//only select visible rows PAR 11045
			continue;
		endif;
		if jRow.itemObject = null then
			continue;
		endif;
		if jRow.itemObject.CMIF_LoadListSummaryObject.isoGroupingKey = null then
			continue;
		endif;
		
		jRow.selected := true;
		if jRow.itemObject &lt;&gt; null then
			theTable.allSelectedObjects.add(jRow.itemObject);
		endif;
	endforeach;


end;</source>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="c058ff66-07f7-46e1-a16b-81d9a05b574a">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     30 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpBackColor		: Integer;
	
begin
	
	inheritMethod(_colorControl);
	tmpBackColor := self.backColor;

	self.fldMain.backColor := tmpBackColor;
	self.shtDLR.backColor := tmpBackColor;
	self.shtTranship.backColor := tmpBackColor;
	self.shtTBA.backColor := tmpBackColor; // TFS 45590
	self.shtPlanned.backColor := tmpBackColor;
	self.shtSummary.backColor := tmpBackColor;
	self.shtNonplanned.backColor := tmpBackColor;
	self.shtAll.backColor := tmpBackColor;
	self.frmPreferences.backColor := tmpBackColor;
	self.setColorsForTable(self.tblDLR);
	self.setColorsForTable(self.tblTranShip);
	self.setColorsForTable(self.tblPlanned);
	self.setColorsForTable(self.tblDLRInfo);
	self.setColorsForTable(self.tblPlannedInfo);
	self.setColorsForTable(self.tblAll);
		
end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setColours" id="d349e5e7-7c36-471d-803f-53d6b55c53af">
        <updating/>
        <source>setColours() updating;
// ---------------------------------------------------------------------------
// Created:     10 January 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if self.xmlColourPlanned = 0 then
		self.xmlColourPlanned := self.ColourYellowLight;
	endif;
	if self.xmlColourNonPlanned = 0 then
		self.xmlColourNonPlanned := self.ColourYellowLight;
	endif;
