    <JadeMethod name="cmbPackageType_click" id="7b6268bb-a232-48e4-bebb-b55cf42f13d8">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbPackageType_click(combobox: ComboBox input) updating;

// Created by cnwdvb1 on 26 June 2006
// 11/07/2017 cnwma1	 TFS #4581:1086 error in Package Maintenance
// 13/02/2024 navra1	 CR 61910/Task 62303 - EUP | API Create default package to run on invoice updating status to POSTED
// JIRA 35466 29JUL NAVAB1 convert to parent aSPECT.
vars

begin

	if combobox.listIndex = -1 then
		return;
	endif;
	self.myProxyObject := null;  //11.07.2017 cnwma1 4581
	self.selectPackageType(combobox.itemData[combobox.listIndex]);
	
	//navra1 - CR 61910/Task 62303 - 13th Feb 2024 - start
	if combobox.text = "Invoice Package" then
//		txtToAddress.width := 187;
//		txtSubject.width := 187;
		chkSendToDebtorEmail.visible := true;
		chkPrefixEmailSubWithInvNo.visible := true;
		chkAttachExtAttOfInv.visible := true;
//		txtMessage.top := 162;
//		lblMessage.top := 146;
	else
//		txtToAddress.width := 334;
//		txtSubject.width := 334;
		chkSendToDebtorEmail.visible := false;
		chkPrefixEmailSubWithInvNo.visible := false;
		chkAttachExtAttOfInv.visible := false;
//		txtMessage.top := 139;
//		lblMessage.top := 122;
	endif;
	//navra1 - CR 61910/Task 62303 - 13th Feb 2024 - end

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbTerminalCams_click" id="edb97163-23bc-4274-be51-24d243b57928">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbTerminalCams_click(_combobox: ComboBox input) updating;

vars
	terminal : CM_Terminal;
begin
	self.cmbCamsProtocol.enabled := true;
	
	terminal := _combobox.listObject.CM_Terminal;
	
	if terminal &lt;&gt; null then
		self.cmbCamsProtocol.listCollection(terminal.camProtocols, true, 0);

		if terminal.camProtocols.size &gt; 0 then
			self.cmbCamsProtocol.listIndex := 1;
		endif;
	endif;
end;
</source>
        <Parameter name="_combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
