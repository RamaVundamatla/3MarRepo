    <JadeMethod name="loadMovementAdd" id="0cfed53c-448c-48e4-a01d-6cfaa642ea17">
        <source>loadMovementAdd(_movementAddProxy:HMS_MovementAdd io) :Boolean protected;

vars
	realHMSTransaction: HMS_Transaction;
//	realObject, proxyObject: HMS_MovementAdd;
	error: CM_Error;
	theTerminal: CM_Terminal;
	transController: CMIF_HMS_TransactionController;
	workingMovementCtrl: CMIF_HMS_WorkingMovement;
	workingVoyageCtrl: CMIF_HMS_WorkingVoyage;
//	countError,countOK: Integer;
begin
	if _movementAddProxy.myMovement = null then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_movementAddProxy.transactionDT.String&amp;" ERROR: "&amp;"No Voyage Movement.",0);
		return false;
	endif;
	if _movementAddProxy.myHMSVoyageData = null then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_movementAddProxy.transactionDT.String&amp;" ERROR: "&amp;"No Voyage Data.",0);
		return false;
	endif;
	beginTransaction;
	create transController transient;
	create workingMovementCtrl transient;
	create workingVoyageCtrl transient;
	transController.myWorkingMovement := workingMovementCtrl;
	workingMovementCtrl.myWorkingVoyage := workingVoyageCtrl;

	//workingMovementCtrl.myWorkingVoyage.ofVessel := app.myRoot.allVessels[_movementAddProxy.myHMSVoyageData.myVoyage.vesselCode];	

	transController.myVoyageMovement := _movementAddProxy.myMovement.HMS_VoyageMovement;
	transController.myHMSVoyageData := _movementAddProxy.myMovement.HMS_VoyageMovement.myHMSVoyageData;
	transController.myTerminal := _movementAddProxy.myMovement.HMS_VoyageMovement.myHMSVoyageData.getMyTerminal();
	transController.type := TRANS_TYPE_AddMovement;
	
	realHMSTransaction := transController.createConversionTransaction(app.myPassport);
	if app.myPassport.allErrorWarnings.size = 0 and 
	   realHMSTransaction &lt;&gt; null then
		realHMSTransaction.setPropertyValue("userCode",_movementAddProxy.userCode);
		realHMSTransaction.setPropertyValue("userName",_movementAddProxy.userName);
		realHMSTransaction.setPropertyValue("transactionDT",_movementAddProxy.transactionDT);
		commitTransaction;
		return true;
	else
		abortTransaction;
		foreach error in app.myPassport.allErrors do
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_movementAddProxy.transactionDT.String&amp;" ERROR: "&amp;error.text,0);
		endforeach;
		return false;
	endif;
epilog
	delete transController;
	delete workingMovementCtrl;
	delete workingVoyageCtrl;
end;</source>
        <access>protected</access>
        <Parameter name="_movementAddProxy" type="HMS_MovementAdd" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadMovementDelete" id="eebf73a8-7a36-476e-ac65-88254177e775">
