        <updating/>
        <source>trxUpdateDetach(params : CMIF_ConnectParams io; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	pxyTI	: CM_TrackedItem;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
		
	if params = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "Detach Parameters", null, null);
	endif;
	if params.myTrackedItem = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "Attach  Parameters: allTrackedItems", null, null);
	endif;		

	app.setContinueCMExceptions(false);
		
	beginTransaction;
	
	app.myUtilityUA.utlUpdateDetach(params, _passport);

epilog	
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="params" type="CMIF_ConnectParams" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
