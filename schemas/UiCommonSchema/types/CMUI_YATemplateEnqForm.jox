    <JadeMethod name="doDelete" id="0595295f-e539-41ec-9f82-00760a776828">
        <updating/>
        <source>doDelete(): Boolean updating;
//30 July 2008	cnwdw1	
//
vars
	yaTemplate: CM_YATemplate;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin

	yaTemplate := self.myCurrentObject.CM_YATemplate;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteYATemplate(yaTemplate, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Yard Allocation Template', app.myPassport, ErrWarnMode_Delete);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;

	return true;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
