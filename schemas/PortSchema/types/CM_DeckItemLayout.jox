    <JadeMethod name="setForCreate" id="05d3f614-0931-4b6c-9ead-6725f8819619">
        <updating/>
        <source>setForCreate(_pxyItemLayout: CM_DeckItemLayout) updating;
// ---------------------------------------------------------------------------
// Created:     06 April 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	pxyItem, realItem : CM_DeckItem;
begin
	self.setForUpdate(_pxyItemLayout);
	
	// PAR 28058
	if _pxyItemLayout.myDeckItem &lt;&gt; null then
		if _pxyItemLayout.myDeckItem.isTransient() then
			pxyItem := _pxyItemLayout.myDeckItem;
			pxyItem.setRealLayout(self);
			pxyItem.setMyDeck(self.myDeckLayer.myDeckLayout.myDeck);
			
			app.myUtilityCA.utlCreateRORODeckItem(pxyItem, realItem, app.myPassport);
		else
			realItem := _pxyItemLayout.myDeckItem;
		endif;
	endif;
	
	//epr par 27519 from copy want to set from proxy not always set to true
	self.isVisible  := _pxyItemLayout.isVisible;
epilog

end;</source>
        <Parameter name="_pxyItemLayout" type="CM_DeckItemLayout"/>
    </JadeMethod>
    <JadeMethod name="setForCreateImport" id="8ebfb36b-8348-434d-a2fb-d262ff8a11f2">
        <updating/>
        <source>setForCreateImport(_proxyDeckItemLayout : CM_DeckItemLayout input; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 May 2011	cnwer1	Initial creation CCMS 1031
13 Apr 2012	cnwrs1	Par 29141 vessel definition is incorrect from Plans
*/

vars
	realDeckItem , pxyDeckItem: CM_DeckItem;
	code : String;
	deck : CM_Deck;
begin
	self.setLabel(_proxyDeckItemLayout.label);
	self.drawFillColour := _proxyDeckItemLayout.drawFillColour;
	self.drawFillStyle :=_proxyDeckItemLayout.drawFillStyle;
	self.drawWidth :=_proxyDeckItemLayout.drawWidth;
	self.code := _proxyDeckItemLayout.code;
	self.description := _proxyDeckItemLayout.description;
	self.remarks := _proxyDeckItemLayout.remarks;
	self.isVisible := _proxyDeckItemLayout.isVisible;
	self.drawLineStyle := _proxyDeckItemLayout.drawLineStyle;
	self.drawLineColour := _proxyDeckItemLayout.drawLineColour;
	self.type:=_proxyDeckItemLayout.type; // PAR 29607
	
	//13 Apr 2012	cnwrs1	Par 29141 vessel definition is incorrect from Plans
	if _proxyDeckItemLayout.myPolygonCMs.size &gt; 0 then
		self.setPointsPolygonCMs(_proxyDeckItemLayout.myPolygonCMs); // PAR 29503
/*	PAR 29503
		self.myPolygonCMs.clear;
		self.pointsPolygon.clear; 
		self.myPolygonPixels.clear;
		_proxyDeckItemLayout.myPolygonCMs.copy(self.myPolygonCMs);
		self.convertMetresToPoints(self.myPolygonCMs, self.pointsPolygon);
		self.pointsPolygon.copy(self.myPolygonPixels);
		*/
	else
		self.setPointsPolygon(_proxyDeckItemLayout.myPolygonPixels);
	endif;
	
	pxyDeckItem:=_proxyDeckItemLayout.myDeckItem;
	if pxyDeckItem &lt;&gt; null then
		deck:=self.myDeckLayer.myDeckLayout.myDeck;
		
		//create self.myDeckItem as _proxyDeckItemLayout.myDeckItem.class transient;
		realDeckItem:=deck.allDeckItems[pxyDeckItem.code];
		if realDeckItem &lt;&gt; null then
			self.myDeckItem:=realDeckItem;
		else
			create self.myDeckItem as _proxyDeckItemLayout.myDeckItem.class persistent;
			
			self.myDeckItem.setRealLayout(self);
			//duplicate key error set the ordinal first
			if self.myDeckItem.isKindOf(CM_ROROLocnDefn) then
				
				self.myDeckItem.CM_ROROLocnDefn.setOrdinal(pxyDeckItem.CM_ROROLocnDefn.ordinal);
			endif;
			if self.myDeckItem.isKindOf(CM_ROROLaneDefn) then
				self.myDeckItem.CM_ROROLaneDefn.setOrdinal(pxyDeckItem.CM_ROROLaneDefn.ordinal);
			endif;
			self.myDeckItem.setMyDeck(deck);
			self.myDeckItem.setForCreateImport(pxyDeckItem,_passport);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_proxyDeckItemLayout" type="CM_DeckItemLayout" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="e2c75486-733e-46ce-b5a1-5e6754472c37">
        <updating/>
        <source>setForUpdate(_pxyLayout: CM_DeckItemLayout) updating;
// ---------------------------------------------------------------------------
// Created:     24 March 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 
// ---------------------------------------------------------------------------

vars
	tmpItem 	: CM_DeckItem;
	realLayer 	: CM_DeckLayerLayout;
begin

	self.setLabel(_pxyLayout.label);
	
	self.drawFillColour := _pxyLayout.drawFillColour;
	self.drawFillStyle 	:=_pxyLayout.drawFillStyle;
	self.drawWidth 		:=_pxyLayout.drawWidth;
	self.code 			:= _pxyLayout.code; 		
	self.description 	:= _pxyLayout.description;	
	self.remarks 		:= _pxyLayout.remarks;		
	self.isVisible 		:= _pxyLayout.isVisible;
	self.drawLineStyle 	:= _pxyLayout.drawLineStyle;
	self.drawLineColour := _pxyLayout.drawLineColour;
	self.type 			:= _pxyLayout.type;
	
	self.setPointsPolygon(_pxyLayout.myPolygonPixels);

	//epr par 27519 wasn't always setting the deck layer
	realLayer := _pxyLayout.myDeckLayer;
	
	if realLayer.isTransient then
		realLayer:=_pxyLayout.myDeckLayer.pxyGetRealObject();
	endif;
	
	self.myDeckLayer := realLayer;
	
	if _pxyLayout.myDeckItem &lt;&gt; null then // graphic does not have to have a real item
		if _pxyLayout.myDeckItem.isTransient then		
			tmpItem := _pxyLayout.myDeckItem.pxyGetRealObject();
		else
			tmpItem :=	_pxyLayout.myDeckItem;
		endif;
		
		if tmpItem &lt;&gt; null then // create, this will be created in the setForCreate
			self.myDeckItem := tmpItem;
		endif;
	else
		self.myDeckItem := null; // PAR 27501
	endif;
	
	// PAR 28990
	if self.type = 0 then
		if self.myDeckItem &lt;&gt; null then
			if self.myDeckItem.isKindOf(CM_ROROLocnDefn) then
				self.type := DeckItemLayoutType_Locn;
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_pxyLayout" type="CM_DeckItemLayout"/>
    </JadeMethod>
