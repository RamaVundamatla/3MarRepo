    <JadeMethod name="createEmptyChild" id="4098bb98-1d6c-4b26-8326-c5f77f3acfa3">
        <updating/>
        <source>createEmptyChild(_parent: SOP_ViewModelObject) updating;
// -----------------------------------------------------------------------------
// Created:		30 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
