    <JadeMethod name="updateDelay" id="53564590-9e4e-407a-8faa-21bc60e9f01c">
        <source>updateDelay(_delay : CM_Delay io) ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/02/2014	cnwma1	Initial creation

*/

vars
	delayProxy 		: CM_Delay;

begin

	beginLoad;
	delayProxy := _delay.pxyCreateUpdateProxy();
	endLoad;
	delayProxy.setProxy(_delay.myTerminal,
					_delay.myVoyage,
					_delay.myDelayType,
					_delay.startDT,
					_delay.estEndDT,
					_delay.endDT,
					_delay.myMachine,
					app.getMyUser(),
					null,
					self.opts.str("Remarks"));
	self.ignoreTrxWarnings(true);	
	app.myTrxUA.trxUpdateDelay(delayProxy, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

epilog

	delete delayProxy;

end;</source>
        <Parameter name="_delay" type="CM_Delay" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateDelayType" id="58cf700c-a3dc-4f48-8bf2-a3dbf8042866">
        <source>updateDelayType(_delayType : CM_DelayType io);

/*

Purpose:		Update Delay Type

Date			Who		Reason
27/02/2014		cnwmh5	Initial creation

*/

vars

	pxyDelayType						: CM_DelayType;
	
	loadState							: Boolean;
	refersToMachine						: Boolean;
	refersToWorkPoint					: Boolean;

begin

	app.cmsBeginLoad(loadState);
	pxyDelayType := _delayType.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadState);
	
	refersToMachine := _delayType.requiresMachine;
	if self.opts.includesKey("RequiresMachine") then
		refersToMachine := self.opts.bool("RequiresMachine").Boolean;
	endif;
	
	refersToWorkPoint := _delayType.requiresWorkpoint;
	if self.opts.includesKey("RequiresWorkpoint") then
		refersToWorkPoint := self.opts.bool("RequiresWorkpoint").Boolean;
	endif;	

	pxyDelayType.setProxy(_delayType.myRoot, 
		_delayType.allDelayTypeGroups, 
		_delayType.myMachineAvailability, 
		_delayType.description,
		_delayType.isNotAvailableForEntry,
		refersToMachine,
		_delayType.requiresVoyage,
		refersToWorkPoint,
		_delayType.isOperational,
		_delayType.canScheduleInAdvance,
		_delayType.delayTypeOrder);
	
	
	app.myTrxUA.trxUpdateDelayType(pxyDelayType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();	
	
epilog

	app.cmsEndLoad(loadState);
	
	delete pxyDelayType;

end;</source>
        <Parameter name="_delayType" type="CM_DelayType" usage="io"/>
    </JadeMethod>
