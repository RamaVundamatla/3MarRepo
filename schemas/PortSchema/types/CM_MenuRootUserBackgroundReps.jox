<Class name="CM_MenuRootUserBackgroundReps" id="a078e4c6-437a-4ca2-9024-1dedfe66c493">
    <superclass name="CM_MenuRoot"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>This flavour of root exists for CM_User::myMenuRootReportsCurrent and
CM_User::myMenuRootReportsSaved. Needs to be of different type because
of inverse back to USER, rather than userTerminal</text>
    <DbClassMap file="cmenu"/>
    <Constant name="Heading_Current" id="69d9a1f3-a0c0-45be-a916-4a3e8c4863c6">
        <source>'Current'</source>
        <type name="String"/>
    </Constant>
    <Constant name="Heading_Saved" id="ad62e136-cda7-4319-aaba-5552513c561c">
        <source>'Saved'</source>
        <type name="String"/>
    </Constant>
    <ExplicitInverseRef name="myUser" id="094f389e-0270-416a-836d-4a48a7fe6ae0">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <embedded/>
        <type name="CM_User"/>
        <access>readonly</access>
        <Inverse name="CM_User::myMenuRootBGRCurrent"/>
        <Inverse name="CM_User::myMenuRootBGRSaved"/>
    </ExplicitInverseRef>
    <JadeMethod name="getExpandedDefault" id="8032cd2e-b191-4c84-ad0c-5a6a29d9a2bb">
        <source>getExpandedDefault(): Boolean;
// ---------------------------------------------------------------------------
// Created:     05 December 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	return true;


end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getHeading" id="bef39f0c-156b-45d7-a9ff-cd1a1ef47391">
        <source>getHeading(): String;
// ---------------------------------------------------------------------------
// Created:     05 December 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if self = self.myUser.myMenuRootBGRCurrent then
	//par 18483
	return app.getErrorString(HeadingCurrent); 
		//return Heading_Current;	
	elseif self = self.myUser.myMenuRootBGRSaved then
	//par 18483
	return app.getErrorString(HeadingSaved); 
		//return Heading_Saved;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLevel" id="8439ab1c-40ad-418b-91da-00bb39052905">
        <source>getLevel(): Integer;
// ---------------------------------------------------------------------------
