    <JadeMethod name="doChangeMOP" id="c7a398df-5b35-4064-83f7-6982d25f83e6">
        <source>doChangeMOP() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 January 2013	cnwndl1	Initial creation	Par 30901

*/

vars

	mop : CM_PaymentMethod;

begin

	mop := self.cmbMOP.listObject.CM_PaymentMethod;
	if mop = null or not mop.isCheque then
		self.lblChqDate.visible := false;
		self.txtChqDate.visible := false;
		self.lblChqBank.visible := false;
		self.txtChqBank.visible := false;
		self.lblChqBranch.visible := false;
		self.txtChqBranch.visible := false;
		self.lblChqNumber.visible := false;
		self.txtChqNumber.visible := false;
		
	else
		self.lblChqDate.visible := true;
		self.txtChqDate.visible := true;
		self.lblChqBank.visible := true;
		self.txtChqBank.visible := true;
		self.lblChqBranch.visible := true;
		self.txtChqBranch.visible := true;
		self.lblChqNumber.visible := true;
		self.txtChqNumber.visible := true;
		
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDeleteCashPaymentLine" id="7a60c378-2729-4b10-98ec-153d4705af1f">
        <updating/>
        <source>doDeleteCashPaymentLine() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 March 2013	cnwndl1	Initial creation	Par 30901

*/

vars

	rowIndex : Integer;
	index : Integer;

begin

	rowIndex := self.tblPayments.row;
	if rowIndex &gt; self.tblPayments.fixedRows and rowIndex &lt;= self.tblPayments.rows then
		self.tblPayments.deleteRow( rowIndex );
	endif;
	
	foreach index in 1 to self.tblPayments.rows do
		self.tblPayments.accessRow(index).selected := false;
	endforeach;
	
	self.enableButtonsSetBalances();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doOKClickPaymentLine" id="f066b73e-d583-47ba-90b6-704887c17131">
        <updating/>
        <source>doOKClickPaymentLine() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 March 2013	cnwndl1	Initial creation	Par 30901

*/

vars

	isUpdate : Boolean;
	rowIndex : Integer;
	payMethStr : String;
	dateStr : String;
	bankStr : String;
	branchStr : String;
	chqNum : String;
	amountStr : Decimal [16,4];

begin

	self.displayPaymentLine( false );
	
	if self.tblPayments.rows &gt; 1 then
		if self.tblPayments.row &gt; 1 and self.tblPayments.row &lt;= self.tblPayments.rows then
			if self.tblPayments.accessRow( self.tblPayments.row ).selected then
				isUpdate := true;
			endif;
		endif;
	endif;
	
	if isUpdate then
		rowIndex := self.tblPayments.row;
	else
		self.tblPayments.rows := self.tblPayments.rows + 1;
		rowIndex := self.tblPayments.rows;
	endif;
	
	
	payMethStr := self.cmbMOP.text;
	dateStr := 	self.txtChqDate.getDate.asStringJMT;
	bankStr := self.txtChqBank.text;
	branchStr := self.txtChqBranch.text;
	chqNum := self.txtChqNumber.text;
	amountStr := self.txtLineAmount.text.asDecimalFromCurrencyString;
	
	if rowIndex &gt; 1 and rowIndex &lt;= self.tblPayments.rows then
		self.tblPayments.setCellText(rowIndex,1,payMethStr &amp; Tab &amp; dateStr &amp; Tab &amp; bankStr &amp; Tab &amp; branchStr &amp; Tab &amp; chqNum &amp; Tab &amp; amountStr.asCurrencyJMT);
		self.tblPayments.accessCell(rowIndex,1).itemObject := self.cmbMOP.listObject;
		self.tblPayments.accessRow(rowIndex).selected := false;
		self.tblPayments.row := 1;
	endif;
	
	self.enableButtonsSetBalances();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doOptClick" id="aff416d4-04d8-4654-a96f-dd6707209fe9">
