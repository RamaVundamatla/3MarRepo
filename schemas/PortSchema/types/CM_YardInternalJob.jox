        <updating/>
        <source>updateStatus() updating;
vars
begin

inheritMethod();  //cnwrd1 changed to use superclass as trq check isntright
/*
	exclusiveLock(self);
	if areAllQueueEntriesEqualStatus(ENTRY_COMPLETE) then
		status := JOB_COMPLETE;
	elseif areAllQueueEntriesEqualStatus(ENTRY_UNACTIONED) then
