    <JadeMethod name="getExtraInfo" id="cfb548f0-d8a0-4ae1-9f3e-664df331e998">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
06 January 2023	navcs2	ChangeRequest 56632:[56057] EUP - VAS Non Operational Work Order
*/

vars
	block   	: CM_DataContainerBlock;
	addStr  	: String;	
begin
	
	inheritMethod(_dataContainer);
	
	addStr := self.allDebtors.listString(Comma,CM_Debtor::code.name);
	
	if addStr &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Debtors), DC_Label, 1, self.allDebtors.first);
		block.addNewItem(addStr, DC_Data, 1,  self.allDebtors.first);
	endif;	
epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getMyDebtor" id="d66e25f7-78fe-4176-8859-f7f93d32a0c3">
        <source>getMyDebtor(): CM_Debtor;
/*
Purpose:			

Date		Who		Reason
23JUN2023	NAVAB1	 BUG 58790
*/
vars
	debtor : CM_Debtor;
begin
	debtor := self.allDebtors.first;
	
	if debtor &lt;&gt; null then
		return debtor;
	endif;
	
	return inheritMethod();

epilog

end;</source>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
