    <JadeMethod name="doResize" id="5ca3c5bd-ac91-4254-b1e3-7e37c287781d">
        <updating/>
        <source>doResize() updating;
//--------------------------------------------------
// Created:	30 November 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpTop : Real;
begin
	inheritMethod();
	tmpTop := self.frmToolbar.height;
	self.fldDetails.move(0, tmpTop, self.clientWidth, self.clientHeight-tmpTop+7);
	self.frmPieGraph.move(10, 10, self.shtPieGraph.width-20, self.shtPieGraph.height-30);	
end;</source>
    </JadeMethod>
    <JadeMethod name="doSearch" id="50ef63da-075b-4971-8c4e-55e78b773b10">
        <updating/>
        <source>doSearch() updating, protected;
//--------------------------------------------------
// Created:	23 November 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpHarbour : HMS_Harbour;
	tmpDate : Date;
begin
	
	self.allVoyageAnalysisByGroupCode.purge;
	self.allVoyageAnalysisArray.purge;
	
	self.allHarbours.clear();
	self.lstHarbours.allSelectedObjects.copy(self.allHarbours);		

	self.allTerminals.clear();
	self.lstTerminals.allSelectedObjects.copy(self.allTerminals);

	if self.allTerminals.isEmpty then
		foreach tmpHarbour in self.allHarbours do
			tmpHarbour.allTerminalsByCode.copy(self.allTerminals);
		endforeach;	
	endif;		

	tmpDate.setDate(1, self.cmbMonth.listIndex, self.cmbYear.text.Integer);	
	self.filterFromDT.setDate(tmpDate);
	tmpDate.setDate(tmpDate.cnEcDaysInMonth, tmpDate.month, tmpDate.year);
	self.filterToDT.setDate(tmpDate);	
		
	self.generateVoyageAnalysis();	
	
	if self.tblData.rows &gt; self.tblData.fixedRows then
		self.frmSearch.visible := true;
		self.showHideSearcher();		
	else
		self.frmSearch.visible := false;
		self.showHideSearcher();
	endif;
	
	self.caption := 'Voyage Statistics ' &amp; self.cmbMonth.text &amp; ' ' &amp; self.cmbYear.text;
	
	self.drawLineGraph();
	self.drawBarGraph();
	self.drawPieGraph();
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSelectAll" id="d7ee0cbf-b47c-4a48-8c87-4d32d3f64364">
        <source>doSelectAll(_lstTable : CMUI_ListTable input) protected;
//--------------------------------------------------
// Created:	25 November 2005 By: cnwgd1
//--------------------------------------------------
vars
	numRows,
	idx	: Integer;
	tmpHarbour : HMS_Harbour;
	tmpWharf : HMS_Wharf;
begin
	if _lstTable = null then
		return;
	endif;
	
	_lstTable.setAllToTrue();
	
	numRows := _lstTable.rows;

	if _lstTable = self.lstHarbours then	
		foreach idx in 1 to numRows do
			self.doHarbourSelect(idx);
		endforeach;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_lstTable" type="CMUI_ListTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawBarGraph" id="9d540b17-4802-4567-b423-9070f3fb211a">
        <source>drawBarGraph() protected;
//--------------------------------------------------
// Created:	02 December 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpDate : Date;
	value,
	tmpYear,
	thisMth,
	mth : Integer;
	str : String;
	tmpAnaly : CMIF_VoyageAnalysis;
	tmpStat : CM_VoyageStatistic;
	term : CM_Terminal;
	tmpDict : CMIF_VoyageAnalyByCodeDict;
begin

	if (not self.shtBarGraph.visible) then
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;

	create tmpDict transient;
	foreach tmpAnaly in self.allVoyageAnalysisByGroupCode do
		if tmpAnaly.group = VoyageStat_CargoOffloaded
		or tmpAnaly.group = VoyageStat_CargoLoaded then
			if tmpAnaly.unitsOfMeasure = BOL_UOM_UNITS then
				tmpDict.add(tmpAnaly);
			endif;
		endif;	
	endforeach;

	self.barGraph.clearGraph();
	self.barGraph.setAndShowGraphTitle('Cargo Units Handled CYTD');
	self.barGraph.init('Cargo Units Handled CYTD', "Month", ' ');
	self.barGraph.backColor := backColor;
	
	thisMth := self.cmbMonth.listIndex;
	tmpYear := self.cmbYear.text.Integer;
	tmpDate.setDate(1, 1, tmpYear);
	mth := 1;
	while mth &lt; 13 do
	
		value := null;
		foreach tmpAnaly in tmpDict do

			foreach term in self.allTerminals do
				tmpStat := term.allVoyageStatistics[tmpDate,tmpAnaly.group,tmpAnaly.code];
				if tmpStat &lt;&gt; null then
					value := value + tmpStat.value.Integer;
				endif;
			endforeach;

		endforeach;

		str := tmpDate.monthName();

		self.barGraph.addValue(str, null, value, self.getColourForMonth(mth));
		mth := mth+1;
		tmpDate.setDate(1, mth, tmpYear);
		
	endwhile;	
	
	self.barGraph.drawGraph();
	
epilog
	delete tmpDict;
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawLineGraph" id="34835cdf-16b6-4c47-af19-c306f07da74d">
        <source>drawLineGraph() protected;
//--------------------------------------------------
// Created:	02 December 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpDate : Date;
	value,
	tmpYear,
	thisMth,
	colour,
	mth : Integer;
	plotValues,
	colorArray : IntegerArray;
	tmpCode,
	str : String;
	obj : CMIF_Object;
	tmpAnaly : CMIF_VoyageAnalysis;
	tmpStat : CM_VoyageStatistic;
	term : CM_Terminal;
	tmpDict : CMIF_VoyageAnalyByCodeDict;
begin

	if (not self.shtLineGraph.visible) then
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;

	create tmpDict transient;
	foreach tmpAnaly in self.allVoyageAnalysisByGroupCode do
		if tmpAnaly.group = VoyageStat_CargoOffloaded
		or tmpAnaly.group = VoyageStat_CargoLoaded then
			if tmpAnaly.unitsOfMeasure = BOL_UOM_METRIC_TONS then
				tmpDict.add(tmpAnaly);
			endif;
		endif;	
	endforeach;

	self.lineGraph.isShowLineLegend := true;
	self.lineGraph.clearGraph();
	self.lineGraph.setAndShowGraphTitle('Cargo ' &amp; BOL_UOM_METRIC_TONS &amp; ' Handled CYTD');
	self.lineGraph.init('Cargo ' &amp; BOL_UOM_METRIC_TONS &amp; ' Handled CYTD', "Month", BOL_UOM_METRIC_TONS);
	self.lineGraph.backColor := backColor;	
	
	create plotValues transient;
	create colorArray transient;	
	
	thisMth := self.cmbMonth.listIndex;
	tmpYear := self.cmbYear.text.Integer;
	tmpDate.setDate(1, 1, tmpYear);
	mth := 1;
	while mth &lt; 13 do
	
		plotValues.clear;
		value := null;
		tmpCode := null;
		foreach tmpAnaly in tmpDict do

			if tmpCode &lt;&gt; null
			and tmpAnaly.code &lt;&gt; tmpCode then
				plotValues.add(value);
				self.lineGraph.addGraphLegend(tmpCode);
				colour := colour+1;				
				colorArray.add(self.getColourForMonth(colour));
				value := null;
			endif;				
						
			foreach term in self.allTerminals do
				tmpStat := term.allVoyageStatistics[tmpDate,tmpAnaly.group,tmpAnaly.code];
				if tmpStat &lt;&gt; null then
					value := value + tmpStat.value.Integer;
				endif;
			endforeach;

			tmpCode := tmpAnaly.code;	
		endforeach;

		plotValues.add(value);
		self.lineGraph.addGraphLegend(tmpCode);
		colour := colour+1;				
		colorArray.add(self.getColourForMonth(colour));

		str := tmpDate.monthName();
		self.lineGraph.addYPoints(str, plotValues);
		mth := mth+1;
		tmpDate.setDate(1, mth, tmpYear);
		
	endwhile;	
	
	self.lineGraph.addLineColors(colorArray);
	self.lineGraph.drawGraph();
	
epilog
	delete plotValues;
	delete colorArray;
	delete tmpDict;
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawPieGraph" id="bb292d2a-0238-41cb-b03f-fb0d33198c69">
        <source>drawPieGraph() protected;
//--------------------------------------------------
// Created:	02 December 2005 By: cnwgd1
//--------------------------------------------------
vars
	cnt,
	subTot,
	totValue,
	value : Integer;
	str : String;
	tmpAnaly : CMIF_VoyageAnalysis;
	tmpStat : CM_VoyageStatistic;
	term : CM_Terminal;
	tmpDict : CMIF_VoyageAnalyByCodeDict;
begin

	if (not self.shtPieGraph.visible) then
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;

	create tmpDict transient;
	foreach tmpAnaly in self.allVoyageAnalysisByGroupCode do
		if tmpAnaly.group = VoyageStat_PassengerVesselCall
		or tmpAnaly.group = VoyageStat_CargoVesselCall then
			tmpDict.add(tmpAnaly);
			totValue := totValue + tmpAnaly.value.Integer;			
		endif;	
	endforeach;

	self.pieGraph.clearGraph();
	self.pieGraph.isShowPieLegend := true;	
	self.pieGraph.backColor := backColor;
	self.pieGraph.move(0, 0, self.frmPieGraph.width, self.frmPieGraph.height);		

	foreach tmpAnaly in tmpDict do
		if str &lt;&gt; null 
		and tmpAnaly.code &lt;&gt; str then
			if totValue &gt; 0 then
				value := ((value / totValue) * 100).Integer;
			endif;
			cnt := cnt+1;		
			self.pieGraph.addValue(str, value, self.getColourForMonth(cnt));
			subTot := subTot + value;
			value := null;
		endif;
				
		value := value + tmpAnaly.value.Integer;
		str := tmpAnaly.code;				
	endforeach;

	if totValue &gt; 0 then
		value := ((value / totValue) * 100).Integer;
	endif;
	subTot := subTot + value;	
	if subTot &lt; 100 then
		value := value + (100 - subTot);
	endif;
	cnt := cnt+1;	
	self.pieGraph.addValue(str, value, self.getColourForMonth(cnt));	

	self.pieGraph.setTitle('Vessel Calls for ' &amp; self.cmbMonth.text);		
	self.pieGraph.drawGraph();
	
epilog
	delete tmpDict;
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="generateTotals" id="93989b6e-ee2b-44bb-989d-558b0f4cfd1c">
        <source>generateTotals()protected;
//--------------------------------------------------
// Created:	29 November 2005 By: cnwgd1
//--------------------------------------------------
vars
	idx,
	group : Integer;
	cargoSet,
	isGroupTotal : Boolean;
	tmpVesselCalls,
	tmpAnalyTotUnits,
	tmpAnalyTotTons,
	tmpAnalyTotal,
	tmpVoyageAnaly : CMIF_VoyageAnalysis;
begin
	
	foreach tmpVoyageAnaly in self.allVoyageAnalysisByGroupCode do
		isGroupTotal := tmpVoyageAnaly.isGroupTotal();

		if tmpVoyageAnaly.group = VoyageStat_CargoOffloaded
		or tmpVoyageAnaly.group = VoyageStat_CargoLoaded then
			
			if tmpAnalyTotUnits = null then
				create tmpAnalyTotTons transient;
				tmpAnalyTotTons.setGroupCodeForTotal(tmpVoyageAnaly.group, BOL_UOM_METRIC_TONS);

				create tmpAnalyTotUnits transient;
				tmpAnalyTotUnits.setGroupCodeForTotal(tmpVoyageAnaly.group, BOL_UOM_UNITS);	
			endif;				
				
			if tmpVoyageAnaly.unitsOfMeasure = BOL_UOM_UNITS then
				tmpAnalyTotUnits.addVoyageAnalysis(tmpVoyageAnaly);
			elseif tmpVoyageAnaly.unitsOfMeasure = BOL_UOM_METRIC_TONS then
				tmpAnalyTotTons.addVoyageAnalysis(tmpVoyageAnaly);				
			endif;

			self.allVoyageAnalysisArray.add(tmpVoyageAnaly);		
					
		else
		
			if (not cargoSet) then
				if tmpAnalyTotTons &lt;&gt; null
				and (not self.allVoyageAnalysisArray.includes(tmpAnalyTotTons)) then
					self.allVoyageAnalysisArray.add(tmpAnalyTotTons);
				endif;
			
				if tmpAnalyTotUnits &lt;&gt; null
				and (not self.allVoyageAnalysisArray.includes(tmpAnalyTotUnits)) then
					self.allVoyageAnalysisArray.add(tmpAnalyTotUnits);
				endif;			
				cargoSet := true;
			endif;

			if tmpVoyageAnaly.group &lt;&gt; group 
			and (not isGroupTotal) then
				if tmpAnalyTotal &lt;&gt; null then
					self.allVoyageAnalysisArray.add(tmpAnalyTotal);
					if tmpAnalyTotal.isVesselCall then
						if tmpVesselCalls = null then
							create tmpVesselCalls transient;
							tmpVesselCalls.setGroupCodeForTotal(tmpAnalyTotal.group, tmpAnalyTotal.unitsOfMeasure);
							tmpVesselCalls.addVoyageAnalysis(tmpAnalyTotal);
						elseif (not tmpVesselCalls.allVoyageAnalysis.includes(tmpAnalyTotal)) then
							tmpVesselCalls.addVoyageAnalysis(tmpAnalyTotal);				
						endif;
					endif;					
				endif;
								
				create tmpAnalyTotal transient;
				tmpAnalyTotal.setGroupCodeForTotal(tmpVoyageAnaly.group, tmpVoyageAnaly.unitsOfMeasure);			
				tmpAnalyTotal.addVoyageAnalysis(tmpVoyageAnaly);
				
			elseif tmpAnalyTotal &lt;&gt; null then
				tmpAnalyTotal.addVoyageAnalysis(tmpVoyageAnaly);
			endif;
			
			group := tmpVoyageAnaly.group;
			if (not isGroupTotal) then
				self.allVoyageAnalysisArray.add(tmpVoyageAnaly);		
			endif;

		endif;
				
	endforeach;

	if tmpAnalyTotal &lt;&gt; null
	and tmpAnalyTotal.isVesselCall then
		if tmpVesselCalls = null then
			create tmpVesselCalls transient;
			tmpVesselCalls.setGroupCodeForTotal(tmpAnalyTotal.group, tmpAnalyTotal.unitsOfMeasure);
			tmpVesselCalls.addVoyageAnalysis(tmpAnalyTotal);																	
		elseif (not tmpVesselCalls.allVoyageAnalysis.includes(tmpAnalyTotal)) then
			tmpVesselCalls.addVoyageAnalysis(tmpAnalyTotal);
		endif;
	endif;
			
	if tmpAnalyTotTons &lt;&gt; null
	and (not self.allVoyageAnalysisArray.includes(tmpAnalyTotTons)) then
		self.allVoyageAnalysisArray.add(tmpAnalyTotTons);
	endif;

	if tmpAnalyTotUnits &lt;&gt; null
	and (not self.allVoyageAnalysisArray.includes(tmpAnalyTotUnits)) then
		self.allVoyageAnalysisArray.add(tmpAnalyTotUnits);
	endif;			

	if tmpAnalyTotal &lt;&gt; null
	and (not self.allVoyageAnalysisArray.includes(tmpAnalyTotal)) then
		self.allVoyageAnalysisArray.add(tmpAnalyTotal);
	endif;

	if tmpVesselCalls &lt;&gt; null
	and (not self.allVoyageAnalysisArray.includes(tmpVesselCalls)) then
		self.allVoyageAnalysisArray.add(tmpVesselCalls);
	endif;									
			
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="generateVoyageAnalysis" id="7c6a0fb7-0f2b-4cd9-9ac9-e805fd075e9c">
        <source>generateVoyageAnalysis()protected;
//--------------------------------------------------
// Created:	29 November 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpTerminal : CM_Terminal;
	tmpVoyageStat : CM_VoyageStatistic;
	iter : Iterator;
	tmpToDate : Date;
	checkDate : Boolean;
	cmifVoyageAnalysis : CMIF_VoyageAnalysis;
begin
	
	self.tblData.rows := self.tblData.fixedRows;
	checkDate := self.filterToDT.isValid;
	tmpToDate := self.filterToDT.date;
	
	foreach tmpTerminal in self.allTerminals do
		iter := tmpTerminal.allVoyageStatistics.createIterator();
		tmpTerminal.allVoyageStatistics.startKeyGeq(self.filterFromDT.date, null, null, iter);
		
		while iter.next(tmpVoyageStat) do
			if checkDate then
				if tmpVoyageStat.monthYear &gt; tmpToDate then
					break;
				endif;
			endif;
			if (not self.includeObject(tmpVoyageStat)) then
				continue;
			endif;
			
			create cmifVoyageAnalysis transient;
			cmifVoyageAnalysis.setFormVoyageStatistic(tmpVoyageStat);				
			self.allVoyageAnalysisByGroupCode.add(cmifVoyageAnalysis);	

		endwhile;
		
		delete iter;
	endforeach;

	self.generateTotals();
	self.displayVoyageAnalysis();

epilog
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getColourForMonth" id="dfdd56e2-13ed-4a38-83de-5eaebaac6d07">
        <source>getColourForMonth(_mth : Integer) : Integer protected;
//--------------------------------------------------
// Created:	02 December 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	
	if _mth = 1 then
		return Red;
	elseif _mth = 2 then
		return White;
	elseif _mth = 3 then
		return Yellow;
	elseif _mth = 4 then
		return Gray;
	elseif _mth = 5 then
		return Green;
	elseif _mth = 6 then
		return self.ColourPink;
	elseif _mth = 7 then
		return self.ColourBlueLight;
	elseif _mth = 8 then
		return Blue;
	elseif _mth = 9 then
		return self.ColourYellowLight;
	elseif _mth = 10 then
		return LightGreen;
	elseif _mth = 11 then
		return Purple;
	elseif _mth = 12 then
		return DarkBlue;
	else
		return app.getRandomColour();																				
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_mth" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
