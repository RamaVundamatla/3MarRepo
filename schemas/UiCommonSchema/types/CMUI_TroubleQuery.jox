    <JadeMethod name="loadDataForFirstTime" id="d8718f0a-c63e-4421-aff1-f094adff5fad">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:     29 July 2008 by cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	regKeys : IntegerArray;

begin
	inheritMethod();
	
	create regKeys transient;
	regKeys.add(J_key_F3);
	regKeys.add(J_key_F4);
	regKeys.add(J_key_F5);
	regKeys.add(J_key_F6);
	regKeys.add(J_key_F7);
	regKeys.add(J_key_F8);
	regKeys.add(J_key_F9);
	regKeys.add(J_key_F10);
	self.addRegisteredKeys(regKeys);


epilog
	delete regKeys;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="61fa75cf-04ef-46c3-b094-2f786d66e3fb">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     06 August 2008 by cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	today : TimeStamp;
	tmpTime : Time;
begin
	inheritMethod();
	
	self.handleMenusForModalDisplay();
	self.height := self.height - 17;
	self.initTable();
	self.initStatusList();
	self.initTerminals();
	self.centreWindow();
	self.dteFrom.setDate(today.date);
	self.dteTo.setDate(today.date);
	tmpTime.setTime(0,0,0,0);
	self.tmeFrom.setTime(tmpTime);
	tmpTime.setTime(23,59,59,0);
	self.tmeTo.setTime(tmpTime);

	self.setNavigatorHeading(self.caption);
	
	// temporary code to hide booking number and  bill of lading
	lblBOL.visible		:= false;	// concms1 21/10/2008
	lblBookRef.visible 	:= false;	// concms1 21/10/2008
	txtBOL.visible		:= false;	// concms1 21/10/2008
	txtBookRef.visible	:= false;	// concms1 21/10/2008

	self.doQuery();
epilog

end;</source>
    </JadeMethod>
