    <CompAttribute name="allFileContent" id="db1c0a65-b1d7-4c46-88a8-f0b665340270">
        <type name="HugeStringArray"/>
        <access>readonly</access>
        <text>
The content of the file created by the JRW report. Will only be used by the User Defined Report Desc's initially.

Added J Harliwich Aug09  MES1011</text>
    </CompAttribute>
