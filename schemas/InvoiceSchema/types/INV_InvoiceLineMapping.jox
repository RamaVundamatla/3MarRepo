    <JadeMethod name="initQueryFrameDebtor" id="67858e5d-f04d-44bd-a7c4-e8ee17a1cfc5">
        <updating/>
        <source>initQueryFrameDebtor() updating, protected;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 11/10/2022	navpw1	TFS: 54566 - Added new multi selected group boxes for Debtors and Invoice Line Types
// 09/04/2025	navlw1 	JIRA-34468: MTN | Filtering on Thin Client Controls Phase 2
vars
	sht					: CMUI_Sheet;
	bank				: CM_Bank;							// ### TFS 54566 06Oct2022 NAVPW1
	invoiceLineDesc		: CM_InvoiceLineDesc;				// ### TFS 54566 06Oct2022 NAVPW1
	invLineTypeArray	: CM_InvLineDescByNarrDupsADict;	// ### TFS 54566 06Oct2022 NAVPW1
	rdg					: CM_RootDebtorGroup;				// ### TFS 54566 06Oct2022 NAVPW1
	debtor				: CM_Debtor;						// ### TFS 54566 06Oct2022 NAVPW1
	rootDebtors			: CM_DebtorNodeByNameDict;			// ### TFS 54566 06Oct2022 NAVPW1
	debtors				: CM_DebtorByNameDict;				// ### TFS 54566 06Oct2022 NAVPW1
	
begin
	sht			:= self.shtQuery1;
	sht.caption	:= "Debtor Mappings";
	
	// 35872 get business unit from user if more than one
	if self.cmbBank.listCount &gt; 1 then
		self.setQueryControl(self.cmbBank);
		self.setQueryControl(self.lblBank);
		self.cmbBank.setFocus();
	else
		self.cmbBank.visible	:= false;
		self.lblBank.visible	:= false;
		//self.lblDebtorQ.top := self.lblBank.top;	// ### TFS 54566 10Oct2022 NAVPW1
		//self.cmbDebtor.top := self.cmbBank.top;	// ### TFS 54566 10Oct2022 NAVPW1
		//self.cmbDebtor.setFocus();				// ### TFS 54566 10Oct2022 NAVPW1
		self.cmbBank.setFocus();					// ### TFS 54566 10Oct2022 NAVPW1
	endif;
	//self.setQueryControl(self.cmbDebtor);			// ### TFS 54566 10Oct2022 NAVPW1
	// ### TFS 54566 06Oct2022 NAVPW1

	self.frmQuery.height	:= 500; //navlw1 #JIRA-34468 09/04/2025
	self.frmQuery.width		:= 500;
	self.cmbBank.width		:= 480;
	
	bank := self.cmbBank.listObject.CM_Bank;
	
	create invLineTypeArray transient;
	
	foreach invoiceLineDesc in bank.invoiceLineDescriptors discreteLock where not invoiceLineDesc.isNotAvailableForEntry do
		invLineTypeArray.add(invoiceLineDesc);
	endforeach;
	
	self.mulInvLineTypes.top						:= self.cmbBank.top + 25;
	self.mulInvLineTypes.left						:= self.cmbBank.left;
	self.mulInvLineTypes.width						:= self.cmbBank.width;
	self.mulInvLineTypes.height						:= 180; //navlw1 #JIRA-34468 09/04/2025
	self.mulInvLineTypes.myAvailableListBox.sorted	:= true;
	self.mulInvLineTypes.mySelectedListBox.sorted	:= true;
	self.mulInvLineTypes.setupControl(null, invLineTypeArray, INV_InvoiceLineMapping::getInvLineTypeDescription.name);
	self.mulInvLineTypes.availableHeading			:= app.getErrorString(Availab_invoice_line_types);
	self.mulInvLineTypes.selectedHeading			:= app.getErrorString(Selecte_invoice_line_types);
	self.mulInvLineTypes.myBaseForm					:= self;
	self.mulInvLineTypes.setSelected(null);
	
	rdg := bank.getRootDebtorGroup();
	
	create rootDebtors transient;
	
	rdg.getDebtors(rootDebtors);
	
	create debtors transient;
	
	foreach debtor in rootDebtors as CM_Debtor discreteLock do
		debtors.add(debtor);
	endforeach;
	
	self.mulDebtors.top							:= self.mulInvLineTypes.top + self.mulInvLineTypes.height + 5;
	self.mulDebtors.left						:= self.mulInvLineTypes.left;
	self.mulDebtors.width						:= self.mulInvLineTypes.width;
	self.mulDebtors.height						:= 180; //navlw1 #JIRA-34468 09/04/2025
	self.mulDebtors.myAvailableListBox.sorted	:= true;
	self.mulDebtors.mySelectedListBox.sorted	:= true;
	self.mulDebtors.setupControl(null, debtors, INV_InvoiceLineMapping::getDebtorName.name);
	self.mulDebtors.availableHeading			:= app.getErrorString(Available_debtors);
	self.mulDebtors.selectedHeading				:= app.getErrorString(Selected_debtors);
	self.mulDebtors.myBaseForm					:= self;
	self.mulDebtors.setSelected(null);
	// ### TFS 54566 06Oct2022 NAVPW1
	
	sht.visible := true;
	
epilog
	delete invLineTypeArray;
	delete rootDebtors;
	delete debtors;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadLines" id="5eb03dda-4d3a-4cdf-8c82-8120a8595896">
        <source>loadLines();
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 17/06/2014	cnwdap1		PAR #34422 Remove beginLock / endLock
// 06/10/2022	navpw1		TFS: 54566 - Added the ability to load only lines that are selected in the query.
// 20/3/2023	navmk20		Bug 56954: FR | 53978 - EUP - Invoicing - Configuration Enhancements - User Story 050 issues
vars

	i					: Integer;
	invoiceLineDesc		: CM_InvoiceLineDesc;
	mappingTable		: CM_DataTable;
	bank				: CM_Bank;
	debtorColumns		: Boolean;
	invLineTypeArray	: CM_InvLineDescByNarrDupsADict;	// ### TFS 54566 06Oct2022 NAVPW1
	
begin
	debtorColumns := true;
	mappingTable := self.tblData;
	bank := self.myCurrentBank;
	
	// ### TFS 54566 06Oct2022 NAVPW1
	create invLineTypeArray transient;
	self.mulInvLineTypes.getSelected(invLineTypeArray);
	
	if invLineTypeArray.isEmpty then
		bank.invoiceLineDescriptors.copy(invLineTypeArray);
	endif;
	
	mappingTable.columns := 1;
	mappingTable.fixedColumns := 1;
	i := 1;
	//foreach invoiceLineDesc in bank.invoiceLineDescriptors where not invoiceLineDesc.isNotAvailableForEntry do
	foreach invoiceLineDesc in invLineTypeArray where not invoiceLineDesc.isNotAvailableForEntry do	// ### TFS 54566 06Oct2022 NAVPW1
		i := i + 1;
	endforeach;
	
	mappingTable.rows := i;
	mappingTable.clear;
	mappingTable.row := 1;
	mappingTable.columnWidth[1] := 260;
	i := 1;
	mappingTable.accessCell(1,1).text := "Invoice Line Types";
	mappingTable.accessedCell.fontBold := true;
	mappingTable.accessedCell.alignment := Table.Alignment_Left_Top;
	//foreach invoiceLineDesc in bank.invoiceLineDescriptors where not invoiceLineDesc.isNotAvailableForEntry do
	foreach invoiceLineDesc in invLineTypeArray where not invoiceLineDesc.isNotAvailableForEntry do	// ### TFS 54566 06Oct2022 NAVPW1
		i := i + 1;
		mappingTable.row := i;
		mappingTable.text := invoiceLineDesc.narration;
		mappingTable.accessRow(i).itemObject := invoiceLineDesc;
	endforeach;
	mappingTable.accessColumn(1).backColor := self.colorHeadingColumn;
	self.setEnableObjects(); // 20.3.2023 navmk20 TFS 56954
epilog
	delete invLineTypeArray;	// ### TFS 54566 06Oct2022 NAVPW1
	
end;</source>
    </JadeMethod>
    <JadeMethod name="loadRateTableByColumnSL" id="ebcc34bf-2218-4c7d-a144-9979ef6e2d9b">
        <source>loadRateTableByColumnSL(_sl : CM_ShippingLine; _company:CM_Bank; _level:Integer; _rateTable:Table io; _col:Integer io; _timeStamp:TimeStamp; _progress:CMS_Progress io);
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20 Feb 2018	jlgmd1		TFS 36954 SNO - Error in SCT2 Rate Table (Swap $CM_RateEntry.decimalPlaces for terminal config)
// ---------------------------------------------------------------------------

vars
	shipPortGroup : CM_ShipPortGroup;
	lineGroupDebtor : CM_LineGroupDebtor;
	service : CM_Service;
	i,j : Integer;
	rateEntry : CM_RateEntry;
	dpl : Integer;
	symbol : Character;

begin

	// TFS 36954 MPD 20 Feb 2018
	dpl := self.getRateEntryDecimalPlaces;
	symbol := app.myRoot.getInvoiceCurrencySymbol.Character;

	foreach shipPortGroup in _sl.shipPortGroups do
		foreach lineGroupDebtor in shipPortGroup.lineGroupDebtors do
			_rateTable.row := 1;
			_rateTable.column := _col;
			_rateTable.text := lineGroupDebtor.code;
			_rateTable.accessColumn(_col).itemObject := lineGroupDebtor;
			j := 1;
			_progress.setAction("Getting rates for Line Group Debtor: " &amp; lineGroupDebtor.code);
			_progress.progress.partsDone := _col - 1;
			app.doWindowEvents(0);

			foreach service in _company.services do
				j := j + 1;
				_rateTable.row := j;
				rateEntry := lineGroupDebtor.getServiceTimeRate(_company, service, _timeStamp);
				if rateEntry &lt;&gt; null then
					//_rateTable.text := rateEntry.getDerivedCostPerUnit(_timeStamp).userCurrencyFormat($CM_RateMoney);
					_rateTable.text := symbol &amp; rateEntry.getDerivedCostPerUnit(_timeStamp).asStringJMTWithPrecision(dpl, false);	// TFS 36954 MPD 20 Feb 2018
					if rateEntry.rate.isKindOf(CM_LineGroupDebtorRate) then
						if rateEntry.rate.CM_LineGroupDebtorRate.lineGroupDebtor = lineGroupDebtor then
							_rateTable.fontBold := true;
						else
							_rateTable.fontBold := false;
						endif;
					else
						_rateTable.fontBold := false;
					endif;
					_rateTable.accessCell(j,_col).itemObject := rateEntry;
				endif;
			endforeach;
			_col := _col + 1;

		endforeach;
	endforeach;

end;</source>
        <Parameter name="_sl" type="CM_ShippingLine"/>
        <Parameter name="_company" type="CM_Bank"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_rateTable" type="Table" usage="io"/>
        <Parameter name="_col" type="Integer" usage="io"/>
        <Parameter name="_timeStamp" type="TimeStamp"/>
        <Parameter name="_progress" type="CMS_Progress" usage="io"/>
    </JadeMethod>
