    <JadeMethod name="typeString" id="e59e7743-8519-4c2f-8aa5-e11e33e340d6">
        <methodInvocation>mapping</methodInvocation>
        <source>typeString(set: Boolean; _value: String io) mapping;
//05 Jun 2025 navma1 MTN-34114  MTN - Performance Improvements - Remove Class::FirstInstance usage  
vars
	taType : CM_TerminalAreaType;
	root   : CM_Root;
begin
	
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	root    := app.myRoot;										//05.06.2025 navma1 #MTN-34114
	taType  := root.allTerminalAreaTypes[self.type];			//05.06.2025 navma1 #MTN-34114
	
	
	if taType = null then
		_value := "Unknown";
	else	
		_value := taType.description.trimRight;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateMachines" id="247f2eec-55c1-421b-b263-bbf76b56873a">
        <updating/>
        <source>updateMachines(_machines : CM_MachineSet) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22/08/2011	cnwdap1	Initial creation PAR #28047 CCMS POL 2095 update selected machines for this terminal area
14 12 2011	cnwer1	PAR 28714
24 Apr 2012	cnwkpd1	PAR #29471 - Fix proxy CM_Machine leaks

*/
vars
//	machine, pxyMachine, realMachine	: CM_Machine;
	
begin
	// PAR #29471 - Replaced all code with clear and copy
	self.allowedMachines.clear();
	_machines.copy(self.allowedMachines);
	
/*	// if we're dealing with the persistent object, remove it from the machine collections of terminal areas
	if not self.isTransient then
		foreach machine in self.allowedMachines do
			machine.allowedTAMasters.remove(self);
		endforeach;
	endif;
	
	// if we're transient, create proxy machines and update these
	// if we're persistent, get the ral machine from the proxies and udpate these
	foreach machine in _machines do
		if self.isTransient then
			//if the machine is allowed for both the RMG area and the RMG interchange area could get a proxy already exists error
			pxyMachine:= app.myProxyManager.getProxyObject(machine).CM_Machine;
			if pxyMachine = null then
				pxyMachine := app.createUpdateProxy(machine).CM_Machine;
			endif;
			pxyMachine.addTAMaster(self);
		else
			realMachine := machine.pxyGetRealObject();
			realMachine.addTAMaster(self);
		endif;
	endforeach;
*/
epilog

end;</source>
        <Parameter name="_machines" type="CM_MachineSet"/>
    </JadeMethod>
