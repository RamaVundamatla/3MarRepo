    <JadeMethod name="initTemplateUsers" id="0396885e-de5a-4c7a-868c-7374ce117076">
        <source>initTemplateUsers(_user : CM_User) protected;
// -------------------------------------------
// Created 10 December 2004 by cnwdvb1
// -------------------------------------------
vars

	aUser 			: CM_User;
	organisation	: CM_Organisation;

begin

	if not self.canAccessTemplates then
		return;
	endif;
	
	app.myPassport.getAllAccessibleUsers(self.allTemplateUsersOutput);

	foreach aUser in self.allTemplateUsersOutput do
		if aUser.canDo(self.myTerminal, PmRptTemplateMaint) then
			self.allTemplateUsersEdit.add(aUser);
		endif;
	endforeach;
	
end;</source>
        <access>protected</access>
        <Parameter name="_user" type="CM_User"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="69274c03-8415-4275-8b3f-b381277d369a">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     24 July 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	theActiveControl	: Control;
	userReport : CM_MenuUserItem;
	jadeReport : CM_JadeReport;
	data : JadePrintData;
begin
	inheritMethod(keyCode, shift);
	
	if keyCode = J_key_Tab then
		theActiveControl := app.activeControl;
		
		if theActiveControl.parent.isKindOf(CM_EntryTable) then
			theActiveControl := theActiveControl.parent.CM_EntryTable;
		endif;
		
		if not theActiveControl.isKindOf(CM_EntryTable) then
			return;
		endif;
		
		if theActiveControl.CM_EntryTable = self.tblParameter then
			self.tblParameter.handleFormTab(keyCode, shift, self.lbReportTree, self.cmbProcess);
		elseif theActiveControl.CM_EntryTable = self.tblPrintOptions then
			self.tblPrintOptions.handleFormTab(keyCode, shift, self.tblParameter, self.btnPrint);
		endif;
		
		theActiveControl.CM_EntryTable.handleTableTab(shift);
	elseif keyCode = J_key_F11 then
		if self.myMenuEntity &lt;&gt; null then
			self.myMenuEntity.inspect;
		endif;
	elseif 	keyCode = J_key_F and shift.bitAnd(2) &lt;&gt; 0 then	// CTRL-F
		self.doReportSearch();
		return;
	elseif keyCode = J_key_Enter then
		self.doLbReportTreeSearch();
		return;
	endif;
	
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
