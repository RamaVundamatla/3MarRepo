<GUIClass name="INV_CargoSearchForm" id="65614c30-ad56-49e0-837b-3e9da1ffa112">
    <superclass name="CMUI_CargoSearchForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <JadeMethod name="addTIs" id="3ab377ba-66c8-4ffd-9727-15d5741b827b">
        <updating/>
        <source>addTIs() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 September 2019	jlgzm1	Initial creation TFS 46054 STWO Adding Extra Details to Manual Invoice Lines
10 March 2023  navmv20 TFS 56128 Task 56129: UI - Manual Invoice Lines - Multi TI Invoice Line Type

*/

vars
	allSelectedObjects : CM_TIArray;
	obj : Object;
	row, count : Integer;
	ti : CM_TrackedItem;
	idx : Integer;
	iter : Iterator; //10/03/2023  navmv20 TFS 56128 Task 56129
begin
	create allSelectedObjects transient;
	self.tblResults.allSelectedObjects.copy(allSelectedObjects);
	if allSelectedObjects.size = 0  then
		app.msgBox(app.getErrorString2(CMUI_Please_Select, "cargo item", "add"),app.getErrorString(NOTHING_SELECTED), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	//10/03/2023  navmv20 TFS 56128 Task 56129 - START
	iter := allSelectedObjects.createIterator();
	while iter.next(ti) do
	// Currently should only be able to select one item, but just in case, only use the first item
	//ti := allSelectedObjects.first;
	
	/*if ti = null then
		return;
	endif;*/
	//10/03/2023  navmv20 TFS 56128 Task 56129 - END
	
	if not self.allSelectedTrackedItems.includes(ti) then
		self.allSelectedTrackedItems.add(ti);
	endif;
	
	//self.tblSelectedItems.clearAllData(); //10/03/2023  navmv20 TFS 56128 Task 56129
	
	idx := self.tblSelectedItems.updateItemObject(ti, self.colorRow1, self.colorRow2, app.myPassport);
	self.tblSelectedItems.accessRow(idx).itemObject := ti;
	self.tblResults.removeItemObject(ti);
	// should only be able to have one item selected, disable the button so no more can be added
	//btnAdd.enabled := false; //10/03/2023  navmv20 TFS 56128 Task 56129
	endwhile; //10/03/2023  navmv20 TFS 56128 Task 56129
	
epilog
	delete allSelectedObjects;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadCombos" id="5416f71d-6cc8-4797-9b3d-d4152cbeebb6">
        <source>loadCombos();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 September 2019	jlgzm1	Initial creation TFS 46054 STWO Adding Extra Details to Manual Invoice Lines

*/

vars
	termArea : CM_TerminalArea;
	
begin

	self.cmbSite.clear;
	
	self.cmbSite.addItem(app.siteEnumToString(TI_SITE_ONSITE));
	self.cmbSite.addItem(app.siteEnumToString(TI_SITE_ONSHIP));
	self.cmbSite.addItem(app.siteEnumToString(TI_SITE_OFFSITE));
	self.cmbSite.addItem(app.siteEnumToString(SEL_QUERYSITE_NOTIFIED));
	
	self.cmbSite.setForText(app.siteEnumToString(TI_SITE_ONSITE));
	
	foreach termArea in self.myTerminal.allTerminalAreas do
		self.txtLocation.addItem(termArea.id);
	endforeach;
	
	self.myAssistant.listTableColour(self.lstColourList);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="removeTIs" id="0acdeb25-2450-4b52-a229-b08a4b7c1a58">
        <source>removeTIs();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 September 2019	jlgzm1	Initial creation TFS 46054 STWO Adding Extra Details to Manual Invoice Lines

*/

vars

begin
	inheritMethod();
	
	// if table is empty then re-enable 'add' button
	if tblSelectedItems.rows &lt;= 1 then
		btnAdd.enabled := true;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="e0f0199d-e948-4c2c-bbe7-789644539844">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 September 2019	jlgzm1	Initial creation TFS 46054 STWO - Adding Extra Details to Manual Invoice Lines
10 March 2023  navmv20 TFS 56128 Task 56129: UI - Manual Invoice Lines - Multi TI Invoice Line Type
*/

vars

	form : INV_ListInvoices;
	cargoId : String;
	cargoType	: CM_CargoType;
	cargoOperator : CM_Operator;
	cargoLocation : CM_LocationsController;
	cargoTA : CM_TerminalArea;

begin
	inheritMethod();
	
	// should only be able to select one item
	//self.tblResults.multiSelect := CM_BaseTable.MultiSelect_None;	//10/03/2023  navmv20 TFS 56128 Task 56129
	
	//13 Dec 2019	NDL	TFS 47954
	if self.myParentForm &lt;&gt; null and self.myParentForm.isKindOf( INV_ListInvoices ) then
		form := self.myParentForm.INV_ListInvoices;
		if form &lt;&gt; null then
			cargoId := form.tblInvProperties.getValueByName(ETRow_CargoId).String;
			cargoType	:= form.cmbCargoTypeInvP.listObject.CM_CargoType;	
			cargoOperator := form.cmbCargoOper.listObject.CM_Operator;
			cargoLocation := form.cmbCargoLoc.listObject.CM_LocationsController;
			if cargoId &lt;&gt; null then
				self.txtCargoID.setValue( cargoId );
			endif;
			if cargoType &lt;&gt; null then
				self.cmbCargoTypes.setObject( cargoType );
			endif;
			if cargoOperator &lt;&gt; null then
				self.cmbOperatorCode.setObject( cargoOperator );
			endif;
			if cargoLocation &lt;&gt; null then
				cargoTA := cargoLocation.getMyTerminalArea;
				if cargoTA &lt;&gt; null then
					self.txtLocation.setValue( cargoTA.id );
				endif;
			endif;
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="35191fd9-2fbe-42d5-8e57-0afac001ad74">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 30 September 2019 08:37:36.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023745, locale);
end;</source>
    </JadeMethod>
</GUIClass>
