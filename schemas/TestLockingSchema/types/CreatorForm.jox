    <JadeMethod name="btnStart_click" id="8035778c-f132-4268-b1f5-77c3b14915c9">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnStart_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 March 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars
	p				: ParentClass;
	c				: ChildClass;
	noParents,
	noChildren,
	sleepTime,
	i,
	count			: Integer;
	
begin
	self.stopped := false;
	
	self.lstLog.clear();
	
	// Tidy up
	beginTransaction;
	ParentClass.instances.purge;
	commitTransaction;
	
	noParents := self.txtParents.text.Integer;
	noChildren := self.txtChildren.text.Integer;
	sleepTime := self.txtSleepTime.text.Integer;
	
	while not self.stopped and count &lt; noParents do
		count := count + 1;
		
		beginTransaction;
		create p;
		p.name := "Parent #" &amp; count.String;
		
		foreach i in 1 to noChildren do
			create c;
			c.name := "Child #" &amp; i.String &amp; " of " &amp; p.name;
			c.myParent := p;
		endforeach;
		commitTransaction;
		
		self.doWindowEvents(sleepTime);
		
		beginTransaction;
		p.name := p.name &amp; ", updated";
		commitTransaction;

		self.doWindowEvents(sleepTime);
		
		beginTransaction;
		delete p;
		commitTransaction;
		
		self.doWindowEvents(sleepTime);

	endwhile;
	
	
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnStop_click" id="1eb36973-c0d1-4b09-aff8-63acb60575a5">
