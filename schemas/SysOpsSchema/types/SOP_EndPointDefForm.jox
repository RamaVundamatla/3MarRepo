    <JadeMethod name="canDoEndpoint" id="04b7ab6f-592d-4f49-bb5c-8e7f538d8c11">
        <source>canDoEndpoint(_endpointDesc : String) : Boolean;
/*
Purpose:	

Date		Who		Reason
17 December 2024	navab1	JIRA 33544
*/

vars
	epTypeType : Integer;
	expDate : Date;
	epType : CM_EWSEndpointType;
begin
	
	// Always show the endpoints for invoice API
	if self.myEntTableView.name = ETView_EndPointInvoiceAPI then
		return true;
	endif;

	epTypeType:= -1;
	epType := self.myEWSAgent.allEWSEndpointTypesByName[_endpointDesc];
	if epType&lt;&gt; null then
		epTypeType := epType.type;
	endif;
	
	return app.myRoot.canDoEWSType(epTypeType, expDate);
epilog

end;</source>
        <Parameter name="_endpointDesc" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="3bcdad52-b8cf-41d5-8504-3770a030bb4c">
        <updating/>
        <source>create() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/04/2023	navdap1		TFS 57207 EUP - Refactor Inspection App API Message
//
vars

begin
	self.permissionView	:= PmAdmExtwebSrvView;
	self.permissionMaint := PmAdmExtwebSrvMaint;
	
	// ### JIRA 33544 17DEC2024 NAVAB1
	create self.myEWSAgent transient;
	self.myEWSAgent.init();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="e337f3c7-ae7c-4c7b-a5e6-bb2225da0b82">
        <updating/>
        <source>doOK() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/04/2023	navdap1		TFS 57207 EUP - Refactor Inspection App API Message
// 20/07/2023	navcs2		Bug 58916: MTN - External Web Service API Endpoint issues
vars
	pxyWebserviceDef : CM_ExternalWebServiceDef;
	tbl : CM_DataTable;
	row, pos, result : Integer;
	description, defname : String;
	endpoint : CM_Endpoint;
	rowValue, verb, point : String;
	endpointTransients : ObjectArray;
	entRow : EntTableRow;

begin
	pxyWebserviceDef := self.myExternalWebServiceDef.CM_ExternalWebServiceDef;		// 20/07/2023 navcs2 Bug 58916
	if pxyWebserviceDef = null then
		return;
	endif;
	
	create endpointTransients transient;
	pxyWebserviceDef.allEndpoints.purge;
	tbl := self.tblEndPoints;
	foreach row in tbl.fixedRows + 1 to tbl.rows do
		if tbl.accessCell(row, 1).text &lt;&gt; null then
			// get end point description, then the matching ent table row
			description := tbl.accessCell(row, 1).text;
			defname := null;
			foreach entRow in self.myEntTableView.allEntTableRows where entRow.getHeadingUnaltered = description do
				defname := entRow.name;
				break;
			endforeach;
			if defname = null then
				continue;
			endif;
			
			// get the verb and endpoint
			rowValue := tbl.accessCell(row, 2).text;
			if rowValue &lt;&gt; null then
				pos := rowValue.pos(Space, 1);
				if pos &lt;&gt; null then
					verb := rowValue[1:pos-1];
					if rowValue.length &gt; pos then
						point := rowValue[pos+1:rowValue.length-pos];
					endif;
				endif;
				if verb &lt;&gt; null and point &lt;&gt; null and defname &lt;&gt; null then
					endpoint := pxyWebserviceDef.allEndpoints[defname];
					if endpoint = null then
						create endpoint transient;
						endpointTransients.add(endpoint);
					endif;
					endpoint.setProxy(defname, point, verb, pxyWebserviceDef);
				endif;
			endif;
		endif;
	endforeach;
	
	/*
	Pending Changes review 20/07/2023 navcs2 Bug 58916
	
	
	while true do
		app.myTrxUA.trxUpdateExtWebService(pxyWebserviceDef, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			 result:= app.showErrorWarningDialog(app.getErrorString(Error), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
	endwhile; 
	*/
	inheritMethod();

epilog
	/*
	Pending Changes review 20/07/2023 navcs2 Bug 58916
	*/
	//if endpointTransients &lt;&gt; null then
		//endpointTransients.purge;
	//endif;
	//delete endpointTransients;
	//delete pxyWebserviceDef;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="bd0f8fff-3590-443f-99f8-56e333144fce">
        <updating/>
        <source>setupForm() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/04/2023	navdap1		TFS 57207 EUP - Refactor Inspection App API Message
// 20/07/2023	navcs2		Bug 58916: MTN - External Web Service API Endpoint issues
vars
	def : EntTableDef;
	view : EntTableView;
	endpoint : CM_Endpoint;
	entRow : EntTableRow;
	displayValue : String;
	idx : Integer;
	tbl : CMUI_ApiEndpointTable;

begin
	inheritMethod();
	
	self.lblDef.caption := self.lblDef.caption &amp; Space &amp; self.myExternalWebServiceDef.name;
	
	self.myEntTableView := self.myExternalWebServiceDef.getEndpointsView; //jlier1 Task 65950 3/9/24 - NSW Dynamics
	
	if not app.myCurrentUserCan(null, PmAdmExtwebSrvMaint) then
		self.tblEndPoints.userInputEnabled := false;
		self.btnOk.enabled := false;
	endif;
	
	self.tblEndPoints.accessCell(1,1).text := "Function" &amp; Tab &amp; "Endpoint Definition";
	self.tblEndPoints.tabKey := J_key_Tab;
	foreach endpoint in self.myExternalWebServiceDef.allEndpoints do
		idx := self.tblEndPointsAddLine(endpoint); // ### JIRA 33544 17DEC2024 NAVAB1 pass in endpoint
		entRow := self.myEntTableView.getEntTableRow(endpoint.defName);
		self.tblEndPoints.accessCell(idx, 1).text := entRow.getHeadingUnaltered;
		displayValue := endpoint.verb &amp; Space &amp; endpoint.endpoint;
		self.tblEndPoints.accessCell(idx, 2).cellControl.CMUI_ApiEndpointTable.setValues(displayValue);
		self.tblEndPoints.accessedCell.text := displayValue;
	endforeach;
	self.tblEndPointsAddLine(null); // ### JIRA 33544 17DEC2024 NAVAB1
	
	// 20/07/2023 navcs2 Bug 58916
	if self.mode = self.myParentForm.SOP_TableMaintForm.Mode_View then
		self.tblEndPoints.enabled := false;
		self.tblEndpointDetails.enabled := false;
		self.btnOk.visible := false;
	endif;
	// 20/07/2023 navcs2 Bug 58916
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblEndPointsAddLine" id="88ac25ed-d11d-414c-82bb-a80548c3f4da">
        <source>tblEndPointsAddLine(_endpoint : CM_Endpoint) : Integer;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/04/2023	navdap1		TFS 57207 EUP - Refactor Inspection App API Message
// 19/07/2023	navcs2		Bug 58916: MTN - External Web Service API Endpoint issues
vars
	idx, tblRow : Integer;
	tbl : CMUI_ApiEndpointTable;
	row : EntTableRow;
	str : String;
	notLicenesed : String;
begin

	idx := self.tblEndPoints.addItem(null);
	if self.myEntTableView &lt;&gt; null then
		foreach row in self.myEntTableView.allEntTableRows do	:outerloop
			//jlier1 TFS 57936 24/5/23
			if row.name = ETRow_BarrierCode and self.myExternalWebServiceDef &lt;&gt; null and not self.myExternalWebServiceDef.isKindOf(CM_APIEndpointServiceDef) then
				continue;
			endif;
			// ### JIRA 33544 17DEC2024 NAVAB1 - are we licensed
			if  not self.canDoEndpoint(row.getHeadingUnaltered()) then
				if _endpoint = null then
					continue;
				else
					if _endpoint.defName &lt;&gt; row.name then // if we are a saved endpoint then include
						continue;
					endif;
					notLicenesed.addStringToList(row.name,","); // ### JIRA 33959 14FEB2025 NAVAB1
				endif;
			endif;
			
			foreach tblRow in self.tblEndPoints.fixedRows + 1 to self.tblEndPoints.rows do
				if self.tblEndPoints.accessCell(tblRow, 1).text = row.getHeadingUnaltered then
					continue outerloop;
				endif;
			endforeach;
			if str = null then
				str := row.getHeadingUnaltered;
			else
				str := str &amp; Tab &amp; row.getHeadingUnaltered;
			endif;
		endforeach;
	endif;
	str := "" &amp; Tab &amp; str;										// 19/07/2023 navcs2 Bug 58916 Added empty line at top of combo
	self.tblEndPoints.accessCell(idx,1).comboList := str;
	self.tblEndPoints.accessedCell.inputType := Table.InputType_ComboBox;
	tbl := self.tblEndpointDetails.loadControl(idx).CMUI_ApiEndpointTable;
	tbl.name := self.tblEndpointDetails.name &amp; "_" &amp; idx.String;
	tbl.setEventMapping("change", "tblEndpointDetails_change");
	tbl.setEventMapping("lostFocus", "tblEndpointDetails_lostFocus");
	tbl.visible := true;
	self.tblEndPoints.accessCell(idx,2).cellControl := tbl;
	
	 // ### JIRA 33959 14FEB2025 NAVAB1
	if notLicenesed &lt;&gt; null then
		app.msgBox("This system is not licensed for end point type '" &amp; notLicenesed &amp; "'.", "Please Note", MsgBox_OK_Only);
		
	endif;
	return idx;
epilog

end;</source>
        <Parameter name="_endpoint" type="CM_Endpoint"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblEndPoints_change" id="eeccee30-d975-448e-9fe5-b84984c06572">
        <controlMethod name="Table::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblEndPoints_change(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
25 July 2023	navcs2	Bug 58916: MTN - External Web Service API Endpoint issues
*/

vars
	row, col : Integer;
	rowValue : String;
begin
	row := table.row;
	col := table.column;
	
	if self.tblEndPoints.accessCell(row, col).text = null then
		self.tblEndPoints.accessCell(row, 2).text := null;
		if self.tblEndPoints.accessCell(row, 2).cellControl &lt;&gt; null then
			self.tblEndPoints.accessCell(row, 2).cellControl.CMUI_ApiEndpointTable.clearRow();
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
