// --------------------------------------------------------------------------------
begin
epilog
	delete self.myIterator;
	delete self.myObjectSet;
end;</source>
    </JadeMethod>
    <ExternalMethod name="displayEntry" id="13c397cd-2de2-425c-bffe-0046a4b63723">
        <updating/>
        <entrypoint>CallControlEvent</entrypoint>
        <library name="jadpmap"/>
        <source>displayEntry(pTheBrowsebuttons: JSSBrowseButtons input; 
			pBrowseType: Integer; 
			pTheObject: Object) is CallControlEvent in jadpmap updating;</source>
        <Parameter name="pTheBrowsebuttons" type="JSSBrowseButtons" usage="input"/>
        <Parameter name="pBrowseType" type="Integer"/>
        <Parameter name="pTheObject" type="Object"/>
    </ExternalMethod>
    <JadeMethod name="listCollection" id="7cfe1f46-3fbb-41d0-8038-65a95ba3decd">
        <updating/>
        <source>listCollection(pTheCollection:Collection; pIsUpdate:Boolean; pShowHow:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		10 February 2003 by cnwdad1
//
// Purpose:		Sets up an iterator for the collection to be bowsed.
//
// Parameters:	pTheCollection - The collection to be browsed.
//				pIsUpdate - Indicates whether to dtect changes to the collection.
//				showpShowHowHow - If '1', the collection order is reversed.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myIterator &lt;&gt; null then
		delete self.myIterator;
	endif;

	if self.myObjectSet &lt;&gt; null then
		delete self.myObjectSet;
	endif;

	if pTheCollection &lt;&gt; null then
		if pTheCollection.isKindOf(VirtualColl) then
			create self.myObjectSet transient;
			pTheCollection.copy(self.myObjectSet);
			self.myIterator	:=	self.myObjectSet.createIterator();
		else
			self.myIterator	:=	pTheCollection.createIterator();
		endif;

		if pIsUpdate then
			beginNotification(pTheCollection, Any_System_Event, Response_Continuous, 1);
		endif;

		self.isShowUpdates	:=	pIsUpdate;
		self.isReversed		:=	(pShowHow = 1);
	endif;
end;</source>
        <Parameter name="pTheCollection" type="Collection"/>
        <Parameter name="pIsUpdate" type="Boolean"/>
        <Parameter name="pShowHow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="ec9414e6-505e-4f7f-b957-389cdfae2571">
        <updating/>
        <source>sysNotify(browsebuttons: JSSBrowseButtons input; eventType: Integer; theObject: Object; eventTag: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		10 February 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	showHow	: Integer;

begin
	app.mousePointer	:=	Busy;
	inheritMethod(browsebuttons, eventType, theObject, eventTag);

	if global.isValidObject(theObject) and theObject.isKindOf(Collection) then
		if self.isReversed then
			showHow	:=	1;
		else
			showHow	:=	0;
		endif;

		self.listCollection(theObject.Collection, self.isShowUpdates, showHow);

		if self.myCurrentObject &lt;&gt; null then
			self.myIterator.startAtObject(self.myCurrentObject);
			self.displayEntry(browsebuttons, 0, self.myCurrentObject);
		endif;
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="browsebuttons" type="JSSBrowseButtons" usage="input"/>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
