    <JadeMethod name="getMeasurementTypeByNameDesc" id="fa1f4f0f-c310-4935-b186-b643a3facde2">
        <source>getMeasurementTypeByNameDesc(_id : String) : CM_MeasurementType;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 07 June 2023	navdap1		Initial creation TFS 57074 EUP - Manifest EDI Operations / Load Task 58604
//
vars
	measure : CM_MeasurementType;

begin
	measure := self.myRoot.allMeasurementTypesByShortName[_id];
	if measure &lt;&gt; null then
		return measure;
	endif;
	
	foreach measure in self.myRoot.allMeasurementTypesByShortName do
		if measure.name = _id then
			return measure;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_id" type="String"/>
        <ReturnType type="CM_MeasurementType"/>
    </JadeMethod>
    <JadeMethod name="getMethodStack" id="3216ac3e-e51d-455b-b15e-389afa427152">
        <source>getMethodStack( _numberOfMethodsToExclude : Integer ) : String;
//09 February 2009	cnwdw1	
//
vars
	stack: HugeStringArray;
	tmpStr,	stackStr : String;

begin
	create stack transient;
	app.getStackDisplayStringArray(stack, _numberOfMethodsToExclude);
	foreach tmpStr in stack do
		stackStr := stackStr &amp; CrLf &amp; tmpStr;
	endforeach;

	return stackStr;
epilog
	stack.purge;
	delete stack;
end;</source>
        <Parameter name="_numberOfMethodsToExclude" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
