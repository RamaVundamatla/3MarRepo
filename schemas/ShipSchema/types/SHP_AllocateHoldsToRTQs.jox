    <JadeMethod name="copyCraneWPAllocations" id="c6b2f0d0-f400-4b99-b1b9-9082c6798028">
        <source>copyCraneWPAllocations();
/*
Purpose:			
Date		Who		Reason
03 February 2015	cnwab1	Initial creation
*/

vars
	iter : Iterator;
	craneWP, hold : CM_Object;
begin
	self.allCranesWPsByHolds.clear();
	
	iter := self.myCurrentVoyage.allCranesWPByHolds.createIterator();
	
		
	while iter.next(craneWP) do
		iter.getCurrentKeys(hold);
		
		if not global.isValidObject(craneWP) or not global.isValidObject(hold) then // remove anny invalid object by not putting them in our local collect. The save clears the voyage's collections and copies the local
			continue;
		endif;
		
		self.allCranesWPsByHolds.putAtKey(hold,craneWP);
	endwhile;


epilog
	delete iter;
end;</source>
    </JadeMethod>
