    <JadeMethod name="cloneReferences" id="03970982-a0de-4dcb-a36a-0fe8cd4cceda">
        <updating/>
        <source>cloneReferences(_sohReporter: CMQF_SOHReporter; _transient : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     18 October 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_sohReporter, _transient);
	self.allTerminals.clear();
	_sohReporter.allTerminals.copy(self.allTerminals);
	
	//self.myActualLogVoyage		:= _obj.myActualLogVoyage;
	//self.myAllocatedLogVoyage	:= _obj.myAllocatedLogVoyage;
	self.setMyVoyageGlobal( _sohReporter.getMyVoyageGlobal );
	self.setMyVoyageGlobalAllocated( _sohReporter.getMyVoyageGlobalAllocated );
	
	self.setMyLocationsController( _sohReporter.getMyLocationsController );
	self.setMyLogGrade( _sohReporter.getMyLogGrade );
	self.setMyLogLength( _sohReporter.getMyLogLength );
	self.setMyLogLot( _sohReporter.getMyLogLot );
	self.setMyLogSpecies( _sohReporter.getMyLogSpecies );
	self.setMyLogTreatment( _sohReporter.getMyLogTreatment );
	self.setMyLogType( _sohReporter.getMyLogType );
	self.myOperator				:= _sohReporter.myOperator;
	self.setMyTerminalArea( _sohReporter.getMyTerminalArea );

end;</source>
        <Parameter name="_sohReporter" type="CMQF_SOHReporter"/>
        <Parameter name="_transient" type="Boolean"/>
    </JadeMethod>
