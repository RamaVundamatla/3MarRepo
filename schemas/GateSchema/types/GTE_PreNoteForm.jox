    <JadeMethod name="getPreNoteOrOnSiteTI" id="fda25573-f4e3-48ef-bb7f-0728a9b147ec">
        <source>getPreNoteOrOnSiteTI(pCode : String) : CM_TrackedItem protected;
//--------------------------------------------------------------
//Created: 06 March 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	cargoType : Integer;
	tmpTI	: CM_TrackedItem;
begin

	if self.cmbTiType.listObject &lt;&gt; null then
		cargoType := cmbTiType.listObject.CM_CargoBOLType.id;
	else
		cargoType := TI_CargoType_Null;
	endif;

	tmpTI := self.myTerminal.lookupTrackedItem(pCode, cargoType, TI_STATE_NOTIFIED, null, true);
	if tmpTI &lt;&gt; null then
		return tmpTI;
	endif;
	return self.myTerminal.lookupTrackedItem(pCode, cargoType, TI_STATE_NORMAL, null, true);
end;</source>
        <access>protected</access>
        <Parameter name="pCode" type="String"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
