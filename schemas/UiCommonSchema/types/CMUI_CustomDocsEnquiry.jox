    <JadeMethod name="buildCombAgent" id="51ea747a-b813-4d5f-96e2-f2924e262e03">
        <source>buildCombAgent();
/*
Purpose:			

Date		Who		Reason
09 August 2023	navab1	CR 56094 TASK 59618
*/

vars
	cmb : CMUI_ComboBox;
	obj : CM_CustomsAgent;
begin
	cmb := self.cmbAgent;
	
	cmb.sorted := true;
	
	foreach obj in app.myRoot.allCustomsAgents discreteLock do
		if obj.isNotAvailableForEntry then
			continue;
		endif;
		
		cmb.addItemObject(obj.code &amp; Tab &amp; obj.name,obj);
	endforeach;
	
	cmb.sorted := false;
	cmb.addItemObject(null,null);		
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="buildCombCargoGroups" id="1659b057-ba0b-4a53-8551-e84d64e29487">
        <source>buildCombCargoGroups();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 February 2024	navrv30	Bug 61880: EUP | FR 53715 - Customs Enquiry screen - Query Issues

*/

vars
	cmb : CMUI_ComboBox;
	obj : CM_TrackedItem;
begin
	cmb := self.cmbCargoGroup;
	
	cmb.sorted := true;
	
