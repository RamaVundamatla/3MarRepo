    <JadeMethod name="changeHSCode" id="fa67d623-f135-4c3b-8c30-71de7613c46d">
        <source>changeHSCode(_code : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 December 2022	jlier1	Initial creation
26/02/2023			navkc1 	CR 59577 Task 62412: UI - HS Code Sys Admin
*/

vars
	hsType : Integer;
	parentValue : String;
	hsCode : CM_HarmonizedSystem;
begin
	
	hsType:=self.myForm.comboBox1.listData;
		
	if hsType =  CM_HarmonizedSystem.HS_SubCode then
		if _code.length &gt; 5 then
			hsCode := app.myRoot.allHSCodes[_code[1:6]];
			if hsCode &lt;&gt; null then
				self.myForm.tblInput1.setValueByName(ETRow_HsParentCode,_code[1:6]);
			endif;
		endif;
	elseif hsType = CM_HarmonizedSystem.HS_Code then
		if _code.length &gt; 3 then
			hsCode := app.myRoot.allHSHeadings[_code[1:4]];
			if hsCode &lt;&gt; null then
				self.myForm.tblInput1.setValueByName(ETRow_HsParentHeading,_code[1:4]);
			endif;
		endif;
	elseif hsType =  CM_HarmonizedSystem.HS_Chapter then
		//can't derive parent from chapter string
	elseif hsType = CM_HarmonizedSystem.HS_Heading then
		if _code.length &gt; 1 then
			hsCode := app.myRoot.allHSChapters[_code[1:2]];
			if hsCode &lt;&gt; null then
				self.myForm.tblInput1.setValueByName(ETRow_HsParentChapter,_code[1:2]);
			endif;
		endif;
	elseif hsType = CM_HarmonizedSystem.HS_Taric then //26/02/2023	navkc1 CR 59577 Task 62412
		if _code.length() &gt; 7 then
			hsCode := app.myRoot.allHSSubCodes[_code[1:8]];
			if hsCode &lt;&gt; null then
				self.myForm.tblInput1.setValueByName(ETRow_HsParentSubCode,_code[1:8]);
			endif;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_code" type="String"/>
    </JadeMethod>
    <JadeMethod name="create" id="0fa76ec1-97bb-4866-95c0-ea1204693870">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 December 2022	jlier1	Initial creation 55583

*/

vars

begin
	self.name := SOP_TableMaintForm.Table_HSCodes;
	self.permissionView	 := PmAdmHSCodeSystemView;
	self.permissionMaint := PmAdmHSCodeSystemMaint;
	self.myDataClass := CM_HarmonizedSystem;
	
	self.allHSCodes.setMembership(CM_HarmonizedSystem);
	self.allHSCodes.addMemberKey(CM_HarmonizedSystem::id.name,false,false);
	self.allHSCodes.endKeys(true);
epilog

end;</source>
    </JadeMethod>
