    <JadeMethod name="doSave" id="ab21fbb4-d0da-404d-a133-dcf131cc4e7a">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     14 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 31/10/2008	consw1		SFW1030 - Rework of Yard Allocations
// 25/02/2010	consw1		PAR #22337 - Correct setting of 'Default Contents Status for Pack Complete' option
// 22 June 2016	cnwns1	TFS 488 - Multi Timezone Support
// 04/07/2017	cnwdap1		TFS 4492 SNO VERMAS Changes
// 21/06/2023	navdap1		TFS 56747 EUP Manifest Load - Internal (Zimmer) - Create
// 01/09/2023	jlizm1		TFS 59985 Truck Seals design changes
// 01/08/2025   navsp1      JIRA-35530 Solution Implementation - COPRAR Trailer Support
// ---------------------------------------------------------------------------
vars
	theForm				: SOP_TableMaintForm;
	tmpCode				: String;
	tmpName				: String;
	dfltCargoBOLType	: CM_CargoBOLType;
	dfltBOLType			: CM_BOLType;
	dfltCargoType,
    dfltTrailerCargoType: CM_CargoType;
    dfltTrailerCargoTypeId : Integer;
	dfltCargoBOLTypeId	: Integer;
	dfltBOLTypeId		: Integer;
	dfltCargoTypeId		: Integer;
	dfltGroupId			: Integer;				// TFS 56747
	dfltGroupType		: CM_CargoType;			// TFS 56747
	col					: CM_CargoBOLTypeArray;
	realTerminal		: CM_Terminal;
	proxyTerminal		: CM_Terminal;
	tempConfig			: CMIF_Config;
	sealShipRec			: Integer;
	sealShipRel			: Integer;
	sealRailRec			: Integer;
	sealRailRel			: Integer;
	sealRoadRec			: Integer;
	sealRoadRel			: Integer;
	sealPack			: Integer;
	sealUnpack			: Integer;
	sealWagonLoad		: Integer;	//10 Mar 2015	NDL	Par 35828
	sealWagonDischarge	: Integer;
	sealTruckLoad		: Integer;
	sealTruckDischarge	: Integer;
	timezoneID,
	timezoneIDShort		: String;
	timezone			: CMIF_TimeZoneInfo;
	
	theController : CMIF_InvoiceSystemDefaults;
	pxyPrenoteValidation : CM_TermPrenoteWeightCriteria;
	cmif_object : CMIF_Object;
	pxyCriteria : CM_YACriteria;
	criteriaToPurge : ObjectSet;
	weighAuth : CM_WeighAuthority;				// TFS 4492
begin

	//epr TFS 8211 19/12/17 removed old drawing stuff

	theForm := self.myForm;
		
	tmpCode	:= theForm.tblInput1.getValueByName(ETRow_Code).String;
	tmpName := theForm.tblInput1.getValueByName(ETRow_Name).String;
	if theForm.cmbTerminalTZone.listIndex &gt; 0 then
		timezone := theForm.cmbTerminalTZone.itemObject[theForm.cmbTerminalTZone.listIndex].CMIF_TimeZoneInfo;
		timezoneID := timezone.id;
	endif;
	timezoneIDShort := self.myIntFaceConfig.timeZoneShortID;
	
	create col transient;
	theForm.mulSelect2.getSelected(col);
	dfltCargoBOLType := theForm.cmbCargoBOLType.listObject.CM_CargoBOLType;
	if dfltCargoBOLType = null then
		dfltCargoBOLTypeId := TI_CargoType_Null;
	else
		dfltCargoBOLTypeId := dfltCargoBOLType.id;
	endif;
	
	dfltCargoType := theForm.cmbCargoType2.listObject.CM_CargoType;
	if dfltCargoType = null then
		dfltCargoTypeId := TI_CargoType_Null;
	else
		dfltCargoTypeId := dfltCargoType.id;
	endif;
	
	dfltBOLType := theForm.cmbBOLType.listObject.CM_BOLType;
	if dfltBOLType = null then
		dfltBOLTypeId := TI_CargoType_Null;
	else
		dfltBOLTypeId := dfltBOLType.id;
	endif;
	
	// TFS 56747 start
	dfltGroupType := theForm.cmbCargoGroup.listObject.CM_CargoType;
	if dfltGroupType = null then
		dfltGroupId := TI_CargoType_Null;
	else
		dfltGroupId := dfltGroupType.id;
	endif;
	// TFS 56747 end

    dfltTrailerCargoType := theForm.cmbTrailerCargoType.listObject.CM_CargoType;        //JIRA-35530
    if dfltTrailerCargoType = null then                                                 //JIRA-35530
        dfltTrailerCargoTypeId  := TI_CargoType_Null;                                   //JIRA-35530
    else                                                                                //JIRA-35530
        dfltTrailerCargoTypeId  := dfltTrailerCargoType.id;                             //JIRA-35530
    endif;                                                                              //JIRA-35530
    
	theForm.tblInput2.setObjectFromTable(self.myIntFaceConfig, 'setObjectFromTableSpecial', false);
	
	
	// ###############################
	// ###############################
	// ###############################
	// ###############################
	
	// ### IF YOU HAVE ADDED TO THE FINANCIAL CONFIG YOU MUST ALSO UPDATE INV_InvoiceSystemDefaults
	create theController transient; // PAR 33572
	if not self.setControllerFromTable(theController) then // PAR 33572
		delete theController; // this means do not save the INV_InvoiceSystemDefaults
	endif;
	
	//cnwmc5 - PAR 32690
	if app.myRoot.isDeprecated("8.1.2") then
		self.myIntFaceConfig.useBookingSummView := true;
	endif;

	if (not self.myIntFaceConfig.gateInAllowAutoComplete) then
		self.myIntFaceConfig.gateInAutoComplete := false;
		//self.myIntFaceConfig.gateInAutoCompleteBkgrnd := false;
		self.myIntFaceConfig.gateIOHideAutoComplete := true;
	endif;

	// PAR 18111
//	self.myIntFaceConfig.defaultContentsStatus := theForm.cmbContentStatus.text;
	
	//+cnwml2 PAR23715 SFW CCMS1131
	sealShipRec := app.sealCheckTypeStringToEnum(theForm.tblFldSheet1.accessCell(2,2).text);
	sealShipRel := app.sealCheckTypeStringToEnum(theForm.tblFldSheet1.accessCell(2,3).text);
	sealRailRec := app.sealCheckTypeStringToEnum(theForm.tblFldSheet1.accessCell(3,2).text);
	sealRailRel := app.sealCheckTypeStringToEnum(theForm.tblFldSheet1.accessCell(3,3).text);
	sealRoadRec := app.sealCheckTypeStringToEnum(theForm.tblFldSheet1.accessCell(4,2).text);
	sealRoadRel := app.sealCheckTypeStringToEnum(theForm.tblFldSheet1.accessCell(4,3).text);
	sealPack := app.sealCheckTypeStringToEnum(theForm.tblFldSheet1.accessCell(5,3).text); //( pack = Release )
	sealUnpack := app.sealCheckTypeStringToEnum(theForm.tblFldSheet1.accessCell(5,2).text); //( unpack = Receive )
	sealWagonLoad := app.sealCheckTypeStringToEnum(theForm.tblFldSheet1.accessCell(6,3).text); //Release
	sealWagonDischarge := app.sealCheckTypeStringToEnum(theForm.tblFldSheet1.accessCell(6,2).text); // Receive
	sealTruckLoad := app.sealCheckTypeStringToEnum(theForm.tblFldSheet1.accessCell(7,3).text);
	sealTruckDischarge := app.sealCheckTypeStringToEnum(theForm.tblFldSheet1.accessCell(7,2).text);
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_Terminal transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
	
	weighAuth := theForm.cmbCertName.listObject.CM_WeighAuthority;						// TFS 4492

	proxyTerminal := theForm.myProxyObject.CM_Terminal;
		
	
	// 22 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	proxyTerminal.setProxy(tmpCode, tmpName,timezoneID,timezoneIDShort, col, dfltCargoTypeId, dfltBOLTypeId, dfltCargoBOLTypeId, dfltGroupId, dfltTrailerCargoTypeId, weighAuth);	// TFS 56747
	proxyTerminal.setSealCheckProxy(sealShipRec, sealShipRel, sealRailRec, sealRailRel, sealRoadRec, sealRoadRel, sealPack, sealUnpack,
									sealWagonLoad, sealWagonDischarge, sealTruckLoad, sealTruckDischarge);				//+cnwml2 PAR23715 SFW CCMS1131

	//epr TFS 1882 17/5/16
	pxyPrenoteValidation:= proxyTerminal.myPrenoteWeightCriteria;
	if pxyPrenoteValidation = null then
		create pxyPrenoteValidation transient;
		pxyPrenoteValidation.setMyTerminal(proxyTerminal);
	endif;
	
	create criteriaToPurge transient;
	pxyPrenoteValidation.allCriteria.copy(criteriaToPurge);
	pxyPrenoteValidation.allCriteria.clear;
	foreach cmif_object in self.allCriteria do
		pxyCriteria := cmif_object.CMIF_YACriteriaPriority.myProxy.CM_YACriteria;
		pxyPrenoteValidation.allCriteria.add(pxyCriteria);
		if criteriaToPurge.includes(pxyCriteria) then
			criteriaToPurge.remove(pxyCriteria);
		endif;
	endforeach;
	
	criteriaToPurge.purge;
	
	
	if theForm.mode = theForm.Mode_Add then
		tempConfig := self.myIntFaceConfig;
		app.myTrxCA.trxCreateTerminal(proxyTerminal, app.actualTimeServer.date, tempConfig, realTerminal, app.myPassport);

	
	elseif theForm.mode = theForm.Mode_Update then
		tempConfig := self.myIntFaceConfig;
		app.myTrxUA.trxUpdateTerminal(proxyTerminal, tempConfig, theController, app.myPassport); // PAR 33572
		
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;

	
	
	return app.myPassport.trxCompletedOK();
epilog
	delete col;
	delete theController;
	delete criteriaToPurge;
	//return app.myPassport.noErrors();
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
