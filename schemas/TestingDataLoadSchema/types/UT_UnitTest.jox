    <JadeMethod name="ignoreTrxWarnings" id="2897f2b5-4a8f-4497-b9d7-9bdf5dd1ffdb">
        <source>ignoreTrxWarnings(_value: Boolean) protected;
//25 September 2009	cnwdw1	
