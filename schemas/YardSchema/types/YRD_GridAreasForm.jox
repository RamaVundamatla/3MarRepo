    <JadeMethod name="doScrollToCorners" id="40a1f9f9-5c3b-4eec-b81a-fab6d05e7c54">
        <updating/>
        <source>doScrollToCorners(pCorner: Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     23 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	//epr par 15087
	if self.myCurrentDrawingController = null then
		return;
	endif;
	self.myCurrentDrawingController.doScrollToCorners(pCorner);

end;</source>
