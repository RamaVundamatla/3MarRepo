    <JadeMethod name="getWeightForValidation" id="fc0fac28-ed9e-46e7-9785-a742d89fe41e">
        <source>getWeightForValidation():Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 September 2013	cnwndl1	Initial creation	Par 

*/

vars

	ti : CM_TrackedItem;
	weightOfMovingCargo : Decimal [16,4];
	quantity : Integer;

begin

	ti := self.myTrackedItem;
	if ti &lt;&gt; null then
		weightOfMovingCargo := ti.totalWeight;
		if self.quantity &gt; 0 and ti.canSplitTotalQuantity then
			if self.quantity &lt; ti.totalQuantity then
				weightOfMovingCargo := ti.totalWeight * ( quantity / ti.totalQuantity );
			endif;
		endif;
	endif;
	
	return weightOfMovingCargo;

epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
