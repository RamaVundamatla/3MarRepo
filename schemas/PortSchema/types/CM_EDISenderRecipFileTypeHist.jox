    <JadeMethod name="dateFormat" id="8af3fcaa-042b-4461-b852-575cf0432c22">
        <source>dateFormat(_timeStamp: TimeStamp):String;
//
//10 Sep 2015	cnwrs1	Par 32883 - EDI File Type sequence number
//
vars

begin
	return _timeStamp.date.shortFormatJMT() &amp; " " &amp; _timeStamp.time.shortFormatJMT()&amp;' ';
end;</source>
        <Parameter name="_timeStamp" type="TimeStamp"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayString" id="8fa8bd82-db11-4865-83d7-24076bf65f61">
        <source>displayString() : String;
//
//18 Sep 2015	cnwrs1	Par 32883 - EDI File Type sequence number
//
vars
	str : String;
begin
	return self.fileVersion&amp;Tab&amp;
		   self.dateFormat(fileDateTime)&amp;Tab&amp;
	       self.fileName&amp;Tab&amp;
		   self.seqNumber.String;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="findDeletedAuditRecord" id="0016c0d8-1505-49c5-9758-b6b949f6b7fa">
        <source>findDeletedAuditRecord() : CM_AuditObject;

vars
	ediData : CM_EDIData;
	deleted : Boolean;
	auditObject : CM_AuditObject;
	auditConfig : CM_AuditConfig;
	startDT : TimeStamp;
begin
	ediData := self.getMyEDIData(deleted);
	if ediData &lt;&gt; null then
		return ediData.allAuditObjectsForClass.first;	//21 Jan 2021	NDL	TFS 50251
	else
		if deleted then
			startDT := self.creationTime;
			auditConfig := app.myRoot.allAuditConfigs[CM_EDIData.name];
		else
			return null;
		endif;
	endif;
	
end;
</source>
        <ReturnType type="CM_AuditObject"/>
    </JadeMethod>
    <JadeMethod name="getConfigNumber" id="3d5a88c9-f4ce-49c7-b08a-225b50a372e4">
        <source>getConfigNumber() : Integer;
//
