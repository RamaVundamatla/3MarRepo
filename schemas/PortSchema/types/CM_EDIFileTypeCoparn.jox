					nad1_1Function := CM_EDIEDIFactRule.Fnct_NAD_n_1_CargoOper_Desc;
				elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_Consignee then
					nad1_1Function := CM_EDIPrenoteTI::consignee.name;
					nad1_Booking := true;
				elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_Consignor then
					nad1_1Function := CM_EDIPrenoteTI::consignor.name;
					nad1_Booking := true;
				elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_CustomAgent then
					nad1_1Function := CM_EDIBookingHeaderTI::customsAgent.name;
					nad1_Booking := true;
				elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_FreightForwd then
					nad1_1Function := CM_EDIPrenoteTI::freightForwarder.name;
					nad1_Booking := true;
				elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_RecCarrier then
					nad1_1Function := CM_EDIEDIFactRule.Fnct_NAD_n_1_RecCarrier_Desc;
				elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_RelCarrier then
					nad1_1Function := CM_EDIEDIFactRule.Fnct_NAD_n_1_RelCarrier_Desc;
				elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_WghtCertNam then
					nad1_1Function := CM_EDIPrenoteTI::weightCertifiedName.name;
					nad1_Prenote := true;
				elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_WghtCertRef then
					nad1_1Function := CM_EDIPrenoteTI::weightCertifiedReference.name;
					nad1_Prenote := true;
				endif;
				if nad1_1Function &lt;&gt; null then
					_msgHelper.setNextField();
					if nad1_Booking then
						if params.mySenderOperator &lt;&gt; null then
							bookingHdr.setPropertyValue(nad1_1Function, params.mySenderOperator.getXlationSystemCode(_msgHelper.currentSubItem, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch)[1:30]);
						else
							bookingHdr.setPropertyValue(nad1_1Function, _msgHelper.currentSubItem.trimBlanks()[1:30]);
						endif;
						if prenoteEDITI &lt;&gt; null then
							prenoteEDITI.setPropertyValue(nad1_1Function, bookingHdr.getPropertyValue(nad1_1Function));
						endif;
					endif;
					if nad1_1Function = CM_EDIEDIFactRule.Fnct_NAD_n_1_CargoOper_Desc then
						if params.mySenderOperator &lt;&gt; null then
							cargoOperatorCode := params.mySenderOperator.getXlationSystemCode(_msgHelper.currentSubItem, XLATION_TYPE_OPERATOR_BYOP, foundMatch)[1:30];
							params.myCargoOperator := app.myRoot.allOperators[cargoOperatorCode];
						else
							params.myCargoOperator := app.myRoot.allOperators[_msgHelper.currentSubItem];
						endif;
						bookingHdr.operatorCode := params.cargoOperatorCode[1:4];
						if prenoteEDITI &lt;&gt; null then
							prenoteEDITI.operatorCode := params.cargoOperatorCode[1:4];
						endif;
					endif;
					if nad1_1Function = CM_EDIEDIFactRule.Fnct_NAD_n_1_RecCarrier_Desc then
						bookingHdr.carrierCode := _msgHelper.currentSubItem[1:10];
					endif;
					if nad1_1Function = CM_EDIEDIFactRule.Fnct_NAD_n_1_RelCarrier_Desc then
						params.releaseCarrier := _msgHelper.currentSubItem[1:10];
					endif;
