    <JadeMethod name="trxUpdateTIAddStorageDays" id="b1a00b2c-f20c-41b0-aeb1-8a21eb185d5c">
        <updating/>
        <source>trxUpdateTIAddStorageDays(	_tiArray 			   : CM_TIArray input;
							_additionalStorageDays : Integer;
							_changeReason          : String;
							_passport 			   : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2012	cnwer1	Initial creation SFW 1295
05 Mar 2019	jlgdi1	TFS 43372 Updates the attribute plannedDT (Future Storage Anniversary) when there is an adjustment in Additional Storage Days.
18 Feb 2021 cnwma1  Bug 50821: STWO - 1- Calculate storage/ demurrage charges for all cargo discharged from a vessel onto Steinweg's Terminal, either Import or Transshipment.
05 Oct 2022  navma1	Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
21 June 2023 navmv20 CR 58373 Task 58381: Jade - Future Storage Additional Days
10 September 2023 CR 58250 Task 58253: UI - Cargo Enquiry New Sheet
20 Feb 2024 navhl20 ChangeRequest 62525: EUP | Retrospective Operations - [54177.060] - Cargo &amp; Truck Checks
*/

vars
	tiTransController : CMIF_TITransactionController;
	newTITransaction	: CM_TITransaction;
	ti 					: CM_TrackedItem;
	plannedDTOld 		: TimeStamp;
	plannedDTNew, freeStorageExpiryTS		: TimeStamp;
	tiTrxDetails 		: String;
	freeStorageExpiry, futureStorageAnni 	: Date;
	storageDetail       : CM_StorageDetail;
	storageExpDetail    : CM_StorageExpiryDetail; //10 September 2023 CR 58250 Task 58253
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception     do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	if _tiArray.isEmpty then    // 09/08/2016 cnwma1 TFS #2467 PAR #38101
		app.raiseCMException2(MethodWithNullParam, method.name, app.getErrorString(Container), null, null);
		return;
	endif;
	
	foreach ti in _tiArray  do 
//		if ti.hasTransactionOfType (TRANS_TYPE_FUTURE_STORAGE) then
		if ti.hasStartedFutureStorageProcess()  then // ### TFS BUG 58953 29JUN2023 NAVAB1
			app.raiseCMException1(ERR_UPDATE_ADDDAYS,ti.id,null,ti);
			return;
		endif;
	endforeach;
	
	_passport.useTITransactionDeferUpdate	:= true;
	_passport.useTIDictDeferUpdate			:= true;
	beginTransaction;
	
	foreach ti in _tiArray do                                  	  // 09/08/2016 cnwma1 TFS #2467 PAR #38101
		ti.setAdditionalStorageDays(_additionalStorageDays);      // 09/08/2016 cnwma1 TFS #2467 PAR #38101
		ti.setAdditionalStorageReason(_changeReason);  // ### TFS BUG 60548 09OCT2023 NAVAB1
		freeStorageExpiryTS := ti.deriveFreeStorageDateTime();  // ### TFS BUG 60548 09OCT2023 NAVAB1 - need to re evaluate the date, using the additional days plus the configuration e.g. receive date, calendars etc.
		ti.setFreeStorageExpiry(freeStorageExpiryTS); // ### TFS BUG 60548 09OCT2023 NAVAB1
		freeStorageExpiry := freeStorageExpiryTS.date; // ### TFS BUG 60548 09OCT2023 NAVAB1
		
		//10 September 2023 CR 58250 Task 58253 - start
		storageExpDetail := ti.getStorageExpiryDetail();
		if storageExpDetail &lt;&gt; null then
			storageExpDetail.updateObjectEdition(ti);
		endif;
		//10 September 2023 CR 58250 Task 58253 - end
		
		// TFS# 43372  --&gt;		
		if ti.isFutureStorage(storageDetail)  // TFS 43372 ADDED JLGAB1 27MAR19 is configured for future storage       //05.10.2022 navma1 #52967
		and ti.isOnSite() then 				// TFS 45464
			futureStorageAnni := ti.getFutureStorageAnniversary(); // ### TFS BUG 60548 09OCT2023 NAVAB1
			plannedDTOld.setDate(futureStorageAnni);		// ### TFS BUG 60548 09OCT2023 NAVAB1
			
			if ti.getTransactionOfType(TRANS_TYPE_FUTURE_STORAGE) = null then 											// Only do this if the future actor has never run
// ### TFS BUG 60548 09OCT2023 NAVAB1				freeStorageExpiry := ti.getFreeStorageExpiryDate(); 													// TFS 45464
// ### TFS BUG 60548 09OCT2023 NAVAB1				ti.getLastFreeStorageDateTime(); //60548
				
				if futureStorageAnni &lt;&gt; freeStorageExpiry then 											// TFS 45464 // ### TFS BUG 60548 09OCT2023 NAVAB1
					//ti.setFutureStorageAnniversary(freeStorageExpiry,storageDetail);									//05.10.2022 navma1 #52967 //21/06/2023 navmv20 CR 58373 Task 58381
					ti.setFutureStorageAnniversary(freeStorageExpiry,storageDetail,false); //21/06/2023 navmv20 CR 58373 Task 58381
					ti.createFutureStorageBGPActor(futureStorageAnni, null, true,storageDetail, false);			//05.10.2022 navma1 #52967
				endif;
			endif;
			
			plannedDTNew.setDate(futureStorageAnni);// ### TFS BUG 60548 09OCT2023 NAVAB1
			
			tiTrxDetails := app.formatForEditTransaction("Future Storage Anniversary",//CM_TrackedItem::plannedDT.name,   //18.02.2021 cnwma1 #50821
														 plannedDTOld.asStringJMT(),
														 plannedDTNew.asStringJMT());
			app.createEditTransaction(ti, tiTrxDetails, null, app.myPassport);			//20.02.2024 navhl20 #62525
		endif;
		
		// &lt;-- TFS# 43372
		
		global.createTxnControllerForType(TRANS_TYPE_FREE_STORAGE_ADJ,tiTransController);
		tiTransController.dateTime		:= app.actualTimeServer;
		tiTransController.userId		:= _passport.getUserCode;
		tiTransController.noCharge		:= true;
		tiTransController.myTrackedItem	:= ti;    // 09/08/2016 cnwma1 TFS #2467 PAR #38101
		tiTransController.CMIF_FreeStorageAdjustment.additionalStorageDays := _additionalStorageDays;
		tiTransController.CMIF_FreeStorageAdjustment.changeReason          := _changeReason;
		app.myUtilityCA.utlCreateTITransaction(tiTransController, newTITransaction, _passport);
		_passport.doDeferredUpdates();
	endforeach;                                              // 09/08/2016 cnwma1 TFS #2467 PAR #38101
	
epilog	
	delete tiTransController;
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
        <Parameter name="_additionalStorageDays" type="Integer"/>
        <Parameter name="_changeReason" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateTIAvailabilityGrade" id="2d8828db-caff-4e03-b815-4cb05f83b15d">
        <updating/>
        <source>trxUpdateTIAvailabilityGrade(_theTI : CM_TrackedItem input; _grade : Integer;
							_passport : CM_Passport input) updating;
//-----------------------------------------
// Created: 8 October 2003 By: cnwgd1
//-----------------------------------------
vars
	tiUpdateCntrl 	: CMIF_TIUpdateController;
	tmpGrade		: CM_MTGrade;
	
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	if _theTI = null then
		app.raiseCMException2(MethodWithNullParam, method.name, app.getErrorString(Container), null, null);
		return;
	endif;
	
	
	// CCMS 1235
	if (not app.myRoot.allAvailableAvailabilityGrades.includesKey(_grade)) then
		app.raiseCMException2(ERR_FIELD_GRADE, _grade.String, app.getErrorString(AvailabilityGrade), null, null);
		return;
	endif;

	tiUpdateCntrl := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);
	
	// DVB change trx to use defered updates. 05/04/05
	_passport.useTITransactionDeferUpdate	:= true;
	_passport.useTIDictDeferUpdate			:= true;
	
	beginTransaction;

	_theTI.setAvailabilityGrade(_grade, tiUpdateCntrl, _passport);
	
	_passport.doDeferredUpdates();
	
epilog	
	delete tiUpdateCntrl;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_grade" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateTIBOL" id="3b71d1dd-a085-410f-accc-cbc27ed37a4d">
        <updating/>
        <source>trxUpdateTIBOL(_pxyTIs : CM_TISet input; _bol: CM_BOL input; _bolDtl : CM_BOLDtl input; _passport: CM_Passport input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	04 Aug 2009 By cnwdw1

Purpose:	Move the TI to a new booking. 

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
30 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
*/
vars
	pxyTI			: CM_TrackedItem;
	realBOL 		: CM_BOL;
	expectedEdition : Integer;
	tmpEvent 		: Integer;
begin
	self.initialiseActivityWithPassport(_passport, method);

	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	beginTransaction;

	foreach pxyTI in _pxyTIs do
		// Update the TI with voyage details from the booking
		pxyTI.setBOL(_bol.number);
		pxyTI.setBOLDtl(_bolDtl);
		
		if _bol.isKindOf(CM_BOLIn) then					//cnwmc5 - 1 May 2014 - PAR 34074
			pxyTI.setMyReceivalBOL(_bol.CM_BOLIn);		//cnwmc5 - 1 May 2014 - PAR 34074
		endif;											//cnwmc5 - 1 May 2014 - PAR 34074
		
		pxyTI.setMyVoyage(_bol.CM_BOLIn.myVoyage, app.myPassport);	
		
		app.myUtilityUA.utlUpdateTrackedItem(pxyTI, null, TI_UPDMODE_NORMAL, null, null, null, _passport);
	endforeach;
	
	if  _passport.hasErrors() then
		return;
	endif;
	
	self.updateObjectEdition(_bol);	// par 30292

epilog
	self.finaliseActivityWithPassport(_passport);
end;

</source>
        <Parameter name="_pxyTIs" type="CM_TISet" usage="input"/>
        <Parameter name="_bol" type="CM_BOL" usage="input"/>
