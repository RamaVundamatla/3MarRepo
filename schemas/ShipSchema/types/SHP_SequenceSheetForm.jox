    <JadeMethod name="positionQueryFrame" id="8ad8cac7-8f86-4f34-bd8f-9e453a39c3d3">
        <source>positionQueryFrame() protected;
// ---------------------------------------------------------------------------
// Created:     17 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.frmQuery.left := (self.width / 2) - (self.frmQuery.width / 2);
	self.frmQuery.top := 100;
	self.frmQuery.height := 300;
	self.frmQuery.width := 320;
	
	self.fldQuery.top := self.frmQueryToolbar.clientHeight;
	self.fldQuery.left := 0;
	self.fldQuery.height := frmQuery.clientHeight - (self.frmQueryToolbar.height + 25);
	self.fldQuery.width := self.frmQuery.clientWidth;


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setDynaKey" id="8841e404-8c57-444f-88ba-d564e6d239de">
        <updating/>
        <source>setDynaKey() : Integer updating, protected;
// ---------------------------------------------------------------------------
// Created:     09 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 18/07/2011	cnwmh5		#27479 - Change to handle Planned correctly.  Add old seq to Custom
vars
	firstVisibleColumn,
	sequenceOption			: Integer;
	sidePort				: Boolean;
	tbl						: CM_DataTable;
begin
	self.dynaKey := null;
	tbl := self.tblData;
	sequenceOption := self.cmbSequence.itemData[self.cmbSequence.listIndex];
	sidePort := self.cmbSide.itemData[self.cmbSide.listIndex].Integer.Boolean;
	
	if sequenceOption = self.Seq_Planned then
		tbl.showColumnByColName(ETRow_SeqNumWorkOrder);					// 18/07/2011 cnwmh5 #27479
		if sidePort then
			firstVisibleColumn := tbl.showColumnByColName(ETRow_SeqNumPort);
			self.dynaKey := ETRow_SeqNumPort;
		else
			firstVisibleColumn := tbl.showColumnByColName(ETRow_SeqNumStarboard);
			self.dynaKey := ETRow_SeqNumStarboard;
		endif;
	
	elseif sequenceOption = self.Seq_Standard then		
		if sidePort then
			firstVisibleColumn := tbl.showColumnByColName(ETRow_SeqNumPort);
			self.dynaKey := ETRow_SeqNumPort;
		else
			firstVisibleColumn := tbl.showColumnByColName(ETRow_SeqNumStarboard);
			self.dynaKey := ETRow_SeqNumStarboard;
		endif;
	
	elseif sequenceOption = self.Seq_Custom then		
		if sidePort then
			tbl.showColumnByColName(ETRow_SeqNumPort);					// 18/07/2011 cnwmh5 #27479
			firstVisibleColumn := tbl.showColumnByColName(ETRow_SeqNumCustomPort);
			self.dynaKey := ETRow_SeqNumCustomPort;
		else
			tbl.showColumnByColName(ETRow_SeqNumStarboard);				// 18/07/2011 cnwmh5 #27479
			firstVisibleColumn := tbl.showColumnByColName(ETRow_SeqNumCustomStarboard);
			self.dynaKey := ETRow_SeqNumCustomStarboard;
		endif;
	endif;
	
	return firstVisibleColumn;
end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setSelectedObject" id="f7062808-e0f6-44e7-afea-9becd83dd686">
        <updating/>
        <source>setSelectedObject()updating;
//--------------------------------------------------
// Created:	12 July 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if (not global.isValidObject(self.myCurrentObject)) then
		self.myCurrentObject := null;
		return;
	endif;
	
	self.tblData.selectObject(self.myCurrentObject, true);

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="051846e5-257a-4083-bd21-8fb044a27c8e">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	myConfig : CMIF_ConfigUserVoyagePlanning;

begin
	self.usesQueryFrame := true;
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.setCaption(app.getErrorString(SequenceSheet));
	app.myRoot.allDrawingAttributes.copy(self.allDrawingAttributes);
	create myConfig transient;
	myConfig.setFromPersistentData(app.getMyUser);
	create self.myBayDrawingController transient;
	self.myBayDrawingController.zeroFilleSeqNum := self.myTerminal.getConfig(ShipRemoveLeadingZeros).Boolean;
	self.myBayDrawingController.setConfig(myConfig);
	self.useTableInfo := true;
	self.useTableSorting := true;
	inheritMethod();
		
	self.setNavigatorHeading(self.caption);
	self.initTable();
	self.doCmbSideBuild();
	self.splMain.setLeftToRightRatioAndResize(80);
	self.frmBayPic.left := 0;
	self.frmBayGridArea20.backColor := White;
	self.frmBayGridArea40.backColor := White;
	self.frmBayPic.backColor := White;
	self.frmBayPic.borderStyle := self.frmBayPic.BorderStyle_None;
		
	//self.btnLocate.bubbleHelp := "Display the selected tracked item in the yard display"; //cnwas3 changed it on the control's properties itself, in jade painter, so it's gonna be translatable now
	self.lblSide.caption := "Berthing:";
	self.lblSequence.caption := "Seq Method:";
	self.btnSelectAll.caption := 'Select All';
	self.btnSelectAll.bubbleHelp := 'Select All';
		
end;</source>
    </JadeMethod>
    <JadeMethod name="showMonitorForPrinting" id="b1bf9ce8-c2a3-479c-8c15-70ab30342dfe">
        <updating/>
        <source>showMonitorForPrinting() : CMIF_Monitor updating, protected;
// ---------------------------------------------------------------------------
// Created:     18 June 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	cmifMonitor					: CMIF_Monitor;
	returnValue,
	partsComplete,
	partsInJob					: Integer;
begin
	delete app.myPassport.myCMIFMonitor;
	create cmifMonitor transient;
	app.myPassport.setMyCMIFMonitor(cmifMonitor);
	cmifMonitor.myParent := self;
	self.frmModalDialog.zOrder(1);
	self.modalDialogShow(null, app.getErrorString(Cancel), app.getErrorString(CMUI_Return_Data), null, null, cmifMonitor.message);
	self.lblModalMessage.caption := 'Sequence Sheet Report Progress';

	return cmifMonitor;
end;</source>
        <access>protected</access>
        <ReturnType type="CMIF_Monitor"/>
    </JadeMethod>
