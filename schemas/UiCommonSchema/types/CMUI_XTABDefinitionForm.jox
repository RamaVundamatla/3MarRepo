    <JadeMethod name="doBtnShowDetails" id="f10ec246-86d0-4587-9ee3-0a895cacea25">
        <updating/>
        <source>doBtnShowDetails() updating, protected;

// ---------------------------------------------------------------------------
// Created:     26 November 2008 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	oldHeight	: Integer;
	oldWidth	: Integer;
	
begin	
	oldHeight 				:= jdbSavedDisplays.height.Integer;
	oldWidth			 	:= jdbSavedDisplays.width.Integer;
	jdbRight.visible 		:= true;
	jdbProperties.visible 	:= true;
	jdbSavedDisplays.height	:= jdbSavedDisplays.parent.Control.clientHeight / 2;
	jdbSavedDisplays.width 	:= oldWidth;
	self.btnRunDefn.left	:= self.jdbRight.left + self.btnHideDetails.left;
	
	// make certain buttons invisible/visible but still enabled via the context menu.
	enableDisableCtrsForHideShow( true );
	
	// make sure the form is not too large for screen resolution of 1024 * 768.
	self.minimumHeight	:= 600;
	self.minimumWidth	:= 800;
	self.height			:= self.minimumHeight;
	self.width			:= self.minimumWidth;
	self.frmMain.width	:= self.minimumWidth - 8;
	
	self.doResize;
	
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doButtonClick" id="077dfb3a-6919-4ed6-a808-a2ab96c23440">
        <source>doButtonClick(_btn :Button input)protected;
// ---------------------------------------------------------------------------
// Created:     27 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	element	:CM_XTABElement;
begin
	if _btn = null then
		return;
	endif;
	
	// highlight only the selected button
	//_btn.fontBold 	:= true;
	_btn.foreColor 	:= Blue;
	
	self.resetButtonValues (self.allButtons_tabs, _btn);
	self.resetButtonValues (self.allButtons_rows, _btn);
	self.resetButtonValues (self.allButtons_columns, _btn);
	self.resetButtonValues (self.allButtons_cells, _btn);
	
	element := _btn.userObject.CM_XTABElement;
	
	// now display details for selected item
	if element.isKindOf (CM_XTABGrouping) then
		self.loadGroupingSheet (element.CM_XTABGrouping);
		
		shtGroupings.setFocus;
		shtProperties.enabled 	:= false;
		shtGroupings.enabled	:= true;
	else
		self.loadCellSheet (element.CM_XTABField);
		// must be a field
		shtProperties.setFocus;
		shtGroupings.enabled 	:= false;
		shtProperties.enabled	:= true;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doDeleteElement" id="f611fc9a-8f65-4cf7-8d55-98d06c43ded7">
        <updating/>
        <source>doDeleteElement( _btn : Button input ) updating, protected;
// ---------------------------------------------------------------------------
// Created:     01 December 2008 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	element	:CM_XTABElement;
begin
	// save off element so it can be deleted at the end
	element := _btn.userObject.CM_XTABElement;
	
	if self.allButtons_tabs.includes (_btn) then
		self.allButtons_tabs.remove (_btn);
	elseif self.allButtons_rows.includes (_btn) then
		self.allButtons_rows.remove (_btn);
	elseif self.allButtons_columns.includes (_btn)  then
		self.allButtons_columns.remove (_btn);
	elseif self.allButtons_cells.includes (_btn) then
		self.allButtons_cells.remove (_btn);
	endif;
	
	self.makeButtonSpare (_btn); // changes parent, reset properties and adds to spare collection
	self.zSetControls();			// cnwrl1 22/06/2009 PAR 19993
	
	delete element;	// inverse maintenance will remove it from the format collections
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doDeleteXTAB" id="3f147c17-286f-494c-9d4d-4ccbb34460d0">
        <updating/>
        <source>doDeleteXTAB():Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     08 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	if self.myCurrentXTAB = null then		// trying to delete the "New Summary" entry which is OK.
		return true;
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteOutputFormat_XTAB(self.myCurrentXTAB, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Delete);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;
	
	return true;
	
epilog
	
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDragDrop" id="63c2ac6c-9cd1-445e-b3f2-04048a6be406">
        <updating/>
        <source>doDragDrop( _control : Control input; win : Window input; x,y : Real ) updating, protected;

// ---------------------------------------------------------------------------
// Created:     26 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 15/12/2009	cnwcs5		ccms 1023 - refactored some code
// ---------------------------------------------------------------------------

vars
	
begin
	self.clearGraphics;
	
	if not self.canDrop (_control, win) then	// cnwcs5 15/12/2009
		return;									// cnwcs5 15/12/2009
	endif;										// cnwcs5 15/12/2009
	
	if win = self.tblProperties then
		// we have dragged a property from the properties table
		self.doDragDrop_AddProperty (win, _control);
		
	elseif win.name = btnField.name then
		// we are dragging a button within the XTAB definition
		if (_control.name = btnField.name and win.Button.parent = _control.parent) or	
			(_control.isKindOf (Frame) and win.Button.parent = _control) then		
			// we are just swapping the order
			self.doDragDrop_MoveElement (win.Button, _control);
			
		elseif win.Button.parent = self.frmCells or 
			_control = self.frmCells or
			(_control.name = btnField.name and _control.Button.parent = self.frmCells) then
			// field to row/column or row/column to field - delete and re-add
			// delete element associated with win and then add element of different type but same property
			self.doDragDrop_ChangeElement (win.Button, _control);
		else
			// moving from row/column/tab or row/column/tab but not the same
			self.doDragDrop_MoveElement (win.Button, _control);
			
		endif;
	endif;
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_control" type="Control" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doDragDrop_AddProperty" id="43182be9-b0ca-4af6-866a-56b42b8372e1">
        <updating/>
        <source>doDragDrop_AddProperty(_win :Window; _control :Control) updating, protected;
// ---------------------------------------------------------------------------
// Created:     02 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  _control 	- control being dropped onto
//							- will be a button, frmTabs, frmRows, frmColumns
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	property	:CM_QueryProperty;
	frame		:Frame;
	btn			:Button;
begin
	property := self.getSelectedProperty;
	
	if _control.isKindOf (Frame) then
		frame 	:= _control.Frame;
	else
		btn		:= _control.Button;
		frame	:= btn.parent.Frame;
	endif;
	
	if frame = self.frmTabs then
		btn := self.doAddTab (property, btn);
	elseif frame = self.frmRows then
		btn := self.doAddRow (property, btn);
	elseif frame = self.frmColumns then
		btn := self.doAddColumn (property, btn);
	else
		btn := self.doAddCell (property, btn);
	endif;
	
	self.doButtonClick (btn);
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_win" type="Window"/>
        <Parameter name="_control" type="Control"/>
    </JadeMethod>
    <JadeMethod name="doDragDrop_ChangeElement" id="d7ece486-40d9-46d5-acb3-cf56af52244c">
        <updating/>
        <source>doDragDrop_ChangeElement(_btnSource :Button input; _controlTarget :Control)updating, protected;
// ---------------------------------------------------------------------------
// Created:     01 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	format			: CM_OutputFormat_XTAB;
	sourceFrame		: Frame; 
	targetFrame		: Frame;
	targetButton	: Button;
	btn				: Button;
	element			: CM_XTABElement;
	property		: CM_QueryProperty;
	
begin
	format 		:= self.myProxyXTAB;
	sourceFrame	:= _btnSource.parent.Frame;
	
	if _controlTarget.isKindOf (Frame) then
		targetFrame 	:= _controlTarget.Frame;
		targetButton	:= null;
	else
		targetFrame 	:= _controlTarget.parent.Frame;
		targetButton	:= _controlTarget.Button;
	endif;

	// save off property for _btnSource before we delete it
	element		:= _btnSource.userObject.CM_XTABElement;
	property 	:= element.getQueryProperty;
	if property = null then
		app.msgBox(	app.getErrorString1( XTAB_InvalidPropertyName, element.propertyName ),
					app.getErrorString( Error ),
					MsgBox_OK_Only );
		return;
	endif;
	
	self.doDeleteElement (_btnSource);
		
	// now use saved property to create a new row/col
	if targetFrame = self.frmTabs then
		btn := self.doAddTab (property, targetButton);
	elseif targetFrame = self.frmColumns then
		btn := self.doAddColumn (property, targetButton);	
	elseif targetFrame = self.frmRows then
		btn := self.doAddRow (property, targetButton);	
	else
		btn := self.doAddCell (property, targetButton);
	endif;
	
	if sourceFrame = self.frmColumns or targetFrame = self.frmColumns then
		self.refreshColumns;
	endif;
	if sourceFrame = self.frmRows or targetFrame = frmRows then
		self.refreshRows;
	endif;
	if sourceFrame = self.frmTabs or targetFrame = self.frmTabs then
		self.refreshTabs;
	endif;
	
	self.refreshFields;
	
	self.doButtonClick (btn);
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_btnSource" type="Button" usage="input"/>
        <Parameter name="_controlTarget" type="Control"/>
    </JadeMethod>
    <JadeMethod name="doDragDrop_MoveElement" id="548821e8-0325-4d92-b541-c4f7bbfca3fc">
        <updating/>
        <source>doDragDrop_MoveElement(
	_btnSource		: Button input;
	_controlTarget	: Control ) updating, protected;
	
// ---------------------------------------------------------------------------
// Created:     01 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	format			: CM_OutputFormat_XTAB;
	sourceFrame		: Frame;
	targetFrame		: Frame;
	element			: CM_XTABElement;
	collButtons		: ObjectArray;
	collElements	: ObjectArray;
	pos				: Integer;
	
begin
	format 		:= self.myProxyXTAB;
	sourceFrame	:= _btnSource.parent.Frame;
	element		:= _btnSource.userObject.CM_XTABElement;
	
	// clear the source frame
	if sourceFrame = self.frmColumns then
		self.allButtons_columns.remove( _btnSource );
		format.allColumns.remove( element.CM_XTABGrouping );
	elseif sourceFrame = self.frmRows then
		self.allButtons_rows.remove( _btnSource );
		format.allRows.remove( element.CM_XTABGrouping );
	elseif sourceFrame = self.frmTabs then
		self.allButtons_tabs.remove( _btnSource );
		format.allTabs.remove( element.CM_XTABGrouping );
	else
		self.allButtons_cells.remove( _btnSource );
		format.allFields.remove( element.CM_XTABField );
	endif;
	
	if _controlTarget.isKindOf( Frame ) then
		targetFrame := _controlTarget.Frame;
	else
		targetFrame := _controlTarget.parent.Frame;
	endif;
	
	// now load the target frame from the current fields.
	_btnSource.parent := targetFrame;
	
	if targetFrame = self.frmColumns then
		collButtons		:= self.allButtons_columns;
		collElements 	:= format.allColumns;
	elseif targetFrame = self.frmRows then
		collButtons 	:= self.allButtons_rows;
		collElements 	:= format.allRows;
	elseif targetFrame = self.frmTabs then
		collButtons 	:= self.allButtons_tabs;
		collElements 	:= format.allTabs;
	else
		collButtons 	:= self.allButtons_cells;	
		collElements 	:= format.allFields;
	endif;
	
	if _controlTarget.isKindOf( Frame ) then
		pos	:= null;
	else
		pos	:= collButtons.indexOf( _controlTarget );
	endif;
	
	// add the new field.
	if pos = 0 then
		collButtons.add( _btnSource );
		collElements.add( _btnSource.userObject );
	else
		collButtons.insert( pos, _btnSource );
		collElements.insert( pos, _btnSource.userObject );
	endif;
	
	// refresh the form
	if sourceFrame = frmColumns or targetFrame = self.frmColumns then
		self.refreshColumns;
	endif;
	
	if sourceFrame = frmRows or targetFrame = self.frmRows then
		self.refreshRows;
	endif;
	
	if sourceFrame = frmTabs or targetFrame = self.frmTabs then
		self.refreshTabs;
	endif;
	
	if sourceFrame = frmCells or targetFrame = self.frmCells then
		self.refreshFields;
	endif;
	
	self.doButtonClick( _btnSource );
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_btnSource" type="Button" usage="input"/>
        <Parameter name="_controlTarget" type="Control"/>
    </JadeMethod>
    <JadeMethod name="doDragOver_Button" id="b7316829-c97f-47e8-b0c1-2711f8e0054f">
        <updating/>
        <source>doDragOver_Button(control: Button input; win: Window input; x,y: Real; state: Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     01 December 2008 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 15/12/2009	cnwcs5		Fixed bug - not drawing insert point
// ---------------------------------------------------------------------------
vars

begin
	if state = self.DragOver_Enter then
		if self.myProxyXTAB.hasTabs and
			//control.name = self.btnField.name then
			control.parent = self.frmTabs then		// cnwcs5 15/12/2009
			// only allow one tab property - GUI rather than model restriction
			return;
		endif;
		self.drawDragInsertPoint_Button (control);
	elseif state = self.DragOver_Leave then
		self.clearGraphics;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="control" type="Button" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doDragOver_Frame" id="e50f7980-2c7a-4ee1-b4be-2bafc30d0cd4">
        <updating/>
        <source>doDragOver_Frame(control: Frame input; win: Window input; x,y: Real; state: Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     01 December 2008 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if state = self.DragOver_Enter then
		if self.myProxyXTAB.hasTabs and control = self.frmTabs then
			// only allow one tab property - GUI rather than model restriction
			return;
		endif;
		self.drawDragInsertPoint_Frame( control );
	elseif state = self.DragOver_Leave then
		self.clearGraphics;
	endif;
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="control" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doLstSavedDisplays" id="08006ee7-17ff-4bb2-b8f7-35df8cf16879">
        <updating/>
        <source>doLstSavedDisplays() updating, protected;
// ---------------------------------------------------------------------------
// Created:     08 December 2008 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	obj				: Object;
	realObject		: CM_OutputFormat_XTAB;
	
begin
	// if the last entry was not saved and it has not been made persistent then remove the entry in the listbox.
	if not self.btnSaveAsDefn.enabled then
		self.removeDummyListEntry;
	endif;
	
	self.clearErrorWarnings();
	
	obj := lstSavedDisplays.listObject;
	
	if obj &lt;&gt; null and obj.isKindOf( CM_OutputFormat_XTAB ) then
		// save off selected XTAB
		self.myCurrentXTAB := obj.CM_OutputFormat_XTAB;
	endif;
	if self.myCurrentXTAB = null then
		return;
	endif;
	
	self.createProxyDefinition();
	if self.myProxyXTAB = null then
		// we must have got an error
		return;
	endif;
	
	self.formMode := Mode_Update;
	
	// Redisplay to ensure latest version of object is shown
	self.displayXTABDefinition( self.myProxyXTAB );
	
	// With latest version confirm that the object can be edited.
	self.zSetControls;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doMnuAddCell_click" id="4f502233-d52f-4351-ba84-5e6fac77405f">
        <updating/>
        <source>doMnuAddCell_click()protected, updating;
// ---------------------------------------------------------------------------
// Created:     15 December 2009 by cnwcs5
// Purpose:     CCMS 1023 - snapshot summaries
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	property	: CM_QueryProperty;
begin
	property := self.getSelectedProperty;
	
	if property = null then
		return;
	endif;
	
	self.doButtonClick( self.doAddCell( property, null ) );
	
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doMnuPopup2Delete" id="d07b02ce-cce7-4ac2-98e1-c182c4f86e25">
        <updating/>
        <source>doMnuPopup2Delete() updating, protected;

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
15 January 2009		cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)

*/
vars
	btn		: Button;
	frame	: Frame;

begin
	btn		:= self.mnuPopup2.userObject.Button;
	frame	:= btn.parent.Frame;
	
	self.doDeleteElement( btn );
	
	if frame = self.frmTabs then
		self.loadGroupingSheet( null );
		self.refreshTabs;
	elseif frame = self.frmRows then
		self.loadGroupingSheet( null );
		self.refreshRows;
	elseif frame = self.frmColumns then
		self.loadGroupingSheet( null );
		self.refreshColumns;
	else
		self.loadCellSheet( null );
		self.refreshFields;
	endif;
	
	self.fldXTAB.topSheet 		:= self.shtTable;
	self.shtGroupings.enabled 	:= false;
	self.shtProperties.enabled	:= false;
	
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="356a2349-f537-4ab4-874b-83f4bdd2826d">
        <updating/>
        <source>doResize() updating;

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
11 February 2009	cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)

*/
	
vars
	
begin
	inheritMethod();
	self.cmbMode.width	:= self.lstSavedDisplays.width - self.lblMode.width - 5;
	self.doResizeRightHandSide;
	
epilog
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="doResizeRightHandSide" id="a1daf13b-6b1a-430e-868d-1f1b8f5d114a">
        <source>doResizeRightHandSide() protected;

// ---------------------------------------------------------------------------
// Created:     26 November 2008 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.refreshTabs;
	self.refreshRows;
	self.refreshColumns;
	self.refreshFields;
	
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSaveXTAB" id="b024da4d-9034-4c1b-b4d6-3cf9b5334f7c">
        <updating/>
        <source>doSaveXTAB() : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     078 December 2008 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	proxy	: CM_OutputFormat_XTAB;
	result	: Integer;
	
begin
	proxy	:= self.myProxyXTAB;
	
	while true do
		if self.formMode = Mode_Add then
			app.myTrxCA.trxCreateOutputFormatXTAB(proxy, self.myCurrentXTAB, app.myPassport);
		elseif self.formMode = Mode_Update then
			app.myTrxUA.trxUpdateOutputFormatXTAB(proxy, self.myCurrentXTAB, self.currentXTABEdition, app.myPassport);
		endif;

		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			break;
		endif;
		
		if self.formMode = Mode_Add then
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
		endif;
		
		if app.myPassport.noErrors and result = IDOK then
			// there must have just been warnings that the user has acknownledged so.
			app.myPassport.warningsAcknowledged	:= true;
			continue;
		endif;
		return false;
	endwhile;
	
	delete self.myProxyXTAB;
	
	return true;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSelectXTAB" id="c6108383-5d55-413e-abf2-04cf9db82464">
        <updating/>
        <source>doSelectXTAB()updating, protected;
// ---------------------------------------------------------------------------
// Created:     08 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	obj	: Object;
	
begin
	obj := lstSavedDisplays.listObject;
	
	if obj &lt;&gt; null and obj.isKindOf( CM_OutputFormat_XTAB ) then
		if self.myProxyXTAB &lt;&gt; null then
			delete self.myProxyXTAB;
		endif;
		
		// save off selected XTAB
		self.myCurrentXTAB := obj.CM_OutputFormat_XTAB;
		// display selecetd XTAB
		self.displayXTABDefinition( self.myCurrentXTAB );
	endif;
	
epilog
	self.zSetControls;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSysNotify" id="c2ec6e58-d6e5-41b0-b5bc-b73979da1eb0">
        <updating/>
        <source>doSysNotify( eventType : Integer; theObject : Object; eventTag : Integer ) updating, protected;

/*

Purpose:		CCMS SFW 1047 - Totals Only Lists
Parameters:		
Return Value:	

Date				Who		Reason
12 January 2009		cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)

*/
	
vars
	index		: Integer;
	
begin
	// refresh list and select the current entry
	self.loadSavedDisplays;
//	lstSavedDisplays.listIndex	:= lstSavedDisplays.findObject( self.myCurrentXTAB );	// cnwrl1 15/09/2009 PAR 20203 - what it was
	if self.myCurrentXTAB = null and self.myProxyXTAB &lt;&gt; null then		// ie user is creating a new one
		// add proxy into tree (alphabetically)
		index										:= self.lstSavedDisplays.addItem( self.myProxyXTAB.name );
		self.lstSavedDisplays.itemObject[ index ]	:= self.myProxyXTAB;
		self.lstSavedDisplays.listIndex				:= index;
	elseif self.myCurrentXTAB &lt;&gt; null then
		lstSavedDisplays.listIndex	:= lstSavedDisplays.findObject( self.myCurrentXTAB );
	endif;
	self.zSetControls;
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doTblProperties_contextMenu" id="56e5661f-9e69-487c-9fa0-0dc289f6e74a">
        <updating/>
        <source>doTblProperties_contextMenu(_table :Table input; _conwin :Window input; _mouse : Boolean;
							_x, _y : Integer ) : Boolean protected, updating;
// ---------------------------------------------------------------------------
// Created:     17 December 2009 by cnwcs5
// Purpose:     CCMS 1023 - snapshot summaries
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	property	: CM_QueryProperty;
begin
	property := self.getSelectedProperty;
	
	if property = null then
		return false;
	endif;
	
	// only one TAB currently allowed.
	self.mnuPopup1AddTab.enabled	:= not self.myProxyXTAB.hasTabs;
	self.mnuPopup1.userObject 		:= self.tblProperties;	// cnwcs5 15/12/2009
	
	// now show the menu and terminate further processing
	return self.showContextMenu( self.mnuPopup1, _table, _conwin, _mouse, _x, _y );
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_conwin" type="Window" usage="input"/>
        <Parameter name="_mouse" type="Boolean"/>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUserNotify" id="f29d72bd-07a4-4e53-a361-8c0aaa1a6819">
        <updating/>
        <source>doUserNotify( eventType : Integer; theObject : Object; eventTag : Integer; userInfo : Any ) updating, protected;

/*

Purpose:		CCMS SFW 1047 - Totals Only Lists
Parameters:		
Return Value:	

Date				Who		Reason
13 January 2009		cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)
15/09/2009			cnwrl1	PAR 20203 - allow for multiple users creating new definitions at the same time

*/
	
vars
	index					: Integer;
	cm_OutputFormat_XTAB	: CM_OutputFormat_XTAB;
	
begin
	// if this event has been done by ourselves just return.
	if process.userCode = userInfo.String then
		return;
	endif;
	
	// if this event is not one of the required events just return.
	if eventType &lt;&gt; EVENT_SummaryTable_Update and eventType &lt;&gt; EVENT_SummaryTable_Delete then
		return;
	endif;
	
	// Handle the delete event.
	if eventType = EVENT_SummaryTable_Delete then
		// if someone else has deleted the saved definition the user is working on display a message.
//		if not global.isValidObject( self.myCurrentXTAB ) then	// cnwrl1 15/09/2009 PAR 20203 - what it was
		if self.myCurrentXTAB &lt;&gt; null and not global.isValidObject( self.myCurrentXTAB ) then
			app.msgBox(	app.getErrorString2(	AnotherUserHas_Del_YourDetails,
												userInfo.String.display,
												app.getErrorString( XTAB_SummaryDefinition ) ),
						app.getErrorString( UnsavedChangesWillBeLost ),
						MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon + MsgBox_Default_First );
			self.myCurrentXTAB		:= null;
			self.myProxyXTAB		:= null;
			self.zClearProxyDetails;					// refreshes the RHS.
			self.myQueryDefinition	:= null;			// force the property table to be refreshed.
		endif;
		// the screen will actually be refreshed via the doSysNotify method!
		return;											// finished with delete event.
	endif;
	
	// handle the update event
	cm_OutputFormat_XTAB	:= theObject.CM_OutputFormat_XTAB;
	
	if global.isValidObject( cm_OutputFormat_XTAB ) and cm_OutputFormat_XTAB &lt;&gt; null then
		// if this user is working on this specific definition then warning the user before the form is refreshed.
		if self.myCurrentXTAB &lt;&gt; null and self.myCurrentXTAB = cm_OutputFormat_XTAB then
			app.msgBox(	app.getErrorString2(	AnotherUserHas_Upd_YourDetails,
												userInfo.String.display,
												app.getErrorString( XTAB_SummaryDefinition ) ),
						app.getErrorString( UnsavedChangesWillBeLost ),
						MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon + MsgBox_Default_First );
			// now refresh the details and obtain the latest version of the definition working on.
			self.loadSavedDisplays;
			lstSavedDisplays.listIndex	:= lstSavedDisplays.findObject( self.myCurrentXTAB );
			self.displayXTABDefinition( self.myCurrentXTAB );
			// now setup this definiton in update mode
			self.doLstSavedDisplays();
		else
			// this user is not working on definition updated so just refresh the list (caters especially for renaming etc).
			self.loadSavedDisplays;
//			lstSavedDisplays.listIndex	:= lstSavedDisplays.findObject( self.myCurrentXTAB );	// cnwrl1 15/09/2009 PAR 20203 - what it was
			if self.myCurrentXTAB = null and self.myProxyXTAB &lt;&gt; null then		// ie user is creating a new one
				// add proxy into tree (alphabetically)
				index										:= self.lstSavedDisplays.addItem( self.myProxyXTAB.name );
				self.lstSavedDisplays.itemObject[ index ]	:= self.myProxyXTAB;
				self.lstSavedDisplays.listIndex				:= index;
			elseif self.myCurrentXTAB &lt;&gt; null then
				lstSavedDisplays.listIndex	:= lstSavedDisplays.findObject( self.myCurrentXTAB );
			endif;
			self.zSetControls;
		endif;
	else
		// object was not valid or null just refresh the list (caters especially for renaming etc).
		self.loadSavedDisplays;
		lstSavedDisplays.listIndex	:= lstSavedDisplays.findObject( self.myCurrentXTAB );
		self.zSetControls;
	endif;
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="drawDragInsertPoint_Button" id="87fbb2ac-9b0e-44da-9ae5-97f3cf61a5f8">
        <updating/>
        <source>drawDragInsertPoint_Button(_btn :Button input)updating, protected;
// ---------------------------------------------------------------------------
// Created:     01 December 2008 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	x, y 		:Real;
	intWidth	:Integer;
begin
	x 			:= _btn.left;
	y 			:= _btn.top;
	intWidth	:= self.drawWidth;
	
	_btn.parent.windowToScreen (x, y);
	self.screenToWindow(x, y);

	if _btn.parent = self.frmColumns then
		// draw down left side of button
		self.drawLine (x, y, x, y+_btn.height, Blue); 
		// draw across top
		self.drawLine (x-5, y-intWidth, x+5, y-intWidth, Blue); 
		// draw below bottom
		self.drawLine (x-5, y+_btn.height, x+5, y+_btn.height, Blue); 
	
	elseif _btn.parent = self.frmCells then
		// draw down left side of button
		self.drawLine (x, y, x, y+_btn.height, Blue); 
		// draw across top
		self.drawLine (x-5, y, x+5, y, Blue); 
		// draw below bottom
		self.drawLine (x-5, y+_btn.height, x+5, y+_btn.height, Blue); 
	else
		// row/tab draw across top of button
		self.drawLine (x, y, x + _btn.width, y, Blue); 
		// draw left hand side
		self.drawLine (x-intWidth, y-5, x-intWidth, y+5, Blue); 
		// draw right hand side
		self.drawLine (x+_btn.width, y-5, x + _btn.width, y+5, Blue); 
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawDragInsertPoint_Frame" id="5b829c27-fbd8-45e8-9006-e81e4d1409c2">
        <updating/>
        <source>drawDragInsertPoint_Frame(_frame :Frame)updating,protected;
// ---------------------------------------------------------------------------
// Created:     01 December 2008 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	btn			:Button;
	x, y		:Real;
	intWidth	:Integer;
begin
	intWidth	:= self.drawWidth;
	
	if _frame = self.frmColumns then
		btn := self.allButtons_columns.last.Button;
	elseif _frame = self.frmCells then
		btn := self.allButtons_cells.last.Button;
	elseif _frame = self.frmTabs then
		btn := self.allButtons_tabs.last.Button; 
	else
		btn := self.allButtons_rows.last.Button;
	endif;
	
	if btn &lt;&gt; null then	
		if _frame = self.frmColumns or _frame = self.frmCells then
			x := btn.left + btn.width;
			y := btn.top;
		
			btn.parent.windowToScreen (x, y);
			self.screenToWindow(x, y);

			if _frame = self.frmColumns then
				// draw down right hand side of button
				self.drawLine (x, y, x, y+btn.height, Blue); 
				// draw across top
				self.drawLine (x-5, y-intWidth, x+5, y-intWidth, Blue); 
				// draw below bottom
				self.drawLine (x-5, y+btn.height, x+5, y+btn.height, Blue); 			
			else
				// draw down right hand side of button
				self.drawLine (x, y, x, y+btn.height, Blue); 
				// draw across top
				self.drawLine (x-5, y, x+5, y, Blue); 
				// draw below bottom
				self.drawLine (x-5, y+btn.height, x+5, y+btn.height, Blue); 
			endif;
		else	// row/tab
			x := btn.left;
			y := btn.top + btn.height;
		
			btn.parent.windowToScreen (x, y);
			self.screenToWindow(x, y);
			
			// row - draw across bottom of button
			self.drawLine (x, y, x + btn.width, y, Blue); 
			// draw left hand side
			self.drawLine (x-intWidth, y-5, x-intWidth, y+5, Blue); 
			// draw right hand side
			self.drawLine (x+btn.width, y-5, x + btn.width, y+5, Blue); 
		endif;
		return;
	endif;
	
	// is we get to here the frame is empty so we have to make up a place to draw
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_frame" type="Frame"/>
    </JadeMethod>
    <JadeMethod name="enableDisableControlsForSaveAs" id="a6e42e6f-d39c-44fa-8279-54a792b46849">
        <source>enableDisableControlsForSaveAs( _enable : Boolean ) protected;
/* ---------------------------------------------------------------------------
Created:     29 January 2009 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars

begin
	// enable or disable all of the controls on this form
	self.jdbBottom.enabled	:= _enable;
	self.jdbTop.enabled		:= _enable;
	
epilog
	
end;</source>
