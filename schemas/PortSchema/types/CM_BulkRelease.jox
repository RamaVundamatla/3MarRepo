    <JadeMethod name="getAllEDIFiles" id="9234a66b-3453-4359-b496-ff489b61b812">
        <source>getAllEDIFiles(_coll :CM_EDIFileArray input);
/*
Date		Who		Reason
29 Nov 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
23/04/2012	cnwcs5	CCMS POL 2172/ par 29480 - Show in reverse order
*/
vars
	file			:CM_EDIFile;
	gotException	:Boolean;
	test			:Integer;
begin
	on Exception do app.handleDeletedObject (exception, file, gotException);
	
	foreach file in self.allEDIFiles reversed do	// par 29480
		test := file.edition;
		
		if gotException then
			gotException := false;
			continue;
		endif;
		
		_coll.add (file);
	endforeach;
epilog

end;</source>
        <Parameter name="_coll" type="CM_EDIFileArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllMeasurementTypesUsed" id="060c8f4f-1501-4e06-8c7d-278452677c59">
        <source>getAllMeasurementTypesUsed( _measurementUnits : StringArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2019	jlger1	Initial creation 41298
6/12/2023	navcs2	ChangeRequest 57537: EUP | Release Request By Type - with Weight
*/

vars
	reserveDetail : CM_ReserveDetail;
	cargoType : CM_CargoType;
	oidString : String;
	measureType : CM_MeasurementType;
begin
	
	foreach reserveDetail in self.allReserveDetails discreteLock do
		cargoType:= reserveDetail.getCargoType;
		if cargoType = null then
			continue;
		endif;
		if cargoType.isBulkByVolume then
			oidString:=cargoType.myVolumeMeasurementType.getOidString;
			if not _measurementUnits.includes(oidString) then
				_measurementUnits.add(oidString);
			endif;
		elseif cargoType.isBulkByWeight then
			oidString:=cargoType.myWeightMeasurementType.getOidString;
			if not _measurementUnits.includes(oidString) then
				_measurementUnits.add(oidString);
			endif;
		elseif reserveDetail.byTypeByWeight then								// 6/12/2023 navcs2 ChangeRequest 57537
			if cargoType.myWeightMeasurementType &lt;&gt; null then					// 6/12/2023 navcs2 ChangeRequest 57537
				oidString:=cargoType.myWeightMeasurementType.getOidString;		// 6/12/2023 navcs2 ChangeRequest 57537
				if not _measurementUnits.includes(oidString) then				// 6/12/2023 navcs2 ChangeRequest 57537
					_measurementUnits.add(oidString);							// 6/12/2023 navcs2 ChangeRequest 57537
				endif;															// 6/12/2023 navcs2 ChangeRequest 57537
			else																// 6/12/2023 navcs2 ChangeRequest 57537
				measureType := app.getDefaultMeasurementForType(Type_Weight);	// 6/12/2023 navcs2 ChangeRequest 57537
				oidString:=measureType.getOidAsString;							// 6/12/2023 navcs2 ChangeRequest 57537
				_measurementUnits.add(oidString);								// 6/12/2023 navcs2 ChangeRequest 57537
			endif;																// 6/12/2023 navcs2 ChangeRequest 57537
		else
			if not _measurementUnits.includes(null) then
				_measurementUnits.add(null);
			endif;
		endif;
		
		
	endforeach;
	
epilog

end;</source>
        <Parameter name="_measurementUnits" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllPreStagedLocations" id="cbf29747-8d81-47ab-b7e0-70d67b6d4720">
        <source>getAllPreStagedLocations(stagingLC : CM_LocationsController io) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2021	jlier1	Initial creation 51879

*/

vars
	tiSet : CM_TISet;
	outStandingItemCount : Integer;
	stagedItemCount : Integer;
	firstStagingLC : CM_LocationsController;
begin
	create tiSet transient;
	outStandingItemCount := self.getTotalOutstanding;
	stagedItemCount := self.getTotalStaged(tiSet, firstStagingLC);
	if outStandingItemCount &gt; 0 and outStandingItemCount = stagedItemCount then
		stagingLC:=firstStagingLC;
		return true;
	endif;
	
	return false;
epilog
	delete tiSet;

end;</source>
        <Parameter name="stagingLC" type="CM_LocationsController" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllVbsOffSchedule" id="b5e8d676-a663-4af7-9cb0-b8cb85c1b241">
        <source>getAllVbsOffSchedule(_vbsDict : CM_VehicleBookingByTs io; _realVVR : CM_VehicleVisitRecord; _includeUsed : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Apr 2025	navnk30	JIRA 34267: TPT | FR 33661.050 VBS - One Release Request and Multiple VBS Appointments - Off Schedule

*/

vars
	vbs		: CM_VehicleBookingTimeSlot;
begin
	foreach vbs in self.allVBTimeslotsById where not vbs.isVehicleVisitOnSchedule(_realVVR) do
	if not _includeUsed and vbs.isUsed() then
		continue;
	endif;
		_vbsDict.tryAdd(vbs);
	endforeach;
epilog

end;

</source>
        <Parameter name="_vbsDict" type="CM_VehicleBookingByTs" usage="io"/>
        <Parameter name="_realVVR" type="CM_VehicleVisitRecord"/>
        <Parameter name="_includeUsed" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllVbsOnSchedule" id="4cd34135-7284-4f96-8dcd-0c7388154b7f">
        <source>getAllVbsOnSchedule(_vbsDict : CM_VehicleBookingByTs io; _realVVR : CM_VehicleVisitRecord; _includeUsed : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Apr 2025	navnk30	JIRA 34267: TPT | FR 33661.050 VBS - One Release Request and Multiple VBS Appointments ? Off Schedule

*/

vars
	vbs		: CM_VehicleBookingTimeSlot;
begin
	foreach vbs in self.allVBTimeslotsById where vbs.isVehicleVisitOnSchedule(_realVVR) do
	if not _includeUsed and vbs.isUsed() then
		continue;
	endif;
		_vbsDict.tryAdd(vbs);
	endforeach;
epilog

end;

</source>
        <Parameter name="_vbsDict" type="CM_VehicleBookingByTs" usage="io"/>
        <Parameter name="_realVVR" type="CM_VehicleVisitRecord"/>
        <Parameter name="_includeUsed" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAnyIdAvailableTiCount" id="7857c5e7-90af-488a-8794-9b20fbf31aa1">
        <source>getAnyIdAvailableTiCount():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 August 2014	cnwndl1	Initial creation	Par 34675

*/

vars

	iter : Iterator;
	ti : CM_TrackedItem;
	count : Integer;

begin

	iter := self.allTrackedItemsAssigned.createIterator;
	while iter.next( ti ) do
		if ti.isTiAvailableForAnyIdSelection() then
			count := count + 1;
		endif;
	endwhile;
	
	return count;

epilog

	delete iter;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAssignedIDs" id="d493f1d6-c10a-45c3-9d32-bfd12a2b949f">
        <source>getAssignedIDs(): String;
//----------------------------------------------------------------
//	Created:	16 June 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	str	: String;
	ti	: CM_TrackedItem;
	
begin

	foreach ti in self.allTrackedItemsAssigned do
		if str = null then
			str := ti.id;
		else
			str := str &amp; ' ' &amp; ti.id;
		endif;
	endforeach;
	
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAssociatedTrailers" id="8b82a6f8-002a-434a-a814-edab5bafa719">
        <source>getAssociatedTrailers(allTrailers : CM_TIArray input) ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2021	jlier1	Initial creation 51879
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

vars
vehicleArray : CM_VehicleArray ;
	vehicle : CM_Vehicle;
	reserve  : CM_ReserveDetail;
	ti : CM_TrackedItem;
	validTrailerCargoTypes : CM_CargoTypeSet;
	reserveDetailSetTrail : CM_ReserveDetailSet;
	cargoType : CM_CargoType;
	iter : Iterator;
	startObject : CM_TrackedItem;
	reason : String;	
	allTis	: CM_TISet;
begin
	create vehicleArray transient;
	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	
	self.getAssociatedTrucks(vehicleArray);
	foreach vehicle in vehicleArray discreteLock do
		foreach ti in vehicle.locationsController.allTrackedItems  discreteLock where ti.isROB and ti.isChassis do
			allTrailers.add(ti);
		endforeach;
	endforeach;
	
	if not self.releaseByType then
		foreach reserve in self.allReserveDetails discreteLock do	
				reserve.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
				//foreach ti in reserve.allTrackedItems discreteLock where  ti.isChassis  do
				foreach ti in allTis discreteLock where  ti.isChassis  do //23/06/2023	navkc1	CR 58406 Task 58408
					if self.allTrackedItemsReleased.includes(ti) then
						continue;
					endif;
					allTrailers.addExclusive(ti);					
				endforeach;
		endforeach;
	else
		if self.myOperatorTerminal = null then	
			return;
		endif;
		create validTrailerCargoTypes transient;
		foreach cargoType in app.myRoot.allCargoTypesById discreteLock where cargoType.productType = ProductType_Trailer do		
			validTrailerCargoTypes.add(cargoType);	
		endforeach;
		if validTrailerCargoTypes.first = null then
			return ;
		endif;
		create reserveDetailSetTrail transient;
		foreach reserve in self.allReserveDetails discreteLock do
			if validTrailerCargoTypes.includes( reserve.getMyCargoType) then
				reserveDetailSetTrail.add(reserve);
				continue;
			endif;
		endforeach;
		if reserveDetailSetTrail.first = null then
			return;
		endif;
		
		foreach cargoType in validTrailerCargoTypes discreteLock do
			iter := self.myOperatorTerminal.allOnsiteTIsByCargoTypeId.createIterator;
			startObject := self.myOperatorTerminal.allOnsiteTIsByCargoTypeId.getAtKeyGeq( cargoType.id, null);
			if startObject &lt;&gt; null and startObject.cargoType = cargoType.id then
				iter.startAtObject(startObject);
				while iter.next(ti) do
					if ti.cargoType &lt;&gt; cargoType.id then
						break;
					endif;
					foreach reserve in reserveDetailSetTrail where reserve.CM_ReserveSelection.myCargoType = cargoType do
						// find any trailers that meet at least one of the reserve details.
						if ti.testAgainstReserveSelection( reserve.CM_ReserveSelection, reason, true, null ) then
							allTrailers.addExclusive(ti);	
							break;
						endif;
					endforeach;
				endwhile;
			endif;
			delete iter;
		endforeach;
	endif;
epilog
	delete vehicleArray;
	delete validTrailerCargoTypes;
	delete reserveDetailSetTrail;
	delete iter;
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
        <Parameter name="allTrailers" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAssociatedTrucks" id="c6f874df-5f4c-4244-b1ce-2de0074f0df9">
        <source>getAssociatedTrucks(truckArray : CM_VehicleArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2021	jlier1	Initial creation TFS 51879

*/

vars
	req : CM_Request;
	roadJob : CM_RoadJob;
	truck : CM_Vehicle;
	showCompletedTrucks : Boolean;
begin
	if truckArray = null then
		return;
	endif;

	//JLIER1 MTN-34143 11/4/25
	if self.myTerminal &lt;&gt; null then
		showCompletedTrucks:=self.myTerminal.getConfig(WebShowCompletedTrucks).Boolean;
	endif;
	
	foreach req in self.allRequestsBeingActioned discreteLock do
		if req.myJob = null or not req.myJob.isRoadJob then
			//Not a road job
			continue;
		endif;
		roadJob := req.myJob.CM_RoadJob;
		if not showCompletedTrucks and roadJob.isCompleteForExit then
			// already completed
			continue;
		endif;
		if roadJob.myVehicleVisit = null or not roadJob.myVehicleVisit.isIncomplete then
			// NOT incomplete
			continue;
		endif;
		truck := roadJob.myVehicle;
		if truck &lt;&gt; null then
			truckArray.addExclusive( truck );
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="truckArray" type="CM_VehicleArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAssociatedWagons" id="048ae094-a8d5-4188-9e42-c90644158c54">
        <source>getAssociatedWagons( _wagonArray : CM_WagonArray input; _includeActioned : Boolean );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 January 2017	cnwndl1	Initial creation	TFS 3198/2877

*/

vars

	req : CM_Request;
	wle : CM_WorkListEntry;
	lc : CM_LocationsController;
	wagon : CM_Wagon;
	resDetail : CM_ReserveDetail;

begin

	foreach req in self.allRequestsBeingActioned discreteLock do
		foreach wle in req.allWorkListEntries discreteLock do
			if wle.status &lt;&gt; WLE_UNACTIONED then
				if not _includeActioned then
					continue;
				endif;
			endif;
			lc := wle.getTargetLocation;
			if lc = null and wle.isKindOf(CM_YardWLE) then
				lc := wle.CM_YardWLE.allLocationControllers.first;
			endif;
			if lc &lt;&gt; null then
				wagon := null;
				if lc.isWagon then
					wagon := lc.CM_WagonController.myWagon;
				endif;
				if wagon &lt;&gt; null then
					_wagonArray.addExclusive( wagon );
				endif;
			endif;
		endforeach;	
	endforeach;
	
	//01 Mar 2017	NDL	TFS 2523
	foreach resDetail in self.allReserveDetails discreteLock do
		foreach req in resDetail.allDeliveryRequests discreteLock do
			foreach wle in req.allWorkListEntries discreteLock do
				if wle.status &lt;&gt; WLE_UNACTIONED then
					if not _includeActioned then
						continue;
					endif;
				endif;
				lc := wle.getTargetLocation;
				if lc = null and wle.isKindOf(CM_YardWLE) then
					lc := wle.CM_YardWLE.allLocationControllers.first;
				endif;
				if lc &lt;&gt; null then
					wagon := null;
					if lc.isWagon then
						wagon := lc.CM_WagonController.myWagon;
					endif;
					if wagon &lt;&gt; null then
						_wagonArray.addExclusive( wagon );
					endif;
				endif;
			endforeach;	
		endforeach;
	endforeach;

epilog

end;</source>
        <Parameter name="_wagonArray" type="CM_WagonArray" usage="input"/>
        <Parameter name="_includeActioned" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="28c0ebaa-f25a-40b6-9888-0275f8a0d07b">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     14 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17/09/2009	consw1		SFW1035 - get info from ReserveDetail rather than Yard Request
// ---------------------------------------------------------------------------
//6/08/2018 	JLGNS1	Bug 39748: Release Request change not audited
//23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
vars
	txt,
	tmpStr	: String;
	tiReq	: CM_TIRequest;
	int,cnt,
	length	: Integer;
	res 	: CM_ReserveDetail;
	tmpTI 	: CM_TrackedItem;
	allTis	: CM_TISet;
	
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	// ### PAR 9539 from here
	res := self.allReserveDetails.first;
	if res &lt;&gt; null then
		txt := txt &amp; res.getAuditText();
		tmpStr 	:= self.getWeightRequested.String;		//Bug 39748
		txt 	:= txt &amp; 'weightRequested' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;	//Bug 39748
		//39748
		foreach res in self.allReserveDetails do
			res.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
			//foreach tmpTI in res.allTrackedItems do
			foreach tmpTI in allTis do //23/06/2023	navkc1	CR 58406 Task 58408
				cnt := cnt + 1;
				tmpStr := tmpTI.id;
				txt := txt &amp; 'Item ' &amp; cnt.String &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
			endforeach;
		endforeach;
	endif;
	
	// 04/02/2008 cnwar2 #15255
	tmpStr 	:= self.getNumItemsBeingActioned.String;
	txt 	:= txt &amp; 'numItemsBeingActioned' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	// 01/07/2008 cnwar2 #16533
	if not self.releaseByType and self.allAvailabilityGrades.size &gt; 0 then
		foreach int in self.allAvailabilityGrades do
			tmpStr := tmpStr &amp; int.String &amp; ", ";
		endforeach;
		length 	:= tmpStr.length;
		tmpStr 	:= tmpStr[1:length-2]; // remove trailing comma
		txt 	:= txt &amp; 'availabilityGrades' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	// CCMS1412
	if self.myPinNo &lt;&gt; null then
		tmpStr := self.myPinNo.pinNo;
	else
		tmpStr := 'null';
	endif;
	txt := txt &amp; 'Pin No.' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		
	return txt;
epilog
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAvailGradesForReport" id="9cbf13e5-f4a5-427b-ba86-eda9838ca782">
        <source>getAvailGradesForReport() : String;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 02 October 2007
//
//----------------------------------------------------------------------

vars
	str : String;
begin
	//Work around for reports as report writer will only use the first 100 chars of a string for dyna dict keys.  //Par15009 Par46096
	str := self.getAvailabilityGrades();
	
	return str[1:100];
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAvailabilityGrades" id="4d1846ee-7c52-4603-93e3-37d9c735d862">
        <source>getAvailabilityGrades():String;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 24/04/2012	cnwcs5	get rid of trailing comma
vars
	allGrades		: IntegerArray;
	numGrades, i	: Integer;
	grade      		: Integer;
	gradesDesc		: String;
	obj        		: CM_MTGrade;
	code			: CM_MTGradeCode;
	canDisplay		: Boolean;
	reserveSel		: CM_ReserveSelection;
begin
	
	if self.releaseByType then
		reserveSel := self.allReserveDetails.first.CM_ReserveSelection;
		
		if reserveSel &lt;&gt; null then
			allGrades := reserveSel.allAvailabilityGrades;
		endif;
	else
		allGrades := self.allAvailabilityGrades;
	endif;
	
	if allGrades = null then
		return null;
	endif;

	numGrades := allGrades.size;

	foreach i in 1 to numGrades do
	    grade 	:= allGrades.at(i);	  
        obj 	:= app.myRoot.allAvailabilityGrades[grade];
		
        if obj &lt;&gt; null then
        	code := null;
			
        	obj.getTranslationForOperator(obj, self.myOperator, null, code, canDisplay);
        	
			if code &lt;&gt; null then
				if gradesDesc = null then
					gradesDesc := code.description;
				else
					gradesDesc := code.description &amp; "," &amp; gradesDesc;
				endif;
				
        	elseif canDisplay then
				if gradesDesc = null then
					gradesDesc := obj.description.trimBlanks;
				else
					gradesDesc := obj.description.trimBlanks &amp; "," &amp; gradesDesc;
				endif;
        	endif;
        endif;
	endforeach;

	return gradesDesc;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAvailabilityGradesIntegers" id="a2c78614-184d-42eb-8fb7-4cc1b550b519">
        <source>getAvailabilityGradesIntegers() : String;
//
// 13 Mar 2017	cnwrs1		TFS3648 add other Release Request fields
//
vars
	gradesCode : String;
	reserve : CM_ReserveDetail;
	availabilityGrades : IntegerArray;
	grade : Integer;
begin
	create availabilityGrades transient;
	foreach reserve in self.allReserveDetails do
		if reserve.isKindOf(CM_ReserveSelection) then
			foreach grade in reserve.CM_ReserveSelection.allAvailabilityGrades do
				if not availabilityGrades.includes(grade) then
					availabilityGrades.add(grade);
				endif;
			endforeach;
		endif;
	endforeach;
	foreach grade in availabilityGrades do
		if gradesCode = null then
			gradesCode := grade.String;
			break;
//		else
//			gradesCode := gradesCode &amp; "," &amp; grade.String;
		endif;
	endforeach;
	return gradesCode;
epilog
	delete availabilityGrades;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAvailableAssignedTis" id="15cd6fa6-e244-4e8f-92ee-bbd8ee43d841">
        <source>getAvailableAssignedTis( _availableAssignedTIs : Collection input; _request : CM_Request);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 April 2020	jlgndl1	Initial creation	TFS 49095
19 Aug 2022		navrk21	Bug 54527: AAT - Unable to Process a truck (Error 1090 Attended access via null object reference)
*/

vars

	ti : CM_TrackedItem;
	lc : CM_LocationsController;
begin

	_availableAssignedTIs.clear();
	
	// ### TFS 52721 16NOV2022 NAVAB1 do not check this if we are assigning to BR as we go along
	if _request.isYardDeliveryReq()
	and self.myTerminal.getConfig(DelReqAddToAssigned).Boolean then 
		return; 
	endif;
	
	foreach ti in self.allTrackedItemsAssigned do
		if ti.hasBeenMerged then
			continue;
		endif;
		
		lc := ti.myPrimaryActualLocation;
		
		if lc = null then
			continue;
		endif;
		//End 19.08.2022 navrk21	#54527
		if ( lc.isVehicle and self.isRoadType ) or
		   ( lc.isWagon   and self.isRailType ) or
		     lc.isMachineController or  lc.isYardInterchangeAreaLocation then
			continue;
		endif;	
		
		_availableAssignedTIs.add( ti );
		
	endforeach;
	
epilog

end;</source>
        <Parameter name="_availableAssignedTIs" type="Collection" usage="input"/>
        <Parameter name="_request" type="CM_Request"/>
    </JadeMethod>
    <JadeMethod name="getAverageWeight" id="1dae77e6-ae6b-4dac-89f4-30db0a190b04">
        <source>getAverageWeight() : Integer;

vars
	reserve : CM_ReserveDetail;
	totalWeight : Integer;
	numberOfItems : Integer;
begin

	foreach reserve in self.allReserveDetails do
		totalWeight := totalWeight + reserve.getAverageWeight();
		numberOfItems := numberOfItems + 1;
	endforeach;
	
	if totalWeight &gt; 0 then
		return (totalWeight / numberOfItems).Integer;
	endif;
	
	return 0;
end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getByTypeProspects" id="b853ea11-20a3-4bfe-a617-2d211ef2ff98">
        <source>getByTypeProspects(parentsArray : CM_TIArray io) protected;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 01 July 2019
TFS#		: 45287
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	ti 						: CM_TrackedItem;
	reserve 				: CM_ReserveDetail;
	opTerm 					: CM_OperatorTerminal;
	reason 					: String;	
	iter 					: Iterator;	
	reserveDetailSetCont 	: CM_ReserveDetailSet;
	startObject 			: CM_TrackedItem;
	validTrailerCargoTypes 	: CM_CargoTypeSet;

begin

	opTerm := self.myOperatorTerminal;
	if opTerm = null then
		return;
	endif;
	
	// we are only interested in reserve details that are for Containers 	
	create reserveDetailSetCont transient;
	
	foreach reserve in self.allReserveDetails do
		if not reserve.isKindOf( CM_ReserveSelection ) then
			continue;
		endif;
		if reserve.CM_ReserveSelection.myCargoType = null then
			continue;
		endif;
		if reserve.CM_ReserveSelection.myCargoType.id = TI_CargoType_Container then
			reserveDetailSetCont.add(reserve);
			continue;
		endif;		
	endforeach;
			
	if reserveDetailSetCont.isEmpty then
		return;
	endif;
	
	if not reserveDetailSetCont.isEmpty then
		iter := opTerm.allOnsiteTIsByCargoTypeId.createIterator;
		startObject := opTerm.allOnsiteTIsByCargoTypeId.getAtKeyGeq( TI_CargoType_Container, null);
		if startObject &lt;&gt; null and startObject.isContainer then
			iter.startAtObject(startObject);
			while iter.next(ti) do
				if not ti.isContainer then
					break;
				endif;
				foreach reserve in reserveDetailSetCont do
					// find any containers that meet at least one of the reserve details.
					if reserve.isKindOf(CM_ReserveSelection) then
						if ti.testAgainstReserveSelection(reserve.CM_ReserveSelection, reason, true, null ) then
							parentsArray.add(ti);						
							break;
						endif;
					endif;
				endforeach;
			endwhile;
		endif;
		delete iter;
	endif;
				
epilog
	
	delete reserveDetailSetCont;
	delete iter;
	delete validTrailerCargoTypes;

end;</source>
        <access>protected</access>
        <Parameter name="parentsArray" type="CM_TIArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getCargoRemarks" id="7d26dc4e-5626-432f-824a-5a814e50e3d5">
        <source>getCargoRemarks() : String;
//
// Purpose:			NOT REFERENCED ANYWHERE BUT USED IN SQL EXTRACTS - DO NOT DELETE
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 09/06/2016	cnwdap1		Initial creation POL TFS #1963 SQL Extract for Bulk Releases
//
vars
	detail : CM_ReserveDetail;
	remarks : String;

begin
	foreach detail in self.allReserveDetails discreteLock do
		remarks := remarks &amp; " " &amp; detail.getDisplayStringForAttribute(ETRow_Remarks, null);
	endforeach;
	
	if remarks = null then
		remarks := self.cargoRemarks;
	else
		remarks := remarks &amp; " " &amp; self.cargoRemarks;
	endif;
	
	remarks :=  remarks.trimBlanks;
	return remarks;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
