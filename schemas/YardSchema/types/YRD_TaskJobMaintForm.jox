    <JadeMethod name="btnEmail_click" id="4faf2b88-d1d7-4b17-aeba-368a02322d48">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnEmail_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 August 2009	cnwmd1	Initial creation

*/

vars

begin
	self.doSelectEmailAddress();
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnJobCancel_click" id="ce366599-f94b-4c1e-aa24-a4a76a206697">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnJobCancel_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 July 2009	cnwmd1	Initial creation

*/

vars

begin
	if self.hasChanged then
		if self.confirmCancel(app.getErrorString(The_Current_Item)) then
			self.unloadForm();
		else
			return;
		endif;
	else	
	self.unloadForm();
	endif;
	
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnJobOK_click" id="05b0f8c4-8395-4fb8-a6d2-d75919c97d99">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnJobOK_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 Jul 2009	cnwmd1	Initial creation
12 Oct 2021	jlizm1	TFS 51963 SAL Voyage Request Changes
15 Feb 2023 navma1  ChangeRequest 56561: FR 53944 | EUP - Simplified Voyage Work Order
*/

vars
	wo : CM_WorkOrder;
begin
	// if setting a voyage request WO to not approved, show reject reason dialogue
	
	wo := self.myCurrentProxyWorkOrder;
	
	if wo &lt;&gt; null and wo.isWorkOrderForVoyageRequest then 
		if wo.taskStatus &lt;&gt; WO_STATUS_NOTAPPROVED and app.workOrderStatusStringToEnum( self.cmbJobStatus.text ) = WO_STATUS_NOTAPPROVED then	//15.02.2023 navma1 #56561
			if not self.setRejectReason() then
				return;
			endif;
		endif;
	endif;
	
	self.doBaseFormSave();
	if app.myPassport.trxCompletedOK then
		self.unloadForm();
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
