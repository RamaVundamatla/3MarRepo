    <JadeMethod name="setBankDetails" id="2d38458e-cd79-40c6-81f3-0de1a6d23b04">
        <source>setBankDetails(_details : String);
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aStrArray : StringArray;
	tmpStr : String;
begin
	create aStrArray transient;
	_details.asStringArrayByDelimiter(aStrArray,Cr);
	self.allBankDetails.clear;
	foreach tmpStr in aStrArray do
		tmpStr := tmpStr.removeCrLfs();
		tmpStr := tmpStr.trimBlanks();
		self.allBankDetails.add(tmpStr);
	endforeach;
epilog
	delete aStrArray;
end;</source>
        <Parameter name="_details" type="String"/>
    </JadeMethod>
