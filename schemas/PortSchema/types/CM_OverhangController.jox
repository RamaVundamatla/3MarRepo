epilog

end;</source>
        <Parameter name="_realController" type="CM_LocationsController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMoveTo" id="cbd7182a-3f04-4238-84f9-103c84f30126">
        <source>validateMoveTo(control: CMIF_MoveController input);
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(control);
	
	if self.myGridArea.isAlignRight and self.myGridRow.allControllersByColumn.first = self then
	else
		app.raiseCMException1(ERR_TI_ON_OVERHANG,"", null, null);
	endif;

end;</source>
        <Parameter name="control" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMoveToOSBackend" id="9f6521bb-4255-4b62-bdf0-d79ddbe25332">
        <source>validateMoveToOSBackend(_control : CMIF_MoveController) : Boolean;
// ---------------------------------------------------------------------------
// Created:     16 February 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	noStackFrom, actualStacked : Integer;
	tiID : String;
begin
	
	noStackFrom := self.getHeightNoStackFrom();
	
	if noStackFrom &lt; 1 then
		return true;
	endif;
	
	actualStacked := self.allTrackedItemOSBackEnds.size;
	if _control.myTrackedItem = null then
		tiID := "item's";
	else
		tiID := _control.myTrackedItem.id &amp; "'s";
	endif;
	
	if (_control.moveMode = REAL_MODE and self.allTrackedItemOSBackEnds.size = (noStackFrom - 1))
	or (_control.moveMode = QUEUE_MODE and (self.allTrackedItemOSBackEndsQd.size + actualStacked) = (noStackFrom - 1))
	or (_control.moveMode = PLANNING_MODE and (self.allTrackedItemOSBackEndsPd.size + actualStacked) = (noStackFrom - 1)) then
	
		app.raiseCMException4(ERR_MOVE_OH,self.getID(),tiID , "overhang", null, null,self);
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <Parameter name="_control" type="CMIF_MoveController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
