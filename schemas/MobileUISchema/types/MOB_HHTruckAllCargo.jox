    <JadeMethod name="setupForNotifications" id="0d29a5e9-c473-4a20-9166-3e9013fa3f16">
        <source>setupForNotifications( _begin : Boolean; _oneObject : Object );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 March 2010	cnwndl1	Initial creation

*/

vars

	obj : Object;
	
begin

	if _begin then
	
		if _oneObject &lt;&gt; null then
		
			self.beginNotification( _oneObject, Any_System_Event, Response_Continuous, 0 );
		
		else
	
			foreach obj in self.allNotableObjects do
				self.beginNotification( obj, Any_System_Event, Response_Continuous, 0 );
			endforeach;
		
		endif;
	
	else
	
		if _oneObject &lt;&gt; null then
		
			self.endNotification( _oneObject, Any_System_Event );
		
		else
	
			self.endNotifications();
		
		endif;
		
	endif;

epilog

end;</source>
        <Parameter name="_begin" type="Boolean"/>
        <Parameter name="_oneObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="ccc9f56e-6d8e-4b31-a3e5-d31a12dc4ac5">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 January 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars
	truck : CM_Vehicle;
begin

	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	truck := self.myMobileGenericAgent.myTruck;

	if truck &lt;&gt; null then
		self.caption := self.caption &amp; " " &amp; truck.getDisplayDetails(true);
	endif;
	
	inheritMethod();
	
	self.setupCmdButtons( 2, app.getErrorString(Complete), app.getErrorString(Back), null, null, null );
	
	if doReturnFromSearch() then
		return;
	endif;
	
	self.myMobileGenericAgent.setMyReceivalRequestInfo(null);
	
	self.setupCargo();
	
	if truck &lt;&gt; null then
		self.allNotableObjects.add(truck);
		self.allNotableObjects.add(truck.locationsController);
	endif;
	self.setupForNotifications(true, null);
	
	self.returnFromDocAction();			// TFS 2653
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
