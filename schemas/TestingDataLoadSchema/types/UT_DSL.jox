    <JadeMethod name="addTaxCode" id="41c137f5-e6bc-4468-95a0-cf6f275b74c4">
        <source>addTaxCode(_code : String; _description : String; _glCode : CM_GLCode) : CM_TaxCode;

vars
	realTaxCode, pxyTaxCode : CM_TaxCode;
	bank	: CM_Bank;
begin
	bank := self.getTerminal().getDefaultCompanyBank();

	create pxyTaxCode as CM_TaxCode transient;
	
	pxyTaxCode.setProxy(_code, 
						_description, 
						bank, 
						_glCode,
						false,null);
	
	app.myTrxCA.trxCreateTaxCode(pxyTaxCode, realTaxCode, app.myPassport);
	
	return realTaxCode;
epilog
	delete pxyTaxCode;
end;
</source>
