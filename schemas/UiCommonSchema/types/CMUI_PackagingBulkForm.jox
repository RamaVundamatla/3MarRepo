    <JadeMethod name="validate" id="eda2e2e3-4376-40ad-906e-8856c29c505a">
        <source>validate( _allTiIdsToCreate : StringArray input; 
			_quantityPerId : Integer output;
			_itemNettWeight : Decimal output;
			_location : CM_LocationsController output
			):Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2013	cnwndl1	Initial creation	CCMS 2274 Break Bulk
21 Dec 2015 cnwma1 PAR #37156  UE 1035 in app MobileUISchema::HandHeldApp of CIGPJMT

*/

vars

	newBaseId : String;
	suffixLength : Integer;
	firstSuffix : Integer;
	lastSuffix : Integer;
	msg : String;
	iter : Iterator;
	startObject : Object;
	existingTi : CM_TrackedItem;
	existingTiSuffixString : String;
	existingTiSuffixInteger : Integer;
	proposedId : String;
	suffixInt : Integer;
	
	amountToProcess : Decimal [16,4];
	foundHeight : Integer;
	amountPerItem : Decimal [16,4];
	operator : CM_Operator;
	cargoType : CM_CargoType;
	prod : CM_Product;
	testDensity : Decimal [16,4];
	descr : String;
begin

	cargoType := self.cmbNewCargoType.listObject.CM_CargoType;
	if cargoType = null then
		msg := app.getErrorString(Select_cargo_type_continu);
		app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
		return false;
	else
		if cargoType.mySystemProductType &lt;&gt; null and cargoType.mySystemProductType.myDensityDec &lt;&gt; null then	// ### TFS 52193 22Nov2021 NAVPW1
			testDensity := cargoType.mySystemProductType.myDensityDec.getRawValue.Decimal;						// ### TFS 52193 22Nov2021 NAVPW1
			descr := cargoType.description;
		endif;
	endif;
	if cargoType.hasProductTypes then
		prod := self.cmbNewProduct.listObject.CM_Product;
		if prod = null then
			msg := app.getErrorString(Please_select_cargo_type_conti);
			app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
			return false;
		endif;
		if prod.myDensityDec &lt;&gt; null then																		// ### TFS 52193 22Nov2021 NAVPW1
			testDensity := prod.myDensityDec.getRawValue.Decimal;												// ### TFS 52193 22Nov2021 NAVPW1
			descr := cargoType.description &amp;  "/" &amp; prod.description;
		endif;
	endif;
	
	if self.myTrackedItem.isBulkByVolume and testDensity &lt;&gt; self.myTrackedItem.getDensity then
		msg := app.getErrorString2(Densi_value_cargo_type_cargo_i, descr &amp; " (" &amp; testDensity.asStringJMT &amp; ")", self.myTrackedItem.id &amp; " (" &amp; self.myTrackedItem.getDensity.asStringJMT &amp; ")");
		app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
		return false;
	endif;
	
	_quantityPerId := txtNewItems.text.Integer;
	amountPerItem := self.tblAmountPerItem.getConvertedValue();
	if self.myTrackedItem.isBulkByVolume then
		_itemNettWeight := self.myTrackedItem.getDensity * amountPerItem;
	else
		_itemNettWeight := amountPerItem;
	endif;
	amountToProcess := self.tblAmountToProc.getConvertedValue();
	if self.myTrackedItem.isBulkByVolume then
		if amountToProcess &gt; self.myTrackedItem.totalVolume then
			msg := app.getErrorString1(Does_not_gave_this_much_volum_, self.myTrackedItem.id);
			app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
			self.tblAmountToProc.setFocus();
			return false;
		endif;
	else
		if amountToProcess &gt; self.myTrackedItem.totalWeight then
			msg := app.getErrorString1(Does_not_gave_this_much_weigh_, self.myTrackedItem.id);
			app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
			self.tblAmountToProc.setFocus();
			return false;
		endif;
	endif;
	
	amountPerItem := self.tblAmountPerItem.getConvertedValue();
	
	if ( amountPerItem * _quantityPerId ) &lt;&gt; amountToProcess then
		msg := app.getErrorString3(Does_not_equal_multipl, self.lblAmountToProc.caption, self.lblAmountPerItem.caption, self.lblINewItems.caption );
		app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
		self.tblAmountToProc.setFocus();
		return false;
	endif;
	
	operator := self.cmbOperator.listObject.CM_Operator; 
	if operator = null then
		msg := app.getErrorString(Please_select_operator);
		app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
		self.cmbOperator.setFocus();
		return false;
	endif;
	
	if self.txtNewLocation.text &lt;&gt; null then
		self.myTerminal.findLocationFromString( self.txtNewLocation.text.trimBlanks, true, _location, foundHeight );
	endif;
	if _location = null then
		msg := app.getErrorString(Location_NotFound);
		app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
		return false;
	endif;
	
	newBaseId := txtId.text.trimBlanks.toUpper;
	if newBaseId = null then
		msg := app.getErrorString(Must_enter_cargo_item_being_sp);
		app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
		self.txtIdSuffix.setFocus();
		return false;
	endif;
		
	firstSuffix := txtIdSuffix.text.Integer;
	lastSuffix := ((firstSuffix + _quantityPerId) - 1);
	suffixLength := txtIdSuffix.text.trimBlanks.length;
	startObject := self.myTerminal.allOnsiteTIsByCargoTypeId.getAtKeyGeq(myTrackedItem.cargoType,newBaseId);
	
	
	
	if self.optBreakBulk.value then
		//Going to create one new BB cargo item with a specific ID.	
		_allTiIdsToCreate.add( newBaseId );
		return true;
		
	elseif self.optPieceBBB.value then
		// going to create mulitple Piece Break Bulk cargo items each with a quantity of one
		// check that the concatenation of the values is not too long
		// check that we have a valid starting id, and that each proposed id would be unique 
		
		if lastSuffix.String.length &gt; suffixLength then
			suffixLength := lastSuffix.String.length;
		endif;
		//if newBaseId.length + suffixLength &gt; 30 then			//21/12/2015 cnwma1 PAR #37156
		if newBaseId.length + suffixLength &gt; 20 then			//21/12/2015 cnwma1 PAR #37156
			msg := app.getErrorString(Propo_combi_with_suffi_resul_p);
			app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
			self.txtId.setFocus();
			return false;
		endif;
		//Because its break bulk that is allowed which is allowed to be split or merged, we can have only one of each id per location per cargo type
		//Using an id that was alreday in use in the area would imply an intent to merge!!!
		if startObject &lt;&gt; null then
			iter := self.myTerminal.allOnsiteTIsByCargoTypeId.createIterator;
			iter.startAtObject(startObject);
			while iter.next(existingTi) do
				if existingTi.cargoType &lt;&gt; myTrackedItem.cargoType then
					//differnt cargo type. All done
					break;
				endif;
				if existingTi.id.length &lt; newBaseId.length then
					//this too short to be a match try the next one
					continue;
				endif;
				if existingTi.id = newBaseId then
					//we will be adding a suffix to newBaseId, so wont be a match, try teh next one.
					continue;
				endif;
				if not existingTi.id.startsWith(newBaseId) then
					//stopped matching at all. All done
					break;
				endif;
				if existingTi.myPrimaryActualLocation &lt;&gt; myTrackedItem.myPrimaryActualLocation then
					//not in the same location, so we don't care
					continue;
				endif;
				//Ok we have one where the first part matches, lets see if the second part of the id
				// could match with any of our proposed ids.
				
				//get the last bit of the id
				existingTiSuffixString := existingTi.id[ newBaseId.length + 1 : end];
				if not existingTiSuffixString.isInteger then
					//it contains alpha chars and ours wont.
					continue;
				endif;
				
				existingTiSuffixInteger := existingTiSuffixString.Integer;
				if existingTiSuffixInteger &lt; firstSuffix or existingTiSuffixInteger &gt; lastSuffix then
					//the Integer value is outside our proposed range
					continue;
				endif;
				//we have one in the same range, SOOOOO is it going to result in the same id?
				proposedId := newBaseId &amp; existingTiSuffixInteger.padLeadingWith('0',suffixLength);
				if existingTi.id &lt;&gt; proposedId then
					// must be a different number of leading zeros, all good
					continue;
				endif;
				
				msg := app.getErrorString1(Propos_alread_used_this_locati,proposedId);
				app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
				self.txtId.setFocus();
				return false;
				
			endwhile;
		endif;
		
		_quantityPerId := 1;	
		foreach suffixInt in firstSuffix to lastSuffix do
			proposedId := newBaseId &amp; suffixInt.padLeadingWith('0',suffixLength);
			_allTiIdsToCreate.add( proposedId );
		endforeach;
		return true;
	
	else
		msg := app.getErrorString(Select_option);
		app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
		return false;
		
	endif;
	
	return false;

epilog

	delete iter;
	
end;</source>
        <access>protected</access>
        <Parameter name="_allTiIdsToCreate" type="StringArray" usage="input"/>
        <Parameter name="_quantityPerId" type="Integer" usage="output"/>
        <Parameter name="_itemNettWeight" type="Decimal" usage="output"/>
        <Parameter name="_location" type="CM_LocationsController" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
