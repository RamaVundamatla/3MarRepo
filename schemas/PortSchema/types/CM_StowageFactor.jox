    <JadeMethod name="myCargoType" id="a56b003a-0aaf-43cf-a219-7062a01073b6">
        <methodInvocation>mapping</methodInvocation>
        <source>myCargoType(set: Boolean; _value: CM_CargoType io) mapping;
// ---------------------------------------------------------------------------
// Created:     01 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	_value := app.myRoot.allCargoTypesById[self.cargoType];

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_CargoType" usage="io"/>
    </JadeMethod>
