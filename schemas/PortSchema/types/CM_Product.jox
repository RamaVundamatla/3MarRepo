    <JadeMethod name="updateForNonInversedReference" id="9c59ee9b-94a8-48c9-bb77-2c78dded3266">
        <updating/>
        <source>updateForNonInversedReference() updating;
// ---------------------------------------------------------------------------
// Created:     04 March 2010 by cnwcs5
// Purpose:     par 22762
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	//if the product is not a system product type then its OK to update this value
	//cnwjo3 par 23669
	if self.hasNoNonInversedUsages then
		if not self.isSystemProductType then
			self.hasNoNonInversedUsages := false;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
