    <JadeMethod name="translateForm" id="ead9b634-7187-45c9-aae7-de63433bf771">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0015257, locale);
	btnExportCSV.translateCaption(Xlat_0015258, locale);
	btnPrintRemarks.translateCaption(Xlat_0015259, locale);
	mnuColOrganiser.translateCaption(Xlat_0015260, locale);
	mnuExportCSV.translateCaption(Xlat_0015261, locale);
	mnuPrint.translateCaption(Xlat_0015262, locale);
	mnuTblContext.translateCaption(Xlat_0015263, locale);
end;</source>
    </JadeMethod>
</GUIClass>
