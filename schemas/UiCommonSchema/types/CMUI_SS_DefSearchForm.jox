    <JadeMethod name="doQuery" id="acf2a6f9-5c1b-4dbe-9028-f2ec73fc06ce">
        <updating/>
        <source>doQuery() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 December 2009	cnwndl1	Initial creation	CCMS 1023
19/08/2010			cnwcs5	par 23706 - change selectMode
*/

vars

	term : CM_Terminal;
	fromDate : Date;
	checkFrom : Boolean;
	toDate : Date;
	checkTo : Boolean;
	
	outputFormat_SS : CM_OutputFormat_SS;
	snapshotDataByDate : CM_SnapshotDataByDateTimeName;
	iter : Iterator;
	snapshotData : CM_SnapshotData;
	startTimeStamp : TimeStamp;
	startObject : CM_SnapshotData;
	runDateTime : TimeStamp;
	
	resultObject : CM_Object;
	results : CM_ObjectArrayActual;
	
begin

	self.tblData.rows := self.tblData.fixedRows;
	
	term := cmbTerminal.listObject.CM_Terminal;
	if term = null then
		app.msgBox(app.getErrorString(Terminal_reference_set), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon);
		cmbTerminal.setFocus();
		return;
	endif;
	
	fromDate := txtFromDate.getDate();
	if not fromDate.isValid then
		if app.msgBox(app.getErrorString(Specify_start_date), app.getErrorString(Warning), MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon) = MsgBox_Return_No then
			txtFromDate.setFocus();
			return;
		endif;
	endif;
	
	toDate := txtToDate.getDate();
	if toDate.isValid and fromDate.isValid and toDate &lt; fromDate then
		app.msgBox(app.getErrorString(DateFromTo), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon);
		txtFromDate.setFocus();
		return;
	endif;
	
	checkFrom := fromDate.isValid;
	checkTo := toDate.isValid;
	
	outputFormat_SS := cmbDefinition.listObject.CM_OutputFormat_SS;
	create results transient;
		
	if not checkFrom and not checkTo then
		if outputFormat_SS = null then
			term.allSnapshotDataByDate.copy(results);
		else
			iter := outputFormat_SS.allSnapshotDatas.createIterator;
			while iter.next( snapshotData ) do
				if snapshotData.myTerminal &lt;&gt; term then
					continue;
				endif;
				results.add( snapshotData );
			endwhile;
		endif;
		
	else
		if outputFormat_SS = null then
			snapshotDataByDate := term.allSnapshotDataByDate;
		else
			snapshotDataByDate := outputFormat_SS.allSnapshotDatas;
		endif;
		
		if not snapshotDataByDate.isEmpty then
			iter := snapshotDataByDate.createIterator;
			if checkFrom then
				startTimeStamp.setDate(fromDate);
				startTimeStamp.setTime( "00:00".Time);
				startObject := snapshotDataByDate.getAtKeyGeq(startTimeStamp, null);
				if startObject &lt;&gt; null then
					iter.startAtObject(startObject);
				endif;
			endif;
		
			while iter.next( snapshotData ) do
				if checkTo then
					runDateTime := snapshotData.runDateTime;
					if runDateTime.Date &gt; toDate then
						break;
					endif;
				endif;
				if snapshotData.myTerminal &lt;&gt; term then
					continue;
				endif;
				results.add( snapshotData );
			endwhile;
			
		endif;
		
	endif;
	
	foreach resultObject in results do
	
		addSnapshotDataToTable( resultObject );
		
	endforeach;
	
	self.tblData.allSelectedObjects.clear();
	//self.tblData.selectMode := Table.SelectMode_WholeRows;	// 19/08/2010 cnwcs5 par 23706
	self.tblData.multiSelect := CM_BaseTable.MultiSelect_Simple;

epilog

	delete results;
	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryCriteriaToolbarContext" id="4e77414e-bae2-446e-979c-e42c75499658">
        <updating/>
        <source>doQueryCriteriaToolbarContext(cntrl: Frame input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 December 2009	cnwndl1	Initial creation

*/

vars
	x1, 
	y1					: Real;
begin

	x1 := x;
	y1 := y;
	if cntrl &lt;&gt; null then
		if (not mouse) then  // if keyboard, use current listIndex value
		    x1 := 20;
		    if cntrl.top &lt; 0 then
		        y1 := 5;
		    else
		        y1 := cntrl.top;
		    endif;
		endif;
		
		conwin.windowToScreen(x1, y1);
	endif;

	self.mnuShowBar2Caption.checked := self.frmSSDef.showCaptions;
	self.mnuShowBar2Caption.visible := true;
	self.mnuShowBar2Caption.enabled := true;
	
	self.screenToWindow(x1, y1);
	self.popupMenu(self.mnuShowBar2, x1.Integer, y1.Integer);
	
	return false;                  // cancel further processing

end;</source>
        <Parameter name="cntrl" type="Frame" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
