    <JadeMethod name="addToolbarControls" id="38c25380-c55d-4976-9085-74e6184d47df">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:     05 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	frm				: CMUI_Toolbar;
	
begin
	frm := self.frmToolbar;
	frm.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnShowSearcher, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnUserColours, CMUI_Toolbar.Control_Alignment_Left);
	inheritMethod();

	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnSelectAllTIs, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnEnquire, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnEdit, CMUI_Toolbar.Control_Alignment_Left);

	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnLocate, CMUI_Toolbar.Control_Alignment_Left);
	
	frm.addButton(self.btnLocateYardEnq, CMUI_Toolbar.Control_Alignment_Left);

	frm.addButton(self.btnRTS, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnCargoUnplan, CMUI_Toolbar.Control_Alignment_Left);
	
	// cnwrl1 16/02/2009 - (CCMS SFW 1047 - Totals Only Lists) - start of coding
	if self.bAllowSummaryDefn then
		frm.addButton( self.btnSummariseAll, CMUI_Toolbar.Control_Alignment_Left );
	endif;
	// cnwrl1 16/02/2009 - (CCMS SFW 1047 - Totals Only Lists) - end of coding
	
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnPreferences, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnQuitSmmryMode, CMUI_Toolbar.Control_Alignment_Left);
	
	if app.isSpecial() then
		frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
		frm.addButton(self.btnDEVMOVINS, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
