    <JadeMethod name="moveTrackedItemSource" id="4bb3b291-3db3-4114-a6a4-9174e5c7fed5">
        <updating/>
        <source>moveTrackedItemSource() updating; 
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		NOTE the TI and the Source Location are set in somewhere like frmGridArea_contextMenu on YRD_GridForm
//				NOTE this code is duplicated in CM_ContainerEnqForm, but the Main copy is on CMUI_GridAreaForm
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	
	self.mousePointer := Window.MousePointer_HourGlass;
	if app.myMoveController = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'app.myMoveController = null');
		return;
	endif;
	
	app.myMoveController.moveTrackedItemSource(self.myTerminal);		
	
epilog
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="moveTrackedItemsSource" id="18ad6e31-1196-42db-87ec-d7869e12b172">
        <updating/>
        <source>moveTrackedItemsSource(_table : CM_DataTable) updating; 
// ---------------------------------------------------------------------------
// Created:		July 2005 By Andrew Bishop cnwab1
//
// Purpose:		BULK LOAD PLAN
//
// ---------------------------------------------------------------------------
vars	
	theTIs : CM_TIArray;
begin
	
	self.mousePointer := Window.MousePointer_HourGlass;
	if app.myMoveController = null or _table = null then
		return;
	endif;
	create theTIs transient;
	_table.allSelectedObjects.copy(theTIs);
	
	app.myMoveController.moveTrackedItemsSource(self.myTerminal,theTIs);
	
epilog

	delete theTIs;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="_table" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="positionQueryFrame" id="e0eca72c-40d9-4056-8058-05588d4ece9c">
        <source>positionQueryFrame() protected;
// ---------------------------------------------------------------------------
// Created:     10 September 2003	cnwth2
//
// Purpose:     
//			 
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 13/04/2018	jlgdap1		TFS 37794 PEL1 Vessel Rates
begin
	self.frmQuery.left		:=	(self.width / 2) - (self.frmQuery.width / 2);
	self.frmQuery.top		:=	100;
	//self.frmQuery.height	:=	250;		// TFS 37794
	//self.frmQuery.width	:=	320;		// TFS 37794
	self.frmQuery.height	:=	260;		// TFS 37794
	self.frmQuery.width		:=	325;		// TFS 37794
	
	self.fldQuery.top		:=	self.frmQueryToolbar.clientHeight()+2;
	self.fldQuery.left		:=	0;
	self.fldQuery.height	:=	frmQuery.clientHeight() - (self.frmQueryToolbar.height + 30);
	self.fldQuery.width		:=	self.frmQuery.clientWidth();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="searcherShowHideControls" id="5f006e56-11ef-47f0-9b90-a44a25ddf4da">
        <source>searcherShowHideControls(_hide :Boolean)protected;
// ---------------------------------------------------------------------------
// Created:     27 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 27/094/2010	cnwcs5		ccms 1118 / par 23580 - enhance EDI form
// ---------------------------------------------------------------------------
vars

begin
	// implement in subclasses to disable all controls when searcher is shown
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_hide" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="dbe17d73-8248-45cd-b5aa-8af509d70969">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	tmpBackColor	: Integer;
begin
	inheritMethod(_colorControl);
	
	tmpBackColor := self.backColor;
	
	self.splMain.backColor		:= tmpBackColor;
	self.frmPopupInfo.backColor := tmpBackColor;
	self.frmQuery.backColor		:= tmpBackColor;
	self.shtQuery1.backColor	:= tmpBackColor;
	self.shtQuery2.backColor	:= tmpBackColor;
	self.shtQuery3.backColor	:= tmpBackColor;
	self.shtQuery4.backColor	:= tmpBackColor;
	self.shtQuery5.backColor	:= tmpBackColor;
	self.shtQuery6.backColor	:= tmpBackColor;
	
	self.setColorsForTable(self.tblData);
	self.setColorsForTable(self.tblInfo);
end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setQueryControl" id="f8d2cb85-198a-4da4-9fcf-369308aec176">
        <source>setQueryControl(_control : Control input);
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

constants
	HorzGap = 10;
vars
begin
	
