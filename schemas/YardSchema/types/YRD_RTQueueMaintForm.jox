    <JadeMethod name="addObjectsToTable" id="3ca712f8-d6bc-4f24-bbd7-e7d6ae220a08">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
// ---------------------------------------------------------------------------
// Created:     22 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	aQ, aSQ : CM_RadioTelemetryQueue;
	breakOut	: Boolean;
begin
	foreach aQ in self.myTerminal.radioTelemetry.masterQueue.allSubQueuesById  do
		if not aQ.isSystemDefinedQueue() then
			self.addObjectToTable(aQ, _numItems, breakOut);
			if breakOut then
				break;
			endif;
		endif;
		foreach aSQ in aQ.allSubQueuesById do
			if not aSQ.isSystemDefinedQueue() then
				self.addObjectToTable(aSQ, _numItems, breakOut);
				if breakOut then
					break;
				endif;
			endif;
		endforeach;

		if breakOut then
			break;
		endif;
	endforeach;
end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="a630b6c7-6863-4c2b-be25-0a775787fd2b">
