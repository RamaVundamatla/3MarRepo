    <JadeMethod name="setupForm" id="a672ed5f-1b99-4d61-95a8-f3014f3ca020">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
begin
	app.mousePointer := Window.MousePointer_Default;
	self.centreWindow();
	self.initGroupBox();
	self.frmToolbar.visible := false;
	self.frmToolbarBtns.visible := false;
	self.tblTIAvailable.visible := self.linkMode = self.Mode_12M;
	self.lblAvailTI.visible := self.linkMode = self.Mode_12M;
	self.btnTIAvailIN.caption := 223.Character; 
	self.btnTIAvailIN.fontName := "Wingdings";
	self.btnTIAvailIN.fontSize := 8;
	self.btnTIAvailIN.visible := self.linkMode = self.Mode_12M;
	self.btnTIAvailOUT.caption := 224.Character; 
	self.btnTIAvailOUT.fontName := "Wingdings";
	self.btnTIAvailOUT.fontSize := 8;
	self.btnTIAvailOUT.visible := self.linkMode = self.Mode_12M;

	inheritMethod();
//	self.doResize();
	self.doResize();
epilog
	app.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
