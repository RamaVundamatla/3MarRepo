    <JadeMethod name="addToolbarControls" id="f555b979-e270-40c1-8c9a-737c9260f0b8">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	toolbar		: CMUI_Toolbar;
	showCaptions	: Boolean;

begin
	inheritMethod();
	toolbar := self.frmToolbar;
	if self.mode = self.Mode_Display then
		toolbar.addButton(self.btnCargoHeights, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnFlipV, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnFlipH, CMUI_Toolbar.Control_Alignment_Left);
	else
		toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnDimensions, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	toolbar.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;


	toolbar := self.frmDimensionTB;
	toolbar.addButton(self.btnSaveDimension, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnAddDimension, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnDeleteDim, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmTBDimCombos, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCancelDimensn, CMUI_Toolbar.Control_Alignment_Right);

	toolbar.positionToolbarControls();
	toolbar.visible := true;

end;</source>
        <access>protected</access>
    </JadeMethod>
