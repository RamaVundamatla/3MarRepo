    <JadeMethod name="buildCombos" id="6598af84-ac66-4c3b-a94e-9aa009cbb113">
        <source>buildCombos() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28/07/2009	cnwmd1	Initial creation
17/05/2018	jlgdap1	TFS 38560 PEL1 Voyage Work Orders
*/

vars
	
begin
	if self.workOrderMode = WorkOrderMode_Cargo then										// TFS 38560
		self.myAssistant.comboBoxCargoWorkOrderTasks(self.cmbTask, self.myTerminal);
	else																					// TFS 38560
		self.myAssistant.comboBoxVoyageWorkOrderTasks(self.cmbTask, self.myTerminal);		// TFS 38560
	endif;																					// TFS 38560
	self.myAssistant.comboBoxWorkOrderStatus(self.cmbJobStatus, app.myPassport.myUser.myOrganisation.isExternal, self.myCurrentProxyWorkOrder.taskStatus);
	self.myAssistant.comboBoxVoyageCurrent(self.cmbVoyage, null, true, false, true, true, false, false, true, false, false);	// TFS 38560
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="checkWODtlCanBeEdited" id="106b064b-f272-4245-b6c0-3fac48dd0827">
        <source>checkWODtlCanBeEdited(_woDtl : CM_WorkOrderDtl) : Boolean protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 26/06/2018	jlgdap1		Initial creation TFS 39432 PEL1 Prevent unexpected program error
//
vars

begin
	return _woDtl.checkWODtlCanBeEdited();//TFS 40029 20AUG18
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_woDtl" type="CM_WorkOrderDtl"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="chkSendEmail_change" id="55f68382-e435-4b3c-885a-8f8f5c2b0dbd">
        <controlMethod name="CheckBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkSendEmail_change(checkbox: CheckBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 January 2010	cnwrd1	Initial creation

*/

vars

begin

	self.lEmail.visible := self.chkSendEmail.value;
	self.txtEmail.visible := self.chkSendEmail.value;
	self.btnEmail.visible := self.chkSendEmail.value;
	
	if self.chkSendEmail.value then
		self.doAddUserEmail();
	endif;
	
epilog

end;</source>
