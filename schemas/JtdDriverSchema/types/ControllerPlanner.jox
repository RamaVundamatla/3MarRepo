		myCMUI_Navigator_1.lstTest.dblClick(myCMUI_Navigator_1.lstTest);  // 14:48:41
		
		app.doWindowEvents(shortPause);
		myYRD_GridAreasForm_1:=app.getForm('YRD_GridAreasForm').Form;
//		listbox:=app.atcgGetAddedControl(myYRD_GridAreasForm_1, ';listbox;CM_MultiSelectListBox;5;-422;23;0;|;msgSelectAreas;CMUI_MultiSelectGroupBox;3;-436;5;0;|').ListBox;
		listbox:=myYRD_GridAreasForm_1.getPropertyValue('msgSelectAreas').Object.getPropertyValue('myAvailableListBox').ListBox;

		app.doWindowEvents(shortPause);
		listbox.listIndex:=app.atcgGetListHierarchicalIndex(listbox, 'Z0'&amp;lane.String&amp;' - RTG Area|', 37);
		listbox.itemSelected[listbox.listIndex]:=true;
		listbox.dblClick(listbox);  // 14:48:48
		
		app.doWindowEvents(shortPause);
		btnSelectAreasSh:=myYRD_GridAreasForm_1.getPropertyValue('btnSelectAreasSh').Button;
		btnSelectAreasSh.click(btnSelectAreasSh);  // 14:48:50
	endforeach;
	
	return 0;
end;</source>
