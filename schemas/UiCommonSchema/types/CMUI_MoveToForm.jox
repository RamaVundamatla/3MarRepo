    <JadeMethod name="addToolbarControls" id="56e2de95-7434-4bf7-ac77-282cd3541625">
        <updating/>
        <source>addToolbarControls() updating, protected;
//--------------------------------------------------
// Created:	25 August 2003 By: cnwgd1
//--------------------------------------------------
vars
	toolbar		: CMUI_Toolbar;
begin
	inheritMethod();
	
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnMoveIt, CMUI_Toolbar.Control_Alignment_Left);
	self.btnMoveIt.visible := true;
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	self.btnCancelBase.enabled 	:= true;	
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnMoveIt_click" id="27ed8f65-4302-413b-91fa-8000996eaf7b">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnMoveIt_click(btn: Button input) updating;
//--------------------------------------------------
// Created:	25 August 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.isMultipleMove then
		self.doMoveItMultiToGrid();	//18 Aug 2011	NDL	Par 28035
	else
		self.doMoveIt();
	endif;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
