    <JadeMethod name="click" id="3add8c42-3366-4762-b49a-dca4be4343c0">
        <updating/>
        <source>click(frame: Frame input) updating;
// ---------------------------------------------------------------------------
// Created:     12 February 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 03 May 2023	navmk20		Task 57853: Jade - Wagon Planning - Rail Line List Planned Wagons
// ---------------------------------------------------------------------------
vars
	theGForm 	: CMUI_GridAreaForm;
	theForm 	: Form;
	idx 		: Integer; 				// 3.5.2023 navmk20 TFS 57853
	object 		: CM_Object;			// 3.5.2023 navmk20 TFS 57853
begin
	inheritMethod(frame);

	if self.mySDF = null then
		return;
	endif;
	theForm := self.mySDF.myParentForm ;
	if theForm = null then
		return;
	endif;
	// Start - 3.5.2023 navmk20 TFS 57853
	if theForm.isKindOf(CMUI_OpsForm) then
		idx := self.mySDF.getRowEndPositionFromY(self.origY);
		object := theForm.CMUI_OpsForm.getObjectForIndex(idx).CM_Object; 
		theForm.CMUI_OpsForm.displayExtraInfoForObj(object);
		return;
	//if not theForm.isKindOf(CMUI_GridAreaForm) then
	elseif not theForm.isKindOf(CMUI_GridAreaForm) then // End - 3.5.2023 navmk20 TFS 57853
		return;
	endif;
	
	theGForm := theForm.CMUI_GridAreaForm;
	theGForm.setMyCurrentSDF(self.mySDF,true);
	theGForm.doBuildMnuZoom(theGForm.mnuZoomSub);
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="dblClick" id="b408d352-2b0f-4855-b615-9b834038a76c">
        <controlMethod name="Frame::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>dblClick(frame: CMUI_ScrollableLabelsFrame input) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin

	if self.myScrollableFrame &lt;&gt; null then
		if self.myScrollableFrame.myScrollingFrame &lt;&gt; null then
			if app.isDragging then
			else
				self.myScrollableFrame.myScrollingFrame.handleLabelFrameDblClick(frame);
			endif;
		endif;
	endif;
	
epilog
	app.isDragging := false;

end;</source>
        <Parameter name="frame" type="CMUI_ScrollableLabelsFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doFrameMouseUp" id="21d7e58c-e541-4962-a14d-7a77c3e7a2d5">
        <updating/>
        <source>doFrameMouseUp(frame: CMUI_ScrollableLabelsFrame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*
Purpose:			
Date				Who			Reason
APRIL 2011		CNWAB1		Initial creation
*/

vars
begin
	on Exception do self.handleInvalidMethodCall(exception);

	if self.mySDF &lt;&gt; null then
		if self.mySDF.myParentForm &lt;&gt; null then
			self.mySDF.myParentForm.sendMsgWithParams("doFrameLabelDrawMouseUpEvent",frame, button,shift, x, y);
		endif;
	endif;
	if self.myScrollableFrame &lt;&gt; null then
		if self.myScrollableFrame.myScrollingFrame &lt;&gt; null then
			if app.isDragging then
			else
				self.myScrollableFrame.myScrollingFrame.handleLabelFrameMouseUp(frame, button, shift, x, y);
			endif;
		endif;
	endif;
	return;
end;</source>
        <Parameter name="frame" type="CMUI_ScrollableLabelsFrame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="dragOver" id="75b67cfb-a0c7-4021-8a5a-8c1f00e78970">
        <updating/>
        <source>dragOver(frame: CMUI_ScrollableLabelsFrame input; win: Window input; x: Real; y: Real; state: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	horizontalScroll : Boolean;	
	theSDF : CMUI_ScrollableDrawingFrame;
	now : TimeStamp;
begin
	inheritMethod(frame, win, x, y, state);

	if self.mySDF &lt;&gt; null then
		return; // NOT USED. Scrolling done on CMUI_GridAreaFrame AKB2004FEB
	endif;
	// new control only
	if self.myScrollableFrame &lt;&gt; null then
		return;// maybe do this later
		if self.myScrollableFrame.myScrollingFrame &lt;&gt; null then
			self.myScrollableFrame.myScrollingFrame.handleLabelFrameDragOver(frame, win,  x, y, state);
		endif;
	endif;
	
end;</source>
        <Parameter name="frame" type="CMUI_ScrollableLabelsFrame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawVLabel" id="b750fb35-1eb2-49a1-babe-a6a06ab37709">
        <source>drawVLabel(caption : String; y1 : Real) protected;
// ---------------------------------------------------------------------------
// Created:      01 August 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	lX 		: Real;
	lY 		: Real;
	frame : CMUI_ScrollableLabelsFrame;

begin
	lX := (self.width / 2) - ((caption.length * 7) / 2);
//	lY := (y1 + ((y2 - y1) / 2)) - 10; // the 10 is half the height of the text in pixels
	self.drawTextAt(caption, lX + 1, y1 + 1, White);
	self.drawTextAt(caption, lX, y1/*lY*/, Black);
end;</source>
        <access>protected</access>
        <Parameter name="caption" type="String"/>
        <Parameter name="y1" type="Real"/>
    </JadeMethod>
    <JadeMethod name="handleInvalidMethodCall" id="c7330f10-800c-4e01-9831-239257bf8983">
        <source>handleInvalidMethodCall(_exc : Exception) : Integer;

constants
	MethodWrong	= 1010;
	
vars
	returnVal		: Integer;
	
begin
	returnVal := Ex_Pass_Back;
	if _exc.errorCode = MethodWrong  then
		if _exc.resumable then
			returnVal := Ex_Resume_Next;
		endif;
	endif;

	return returnVal;

end;</source>
        <Parameter name="_exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="isHorizontal" id="973a4137-120b-42ed-be7d-d4d03a1fd9d6">
        <source>isHorizontal(_alignedBottom: Boolean io) : Boolean;
/*

Purpose:			


Return Value:		


Date		Who		Reason
14 December 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if  self.myScrollableFrame.myHLabels = self then
		_alignedBottom:=myScrollableFrame.hLabelsAlignBottom;
		return true;
	endif;
	return false;


epilog

end;</source>
        <Parameter name="_alignedBottom" type="Boolean" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isVertical" id="56ff4474-02b4-4aff-8817-fc76c19cb72b">
        <source>isVertical(_alignedLeft : Boolean io) : Boolean;
/*

Purpose:			


Return Value:		


Date		Who		Reason
14 December 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if  self.myScrollableFrame.myVLabels = self then
		_alignedLeft:=myScrollableFrame.vLabelsAlignLeft;
		return true;
	endif;
	return false;


epilog

end;</source>
        <Parameter name="_alignedLeft" type="Boolean" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="mouseDown" id="ae706a7e-c549-4fac-ae05-2105b8d80db3">
        <updating/>
        <source>mouseDown(frame: CMUI_ScrollableLabelsFrame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     12 February 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.origX := x.Integer;
	self.origY := y.Integer;
	self.origShift := shift;
	self.origButton := button;

	if self.mySDF &lt;&gt; null then
		self.mySDF.handleLabelFrameMouseDown(frame, button, shift, x, y);
	endif;
	if self.myScrollableFrame &lt;&gt; null then
		if self.myScrollableFrame.myScrollingFrame &lt;&gt; null then
			if app.isDragging then
			else
				self.myScrollableFrame.myScrollingFrame.handleLabelFrameMouseDown(frame, button, shift, x, y);
			endif;
		endif;
	endif;

end;</source>
        <Parameter name="frame" type="CMUI_ScrollableLabelsFrame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseMove" id="05c1bd23-385d-4d85-a19d-cbdfb3383c57">
        <updating/>
        <source>mouseMove(frame: CMUI_ScrollableLabelsFrame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(frame, button, shift, x, y);
	
	if self.mySDF &lt;&gt; null then
		return;
	endif;
	
	// new control only
	if self.myScrollableFrame &lt;&gt; null then
		if self.myScrollableFrame.myScrollingFrame &lt;&gt; null then
			self.myScrollableFrame.myScrollingFrame.handleLabelFrameMouseMove(frame, button, shift, x, y);
		endif;
	endif;
	
end;</source>
        <Parameter name="frame" type="CMUI_ScrollableLabelsFrame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseUp" id="eccc957d-4ed9-4f2b-896e-fe8b6c35deda">
        <controlMethod name="Frame::mouseUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>mouseUp(frame: CMUI_ScrollableLabelsFrame input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin

	inheritMethod(frame, button, shift, x, y);
	
	self.doFrameMouseUp(frame, button, shift, x,y);
	
epilog
	app.isDragging := false;
end;</source>
        <Parameter name="frame" type="CMUI_ScrollableLabelsFrame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="repositionAfterResize" id="2b6e0130-6ade-49d9-8540-fc567010dafe">
        <updating/>
        <source>repositionAfterResize() updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
 	newLeft, newTop, newWidth, newHeight,
   	parentWidth,
   	parentHeight	: Real;
	myName : String;
begin
	myName := self.name;
	if self.alignContainer &lt;&gt; self.AlignContainer_None then
		// Jade will take care of the resize
		return;
	endif;

	if self.parent.isKindOf(Form) then
		parentWidth  := self.parent.Form.clientWidth;
		parentHeight := self.parent.Form.clientHeight;
	elseif self.parent.isKindOf(Control) then
		parentWidth  := self.parent.Control.clientWidth;
		parentHeight := self.parent.Control.clientHeight;
	else
		parentWidth  := self.parent.width;
		parentHeight := self.parent.height;
	endif;
	
	newLeft 	:= self.left;
	newTop 		:= self.top;
	newWidth 	:= self.width;
	newHeight 	:= self.height;

	if self.lockRight then
		newLeft := (parentWidth - newWidth - self.distanceFromRight).max(0);
	endif;
	if self.lockBottom then
		newTop := (parentHeight - newHeight - self.distanceFromBottom).max(0);
	endif;
	if self.stretchWidth then
		newWidth := (parentWidth - newLeft - self.distanceFromRight).max(0);
	endif;
	if self.stretchHeight then
		newHeight := (parentHeight - newTop - self.distanceFromBottom).max(0);
	endif;
		
	if newLeft &lt;&gt; self.left or newTop &lt;&gt; self.top or newWidth &lt;&gt; self.width or newHeight &lt;&gt; self.height then
		self.move(newLeft, newTop, newWidth, newHeight);
	endif;

end;</source>
    </JadeMethod>
