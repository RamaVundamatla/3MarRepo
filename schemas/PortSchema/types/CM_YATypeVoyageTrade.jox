<Class name="CM_YATypeVoyageTrade" id="77c3960f-cb09-4d65-8d08-2364ac89bba2">
    <superclass name="CM_YACriteriaType"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="getAllCriteriaValues" id="415a1045-fab4-4d1c-bcc3-c2b80733cad5">
        <source>getAllCriteriaValues(_terminalObj:CM_Terminal; _allCriteriaValues: ObjectSet input; _filter : Integer; _allDependentObjs : CM_ObjectArray);
// --------------------------------------------------------------------------------
// Created:		07 March 2005 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//17 September 2013	cnwmc5	PAR 31255 - allowing dependent objects the criteria is based on.
// --------------------------------------------------------------------------------
begin
	app.myRoot.allTradesByDescription.copy(_allCriteriaValues);
end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_allCriteriaValues" type="ObjectSet" usage="input"/>
        <Parameter name="_filter" type="Integer"/>
        <Parameter name="_allDependentObjs" type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="getDataDisplay" id="f6ca7b4b-ddb6-4ae8-838c-0cd863193e73">
        <source>getDataDisplay(pDataObj : CM_YAData) : String;
//01 August 2008	cnwdw1
begin
	return pDataObj.CM_YADataObjects.getDataDisplay(self);
end;</source>
        <Parameter name="pDataObj" type="CM_YAData"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="f15d31b9-fc53-4062-9b8f-03800d082023">
        <source>getDisplay(dataObj : Object) : String;
//01 August 2008	cnwdw1
begin
	return dataObj.CM_Trade.description;
end;</source>
        <Parameter name="dataObj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getObjects" id="d3f21da5-8a7a-4be0-899f-d291ed0aa0ae">
        <source>getObjects(objects: ObjectLongNameDict input);
//03 August 2008	cnwdw1	
// Return a dict of objects for this criteria type
vars
	trade: CM_Trade;
begin
	foreach trade in app.myRoot.allTradesByDescription do
		objects[trade.getYAIdentifier] := trade;
	endforeach;
end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTypeName" id="86061342-25da-4bf2-839f-e3ce1141be10">
        <source>getTypeName(): String;
// --------------------------------------------------------------------------------
// Created:		16 March 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return "Voyage Trade";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isCMIFDataMatch" id="003c8fb0-4805-4467-9836-9ae32e19adec">
        <source>isCMIFDataMatch(_cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created 12 August 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	return _cmifAutoPlan.isVoyageTrade_Match(_yaData);


end;</source>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStorageDetailMatch" id="f21cfab4-d718-4836-9b3c-2c134cae058d">
        <source>isStorageDetailMatch(_criteria : CM_YACriteria; _ti: CM_TrackedItem; _tiTrx : CM_TITransaction): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2023	navmk20	Task 57998: JADE - Storage Config - YA Criteria Storage Matching

*/

vars
	tradeCode			: CM_Trade;
	yaData				: CM_YAData;
	myVoyageTradeCode 	: String;
begin

	if _tiTrx &lt;&gt; null and _tiTrx.myTrackedItem &lt;&gt; null then 
		myVoyageTradeCode := _tiTrx.myTrackedItem.getMyVoyageTradeCode();
	elseif _ti &lt;&gt; null then
		myVoyageTradeCode := _ti.getMyVoyageTradeCode;
	endif;
	
	if myVoyageTradeCode &lt;&gt; null then
		tradeCode := app.myRoot.allTradesByDescription[myVoyageTradeCode];
	endif;
	
	yaData := _criteria.myYAData;
	
	if yaData.CM_YADataObjects.matchesStorage(tradeCode) then
		return true;
	endif;
	
	if yaData.isKindOf(CM_YADataPattern) and
	   yaData.CM_YADataPattern.pattern = null then
		return true;
	endif;
	
	return false;
end;
</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
