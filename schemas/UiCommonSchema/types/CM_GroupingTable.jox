    <JadeMethod name="setGroupingRow" id="8246671b-0906-42b7-b37c-5425e876cb10">
        <updating/>
        <source>setGroupingRow(_rowName :String; _entTableDef :EntTableDef)updating, protected;
// ---------------------------------------------------------------------------
// Created:     12 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	group	:EntTableRow;
begin
	// need to call this method after ETView has been set
	group := _entTableDef.getEntTableRow (_rowName);
	
	if group &lt;&gt; null then
		self.allGroupingETRows.atPut (1, group); 
	endif;
	
	self.maxSortColumns := self.MaxJadeSortColumns;	// par 2117 - max number for Jade
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_entTableDef" type="EntTableDef"/>
    </JadeMethod>
    <JadeMethod name="setMaxSortColumns" id="1a4b1e6a-5c1e-4b95-8550-fd5223dde818">
        <updating/>
        <source>setMaxSortColumns(_maxSort: Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     15 October 2009 by cnwcs5
// Purpose:     par 21171 - sorting issues
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _maxSort &gt; self.MaxJadeSortColumns then
		self.maxSortColumns := self.MaxJadeSortColumns;
	else
		self.maxSortColumns	:= _maxSort;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_maxSort" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setSortColumnsForMaxNumCols" id="7b30c1bd-da8c-4feb-8452-8639c1c6ea01">
        <updating/>
        <source>setSortColumnsForMaxNumCols() updating;
// ---------------------------------------------------------------------------
// Created:     12 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config/road ops form changes
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	collIndex, sortIndex,
	col,
	numSortCols		: Integer;
	rowName			: String;
	descend			: Boolean;
	entRow			: EntTableRow;
begin
	if not self.hasGroups then
		inheritMethod;
		return;
	endif;
	
	if 	self.disallowColumnSorter then
		return;
	endif;
	
	// number of sort columns - the user ones and those we need for grouping
	numSortCols := self.getNumberOfSortColumns;
	
	if numSortCols &gt; self.MaxJadeSortColumns then	// par 21171
		// we can't have more than the jade max
		numSortCols := self.MaxJadeSortColumns;		// par 21171
	endif;
	
	if numSortCols &gt; (self.maxSortColumns + 2) then
		numSortCols := (self.maxSortColumns + 2);
	endif;

	// using jade sort
	collIndex := 1;
	sortIndex := 1;
	
	if self.hasGroups then
		// add in our grouping colums
		self.addGroupColsToJadeSortOrder;
		// next sort key is number 3
		sortIndex := 3;
	endif;
	
	while sortIndex &lt;= numSortCols do
		if sortIndex &gt; self.MaxJadeSortColumns then	// par 21171
			// Jade can only sort up to 6 columns
			break;
		endif;
					
		rowName := self.allTblDataSortColumns[collIndex];
		descend := self.allTblDataSortDescending[collIndex];
		entRow 	:= self.getEntRowColumnByRowName(rowName, col);

		if entRow &lt;&gt; null then
			// valid row, set sort order					
			self.sortColumn[sortIndex] 	:= col;    
			self.sortAsc[sortIndex] 	:= (not descend);
			self.sortCased[sortIndex]	:= false;
			self.sortType[sortIndex] 	:= self.convertInputTypeToSortType(entRow.inputType);
		endif;
	
		collIndex := collIndex + 1;
		sortIndex := sortIndex + 1;
	endwhile;

	self.resort;

end;</source>
    </JadeMethod>
    <JadeMethod name="setTblDataEntRowsFromView_Grp" id="6ab871c3-e6c6-453c-8ed9-82ce578402e9">
        <updating/>
        <source>setTblDataEntRowsFromView_Grp(_entTableDef : EntTableDef; _viewName: String; _group :String) updating;
// ---------------------------------------------------------------------------
// Created:     12 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	// we just need to set the group first
	self.setGroupingRow (_group, _entTableDef);
	
	self.setTblDataEntRowsFromView (_entTableDef, _viewName);
	
	self.setSortColumns;
epilog

end;</source>
        <Parameter name="_entTableDef" type="EntTableDef"/>
        <Parameter name="_viewName" type="String"/>
        <Parameter name="_group" type="String"/>
    </JadeMethod>
    <JadeMethod name="showColumnOrganiserFrm" id="ed972dd7-8836-4df2-8f9b-73eaade05bcc">
        <updating/>
        <source>showColumnOrganiserFrm(_terminal: CM_Terminal; _additionalRows: EntTableRowArray) updating;
// ---------------------------------------------------------------------------
// Created:     12 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	max	:Integer;
begin
	if self.hasGroups then
		// I only want the userto be able to select one more sort column
		max := self.maxSortColumns;
		
		self.maxSortColumns	:= max - self.NumGroupSortColumns;	// par 21171
		
		inheritMethod(_terminal, _additionalRows);
		
		self.maxSortColumns := max;
	else
		inheritMethod(_terminal, _additionalRows);
	endif;

epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_additionalRows" type="EntTableRowArray"/>
    </JadeMethod>
    <JadeMethod name="updateGroupingValue" id="88bd9aca-db6b-41c7-b4dc-4fdcd4f29c08">
        <updating/>
        <source>updateGroupingValue(_row :Integer; _obj :CM_Object)updating;
// ---------------------------------------------------------------------------
// Created:     13 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	value :String;
begin
	if not self.hasGroups then
		return;
	endif;
	
	value := _obj.getDisplayStringForAttribute (self.getGroupingETRow.name, false);
	
	self.setCellValueByName (self.getGroupingETRow.name, _row, value);
epilog

end;</source>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="updateItemObject" id="e3c54faf-da0b-4f93-87dc-2f5f912934c1">
        <updating/>
        <source>updateItemObject(_object: CM_Object; _colour1: Integer; _colour2: Integer; _passport: CM_Passport): Integer updating;
/*
Date		Who		Reason
25 May 2010	cnwmh5	Initial creation

*/

vars
	needsToResort	: Boolean;
	originalStr		: String;
	updatedStr		: String;
	rowIdx			: Integer;
begin

	// check object in table if not then set to resort else
	// get the sort / grouping values
	self.findObjectInRow(_object, rowIdx);
	
	if rowIdx = 0 then
		needsToResort := true;
	else
		originalStr := self.getSortGroupingCompareValues(rowIdx);
	endif;
	
	// update the table
	rowIdx := inheritMethod(_object, _colour1, _colour2, _passport);
	
	// get the new sort / grouping details
	updatedStr := self.getSortGroupingCompareValues(rowIdx);
		
	// check to see if different. If yes then set resort
	if originalStr &lt;&gt; updatedStr  then
		needsToResort := true;
	endif;

	// set the tag value to say whether needs to resort
	self.tag := needsToResort.String;
	
	return rowIdx;
epilog
	
end;</source>
        <Parameter name="_object" type="CM_Object"/>
        <Parameter name="_colour1" type="Integer"/>
        <Parameter name="_colour2" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
