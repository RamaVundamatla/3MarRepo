    </PrimAttribute>
    <JadeMethod name="buildTagBody" id="0561fe19-c70d-4413-8ba0-ea4fd2c5bf0f">
        <source>buildTagBody(): String protected;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	formElementObj	: CnEcHtmlFormElement;
	htmlString		: String;
	
begin
	htmlString	:=	' METHOD="' &amp; self.formMethod &amp; '"' &amp;
					' ACTION="' &amp; self.formAction &amp; '"';
	
	if self.formEncodeType &lt;&gt; null then
		htmlString	:=	htmlString &amp; 'ENCTYPE="' &amp; self.formEncodeType &amp; '"';
	endif;
	
	if self.formTarget &lt;&gt; null then
		htmlString	:=	htmlString &amp; 'TARGET="' &amp; self.formTarget &amp; '"';
	endif;
	
	htmlString	:=	htmlString &amp; inheritMethod();
	htmlString	:=	htmlString &amp; '&gt;' &amp; CrLf;
	
	foreach formElementObj in self.allInputTags do
		htmlString	:=	htmlString &amp; formElementObj.getHtml();
	endforeach;
	
	return htmlString;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="createCheckBox" id="365b4fc0-6be4-43a6-bdfc-e8862df2210c">
