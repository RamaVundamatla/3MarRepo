        <ReturnType type="Method"/>
    </JadeMethod>
    <JadeMethod name="isRunnableUnitTestMethod" id="697ab4d0-6055-489f-9e41-61ead1cbcd39">
        <source>isRunnableUnitTestMethod() : Boolean;

/*

Purpose:			Return if is a method that the unit test framework can run		

Date				Who		Reason
23 September 2011	cnwmh5	Initial creation

*/
constants
	Capitals				: String = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
vars
	testIsRunnable			: Boolean;
begin
	
	testIsRunnable := false;

	//if (self.name[1:1] = "t" or self.name[1:1] = "i") and Capitals.pos(self.name[2:1], 1) &gt; 0 then
	if self.name[1:1] = "t" and Capitals.pos(self.name[2:1], 1) &gt; 0 then
		testIsRunnable := true;
	endif;

	return testIsRunnable;
					
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTestToBeCounted" id="bfb82e11-ce5e-4255-8017-9cf23a11dc1a">
        <source>isTestToBeCounted() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 September 2012	cnwmc5	Initial creation

*/

constants
	Capitals	: String = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
vars
	countTest	: Boolean;
begin
	countTest := false;

	if (self.name[1:1] = "t" or self.name[1:1] = "i") and Capitals.pos(self.name[2:1], 1) &gt; 0 then
		countTest := true;
	endif;

	return countTest;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
