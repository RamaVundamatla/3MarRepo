    <JadeMethod name="getBillOfLading" id="77c021c6-c477-4db1-bfe3-2cd983aa3a82">
        <source>getBillOfLading() : String;
// 37549 return BOL number
vars

	bolNumber	: String;
	
begin

	if self.myTrackedItem &lt;&gt; null then
		bolNumber  := self.myTrackedItem.billOfLading;
	//elseif self.myBookingRef &lt;&gt; null then
	//	height := self.myBookingRef.height;
	elseif self.myBOL &lt;&gt; null then
		bolNumber := self.myBOL.number;
	//elseif self.myGateReceival &lt;&gt; null then
	//	height := self.myGateReceival.height;
	//elseif self.myGateReceivalByType &lt;&gt; null then
	//	height := self.myGateReceivalByType.height;
	endif;
	
	return bolNumber;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBooking" id="8b9bcb66-7cac-48df-b7ad-ff4c0b3a4920">
        <source>getBooking():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 January 2010	cnwndl1	Initial creation	CCMS MES 1004

*/

vars

	bookingId : String;
	
begin

	if self.myTrackedItem &lt;&gt; null then
		bookingId := self.myTrackedItem.bookingReference;
	elseif self.myBookingRef &lt;&gt; null then
		bookingId := self.myBookingRef.bookingReference;
	elseif self.myBOL &lt;&gt; null then
		bookingId := null;
	elseif self.myGateReceival &lt;&gt; null then
		bookingId := self.myGateReceival.bookingReference;
	elseif self.myGateReceivalByType &lt;&gt; null then	//	10/12/2010 cnwmh5 #26556
		bookingId := self.myGateReceivalByType.myReceivalInfo.myBooking.bookingReference;
	endif;
	
	return app.getErrorString(BookingRef) &amp; "  =  " &amp; bookingId;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
