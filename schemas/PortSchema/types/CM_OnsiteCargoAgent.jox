<Class name="CM_OnsiteCargoAgent" id="9eb6bfde-dab8-4e2d-9e8a-ea2cfb4b9f1b">
    <superclass name="CM_Agent"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
