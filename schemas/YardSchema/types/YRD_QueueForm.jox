        <updating/>
        <source>mnuHideOffMachines_click(menuItem: MenuItem input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 August 2011	#cnwdz2	 27747

*/

vars
	row 			: Integer;
	machine			: CM_Machine;
	hideOffMachines : Boolean;
begin
	if self.mnuHideOffMachines.checked then
		hideOffMachines := false;
	else
		hideOffMachines := true;
	endif;
	
	self.mnuHideOffMachines.checked := hideOffMachines;
	
	foreach row in 1 to self.tblMachines.rows do
		machine := tblMachines.accessRow(row).itemObject.CM_Machine;
		self.showHideLoggedOffMachines(machine, row);
	endforeach;

epilog

end;</source>
