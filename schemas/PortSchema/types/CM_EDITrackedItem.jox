    <JadeMethod name="setPropertyByName" id="b5a72286-1be0-4112-a36b-49670b871dfb">
        <updating/>
        <source>setPropertyByName(_columnName : String; _value : String io)  : Boolean updating;
//
/// 22 Feb 2016	cnwrs1	TFS 3401 fixup EDI Operations update of EDI TIs
//
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 02 Oct 2020  cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
// 23 Feb 2024	navdap1	TFS 62598 EUP | FR - 53824 - Transport Manifest - Shipping Line Code Not Saved in EDI Operations
vars
	aCargoType : CM_CargoType;
	updated : Boolean;
begin
	updated := true;
	if _columnName = ETRow_Action and self.isKindOf(CM_EDICargoGroupAssign) then
		self.CM_EDICargoGroupAssign.messageMode := _value;
	elseif _columnName = CM_EDIPortTI::allTranshipPortCodes.name then //cnwrs1 CCMS 1137 01 July 2010
		self.setTranshipPortCodes(_value);
	elseif _columnName = ETRow_AssignedCargoIds and self.isKindOf(CM_EDICargoGroupNotified) then
		self.CM_EDICargoGroupNotified.setAssignedCargoIdsFromString(_value);
	elseif _columnName = ETRow_ContainerID and self.isKindOf(CM_EDIBookingItemTI) then
		_value := _value.toUpper;
		self.CM_EDIBookingItemTI.cargoId:=_value;
	elseif _columnName = ETRow_CarbonDioxide then 
		if _value.trimBlanks = null then
			_value := NULL_CARBON_DIOXIDE.String;
		endif;
		self.setPropertyValue(_columnName, _value.Decimal);		//07 Apr 2020	NDL	TFS 47958
	elseif _columnName = ETRow_Oxygen then 
		if _value.trimBlanks = null then
			_value := NULL_OXYGEN.String;
		endif;
		self.setPropertyValue(_columnName, _value.Decimal);		//07 Apr 2020	NDL	TFS 47958
	elseif _columnName = ETRow_Humidity then	//03 Apr 2020	NDL	TFS 47958
		if _value.trimBlanks = null then
			_value := NULL_HUMIDITY.String;
		endif;
		self.setPropertyValue(_columnName, _value.Decimal);
	elseif _columnName = ETRow_CargoIds and self.isKindOf(CM_EDICargoGroupAssign) then
		self.CM_EDICargoGroupAssign.setCargoIdsFromString(_value);
	elseif _columnName = ETRow_CargoIds and self.isKindOf(CM_EDIMultiMoveGroup) then
		_value := _value.toUpper;
		self.CM_EDIMultiMoveGroup.setCargoIdsFromString(_value);
	elseif _columnName = ETRow_CargoTypeDescr then
		// attempt to match the edited data to either the cargo type abbreviation or the description.
		aCargoType	:= app.myRoot.getCargoTypeFromAbbrevOrDescr(_value);
		if aCargoType = null then
			// not found - so set the screen value as the incorrect one.
			self.setPropertyValue(ETRow_CargoType, null);
			self.setPropertyValue(ETRow_CargoTypeDescr, _value[1 : CM_CargoType::description.getLengthForString]);
		else
			self.setPropertyValue(ETRow_CargoType, aCargoType.id);
			self.setPropertyValue(ETRow_CargoTypeDescr, aCargoType.description);	// in case abbreviation entered.
		endif;
	elseif _columnName = ETRow_ClientRef1 then								// PAR #33019
		self.CM_EDIBOLHdrTI.setServiceOrderNbr(_value);					// PAR #33019
	elseif _columnName = ETRow_ClientRef2 then								// PAR #33019
		self.CM_EDIBOLHdrTI.setPONbr(_value);								// PAR #33019
	elseif _columnName = ETRow_CooledType then
		self.setCooledType(_value);
	elseif _columnName = ETRow_CreatedTime then //PAR22850 Prevents an attempt to change the date a file was loaded.  Should never allow a change to created time to occur.  cnwsh3 8/3/2010.
	elseif _columnName = ETRow_DischargePorts then
		self.setOptDischargePorts(_value);
	elseif _columnName = ETRow_FullOrMT then  //par 18411
		self.setPropertyValue(_columnName, _value.trimBlanks[1:1]);
	elseif _columnName = ETRow_ImCodes or 
		   _columnName = ETRow_Hazardous or 
		   _columnName = ETRow_Hazards then		// 14/03/2014 cnwmh5 #33648
		self.setImCodes(_value);
	elseif _columnName = ETRow_ImportReleasePIN then 							//cnwgb1 PAR 21881 11.12.2009
		self.setOperatorImportReleasePIN(_value);
	elseif _columnName = ETRow_IsCertifiedWeight then 
		if self.isKindOf(CM_EDIBookingItemTI) then 
			self.CM_EDIBookingItemTI.isVerifiedWeight := _value.asBooleanJMT;
		elseif self.isKindOf(CM_EDILoadListTI) then
			self.CM_EDILoadListTI.isWeightCertified := _value.asBooleanJMT;
		else
			updated := false;
		endif;
	elseif _columnName = ETRow_IsWaterCooled then
		if _value.trimBlanks.toUpper = "YES" then
			self.setCooledType("W");
		else
			self.setCooledType("X");
		endif;
	elseif _columnName = ETRow_LocationId and self.isKindOf(CM_EDICargoGroupNotified) then
		self.CM_EDICargoGroupNotified.defaultLocation := _value;
	elseif (_columnName = ETRow_LocationId or 
		    _columnName = ETRow_StowageId) then
		//must be saved as a 7 digit stowage id (displayed as 6)
		if _value = null or (_value.isInteger and _value.Integer = 0) then
			self.setLocationId("");
		else
			//th2 removed padding of zeros here - this must be done in the subclasses to which it pertains
			self.setLocationId(_value);	
		endif;
	elseif (_columnName = ETRow_NewStowageId) then	//PAR 19333. June 2009
		//must be saved as a 7 digit new stowage id (displayed as 6)
		if _value = null or (_value.isInteger and _value.Integer = 0) then
			self.setNewStowageId("");
		else
			self.setNewStowageId(_value);	
		endif;
	elseif _columnName = ETRow_OutOfGauge then
		if _value.trimBlanks.toUpper = "YES" then
			self.setPropertyValue(_columnName, true);
		else
			self.setPropertyValue(_columnName, false);
		endif;	
	elseif _columnName = ETRow_OverHeight or
		   _columnName = ETRow_OverLengthFront or
		   _columnName = ETRow_OverLengthBack or
		   _columnName = ETRow_OverWidthLeft or
		   _columnName = ETRow_OverWidthRight then
		if _value.trimBlanks = null then
			_value := NULL_INTEGER.String;
		endif;
		self.setPropertyValue(_columnName, _value.Decimal);
	elseif _columnName = ETRow_PackTempC then 
		if _value.trimBlanks = null then
			_value := NULL_TEMPERATURE.String;
		endif;
		self.setPropertyValue(_columnName, _value.Real);	
	elseif _columnName = ETRow_PackTempF then 
		if _value.trimBlanks = null then
			_value :=app.temperatureConversion(true, NULL_TEMPERATURE).String; 
		endif;
		self.setPropertyValue(_columnName, _value.Real);
	elseif _columnName = ETRow_PackTime then 
		if _value.trimBlanks = null then
			_value := NULL_TIME.String;
		endif;
		self.setPropertyValue(_columnName, _value.Time);	
	//17/11/2015 cnwma1 PAR #37167 
	elseif _columnName = ETRow_CargoID and self.isEDIHazDetails then	//18 Nov 2016	NDL	TFS 2843 / 2604 //epr TFS 4139 27/4/17 changed from parent Cargo id	
		_value := _value.toUpper;
		self.CM_EDIHazDetailsTI.setId(_value);
	elseif _columnName = ETRow_SalesOrderNbr then							// PAR #33019
		self.CM_EDICargoTI.setSalesOrderNbr(_value);						// PAR #33019
	elseif _columnName = ETRow_SealNum and self.isKindOf(CM_EDIStopTI) then
		self.CM_EDIStopTI.setTISealNumOperator(_value);
	elseif _columnName = ETRow_Status then
		//allow a change to unprocessed state - only set for CusRes
		if _value.String = "0" then
			self.setStatus(CM_EDIFile.EDI_STATUS_UNPROCESSED);
		endif;
	elseif _columnName = ETRow_Temperature then
		if _value.trimBlanks = null then
			_value := NULL_TEMPERATURE.String;
		endif;
		self.setPropertyValue(_columnName, _value.Real);	
	elseif _columnName = ETRow_TimeAllowedOffPower then 
		if _value.trimBlanks = null then
			_value := NULL_ALLOWABLE_TIME_OFF_POWER.String;
		endif;
		self.setPropertyValue(_columnName, _value.Decimal);	
	elseif _columnName = ETRow_TotalWeight and not (self.isKindOf(CM_EDIStopTI) or self.isKindOf(CM_EDIVGMTI)) then								//+cnwml2 PAR22485
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;self.String&amp;' '&amp;_columnName;
		self.setPropertyValue(ETRow_Weight, _value.Decimal);
	elseif _columnName = ETRow_Vehicle and self.isKindOf(CM_EDIBOLHdrTI) then									// PAR #36797
		self.CM_EDIBOLHdrTI.setVehicle(_value);							// PAR #36797
	elseif _columnName = ETRow_Vent then //par18451 nov 2008 cnwrs1
		if _value.trimBlanks = null then
			_value := NULL_VENTILATION.String;
		endif;
		self.setPropertyValue(_columnName, _value.Decimal);	//par19252 cnwrs1 may 2009
	elseif _columnName = ETRow_WagonSeals then	//13 Mar 2015	NDL	Par 35828
		self.setWagonSeals(_value);
	//cnwmc5 - 4 September 2014 - PAR 34533
	elseif _columnName.isMeasurementType() then
		self.setMeasurementTypeValue(_columnName, _value);
	elseif _columnName = ETRow_ValidOperators and self.isKindOf(CM_EDIVoyageTI) then
		    self.CM_EDIVoyageTI.setValidOperatorsFromString (_value);
	elseif _columnName = ETRow_Stevedore and self.isKindOf(CM_EDIBookingHeaderTI) then		 //02.10.2020 cnwma1 TFS #50112
		self.CM_EDIBookingHeaderTI.stevedore := _value;
	elseif _columnName = ETRow_Stevedore and self.isKindOf(CM_EDIBookingRefTI) then		 //02.10.2020 cnwma1 TFS #50112
		self.CM_EDIBookingRefTI.stevedore := _value;
	elseif _columnName = ETRow_ShippingLineCode then		// TFS 62598
		self.shippingLineCodeForTI := _value;				// TFS 62598
	else
		updated := false;
	endif;
	return updated;
end;</source>
        <Parameter name="_columnName" type="String"/>
        <Parameter name="_value" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setPropertyFromField" id="b7cebff0-53e5-4253-99d5-1da18420f1a7">
        <updating/>
        <source>setPropertyFromField(_fieldName: String; _value: Any; _ediFile : CM_EDIFile; _xlationOperator : CM_Operator) updating;	//ccms 1976 cnwrs1 17 dec 2010
//----------------------------------------------------------------
//	Created:	17 November 2004	by Jason Chapman  (cnwjc2)
// 21 Nov 2022	navma1	ChangeRequest 55424: MTN - Improve the performance of Edi file loading
//----------------------------------------------------------------
vars
	value		: Any;
	prop		: Property;
	propLength	: Integer;
begin

	value 		:= _value;
	prop 		:= self.class.getPropertyInHTree(_fieldName);
	if prop &lt;&gt; null then	//09 Jun 2017	NDL	TFS 4331
		propLength 	:= prop.getLength()-1;	//String property returns value larger than actual by 1 (includes null terminator)
			
		if prop.type = String then
			if (propLength &gt; 0) and (propLength &lt; value.String.length) then
				value := value.String[1:propLength];
			endif;
		endif;
	endif;
	
	//check for fields that should be translated (ports, isoCodes, commodity desc, etc)
	self.setEDITIProperty(_fieldName, _value, _ediFile, null, _xlationOperator,null);	//cnwrs1 15 dec 2010 ccms 1976		//21.11.2022 navma1 #55424
end;</source>
        <Parameter name="_fieldName" type="String"/>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_ediFile" type="CM_EDIFile"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
    </JadeMethod>
