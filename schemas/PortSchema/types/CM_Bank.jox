    <JadeMethod name="getPeriodEndDate" id="b7317709-dcac-4249-b23b-b50cf14cdaa9">
        <source>getPeriodEndDate(_anFPE : CM_FinancialPeriodEnd; _date : TimeStamp; _greaterThan : Boolean) : TimeStamp;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	anFPE : CM_FinancialPeriodEnd;
	anFPDT : CM_FinancialPeriodDateTime;
	aFPETS : TimeStamp;
begin
	anFPE := _anFPE;
	if anFPE = null then
		anFPE := app.myRoot.myRootCompany.getDefaultFPE();
	endif;
	
	if anFPE = null then
		app.raiseCMException2(ERR_INVALID_VALUE,"Financial Period","You have no default financial periods setup!",null,null);
		return null;
	endif;	

	if _greaterThan then
		foreach 	anFPDT in anFPE.allFinancialPeriodEndDates do
		// is it within our date range?
			if anFPDT.dateTime &gt; _date then
				aFPETS := anFPDT.dateTime;
				break;
			endif;
		endforeach;
	else
		foreach 	anFPDT in anFPE.allFinancialPeriodEndDates reversed do
		// is it within our date range?
			if anFPDT.dateTime &lt;= _date then
				aFPETS := anFPDT.dateTime;
				break;
			endif;
		endforeach;
	
	endif;

	return aFPETS;
end;</source>
        <Parameter name="_anFPE" type="CM_FinancialPeriodEnd"/>
        <Parameter name="_date" type="TimeStamp"/>
        <Parameter name="_greaterThan" type="Boolean"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getPeriodEndDateDebtor" id="646e4e99-c488-4e82-8a05-a569d50818ec">
        <source>getPeriodEndDateDebtor(_debtor : CM_Debtor; _date : TimeStamp; _greaterThan : Boolean) : TimeStamp;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	anFPE : CM_FinancialPeriodEnd;
	anFPDT : CM_FinancialPeriodDateTime;
	aFPETS : TimeStamp;
begin
	anFPE := _debtor.myFinancialPeriodEnd;

	return self.getPeriodEndDate(anFPE,_date,_greaterThan);
end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_date" type="TimeStamp"/>
        <Parameter name="_greaterThan" type="Boolean"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getPeriodEndDateInitialise" id="35443807-949c-4a44-8bf4-7ec22409579c">
        <source>getPeriodEndDateInitialise(_debtor : CM_Debtor; _invoiceType : CM_InvoiceDesc; _date : TimeStamp; _greaterThan : Boolean) : TimeStamp;
// ---------------------------------------------------------------------------
// Created:		June 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//	23510	debtor billing period, debtor parameter and allInvoiceDescDebtorMappings look up added
// ---------------------------------------------------------------------------

vars
	anFPE : CM_FinancialPeriodEnd;
	map	: CM_DebtorBankInvTypeDtl;
	ts : TimeStamp;	//14 Oct 2019	NDL	TFS 46956
	tsInterval : TimeStampInterval;		//14 Oct 2019	NDL	TFS 46956
begin
	map := self.allDebtorBankInvTypeDtls[_debtor, _invoiceType];
	if map &lt;&gt; null then
		anFPE := map.myFinancialPeriodEnd;
	// ### TFS 54565 (54384) 06Oct2022 NAVPW1
	elseif _invoiceType.hasDebtorSeparationAccrual(_debtor) then
		anFPE := _invoiceType.getDebtorSeparationAccrual(_debtor);
	else
		anFPE := _invoiceType.myFinancialPeriodEnd;
	endif;

//	return self.getPeriodEndDate(anFPE,_date,_greaterThan);
	
	//14 Oct 2019	NDL	TFS 46956
	ts := self.getPeriodEndDate(anFPE,_date,_greaterThan);
	if _greaterThan then
		tsInterval.set(0,1); // i.e. one millisecond
		ts := ts - tsInterval; // to make teh time one millisecond earlier.
	endif;
	
	return ts;

end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_invoiceType" type="CM_InvoiceDesc"/>
        <Parameter name="_date" type="TimeStamp"/>
        <Parameter name="_greaterThan" type="Boolean"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getPeriodEndDates" id="38af6714-12f3-4ece-bdf0-a2b0d65cd9e6">
        <source>getPeriodEndDates(_debtor : CM_Debtor; _dateFrom, _dateTo : TimeStamp; _arrDateTimes: TimeStampArray input) ;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	anFPE : CM_FinancialPeriodEnd;
	anFPDT : CM_FinancialPeriodDateTime;
	aFPETS : TimeStamp;
begin
	if _debtor &lt;&gt; null then
		anFPE := _debtor.myFinancialPeriodEnd;
	endif;
	if anFPE = null then
		anFPE := app.myRoot.myRootCompany.getDefaultFPE();
	endif;

	if anFPE = null then
		app.raiseCMException2(ERR_INVALID_VALUE,"Financial Period","You have no default financial periods setup!",null,null);
	endif;	

	foreach 	anFPDT in anFPE.allFinancialPeriodEndDates do
	// is it within our date range?
		if anFPDT.dateTime &gt;= _dateFrom 
		and anFPDT.dateTime &lt;= _dateTo then
			_arrDateTimes.add(anFPDT.dateTime);
		endif;
	endforeach;

end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_dateFrom" type="TimeStamp"/>
        <Parameter name="_dateTo" type="TimeStamp"/>
        <Parameter name="_arrDateTimes" type="TimeStampArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getQuantityRangeForTransaction" id="6ce2abb4-e1a6-47cd-a102-893e0469fb75">
        <source>getQuantityRangeForTransaction( _transaction : CM_TITransaction ) : CM_QuantityRangeMap;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 April 2019	jlgndl1	Initial creation	TFS 43405

*/

vars

	aSBController : CMIF_ServiceBroker;
	qm : CM_QuantityMap;
	
begin
	if _transaction = null then
		return null;
	endif;

	create aSBController transient;
	aSBController.myTransaction := _transaction;
	
	self.getInvoiceLineDescForXaction(aSBController);

	//11 Apr 2019	NDL	TFS 43405
	if aSBController.myServiceBroker &lt;&gt; null then
		qm := aSBController.myServiceBroker.myChildQuantityMap;
		if qm &lt;&gt; null and not qm.allQuantityRanges.isEmpty then
			return qm.allQuantityRanges.first;
		endif;
	endif;
	
	return null;
	
epilog
	delete aSBController;



end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <ReturnType type="CM_QuantityRangeMap"/>
    </JadeMethod>
    <JadeMethod name="getRemittanceAddressString" id="0c9c18b5-53e8-40ac-b72e-51a56a5c7de8">
        <source>getRemittanceAddressString() : String;
// ---------------------------------------------------------------------------
// Created:		September 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aStr : String;
	idx, endIdx : Integer;
begin
	if self.physicalAddress = null then
		return null;
	endif;
	if self.physicalAddress.isEmpty then
		return null;
	endif;
	
	endIdx := self.physicalAddress.size;
	foreach idx in 1 to endIdx do
		aStr := aStr &amp; self.physicalAddress[idx] &amp; CrLf;
	endforeach;
	
	return aStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRootDebtorGroup" id="a3f1e36a-43ca-4655-b193-e2f94f5e19f7">
        <updating/>
        <source>getRootDebtorGroup() : CM_RootDebtorGroup updating;
// ---------------------------------------------------------------------------
// Created:		10 July 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
begin
	// create the root Debtor Object
//	if not global.isValidObject(self.rootDebtorGroup) then
	if self.rootDebtorGroup = null then
		create self.rootDebtorGroup;
		self.rootDebtorGroup.bank := self;
		self.rootDebtorGroup.name := "RDG";
		self.rootDebtorGroup.remarks := "Root Debtor Group for the Company." &amp; CrLf &amp; CrLf &amp; "The Root Debtor Group was created and is owned by the Company.";
		self.rootDebtorGroup.setGroup(null);
	endif;

	return self.rootDebtorGroup;
end;</source>
        <ReturnType type="CM_RootDebtorGroup"/>
    </JadeMethod>
