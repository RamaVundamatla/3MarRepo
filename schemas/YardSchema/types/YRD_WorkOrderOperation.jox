    <JadeMethod name="validateRBTAllocated" id="22620a2f-1e2c-4e07-ae37-52e85d62274c">
        <source>validateRBTAllocated(_job : CM_Job);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Mar 2025	navhl20 CR MTN-34425: MTN - Removing unnecessary codes from Work Order Operation screen methods.

*/

vars
	oldJobSheet	: CM_WorkPointJobSheet;
	job			: CM_Job;
	voyJob		: CM_VoyageWorkPointJob;
	allVoyJobs	: CM_JobArray;
begin
	if _job.isRBTAllocated() and _job.isKindOf(CM_WOReleaseCargoJob) then
		allVoyJobs := _job.getAllVoyJobs();
		if allVoyJobs.isNotEmpty then
			voyJob := allVoyJobs.first.CM_VoyageWorkPointJob;
		endif;
		if voyJob &lt;&gt; null then
			oldJobSheet := voyJob.myJobSheetForWorkPoint;
		endif;
		app.raiseCMException2(Already_assigned_gang,job.id,oldJobSheet.externalName,null,self);
	endif;
epilog

end;</source>
        <Parameter name="_job" type="CM_Job"/>
    </JadeMethod>
</GUIClass>
