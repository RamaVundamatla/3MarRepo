    <JadeMethod name="addRowToTable" id="81b14919-2711-4772-a0b0-4439a786b7e3">
        <source>addRowToTable(_workOrder 		: CM_WorkOrder;
			  _tbl 	     		: CM_DataTable io;
			  _voyWoToInclude, 
			  _cargoWoToInclude,
			  _toDoWoToInclude  : IntegerArray) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 Aug 2009	cnwmd1	Initial creation
16 Aug 2022	navcs2	Bug 54237: MTN - Work Order Maintenance - Lookup Work Order Type
15 dec 2022 navcs2  ChangeRequest 54698:[54264] EUP - [Framework] - Enable VAS Work Order in Work Order Enquiry Screen
16 Dec 2022 navma1	Bug 54234: MTN - Work Order Maintenance - Work Order tasks are duplicated when adding a todo task to the Receive Cargo
*/

vars
	theDataLine      : String;
	workOrderDtl     : CM_WorkOrderDtl;
	taskType		 : Integer; 
begin
	if _workOrder.archived = true and self.chkInclArchived.value = false then
		return;
	endif;
	
	if self.isEnqType_WorkOrder then
		
		//23/06/2025	navkc1 JIRA MTN 34973
		if not _tbl.isPaginated() then
			theDataLine := _workOrder.getAttributeStringForDefArray(_tbl.allTblDataEntRows);
		endif;
		
		_tbl.addItemObject(_workOrder, theDataLine);  //23/06/2025	navkc1 JIRA MTN 34973
		//_tbl.accessRow(_tbl.addItem(theDataLine)).itemObject := _workOrder;
		//self.doNotableAdd(_workOrder); //23/06/2025	navkc1 JIRA MTN 34973 - handled in _tbl.addItemObject;
	elseif self.isEnqType_Task then
		
		foreach workOrderDtl in _workOrder.allWoDtls do
			/*
			16/08/2022 navcs2 #54237
			*/
			taskType   := workOrderDtl.getWorkOrderTaskIdByClass();	
			
			if workOrderDtl.isKindOf(CM_WorkOrderVoyageDtl) then
				if not _voyWoToInclude.includes(taskType) then
					continue;
				endif;
			elseif workOrderDtl.isKindOf(CM_WorkOrderToDoDtl) then									//#54698:[54264]
				if not _toDoWoToInclude.includes(taskType) then
					continue;
				endif;
			else
				if not _cargoWoToInclude.includes(taskType) then
					continue;
				endif;
			endif;
			
			//23/06/2025	navkc1 JIRA MTN 34973
			if not _tbl.isPaginated() then
				theDataLine := workOrderDtl.getAttributeStringForDefArray(_tbl.allTblDataEntRows);
			endif;
			_tbl.removeItemObject(workOrderDtl);													//16.12.2022 navma1 #54234
			
			_tbl.addItemObject(workOrderDtl, theDataLine); //23/06/2025	navkc1 JIRA MTN 34973
			//_tbl.accessRow(_tbl.addItem(theDataLine)).itemObject := workOrderDtl;
			//self.doNotableAdd(workOrderDtl); //23/06/2025	navkc1 JIRA MTN 34973 - handled in _tbl.addItemObject;
		endforeach;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_workOrder" type="CM_WorkOrder"/>
        <Parameter name="_tbl" type="CM_DataTable" usage="io"/>
        <Parameter name="_voyWoToInclude" type="IntegerArray"/>
        <Parameter name="_cargoWoToInclude" type="IntegerArray"/>
        <Parameter name="_toDoWoToInclude" type="IntegerArray"/>
    </JadeMethod>
    <JadeMethod name="addRowToTableForTask" id="5b4a0e54-4cf0-4fc1-8a00-e8bc7d757b24">
        <source>addRowToTableForTask(_workOrderDtl 		: CM_WorkOrderDtl;
					_tbl 	     		: CM_DataTable io) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2024	navlc30	Initial creation
28 May 2024 navlc30 ChangeRequest 64321: MTN - Multithreading For Work Order Enquiry and Work Order Operation Screen
*/

vars
	theDataLine      : String;
begin

	//23/06/2025	navkc1 JIRA MTN 34973
	if not _tbl.isPaginated() then
		theDataLine := _workOrderDtl.getAttributeStringForDefArray(_tbl.allTblDataEntRows);
	endif;
	_tbl.removeItemObject(_workOrderDtl);													//16.12.2022 navma1 #54234
	
	_tbl.addItemObject(_workOrderDtl, theDataLine);  //23/06/2025	navkc1 JIRA MTN 34973
	//_tbl.accessRow(_tbl.addItem(theDataLine)).itemObject := _workOrderDtl;
	//self.doNotableAdd(_workOrderDtl); //23/06/2025	navkc1 JIRA MTN 34973 - handled in _tbl.addItemObject;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_workOrderDtl" type="CM_WorkOrderDtl"/>
        <Parameter name="_tbl" type="CM_DataTable" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="f2de0ce6-e7e5-4aa4-877a-f93ed2e6bca3">
        <updating/>
        <source>addToolbarControls() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		 Reason
24/07/2009	cnwmd1	 Initial creation
17/05/2018	jlgdap1  TFS 38560 PEL1 Voyage Work Orders
24/09/2021	jlizm1	 TFS 51963 SAL Voyage Request Changes
14/07/2022	navcs2	 ChangeRequest 53932: MTN - Jobs Changes
03 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
07/12/2022	navcs2	 ChangeRequest 54698:[54264] EUP - [Framework] - Enable VAS Work Order in Work Order Enquiry Screen
28/02/2023  navma1	 ChangeRequest 56006:[56007] EUP - [Framework] - New VAS Workorder Subscription
24 Mar 2023 navhl20  ChangeRequest 57315:[57316] EUP - [Framework] - Allow Text filtering on the work order screen
05 May 2023 navma1  ChangeRequest 57878: EUP - Delivery Dispatch – Screen Design
*/

vars
	frm 		  : CMUI_Toolbar;		
	leftAlignment : Integer;
	
begin
	
	leftAlignment	:= CMUI_Toolbar.Control_Alignment_Left;
	frm 		    := self.frmToolbar;
	
	//07/05/2025	navkc1 JIRA MTN-34592
	frm.addButton(self.btnNotifications, CMUI_Toolbar.Control_Alignment_Right);
	self.btnNotifications.visible := true;
	
	inheritMethod();
	
	frm.addButton(self.btnShowSearcher, leftAlignment);
	frm.addButton(self.btnPrint, 		leftAlignment);
	frm.addButton(self.btnExportCSVQE,  leftAlignment);
	
	frm.addSeperator(leftAlignment);
	frm.addButton(self.btnNewCargoWO, leftAlignment);
	frm.addButton(self.btnNewVoyWO,   leftAlignment);			// TFS 38560
	
	if self.hasVasSubscription then								//28.02.2023 navma1 #56006:[56007]
		frm.addButton(self.btnNewToDoWO, leftAlignment);
	endif;
	
	frm.addButton(self.btnEditItem, leftAlignment);
	frm.addButton(self.btnDelete, leftAlignment);
	
	//15 Jun 2018	NDL	TFS 39167
	frm.addSeperator(leftAlignment);
	frm.addButton(self.btnOOWConfirm, leftAlignment);
	
	// TFS 51963
	if app.myCurrentUserCan(self.myTerminal, PmFileAttachView)  or  
	   app.myCurrentUserCan(self.myTerminal, PmFileAttachMaint) then
		frm.addButton(self.btnAttachments, leftAlignment);
	endif;
	
	frm.addSeperator(leftAlignment);							//03.10.2022 navtnr20 #54967
	frm.addButton(self.btnInstruction, leftAlignment);			//03.10.2022 navtnr20 #54967
	
	if self.hasVasSubscription then								//05.05.2023 navma1 #57878
		frm.addSeperator(leftAlignment);
		frm.addButton(self.btnWorkOrderOperation,leftAlignment);
	
	endif;
	
	frm.addSeperator(leftAlignment);
	self.frmEnqOptions.borderStyle := Frame.BorderStyle_None;
	frm.addFrame(self.frmEnqOptions, leftAlignment);

/*	//05/06/2024	navkc1 CR 63736 Task 63770 - Replaced with new control
	frm.addSeperator(leftAlignment);							//24.3.2023 navhl20	#57315:[57316]
	frm.addFrame(self.frmFilterBox, leftAlignment);				//24.3.2023 navhl20	#57315:[57316]
	frm.addButton(self.btnClearFilter, leftAlignment); 			//24.3.2023 navhl20	#57315:[57316]
*/

	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);					//05/06/2024	navkc1 CR 63736 Task 63770
	frm.addFrame(self.frmTblFilter, CMUI_Toolbar.Control_Alignment_Left); 	//05/06/2024	navkc1 CR 63736 Task 63770
	self.frmTblFilter.visible := true;										//05/06/2024	navkc1 CR 63736 Task 63770
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addToolbarControlsQuery" id="60a87839-27c7-4da2-9aa0-6b3a643304b9">
        <source>addToolbarControlsQuery() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 July 2009	cnwmd1	Initial creation
04 June 2025    navsp1  JIRA-34585 MTN | Work Order Enquiry Query Refactor
*/

vars
	queryToolbar			: CMUI_Toolbar;
begin
	inheritMethod();
	queryToolbar := self.frmQueryToolbar;
	queryToolbar.addButton(self.btnQuery, CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addButton(self.btnResetSearch, CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addButton(self.btnHideSearcher, CMUI_Toolbar.Control_Alignment_Left);
    queryToolbar.addButton(self.btnClearFilterValues, CMUI_Toolbar.Control_Alignment_Left); //JIRA-34585
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnAttachments_click" id="aa35d293-847e-4eae-98ad-c508bacd34ee">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAttachments_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
24 September 2021	jlizm1	Initial creation TFS 51963 SAL Voyage Request Changes
09 March 2022		jlizm1	TFS 52834 SAL file attachments filter by work order

*/

vars

	obj : Object;
	schema : Schema;
	class : Class;
	assistant : Object;

begin

