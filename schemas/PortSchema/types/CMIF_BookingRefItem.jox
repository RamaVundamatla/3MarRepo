    <JadeMethod name="setSpecialStow" id="f137788b-99ed-4842-91e1-5a8f08747814">
        <updating/>
        <source>setSpecialStow( _specStow : CM_SpecialStow; _str : String ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 June 2017	cnwndl1	Initial creation	TFS 4454

*/

vars

	specStow : CM_SpecialStow;

begin

	if _specStow &lt;&gt; null then
		specStow := _specStow;
	elseif _str.trimBlanks &lt;&gt; null then
		specStow := app.myRoot.allSpecialStows.getAtKey( _str.trimBlanks );
	endif;
	
	self.mySpecialStow := specStow;

epilog

end;</source>
        <Parameter name="_specStow" type="CM_SpecialStow"/>
        <Parameter name="_str" type="String"/>
    </JadeMethod>
    <JadeMethod name="setTIHazardsFromEDI" id="be507f39-9374-485c-aa76-8a31d548771a">
        <source>setTIHazardsFromEDI( _allEDITiHazards : ObjectSet );
/*

Purpose:			

Parameters:			

Return Value:		
/* Changes

Date		Name	TFS#			Description
============================================================================
21/11/2016	cnwndl1	TFS 2843 / 2604	Initial creation	
27/05/2019	jlgka1	TFS 43346		LNX - Multiple Hazardous Details with same Hazardous Class.
============================================================================*/

vars	
	obj 	 : Object;
	ediTIHaz : CM_EDIHazDetailsTI;
	tiHaz 	 : CM_TIHazard;
begin

	if _allEDITiHazards &lt;&gt; null and not _allEDITiHazards.isEmpty then
	
		self.allTIHazards.purge;
		
		foreach obj in _allEDITiHazards do
			if obj.isKindOf(CM_EDIHazDetailsTI) then
				ediTIHaz := obj.CM_EDIHazDetailsTI;
				
				create tiHaz transient;
				tiHaz.setPxyFromEDI( ediTIHaz );
				self.allTIHazards.add( tiHaz );
			endif;
		endforeach;
	endif;

epilog

end;</source>
        <Parameter name="_allEDITiHazards" type="ObjectSet"/>
    </JadeMethod>
    <JadeMethod name="setTaskDescsToAddFromEDI" id="8024bc68-8464-4194-b8f7-3c1d751a4540">
        <updating/>
        <source>setTaskDescsToAddFromEDI( _cargoType : Integer; _objArray : ObjectSet input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 October 2016	cnwndl1	Initial creation	TFS 2001 / 2792

*/

vars

	obj : Object;
	ediTI : CM_EDITaskRemarkRelBookTI;
	
	iter : Iterator;
	remark : String;
	str : String;
	
	taskDesc : CM_ToDoTaskDesc;
	selectedTaskDesc : CM_ToDoTaskDesc;
	
	cargoTypeObj : CM_CargoType;

begin

	self.allTaskDescsToAdd.clear;
	self.allTaskRemarkToAdd.clear;
	
	cargoTypeObj := app.myRoot.allCargoTypesById[_cargoType];

	if _objArray &lt;&gt; null then
		iter := app.myRoot.allToDoTaskDescriptions.createIterator;
		foreach obj in _objArray do
			if obj.isKindOf(CM_EDITaskRemarkRelBookTI) then
				ediTI := obj.CM_EDITaskRemarkRelBookTI;
				str := ediTI.taskCode;
				remark := ediTI.toDoRemarks;
				if str = null then
					app.raiseCMException1(ERR_NO_TODO_TASK, "null", ETRow_TaskCode, ediTI);
					continue;
				endif;
				selectedTaskDesc := null;
				if str.isInteger() then
					selectedTaskDesc := app.myRoot.allToDoTaskDescriptions[str.Integer];
				else
					iter.reset();
					while iter.next(taskDesc) do
						if str = taskDesc.shortDescription
						then
							selectedTaskDesc := taskDesc;
							break;
						endif;
					endwhile;
				endif;
				
				if selectedTaskDesc = null then
					app.raiseCMException1(ERR_NO_TODO_TASK, str, ETRow_TaskCode, ediTI);	
					continue;
				endif;
				
				if not selectedTaskDesc.allCargoTypes.includes(cargoTypeObj) then
					app.raiseCMException2(TaskCargoTypeMismatch, str, cargoTypeObj.abbreviation, ETRow_TaskCode, ediTI);	
					continue;
				endif;
				
				self.allTaskDescsToAdd.add(selectedTaskDesc);
				self.allTaskRemarkToAdd.add(remark);
			
			endif;
		endforeach;
	endif;
	
epilog

	delete iter;

end;</source>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_objArray" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setViewName" id="2b5bd737-1b01-4af4-9341-2ebde70a7d87">
        <updating/>
        <source>setViewName(_view : String)updating;
/*
	Created on 14 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	viewName := _view;
end;</source>
        <Parameter name="_view" type="String"/>
    </JadeMethod>
    <JadeMethod name="validate" id="939d1928-f197-46c1-acdc-c781fc42d4ca">
        <updating/>
        <source>validate(_passport : CM_Passport input) updating, protected;
/*

Purpose:			Validate receiver Booking Ref Item

Parameters:			Passport

Return Value:		Passport updated with errors

/****Changes

Date		Name	TFS#			Description
============================================================================
13 Feb 2008 cnwdh1					Initial creation
08/02/2010	cnwcs5	par 22762  		Make sure cargo type/sub cargo type entered and valid
									(temporary till this area gets fixed up)
11/05/2010	cnwrl1	PAR 24007  		Above code was assumming that a product subtype would be found!
06 Dec 2011	cnwkpd1	PAR #28803  	EDI Train Consist errors
									Add validation of ISO Type and ISO Group - if these are not null, then they must be valid
16/09/2104	cnwdap1	PAR #33944 		Include maximum weight validation
06/10/2016	cnwdap1	TFS 2650 		Validate the stops and to do tasks to be applied
04/07/2018  jlgrh7 	TFS #39128 		ADP - FW: DL for Rotation 1801002901 in production
23/07/2018	jlgrh7 	TFS #39437  	POL - Re: Ticket 39226: [Fwd: ##RE-8122## : Bookings in terminal SGI not loading]
09/01/2019	jlgka1	42811			Use operator display fahrenheit to display 
									temperature warning message.
27 Jul 2022	navsj20	TFS 53862		EUP - WMS - Damage Recording Extra Details
============================================================================*/
	
vars
	product				: CM_Product;
	tmpCommodity 		: CM_Commodity;
	invalid				: Boolean;
	tempStr				: String;
	tmpISOType			: CM_ISOType;
	tmpISOGroup			: CM_ISOTypeGroup;
	validateWeight		: Boolean;						// PAR #33944
	maxWeight			: Integer;						// PAR #33944
	measureType			: CM_MeasurementType;			// PAR #33944
	weightStr			: String;						// PAR #33944
	terminal			: CM_Terminal;					// PAR #33944
	tempCheck			: Boolean;						// PAR #33944
	stop				: CM_StopsTable;				// TFS 2650
	task				: CM_ToDoTaskDesc;				// TFS 2650
	operator			: CM_Operator; 					// jlgka1 TFS 42811
	displayFahrenheit	: Boolean;	   					// jlgka1 TFS 42811	
	criteria 			: CM_YACriteria;				//27 Jul 2022	navsj20	TFS 53862
begin
	terminal := app.getMyTerminalDO_NOT_USE();

	// par 22762 - start
	if self.cargoType = null then	
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'No cargo type ');	
	endif;
	
	if self.myCargoType = null then	
		app.raiseUnexpectedProgramError (self.class.name, method.name, self.cargoType. String &amp; ' is not a valid cargo type ');	
	endif;	
	
	if self.myCargoType.isSubCargoTypeRequired then
		product := self.myProduct;
		
		if product = null then
			app.raiseCMException(Unspecified_product,app.getErrorString(Unspecified_product),null);
//		endif;						// cnwrl1 11/05/2010 PAR 24007 - what it was
		// without the else if the subtype (ie the product) is not supplied the product.code dereference gets an UE 1090
		else
			on Exception do app.handleDeletedObject (exception, product, invalid);
			tempStr := product.code;	// force exception if invalid
			
			if invalid then
				app.raiseUnexpectedProgramError (self.class.name, method.name, 'Invalid sub cargo type ');
			endif;
			
			on Exception do null;
		endif;						// cnwrl1 11/05/2010 PAR 24007
	endif;
	// par 22762 - end
	
	if self.quantity = 0 then
		if myCMIF_BookingRef &lt;&gt; null then
			if myCMIF_BookingRef.myProxyBookingRef &lt;&gt; null and myCMIF_BookingRef.myProxyBookingRef.bookingReference &lt;&gt; null then
				app.raiseCMWarning1 (WARN_GENERIC, 'There is no value entered for the quantity (' &amp; myCMIF_BookingRef.myProxyBookingRef.bookingReference &amp; ')', ETRow_Quantity, null, null);
			else
				app.raiseCMWarning1 (WARN_GENERIC, 'There is no value entered for the quantity.', ETRow_Quantity, null, null);
			endif;
		else
			app.raiseCMWarning1 (WARN_GENERIC, 'There is no value entered for the quantity.', ETRow_Quantity, null, null);
		endif;
	endif;
	
	//  CCMS1654 - Controlled Atmosphere Improvements
	if self.getOxygen &lt;&gt; NULL_OXYGEN or self.getCarbonDioxide &lt;&gt; NULL_CARBON_DIOXIDE then
		tmpCommodity := app.myRoot.allCommodities[self.commodity];
		if tmpCommodity &lt;&gt; null then
			if tmpCommodity.isEmpty then	
				app.raiseCMException2(ERR_Commodity_does_not_require, null, "oxygen or carbon dioxide", ETRow_Oxygen, null);
			endif;
		endif;
	endif;
	
	if self.getOxygen = NULL_OXYGEN then
		if self.isControlledAtmosphere then
//			app.raiseCMException1(REQUIRED_FIELD, 'Oxygen', ETRow_Oxygen, null);
			app.raiseCMException(Input_required_field_oxygen, ETRow_Oxygen, null); // cnwdb2	PAR 35364
			return;
		endif;
	elseif self.getOxygen &lt; 0 or self.getOxygen &gt; 100 then
		app.raiseCMException( ERR_CA_OUT_OF_RANGE, ETRow_Oxygen, null );
	endif;

	if self.getCarbonDioxide = NULL_CARBON_DIOXIDE then
		if self.isControlledAtmosphere then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Carbon Dioxide', ETRow_CarbonDioxide, null);
			app.raiseCMException(Input_required_field_carbDiox, ETRow_CarbonDioxide, null); // cnwdb2	PAR 35364
			return;
		endif;
	elseif self.getCarbonDioxide &lt; 0 or self.getCarbonDioxide &gt; 100 then
		app.raiseCMException( ERR_CA_OUT_OF_RANGE, ETRow_CarbonDioxide, null );
	endif;

	// PAR #28803 - Rework code to allow for additional checked to be added
	// cnwrs1 20 nov 2010 par 26223
	if self.commodity &lt;&gt; null 
	and self.myCargoType &lt;&gt; null and self.myCargoType.isCommodityRequired then		//cnwmc5 - 18 Feb 2016 - PAR 37522
		tmpCommodity := app.myRoot.allCommodities[self.commodity.toUpper()];								//+TFS39128						
		
		if tmpCommodity = null then
			app.raiseCMWarning1(ERR_INVALID_COMMODITY, self.commodity, app.getString(Commodity), self, null); //this line causes unit test tmultiPrenote to fail	//par26681 cnwrs1 29 Decd 2010
        else
			// found one but must also be available to be used.
			if tmpCommodity.isNotAvailableForEntry then
				// The users (in particular CentrePort) want an error not a warning as warning often get missed.
				app.raiseCMWarning1(Commodity_available_entry, self.commodity, app.getString(Commodity), self, null);	//par26681 cnwrs1 29 Decd 2010
			endif;
		
			// Need to make sure the commodity contains the relevant cargo type.
			if tmpCommodity.allCargoTypes[self.cargoType] = null then
				app.raiseCMWarning2(CargoType_NotValid4_Commodity, self.cargoTypeDescr, self.commodity, ETRow_CargoTypeDescr, self, null);	//par26681 cnwrs1 29 Decd 2010
			endif;
		endif;
	endif;
	
	// PAR #28803 - Additional validation for ISO Type and ISO Group
	if self.isoType &lt;&gt; null then
		tmpISOType := app.myRoot.allISOTypes[self.isoType];
		if tmpISOType = null then
			app.raiseCMException2(InvalidSettings, app.getErrorString(ISO_Type), self.isoType, null, self);
		endif;
	endif;

	if self.isoTypeGroup &lt;&gt; null then
		tmpISOGroup := app.myRoot.allISOTypeGroups[self.isoTypeGroup];
		if tmpISOGroup = null then
			app.raiseCMException2(InvalidSettings, app.getErrorString(ISO_Group), self.isoTypeGroup, null, self);
		endif;
	endif;
	
	// PAR #33944 Add temperature checks to bring this in line with CM_BookingRefItem validation
	if terminal.getConfig( ReeferBookingReqsTemp ).Boolean then
		if (tmpCommodity &lt;&gt; null and tmpCommodity.hasTemp) or (tmpISOType &lt;&gt; null and tmpISOType.isReefer) then
		//Has at least one thing indication temp check may be required
			tempCheck := true; // default value
			if (tmpISOType &lt;&gt; null and tmpISOType.isReefer) then
				//its a reefer 
				if (tmpCommodity &lt;&gt; null and not tmpCommodity.hasTemp) then
					// but the commodity inside does not need a temp.
					tempCheck := false;
				endif;
			endif;
			
			if tempCheck then
				if self.temperature = NULL_TEMPERATURE then
					app.raiseCMException(Reefer_type_bookin_requir_temp, null, self);
				else
					if  tmpCommodity &lt;&gt; null and tmpCommodity.hasTemp then
						// jlgka1 TFS 42811 --&gt;
						if myCMIF_BookingRef &lt;&gt; null then	
							if myCMIF_BookingRef.myProxyBookingRef &lt;&gt; null then
								operator := self.myCMIF_BookingRef.myProxyBookingRef.myOperator;
								if operator &lt;&gt; null then
									displayFahrenheit := operator.displayTempFahrenheit;
								endif;
							endif;	
						endif;
						// jlgka1 TFS 42811 &lt;--
						tmpCommodity.validateTemperature(	self.temperature,	//_temperature : Real;
															displayFahrenheit,	//_displayFahreiheit : Boolean;
															null,	//_packTempDetails : CM_PackTempReading;
															null,	//_allowableTimeOffPower : Decimal;
															self.myCargoType.description,	//_idString	: String;
															true,	//_giveErrorTemp : Boolean;
															true,	//_ignoreIfNullTemp : Boolean;
															true,	//_validateHasTemp : Boolean;
															false,	//_validatePackTemp : Boolean;
															false,	//_giveErrorpackTemp : Boolean;
															null	//_ti : CM_TrackedItem
															);
					endif;
					
				endif;
			endif;
			
		endif;
	endif;
	
	if self.weight &lt;&gt; NULL_WEIGHT then
		validateWeight := true;
		maxWeight := terminal.getConfig(MaxLiftWeight).Integer;											//+TFS39437
		if self.quantity &gt; 1 then
			if (self.weight / self.quantity ) &lt; maxWeight then
				validateWeight := false;
			endif;
		endif;
		
		if maxWeight &lt;&gt; NULL_WEIGHT and self.weight &gt; maxWeight and validateWeight then
			measureType := app.getDefaultMeasurementForType(Type_Weight);
			if measureType = null or measureType.isSameAsDatabaseValue then
				weightStr := null;
			else
				weightStr := measureType.getWeightConvertedStrForError(maxWeight.Decimal);
			endif;
			if terminal.getConfig(MaxLiftWeightWarnOnly).Boolean then
				app.raiseCMWarning3(VB_MAX_LIFT_WEIGHT, self.cargoTypeDescr, maxWeight.String, weightStr, ETRow_TotalWeight, null, null);
			else
				app.raiseCMException3(VB_MAX_LIFT_WEIGHT, self.cargoTypeDescr, maxWeight.String, weightStr, ETRow_TotalWeight, null);
			endif;
		endif;
	endif;
	// PAR #33944 end
	
	// TFS 2650 start
	if not self.allStopTablesToAdd.isEmpty then
		foreach stop in self.allStopTablesToAdd do
			//if not stop.allCargoTypesNew.includes(self.myCargoType) then		//20 Jul 2022	navsj20	TFS 53862
			if stop.myStopCriteria &lt;&gt; null  then	//20 Jul 2022	navsj20	TFS 53862
				foreach criteria in stop.myStopCriteria.allCriteria where criteria.myYACriteriaType.type = YACriteriaType_CargoType 
				and not criteria.myYAData.CM_YADataObjects.allObjects.includes(self.myCargoType) do												//27 Jul 2022	navsj20	TFS 53862
					app.raiseCMException2(StopCargoTypeMismatch, stop.code, self.myCargoType.description, ETRow_StopsToApply, null);
				endforeach;				
			endif;	
			if stop.requiresInfo then
				app.raiseCMException1(Stop_not_valid_this_operat, stop.code, ETRow_StopsToApply, null);
			endif;
		endforeach;
	endif;
	if not self.allTaskDescsToAdd.isEmpty then
		foreach task in self.allTaskDescsToAdd do
			if not task.allCargoTypes.includes(self.myCargoType) then
				app.raiseCMException2(TaskCargoTypeMismatch, task.description, self.myCargoType.description, null, null);
			endif;
		endforeach;
	endif;
	// TFS 2650 end
	
end;
</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="5f7fb7e3-0a21-4d69-b4ac-b9c6c3d5c507">
        <updating/>
        <source>validateForCreate(_passport: CM_Passport input): Boolean updating;
/*
	Created on 13 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	self.validate(_passport);
	return true;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="e3081c36-4e34-492e-a668-8f6555e39b1c">
        <updating/>
        <source>validateForUpdate(_passport: CM_Passport input): Boolean updating;
/*
	Created on 14 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	updating := true;
	self.validate(_passport);
	return true;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
