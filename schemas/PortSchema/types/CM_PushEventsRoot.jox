    <JadeMethod name="exportAsXMLDocIgnoreAttr" id="f5643d2a-885c-48ef-8a35-70b6ef3af333">
        <source>exportAsXMLDocIgnoreAttr(_property: Property input): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
24 January 2020		jlgzm1	Initial creation TFS 47920 Event Stream Admin JMT UI

*/

vars

begin
	if _property = CM_PushEventsRoot::configurationDetails then
		return true;
	elseif _property = CM_PushEventsRoot::replayEndTS then
		return true;
	elseif _property = CM_PushEventsRoot::replayStartTS then
		return true;
	elseif _property = CM_PushEventsRoot::replayIdentifier then
		return true;
	else
		return inheritMethod(_property);
	endif;

epilog

end;</source>
        <Parameter name="_property" type="Property" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="exportAsXMLInverseRef" id="e526743b-dfdc-4b8e-afc4-8ffcf811c611">
        <source>exportAsXMLInverseRef(_property: Reference): Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
24 January 2020		jlgzm1	Initial creation TFS 47920 Event Stream Admin JMT UI

*/

vars

begin
	if _property = CM_PushEventsRoot::allEventStreamDefinitions then
		return ExportAsParent;	
	else
		return inheritMethod(_property);
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Reference"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
