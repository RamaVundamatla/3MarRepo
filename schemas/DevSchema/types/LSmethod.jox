    <JadeMethod name="addLiteral" id="e37ec208-ae82-44b1-9d1d-f61a38b95a0a">
        <source>addLiteral(_text : String; _startPosition : Integer);

vars
	lsLiteral : LSliteral;
begin
	create lsLiteral transient;
	lsLiteral.startPosition := _startPosition;
	allLiterals.add(lsLiteral);
end;</source>
        <Parameter name="_text" type="String"/>
        <Parameter name="_startPosition" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="delete" id="3d6a5e8e-0804-4fa4-abbc-287ab7f4a022">
        <updating/>
        <source>delete() updating;

/*

Purpose:		

Date			Who		Reason
16/03/2015		cnwmh5	Initial creation

*/

vars
	
begin
	self.allLiterals.purge();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="findLiterals" id="915ce629-6b5e-4ad0-a8d5-78cc5c73a970">
        <source>findLiterals();

vars
	literals : HugeStringArray;
	startPositions : IntegerArray;
begin
	create literals transient;
	create startPositions transient;
	myMethod.findLiterals(literals, startPositions);
epilog
	delete literals;
	delete startPositions;
end;</source>
    </JadeMethod>
</Class>
