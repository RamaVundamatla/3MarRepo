    <JadeMethod name="shouldAuditProperty" id="0d4dc8cb-242e-46f3-9da4-c408bab8fb03">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 February 2019	jlger1	Initial creation

*/

vars

begin
	if _property = null or
	   _property.name = CM_WodCargoRequest::myTrackedItem.name or
		_property.name = CM_WodCargoRequest::myVoyageCargoRequest.name or
		_property.name = CM_WodCargoRequest::myPermitRequest.name then
		return false;
	else
		
		return inheritMethod(_rootClass, _property);
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="ca81efaf-8ca2-48eb-81c5-65658af488c0">
        <source>validateForCreate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2018	jlgndl1	Initial creation	TFS 38560

*/

vars

begin

	inheritMethod();
	
	self.validateForUpdate();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="5ef62e9a-91d9-4cdf-a11e-73cc8bd51cc6">
        <source>validateForUpdate();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		TFS		Reason
18 May 2018	jlgndl1	38560	Initial creation	
06 Aug 2019	jlgdi1	45704	Added new error message for export and import
*/

vars
	thisPortCode : String;
	
begin
	inheritMethod();
	
	if self.myCargoType = null then
		app.raiseCMException(Input_required_field_cargoType, null, null);
		
	else
		if self.myCargoType.isBulkByVolume then
			if self.totalVolume &lt;= 0 then
				app.raiseCMException(Input_required_field_volume, null, null);
			endif;
			
		elseif self.myCargoType.isBulkByWeight then
			if self.totalWeight &lt;= 0 then
				app.raiseCMException(Input_required_field_weight, null, null);
			endif;
			
		elseif self.myCargoType.isBulkByQuantity then
			if self.totalQuantity &lt;= 0 then
				app.raiseCMException(Input_required_field_quantity, null, null);
			endif;
			
		endif;
		
		if self.myCargoType.isCommodityRequired and self.myCommodity = null then
			app.raiseCMException(Input_required_field_commodity, null, null);
		endif;
		
		if self.myCargoType.isSubCargoTypeRequired and self.myCargoSubType = null then
			app.raiseCMException(Please_select_cargo_subtype, null, null);
		endif;
	
	endif;

	if self.myOperator = null then
		app.raiseCMException(Input_required_field_operator, null, null);
	endif;
	// epr TFS 41310 15/10/18
	//27 Jun 2018	NDL	TFS 39246
	/*if not self.isTransient and self.myVoyageCargoRequest = null then
		if self.permitType = 0 then
			app.raiseCMException(Must_select_permit_type, null, null);
		endif;
	endif;*/
	
	//10 Jul 2018	NDL	- Testing changes TFS 39167
	if imexStatus = 0 then
		app.raiseCMException(Input_required_field_ImexStats, null, null);
	endif;
	if self.numGangs &lt; 1 then
		app.raiseCMException(Number_gangs_must_least, null, null);
	endif;
	if self.transferType &lt; 1 then
		app.raiseCMException(Transfer_type_required, null, null);
	endif;
	
	//12 Nov 2018	NDL - TFS 41907
	if self.dischargePort &lt;&gt; null then
		if self.dischargePort = self.loadPort then
			app.raiseCMException( Load_discha_ports_not_same, null, null );
		endif;
		thisPortCode := self.getMyParent.myTerminal.getConfig(PortDestCode).String;
		if imexStatus = TI_IMEX_STATUS_EXPORT then
			if self.dischargePort = thisPortCode then
				// TFS 45704
				app.raiseCMException2(Dischrg_Port_cant_be_ourselves,
									  self.dischargePort,
									  thisPortCode,
									  null,
									  null);
			endif;
		elseif imexStatus = TI_IMEX_STATUS_IMPORT then
			if self.loadPort = thisPortCode then
				// TFS 45704
				app.raiseCMException2(Load_Port_cant_be_ourselves,
									  self.loadPort,
									  thisPortCode,
									  null,
									  null);
			endif;
		endif;
	endif;
end;</source>
    </JadeMethod>
</Class>
