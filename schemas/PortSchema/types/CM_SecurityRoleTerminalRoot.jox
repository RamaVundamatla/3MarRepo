<Class name="CM_SecurityRoleTerminalRoot" id="ce341ae9-f84c-4f10-9553-131f1d1335b5">
    <superclass name="CM_SecurityRoleTerminal"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <JadeMethod name="addEventType" id="940294c4-2660-46b1-829c-0026b11cd3dc">
        <updating/>
        <source>addEventType( eventType : CM_EventType )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 March 2020	jlgndl1	Initial creation	TFS 48784

*/

vars

begin

	if eventType &lt;&gt; null and eventType.canIncludeInSecurityRole then
		if not self.allEventTypes.includes( eventType ) then
			self.allEventTypes.add( eventType );
		endif; 
	endif;

epilog

end;</source>
        <Parameter name="eventType" type="CM_EventType"/>
    </JadeMethod>
    <JadeMethod name="addToDoTaskToRootRole" id="97bdb735-781b-4941-9570-de348658611e">
        <source>addToDoTaskToRootRole(_todoTask : CM_ToDoTaskDesc);
// ---------------------------------------------------------------------------
// Created:     04 October 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if _todoTask = null then
		return;
	endif;
	
	if (not self.allToDoTasksAddRemove.includes(_todoTask)) then
		self.allToDoTasksAddRemove.add(_todoTask);
	endif;
	if (not self.allToDoTasksComplete.includes(_todoTask)) then
		self.allToDoTasksComplete.add(_todoTask);
	endif;

end;</source>
        <Parameter name="_todoTask" type="CM_ToDoTaskDesc"/>
    </JadeMethod>
