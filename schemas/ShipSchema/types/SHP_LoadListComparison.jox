    <JadeMethod name="setSelected" id="82c2a43b-1182-457c-9e4e-31f48ede6304">
        <source>setSelected();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 July 2022	navkc1	Initial creation	ChangeRequest 53629: PNL-Cargo Comparison - Different fields save on close for Load List and Discharge List.

*/

vars
	association 	: CM_Association; //par 25235 cnwrs1 3 aug 2010
	obj 			: Object;
	str 			: String;
	list 			: ObjectSet;
	voyage			: CM_Voyage;					//navra1 - MTN-33038 - 14th Oct 2024
	listIgnoreFields : StringArray;					//navra1 - MTN-33038 - 14th Oct 2024
	listName : String;								//navra1 - MTN-33038 - 14th Oct 2024
	nameChangedIgnoreFields : StringArray;			//navra1 - MTN-33038 - 14th Oct 2024
	cargoCompareName : String;						//navra1 - MTN-33038 - 14th Oct 2024
begin
	create list transient;
	
	//navra1 - MTN-33038 - 14th Oct 2024
	voyage := app.myCurrentVoyage;
	if voyage &lt;&gt; null and voyage.isAutomaticProcess() and voyage.myTerminal &lt;&gt; null and voyage.myTerminal.myEDIComparisonConfig &lt;&gt; null then
		listIgnoreFields := voyage.myTerminal.myEDIComparisonConfig.ignoreFields;		
		
		if listIgnoreFields &lt;&gt; null then
			create nameChangedIgnoreFields transient;
			foreach listName in listIgnoreFields do
				cargoCompareName := self.getCargoCompareNameFor(listName.toLower());
				if cargoCompareName &lt;&gt; null then
					nameChangedIgnoreFields.add(cargoCompareName);
				endif;
			endforeach;
			foreach obj in self.allIgnoreFieldsObjects do
				association := obj.CM_Association;				
				if nameChangedIgnoreFields.includes(association.asString().toLower()) then
					list.add(association);				
				endif;				
			endforeach;
		endif;
	else																											//navra1 - MTN-33038 - 14th Oct 2024
		foreach obj in self.allIgnoreFieldsObjects do
			association := obj.CM_Association;
			str := "ignore" &amp; association.asString;
			if self.availableXML.cnEcGetTagValueOfName(str).Boolean then
				list.add(association);
			endif;
		endforeach;
	endif;																											//navra1 - MTN-33038 - 14th Oct 2024
	
	self.mulSelectIgnore.setSelected(list);

	list.clear();
	
	foreach obj in self.allUpdateFieldsObjects do
		association := obj.CM_Association;
		str := "update" &amp; association.asString;
		if self.availableXML.cnEcGetTagValueOfName(str).Boolean then
			list.add(association);
		endif;
	endforeach;
	
	self.mulSelectUpdate.setSelected(list);
	
	list.clear();
	
	foreach obj in self.allTranshipFieldsObjects do
		association := obj.CM_Association;
		str := "tranship" &amp; association.asString;
		if self.availableXML.cnEcGetTagValueOfName(str).Boolean then
			list.add(association);
		endif;
	endforeach;
	
	self.mulSelTranship.setSelected(list);
	
epilog
	delete nameChangedIgnoreFields;																					//navra1 - MTN-33038 - 14th Oct 2024
	delete list;
end;</source>
    </JadeMethod>
