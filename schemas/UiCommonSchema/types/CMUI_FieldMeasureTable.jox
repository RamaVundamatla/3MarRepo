    <JadeMethod name="accessColumn" id="d9c9ff5f-1291-4775-85a3-9a74bbac5a7d">
        <updating/>
        <source>accessColumn(_col : Integer) : JadeTableColumn updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/03/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars

begin
	return self.myMeasurementTable.accessColumn(_col);
epilog

end;</source>
        <Parameter name="_col" type="Integer"/>
        <ReturnType type="JadeTableColumn"/>
    </JadeMethod>
    <JadeMethod name="buildSelf" id="9fa4f8e2-386f-48a3-99cd-2ee79f03bb81">
        <updating/>
        <source>buildSelf() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/03/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars
	controlWidth	: Real;
	controlLeft		: Real;
	measureTable	: CMUI_MeasurementTableField;
	
begin
	inheritMethod();
	
	create measureTable transient;
	
	measureTable.parent		:=	self;
	self.form.addControl(measureTable);
	controlLeft				:=	self.myLabel.left + self.myLabel.width + CMUI_FieldFrame.HORIZONTAL_SPACING;
	controlWidth			:=	self.clientWidth() - controlLeft;
	measureTable.move(controlLeft, 0, controlWidth, measureTable.height);
	measureTable.setColumnWidths((controlWidth / 3).Integer, (controlWidth / 3).Integer);
	if not self.parent.isKindOf(Table) then
		measureTable.tabKey := J_key_Tab;
	endif;
	measureTable.selectMode := Table.SelectMode_None;
	
	self.myMeasurementTable	:=	measureTable;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
