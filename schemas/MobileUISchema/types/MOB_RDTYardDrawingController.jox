    <JadeMethod name="bringMaxRowColsIntoView" id="ef0aef56-9cab-4808-a066-e61edd5f510c">
        <updating/>
        <source>bringMaxRowColsIntoView() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 April 2010	cnwjk3	Initial creation

*/

vars

begin
	// if we can fit all columns on the screen then adjust accordingly so that they are all displayed.
	if self.maxGridCol &lt;= numGridColsFit then
		self.leftGridCol := 1;
		self.rightGridCol := self.maxGridCol;
	endif;
	// Same for rows
	if self.maxGridRow &lt;= numGridRowsFit then
		self.topGridRow := 1;
		self.bottomGridRow := self.maxGridRow;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="calcBestZoom" id="c65b9f39-e043-4685-9abd-7c2b084a1bef">
        <updating/>
        <source>calcBestZoom() updating, protected;

/*

Purpose:			
	Calculate the best zoom level, based on the drawing frame's height
Parameters:			

Return Value:		


Date		Who		Reason
10 May 2010	cnwjk3	Initial creation

*/

vars
	height : Integer;
begin
	height := self.myViewportFrame.height.Integer;
	if height &gt;= 210 then
		self.scaleFactor := 2.5;
	elseif height &gt;= 190 then
		self.scaleFactor := 2.25;
	elseif height &gt;= 170 then
		self.scaleFactor := 2;
	elseif height &gt;= 150 then
		self.scaleFactor := 1.75;
	elseif height &gt;= 130 then 
		self.scaleFactor := 1.5;
	else
		self.scaleFactor := 1.25;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="calcCenteredColumnsFlipped" id="088116b4-1a4b-4c87-b116-f6679c6bfdf6">
        <updating/>
        <source>calcCenteredColumnsFlipped() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 May 2010	cnwjk3	Initial creation

*/

vars
	spareSpace,
	lcWidthPixels,
	gridWidthPixels,
	leftSpare,
	rightSpare,
	frameWidth,
	cx 				: Real;
	numColsAvailRight,
	numColsFitLeft,
	numColsFitRight : Integer;
begin
	frameWidth := self.myDrawingFrame.clientWidth();
	gridWidthPixels := self.getGridWidth();
	lcWidthPixels := self.getLCWidth();
	
	cx := frameWidth/2;

	// calculate the right offset
	// New
	self.rightOffset := cx.Integer;
	if self.isLandscape then
		self.rightOffset := self.rightOffset - self.getSizeInPixels(self.lcYGridOffsetFt).Integer;
	else
		self.rightOffset := self.rightOffset - self.getSizeInPixels(self.lcXGridOffsetFt).Integer;
	endif;
	self.rightOffset := (self.rightOffset - lcWidthPixels/2).Integer;
	//
			
	// calculate the number of grid columns that will fit to the left (fully in view)
	leftSpare := frameWidth - (self.rightOffset + gridWidthPixels);
	numColsFitLeft := (leftSpare / gridWidthPixels).Integer;

	// calculate the number of columns that will fit to the right (fully in view)
	rightSpare := self.rightOffset-1;
	numColsFitRight := (rightSpare / gridWidthPixels).Integer;
			
	// calc max number of rows/columns
	self.calcMaxRowsCols();
	

	// Calculate the left col
	self.leftGridCol := self.colLC + numColsFitLeft;
	if self.leftGridCol &gt; self.maxGridCol then
		self.leftGridCol := self.maxGridCol;
	endif;
	
	// calculate the right col
	self.rightGridCol := self.colLC - numColsFitRight;
	if self.rightGridCol &lt; 1 then
		self.rightGridCol := 1;
	endif;

	// Calculate the number of grid cols available to the right of the  highlighted location
	numColsAvailRight := self.colLC - 1;
	if numColsAvailRight &gt; numColsFitRight then
		// Calculate the spare space betwwen the RHS of the frame and the first column that fits fully.
		spareSpace := rightOffset - (numColsFitRight * gridWidthPixels);
		if spareSpace &gt; 0 then
			if self.rightGridCol &gt; 1 then
				// We can display one more grid column, partially, do this by adjusting the hScroll ofset
				self.rightGridCol := self.rightGridCol - 1;
				self.hScrollOffset := (gridWidthPixels - spareSpace).Integer;
				self.rightOffset := 0;
			endif;
		endif;		
	else
		// Adjust for the actual number of columns which fit to the right 
		self.rightOffset := self.rightOffset - ((self.colLC - self.rightGridCol) * gridWidthPixels).Integer;
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="calcCenteredColumnsUnflipped" id="fe54cc84-3e4d-40c4-a72c-702269630f9d">
        <updating/>
        <source>calcCenteredColumnsUnflipped() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 May 2010	cnwjk3	Initial creation

*/

vars
	spareSpace,
	lcWidthPixels,
	gridWidthPixels,
	leftSpare,
	rightSpare,
	frameWidth,
	cx 					: Real;
	numColsAvailLeft,
	numColsFitLeft,
	numColsFitRight 	: Integer;
begin
	frameWidth := self.myDrawingFrame.clientWidth();
	gridWidthPixels := self.getGridWidth();
	lcWidthPixels := self.getLCWidth();
	
	cx := frameWidth/2;
	
	// New  
	// Calculate the left offset
	self.leftOffset := cx.Integer;
	if self.isLandscape then
		self.leftOffset := self.leftOffset - self.getSizeInPixels(self.lcYGridOffsetFt).Integer;
	else
		self.leftOffset := self.leftOffset - self.getSizeInPixels(self.lcXGridOffsetFt).Integer;
	endif;
	self.leftOffset := (self.leftOffset - lcWidthPixels/2).Integer;
	//
	
	// calculate the number of grid columns that will fit to the left (fully in view)
	leftSpare := self.leftOffset-1;	
	numColsFitLeft := (leftSpare / gridWidthPixels).Integer;

	// calculate the number of columns that will fit to the right (fully in view)
	rightSpare := frameWidth - (self.leftOffset + gridWidthPixels);
	numColsFitRight := (rightSpare / gridWidthPixels).Integer;
	
	self.calcMaxRowsCols();
	
	// Calculate the left col
	self.leftGridCol := self.colLC - numColsFitLeft;
	if self.leftGridCol &lt; 1 then
		self.leftGridCol := 1;
	endif;
	
	// calculate the right col
	self.rightGridCol := self.colLC + numColsFitRight;
	if self.rightGridCol &gt; self.maxGridCol then
		self.rightGridCol := self.maxGridCol;
	endif;		
	
	// Calculate the number of grid cols available to the left of the  highlighted location
	numColsAvailLeft := self.colLC - 1;
	if numColsAvailLeft &gt;  numColsFitLeft then
		// Calculate the spare space betwwen the LHS of the frame and the first column that fits fully.
		spareSpace := leftOffset - (numColsFitLeft * gridWidthPixels);
		if spareSpace &gt; 0 then
			if self.leftGridCol &gt; 1 then
				// We can display one more grid column, partially, do this by adjusting the hScroll ofset
				self.leftGridCol := self.leftGridCol - 1;
				self.hScrollOffset := (spareSpace - gridWidthPixels).Integer;
				self.leftOffset := 0;
			endif;
		endif;
	else
		// Adjust for the actual number of columns which fit to the left 
		self.leftOffset := self.leftOffset - ((self.colLC - self.leftGridCol) * gridWidthPixels).Integer;
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="calcCenteredRowsFlipped" id="c4a14f96-3605-4317-abad-3547c6123b20">
        <updating/>
        <source>calcCenteredRowsFlipped() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 May 2010	cnwjk3	Initial creation

*/

vars
	spareSpace,
	lcHeightPixels,
	gridHeightPixels,
	topSpare,
	bottomSpare,
	frameHeight,
	cy 				: Real;
	numRowsAvailBottom,
	numRowsFitTop,
	numRowsFitBottom : Integer;
begin
	frameHeight := self.myDrawingFrame.clientHeight();
	gridHeightPixels := self.getGridHeight();
	lcHeightPixels := self.getLCHeight();
	
	cy := frameHeight/2;

	// calculate the bottom offset
	// New
	self.bottomOffset := cy.Integer;
	if self.isLandscape then
		self.bottomOffset := self.bottomOffset - self.getSizeInPixels(self.lcXGridOffsetFt).Integer;
	else
		self.bottomOffset := self.bottomOffset - self.getSizeInPixels(self.lcYGridOffsetFt).Integer;
	endif;
	self.bottomOffset := (self.bottomOffset - lcHeightPixels/2).Integer;
	//

	// calculate the number of grid rows that will fit to the top (fully in view)
	topSpare := frameHeight - (self.bottomOffset + gridHeightPixels);
	numRowsFitTop := (topSpare / gridHeightPixels).Integer;

	// calculate the number of rows that will fit to the bottom (fully in view)
	bottomSpare := self.bottomOffset-1;
	numRowsFitBottom := (bottomSpare / gridHeightPixels).Integer;
			
	// calc max number of rows/columns
	self.calcMaxRowsCols();

	// Calculate the top row
	self.topGridRow := self.rowLC + numRowsFitTop;
	if self.topGridRow &gt; self.maxGridRow then
		self.topGridRow := self.maxGridRow;
	endif;
	
	// calculate the bottom row
	self.bottomGridRow := self.rowLC - numRowsFitBottom;
	if self.bottomGridRow &lt; 1 then
		self.bottomGridRow := 1;
	endif;

	// Calculate the number of grid rows available to the bottom of the  highlighted location
	numRowsAvailBottom := self.rowLC - 1;
	if numRowsAvailBottom &gt; numRowsFitBottom then
		// Calculate the spare space between the bottom of the frame and the first row that fits fully.
		spareSpace := self.bottomOffset - (numRowsFitBottom * gridHeightPixels);
		if spareSpace &gt; 0 then
			if self.bottomGridRow &gt; 1 then
				// We can display one more grid row, partially, do this by adjusting the vScroll ofset
				self.bottomGridRow := self.bottomGridRow - 1;
				self.vScrollOffset := (gridHeightPixels - spareSpace).Integer;
				self.bottomOffset := 0;
			endif;
		endif;		
	else
		// Adjust for the actual number of rows which fit to the bottom 
		self.bottomOffset := self.bottomOffset - ((self.rowLC - self.bottomGridRow) * gridHeightPixels).Integer;
	endif;			
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="calcCenteredRowsUnflipped" id="a7883309-b0f0-4fb3-a3ec-b95345d798fc">
        <updating/>
        <source>calcCenteredRowsUnflipped() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 May 2010	cnwjk3	Initial creation

*/

vars
	spareSpace,
	lcHeightPixels,
	gridHeightPixels,
	topSpare,
	bottomSpare,
	frameHeight,
	cy 					: Real;
	numRowsAvailTop,
	numRowsFitTop,
	numRowsFitBottom 	: Integer;
begin
	frameHeight := self.myDrawingFrame.clientHeight();
	gridHeightPixels := self.getGridHeight();
	lcHeightPixels := self.getLCHeight();
	
	cy := frameHeight/2;

	// New 
	// calculate the left offset
	self.topOffset := cy.Integer;
	if self.isLandscape then
		self.topOffset := self.topOffset - self.getSizeInPixels(self.lcXGridOffsetFt).Integer;
	else
		self.topOffset := self.topOffset - self.getSizeInPixels(self.lcYGridOffsetFt).Integer;
	endif;
	self.topOffset := (self.topOffset - lcHeightPixels/2).Integer;
	//

	// calculate the number of grid rows that will fit to the top (fully in view)
	topSpare := self.topOffset-1;	
	numRowsFitTop := (topSpare / gridHeightPixels).Integer;

	// calculate the number of rows that will fit to the bottom (fully in view)
	bottomSpare := frameHeight - (self.topOffset + gridHeightPixels);
	numRowsFitBottom := (bottomSpare / gridHeightPixels).Integer;
	
	self.calcMaxRowsCols();

	// Calculate the top row
	self.topGridRow := self.rowLC - numRowsFitTop;
	if self.topGridRow &lt; 1 then
		self.topGridRow := 1;
	endif;
	
	// calculate the bottom row
	self.bottomGridRow := self.rowLC + numRowsFitBottom;
	if self.bottomGridRow &gt; self.maxGridRow then
		self.bottomGridRow := self.maxGridRow;
	endif;		
	
	// Calculate the number of grid rows available to the top of the  highlighted location
	numRowsAvailTop := self.rowLC - 1;
	if numRowsAvailTop &gt;  numRowsFitTop then
		// Calculate the spare space betwwen the top of the frame and the first row that fits fully.
		spareSpace := topOffset - (numRowsFitTop * gridHeightPixels);
		if spareSpace &gt; 0 then
			if self.topGridRow &gt; 1 then
				// We can display one more grid row, partially, do this by adjusting the vScroll ofset
				self.topGridRow := self.topGridRow - 1;
				self.vScrollOffset := (spareSpace - gridHeightPixels).Integer;
				self.topOffset := 0;
			endif;
		endif;
	else
		// Adjust for the actual number of rows which fit to the top 
		self.topOffset := self.topOffset - ((self.rowLC - self.topGridRow) * gridHeightPixels).Integer;
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="calcDrawCols" id="2a7f3375-968b-4fea-b0d6-445417d1be59">
        <updating/>
        <source>calcDrawCols() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 April 2010	cnwjk3	Initial creation

*/

vars

begin
	if self.flipH then
		self.calcGridDrawColsFlipped();
	else
		self.calcGridDrawColsUnflipped();
	endif;
	
	// Keep things in range
	if self.leftGridColDraw &gt; self.maxGridCol then
		self.leftGridColDraw := self.maxGridCol;
	endif;
	
	if self.leftGridColDraw &lt; 1 then
		self.leftGridColDraw := 1;
	endif;

	if self.rightGridColDraw &gt; self.maxGridCol then
		self.rightGridColDraw := self.maxGridCol;
	endif;
	
	if self.rightGridColDraw &lt; 1 then
		self.rightGridColDraw := 1;
	endif;

	if self.leftGridCol &gt; self.maxGridCol then
		self.leftGridCol := self.maxGridCol;
	endif;
	
	if self.leftGridCol &lt; 1 then
		self.leftGridCol := 1;
	endif;

	if self.rightGridCol &gt; self.maxGridCol then
		self.rightGridCol := self.maxGridCol;
	endif;
	
	if self.rightGridCol &lt; 1 then
		self.rightGridCol := 1;
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="calcDrawRows" id="05917436-f607-4ebe-84dd-4f2731d2b1f0">
        <updating/>
        <source>calcDrawRows() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 April 2010	cnwjk3	Initial creation

*/

vars

begin
	if self.flipV then
		self.calcGridDrawRowsFlipped();
	else
		self.calcGridDrawRowsUnflipped();
	endif;
	
	// Keep things in range
	if self.topGridRowDraw &gt; self.maxGridRow then
		self.topGridRowDraw := self.maxGridRow;
	endif;
	
	if self.topGridRowDraw &lt; 1 then
		self.topGridRowDraw := 1;
	endif;

	if self.bottomGridRowDraw &gt; self.maxGridRow then
		self.bottomGridRowDraw := self.maxGridRow;
	endif;
	
	if self.bottomGridRowDraw &lt; 1 then
		self.bottomGridRowDraw := 1;
	endif;

	if self.topGridRow &gt; self.maxGridRow then
		self.topGridRow := self.maxGridRow;
	endif;
	
	if self.topGridRow &lt; 1 then
		self.topGridRow := 1;
	endif;

	if self.bottomGridRow &gt; self.maxGridRow then
		self.bottomGridRow := self.maxGridRow;
	endif;
	
	if self.bottomGridRow &lt; 1 then
		self.bottomGridRow := 1;
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="calcGridDrawColsFlipped" id="d5b4d6e0-3878-4c14-bfa9-9a0aab2af61e">
        <updating/>
        <source>calcGridDrawColsFlipped() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2010	cnwjk3	Initial creation

*/

vars
 
begin
	if self.numGridColsFit &lt; self.maxGridCol and self.leftGridCol &lt; self.maxGridCol then
		self.leftGridColDraw := self.leftGridCol + 1;
	else
		self.leftGridColDraw := self.leftGridCol;
	endif;
	self.rightGridColDraw := self.rightGridCol;
	
	
	self.xDrawOffset := 0;
	if self.hScrollOffset &lt; 0 then
		if self.rightGridColDraw &gt; 1 then  
			self.rightGridColDraw := self.rightGridColDraw -1;
			self.xDrawOffset := (self.hScrollOffset + self.getGridWidth()).Integer;
		endif;
	else
		self.xDrawOffset := self.hScrollOffset;
	endif;
			
	self.numGridColsToDraw := self.leftGridColDraw - self.rightGridColDraw + 1;	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="calcGridDrawColsFlippedOLD" id="e129d8c0-55d5-44c6-a896-5261251277d5">
        <updating/>
        <source>calcGridDrawColsFlippedOLD() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2010	cnwjk3	Initial creation

*/

vars
 
begin
	if self.numGridColsFit &lt; self.maxGridCol  and  self.rightGridCol &gt; 1 then
		//self.rightColDraw := self.rightCol - 1;
		self.rightGridColDraw := self.leftGridCol - self.numGridColsFit;
	else
		self.rightGridColDraw := self.rightGridCol;
	endif;
	self.leftGridColDraw := self.leftGridCol;	
	
	// Adjust for partial scroll, where LHS column should be partially drawn
	self.xDrawOffset := 0;
	if self.hScrollOffset &gt; 0 then
		if self.leftGridColDraw &lt; self.maxGridCol then
			self.leftGridColDraw := self.leftGridColDraw + 1;
			self.xDrawOffset := (self.hScrollOffset - self.getGridWidth()).Integer;
		endif;
	elseif self.hScrollOffset &lt; 0 then
		self.xDrawOffset := self.hScrollOffset;
	endif;

	self.numGridColsToDraw := self.leftGridColDraw - self.rightGridColDraw + 1;	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="calcGridDrawColsUnflipped" id="c130db89-482b-43c2-8041-414b686dda60">
        <updating/>
        <source>calcGridDrawColsUnflipped() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 April 2010	cnwjk3	Initial creation

*/

vars

begin
	// Calculate how many columns we want to draw. This may be 1 more than fits,
	// to allow drawing of items which don't quite fit, rather than leaving a blank space
	// at the right of the viewport
	
	if self.numGridColsFit &lt; self.maxGridCol and self.rightGridCol &lt; self.maxGridCol then
		self.rightGridColDraw := self.rightGridCol + 1;
	else
		self.rightGridColDraw := self.rightGridCol;
	endif;
	self.leftGridColDraw := self.leftGridCol;
	
	// Adjust for partial scroll, where LHS column should be partially drawn
	self.xDrawOffset := 0;
	if self.hScrollOffset &gt; 0 then
		if self.leftGridColDraw &gt; 1 then
			self.leftGridColDraw := self.leftGridColDraw - 1;
			self.xDrawOffset := (self.hScrollOffset - self.getGridWidth()).Integer;
		endif;
	elseif self.hScrollOffset &lt; 0 then
		self.xDrawOffset := self.hScrollOffset;
	endif;
		
	self.numGridColsToDraw := self.rightGridColDraw - self.leftGridColDraw + 1;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="calcGridDrawRowsFlipped" id="132f8656-436b-4862-b863-aebd8d312fbc">
        <updating/>
        <source>calcGridDrawRowsFlipped() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2010	cnwjk3	Initial creation

*/

vars

begin
	if self.numGridRowsFit &lt; self.maxGridRow and self.topGridRow &lt; self.maxGridRow then
		self.topGridRowDraw := self.topGridRow + 1;
	else
		self.topGridRowDraw := self.topGridRow;
	endif;
	self.bottomGridRowDraw := self.bottomGridRow;
	
	
	self.yDrawOffset := 0;
	if self.vScrollOffset &lt; 0 then
		if self.bottomGridRowDraw &gt; 1 then  
			self.bottomGridRowDraw := self.bottomGridRowDraw -1;
			self.yDrawOffset := (self.vScrollOffset + self.getGridHeight()).Integer;
		endif;
	else
		self.yDrawOffset := self.vScrollOffset;
	endif;
			
	self.numGridRowsToDraw := self.topGridRowDraw - self.bottomGridRowDraw + 1;	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="calcGridDrawRowsFlippedOLD" id="33f981d1-f8b5-4164-b7a8-787f58f57b57">
        <updating/>
        <source>calcGridDrawRowsFlippedOLD() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


