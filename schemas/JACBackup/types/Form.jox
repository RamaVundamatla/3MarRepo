<GUIClass name="Form">
    <JadeMethod name="getControlWithName" id="79db985e-cb9a-4340-bdb5-29de34f16059">
        <source>getControlWithName(nam:String):Control;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	i: Integer;
	c: Control;
	up: String;
begin
	up := nam.toUpper;
	foreach i in 1 to controlCount do
		if controls(i).name.toUpper = up then
			return controls(i);
		endif;
	endforeach;
	return null;
end;</source>
        <Parameter name="nam" type="String"/>
        <ReturnType type="Control"/>
    </JadeMethod>
</GUIClass>
