    <JadeMethod name="listTableResouceType" id="47a4505a-b435-4f5b-b0cc-add70ae3adb0">
        <source>listTableResouceType(_listTable : CMUI_ListTable input);
// ---------------------------------------------------------------------------
// Created:     10 February 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	resourceTable :	HMS_ResourceTypeByCodeDict;
	resourceType : HMS_ResourceType;
begin
//	was used for displaying all resourses in  harbour
//	if _harbour = null then 
//		return;
//	endif;
	
	
// Changed to foloowing as dont want not available for entries to be in collection. 
// If the object has one of these assigned they will need to be added seperately. 
	resourceTable := app.myRoot.allResourceTypes;
	
	foreach resourceType in  resourceTable discreteLock do 
		if not resourceType.isNotAvailableForEntry then 
			_listTable.addItemObject(self.displayEntryHMSResourceType(resourceType), resourceType);
		endif;	
	endforeach;
	
//	_listTable.displayCollection(resourceTable, false, Table.DisplayCollection_Forward, null);

end;</source>
