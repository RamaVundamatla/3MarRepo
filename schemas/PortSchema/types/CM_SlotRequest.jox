    <JadeMethod name="isSpecialStow" id="f7c1c2ca-0ef8-4b85-a0de-7a1ebd69ed65">
        <source>isSpecialStow() : Boolean;
// ---------------------------------------------------------------------------
// Created:		11 May 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------




// ANY CHANGES HERE MUST BE MIRRORED IN THE SAME METHOD ON CM_CONTAINER




vars
