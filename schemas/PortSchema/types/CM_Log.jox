    <JadeMethod name="setBOLLocationOID" id="52673887-5fd5-4d69-89ec-451f6d778a5a">
        <updating/>
        <source>setBOLLocationOID(_aLocationController: CM_LocationsController) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 October 2014	cnwrd1	Initial creation

*/

vars

begin
	
	if _aLocationController = null then
		return;
	endif;

	if myReceivalBOL &lt;&gt; null then
		myReceivalBOL.setMyLogControllerOID(_aLocationController );
	endif;

epilog

end;</source>
        <access>protected</access>
