    <JadeMethod name="setProxyForOrderResponse" id="8d5e093b-30b8-42ed-b3f5-ae89324ba174">
        <updating/>
        <source>setProxyForOrderResponse(_sendRecvMessage:String; _webServiceDefinition : CM_ExternalWebServiceDef; _terminal : CM_Terminal; _responseCode : Integer io; _response : String io) updating;			//navra1 - MTN-35875- 5th Sep 2025-1
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 August 2025	navra1	Initial creation for //navra1 - MTN-34782 - 15th July 2025

*/

vars

begin
	self.createdUser := app.getMyUserCode();
	self.created := app.actualTimeServer();
	self.myRoot:=app.myRoot;	
	self.myTerminal := _terminal;
	self.interfaceName := ExternalWebServiceAgGateway;
	self.sendRecvMessage := _sendRecvMessage;
	self.myExtWebserviceDef:=_webServiceDefinition;
	self.description := CM_EWSActivityAgGateway.DIRECTION_SEND &amp; "-" &amp; CM_EWSActivityAgGateway.MESSAGE_TYPE_ORDERRESPONSE;
	self.direction := CM_EWSActivityAgGateway.DIRECTION_SEND;	
	self.messageType := CM_EWSActivityAgGateway.MESSAGE_TYPE_ORDERRESPONSE;
	self.response := _response;													//navra1 - MTN-35875- 5th Sep 2025-1				
	self.responseCode := _responseCode;											//navra1 - MTN-35875- 5th Sep 2025-1
epilog

end;</source>
        <Parameter name="_sendRecvMessage" type="String"/>
        <Parameter name="_webServiceDefinition" type="CM_ExternalWebServiceDef"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_responseCode" type="Integer" usage="io"/>
        <Parameter name="_response" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setProxyForRecvOrderCreateUpd" id="fad720ed-19fa-4a8c-97bb-b43895ad148e">
