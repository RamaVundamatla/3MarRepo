    <JadeMethod name="addBulkReleaseToSummary" id="0f7df406-380b-4b7a-acfc-f021e6eeee57">
        <source>addBulkReleaseToSummary(_release : CM_BulkRelease; _coll: CMIF_LoadListSumByTrainDestISO input);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/11/2010	cnwdap1	Initial creation PAR #23794 CCMS MES 1102
20/07/2018	jlgmd1	TFS #39261 SNO - Show Reserve Detail lines on Load List
*/
vars
	isoGroupingKey	: String;
	destinationPort	: String;
	trainCode		: String;
	sumObj			: CMIF_LoadListSummaryObject;
	mode			: Integer;
	detail			: CM_ReserveDetail;

begin
	
	if _release.myDestinationPort &lt;&gt; null then
		destinationPort := _release.myDestinationPort.code;
	endif;
	if _release.myAssignedTrain = null then
		trainCode := app.getErrorString(Not_Assigned);
	else
		trainCode := _release.myAssignedTrain.code;
	endif;
	
	foreach detail in _release.allReserveDetails discreteLock do
	
		isoGroupingKey :=detail.getPlannerReportGroup();
		sumObj := _coll[trainCode,destinationPort,isoGroupingKey];
		
		if sumObj = null then
			create sumObj transient;
			
			sumObj.train := trainCode;
			sumObj.destinationPort := destinationPort;
			sumObj.isoGroupingKey :=isoGroupingKey;
			sumObj.isoGroupingCode := detail.getPlannerReportGroupDesc();
			
			_coll.add(sumObj);
			mode := CMIF_LoadListSummaryObject.MODE_ADD;
		else
			mode := CMIF_LoadListSummaryObject.MODE_UPDATE;
		endif;
		
		sumObj.totalsForBulkRelease(detail, mode);
	endforeach;
	
epilog

end;</source>
        <Parameter name="_release" type="CM_BulkRelease"/>
        <Parameter name="_coll" type="CMIF_LoadListSumByTrainDestISO" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addTIToSummary" id="d28c5af3-543f-4fa7-a35a-0d813a1bc3f4">
        <source>addTIToSummary(_ti: CM_TrackedItem; _coll: CMIF_LoadListSumByTrainDestISO input);
//----------------------------------------------------------------
//	Created:	14 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	ti				: CM_TrackedItem;
	isoGroupingKey	: String;
	sumObj			: CMIF_LoadListSummaryObject;
	mode			: Integer;
	destinationPort : String;
//	imexStatusDesc : String;
//	imexStatus : Integer;
	trainCode 		: String;
	
begin
	ti := _ti;
	
	isoGroupingKey := ti.getPlannerReportGroup();
	destinationPort := ti.destinationPort;
//	imexStatusDesc := "String";
//	imexStatus := 0;
	if ti.myTrainAssigned = null then
		trainCode := app.getErrorString(Not_Assigned);
	else
		trainCode := ti.myTrainAssigned.code;
//		imexStatusDesc := ti.myTrainAssigned.code;
//		imexStatus := ti.myTrainAssigned.code[3:end].Integer;
	endif;
	
	sumObj := _coll[trainCode,destinationPort,isoGroupingKey];
	
	if sumObj = null then
		create sumObj transient;
		
//		sumObj.extraKey := "All";
		sumObj.train := trainCode;
//		sumObj.imexStatus := imexStatus;
//		sumObj.imexStatusDescription := imexStatusDesc;
		sumObj.destinationPort := destinationPort;
		sumObj.isoGroupingKey :=isoGroupingKey;
		sumObj.isoGroupingCode := ti.getPlannerReportGroupDesc();
		
		_coll.add(sumObj);
		mode := CMIF_LoadListSummaryObject.MODE_ADD;
	else
		mode := CMIF_LoadListSummaryObject.MODE_UPDATE;
	endif;
	
	//epr ccms 1011 19/7/05 just being extra careful
	//if not sumObj.allTrackedItems.includes(ti) then
	if not sumObj.allTrackedItems.includes(ti) then
		sumObj.allTrackedItems.add(ti);	
	else
	//don't update all the totals
		return;
	endif;
	
	sumObj.totalsForTi(ti, mode);
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_coll" type="CMIF_LoadListSumByTrainDestISO" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addWLEToSummary" id="9bfbe090-01c6-4af1-a734-a45264f0b98d">
        <source>addWLEToSummary(_wle : CM_WorkListEntry; _coll: CMIF_LoadListSumByTrainDestISO input);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/10/2010	cnwdap1	Initial creation PAR #23794 CCMS MES 1102 Release requests on rail load list
01/12/2010	cnwdap1	PAR #26477 Refinement of trainCode assignment
*/
vars
	wle				: CM_WorkListEntry;
	isoGroupingKey	: String;
	sumObj			: CMIF_LoadListSummaryObject;
	mode			: Integer;
	destinationPort : String;
	trainCode 		: String;

begin
	wle := _wle;
	
	isoGroupingKey := wle.getPlannerReportGroup;
	if CM_YardDeliveryRequest.hasInstance(wle.myRequest) then
		destinationPort := wle.myRequest.CM_YardDeliveryRequest.myRelease.myDestinationPort.code;
		if wle.myRequest.CM_YardDeliveryRequest.myRelease.CM_BulkRelease.myAssignedTrain = null then
			trainCode := app.getErrorString(Not_Assigned);
		else
			trainCode := wle.myRequest.CM_YardDeliveryRequest.myRelease.CM_BulkRelease.myAssignedTrain.code;
		endif;
	elseif CM_DeliveryRequest.hasInstance(wle.myRequest) then
		if wle.myRequest.CM_DeliveryRequest.myOriginatingBulkRelease &lt;&gt; null and wle.myRequest.CM_DeliveryRequest.myOriginatingBulkRelease.myDestinationPort &lt;&gt; null then
			destinationPort := wle.myRequest.CM_DeliveryRequest.myOriginatingBulkRelease.myDestinationPort.code;
		endif;
		// PAR #26477 range of options for getting train code, based on how this WLE has been assigned to rail
		if wle.myRequest.CM_DeliveryRequest.myJob.CM_RailJob.getMyTrain &lt;&gt; null then
			trainCode := wle.myRequest.CM_DeliveryRequest.myJob.CM_RailJob.getMyTrain().code;
		elseif not wle.CM_YardWLE.allLocationControllers.isEmpty then
			trainCode := wle.CM_YardWLE.allLocationControllers.first.myWagon.myTrainOutwards.code;
		elseif wle.myRequest.CM_DeliveryRequest.myOriginatingBulkRelease &lt;&gt; null then
			if wle.myRequest.CM_DeliveryRequest.myOriginatingBulkRelease.myAssignedTrain &lt;&gt; null then
				trainCode := wle.myRequest.CM_DeliveryRequest.myOriginatingBulkRelease.myAssignedTrain.code;
			endif;
		elseif wle.myRequest.CM_DeliveryRequest.bulkRelease &lt;&gt; null then
			if wle.myRequest.CM_DeliveryRequest.bulkRelease.myAssignedTrain &lt;&gt; null then
				trainCode := wle.myRequest.CM_DeliveryRequest.bulkRelease.myAssignedTrain.code;
			endif;
		endif;
		// PAR #26477 end
	endif;
	
	sumObj := _coll[trainCode,destinationPort,isoGroupingKey];
	
	if sumObj = null then
		create sumObj transient;
		
		sumObj.train := trainCode;
		sumObj.destinationPort := destinationPort;
		sumObj.isoGroupingKey :=isoGroupingKey;
		sumObj.isoGroupingCode := wle.myRequest.CM_DeliveryRequest.getPlannersGroupDesc();
		
		_coll.add(sumObj);
		mode := CMIF_LoadListSummaryObject.MODE_ADD;
	else
		mode := CMIF_LoadListSummaryObject.MODE_UPDATE;
	endif;
	
	if not sumObj.allWorkListEntries.includes(wle) then	
		sumObj.allWorkListEntries.add(wle);
	else
	//don't update all the totals
		return;
	endif;
	
	sumObj.totalsForWle(wle, mode);
epilog

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_coll" type="CMIF_LoadListSumByTrainDestISO" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doFilter" id="338d4fd4-b099-4f1f-b018-926ae1096895">
        <source>doFilter(_ti: CM_TrackedItem): Boolean protected;
//----------------------------------------------------------------
//	Created:	21 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	theDestinationPort		: CM_Port;
begin
	
	if not _ti.isIntendedForReleaseRail() then
		return false;
	endif;

	if _ti.myPrimaryActualLocation &lt;&gt; null and _ti.myPrimaryActualLocation.isWagon() then
		// once the planned cargo is moved to the outward wagon it is no longer planned, so want to ignore it from the non planned list, however include if it is on a different train.
		return false;
	endif;
	if _ti.isOffSite() then // TRAIN has departed, TI has no primaryActualLocation but is nolonger a pre note
		return false;
	endif;
	
	
	

	theDestinationPort := app.myRoot.allPorts[_ti.destinationPort.trimBlanks];
	
	if (self.allCargoTypes.isEmpty or self.allCargoTypes.includes(_ti.myCargoType)) and
	(self.allPortsDischarge.isEmpty or (theDestinationPort &lt;&gt; null and self.allPortsDischarge.includes(theDestinationPort))) and
	(self.allOperators.isEmpty or self.allOperators.includes(_ti.myOperator)) and
	(self.getMyTrain = null or (self.getMyTrain =_ti.myTrainAssigned) or _ti.myTrainAssigned = null)
	then
		return true;
	endif;
	
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doFilterWle" id="39f46915-c6c5-4fac-8178-07d15dee502c">
        <source>doFilterWle(_wle : CM_WorkListEntry) : Boolean protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/10/2010	cnwdap1	Initial creation PAR #23794 CCMS MES 1102
*/
vars
	request 		: CM_Request;
	cargoType		: CM_CargoType;
	destinationPort	: CM_Port;
	train			: CM_Train;
	operator		: CM_Operator;
	
begin
	request		:= _wle.myRequest;
	if not CM_DeliveryRequest.hasInstance(request) then
		return false;
	endif;
	if not CM_RailJob.hasInstance(request.myJob) then
		return false;
	endif;
	if CM_YardDeliveryRequest.hasInstance(request) then
		destinationPort := request.CM_YardDeliveryRequest.myRelease.myDestinationPort;
		train 			:= request.CM_YardDeliveryRequest.myRelease.myAssignedTrain;
	elseif CM_DeliveryRequest.hasInstance(request) then
		if request.CM_DeliveryRequest.myOriginatingBulkRelease &lt;&gt; null and request.CM_DeliveryRequest.myOriginatingBulkRelease.myDestinationPort &lt;&gt; null then
			destinationPort := request.CM_DeliveryRequest.myOriginatingBulkRelease.myDestinationPort;
		endif;
		train			:= request.CM_DeliveryRequest.myJob.CM_RailJob.getMyTrain;
	endif;
	cargoType			:= request.CM_DeliveryRequest.myCargoType;
	operator			:= app.myRoot.allOperators[request.CM_DeliveryRequest.operatorCode];
	
	if (self.allCargoTypes.isEmpty or self.allCargoTypes.includes(cargoType)) and
	(self.allPortsDischarge.isEmpty or (destinationPort &lt;&gt; null and self.allPortsDischarge.includes(destinationPort))) and
	(self.allOperators.isEmpty or (operator &lt;&gt; null and self.allOperators.includes(operator))) and
	(self.getMyTrain = null or (self.getMyTrain = train) or train = null)
	then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="filterObjects" id="014e653a-9689-4b6d-8479-9a56e0e71bb5">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
//----------------------------------------------------------------
//	Created:	14 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	----------------------------------------------------
// 29/10/2010	cnwdap1		PAR #23794 CCMS MES 1102 Show release requests on rail load list
// 01/12/2010	cnwdap1		PAR #26477 expand checking to cater for requests assigned to rail areas after train has arrived
vars
	train				: CM_Train;
	querySelf			: CMQF_TrainLoadListSummary;
	breakOut			: Boolean;
	tmpColl				: CMIF_LoadListSumByTrainDestISO;
	ti					: CM_TrackedItem;
	bulkRelease			: CM_BulkRelease;			// PAR #23794
	deliveryRequest		: CM_Request;				// PAR #23794
	wle					: CM_WorkListEntry;			// PAR #23794
	railJob				: CM_Job;					// PAR #23794
	wagon				: CM_Wagon;					// PAR #23794
	lc					: CM_WagonController;		// PAR #23794
	localWLEArray 		: CM_WLEArray;	//18 July 2016	NDL	TFS 2329
begin
	querySelf := self;
	train := querySelf.getMyTrain;
	
	//18 July 2016	NDL	TFS 2329
	create localWLEArray transient;
	self.allWLEs.copy(localWLEArray);
	localWLEArray.removeInvalidObjects();
	
	//if train = null and allTIs.isEmpty then							// PAR #23794
	//if train = null and allTIs.isEmpty and self.allWLEs.isEmpty then	// PAR #23794
	if train = null and allTIs.isEmpty and localWLEArray.isEmpty then
		return;
	endif;

	tmpColl := _collection.CMIF_LoadListSumByTrainDestISO;
	
	if not allTIs.isEmpty then
		foreach ti in allTIs  discreteLock do
			if querySelf.checkStatusIncludesObject(ti, _passport, breakOut) then
				querySelf.addTIToSummary(ti, tmpColl);
			endif;
		endforeach;
	//	else
	elseif train &lt;&gt; null then
		foreach ti in train.allAssignedTIs  discreteLock do
			if querySelf.checkStatusIncludesObject(ti, _passport, breakOut) then
				querySelf.addTIToSummary(ti, tmpColl);
			endif;
		endforeach;
	endif;
	
	// PAR #23794 read through all bulk releases on the train if config setting is on
//	if app.getMyTerminalDO_NOT_USE.getConfig(ShowRelReqOnRailLoadList).Boolean then

	if showReleaseRequests( train ) then	//08 Dec 2011	NDL	Par 28815
		if not self.allWLEs.isEmpty then
			foreach wle in self.allWLEs discreteLock do
				if querySelf.checkStatusIncludesObject(wle, _passport, breakOut) then
					querySelf.addWLEToSummary(wle, tmpColl);
				endif;
			endforeach;
		else
			if train &lt;&gt; null then
				foreach bulkRelease in train.allBulkReleases discreteLock do
					// then all delivery requests on the bulk release
					foreach deliveryRequest in bulkRelease.allDeliveryRequests discreteLock do
						// then all WLEs on the delivery request
						foreach wle in deliveryRequest.allWorkListEntries do
							if querySelf.checkStatusIncludesObject(wle, _passport, breakOut) then
								querySelf.addWLEToSummary(wle, tmpColl);
							endif;
						endforeach;
					endforeach;
					// PAR #26477 and all delivery requests being actioned - this covers bulk releases assigned to 
					// a rail area once the train has arrived
					foreach deliveryRequest in bulkRelease.allRequestsBeingActioned discreteLock do
						foreach wle in deliveryRequest.allWorkListEntries do
							if querySelf.checkStatusIncludesObject(wle, _passport, breakOut) then
								querySelf.addWLEToSummary(wle, tmpColl);
							endif;
						endforeach;
					endforeach;
					// and all delivery requests
					foreach deliveryRequest in bulkRelease.requests discreteLock do
						foreach wle in deliveryRequest.allWorkListEntries do
							if querySelf.checkStatusIncludesObject(wle, _passport, breakOut) then
								querySelf.addWLEToSummary(wle, tmpColl);
							endif;
						endforeach;
					endforeach;
					// PAR #26477 end
					// we need to include releases assigned directly to the train
					self.addBulkReleaseToSummary(bulkRelease, tmpColl);
				endforeach;
				
				// check job sheets as well
				if train.myJobSheet &lt;&gt; null then
					foreach railJob in train.myJobSheet.allJobsByOrder discreteLock do
						// then all requests in the rail job
						foreach deliveryRequest in railJob.allRequests discreteLock do
							// then wles on the request
							foreach wle in deliveryRequest.allWorkListEntries do
								if querySelf.checkStatusIncludesObject(wle, _passport, breakOut) then
									querySelf.addWLEToSummary(wle, tmpColl);
								endif;
							endforeach;
						endforeach;
					endforeach;
				endif;
				
				// and if train has been confrmed inwards, check wagon jobs
				if train.arrivalDT &lt;&gt; null then
					foreach wagon in train.allWagonsByIdOutward discreteLock do
						//foreach lc in wagon.allLocationsControllers discreteLock do	
						foreach lc in wagon.allLocationsControllersArray discreteLock do	//04 Dec 2014	NDL	Par 35345	
							foreach wle in lc.allRailWLELoad discreteLock do
								if querySelf.checkStatusIncludesObject(wle, _passport, breakOut) then
									querySelf.addWLEToSummary(wle, tmpColl);
								endif;
							endforeach;
						endforeach;
									
						foreach railJob in wagon.allRailJobs discreteLock do
							foreach wle in railJob.workListEntries discreteLock do
								if querySelf.checkStatusIncludesObject(wle, _passport, breakOut) then
									querySelf.addWLEToSummary(wle, tmpColl);
								endif;
							endforeach;
						endforeach;
					endforeach;
				endif;
			endif;
		endif;
	endif;
	// PAR #23794 end
	
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getMyTrain" id="4c59efc0-3f17-48dc-9202-e4ed7d554c5b">
        <source>getMyTrain():CM_Train;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

	train : CM_Train;
	edition : Integer;
	invalidObj : Boolean;

begin

	train := self.myTrain;

	if train = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, train, invalidObj );
	edition := train.edition;
	
	if invalidObj then
		return null;
	endif;
	
	return train;

epilog

end;</source>
        <ReturnType type="CM_Train"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="0db1d748-95ef-49bc-b6c0-76bba4aa1c64">
        <updating/>
        <source>includesObject(_obj: CM_Object; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;
//----------------------------------------------------------------
//	Created:	14 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/*

Date		Who		Reason
14 Jul 2010	cnwkpd1	PAR #24985 - handle invalid objects using exception handler for performance
29 Oct 2010	cnwdap1	PAR #23794 CCMS MES 1102 release requests on rail load list - handle wle as well as ti
*/

vars
	tmpTi			: CM_TrackedItem;
	failedDAC		: CM_DataAccessController;
	invalid			: Boolean;
	ed				: Integer;
	tmpWle			: CM_WorkListEntry;		// PAR #23794

begin
//	if not global.isValidObject(_obj) then // CCMS 101 if a tranship is made not TS then the clone for the export voyage will have been deleted.
	if _obj = null then
		self.doRebuild := true;
	else
		if CM_TrackedItem.hasInstance(_obj) then
			tmpTi := _obj.CM_TrackedItem;
			
			on Exception do app.handleDeletedObject(exception, tmpTi, invalid);		// PAR #24985
			
			if ( not tmpTi.isChild ) then
				if self.doFilter(tmpTi) and	tmpTi.canUserAccessSelf(null, failedDAC,_passport) then
					return true;
				endif;
			endif;
			
			if invalid then					// PAR #24985
				self.doRebuild := true;
			endif;
			
		// PAR #23794
		elseif CM_WorkListEntry.hasInstance(_obj) then
			tmpWle := _obj.CM_WorkListEntry;
			
			on Exception do app.handleDeletedObject(exception, tmpWle, invalid);
			if self.doFilterWle(tmpWle) and	tmpWle.canUserAccessSelf(null, failedDAC,_passport) then
				return true;
			endif;
			if invalid then
				self.doRebuild := true;
			endif;
		// PAR #23794 end
			
		endif;
	endif;
	
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includesObjectSR" id="abaafb79-19bf-42f2-9c81-6b447e2d5f82">
        <source>includesObjectSR(_sr: CM_SlotRequest; _passport: CM_Passport): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 Jul 2009	cnwndl1	Initial creation
13 Jul 2010	cnwkpd1	PAR #24985 - Handle default Cargo type (Container) correctly

*/

vars
	sr		: CM_SlotRequest;
	disPort	: CM_Port;
	ct		: CM_CargoType;
	
begin
	sr := _sr;
	
	if sr.moveType = DISCHARGE_MOVETYPE
	or sr.moveType = NULL_MOVETYPE
	or sr.moveType = SOB_MOVETYPE
	or (sr.moveType = DLR_MOVETYPE and sr.isDischarge)
	or sr.isBackend // PAR 19945
	//or (sr.getAttrIs40() and sr.getAttrIsBackend()) then		// 21/07/2010 cnwmh5 #24958
	or (sr.getAttrIs40() and sr.getAttrIsBackend())
	or sr.getAttrIsBackend() then								// 21/07/2010 cnwmh5 #24958
		return false;
	endif;

	disPort := app.myRoot.allPorts[sr.dischargePort];

	// PAR #24985 - Allow for getAttrCargoType returning null
	ct := sr.getAttrCargoType();
	if ct = null then
		ct := app.myRoot.allCargoTypesById[TI_CargoType_Container];
	endif;
	
	if (self.allCargoTypes.isEmpty or self.allCargoTypes.includes(ct))
	and (self.allPortsDischarge.isEmpty() or (disPort &lt;&gt; null and self.allPortsDischarge.includes(disPort)))
	then
		return true;
	endif;
	
	return false;
end;</source>
        <Parameter name="_sr" type="CM_SlotRequest"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyTrain" id="d4af5ac4-b6f3-4da3-8a31-208ecd32df89">
        <updating/>
        <source>setMyTrain( _train : CM_Train ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

begin

	self.myTrain := _train;

epilog

end;</source>
        <Parameter name="_train" type="CM_Train"/>
    </JadeMethod>
    <JadeMethod name="showReleaseRequests" id="be765e0b-77a2-4acd-847a-beecf563be02">
        <source>showReleaseRequests( train : CM_Train ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 December 2011	cnwndl1	Initial creation	Par 28815

*/

vars

	term : CM_Terminal;
	wle : CM_WorkListEntry;
	edition : Integer;	//18 July 2016	NDL	TFS 2329
	invalid : Boolean;	//18 July 2016	NDL	TFS 2329

begin

	if not allTIs.isEmpty then
		term := allTIs.first.myTerminal;
	endif;
	
	if term = null and train &lt;&gt; null then
		if not train.allAssignedTIs.isEmpty then
			term := train.allAssignedTIs.first.myTerminal;
		endif;
	endif;
	
	if term = null and  not self.allWLEs.isEmpty  then
	//	term := self.allWLEs.first.getMyTerminal;
		//18 July 2016	NDL	TFS 2329
		on Exception do app.handleDeletedObject( exception, wle, invalid );	
		foreach wle in self.allWLEs do
			invalid := false;
			edition := wle.edition;
			if invalid then
				continue;
			endif;
			term := wle.getMyTerminal;
			if term &lt;&gt; null then
				break;
			endif;
		endforeach;
	endif;
	
	if term = null then
		term := app.getMyTerminalDO_NOT_USE;
	endif;
	
	if term = null then
		return false;
	endif;
	
	return term.getConfig(ShowRelReqOnRailLoadList).Boolean;

epilog

end;
</source>
        <Parameter name="train" type="CM_Train"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
