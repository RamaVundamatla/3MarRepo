    <JadeMethod name="buildLargePoly" id="f7e349f9-263a-4599-898e-2e598496a90d">
        <source>buildLargePoly(decArr : DecimalArray input) : DecimalArray;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 September 2012	cnwmc5	Initial creation

*/

vars
	decStr : String;
	decStrArr : StringArray;
	
	dec : Decimal[10,2];
	str : String;
begin
	decStr := "48.33,-7.97,
			58.53,-7.97,
			58.53,-7.16,
			60.17,-7.16,
			60.17,-6.54,
			64.25,-6.54,
			64.25,-5.93,
			73.84,-5.93,
			73.84,-4.50,
			74.04,-4.50,
			74.04,4.89,
			73.84,4.89,
			73.84,6.11,
			64.04,6.11,
			64.04,6.93,
			61.19,6.93,
			61.19,7.54,
			56.70,7.54,
			56.70,8.35,
			53.84,8.35,
			53.84,9.58,
			48.94,9.58,
			48.94,10.40,
			45.06,10.40,
			45.06,11.21,
			42.41,11.21,
			42.41,11.82,
			37.92,11.82,
			37.92,13.05,
			35.27,13.05,
			35.27,14.07,
			28.13,14.07,
			28.13,14.48,
			24.45,14.48,
			24.45,15.09,
			9.76,15.09,
			9.76,12.84,
			7.92,12.84,
			7.92,12.23,
			7.11,12.23,
			7.11,1.82,
			7.92,1.82,
			7.92,1.42,
			13.84,1.42,
			13.84,-0.42,
			25.68,-0.42,
			25.68,1.42,
			27.31,1.42,
			27.31,-0.83,
			26.49,-0.83,
			26.49,-6.14,
			33.43,-6.14,
			33.43,-5.93,
			33.64,-5.93,
			33.64,-5.32,
			34.45,-5.32,
			34.45,-4.71,
			35.47,-4.71,
			35.47,-3.28,
			36.29,-3.28,
			36.29,-2.26,
			37.51,-2.26,
			37.51,-1.24,
			38.94,-1.24,
			38.94,0.80,
			42.82,0.80,
			42.82,-0.83,
			44.45,-0.83,
			44.45,-3.28,
			46.49,-3.28,
			46.49,-5.73,
			48.33,-5.73,
			48.33,-7.97";
	
	create decStrArr transient;
	
	decStrArr := decStr.cnGetTokens(",");
	
	foreach str in decStrArr do
		decArr.add(str.Decimal);
	endforeach;
	
	return decArr;	
epilog
	delete decStrArr;
end;</source>
        <Parameter name="decArr" type="DecimalArray" usage="input"/>
        <ReturnType type="DecimalArray"/>
    </JadeMethod>
    <JadeMethod name="calcBestPlace" id="90cec1fa-119f-4ad7-b035-3a4831d7b57d">
        <source>calcBestPlace(_polygon : PointArray);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2012	cnwmc5	Initial creation

*/

vars
	bestPlace, polygon	: PointArray;
	frame 				: Frame;
	x1, y1, x2, y2		: Real;
	point, point2		: Point;
	wasOut				: Boolean;
	offset, origY, 
	maxX, maxY, height 	: Integer;
	isAngled			: Boolean;
	x, a				: Integer;
	
	lPoint, lPoint2		: Point;
begin
	frame := self.drawFrame;
	wasOut := false;
	isAngled := false;
	height := 50;
	
	create bestPlace transient;
	create polygon transient;
	
	// Starting points (inside poly)
	foreach point in _polygon do
		if bestPlace.isEmpty() then
			bestPlace.add(point);
			origY := point.y;
		elseif point.x &lt; bestPlace[1].x then
			bestPlace[1] := point;
		elseif point.x = bestPlace[1].x and point.y &lt; bestPlace[1].y then
			bestPlace[1] := point;
		endif;
		
		//Find the largest Y point
		if maxY = null then
			maxY := point.y;
		elseif maxY &lt; point.y then
			maxY := point.y;
		endif;
		
		//Find the largest X point
		if maxX = null then
			maxX := point.x;
		elseif maxX &lt; point.x then
			maxX := point.x;
		endif;
	endforeach;
	
	// Calculate other points...
	point.set((maxX/1.5).Integer, bestPlace[1].y + height);
	bestPlace.add(point);
	
	//Build opposites... only needed for check if inside polygon.
	point.set(bestPlace[1].x, bestPlace[2].y);
	bestPlace.add(point);
	point.set(bestPlace[2].x, bestPlace[1].y);
	bestPlace.add(point);
	
	_polygon.copy(polygon);
	
	polygon.add(polygon[1]);
	
	x := 1;
	a := 1;
	/*foreach point in _polygon do
		foreach a in x to polygon.size do
			point2 := polygon[a];
			if point = point2 then
				continue;
			endif;
			if point.x &lt;&gt; point2.x then
				if point.y &lt;&gt; point2.y then
					if lPoint = null then
						lPoint := point;
						lPoint2 := point2;
					elseif point.x &lt; lPoint.x then
						lPoint := point;
						if a = polygon.size then
							lPoint2 := polygon[1];
						else
							lPoint2 := polygon[a+1];
						endif;
					endif;
					isAngled := true;
					//write "Is Angled: " &amp; isAngled.String &amp; Tab &amp; "Point x: " &amp; point.x.String &amp; Tab &amp; "Point y: " &amp; point.y.String &amp; Tab &amp; "Point2 x: " &amp; point2.x.String &amp; Tab &amp; "Point2 y: " &amp; point2.y.String;
				endif;
			endif;
			x := x + 1;
			break;
		endforeach;
	endforeach;*/

	foreach a in 1 to polygon.size do
		if a = polygon.size then
			break;
		endif;
		
		point := polygon[a];
		point2 := polygon[a+1];
		if point = point2 then
			continue;
		endif;
		
		if point.x &lt; point2.x and point.y &gt; point2.y or point.x &gt; point2.x and point.y &lt; point2.y then
			if lPoint = null then
				lPoint := point;
				lPoint2 := point2;
			elseif point.x &lt; lPoint.x or point2.x &lt; lPoint2.x then
				lPoint := point;
				lPoint2 := point2;
			endif;
			isAngled := true;
		endif;
	endforeach;
	
	if isAngled then
		point.setX(((lPoint.x + lPoint2.x) / 2).Integer);
		point.setY(((lPoint.y + lPoint2.y) / 2).Integer);
		foreach point2 in _polygon do
			if point2.x &lt; point.x and point2.y &lt; point.y then
				isAngled := false;
				break;
			endif;
		endforeach;
	endif;
	
	// FOR TESTING
	frame.drawLine(lPoint.x, lPoint.y, 0, 0, Red);
	frame.drawLine(lPoint2.x, lPoint2.y, 0, 0, Red);
	//write "lPoint: " &amp; lPoint.x.String &amp; ", " &amp; lPoint.y.String &amp; Tab &amp; "lPoint2: " &amp; lPoint2.x.String &amp; ", " &amp; lPoint2.y.String;
	
	// Find the best place...
	if isAngled then
		bestPlace.clear();
		point.setX(((lPoint.x + lPoint2.x) / 2).Integer + 1);
		point.setY(((lPoint.y + lPoint2.y) / 2).Integer + 1);
		bestPlace.add(point);
		
		point.set(maxX, bestPlace[1].y);
		bestPlace.add(point);
		
		point.set(bestPlace[1].x, maxY);
		bestPlace.add(point);
		
		point.set(maxX, maxY);
		bestPlace.add(point);
		
		while _polygon.intersectsPolygon(bestPlace) = false do
			bestPlace[2].setX(bestPlace[2].x - 1);
			bestPlace[3].setY(bestPlace[3].y - 1);
			bestPlace[4].set((bestPlace[4].x - 1), (bestPlace[4].y - 1));
		endwhile;

		bestPlace[2].set(bestPlace[4].x, bestPlace[4].y);
		
		offset := 1;
	else
		while _polygon.intersectsPolygon(bestPlace) = false do
			bestPlace[1].setY(bestPlace[1].y + 2);
			bestPlace[2].setY(bestPlace[2].y + 2);
			bestPlace[3].setY(bestPlace[3].y + 2);
			bestPlace[4].setY(bestPlace[4].y + 2);
			
			if bestPlace[2].y &gt; maxY then
				height := height - 2;
				bestPlace[1].setY(origY);
				bestPlace[2].setY(origY + height);
				bestPlace[3].setY(origY + height);
				bestPlace[4].setY(origY);
			endif;
			
		endwhile;
		
		offset := 2;
	endif;
	
	//Pull into real's
	x1 := bestPlace[1].x + offset;
	y1 := bestPlace[1].y + offset;
	x2 := bestPlace[2].x + offset;
	y2 := bestPlace[2].y + offset;	
	
	frame.drawFilledRectangle(x1, y1, x2, y2, Red);
epilog
	delete bestPlace;
	delete polygon;
end;

//calcBestPlace(_polygon : PointArray);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2012	cnwmc5	Initial creation

*/

/*vars
	bestPlace 		: PointArray;
	frame 			: Frame;
	x1, y1, x2, y2	: Real;
	point			: Point;
	wasOut			: Boolean;
	offset, origY, 
	maxX, maxY, height : Integer;
	
begin
	frame := self.drawFrame;
	wasOut := false;
	height := 50;
	create bestPlace transient;
	
	// Starting points (inside poly)
	foreach point in _polygon do
		if bestPlace.isEmpty() then
			bestPlace.add(point);
			origY := point.y;
		elseif point.x &lt; bestPlace[1].x then
			bestPlace[1] := point;
		elseif point.x = bestPlace[1].x and point.y &lt; bestPlace[1].y then
			bestPlace[1] := point;
		endif;
		
		//Find the largest Y point
		if maxY = null then
			maxY := point.y;
		elseif maxY &lt; point.y then
			maxY := point.y;
		endif;
		
		//Find the largest X point
		if maxX = null then
			maxX := point.x;
		elseif maxX &lt; point.x then
			maxX := point.x;
		endif;
	endforeach;
	
	// Calculate other points...
	point.set((maxX/1.5).Integer, bestPlace[1].y + height);
	bestPlace.add(point);
	
	//Build opposites... only needed for check if inside polygon.
	point.set(bestPlace[1].x, bestPlace[2].y);
	bestPlace.add(point);
	point.set(bestPlace[2].x, bestPlace[1].y);
	bestPlace.add(point);
	
	// Find the best place...
	while _polygon.intersectsPolygon(bestPlace) = false do
		bestPlace[1].setY(bestPlace[1].y + 2);
		bestPlace[2].setY(bestPlace[2].y + 2);
		bestPlace[3].setY(bestPlace[3].y + 2);
		bestPlace[4].setY(bestPlace[4].y + 2);
		
		if bestPlace[2].y &gt; maxY then
			height := height - 2;
			bestPlace[1].setY(origY);
			bestPlace[2].setY(origY + height);
			bestPlace[3].setY(origY + height);
			bestPlace[4].setY(origY);
			
			//bestPlace[1].setX((maxX/2).Integer - 10);
			//bestPlace[2].setX((maxX/2).Integer - 10);
			//maxX := maxX - 10;
		endif;
		
		wasOut := true;
	endwhile;
	
	offset := 2;
	
	//Pull into real's
	x1 := bestPlace[1].x + offset;
	y1 := bestPlace[1].y + offset;
	x2 := bestPlace[2].x + offset;
	y2 := bestPlace[2].y + offset;	
	
	frame.drawFilledRectangle(x1, y1, x2, y2, Red);
epilog
	delete bestPlace;
end;*/</source>
        <Parameter name="_polygon" type="PointArray"/>
    </JadeMethod>
