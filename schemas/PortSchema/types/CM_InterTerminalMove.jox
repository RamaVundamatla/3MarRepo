    <JadeMethod name="setForUpdate" id="8908853a-fe6f-4646-bd7c-fc849ca2a679">
        <updating/>
        <source>setForUpdate(_pxyITMove : CM_InterTerminalMove) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2010	cnwrd1	Initial creation

*/

vars

begin

	self.cargoID := _pxyITMove.cargoID;
	self.completedDT := _pxyITMove.completedDT;	
	self.myInterTermVehicleJob := _pxyITMove.myInterTermVehicleJob; 
	
	// constant stuff
	self.myOperator := _pxyITMove.myOperator;
	
	//source stuff
	self.mySourceTI := _pxyITMove.mySourceTI;
	self.mySourceTerminal := _pxyITMove.mySourceTerminal;
	self.mySourceVehicle := _pxyITMove.mySourceVehicle;
	self.mySourceVehicleVisit := _pxyITMove.mySourceVehicleVisit;
	
	
	//target stuff
	self.myTargetTI := _pxyITMove.myTargetTI;
	self.myTargetTerminal := _pxyITMove.myTargetTerminal; 
	self.myTargetVehicle := _pxyITMove.myTargetVehicle;
	self.myTargetVehicleVisit := _pxyITMove.myTargetVehicleVisit;
	self.myTargetLC := _pxyITMove.myTargetLC;
	
	self.releasedDT := _pxyITMove.releasedDT;
	self.status := _pxyITMove.status;
	self.vehicleID := _pxyITMove.vehicleID;
	self.vehiclePickupDT := _pxyITMove.vehiclePickupDT;
	self.vehicleSetdownDT := _pxyITMove.vehicleSetdownDT;
	

	

epilog

end;</source>
        <Parameter name="_pxyITMove" type="CM_InterTerminalMove"/>
    </JadeMethod>
