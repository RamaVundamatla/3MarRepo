    <JadeMethod name="allIMEX" id="7af6e9ab-d2cd-4ff3-9cdb-236240925894">
        <source>allIMEX() : Boolean;
//Indicates that this template applies to all IMEX statuses.
vars
	value : Boolean;
begin
	value := (imports = exports);
	if value  = true then
		value := (exports = storage);		//All true or all false
	endif;
	return value;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
