    <JadeMethod name="drawNumTIs" id="eceb5243-ffaf-4c17-950c-7f7e950923f9">
        <source>drawNumTIs(numTIs2 : Integer; numTI2Str : String io; numTIs3 : Integer; numTI3Str : String io; _theFrame : CMUI_GridAreaFrame input; 
								numTIs : Integer; lFactor : Real; startX : Real; startY : Real; foreColour : Integer);
/*

Purpose:			TFS 49523

Parameters:			

Return Value:		

Date		Who		Reason
09 June 2020	jlgab1	Initial creation

*/

vars

begin
    if numTIs2 &gt; 0 then
		 numTI2Str := " " &amp; numTI2Str &amp; numTIs2.String;
	else
		numTI2Str := "";
	endif;
	if numTIs3 &gt; 0 then
		 numTI3Str := " " &amp; numTI3Str &amp; numTIs3.String;
	else
		numTI3Str := "";
	endif;
	
	_theFrame.drawTextAt(numTIs.String &amp;  numTI2Str &amp; numTI3Str, startX, startY, foreColour);
end;
</source>
        <Parameter name="numTIs2" type="Integer"/>
        <Parameter name="numTI2Str" type="String" usage="io"/>
        <Parameter name="numTIs3" type="Integer"/>
        <Parameter name="numTI3Str" type="String" usage="io"/>
        <Parameter name="_theFrame" type="CMUI_GridAreaFrame" usage="input"/>
        <Parameter name="numTIs" type="Integer"/>
        <Parameter name="lFactor" type="Real"/>
        <Parameter name="startX" type="Real"/>
        <Parameter name="startY" type="Real"/>
        <Parameter name="foreColour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawOpenDoor" id="26169113-f8e6-4661-b296-2f0d0b721fe7">
        <updating/>
        <source>drawOpenDoor(  _theFrame : CMUI_GridAreaFrame input; startY : Real ):Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 March 2013	cnwndl1	Initial creation

*/

vars

	bin : Binary;
	pic : CMUI_Picture;
	width : Real;

begin

	width := self.x2 - self.x1;
	
	if not app.isSpecial or width &lt; 40 then
		if self.openDoor &lt;&gt; null then
			self.openDoor.visible := false;
		endif;
		return false;
	endif;
	
	if self.boxcarLocIndex.isEven then
		return false;
	endif;
	
	if self.openDoor = null then
		create pic transient;
		bin := app.myRoot.getConfig(PicOpenDoor).Binary;
		pic.width := 40;
		pic.height := 40;
		pic.stretch := 4;
		pic.picture := bin;
		pic.left := self.x1;
		pic.top := startY;
		_theFrame.form.addControl(pic);
		pic.parent := _theFrame;
		self.setOpenDoor(pic);
	endif;
	
	self.openDoor.visible := true;
	self.openDoor.zOrder(1);
	return true;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_theFrame" type="CMUI_GridAreaFrame" usage="input"/>
        <Parameter name="startY" type="Real"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawOtherModeTI" id="8a5d1b3d-1b60-48c0-85e0-d5bb69647eb4">
        <source>drawOtherModeTI(_theFrame: CMUI_GridAreaFrame input;
				_mode, _theTIIndex : Integer; _theTI : CM_TrackedItem; _theLetter : String; _colour : Integer;
				_x1: Real; _y1: Real; _x2: Real; _y2: Real) protected;
// ---------------------------------------------------------------------------
// Created:		7 August 2003 by cnwsgp1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 10/07/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	tm_x2, tm_x1,tm_y1,tm_y2	: Real;
	idx : Integer;
	lFactor : Real;
	theAttributeArray : CMUI_GridAttributesArray;
	theGridAttributes : CMUI_GridAttributes;
	theGridArea : CMUI_GridArea;
	
	xOffset : Integer;
	yOffset : Integer;
	yOffsetFnt : Integer;
	xOffsetFnt : Integer;
	tmpIndex : Real;
	wagon : CM_Wagon;
	flatCarOffSet : Real;
	
begin	
	theGridArea := self.myGridArea;

	if _mode = REAL_MODE then
		theAttributeArray := self.allTrackedItemAttributes;
	elseif _mode = QUEUE_MODE then
		theAttributeArray := self.allQueuedTrackedItemAttributes;
	elseif _mode = PLANNING_MODE then
		theAttributeArray := self.allPlanTrackedItemAttributes;
	endif;

	theGridAttributes := theAttributeArray[_theTIIndex];
//	self.drawTIAddViewModeLegend(theGridAttributes);	
	tm_y1 := _y1;
	tm_x1 := _x1;
	
	idx := theGridAttributes.width;
	if idx &gt; 1 then
		// This TI spans more than one controller so have to
		// find subsequent controllers and alter x2
		
		//13 Jan 2015	NDL	Par 35346
		if idx = 4 then
			//check if it is bigger than a 40 and is on a flatcar so would need drawing the real length.
			tmpIndex := _theTI.getMultiplierForDrawing() * 2;
			wagon := theGridArea.YRD_WagonArea.myWagon;
			if tmpIndex &gt; 4 and wagon &lt;&gt; null and wagon.isFlatcar then
				flatCarOffSet := tmpIndex - 4;
			endif;
		endif;
		
		if theGridArea.flipHorizontal then
		//	tm_x1 := _x2 - (idx * (_x2 - _x1)) - 2;
		//	tm_x2 := _x2 + 2;
			///13 Jan 2015	NDL	Par 35345
			tm_x2 := _x2 - ( (idx - 1 ) * (_x2 - _x1 ));
			tm_x1 := tm_x2 - ( idx * (_x2 - _x1 ));
			if flatCarOffSet &gt; 0 then
				tm_x1 := tm_x2 - ( tmpIndex * (_x2 - _x1 ));
			endif;
		else
			tm_x2 := tm_x1 + (idx * (_x2 - tm_x1)) ;
			///13 Jan 2015	NDL	Par 35345
			if flatCarOffSet &gt; 0 then
				tm_x2 := tm_x2 + (flatCarOffSet * (_x2 - tm_x1)) ;
			endif;
		endif;
	else
		tm_x2 := _x2;
	endif;

	tm_x2 := tm_x2 - 1;
	tm_y2 := _y2 - 1;

	_theFrame.drawFontName := "Arial";
	_theFrame.drawFontBold := false;
	_theFrame.drawStyle := Frame.DrawStyle_Solid;
	_theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
	_theFrame.drawTextAlign := Frame.DrawTextAlign_Left;
	_theFrame.drawFillColor := White;

	lFactor := theGridArea.scaleXFactor;	
	if lFactor &lt; 2.5 then
		_theFrame.drawWidth := 1;
	else
		_theFrame.drawWidth := 2;
	endif;
	
	xOffset := (lFactor * 2).Integer;// div self.heightOfStack;
	yOffset := (lFactor * 3).Integer;// div self.heightOfStack;
	_theFrame.drawFontSize := (7 * lFactor); //self.heightOfStack;
	_theFrame.fontSize := _theFrame.drawFontSize;

	yOffsetFnt := -1;
	xOffsetFnt := ((tm_x2 - xOffset) - (tm_x1 + xOffset) - (_theFrame.getTextExtent(_theLetter))) div 2 + xOffset;

	_theFrame.drawFilledRectangle(tm_x1 + xOffset, tm_y1 + yOffset, tm_x2 - xOffset, tm_y2 - yOffset,  _colour);
	_theFrame.drawTextAt(_theLetter, tm_x1 + xOffsetFnt, tm_y1 + yOffsetFnt, _colour); 
end;</source>
        <access>protected</access>
        <Parameter name="_theFrame" type="CMUI_GridAreaFrame" usage="input"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_theTIIndex" type="Integer"/>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_theLetter" type="String"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawRelease" id="8ccc4a5a-f1cf-4aa4-8934-27db3407273f">
        <updating/>
        <source>drawRelease(_theFrame: CMUI_GridAreaFrame input; _theWLE: CM_WorkListEntry; _x1, _y1, _x2, _y2: Real) updating, protected;
// -----------------------------------------------------------------------------
// Created:		26 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	countWagonLC : Integer;
	lOuterColourUpper, lOuterColourLower, lTIColour : Integer;
	lFactor : Real;
	theCharacterWidth, theFontSize : Integer;
	theGridArea : CMUI_GridArea;
	theText : String;
	tm_x1, tm_x2, tm_y1, tm_y2 : Real;
	wagonLC : CM_WagonController;
	lcWidth : Real;
	wagonLength : Real;
	wagon : CM_Wagon;
	wagonOffset : Real;
	
begin
	theGridArea := self.myGridArea;
	lFactor := theGridArea.scaleXFactor;
	_theFrame.drawFontName := "Arial";
	_theFrame.drawWidth := 1;
	if lFactor &gt; 2 then
		_theFrame.drawWidth := 2;
	endif;
	
	lcWidth := (_x2 - _x1);
	
	wagonLC := self.myLocationsController.CM_WagonController;
	wagon := wagonLC.myWagon;
	wagonLength := ( lcWidth * wagon.allLocationsControllersArray.size );
	wagonOffset :=  _x1 - (( wagon.allLocationsControllersArray.indexOf(wagonLC) - 1 ) * lcWidth ) + 10;
	
	while true do
		if wagonLC.myWagon.isWellcarVisit then	//15 Dec 2014	NDL	Par 35346
			//countWagonLC := wagonLC.getNumUnitsFlexiOffset( _theWLE.myTrackedItem );
			countWagonLC := wagonLC.myWagon.getLengthInUnitsForWagon( _theWLE ).Integer;
			break;
		endif;
		countWagonLC := countWagonLC + 1;
		wagonLC := wagonLC.myNextController;
		if wagonLC = null or not wagonLC.allRailWLELoad.includes(_theWLE) then
			break;
		endif;
	endwhile;

	tm_x1 := _x1;
	tm_x2 := _x1 + ( countWagonLC * lcWidth );
	
	if theGridArea.flipHorizontal then
	//	tm_x1 := tm_x1 - (tm_x2 - _x2);
	///	tm_x2 := tm_x1 + ( countWagonLC * lcWidth );
		tm_x2 := wagonOffset + wagonLength - _x1;
		tm_x1 := tm_x2 - ( countWagonLC * lcWidth );
	endif;
	
//write _x1.String &amp; "," &amp; _x2.String &amp; " - " &amp; tm_x1.String &amp; "," &amp; tm_x2.String  &amp; "   " &amp; countWagonLC.String;
	
	tm_x1 := tm_x1 + _theFrame.drawWidth;
	tm_y1 := _y1 + _theFrame.drawWidth;
	
	tm_x2 := tm_x2 - 1;
	tm_y2 := _y2 - 1;

	lTIColour := White;
	lOuterColourUpper := Black;
	lOuterColourLower := DarkGray;

	_theFrame.drawStyle := Frame.DrawStyle_Solid;
	_theFrame.drawFillColor := lTIColour;
	_theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
	_theFrame.drawFilledRectangle(tm_x1, tm_y1, tm_x2, tm_y2,  lTIColour); 
	_theFrame.drawLine(tm_x1, tm_y1, tm_x2 + 1, tm_y1 ,  lOuterColourUpper);
	_theFrame.drawLine(tm_x1, tm_y1, tm_x1, tm_y2,  lOuterColourUpper);
	_theFrame.drawLine(tm_x2, tm_y1 + 1, tm_x2, tm_y2 + 1,  lOuterColourLower);
	_theFrame.drawLine(tm_x1, tm_y2, tm_x2, tm_y2,  lOuterColourLower);
	
	tm_x1 := tm_x1 + _theFrame.drawWidth;
	
	_theFrame.drawWidth := 1;
	
	if countWagonLC &lt; 2 then
		return;
	endif;
	
	if lFactor &lt; 2 then
		theFontSize := 6;
	elseif lFactor &lt; 3 and countWagonLC &lt; 3 then
		theFontSize := 6;
	else
		theFontSize := 8;
	endif;
	
	theText := _theWLE.myRequest.getDisplayStringForAttribute(ETRow_OperatorCode, true);

	if lFactor &gt;= 2 or countWagonLC &gt; 3 then
		theText := theText &amp; ' ' &amp; _theWLE.myRequest.getDisplayStringForAttribute(ETRow_IsoType, true);
	endif;

	self.drawTITextLeft(_theFrame, _theFrame.drawFontName, theFontSize,	theText, White,
							(tm_x1 + 0.5 * (tm_x2 - tm_x1)).Integer, tm_y1.Integer, _y2.Integer);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_theFrame" type="CMUI_GridAreaFrame" usage="input"/>
        <Parameter name="_theWLE" type="CM_WorkListEntry"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawSelf" id="c8b52469-d814-4dbe-b6aa-4abf30605d06">
        <updating/>
        <source>drawSelf(pFrame: CMUI_GridAreaFrame input) updating;
// ---------------------------------------------------------------------------
// Created:     31 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 05/06/2009	consw1		PAR 19710 - SFW1067 Rail Simplifications
// 02/07/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// 26/08/2009	consw1		PAR 19913 - SFW1094 Rail Simplifications
// 10/11/2010	cnwdap1		PAR #23794 CCMS MES 1102 draw WLE with a TBA TI same as WLE without a TI
// ---------------------------------------------------------------------------
constants
	Local_ACTUAL_MODE = 6;

vars
	startY,
	endY		: Real;
	theDummyTI,
	theTI		: CM_TrackedItem;
	aPicture 	: Binary;
	lTIArray	: CM_TIArray;
	lTIFiltered	: CM_TIArray;
	lTIInward	: CM_TIArray;
	gridPnt 	: CMUI_GridPoint;
	tmpLetter	: String;
	idx,
	tmpFrameHeight,	
	numTIs,numTIs2, numTIs3, // numTIs2 and numTIs3 are the count for the other display modes, so if Actual the others are planned and queued
	displayMode, displayMode2, displayMode3,
	letterIndex,
	theColour 	: Integer;
	theMode 	: Integer;
	theGridArea : CMUI_GridArea;
	theAttributeArray : CMUI_GridAttributesArray;
	lTIFilteredAttributeArray : CMUI_GridAttributesArray;
	tmpGridAttributes,
	theGridAttributes : CMUI_GridAttributes;
	wagonLC : CM_WagonController;
	wleLoad : CM_WorkListEntry;
	wleLoadIndex : Integer;
	hasQ : Boolean;
	myGA : CMUI_GridArea;
	wagon : CM_Wagon;
begin
	myGA := self.myGridArea;
	
	if self.heightOfStack = 0 then
		// Nothing to draw
		return;
	endif;

	theGridArea := self.myGridArea;
	displayMode := theGridArea.mySDF.displayMode;
	tmpFrameHeight	:= pFrame.height.Integer;
	theDummyTI := theGridArea.myDummyTI;

//   this is for testing draws gray box so you can see this point
//	pFrame.drawFillColor := pFrame.backColor;
//	pFrame.drawFilledRectangle(self.x1,self.y1,self.x2,self.y2,  Gray);

	create lTIFiltered transient;
	create lTIFilteredAttributeArray transient; 
	create lTIInward transient;
	
	if theGridArea.YRD_WagonArea.isOutward then
		//  Received TIs are not shown when viewing an outward wagon
		foreach theTI in self.allTrackedItems do
			idx := idx + 1;
			if theGridArea.YRD_WagonArea.myWagon.isTIOutward(theTI) then
				lTIFiltered.add(theTI);
				lTIFilteredAttributeArray.add(self.allTrackedItemAttributes[idx]);
			else
				lTIInward.add(theTI);
			endif;
		endforeach;
	else
		self.allTrackedItems.copy(lTIFiltered);
		self.allTrackedItemAttributes.copy(lTIFilteredAttributeArray);
	endif;

	if displayMode = DISPLAY_MODE_ACTUAL then
		displayMode2 := DISPLAY_MODE_PLAN; // TFS 49523
		displayMode3 := DISPLAY_MODE_QUEUE; // TFS 49523
		
		lTIArray := lTIFiltered;
		theAttributeArray := lTIFilteredAttributeArray;
	elseif displayMode = DISPLAY_MODE_QUEUE then
		displayMode2 := DISPLAY_MODE_ACTUAL; // TFS 49523
		displayMode3 := DISPLAY_MODE_PLAN; // TFS 49523
		lTIArray := self.allQueuedTrackedItems;
		theAttributeArray := self.allQueuedTrackedItemAttributes;		
	elseif displayMode = DISPLAY_MODE_PLAN then
		displayMode2 := DISPLAY_MODE_ACTUAL; // TFS 49523
		displayMode3 := DISPLAY_MODE_QUEUE; // TFS 49523
		lTIArray := self.allPlannedTrackedItems;
		theAttributeArray := self.allPlanTrackedItemAttributes;		
	endif;

	numTIs := lTIArray.size;
	pFrame.drawWidth := 1;
	self.cellHeight := ((self.y2 - self.y1) / self.heightOfStack).Integer;
	
	if self.myGridArea.isBoxcar then
		//20 Aug 2013	NDL	Par 32174
// TFS 49523		self.drawBoxcarCargo(pFrame,numTIs);
		wagon :=  self.myGridArea.YRD_WagonArea.myWagon; // TFS 49523
		if wagon.myWagonClass.numOfTwenty = CM_BoxcarVisit.BoxcarGraphicBulk then // TFS 49523 BULK
			// Performance. There is a YRD_WagonPoint for every 10 feet of the wagon. 
			// The Bulk car drawing only uses the first YRD_WagonPoint, So only need to get these numTIs once
			if self.myGridArea.allGridPoints.first = self then 
				numTIs := self.myGridArea.getCargoCountForBoxcarGraphic(displayMode);
				numTIs2 := self.myGridArea.getCargoCountForBoxcarGraphic(displayMode2);
				numTIs3 := self.myGridArea.getCargoCountForBoxcarGraphic(displayMode3);
			endif;
	
			self.drawBulkCar(pFrame,numTIs, displayMode,numTIs2, displayMode2,numTIs3, displayMode3);// TFS 49523
		elseif wagon.myWagonClass.numOfTwenty = CM_BoxcarVisit.BoxcarGraphicTransporter then // TFS 49523 TRANSPORTER
			// Performance. There is a YRD_WagonPoint for every 10 feet of the wagon. 
			// The Bulk car drawing only uses the first YRD_WagonPoint, So only need to get these numTIs once
			if self.myGridArea.allGridPoints.first = self then 
				numTIs := self.myGridArea.getCargoCountForBoxcarGraphic(displayMode);
				numTIs2 := self.myGridArea.getCargoCountForBoxcarGraphic(displayMode2);
				numTIs3 := self.myGridArea.getCargoCountForBoxcarGraphic(displayMode3);
			endif;
	
			self.drawTransporter(pFrame,numTIs, displayMode,numTIs2, displayMode2,numTIs3, displayMode3);// TFS 49523
		else// TFS 49523
			numTIs := self.myGridArea.getCargoCountForBoxcarGraphic(displayMode);
			//numTIs2 := self.myGridArea.getCargoCountForBoxcarGraphic(displayMode2);
			//numTIs3 := self.myGridArea.getCargoCountForBoxcarGraphic(displayMode3);
			self.drawBoxcarCargo(pFrame,numTIs);
		
		endif;

		return;
	endif;

	if self.myGridArea.isSkeletonCar then	// TFS 2533
		self.drawSkeletonCarArm(pFrame, numTIs);
		return;
	endif;

	foreach idx in 1 to theGridArea.YRD_WagonArea.myWagon.myWagonClass.maxNumInStack do
		startY 	:= self.getYPosFromIdx(idx);
		endY	:= startY + self.cellHeight;
		theTI 	:= null;
		if idx &lt;= numTIs then
			theTI := lTIArray[idx];
			theGridAttributes := theAttributeArray[idx];			
			
			if theTI &lt;&gt; theDummyTI then
				//self.drawTI(pFrame, theTI,theGridAttributes, self.x1, startY, self.x2, endY);
				//cnwjo3 par 21929
				self.drawTI(pFrame, theTI,theGridAttributes, self.newOffset(self.x1,myGA,theTI), startY, self.newOffset(self.x2,myGA,theTI), endY);
			else
				// We have an item that is displayed over more than one wagon point.
				// Only the first wagon point has the tracked items associated with it and
				// one of the other wagon points has been clicked.  Get the previous wagon
				// point and redraw the tracked item when the actual wagon point is found.
				if theTI &lt;&gt; null then
					gridPnt := theGridArea.allGridPoints.getAtKey(self.myGridRow.row, self.myGridColumn.column - 1);
					if gridPnt &lt;&gt; null then
						gridPnt.drawSelf(pFrame);
					endif;
				endif;
			endif;
		endif;
		if theTI = null then
			// draw the Ps and Qs in addition to the actual TI graphic
			theTI := null;
			letterIndex := letterIndex + 1;
			theMode := 0;
			theColour := Black;
			tmpLetter := null;
			hasQ := false;
			if displayMode &lt;&gt; DISPLAY_MODE_ACTUAL then
				if (not lTIFiltered.isEmpty) and letterIndex &lt;= lTIFiltered.size then
					theTI := lTIFiltered[letterIndex];
					theMode := REAL_MODE;
					tmpLetter := tmpLetter &amp; 'A';
				endif;
			endif;			
			if displayMode &lt;&gt; DISPLAY_MODE_QUEUE then
				if (not self.allQueuedTrackedItems.isEmpty) and letterIndex &lt;= self.allQueuedTrackedItems.size then
					theTI := self.allQueuedTrackedItems[letterIndex];
					theMode := QUEUE_MODE;
					tmpLetter := tmpLetter &amp; ' Q';
					hasQ := true;
				endif;
			endif;
			if displayMode &lt;&gt; DISPLAY_MODE_PLAN then
				if (not self.allPlannedTrackedItems.isEmpty) and (letterIndex &lt;= self.allPlannedTrackedItems.size) 
				and not hasQ then // Do not show Q&amp;P Just Q or P
					theTI := self.allPlannedTrackedItems[letterIndex];
					theMode :=  PLANNING_MODE;
					tmpLetter := tmpLetter &amp; ' P';
				endif;
				if theTI = null and tmpLetter = null then
					//  Include received TIs still on wagon when viewing an outward wagon and no outwards info to show yet
					if (not lTIInward.isEmpty) and letterIndex &lt;= lTIInward.size then
						theTI := lTIInward[letterIndex];
						theColour := YRD_WagonArea.DisabledGrey_Light;
						theMode := REAL_MODE;
						tmpLetter := tmpLetter &amp; 'A';
					endif;
				endif;
			endif;
			if theTI &lt;&gt; null then
				if theTI &lt;&gt; theDummyTI then
					//self.drawOtherModeTI(pFrame, theMode, letterIndex, tmpLetter, theColour, self.x1, startY, self.x2, endY);
					self.drawOtherModeTI(pFrame, theMode, letterIndex, theTI, tmpLetter, theColour, self.newOffset(self.x1,myGA,theTI), startY, self.newOffset(self.x2,myGA,theTI), endY);
//					self.doDrawFMLetter(displayMode, letterIndex, White, startY, endY, theDummyTI, pFrame);
				endif;
			endif;			
		endif;
		//  Draw release in progress
		if theTI = null and theGridArea.YRD_WagonArea.isOutward then
			wagonLC := self.myLocationsController.CM_WagonController;
			while true do
				wleLoadIndex := wleLoadIndex + 1;
				if wleLoadIndex &gt; wagonLC.allRailWLELoad.size then
					break;
				endif;
				// allRailWLELoad lonly contains release request type WLEs
				wleLoad := wagonLC.allRailWLELoad[wleLoadIndex];
		//		if wleLoad.status &lt;&gt; WLE_COMPLETED and (wleLoad.myTrackedItem = null or wleLoad.myTrackedItem.isTBA) then	// PAR #23794
				if wleLoad.status &lt;&gt; WLE_COMPLETED and
				(wleLoad.myTrackedItem = null or wleLoad.myTrackedItem.isTBAorIsRRP or ( not wleLoad.myTrackedItem.isQueued and not wleLoad.myTrackedItem.isPlanned(PLANNING_MODE) ) )	//13 Jan 2017	NDL	YFS 3192/2877
				then
					if wagonLC.myPreviousController = null
					or not wagonLC.myPreviousController.allRailWLELoad.includes(wleLoad) then
						//self.drawRelease(pFrame, wleLoad, self.x1, startY, self.x2, endY);
						self.drawRelease(pFrame, wleLoad, self.newOffset(self.x1,myGA,theTI), startY, self.newOffset(self.x2,myGA,theTI), endY);
						break;
					endif;
				endif;
			endwhile;			
		endif;
	endforeach;

epilog
	delete lTIFiltered;
	delete lTIFilteredAttributeArray; 
	delete lTIInward;
end;</source>
        <Parameter name="pFrame" type="CMUI_GridAreaFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawSkeletonCarArm" id="f47e0e52-401f-4ee6-9525-95518b4c3c74">
        <source>drawSkeletonCarArm(_theFrame : CMUI_GridAreaFrame input; _numTIs: Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 September 2016	cnwmp6	Initial creation	TFS 2533

*/

vars

	startY : Real;
	endY : Real;
	startX,
	endX: Real;
	midpoint: Integer;
	logHeight: Integer;
	
begin

	startY 	:= self.getYPosFromIdx(1);
	endY	:= startY + self.cellHeight + 2;
	startX	:= self.x1;
	endX	:= self.x2;
	if self.boxcarLocIndex = 1 then
		startX := startX + ((endX - startX) * 0.375);
	endif;
	if self.boxcarLocIndex = 8 then
		endX := endX - ((endX - startX) * 0.375);
	endif;

	_theFrame.drawFillColor := Brown;
	if _numTIs &gt; 0 then
		logHeight := ((endY - startY) * .75).Integer;
		_theFrame.drawFilledRectangle(startX, endY - logHeight, endX, endY, Brown);
		_theFrame.drawLine(startX, endY - (logHeight * 0.33), endX, endY - (logHeight * 0.33), Black);
		_theFrame.drawLine(startX, endY - (logHeight * 0.67), endX, endY - (logHeight * 0.67), Black);
	endif;
	
	if self.myGridArea.YRD_WagonArea.myWagon.confirmed then
		_theFrame.drawFillColor := CM_SkeletonCarVisit.SkeletonCarDrawColour;
	else
		_theFrame.drawFillColor := YRD_WagonArea.DisabledGrey_Light;
	endif;
	
	midpoint := (self.x1 + (self.x2 - self.x1) / 2).Integer;
	
	if self.isSkeletonCarArm then
		_theFrame.drawFilledRectangle(midpoint - 2, endY, midpoint + 2, startY, Black);
	endif;
	
epilog

end;</source>
        <Parameter name="_theFrame" type="CMUI_GridAreaFrame" usage="input"/>
        <Parameter name="_numTIs" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawTI" id="2188b3c3-2236-449f-8ffa-649fe7e163aa">
        <updating/>
        <source>drawTI(_theFrame: CMUI_GridAreaFrame input; _theTI: CM_TrackedItem; 
		_theGridAttributes : CMUI_GridAttributes input;
		 _x1: Real; _y1: Real; _x2: Real; _y2: Real) protected, updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/05/2009	consw1		PAR 19710 - SFW1067 Rail Simplifications
// 24/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// 20/05/2015	cnwdap1		PAR #36206 TFS 324/334 Graphical Representation of Hazard Class and Special Stow
// ---------------------------------------------------------------------------
vars
	lOuterColourUpper, lOuterColourLower,lTIColour,lWeight,theTextWidth,theWeightWidth, theCharacterWidth : Integer;
	tmpIdx, tm_x2, tm_x1,tm_y1,tm_y2	: Real;
	tmpX1, tmpX2 : Real;
	lDisplayMode,idx,lViewMode : Integer;
	lFactor : Real;
	theAttibuteString : String;
	theDrawingAttribute : CM_DrawingAttribute;
	theHoleWidth, theFontSize : Integer;
	theGridArea : CMUI_GridArea;
	selOffSet : Integer;
	mySelf : SelfType;
	maxNumInStack : Integer;	//05 Dec 2014	NDL	Par 35345
	form : Form;	//05 Dec 2014	NDL	Par 35345
	selectedTI : CM_TrackedItem;	//05 Dec 2014	NDL	Par 35345
	selected : Boolean;	//05 Dec 2014	NDL	Par 35345
	haz : CM_TIHazard;									// PAR #36206
	hazClass : CM_HazardClass;							// PAR #36206
	specialStow : CM_SpecialStow;						// PAR #36206

begin
	mySelf := self;

	theGridArea := self.myGridArea;
	lFactor := theGridArea.scaleXFactor;
	lDisplayMode := theGridArea.mySDF.displayMode;
	lViewMode := theGridArea.mySDF.viewMode;
	_theFrame.drawFontName := "Arial";
	
	//05 Dec 2014	NDL	Par 35345
	selected := true;
	maxNumInStack := theGridArea.YRD_WagonArea.myWagon.myWagonClass.maxNumInStack;	//05 Dec 2014	NDL	Par 35345
	if maxNumInStack &gt; 1 then
		if self.myGridArea.mySDF &lt;&gt; null then
			form := self.myGridArea.mySDF.form;
			if form &lt;&gt; null and form.isKindOf( YRD_RailOperationsForm ) then
				selectedTI := form.YRD_RailOperationsForm.myCurrentTrackedItem;
				if not self.myGridArea.allSelectedPoints.isEmpty then
					if selectedTI = null or selectedTI &lt;&gt; _theTI then
						selected := false;
					endif;
				endif;
			endif;
		endif;
	endif;

	tm_y1 := _y1;
	tm_x1 := _x1;
	tmpX1 := _x1;
	tmpX2 := _x2;
	
	idx := _theGridAttributes.width ;
	if theGridArea.YRD_WagonArea.myWagon.isWellcarVisit and _theTI &lt;&gt; null and _theTI.isContainer then	//05 Dec 2014	NDL	Par 35345
		//CICE multistacking 45's and 53's -  only draw containers as 20's or 40's
		tmpIdx := self.adjustEndXForCargoMultiStack(_theTI, tmpX1, tmpX2);
	else
		tmpIdx := self.adjustEndXForCargoGetNumLCs(_theTI, tmpX1, tmpX2); // PAR 17263
	endif;
	tm_x2 := tmpX2; // PAR 17263

	if theGridArea.flipHorizontal then
		tm_x2 := tmpX1;
		tm_x1 := tm_x2 - ( tmpX2 - tmpX1 );
	endif;
	
	tm_x2 := tm_x2 - 1;
	tm_y2 := _y2 - 1;

	if _theTI.isKindOf(CM_Tower) then
		lTIColour := 33023; // ORANGE
	elseif self.disabledAppearance then
		lTIColour := YRD_WagonArea.DisabledGrey_Light;
	else
		lTIColour := _theGridAttributes.allDisplayColors[lViewMode];
	endif;

	if lTIColour = NullColour then
		lTIColour := White;
	endif;

	// if they have used the selector this will not be empty. If this TI is not in the selector collection then show in White
	if not theGridArea.mySDF.allSelectorTIs.isEmpty then
		if not theGridArea.mySDF.allSelectorTIs.includes(_theTI) then	
			lTIColour := White;
		endif;
	endif;
//	if myGridArea.allSelectedTrackedItems.includes(_theTI) then
//	if myGridArea.allSelectedPoints.includes(self) then
	if myGridArea.allSelectedPoints.includes(self) and selected then	//05 Dec 2014	NDL	Par 35345
		_theFrame.drawFillColor := White;
		_theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
		_theFrame.drawFilledRectangle(tm_x1, tm_y1, tm_x2, tm_y2,  White); 
		if lFactor = 1 then
			selOffSet := 2;
		elseif lFactor = 4 then
			selOffSet := 4;
		else
			selOffSet := 3;
		endif;
		tm_x1 := tm_x1 + selOffSet;
		tm_y1 := tm_y1 + selOffSet;
		tm_x2 := tm_x2 - selOffSet;
		tm_y2 := tm_y2 - selOffSet;
		
		lOuterColourUpper := DarkGray;
		lOuterColourLower := White;
		_theFrame.drawWidth := 1;
		_theFrame.drawStyle := Frame.DrawStyle_Solid; //DrawStyle_Dash;
	else
		lOuterColourUpper := White;
		lOuterColourLower := DarkGray;
		_theFrame.drawWidth := 1;
		_theFrame.drawStyle := Frame.DrawStyle_Solid;
	endif;

	_theFrame.drawFillColor := lTIColour;
	_theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
	_theFrame.drawFilledRectangle(tm_x1, tm_y1, tm_x2, tm_y2,  lTIColour); 
	_theFrame.drawLine(tm_x1, tm_y1, tm_x2 + 1, tm_y1 ,  lOuterColourUpper);
	_theFrame.drawLine(tm_x1, tm_y1, tm_x1, tm_y2,  lOuterColourUpper);
	_theFrame.drawLine(tm_x2, tm_y1 + 1, tm_x2, tm_y2 + 1,  lOuterColourLower);
	_theFrame.drawLine(tm_x1, tm_y2, tm_x2, tm_y2,  lOuterColourLower);

	_theFrame.drawWidth := 1;
	if _theTI.isKindOf(CM_Tower) then
		tm_x1 := tm_x1 + 3;
		tm_y1 := tm_y1 + 3;
		tm_y2 := tm_y2 - 3;
		tm_x2 := tm_x2 - 3;
		if lFactor = 2 then
			theHoleWidth := 7;
		elseif lFactor = 3 then
			theHoleWidth := 12;
		elseif lFactor = 4 then
			theHoleWidth := 16;
		elseif lFactor = 1.5 then
			theHoleWidth := 5;
		elseif lFactor = 1 then
			theHoleWidth := 4;
		endif;
		if lFactor &gt; 1 then
			// top Left
			_theFrame.drawEllipse1(tm_x1, tm_y1, tm_x1 + theHoleWidth, tm_y1 + theHoleWidth, Black);
			// top right
			_theFrame.drawEllipse1(tm_x2 - theHoleWidth , tm_y1, tm_x2, tm_y1 + theHoleWidth, Black);
		endif;
		// bottom left
		_theFrame.drawEllipse1(tm_x1, tm_y2 - theHoleWidth,tm_x1 + theHoleWidth, tm_y2, Black);
		// bottom right
		_theFrame.drawEllipse1(tm_x2 - theHoleWidth , tm_y2 - theHoleWidth, tm_x2, tm_y2, Black);
		return;
	endif;
	// work out the width of the rectangle and split up, to get the even width for the attribute characters
	if _theGridAttributes.width &lt; 1 then
		_theGridAttributes.width := 1;
	endif;

	theCharacterWidth := ((tm_x2 - tm_x1) / (2 * _theGridAttributes.width)).Integer;

	tm_x1 := tm_x1 + (theCharacterWidth / 2).Integer;
	tm_y1 := _y2;
	idx := 1;
	theFontSize := ((self.FontSize * lFactor)div 2).Integer;
	if lFactor &lt; 2 then
		theFontSize := 8;
	elseif lFactor = 2 then
		theFontSize := 10;
	elseif lFactor = 2.5 then
		theFontSize := 12;
	elseif lFactor = 3.0 then
		theFontSize := 14;
	elseif lFactor = 3.5 then
		theFontSize := 16;
	elseif lFactor = 4 then
		theFontSize := 18;
	endif;
	foreach theAttibuteString in _theGridAttributes.allDisplayIcons do
		theDrawingAttribute := null; //03 Aug 2015	NDL found during testing test case 01-381
		if theAttibuteString = PicTIHazard and _theTI &lt;&gt; null then						// PAR #36206
			haz := _theTI.getHazardFirst();												// PAR #36206
			if haz &lt;&gt; null then															// PAR #36206
				hazClass := haz.getClassObject;											// PAR #36206
				if hazClass &lt;&gt; null and hazClass.myDrawingAttribute &lt;&gt; null then		// PAR #36206
					theDrawingAttribute := hazClass.myDrawingAttribute;					// PAR #36206
				endif;																	// PAR #36206
			endif;																		// PAR #36206
		elseif theAttibuteString = PicSpecialStow and _theTI &lt;&gt; null then				// PAR #36206
			specialStow := app.myRoot.allSpecialStows[_theTI.specialStow];				// PAR #36206
			if specialStow &lt;&gt; null and specialStow.myDrawingAttribute &lt;&gt; null then		// PAR #36206
				theDrawingAttribute := specialStow.myDrawingAttribute;					// PAR #36206
			endif;																		// PAR #36206
		endif;																			// PAR #36206
		if theDrawingAttribute = null then												// PAR #36206
			theDrawingAttribute := theGridArea.mySDF.allDrawingAttributes[theAttibuteString];
		endif;																			// PAR #36206
		if theDrawingAttribute &lt;&gt; null then
			theTextWidth := self.drawTITextLeft(_theFrame,theDrawingAttribute.fontName,theFontSize,
						theDrawingAttribute.fontCharacter.Character,theDrawingAttribute.colour,
						tm_x1.Integer, _y1.Integer, _y2.Integer);

			tm_x1 := tm_x1 + theCharacterWidth;
			
			// Only 3 icons on a 20' and 6 on a 40'
			if (tm_x1 + theCharacterWidth).Integer &gt; (tm_x2 + (theCharacterWidth / 2).Integer) then
				break;
			endif;
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_theFrame" type="CMUI_GridAreaFrame" usage="input"/>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_theGridAttributes" type="CMUI_GridAttributes" usage="input"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawTransporter" id="f978bf11-6174-45c2-a1f8-ff0a5f5aefb1">
        <updating/>
        <source>drawTransporter( _theFrame : CMUI_GridAreaFrame input; numTIs : Integer ; _displayMode : Integer 
															; numTIs2 : Integer; _displayMode2 : Integer
															; numTIs3 : Integer; _displayMode3 : Integer) protected, updating;
/*

Purpose:		TFS 49523	

						The wagon length is based on X number of 10 foot lengths
						We draw in multiples of this unit, but we do not have to.

Return Value:		

Date		Who		Reason
4JUN2020 JLGAB1

*/

vars

	startY : Real;
	endY : Real;
	startX , endX : Real;
	
	xOffset : Integer;
	yOffset : Integer;
	yOffsetFnt : Integer;
	xOffsetFnt : Integer;
	lFactor : Real;
	
	increment : Real;
	newY : Real;
	wagonWidth, totalCols, controllerWidth : Integer;
	pointsArray : RealArray;
		
	colour1, colour2, colour3 : Integer;
	numTI2Str, numTI3Str : String;

begin

	if self.myGridArea.allGridPoints.first &lt;&gt; self then
		return;
	endif;
	lFactor := self.myGridArea.scaleXFactor;	

	self.getNumTIString(_displayMode2, numTI2Str, _displayMode3, numTI3Str);

	startY 	:= self.getYPosFromIdx(1);
	endY	:= startY + self.cellHeight + 2;
	startX := self.x1;
	
	if not self.myGridArea.YRD_WagonArea.myWagon.confirmed then
		colour1 := YRD_WagonArea.DisabledGrey_Light;
		colour2 := YRD_WagonArea.DisabledGrey_Light;
		colour3 := YRD_WagonArea.DisabledGrey_Light;
		
	else
		colour1 := YRD_WagonArea.DisabledGrey_Light;
		colour3 := CM_BoxcarVisit.TransporterDrawColour; 
	endif;
	
	_theFrame.drawWidth := 1;
	
	totalCols := self.myGridArea.allGridColumns.size;
	controllerWidth := (self.x2 - self.x1).Integer + 1;
	wagonWidth := (controllerWidth * totalCols).Integer;
	endX := wagonWidth;
	
	// BACKGROUND
	_theFrame.drawFillColor := colour1;
	_theFrame.drawFillStyle := Frame.DrawFillStyle_VertLine4;
	_theFrame.drawRoundRectangle(startX + 3 * lFactor, startY, endX - 1 * lFactor, endY, 3,5, colour1); 
	
	
	_theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
	create pointsArray transient;
	
	// UPPER DECK
	_theFrame.drawFillColor := colour3;
	pointsArray.add(startX); pointsArray.add(startY + 1 * lFactor);
	pointsArray.add(startX + 3 * lFactor); pointsArray.add(startY + 4.5 * lFactor);
	pointsArray.add(endX); pointsArray.add(startY + 4.5 * lFactor);
	pointsArray.add(endX); pointsArray.add(startY + 6 * lFactor);
	
	pointsArray.add(startX + 3 * lFactor); pointsArray.add(startY + 6 * lFactor);
	pointsArray.add(startX); pointsArray.add(startY + 3 * lFactor);
	pointsArray.add(startX); pointsArray.add(startY + 1 * lFactor);
	_theFrame.drawFilledPolygon(pointsArray,_theFrame.drawFillColor);
	
	pointsArray.clear;
	
	// RIGHT SUPPORT
	_theFrame.drawFillColor := colour3;
	pointsArray.add(endX - 8 * lFactor); pointsArray.add(startY + 4 * lFactor);
	pointsArray.add(endX - 5 * lFactor); pointsArray.add(startY + 4 * lFactor);
	pointsArray.add(endX - 2 * lFactor); pointsArray.add(endY);
	pointsArray.add(endX - 5* lFactor); pointsArray.add(endY);
	pointsArray.add(endX - 8 * lFactor); pointsArray.add(startY + 5 * lFactor);
	_theFrame.drawFilledPolygon(pointsArray,_theFrame.drawFillColor);
	
	pointsArray.clear;
	
	// LEFT SUPPORT
	_theFrame.drawFillColor := colour3;
	pointsArray.add(startX + 2 * lFactor); pointsArray.add(startY + 4 * lFactor);
	pointsArray.add(startX + 5 * lFactor); pointsArray.add(startY + 4 * lFactor);
	pointsArray.add(startX + 8 * lFactor); pointsArray.add(endY);
	pointsArray.add(startX + 5 * lFactor); pointsArray.add(endY);
	pointsArray.add(startX + 2 * lFactor); pointsArray.add(startY + 4 * lFactor);
	_theFrame.drawFilledPolygon(pointsArray,_theFrame.drawFillColor);
	
	pointsArray.clear;
	
	// ### ACTUAL PLANNED
	_theFrame.drawFontName := "Arial";
	_theFrame.drawFontBold := false;
	
	if lFactor &lt; 2.5 then
		_theFrame.drawWidth := 1;
	else
		_theFrame.drawWidth := 2;
	endif;
	
	_theFrame.drawFontSize := (3 * lFactor); 
	_theFrame.fontSize := _theFrame.drawFontSize;
	_theFrame.drawTextAlign := _theFrame.DrawTextAlign_Left;
	
	
    self.drawNumTIs(numTIs2, numTI2Str, numTIs3, numTI3Str, _theFrame, numTIs, lFactor, self.x1+ (5 * lFactor), startY, Black);
		
	self.drawGraffitiMTN(_theFrame,(totalCols - 3) * controllerWidth,startY + 1, wagonWidth);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_theFrame" type="CMUI_GridAreaFrame" usage="input"/>
        <Parameter name="numTIs" type="Integer"/>
        <Parameter name="_displayMode" type="Integer"/>
        <Parameter name="numTIs2" type="Integer"/>
        <Parameter name="_displayMode2" type="Integer"/>
        <Parameter name="numTIs3" type="Integer"/>
        <Parameter name="_displayMode3" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getBulkRelease" id="8441d18b-5452-47bb-8312-6b6c3be64353">
        <source>getBulkRelease(_x, _y : Real) : CM_BulkRelease;
// -----------------------------------------------------------------------------
// Created:		26 August 2009 by consw1
//
// Purpose:		Return the originating Bulk Release for the incomplete release
//				displayed at the given co-ordinates.
//
// Parameters:	x,y co-ordinates
//
// Returns:		Originating Bulk Release
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	idx : Integer;
	tmpY : Real;
	wagonLC : CM_WagonController;
	wleLoad : CM_WorkListEntry;

begin
	if not self.myGridArea.YRD_WagonArea.isOutward or self.getTI(_x,_y) &lt;&gt; null then
		return null;
	endif;
	
	idx := 1;
	tmpY := _y;
	
	while true do
		tmpY := tmpY + self.cellHeight;
		if tmpY &gt; self.y2 or self.getTI(_x,tmpY) &lt;&gt; null then
			break;
		endif;
		idx := idx + 1;
	endwhile;
	
	wagonLC := self.myLocationsController.CM_WagonController;
	
	if wagonLC.allRailWLELoad.size &lt; idx then
		return null;
	endif;
	
	wleLoad := self.myLocationsController.CM_WagonController.allRailWLELoad[idx];
	
	if wleLoad = null 
	or wleLoad.status = WLE_COMPLETED 
	or wleLoad.myTrackedItem &lt;&gt; null
	or wleLoad.myRequest = null then
		return null;
	endif;
	
	return wleLoad.myRequest.myOriginatingBulkRelease;

epilog

end;</source>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="getNumTIString" id="28e20a07-b7e2-4ca8-836e-92d8ed262158">
        <source>getNumTIString(_displayMode2 : Integer; numTI2Str : String io; _displayMode3 : Integer; numTI3Str : String io);
/*

Purpose:			TFS 49523

Parameters:			

Return Value:		

Date		Who		Reason
09 June 2020	jlgab1	Initial creation

*/

vars

begin
    if _displayMode2 = DISPLAY_MODE_ACTUAL then
		numTI2Str := "A";
	elseif _displayMode2 = DISPLAY_MODE_QUEUE then
		numTI2Str := "Q";
	else
		numTI2Str := "P";
	endif;	

	if _displayMode3 = DISPLAY_MODE_ACTUAL then
		numTI3Str := "A";
	elseif _displayMode3 = DISPLAY_MODE_QUEUE then
		numTI3Str := "Q";
	else
		numTI3Str := "P";
	endif;
end;
</source>
        <Parameter name="_displayMode2" type="Integer"/>
        <Parameter name="numTI2Str" type="String" usage="io"/>
        <Parameter name="_displayMode3" type="Integer"/>
        <Parameter name="numTI3Str" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getTI" id="fb76c589-d119-43c5-b0af-1e18b2b587c7">
        <source>getTI(x, y : Real) : CM_TrackedItem;
// ---------------------------------------------------------------------------
// Created:     22 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 02/07/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	theTI	: CM_TrackedItem;
	rtnStr	: String;
	tmpYPos	: Real;
	numTIs,
	idx		: Integer;
	lTIArray : CM_TIArray;
	lTIFiltered	: CM_TIArray;
	lDisplayMode : Integer;
begin
	create lTIArray transient;
	
	if self.myLocationsController = null then
		return theTI;
	endif;

	lDisplayMode := self.myGridArea.mySDF.displayMode;

	if lDisplayMode = DISPLAY_MODE_ACTUAL then
		self.myLocationsController.getTIs(lTIArray, REAL_MODE, true); // PAR 27749
	elseif lDisplayMode = DISPLAY_MODE_QUEUE then
		self.myLocationsController.getTIs(lTIArray, QUEUE_MODE, true); // PAR 27749
	elseif lDisplayMode = DISPLAY_MODE_PLAN then
		self.myLocationsController.getTIs(lTIArray, PLANNING_MODE, true); // PAR 27749
	else
		self.myLocationsController.getTIs(lTIArray, REAL_MODE, true); // PAR 27749
	endif;

	if self.myGridArea.YRD_WagonArea.isOutward and lDisplayMode = DISPLAY_MODE_ACTUAL then
		//  Received TIs are not shown when viewing an outward wagon
		create lTIFiltered transient;
		foreach theTI in lTIArray where self.myGridArea.YRD_WagonArea.myWagon.isTIOutward(theTI) do
			lTIFiltered.add(theTI);
		endforeach;
		lTIArray.clear;
		lTIFiltered.copy(lTIArray);
		theTI := null;
	endif;

	if lTIArray.size = 0 then
		return theTI;
	endif;
	
	numTIs := lTIArray.size;
	foreach idx in 1 to numTIs do
		tmpYPos := self.getYPosFromIdx(idx);
		if y &gt;= tmpYPos then
			theTI := lTIArray[idx];
			break;
		endif;
	endforeach;
	
	return theTI;
epilog
	delete lTIArray;
	delete lTIFiltered;
end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getTIDetails" id="d9ec1e98-ed8f-4a84-9b1a-6da984dfbe4e">
        <source>getTIDetails(x, y : Real) : String;
// ---------------------------------------------------------------------------
// Created:     22 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theTI	: CM_TrackedItem;
	rtnStr	: String;
	tmpYPos	: Real;
	numTIs,
	idx		: Integer;
	
begin

	theTI := self.getTI(x, y);
	
	if theTI &lt;&gt; null then	
		rtnStr := theTI.id ;
		if theTI.isKindOf(CM_Container) then
			rtnStr := rtnStr &amp; " - " &amp; theTI.CM_Container.isoType;
			
		endif;
		//rtnStr := rtnStr &amp; ", " &amp; theTI.cargoTypeDescr; // &amp; " (" &amp; theTI.String &amp; ")";
//		theTI.inspect;
	endif;
	
	return rtnStr;

end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="newOffset" id="d3e2bd93-48b5-4ba0-b2d5-62340cf42923">
        <source>newOffset(_value : Real; _ga : CMUI_GridArea; _ti : CM_TrackedItem) : Real;
// --------------------------------------------------------------------------------
// Created:		11 December 2009 by cnwjo3
//
// Purpose:		If a Rail Area is flipped then need to change the offset of the starting points of the TI on the wagon.
//				par 21929
//
//21 Nov 2016 cnwrs1	Par 37738 TFS 2949 incorrect UPSP rail location being displayed
constants
	TI20	: Real = 10;
	TI40	: Real = 30;
	TISMALL	: Real = 1;
vars
	newValue : Real;
	is40 : Boolean;
	isGen : Boolean;
	isLCL : Boolean;
	scaleFactor : Real;
	is20 : Boolean;
	invalid : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, _ti, invalid);		 // PAR 37738
	if _ti &lt;&gt; null then
		is20 := _ti.is20;	//09 Dec 2014	NDL	Par 35345
		if invalid then
			return 0;
		endif;
		is40 := _ti.isForty();
		isGen := _ti.isKindOf(CM_Generator);
		isLCL := _ti.isKindOf(CM_LCL);
	endif;
	scaleFactor := _ga.mySDF.scaleFactor;
	
	newValue := _value;
	
	if _ga.flipHorizontal then
		if isGen or isLCL then
			newValue := newValue + TISMALL * scaleFactor;
	/*	elseif is40 then
			newValue := newValue + TI40 * scaleFactor;
		elseif not is40 then
			newValue := newValue + TI20 * scaleFactor; */
		//09 Dec 2014	NDL	Par 35345
		elseif is20 then	
			newValue := newValue + TI20 * scaleFactor;
		else
			newValue := newValue + TI40 * scaleFactor;
		endif;
	endif;
	
	return newValue;
end;</source>
        <Parameter name="_value" type="Real"/>
        <Parameter name="_ga" type="CMUI_GridArea"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="d90e7def-0b1c-4d41-b34e-186faccf4f51">
        <updating/>
        <source>setForCreate(pController : CM_WagonController; pWagonRow : YRD_WagonRow;
			 pWagonCol : YRD_WagonColumn; pGridArea : YRD_WagonArea; 
			 maxStackHeight : Integer; _controller : CMIF_DrawingAttrController input) updating;
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theTIs : CM_TIArray;
	aColour, idx : Integer;
	aLetter : String;
	aTI : CM_TrackedItem;
begin

	self.myLocationsController := pController;
	create theTIs transient;

	// Get all the TIs that are actually here
	theTIs.clear;
	self.myLocationsController.getTIs(theTIs, REAL_MODE, true); // PAR 27749
	// Only include those TIs where my controller is their primary location
	foreach aTI in theTIs do
		self.setForCreateTI(aTI, REAL_MODE, _controller);
		if aTI.getPrimaryLocation(REAL_MODE) = self.myLocationsController then
//			idx := aTI.allLocations.indexOf(self.myLocationsController);
			self.allTrackedItems.add(aTI);
		else
			// add in the dummy TI, this allows us to draw correctly for TIs spanning more than one point
			self.allTrackedItems.add(pGridArea.myDummyTI);
		endif;
		
	endforeach;

	// Get all the TIs that are QUEUED here
	theTIs.clear;
	self.myLocationsController.getTIs(theTIs, QUEUE_MODE, true); // PAR 27749
	// Only include those TIs where my controller is their primary location
	foreach aTI in theTIs do
		self.setForCreateTI(aTI,QUEUE_MODE, _controller);
		if aTI.getPrimaryLocation(QUEUE_MODE) = self.myLocationsController then
			self.allQueuedTrackedItems.add(aTI);
		else
			// add in the dummy TI, this allows us to draw correctly for TIs spanning more than one point
			self.allQueuedTrackedItems.add(pGridArea.myDummyTI);
		endif;
	endforeach;

	// Get all the TIs that are PLANNED here
	theTIs.clear;
	self.myLocationsController.getTIs(theTIs, PLANNING_MODE, true); // PAR 27749
	// Only include those TIs where my controller is their primary location
	foreach aTI in theTIs do
		self.setForCreateTI(aTI,PLANNING_MODE, _controller);
		if aTI.getPrimaryLocation(PLANNING_MODE) = self.myLocationsController then
			self.allPlannedTrackedItems.add(aTI);
		else
			// add in the dummy TI, this allows us to draw correctly for TIs spanning more than one point
			self.allPlannedTrackedItems.add(pGridArea.myDummyTI);
		endif;
	endforeach;


//	self.myLocationsController.getDrawingAttributes(null,null,null,aColour, aLetter);	
	self.colour := aColour;
	self.letter := aLetter;
	self.power := self.myLocationsController.hasPower();
	
	self.heightOfStack := maxStackHeight;	// Need to determine what this should be set to!
	self.myLocationsController := pController;
	self.myGridColumn 	:= pWagonCol;
	self.myGridRow		:= pWagonRow;
	
	self.myGridArea 	:= pGridArea;
epilog
delete theTIs;
end;</source>
        <Parameter name="pController" type="CM_WagonController"/>
        <Parameter name="pWagonRow" type="YRD_WagonRow"/>
        <Parameter name="pWagonCol" type="YRD_WagonColumn"/>
        <Parameter name="pGridArea" type="YRD_WagonArea"/>
        <Parameter name="maxStackHeight" type="Integer"/>
        <Parameter name="_controller" type="CMIF_DrawingAttrController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="e7634e19-a943-4547-aa15-376ea8da78d2">
        <updating/>
        <source>setForUpdate(_controller : CMIF_DrawingAttrController input) updating;
// ---------------------------------------------------------------------------
// Created:		12 August 2003 by cnwsgp1
// ---------------------------------------------------------------------------
begin
	inheritMethod(_controller);

	self.setTrackedItems(_controller);
	self.myGridArea.mySDF.myParentForm.sendMsgWithParams("doNoteForObject", self); // this will update the macro info table
end;</source>
        <Parameter name="_controller" type="CMIF_DrawingAttrController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setGraffitiBish" id="c30ba5a9-ace3-4336-8127-0dc8775639e5">
        <updating/>
        <source>setGraffitiBish(_pic : CMUI_Picture) updating;
/*
Purpose:	TFS 49523		
Date				Who			Reason
JUNE 2020		JLGAB1 initial creation
*/



vars

begin

	self.graffitiBish := _pic;

epilog

end;</source>
