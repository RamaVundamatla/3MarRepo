    <JadeMethod name="actionForCreateInternal" id="f73f253a-cd51-4c40-b7b2-b4d45ee190d2">
        <updating/>
        <source>actionForCreateInternal(_vvRec : CM_VehicleVisitRecord input; _passport: CM_Passport input; _pxyTI : CM_TrackedItem input): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     25 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 25/03/2010		cnwdap1			PAR #22938 need to udpate proxy TI passed in
// 29/03/2010		cnwdap1			PAR #23355 Need to relink tracked items with gte_entities, as these links get broken when processing children
// 24/03/2014		cnwdap1			PAR #33606 CCMS SFW 1366 Bulk - same rules for prenotes as break-bulk
// 30/04/2015		cnwdap1			PAR #36094 CCMS SFW 1413 TFS 313 Cold Store Enhancements
// 30/06/2015		cnwdap1			PAR #36421 Hazardous Materials Handling
// 10/11/2015		cnwma1			PAR #36754 1210 in CM_TrackedItem::matchTBA and  CM_RoadJob::updateReleaseTI
// 30/12/2015       cnwma1			PAR #37331 Assigning TBA Numbers to Containers
// 23/09/2016		cnwdap1			TFS 2651 - new parameter for moveToLocation, pass in document actions from booking item
// 27 Feb 2018		cnwma1 			ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers
// 01/03/2019		jlgzm1			TFS 43611 - SNO VGM process weighed transaction not charged
// 11/03/2019		jlgzm1			TFS 43748 - SNO Weighed transaction charging the default debtor, not updating from gate values
// 14/11/2019		jlgdap1			TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
// 27/09/2021		navdap1			TFS 52081 MTN Cannot Add Reading for a Reefer for a time other than Now
// 15/10/2021		navdap1			TFS 51935 SAL Direct Loading Partial Prenoted Cargo from Truck to Vessel
// 07/12/2021		navdap1			TFS 52293 SAL Direct Loading - Marking Job as Direct Delivery
// 11/01/2022		navpw1			TFS: 52631 Added Backdating for VVR transactions
// 04/03/2022		navdap1			TFS 52690 MTN Direct Delivery check box ticked/unticked on Road Gate Receive form not working
// 17/05/2022		jlizm1			TFS 53084 GPHA revceival/release of tranship cargo
// 27/03/2023		navkc1			Task CR#57036 57221: Jade - Move New Cargo to Trailer Not Pack
// 06/04/2023		navkc1			CR# 56431 Task 56438: UI - Cargo Enquiry
// 25/01/2024	 	navra1  		TFS 62081 - CUX | Auto-setdown of cargo that doesn't require a machine move
// 05/02/2023		navkc1 			Bug 62302: CUX | Can't mark onboard or child cargo as 'overlanded'
// ---------------------------------------------------------------------------

vars
	
	roadJob 		: CM_RoadJob;
	chassisTI,
	transferTI,
	pxyTI			: CM_TrackedItem;
	txnParams		: CMIF_TITransactionController;
	moveLC,
	plannedLocn,
	chassisLC : CM_LocationsController;
	subItem 		: CMGTE_Entity;
	theCargoType	: CM_CargoType;
	tiUpdateCntrlr 	: CMIF_TIUpdateController;
	moveMode, moveType: Integer;
	chassis, lastChassis	: CM_TILC;
	photo			: CM_Attachment;
	tempParams 		: CMIF_TempReading;			// PAR #36094
	newPxy			: CM_TrackedItem;			// PAR #36094
	load			: Boolean;					// PAR #36094
	invalidJob 		: Boolean;
	edition    		: Integer;
//	control : CMIF_MoveController;
	documentAction 	: CM_DocumentActions;		// TFS 2651
	splitWeight : Decimal[16,4];	//29 Aug 2018	NDL	TFS 39769
	prenoteTI : CM_TrackedItem;
	tiTrans 		: CM_TITransaction; 		//TFS 43611
	weighedTrans    : CM_TITransaction;			//TFS 43611
	bu				: CM_Bank;					//TFS 43611
	resyncContrlr	: CMIF_TiTransactionResync;	//TFS 43611
	aspaRoadProcess : Boolean;	//07 Oct 2020	NDL	TFS 49189
	effectiveTS : TimeStamp;	//07 Oct 2020	NDL	TFS 49189
	pxyForTempReading : CM_TrackedItem;	//01 Sep 2021	NDL	TFS 51874
	wle : CM_WorkListEntry;			// TFS 52293
	copyWLEsForDD : Boolean;		// TFS 52293
	clearDirectDelivery : Boolean;		// TFS 52690
	childTi,
	myTI			: CM_TrackedItem;	// 28/03/2023 navkc1 #57221
	moveToParentTrailer : Boolean;		// 28/03/2023 navkc1 #57221
	childTiID		: String;
begin

	// Should be called on a persistent instance
	if self.isTransient then
		app.raiseUnexpectedProgramError(class.name, method.name, 'persisent method called for transient object');
		return false;
	endif;
	
	//07 Oct 2020	NDL	TFS 49189
	aspaRoadProcess := self.getVehicleVisitRecord.myTerminal.roadProcessIsASPA;	
	if aspaRoadProcess and self.myVehicleVisitRecord &lt;&gt; null and self.myVehicleVisitRecord.timeIn.Date.isValid then
		effectiveTS := self.myVehicleVisitRecord.timeIn;
	else
		effectiveTS := null;
	endif;

	if aspaRoadProcess then
		//doesn't use jobs or wles
	else
		roadJob := self.getVehicleVisitRecord.myRoadJob;
		
		if roadJob = null then
			return false;
		endif;
		
		on Exception do app.handleDeletedObject(exception, roadJob, invalidJob);   // 10/11/2015 cnwma1 PAR #36754
		edition :=roadJob.edition;
		if invalidJob then 
			return false; 
		endif;
	endif;
	
	if (self.myTrackedItem &lt;&gt; null and self.myTrackedItem.directDelivery and not self.directDelivery) 	// TFS 52690
	 // ### TFS 53720 26MAY2022 NAVAB1 - removed the first 'not' in 	or (_pxyTI &lt;&gt; null and not _pxyTI.directDelivery and not self.directDelivery) then					// TFS 52690
	or (_pxyTI &lt;&gt; null and _pxyTI.directDelivery and not self.directDelivery) then					// TFS 52690
		clearDirectDelivery := true;																	// TFS 52690
	endif;																								// TFS 52690
	
	theCargoType := app.myRoot.allCargoTypesById[self.cargoType];
	if theCargoType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'cargo type', 'cargoType', null);
		if self.isTrailer then	//14 Oct 2020	NDL	TFS 49189
			app.raiseCMException(Must_select_type_trailer, 'trailer cargoType', self);
		else
			app.raiseCMException(Input_required_field_cargoType, 'cargoType', null); // cnwdb2	PAR 35364
		endif;
		return _passport.noErrors();
	endif;
	
	tiUpdateCntrlr := app.createTIUpdateControl( TI_UPDMODE_RECEIPT, app.myPassport.userCode, null );
	if self.isFromPrenote and self.myTrackedItem &lt;&gt; null then
		prenoteTI:= self.myTrackedItem;		
		// All Inter Terminal Transfers are pre-noted
		transferTI := self.myTerminal.lookupTrackedItem(self.id, self.cargoType, TI_STATE_TRANSFER, null, false);
	
		if transferTI &lt;&gt; null and _pxyTI &lt;&gt; null then
			transferTI.setForTransitReceival(_pxyTI, _passport.myTerminal);
			self.myTrackedItem  := _passport.myTerminal.createTrackedItem(_pxyTI, _passport);
		else
			
					
			pxyTI := _pxyTI;
			//25 Feb 2016	NDL	Par 37589
			if pxyTI = null or self.myTrackedItem.myParent &lt;&gt; null then		
				//its a child, it the parent has been updated any existing child proxy will be out of date. (Apart from which it is never passed in...)
				//OR if we wer going to unconditionally create it, any existing one should be deleted.
				pxyTI := self.myTrackedItem.pxyGetProxyObject();
				delete pxyTI;
				pxyTI := app.createUpdateProxy(self.myTrackedItem).CM_TrackedItem;
			endif;
			
			//CCMS 2274 Break-bulk changes
			//if prenote total quanity is greater than receival num items and prenote is Break-bulkGeneric that allows duplicates then couple differnt things must happen
			// have to delink proxy from prenote ti will need to still have the prenote ti and the onsite ti
			// after new ti moved onsite update prenote ti total quantity less onsite ti total quantity
			//if self.myTrackedItem.canSplitTotalQuantity and self.myTrackedItem.totalQuantity &gt; self.totalQuantity then		// PAR #33606
			if self.myTrackedItem.canSplitTotalQuantity and 																	// PAR #33606
			((self.myTrackedItem.isBulkCargo and self.myTrackedItem.myCargoType.isTrackByWeight and self.myTrackedItem.totalWeight &gt; self.weightTotal) or			// PAR #33606
			(self.myTrackedItem.isBulkCargo and  self.myTrackedItem.myCargoType.isTrackByVolume and self.myTrackedItem.totalVolume &gt; self.volumeTotal) or		// PAR #33606
			(self.myTrackedItem.myCargoType.isBulkByQuantity and self.myTrackedItem.totalQuantity &gt; self.totalQuantity)) then		//epr TFS 40599  31/8/18															// PAR #33606
				//have to unlink if there is a pxy
				app.myProxyManager.deleteProxyLink(pxyTI);
				
				
				//29 Aug 2018	NDL	TFS 39769 - do a split as a pre-note so we get all the std transactions
				if self.myTrackedItem.myCargoType.isBulkMulti and not self.myTrackedItem.myCargoType.isTrackByWeight then
					splitWeight := self.volumeTotal * self.myTrackedItem.getDensity;				
				else
					splitWeight := self.weightTotal;
				endif;	
				
				app.myUtilityUA.utlSplitBreakBulkToNewID(	self.myTrackedItem.CM_Cargo,	//_sourceTi : CM_Cargo io;
															self.myTrackedItem.id,	//_newId : String; 
															self.myTrackedItem,	//_newTi : CM_Cargo output; 
															self.totalQuantity,	//_quantity : Integer;
															splitWeight,	//_weight : Decimal;
															self.myTrackedItem.myOperator,	//_operator : CM_Operator; 
															true,	//_includeStops : Boolean;
															true,	//_includeToDo : Boolean;
															true,	//_includeDamage : Boolean;
															true,	//_includeHaz : Boolean;
															effectiveTS, //_effectiveTS : TimeStamp;
															_passport	//_passport : CM_Passport input
															);
				
				if clearDirectDelivery then									// TFS 52690
					self.myTrackedItem.setDirectDelivery(false, false);		// TFS 52690
				endif;														// TFS 52690
				
			else		
				// Do nothing as the pre-note has already been validated
				// PAR #22938 actually need to do something here now because of changes to handle attachments
				// we now have a _pxyTI passed through from the receival screen, so need to update it
				pxyTI.setPxyFromCMGTE_Receival(self, _passport);
				self.deleteRemovedChildrenFromTI(pxyTI);									// cnwjk3 PAR 23476 30/03/10
				// cnwer1 this is done as part of self.validateForCreate which is always called before this method means we get warnings twice
				if not pxyTI.isValid then
					pxyTI.validateTrackedItem(tiUpdateCntrlr, app.myPassport );			
				endif;
				self.myTrackedItem.setForUpdate(pxyTI, tiUpdateCntrlr, null, true, _passport);
			endif;
		endif;
	else

		if _pxyTI &lt;&gt; null then
			// The pxyTI will have already been validated, so don't repeat
			self.myTrackedItem := _passport.myTerminal.createTrackedItem(_pxyTI, _passport);
			
			
			
		else
			pxyTI := self.myTerminal.createTI(theCargoType, true);
		
			if pxyTI = null then
				app.raiseUnexpectedProgramError(class.name, method.name, 'pxyTI not found');
				return false;
			endif;

			self.setPxyTiFromRealGTE(pxyTI, _passport);
			pxyTI.validateTrackedItem(tiUpdateCntrlr, app.myPassport );	
			self.myTrackedItem := _passport.myTerminal.createTrackedItem(pxyTI, _passport);
		endif;
		
		if self.myTrackedItem &lt;&gt; null and app.myRoot.allowTranshipInterModal and self.myTrackedItem.isTranshipItem then	// TFS 53084
			self.myTrackedItem.setTransitStatus(TI_TransitStatusInterModal, true, _passport);							// TFS 53084
		endif;
	endif;
	
	// Warnings must be acknowledged before autoplanning can happen
	if _passport.hasErrors then 
		return false;
	endif;
	
	if _passport.noErrors() then
		foreach photo in self.allAttachments do
			photo.setMyParent(self.myTrackedItem);
		endforeach;
		
	endif;
	
	if _passport.noErrors() and self.damaged then
		// Create damaged transaction.
		create txnParams transient;
		txnParams.type		:= TRANS_TYPE_DAMAGED;
		txnParams.noCharge	:= true;
		//07 Oct 2020	NDL	TFS 49189
		if effectiveTS &lt;&gt; null and effectiveTS.Date.isValid then
			txnParams.dateTime := effectiveTS;
		endif;
		
		self.myTrackedItem.createTransaction(txnParams, _passport);
	endif;

	// 29/05/2009 cnwar2 CCMS1040/#19796
	if self.myTrackedItem.myVoyage &lt;&gt; null then
		if (self.myTrackedItem.cutoffTS.isValid and self.myTrackedItem.cutoffTS &lt; app.actualTimeServer)
		or (self.myTrackedItem.earliestReceivalTS.isValid and self.myTrackedItem.earliestReceivalTS &gt; app.actualTimeServer) then
			// create receival outside restriction transaction
			if txnParams = null then
				create txnParams transient;
			endif;
			txnParams.type := TRANS_TYPE_Rec_Outside_Restric;
			txnParams.myTrackedItem := self.myTrackedItem;
			//07 Oct 2020	NDL	TFS 49189
			if effectiveTS &lt;&gt; null and effectiveTS.Date.isValid then
				txnParams.dateTime := effectiveTS;
			endif;
			self.myTrackedItem.createTransaction(txnParams, app.myPassport);

		endif;
	endif;
	
	// PAR #36094 If receival temperature is set on me, and my TI has no temperature readings, create one
	// Except for pre-notes
	if self.receivalTemperature &lt;&gt; NULL_TEMPERATURE and self.myTrackedItem.getReceivedTemperature = NULL_TEMPERATURE then
		if not self.myTrackedItem.isPreNote then
			create tempParams transient;
		/*	tempParams.isRefConReading := false;
			tempParams.isRefConAlarm := false;
			tempParams.refConRawData := null;
			tempParams.dateTime := app.actualTimeServer;
			tempParams.noCharge := false;
			tempParams.userId := app.getMyUserCode();
			tempParams.myTerminal := self.myTerminal;
			tempParams.temperature := self.receivalTemperature;
			//07 Oct 2020	NDL	TFS 49189
			if effectiveTS &lt;&gt; null and effectiveTS.Date.isValid then
				tempParams.dateTime := effectiveTS;
			endif;
			if _pxyTI &lt;&gt; null and _pxyTI.pxyIsProxy then
				tempParams.myTrackedItem := _pxyTI;
			elseif pxyTI &lt;&gt; null and pxyTI.pxyIsProxy then
				tempParams.myTrackedItem := pxyTI;
			else	
				app.cmsBeginLoad(load);
				newPxy := self.myTrackedItem.pxyCreateUpdateProxy();
				app.cmsEndLoad(load);
				tempParams.myTrackedItem := newPxy;
			endif; */
			
			//01 Sep 2021	NDL	TFS 51874
			if _pxyTI &lt;&gt; null and _pxyTI.pxyIsProxy then
				pxyForTempReading := _pxyTI;
			elseif pxyTI &lt;&gt; null and pxyTI.pxyIsProxy then
				pxyForTempReading := pxyTI;
			else	
				app.cmsBeginLoad(load);
				newPxy := self.myTrackedItem.pxyCreateUpdateProxy();
				app.cmsEndLoad(load);
				pxyForTempReading := newPxy;
			endif;
			//01 Sep 2021	NDL	TFS 51874 - Use common code instead of 14 different variant copies....
			tempParams.initialise( 	pxyForTempReading,	//_reefer : CM_TrackedItem;
									false,	//_defaultNoChargeValue : Boolean;
									app.actualTimeServer,	//_dateTime : TimeStamp;		// TFS 52081
									self.receivalTemperature	//_temperature : Real
									);
			
			if effectiveTS &lt;&gt; null and effectiveTS.Date.isValid then
				tempParams.dateTime := effectiveTS;
			endif;
			
			app.myUtilityCA.utlCreateTempReading(tempParams, _passport);
		endif;
	endif;
	// PAR #36094 end
	
	if _passport.noErrors() then 
		// PAR #23355 rebuild the link between children and their tracked items - this has been broken 
		// by CM_TrackedItem::setChildrenForUpdate on the parent, which deletes all children 
		// and recreates them
		if self.isFromPrenote and not self.allChildren.isEmpty then
			self.rebuildChildLinks();
		endif;
		
		myTI := self.myTrackedItem; // 28/03/2023 navkc1 #57221
		moveToParentTrailer := self.myTerminal.getConfig(MoveTIToParentTrailer).Boolean and myTI &lt;&gt; null and myTI.isChassis(); // 28/03/2023 navkc1 #57221
		
		foreach subItem in self.allChildren discreteLock  do
			// 28/03/2023 navkc1 #57221
			if not subItem.actionForCreateChildren(self.myVehicleVisitRecord, _passport,null, moveToParentTrailer) then
				break;
			endif;
		endforeach;
	endif;

	// PAR #36421 Update hazardous details on parent from the details on all children
	self.myTrackedItem.setHazardsFromChildren();
	
	// TFS 46405 Check flat rack status on parent/children
	if self.myTrackedItem.isContainer then
		self.myTrackedItem.CM_Container.setFlatEndDirection();
	endif;
	// TFS 46405 end
	
	if self.myParent &lt;&gt; null and self.myParent.CMGTE_Receival.imexStatus &lt;&gt; TI_IMEX_STATUS_REMAINONBOARD then // attachments are moved with parent
		return true;
	endif;
	
	// ###################
	// ### MOVE CARGO TO TRUCK
	// ###################
	if _passport.noErrors() and  self.myParent = null then 

		if self.myVehicleVisitRecord.myInCMGTE_Chassis &lt;&gt; null and self &lt;&gt; self.myVehicleVisitRecord.myInCMGTE_Chassis then
			chassis:=self.myVehicleVisitRecord.myInCMGTE_Chassis.myTrackedItem.CM_TILC;
		endif;
		
		if chassis &lt;&gt; null then
			//if we are moving chassis on a chassis should stack them on the last 
			if self.myTrackedItem.isChassis then
				lastChassis:=chassis;
				//epr par 32560 25/9/13 when receiving multiple chassis on a chassis - stack them 
				while chassisLC = null do
					chassisTI:=lastChassis.allLCs.first.allTrackedItems.first;
				
					if chassisTI &lt;&gt; null and chassisTI.isKindOf(CM_TILC) then
						lastChassis:=chassisTI.CM_TILC;
					else
						chassisLC:=lastChassis.getNextFreeLC();
						break;
					endif;
				endwhile;
			endif;
			
			if chassisLC = null then
			
				//get first free lc controller
				chassisLC:=chassis.getNextFreeLC();
			endif;
			
			if chassisLC = null then
				//raise exception trying to bruing in more containers on this chassis than room
				app.raiseCMException1(Move_WillBeOverCap,chassis.id,null,null);
				return null;
			endif;
		endif;
		
		if chassisLC &lt;&gt; null then
			moveLC :=chassisLC;
		else
			//moveLC :=  roadJob.myVehicle.locationsController;
			moveLC := self.getVehicleVisitRecord.vehicle.locationsController; //07 Oct 2020	NDL	TFS 49189
		endif;
		//epr CCMS 1409 par 35553 22/1/15 needed the roadJob
		//self.myTrackedItem.moveToLocation( moveLC, roadJob, null, null,REAL_MODE, false, true, false, false, false,   false,null, null,_passport);				// TFS 2651
		if self.myTrackedItem.myBookingRefItem &lt;&gt; null and self.myTrackedItem.myBookingRefItem.myBookingRefItemActions &lt;&gt; null then									// TFS 2651
			documentAction := self.myTrackedItem.myBookingRefItem.myBookingRefItemActions;																			// TFS 2651
		endif;
		
		self.myTrackedItem.moveToLocation( moveLC, roadJob, null, null,REAL_MODE, false, true, false, false, false,   false,null, null, documentAction, effectiveTS, self.getVehicleVisitRecord, _passport);	// TFS 2651
		self.myTrackedItem.setHazardLocationsForMode(REAL_MODE, false);
		
		//27.02.2018 cnwma1 ChangeRequest #36813
		if self.myTrackedItem.getGenerator &lt;&gt; null then
			self.myTrackedItem.getGenerator.changeState(self.myTrackedItem.state,_passport);
		endif;
		//27.02.2018 cnwma1 ChangeRequest #36813
		
		if clearDirectDelivery then							// TFS 52690
			self.myTrackedItem.unplanDirectDelivery();		// TFS 52690
		endif;												// TFS 52690
	endif;
	
	//07 May 2014	NDL	Par 34076
	if _passport.noErrors then
		if not self.allSealCheckDetails.isEmpty then
			self.myTrackedItem.setSealCheckTransFrom( self, _passport );
		endif;
	endif;
	
	//tfs43611
	tiTrans := self.myTrackedItem.getLastTransOfClass(CM_Weighed);
	// if the last weigh transaction was for a prenote
	if tiTrans &lt;&gt; null and tiTrans.state = TI_STATE_NOTIFIED then
		weighedTrans := tiTrans.CM_Weighed;
		//resync the transaction now that the cargo is onsite, to create charges
		create resyncContrlr transient;	
		//resync everything except for weight //tfs43748 begin
		resyncContrlr.myTrackedItem := self.myTrackedItem;
		resyncContrlr.updateBusinessUnit := true;
		resyncContrlr.updateCommodity := true;
		resyncContrlr.updateConsignee := true;
		resyncContrlr.updateConsignor := true;
		resyncContrlr.updateContents := true;
		resyncContrlr.updateCustomsAgent := true;
		resyncContrlr.updateDestinationPort := true;
		resyncContrlr.updateDischargePort := true;
		resyncContrlr.updateFreightForwarder := true;
		resyncContrlr.updateImexStatus := true;
		resyncContrlr.updateOperator := true;
		resyncContrlr.updateQuantity := true;
		resyncContrlr.updateVolume := true;
		
		weighedTrans.setForUpdateResync(resyncContrlr, _passport); //tfs43748 end
	endif;
	//tfs43611 end
	
	if aspaRoadProcess then	//07 Oct 2020	NDL	TFS 49189
		return true;
	endif;
	
	// ###################
	// ### CREATE MY REQUEST
	// ###################
	if _passport.noErrors then
		if not self.createRequest(_passport) then
			return false;
		endif;
	endif;
	
	if self.moveToTruckOnly then	// 03 Jun 2010	NDL	Par 23903 - Only want the item created on the truck, not moved to the planned location.
		return true;
	endif;

	if _passport.noErrors then
		// TFS 51935 if prenote and direct delivery, and terminal is configured for direct truck loading to voyage,
		// don't plan the cargo but copy the future planned moves from the prenote to the road job
		//if prenoteTI &lt;&gt; null and prenoteTI.directDelivery then							// TFS 52293	// TFS 52690
		if prenoteTI &lt;&gt; null and prenoteTI.directDelivery and not clearDirectDelivery then	// TFS 52293	// TFS 52690
			foreach wle in prenoteTI.allWorklistEntries do		// TFS 52293
				if wle.job.isDirectDeliveryJob then				// TFS 52293
					copyWLEsForDD := true;						// TFS 52293
					break;										// TFS 52293
				endif;											// TFS 52293
			endforeach;											// TFS 52293
		endif;													// TFS 52293
		//if self.myParent = null and self.myTrackedItem.getImExStatus &lt;&gt; TI_IMEX_STATUS_REMAINONBOARD and self.myTerminal.getConfig(DirectTruck2VesselMult).Boolean then	// TFS 52293
		if self.myParent = null and self.myTrackedItem.getImExStatus &lt;&gt; TI_IMEX_STATUS_REMAINONBOARD and copyWLEsForDD then	// TFS 52293
			self.directDeliveryCopyWLEs(roadJob, prenoteTI);
		// TFS 51935 end
		elseif self.myParent = null and self.myTrackedItem.getImExStatus &lt;&gt; TI_IMEX_STATUS_REMAINONBOARD then // do not Q attachments
			// Autoplan the TI to suitable yard location
			//if roadJob &lt;&gt; null and roadJob.autoComplete or self.autoComplete then						//navra1 - 25th Jan 2024 - TFS 62081
			if roadJob &lt;&gt; null and roadJob.canBeAutoCompleted(self.myTrackedItem, self,false) then			//navra1 - 25th Jan 2024 - TFS 62081
				moveMode := PLANNING_MODE; 
				moveType := TI_FutureMovePlanned;
			else
				moveMode := QUEUE_MODE;
				moveType := TI_FutureMoveQueued;
			endif;	
			plannedLocn := self.getPlannedLocation();
			//epr TFS 41300 3/11/18 
			if plannedLocn = null and prenoteTI &lt;&gt; null and prenoteTI &lt;&gt; self.myTrackedItem and self.directDelivery then
				plannedLocn:=prenoteTI.myPrimaryPlannedLocation;
				if plannedLocn &lt;&gt; null and plannedLocn.isYardLocation then			
					plannedLocn:=null;
				else
					moveMode := PLANNING_MODE;
				endif;
			endif;
			
			if plannedLocn &lt;&gt; null then 
				//self.myTrackedItem.moveToLocation(plannedLocn, roadJob, null, null,moveMode, false, true, false, false,false,  false, null,null,_passport);		// TFS 2651
				self.myTrackedItem.moveToLocation(plannedLocn, roadJob, null, null,moveMode, false, true, false, false,false,  false, null,null,null,null,self.getVehicleVisitRecord,_passport);	// TFS 2651
			endif;
			if (plannedLocn = null)	then 
				app.autoPlanAlertOverride(self.myTerminal);
				// Try to autoplan, but is ok if fails PAR 21068
				if self.myTrackedItem.myMatchedTBA = null then							//30/12/2015	cnwma1 PAR #37331	
					self.myTrackedItem.autoPlan(moveMode, roadJob, null, null, _passport);
				endif;
			endif;
		endif;
	endif;	
	
	//05 Apr 2013	NDL	Par 31102
	if _passport.noErrors then
		//if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.directDelivery then																		// TFS 51935
		//if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.directDelivery and not self.myTerminal.getConfig(DirectTruck2VesselMult).Boolean then	// TFS 51935	// TFS 52293
		if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.directDelivery and (roadJob = null or not roadJob.isDirectDeliveryJob) then				// TFS 51935	// TFS 52293
			app.raiseCMWarning1(Is_Direct_delivery, self.myTrackedItem.id, null, null, null);
		endif;
	endif;
	
	//06/04/2023	navkc1	CR# 56431 Task 56438
	if _passport.noErrors() and self.attributeisOverlanded then
		create txnParams transient;
		txnParams.type := TRANS_TYPE_OVERLANDED;
		self.myTrackedItem.createTransaction(txnParams, _passport);
		delete txnParams;
	endif;
	
	//05/02/2023	navkc1 Bug 62302 - Loop persistent child cargo
	if myTI &lt;&gt; null then
		foreach childTi in myTI.allChildren discreteLock do
			childTiID := childTi.id;
			// Find the child cargo in cmif
			foreach subItem in self.allChildren do : cmif
				if subItem.id &lt;&gt; childTiID or not subItem.isOverlanded() then
					continue;
				endif;
				// Create Overlanded transactions
				create txnParams transient;
				txnParams.type := TRANS_TYPE_OVERLANDED;
				childTi.createTransaction(txnParams, _passport);
				delete txnParams;
				
				break cmif;
			endforeach;
		endforeach;
	endif;
	
	return true;
epilog
	app.cmsEndLoad(load);					// PAR #36904
	delete newPxy;							// PAR #36904
	delete tempParams;						// PAR #36904
	delete txnParams;
	delete pxyTI;
	delete tiUpdateCntrlr;
//	delete control;
	delete resyncContrlr;					// TFS 43611
end;</source>
        <access>protected</access>
