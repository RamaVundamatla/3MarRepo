<Class name="CM_KubotaWeightController" id="68b4219a-cdb2-4713-b15d-bf3ad998944e">
    <superclass name="CM_WeightIntController"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <JadeMethod name="generateDevTestData" id="dbd7cf35-a40b-4b95-b238-445c58942b41">
        <source>generateDevTestData();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 July 2021	navndl1	Initial creation	TFS 

*/

vars

	rawKgs : Integer;
	repeatStr : String;
	index : Integer;
	randomNum : Integer;
	strResponse : String;
	binResponse : Binary;
	weight : Decimal[16,4];

begin
	/*
	
		data expected in format 
		
		33120.kg&lt;3&gt;&lt;\r&gt;&lt;\n&gt;&lt;2&gt;S331203312033120G+      33120.kg&lt;3&gt;&lt;\r&gt;&lt;\n&gt;&lt;2&gt;S331203312033120G+      33120.kg&lt;3&gt;&lt;\r&gt;&lt;\n&gt;&lt;2&gt;S331203312033120G+      33120.kg&lt;3&gt;&lt;\r&gt;&lt;\n&gt;&lt;2&gt;S331203312033120G+      33120.kg&lt;3&gt;&lt;\r&gt;&lt;\n&gt;&lt;2&gt;S331203312033120G+      33120.kg&lt;3&gt;&lt;\r&gt;&lt;\n&gt;&lt;2&gt;S331203312033120G+      33120.kg&lt;3&gt;&lt;\r&gt;&lt;\n&gt;&lt;2&gt;S331203312033120G+      33120.kg&lt;3&gt;&lt;\r&gt;&lt;\n&gt;&lt;2&gt;S331203312033120G+      33120.kg&lt;3&gt;&lt;\r&gt;&lt;\n&gt;&lt;2&gt;S331203312033120G+      33120.kg&lt;3&gt;&lt;\r&gt;&lt;\n&gt;&lt;2&gt;S331203312033120G+      33120.kg&lt;3&gt;&lt;\r&gt;&lt;\n&gt;
	
		
		read the data beween the &lt;2&gt; and &lt;3&gt; to get the kg amount between the + and .kg
		
		read until you get 5 weight readings the same and reutrn it
		
	*/
	
	randomNum := app.random(8);
	
	if randomNum = 1 then
		rawKgs := 33120;
	elseif randomNum = 2 then
		rawKgs := 30019;
	elseif randomNum = 3 then
		rawKgs := 31888;
	elseif randomNum = 4 then
		rawKgs := 32327;
	elseif randomNum = 5 then
		rawKgs := 24577;
	elseif randomNum = 6 then
		rawKgs := 23917;
	elseif randomNum = 7 then
		rawKgs := 24666;
	elseif randomNum = 8 then
		rawKgs := 25305;
	endif;
	
	repeatStr := "+      " &amp; rawKgs.String &amp; ".kg&lt;3&gt;&lt;\r&gt;&lt;\n&gt;&lt;2&gt;S331203312033120G";
	foreach index in 1 to 7 do
		strResponse := strResponse &amp; repeatStr;
	endforeach;
	
	binResponse := strResponse.Binary;
	
	weight := self.getWeight( binResponse );
	
	self.myWeightCallerInterface.sendWeight(weight);

epilog

end;</source>
    </JadeMethod>
