    <JadeMethod name="getPrimaryTrackedItem" id="d1bf2872-79da-4f69-b41e-5503f7b414fa">
        <source>getPrimaryTrackedItem(mode : Integer) : CM_TrackedItem;
/*
 ------------------------------------------------------------------------
Created:			28 May 2002 by cnwdwq1
Purpose:			Returns the "first" ti in the list for the mode.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	array : CM_TIArray;
begin
	create array transient;
	self.getTIs(array, mode, true); // PAR 27749
	if array.isEmpty then
		return null;
	endif;
	return array[1];
epilog
	delete array;
end;</source>
