    <JadeMethod name="buildCombo" id="cccd7aad-4e00-4757-a4d6-dfcae0df073a">
        <source>buildCombo();
/*
Purpose:	

Date		Who		Reason
19 September 2024	navab1	CR 65820 TASK 65822
*/

vars
	qryReport : CM_QryReport;
	format : Integer;
	cmb : CMUI_ComboBox;
	reportAgent : CMUI_ReportAgentStd;
begin
	cmb := self.cmbFormats;
	cmb.clear();

	cmb.sorted := true;

	create reportAgent transient;
	qryReport := self.myReport;
	
	if qryReport.reportFormats.includes(JadeReportWriterReport.CSV) then
		cmb.itemData[cmb.addItem(reportAgent.FORMAT_OPTION_CSV)]		:= JadeReportWriterReport.CSV; 
	endif;																
	if qryReport.reportFormats.includes(JadeReportWriterReport.HTML) then
		cmb.itemData[cmb.addItem(reportAgent.FORMAT_OPTION_HTML)] 	:= JadeReportWriterReport.HTML;
	endif;																
	if qryReport.reportFormats.includes(JadeReportWriterReport.RTF) then
		cmb.itemData[cmb.addItem(reportAgent.FORMAT_OPTION_RTF)]		:= JadeReportWriterReport.RTF;
	endif;																
	if qryReport.reportFormats.includes(JadeReportWriterReport.XML) then
		cmb.itemData[cmb.addItem(reportAgent.FORMAT_OPTION_XML)]		:= JadeReportWriterReport.XML;
	endif;																
	if qryReport.reportFormats.includes(JadeReportWriterReport.TEXT) then
		cmb.itemData[cmb.addItem(reportAgent.FORMAT_OPTION_TEXT)]	:= JadeReportWriterReport.TEXT;
	endif;																
	
	cmb.listIndex := 1;
epilog
	delete reportAgent;
end;</source>
    </JadeMethod>
    <JadeMethod name="fileSilentExceptionHandler" id="32cea5a7-4dd7-4c30-b2a0-2cd6c1428e1d">
        <source>fileSilentExceptionHandler(_exObj: Exception; _hadFileException : Boolean io): Integer;
/*
Purpose:	

Date		Who		Reason
19 September 2024	navab1	CR 65813 TASK 65877
*/
vars
	returnVal		: Integer;
begin
	returnVal := Ex_Pass_Back;
	if _exObj.errorCode &gt; 5000 and _exObj.errorCode &lt;= 5099 then
		_hadFileException:=true;
		if _exObj.resumable then
			returnVal := Ex_Resume_Next;
		endif;
	endif;

	return returnVal;
epilog

end;</source>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_hadFileException" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getExportFileName" id="3c41c026-614d-47ec-be5b-a92b99e2990f">
        <source>getExportFileName(_startDT :TimeStamp; _extension : String) : String;
/*
Purpose:	

Date		Who		Reason
19 September 2024	navab1	CR 65813 TASK 65877
*/
vars
	
begin
	return self.reportName &amp; "-" &amp; 
			_startDT.date.userFormat($CM_YearFormat) &amp; 
			_startDT.time.formatAsHHMMSS &amp; 
			_extension ;
epilog

end;</source>
        <Parameter name="_startDT" type="TimeStamp"/>
        <Parameter name="_extension" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExportFileNameBase" id="0f31f3e5-9b1b-4758-a5ba-75886d95175b">
        <source>getExportFileNameBase(_exportPath : String): String;
/*
Purpose:	

Date		Who		Reason
19 September 2024	navab1	CR 65813 TASK 65877
*/
vars
	fdir:         FileFolder;
	target:       String;
	pos:          Integer;
	hadFileException : Boolean;
begin
	if _exportPath = null then
		target := app.getJadeInstallDir;
		pos := target.reversePos("\");
		if pos &gt; 0 then
			target := target[1:pos - 1];
		endif;
		target := target &amp; "\" &amp; app.getErrorString(Proforma) &amp; "\";
	else
		target := _exportPath.normaliseDirectory().substituteDirectory();
	endif;
		
	create fdir transient;
	fdir.fileName := target;
	
	on FileException do self.fileSilentExceptionHandler(exception,hadFileException);
	
	if not fdir.isAvailable then
		fdir.make;
	endif;
	
	if hadFileException then
		target := app.getJadeInstallDir;
		pos := target.reversePos("\");
		if pos &gt; 0 then
			target := target[1:pos - 1];
		endif;
		target := target &amp; "\" &amp; app.getErrorString(Proforma) &amp; "\";
		fdir.fileName := target;
		if not fdir.isAvailable then
			fdir.make;
		endif;
	endif;
	

	return target;
epilog
	delete fdir;
end;</source>
        <Parameter name="_exportPath" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFileExtension" id="aa0da48a-324c-4e8b-864b-f4f4303dc87c">
        <source>getFileExtension() : String;
/*
Purpose:	

Date		Who		Reason
19 September 2024	navab1	CR 65813 TASK 65877
*/
vars

begin

	return "." &amp; self.cmbFormats.text.toLower();

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFileForExtract" id="7f5b31ec-63f2-46a5-828a-431c78656608">
        <updating/>
        <source>getFileForExtract(_defaultFileName, _extension : String): File updating;
/*
Purpose:	

Date		Who		Reason
19 September 2024	navab1	CR 65813 TASK 65877
*/
vars
	filePath,
	exportPath	: String;
	file		: File; 
	fs 			: CMDFileSave;

begin
	create fs transient;
	fs.dialogTitle := "Specify the Report Output"; //app.getErrorString(Specif_file_invoic_contra_expo);
	fs.resetCurrentPath := true;
	exportPath := MiscDir &amp; "\"&amp; app.getErrorString(Proforma) &amp; "\";
	fs.initDir := self.getExportFileNameBase(exportPath);
	fs.fileName := self.getExportFileName(app.actualTimeAppServer,_extension);
	
	if fs.open = 0 then
		create file transient;
		file.fileName := fs.fileName;
		file.mode := File.Mode_Output;

		if (not file.tryOpen) then
			app.raiseCMException1(FileUnavailable, file.fileName, null, null);	
			return null;
		endif;
	endif;

	return file;
epilog

end;</source>
        <Parameter name="_defaultFileName" type="String"/>
        <Parameter name="_extension" type="String"/>
        <ReturnType type="File"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="7c3573b1-1ce9-4b48-b4df-4c831ef7fa45">
        <updating/>
        <source>setupForm() updating;
/*
Purpose:	

Date		Who		Reason
19 September 2024	navab1	CR 65813 TASK 65877
*/
