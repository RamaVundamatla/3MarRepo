<GUIClass name="MOB_HHMsgBoxAndAlert" id="edc2bd25-ba23-4c03-8a63-764b6f86df89">
    <superclass name="MOB_HandHeldMsgBox"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="lblMessage" id="bf46f821-8041-4b30-883b-9154f6eef4f0">
        <embedded/>
        <type name="MOB_Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="txtMessage" id="32ff0845-789a-4fd4-8e0c-05780b47fc69">
        <embedded/>
        <type name="MOB_TextBox"/>
    </ImplicitInverseRef>
    <JadeMethod name="btnDialog1_click" id="11dcebc8-497e-48a9-8ff2-6601df55be8c">
        <updating/>
        <source>btnDialog1_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars
	addText : String;
	alertText : String;
begin

	self.modalResult	:=	btn.tag.Integer;
	if self.txtMessage.text &lt;&gt; self.lblMessage.caption then
		addText := self.txtMessage.text;
	endif;
	
	alertText := alertText  &amp; app.getErrorString1(Alert_raised_from_user, app.getMyUserCode) &amp; " : " &amp; lblText.caption;
	if addText &lt;&gt; null then
		alertText := alertText  &amp; " [" &amp; addText &amp; "]";
	endif;
	
	app.myPassport.createAlert(	SEVERE_ERROR, 
								alertText,
								EVENT_AT_HandHeldAlert,
								null);
								
	beginTransaction;
	app.commitAlert();
	commitTransaction;
	
	if app.myPassport.hasErrors then
		self.msgBox( "Failed to send Alert", "Raise Alert", MsgBox_OK_Only, false );
	endif;

	self.unloadForm();

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="b6154a16-56cc-4081-9a18-4a53c943b7b4">
        <updating/>
        <source>doResize() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 Feb 2010	cnwndl1	Initial creation
16 Dec 2013	cnwkpd1	PAR #33170 - Fix positioning of the Alert and Cancel buttons on Windows Mobile

*/

constants

	WIDTH = 239;
	Dummy = "Dummy";
	
vars

	textHeightForWidth,
	textHeight : Integer;
	lblHeight, frmHeight : Real;
	activeFormMargin : Integer;
	
begin

	self.width := WIDTH;
	
	if self.useHHResizeCode then	//26 Feb 2015	NDL	Par 35604
		if self.resizedMargin &gt; 2 then
			inheritMethod();
			self.txtMessage.fontSize := self.drawFontSize;
			self.fraMain.fontSize := self.drawFontSize;
		//	return;
		endif;
	endif;
		
	textHeightForWidth := self.getTextHeightForWidth(self.aMessage, (self.fraMain.width - 4).Integer );
	textHeight:= self.lblText.getTextHeight(Dummy);
	lblHeight:=(textHeightForWidth + (textHeight * 2));
	
	self.lblText.parentAspect := 0;
	self.lblText.left := 2;
	self.lblText.width := self.fraMain.width - 4;
	self.lblText.height := lblHeight;
	
	self.txtMessage.top := self.lblText.top + self.lblText.height + 2;
	self.txtMessage.left := self.lblText.left;
	self.txtMessage.width := self.lblText.width;
	self.txtMessage.text := self.lblMessage.caption;
	
	
	frmHeight := self.txtMessage.top + self.txtMessage.height +  self.resizedMargin + btnDialog1.clientHeight + 20;
	
	// PAR #33170 - Changed order to ensure form is resized before the frame height is set
	self.height:=frmHeight + self.btnDialog1.height + (2 *  self.resizedMargin);	//05 Jan 2015	NDL	Par 37367
	fraMain.height:=frmHeight;
	
	
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setResizeableMarginAndFontSize" id="64918381-a863-4bd6-b4a3-addcb68b8868">
