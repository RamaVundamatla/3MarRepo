    <JadeMethod name="createContractDetailVolBased" id="4943ca14-0eeb-4631-89f2-fa0a4ec09ef2">
        <source>createContractDetailVolBased(_realCon : CM_InvoiceContract; _operator : CM_Operator; _cargoTypes : CM_CargoBOLTypeSet; _type : Integer; _createServiceETC : Boolean; _vbCalcType : String) : CM_InvoiceContractDtlsVolBased;
/*
Purpose:			

Date		Who		Reason
08 December 2022	navab1	TFS CR 55624 TASK 55699
08 Feb 2023	navmv20 TFS 55650 Task 55702: Jade - Contracts XML Load TRX
 // ### TFS BUG 57505 13APR2023 NAVAB1 added _vbCalcType
*/
constants
	Service1 = "UT_ServiceContractVB-1";
	Service2 = "UT_ServiceContractVB-2";
	InvType = "UT_InvTypeContractVB";
	InvLineType = "UT_LineTypeContractVB";
vars
	pxyConDtl, localRealDetail : CM_InvoiceContractDtlsVolBased;
	realConDtl : CM_InvoiceContractDetails;
	fromTS, toTS : TimeStamp;
	operator : CM_Operator;
	invLineType100 : CM_InvoiceLineDesc;
	invType : CM_InvoiceDesc;
	services : CM_ServiceByNameDict;
	pxyCriteria : CM_InvoiceContractCriteria;
	cargoType : CM_CargoType;
	operators : CM_OperatorSet;
	yaCriteria : CM_YACriteria;
	cmifCriteria : CMIF_YACriteriaPriority;
	criteriaType	: CM_YACriteriaType;
	allCriteria : CMIF_Array;
	yaPurge : CM_ObjectSet;
	calcTypeVB, calcTypeOrig : CM_CalculationType;
	service100, service200 : CM_Service;
	criteriaDesc : String;
begin
	if _createServiceETC then
		self.deleteUTInvoiceLineTypes();
	endif;
	
	fromTS := _realCon.fromTS;
	toTS := _realCon.toTS;

	operator := _operator;
	if operator = null then
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	endif;
	
	calcTypeOrig := app.myRoot.allCalculationTypesByCode["CCT01"]; // Value of 1
	calcTypeVB := app.myRoot.allCalculationTypesByCode[_vbCalcType]; // Weight KGs, the contract can override the calculation type to be used.
	
	// Only one service for volume based contracts. If have 2 or more each CM_Charge will have the same values because the contract can override the calc type and the amount, 
	//			resulting in the invoice line being double or triple etc.
	if _createServiceETC then
		service100 := self.createInvoiceService(Service1,"1- Unit test for TFS 55623", calcTypeOrig, null);
		self.assertNotNullMsg(service100, Service1 &amp; " not created");
		create services transient;
		services.add(service100);
	 
		invType := self.createInvoiceType(InvType, InvoiceTypeGeneral);
		self.assertNotNullMsg(invType, "Invoice type " &amp; InvType &amp; " not created");
		
		invLineType100 := self.createInvoiceLineType(InvLineType, calcTypeOrig, invType, services,"SDT1"); // SDT1 - Operator
		self.assertNotNullMsg(invLineType100, InvLineType &amp; " not created");
	else
		invLineType100:= _realCon.myBusinessUnit.invoiceLineDescriptors[InvLineType];
	endif;
	
	create pxyConDtl transient;
	// Detail has different calc type because this must update the invoice line amount.
	//pxyConDtl.setProxy(INV_CONTRACT_TYPE_VOLUME_BASED,123, fromTS, toTS,calcTypeVB,_realCon,invLineType100, _realCon.myBusinessUnit, null); //08/02/2023 navmv20 TFS 55650 TASK 55702
	pxyConDtl.setProxy(null,INV_CONTRACT_TYPE_VOLUME_BASED,123, fromTS, toTS,calcTypeVB,_realCon,invLineType100, _realCon.myBusinessUnit, null,null); //08/02/2023 navmv20 TFS 55650 TASK 55702
	pxyConDtl.setProxyVolBased(true,true,true,_type);
	
	// ### TFS CR 55623 TASK 55680, adding criteria to contract detail
	// ### SETUP CRITERIA FOR DETAIL
	
	create operators transient;
	operators.add(operator);
	
	create yaPurge transient;
	create allCriteria transient;
	yaPurge.add(allCriteria);
	create pxyCriteria transient;
	yaPurge.add(pxyCriteria);
	
	// ### CARGO TYPE
	create cmifCriteria transient;
	yaPurge.add(cmifCriteria);
	create yaCriteria transient;
	yaPurge.add(yaCriteria);
	criteriaType := app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType];
	yaCriteria.setProxy(criteriaType,_cargoTypes,null);
	cmifCriteria.setReferences(yaCriteria);
	allCriteria.add(cmifCriteria);
	
	// ### OPERATOR
	create cmifCriteria transient;
	yaPurge.add(cmifCriteria);
	create yaCriteria transient;
	yaPurge.add(yaCriteria);
	criteriaType := app.myRoot.allYACriteriaTypes[YACriteriaType_OperatorItem];
	yaCriteria.setProxy(criteriaType,operators,null);
	cmifCriteria.setReferences(yaCriteria);
	allCriteria.add(cmifCriteria);
	
	
	
	pxyCriteria.setProxyContract(allCriteria,999, "UT_ContractCriteria_01", "UT_ContractCriteriaDescription_01", pxyConDtl);
	criteriaDesc := pxyCriteria.getCriteriaSummary("/"); 
	if criteriaDesc &lt;&gt; "" then
		pxyCriteria.setPropertyValue("description", criteriaDesc);
	endif;
	
	app.myTrxCA.trxCreateInvContractDtl(pxyConDtl, realConDtl, app.myPassport);
	localRealDetail := realConDtl.CM_InvoiceContractDtlsVolBased;
	
	assertNoTrxErrorsOrWarnings();
	assertTrueMsg(localRealDetail.isKindOf(CM_InvoiceContractDtlsVolBased), "lass should be accumulateForRailReceival");
	assertTrueMsg(localRealDetail.accumulateForRailReceival = true, "accumulateForRailReceival is false");
	assertTrueMsg(localRealDetail.accumulateForRoadReceival = true, "accumulateForRoadReceival is false");
	assertTrueMsg(localRealDetail.accumulateForShipReceival = true, "accumulateForShipReceival is false");
	assertTrueMsg(localRealDetail.accumulationType = _type, "accumulationType is wrong");
	
	assertTrueMsg(localRealDetail.myInvoiceContract &lt;&gt; null, "Contract is null");
	assertTrueMsg(localRealDetail.myInvoiceContract = _realCon, "Contract is wrong");
	assertTrueMsg(localRealDetail.contractType = INV_CONTRACT_TYPE_VOLUME_BASED, "Contract Type is wrong");
	assertTrueMsg(localRealDetail.fromTS = fromTS, "From Date is wrong");
	assertTrueMsg(localRealDetail.toTS = toTS, "To Date is wrong");
	assertTrueMsg(localRealDetail.myCalculationType &lt;&gt; null, "Calculation Type is null");
	assertTrueMsg(localRealDetail.myCalculationType = calcTypeVB, "Calculation Type is wrong");
	assertTrueMsg(localRealDetail.myInvoiceLineType &lt;&gt; null, "Line Type is null");
	assertTrueMsg(localRealDetail.myInvoiceLineType = invLineType100, "Line Type is wrong");
	assertTrueMsg(localRealDetail.myInvoiceContractCriteria &lt;&gt; null, "Criteria is null"); // ### TFS CR 55623 TASK 55680
	assertTrueMsg(localRealDetail.myInvoiceContractCriteria.allCriteria.size = 2, "Criteria should have 2 criteria, has " &amp; 
								localRealDetail.myInvoiceContractCriteria.allCriteria.size.String); // ### TFS CR 55623 TASK 55680
	
	return localRealDetail;
epilog
	delete pxyConDtl;
	delete operators;
	if yaPurge &lt;&gt; null then
		yaPurge.purge();
		delete yaPurge;
	endif;
	delete services;
end;</source>
        <Parameter name="_realCon" type="CM_InvoiceContract"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_cargoTypes" type="CM_CargoBOLTypeSet"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_createServiceETC" type="Boolean"/>
        <Parameter name="_vbCalcType" type="String"/>
        <ReturnType type="CM_InvoiceContractDtlsVolBased"/>
    </JadeMethod>
    <JadeMethod name="createContractRate" id="0a12b00b-59b6-46ed-97a9-bc81cd3c380e">
        <source>createContractRate(_contractDtl : CM_InvoiceContractDetails; _service : CM_Service) : CM_InvoiceContractRate;
/*
Purpose:			

Date		Who		Reason
08 December 2022	navab1	TFS CR 55623 TASK 55676
08 Feb 2023	navmv20 TFS 55650 Task 55702: Jade - Contracts XML Load TRX
*/

vars
	proxyRate, realRate : CM_InvoiceContractRate;
begin

	create proxyRate transient;
	//proxyRate.setProxy(_service, _contractDtl); //08/02/2023 navmv20 TFS 55650 TASK 55702
	proxyRate.setProxy(null, _service, _contractDtl, _service.myCalculationType); //08/02/2023 navmv20 TFS 55650 TASK 55702 // ### TFS CR 61579 TASK 62453 12FEB2024 NAVAB1

	app.myTrxCA.trxCreateInvContractDtlRt(proxyRate, realRate, app.myPassport);
	
	assertNoTrxErrorsOrWarnings();
	assertTrueMsg(realRate.myInvoiceContractDetail &lt;&gt; null, "Contract Detail is null");
	assertTrueMsg(realRate.myInvoiceContractDetail = _contractDtl, "Contract Detail is wrong");
	assertTrueMsg(realRate.myService &lt;&gt; null, "Service is null");
	assertTrueMsg(realRate.myService = _service, "Service is wrong");
	
	return realRate;
epilog
	delete proxyRate;
end;</source>
        <Parameter name="_contractDtl" type="CM_InvoiceContractDetails"/>
        <Parameter name="_service" type="CM_Service"/>
        <ReturnType type="CM_InvoiceContractRate"/>
    </JadeMethod>
    <JadeMethod name="createContractRateEntry" id="c06df834-f136-4a0f-86e0-ba44ec5f23f0">
        <source>createContractRateEntry(_rate : CM_InvoiceContractRate; _cpu, _fromAmt, _toAmt : Decimal; _fromTS, _toTS : TimeStamp) : CM_InvoiceContractRateEntry;
/*
Purpose:			

Date		Who		Reason
09 December 2022	navab1	TFS CR 55623 TASK 55678
08 Feb 2023	navmv20 TFS 55650 Task 55702: Jade - Contracts XML Load TRX
*/

vars
	pxyEntry, realEntry : CM_InvoiceContractRateEntry;
	realDetail : CM_InvoiceContractDetails;
	fromTS, toTS : TimeStamp;
begin
	if _rate &lt;&gt; null then
		realDetail := _rate.myInvoiceContractDetail;
	endif;
	
	create pxyEntry transient;
	//pxyEntry.setProxy(_cpu, _fromAmt,_toAmt, _fromTS, _toTS,_rate, realDetail.myBusinessUnit); //08/02/2023 navmv20 TFS 55650 TASK 55702
	pxyEntry.setProxy(null, _cpu, _fromAmt,_toAmt, _fromTS, _toTS,_rate, realDetail.myBusinessUnit); //08/02/2023 navmv20 TFS 55650 TASK 55702

	app.myTrxCA.trxCreateInvContractDtlRtEntry(pxyEntry, realEntry, app.myPassport);
	
	assertNoTrxErrorsOrWarnings();
	assertTrueMsg(realEntry.myInvoiceContractRate &lt;&gt; null, "Contract Rate is null");
	assertTrueMsg(realEntry.myInvoiceContractRate = _rate, "Contract Rate is wrong");
	assertTrueMsg(realEntry.fromAmount = _fromAmt, "Rate Entry 'from amount' is wrong");
	assertTrueMsg(realEntry.toAmount = _toAmt, "Rate Entry 'to amount' is wrong");
	assertTrueMsg(realEntry.costPerUnit = _cpu, "Rate Entry CostPerUnit is wrong");

	return realEntry;
epilog
	delete pxyEntry;
end;</source>
