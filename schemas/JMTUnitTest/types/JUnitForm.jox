    <JadeMethod name="updateCategoryDetails" id="9b00e04c-727a-4388-8e8c-76a28e3e79f5">
        <updating/>
        <source>updateCategoryDetails(_category : UM_Category io; _selectedObjects : ObjectArray) updating;


/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
26 August 2011	cnwmh5	Initial creation

*/

constants
	XMLHeader				: String = "&lt;?xml version=";
	XMLAdditional			: String = "UT_Additional";
	XMLCategories			: String = "Categories";
	XMLCategory				: String = "Category";
	XMLAttributeCanDelete	: String = "CanDelete";
	XMLEndString			: String = XMLAdditional &amp; "&gt;";
	ScheduleText			: String = "SCHEDULE_";
vars
	
	obj						: Object;
	xmlDocument				: JadeXMLDocument;
	xmlElement,
	xmlElementAdditional,
	xmlElementCategories,
	xmlElementCategory		: JadeXMLElement;
	xmlAttributeCategories	: JadeXMLAttribute;
	
	xmlElementArray			: JadeXMLElementArray;
	currentClassMethodArray	: ObjectArray;
	
	
	classMethodText			: String;
	categoryName			: String;
	xmlText					: String;
	otherText				: String;
	xmlHeaderPos			: Integer;
	xmlEndPos				: Integer;
	elementFound			: Boolean;
	canBeDeleted			: Boolean;

begin

	on JadeXMLException do app.handleXMLExceptions(exception);

	categoryName := _category.name;
	
	// clear all classes / methods out of categorys allCategoryClassMethods
	create currentClassMethodArray transient;
	_category.allCategoryClassMethods.copy(currentClassMethodArray);
	_category.allCategoryClassMethods.clear();
		
	// get the objects that we need to write
	foreach obj in _selectedObjects do
	
		// get the current xmlDocument
		delete xmlDocument;
		create xmlDocument transient;
		xmlDocument.outputDeclaration := true;
		
		// get the class / method text
		if obj.isKindOf(Class) then
			classMethodText := obj.Class.text;
		else
			// if not a method we require then don't do anything
			if not obj.Method.isRunnableUnitTestMethod() then
				continue;
			endif;
			classMethodText := obj.Method.text;
		endif;
		
		// check to see whether we have xml text
		xmlHeaderPos := classMethodText.pos(XMLHeader, 1);
		xmlEndPos := classMethodText.reversePos(XMLEndString);
		xmlText := null;
		if xmlHeaderPos &lt;&gt; 0 then
			xmlText := classMethodText[xmlHeaderPos:xmlEndPos + XMLEndString.length - xmlHeaderPos];
		endif;
		
		if xmlHeaderPos = 0 then
			otherText := classMethodText;
		elseif xmlHeaderPos &gt; 1 then
			otherText := classMethodText[1:xmlHeaderPos-1];
			if xmlEndPos + XMLEndString.length &lt; classMethodText.length then
				if otherText.trimBlanks() &lt;&gt; null then
					otherText := otherText.trimBlanks() &amp; CrLf &amp; CrLf;
				endif;
				otherText := otherText.trimBlanks() &amp; classMethodText[xmlEndPos + XMLEndString.length + 1:end];
			endif;
		endif;
		if otherText &lt;&gt; null and otherText.reversePos(CrLf) = 0 then
			otherText := otherText &amp; CrLf;
		endif;
				
		// only parse the string if text exists
		if xmlText &lt;&gt; null then
			xmlDocument.parseString(xmlText);
		endif;
	
		// check to see if we have the UT_Additional element exists
		xmlElementAdditional := xmlDocument.getElementByTagName(XMLAdditional);
		if xmlElementAdditional = null then
			xmlElementAdditional := xmlDocument.addElement(XMLAdditional);
		endif;
		
		// check to see if the Categories element exists
		xmlElementCategories := xmlElementAdditional.getElementByTagName(XMLCategories);
		
		if xmlElementCategories = null then
			// create if it doesn't exist
			xmlElementCategories := xmlElementAdditional.addElement(XMLCategories);
			xmlAttributeCategories := xmlElementCategories.getAttributeByName(XMLAttributeCanDelete);
		endif;
	
		// create xml element
		create xmlElementArray transient;
		xmlElementCategories.getAllElementsByTagName(XMLCategory, xmlElementArray);
		elementFound := false;
		foreach xmlElement in xmlElementArray do
			if xmlElement.text = categoryName then
				elementFound := true;
				break;
			endif;
		endforeach;
		if not elementFound then
			xmlElementCategory := xmlElementCategories.addElement(XMLCategory);
			xmlElementCategory.setText(categoryName);
			canBeDeleted := true;
			if categoryName[1:9] = ScheduleText then
				canBeDeleted := false;
			endif;
			xmlElementCategory.addAttribute(XMLAttributeCanDelete, canBeDeleted.String);
			_category.updateCanBeDeleted(canBeDeleted);
		endif;
		
		
		// update the catgories details
		_category.updateClassMethodCollection(obj);
		
		// remove from the original class / methods collection
		if currentClassMethodArray.includes(obj) then
			currentClassMethodArray.remove(obj);
		endif;
		
		// write the xml to the class / methods text attribute
		beginTransaction;
		obj.setPropertyValue("text", otherText &amp; xmlDocument.writeToString());
		commitTransaction;
	
	endforeach;
	
	// read through what is left from the original list and delete 
	self.doDeleteCategory(_category, categoryName, currentClassMethodArray);
	
epilog

	delete xmlDocument;
	delete xmlElementArray;
	delete currentClassMethodArray;
	
end;
</source>
        <Parameter name="_category" type="UM_Category" usage="io"/>
        <Parameter name="_selectedObjects" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="991e7bae-be2e-4f8b-abd1-b556c3b7cf9f">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating, clientExecution;
//18 December 2008	cnwdw1	
//
vars
	index: Integer;
	result: UT_TestResult;
	deleted: Boolean;
	int : Integer;
	methodDetails : String;
	classMethod : UM_UnitTestClassMethod;
	elapsed : String;
begin
	on Exception do app.handleDeletedObject(exception, result, deleted);
	
//	app.writeLog("The Object: " &amp; theObject.String &amp; Tab &amp; "Event type: " &amp; eventType.String &amp; Tab &amp; "Event tag: " &amp; eventTag.String &amp; Tab &amp; "User info: " &amp; userInfo.String, LogINFO);
	
	index := lbxTests.findObject(theObject);
	
	// 28/04/2014 cnwmh5
	if theObject &lt;&gt; null and theObject.isKindOf(Method) then
		classMethod := UM_Root.firstInstance.allRunnableUTClassesMethods[theObject.Method.schemaType.name, theObject.Method.name];
		methodDetails := "Method: " &amp; theObject.Method.schemaType.name &amp; "::" &amp; theObject.Method.name;
		if classMethod &lt;&gt; null then
			elapsed := classMethod.getLastPassedElapsedTime();
			if elapsed &lt;&gt; null then
				methodDetails := methodDetails &amp; "       " &amp; "O/Night time: " &amp; elapsed &amp; " secs";
			endif;
		endif;
		methodDetails := methodDetails &amp; "    " &amp; "Started: " &amp; app.cnGetServerTime().Time.String;
	endif;

	if userInfo = null and index &gt; 0 then
		lbxTests.itemPicture[index] := picRunning.picture;
		//cnwmc5 6/9/2012
		//self.lblCurrentMethod.caption := "Method: " &amp; theObject.Method.schemaType.name &amp; "::" &amp; theObject.Method.name;
		showTotals();																			// 28/04/2014
		self.lblCurrent.caption := self.lblCurrent.caption &amp; methodDetails;
	elseif userInfo &lt;&gt; null and index &gt; 0 then
		if userInfo.isKindOf(Integer) then
			// this is for setting the results on another users screen.
			//pass = 2, fail = 1;
			int := userInfo.Integer;
			if int &gt; 0 then
				if lbxTests.itemPicture[index] = picRunning.picture then
					if int = 2 then	// method succeeded
						lbxTests.itemPicture[index] := picSuccess.picture;
					elseif int = 1 then
						lbxTests.itemPicture[index] := picFailed.picture;
					endif;
				endif;
			endif;
		elseif userInfo.isKindOf(String) then
			self.txtResultDetails.text := self.txtResultDetails.text &amp; CrLf &amp; userInfo.String;
		else
			result := userInfo.UT_TestResult;
			if result = null then
				return;
			endif;
			if result.hasPassed() then	// method succeeded
				lbxTests.itemPicture[index] := picSuccess.picture;
				self.currentPassedCount := self.currentPassedCount + 1;
				self.currentRunCount := self.currentRunCount + 1;
			else
				lbxTests.itemPicture[index] := picFailed.picture;
				self.currentFailedCount := self.currentFailedCount + 1;
				self.currentRunCount := self.currentRunCount + 1;
			endif;
			if deleted then
				return;
			endif;
			self.appendToResults(result);
			self.recalcTotals();
			self.showTotals();
			self.lblCurrent.caption := self.lblCurrent.caption &amp; methodDetails;									// 28/04/2014 cnwmh5
		endif;
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
