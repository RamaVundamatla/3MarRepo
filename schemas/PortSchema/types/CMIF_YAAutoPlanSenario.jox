    <JadeMethod name="isHazardous_Match" id="b53269ea-ccc4-4abb-8275-73eb67c3fb3e">
        <source>isHazardous_Match(_yaData: CM_YADataString): Boolean;
// -------------------------------------------
// Created 31 May 2005 by cnwdvb1
// -------------------------------------------
// Changed On	By			Reason
// ----------	---------	-----------------------------------------------------
// 01/08/2017	cnwdap1		TFS 5609 SNO Road Gate Cargo Check Criteria
vars

	hazardClass1 			: Object;
	hazardClass2		: Object;

begin

	// Only priorities will be empty.
	//-cnwml2 PAR24472
	//if _yaData.isEmpty() then
	//	return true;
	//endif;
	
	//+cnwml2 PAR24472
	foreach hazardClass1 in self.allHazards discreteLock do
		if hazardClass1.isKindOf(CM_HazardClass) then
			hazardClass2 := hazardClass1.CM_HazardClass;
			if _yaData.doesValueMatch(hazardClass2.CM_HazardClass.code) then
				return true;
			endif;
		elseif hazardClass1.isKindOf(CMIF_Hazard) then
			hazardClass2 := hazardClass1.CMIF_Hazard;
			if _yaData.doesValueMatch(hazardClass2.CMIF_Hazard.code) then
				return true;
			endif;
			
		elseif hazardClass1.isKindOf(CM_TIHazard) then							// TFS 5609
			hazardClass2 := hazardClass1.CM_TIHazard;							// TFS 5609
			if _yaData.doesValueMatch(hazardClass2.CM_TIHazard.code) then		// TFS 5609
				return true;													// TFS 5609
			endif;																// TFS 5609
		endif;
		

	endforeach;

	return false;

end;</source>
        <Parameter name="_yaData" type="CM_YADataString"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
