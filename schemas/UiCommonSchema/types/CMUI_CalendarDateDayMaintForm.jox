	self.splMain.enabled := true;
	self.grpNewDate.enabled := false;
	self.btnNew.enabled := true;
	self.btnUpdate.enabled := not tblDayData.allSelectedObjects.isEmpty;
	self.btnRemove.enabled := not tblDayData.allSelectedObjects.isEmpty;

epilog

end;</source>
