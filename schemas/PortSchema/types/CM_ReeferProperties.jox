    <JadeMethod name="create" id="0a4a87f6-a489-417f-a2d6-0fabd75311ee">
        <updating/>
        <source>create() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25/11/2009	cnwdap1	Initial creation
*/
vars

begin
	self.temperature 	:= NULL_TEMPERATURE;
	self.setHumidity( NULL_HUMIDITY );
	self.ventilation 	:= NULL_VENTILATION;
	self.setCarbonDioxide( NULL_CARBON_DIOXIDE );
	self.setOxygen( NULL_OXYGEN );
	self.createDefaults(); //+ cnwas3, Par 26199
epilog

end;</source>
    </JadeMethod>
