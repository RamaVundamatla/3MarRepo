    <JadeMethod name="init" id="0b886149-bd75-4cc6-8d76-20479482e00b">
        <updating/>
        <source>init(_heading : String; _passport : CM_Passport; _mode : Integer) updating;
// ---------------------------------------------------------------------------
// Created:	15 January 2009 By Graeme Black cnwgb1
// Purpose:	Copied from MOB_ErrorWarningForm
// ---------------------------------------------------------------------------
vars
	err			: CM_Error;
	rowNo		: Integer;
	tblRow		: JadeTableRow;
	tmpStr		: String;
	
begin
	self.mode 			:= _mode;
	self.hasErrors		:= (not _passport.allErrors.isEmpty);
	
	if _passport.warningsIgnored then
		self.hasWarnings:=false;
	else
		self.hasWarnings	:= (not _passport.allWarnings.isEmpty);
	endif;
	
	self.setupTable();
	
	self.setHeadings(_heading);
	
	foreach err in _passport.allErrors do
		rowNo := tblErrors.addItem(err.text);
		tblRow := tblErrors.accessRow(rowNo);
		tblRow.foreColor := Red;
	endforeach;

	if self.hasWarnings then
		foreach err in _passport.allWarnings do
			rowNo := tblErrors.addItem(err.text);
			tblRow := tblErrors.accessRow(rowNo);
			tblRow.foreColor := Blue;
		endforeach;
	endif;

	
	app.mousePointer := MousePointer_Default;

epilog
end;</source>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="isModeDelete" id="55d71075-c53b-4619-b9a6-094fc3b5c929">
        <source>isModeDelete() : Boolean protected;
// ---------------------------------------------------------------------------
// Created:	15 January 2009 By Graeme Black cnwgb1
// Status: 	Unfinished
// Purpose:	
// ---------------------------------------------------------------------------
vars
begin
	return 	self.mode.bitAnd(ErrWarnMode_Delete).Boolean;
epilog
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setHeadings" id="63b6e77d-6f59-4e14-9b83-64e279f3ca01">
        <updating/>
        <source>setHeadings(_heading : String) protected, updating;
// ---------------------------------------------------------------------------
// Created:	15 January 2009 By Graeme Black cnwgb1
// Purpose:	Copied from MOB_ErrorWarningForm
// ---------------------------------------------------------------------------

vars
	titleStr	: String;
	
begin
	if self.hasErrors and (not self.canAckWarningsSkipErrors) then
		if self.hasWarnings then
			titleStr := app.getErrorString(EWD_Errors_Warnings);
		else
			titleStr := app.getErrorString(Errors);
		endif;

	elseif self.canAckWarningsSkipErrors then
		if self.hasErrors and self.hasWarnings then
			titleStr := app.getErrorString(EWD_Errors_Warnings);
		elseif self.hasErrors then
			titleStr := app.getErrorString(Errors);
		else
			titleStr := app.getErrorString(EWD_Warnings);
		endif;
		
	elseif self.canAcknowledgeWarnings then
		titleStr := app.getErrorString(EWD_Warnings);
	else
		titleStr := app.getErrorString(EWD_Warnings);
	endif;
	
	if _heading &lt;&gt; null then
		self.caption := titleStr &amp; ': ' &amp; _heading;
	else
		self.caption := titleStr;
	endif;

epilog
end;</source>
        <access>protected</access>
        <Parameter name="_heading" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="7d7ec381-a63f-42fe-9356-9fd58ff5faf4">
        <updating/>
        <source>setupForm() updating, protected;
// ---------------------------------------------------------------------------
// Created:	14 January 2009 By Graeme Black cnwgb1
// Status: 	Unfinished
// Purpose:	
// ---------------------------------------------------------------------------
vars
	actionStr	: String;
begin
	inheritMethod();

	self.setupCmdButtons(2, "OK", app.getErrorString(Cancel), null, null, null );
	
	if self.isModeDelete then
		actionStr := 'deleted';
	else
		actionStr := 'saved';
	endif;

	if self.hasErrors and (not self.canAckWarningsSkipErrors) then
		if self.hasWarnings then
			self.lblHeader.caption := app.getErrorString1(EWD_Cannot_Continue, actionStr);
		else
			self.lblHeader.caption := app.getErrorString1(EWD_Error_Cannot_Continue, actionStr);
		endif;
		
		self.btnOne.enabled := false;

	elseif self.canAckWarningsSkipErrors then
		if self.hasErrors and self.hasWarnings then
			self.lblHeader.caption := app.getErrorString(EWD_Warn_SkipErrors);
			self.btnOne.caption := app.getErrorString(Save);
		elseif self.hasErrors then
			self.lblHeader.caption := app.getErrorString1(EWD_Error_Cannot_Continue, actionStr);
			self.btnOne.enabled := false;				
		else
			if self.isModeDelete then
				self.lblHeader.caption := app.getErrorString(EWD_Warn_Continue_Cancel);
				self.btnOne.caption := app.getErrorString(Delete_Caption);
			else
				self.lblHeader.caption := app.getErrorString(EWD_Warn_Continue_Review);
				self.btnOne.caption := app.getErrorString(Save);
			endif;
		endif;
		
	elseif self.canAcknowledgeWarnings then
		if self.isModeDelete then
			self.lblHeader.caption := app.getErrorString(EWD_Warn_Continue_Cancel);
			self.btnOne.caption := app.getErrorString(Delete_Caption);
		else
			self.lblHeader.caption := app.getErrorString(EWD_Warn_Continue_Review);
			self.btnOne.caption := app.getErrorString(Save);
		endif;

	else
		self.lblHeader.caption := app.getErrorString(EWD_Warning_Resubmit);
		self.btnOne.enabled := false;						
	endif;
	
	self.doResize();
epilog
end;</source>
        <access>protected</access>
    </JadeMethod>
