<CollClass name="CM_LocalesByLocaleNameDict" id="05a39bb0-4995-47ff-9581-e55635645456">
    <loadFactor>66</loadFactor>
    <memberType name="CM_Locale"/>
    <superclass name="MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <MemberKey>
        <property name="CM_Locale::localeId"/>
    </MemberKey>
    <JadeMethod name="getLocaleByDescription" id="d3e51913-20a4-48f9-9757-97e129bf8797">
        <source>getLocaleByDescription(_localeDescription : String) : CM_Locale;
/*

Purpose:			Gets the locale by the description. If you pass in null it returns null

Parameters:			_localeDescription	String	The description of the locale to find

Return Value:		CM_Locale	The locale that matches the description

Date		Who		Reason
19 August 2022	navpw1	Initial creation TFS: 54564 (54374)
*/

vars
	locale : CM_Locale;
	
begin
	if _localeDescription = null then
		return null;
	endif;
	
	foreach locale in self do
		if locale.localeDescription &lt;&gt; _localeDescription then
			continue;
		endif;
		
		return locale;
		
	endforeach;
	
	return null;
	
end;</source>
        <Parameter name="_localeDescription" type="String"/>
        <ReturnType type="CM_Locale"/>
    </JadeMethod>
</CollClass>
