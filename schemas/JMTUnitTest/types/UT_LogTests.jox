    <JadeMethod name="uLogXMLWeight" id="1b947c6e-fd81-4a10-b471-66ac17f7c375">
        <source>uLogXMLWeight();

/*

Purpose:			Feed an XML weight update for a given BOL

Parameters:			

Return Value:		


Date		Who		Reason
27 November 2013	cnwjre1	Initial creation
// 17/08/2016 cnwrh7	TFS	2501

*/

vars

	bolNumber	: String;
	operatorCode	: String;
	terminalId		: String;
	passTerm	: CM_Terminal;
	terminal		: CM_Terminal;
	operator	: CM_Operator;
	bolIn		: CM_BOLIn;
	
begin
	passTerm := app.myPassport.myTerminal;
	terminalId := "T01";
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminalId);
	terminal := self.getTerminal();
	app.myPassport.setPropertyValue("myTerminal", terminal);

	bolNumber := "BOL33046";
	operatorCode := "FF";
	
	if app.myPassport.myTerminal.radioTelemetry.allRTDevices[RTDeviceId] = null then
		self.addRTDevice(RTDevice_HandHeld, RTDeviceId, RTDeviceModel, "PC_LOGS_T1", null, false, false,false); // when creating BOLIn and logs via XML, it requires some RT Device code, // +17/08/2016 cnwrh7	TFS	2501
	endif;	
	operator	:= self.getOperator(operatorCode);
	
	bolIn := self.updateBOLWeight2(RTDeviceId,	
					bolNumber, //_bolNoLookup,
					'0.220',//_netWeight,
					bolNumber,//_number,	
					operator.code//_operatorLookup,
					);

	self.assertNotNull(bolIn);
	
epilog
	app.myPassport.setPropertyValue("myTerminal", passTerm);
end;</source>
    </JadeMethod>
    <JadeMethod name="xmlCreateUpdateLocation" id="4c5adf92-b81a-4d62-a117-c99df6182d1a">
        <source>xmlCreateUpdateLocation(_action			: String;		// 'add' or 'update'
						_rowArea		: CM_LogArea;
						_logRowId		: String;
						_allOperators,		// 
						_allSpecies,
						_allGrades,
						_allLogTypes,
						_allTreatments,
						_allLengths		: String;
						_status			: String;
						_comment		: String;
						_docketChecked,
						_checkScaled,
						_inspected,
						_fumigated		: Boolean) : CM_LogController;
//	06 May 2011	by cnwvu1

// If parameter = null, its value will be taken from XmlLogRowMntRq constant

vars
	remoteManager	: CM_RemoteDataManagerExternal;
	xmlSession		: CM_XMLSession;
	struct 			: CnEcXmlStructureInstance;
	parser			: CnEcXmlParser;
	xmlStr			: String;
	tmpStruct		: CnEcXmlStructureInstance;
	userId,
	terminalCode	: String;
	xmlVersion		: String;
	obj				: Object;
	location		: CM_LogController;
	
begin

	//------------------------------------------------------------------
	//				Preparing parameters for XML process
	//------------------------------------------------------------------
	xmlStr			:= self.XML_LogRowMntRq;
	userId := self.testProfile.getSetting(UT_Profile.P_USER).asString;
	if userId = null then		// 19/49/2011 cnwmh5
		userId := 'UNITTEST';
	endif;

	terminalCode	:= self.getTerminal().code;
	
	
	//------------------------------------------------------------------
	//					Creating XML structure
	//------------------------------------------------------------------
	
	create remoteManager transient;
	create xmlSession transient;
	
	create struct as CnEcXmlGroupInstance transient;
	create parser transient;
	parser.parseToMsgStructure(xmlStr, struct);
	
	//----------------------------------------------------------------------------------------------------------
	//				Setting current parameters into XML data, 
	//				I am not interested in data from XML_LogRowMntRq constant - I use it as a pattern only.
	//----------------------------------------------------------------------------------------------------------
	tmpStruct := struct.findStructure(XML_ACTION);			tmpStruct.initializeWithTagData(tmpStruct.tagName, _action,					tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_LOGAREA);			tmpStruct.initializeWithTagData(tmpStruct.tagName, _rowArea.id,				tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_LOGROW);			tmpStruct.initializeWithTagData(tmpStruct.tagName, _logRowId,				tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_SUPPLIER);		tmpStruct.initializeWithTagData(tmpStruct.tagName, _allOperators,			tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_SPECIES);			tmpStruct.initializeWithTagData(tmpStruct.tagName, _allSpecies,				tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_GRADE);			tmpStruct.initializeWithTagData(tmpStruct.tagName, _allGrades,				tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_LOGTYPE);			tmpStruct.initializeWithTagData(tmpStruct.tagName, _allLogTypes,			tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_TREATMENT);		tmpStruct.initializeWithTagData(tmpStruct.tagName, _allTreatments,			tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_LENGTH);			tmpStruct.initializeWithTagData(tmpStruct.tagName, _allLengths, 			tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_STATUS);			tmpStruct.initializeWithTagData(tmpStruct.tagName, _status,		 			tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_COMMENT);			tmpStruct.initializeWithTagData(tmpStruct.tagName, _comment, tmpStruct.		tagAttribute);
	tmpStruct := struct.findStructure(XML_DOCKETCHECKED);	tmpStruct.initializeWithTagData(tmpStruct.tagName, _docketChecked.String,	tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_CHECKSCALED);		tmpStruct.initializeWithTagData(tmpStruct.tagName, _checkScaled.String,		tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_INSPECTED);		tmpStruct.initializeWithTagData(tmpStruct.tagName, _inspected.String,		tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_FUMIGATED);		tmpStruct.initializeWithTagData(tmpStruct.tagName, _fumigated.String,		tmpStruct.tagAttribute);


	//------------------------------------------------------------------
	//						setting XML session
	//------------------------------------------------------------------
	//see CM_XMLWorker::DoTheWork()
	tmpStruct := struct.findStructure(XML_DEVICEID);	tmpStruct.initializeWithTagData(tmpStruct.tagName, self.RTDeviceId, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_USERID);		tmpStruct.initializeWithTagData(tmpStruct.tagName, userId, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_TERMINAL);	tmpStruct.initializeWithTagData(tmpStruct.tagName, terminalCode, tmpStruct.tagAttribute);
	xmlVersion:= struct.findStructure(XML_VERSION).tagData;
	
	
	xmlSession.set(userId, self.RTDeviceId, terminalCode, xmlVersion, null/*_passwd*/);	
	
	self.assertNotNull(xmlSession.myTerminal);
	self.assertNotNull(xmlSession.myUser);
	self.assertNotNull(xmlSession.myDevice);
	
	
	//------------------------------------------------------------------
	//						creating / updating location
	//------------------------------------------------------------------
	remoteManager.processExternal(xmlStr, struct, xmlSession);
	self.assertNoTrxErrorsOrWarnings();
	
	location := getLogRow(_rowArea.id, _logRowId);
	self.assertNotNull(location);
	
	return location;

epilog

	delete remoteManager;
	delete xmlSession;
	delete struct;
	delete parser;
	
end;</source>
