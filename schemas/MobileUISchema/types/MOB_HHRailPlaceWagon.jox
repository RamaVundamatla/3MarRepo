    <JadeMethod name="hideAllPosButtons" id="78ce90ab-7921-452e-90ad-1d24ee5c004f">
        <source>hideAllPosButtons( wagon : CM_Wagon );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 August 2010	cnwndl1	Initial creation
14 Oct 2014	NDL	Par 35040

*/

vars

	size : Integer;
	index : Integer;
	btn : Button;
	
begin

	size := wagon.allLocationsControllersArray.size;
	if size = 0 then
		return;
	endif;
	foreach index in 1 to size do
		btn := self.btnWagonPos.getControl(index).Button;
		if btn &lt;&gt; null then
			btn.visible := false;
		endif;
	endforeach;
	
	if wagon.myWagonClass.maxNumInStack &gt; 1 then
		foreach index in 1 to size do
			btn := self.btnWagonPos2.getControl(index).Button;
			if btn &lt;&gt; null then
				btn.visible := false;
			endif;
		endforeach;
	endif; 

epilog

end;</source>
        <Parameter name="wagon" type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="hideOverlappedPriorPosi" id="3a6fe8a6-6e7c-4de0-85c7-7aaa8c0ba9a4">
        <source>hideOverlappedPriorPosi( _wagCont : CM_WagonController; heightIndex : Integer ) protected; 

/*

Purpose:	
		
		Hide the prior position buttonif it has less than 10 feet left on it,
		assuming the passed in wagon controller has cargo...
		because less than 10 feet is not useable.
		
Parameters:			

Return Value:		


Date		Who		Reason
18 August 2010	cnwndl1	Initial creation	Par 25215
14 Oct 2014	NDL	Par 35040

*/

vars

	indexOfWagCont : Integer;
	priorWagCont : CM_WagonController;
	posiIndex : Integer;
	posiButton : Button;
	
begin
	if _wagCont = null then
		return;
	endif;
	
	indexOfWagCont := _wagCont.myWagon.allLocationsControllersArray.indexOf(_wagCont);
	
	if indexOfWagCont = 1 then
		// I'm the first one, there is nothing prior to be part filled.
		return;
	endif;
		
	if _wagCont.allTrackedItems.isEmpty then
		// I'm not used, so the contiguous area will be at least 10 feet (i.e. big enough for a generator). 
		return;
	endif;

	priorWagCont := _wagCont.myPreviousController;
	
	if priorWagCont = null then
		// there is nothing prior to be part filled.
		return;
	endif;
	
	if not priorWagCont.allTrackedItems.isEmpty then
		// its used, nothing to do..
		return;
	endif;
	
	if priorWagCont.offsetFlexi &gt; 0 then
		// it is partly used....
		posiIndex := indexOfWagCont - 1;
		if heightIndex = 2 then
			posiButton := self.btnWagonPos2.getControl(posiIndex).Button;
		else
			posiButton := self.btnWagonPos.getControl(posiIndex).Button;
		endif;
		if posiButton &lt;&gt; null and posiButton.visible then
			posiButton.visible := false;
		endif;
	endif;
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_wagCont" type="CM_WagonController"/>
        <Parameter name="heightIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="isIdReversed" id="9ea1dee2-c1a3-4d3c-8f70-5d9470e9e656">
        <source>isIdReversed():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

begin

	return self.myTerminal.getConfig(RailHHWagonUseReversedID).Boolean;
	
epilog

end;</source>
