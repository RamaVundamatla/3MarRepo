    <JadeMethod name="valTerminal" id="da37b6d4-4f86-4db4-b459-44c60882df49">
        <source>valTerminal(pRealTerminal,pProxyTerminal:CM_Terminal);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//// 22 June 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------
vars
	tmpCode		: String;
	tempTerminal : CM_Terminal;
begin

	self.raiseExceptionIfNull(pProxyTerminal, 'Terminal Proxy');
	self.raiseExceptionIfNull(pRealTerminal, "Terminal Existing");
	pProxyTerminal.raiseExceptionIfNotProxy(method);
	
	tmpCode := pProxyTerminal.code;
	tempTerminal := app.myRoot.allTerminals[tmpCode];
	if (tempTerminal &lt;&gt; null) and (tempTerminal.code &lt;&gt; pRealTerminal.code) then
		app.raiseCMException(ERR_TERMINAL_DUPLICATE, pRealTerminal.code, null);
	endif;
	
	
	if pProxyTerminal.timeZoneID &lt;&gt; pRealTerminal.timeZoneID then				// 22 June 2016	cnwns1	TFS 488 - Multi Timezone Support
		app.raiseCMWarning(WARN_Change_timezone, "timezoneId", null, null);		// 22 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	endif;																		// 22 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	pProxyTerminal.validateForUpdate;


epilog
	
end;</source>
        <Parameter name="pRealTerminal" type="CM_Terminal"/>
        <Parameter name="pProxyTerminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="valTerminalArea" id="c9e477a0-3ee7-4a5e-b1a2-fbf3856d364b">
        <source>valTerminalArea(pProxyTA : CM_TerminalAreaMaster input; pRealTA : CM_TerminalAreaMaster);
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

