    <JadeMethod name="doUnmatch" id="2f66e09d-84b5-447a-bf39-4854958f0800">
        <updating/>
        <source>doUnmatch(_bolOut : CM_BOLOut; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     30 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	bolOutOrderLine		: CM_BOLOutStockOrderLineTI;
begin
	foreach bolOutOrderLine in self.allBOLOutStockOrderTIs do
		if bolOutOrderLine.myBOLOut = _bolOut then
			bolOutOrderLine.setForUpdate(null, self, null);
		endif;
	endforeach;

end;</source>
        <Parameter name="_bolOut" type="CM_BOLOut"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getConsignee" id="ddd71829-b669-4b7a-95c8-08b553d01fe5">
        <source>getConsignee(): CM_ConsigneeConsignor;
//----------------------------------------------------------------
//	Created:	31 March 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if self.myStockOrderHeader &lt;&gt; null then
		return app.myRoot.allConsigneeConsignors[self.myStockOrderHeader.getConsigneeCode];
	endif;

end;</source>
        <ReturnType type="CM_ConsigneeConsignor"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="791886ae-d992-4fa5-a514-accce491d50e">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     28 June 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _attrName = ETRow_NoFulfilled then
		if self.isTransient() then
			return null;
		else
			return self.getNumberFulfilled().String;
		endif;
	endif;
	
	return inheritMethod(_attrName, _short);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
