<Class name="CMQF_Container">
    <JadeMethod name="setFromAgent" id="d60b77a3-cabb-4692-ac0e-18c35003021a">
        <updating/>
        <source>setFromAgent(_agent : CMUI_ReportAgent input) updating;
// ---------------------------------------------------------------------------
// Created:     13 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	jobText			: String;
	jobIDStartPos	: Integer;
	listObject		: Object;
	tmpVoyJob	: CM_VoyageJob;
begin
	inheritMethod(_agent);

	self.connected := _agent.getValueByNameIfVisible(ETRow_IsConnected).Boolean;

	if _agent.isRowIncluded(ETRow_LastConnectDT) then
		if _agent.state = _agent.STATE_TEMPLATE_SAVE or
		   _agent.state = _agent.STATE_TEMPLATE_EDIT then
			/*self.setTemplateDateFields(_agent.getValueByNameIfVisible(ETRow_LastConnectDT).String, 
								self.onDateTplType, self.onDateTplFactor, ETRow_LastConnectDT);*/
			self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_LastConnectDT), 
								self.onDateTplType, self.onDateTplFactor, ETRow_LastConnectDT);
		else
//			self.onDate := _agent.getSelectedOnDate(); Par 11089
			self.onDate := _agent.getValueByNameIfVisible(ETRow_LastConnectDT).Date;	
		endif;
	endif;
	
// cnwdad1 19/11/2010 - PAR #25218.
	if _agent.isRowIncluded(ETRow_FromPackByDate) then
		if _agent.state = _agent.STATE_TEMPLATE_SAVE
		or _agent.state = _agent.STATE_TEMPLATE_EDIT
		then
			self.setTemplateDateFields(	_agent.getValueForTemplateDates(ETRow_FromPackByDate),
										self.startDateTplType,
										self.startDateTplFactor,
										ETRow_FromPackByDate);
//			self.fromPackByDate	:=	self.setDateFromTemplate(self.startDateTplType, self.startDateTplFactor, app.actualTimeServer().date());
		else
			self.fromPackByDate := _agent.getValueByNameIfVisible(ETRow_FromPackByDate).Date;
		endif;
	endif;
	if _agent.isRowIncluded(ETRow_ToPackByDate) then
		if _agent.state = _agent.STATE_TEMPLATE_SAVE
		or _agent.state = _agent.STATE_TEMPLATE_EDIT
		then
			self.setTemplateDateFields(	_agent.getValueForTemplateDates(ETRow_ToPackByDate),
										self.endDateTplType,
										self.endDateTplFactor,
										ETRow_ToPackByDate);
//			self.toPackByDate	:=	self.setDateFromTemplate(self.endDateTplType, self.endDateTplFactor, app.actualTimeServer().date());
		else
			self.toPackByDate := _agent.getValueByNameIfVisible(ETRow_ToPackByDate).Date;
		endif;
	endif;
// cnwdad1 19/11/2010 - PAR #25218, END.

	//30 Dec 2010	NDL	Par 26650
	if _agent.isRowIncluded(ETRow_FromEstReqDate) then
		if _agent.state = _agent.STATE_TEMPLATE_SAVE
		or _agent.state = _agent.STATE_TEMPLATE_EDIT
		then
			self.setTemplateDateFields(	_agent.getValueForTemplateDates(ETRow_FromEstReqDate),
										self.startDateTplType,
										self.startDateTplFactor,
										ETRow_FromEstReqDate);
		else
			self.fromPackByDate := _agent.getValueByNameIfVisible(ETRow_FromEstReqDate).Date;
		endif;
	endif;
	if _agent.isRowIncluded(ETRow_ToEstReqDate) then
		if _agent.state = _agent.STATE_TEMPLATE_SAVE
		or _agent.state = _agent.STATE_TEMPLATE_EDIT
		then
			self.setTemplateDateFields(	_agent.getValueForTemplateDates(ETRow_ToEstReqDate),
										self.endDateTplType,
										self.endDateTplFactor,
										ETRow_ToEstReqDate);
		else
			self.toPackByDate := _agent.getValueByNameIfVisible(ETRow_ToEstReqDate).Date;
		endif;
	endif;
	
	
	
	tmpVoyJob := _agent.getSelectedVoyageJob();
	if tmpVoyJob &lt;&gt; null then
		self.jobId := tmpVoyJob.id;
	endif;
	
	if _agent.isRowIncluded(ETRow_AvaGrade) then
		self.allQryAvaGrades.clear;
		_agent.getSelectedAvaGrades(self.allQryAvaGrades);
	endif;
	
	if _agent.isRowIncluded(ETRow_PackArea) then
		self.allQryPackAreas.clear;
		_agent.getSelectedPackAreas(self.allQryPackAreas);
	endif;
	
	if _agent.isRowIncluded(ETRow_EndTime) then
		self.onTime := _agent.getValueByNameIfVisible(ETRow_EndTime).Time;	
//		self.onTime := _agent.getSelectedEndTime();
	endif;
		
	if _agent.isRowIncluded(ETRow_PackByDate) then
		self.packByDate := _agent.getValueByNameIfVisible(ETRow_PackByDate).Date;	
	endif;
// cnwdad1 19/11/2010 - PAR #25218.
//// cnwdad1 16/08/2010 - PAR #25218.
//	if _agent.isRowIncluded(ETRow_FromPackByDate) then
//		self.fromPackByDate := _agent.getValueByNameIfVisible(ETRow_FromPackByDate).Date;	
//	endif;
//	if _agent.isRowIncluded(ETRow_ToPackByDate) then
//		self.toPackByDate := _agent.getValueByNameIfVisible(ETRow_ToPackByDate).Date;	
//	endif;
end;</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
