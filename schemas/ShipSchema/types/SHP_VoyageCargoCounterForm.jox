    <JadeMethod name="create" id="5e40be4d-0a1e-4939-9fbd-4ae4a194aab1">
        <updating/>
        <source>create() updating;
/*		
Date		Who		Reason
18 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars

begin
	self.permissionView		:= PmShipVoyageCargoCounter;
	self.permissionMaint	:= PmShipVoyageCargoCounter;

	self.helpFileName := HelpFile_Voyage;
	
	create self.myCargoCounterOutputAgent transient;
	
	self.isActual			:= true;
	self.isContainerCount	:= true;
	self.isContainerTEU		:= true;
	self.isGCArea			:= true;
	self.isGCCount			:= true;
	self.isGCLM				:= true;
	self.isGCQty			:= true;
	self.isGCVolume			:= true;
	self.isGCWeight			:= true;
epilog

end;</source>
    </JadeMethod>
