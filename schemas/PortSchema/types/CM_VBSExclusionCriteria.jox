    <JadeMethod name="validateMe" id="b4782de7-69da-4839-a461-e1aebc8ce449">
        <source>validateMe();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2015	cnwndl1	Initial creation	Par 36234

*/

vars

begin

	if self.myVehicleBookingTerminal = null then
		app.raiseCMException(Vehicle_booking_termina_refere, null, null);
	endif;
	
	inheritMethod();

epilog

end;</source>
