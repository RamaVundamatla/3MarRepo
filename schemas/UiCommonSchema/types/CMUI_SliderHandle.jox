    <JadeMethod name="doFrameMouseMove" id="03038248-26d8-4f41-bb89-1a559ebb85a1">
        <updating/>
        <source>doFrameMouseMove(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theColour : Integer;

begin
	on Exception do self.handleInvalidMethodCall(exception);
	
	self.form.sendMsgWithParams("doFrameSliderMouseMove",frame, button,shift, x, y);

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="handleInvalidMethodCall" id="4b7f0da7-2249-4473-9e0c-fdf3a02fa54e">
        <source>handleInvalidMethodCall(_exc : Exception) : Integer;

constants
	MethodWrong	= 1010;
	
vars
	returnVal		: Integer;
	
begin
	returnVal := Ex_Pass_Back;
	if _exc.errorCode = MethodWrong  then
		if _exc.resumable then
			returnVal := Ex_Resume_Next;
		endif;
	endif;

	return returnVal;

end;</source>
        <Parameter name="_exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initValues" id="82df39be-c552-4afb-aec0-31fd04a2a41d">
        <updating/>
        <source>initValues() updating;
// ---------------------------------------------------------------------------
// Created:     13 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.maxX := (self.parent.width - self.width -4);
	self.minX := 2;
	
	// % that 1 pixel equals, as 1 pixel is the smallest amount we can change by
	self.pixelPC := ((self.maxX - self.minX)/100);

//	app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1. self.parent.width: ' &amp; self.parent.width.String &amp; " self.width: " &amp; self.width.String &amp; " self.minX: " &amp; self.minX.String &amp; " self.maxX: " &amp; self.maxX.String &amp; " self.pixelPC: " &amp; self.pixelPC.String );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="mouseEnter" id="b476cfd2-c629-4ac6-8b42-ffd003cf3312">
        <updating/>
        <source>mouseEnter(frame: Frame input) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(frame);

	app.mousePointer := Window.MousePointer_WE;
	
	
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mouseMove" id="b3c65d54-b07b-4279-a135-f0852eecd01a">
        <controlMethod name="CMUI_MoveableFrame::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mouseMove(frame: CMUI_MoveableFrame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     13 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpX, tmpY,
	parentX,
	parentY			: Real;

begin

	if self.inDragMode then
		// convert x,y to be relative to parent window
		parentX := x + self.left;
		parentY := y + self.top;
//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1. self.minX: ' &amp; self.minX.String &amp; " self.maxX: " &amp; self.maxX.String );		
		tmpX := self.left + parentX - self.mouseDownX;
		if tmpX &gt; self.maxX then
			tmpX := self.maxX;
		endif;
		if tmpX &lt; self.minX then
			tmpX := self.minX;
		endif;
		
		tmpY := self.top;// + parentY - self.mouseDownY;
		
		self.move(tmpX, tmpY, self.width, self.height);
		
		self.setSlideValue();
		self.mouseDownX := parentX;
		self.mouseDownY := parentY;
		
//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1. %: ' &amp; self.valuePC.String &amp; " " &amp; " amt: " &amp; self.valueAmount.String &amp; '  Start: ' &amp; self.valueStart.String &amp; " End: " &amp; self.valueEnd.String);
		self.doFrameMouseMove(frame,button,shift,x,y);
	endif;
	
	//inheritMethod(frame, button, shift, x, y);

epilog

end;</source>
        <Parameter name="frame" type="CMUI_MoveableFrame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="moveToValues" id="e3dac820-cbf8-48cb-a8a9-34a21d3339fc">
        <updating/>
        <source>moveToValues(_value : Integer) updating; // value between 1 and 100, a percentage
// ---------------------------------------------------------------------------
// Created:     31 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	tmpValue : Integer;
	newLeft : Real;
begin
	if _value &lt; 1 then
		tmpValue := 1;
	elseif _value &gt; 100 then
		tmpValue := 100;
	else
		tmpValue := _value;
	endif;

	newLeft := (self.pixelPC * tmpValue);
	self.left := newLeft; // move the handle


//	app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1. tmpValue: ' &amp; tmpValue.String &amp; " self.pixelPC: " &amp; self.pixelPC.String &amp;  " newLeft: " &amp; newLeft.String);	


epilog

end;</source>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setSlideValue" id="188cb918-0bdd-4330-9842-9b837fd586ff">
        <updating/>
        <source>setSlideValue() updating;
// ---------------------------------------------------------------------------
// Created:     13 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
//
// set the % and amount based on the user moving the slider
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	
	self.valuePC := (self.left * self.pixelPC).Integer; // a value between 1 and 100
	if self.valuePC &gt; 100 then
		self.valuePC := 100;
	elseif self.valuePC &lt; 1 then
		self.valuePC := 1;
	endif;
	self.setValueAmount(self.valuePC);
//	app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1. Value : ' &amp; self.valuePC.String &amp; "% - self.pixelPC: " &amp; self.pixelPC.String &amp; " LEF: " &amp; self.left.String);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setValueAmount" id="3032490e-312b-4e62-a708-2de0b863bee8">
        <updating/>
        <source>setValueAmount(_valuePC : Decimal) updating;
// ---------------------------------------------------------------------------
// Created:     27 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
//
// pass in the percentage and this will set the value and move the handle
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
begin
	//What is the Actual value?
	

	self.valueAmount := (self.valuePerPC * _valuePC) + self.valueStart;
	self.valuePC := _valuePC;
	if self.valuePC &gt; 100 then
		self.valuePC := 100;
	elseif self.valuePC &lt; 1 then
		self.valuePC := 1;
	endif;
//write  "valueAmount: " &amp; valueAmount.String &amp; " valuePC: " &amp; _valuePC.String &amp; " self.valuePerPC: " &amp; self.valuePerPC.String;
	
epilog

end;</source>
        <Parameter name="_valuePC" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setValuePC" id="3dce28c6-c183-4a13-86c8-9c51f9eb751b">
        <updating/>
        <source>setValuePC(_valueAmount : Decimal) updating;
// ---------------------------------------------------------------------------
// Created:     27 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
//
// pass in an amount within the given start and end value range, this will set the percentage and move the handle.
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
begin
	if self.valueEnd = self.valueStart then
		return;
		
	endif;
	
	// What is the PC value?
	self.valuePC := (100 / ((valueEnd - valueStart) / (_valueAmount - valueStart)));
	if self.valuePC &gt; 100 then
		self.valuePC := 100;
	elseif self.valuePC &lt; 1 then
		self.valuePC := 1;
	endif;
	self.valueAmount := _valueAmount;
	//write  "valueAmount: " &amp; -valueAmount.String &amp; " valuePC: " &amp; valuePC.String;
epilog

end;</source>
        <Parameter name="_valueAmount" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setValueRange" id="9a4f7a31-b67b-4abd-9ef1-89d838bd3845">
        <updating/>
        <source>setValueRange(_start, _end : Decimal) updating;
// ---------------------------------------------------------------------------
// Created:     27 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
temp : Decimal[10,4];
begin

	self.valueStart := _start;
	self.valueEnd := _end;
	
	temp := ((valueEnd - valueStart) / 100);
	self.valuePerPC := ((valueEnd - valueStart) / 100);
	
//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1. 	temp: ' &amp; 	temp.String &amp; " self.valuePerPC: " &amp; self.valuePerPC.String );
epilog

end;</source>
        <Parameter name="_start" type="Decimal"/>
        <Parameter name="_end" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="8013dafb-129c-4718-80ff-a91422d45112">
        <controlMethod name="CMUI_MoveableFrame::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// ---------------------------------------------------------------------------
// Created:     13 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(cntrl, persistCntrl);

	if self.isInPainter() then
		return;
	endif;
	
	self.initValues();
epilog

end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
