    <JadeMethod name="makeMessageRFF_RE" id="db1bd79b-d381-4cd8-bd81-94ecc2ceadde">
        <source>makeMessageRFF_RE(_protocol :CM_CamProtocol; _group :HugeStringArray input; _ti :CM_TrackedItem):String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 March 2025	navra1	Initial creation - //navra1 - MTN-34174 - 7th Mar 2024

*/

vars
	msg, relReq	:String;
begin
	if _protocol.isCoarri213() then
		relReq := _ti.bulkReleaseAssignedCode;	
	endif;
	
	if relReq &lt;&gt; null then
		msg := self.makeRFFSegment (_protocol, _group, "RE", relReq);
	endif;
	
	return msg;
epilog

end;</source>
