<CollClass name="MOB_ControlsByNameDict" id="b302e8dc-61fe-4099-b0f2-6feb305c44c3">
    <duplicatesAllowed/>
    <loadFactor>66</loadFactor>
    <memberType name="Control"/>
    <superclass name="ExtKeyDictionary"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="radioTelemetry"/>
    <ExternalKey name="name">
        <length>31</length>
        <type name="String"/>
    </ExternalKey>
    <JadeMethod name="add" id="1740ee20-4d8e-47d7-8ea8-972c783ea8cd">
        <lockReceiver/>
        <updating/>
        <source>add(value: MemberType) updating, lockReceiver;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 January 2010	cnwndl1	Initial creation

*/

vars

begin
	if value &lt;&gt; null then
		self.putAtKey(value.name, value);
	endif;

end;</source>
        <Parameter name="value" type="MemberType"/>
    </JadeMethod>
    <JadeMethod name="remove" id="e5b2f165-385e-418c-a8ad-e71951955d77">
        <lockReceiver/>
        <updating/>
        <source>remove(value: MemberType) updating, lockReceiver;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 September 2013	cnwndl1	Initial creation	Par 32413

*/

vars

begin
	if value &lt;&gt; null then
		if self.includes(value) then
			self.removeKeyEntry(value.name, value);
		endif;
	endif;

epilog

end;</source>
        <Parameter name="value" type="MemberType"/>
    </JadeMethod>
</CollClass>
