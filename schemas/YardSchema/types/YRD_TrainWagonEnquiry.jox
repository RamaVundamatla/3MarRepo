    <JadeMethod name="create" id="e2ba3e69-b36c-4884-a332-c46cfcf9caaa">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>create() updating, clientExecution;
/*
----------   ----------  --------------------------------------------------
Created:	07 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.permissionView		:= PmAdmRailenqView;
	self.permissionMaint	:= PmAdmRailenqMaint;	 // TFS 2198
	self.helpFileName 		:= HelpFile_Yard;
	

end;


</source>
    </JadeMethod>
    <JadeMethod name="displayTable" id="4ef2d762-e6e0-4164-943a-549af5c45443">
        <updating/>
        <source>displayTable() updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theWagon 			: CM_Wagon;
	theDataLine 	: String;
	loadStateSet 	: Boolean;
	wagonDict			: CM_WagonByIDByDateDict;
	tbl				: CM_DataTable;
	voyage			: CM_Voyage;
begin
	self.mousePointer := Window.MousePointer_HourGlass;
	
	tbl := self.tblData;
	
	tbl.rows := tbl.fixedRows;
	self.doNotableClear();
	
	create wagonDict transient;
	
	if not self.allWagons.isEmpty() then
		self.allWagons.copy(wagonDict);
	elseif self.myCurrentTrain = null then
		self.myTerminal.allWagons.copy(wagonDict);
		if self.chkDepartedWagon.value then
			self.myTerminal.allWagonsDeparted.copy(wagonDict);
		endif;
	else
		if self.optDirIn.value then
			self.myCurrentTrain.allWagonsByIdInward.copy(wagonDict);
		else
			self.myCurrentTrain.allWagonsByIdOutward.copy(wagonDict);
		endif;
	endif;

	app.cmsBeginLoad(loadStateSet);
	foreach theWagon in wagonDict discreteLock do
		if not self.includeObject(theWagon) then
			continue;
		endif;
		
		theDataLine := theWagon.getAttributeStringForDefArray(tbl.allTblDataEntRows);
		tbl.accessRow(tbl.addItem(theDataLine)).itemObject := theWagon;
		
		self.doNotableAdd(theWagon);

	endforeach;
	
epilog
	delete wagonDict;
	app.cmsEndLoad(loadStateSet);
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doAddReleaseRequest" id="f320ec3b-8247-4559-a30f-60a66ce75d16">
