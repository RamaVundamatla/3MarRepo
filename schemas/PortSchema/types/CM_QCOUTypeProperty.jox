    <JadeMethod name="setComboValues" id="2d113f8d-0a3f-4e6b-b64a-1783fb568d5e">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
// ---------------------------------------------------------------------------
// Created:     22 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	_combo.clear();
	_combo.addItem(COU_UNDEFINED_NAME);
	_combo.addItem(COU_SHORT_NAME);
	_combo.addItem(COU_LONG_NAME);
	_combo.addItem(COU_MARINE_NAME);
	_combo.addItem(COU_LAND_NAME);
	
	if CM_QIntegerLookupEqual.hasInstance(_queryOperator) then
		_combo.text := self.translateToDisplayValue(_queryOperator.CM_QIntegerLookupEqual.searchValue);
	elseif CM_QIntegerLookupNotEqual.hasInstance(_queryOperator) then
		_combo.text := self.translateToDisplayValue(_queryOperator.CM_QIntegerLookupNotEqual.searchValue);
	endif;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="bbbe9f79-a2b8-40ed-86de-70d2a844421b">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QIntegerIsOneOf; _passport: CM_Passport);
// ---------------------------------------------------------------------------
// Created:     22 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	intArray	: IntegerArray;
	idx,intSite	: Integer;
	strObj		: CM_String;
begin

	_tbl.purgeTableObjects();
	_tbl.clear;
	_tbl.rows := _tbl.fixedRows;
	
	create intArray transient;
	
	intArray.add(COU_TYPE_UNDEFINED);
	intArray.add(COU_TYPE_SHORT);
	intArray.add(COU_TYPE_LONG);
	intArray.add(COU_TYPE_MARINE);
	intArray.add(COU_TYPE_LAND);

	self.setListTableFromIntConstants(_tbl, _operator, intArray, TI_COU_TYPE_Constant);	

epilog
	delete intArray;
end;

/*
vars

begin
	_tbl.rows := _tbl.fixedRows;
	
	_tbl.addItem(_operator.allSelectionValues.includes(COU_TYPE_UNDEFINED).Boolean.cnEcGetTableCheckBoxValue 
				&amp; Tab &amp; COU_UNDEFINED_NAME);
	_tbl.addItem(_operator.allSelectionValues.includes(COU_TYPE_SHORT).Boolean.cnEcGetTableCheckBoxValue 
				&amp; Tab &amp; COU_SHORT_NAME);
	_tbl.addItem(_operator.allSelectionValues.includes(COU_TYPE_LONG).Boolean.cnEcGetTableCheckBoxValue 
				&amp; Tab &amp; COU_LONG_NAME);
	_tbl.addItem(_operator.allSelectionValues.includes(COU_TYPE_MARINE).Boolean.cnEcGetTableCheckBoxValue 
				&amp; Tab &amp; COU_MARINE_NAME);
	_tbl.addItem(_operator.allSelectionValues.includes(COU_TYPE_LAND).Boolean.cnEcGetTableCheckBoxValue 
				&amp; Tab &amp; COU_LAND_NAME);


//TI_COU_TYPE_Constant
end;

*/</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QIntegerIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="6dae0af9-a156-4420-8926-0feda9ea8a4b">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
// ---------------------------------------------------------------------------
// Created:     22 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	str			: String;
	couType,
	numRows,
	idx			: Integer;
	ia			: IntegerArray;

begin

	create ia transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			couType := app.couTypeStringToEnum(_tbl.getCellText(idx, 2));
			ia.add(couType);
		endif;
	endforeach;
	
	_op.setSearchValue(ia);

epilog
	delete ia;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateStringToSearchValue" id="3ffc172d-df87-413b-836f-8ba4010efe68">
        <source>translateStringToSearchValue(_value: Any; _criteriaLine : CM_SelectorCriteriaLine ): Any;
// ----------------------------------------------------------------------
// Created 12 May 2008 by cnwvu1
//
// Purpose:	Gets value as String from RT screen and returns value
//			 into criteriaLineLine for running a query
// ----------------------------------------------------------------------

vars
	intCou	: Integer;

begin

	if _value.String.isInteger then
		return _value;
	endif;
	
	intCou := app.couTypeStringToEnum(_value.String);
	
	if intCou = COU_TYPE_UNDEFINED and _value &lt;&gt; null then	 //Par 17092	cnwvu1, June 2008
		app.raiseCMException2( ERR_FIELD_VALUE, _value.String, _criteriaLine.myQueryProperty.niceName, null, self );
	endif;
	
	return intCou;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="c85a54d5-f7af-4097-8d3f-28416f4939d5">
        <source>translateToDisplayValue(_couType : Integer): String;
// ---------------------------------------------------------------------------
// Created:     22 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	return app.couTypeEnumToString(_couType);

end;</source>
        <Parameter name="_couType" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="b7f045b3-697a-47a5-a723-00ac40fdd63d">
        <source>translateToSearchValue(_couTypeDescription : String): Any;
// ---------------------------------------------------------------------------
// Created:     22 September 2003	cnwth2
//
