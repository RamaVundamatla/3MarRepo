    <JadeMethod name="initSpecificReport" id="a443b3a9-d8a8-47f1-8869-d80e37c72d01">
        <updating/>
        <source>initSpecificReport(	_data			: CM_Object; 
					_dataClass,
					_printerName, 
					_userCode		: String; 
					_allTerminals	: CM_TerminalByCodeDict;
					_reportConstant, 
					_outputType		: Integer;
					_passport		: CM_Passport) updating;

// cnwdvb1 17 April 2003 

vars

begin

	self.myUser			:= _passport.myUser;
	_allTerminals.copy(self.allTerminals);
	self.myDataObject	:= _data;
	self.printerName	:= _printerName;
	self.reportConstant	:= _reportConstant;
	self.dataClass		:= _dataClass;
	self.myUser			:= app.myRoot.allUsers[_userCode.toUpper];
	self.outputType		:= _outputType;
	self.initRequestEvent(true, false, null);

end;</source>
        <Parameter name="_data" type="CM_Object"/>
        <Parameter name="_dataClass" type="String"/>
        <Parameter name="_printerName" type="String"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_allTerminals" type="CM_TerminalByCodeDict"/>
        <Parameter name="_reportConstant" type="Integer"/>
        <Parameter name="_outputType" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="processSpecificReport" id="dea81638-b8d5-4f5a-9d2d-8dcc676e3a64">
        <source>processSpecificReport() protected;

// cnwdvb1 17 April 2003 

vars

	theQryReport	: CM_QryReport;	
	filter			: CMQF_AnyDataObject;
	destination		: Integer;
	profName		: String;
	userReport 		: CM_MenuUserReport;
	user			: CM_User;
	userSet			: CM_UserSet;

begin

	app.myPassport.setMyTerminal(null);
	
	theQryReport := app.myRoot.myReportMenuRoot.getReportByConstantValue(self.reportConstant);
	if  theQryReport = null then
		app.raiseCMException1(BackgroundErrorGeneral, 'INFO &gt;&gt; Error processing specific report. Could not locate report definition',
		 null, null);
		return;
	endif;
	filter := theQryReport.createFilter().CMQF_AnyDataObject;
	filter.initialize();
	filter.dataClass	:= self.dataClass;
	filter.setMyDataObject( self.myDataObject );
	self.allTerminals.copy(filter.allTerminals);
	
	destination := JadeReportWriterReport.PRINTER;
	create userSet transient;
	userSet.add(user);
	
	app.myTrxCA.trxCreateAndRunBackgroundRpt(	false,
												theQryReport.reportName,
												null,
												profName,
												self.printerName,
												null,
												destination,
												self.outputType,
												false,
												filter,
												theQryReport,
												null,
												null,
												user.code,
												userSet,
                                                null, //MTN-36668
												app.myPassport);
		
/*	app.myTrxCA.trxCreateMenuUserReport(	filter,
											theQryReport,
											destination,
											profName,
											userReport, 
											null,
											app.getMyUser.myMenuRootBGRCurrent, 
											null,
											false, 
											theQryReport.reportName,
											null,
											self.printerName,
											null,
											self.outputType,
											app.myPassport);*/
							
	if app.myPassport.trxCompletedOK then
		return;
	endif;
	app.raiseCMException1(BackgroundErrorGeneral, 'INFO &gt;&gt; Error processing specific report ' &amp; theQryReport.reportName, null, null);
epilog
	delete filter;
	delete userSet;
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
