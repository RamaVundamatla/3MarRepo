    <JadeMethod name="getSystemModeDesc" id="e68dd07f-01e9-4dac-ac8e-39e047dc4c19">
        <source>getSystemModeDesc() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2019	jlger1	Initial creation 42569
 
*/

vars

begin
	if self.systemMode = CM_Root.SystemMode_Dev then
		return  "Development";
	elseif self.systemMode = CM_Root.SystemMode_Production then
		return "Production";
	elseif self.systemMode = CM_Root.SystemMode_Test then
		return "Test";
	elseif self.systemMode = CM_Root.SystemMode_UAT then
		return "UAT";
	else
		return  "Unknown";
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSystemModeFromString" id="bf7dece6-5be6-4983-aff1-86c0a1449547">
        <source>getSystemModeFromString(_value : String) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 May 2019	jlger1	Initial creation 42569

*/

vars

begin
	if _value = "Development"  then
		return CM_Root.SystemMode_Dev;
	elseif _value = "Production"  then
		return CM_Root.SystemMode_Production;
	elseif _value ="Test"  then
		return CM_Root.SystemMode_Test;
	elseif _value ="UAT"  then
		return CM_Root.SystemMode_UAT;	
	endif;
	
	return SystemMode_Dev;
epilog

end;</source>
        <Parameter name="_value" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSystemModeShortDesc" id="b86f22b2-a860-428a-83b7-2c18cf9d7d1e">
