    <JadeMethod name="createDragSelectFrame" id="7a149cb5-688b-4ef0-9c9c-aa444cad46cf">
        <updating/>
        <source>createDragSelectFrame() updating;
// ---------------------------------------------------------------------------
// Created:		07 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	delete self.myDragSelectFrame;
	create self.myDragSelectFrame transient ;
	
	self.myDragSelectFrame.parent := self;
	self.myDragSelectFrame.setForCreate();
	self.form.addControl(self.myDragSelectFrame);

end;</source>
    </JadeMethod>
    <JadeMethod name="getBayFrameFromXY" id="4f9c9ebe-2280-46eb-a503-dae26adf6d24">
        <source>getBayFrameFromXY(x: Real; y: Real) : CMUI_GridAreaDrawingFrame;
// ---------------------------------------------------------------------------
// Created:		07 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
vars

begin
	if self.form.isKindOf(SHP_VoyageAreaForm2) then															// PAR #36766
		return self.form.SHP_VoyageAreaForm2.myBayDrawingController.getBayFrameFromXY(x,y);
	elseif self.form.isKindOf(SHP_BulkVoyagePlanningForm) then												// PAR #36766
		return self.form.SHP_BulkVoyagePlanningForm.myBulkDrawingController.getHoldFrameFromXY(x,y);		// PAR #36766
	else																									// PAR #36766
		return null;																						// PAR #36766
	endif;																									// PAR #36766
end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <ReturnType type="CMUI_GridAreaDrawingFrame"/>
    </JadeMethod>
    <JadeMethod name="getHoldFrameFromXY" id="5a2e0b5f-4b7f-42e7-8ae7-b8ac67a16030">
        <source>getHoldFrameFromXY(x : Real; y : Real) : SHP_BulkDrawingFrame;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars

begin
	return self.form.SHP_BulkVoyagePlanningForm.myBulkDrawingController.getHoldFrameFromXY(x,y);
epilog

end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <ReturnType type="SHP_BulkDrawingFrame"/>
    </JadeMethod>
    <JadeMethod name="resizeDragFrame" id="8d07018e-3a39-4962-be07-f26589529b04">
        <source>resizeDragFrame();
// ---------------------------------------------------------------------------
// Created:		07 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.myDragSelectFrame.move(0,0,self.clientWidth,self.clientHeight);
end;</source>
    </JadeMethod>
    <JadeMethod name="selectBlockOfObjectsFromXYs" id="a400b952-6188-43e2-bc99-8004a53763c0">
        <updating/>
        <source>selectBlockOfObjectsFromXYs( _class : Class; _x1,_y1,_x2,_y2 : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		07 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.form.SHP_VoyageAreaForm2.myBayDrawingController.selectBlockOfObjectsFromXYs(_class,_x1,_y1,_x2,_y2 );

	
end;</source>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
    </JadeMethod>
