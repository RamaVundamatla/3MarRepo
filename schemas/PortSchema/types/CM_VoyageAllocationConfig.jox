<Class name="CM_VoyageAllocationConfig" id="f5282312-4521-4e8f-b445-5873cf778c22">
    <superclass name="CM_YAIMEXConfig"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="voyages"/>
    <ExplicitInverseRef name="myVoyage" id="28437bba-49c8-496a-bc5c-c76f2f73882e">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Voyage"/>
        <access>readonly</access>
        <Inverse name="CM_Voyage::allVoyageAllocationConfigs"/>
    </ExplicitInverseRef>
    <ImplicitInverseRef name="myYACriteriaTypeForColour" id="fa65a7d9-5182-47da-bee0-50b66c78d67b">
        <embedded/>
        <type name="CM_YACriteriaType"/>
        <access>readonly</access>
