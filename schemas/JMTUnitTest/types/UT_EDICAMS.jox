		self.assertTrueMsg(sent_5.compareEql(exp_5,true,false,null),"The message sent for UC5 was not as expected"&amp;"SENT"&amp;CrLf&amp;sent_5&amp;"EXPECTED"&amp;CrLf&amp;exp_5);		
	endif;
	
	theLines.purge();
	delete theLines;			
	
