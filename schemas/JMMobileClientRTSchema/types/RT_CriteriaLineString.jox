<GUIClass name="RT_CriteriaLineString" id="23589e2f-5c3e-453b-a03c-28487466bd6d">
    <superclass name="RT_CriteriaLineValue"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <ExplicitInverseRef name="myTxtSearchValueA" id="1b69c8f6-b56d-455b-8e46-97cf04175c81">
        <kind>parent</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="TextBox_QueryCriteria"/>
        <access>readonly</access>
        <Inverse name="TextBox_QueryCriteria::myCriteriaLineString"/>
    </ExplicitInverseRef>
    <JadeMethod name="createControlsForTheForm" id="cdf5dfaa-26b5-4fb2-b702-65c61ac50a6a">
        <updating/>
        <source>createControlsForTheForm( 	_lblCriteriaCaption: String; 
							_searchValueA: String; _searchValueB: String; _optBtnValue: Boolean; 
							_slip: Real) updating;
// ---------------------------------------------------------------------------------------------
// Created 07 may 2008 by cnwvu1
// ---------------------------------------------------------------------------------------------

vars
	clonedTextBox	: TextBox_QueryCriteria;
	numb			: Integer;
	exampleTxt		: TextBox_QueryCriteria;

begin

	if self.myForm.aAllQueryCriteriaLines.isEmpty then
		return;
	endif;
	
	inheritMethod(_lblCriteriaCaption, _searchValueA, _searchValueB, _optBtnValue, _slip);
	
	if self.myForm.aAllQueryCriteriaLines.size = 1 then

		// creating the first criteria line - using controls on a form
		self.myTxtSearchValueA		:= self.myForm.txtSearchValueA1;
		// default searching values for captions
		self.myTxtSearchValueA.text	:= _searchValueA;
	
	else
	
		// cloning controls for the other criteria lines
		numb := self.myForm.aAllQueryCriteriaLines.size;

		// cloning txtSearchValueA1 and txtSearchValueB1
		exampleTxt				:= self.myForm.txtSearchValueA1;
		clonedTextBox			:= exampleTxt.cloneSelf( true );
		clonedTextBox.setForCreate( self.myForm,
									exampleTxt.name.String[ 1 : exampleTxt.name.length()-1 ] &amp; numb.String,
									_searchValueA,
									exampleTxt.parent.Control,
									exampleTxt.top + _slip );
		self.myTxtSearchValueA	:= clonedTextBox;

	endif;
	
end;
</source>
        <Parameter name="_lblCriteriaCaption" type="String"/>
        <Parameter name="_searchValueA" type="String"/>
        <Parameter name="_searchValueB" type="String"/>
        <Parameter name="_optBtnValue" type="Boolean"/>
        <Parameter name="_slip" type="Real"/>
    </JadeMethod>
    <JadeMethod name="deleteClone" id="5142417f-d9be-44bd-8103-facb701edbe8">
        <updating/>
        <source>deleteClone() updating;
// -------------------------------------------
// Created 07 may 2008 by cnwvu1
// -------------------------------------------
vars
	criteriaLine : RT_QueryCriteriaLine;

begin

	criteriaLine := myForm.aAllQueryCriteriaLines.first;
	
	if criteriaLine = null then
		return;
	endif;
	
	if criteriaLine = self then
	
		// hiding controls on the form
		self.myTxtSearchValueA.visible	:= false;
		//breaking reference and saving the buttons on a form as example for cloning
		self.myTxtSearchValueA	:= null;
		
	endif;
	
	inheritMethod();	// deletes a criteriaLine
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="getDtoDefinitionFromRT" id="cd771a74-0323-4eb7-974d-ed93a19d0678">
        <source>getDtoDefinitionFromRT(	_queryOperatorOid, _propClassName, _propName : String output;
						_searchValueA, _searchValueB : String output; _searchValueBoolean : Boolean output );
// -----------------------------------------------------------------------------------------------
// Created 07 may 2008 by cnwvu1
// -----------------------------------------------------------------------------------------------

vars

begin

	inheritMethod(_queryOperatorOid, _propClassName, _propName, _searchValueA, _searchValueB, _searchValueBoolean);
	
	_searchValueA		:= self.myTxtSearchValueA.text;

end;
</source>
        <Parameter name="_queryOperatorOid" type="String" usage="output"/>
        <Parameter name="_propClassName" type="String" usage="output"/>
        <Parameter name="_propName" type="String" usage="output"/>
        <Parameter name="_searchValueA" type="String" usage="output"/>
        <Parameter name="_searchValueB" type="String" usage="output"/>
        <Parameter name="_searchValueBoolean" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="8959ebe0-e27f-4acb-8e7a-24b4a87d676e">
        <updating/>
        <source>setForCreate( _form : RadioTelemetryMainForm; 
				_propClassName, _propName, _queryOperatorOid : String;
				_lblCriteriaCaption, _searchValueA, _searchValueB : String; 
				_optBtnValue : Boolean;
				_slip : Real; _tabIndex : Integer ) updating;
// -------------------------------------------
// Created 07 may 2008 by cnwvu1
// -------------------------------------------

vars

begin

	inheritMethod(_form, _propClassName, _propName, _queryOperatorOid, _lblCriteriaCaption, _searchValueA, _searchValueB, _optBtnValue, _slip, _tabIndex );
	
	self.myTxtSearchValueA.visible	:= true;
	self.myTxtSearchValueA.tabIndex	:= _tabIndex;
	
end;
</source>
        <Parameter name="_form" type="RadioTelemetryMainForm"/>
        <Parameter name="_propClassName" type="String"/>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_queryOperatorOid" type="String"/>
        <Parameter name="_lblCriteriaCaption" type="String"/>
        <Parameter name="_searchValueA" type="String"/>
        <Parameter name="_searchValueB" type="String"/>
        <Parameter name="_optBtnValue" type="Boolean"/>
        <Parameter name="_slip" type="Real"/>
        <Parameter name="_tabIndex" type="Integer"/>
    </JadeMethod>
