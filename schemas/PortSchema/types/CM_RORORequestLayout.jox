    <JadeMethod name="getDeckItem" id="4aefb46d-31cd-45af-a5a8-e5add44243c5">
        <source>getDeckItem():CM_DeckItem;
/*
Date		Who		Reason
01 Aug 2012	cnwcs5	Initial creation - par 29124
*/
vars
	request		:CM_RORORequest;
	lc			:CM_VoyageROROController;
	lane		:CM_ROROLaneController;
	deckItem	:CM_DeckItem;
begin
	request := self.myRequest;
	
	if request = null then
		return null;
	endif;
	
	lc := request.myROROController;
	
	if lc = null then
		return null;
	endif;
	
	if lc.isKindOf(CM_ROROLanePositionController) then
		lane := lc.CM_ROROLanePositionController.myLaneController;
		
		if lane = null then
			return null;
		endif;
		
		deckItem := lane.getDefn();
	else
		deckItem := lc.getDefn();
	endif;
	
	return deckItem;
epilog

end;</source>
        <ReturnType type="CM_DeckItem"/>
    </JadeMethod>
    <JadeMethod name="getDeckItemLayout" id="48edaa3a-3a46-4dab-842e-c123342eb47a">
