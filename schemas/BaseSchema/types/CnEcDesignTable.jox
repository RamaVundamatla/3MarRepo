    <JadeMethod name="unselectRow" id="e7c6ad10-b409-47b3-8e7d-1187104f8cdc">
        <updating/>
        <source>unselectRow() updating;

vars
	loopIndex					: Integer;
	rowIndex					: Integer;
begin
	rowIndex := self.row;
	if rowIndex &gt; 1 then
		loopIndex := self.columns;
		while loopIndex &gt; 1 do
			self.setCellSelected(rowIndex, loopIndex, false);
			loopIndex := loopIndex - 1;
		endwhile;
		self.column := 1;
		if self.itemObject = selectedObject then
			selectedObject := null;
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="updateThisRow" id="a2937932-0f43-41f5-a140-587c32f604b5">
        <updating/>
        <source>updateThisRow(obj : Object; thisRow : Integer) updating;

vars
	loopIndex					: Integer;
	maxIndex					: Integer;
	accessModeSave				: Integer;
begin
	self.column := 1;
	self.row 	:= thisRow;
	self.itemObject := obj;

	loopIndex := 2;
	maxIndex := self.columns;
	while loopIndex &lt;= maxIndex do

		if columnInputTypeArray[loopIndex - 1][1:1] = Table.InputType_ComboBox.String then
			self.column := loopIndex;
			accessModeSave := self.accessMode;
			self.accessMode := Table.AccessMode_Cell;
//			self.comboList := self.displayEntry(self, obj, self.getCellText(1, loopIndex));
			self.comboList := self.displayEntry(self, obj, self.columnHeadingArray[loopIndex - 1]);
			self.comboIndex := 1;
			self.accessMode := accessModeSave;
		else
//			self.setCellText(thisRow, loopIndex, self.displayEntry(self, obj, self.getCellText(1, loopIndex)));
			self.setCellText(thisRow, loopIndex, self.displayEntry(self, obj, self.columnHeadingArray[loopIndex - 1]));
		endif;
		if columnPictureArray[loopIndex - 1] then	//	the arrays do not know about column 1 at runtime
			self.column := loopIndex;
//			self.picture := self.displayPicture(self, obj, self.getCellText(1, loopIndex));
			self.picture := self.displayPicture(self, obj, self.columnHeadingArray[loopIndex - 1]);
		endif;

		loopIndex := loopIndex + 1;
	endwhile;
	self.column := 1;

	if currentSession &lt;&gt; null then
		if webHyperlinkColumn &gt; 0 and webHyperlinkColumn &lt; self.columns then
			self.hyperlinkColumn[thisRow] := webHyperlinkColumn + 1;
		endif;
	endif;
end;</source>
        <Parameter name="obj" type="Object"/>
        <Parameter name="thisRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="3abb9044-9fb6-4a24-9c4e-fd603cbb8dd2">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;

vars
	loopIndex					: Integer;
	maxIndex					: Integer;
	obj							: Object;
	f							: Form;
	ctl							: Control;
	formX						: Real;
	formY						: Real;
begin
	if self.isInPainter() then
		if persistCntrl = cntrl then
			persistTable := cntrl.userObject.CnEcDesignTable;
		else
			persistTable := persistCntrl.CnEcDesignTable;
		endif;

		if persistTable = null then
			foreach obj in Form.instances do
				if obj.Form.name = self.form.name then
					f := obj.Form;
					break;
				endif;
			endforeach;
			if f &lt;&gt; null then
				maxIndex := f.controlCount;
				loopIndex := 1;
				while loopIndex &lt;= maxIndex do
					ctl := f.controls(loopIndex);
					if ctl.name = self.name then
						persistTable := ctl.CnEcDesignTable;
						break;
					endif;
					loopIndex := loopIndex + 1;
				endwhile;
			endif;
			if persistTable = null then
				persistTable := cntrl.userObject.CnEcDesignTable;
			endif;
		endif;
		
		self.sizeColumnArrays();
	else
		create myMenuForm transient;
		myMenuForm.transientTable := self;
		myMenuForm.minButton := false;
		myMenuForm.maxButton := false;
		myMenuForm.controlBox := false;
		myMenuForm.caption := "";
// cnwdad1 24/06/2005 - The controlToForm method has been de-implemented. Now using the
// Control::convertFormPositioin instead.
//		self.form.controlToForm(self.hwnd(), formX, formY);
//		self.form.windowToScreen(formX, formY);
		formX	:=	self.getFormLeft();
		formY	:=	self.getFormTop();
		self.convertFormPosition(formX, formY);
		myMenuForm.setFormParent(self.form);
		myMenuForm.move((formX).Integer,(formY).Integer,0, 0);
		myMenuForm.visible := false;
	endif;

	buildTableColumns();

	inheritMethod(cntrl, persistCntrl);

	if currentSession &lt;&gt; null then
		disableVirtualScroll := true;
	//
	//
	//
		self.width := self.width - 15;
		create webPreviousButton transient;
		webPreviousButton.previousButton := true;
		create webNextButton transient;
		webPreviousButton.parent := self.parent;
		webNextButton.parent := self.parent;
		self.form.addControl(webPreviousButton);
		self.form.addControl(webNextButton);
	endif;

	/*	Create the vertical scrollbar */
	create myVerticalScrollBar transient;
	myVerticalScrollBar.parent 		:= self.parent;
    myVerticalScrollBar.visible 	:= false;
   	self.currentScrollbarPosition	:= 0;
   	myVerticalScrollBar.min			:= 1;
	myVerticalScrollBar.max			:= self.rows;
   	myVerticalScrollBar.smallChange	:= 1;
   	myVerticalScrollBar.largeChange := self.lines();
   	if myVerticalScrollBar.max &gt; self.lines() then
   		myVerticalScrollBar.visible := true;
   	endif;

   	if disableVirtualScroll then
   		if self.scrollBars = Window.ScrollBars_None or self.scrollBars = Window.ScrollBars_Vertical then
   			self.scrollBars := ScrollBars_Vertical;
   		else
   			self.scrollBars := Window.ScrollBars_Both;
   		endif;
   	endif;

    /*	Add the scrollbar control to the form */
	self.form.addControl (myVerticalScrollBar);
	positionScrollbar();
	myVerticalScrollBar.zOrder(1);
	if self.dropDown &gt; 0 then
		myVerticalScrollBar.visible := false;
	endif;

	if not self.isInPainter() then
	/*	Remember the size of the Table */
		currentWidth	:= self.width;
		currentHeight	:= self.height;
		currentLeft		:= self.left;
		currentTop		:= self.top;

	/* Load the Table */
		if myCollectionOid &lt;&gt; null then
			if sortOrder = SORT_COLLECTION then
				self.myIterator.reset;
				self.loadSubset (END_OF_LIST);
			else
				self.myIterator.reset;
				self.loadSubsetReversed(END_OF_LIST);
			endif;
			self.currentScrollbarPosition := 1;
		endif;
	endif;
	if self.dropDown &gt; 0 then
		myVerticalScrollBar.visible := false;
	endif;
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
