<Class name="WS_NSDSArgoYard" id="cb4d2332-dbdf-4075-b1d6-fc94aa42a369">
    <superclass name="WS_NSDSObject"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="abm_gkey" id="29680374-0a83-444d-8ecc-d290d230ba5a">
        <embedded/>
        <type name="Integer64"/>
    </PrimAttribute>
    <PrimAttribute name="fcy_gkey" id="b762cb2c-82ea-4dfb-ace4-f136448b907b">
        <embedded/>
        <type name="Integer64"/>
    </PrimAttribute>
    <PrimAttribute name="id" id="22998036-775c-4fe8-8523-685c54295b92">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="name" id="9ab8253e-5601-430c-8645-f3c5b1a8b038">
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="setProxyObject" id="5e620304-eafb-40e7-9e10-b3bb23676a4f">
        <updating/>
        <source>setProxyObject(_any: Any) updating;
/*
Purpose:			

Date		Who		Reason
28 April 2022	navab1	TFS 53369
*/

vars
	helper 	: CMIF_ArgoYard;
	ewsOpsView: CM_EWSActivityOpsview;
begin
	
	inheritMethod(_any);
	
	create helper transient;
	create ewsOpsView transient;
	ewsOpsView.initialiseActivity("","",_any.CM_Object.getMyTerminal(),_any.CM_Object, null,null,false,null);
	helper.initializeForActivity(_any, ewsOpsView);
	
	self.tableName	:= helper.tableName;
	self.gkey       := helper.gkey;
	self.id 		:= helper.id;
	self.name 	    := helper.name;
	self.abm_gkey 	    := helper.abm_gkey;
	self.fcy_gkey 	    := helper.fcy_gkey;

epilog
	delete helper;
	delete ewsOpsView;

end;</source>
        <Parameter name="_any" type="Any"/>
    </JadeMethod>
</Class>
