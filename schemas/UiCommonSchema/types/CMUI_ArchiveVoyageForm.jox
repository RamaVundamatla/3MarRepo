    <JadeMethod name="continueArchiveAfterCheck" id="d12c310d-9cc1-4bb6-8472-a230596f1adf">
        <source>continueArchiveAfterCheck(_removeEDITIs, 
						  _removeNonWorkedTIs, 
						  _removePrenoteTIs, 
						  _removeTBATIs, 
						  _removeBookRefs, 
						  _archiveBookRefs 		: Boolean input): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 Feb 2004	cnwsh3	Initial creation
12 Mar 2020 cnwma1  Bug 48863: JMT - Voyage Archive, Non Worked Cargo Issue	

*/
vars
	ediNum			  : Integer;
	nonWorkedNum	  : Integer;
	prenoteNum		  : Integer;
	removeTBANum	  : Integer;
	removeBookRefNum  : Integer;
	archiveBookRefNum : Integer;
	structure		  : CM_CellularVoyageStructure;
	bayCount,
	slotCount		  : Integer;
	bayVoy			  : CM_BayVoyage;
	msgInfo			  : String;
	voyageInfo		  : String;
	voyageObj		  : CM_Voyage;
	isClear			  : Boolean;
	termVoyCount	  : Integer;
	robToBeDeleted    : CM_TISet;
	removeRRPNum	  : Integer;
begin
	if self.aAllVoyages.isEmpty() then
		return false;
	endif;
	
	isClear	:=	true;
	
	foreach voyageObj in self.aAllVoyages do
		
		/* 
		13/03/2020 cnwma1 Bug #48863
		structure	:=	voyageObj.myCellularVoyageStructure;
		if structure = null then
			// continue as HMS voyages can be archived, but
			// the following is only for cellular voyages.
			continue;
		else
			isClear	:=	false;
		endif;
		*/
		isClear	:=	false; 
		
		if voyageInfo = null then
			voyageInfo	:=	"Voyage " &amp; voyageObj.code &amp; ": " &amp; CrLf;
		else
			voyageInfo	:=	voyageInfo &amp; CrLf &amp; "Voyage " &amp; voyageObj.code &amp; ": " &amp; CrLf;
		endif;
		
		/* 
		13/03/2020 cnwma1 Bug #48863
		bayCount := structure.allBayVoyagesByOrdinal.size();
		
		foreach bayVoy in structure.allBayVoyagesByOrdinal do
			slotCount := slotCount + bayVoy.allSlotControllersByOrdinal.size();
		endforeach;
		
		if slotCount &lt;&gt; null then
			voyageInfo	:=	voyageInfo &amp; slotCount.String &amp; ' slot controller(s), ';
		endif;
		*/
		
		if _removeEDITIs then
			ediNum := voyageObj.allEDIBayPlans.size;
			if ediNum &lt;&gt; null then
				voyageInfo	:=	voyageInfo &amp; ediNum.String &amp; ' EDI bay plan(s)'&amp; CrLf;
			endif;
		endif;
		
		if _removeNonWorkedTIs then
			//nonWorkedNum := voyageObj.allOnshipTIsByCargoTypeId.size; 			   //12.03.2020 cnwma1  #48863
			create robToBeDeleted transient;
			nonWorkedNum   := voyageObj.getNonWorkedROB(robToBeDeleted);               //12.03.2020 cnwma1  #48863
			if nonWorkedNum &lt;&gt; null then
				voyageInfo	:=	voyageInfo &amp; nonWorkedNum.String &amp; ' remain on board tracked item(s) ' &amp; CrLf;
			endif;
		endif;
		
		if _removePrenoteTIs then
			prenoteNum := voyageObj.allNotifiedTIsByCargoTypeId.size;
			if prenoteNum &lt;&gt; null then 
				voyageInfo	:=	voyageInfo &amp; prenoteNum.String &amp; ' prenotified tracked item(s)'&amp; CrLf;
			endif;
		endif;
		
		if _removeTBATIs then
			removeTBANum := voyageObj.allTbaTIsByCargoTypeId.size;
			if removeTBANum &lt;&gt; null then
				voyageInfo	:=	voyageInfo &amp; removeTBANum.String &amp; ' TBA tracked item(s) '&amp; CrLf;
			endif;
			//16 Mar 2020	NDL	TFS 47004
			removeRRPNum := voyageObj.allRRPTIsByCargoTypeId.size;
			if removeRRPNum &lt;&gt; null then
				voyageInfo	:=	voyageInfo &amp; removeRRPNum.String &amp; ' RRP tracked item(s) '&amp; CrLf;
			endif;
		endif;
		if _removeBookRefs then
			removeBookRefNum := voyageObj.allBookingRefs.size;
			if removeBookRefNum &lt;&gt; null then
				voyageInfo	:=	voyageInfo &amp; removeBookRefNum.String &amp; ' Booking Reference(s) ' &amp; CrLf;
			endif;
		endif;
		//10 Sep 2009	NDL	Par 20413
		if _archiveBookRefs then
			archiveBookRefNum := voyageObj.allBookingRefs.size;
			if archiveBookRefNum &gt; 0 then
				voyageInfo	:=	voyageInfo &amp; archiveBookRefNum.String &amp; ' Booking Reference(s) '&amp; CrLf;
			endif;
		endif;
		
		//24 Jan 2011	NDL	Par 26676
		if not voyageObj.allVoyageInlandTerminals.isEmpty then
			termVoyCount := termVoyCount + voyageObj.allVoyageInlandTerminals.size;
		endif;
		
	endforeach;
	
	if isClear then
		return true;
	endif;
	
	msgInfo	:=	"There are:" &amp; CrLf &amp; CrLf &amp; voyageInfo &amp; CrLf &amp; CrLf &amp; "...to process or check.";
	
	//if prenoteNum = null and removeTBANum = null and slotCount = null and ediNum = null and nonWorkedNum = null then  //13/03/2020 cnwma1 Bug #48863
	if prenoteNum = null and removeTBANum = null  and ediNum = null and nonWorkedNum = null then                        //13/03/2020 cnwma1 Bug #48863
		msgInfo	:=	null;
	endif;
	
	//24 Jan 2011	NDL	Par 26676
	if termVoyCount &gt; 0 then
		if msgInfo &lt;&gt; null then
			msgInfo := msgInfo &amp; CrLf&amp; CrLf;
		endif;
		msgInfo := msgInfo &amp; app.getErrorString1(Related_inland_terminals, termVoyCount.String);
	endif;
	
	if app.msgBox(	msgInfo &amp; CrLf &amp; CrLf &amp; app.getErrorString(ArchiveConfirm) &amp; CrLf &amp; 
					app.getErrorString(AbortWarning) &amp; CrLf &amp; CrLf &amp; 
					app.getErrorString(AreYouSure) ,
					app.getErrorString(ArchiveConfirmProcess),
					MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes then
		return true;
	else 
		return false;
	endif;
epilog
	delete robToBeDeleted;
end;</source>
        <Parameter name="_removeEDITIs" type="Boolean" usage="input"/>
        <Parameter name="_removeNonWorkedTIs" type="Boolean" usage="input"/>
        <Parameter name="_removePrenoteTIs" type="Boolean" usage="input"/>
        <Parameter name="_removeTBATIs" type="Boolean" usage="input"/>
        <Parameter name="_removeBookRefs" type="Boolean" usage="input"/>
        <Parameter name="_archiveBookRefs" type="Boolean" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="3e873811-3b45-4fd8-9d89-517ed6bee500">
        <updating/>
        <source>create() updating;
//--------------------------------------------------
// Created:	11 August 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.helpFileName := HelpFile_Voyage;
	self.permissionView  := PmVoyageArchive;
	self.permissionMaint := PmVoyageArchive;
end;</source>
    </JadeMethod>
    <JadeMethod name="doArchive" id="90593e5c-1d74-4458-8c26-8c525cdb399d">
        <updating/>
        <source>doArchive() : Boolean updating;
//--------------------------------------------------
// Created:	11 August 2005 By: cnwgd1
//--------------------------------------------------
vars
	removeEDITrackedItems,
	removeNonWorkedTrackedItems,
	removePreNotifiedTrackedItems,
	removeTBATrackedItems : Boolean;
	removeBookRef : Boolean;
	archiveBookRef : Boolean;
	archiveInt	: CMIF_ArchiveVoyage;
	theMonitor	: CMIF_Monitor;
	voyageObj	: CM_Voyage;
	isInError	: Boolean;
	tmpMess : String;
	
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
	
begin

	if self.aAllVoyages.isEmpty() then
		return false;
	endif;
	
	isInError	:=	false;

	foreach voyageObj in self.aAllVoyages do
		if not voyageObj.canVoyageBeArchived(tmpMess,not self.cbxCompleteJobs.value) then //jlier1 JIRA#28679 10/12/24
			app.msgBox( app.getErrorString(Cannot_archive_voyage) &amp;" (" &amp; voyageObj.code &amp; "). " &amp; Cr &amp; Cr &amp; tmpMess, app.getErrorString(Archive_aborted), MsgBox_Exclamation_Mark_Icon);
			isInError	:=	true;
		
		endif;
	endforeach;
	
	
	foreach voyageObj in self.aAllVoyages do
		if voyageObj.isTransient() then
			app.raiseUnexpectedProgramError(class.name, method.name, "Cannot archive an unsaved voyage (" &amp; voyageObj.code &amp; ").");
			isInError	:=	true;
		endif;
	endforeach;
	
	if isInError then
		return false;
	endif;
	
	app.mousePointer	:=	Window.MousePointer_HourGlass;

	removeEDITrackedItems			:=	self.cbxRemoveEDI.value;
	removeNonWorkedTrackedItems		:=	self.cbxRemoveNonWork.value;
	removePreNotifiedTrackedItems	:=	self.cbxRemovePreNote.value;
	removeTBATrackedItems			:=	self.cbxRemoveTBA.value;
	removeBookRef := self.cbxRemoveBookRef.value;
	archiveBookRef := self.cbxArchiveBookR.value;	//10 Sep 2009	NDL	Par 20413
	
	//10 Sep 2009	NDL	Par 20413
	if removeBookRef and archiveBookRef then
		app.raiseUnexpectedProgramError(class.name, method.name, "Cannot archive and remove Booking References!");
		isInError	:=	true;
		return false;
	endif;

	if not self.continueArchiveAfterCheck(removeEDITrackedItems, removeNonWorkedTrackedItems, removePreNotifiedTrackedItems, removeTBATrackedItems, removeBookRef, archiveBookRef)  then
    	return false;
    endif;
	
	app.myPassport.myActivityCapture.startCaptureDebugMisc('Archiving voyage');

	create archiveInt transient;
	archiveInt.isNoDatesAllowed					:=	self.aIsNoDatesAllowed;
	archiveInt.removeEDITrackedItems			:=	removeEDITrackedItems;
	archiveInt.removeNonWorkedTrackedItems		:=	removeNonWorkedTrackedItems;
	archiveInt.removePreNotifiedTrackedItems	:=	removePreNotifiedTrackedItems;
	archiveInt.removeTBATrackedItems			:=	removeTBATrackedItems;
	archiveInt.removeBookingRefs := removeBookRef;
	archiveInt.archiveBookingRef := archiveBookRef;	//10 Sep 2009	NDL	Par 20413

	self.aAllVoyages.copy(archiveInt.allVoyages);
	
	create theMonitor transient;
	theMonitor.myParent		:=	self;
	archiveInt.myMonitor	:=	theMonitor;
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		self.modalDialogShow(null, null, null, null, app.getErrorString(Archiving_voyages), 'Archiving' &amp; '...');
	
		app.myTrxUA.trxUpdateVoyageArchive(archiveInt, app.myPassport);
		app.myPassport.myActivityCapture.stopCaptureDebugMisc();
	
		if app.myPassport.trxCompletedOK then
			app.msgBox('The selected voyage(s) has been successfully archived.', app.getErrorString(VoyageArchived), MsgBox_OK_Only);
			break;
		else
			theResult := app.showErrorWarningDialog(app.getErrorString(VoyageArchive), app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;
	
	return true;	
	
epilog
	self.progressFinish;
	app.mousePointer	:=	Window.MousePointer_Default;
	app.myPassport.setMyCMIFMonitor(null);
 	delete theMonitor;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doOK" id="02bb9d7e-de7b-4233-8d03-71b6536d00a1">
