    <JadeMethod name="verifyAll" id="9a74f5b2-4a7a-4bde-a122-e37a3c58fa62">
        <updating/>
        <source>verifyAll() updating;
//----------------------------------------------------------------
//	Created:	21 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	numInError	: Integer;
begin
	on Exception do validationExceptionHandler(exception, app.myPassport);	//cnwrs1 par 27392 18 Apr 2011

	app.myPassport.clearErrorsWarnings;
	app.setContinueCMExceptions(true);	//cnwrs1 par 27392 18 Apr 2011
	
	numInError := self.verifyEDIData();
	
	if numInError = 0 then
		numInError := self.verifyEDIDataTIs(app.myPassport);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="verifyEDIData" id="5f725c01-5bc9-4cc9-bdf5-4246828a4481">
        <updating/>
        <source>verifyEDIData(): Integer updating;
vars

begin
	return 0;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="verifyEDIDataTIs" id="11ada982-6665-48b6-b127-d6c10632497e">
        <updating/>
        <source>verifyEDIDataTIs(_passport : CM_Passport input): Integer updating;

// 02 July 2008	concms1	par 17348 Raise exception if the voyage is non-planned or non-worked
// 06/08/2012	cnwcs5	par 30136 - EDI BGP Split
vars
	voyage			: CM_Voyage;
	setStatus		: Integer;
begin
	
	voyage := self.getMyTerminal.lookupVoyage(self.voyageCode, null, false);

	if voyage = null then
		app.raiseCMException2(ERR_VOYAGE_CODE,self.voyageCode, 'voyage code', null, self);
		return 1;
	elseif voyage.myCellularVoyageStructure = null then
		app.raiseCMException1(ERR_INVALID_VOYAGE, "(non-cellular voyage " &amp; self.voyageCode &amp; " )", 'voyageCode', self);
		return 1;
	endif;
	//need to check for jobs, if there are jobs we should bail out 
	if voyage.hasLoadJobs then
			app.raiseCMException(ERR_VOYAGE_JOBS_EXIST, 'allVoyageJobs', self);
		return 1;
	endif;
	
	//epr par 37090 23/10/15 CCMS 2538 EDI Admin Improvements
	if voyage &lt;&gt; null and voyage.hasDeparted  and  self.getMyTerminal.getConfig(EdiAddVoyageDepartError).Boolean then
		app.raiseCMException1(Voyage_departed,voyage.code,"Voyage Code", self);
		return 1;
	endif;

	//verifyOnly is true
	app.myTrxCA.trxCreateEDILoadColourCode(self.allStowAdviceTIsInLoadOrder, voyage.myCellularVoyageStructure, self, true, _passport);	
	
	return _passport.allErrors.size;	//par27392 cnwrs1 14 Apr 2011
epilog
	//--------------------------------------
	// Set status
	//--------------------------------------
	setStatus := self.getStatusAfterVerifyOrDBLoad (true, _passport);	// par 30136 Aug 2012
	
	app.myTrxUA.trxSetEDIDataStatusAfterVerify(self, setStatus);	//par27392 cnwrs1 14 Apr 2011
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="warnOnDBLoad" id="0943af71-aff7-461a-9da1-9c065c2784d3">
        <source>warnOnDBLoad(_message: String output; _flags: Integer output; _intCancel: Integer output);
//----------------------------------------------------------------
//	Created:	21 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	_message	:= app.getErrorString(WARN_EDI_LOAD_STOW);
	_flags		:= MsgBox_Yes_No + MsgBox_Question_Mark_Icon;
	_intCancel	:= MsgBox_Return_No;

end;</source>
        <Parameter name="_message" type="String" usage="output"/>
        <Parameter name="_flags" type="Integer" usage="output"/>
        <Parameter name="_intCancel" type="Integer" usage="output"/>
    </JadeMethod>
