<GUIClass name="MOB_HHBRLocLoaderCargo" id="cc31013b-161f-4fb7-81e5-37933794c62a">
    <superclass name="MOB_HHTruckCargo"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="myBulkRelease" id="e527f797-6218-45f6-85e1-cc6d0bcab60c">
        <embedded/>
        <type name="CM_BulkRelease"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myTargetLocation" id="9dc33d92-cae4-444c-87fa-caa4ca0962c8">
        <embedded/>
        <type name="CM_LocationsController"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="checkIfLockedDown" id="4f99fded-6899-4ad6-ba08-8945d779f90c">
        <source>checkIfLockedDown();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 August 2014	cnwndl1	Initial creation	Par 34717 / CCMS 2384

*/

vars
	row : Integer;
	cargoType : CM_CargoType;
begin

	if self.tblCargo.column &lt;&gt; 2 then
		return;
	endif;
	
	if self.lockedDown then
		row := tblCargo.row;
		if row &gt; 0 then
		
			cargoType := self.getCargoTypeForMeasurementType();
			
			if row = tblCargo.getRow(ETRow_NumItems) 
			and ( cargoType = null or cargoType.isBulkByQuantity )
			then
				return;
			endif;
			self.tblCargo.topRow := row;
			self.tblCargo.row := row;
			self.tblCargo.column := 1;
			self.tblCargo.setFocus();
			self.tblCargo.leftColumn := 1;
			self.msgBox( app.getErrorString1(No_Handheld_Chg_allowed, tblCargo.getCellText(row,1)) ,app.getErrorString(Warning) ,MsgBox_OK_Only, true );
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="findLocationToMoveTo" id="9fbf4cfd-553f-4092-ab47-479657f504c4">
        <source>findLocationToMoveTo( tmpFoundLC : CM_LocationsController output ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 August 2014	cnwndl1	Initial creation	Par 34717 / CCMS 2384

*/

vars

	row : Integer;
	dataString : String;
	term : CM_Terminal;
	tmpFoundHeight : Integer;
	errMess : String;
	
begin

	// Find the location we are moving to.
	row := tblCargo.getRow(ETRow_Location);
	if row &gt; 0 then
		dataString := tblCargo.getCellText(row,2).trimBlanks.toUpper;
	endif;
	if dataString = null then
		errMess := app.getErrorString( No_Location_entered );
	else
		term := self.myMobileGenericAgent.getTerminal;
		term.findLocationFromString(dataString, true, tmpFoundLC, tmpFoundHeight);
		
		if tmpFoundLC = null then
			errMess := app.getErrorString1(Location_NotFound, "'" &amp; dataString &amp; "'");
		else
			if self.formAction = self.UnloadingTi or self.formAction = self.UnloadingUnknownTi then
				if not tmpFoundLC.isYardLocation then
					errMess := app.getErrorString(Location_must_yard);
				elseif tmpFoundLC.isVehicle then
					errMess := app.getErrorString(Location_Not_vehicle);
				elseif tmpFoundLC.isMachineController then	// Par 23284
					errMess := app.getErrorString(Location_must_yard);
				endif;
			else
			endif;
		endif;
		
	endif;
	
	if errMess &lt;&gt; null then
		self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true );
		row := tblCargo.getRow(ETRow_Location);
		if row &gt; 0 then
			self.tblCargo.row := row;
			self.tblCargo.setFocus();
			self.tblCargo.leftColumn := 1;
		endif;
		return false;
	endif; 
	
	return true;
	
epilog

end;</source>
        <Parameter name="tmpFoundLC" type="CM_LocationsController" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getLocationForTablePopulation" id="63f76151-001f-4cc8-9c63-091bf9a48eb1">
        <source>getLocationForTablePopulation(entTableRow: EntTableRowEntity; errMsg: String output): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 August 2014	cnwndl1	Initial creation	Par 34717 / CCMS 2384

*/

vars

	tmpFoundHeight : Integer;
	prevLocation : CM_LocationsController;

begin

	if self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.TruckLoad
	or self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.RailRelease	//26 Jan 2017	NDL	TFS 3198/2877
	then
		if self.myTargetLocation &lt;&gt; null then
			return self.myTargetLocation.getFullId;
		endif;
	endif;
	
	if self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.TruckUnload
	or self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.RailReceipt	//26 Jan 2017	NDL	TFS 3198/2877
	then
		if self.myTrackedItem &lt;&gt; null then
			self.myMobileGenericAgent.myTerminal.findLocationFromString( self.myTrackedItem.priorLocation, true, prevLocation, tmpFoundHeight);
			if prevLocation &lt;&gt; null then
				return prevLocation.getFullId;
			endif;
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <Parameter name="entTableRow" type="EntTableRowEntity"/>
        <Parameter name="errMsg" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getQuantityLoaded" id="6c928846-6c38-4462-8ffc-db91864c603e">
        <source>getQuantityLoaded( _weightLoaded : Decimal output; _reserveDetail : CM_ReserveDetail) : Integer;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 March 2015	cnwdw1	Initial creation
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/
vars
	count: Integer;
	ti: CM_TrackedItem;
	wagon : CM_Wagon;
	wc : CM_WagonController;
	tiSet : CM_TISet;
begin
	if self.myTargetLocation.isWagon then	//26 Jan 2016	NDl	TFS 3198/2877
		create tiSet transient;
		wagon := self.myTargetLocation.CM_WagonController.myWagon;
		foreach wc in wagon.allLocationsControllersArray discreteLock do
			foreach ti in wc.allTrackedItems do
				if tiSet.includes( ti ) then
					continue;
				endif;
				tiSet.add(ti);
				if _reserveDetail &lt;&gt; null then
					//if not _reserveDetail.allTrackedItems.includes(ti) then
					if not _reserveDetail.includeTrackedItem(ti, false) then //23/06/2023	navkc1	CR 58406 Task 58408
						continue;
					endif;
				endif;
				count := count + ( ti.totalQuantity.max(1) );
				_weightLoaded := _weightLoaded + ti.totalWeight;	
			endforeach;
		endforeach;
	
	else
		foreach ti in self.myTargetLocation.allTrackedItems do
			// cnwmc5 - 2 Feb 2016 - PAR 37483
			if _reserveDetail &lt;&gt; null then
				//if not _reserveDetail.allTrackedItems.includes(ti) then
				if not _reserveDetail.includeTrackedItem(ti, false) then //23/06/2023	navkc1	CR 58406 Task 58408
					continue;
				endif;
			endif;
			
			count := count + ( ti.totalQuantity.max(1) );
			_weightLoaded := _weightLoaded + ti.totalWeight;	//12 Nov 2015	NDL	Par 37092
		endforeach;
	
	endif;
	
	return count;
	
epilog

	delete tiSet;
end;</source>
        <Parameter name="_weightLoaded" type="Decimal" usage="output"/>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getQuantityToLoad" id="44012f10-1c73-49e1-aed9-a814c3b14f6a">
        <source>getQuantityToLoad( _weightToLoad : Decimal output) : Integer;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 March 2015	cnwdw1	Initial creation
*/
vars
	wles: CM_WLESet;
	wle: CM_WorkListEntry;
	quantity: Integer;
	request : CM_Request;
begin
	create wles transient;
	self.getWLEsForRelease(wles);
	foreach wle in wles do
		
		quantity := quantity + wle.quantity.max(1);	//20 May 2015	NDL	Par 36127
		_weightToLoad := _weightToLoad + wle.weight;
		
	endforeach;
	
	return quantity;
epilog
	delete wles;
end;</source>
        <Parameter name="_weightToLoad" type="Decimal" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRoadJob" id="6d0f0063-38df-48b5-867c-29f2185c4e8f">
        <source>getRoadJob():CM_RoadJob;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 November 2015	cnwndl1	Initial creation	Par 37153

*/

vars

	roadJob : CM_RoadJob;
	truck : CM_Vehicle;
	job : CM_Job;

begin

	if self.myTargetLocation.isVehicle then
		truck := self.myTargetLocation.CM_VehicleController.vehicle;
		if truck = null then
			return null;
		endif;
		foreach job in truck.allRoadJobs do
			if job.status = JOB_COMPLETE then
				continue;
			endif;
			if not job.isRelease then
				continue;
			endif;
			roadJob := job.CM_RoadJob;
		endforeach;
		
	elseif myTargetLocation.isTILCController then
		roadJob := self.myTargetLocation.CM_TILCController.myTILC.jobRoadRelease;	
	endif;
	
	return roadJob;
	
epilog

end;</source>
        <ReturnType type="CM_RoadJob"/>
    </JadeMethod>
    <JadeMethod name="getWLEsForRelease" id="b6291a17-0591-41e1-8bed-f04d72abbfff">
        <source>getWLEsForRelease(_wles: CM_WLESet io):CM_WorkListEntry;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 November 2014	cnwndl1	Initial creation	Par 35146 / CCMS 2384

*/
vars

	roadJob : CM_RoadJob;
	job : CM_Job;
	wle : CM_WorkListEntry;
	wagon : CM_Wagon;
	lc : CM_LocationsController;
	
begin

	
	if self.myTargetLocation &lt;&gt; null and self.myTargetLocation.isWagon then	//25 Jan 2017	NDL	TFS 3198/2877
		wagon := self.myTargetLocation.CM_WagonController.myWagon;
		foreach lc in wagon.allLocationsControllersArray discreteLock do
			foreach wle in lc.CM_WagonController.allRailWLELoad do
				if wle.myRequest &lt;&gt; null then
					if wle.myRequest.myOriginatingBulkRelease = self.myBulkRelease then
						_wles.addNoDuplicates(wle,false);
					endif;
				endif;
			endforeach;
		endforeach;

	else
		roadJob := self.getRoadJob();	//30 Nov 2015	NDL	Par 37153
		
		if roadJob &lt;&gt; null then
			foreach wle in roadJob.workListEntries do
				if wle.myRequest &lt;&gt; null then
					if wle.myRequest.myOriginatingBulkRelease = self.myBulkRelease then
						_wles.add(wle);
					endif;
				endif;
			endforeach;
		endif;
	
	endif;
	return null;

epilog
end;
</source>
        <Parameter name="_wles" type="CM_WLESet" usage="io"/>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="getWLEsForReserve" id="e618270b-af28-46ce-ba35-000053cafbfe">
        <source>getWLEsForReserve(_wles: CM_WLESet io; _reserveDetail : CM_ReserveDetail);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 February 2016	cnwmc5	Initial creation	PAR 37483

*/

vars

	roadJob : CM_RoadJob;
	job : CM_Job;
	wle : CM_WorkListEntry;
	wagon : CM_Wagon;
	lc : CM_LocationsController;
	
begin
	if _reserveDetail = null then
		return;
	endif;
	
	if self.myTargetLocation &lt;&gt; null and self.myTargetLocation.isWagon then	//25 Jan 2017	NDL	TFS 3198/2877
		wagon := self.myTargetLocation.CM_WagonController.myWagon;
		foreach lc in wagon.allLocationsControllersArray discreteLock do
			foreach wle in lc.CM_WagonController.allRailWLELoad do
				if _wles.includes( wle ) then
					continue;
				endif;
				if wle.myRequest &lt;&gt; null then
					if wle.myRequest.myOriginatingBulkRelease &lt;&gt; self.myBulkRelease then
						continue;
					endif;
					if wle.myRequest.myReserveDetail = _reserveDetail then
						_wles.add(wle);
					endif;
				endif;
			endforeach;
		endforeach;
		
	else
	
		roadJob := self.getRoadJob();
		
		if roadJob &lt;&gt; null then
			foreach wle in roadJob.workListEntries do
				if wle.myRequest &lt;&gt; null then
					if wle.myRequest.myReserveDetail = _reserveDetail then
						_wles.add(wle);
					endif;
				endif;
			endforeach;
		endif;
	
	endif;

epilog

end;
</source>
        <Parameter name="_wles" type="CM_WLESet" usage="io"/>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
    </JadeMethod>
    <JadeMethod name="getWleFromLocation" id="eb8236cc-4304-47a4-b882-08dc9f86ef67">
        <source>getWleFromLocation(_reserveDetail : CM_ReserveDetail):CM_WorkListEntry;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 November 2014	cnwndl1	Initial creation	Par 35146 / CCMS 2384

*/
vars

	roadJob : CM_RoadJob;
	job : CM_Job;
	wle : CM_WorkListEntry;
	wagon : CM_Wagon;
	lc : CM_LocationsController;
	validWleSet : CM_WLESet;
	req : CM_Request;

begin

	if self.myTargetLocation &lt;&gt; null and self.myTargetLocation.isWagon then
		//26 Jan 2017	NDL	TFS 3198/2877
		wagon := self.myTargetLocation.CM_WagonController.myWagon;
		
		create validWleSet transient;
		foreach lc in wagon.allLocationsControllersArray discreteLock do
			foreach wle in lc.CM_WagonController.allRailWLELoad do
				if wle.status = WLE_COMPLETED then
					continue;
				endif;
				if wle.myTrackedItem = null
				or wle.myTrackedItem.isRRP	//31 Mar 2020	NDL	Tfs 47004
				or wle.myTrackedItem = self.myTrackedItem
				then
					req := wle.myRequest;
					if req = null then
						continue;
					endif;
					if _reserveDetail &lt;&gt; null then
						if req.myReserveDetail &lt;&gt; _reserveDetail then
							continue;
						endif;
					endif;
					if wle.myTrackedItem = self.myTrackedItem then
						// if its actually this one, use it
						return wle;
						break;
					else
						//otherwise add to the valid set of wles to consider
						validWleSet.addNoDuplicates( wle, false );
					endif;
				endif;
			endforeach;
		endforeach;
		
		return validWleSet.first;
		
	else
	
		roadJob := self.getRoadJob();	//30 Nov 2015	NDL	Par 37153
		
		//17 Nov 2015	NDL	Par 37092
		if roadJob = null then
			return null;
		endif;
		
		
		wle := roadJob.getWLEForTI( self.myTrackedItem );
		if wle &lt;&gt; null then
			return wle;
		endif;
		
		foreach wle in roadJob.workListEntries do   // PAR 35781
			if wle.status = WLE_COMPLETED then
				continue;
			endif;
			if wle.myRequest &lt;&gt; null then
				if wle.myRequest.myOriginatingBulkRelease = self.myBulkRelease then
					// cnwmc5 - 2 Feb 2016 - PAR 37483
					if _reserveDetail = null or wle.myRequest.myReserveDetail = _reserveDetail then	//12 Feb 2016	NDL	Par 37537
						return wle;
					endif;
				endif;
			endif;
		endforeach;
	
	endif;
	
	return null;

epilog

	delete validWleSet;
	
end;
</source>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="saveChanges" id="139a33e1-c673-4eaf-a6b7-225e264fbae9">
        <updating/>
        <source>saveChanges(_fromChecks: Boolean): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 August 2014	cnwndl1	Initial creation	Par 34717 / CCMS 2384

*/

vars

	tmpFoundLC : CM_LocationsController;
	checksSubCargo : CM_TrackedItem;
	row : Integer;
	quantity : Integer;
	weight : Decimal [16,4];
	wle : CM_WorkListEntry;
	wleToProcess : CM_WorkListEntry;
	mess : String;
	reserveDetail : CM_ReserveDetail;
	tiToAdd : CM_TrackedItem;
	moveController : CMIF_MoveController;
	result : Integer;
	doRemove : Boolean;
	exactRailTarget : CM_LocationsController;
	wagon : CM_Wagon;
	
begin

	if self.myTrackedItem = null then
		self.msgBox(app.getErrorString(No_Cargo_selected), app.getErrorString(Error), MsgBox_OK_Only, true);
		return false;
	endif;
	
	if not self.findLocationToMoveTo( tmpFoundLC ) then
		return false;
	endif;
	
	if self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.TruckLoad then
	
		if not self.validate() then
			return false;
		endif;
	
		if self.myMobileGenericAgent.isWaitingOnRequiredChecks(CARGO_CHECK_CONTEXT_TRUKLOAD, self.myTrackedItem, checksSubCargo) &lt;&gt; null then //28 May 2010	NDL	Par 23698
			self.handleBtnTwo();
			return false;
		endif;
		
	elseif self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.TruckUnload then
		if self.myMobileGenericAgent.isWaitingOnRequiredChecks(CARGO_CHECK_CONTEXT_TRUKUNLOAD, self.myTrackedItem, checksSubCargo) &lt;&gt; null then //28 May 2010	NDL	Par 23698
			self.handleBtnTwo();
			return false;
		endif;
	
	//26 Jan 2017	NDL	TFS 3198/2877
	elseif self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.RailRelease then
	
		if not self.validate() then
			return false;
		endif;
	
		if self.myMobileGenericAgent.isWaitingOnRequiredChecks(CARGO_CHECK_CONTEXT_RAIL_REL, self.myTrackedItem, checksSubCargo) &lt;&gt; null then 
			self.handleBtnTwo();
			return false;
		endif;
	
	//26 Jan 2017	NDL	TFS 3198/2877
	elseif  self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.RailReceipt then
		if self.myMobileGenericAgent.isWaitingOnRequiredChecks(CARGO_CHECK_CONTEXT_RAIL_REC, self.myTrackedItem, checksSubCargo) &lt;&gt; null then 
			self.handleBtnTwo();
			return false;
		endif;
		
	endif;
				
	if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.canSplitTotalQuantity then
		if self.myTrackedItem.isBulkByQuantity then
			row := tblCargo.getRow(ETRow_NumItems);
			if row &gt; 0 then
				quantity := tblCargo.getCellText(row,2).trimBlanks.Integer;
			endif;
		elseif  self.myTrackedItem.isBulkByWeight or self.myTrackedItem.isBulkByVolume then
			weight := self.getConvertedWeight;
		endif;
		
		// cnwmc5 - 2 Feb 2016 - PAR 37483
		reserveDetail := self.myMobileGenericAgent.myReserveSelection;
		if reserveDetail = null then
			reserveDetail := self.myMobileGenericAgent.getReserveDetailCargoMatches( self.myTrackedItem, quantity, weight, mess );
		endif;
		
//		PAR 36127 Thsi was picking wle from wrong truck when concurrent trucks being loaded
//        It now gets correclty assigned later 	
		wleToProcess :=  self.getWleFromLocation(reserveDetail);			// cnwmc5 - 2 Feb 2016 - PAR 37483
		if wleToProcess = null then
			foreach wle in self.myTrackedItem.allWorklistEntries do
				if wle.status = WLE_COMPLETED then
					continue;
				endif;
				wleToProcess := wle;
				break;
			endforeach;
		endif;
	endif;
	
	if self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.TruckLoad
	or self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.RailRelease	//26 Jan 2017	NDL	TFS3198/2877
	then
		
		// cnwmc5 - 2 Feb 2016 - PAR 37483
		if reserveDetail = null then
			reserveDetail := self.myMobileGenericAgent.myReserveSelection;
		endif;
		if reserveDetail = null then
			reserveDetail := self.myMobileGenericAgent.getReserveDetailCargoMatches( self.myTrackedItem, quantity, weight, mess );
		endif;
		
		if reserveDetail = null then
			self.msgBox(mess, app.getErrorString(Error), MsgBox_OK_Only, false);
			return false;
		endif;
		//19 Nov 2014	NDL	Par 35146 / CCMS 2384
		if wleToProcess = null then
			wleToProcess :=  self.getWleFromLocation(reserveDetail);		// cnwmc5 - 2 Feb 2016 - PAR 37483
		endif;
		
	endif;
	
//	if wleToProcess &lt;&gt; null and wleToProcess.myTrackedItem = null then
	if wleToProcess &lt;&gt; null
	and ( wleToProcess.myTrackedItem = null or wleToProcess.myTrackedItem.isRRP ) then	//26 Jan 2017	NDL	TFS 3198/2877
		//26 Jan 2017	NDL	TFS 3198/2877
		if tmpFoundLC &lt;&gt; null and tmpFoundLC.isWagon then
			wagon := tmpFoundLC.CM_WagonController.myWagon;
			exactRailTarget := wleToProcess.getTargetLocation;
			if exactRailTarget = null and wleToProcess.isYardReleaseAssigned then
				exactRailTarget := wleToProcess.CM_YardWLE.allLocationControllers.first;
			endif;
			if exactRailTarget &lt;&gt; null
			and exactRailTarget.isWagon
			and exactRailTarget.CM_WagonController.myWagon = wagon then
				// all good we will use it
			else
				exactRailTarget := null;
			endif;
		endif;
		
		// wle from a delivery request that was for Items by type. ( I.e. no associated cargo items yet.)
		create moveController transient;
		moveController.setMyWorkListEntry(wleToProcess);
		if exactRailTarget &lt;&gt; null then	//26 Jan 2017	NDL	TFS 3198/2877
			moveController.setMyToPrimaryLocation(exactRailTarget);
		else
			moveController.setMyToPrimaryLocation(tmpFoundLC);
		endif;
		moveController.setMyTrackedItem(self.myTrackedItem);
		moveController.setQuantity(quantity);  // PAR 35781
		moveController.setWeight(weight);	//26 Nov 2015	NDL	Par 37092
		if reserveDetail &lt;&gt; null 
		and reserveDetail.myReserveDetailActions &lt;&gt; null then // TFS 3283 Setting
			// TFS 3283 Direct delivery only add TI if we have not processed before i.e. staged.
			// TFS 3283 Setting this ultimately calls code to create or update (accumulate) the doc actions.
			if not reserveDetail.myReserveDetailActions.includesTi(self.myTrackedItem) then
				moveController.setMyDocumentActions( reserveDetail.myReserveDetailActions );
			endif;
		endif;
		
		while true do
			app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);	
			if not app.myPassport.trxCompletedOK then
				result := app.showErrorWarningDialog(app.getErrorString( Assign_release ), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			break;
		endwhile;
		if result &lt;&gt; IDOK then
			return false;
		endif;
		
	else
	
		//26 Jan 2017	NDL	TFS 3198/2877
		if tmpFoundLC &lt;&gt; null and tmpFoundLC.isWagon and wleToProcess &lt;&gt; null then
			wagon := tmpFoundLC.CM_WagonController.myWagon;
			exactRailTarget := wleToProcess.getTargetLocation;
			if exactRailTarget = null and wleToProcess.isYardReleaseAssigned then
				exactRailTarget := wleToProcess.CM_YardWLE.allLocationControllers.first;
			endif;
			if exactRailTarget &lt;&gt; null
			and exactRailTarget.isWagon
			and exactRailTarget.CM_WagonController.myWagon = wagon then
				// all good we will use it
				tmpFoundLC :=  exactRailTarget;
			endif;
		endif;
		if not self.myMobileGenericAgent.moveTI( self.myTrackedItem, null, tmpFoundLC, wleToProcess, false, quantity, weight, null ) then
			return false;
		endif;
		
	endif;
	
	if self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.TruckLoad
	or self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.RailRelease	//26 Jan 2017	NDL	TFS3198/2877
	then
		if moveController &lt;&gt; null then	//03 Nov 2015	NDL	Par 37005
			// used a wleToProcess
			tiToAdd := moveController.myTrackedItem;
		else
			// came thru the direct move code
			if tmpFoundLC.isWagon then
				tiToAdd := tmpFoundLC.CM_WagonController.myWagon.findTi( self.myTrackedItem.id );
			else
				tiToAdd := tmpFoundLC.allTrackedItemsById.getAtKey( self.myTrackedItem.id, self.myTrackedItem.cargoType ); // Might have been split off.. 
			endif;
		endif;
		app.myTrxUA.trxAddToReserveDetail( reserveDetail, tiToAdd, app.myPassport );
		
	elseif ( self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.TruckUnload 
		or self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.RailReceipt )	//26 Jan 2017	NDL	TFS3198/2877
		then
		//If its been merged and zombied, remove it from the assignned... otherwise don't - 09 Dec 2015	NDL TFS752-12
		if self.myBulkRelease &lt;&gt; null then
			if self.myTrackedItem.hasBeenMerged then
				doRemove := true;
			endif;
			if doRemove then
				app.myTrxUA.trxRemoveReserveSelections( self.myBulkRelease, self.myTrackedItem, app.myPassport );
			endif;
		endif;
		
	endif;
	
	return true;
	
epilog

	delete moveController;
	
end;</source>
        <Parameter name="_fromChecks" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setBaseData" id="823c76d9-cb65-4306-ba4c-5bf2766f1207">
        <updating/>
        <source>setBaseData() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 August 2014	cnwndl1	Initial creation	Par 34717 / CCMS 2384

*/

vars

begin
	
	self.myBulkRelease := self.myMobileGenericAgent.myBulkRelease;
	self.myTargetLocation := self.myMobileGenericAgent.myLocationsController;
	self.myTrackedItem := self.myMobileGenericAgent.myNextTiToAction;
	
	self.caption := self.caption &amp; " " &amp; self.myTrackedItem.id;
	
	self.lockDownTheAttributes();

epilog

end;</source>
