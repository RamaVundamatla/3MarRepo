    <JadeMethod name="validateForCreate" id="f4147b54-eb2b-4357-bde3-08a418aa86b9">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if app.myRoot.allMachineTypes[type] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.type.String, null, null);
	endif;

	self.validateMe;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="50e9f2a5-c4c6-4876-a182-4eea1c55807b">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if (not self.allAllowedCargoTypes.isEmpty) or
		(not self.allAllowedTATypes.isEmpty) then
			app.raiseCMException2(ObjectStillHasEntries, self.type.String, "Machine Types", null, null);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="5f1d2053-8d80-43cd-84a2-3190ea714e8a">
