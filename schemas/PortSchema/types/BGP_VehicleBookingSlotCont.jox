    <JadeMethod name="timerEvent" id="674dbd00-9169-4476-a064-114a3c99a8fa">
        <updating/>
        <source>timerEvent(_eventTag: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 August 2013	cnwndl1	Initial creation	Par 32077

*/
vars

begin

	if	_eventTag = AutoTimer_Event_Tag then
	
		self.doTheNeedful();
	
	else
		inheritMethod(_eventTag);
	endif;
end;
</source>
        <Parameter name="_eventTag" type="Integer"/>
    </JadeMethod>
</Class>
