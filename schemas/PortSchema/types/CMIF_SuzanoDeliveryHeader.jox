    <JadeMethod name="setDetails" id="5e2e1ae3-097c-49d0-9a43-dcb1bd56f812">
        <updating/>
        <source>setDetails(_eventTransaction : CM_EventTransaction; _segment : String; _sequence : Integer; _transportId : String; _transportTypeCode : String; _message : String; _salesOrder : String; _salesOrderLine : String) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 09/03/2023	navdap1		Initial creation TFS 56796 PRP Suzano EDI Delivery Communication
//
vars

begin
	self.myEventTransaction := _eventTransaction;
	self.message 			:= _message;
	self.salesOrder 		:= _salesOrder;
	self.salesOrderLine 	:= _salesOrderLine;
	self.transportId 		:= _transportId;
	self.transportTypeCode 	:= _transportTypeCode;
	
	self.segment			:= _segment;
	self.sequenceNbr		:= _sequence;
epilog

end;</source>
        <Parameter name="_eventTransaction" type="CM_EventTransaction"/>
        <Parameter name="_segment" type="String"/>
        <Parameter name="_sequence" type="Integer"/>
        <Parameter name="_transportId" type="String"/>
        <Parameter name="_transportTypeCode" type="String"/>
        <Parameter name="_message" type="String"/>
        <Parameter name="_salesOrder" type="String"/>
        <Parameter name="_salesOrderLine" type="String"/>
    </JadeMethod>
