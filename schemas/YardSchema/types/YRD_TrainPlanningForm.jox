        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mySDF_dragOver(frame: Frame input; win: Window input; x: Real; y: Real; state: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// 16/07/2009	consw1		Par 20293 - UE 1090
// ---------------------------------------------------------------------------

vars

begin
	if app.myMoveController &lt;&gt; null or app.myWagonMoveController &lt;&gt; null then
		if app.activeForm &lt;&gt; self then
			self.setFocus();
			self.zOrder(1);
		endif;
	endif;

	self.setMyCurrentSDF(frame.CMUI_ScrollableDrawingFrame);

epilog

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
