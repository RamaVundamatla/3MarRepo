    <JadeMethod name="getCollectionForMode" id="1db8fe87-2160-4ec0-b1d3-69be0e2ea768">
        <source>getCollectionForMode(_coll :Collection):CM_ObjectSet protected;
// ---------------------------------------------------------------------------
// Created:     15 February 2010 by cnwcs5
// Purpose:     CCMS 1925 / PAR 22295 Release Summaries
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	obj			:Object;
	coll		:CM_ObjectSet;
	iter		:Iterator;
	invalidObj	:Boolean;
	detail		:CM_ReserveDetail;
	item		:CM_BookingRefItem;
begin
	obj := _coll.first.Object;																
	
	if obj = null then
		return null;
	endif;
	
	if obj.isKindOf (CM_BulkRelease) and self.myOutputFormat_XTAB.isReleaseItemMode then	
		// if we have a collection of releases and the summary mode is release item we 
		// populate a collection of relevant release items and run the summary against that collection
		create coll transient;												
		
		iter := _coll.createIterator;	
		
		on Exception do app.handleDeletedObject (exception, obj, invalidObj);				
		
		while iter.next (obj) do															
			if obj.isKindOf (CM_BulkRelease) then	// we expect them all to be of the same type											
				foreach detail in obj.CM_BulkRelease.allReserveDetails do					
					coll.addNoDuplicates (detail, false);						
				endforeach;																	
			endif;																			
		endwhile;		
		
		return coll;
	elseif obj.isKindOf (CM_BookingRef) and self.myOutputFormat_XTAB.isBookRefItemMode then
		// if we have a collection of bookings and the summary mode is booking item we 
		// populate a collection of relevant booking items and run the summary against that collection
		create coll transient;
		
		iter := _coll.createIterator;
		
		on Exception do app.handleDeletedObject (exception, obj, invalidObj);	
		
		while iter.next( obj ) do 
			if obj.isKindOf (CM_BookingRef) then
				foreach item in obj.CM_BookingRef.allBookingRefItems do 
					coll.addNoDuplicates (item, false);
				endforeach;
			endif;
		endwhile;	
		
		return coll;
	endif;																					

epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_coll" type="Collection"/>
        <ReturnType type="CM_ObjectSet"/>
    </JadeMethod>
    <JadeMethod name="getColumnHeadings_Headings" id="de43329d-6aef-4031-bc25-efd871d205c9">
        <source>getColumnHeadings_Headings(_keyArray, _headingArray :StringArray input; _numTabs, _numRows, _numCols :Integer; _iter :Iterator; _clear :Boolean) protected;
// ---------------------------------------------------------------------------
// Created:     09 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
//				gets column key/heading values from the Headings collection
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 01/12/2009	cnwcs5		ccms1028 - new parameter _headingArray
// ---------------------------------------------------------------------------
vars
	int,
	grpIndex	:Integer;
	keyValue, headingValue		:String;
	mapping		:CM_XTABMapping;
begin
	if _clear then
		_keyArray.clear;
		_headingArray.clear;
	endif;
	
	foreach int in (_numTabs + 1) to (_numTabs + _numCols) do	// higher level keys are tabs
		keyValue 		:= _iter.getCurrentKey(int).String;
		headingValue	:= keyValue;
		grpIndex		:= self.keyHeading_to_indexGrouping(int);					
		
		self.trimLeadingZeros (grpIndex, keyValue);
		
		_keyArray.add (keyValue); 
		
		// if we are displaying mapped values in mapping line order rather than
		// mapped value order then the value of the key will be different to the
		// heading value that is displayed.
		
		mapping 		:= self.allGroupingMappings [grpIndex].CM_XTABMapping;	
		
		if mapping &lt;&gt; null then													
			headingValue := self.getMappingForKeyValue (headingValue, mapping);	
		endif;																	
		
		self.trimLeadingZeros (grpIndex, headingValue);
		
		_headingArray.add (headingValue); 
	endforeach;
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_keyArray" type="StringArray" usage="input"/>
        <Parameter name="_headingArray" type="StringArray" usage="input"/>
        <Parameter name="_numTabs" type="Integer"/>
        <Parameter name="_numRows" type="Integer"/>
        <Parameter name="_numCols" type="Integer"/>
        <Parameter name="_iter" type="Iterator"/>
        <Parameter name="_clear" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDetailColLevel" id="794243b5-040f-41a8-9752-accda10c8b97">
        <source>getDetailColLevel(_numCols:Integer):Integer protected;
// ---------------------------------------------------------------------------
// Created:     08 December 2009 by cnwcs5
// Purpose:     CCMS 1028 - summary mappings
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _numCols = 0 then
		// if no rows out detail row level will be 1
		return _numCols + 1;
	else
		return _numCols;
	endif;
epilog

end;</source>
