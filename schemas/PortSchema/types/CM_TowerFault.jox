<Class name="CM_TowerFault" id="8aacebfe-56af-4ce9-a45a-fae320390dcd">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Is an entry in the tower fault table @ terminal level</text>
    <DbClassMap file="terminal"/>
    <PrimAttribute name="code" id="3a3e1889-abc9-433c-8ee2-ba91201d3f5e">
        <length>5</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="description" id="2312cca7-50c6-4167-a060-01153cca84b4">
        <length>26</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myRoot" id="ca497354-9aa1-4097-a1cb-abfd302801e4">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Root"/>
        <access>readonly</access>
        <Inverse name="CM_Root::allTowerFaults"/>
    </ExplicitInverseRef>
    <JadeMethod name="identity" id="8e820072-195e-435b-9ff0-f3e3a85cbee5">
        <source>identity(): String;
// ---------------------------------------------------------------------------
// Created:     04 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return self.identityWithAttribute(CM_TowerFault::code.name);

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="51c539db-fcc0-45dc-9858-214e5004f58e">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     09 February 2002 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	proxyTowerFault:CM_TowerFault;
	completedOK		: Boolean;
	
begin

	proxyTowerFault := inheritMethod();

	// RJS - need to add other references here, including collections
	// self.ports is inversed and this is the auto end so no need
	// to copy to the proxy
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyTowerFault;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyTowerFault;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="5da15299-f207-4fc2-8e72-29aed669bfe2">
        <updating/>
        <source>setForCreate(pProxyTowerFault:CM_TowerFault) updating;
// ---------------------------------------------------------------------------
// Created:     16 January 2002 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	pProxyTowerFault.raiseExceptionIfNotTransient(method);
	
	self.code := pProxyTowerFault.code;
	self.description := pProxyTowerFault.description;
	self.myRoot := app.myRoot;

end;</source>
        <Parameter name="pProxyTowerFault" type="CM_TowerFault"/>
    </JadeMethod>
    <JadeMethod name="setMyRoot" id="5292e731-c750-4d62-a709-db5f5f8643cb">
        <updating/>
        <source>setMyRoot() updating;
// ---------------------------------------------------------------------------
// Created:     04 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.myRoot := app.myRoot;

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxy" id="0495f151-3f5c-494f-b59c-5c5ca61981e6">
        <updating/>
        <source>setProxy(pCode, pDescription : String) updating;

vars

begin

	self.raiseExceptionIfNotTransient(method);

	self.code := pCode[1:4];
	self.description := pDescription[1:25];
	self.myRoot := app.myRoot;
	
end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pDescription" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="9738640d-6acb-4f55-a895-4e4207b72f11">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     16 January 2002 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if app.myRoot.allTowerFaults[self.code] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	endif;

	self.validateMe;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="8e18eb04-b984-44ba-91ad-7ce9a8098973">
        <source>validateMe() protected;

vars

begin
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'TowerFault Code', null, null);
		app.raiseCMException(Input_required_field_twrFltCde, null, null); // cnwdb2	PAR 35364
	endif;
	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'TowerFault Description', null, null);
		app.raiseCMException(Input_required_field_twrFltDes, null, null); // cnwdb2	PAR 35364
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
