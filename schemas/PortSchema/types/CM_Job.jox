    <JadeMethod name="causeTerminalEvent" id="caa57996-cbcd-44fb-a4c0-c8b3495390e4">
        <source>causeTerminalEvent(_mode : Integer);
//--------------------------------------------------------------
//Created: 02 May 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if self.isTransient then
		return;
	endif;
	//jlier1 MTN-34200 11/3/24
	if self.myJobSheetForWorkOrder &lt;&gt; null  then
		if _mode = self.Event_Mode_Create or _mode =  Event_Mode_Update then
			app.myEventManager.createSingleObjInfoNoteEvt(self, self.myJobSheetForWorkOrder.myTerminal.getTerminalEvent(WorkOrderJob_Update_Event),  self);
		elseif _mode = 	Event_Mode_Delete then
			app.myEventManager.createSingleObjInfoNoteEvt(self, self.myJobSheetForWorkOrder.myTerminal.getTerminalEvent(WorkOrderJob_Delete_Event),  self);
		endif;
	endif;

end;</source>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
