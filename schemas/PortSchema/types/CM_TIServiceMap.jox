    <JadeMethod name="getItemCode" id="efc8b0a4-c1c4-4835-9df2-267e4a1830d1">
        <source>getItemCode(): String;
// 23659 Apr 2010 invoice transaction map extract to use codes instead of descriptions
vars

begin
	if self.myCargoType &lt;&gt; null then
		return self.myCargoType.abbreviation &amp; "| " &amp; self.myCargoType.description;	// 33095 use '|' delimiter to handle spaces in the id
	elseif self.className &lt;&gt; null then 
		return self.className[4:end];
	else
		return CM_FinancialObject.Extract_Default;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
