    <JadeMethod name="setProxy" id="38c9a6d2-51f2-425a-8568-5b426cb7d726">
        <updating/>
        <source>setProxy(	pCode,
			pPortCode,
			pDescription,
			pCcodePrint				: String;
			pColour					: Integer;
			pMyCountry				: CM_Country;
			pMyPortGroup			: CM_PortGroup;
			_usLocationCode			: String;
			_isNotAvailableForEntry : Boolean;
			_isPort					: Boolean;
			_isRail					: Boolean;
			_isRoad					: Boolean;
			_isAirport				: Boolean;
			_isPostal				: Boolean;
			_isMulti				: Boolean;
			_isFixed				: Boolean;
			_isBorder				: Boolean) updating;

vars

begin

	self.raiseExceptionIfNotTransient(method);

	self.code := pCode[1:5];
	self.portCode := pPortCode[1:3];
	
	self.description := pDescription[1:40];
	self.ccodePrint := pCcodePrint[1:5];
	self.colour := pColour;
	self.isNotAvailableForEntry := _isNotAvailableForEntry;
	self.bIsPort 			:= _isPort;
	self.bIsRail 			:= _isRail;
	self.bIsRoad 			:= _isRoad;
	self.bIsAirport 		:= _isAirport;
	self.bIsPostalExchange 	:= _isPostal;
	self.bIsMultiModal 		:= _isMulti;
	self.bIsFixedTransport 	:= _isFixed;
	self.bIsBorderCrossing 	:= _isBorder;
	self.myCountry := pMyCountry;
	self.myPortGroup := pMyPortGroup;
	self.myRoot	:= app.myRoot;
	self.usLocationID := _usLocationCode;
	
end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pPortCode" type="String"/>
        <Parameter name="pDescription" type="String"/>
        <Parameter name="pCcodePrint" type="String"/>
        <Parameter name="pColour" type="Integer"/>
        <Parameter name="pMyCountry" type="CM_Country"/>
        <Parameter name="pMyPortGroup" type="CM_PortGroup"/>
        <Parameter name="_usLocationCode" type="String"/>
        <Parameter name="_isNotAvailableForEntry" type="Boolean"/>
        <Parameter name="_isPort" type="Boolean"/>
        <Parameter name="_isRail" type="Boolean"/>
        <Parameter name="_isRoad" type="Boolean"/>
        <Parameter name="_isAirport" type="Boolean"/>
        <Parameter name="_isPostal" type="Boolean"/>
        <Parameter name="_isMulti" type="Boolean"/>
        <Parameter name="_isFixed" type="Boolean"/>
        <Parameter name="_isBorder" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateFromImport" id="9c0213fc-835f-43a5-91c1-5e072c26f1bd">
        <updating/>
        <source>updateFromImport(_cmif : CMIF_PortSorter input; _root : CM_Root) updating;

// Created by cnwdvb1 on 06 April 2006
// Must be called inside transaction.

// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/6/2006	RBarr		CM_Port::codeDisplay attribute obsolete
// ---------------------------------------------------------------------------

vars

	pxyCountry,
	country	: CM_Country;


begin

	self.code					:= _cmif.fileCountryCode &amp; _cmif.filePortCode;
	self.description			:= _cmif.fileCodeDescription;
	self.portCode		:= _cmif.filePortCode;
	self.isActive				:= _cmif.isActive;
	
	if _cmif.fileCodeType.pos("1", 1) &lt;&gt; 0 then
		self.bIsPort := true;
	else
		self.bIsPort := false;
	endif;
	
	if _cmif.fileCodeType.pos("2", 1) &lt;&gt; 0 then
		self.bIsRail := true;
	else
		self.bIsRail := false;
	endif;
	
	if _cmif.fileCodeType.pos("3", 1) &lt;&gt; 0 then
		self.bIsRoad := true;
	else
		self.bIsRoad := false;
	endif;
	
	if _cmif.fileCodeType.pos("4", 1) &lt;&gt; 0 then
		self.bIsAirport := true;
	else
		self.bIsAirport := false;
	endif;
	
	if _cmif.fileCodeType.pos("5", 1) &lt;&gt; 0 then
		self.bIsPostalExchange := true;
	else
		self.bIsPostalExchange := false;
	endif;
	
	if _cmif.fileCodeType.pos("6", 1) &lt;&gt; 0 then
		self.bIsMultiModal := true;
	else
		self.bIsMultiModal := false;
	endif;
	
	if _cmif.fileCodeType.pos("7", 1) &lt;&gt; 0 then
		self.bIsFixedTransport := true;
	else
		self.bIsFixedTransport := false;
	endif;
	
	if _cmif.fileCodeType.pos("B", 1) &lt;&gt; 0 then
		self.bIsBorderCrossing := true;
	else
		self.bIsBorderCrossing := false;
	endif;
	
	country := app.myRoot.allCountries[_cmif.fileCountryCode];
	
	if country = null then
		create pxyCountry transient;
		pxyCountry.setProxy(_cmif.fileCountryCode, _cmif.fileCountryCode, null, null, false, null);
		create country persistent;
		country.setForCreate(pxyCountry);
	endif;
	
	if self.myCountry &lt;&gt; country then
		self.myCountry := country;
	endif;
	
	if self.myRoot = null then
		self.myRoot := _root;
	endif;

end;</source>
        <Parameter name="_cmif" type="CMIF_PortSorter" usage="input"/>
        <Parameter name="_root" type="CM_Root"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="34aafbd7-86f9-4719-bda6-a99234992934">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	//if app.myRoot.allPorts[code] &lt;&gt; null then
	if app.myRoot.allPorts[code] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	endif;
	self.validateForUpdate;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="b486c2a0-b9d4-4dce-8149-ec7e9e4333e8">
