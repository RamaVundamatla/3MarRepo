    </JadeMethod>
    <JadeMethod name="keyDown" id="2193a3b7-a0cc-4618-9a0d-4d656b8d07c8">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// -------------------------------------------
// Created 26 August 2003 by cnwdvb1
// -------------------------------------------
vars

	theActiveControl	: Control;
	
begin

	inheritMethod(keyCode, shift);
	theActiveControl := app.activeControl;
	if theActiveControl.parent.isKindOf(CM_EntryTable) then
		theActiveControl := theActiveControl.parent.Control;
	endif;
	if keyCode = J_key_Tab then
		self.tblEmail.handleFormTab(keyCode, shift, self.txtBody, self.txtSubject);
		if theActiveControl.isKindOf(CM_EntryTable) and theActiveControl.visible then
			theActiveControl.CM_EntryTable.handleTableTab(shift);
		endif;
	endif;
	
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="lstAddresses_displayRow" id="e1731b44-bf34-42d9-8677-dba1a48ebac0">
        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstAddresses_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;
// -------------------------------------------
// Created 26 August 2003 by cnwdvb1
// -------------------------------------------
vars

	selected	: Boolean;
	type		: String;
	entity		: CM_EmailEntity;
	
begin

	entity := obj.CM_EmailEntity;
	if entity.type = Email_Group then
		type := ' (Email Group)';
	else
		type := ' (' &amp; entity.getEmailAddress() &amp; ')';
	endif;
	selected := table.CMUI_ListTable.allSelectedObjects.includes(obj);
	if selected then
		return TableCheckBox_Selected  &amp; Tab &amp; obj.CM_EmailEntity.name &amp; type;
	else
		return  TableCheckBox_NotSelected &amp; Tab &amp; obj.CM_EmailEntity.name &amp; type;
	endif;	



end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="lstAddresses_keyDown" id="37f85ae0-5069-423b-ba98-f167205b0872">
        <controlMethod name="Table::keyDown"/>
