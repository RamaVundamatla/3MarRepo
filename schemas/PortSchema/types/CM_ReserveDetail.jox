    <JadeMethod name="getProspectiveCargo" id="09185685-731c-449a-a721-5e777e2fa9c3">
        <source>getProspectiveCargo( 	_targetLocation : CM_LocationsController;
						_tiDictionary		: Collection input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 September 2021	jlier1	Initial creation 51879 refactored out of CM_BulkRelease getProspectiveCargo
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
20/12/2024	navkc1 JIRA Bug MTN-33697: MTN - Internal server error in release staging app
*/

vars
	ti : CM_TrackedItem;
	isPacking : Boolean;
	allTis	: CM_TISet;
begin
	
	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	
	isPacking:=self.myReserveHeader.isPackingType ;
	
	if not isPackingChild then	
		if self.isComplete then	
			return;
		endif;
		//epr TFS 51879 31/8/21
		if app.isCargoGroupEnabled then
			if isPacking then
				if self.isFullyPacked then
					return;
				endif;
			else
				if self.isFullyLoaded then
					return;
				endif;
			endif;
		endif;
	endif;
		
	self.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
	//foreach ti in self.allTrackedItems discreteLock do
	foreach ti in allTis discreteLock do //23/06/2023	navkc1	CR 58406 Task 58408
		if not ti.isAvailableToStageFor(self.myReserveHeader) then
			continue;
		endif; 
			
		if not isPackingChild then	
			if isPacking then
				if ti.isContainer or ti.isChassis then
					//will be associated so as to be a parent not a child.
					continue;
				endif;
			endif;
			//epr TFS 45291 23/9/19 
			
		else
			if ti.myPrimaryActualLocation = null or  not ti.isOnSite then
				continue;
			endif;
			if self.myReserveHeader.isRoadType then    // 36127
				if ti.myPrimaryActualLocation.isVehicle then
					continue;
				elseif ti.myPrimaryActualLocation.isTILCController then
					continue;
				endif;
			endif;
		endif;

		if ti.myPrimaryActualLocation = _targetLocation then
			continue;
		elseif ( _targetLocation &lt;&gt; null and _targetLocation.isWagon ) then	
			if ti.myPrimaryActualLocation.isWagon
			and ( ti.myPrimaryActualLocation.CM_WagonController.myWagon = _targetLocation.CM_WagonController.myWagon )
			then
				continue;
			endif;
		endif;

		//_tiDictionary.add( ti );
		_tiDictionary.tryAdd( ti ); //20/12/2024	navkc1 JIRA Bug MTN-33697
	endforeach;

epilog
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
        <Parameter name="_targetLocation" type="CM_LocationsController"/>
        <Parameter name="_tiDictionary" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getQuantReleasedOrLoaded" id="1212a3d7-defb-418b-9077-ca571c93e718">
        <source>getQuantReleasedOrLoaded():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Mar 2025	navhl20	Bug MTN-34073 : TPT - Unable to display released weight on report
*/
vars
	result 	: Integer;
	ti 		: CM_TrackedItem;
begin
	foreach ti in self.allTrackedItemsReleased discreteLock do
		result := result + ti.totalQuantity;
	endforeach;
	
	if result = null then
		foreach ti in self.allTrackedItems discreteLock do
			result := result + ti.totalQuantity;
		endforeach;
	endif;
	
	return result;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
