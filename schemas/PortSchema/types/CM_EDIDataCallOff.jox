    <JadeMethod name="getEDIDataTypeChildren" id="972066b7-c37d-4bed-baea-5948c0d2105e">
        <source>getEDIDataTypeChildren(_ediDataType: Integer; _childrenDataTypes: IntegerArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
*/

vars

begin
	if _ediDataType = EDIDataType_JMTInternal then
		_childrenDataTypes.add(EDIDataType_CallOff);
	elseif _ediDataType = EDIDataType_CallOff then
		_childrenDataTypes.add(EDIDataType_RequestHeader);
	elseif _ediDataType = EDIDataType_RequestHeader then
		_childrenDataTypes.add(EDIDataType_RequestDetail);
	elseif _ediDataType = EDIDataType_RequestDetail then
		_childrenDataTypes.add(EDIDataType_RequestCriteria);
	elseif _ediDataType = EDIDataType_RequestCriteria then
		_childrenDataTypes.add(EDIDataType_ReqBookToDo);
	endif;

epilog

end;</source>
