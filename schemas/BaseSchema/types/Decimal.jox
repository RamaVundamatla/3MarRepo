<PrimType name="Decimal">
    <JadeMethod name="cnEcAdd" id="52721016-aa73-4c36-83f1-7b63568520f4">
        <updating/>
        <source>cnEcAdd(pIncrement:Decimal):Decimal updating;
// --------------------------------------------------------------------------------
// Created:		06 May 2001 by cnwdad1
//
// Purpose:		Increments the receiver by the value specified by the parameter,
//				and returns the result.
//
//				*************************************************************
//				* NOTE: Do not use this method to increment a loop counter. *
//				*************************************************************
//
// Parameters:	pIncrement (Integer) - The amount by which to increment the receiver.
//
// Returns:		The result of the increment.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self := self + pIncrement;
epilog
	return self;
end;</source>
        <Parameter name="pIncrement" type="Decimal"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="cnEcAsKilobytes" id="5e66be8c-5efc-49ac-bce2-4ec9124a6a36">
        <source>cnEcAsKilobytes():Real;
// -----------------------------------------------------------------------------
// Created:		21 January 2002 by cnwdad1
//
// Purpose:		Converts the receiver's value into its equivalent kilobytes.
//
// Parameters:	None
//
// Returns:		The receiver converted into kilobytes.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
constants
	BYTES_PER_KILOBYTE	: Integer = 1024;
	
begin
	return self / BYTES_PER_KILOBYTE;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="cnEcAsMegabytes" id="ee4b69be-b76f-4237-b5ac-9e6d846487c7">
        <source>cnEcAsMegabytes():Real;
// -----------------------------------------------------------------------------
// Created:		21 January 2002 by cnwdad1
//
// Purpose:		Converts the receiver's value into its equivalent megabytes.
//
// Parameters:	None
//
// Returns:		The receiver converted into megabytes.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
constants
	BYTES_PER_MEGABYTE	: Integer = 1048576;
	
begin
	return self / BYTES_PER_MEGABYTE;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="cnEcAsPercent" id="ca86ff57-d386-444b-97f0-22bb6910d990">
        <source>cnEcAsPercent(pDecimalPlaces:Integer; pIsRounded:Boolean):String;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		Returns the receiver as a string formatted with a percent sign.
//
// Parameters:	pDecimalPlaces (Integer) - The number of places to truncate or
//					round off to.
//				pIsRounded (Boolean) - If true, residuals will be rounded off,
//					otherwise residuals will be discarded.
//
// Returns:		A string with the resulting percent value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	PERCENT_SIGN	: Character = "%";

vars
	stringResult	: String;
	
begin
	if pDecimalPlaces = 0 then
		if pIsRounded then
			stringResult	:=	self.rounded.String;
		else
			stringResult	:=	self.truncated.String;
		endif;
	else
		if pIsRounded then
			stringResult	:=	self.roundedTo(pDecimalPlaces).String;
		else
			stringResult	:=	self.truncatedTo(pDecimalPlaces).String;
		endif;
	endif;
	
	return stringResult &amp; PERCENT_SIGN;
end;</source>
        <Parameter name="pDecimalPlaces" type="Integer"/>
        <Parameter name="pIsRounded" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcAsWords" id="597eaa44-6021-4265-b7f1-f355d5ce0eb9">
        <source>cnEcAsWords(pFullLocaleObj:LocaleFullInfo; pWordedWholeAmount:String io; pWordedDecimalAmount:String io);
// --------------------------------------------------------------------------------
// Created:		21 August 2001 by cnwdad1
//
// Purpose:		Converts the receiver into a string, expressed in words.
//
// Parameters:	pTheNumberFormat - The locale of the number format information to
//					apply to the receiver, for example, the US "Billion" versus the
//					UK "Thousand Million".
//
//					If the locale is null, the default will be used.
//
//				pWordedWholeAmount - The receiver's whole amount expressed in words.
//				pWordedDecimalAMount - The receiver's decimal amount expressed in words.
//
// Returns:		The whole and decimal amount parameters, expressed in words.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	fullLocaleObj		: LocaleFullInfo;
	wholeAmount			: Real;
	decimalAmount		: Real;
	stringValue			: String;
	decimalSeparator	: String;
	separatorPosition	: Integer;
	
begin
	if pFullLocaleObj = null then
		fullLocaleObj	:=	app.currentLocaleInfo;
	else
		fullLocaleObj	:=	pFullLocaleObj;
	endif;
	
	stringValue			:=	self.String;
	decimalSeparator	:=	fullLocaleObj.numericInfo.decimalSeparator;
	separatorPosition	:=	stringValue.reversePos(decimalSeparator);
	
	if separatorPosition = 0 then
		wholeAmount		:=	self;
		decimalAmount	:=	0;
	else
		wholeAmount		:=	(stringValue.String[1:(separatorPosition - 1)]).Real;
		decimalAmount	:=	(stringValue.String[(separatorPosition + 1):end]).Real;
	endif;
	
	pWordedWholeAmount	:=	wholeAmount.cnEcAsWordsWhole(fullLocaleObj);
	
	if decimalAmount = 0 then
		pWordedDecimalAmount	:= $CNEC_NUM_ZERO;
	else
		pWordedDecimalAmount	:=	decimalAmount.cnEcAsWordsWhole(fullLocaleObj);
	endif;
end;</source>
        <Parameter name="pFullLocaleObj" type="LocaleFullInfo"/>
        <Parameter name="pWordedWholeAmount" type="String" usage="io"/>
        <Parameter name="pWordedDecimalAmount" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="cnEcFractionValue" id="99cfc792-cf44-45c0-89a7-ffd226535068">
        <source>cnEcFractionValue():Integer;
// -----------------------------------------------------------------------------
// Created:		20 January 2002 by cnwdad1
//
// Purpose:		Returns the fractional value of the receiver.
//
// Parameters:	None
//
// Returns:		The fraction part of the receiver, as a whole number (Integer).
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	fractionValue	: Real;
	decimalPlaces	: Integer;
	
begin
	decimalPlaces	:=	self.getDeclaredScaleFactor();
	
	if decimalPlaces = 0 then
		return 0;
	else
		fractionValue	:=	self mod 1;
		fractionValue	:=	fractionValue * (10 ^ decimalPlaces);
		
		return fractionValue.Integer;
	endif;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcMax" id="1345d443-1502-45da-af15-3fd2b1bdde54">
        <source>cnEcMax(pDecimal:Decimal):Decimal;
// --------------------------------------------------------------------------------
// Created:		15 March 2007 by cnwdad1
//
// Purpose:		Returns which ever is the greatest value between the receiver and the
//				parameter.
//
// Parameters:	pDecimal - The decimal to compare the receiver to.
//
// Returns:		The latest decimal.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self &gt; pDecimal then
		return self;
	else
		return pDecimal;
	endif;
end;</source>
        <Parameter name="pDecimal" type="Decimal"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="cnEcMin" id="ead8f263-ba2c-490d-b02b-ef16f0053d3e">
        <source>cnEcMin(pDecimal:Decimal):Decimal;
// --------------------------------------------------------------------------------
// Created:		15 March 2007 by cnwdad1
//
// Purpose:		Returns which ever is the smallest value between the receiver and the
//				parameter.
//
// Parameters:	pDecimal - The decimal to compare the receiver to.
//
// Returns:		The smallest decimal value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self &lt; pDecimal then
		return self;
	else
		return pDecimal;
	endif;
end;</source>
        <Parameter name="pDecimal" type="Decimal"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="cnEcNumberFormat" id="40461ca9-d82e-4ff9-b563-10dd27bef5ff">
        <source>cnEcNumberFormat():String;
// -----------------------------------------------------------------------------
// Created:		20 January 2002 by cnwdad1
//
// Purpose:		Formats the receiver as a string value, i.e. 1234.56 will be
//				returned as "1,234.56".
//
// Parameters:	None
//
// Returns:		The receiver formatted as a string.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	if self.getDeclaredScaleFactor() = 0 then
		return self.userNumberFormat($CNEC_NO_DECIMALS);
	else
		return self.numberFormat();
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcRoundToFiveCents" id="b84b04e6-6217-4b84-89a1-40422cfa386f">
        <source>cnEcRoundToFiveCents():Decimal;
// --------------------------------------------------------------------------------
// Created:		08 November 2000 by cnwdad1
//
// Purpose:		Rounds the receiver to the nearest five cents.
//
// Parameters:	None
//
// Returns:		The rounded dollar value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	dollarAmount		: Integer;
	centsAmount			: Integer;
	remainingAmount		: Integer;
	roundedAmount		: Decimal[12, 2];
	
begin
	dollarAmount	:=	self.Integer;
	centsAmount		:=	((self - dollarAmount) * 100).Integer;
	remainingAmount	:=	centsAmount mod 5;

	if remainingAmount &lt; 3 then					// We must round down.
		centsAmount	:=	centsAmount - remainingAmount;
	else										// We are rounding up.
		centsAmount	:=	centsAmount + (5 - remainingAmount);

		if centsAmount = 100 then
			centsAmount		:=	0;
			dollarAmount	:=	dollarAmount + 1;
		endif;
	endif;

	roundedAmount	:=	dollarAmount + (centsAmount / 100);
	
	return roundedAmount;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="cnEcRoundToFiveCentsMod" id="c28eb673-c888-4da8-b1b0-b6490a27f28e">
        <source>cnEcRoundToFiveCentsMod(pRemainder:Integer io):Decimal;
// --------------------------------------------------------------------------------
// Created:		08 November 2000 by cnwdad1
//
// Purpose:		Rounds the receiver to the nearest five cents, and returns the
//				remainder in the I/O parameter.
//
// Parameters:	pRemainder (Integer) - An I/O parameter which will return the
//				remainder of the receiver after rounding.
//
// Returns:		The rounded dollar value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	dollarAmount		: Integer;
	centsAmount			: Integer;
	remainingAmount		: Integer;
	roundedAmount		: Decimal[12, 2];
	
begin
	dollarAmount	:=	self.Integer;
	centsAmount		:=	((self - dollarAmount) * 100).Integer;
	remainingAmount	:=	centsAmount mod 5;

	if remainingAmount &lt; 3 then					// We must round down.
		centsAmount	:=	centsAmount - remainingAmount;
	else										// We are rounding up.
		centsAmount	:=	centsAmount + (5 - remainingAmount);

		if centsAmount = 100 then
			centsAmount		:=	0;
			dollarAmount	:=	dollarAmount + 1;
		endif;
	endif;

	roundedAmount	:=	dollarAmount + (centsAmount / 100);
	pRemainder		:=	remainingAmount;
	
	return roundedAmount;
end;</source>
        <Parameter name="pRemainder" type="Integer" usage="io"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="cnEcRoundToTenCents" id="0baa592b-6933-4cdd-83ce-822af0ad2804">
        <source>cnEcRoundToTenCents():Decimal;
// --------------------------------------------------------------------------------
// Created:		08 November 2000 by cnwdad1
//
// Purpose:		Rounds the receiver to the nearest ten cents.
//
// Parameters:	None
//
// Returns:		The rounded dollar value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	dollarAmount		: Integer;
	centsAmount			: Integer;
	remainingAmount		: Integer;
	roundedAmount		: Decimal[12, 2];
	
begin
	dollarAmount	:=	self.Integer;
	centsAmount		:=	((self - dollarAmount) * 100).Integer;
	remainingAmount	:=	centsAmount mod 10;

	if remainingAmount &lt; 5 then					// We must round down.
		centsAmount	:=	centsAmount - remainingAmount;
	else										// We are rounding up.
		centsAmount	:=	centsAmount + (10 - remainingAmount);

		if centsAmount = 100 then
			centsAmount		:=	0;
			dollarAmount	:=	dollarAmount + 1;
		endif;
	endif;

	roundedAmount	:=	dollarAmount + (centsAmount / 100);
	
	return roundedAmount;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="cnEcRoundToTenCentsMod" id="e61871f6-2995-4331-977d-9ee73ded6d7e">
        <source>cnEcRoundToTenCentsMod(pRemainder:Integer io):Decimal;
// --------------------------------------------------------------------------------
// Created:		08 November 2000 by cnwdad1
//
// Purpose:		Rounds the receiver to the nearest ten cents, and returns the
//				remainder in the I/O parameter.
//
// Parameters:	pRemainder (Integer) - An I/O parameter which will return the
//				remainder of the receiver after rounding.
//
// Returns:		The rounded dollar value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	dollarAmount		: Integer;
	centsAmount			: Integer;
	remainingAmount		: Integer;
	roundedAmount		: Decimal[12, 2];
	
begin
	dollarAmount	:=	self.Integer;
	centsAmount		:=	((self - dollarAmount) * 100).Integer;
	remainingAmount	:=	centsAmount mod 10;

	if remainingAmount &lt; 5 then					// We must round down.
		centsAmount	:=	centsAmount - remainingAmount;
	else										// We are rounding up.
		centsAmount	:=	centsAmount + (10 - remainingAmount);

		if centsAmount = 100 then
			centsAmount		:=	0;
			dollarAmount	:=	dollarAmount + 1;
		endif;
	endif;

	roundedAmount	:=	dollarAmount + (centsAmount / 100);
	pRemainder		:=	remainingAmount;
	
	return roundedAmount;
end;</source>
        <Parameter name="pRemainder" type="Integer" usage="io"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="cnEcStripDecimalZeros" id="59c95cbd-c704-4955-ad00-229b98fc19a0">
        <source>cnEcStripDecimalZeros():String;
// --------------------------------------------------------------------------------
// Created:		27 July 2002 by cnwdad1
//
// Purpose:		Strips all trailing zeros following the decimal point.  If no
//				decimal point is found, then the whole value is return.
//
// Parameters:	None
//
// Returns:		The stripped decimal as a string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	resultValue			: String;
	decimalCharacter	: String;
	decimalPosition		: Integer;
	valueLength			: Integer;
	characterPosition	: Integer;
	
begin
	resultValue			:=	self.String;
	decimalCharacter	:=	app.currentLocaleInfo.numericInfo.decimalSeparator;
	decimalPosition		:=	resultValue.pos(decimalCharacter, 1);
	
	if decimalPosition = 0 then
		return resultValue;
	else
		valueLength	:=	resultValue.length();
		
		foreach characterPosition in 1 to valueLength reversed do
			if characterPosition = decimalPosition then
				characterPosition	:=	decimalPosition - 1;
				break;
				
			elseif resultValue[characterPosition] &lt;&gt; "0" then
				break;
				
			endif;
		endforeach;
	endif;
	
	if characterPosition &lt; valueLength then
		resultValue	:=	resultValue[1:characterPosition];
	endif;
epilog
	return resultValue;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcTake" id="729257ae-9276-4bac-a0bf-47dc3819c13b">
        <updating/>
        <source>cnEcTake(pDecrement:Decimal):Decimal updating;
// --------------------------------------------------------------------------------
// Created:		06 May 2001 by cnwdad1
//
// Purpose:		Decrements the receiver by the value specified by the parameter,
//				and returns the result.
//
//				*************************************************************
//				* NOTE: Do not use this method to decrement a loop counter. *
//				*************************************************************
//
// Parameters:	pDecrement (Integer) - The amount by which to decrement the receiver.
//
// Returns:		The result of the decrement.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self := self - pDecrement;
epilog
	return self;
end;</source>
        <Parameter name="pDecrement" type="Decimal"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="cnEcWholeValue" id="53482b01-408b-4b20-84aa-dcdf9412360a">
        <source>cnEcWholeValue():Integer;
// -----------------------------------------------------------------------------
// Created:		20 January 2002 by cnwdad1
//
// Purpose:		Returns the whole value of the receiver.
//
// Parameters:	None
//
// Returns:		The whole part of the receiver, as an integer.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	return (self.truncatedTo(0)).Integer;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
</PrimType>
