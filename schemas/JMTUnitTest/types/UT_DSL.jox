    <JadeMethod name="findTIsWithIDInTerminalQuick" id="889dc1f5-54de-4dad-982d-545e36e76bd2">
        <source>findTIsWithIDInTerminalQuick(_tiId : String; _tiSet : CM_TISet io);

/*

Purpose:		Rather than use getTrackedItem and getTrackedItemByCargoType which
				use the lookupAllTIsOfIdCargoType methods this is a cutdown faster 
				version of this without all the cmifMonitor stuff.

Date			Who		Reason
24/11/2014		cnwmh5	Initial creation

*/

vars

	terminal				: CM_Terminal;
	voyage					: CM_Voyage;
	ti						: CM_TrackedItem;

	iter					: Iterator;
	
	ts						: TimeStamp;

begin

	if _tiSet = null then
		return;
	endif;

	terminal := self.getTerminal();
	
	self.sendMsg("deleteMyMergeIter");
	
	// create mergeIter the 1st time in
	if self.myMergeIter = null then
		self.sendMsg("createMyMergeIter");
		
		self.myMergeIter.addCollection(terminal.allNotifiedTIsByIdCargoType);
		self.myMergeIter.addCollection(terminal.allOnsiteTIsByIdCargoType);
		
		foreach voyage in terminal.allVoyagesArchived do
			self.myMergeIter.addCollection(voyage.allOnshipTIsByIdCargoType);
		endforeach;
		
		foreach voyage in terminal.allVoyagesByCode do
			//if not voyage.allOnshipTIsByIdCargoType.isEmpty() then
				self.myMergeIter.addCollection(voyage.allOnshipTIsByIdCargoType);
			//endif;
		endforeach;
	endif;
	
	self.myMergeIter.startKeyGeq(_tiId, 0);
	while self.myMergeIter.next(ti) and ti.id = _tiId do
		_tiSet.add(ti);	
	endwhile;
	
	ts := null;
	iter := terminal.allOffsiteTIsByIdCargoType.createIterator;
	terminal.allOffsiteTIsByIdCargoType.startKeyGeq(_tiId, null, ts, iter);
	while iter.next(ti) and ti.id = _tiId do
		_tiSet.add(ti);
	endwhile;
	
epilog

	delete iter;

end;</source>
        <Parameter name="_tiId" type="String"/>
        <Parameter name="_tiSet" type="CM_TISet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="gateInBulkGate" id="e0db3318-74e8-4a31-b9eb-e68a461e31cf">
        <source>gateInBulkGate(_truck, _state, _driver, _cargoID,_cargoType,_commodity: String;
				_carrier : CM_Carrier;
				_gate: CM_Gate;
				_scaleWeight : Decimal;
				_direction : Integer;
				_cargoItem : CM_TrackedItem;//may be prenote
				_myBulkGateAgent : CM_BulkGateProcessingAgent io;
				terminal : CM_Terminal;
				_bulkRelease : CM_BulkRelease
				);

//13/05/2022 navhl20 TFS 53430  EUP - Sub Carrier registration in MTN
vars
	result 			: Integer;
	pxyVVR			: CM_VehicleVisitRecord; 
	realVVR 		: CM_VehicleVisitRecord;
	printBuckSlip	: Boolean;	
	gate 			: CM_Gate;	
	defaultPrinterName : String;
//	scaleWeight 	: Decimal[16,4];  // in kilos

	realTruck 		: CM_Vehicle;
	pxyVehicle 		: CM_Vehicle;

	aGate			: CM_GateArea;		
	ownerTrailerID	: String;
	tmpController : CMIF_FlexiGateController;
	controller : CMIF_FlexiGateController;
	gateEntity: CMGTE_Entity;
	gateName: String;
	cargoType : CM_CargoType;
	id: String;
	resDet : CM_ReserveDetail;

begin


	create pxyVVR transient;	


	pxyVVR.setAutoComplete(false);
	pxyVVR.setTimeIn(null, null);
		
	
	create tmpController transient;
	
	if _direction = Inward then
		create _myBulkGateAgent.myPxyGTEEntity as CMGTE_Receival transient;
		tmpController.jobType 		:= CMGTE_Entity.JobType_GeneralIN;		
		_myBulkGateAgent.setDirection(true);
	elseif _direction = Outward then
		create _myBulkGateAgent.myPxyGTEEntity as CMGTE_Release transient;
		tmpController.jobType 		:= CMGTE_Entity.JobType_GeneralOUT;
		_myBulkGateAgent.setDirection(false);
	else
		//Is not Inward or outward - we have a problem
		return;
	endif;
	 
	tmpController.myTerminal := terminal;
	if _myBulkGateAgent.myPxyGTEEntity.isKindOf(CMGTE_Release) and _bulkRelease &lt;&gt; null then 
		_myBulkGateAgent.myPxyGTEEntity.setPXYFromController(tmpController);
	endif;
	
	
	_myBulkGateAgent.myPxyGTEEntity.setPxyFromTI(_cargoItem);
	_myBulkGateAgent.myPxyGTEEntity.setWeight(_cargoItem.totalWeight);
	
	if _bulkRelease &lt;&gt; null then	
		resDet :=	_bulkRelease.getReserveDetail();
		_myBulkGateAgent.myPxyGTEEntity.CMGTE_Release.setPXYFromBulkRelease(_bulkRelease, resDet);
		if _cargoItem.totalWeight &gt; resDet.getWeightOutstanding then
			_myBulkGateAgent.myPxyGTEEntity.setWeight(resDet.getWeightOutstanding);
		endif;
	endif;
	
	
	
	
	
	
		
	
	aGate := _gate.getFirstAGate_IN;
	//pxyVVR.setProxyFlexiGate(_driver, _driver, _carrier.code, _truck, _state, null,terminal,_gate ,aGate.getDefaultLane_IN, ownerTrailerID);		//13/05/2022 navhl20 TFS 53430
	pxyVVR.setProxyFlexiGate(_driver, _driver, _carrier.code, null, _truck, _state, null,terminal,_gate ,aGate.getDefaultLane_IN, ownerTrailerID);		//13/05/2022 navhl20 TFS 53430  
	

	if 	_myBulkGateAgent.myPxyGTEEntity &lt;&gt; null then		
		_myBulkGateAgent.myPxyGTEEntity.setMyVehicleVisit(pxyVVR);
	else
		_myBulkGateAgent.myPxyGTEEntity :=  pxyVVR.allGateEntities.first();
	endif;


	_myBulkGateAgent.doSetGTEWeights(pxyVVR);
	
	realTruck :=  terminal.vehicles.getAtKey(_truck,_state);
	
	if realTruck = null then
		create pxyVehicle transient;
		
		pxyVehicle.setProxy( _truck, null, null, 0, _carrier ,_state,  false, terminal);
	
		app.myTrxCA.trxCreateVehicle( pxyVehicle, realTruck, app.myPassport );
	
		delete pxyVehicle;
	endif;

	while true do
		app.myTrxCA.trxProcessBulkGateIn(pxyVVR, realVVR, _scaleWeight,_scaleWeight, null,  app.myPassport);
        if app.myPassport.trxCompletedOK then
            break;
        else
			if app.myPassport.noErrors  then	
				app.myPassport.warningsAcknowledged     := true;
				continue;
			endif;
			break;
        endif;
        break;
	endwhile;
	
_myBulkGateAgent.myRealVVR := realVVR;

	





epilog
	delete pxyVVR;
	
	delete pxyVehicle;
	delete	tmpController;
//	delete	_myBulkGateAgent.myPxyGTEEntity;
end;</source>
        <Parameter name="_truck" type="String"/>
        <Parameter name="_state" type="String"/>
        <Parameter name="_driver" type="String"/>
        <Parameter name="_cargoID" type="String"/>
        <Parameter name="_cargoType" type="String"/>
        <Parameter name="_commodity" type="String"/>
        <Parameter name="_carrier" type="CM_Carrier"/>
        <Parameter name="_gate" type="CM_Gate"/>
        <Parameter name="_scaleWeight" type="Decimal"/>
        <Parameter name="_direction" type="Integer"/>
        <Parameter name="_cargoItem" type="CM_TrackedItem"/>
        <Parameter name="_myBulkGateAgent" type="CM_BulkGateProcessingAgent" usage="io"/>
        <Parameter name="terminal" type="CM_Terminal"/>
        <Parameter name="_bulkRelease" type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="gateInContainer" id="6a43f2fe-332f-4763-8549-d2d52372288e">
        <source>gateInContainer(_truck, _containerID: String; _isoCode: String; _operatorCode: String; _commodity: String; _gate: Any): CM_VehicleVisitRecord;
//30 July 2009		cnwdw1	
//02 November 2009	cnwdap1	Add overdimension option
// 04/02/2014		cnwmh5	Add Driver name
vars
	pxyVVR, vVR: CM_VehicleVisitRecord; 
	gateEntity: CMGTE_Entity;
	gateName: String;
	driverName : String;
	expectErrors : Boolean;
	
begin

	expectErrors := self.opts.bool("ExpectErrors");

	if _gate.isKindOf(String) then
		gateName := _gate.String;
	elseif _gate.isKindOf(CM_Gate) then
		gateName := _gate.CM_Gate.name;
	endif;
	
	if gateName = null then
		gateName := self.getTerminal.getDefaultGate_IN().name;
	endif;
	
	// check if driver name passed
	if self.opts.includesKey("DriverName") then							// 04/02/2014 cnwmh5
		driverName := self.opts.str("DriverName");
	endif;
	
	// Create the Vehicle Visit Record
	vVR := addVehicleVisitRecord(_truck, "", driverName, gateName);
	self.assertNoTrxErrorsOrWarnings();
	if vVR = null then
		return null;
	endif;
	
	// Create the Gate Entity for first container
	gateEntity := self.createGateEntity(vVR, "CONT", _containerID, _isoCode, _operatorCode, _commodity, 1);
	if expectErrors and  app.myPassport.hasErrors then
		return vVR;
	endif;
	
	// Create the Gate Entity for second container
	gateEntity := self.createGateEntity(vVR, "CONT", self.opts.str("ContainerID2"), _isoCode, _operatorCode, _commodity, 1);
	
	
	// Complete the Gate In - Road job is created
	pxyVVR := app.createUpdateProxy(vVR).CM_VehicleVisitRecord;
	self.ignoreTrxWarnings(true);  // Need to ignore the id check digit warning
	app.myTrxCA.trxCreateInOutFlexiJob(pxyVVR, vVR,null, app.myPassport);
	if expectErrors then
		return vVR;
	endif;
	self.assertNoTrxErrorsOrWarnings();
	self.checkTIsForTxnOfType(vVR.allReceivedTrackedItems, TRANS_TYPE_REC_ROAD);				// 16/08/2012 cnwmh5
	return vVR;

epilog
	delete pxyVVR;
end;</source>
        <Parameter name="_truck" type="String"/>
        <Parameter name="_containerID" type="String"/>
        <Parameter name="_isoCode" type="String"/>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_commodity" type="String"/>
        <Parameter name="_gate" type="Any"/>
        <ReturnType type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="gateInContainerAtOutGate" id="e13d73df-c684-48a8-a5b1-a58e425bdf45">
        <source>gateInContainerAtOutGate(_vVR: CM_VehicleVisitRecord input; _containerID: String; _isoCode: String; _operatorCode: String; _commodity: String): CM_VehicleVisitRecord;
//30 July 2009	cnwdw1	
// Add a container receival at gate out
// 05/08/2011 cnwmh5 Change to user UT_UnitTest's opts
vars
	controller : CMIF_FlexiGateController;
	pxyGateEntity, gateEntity: CMGTE_Entity;
begin

	// Create the GTE Entity and add to VVR
	create controller transient;
	create pxyGateEntity as CMGTE_Container transient;
	controller.myTerminal := self.getTerminal();
	if app.myRoot.isAnEmptyCommodity(_commodity, false) then
		controller.jobType := CMGTE_Entity.JobType_EmptyIN;   // MT
	else
		controller.jobType := CMGTE_Entity.JobType_FullIN;   // MT
	endif;
	
	controller.id := _containerID;
	controller.isoTypeCode := _isoCode;
	controller.operatorCode := _operatorCode;
	controller.commodity := _commodity;
	controller.carriageTempC := NULL_TEMPERATURE;
	controller.setCarbonDioxide( NULL_CARBON_DIOXIDE );
	controller.setOxygen( NULL_OXYGEN );
	controller.imexStatus := TI_IMEX_STATUS_STORAGE;
	controller.weightTotal := 2000;
	controller.yardLocationTxt := self.opts.str("Location");
	controller.myVehicleVisitRecord := _vVR;
	pxyGateEntity.setPXYFromController(controller); 

	self.ignoreTrxWarnings(true);
	app.myTrxCA.trxCreateAndActionGateEntity(_vVR, pxyGateEntity, null, gateEntity, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.checkTIsForTxnOfType(_vVR.allReceivedTrackedItems, TRANS_TYPE_REC_ROAD);			// 17/08/2012 cnwmh5
	return _vVR;
epilog
	delete pxyGateEntity;
	delete controller;
end;</source>
        <Parameter name="_vVR" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_containerID" type="String"/>
        <Parameter name="_isoCode" type="String"/>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_commodity" type="String"/>
        <ReturnType type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="gateInGC" id="b28c782d-a04d-430c-93be-dc8be3cde033">
        <source>gateInGC(_truck, _state, _driver: String; _containerID: Any;
			_cargoType: String;
			_operatorCode: String; 
			_commodity: String;
			_gate: Any;
			_totalQuantity : Integer): CM_VehicleVisitRecord;
//30 July 2009	cnwdw1	
// 05/08/2011	cnwmh5	Change to use UT_UnitTest's opts
vars
	pxyVVR, vVR: CM_VehicleVisitRecord; 
	controller : CMIF_FlexiGateController;
	gateEntity: CMGTE_Entity;
	gateName: String;
	cargoType : CM_CargoType;
	id: String;
begin

	if _gate.isKindOf(String) then
		gateName := _gate.String;
	else
		gateName := _gate.CM_Gate.name;
	endif;


	// Create the Vehicle Visit Record
	vVR := addVehicleVisitRecord(_truck, _state, _driver, gateName);
	cargoType := getRoot.getCargoTypeFromAbbrevOrDescr( _cargoType );
	if _containerID.isKindOf(String) then
		gateEntity := self.createGateEntity(vVR, cargoType.abbreviation, _containerID.String, null, _operatorCode, _commodity, _totalQuantity);
	elseif _containerID.isKindOf(StringArray) then
		foreach id in _containerID.StringArray do
			gateEntity := self.createGateEntity(vVR, cargoType.abbreviation, id, null, _operatorCode, _commodity, _totalQuantity);
		endforeach;
	endif;
	
	// Complete the Gate In - Road job is created
	pxyVVR := app.createUpdateProxy(vVR).CM_VehicleVisitRecord;
	self.ignoreTrxWarnings(true);
	app.myTrxCA.trxCreateInOutFlexiJob(pxyVVR, vVR,null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.checkTIsForTxnOfType(vVR.allReceivedTrackedItems, TRANS_TYPE_REC_ROAD);		// 17/08/2012 cnwmh5
	return vVR;

epilog
	delete pxyVVR;
end;</source>
        <Parameter name="_truck" type="String"/>
        <Parameter name="_state" type="String"/>
        <Parameter name="_driver" type="String"/>
        <Parameter name="_containerID" type="Any"/>
        <Parameter name="_cargoType" type="String"/>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_commodity" type="String"/>
        <Parameter name="_gate" type="Any"/>
        <Parameter name="_totalQuantity" type="Integer"/>
        <ReturnType type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="gateInGCByType" id="48e6951e-3445-4c7c-97de-e76a66b794eb">
        <source>gateInGCByType(_truck, _state, _driver: String; _gate: Any): CM_VehicleVisitRecord;
//30 July 2009	cnwdw1	
// Gate in  General Cargo by Type
// 05/08/2011 	cnwmh5	Change to use UT_UnitTest's opts
vars
	pxyVVR, vVR: CM_VehicleVisitRecord; 
	controller : CMIF_FlexiGateController;
	pxyGateEntity, gateEntity: CMGTE_Entity;
	gateName: String;
	booking: CM_BookingRef;
	cargoType: String;
begin

	if _gate.isKindOf(String) then
		gateName := _gate.String;
	else
		gateName := _gate.CM_Gate.name;
	endif;


	// Create the Vehicle Visit Record
	vVR := addVehicleVisitRecord(_truck, _state, _driver, gateName);

		// Create the GTE Entity and add to VVR
	create controller transient;
	create pxyGateEntity as CMGTE_ReceivalByType transient;
	controller.myTerminal := self.getTerminal();
	controller.jobType := CMGTE_Entity.JobType_GeneralIN;   
	cargoType := self.opts.str("CargoType");
	if cargoType &lt;&gt; null then
		controller.cargoType :=  self.getCargoType(cargoType).id;  
	endif;
	
	controller.commodity := self.opts.str("Commodity");
	controller.numItems := self.opts.int("Quantity");
	controller.operatorCode := self.opts.str("Operator");
	booking := self.opts.obj("myBooking").CM_BookingRef;
	if booking &lt;&gt; null then
		controller.bookingNumber := booking.bookingReference;
		if booking.myVoyage &lt;&gt; null then
			controller.voyageCode := booking.myVoyage.code;
		endif;
	endif;
	controller.myBookingRefItem := self.opts.obj("myBookingItem").CM_BookingRefItem;
	controller.yardLocationTxt := self.opts.str("YardInterchangeArea");
	controller.myVehicleVisitRecord := vVR;
	pxyGateEntity.setPXYFromController(controller); 
	
	app.myTrxCA.trxCreateInOutFlexiGateEntity(vVR, pxyGateEntity, gateEntity, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	delete pxyVVR;
	delete pxyGateEntity;
	delete controller;
	
	// Complete the Gate In - Road job is created
	pxyVVR := app.createUpdateProxy(vVR).CM_VehicleVisitRecord;
	self.ignoreTrxWarnings(true);
	app.myTrxCA.trxCreateInOutFlexiJob(pxyVVR, vVR,null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	return vVR;

epilog
	delete pxyVVR;
	delete pxyGateEntity;
	delete controller;
end;</source>
        <Parameter name="_truck" type="String"/>
        <Parameter name="_state" type="String"/>
        <Parameter name="_driver" type="String"/>
        <Parameter name="_gate" type="Any"/>
        <ReturnType type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="gateInGCMultipleCargoTypes" id="eab7913d-df08-4ba8-85a7-8dd5be52b407">
        <source>gateInGCMultipleCargoTypes(_truck, _state, _driver: String; _cargoIDs: StringArray;
			_cargoTypes: StringArray;
			_operatorCode: String; 
			_commodity: String;
			_gate: Any;
			_totalQuantity : Integer): CM_VehicleVisitRecord;
/*

Purpose:			

Parameters:			

The _cargoTypes and _cargoIDs are StringArrays, and this method expects them to be of the same size, and it creates each _cargoID[x] as _cargoType[x]

Return Value:		

Date		Who		Reason
31 January 2024	navra1	Initial creation for TFS 62081

*/

vars
	pxyVVR, vVR: CM_VehicleVisitRecord; 
	controller : CMIF_FlexiGateController;
	gateEntity: CMGTE_Entity;
	gateName: String;
	cargoType : CM_CargoType;
	id: String;
	iter : Integer;
begin

	if _cargoIDs = null or _cargoTypes = null then
		return null;
	endif;
	
	if _cargoIDs.size() &lt;&gt; _cargoTypes.size() then
		return null;
	endif;
	
	if _gate.isKindOf(String) then
		gateName := _gate.String;
	else
		gateName := _gate.CM_Gate.name;
	endif;


	// Create the Vehicle Visit Record
	vVR := addVehicleVisitRecord(_truck, _state, _driver, gateName);
	
	iter := 1;
	foreach id in _cargoIDs do
		cargoType := getRoot.getCargoTypeFromAbbrevOrDescr( _cargoTypes[iter]);		
		gateEntity := self.createGateEntity(vVR, cargoType.abbreviation, id, null, _operatorCode, _commodity, _totalQuantity);	
		iter := iter + 1;
	endforeach;	
	
	// Complete the Gate In - Road job is created
	pxyVVR := app.createUpdateProxy(vVR).CM_VehicleVisitRecord;
	self.ignoreTrxWarnings(true);
	app.myTrxCA.trxCreateInOutFlexiJob(pxyVVR, vVR,null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.checkTIsForTxnOfType(vVR.allReceivedTrackedItems, TRANS_TYPE_REC_ROAD);		// 17/08/2012 cnwmh5
	return vVR;

epilog
	delete pxyVVR;
end;</source>
        <Parameter name="_truck" type="String"/>
        <Parameter name="_state" type="String"/>
        <Parameter name="_driver" type="String"/>
        <Parameter name="_cargoIDs" type="StringArray"/>
        <Parameter name="_cargoTypes" type="StringArray"/>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_commodity" type="String"/>
        <Parameter name="_gate" type="Any"/>
        <Parameter name="_totalQuantity" type="Integer"/>
        <ReturnType type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="gateInGenerator" id="634f3816-f143-43d7-b07a-f9202c74c2af">
        <source>gateInGenerator(_truck, _generatorID: String; _operatorCode: String; _gate: Any): CM_VehicleVisitRecord;
//
// 19 May 2017	cnwrs1	TFS 4259 _ Penn Seaboard implimentation
//
vars
	pxyVVR : CM_VehicleVisitRecord; 
	vVR : CM_VehicleVisitRecord; 
	gateEntity : CMGTE_Entity;
	gateName : String;
	driverName : String;
	expectErrors : Boolean;
begin
	expectErrors := self.opts.bool("ExpectErrors");

	if _gate.isKindOf(String) then
		gateName := _gate.String;
	elseif _gate.isKindOf(CM_Gate) then
		gateName := _gate.CM_Gate.name;
	endif;
	
	if gateName = null then
		gateName := self.getTerminal.getDefaultGate_IN().name;
	endif;
	
	// check if driver name passed
	if self.opts.includesKey("DriverName") then							// 04/02/2014 cnwmh5
		driverName := self.opts.str("DriverName");
	endif;
	
	// Create the Vehicle Visit Record
	vVR := addVehicleVisitRecord(_truck, "", driverName, gateName);
	self.assertNoTrxErrorsOrWarnings();
	if vVR = null then
		return null;
	endif;
	
	// Create the Gate Entity for first container
	gateEntity := self.createGateEntity(vVR, "GEN", _generatorID, null, _operatorCode, null, 1);
	if expectErrors and  app.myPassport.hasErrors then
		return vVR;
	endif;
	
	// Create the Gate Entity for second container
//	gateEntity := self.createGateEntity(vVR, "GEN", self.opts.str("ContainerID2"), _isoCode, _operatorCode, _commodity, 1);
	
	// Complete the Gate In - Road job is created
	pxyVVR := app.createUpdateProxy(vVR).CM_VehicleVisitRecord;
	self.ignoreTrxWarnings(true);  // Need to ignore the id check digit warning
	app.myTrxCA.trxCreateInOutFlexiJob(pxyVVR, vVR, null, app.myPassport);
	if expectErrors then
		return vVR;
	endif;
	self.assertNoTrxErrorsOrWarnings();
	self.checkTIsForTxnOfType(vVR.allReceivedTrackedItems, TRANS_TYPE_REC_ROAD);				// 16/08/2012 cnwmh5
	return vVR;

epilog
	delete pxyVVR;
end;
</source>
        <Parameter name="_truck" type="String"/>
        <Parameter name="_generatorID" type="String"/>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_gate" type="Any"/>
        <ReturnType type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="gateInMultiContainer" id="c0056231-7096-4c10-97d6-21798011d44f">
        <source>gateInMultiContainer(_truck: String; _isoCode: String; _operatorCode: String; _commodity: String; _gate: Any; _tiSet: CM_TISet): CM_VehicleVisitRecord;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Apr 2023	navhl20	ChangeRequest 55443:[54991] EUP - Receive Cargo Work Order - Enhancements
22 Feb 2024 navhl20 ChangeRequest 62525: EUP | Retrospective Operations - [54177.060] - Cargo &amp; Truck Checks
*/

vars
	pxyVVR, vVR		: CM_VehicleVisitRecord; 
	gateEntity		: CMGTE_Entity;
	gateName		: String;
	driverName 		: String;
	expectErrors 	: Boolean;
	ti				: CM_TrackedItem;
	retroDT			: TimeStamp;
begin

	expectErrors := self.opts.bool("ExpectErrors");

	if _gate.isKindOf(String) then
		gateName := _gate.String;
	elseif _gate.isKindOf(CM_Gate) then
		gateName := _gate.CM_Gate.name;
	endif;
	
	if gateName = null then
		gateName := self.getTerminal.getDefaultGate_IN().name;
	endif;
	
	// check if driver name passed
	if self.opts.includesKey("DriverName") then
		driverName := self.opts.str("DriverName");
	endif;
	
	if self.opts.includesKey("RetroDT") then				//22.02.2024 navhl20 #62525
		retroDT := self.opts.timestamp("RetroDT");
	endif;
	
	// Create the Vehicle Visit Record
	self.opts.purge();										//22.02.2024 navhl20 #62525
	self.opts.addAssoc('RetroDT', retroDT);					//22.02.2024 navhl20 #62525
	vVR := addVehicleVisitRecord(_truck, "", driverName, gateName);
	self.assertNoTrxErrorsOrWarnings();
	if vVR = null then
		return null;
	endif;
	
	// Create the Gate Entity containers
	foreach ti in _tiSet do
		gateEntity := self.createGateEntity(vVR, "CONT", ti.id, _isoCode, _operatorCode, _commodity, 1);
	endforeach;
	if expectErrors and  app.myPassport.hasErrors then
		return vVR;
	endif;
	
	// Complete the Gate In - Road job is created
	pxyVVR := app.createUpdateProxy(vVR).CM_VehicleVisitRecord;
	self.ignoreTrxWarnings(true);  // Need to ignore the id check digit warning
	app.myTrxCA.trxCreateInOutFlexiJob(pxyVVR, vVR,null, app.myPassport);
	if expectErrors then
		return vVR;
	endif;
	self.assertNoTrxErrorsOrWarnings();
	self.checkTIsForTxnOfType(vVR.allReceivedTrackedItems, TRANS_TYPE_REC_ROAD);
	return vVR;

epilog
	delete pxyVVR;
end;</source>
        <Parameter name="_truck" type="String"/>
        <Parameter name="_isoCode" type="String"/>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_commodity" type="String"/>
        <Parameter name="_gate" type="Any"/>
        <Parameter name="_tiSet" type="CM_TISet"/>
        <ReturnType type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="gateInPinReceival" id="76eaee1d-057d-4fe5-9113-598214d9a93f">
        <source>gateInPinReceival(_pin: String; _truckReg: String);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 Dec 2011	cnwrd1	Initial creation
06 Jun 2023 navma1  ChangeRequest 58339: EUP | Delivery Dispatch Screen - Road Operation
*/
vars
	pinNo				: CM_PinNo;
	tiArrayObj,
	tiDeleteArray		: CMIF_TIObjectArray;
	ioCommonObj			: CMIF_InOutCommon;
	receivalObj 		: CMIF_Receival;
	item				: Object;
	ti 					: CM_TrackedItem;
	portCode			: String;
	isContainer			: Boolean;
	allStops			: CM_StopsByIdDict;
	wod					: CM_WorkOrderTIDtl;
	bookingRef			: CM_BookingRef;
	bookingRefItem		: CM_BookingRefItem;
	term				: CM_Terminal;
	bookingRefStr		: String;
	tiArray				: CM_TrackedItemArray;
begin
	create tiArray transient;
	term  := self.getMyTerminal;
	pinNo := self.getTerminal().allPinNos[_pin];
	
	assertNotNull(pinNo);
	assertEqual(pinNo.allItems.size, 1);
	item := pinNo.allItems.first;
	
	if item.isKindOf(CM_TrackedItem) then
		assertTrue(item.isKindOf(CM_TrackedItem));
		ti := item.CM_TrackedItem;
		tiArray.add(ti);
	elseif item.isKindOf(CM_WorkOrderTI) then
		wod := item.CM_WorkOrderTI.allWoDtls.first.CM_WorkOrderTIDtl;
		if wod.isKindOf(CM_WodReceive) then
			bookingRef 		:= wod.CM_WodReceive.myBookingRef;
			if bookingRef &lt;&gt; null then
				bookingRefStr  := bookingRef.bookingReference;
				bookingRefItem := bookingRef.allBookingRefItems.first;
				bookingRefItem.allTIs.copy(tiArray);
			endif;
		endif;
	endif;
	
	create tiArrayObj transient;
	create tiDeleteArray transient;
	create ioCommonObj transient;
	foreach ti in tiArray do 
	
	
		ioCommonObj.myTerminal 		:= term;
		ioCommonObj.carrierCode 	:= self.getProfileStr(UT_Profile.P_CARRIER);
		ioCommonObj.regNumber 	    := _truckReg;
		ioCommonObj.myGateEntry 	:= term.getConfig(GateDefaultEntry).CM_Gate;
		ioCommonObj.roadTransAreaId	:= term.getConfig(DefRoadOpsArea).String.trimRight(); 	
		
		if self.opts.includesKey("BatNumber") then
			ioCommonObj.batNumber := self.opts.str("BatNumber");
		endif;
		
		
		isContainer		:=	ti.isContainer();
		
		// Receive a container.
		create receivalObj transient;
		tiArrayObj.add(receivalObj);
		tiDeleteArray.add(receivalObj);			

		receivalObj.setMyPersistentTrackedItem(ti);
		receivalObj.setMyInOutCommon(ioCommonObj);
		receivalObj.myTerminal				:=	term;
		receivalObj.mySubTerminal 			:= ti.mySubTerminal; 
		receivalObj.hasAttachments			:=	ti.hasChildren;
		receivalObj.isFromPrenote			:= 	true;	
		receivalObj.myBookingRefItem		:= bookingRefItem;						//06.06.2023 navma1 #58339
		receivalObj.bookingReference		:= bookingRefStr;						//06.06.2023 navma1 #58339
		receivalObj.ignoreWarnings			:= true;
		receivalObj.myTerminal				:= self.getTerminal;

		foreach portCode in ti.allDischargePorts do
			receivalObj.allDischargePorts.add(portCode);
		endforeach;

		receivalObj.bookingReference				:=	ti.bookingReference;
		receivalObj.cargoType						:=	ti.cargoType;
		
		if isContainer then
			receivalObj.availabilityGrade			:=	ti.CM_Container.availabilityGrade;	// cnwdad1 11/01/2007 - PAR #13256.
			receivalObj.carriageTempC				:=	ti.CM_Container.getTemperature;
			receivalObj.carriageTempF				:=	ti.CM_Container.temperatureInFahrenheit;
			receivalObj.clean						:=	ti.CM_Container.isClean;
			receivalObj.contentsStatus				:=	ti.CM_Container.contentsStatus;
			receivalObj.hasCOU						:=	ti.CM_Container.getCou &lt;&gt; null;
			receivalObj.hasCoolingWaterConnection	:=	ti.CM_Container.getHasCoolingWaterConnection();
			receivalObj.coolingType					:=	ti.CM_Container.getCoolingType;
			receivalObj.isoType						:=	ti.CM_Container.isoType;
			receivalObj.offsiteCleaned				:=	ti.CM_Container.offsiteCleaned;
			receivalObj.offsitePreTrip				:=	ti.CM_Container.offsitePreTrip;
			
			if ti.CM_Container.packedDT &lt;&gt; null
			and ti.CM_Container.getPackTempDetails &lt;&gt; null
			then
				receivalObj.packTempC	:=	ti.CM_Container.getPackTempDetails.tempC;
				receivalObj.packTempF	:=	ti.CM_Container.getPackTempDetails.tempF;
			else
				receivalObj.packTempC	:=	NULL_TEMPERATURE;
			endif;
			
			receivalObj.packTime			:=	ti.CM_Container.packedDT.time;
			receivalObj.preTripped			:=	ti.CM_Container.getPreTripDT &lt;&gt; null;
			receivalObj.reeferRemarks		:=	ti.CM_Container.getReeferRemarks;
			receivalObj.ventilation			:=	ti.CM_Container.getVentilation;
			receivalObj.overHeight			:=	ti.CM_Container.overHeight;
			receivalObj.overLengthFront		:=	ti.CM_Container.overLengthFront;
			receivalObj.overLengthRear		:=	ti.CM_Container.overLengthRear;
			receivalObj.overWidthLeft		:=	ti.CM_Container.overWidthLeft;
			receivalObj.overWidthRight		:=	ti.CM_Container.overWidthRight;
			
			receivalObj.setHumidity( ti.CM_Container.getHumidity );
			receivalObj.setCarbonDioxide( ti.CM_Container.getCarbonDioxide );
			receivalObj.setOxygen( ti.CM_Container.getOxygen );
		else
			receivalObj.carriageTempC		:=	0;
			receivalObj.carriageTempF		:=	0;
			receivalObj.clean				:=	false;
			receivalObj.contentsStatus		:=	0;
			receivalObj.hasCOU				:=	false;
		endif;
		
		receivalObj.commodity				:=	ti.commodity;
		receivalObj.companyCode				:=	ti.companyCode;
		receivalObj.consigneeCode			:=	ti.consignee;
		receivalObj.consignorCode			:=	ti.consignor;
		receivalObj.consignorVoyageCode		:=	ti.consignorVoyageCode;
		receivalObj.freightForwarderCode	:=	ti.freightForwarderCode;	//PAR 23771 15/04/2010
		receivalObj.customExportEntryNumber	:=	ti.customExportEntryNumber;
		receivalObj.damaged					:=	ti.damaged;
		receivalObj.description				:=	ti.description;
		receivalObj.destinationPort			:=	ti.destinationPort;
		receivalObj.dischargePort			:=	ti.dischargePort;
		receivalObj.myTranshipToPort			:=	ti.myTranshipToPort;
		receivalObj.eirNumber				:=	ti.eirNumber;
		receivalObj.createSealsFromTi( ti );
	
		receivalObj.height					:=	ti.height;
		receivalObj.id						:=	ti.id;
		receivalObj.imExStatus				:=	ti.getImExStatusObject();
		receivalObj.inspected				:=	ti.inspectDT &lt;&gt; null;
		receivalObj.length					:=	ti.length;
		receivalObj.loadPort				:=	self.getTerminal.getConfig(PortDestCode).String;
		receivalObj.mark					:=	ti.mark;
		receivalObj.operatorCode			:=	ti.operatorCode;
		
		receivalObj.preSlung				:=	false;
		receivalObj.quantity				:=	ti.quantity;
		receivalObj.receiptTransportMode	:=	TI_TRANSMODE_ROAD;
		receivalObj.remarks					:=	ti.remarks;
		receivalObj.statusString			:=	ti.getStatusCode();
		receivalObj.voyageCode				:=	ti.voyageCode;
		receivalObj.weightTotal				:=	ti.totalWeight;
		receivalObj.wet						:=	false;
		receivalObj.width					:=	ti.width;
		receivalObj.myProduct				:=	ti.myProduct;
		receivalObj.volume					:=  ti.getMyTotalVolume; 
		receivalObj.packDate			    := ti.packDate;
		receivalObj.packTime 			    := ti.packTime;
		receivalObj.packTempC 			    := ti.packTempC.Real;
		receivalObj.packTempF 			    := ti.packTempF.Real;
		
		if ti.myReeferProperties &lt;&gt; null then
			receivalObj.allowableTimeOffPower := ti.myReeferProperties.allowableTimeOffPower;
		endif;

		receivalObj.yardLocationTxt := 'UT_BS';	
		ioCommonObj.autoComplete := true;
	endforeach;
	
	self.ignoreTrxWarnings(true);
	app.myTrxCA.trxCreateInOut(ioCommonObj, tiArrayObj, app.myPassport, null);	//TFS 53107, AjitM, navam1
	self.assertNoTrxErrorsOrWarnings();
	self.checkTIForTxnOfType(ti, TRANS_TYPE_REC_ROAD);					

epilog
	delete tiArrayObj;
	delete ioCommonObj;
	delete allStops;
	delete receivalObj;
	if tiDeleteArray &lt;&gt; null then
		tiDeleteArray.purge();
		delete tiDeleteArray;
	endif;
	delete tiArray;
end;</source>
        <Parameter name="_pin" type="String"/>
        <Parameter name="_truckReg" type="String"/>
    </JadeMethod>
    <JadeMethod name="gateInPrenote" id="bbe3f83a-ceec-4c98-b4b7-44dcac65be9d">
        <source>gateInPrenote(_truck, _state, _driver: String; _ti: Any; _gate: Any): CM_VehicleVisitRecord;
// 03/01/2013 cnwdw1	
// Gate in prenoted cargo 
//
// 06/12/2019		jlgzm1	TFS 47865 STWO Deleting partially received prenotes
// 01/12/2021		navdap1	TFS 52360 SAL Direct Prenote to Voyage Incorrect Job Values
vars
	pxyVVR, vVR: CM_VehicleVisitRecord; 
	pxyGateEntity, gateEntity: CMGTE_Entity;
	gateName: String;
	ti: CM_TrackedItem;
	tiSet : CM_TISet;

begin

	if _gate.isKindOf(String) then
		gateName := _gate.String;
	else
		gateName := _gate.CM_Gate.name;
	endif;
	
	if _ti.isKindOf(String) then
		ti := self.getTrackedItem(_ti.String);
	elseif _ti.isKindOf(CM_TISet) then	//11 Jun 2019	NDL	TFS 42876
		// a set of prenotes
		tiSet := _ti.CM_TISet;
	else
		ti := _ti.CM_TrackedItem;
	endif;

	vVR := addVehicleVisitRecord(_truck, _state, _driver, gateName);

	if tiSet &lt;&gt; null then
		//11 Jun 2019	NDL	TFS 42876
		foreach ti in tiSet do
			create pxyGateEntity as ti.getGTEClassToCreate() transient;
			pxyGateEntity.setPxyFromTI(ti);
			if self.opts.includesKey("Weight") then
				pxyGateEntity.setWeight( self.opts.dec("Weight") );
			endif;
			if self.opts.includesKey("Quantity") then							// TFS 47865
				pxyGateEntity.setTotalQuantity( self.opts.int("Quantity") );	// TFS 47865
			endif;
			self.ignoreTrxWarnings(true);
			app.myTrxCA.trxCreateInOutFlexiGateEntity(vVR, pxyGateEntity, gateEntity, app.myPassport);
			self.assertNoTrxErrorsOrWarnings();
			delete pxyGateEntity;	
		endforeach;
	else
		create pxyGateEntity as ti.getGTEClassToCreate() transient;
		pxyGateEntity.setPxyFromTI(ti);
		if self.opts.includesKey("Weight") then
			pxyGateEntity.setWeight( self.opts.dec("Weight") );
		endif;
		if self.opts.includesKey("TotalWeight") and pxyGateEntity.isKindOf(CMGTE_Receival) then				// TFS 52360
			pxyGateEntity.CMGTE_Receival.setTotalWeightAndCertified( self.opts.dec("TotalWeight"), false );	// TFS 52360
		endif;																								// TFS 52360
		if self.opts.includesKey("CargoWeight") and pxyGateEntity.isKindOf(CMGTE_Receival) then				// TFS 52360
			pxyGateEntity.CMGTE_Receival.setWeightCargo( self.opts.dec("CargoWeight"));						// TFS 52360
		endif;																								// TFS 52360
		if self.opts.includesKey("TareWeight") and pxyGateEntity.isKindOf(CMGTE_Receival) then				// TFS 52360
			pxyGateEntity.CMGTE_Receival.setWeightCargo( self.opts.dec("TareWeight"));						// TFS 52360
		endif;																								// TFS 52360
		if self.opts.includesKey("Quantity") then								// TFS 47865
			pxyGateEntity.setTotalQuantity( self.opts.int("Quantity") );		// TFS 47865
		endif;
		self.ignoreTrxWarnings(true);
		app.myTrxCA.trxCreateInOutFlexiGateEntity(vVR, pxyGateEntity, gateEntity, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		delete pxyVVR;
		delete pxyGateEntity;
	endif;
	
	pxyVVR := app.createUpdateProxy(vVR).CM_VehicleVisitRecord;
	self.ignoreTrxWarnings(true);
	app.myTrxCA.trxCreateInOutFlexiJob(pxyVVR, vVR,null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.checkTIsForTxnOfType(vVR.allReceivedTrackedItems, TRANS_TYPE_REC_ROAD);		// 17/08/2012 cnwmh5
	return vVR;

epilog
	delete pxyVVR;
	delete pxyGateEntity;
end;</source>
        <Parameter name="_truck" type="String"/>
        <Parameter name="_state" type="String"/>
        <Parameter name="_driver" type="String"/>
        <Parameter name="_ti" type="Any"/>
        <Parameter name="_gate" type="Any"/>
        <ReturnType type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="gateInTrailer" id="a863a414-d0fe-4115-860e-18fda062dea4">
        <source>gateInTrailer(_truck, _trailerID: String; _cargoType, _trailerType: String; _operatorCode: String; _gate: Any): CM_VehicleVisitRecord;
//30 July 2009	cnwdw1	
// 05/08/2011	cnwmh5 Change to use UT_UnitTest's opts
// 23 May 2025	navhl20 Bug MTN-34910: MTN - Road Gate Autocomplete is not working
vars
	pxyVVR, vVR: CM_VehicleVisitRecord; 
	controller : CMIF_FlexiGateController;
	pxyAttachment, pxyGateEntity, gateEntity: CMGTE_Entity;
	attachment: String;
	gateName: String;
begin

	if _gate.isKindOf(String) then
		gateName := _gate.String;
	else
		gateName := _gate.CM_Gate.name;
	endif;
	
	// Create the Vehicle Visit Record
	vVR := addVehicleVisitRecord(_truck, "", "", gateName);

	if _trailerID &lt;&gt; null then
		// Create the GTE Entity and add to VVR
		attachment := self.opts.str("Attachment");
		if attachment &lt;&gt; null then
			create controller transient;
			create pxyAttachment as CMGTE_Container transient;
			controller.myTerminal := self.getTerminal();
			if app.myRoot.isAnEmptyCommodity(self.opts.str("Commodity"), false) then
				controller.jobType := CMGTE_Entity.JobType_EmptyIN;   // MT
			else
				controller.jobType := CMGTE_Entity.JobType_FullIN;   // MT
			endif;
			
			controller.id := attachment;
			controller.isoTypeCode := self.opts.str("IsoType");
			controller.operatorCode := _operatorCode;
			controller.commodity := self.opts.str("Commodity");
			controller.weightTotal := 2000;
			controller.carriageTempC := NULL_TEMPERATURE;
			controller.setCarbonDioxide( NULL_CARBON_DIOXIDE );
			controller.setOxygen( NULL_OXYGEN );
			controller.myVehicleVisitRecord := vVR;
			pxyAttachment.setPXYFromController(controller); 
			delete controller;
		endif;
		
		create controller transient;
		create pxyGateEntity as CMGTE_TILC transient;
		controller.myTerminal := self.getTerminal();
		controller.jobType := CMGTE_Entity.JobType_ChassisIN;  
		controller.id := _trailerID;
		controller.cargoType := self.getCargoType(_cargoType).id;
		controller.myChassisType := self.getTrailerType(_trailerType);
		controller.operatorCode := _operatorCode;
		controller.weightTotal := 2000;
		controller.imexStatus := self.opts.int("Imex");											//23.05.2025 navhl20 #34910
		controller.dischargePort := self.opts.str("DishPort");									//23.05.2025 navhl20 #34910
		controller.carriageTempC := NULL_TEMPERATURE;
		controller.setCarbonDioxide( NULL_INTEGER );
		controller.setOxygen( NULL_INTEGER );
		controller.voyageCode := self.opts.str("Voyage");
		controller.yardLocationTxt := self.opts.str("Location");
		
		controller.myBookingRefItem := self.opts.obj("bookingItem").CM_BookingRefItem;
		if controller.myBookingRefItem &lt;&gt; null then
			controller.bookingNumber := controller.myBookingRefItem.myBookingReference.bookingReference;
		endif;
		controller.myVehicleVisitRecord := vVR;
		pxyGateEntity.setPXYFromController(controller); 
		if pxyAttachment &lt;&gt; null then
			pxyAttachment.setParentObject(pxyGateEntity);
		endif;
	endif;
	
	app.myTrxCA.trxCreateInOutFlexiGateEntity(vVR, pxyGateEntity, gateEntity, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	delete pxyVVR;
	delete pxyGateEntity;
	delete controller;
	
	// Complete the Gate In - Road job is created
	pxyVVR := app.createUpdateProxy(vVR).CM_VehicleVisitRecord;
	self.ignoreTrxWarnings(true);  // Need to ignore the id check digit warning
	app.myTrxCA.trxCreateInOutFlexiJob(pxyVVR, vVR,null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.checkTIsForTxnOfType(vVR.allReceivedTrackedItems, TRANS_TYPE_REC_ROAD);					// 17/08/2012 cnwmh5
	return vVR;

epilog
	delete pxyVVR;
	delete pxyGateEntity;
	delete controller;
//	delete pxyAttachment;
end;</source>
        <Parameter name="_truck" type="String"/>
        <Parameter name="_trailerID" type="String"/>
        <Parameter name="_cargoType" type="String"/>
        <Parameter name="_trailerType" type="String"/>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_gate" type="Any"/>
        <ReturnType type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="gateInTrailerAndContainer" id="28e3f651-6eef-47f3-8d28-236696105eb4">
        <source>gateInTrailerAndContainer(	_truck, _trailerID, _containerId: String;
						 _trailerType: String;
						_isoCode: String; _operatorCode: String; _commodity: String; 
						_gate: Any): CM_VehicleVisitRecord;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 July 2013	cnwer1	Initial creation CCMS DPH 2274
10 Mar 2023		jlika1	TFS 56923 - Add width to Trailer
11 May 2023		navdap1	TFS 56801 EUP - EDI Message Type - Transport Status Message Processing
*/

vars
	pxyVVR, vVR: CM_VehicleVisitRecord; 
	gateEntity,gateChassis: CMGTE_Entity;
	gateName: String;
	
	pxyGateChassis : CMGTE_TILC; 
	tmpController	: CMIF_FlexiGateController;
	tt : CM_TILCType;
	
begin

	if _gate.isKindOf(String) then
		gateName := _gate.String;
	else
		gateName := _gate.CM_Gate.name;
	endif;
	
	// Create the Vehicle Visit Record
	vVR := addVehicleVisitRecord(_truck, "", "", gateName);
	self.assertNoTrxErrorsOrWarnings();
	if vVR = null then
		return null;
	endif;
	

	// Create the Gate Entity for first container
// Create the Gate Entity for first container
	if _containerId &lt;&gt; null then
		gateEntity := self.createGateEntity(vVR, "CONT", _containerId, _isoCode, _operatorCode, _commodity, 1);
		self.assertNotNull(gateEntity);
	endif;
	
		// Complete the Gate In - Road job is created
	pxyVVR := app.createUpdateProxy(vVR).CM_VehicleVisitRecord;
	
	tt:=app.myRoot.allTILCTypes[null,_trailerType];
	self.assertNotNull(tt);
	pxyGateChassis := pxyVVR.pxyGetInChassis();
	create tmpController transient;
	tmpController.myTerminal:=self.getTerminal();
	tmpController.jobType 				:= CMGTE_Entity.JobType_ChassisIN;
	tmpController.id 					:= _trailerID;
	
	//21/10/2025	navkc1 JIRA 36056
	if self.opts.includesKey('totalWeight') then
		tmpController.weightTotal := self.opts.int('totalWeight');
	endif;
	
	tmpController.weightTare 			:=tt.tareWeight;	//25 Feb 2014	NDL	Par 33561
	tmpController.width					:=tt.width;			//10/03/2023 jlika1 TFS 56923
	tmpController.myVehicleVisitRecord :=pxyVVR;
	tmpController.operatorCode :=_operatorCode;
	tmpController.myChassisType := tt;
	tmpController.cargoType:=tt.myCargoType.id;
	tmpController.yardLocationTxt := self.opts.str("Location");
	tmpController.remarks := self.createdByUnitTest(null);						// 10/09/2015 cnwmh5
	if self.opts.includesKey("TrailerImexStatus") then						// TFS 56801
		tmpController.imexStatus := self.opts.int("TrailerImexStatus");		// TFS 56801
	endif;																	// TFS 56801
	pxyGateChassis.setPXYFromController(tmpController);

	self.ignoreTrxWarnings(true);  // Need to ignore the id check digit warning
	app.myTrxCA.trxCreateInOutFlexiGateEntity(vVR, pxyGateChassis, gateChassis, app.myPassport);
	self.assertNoTrxErrors();
	
	delete pxyVVR;
	pxyVVR := app.createUpdateProxy(vVR).CM_VehicleVisitRecord;
	
	self.ignoreTrxWarnings(true);  // Need to ignore the id check digit warning
	app.myTrxCA.trxCreateInOutFlexiJob(pxyVVR, vVR,null, app.myPassport);
	self.assertNoTrxErrors();
	self.checkTIsForTxnOfType(vVR.allReceivedTrackedItems, TRANS_TYPE_REC_ROAD);				// 16/08/2012 cnwmh5
	return vVR;

epilog
	delete pxyVVR;
	delete tmpController;
end;</source>
        <Parameter name="_truck" type="String"/>
        <Parameter name="_trailerID" type="String"/>
        <Parameter name="_containerId" type="String"/>
        <Parameter name="_trailerType" type="String"/>
        <Parameter name="_isoCode" type="String"/>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_commodity" type="String"/>
        <Parameter name="_gate" type="Any"/>
        <ReturnType type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="gateOutBulkGate" id="c52adf3d-b64f-4b8f-83ca-bf7378306908">
        <source>gateOutBulkGate( _agent: CM_BulkGateProcessingAgent io; _newScaleWeight : Decimal; _rawScaleWeight : Decimal; _cargoWeight : Decimal);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 November 2016	cnwns1	Initial creation

*/

vars
	expectErrors 	: Boolean;
	pxyVVR 			: CM_VehicleVisitRecord;
	vehicle 		: CM_Vehicle;
	wle 			: CM_WorkListEntry;
	arrAllWarnings 	: HugeStringArray;
	result 			: Integer;
	realVVR : CM_VehicleVisitRecord;
begin
	
	create arrAllWarnings transient;
	
	realVVR := _agent.myRealVVR;
	expectErrors := self.opts.bool("ExpectErrors");
	pxyVVR := app.createUpdateProxy(realVVR).CM_VehicleVisitRecord;
	self.assertNotNullMsg(pxyVVR,"pxyVVR  Is null");
	
	vehicle := realVVR.vehicle;
	self.assertNotNullMsg(vehicle,"vehicle  Is null");
	
	wle :=	vehicle.allRoadJobs.first.workListEntries.first;
	self.assertNotNullMsg(wle,"wle  Is null");
	
	
	while true do
		app.myTrxCA.trxProcessBulkGateOut( _agent, _newScaleWeight, _rawScaleWeight, _cargoWeight, app.myPassport);
        if app.myPassport.trxCompletedOK then
            break;
        else
			if app.myPassport.noErrors  then	
				app.myPassport.warningsAcknowledged     := true;
				continue;
			endif;
			break;
        endif;
        break;
	endwhile;
	
	//21 Nov 2017	NDL	TFS 7820
	if expectErrors and app.myPassport.hasErrors then
		return;
	endif;
	
	
	self.assertNoTrxErrorsOrWarnings();
	
	
	if not realVVR.allReceivedTrackedItems.isEmpty() then										// 16/08/2012 cnwmh5
		self.checkTIsForTxnOfType(realVVR.allReceivedTrackedItems, TRANS_TYPE_REC_ROAD);
	endif;
	if not realVVR.allReleasedTrackedItems.isEmpty() then										// 16/08/2012 cnwmh5
		self.checkTIsForTxnOfType(realVVR.allReleasedTrackedItems, TRANS_TYPE_REL_ROAD);
	endif;
epilog
delete	pxyVVR	;
delete	arrAllWarnings;
end;</source>
        <Parameter name="_agent" type="CM_BulkGateProcessingAgent" usage="io"/>
        <Parameter name="_newScaleWeight" type="Decimal"/>
        <Parameter name="_rawScaleWeight" type="Decimal"/>
        <Parameter name="_cargoWeight" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="gateOutContainer" id="229253a7-c563-4e37-8c46-90af20bc4806">
        <source>gateOutContainer(_truck, _state, _driver: String; _container: CM_Container; _empty: Boolean; _gate: Any; _taId : String): CM_VehicleVisitRecord;
//30 July 2009	cnwdw1	
// 08/02/2010 	cwjre1 terminal area id parameter added for CCMS 1101 MT release handling
// 28 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
//23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
vars
	pxyVVR, vVR: CM_VehicleVisitRecord; 
	controller : CMIF_FlexiGateController;
	pxyGateEntity, gateEntity: CMGTE_Entity;
	release: CM_BulkRelease;
	gateName: String;
	releaseType : Integer;
	bestPick: Boolean;
	customsNumber : String;
	deliveryNumber : String;
	operImportReleasePin : String;
	releaseByType : Boolean;
	clientRef: String;
	reserveDetail: CM_ReserveDetail;
	reserveTI: CM_ReserveTI;
	relRemarks : String;
	subTerminal : CM_SubTerminal;
	expectErrors : Boolean;
	gteRemarks : String;	//01 Sep 2015	NDL	Par 36839
	firstTI	: CM_TrackedItem;
begin
	
	bestPick := self.opts.bool("BestPick");
	expectErrors := self.opts.bool("ExpectErrors");

	if _gate.isKindOf(String) then
		gateName := _gate.String;
	else
		gateName := _gate.CM_Gate.name;
	endif;
	
	//05 Jul 2-21	NDL TFS 51443
	if self.opts.includesKey("VVR") then 
		vVR :=self.opts.obj("VVR").CM_VehicleVisitRecord;
	endif;

	// Create the Vehicle Visit Record
	if vVR = null then
		vVR := addVehicleVisitRecord(_truck, _state, _driver, gateName);
	endif;
	
	// Create the GTE Entity and add to VVR
	create controller transient;
	create pxyGateEntity as CMGTE_Release transient;
	controller.myTerminal := self.getTerminal();
	if _empty then
		controller.jobType := CMGTE_Entity.JobType_EmptyOUT;   // MT
	else
		controller.jobType := CMGTE_Entity.JobType_FullOUT;   // MT
	endif;
	
	controller.numItems := 1;
	
	if _container &lt;&gt; null then
		controller.id := _container.id;
		controller.isoTypeCode := _container.isoType;
		controller.operatorCode := _container.operatorCode;
		controller.consigneeCode	:= _container.consignee;	// par 29480 April 2012
		if self.opts.includesKey("RelRemarks") then    //cnwma1 30/10/2014 PAR #35088
			controller.remarks :=self.opts.str("RelRemarks");
		endif;
		
		controller.customEntryNumber := _container.customsEntryNumber;	//03 July 2015	NDL	Par 36543
		controller.myTrackedItem := _container;	//02 July 2015	NDL	Par 36543
		
	endif;
	controller.cargoType := TI_CargoType_Container;
	controller.myVehicleVisitRecord := vVR;
	controller.yardLocationTxt :=  _taId;
	
	//28/10/2025	navkc1 JIRA 36411
	if self.opts.includesKey("SourceTA") then
		controller.allSourceTAs.add(self.opts.obj("SourceTA").CM_TerminalArea);
	endif;
	
	//28/10/2025	navkc1 JIRA 36411
	if self.opts.includesKey("SourceGrid") then
		controller.allSourceTAGridObjs.add(self.opts.obj("SourceGrid").CM_GridColumn);
	endif;
	
	releaseType := null;
	release := self.opts.obj("release").CM_BulkRelease;
	if release &lt;&gt; null then 
		controller.myBulkRelease := release;
		if _container &lt;&gt; null then
			// Release by Id so try to find a matching reserve TI
			foreach reserveDetail in release.allReserveDetails do
				if reserveDetail.isKindOf(CM_ReserveTI) then
					reserveTI := reserveDetail.CM_ReserveTI;
					firstTI := reserveTI.getFirstTI(false); //23/06/2023	navkc1	CR 58406 Task 58408
					//if reserveTI.allTrackedItems.first &lt;&gt; null and reserveTI.allTrackedItems.first.id = _container.id then
					if firstTI &lt;&gt; null and firstTI.id = _container.id then //23/06/2023	navkc1	CR 58406 Task 58408
						controller.myReserveDetail := reserveDetail;
						break;
					endif;
				endif;
			endforeach;
		endif;
		if controller.myReserveDetail = null then
			controller.myReserveDetail := release.allReserveDetails.first;
		endif;
		controller.deliveryReason	:= release.deliveryReasonDescr;	// cnwcs5 June2012
		
		if controller.myReserveDetail &lt;&gt; null then
			controller.isoTypeCode := controller.myReserveDetail.getISOTypeCode;
			controller.isoGroup := controller.myReserveDetail.getISOGroupCode;
			controller.operatorCode := controller.myReserveDetail.getOperatorCode;
			if release.myVoyage &lt;&gt; null then
				controller.voyageCode := release.myVoyage.code;
			endif;
			if controller.myReserveDetail.isKindOf(CM_ReserveSelection) then
				controller.myReserveDetail.CM_ReserveSelection.allTerminalAreas.copy(controller.allSourceTAs);
				controller.billOfLading := controller.myReserveDetail.getBOLNumber;
			endif;
			if not opts.includesKey("BestPick") then
				bestPick := controller.myReserveDetail.bestPick;
			endif;
		endif;
		
		controller.mtOnly := not release.fullRelease;
		if controller.mtOnly then
			controller.commodity := "MT";
		endif;
		releaseType := release.type;
		releaseByType := release.releaseByType;
	endif;
	
	//28/10/2025	navkc1 JIRA 36411
	if self.opts.includesKey("ReleaseByType") then
		releaseByType := self.opts.bool("ReleaseByType");
	endif;
	
	//28/10/2025	navkc1 JIRA 36411
	if controller.isoTypeCode = null and self.opts.includesKey("ISOType") then
		controller.isoTypeCode := self.opts.str("ISOType");
	endif;
	
	//28/10/2025	navkc1 JIRA 36411
	if controller.operatorCode = null and self.opts.includesKey("OperatorCode") then
		controller.operatorCode := self.opts.str("OperatorCode");
	endif;
	
	if app.isSubTerminalsOn(self.getTerminal) then
		subTerminal := self.getTerminal.getDefaultSubTerminal(	CM_SubTerminal.Type_BulkRelease,
																				releaseType,	// cnwdad1 27/01/2010 - PAR #22205.
																				0,
																				null,
																				false);
		if subTerminal &lt;&gt; null then
			controller.subTerminalCode := subTerminal.code;
		endif;
	endif;

	pxyGateEntity.setPXYFromController(controller); 
	if _container &lt;&gt; null or not releaseByType then
		pxyGateEntity.CMGTE_Release.setIsReleaseById(true);
	else
		pxyGateEntity.CMGTE_Release.setIsReleaseById(false);
	endif;
	pxyGateEntity.CMGTE_Release.setBestPick(bestPick);
	
	//+cnwml2 PAR25757
	customsNumber := self.opts.str("customsNumber");
	if customsNumber &lt;&gt; null then
		pxyGateEntity.CMGTE_Release.setCustomsEntryNumber(customsNumber);
	endif;
	
	//+cnwml2 PAR25757
	deliveryNumber:= self.opts.str("deliveryNumber");
	if deliveryNumber &lt;&gt; null then
		pxyGateEntity.CMGTE_Release.setDeliveryNumber(deliveryNumber);
	endif;
	
	// cnwrl1 07/10/2010 PAR 25958 - start of coding
	operImportReleasePin	:= self.opts.str("operImportReleasePin");
	if operImportReleasePin &lt;&gt; null then
		pxyGateEntity.CMGTE_Release.setImportReleasePIN( operImportReleasePin );
	endif;
	// cnwrl1 07/10/2010 PAR 25958 - end of coding

	clientRef	:= self.opts.str("clientRef");
	if clientRef &lt;&gt; null then
		pxyGateEntity.setClientRef( clientRef );
	endif;
	
	//01 Sep 2015	NDL	Par 36839
	gteRemarks := self.opts.str("GTERemarks");
	if gteRemarks &lt;&gt; null then
		pxyGateEntity.CMGTE_Release.setRemarks( gteRemarks );
	endif;
	
	self.ignoreTrxWarnings(true);
	app.myTrxCA.trxCreateInOutFlexiGateEntity(vVR, pxyGateEntity, gateEntity, app.myPassport);
	if not expectErrors then
		self.assertNoTrxErrorsOrWarnings();
	endif;
	delete pxyVVR;
	delete pxyGateEntity;
	delete controller;
	
	if self.opts.bool("completeAfter") then
		return vVR;
	endif;
	
	if not app.myPassport.hasErrors then
		return self.completeGateOutContainer(vVR);
	else
		return null;
	endif;
epilog
	delete pxyVVR;
	delete pxyGateEntity;
	delete controller;
end;</source>
        <Parameter name="_truck" type="String"/>
        <Parameter name="_state" type="String"/>
        <Parameter name="_driver" type="String"/>
        <Parameter name="_container" type="CM_Container"/>
        <Parameter name="_empty" type="Boolean"/>
        <Parameter name="_gate" type="Any"/>
        <Parameter name="_taId" type="String"/>
        <ReturnType type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="gateOutGC" id="cd2e81e7-51bd-4858-83e1-b28c04fcbd75">
        <source>gateOutGC(_truck, _state, _driver: String; _cargo: CM_TrackedItem; _gate: Any; _taId : String): CM_VehicleVisitRecord;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 May 2013	cnwrd1	Initial creation
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

vars
	pxyVVR, vVR: CM_VehicleVisitRecord; 
	controller : CMIF_FlexiGateController;
	pxyGateEntity, gateEntity: CMGTE_Entity;
	release: CM_BulkRelease;
	gateName: String;
	releaseType : Integer;
	bestPick: Boolean;
	customsNumber : String;
	deliveryNumber : String;
	operImportReleasePin : String;
	releaseByType : Boolean;
	subTerm : CM_SubTerminal;
	ti : CM_TrackedItem;
	gateOutCargoId : String;
	reserveDetail : CM_ReserveDetail;
	consigneeCode: String;
	makeByType, anyAmt, anyId : Boolean;
	allTis		: CM_TISet;
	cargotype : CM_CargoType;
begin
	
	if _gate.isKindOf(String) then
		gateName := _gate.String;
	else
		gateName := _gate.CM_Gate.name;
	endif;
	
	create allTis transient;  //23/06/2023	navkc1	CR 58406 Task 58408

	// Create the Vehicle Visit Record
	vVR := addVehicleVisitRecord(_truck, _state, _driver, gateName);
	
	// Create the GTE Entity and add to VVR
	create controller transient;
	create pxyGateEntity as CMGTE_Release transient;
	controller.myTerminal := self.getTerminal();
	controller.jobType := CMGTE_Entity.JobType_GeneralOUT; 
	controller.numItems := 1;
	
	if self.opts.includesKey("MakeByType") then
		makeByType :=  self.opts.bool('MakeByType');
		releaseByType := makeByType;
	endif;
	
	if _cargo &lt;&gt; null then
		if not makeByType then
			controller.id := _cargo.id;
			controller.myTrackedItem := _cargo;
		endif;
		controller.operatorCode := _cargo.operatorCode;
		if self.opts.includesKey('TotalRequested') and _cargo.isKindOf(CM_BreakBulkGeneric) then
			controller.numItems :=  self.opts.int('TotalRequested');
		endif;
		
		// ### TFS CR 60922 TASK 60980 09NOV2023 NAVAB1
		if self.opts.includesKey('WeightRequested') and _cargo.isKindOf(CM_Bulk) then
			controller.weight :=  self.opts.dec('WeightRequested');
		endif;
		if self.opts.includesKey('TotalWeight') and _cargo.isKindOf(CM_Bulk) then
			controller.weightTotal :=  self.opts.dec('TotalWeight');
		endif;
		controller.cargoType := _cargo.cargoType;

	endif;
	
	controller.myVehicleVisitRecord := vVR;
	controller.yardLocationTxt :=  _taId;
	
	if self.opts.includesKey("consigneeCode") then    // cnwmk3 11/03/2016 for UT_Gate: tUpdateConsignee
	consigneeCode := self.opts.str("consigneeCode");
	controller.consigneeCode := consigneeCode;
	else
	consigneeCode:= null;
	endif;
	
	// 12/05/2015 cnwmh5
	if self.opts.includesKey("ReleaseRequest") then
		if self.opts.obj("ReleaseRequest") = null then
			release := self.addReleaseById(_cargo.id, BR_TYPE_ROAD, _cargo);
		else
			release := self.opts.obj("ReleaseRequest").CM_BulkRelease;
		endif;
		
		controller.myBulkRelease := release;
		gateOutCargoId := self.opts.str("GateOutCargoId");
		if gateOutCargoId = null then
			controller.myReserveDetail := release.allReserveDetails.first;
			
			// ### TFS CR 60922 TASK 60980 30OCT2023 NAVAB1
			cargotype := controller.myReserveDetail.getMyCargoType();
			controller.cargoType := cargotype.id;
			
		else
			foreach reserveDetail in release.allReserveDetails do : reserveDetailFound
				//23/06/2023	navkc1	CR 58406 Task 58408
				reserveDetail.getAllTrackedItems(allTis, false);
				
				//foreach ti in reserveDetail.allTrackedItems do
				foreach ti in allTis do //23/06/2023	navkc1	CR 58406 Task 58408
					if ti.id = gateOutCargoId then
						break reserveDetailFound;
					endif;
				endforeach;
			endforeach;
			self.assertNotNull(reserveDetail);
			controller.myReserveDetail := reserveDetail;
			controller.cargoType := ti.cargoType;
			controller.id := ti.id;
			controller.myTrackedItem := ti;
			controller.operatorCode := ti.operatorCode;
		endif;
		controller.deliveryReason	:= release.deliveryReasonDescr;	// cnwcs5 June2012
		
		if controller.myReserveDetail &lt;&gt; null then
			controller.operatorCode := controller.myReserveDetail.getOperatorCode;
			if release.myVoyage &lt;&gt; null then
				controller.voyageCode := release.myVoyage.code;
			endif;
			if controller.myReserveDetail.isKindOf(CM_ReserveSelection) then
				controller.myReserveDetail.CM_ReserveSelection.allTerminalAreas.copy(controller.allSourceTAs);
				controller.billOfLading := controller.myReserveDetail.getBOLNumber;
			endif;
		endif;
		controller.mtOnly := not release.fullRelease;
		releaseType := release.type;
		releaseByType := release.releaseByType;
	endif;
	
	/*
	if self.opts.bool("addRelease") then
		release := self.addReleaseById(_cargo.id, BR_TYPE_ROAD, _cargo);
		
		controller.myBulkRelease := release;
		controller.myReserveDetail := release.allReserveDetails.first;
		controller.deliveryReason	:= release.deliveryReasonDescr;	// cnwcs5 June2012
		
		if controller.myReserveDetail &lt;&gt; null then
			controller.operatorCode := controller.myReserveDetail.getOperatorCode;
			if release.myVoyage &lt;&gt; null then
				controller.voyageCode := release.myVoyage.code;
			endif;
			if controller.myReserveDetail.isKindOf(CM_ReserveSelection) then
				controller.myReserveDetail.CM_ReserveSelection.allTerminalAreas.copy(controller.allSourceTAs);
				controller.billOfLading := controller.myReserveDetail.getBOLNumber;
			endif;
		endif;
		controller.mtOnly := not release.fullRelease;
		releaseType := release.type;
		releaseByType := release.releaseByType;
	endif;
	*/
	
	if app.isSubTerminalsOn(self.getTerminal) then
		subTerm :=  self.getTerminal.getDefaultSubTerminal(	CM_SubTerminal.Type_BulkRelease,
															releaseType,	// cnwdad1 27/01/2010 - PAR #22205.
															0,
															null,
															false);
		if subTerm &lt;&gt; null then
			controller.subTerminalCode := subTerm.code;
		endif;
	endif;

	// ### TFS CR 60922 TASK 60980 09NOV2023 NAVAB1
	if self.opts.includesKey("AnyAmt") then
		anyAmt := self.opts.bool("AnyId");
		if anyAmt
		and self.opts.includesKey('WeightRequested') then
			controller.weight :=  self.opts.dec('WeightRequested');
		endif;
	endif;

	pxyGateEntity.setPXYFromController(controller); 
	if makeByType then
		pxyGateEntity.CMGTE_Release.setIsReleaseById(false);
	elseif _cargo &lt;&gt; null or not releaseByType then
		pxyGateEntity.CMGTE_Release.setIsReleaseById(true);
	else
		pxyGateEntity.CMGTE_Release.setIsReleaseById(false);
	endif;
	pxyGateEntity.CMGTE_Release.setBestPick(false);
	
	//+cnwml2 PAR25757
	customsNumber := self.opts.str("customsNumber");
	if customsNumber &lt;&gt; null then
		pxyGateEntity.CMGTE_Release.setCustomsEntryNumber(customsNumber);
	endif;

	// ### TFS CR 60922 TASK 60980 30OCT2023 NAVAB1
	if self.opts.includesKey("AnyId") then
		anyId := self.opts.bool("AnyId");
		pxyGateEntity.CMGTE_Release.setIsAnyId(anyId);
	endif;
	if self.opts.includesKey("AnyAmt") then
		anyAmt := self.opts.bool("AnyAmt");
		pxyGateEntity.CMGTE_Release.setIsAnyAmount(anyAmt);
	endif;
	
	
	//+cnwml2 PAR25757
	deliveryNumber:= self.opts.str("deliveryNumber");
	if deliveryNumber &lt;&gt; null then
		pxyGateEntity.CMGTE_Release.setDeliveryNumber(deliveryNumber);
	endif;
	
	// cnwrl1 07/10/2010 PAR 25958 - start of coding
	operImportReleasePin	:= self.opts.str("operImportReleasePin");
	if operImportReleasePin &lt;&gt; null then
		pxyGateEntity.CMGTE_Release.setImportReleasePIN( operImportReleasePin );
	endif;
	// cnwrl1 07/10/2010 PAR 25958 - end of coding
	
	self.ignoreTrxWarnings(true);
	app.myTrxCA.trxCreateInOutFlexiGateEntity(vVR, pxyGateEntity, gateEntity, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	delete pxyVVR;
	delete pxyGateEntity;
	delete controller;
	
	// Complete the Gate In - Road job is created
	pxyVVR := app.createUpdateProxy(vVR).CM_VehicleVisitRecord;
	self.ignoreTrxWarnings(true);
	app.myTrxCA.trxCreateInOutFlexiJob(pxyVVR, vVR, null,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	return vVR;
epilog
	delete pxyVVR;
	delete pxyGateEntity;
	delete controller;
	delete allTis;
end;</source>
        <Parameter name="_truck" type="String"/>
        <Parameter name="_state" type="String"/>
        <Parameter name="_driver" type="String"/>
        <Parameter name="_cargo" type="CM_TrackedItem"/>
        <Parameter name="_gate" type="Any"/>
        <Parameter name="_taId" type="String"/>
        <ReturnType type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="gateOutGenerator" id="ef1fa6e7-f7ed-4499-b882-0fdc2756c094">
        <source>gateOutGenerator(_truck, _state, _driver: String; _generator: CM_Generator; _empty: Boolean; _gate: Any; _taId : String): CM_VehicleVisitRecord;
// cnwrs1
//
// 19 May 2017	cnwrs1	TFS 4259 _ Penn Seaboard implimentation
//23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
//
vars
	pxyVVR, vVR: CM_VehicleVisitRecord; 
	controller : CMIF_FlexiGateController;
	pxyGateEntity, gateEntity: CMGTE_Entity;
	release: CM_BulkRelease;
	gateName: String;
	releaseType : Integer;
	bestPick: Boolean;
	customsNumber : String;
	deliveryNumber : String;
	operImportReleasePin : String;
	releaseByType : Boolean;
	clientRef: String;
	reserveDetail: CM_ReserveDetail;
	reserveTI: CM_ReserveTI;
	relRemarks : String;
	subTerminal : CM_SubTerminal;
	expectErrors : Boolean;
	gteRemarks : String;	//01 Sep 2015	NDL	Par 36839
	firstTi	: CM_TrackedItem;
begin
	
	bestPick := self.opts.bool("BestPick");
	expectErrors := self.opts.bool("ExpectErrors");

	if _gate.isKindOf(String) then
		gateName := _gate.String;
	else
		gateName := _gate.CM_Gate.name;
	endif;


	// Create the Vehicle Visit Record
	vVR := addVehicleVisitRecord(_truck, _state, _driver, gateName);
	
	// Create the GTE Entity and add to VVR
	create controller transient;
	create pxyGateEntity as CMGTE_Release transient;
	controller.myTerminal := self.getTerminal();
	if _empty then
		controller.jobType := CMGTE_Entity.JobType_EmptyOUT;   // MT
	else
		controller.jobType := CMGTE_Entity.JobType_FullOUT;   // MT
	endif;
	
	controller.numItems := 1;
	
	if _generator &lt;&gt; null then
		controller.id := _generator.id;
//		controller.isoTypeCode := _container.isoType;
		controller.operatorCode := _generator.operatorCode;
		controller.consigneeCode	:= _generator.consignee;	// par 29480 April 2012
		if self.opts.includesKey("RelRemarks") then    //cnwma1 30/10/2014 PAR #35088
			controller.remarks :=self.opts.str("RelRemarks");
		endif;
		
		controller.customEntryNumber := _generator.customsEntryNumber;	//03 July 2015	NDL	Par 36543
		controller.myTrackedItem := _generator;	//02 July 2015	NDL	Par 36543
		
	endif;
	controller.cargoType := TI_CargoType_Generator;
	controller.myVehicleVisitRecord := vVR;
	controller.yardLocationTxt :=  _taId;
	releaseType := null;
	release := self.opts.obj("release").CM_BulkRelease;
	if release &lt;&gt; null then 
		controller.myBulkRelease := release;
		if _generator &lt;&gt; null then
			// Release by Id so try to find a matching reserve TI
			foreach reserveDetail in release.allReserveDetails do
				if reserveDetail.isKindOf(CM_ReserveTI) then
					reserveTI := reserveDetail.CM_ReserveTI;
					firstTi := reserveTI.getFirstTI(false); //23/06/2023	navkc1	CR 58406 Task 58408
					//if reserveTI.allTrackedItems.first &lt;&gt; null and reserveTI.allTrackedItems.first.id = _generator.id then
					if firstTi &lt;&gt; null and firstTi.id = _generator.id then
						controller.myReserveDetail := reserveDetail;
						break;
					endif;
				endif;
			endforeach;
		endif;
		if controller.myReserveDetail = null then
			controller.myReserveDetail := release.allReserveDetails.first;
		endif;
		controller.deliveryReason	:= release.deliveryReasonDescr;	// cnwcs5 June2012
		
		if controller.myReserveDetail &lt;&gt; null then
			controller.isoTypeCode := controller.myReserveDetail.getISOTypeCode;
			controller.isoGroup := controller.myReserveDetail.getISOGroupCode;
			controller.operatorCode := controller.myReserveDetail.getOperatorCode;
			if release.myVoyage &lt;&gt; null then
				controller.voyageCode := release.myVoyage.code;
			endif;
			if controller.myReserveDetail.isKindOf(CM_ReserveSelection) then
				controller.myReserveDetail.CM_ReserveSelection.allTerminalAreas.copy(controller.allSourceTAs);
				controller.billOfLading := controller.myReserveDetail.getBOLNumber;
			endif;
			if not opts.includesKey("BestPick") then
				bestPick := controller.myReserveDetail.bestPick;
			endif;
		endif;
		
		controller.mtOnly := not release.fullRelease;
		if controller.mtOnly then
			controller.commodity := "MT";
		endif;
		releaseType := release.type;
		releaseByType := release.releaseByType;
	endif;
	
	if app.isSubTerminalsOn(self.getTerminal) then
		subTerminal := self.getTerminal.getDefaultSubTerminal(	CM_SubTerminal.Type_BulkRelease,
																				releaseType,	// cnwdad1 27/01/2010 - PAR #22205.
																				0,
																				null,
																				false);
		if subTerminal &lt;&gt; null then
			controller.subTerminalCode := subTerminal.code;
		endif;
	endif;

	pxyGateEntity.setPXYFromController(controller); 
	if _generator &lt;&gt; null or not releaseByType then
		pxyGateEntity.CMGTE_Release.setIsReleaseById(true);
	else
		pxyGateEntity.CMGTE_Release.setIsReleaseById(false);
	endif;
	pxyGateEntity.CMGTE_Release.setBestPick(bestPick);
	
	//+cnwml2 PAR25757
	customsNumber := self.opts.str("customsNumber");
	if customsNumber &lt;&gt; null then
		pxyGateEntity.CMGTE_Release.setCustomsEntryNumber(customsNumber);
	endif;
	
	//+cnwml2 PAR25757
	deliveryNumber:= self.opts.str("deliveryNumber");
	if deliveryNumber &lt;&gt; null then
		pxyGateEntity.CMGTE_Release.setDeliveryNumber(deliveryNumber);
	endif;
	
	// cnwrl1 07/10/2010 PAR 25958 - start of coding
	operImportReleasePin	:= self.opts.str("operImportReleasePin");
	if operImportReleasePin &lt;&gt; null then
		pxyGateEntity.CMGTE_Release.setImportReleasePIN( operImportReleasePin );
	endif;
	// cnwrl1 07/10/2010 PAR 25958 - end of coding

	clientRef	:= self.opts.str("clientRef");
	if clientRef &lt;&gt; null then
		pxyGateEntity.setClientRef( clientRef );
	endif;
	
	//01 Sep 2015	NDL	Par 36839
	gteRemarks := self.opts.str("GTERemarks");
	if gteRemarks &lt;&gt; null then
		pxyGateEntity.CMGTE_Release.setRemarks( gteRemarks );
	endif;
	
	self.ignoreTrxWarnings(true);
	app.myTrxCA.trxCreateInOutFlexiGateEntity(vVR, pxyGateEntity, gateEntity, app.myPassport);
	if not expectErrors then
		self.assertNoTrxErrorsOrWarnings();
	endif;
	delete pxyVVR;
	delete pxyGateEntity;
	delete controller;
	
	if self.opts.bool("completeAfter") then
		return vVR;
	endif;
	
	return self.completeGateOutContainer(vVR);

epilog
	delete pxyVVR;
	delete pxyGateEntity;
	delete controller;
end;</source>
        <Parameter name="_truck" type="String"/>
        <Parameter name="_state" type="String"/>
        <Parameter name="_driver" type="String"/>
        <Parameter name="_generator" type="CM_Generator"/>
        <Parameter name="_empty" type="Boolean"/>
        <Parameter name="_gate" type="Any"/>
        <Parameter name="_taId" type="String"/>
        <ReturnType type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="gateOutPinRelease" id="448ed65c-ed90-4332-b587-06a94770cdc4">
        <source>gateOutPinRelease(_pin: String; _truckReg: String);
//29 December 2008	cnwdw1	
//
//17 jun 2015	cnwrs1	add all reserveSelections
//12 Jan 2023 navhl20 Bug 62026: MTN - Unit test case missing for release road
vars
	pinNo: CM_PinNo;
	outObjects : CMIF_TIObjectArray;
	inOutCommon: CMIF_InOutCommon;
	releaseByType: CMIF_ReleaseByType;
	item: Object;
	release: CM_BulkRelease;
	releaseById	: CMIF_ReleaseById;
	reserveDetail : CM_ReserveDetail;
	anyIdAnyAmount : Boolean;
	wod	: CM_WorkOrderTIDtl;
begin
	pinNo := self.getTerminal().allPinNos[_pin];
	assertNotNull(pinNo);
	assertEqual(pinNo.allItems.size, 1);
	item := pinNo.allItems.first;
	
	if item.isKindOf(CM_BulkRelease) then								//12.01.2023 navhl20 #62026
		self.assertTrue(item.isKindOf(CM_BulkRelease));
		release := item.CM_BulkRelease;
	elseif item.isKindOf(CM_WorkOrderTI) then
		wod := item.CM_WorkOrderTI.allWoDtls.first.CM_WorkOrderTIDtl;
		if wod.isKindOf(CM_WodRelease) then
			release := wod.CM_WodRelease.myReleaseRequest;
		endif;
	endif;
	
	create outObjects transient;
	create inOutCommon transient;
	inOutCommon.myTerminal := self.getTerminal();
	inOutCommon.carrierCode := release.carrierId;
	inOutCommon.regNumber := _truckReg;
	inOutCommon.myGateEntry := self.getTerminal.getConfig(GateDefaultEntry).CM_Gate;
	
	if self.opts.includesKey("BatNumber") then
		inOutCommon.batNumber := self.opts.str("BatNumber");
	endif;
	if self.opts.includesKey("AnyAmtAnyId") then
		anyIdAnyAmount := self.opts.bool("AnyAmtAnyId");
	endif;
	
	if not release.allReserveDetails.isEmpty then
		if release.allReserveDetails.first.isKindOf(CM_ReserveSelection) then
			create releaseByType transient;
			releaseByType.setFromBulkRelease(release, release.allReserveDetails.first.CM_ReserveSelection);
			releaseByType.myTerminal := self.getTerminal();
			releaseByType.setMyInOutCommon(inOutCommon);
			releaseByType.quantity := release.allReserveDetails.first.CM_ReserveSelection.totalRequested;		//12.01.2023 navhl20 #62026
			releaseByType.mySubTerminal := self.getTerminal().getDefaultSubTerminalForRel(release.type);
			outObjects.add(releaseByType);
		elseif release.allReserveDetails.first.isKindOf(CM_ReserveTI) then
			foreach reserveDetail in release.allReserveDetails do
				if anyIdAnyAmount then
					create releaseById transient;
					releaseById.setForAAAI( release );
					releaseById.myTerminal := self.getTerminal();
					releaseById.setMyInOutCommon(inOutCommon);
					releaseById.mySubTerminal := self.getTerminal().getDefaultSubTerminalForRel(release.type);
					outObjects.add(releaseById);
				else
					create releaseById transient;
					releaseById.setFromBulkRelease(release, reserveDetail.CM_ReserveTI);
					releaseById.myTerminal := self.getTerminal();
					releaseById.setMyInOutCommon(inOutCommon);
					releaseById.mySubTerminal := self.getTerminal().getDefaultSubTerminalForRel(release.type);
					outObjects.add(releaseById);
				endif;
			endforeach;
		endif;
	endif;
	
	self.ignoreTrxWarnings(true);
	app.myTrxCA.trxCreateInOut(inOutCommon, outObjects, app.myPassport, null);	//TFS 53107, AjitM, navam1
	self.assertNoTrxErrorsOrWarnings();

epilog
	if outObjects &lt;&gt; null then
		outObjects.purge;
	endif;
	delete outObjects;
	delete inOutCommon;
//	delete releaseByType;
//	delete releaseById;
end;</source>
        <Parameter name="_pin" type="String"/>
        <Parameter name="_truckReg" type="String"/>
    </JadeMethod>
    <JadeMethod name="gateOutTrailerAndContainer" id="b3a7c4ed-2dd4-48e0-b5ad-38e04aa8e664">
        <source>gateOutTrailerAndContainer(_truck : String;
							_trailer : CM_TILC;
							 _container : CM_Container;
						_gate: Any; _vVR: CM_VehicleVisitRecord): CM_VehicleVisitRecord;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 July 2013	cnwer1	Initial creation CCMS DPH 2274
24 May 2017		cnwrs1	TFS 4259 _ Penn Seaboard implimentation
10 Mar 2023		jlika1	TFS 56923 - Add width to Trailer
*/


vars
pxyVVR, vVR: CM_VehicleVisitRecord; 
	pxyGateEntity,gateEntity,gateChassis: CMGTE_Entity;
	gateName: String;
	
	pxyGateChassis : CMGTE_Release; 
	tmpController	: CMIF_FlexiGateController;
	tt : CM_TILCType;
begin

	if _gate.isKindOf(String) then
		gateName := _gate.String;
	else
		gateName := _gate.CM_Gate.name;
	endif;
	
	// Create the Vehicle Visit Record
	if _vVR = null then
		vVR := addVehicleVisitRecord(_truck, "", "", gateName);
		self.assertNoTrxErrorsOrWarnings();
	else
		vVR := _vVR;
	endif;
	if vVR = null then
		return null;
	endif;
	
	create tmpController transient;
	// Create the Gate Entity for first container
	if _container &lt;&gt; null then
		
			create pxyGateEntity as CMGTE_Release transient;
			tmpController.myTerminal := self.getTerminal();
			if _container.isEmpty then
				tmpController.jobType := CMGTE_Entity.JobType_EmptyOUT;
			else
				tmpController.jobType := CMGTE_Entity.JobType_FullOUT; 
			endif;
			
			tmpController.numItems := 1;
	
			
			tmpController.id := _container.id;
			tmpController.isoTypeCode := _container.isoType;
			tmpController.operatorCode := _container.operatorCode;
			tmpController.consigneeCode	:= _container.consignee;	// par 29480 April 2012
		
			tmpController.cargoType := TI_CargoType_Container;
			tmpController.myVehicleVisitRecord := vVR;
			
			pxyGateEntity.setPXYFromController(tmpController); 
			pxyGateEntity.CMGTE_Release.setIsReleaseById(true);
			
			self.ignoreTrxWarnings(true);
			app.myTrxCA.trxCreateInOutFlexiGateEntity(vVR, pxyGateEntity, gateEntity, app.myPassport);
			self.assertNoTrxErrorsOrWarnings();
			self.assertNotNull(gateEntity);
			app.myProxyManager.clearAllProxies();
	endif;

	self.assertNotNull(_trailer);
		// Complete the Gate In - Road job is created
	pxyVVR := app.createUpdateProxy(vVR).CM_VehicleVisitRecord;
		
	pxyGateChassis := pxyVVR.pxyGetOutChassis();
	pxyGateChassis.setIsReleaseById(true);
	delete tmpController;
	create tmpController transient;
	tmpController.myTerminal:=self.getTerminal();
	tmpController.jobType 				:= CMGTE_Entity.JobType_ChassisOut;
	tmpController.id 					:= _trailer.id;
	tmpController.weightTotal 			:=_trailer.getTareWeight;
	tmpController.myVehicleVisitRecord :=pxyVVR;
	tmpController.operatorCode :=_trailer.operatorCode;
	tmpController.myChassisType := _trailer.myTILCType;
	tmpController.cargoType:=_trailer.myCargoType.id;
	tmpController.width:=_trailer.width;
	pxyGateChassis.setPXYFromController(tmpController);

	self.ignoreTrxWarnings(true);  // Need to ignore the id check digit warning
	app.myTrxCA.trxCreateInOutFlexiGateEntity(vVR, pxyGateChassis, gateChassis, app.myPassport);
	self.assertNoTrxErrors();
	
	delete pxyVVR;
	app.myProxyManager.clearAllProxies();
	pxyVVR := app.createUpdateProxy(vVR).CM_VehicleVisitRecord;
	
	self.ignoreTrxWarnings(true);  // Need to ignore the id check digit warning
	app.myTrxCA.trxCreateInOutFlexiJob(pxyVVR, vVR,null, app.myPassport);
	self.assertNoTrxErrors();
	app.myProxyManager.clearAllProxies();
	self.checkTIsForTxnOfType(vVR.allReceivedTrackedItems, TRANS_TYPE_REC_ROAD);				// 16/08/2012 cnwmh5
	return vVR;

epilog
	delete pxyVVR;
	delete tmpController;
	delete pxyGateEntity;
end;</source>
        <Parameter name="_truck" type="String"/>
        <Parameter name="_trailer" type="CM_TILC"/>
        <Parameter name="_container" type="CM_Container"/>
        <Parameter name="_gate" type="Any"/>
        <Parameter name="_vVR" type="CM_VehicleVisitRecord"/>
        <ReturnType type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="gateOutTrailerByTypeAndCont" id="6abe45c7-2df3-451b-bf14-893ddaa3bec3">
        <source>gateOutTrailerByTypeAndCont(_truck : String;
							_trailerType : CM_TILCType;
							_trailerOperator	: String;
							 _container : CM_Container;
							_gate: Any): CM_VehicleVisitRecord;
/*

Date		Who		Reason
17 March 2014	cnwer1	Initial creation PAR

*/

vars
pxyVVR, vVR: CM_VehicleVisitRecord; 
	pxyGateEntity,gateEntity,gateChassis: CMGTE_Entity;
	gateName: String;
	
	pxyGateChassis : CMGTE_Release; 
	tmpController	: CMIF_FlexiGateController;
	tt : CM_TILCType;
begin

	if _gate.isKindOf(String) then
		gateName := _gate.String;
	else
		gateName := _gate.CM_Gate.name;
	endif;
	
	// Create the Vehicle Visit Record
	vVR := addVehicleVisitRecord(_truck, "", "", gateName);
	self.assertNoTrxErrorsOrWarnings();
	if vVR = null then
		return null;
	endif;
	
	create tmpController transient;
	// Create the Gate Entity for first container
	if _container &lt;&gt; null then
		
			create pxyGateEntity as CMGTE_Release transient;
			tmpController.myTerminal := self.getTerminal();
			if _container.isEmpty then
				tmpController.jobType := CMGTE_Entity.JobType_EmptyOUT;
			else
				tmpController.jobType := CMGTE_Entity.JobType_FullOUT; 
			endif;
			
			tmpController.numItems := 1;
	
			
			tmpController.id := _container.id;
			tmpController.isoTypeCode := _container.isoType;
			tmpController.operatorCode := _container.operatorCode;
				tmpController.consigneeCode	:= _container.consignee;	// par 29480 April 2012
		
			tmpController.cargoType := TI_CargoType_Container;
			tmpController.myVehicleVisitRecord := vVR;
			
			pxyGateEntity.setPXYFromController(tmpController); 
			pxyGateEntity.CMGTE_Release.setIsReleaseById(true);
			
			self.ignoreTrxWarnings(true);
			app.myTrxCA.trxCreateInOutFlexiGateEntity(vVR, pxyGateEntity, gateEntity, app.myPassport);
			self.assertNoTrxErrorsOrWarnings();
			self.assertNotNull(gateEntity);
	
	endif;
	
	

	self.assertNotNull(_trailerType);
		// Complete the Gate In - Road job is created
	pxyVVR := app.createUpdateProxy(vVR).CM_VehicleVisitRecord;
	

	pxyGateChassis := pxyVVR.pxyGetOutChassis();
	pxyGateChassis.setIsReleaseById(false);
	delete tmpController;
	create tmpController transient;
	tmpController.myTerminal:=self.getTerminal();
	tmpController.jobType 				:= CMGTE_Entity.JobType_ChassisOut;
	tmpController.myVehicleVisitRecord :=pxyVVR;
	tmpController.operatorCode :=_trailerOperator;
	tmpController.myChassisType := _trailerType;
	tmpController.cargoType:=_trailerType.myCargoType.id;
	pxyGateChassis.setPXYFromController(tmpController);

	self.ignoreTrxWarnings(true);  // Need to ignore the id check digit warning
	app.myTrxCA.trxCreateInOutFlexiGateEntity(vVR, pxyGateChassis, gateChassis, app.myPassport);
	self.assertNoTrxErrors();
	
	delete pxyVVR;
	pxyVVR := app.createUpdateProxy(vVR).CM_VehicleVisitRecord;
	
	self.ignoreTrxWarnings(true);  // Need to ignore the id check digit warning
	app.myTrxCA.trxCreateInOutFlexiJob(pxyVVR, vVR,null, app.myPassport);
	self.assertNoTrxErrors();
	self.checkTIsForTxnOfType(vVR.allReceivedTrackedItems, TRANS_TYPE_REC_ROAD);				// 16/08/2012 cnwmh5
	return vVR;

epilog
	delete pxyVVR;
	delete tmpController;
	delete pxyGateEntity;

end;</source>
        <Parameter name="_truck" type="String"/>
        <Parameter name="_trailerType" type="CM_TILCType"/>
        <Parameter name="_trailerOperator" type="String"/>
        <Parameter name="_container" type="CM_Container"/>
        <Parameter name="_gate" type="Any"/>
        <ReturnType type="CM_VehicleVisitRecord"/>
    </JadeMethod>
