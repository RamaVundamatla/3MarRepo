    <JadeMethod name="copyFrom" id="88b92308-755f-41cf-9ede-6c1c0268eca8">
        <updating/>
        <source>copyFrom(_map : CM_ProductMap; _product : CM_Product; _parent : CM_ProductGroupMap) updating;
// 32311 set up self from the parameter plus the new product, copy all of the parameter map children under self.
vars
	imex		: CM_ImexServiceMap;
	newImex		: CM_ImexServiceMap;
begin
	self.myProduct := _product;
	if _parent = null then
		self.myProductGroupMap := _map.myProductGroupMap;
	else
		self.myProductGroupMap := _parent;
	endif;
	foreach imex in _map.allImExMaps do
		create newImex as imex.class persistent;
		newImex.copyFrom(imex, imex.imexStatus, self);
	endforeach;
end;
</source>
        <Parameter name="_map" type="CM_ProductMap"/>
        <Parameter name="_product" type="CM_Product"/>
        <Parameter name="_parent" type="CM_ProductGroupMap"/>
    </JadeMethod>
