    <JadeMethod name="setInvContractDetail" id="2d43ee4c-0542-4570-8e02-0a1b3471ae18">
        <updating/>
        <source>setInvContractDetail(_invContractDetail:CM_InvoiceContractDetails)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Feb 2023 navtnr20	TFS CR 55646 TTask 55665: UI - Contract Details

*/

vars
	contractDetail : CM_InvoiceContractDetails;
	loadStage: Boolean;
begin
	self.myContractDetails := _invContractDetail;
	//31/01/2023	navkc1 Bug 61578
	if self.myContractDetails &lt;&gt; null and (self.mode = self.MODE_UPDATE or self.mode = self.MODE_COPY) then
		// UPDATE
		if self.mode = self.MODE_UPDATE then
			if self.myContractDetails.isKindOf(CM_InvoiceContractDtlsVolBased) then	 //15-03-2023 navtnr20 CR 55647 TASK 55696
				self.myPxyContractDetails := app.createUpdateProxy(self.myContractDetails).CM_InvoiceContractDtlsVolBased; //15-03-2023 navtnr20 CR 55647 TASK 55696
			else
				self.myPxyContractDetails := app.createUpdateProxy(self.myContractDetails).CM_InvoiceContractDetails;
			endif;
		// COPY - We already passed in a transient object, use that
		else
			self.myPxyContractDetails := self.myContractDetails;
		endif;
	else
		if self.chkVolume.value then	 //15-03-2023 navtnr20 CR 55647 TASK 55696
			create myPxyContractDetails as CM_InvoiceContractDtlsVolBased transient; //15-03-2023 navtnr20 CR 55647 TASK 55696
		else
			create self.myPxyContractDetails transient;
		endif;
	endif;
epilog
	
end;</source>
        <Parameter name="_invContractDetail" type="CM_InvoiceContractDetails"/>
    </JadeMethod>
