    <JadeMethod name="validateMe" id="93325f3f-f864-48d7-bf29-4e3995d39a25">
        <source>validateMe();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

	existing : CM_VehicleBookingDayTemplate;
	myReal : CM_VehicleBookingDayTemplate;
	str1 : String;
	str2 : String;
	str3 : String;

begin

	if self.name.trimBlanks = null then
		app.raiseCMException(Name_required_field, null, null);
		return;
	endif;
	
	if self.myCalendar = null and self.priority &lt;&gt; 999 then
		app.raiseCMException(Please_select_calendar, null, null);
		return;
	endif;
	
//	check we only have one per calendar...
	if self.isTransient then
		myReal := self.pxyGetRealObject;
	else
		myReal := self;
	endif;
	
	existing := myVehicleBookingTerminal.allVehicleBookingDayTemplates.getAtKey(self.myCalendar);
	myReal := self.pxyGetRealObject;
	if myReal &lt;&gt; existing then
		if self.myCalendar = null then
			//default already exists
			str1 := app.getErrorString(Default);
			str2 := app.getErrorString(Vehicle_schedule_day_template);
			str3 := null;
			app.raiseCMException3(ERR_DUPLICATE_KEY, str1, str2, str3, null, null);
			
		else
			//example of this calendar already exists
			str1 := self.myCalendar.description;
			str2 := app.getErrorString(Vehicle_schedule_day_template);
			str3 := null;
			app.raiseCMException3(ERR_DUPLICATE_KEY, str1, str2, str3, null, null);
			
		endif;
	endif;
	

epilog

end;</source>
    </JadeMethod>
</Class>
