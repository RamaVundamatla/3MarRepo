    <JadeMethod name="canHaveAsChild" id="024aadf0-4ed4-430f-9abf-1133d3255503">
        <source>canHaveAsChild(pProposedChild: Control; pRejectionReason: String output): Boolean;

begin
	if (not inheritMethod(pProposedChild, pRejectionReason)) then
		return false;
	endif; 

	if pProposedChild.isKindOf(BaseControl)
	or pProposedChild.isKindOf(Folder)
	or pProposedChild.isKindOf(Frame)
	or pProposedChild.isKindOf(GroupBox)
	or pProposedChild.isKindOf(ListBox)
	or pProposedChild.isKindOf(Picture)
	or pProposedChild.isKindOf(Table)
	or pProposedChild.isKindOf(TextBox)
	then
		return true;
	else
		pRejectionReason := pProposedChild.class.name &amp; " controls not allowed in a CnEcSplitContainer";
		return false;
	endif;
end;</source>
        <Parameter name="pProposedChild" type="Control"/>
        <Parameter name="pRejectionReason" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hideLeftControl" id="e50be4f4-3ae5-4f21-b0e3-d661085d202f">
        <updating/>
        <source>hideLeftControl() updating;
// ---------------------------------------------------------------------------
// Created:     14 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	self.myLeftControl.visible := false;
	
	if self.isSplitHorizontal then
		self.myHorizontalSplitter.visible := false;
	else
		self.myVerticalSplitter.visible := false;
	endif;

	self.setLeftToRightRatio(0);
end;</source>
    </JadeMethod>
    <JadeMethod name="hideRightControl" id="bf48de1a-62b9-43b2-ab6a-486b2169b457">
        <updating/>
        <source>hideRightControl() updating;
// ---------------------------------------------------------------------------
// Created:     19 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	self.myRightControl.visible := false;
	
	if self.isSplitHorizontal then
		self.myHorizontalSplitter.visible := false;
	else
		self.myVerticalSplitter.visible := false;
	endif;

	self.setLeftToRightRatio(100);
end;</source>
    </JadeMethod>
    <JadeMethod name="initializeSplitter" id="4e9e0400-29e0-4833-bd5a-6efb2432de40">
        <updating/>
        <source>initializeSplitter() protected, updating;

/*
Purpose:		Initial setup for the vertical splitter bar


Return Value:



Date		Who		Reason
22 Feb 00	KPD		Initial creation


*/

vars
	vSplitter	: JSSVerticalSplitter;
	hSplitter	: JSSHorizontalSplitter;

begin
	if isSplitHorizontal then
		hSplitter	:=	self.myHorizontalSplitter;

		if hSplitter = null then
			create hSplitter transient;
		endif;

		hSplitter.parent	:= self;
		form.addControl(hSplitter);
   	else
		vSplitter	:=	self.myVerticalSplitter;

		if vSplitter = null then
			create vSplitter transient;
		endif;

		vSplitter.parent	:= self;
		form.addControl(vSplitter);
 	endif;

epilog
	if isSplitHorizontal then
		self.myHorizontalSplitter	:=	hSplitter;	
	else
		self.myVerticalSplitter		:=	vSplitter;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
