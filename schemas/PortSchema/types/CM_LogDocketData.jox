    <JadeMethod name="validateForCreate" id="bcda6876-c395-4faa-b408-3b5f5eeaef26">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     13 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	carrier 			: CM_Carrier;
	operator			: CM_Operator;
	species				: CM_LogSpecies;
	grade				: CM_LogGrade;
	length				: CM_LogLength;
	logType				: CM_LogType;
	treament			: CM_LogTreatment;
	logOrg				: CM_LoggingOrganisation;
	consignor			: CM_ConsigneeConsignor;
	docketErrorType		: CM_DocketErrorType;
	forest				: CM_SourceLocation;
	compart				: CM_SourceSubLocation;
	stand				: CM_SourceSubSubLocation;
	userTerminal		: CM_UserTerminal;
	
	failedDAC			: CM_DataAccessController;
	
	tmpCompare			: CMIF_SearchTypes;
	allLogLocations		: CM_LCByIdExtKeyDict;
	logLocation			: CM_LocationsController;
	
	realBlock			: CM_TerminalArea;
	
	yardTokens			: StringArray;
	block				: String;
	row					: String;
	
	ticketSequenceData	: CM_TicketSequenceData;
	
begin
	
	if self.docketNumber = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Bush docket Number', null, null);
		app.raiseCMException(Input_required_field_bshDocNum, null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.weightGross &lt; 0 then
		app.raiseCMException1(XXX_less_than_zero, app.getErrorString(Gross_weight), null, null);
	endif;
	
	if self.weightTare &lt; 0 then
		app.raiseCMException1(XXX_less_than_zero, app.getErrorString(Tare_weight), null, null);
	endif;
	
	if self.weightNett &lt; 0 then
		app.raiseCMException1(XXX_less_than_zero, app.getErrorString(Nett_weight), null, null);
	endif;
	
	if self.carrierCode &lt;&gt; null then
		carrier := app.myRoot.allCarriers[self.carrierCode];
		if carrier = null or carrier.isNotAvailableForEntry then
			app.raiseCMException2(ERR_Carrier_Unknown, self.carrierCode, null, null, null);
		endif;
	endif;
	
	if self.operatorCode &lt;&gt; null then
		operator := app.myRoot.allOperators[self.operatorCode];
		if operator = null or (not operator.canUserAccessSelf(null, failedDAC, app.myPassport)) then
			app.raiseCMException1(ERR_INVALID_OPERATOR, self.operatorCode, null, null);
			return;
		endif;
	endif;
	
	if self.logSpeciesCode &lt;&gt; null then
		species := operator.getLogSpecies(self.logSpeciesCode);
		if species = null or species.notAvailableForEntry then
			app.raiseCMException1(LogSpeciesInvalid, self.logSpeciesCode, null, null);
		endif;
	endif;
	
	if species &lt;&gt; null and self.logGradeCode &lt;&gt; null then
		grade := operator.getLogGrade(species.code, self.logGradeCode);
		if grade = null or grade.notAvailableForEntry then
			app.raiseCMException1(LogGradeInvalid, self.logGradeCode, null, null);
		endif;
	endif;
	
	if species &lt;&gt; null and grade &lt;&gt; null then
		if self.lengthRandom &lt;&gt; null then
			length := operator.getLogLengthForGrade(species.code, grade.code, self.lengthRandom);
			if length = null or length.notAvailableForEntry then
				app.raiseCMException1(LogLengthInvalid, self.lengthRandom, null, null);
			endif;
		endif;
		
		if self.logTypeCode &lt;&gt; null then
			logType := operator.getLogTypeForGrade(species.code, grade.code, self.logTypeCode);
			if logType = null or logType.notAvailableForEntry then	
				app.raiseCMException1(LogTypeInvalid, self.logTypeCode, null, null);
			endif;
		endif;
		
		if self.logTreatmentCode &lt;&gt; null then
			treament := operator.getLogTreatmentForGrade(species.code, grade.code, self.logTreatmentCode);
			if treament = null or treament.notAvailableForEntry then
				app.raiseCMException1(Log_treatment_invalid, self.logTreatmentCode, null, null);
			endif;
		endif;
	endif;
	
	if self.loggingOrganisation &lt;&gt; null then
		logOrg := app.myRoot.allLoggingOrganisations[self.loggingOrganisation];
		if logOrg = null or logOrg.notAvailableForEntry then
			app.raiseCMException1(Log_org_invalid, self.loggingOrganisation, null, null);
		endif;
	endif;
	
	if self.consignorCode &lt;&gt; null then
		consignor := app.myRoot.allConsigneeConsignors[self.consignorCode];
		if consignor = null or consignor.isNotAvailableForEntry then
			app.raiseCMException1(ERR_INVALID_CONSIGN, self.consignorCode, null, null);
		endif;
	endif;
	
	if self.forest &lt;&gt; null then
		if operator.getAllSrcLocn &lt;&gt; null then
			forest := operator.getAllSrcLocn[self.forest].CM_SourceLocation;
		endif;
		if forest = null or forest.notAvailableForEntry then
			app.raiseCMException1(Forest_invalid, self.forest, null, null);
		endif;
	endif;
	
	if forest &lt;&gt; null and self.compartment &lt;&gt; null then
		compart := forest.allSubLocations[self.compartment].CM_SourceSubLocation;
		if compart = null or compart.notAvailableForEntry then
			app.raiseCMException2(Compartment_invalid, self.compartment, self.forest, null, null);
		endif;
	endif;
	
	if compart &lt;&gt; null and self.stand &lt;&gt; null then
		stand := compart.allSubSubLocations[self.stand].CM_SourceSubSubLocation;
		if stand = null or stand.notAvailableForEntry then
			app.raiseCMException1(Stand_invalid, self.stand, null, null);
		endif;
	endif;

	if self.docketError &lt;&gt; null then
		docketErrorType := app.myRoot.allDocketErrorTypes[self.docketError];
		if docketErrorType = null or docketErrorType.notAvailableForEntry then
			app.raiseCMException1(Docket_error_code_not_found, self.docketError, null, null);
		endif;
	endif;
	
	if self.scalerCode &lt;&gt; null then
		userTerminal := self.myTerminal.allUserTerminals[self.scalerCode];
		if userTerminal = null then
			app.raiseCMException1(Scaler_code_invalid, self.scalerCode, null, null);
		endif;
	endif;
	
	//cnwmc5 - 18 August 2014 - PAR 34761 - changing the way yardLocation is validated... it now needs to be "BlockID [space] RowID"
	if self.yardLocation &lt;&gt; null then
		create yardTokens transient;
		self.yardLocation.getTokensForDelimiter(" ", yardTokens);
		
		if yardTokens.size &gt; 1 then
			block := yardTokens[1];
			row := yardTokens[2];
			
			create tmpCompare transient;
			create allLogLocations transient;
			
			tmpCompare.myOperator	:= operator;
			tmpCompare.mySpecies	:= species;
			tmpCompare.myGrade		:= grade;
			tmpCompare.myType 		:= logType;
			tmpCompare.myTreatment	:= treament;
			tmpCompare.myLength		:= length;
			
			realBlock := self.myTerminal.allTerminalAreas[block];
			if realBlock &lt;&gt; null then
				realBlock.availableLocationsForType(tmpCompare, allLogLocations);
			endif;
			//self.myTerminal.availableLocationsForType(tmpCompare, allLogLocations, TA_TYPE_LOGAREA);
			
			if allLogLocations.size &gt; 0 then
				logLocation := allLogLocations[row];
				if logLocation = null then
					app.raiseCMException1(Err_InvalidLocation, self.yardLocation, null, null);
				endif;
			else
				app.raiseCMException1(Err_InvalidLocation, self.yardLocation, null, null);
			endif;
		else
			app.raiseCMException1(Err_InvalidLocation, self.yardLocation, null, null);
		endif;
	endif;
	
	foreach ticketSequenceData in self.allTicketSequenceData do
		ticketSequenceData.validateForCreate();
	endforeach;
	
epilog
	delete yardTokens;
	delete tmpCompare;
	delete allLogLocations;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="ebe313fc-2819-4e15-8a7d-c89ee6568a07">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 December 2014	cnwmc5	Initial creation

*/

vars

begin
	self.validateForCreate();
epilog

end;</source>
    </JadeMethod>
</Class>
