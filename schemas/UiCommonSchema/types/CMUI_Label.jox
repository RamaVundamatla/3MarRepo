<GUIClass name="CMUI_Label" id="20a02527-3e95-4f58-a4e6-7d3b00b9a4d7">
    <superclass name="Label"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <PrimAttribute name="distanceFromBottom" id="8e92b513-5493-4751-ae8e-e4af2ff8775e">
        <embedded/>
        <type name="Real"/>
    </PrimAttribute>
    <PrimAttribute name="distanceFromRight" id="9b7c3d23-5cbc-450a-bc89-3333fae21729">
        <embedded/>
        <type name="Real"/>
    </PrimAttribute>
    <PrimAttribute name="lockBottom" id="35be0060-bed4-4240-9120-239d352b80ec">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="lockRight" id="889476b9-a657-45b7-98d9-11d7f8aa5071">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="stretchHeight" id="9d52b9b0-8a0c-44f0-ba47-8b5fd551da34">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="stretchWidth" id="6841e6d3-e42d-4160-9013-84a7acfb1ebb">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <JadeMethod name="create" id="4c03089b-d06c-45d4-b2bc-8ccc0d51b3df">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     28 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.transparent := true;

end;</source>
    </JadeMethod>
    <JadeMethod name="repositionAfterResize" id="14b42cf7-5196-4506-b1f6-8030bdd42ae5">
        <updating/>
        <source>repositionAfterResize() updating;

vars
   	newLeft, newTop, newWidth, newHeight,
   	parentWidth, parentHeight	: Real;

begin
	
	newLeft 	:= self.left;
	newTop 		:= self.top;
	newWidth 	:= self.width;
	newHeight 	:= self.height;
	
	if self.parent.isKindOf(Form) then
		parentWidth  := self.parent.Form.clientWidth;
		parentHeight := self.parent.Form.clientHeight;
	elseif self.parent.isKindOf(Control) then
		parentWidth  := self.parent.Control.clientWidth;
		parentHeight := self.parent.Control.clientHeight;
	else
		parentWidth  := self.parent.width;
		parentHeight := self.parent.height;
	endif;

	if lockRight then
		newLeft := (parentWidth - newWidth - self.distanceFromRight).max(0);
	endif;
	if lockBottom then
		newTop := (parentHeight - newHeight - self.distanceFromBottom).max(0);
	endif;
	
	if stretchWidth then
		newWidth := (parentWidth - newLeft - distanceFromRight).max(0);
	endif;
	if stretchHeight then
		newHeight := (parentHeight - newTop - distanceFromBottom).max(0);
	endif;
	
	if newLeft &lt;&gt; self.left or newTop &lt;&gt; self.top or newWidth &lt;&gt; self.width or newHeight &lt;&gt; self.height then
		self.move(newLeft, newTop, newWidth, newHeight);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setDistanceFromBottom" id="28b6a7c0-7da5-440a-8108-a64d225ddc72">
        <updating/>
        <source>setDistanceFromBottom(_value	:	Real) updating;
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 26 August 2003
//
//-----------------------------------------------------------------------

vars

begin
	if self.distanceFromBottom &lt;&gt; _value then
		self.distanceFromBottom := _value;
	endif;
end;</source>
        <Parameter name="_value" type="Real"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="9f6c4f42-15b7-43ca-9a67-427e5ab0b74a">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// ---------------------------------------------------------------------------
// Created:     28 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(cntrl, persistCntrl);
// this caused problems with sometimes the caption on the label not being displayed
//	self.transparent := true;

end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
