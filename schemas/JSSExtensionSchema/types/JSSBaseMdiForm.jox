    <JadeMethod name="mnuJSSFileOptionsChild_click" id="3e2a3a42-9ba2-4d20-a451-547927cac006">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuJSSFileOptionsChild_click(menuItem: MenuItem input) updating;
// --------------------------------------------------------------------------------
