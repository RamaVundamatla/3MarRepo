    <JadeMethod name="deleteVVR" id="8f3efd71-0ef5-4095-a2f6-2bd332c1e19c">
        <source>deleteVVR(_vvr : CM_VehicleVisitRecord input);
//04 November 2010	cnwml2

vars

	vvrDetails				: CM_VehicleVisitRecordDetail;
	ti						: CM_TrackedItem;
	bulkRelease				: CM_BulkRelease;
	terminal				: CM_Terminal;
	
	iter					: Iterator;
	
	requestSet				: CM_RequestSet;
	
	deliveryRelease			: String;
	ts						: TimeStamp;

begin

	// 09/05/2014 cnwmh5 - Read through the details to get delivery release from ti
	terminal := self.getTerminal();
	
	create requestSet transient;
		
	foreach vvrDetails in _vvr.allVehicleVisitRecordDetails do				
		if not vvrDetails.getExtraInfo_TrackedItem().isKindOf(CM_TrackedItem) then
			continue;
		endif;
		ti := vvrDetails.getExtraInfo_TrackedItem();
		deliveryRelease := ti.deliveryRelease;
		break;
	endforeach;

	if deliveryRelease &lt;&gt; null then
		delete iter;
		ts := null;
		iter := terminal.allBulkReleasesByCodeDate.createIterator;
		terminal.allBulkReleasesByCodeDate.startKeyLeq(deliveryRelease, ts, iter);
		while iter.back(bulkRelease) do
			if bulkRelease.code &lt;&gt; deliveryRelease then
				break;
			endif;
			bulkRelease.requests.copyNoDups(requestSet);
		endwhile;
	endif;
	delete iter;
	self.deleteRequest(ti, requestSet);

	beginTransaction;
		_vvr.erase(NORMAL_ERASE);
	commitTransaction;
	
epilog

	delete iter;
	delete requestSet;
	
end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
    </JadeMethod>
    <JadeMethod name="deleteVVSTerminal" id="362a4834-3da7-44d3-8c3d-20c9e0f26241">
