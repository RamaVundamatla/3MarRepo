            <optionsList>
                <value>0 - None</value>
                <value>1 - Picture to Control</value>
                <value>2 - Control to Picture</value>
                <value>3 - Control Proportional to Picture</value>
                <value>4 - Picture Proportional to Control</value>
                <value>5 - Picture Centered on Control</value>
            </optionsList>
        </DevControlProperties>
        <DevControlProperties name="tabIndex">
