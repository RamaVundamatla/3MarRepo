    <JadeMethod name="setForCreate" id="cd677996-a159-4276-af9e-a2171321e645">
        <updating/>
        <source>setForCreate(_pxyESEventType : CM_EventStreamEventType; _eventStreamDef : CM_EventStreamDefinition) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 January 2020		jlgzm1	Initial creation TFS 47920 Event Stream Admin JMT UI

*/

vars

begin
	self.setForUpdate(_pxyESEventType, _eventStreamDef);
	
	self.myRoot := CM_Root.firstInstance;	//07 Jul 2020	ND:	TFS 49590
	
epilog

end;</source>
        <Parameter name="_pxyESEventType" type="CM_EventStreamEventType"/>
        <Parameter name="_eventStreamDef" type="CM_EventStreamDefinition"/>
