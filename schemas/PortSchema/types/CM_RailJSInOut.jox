    <JadeMethod name="getRailJSInOuRake" id="f4cff584-c3ae-4774-8392-d24a15cd61d3">
        <source>getRailJSInOuRake(pRail : CM_Rail) : CM_RailJSInOutRake;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lRailJSInOutRake : CM_RailJSInOutRake;
begin

	foreach lRailJSInOutRake in self.inoutRakes do
		if lRailJSInOutRake.myRail = pRail then 
			return lRailJSInOutRake;
		endif;
	endforeach;
	return null;
end;</source>
        <Parameter name="pRail" type="CM_Rail"/>
        <ReturnType type="CM_RailJSInOutRake"/>
    </JadeMethod>
    <JadeMethod name="getTypeString" id="0117e22a-e23e-4357-8bf8-15690dccc798">
