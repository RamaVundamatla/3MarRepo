    </JadeMethod>
    <JadeMethod name="setDoorsDirectionForContainers" id="67fb203b-76e1-4299-a9fa-a698b4788d10">
        <source>setDoorsDirectionForContainers(_pxyVVR : CM_VehicleVisitRecord);
/* ---------------------------------------------------------------------------
Created:	12 October 2010	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	container		: CMGTE_Entity;
	pxyContainerBulkRel,
	containerBulkRel: CMGTE_Release;
	frm				: GTE_FlexiContainerFrame;
	idx				: Integer;
	
begin
	
	foreach container in _pxyVVR.allGateEntities where container.isContainer() do
	
		// -------------------------------------------------------------------
		//						RELEASE BY TYPE
		// -------------------------------------------------------------------
		// #25789 12.10.2010 - START
		if container.isKindOf(CMGTE_Release) then
			containerBulkRel := container.CMGTE_Release;
			if not containerBulkRel.isReleaseById then	// when release by type, there are no container's id. Need to figure out door direction in specific way.
				
				foreach frm in self.myTrkFlexiLayOut.allFlexiContainerFrames where frm.myContainer &lt;&gt; null do
					//P.S. frm.myContainer is persistent, its pxy object has doors direction set.
					pxyContainerBulkRel := app.myProxyManager.getProxyObject(frm.myContainer).CMGTE_Release;
					if pxyContainerBulkRel = containerBulkRel then
						containerBulkRel.setDoorsDirection(frm.getDoorsDir());
						break;
					endif;
				endforeach;
				
				continue;
				
			endif;
		endif;
		// #25789 12.10.2010 - FINISH
	
		// -------------------------------------------------------------------
		//						RELEASE BY ID
		// -------------------------------------------------------------------
		idx:=self.myTrkFlexiLayIn.allFlexiContainerFrames.getIdxById(container.getID());
		if idx&lt;&gt;0 then 
			container.setDoorsDirection(self.myTrkFlexiLayIn.allFlexiContainerFrames[idx].getDoorsDir);
		else
			idx:=self.myTrkFlexiLayOut.allFlexiContainerFrames.getIdxById(container.getID());
			if idx&lt;&gt;0 then
				container.setDoorsDirection(self.myTrkFlexiLayOut.allFlexiContainerFrames[idx].getDoorsDir);
			endif;
		endif;

	endforeach;

end;</source>
        <Parameter name="_pxyVVR" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="setDriverDetails" id="0bee3231-ea51-468b-9d9f-120d548ca703">
        <source>setDriverDetails(_driver : CM_DriverDetails) protected;
/*

Date		Who		Reason
26 November 2014	cnwer1	Initial creation PAR 35304

*/

vars

begin
	if _driver = null then
		return;
	endif;
	
	if self.cmbDriver.visible then
		self.cmbDriver.setIndexFromObject(_driver);
	else
		self.txtDriverName.text:=_driver.name;
		self.txtDriverCode.text:=_driver.code;
	endif;
		
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_driver" type="CM_DriverDetails"/>
    </JadeMethod>
    <JadeMethod name="setErrorsToIgnore" id="692ce702-460d-44ec-a4e1-a474f3031ca2">
        <source>setErrorsToIgnore(_passport : CM_Passport input; terminal : CM_Terminal);
// ---------------------------------------------------------------------------
// Created:     08 September 2008 by cnwab1
//
//	Purpose: 	These errors will not abort teh transaction and stop the update, 
//					these errors and any warnings will be recorded for later processing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 
// ---------------------------------------------------------------------------

vars

begin
	_passport.clearErrorsToIgnore();
	process.needGateConfig(); // Quick Reference 	
	// ERROR for In Out COMMON
	_passport.errorsToIgnore.add(ERR_Driver_Unknown);
	_passport.errorsToIgnore.add(ERR_Carrier_Unknown);
	
	//cnwmc5 - 9 Sep 2015 - PAR 36814
	if not terminal.getConfig(KnownTruckRequired).Boolean then
		_passport.errorsToIgnore.add(ERR_Truck_Unknown);
	endif;
	
	_passport.errorsToIgnore.add(ERR_Carrier_Blank);
	_passport.errorsToIgnore.add(ERR_TruckNotForCarrier);
	_passport.errorsToIgnore.add(VehicleIsOnSite);
	_passport.errorsToIgnore.add(ERR_Generator_Wrong_Type);
	_passport.errorsToIgnore.add(ERR_noGenSetForNonReeferISOTyp);	//Par18790. April 209
	
	// ERRORs for create job
//	_passport.errorsToIgnore.add(ERR_Trouble_With_Job);
	_passport.errorsToIgnore.add(AutoPlanningYAError); // TI does not Autoplan
	
	
//	_passport.errorsToIgnore.add(ERR_GateLane_Unknown);		// Force gate to enter
	
	// ERRORS for IN EMPTY
	
//	_passport.errorsToIgnore.add(ERR_Cargo_Unknown);
	_passport.errorsToIgnore.add(ERROR_NOT_IN_FLEET_FILE);
	_passport.errorsToIgnore.add(ERR_TI_ONSITE);
	_passport.errorsToIgnore.add(ERR_ALREADY_ONSITE);
	_passport.errorsToIgnore.add(ERR_ALREADY_ATTACHED);
	_passport.errorsToIgnore.add(ERR_TI_HAS_BULK_REL);
	_passport.errorsToIgnore.add(WARN_BOOKING_REF);
	_passport.errorsToIgnore.add(ERR_TI_ALREADY_ALLOCATED);
	
	// ERRORS for IN FULL
	_passport.errorsToIgnore.add(ERR_INVALID_ISOTYPE);

	// ERRORS for OUT EMPTY
	_passport.errorsToIgnore.add(ERR_TI_NOT_ONSITE);
	_passport.errorsToIgnore.add(ERR_NotEmpty);
	_passport.errorsToIgnore.add(ERR_NotFull);
	_passport.errorsToIgnore.add(ERR_Booking_Exceeded);
	
	
epilog
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setFieldsFromChassisOut" id="0856443a-b29e-41e8-8e89-12c6100492d9">
        <source>setFieldsFromChassisOut(_theTrailer : CM_TILC) protected;
/*
Date		Who		Reason
02 June 2009	cnwjk3	Initial creation
*/

vars
	
begin
