    <JadeMethod name="doComplete" id="5982cb0a-0940-45d2-8e8b-a2bb4a2e9312">
        <source>doComplete():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 February 2016	cnwndl1	Initial creation	TFS 1593

*/

vars

	errMsg : String;
	lc : CM_LocationsController;
	tiLen : Real;
begin

	if not self.validateComplete(lc) then
		return false;
	endif;
	
	//epr TFS 3194 9/2/17
	if lc.isKindOf(CM_RoRoController) then
		if not lc.CM_RoRoController.canFitCargo(self.myTrackedItem,false,null, null,tiLen) then
			//unqueue and requeue
			self.doAutoPlan();
			lc:=null;
			if not self.validateComplete(lc) then
				return false;
			endif;
			if self.myTrackedItem.myPrimaryQueuedLocation &lt;&gt; null then
				self.txtLocation.text := app.getErrorString(MOVE_TYPE_Queued) &amp; " - " &amp; self.myTrackedItem.myPrimaryQueuedLocation.getFullId;
			elseif self.myTrackedItem.myPrimaryPlannedLocation &lt;&gt; null then
				self.txtLocation.text := app.getErrorString(MOVE_TYPE_Planned) &amp; " - " &amp; self.myTrackedItem.myPrimaryPlannedLocation.getFullId;
			endif;
		endif;
	endif;
	

	if not self.myMobileGenericAgent.moveTI( self.myTrackedItem, null, lc, null, false, 0, 0, null ) then
		return false;
	endif;
	
	return true;

epilog

	if errMsg &lt;&gt; null then
		app.msgBox( errMsg, app.getErrorString(Error), MsgBox_OK_Only );
	endif;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doProcess" id="66085979-52a5-43b0-bd70-a1d1a584a601">
        <source>doProcess():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 February 2016	cnwndl1	Initial creation	TFS 1593


*/

vars

	errMsg : String;
	wle : CM_WorkListEntry;

begin

	if self.myTrackedItem = null then
		errMsg := app.getErrorString(Vehicle_selected);
		return false;
	endif;
	
	if self.myTrackedItem.myPrimaryActualLocation &lt;&gt; here then
		//wle := self.myTrackedItem.getVoyageWLEUnactioned( false );
		wle := self.myTrackedItem.getVoyageWLEForLCUnactioned( false, here );	//23 Jun 2016	NDL	TFS 2172
		if not self.myMobileGenericAgent.moveTI( self.myTrackedItem, null, here, wle, false, 0, 0, null ) then
			return false;
		endif;
	endif;
	
	if self.myTrackedItem.myPrimaryQueuedLocation = null and self.myTrackedItem.myPrimaryPlannedLocation = null then
		self.doAutoPlan();
	endif;
	
	if self.myTrackedItem.myPrimaryQueuedLocation = null and self.myTrackedItem.myPrimaryPlannedLocation = null then
		errMsg := app.getErrorString1( Not_queued_anywhere, self.myTrackedItem.id);
		return false;
	endif;
	
	if self.myTrackedItem.myPrimaryQueuedLocation &lt;&gt; null then
		self.txtLocation.text := app.getErrorString(MOVE_TYPE_Queued) &amp; " - " &amp; self.myTrackedItem.myPrimaryQueuedLocation.getFullId;
	elseif self.myTrackedItem.myPrimaryPlannedLocation &lt;&gt; null then
		self.txtLocation.text := app.getErrorString(MOVE_TYPE_Planned) &amp; " - " &amp; self.myTrackedItem.myPrimaryPlannedLocation.getFullId;
	else
		self.txtLocation.text := self.lblLocation.caption;
	endif;
	
	return true;

epilog

	if errMsg &lt;&gt; null then
		app.msgBox( errMsg, app.getErrorString(Error), MsgBox_OK_Only );
	endif;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="4ffd7a89-f5f1-4c62-8985-8800bdea8bfb">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 February 2016	cnwndl1	Initial creation		TFS 1593

*/

vars

	top : Real;
	width : Real;
	now : TimeStamp;
	stdHeight : Real;
	stdWidth : Real;
	tabIndex : Integer;
	
	damTableIndex : Integer;
	tblHeight : Real;

begin

	self.setResizeableMarginAndFontSize();
	
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	tabIndex := 4000;
	
	self.resizeCmdButtons();
	
	top := self.resizedMargin;
	width := stdWidth - self.getSearchButtonSpace();
	if _initialSetup then
		self.txtCargoId.setAndIncrementTabIndex( tabIndex );
		self.txtCargoId.visible := true;
	endif;
	self.txtCargoId.move(self.resizedMargin,
						 top,
						 width,
						 stdHeight );
						 
	width := self.getStdControlHeight();
	if _initialSetup then
		self.btnPartCargoId.visible := true;
		self.btnPartCargoId.setAndIncrementTabIndex( tabIndex );
	endif;
	self.btnPartCargoId.move(self.txtCargoId.left + self.txtCargoId.width + self.resizedMargin,
							 top,
							 width,
							 stdHeight );
						 
	top := top + self.txtCargoId.height + self.resizedMargin;
	if _initialSetup then
		self.lblCargoType.visible := true;
		self.lblCargoType.setAndIncrementTabIndex( tabIndex );
	endif;
	self.lblCargoType.move( self.resizedMargin,
							top,
							stdWidth,
							stdHeight ); 
							 
	top := top + self.lblCargoType.height + self.resizedMargin;
	if _initialSetup then
		self.lblCargoDesc.visible := true;
		self.lblCargoDesc.setAndIncrementTabIndex( tabIndex );
	endif;
	self.lblCargoDesc.move( self.resizedMargin,
							top,
							stdWidth,
							stdHeight ); 
							 
	top := top + self.lblCargoDesc.height + self.resizedMargin;
	if _initialSetup then
		self.txtLocation.visible := true;
		self.txtLocation.enabled := false;
		self.txtLocation.setAndIncrementTabIndex( tabIndex );
	endif;
	self.txtLocation.move(	self.resizedMargin,
							top,
							stdWidth,
							stdHeight ); 
							
	
							
	top := self.btnOne.top - self.btnOne.height - self.resizedMargin;
	if _initialSetup then
		damTableIndex := tabIndex + 1;
		tabIndex := damTableIndex + 1;
		self.btnDirty.visible := true;
		self.btnDirty.setAndIncrementTabIndex( tabIndex );
	endif;
	self.btnDirty.move(	self.btnThree.left,
						top,
						self.btnThree.width,
						self.btnThree.height ); 
							
	if _initialSetup then
		damTableIndex := tabIndex + 1;
		tabIndex := damTableIndex + 1;
		self.btnDamage.visible := true;
		self.btnDamage.setAndIncrementTabIndex( tabIndex );
	endif;
	self.btnDamage.move(	self.btnTwo.left,
							top,
							self.btnTwo.width,
							self.btnTwo.height ); 
							
	if _initialSetup then
		self.btnLabel.visible := true;
		self.btnLabel.setAndIncrementTabIndex( tabIndex );
	endif;
	self.btnLabel.move(	self.btnOne.left,
						top,
						self.btnOne.width,
						self.btnOne.height ); 
						
	
	top := self.txtLocation.top + self.txtLocation.height + self.resizedMargin;
	tblHeight := self.btnLabel.top - top - self.resizedMargin - self.resizedMargin;
	if _initialSetup then
		self.tblDamage.visible := true;
		self.tblDamage.setAndIncrementTabIndex( damTableIndex );
	endif;
	self.tblDamage.move(	self.resizedMargin,
							top,
							stdWidth,
							tblHeight );
							
	if _initialSetup then
		self.lblNoDamage.visible := false;
		self.lblNoDamage.enabled := false;
		self.lblNoDamage.setAndIncrementTabIndex( tabIndex );
	endif;
	self.lblNoDamage.move(	self.resizedMargin,
							top,
							stdWidth,
							stdHeight );


epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveDamage" id="f68418ec-a3a4-4b08-82ba-fe4cc4a065f4">
        <source>doSaveDamage() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 February 2016	cnwndl1	Initial creation		TFS 1593

*/

vars

	errors : String;
	sessionAgent : CM_MobileAgent;
	damageInterface : IF_DamageDetails;
	priorLocStr : String;
	currentLocStr : String;
	damageLC : String; // The location the cargo was n when the damage was noted.
	returnValue : Integer;
	damageInstance : CM_DamageInstance;

begin

	if self.myTrackedItem.myPrimaryActualLocation &lt;&gt; here then
		priorLocStr := self.myTrackedItem.myPrimaryActualLocation.getFullId;
		currentLocStr := here.getFullId;
	else
		priorLocStr := self.myTrackedItem.priorLocation;
		currentLocStr := self.myTrackedItem.myPrimaryActualLocation.getFullId;
	endif;

	if priorLocStr = null then
		damageLC := currentLocStr;
	else
		//Make them choose.
		returnValue := self.optBox(priorLocStr, currentLocStr, null, null, 2, app.getErrorString(Pleas_selec_locat_cargo_when_d) );
		if returnValue = 1 then
			damageLC := priorLocStr;
		elseif returnValue = 2 then
			damageLC := currentLocStr;
		endif;
	endif;

	app.mousePointer := self.MousePointer_HourGlass;
	sessionAgent := self.getSessionAgent();
	sessionAgent.setMyProxy( self.myTrackedItem );
	
	damageInterface:=sessionAgent.getMyProxyObject.IF_DamageDetails;
	
	self.tblDamage.setProxyFromTable( damageInterface, errors, damageLC );
	
	if sessionAgent.updateDamages(damageInterface, null, 3) then
		self.populateTrackedItem();
		return;
	endif;
	
	if errors &lt;&gt; null then
		self.msgBox(errors,app.getErrorString(Error),MsgBox_OK_Only, false);
	endif; 
	
epilog

	sessionAgent.setMyProxy(null);
	app.mousePointer := self.MousePointer_Default;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTFS2567Rules" id="d6736775-007c-4ab5-a9c5-1e4cd37c2038">
        <updating/>
        <source>doTFS2567Rules():Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		This is a temporary work around that is a dirty method to attempt to find a vehicle
					on the voyage based on a bar-code label that is attached to the car windscreen.
					The (scanned) bar code may or may not be similar in some way to the VIN
					The client "THOUGHT" this bar code was the vehicles VIN, and has recorded the real VIN
					as the cargo Id field.
					The client wants to be able to scan the un-related bar-code and find the cargo item.
					The bar-code value is sometimes the VIN, but often it is not.
					The barcode is sometimes the VIN with prefix characters and/or suffix characters
					Sometimes the barcode is a portion of the VIN 
					Sometimes the barcode is a portion of the VIN with additional pre-fix or suffix characters
					Sometimes the barcode has embedded spaces.
					
					The client wants us to try and identify a single the matching vehicle from the cargo ( related
					to the voyage ) using some rules they have come up with.
					
					If these rules identify a single cargo item on the voyage, JMT is to then automatically update the
					'alternate Id' of the Cargo Item with the 'scanned value' so that future searches for this cargo item
					via the bar-code (that have the facility to search using 'alternate Ids') would potentially find
					the cargo without all this palava.
					
Date		Who		Reason
18 August 2016	cnwndl1	Initial creation	TFS 2567	

*/

vars

	rawUserStr : String;
	cargoId : String;
	term : CM_Terminal;
	firstTi : CM_TrackedItem;
	tiArray : CM_TIArray;
	iter : Iterator;
	ti : CM_TrackedItem;
	voyage : CM_Voyage;
	revDict : CM_TIByIdCargoTypeDictRev;	
	cargoIdLength : Integer;	
	cargoIdReversed : String;
	load : Boolean;
	pxyTi : CM_TrackedItem;
	tiToUppdate : CM_TrackedItem;
	processedText : String;
	cmif : CMIF_IDConversion;
	result : Integer;

begin

	rawUserStr := self.txtCargoId.text.trimBlanks;
	if rawUserStr = null then
		// No value entered
		return false;
	endif;
	if rawUserStr = self.lblCargoId.caption.toUpper then
		// No value entered
		return false;
	endif;

	create tiArray transient;
	term := self.myMobileDataAgent.myTerminal;
	voyage := self.myMobileGenericAgent.myVoyage;
	
	cargoId := rawUserStr;
	cargoIdLength := cargoId.length;	
	cargoIdReversed := cargoId.reverse;	
	
	//First Rule
	//Check for an exact match of the scanned value against the recorded cargo ID first
	if cargoId.length = 17 then
	
		firstTi := voyage.allOnshipTIsByIdCargoType.getAtKeyGeq(cargoId,null);
		if firstTi &lt;&gt; null and firstTi.id = cargoId then
			iter := voyage.allOnshipTIsByIdCargoType.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.id &lt;&gt; cargoId then
					break;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
		
		if tiArray.size &gt; 1 then
			//found more than one, we are screwed, bail.
			return false;
		elseif tiArray.size = 1 then
			//we have an exact match
			//just populate the form.
			self.setMyTrackedItem(	tiArray.first );	
			populateTrackedItem();
			return true;
		endif;
		
	endif;
	
	//second rule
	// Use the last 6 characters "for a reverse id search". (I.e a partial match)
	if cargoIdLength &gt;= 6 then
	
		cargoIdReversed := rawUserStr.reverse[1:6].trimBlanks; // first 6 chars of the reversed scanned value
		cargoIdLength := cargoIdReversed.length; // Not necessarily 6, because we might have trimmed a space
												// that was previously embedded but was on the end after
												// the truncation
		firstTi := voyage.allOnshipTIsByIdCargoTypeRev.getAtKeyGeq(cargoIdReversed,null);
		if firstTi &lt;&gt; null and firstTi.idReversed[1:cargoIdLength] = cargoIdReversed then
			iter := voyage.allOnshipTIsByIdCargoTypeRev.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.idReversed[1:cargoIdLength] &lt;&gt; cargoIdReversed then
					break;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
		
		if tiArray.size &gt; 1 then
			//found more than one, we are screwed, bail.
			return false;
		elseif tiArray.size = 1 then
			//we have a single match, we need to update its alternate id with the raw scanned data
			//and then populate the form.
			tiToUppdate := tiArray.first;
		endif;
		
	endif;
	
	//third rule
	// Apply the user hook code - "typically for pre-fix and suffix handling"
	if tiToUppdate = null then
	
		create cmif transient;
		cmif.myTerminal := term;
		cmif.myVoyage := voyage;
		cmif.scannedValue := rawUserStr;
		cmif.isAlternateId := false;
		cmif.callerName := self.class.name;
	
		processedText := app.convertScannedCargoId( null,  null, false, cmif );
		
		if processedText &lt;&gt; rawUserStr then	// because no point in trying it if its not different
		
			//OK we have something that has potentially had some suffix crap taken off the end
			
			cargoId := processedText;
			cargoIdLength := cargoId.length;	
			cargoIdReversed := cargoId.reverse;
			//try an exact match against the hook code processed text.
			firstTi := voyage.allOnshipTIsByIdCargoType.getAtKeyGeq(cargoId,null);
			if firstTi &lt;&gt; null and firstTi.id[1:cargoIdLength] = cargoId then
				iter := voyage.allOnshipTIsByIdCargoType.createIterator;
				iter.startAtObject(firstTi);
				while iter.next( ti ) do
					if ti.id[1:cargoIdLength] &lt;&gt; cargoId then
						break;
					endif;
					tiArray.addExclusive(ti);
				endwhile;
				delete iter;
			endif;
			
			if tiArray.size &gt; 1 then
				//found more than one, we are screwed, bail.
				return false;
			elseif tiArray.size = 1 then
				//we have a single match, we need to update its alternate id with the raw scanned data
				//and then populate the form.
				tiToUppdate := tiArray.first;
			endif;
			
			if tiToUppdate = null then
				//Try a reverse id match against the hook code processed text.
				if tiArray.isEmpty then
					firstTi := voyage.allOnshipTIsByIdCargoTypeRev.getAtKeyGeq(cargoIdReversed,null);
					if firstTi &lt;&gt; null and firstTi.idReversed[1:cargoIdLength] = cargoIdReversed then
						iter := voyage.allOnshipTIsByIdCargoTypeRev.createIterator;
						iter.startAtObject(firstTi);
						while iter.next( ti ) do
							if ti.idReversed[1:cargoIdLength] &lt;&gt; cargoIdReversed then
								break;
							endif;
							tiArray.addExclusive(ti);
						endwhile;
						delete iter;
					endif;
				
					if tiArray.size &gt; 1 then
						//found more than one, we are screwed, bail.
						return false;
					elseif tiArray.size = 1 then
						//we have a single match, we need to update its alternate id with the raw scanned data
						//and then populate the form.
						tiToUppdate := tiArray.first;
					endif;
					
				endif;
			endif;
				
		endif;

	endif;
	
	// If we get to here and have one to play with, update its alternate id with the raw scanned data
	// and populate the form
	if tiToUppdate &lt;&gt; null then
		
		app.cmsBeginLoad(load);
		pxyTi := tiToUppdate.pxyCreateUpdateProxy();
		app.cmsEndLoad(load);
		
		pxyTi.zSetPxyAlternativeId( rawUserStr );
		
		app.myPassport.clearErrorsWarnings();
		
		while true do
			app.myTrxUA.trxUpdateTrackedItem(pxyTi, null, TI_UPDMODE_NORMAL, null, app.myPassport);
			
			if app.myPassport.trxCompletedOK then
				break;
			else
				//If there were warnings, give the user a chance to see them. If there are no errors they may decide to acknowledge
				//them and update anyway.
				result := app.showErrorWarningDialog('Alternate Id Update', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			return false;
		endwhile;
		
		self.setMyTrackedItem(	tiToUppdate );	
		populateTrackedItem();
		return true;
	
	endif;
	
	//nothing found that nearly matches...	
	return false;
	
epilog

	delete tiArray;
	delete iter;
	delete pxyTi;
	delete cmif;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findTIsInMyWorkPoint" id="09c9164e-a5b9-48f4-93ab-2491c55d4430">
        <source>findTIsInMyWorkPoint( cargoId : String; tiArray : CM_TIArray input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 February 2016	cnwndl1	Initial creation

*/

vars

	wp : CM_WorkPoint;
	wpDischargeLanes : CM_LCArray;
	lc : CM_LocationsController;
	firstTi : CM_TrackedItem;
	cargoIdLength : Integer;
	iter : Iterator;
	ti : CM_TrackedItem;

begin

	if cargoId = null then
		return;
	endif;

	wp := self.myMobileGenericAgent.myWorkPoint;
	if wp = null or wp.myWorkPointInterchangeArea = null then
		return;
	endif;
	
	cargoIdLength := cargoId.length;
	
	create wpDischargeLanes transient;
	wp.myWorkPointInterchangeArea.getLanes(wpDischargeLanes);
	
	foreach lc in wpDischargeLanes do
	
		firstTi := lc.allTrackedItemsById.getAtKeyGeq(cargoId,null);
		if firstTi &lt;&gt; null and firstTi.id[1:cargoIdLength] = cargoId then
			iter := lc.allTrackedItemsById.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.id[1:cargoIdLength] &lt;&gt; cargoId then
					break;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
	
	endforeach;

epilog

	delete wpDischargeLanes;
	delete iter;

end;</source>
        <access>protected</access>
        <Parameter name="cargoId" type="String"/>
        <Parameter name="tiArray" type="CM_TIArray" usage="input"/>
    </JadeMethod>
