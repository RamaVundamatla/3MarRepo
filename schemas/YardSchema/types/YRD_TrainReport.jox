    <JadeMethod name="chkPrintCargoCON_click" id="a562233f-0e83-4e7b-89ac-3a3f39191c8a">
        <controlMethod name="CMUI_CheckBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkPrintCargoCON_click(checkbox: CheckBox input) updating;
// ---------------------------------------------------------------------------
// Created:     07 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if not self.chkPrintCargoWAG.value
	and not self.chkPrintCargoOP.value 
	and not checkbox.value then
		checkbox.value := true;
	endif;

epilog

end;</source>
