//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if _git = null then
		return;
	endif;
	
	_git.bookingRef := self.bookingReference;
	
	
epilog

end;</source>
        <Parameter name="_git" type="CM_GateItemDetail" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="c96e31a7-0ba7-4959-9901-95d70970b1b8">
        <updating/>
        <source>validateForCreate(_passport : CM_Passport input): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     16 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 13 Nov 2014  cnwma1      PAR #35190 DH- Kiosk is removing the Cargo type off the empty release request
// ---------------------------------------------------------------------------
vars
	tmpOperatorGroup : CM_OperatorGroup;
	tmpDeliveryReq : CM_DeliveryRequest;
	theBulkRelease : CM_BulkRelease;
	tmpDeliveryNumber,
	tmpCarrierID : String;
	tmpPinNo : String;
	theCargoType, tmpCargoType : CM_CargoType;
	ti : CM_TrackedItem;
	//isoGroup : String; //cnwrd1 par 25590 1.9.2010	//cnwmc5 - PAR 32207 - 11 Sep 2013
	isoType : CM_ISOType; //cnwrd1 par 25590 1.9.2010
begin
	tmpOperatorGroup := self.validateOperatorGroup();

	create tmpDeliveryReq transient;
		
	self.myProxyYardRequest := tmpDeliveryReq;

	tmpDeliveryNumber := self.releaseNo;
	if tmpDeliveryNumber = null then
		// Par8380 use BR system code if there is one as a system BR is created if one is not found
		// all subsequent requests that dont have a BR will be attached to the system generated BR
		tmpDeliveryNumber := self.systemBulkReleaseCode;
	endif;

	//added by cnwyl1 for par 13816
	if (self.myBulkRelease &lt;&gt; null) then
		tmpPinNo := self.myBulkRelease.getPinNumber();
	else
		tmpPinNo := null;
	endif;
	
	//+cnwml2 PAR21531
	theCargoType := null;
	if self.myBulkRelease &lt;&gt; null then
		tmpCargoType := null;
		if self.myBulkRelease.allTrackedItemsAssigned.isNotEmpty then      //13/11/2014 cnwma1 PAR #35190
			foreach ti in self.myBulkRelease.allTrackedItemsAssigned do
				if tmpCargoType = null then
					tmpCargoType := ti.myCargoType;
				else
					if ti.myCargoType &lt;&gt; tmpCargoType then
						theCargoType := null;
					endif;
				endif;
			endforeach;
			theCargoType := tmpCargoType;
		else
			theCargoType := self.myCargoType;
		endif;
	endif;
	
	//cnwmc5 - PAR 32207 - 11 Sep 2013 - comment out as no longer used
	//cnwrd1 par 25590 1.9.2010						
	/*if self.doISOGroupCheck then // iso group check is kinda defunct but still used on the gate in/out so here we need to go find our iso type , grab its group and use that as this flag has been depreciated.
		if self.isoType &lt;&gt; null then
			isoType := app.myRoot.allISOTypes[self.isoType];
			if isoType.myISOTypeGroup &lt;&gt; null then 
				isoGroup := isoType.myISOTypeGroup.code;
			endif;
		endif;
	endif;*/

	tmpDeliveryReq.set(self.consigneeCode, self.consignorVoyageCode, tmpDeliveryNumber, 
					   self.eirNumber, self.isoType, self.operatorCode,
					   tmpOperatorGroup,
					//   self.myCargoType,
					   theCargoType,					//+cnwml2 PAR21531
					   self.clean, self.doISOGroupCheck, self.doorsDirection, 
					   self.heavyRated,
					   false, 	/* isReceipt */
					   self.needCOU, self.needGenerator,
					   self.removeStops, self.quantity,
					   null,	/* reasonCode */
					   self.allAvailabilityGrades, self.deliveryReason, self.remarks, 
					   null,	/* ids */
					  // self.myBulkRelease.getPinNumber(),	// pinNo	CCMS1037
					   tmpPinNo,//for par13816
					   self.myTransferToTerminal,
					   self.myBulkRelease,
					   self.mySubTerminal,		// cnwdad1 02/07/2009 - CCMS 1735
					   //cnwmc5 - PAR 32207 - 11 Sep 2013
					   self.isoTypeGroup,					// MES1008 JMH 29/9/09 Add iso group //cnwrd1 par 25590 1.9.2010
					   0,				// imex
					   null,
					   null,
					   null //BOL 18 Feb 2014	NDL	Par 33524
					   );

	tmpDeliveryReq.setIds(self.ids);
	
	//th2 for PAR 14966 - set the road job so that in the following validation, the
	//total number of delivery requests being made can by assessed in comparison the 
	//associated release request's outstanding quantity and raise a warning if this is
	//about to be exceeded.
	if self.myIntFaceInOutCommon.myProxyRoadJob &lt;&gt; null then
		tmpDeliveryReq.setJob(self.myIntFaceInOutCommon.myProxyRoadJob);
	endif;
	
	if self.myBulkRelease &lt;&gt; null and self.myBulkRelease.fullRelease then	//30 Aug 2021	NDL	TFS 51873
		//Doesn't make any sense to set commodity to MT when we know its NOT.
	else
		//epr make sure when this are created commodity is set as MT
		tmpDeliveryReq.setMTCommodity();
	endif;
	//tmpDeliveryReq.
	// CCMS 1412
	tmpDeliveryReq.validateForCreate(self.myUserObject);
	
	// CCMS 1412 Test carrier is the same as the one assigned to the bulk release
	// have to do it here as the job is not assigned to the delivery request at this stage
	if self.myIntFaceInOutCommon = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'myIntFaceInOutCommon not set (call setMyInOutCommon(..) to set)');
		return null;
	endif;	
	
	tmpCarrierID := self.myIntFaceInOutCommon.carrierCode;
	theBulkRelease := tmpDeliveryReq.myOriginatingBulkRelease;
	
	if tmpCarrierID &lt;&gt; null
	and theBulkRelease &lt;&gt; null
	and theBulkRelease.carrierId &lt;&gt; null
	then
		if tmpCarrierID &lt;&gt; theBulkRelease.carrierId then
			// For security reasons do not tell them which carrier it should be.
		//	app.raiseCMWarning1(PortSchemaReleaseError, 'ERROR: The Carrier (' &amp; tmpCarrierID &amp; ') is not assigned to release ' &amp;
		//						theBulkRelease.getDescription(true) &amp; '.', ETRow_CarrierId, self.myUserObject, theBulkRelease);
			app.raiseCMWarning2(Carrier_not_assigne_release, tmpCarrierID, theBulkRelease.getDescription(true), ETRow_CarrierId, self.myUserObject, theBulkRelease);//13 Sep 2012	NDL	Par 30366
		endif;
	endif;
	
	return _passport.noErrors();
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateOperatorGroup" id="cc832268-da7c-43eb-90eb-deec3dbb21df">
        <updating/>
        <source>validateOperatorGroup() : CM_OperatorGroup updating;
//--------------------------------------------------------------
//Created: 28 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars
begin
	if self.myOperatorGroup = null then
		if self.operatorGroupCode &lt;&gt; null then
			self.myOperatorGroup := app.myRoot.allOperatorGroups[self.operatorGroupCode];
			if self.myOperatorGroup = null then
				app.raiseCMException1(ERR_INVALID_OPERATOR_GROUP, self.operatorGroupCode, ETRow_MyOperatorGroup, null);
			endif;
		endif;
	endif;

epilog	
	return self.myOperatorGroup;
end;</source>
        <ReturnType type="CM_OperatorGroup"/>
    </JadeMethod>
</Class>
