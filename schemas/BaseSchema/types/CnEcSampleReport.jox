    <JadeMethod name="doPrintAttributes" id="d7319b60-04a7-4762-99a7-fc02217da1c0">
        <updating/>
        <source>doPrintAttributes(pBaseRootObj:CnEcBaseRoot; pErrorMessage:String io):Integer updating, protected;
// --------------------------------------------------------------------------------
// Created:		08 August 2000 by cnwdad1
//
// Purpose:		Print the list of attributes for the BaseRoot Class.
//
// Parameters:	pBaseRootObj - The BaseSchema root object.
//				pErrorMessage - Returns a message if an error occurs.
//
// Returns:		The result of the print request, i.e. the CNEC_REPORT_PRINTED or
//				CNEC_REPORT_ERROR global constant value.
//
// Changed On Changed By Reason
// ---------- ---------- ----------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	propertyObj			: Property;
	propertyInfo		: String;
	propertyCollObj		: PropertyColl;
	
begin
	// Print the heading.
	
	if not self.printMediumHeading("Class Attributes", pErrorMessage) then
		return CNEC_REPORT_ERROR;
	endif;

	// Now print the details beneath the heading.

	//on Exception do ignoreDisplayError(exception);
	propertyCollObj	:=	pBaseRootObj.class().allProperties();	

	foreach propertyObj in propertyCollObj do
		if propertyObj.getType.name = "Binary" then
			propertyInfo	:=	propertyObj.name &amp; " = &lt;binary data - not shown&gt;";
		else
			propertyInfo	:=	propertyObj.name &amp; " = " &amp; getPropertyValue(propertyObj.name).String;
		endif;
		
		if not self.printBody(propertyInfo, pErrorMessage) then
			return CNEC_REPORT_ERROR;
		endif;
	endforeach;
	
	return CNEC_REPORT_PRINTED;
epilog
	delete propertyCollObj;
end;</source>
        <access>protected</access>
        <Parameter name="pBaseRootObj" type="CnEcBaseRoot"/>
        <Parameter name="pErrorMessage" type="String" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doPrintClassText" id="d9174cbd-de9c-4201-a094-caec527b5462">
        <updating/>
        <source>doPrintClassText(pBaseRootObj:CnEcBaseRoot; pErrorMessage:String io):Integer updating, protected;
// --------------------------------------------------------------------------------
// Created:		08 August 2000 by cnwdad1
//
// Purpose:		Print the Class text for the BaseRoot Class.
//
// Parameters:	pBaseRootObj - The BaseSchema root object.
//				pErrorMessage - Returns a message if an error occurs.
//
// Returns:		The result of the print request, i.e. the CNEC_REPORT_PRINTED or
//				CNEC_REPORT_ERROR global constant value.
//
// Changed On Changed By Reason
// ---------- ---------- ----------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Print the heading.

	if not self.printMediumHeading("Class Text", pErrorMessage) then
		return CNEC_REPORT_ERROR;
	endif;

	// Now print the details beneath the heading.

	if not self.printBody(pBaseRootObj.class().text, pErrorMessage) then
		return CNEC_REPORT_ERROR;
	else
		return CNEC_REPORT_PRINTED;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pBaseRootObj" type="CnEcBaseRoot"/>
        <Parameter name="pErrorMessage" type="String" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doPrintMethods" id="631453cf-a39e-4c71-8782-b8cee71d545f">
        <updating/>
        <source>doPrintMethods(pBaseRootObj:CnEcBaseRoot; pErrorMessage:String io):Integer updating, protected;
// --------------------------------------------------------------------------------
// Created:		08 August 2000 by cnwdad1
//
// Purpose:		Print the list of methods for the BaseRoot Class.
//
// Parameters:	pBaseRootObj - The BaseSchema root object.
//				pErrorMessage - Returns a message if an error occurs.
//
// Returns:		The result of the print request, i.e. the CNEC_REPORT_PRINTED or
//				CNEC_REPORT_ERROR global constant value.
//
// Changed On Changed By Reason
// ---------- ---------- ----------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	methodObj		: Method;
	methodSetObj	: MethodSet;

begin
	// Print the heading.

	if not self.printMediumHeading("Class Methods", pErrorMessage) then
		return CNEC_REPORT_ERROR;
	endif;

	// Now print the details beneath the heading.

	create methodSetObj transient;
	pBaseRootObj.class().allMethods(methodSetObj);

	foreach methodObj in methodSetObj do
		if self.printBody(methodObj.makeHeader &amp; ";", pErrorMessage) then
			if not self.doPrint(fraLine, pErrorMessage) then
				return CNEC_REPORT_ERROR;
			endif;
		else
			return CNEC_REPORT_ERROR;
		endif;
	endforeach;

	return CNEC_REPORT_PRINTED;
epilog
	delete methodSetObj;
end;</source>
        <access>protected</access>
        <Parameter name="pBaseRootObj" type="CnEcBaseRoot"/>
        <Parameter name="pErrorMessage" type="String" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doValidateParameterValues" id="540ea5a7-68d1-404b-86c0-3b1a4c440968">
        <updating/>
        <source>doValidateParameterValues(pParameterCollObj: CnEcReportParameterValueDict; pErrorMessage: String output): Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		08 August 2000 by cnwdad1
//
// Purpose:		Validates the report's parameters.
//
// Parameters:	pParameterCollObj - The collection of parameter value objects.
//				pErrorMessage - Returns an error message if the value of a parameter
//					is not valid.
//
// Returns:		True if all of the parameters are valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	parameterValueObj	: CnEcReportParameterValue;
	parameterName		: String;
	stringValue			: String;
	objectValue			: Object;

begin
	foreach parameterValueObj in pParameterCollObj do
		parameterName	:=	parameterValueObj.myReportParameter.parameterName;
		stringValue		:=	parameterValueObj.stringValue;
		objectValue		:=	parameterValueObj.myObjectValue;
		
		if parameterName = self.PARAM_BASEROOT then
			if objectValue = null then
				pErrorMessage	:=	"Please select the BaseRoot object whose properties you wish to print.";
				return false;
			endif;
		elseif parameterName = self.PARAM_PRINT_ATTRIBUTES then
			if stringValue &lt;&gt; "true" and stringValue &lt;&gt; "false" then
				pErrorMessage	:=	"Please select 'True' or 'False' for the 'Print Attributes' option.";
				return false;
			endif;
		elseif parameterName = self.PARAM_PRINT_METHODS then
			if stringValue &lt;&gt; "true" and stringValue &lt;&gt; "false" then
				pErrorMessage	:=	"Please select 'True' or 'False' for the 'Print Methods' option.";
				return false;
			endif;
		elseif parameterName = self.PARAM_PRINT_TEXT then
			if stringValue &lt;&gt; "true" and stringValue &lt;&gt; "false" then
				pErrorMessage	:=	"Please select 'True' or 'False' for the 'Print Class Text' option.";
				return false;
			endif;
		else
			pErrorMessage	:=	"'" &amp; parameterName &amp; "' is not a valid parameter name for this report.";
			return false;
		endif;
	endforeach;
	
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="pParameterCollObj" type="CnEcReportParameterValueDict"/>
        <Parameter name="pErrorMessage" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isParameterRequired" id="991a10e5-a4e0-4832-be6c-8fab88bb16d8">
        <source>isParameterRequired(pParameterName: String): Boolean;
// --------------------------------------------------------------------------------
// Created:		08 August 2000 by cnwdad1
//
// Purpose:		Determines whether the Report Parameter specified by the name is
//				a required parameter (a value is mandatory).
//
// Parameters:	pParameterName (String) - The name of the parameter.
//
// Returns:		True if a parameter value is required, otherwise false.
//
// Changed On Changed By Reason
// ---------- ---------- ----------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pParameterName = self.PARAM_BASEROOT then
		return true;
	elseif pParameterName = self.PARAM_PRINT_ATTRIBUTES then
		return true;
	elseif pParameterName = self.PARAM_PRINT_METHODS then
		return true;
	elseif pParameterName = self.PARAM_PRINT_TEXT then
		return true;
	else
		return false;
	endif;
end;</source>
        <Parameter name="pParameterName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="printReport" id="b11fdd74-9924-41d0-a10c-6940d5afd200">
        <updating/>
        <source>printReport(pQueueEntryObj: CnEcReportQueueEntry; pIsPreview: Boolean; pErrorMessage: String output): Integer updating;
// --------------------------------------------------------------------------------
// Created:		08 August 2000 by cnwdad1
//
// Purpose:		Refer to the comments in the superclass implementation of this method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	printResult			: Integer;
	baseRootObj			: CnEcBaseRoot;
	isPrintAttributes	: Boolean;
	isPrintMethods		: Boolean;
	isPrintClassText	: Boolean;
	currentTimeStamp	: TimeStamp;
	
begin
	// Next, inherit to validate parameters and set up the printer configuration etc.
	
	printResult	:=	inheritMethod(pQueueEntryObj, pIsPreview, pErrorMessage);
	
	if printResult = CNEC_REPORT_ERROR then
		return printResult;
	endif;
	
	// Then set up the report headers and footers etc.
	
	lblReportTitle.caption	:=	"BaseRoot Information";
	self.aMyPrinter.setHeader(fraHeader);
	lblFootRunDate.caption	:=	currentTimeStamp.String;
	self.aMyPrinter.setFooter(fraFooter);
	
	// Now start printing the report.
	
	pQueueEntryObj.getParameterValue(self.PARAM_BASEROOT, baseRootObj);
	pQueueEntryObj.getParameterValue(self.PARAM_PRINT_ATTRIBUTES, isPrintAttributes);
	pQueueEntryObj.getParameterValue(self.PARAM_PRINT_METHODS, isPrintMethods);
	pQueueEntryObj.getParameterValue(self.PARAM_PRINT_TEXT, isPrintClassText);

	// Print the object OID.

	if self.printMediumHeading("BaseRoot Object", pErrorMessage) then
		if not self.printBody(baseRootObj.String, pErrorMessage) then
			return CNEC_REPORT_ERROR;
		endif;
	else
		return CNEC_REPORT_ERROR;
	endif;

	// Print the Class Text.

	if isPrintClassText then
		printResult	:=	self.doPrintClassText(baseRootObj, pErrorMessage);
		
		if printResult = CNEC_REPORT_ERROR then
			return printResult;
		endif;
	endif;

	// Print the Attributes.

	if isPrintAttributes then
		printResult	:=	self.doPrintAttributes(baseRootObj, pErrorMessage);

		if printResult = CNEC_REPORT_ERROR then
			return printResult;
		endif;
	endif;
	
	// Print the Methods.
	
	if isPrintMethods then
		printResult	:=	self.doPrintMethods(baseRootObj, pErrorMessage);
		
		if printResult = CNEC_REPORT_ERROR then
			return printResult;
		endif;
	endif;
	
	// *******************************************************************************
	// * Must always call "self.printFinish" to close the printer and any files etc. *
	// *******************************************************************************
	
	return self.printFinish();
end;</source>
        <Parameter name="pQueueEntryObj" type="CnEcReportQueueEntry"/>
        <Parameter name="pIsPreview" type="Boolean"/>
        <Parameter name="pErrorMessage" type="String" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</GUIClass>
