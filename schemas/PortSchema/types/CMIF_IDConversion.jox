    <JadeMethod name="convertedCargoId" id="2322db88-dbaa-460c-bb42-c5d4343ab0e9">
        <methodInvocation>mapping</methodInvocation>
        <source>convertedCargoId(set : Boolean; _value : String io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 July 2016	cnwndl1	Initial creation	TFS 2275

*/

vars

begin

	if set then
		_value := null;
	else
		if scannedValue &lt;&gt; null then
			if scannedValue[1] = "&lt;" then
				if scannedValue[scannedValue.length] = "&gt;" then
					_value := scannedValue;
					return;
				endif;
			endif;
		endif;
		
		if self.isAlternateId then
			_value := scannedValue[1:30];
		else
			_value := scannedValue[1:20];
		endif;
	endif;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="exampleVinConvert" id="32d9030d-8548-4f14-9ac6-44ec3960b12c">
        <source>exampleVinConvert():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2016	cnwndl1	Initial creation	TFS 2275 / 2216
				The issue is that the barcoded VIN value does not always match the
				real 'VIN' number on the vehicle.
				If real VIN number is to be used as the Cargo Id, then the scanned
				value needs to be converted to look the same as the printed VIN number
				that will be recorded everywhere else.

*/

vars

	length : Integer;
	firstChar : Character;
	secondCharacter : Character;
	thirdCharacter : Character;
	lastChar : Character;
	
	reference : Integer;

begin

	reference := HookType_CargoIdConversion; // here to provide some sort of reference.... Consider changing the default code in the text of
											//	the hook code if you change this method

	//find the exact length of the original scanned value as it was scanned
	length := self.scannedValue.length;
	
	if length &lt;= 17 then
		// if the length is less than or equal to 17 characters in length, just return it
		return self.scannedValue;
	endif;
	
	// formats and meaning of the data in teh VIN is as per information found in 
	//"https://en.wikipedia.org/wiki/Vehicle_identification_number"
	
	// It is apparently common to prefix the bar-coded VIN number
	// with an 'I' apparently indicating an 'Import'
	// The first 3 chars are the 'World Manufacturer Identifier'
	// and none of them start with 'I'
	
	// establist what the first and last characters are in the scanned value
	firstChar := self.scannedValue[1].toUpper;
	lastChar := self.scannedValue[length].toUpper;
	
	if firstChar = "&lt;" and lastChar = "&gt;" then
		//This is probably a hand held field instruction like "&lt;PLEASE ENTER CARGO ID&gt;"
		return self.scannedValue;
	endif;
	
	//So first simple rule 
	if length = 18 then
		if firstChar = "I" then
			// The value is one character too long and starts with an 'I'
			// return the value starting at the second character
			return self.scannedValue[2:end];
		endif;
	endif;
	
	//apparently some numbers are actually wrapped in asterix (both ends)
	//So second simple rule
	if length = 19 then
		if firstChar = "*" and lastChar = "*" then
			// return 17 characters starting at the second character
			return self.scannedValue[2:17];
		endif;
	endif;
	
	secondCharacter := self.scannedValue[2].toUpper;
	thirdCharacter := self.scannedValue[3].toUpper;
	//A more specific rule, apparently Japanese assembled Toyotas can have suffixs on the vin
	// The first character represents the country of origin.
	// The second and third character(s) represents the manufacturer.
	
	if firstChar = "J" and secondCharacter = "T" then
		// So first character 'J' = Japan, second character 'T' = Toyota 
		// return 17 characters starting at the first character
		return self.scannedValue[1:17];
	endif;
	
	//08 Aug 2016	NDL	TFS 2504 - Additional VIN numbers
	if length = 18 and firstChar = "M" and secondCharacter = "R" and thirdCharacter = "1" then
		//"MR1" - possibly means Thailand Toyota... anyway examples seem to have an additional suffix.
		// return 17 characters starting at the first character
		return self.scannedValue[1:17];
	endif;
	
	//Other specific rules should be implemented immediately under this comment...
	
	
	
	
	// Finally if no other rules have been invoked
	// do the following.
	
	if self.isAlternateId then
		// We are using the value as an 'alternate id', these are allowed to be a maximum of 30
		// characters in length, so if its longer, truncate it to a max of 30.
		return self.scannedValue[1:30];
	else
		// We are using the value as a 'cargo id', (the default behaviour) these are a maximum of 20
		// characters in length, so if its longer, truncate it to a max of 20.
		return self.scannedValue[1:20];
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
