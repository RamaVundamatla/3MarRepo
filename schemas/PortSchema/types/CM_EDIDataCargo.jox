    <JadeMethod name="doesReceiptTransportModeExist" id="2cf9c32c-a782-48be-bd52-150b7c3ed283">
        <source>doesReceiptTransportModeExist(_receiptTransportMode: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
6 April 2023	navra1	Initial creation for 57263

*/

vars
	ediTi: CM_EDITrackedItem;
begin
	foreach ediTi in self.allEDITrackedItems do
		if ediTi.isKindOf(CM_EDICargoTI) then
			if app.transportModeENumToString(ediTi.CM_EDICargoTI.receiptTransportMode).toUpper().compareEql(_receiptTransportMode.toUpper(), true, false, null) then
				return true;
			endif;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <Parameter name="_receiptTransportMode" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="f496bea3-e705-45c8-8897-67d6137ec572">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
----------   ----------  --------------------------------------------------
Created:	20 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	str		: String;
begin
	if _attrName = ETRow_Site then
		return app.siteEnumToString(self.createToSite);
	endif;
	
	return inheritMethod(_attrName, _short);
	

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
