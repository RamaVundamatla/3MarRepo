    <JadeMethod name="setForCreate" id="f2c8955b-5f82-4bb6-811e-af2bc4456b1e">
        <updating/>
        <source>setForCreate( _pxyWoDDtl : CM_WorkOrderDtl io; _realWorkOrder : CM_WorkOrder) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 Jul 2009	cnwrd1	Initial creation
28 Aug 2009	cnwmd1	Added dyna dict to ensure taskId is unique.  Previously was generating id's that already exist. This is because tasks can freely be added/deleted/order changed.
24 Jan 2023	navma1  ChangeRequest 56141:[56147] EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
18 Jan 2023	navcs2	ChangeRequest 56633:[56211] EUP - VAS Work Order Transactions
14 Mar 2023 navma1  ChangeRequest 56633:[56211] EUP - VAS Work Order Transactions
16/11/2023	navcs2	ChangeRequest 60866: EUP | Manifest - Single Work Order per transport

*/

vars
	workOrder  		: CM_WorkOrder;
	int 			: Integer;
	uniqueSuffix, 
	uniquePrefix 	: String;
	dynaDict 		: DynaDictionary;
	unique 			: Boolean;
	terminal        : CM_Terminal;
	wotran : CM_WOTransaction;
begin

	workOrder := _realWorkOrder;
	
	if workOrder = null then
		app.raiseUnexpectedProgramError(self.class.name, method.name, "Parent is null, should contain a WorkOrder");
	endif;
	
	terminal		:= workOrder.myTerminal;	//14.03.2023 navma1 #56633:[56211]
	self.myParent	:= workOrder; 				//epr TFS 39166 14/6/18
	uniquePrefix 	:= workOrder.id &amp; "-";
	
	create dynaDict transient;
	dynaDict.setMembership(CM_WorkOrderDtl);
	dynaDict.addMemberKey(CM_WorkOrderDtl::taskID.name, false, true);
	dynaDict.endKeys(true);
	_pxyWoDDtl.myParent.allWoDtls.copy(dynaDict);
	
	//24.01.2023 navma1 #56141:[56147]
	if workOrder.allWoDtls.isEmpty then
		int := workOrder.allWoDtls.size()	+1;
	else 
		int := workOrder.allWoDtls.size();
	endif;
	
	
	while not unique do
		uniqueSuffix := terminal.getNextSuffix(int);										//14.03.2023 navma1  56633:[56211]
		unique 		 := dynaDict.getAtKey(uniquePrefix &amp; uniqueSuffix) = null;
		int := int + 1;
	endwhile;
	
	if _pxyWoDDtl.taskID &lt;&gt; null then 														// 16/11/2023	navcs2	ChangeRequest 60866
		self.taskID :=_pxyWoDDtl.taskID;													// 16/11/2023	navcs2	ChangeRequest 60866
	else																					// 16/11/2023	navcs2	ChangeRequest 60866
		self.taskID 	  := uniquePrefix &amp; uniqueSuffix;	
		_pxyWoDDtl.taskID := self.taskID;
	endif;
	
	self.setForUpdate( _pxyWoDDtl );
	
	if not self.isKindOf(CM_WorkOrderVoyageDtl) then 	// 18.01.2023 navcs2 #56633:[56211]	//14.03.2023 navma1  56633:[56211]
		wotran := self.createWOTransaction(TRANS_CREATED, null, null);
		/* // ### TFS DEFECT 59150 17JUL2023 NAVAB1
		// ### TFS BUG58790 23JUN2023 NAVAB1
		if wotran &lt;&gt; null then
			wotran.createCharge();
		endif;
		*/
	endif;
	
	//jlier1 29/5/25 MTN-34591 
	self.causeTerminalEvent(Event_WODtl_Create);
	
epilog
	delete dynaDict;
end;</source>
        <Parameter name="_pxyWoDDtl" type="CM_WorkOrderDtl" usage="io"/>
        <Parameter name="_realWorkOrder" type="CM_WorkOrder"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="c99909be-ae43-4b0c-af15-17c3c5fddd79">
        <updating/>
        <source>setForUpdate( _pxyWoDDtl : CM_WorkOrderDtl) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 Jul 2009	cnwrd1	Initial creation
29 Jun 2023	navdap1	TFS 58813 EUP Manifest Instructions and Work Orders
*/

vars
	instructions, realInstructions : CM_InstructionsIssued;		// TFS 58813
	isNew : Boolean;											// TFS 58813

begin
	self.autoQueueTask := _pxyWoDDtl.autoQueueTask;
	self.requiredByDT := _pxyWoDDtl.requiredByDT;
	self.startByDT := _pxyWoDDtl.startByDT;
	
	// TFS 58813 start
	if self.myInstructions &lt;&gt; null and _pxyWoDDtl.myInstructions = null then
		realInstructions := self.myInstructions;
		delete realInstructions;
		
	elseif _pxyWoDDtl.myInstructions &lt;&gt; null then
		if self.myInstructions = null then
			create instructions transient;
			create realInstructions persistent;
			isNew := true;
		else
			instructions := self.myInstructions.pxyCreateUpdateProxy().CM_InstructionsIssued;
			realInstructions := self.myInstructions;
		endif;
		
		instructions.setProxy(	_pxyWoDDtl.myInstructions.internalInstructions,
								_pxyWoDDtl.myInstructions.externalInstruction,
								_pxyWoDDtl.myInstructions.myInstructionType,
								self	);
		
		if isNew then
			realInstructions.setForCreate(instructions);
		else
			realInstructions.setForUpdate(instructions);
		endif;
	endif;
	// TFS 58813 end
	
epilog
	delete instructions;	// TFS 58813
end;</source>
        <Parameter name="_pxyWoDDtl" type="CM_WorkOrderDtl"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateCompleted" id="43e96d0c-1d39-4994-bcfe-cec4a8c37a8c">
