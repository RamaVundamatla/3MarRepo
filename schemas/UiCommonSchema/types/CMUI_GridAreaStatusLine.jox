//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	create self.myFrameDisplayMode transient;
	
	//cnwmc5 - PAR 31051
	if not self.isInPainter then
		if not app.isUsingSkin then
			self.myFrameDisplayMode.bevelInner := Frame.Bevel_Inset;
			self.myFrameDisplayMode.bevelInnerWidth := 1;
			self.myFrameDisplayMode.bevelOuter := Frame.Bevel_None; //Bevel_Raised;
			self.myFrameDisplayMode.bevelOuterWidth := 0;
			self.myFrameDisplayMode.borderStyle := Table.BorderStyle_None;
			self.myFrameDisplayMode.boundaryWidth := 2;
			self.myFrameDisplayMode.backColor := self.myFrameDisplayMode.boundaryColor;
		endif;
	endif;
	
	self.myFrameDisplayMode.myParent := self;
	
	self.myFrameDisplayMode.caption := null;
	self.myFrameDisplayMode.enabled := true;

	self.myFrameDisplayMode.parent := self;
	self.form.addControl(self.myFrameDisplayMode);

end;</source>
