    <JadeMethod name="autoPlan" id="25951d50-d884-46bd-a77d-5366f6364ba9">
        <updating/>
        <source>autoPlan(obj : CMIF_AutoMovePlan input) updating;
// ---------------------------------------------------------------------------
// Created:		May 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.myTerminalArea.autoPlan(obj,self);
end;</source>
        <Parameter name="obj" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
    <JadeMethod name="autoPlanRequest" id="62bb0ae5-0790-4b00-8379-c90b6f6bf8c1">
        <source>autoPlanRequest(obj : CMIF_AutoMovePlan input);
//This is as low as we go. We are looking for a valid TI (or location) to satisfy
//the current request
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

vars
	lc	:CM_LocationsController;
	locnId	:	String;
begin

	//---------------
	//Iterate through all the LC's in this list, test each one
	//---------------
	if self.allLocationControllers.isEmpty then
		//obj.addLogEntry("No Locations to search in Attribute Plan: " &amp; attributePlan.id, IsForLogging); //- cnwmd1, Par 20524
		obj.addLogEntry(app.getErrorString1(Locatio_search_attribu_plan,attributePlan.id), IsForLogging, Locatio_search_attribu_plan);
	  return;
  endif;
	foreach lc in self.allLocationControllers do
		locnId := lc.getFullId;
		//obj.addLogEntry("Testing : " &amp; locnId , IsForLogging); //- cnwmd1, Par 20524
		obj.addLogEntry(app.getErrorString1(Testing, locnId) , IsForLogging, Testing);

		//------------
 		//Set lc as a candidate, methods nuke it if it aint!
		//------------
		obj.updateController(lc);
		//------------
 		//Get LC to do work
		//------------
	 	lc.testAutoPlanRequest(obj);

		if obj.getController &lt;&gt; null then
			//-------------
			//FOUND 1!!!!
			//-------------
			return;
		endif;
//		unlock(lc);
 	endforeach;
//epilog
//	unlock(lc);
end;</source>
        <Parameter name="obj" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
    <JadeMethod name="clone" id="c1dad4d5-a5cf-4691-ab8e-0ae290c1cf12">
        <source>clone() : CM_AttributeArea;
//Copies the object
vars
	aa	:	CM_AttributeArea;
begin
	//------------------
	//Clone it
	//------------------
	aa := cloneSelf(false);	//This copies the restrictedTerminalArea id string.
	//------------------
	//Copy refs, these do NOT know about us
	//------------------
	self.allLocationControllers.copy(aa.allLocationControllers);
	aa.myTerminalArea := self.myTerminalArea;
	return aa;
end;</source>
        <ReturnType type="CM_AttributeArea"/>
    </JadeMethod>
    <JadeMethod name="myTerminal" id="c4f78b24-0f86-4ce3-b480-4dd3410d8171">
        <methodInvocation>mapping</methodInvocation>
        <source>myTerminal(set: Boolean; _value: CM_Terminal io) mapping;
// ---------------------------------------------------------------------------
// Created:     20 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	if self.myTerminalArea = null then
		return;
	endif;
	
	_value := self.myTerminalArea.myTerminal;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_Terminal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="823e5e96-781c-494e-a28f-6d13082cd2b8">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ParatheProxyters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------

vars
	theProxy : SelfType;
	completedOK		: Boolean;
begin
	theProxy :=  inheritMethod();

	self.allLocationControllers.copy(theProxy.allLocationControllers);

	theProxy.myTerminalArea := self.myTerminalArea;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return theProxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete theProxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setAttributeLocations" id="49d77828-7dc0-46a4-8ef7-1c01b9d49929">
        <updating/>
        <source>setAttributeLocations(lcs : CM_LCArray) updating;
/*
 ------------------------------------------------------------------------
Created:			23 September 2002 by cnwdwq1
Purpose:			Sets the locations controllers array in the order they wi sh to set them in.
							Basically I re-set the collection in the passed in order.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	//--------------------
	//Clear first
	//--------------------
	self.allLocationControllers.clear;
	if lcs.isEmpty then
		return;
	endif;
	//--------------------
	//add them in.
	//--------------------
	lcs.copy(self.allLocationControllers);
end;</source>
        <Parameter name="lcs" type="CM_LCArray"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="3f7ad581-95a5-4c72-be2e-77b812def896">
        <updating/>
        <source>setForCreate(_theProxy : CM_AttributeArea) updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.setAttributeLocations(_theProxy.allLocationControllers);
	self.myTerminalArea := _theProxy.myTerminalArea;
	restrictedTermAreaId := self.myTerminalArea.id;
end;</source>
        <Parameter name="_theProxy" type="CM_AttributeArea"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="a6fce54f-2795-4041-ad18-9c0913d79794">
        <updating/>
        <source>setForUpdate(_theProxy : CM_AttributeArea) updating;
/*
 ------------------------------------------------------------------------
Created:			20 September 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	self.restrictedTermAreaId 	:= _theProxy.myTerminalArea.id;
	self.myTerminalArea 		:= _theProxy.myTerminalArea;
	self.setAttributeLocations(_theProxy.allLocationControllers);
end;</source>
        <Parameter name="_theProxy" type="CM_AttributeArea"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="d513e5bd-ed10-46ac-bffa-cd1a0dbf933b">
        <updating/>
        <source>setProxy(_myTerminalArea : CM_TerminalArea; _lcs : CM_LCArray) updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	self.restrictedTermAreaId	:= _myTerminalArea.id;
	self.myTerminalArea			:= _myTerminalArea;
	self.setAttributeLocations(_lcs);

end;</source>
        <Parameter name="_myTerminalArea" type="CM_TerminalArea"/>
        <Parameter name="_lcs" type="CM_LCArray"/>
    </JadeMethod>
    <JadeMethod name="setTerminalAreaId" id="089f179c-be27-491e-a14c-e9e5269ff8a7">
        <updating/>
        <source>setTerminalAreaId(_id : String) updating;
// ---------------------------------------------------------------------------
// Created:     24 March 2003 by cnwrs2
