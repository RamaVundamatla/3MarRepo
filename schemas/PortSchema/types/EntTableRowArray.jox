    <JadeMethod name="getEntRowNamed" id="dfa1b7ec-de94-4664-8574-0fb084eb8936">
        <source>getEntRowNamed( _name : String ):EntTableRow;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2013	cnwndl1	Initial creation	Par 32894

*/

vars

	iter : Iterator;
	row : EntTableRow;

begin

	iter := self.createIterator;
	while iter.next( row ) do
		if row.name = _name then
			return row;
		endif;
	endwhile;
	
	return null;

epilog

	delete iter;

end;
</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="EntTableRow"/>
    </JadeMethod>
