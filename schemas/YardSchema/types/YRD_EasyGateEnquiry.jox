    <JadeMethod name="sysNotify" id="239f62db-617e-465a-8d9a-5f4776811ca3">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 February 2010	cnwrd1	Initial creation

*/

vars

begin


	if  theObject.isKindOf( CM_InterTerminalMove )  then	
	
		if eventType = Object_Update_Event then
			self.tblDataSysNotifyUpdate(eventType, theObject, eventTag);
	
		elseif eventType = Object_Create_Event then
			self.tblDataSysNotifyCreate(eventType, theObject, eventTag);
	
		elseif eventType = Object_Delete_Event then
			self.tblDataSysNotifyDelete(eventType, theObject, eventTag);
		endif;
	endif;

epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblDataSysNotifyCreate" id="cc8b0ee5-5d1b-4319-9766-2cd87308328e">
        <updating/>
        <source>tblDataSysNotifyCreate(_eventType: Integer; _theObject: Object; _eventTag: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 February 2010	cnwrd1	Initial creation

*/

vars

	theTable : CM_DataTable;	
	include : Boolean;
	theRow	: Integer;
	theITM	: CM_InterTerminalMove;
begin
	include := false;

	if _theObject.isKindOf( CM_InterTerminalMove) then
		include := self.includeObject(_theObject.CM_InterTerminalMove);
		theITM := _theObject.CM_InterTerminalMove;
	else
		return;
	endif;


	if not include then
		return;
	endif;
	
	if theITM.mySourceTerminal = self.myTerminal or theITM.myTargetTerminal = self.myTerminal then
	
		if 	(self.chkIncIncoming.value = true and theITM.mySourceTerminal = self.myTerminal) or
			(self.chkIncOutgoing.value = true and theITM.myTargetTerminal = self.myTerminal) then

			if (not self.tblData.findObjectInRow(theITM, theRow)) then		
				self.addRowToTable( theITM , self.tblData);
				self.setButtonState;
			endif;

		endif;

	endif;

epilog

end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblDataSysNotifyDelete" id="c1dcc100-54b8-4569-985a-a2fb49700ccf">
        <updating/>
        <source>tblDataSysNotifyDelete(_eventType: Integer; _theObject: Object; _eventTag: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 February 2010	cnwrd1	Initial creation

*/

vars

begin
	self.removeFromTable(_theObject.CM_Object);
	self.myCurrentInterTerminalMove := null;
	self.setButtonState;
epilog

end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblDataSysNotifyUpdate" id="b6a1bb91-8bd3-470b-9477-d92f06975ea3">
        <updating/>
        <source>tblDataSysNotifyUpdate(_eventType: Integer; _theObject: Object; _eventTag: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 February 2010	cnwrd1	Initial creation

*/

vars
	interTermMove	: CM_InterTerminalMove;
	theRow : Integer;
begin
	// somethings been update we need to find if we have it in the table and update.
	
	if CM_InterTerminalMove.hasInstance(_theObject) then
		interTermMove := _theObject.CM_InterTerminalMove;
	else
		return;
	endif;

	self.tblData.findObjectInRow(interTermMove, theRow);

	if theRow &gt; 0 then		
		self.tblData.accessCell(theRow, 1).text := interTermMove.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);			
		self.setButtonState;
	endif;

epilog

end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="4a3bbb93-a3a5-4f32-8e2e-f01ab97e2d04">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014177, locale);
	btnLoadTruck.translateBubbleHelp(Xlat_0014644, locale);
	btnLoadTruck.translateCaption(Xlat_0014179, locale);
	btnReturnTruck.translateBubbleHelp(Xlat_0014645, locale);
	btnReturnTruck.translateCaption(Xlat_0014181, locale);
	btnReturnYard.translateBubbleHelp(Xlat_0014646, locale);
	btnReturnYard.translateCaption(Xlat_0014183, locale);
	btnUnloadTruck.translateBubbleHelp(Xlat_0014647, locale);
	btnUnloadTruck.translateCaption(Xlat_0014185, locale);
	chkIncIncoming.translateCaption(Xlat_0014187, locale);
	chkIncOutgoing.translateCaption(Xlat_0014188, locale);
	lCargoID.translateCaption(Xlat_0014648, locale);
	lOperator.translateCaption(Xlat_0014649, locale);
	lPickupFrom.translateCaption(Xlat_0014650, locale);
	lPickupFrom_1.translateCaption(Xlat_0014651, locale);
	lVehicleID.translateCaption(Xlat_0014652, locale);
	mnuCargoTasks.translateCaption(Xlat_0014194, locale);
	mnuLoadTruck.translateCaption(Xlat_0014195, locale);
	mnuReturnTruck.translateCaption(Xlat_0014196, locale);
	mnuReturnYard.translateCaption(Xlat_0014197, locale);
	mnuUnloadTruck.translateCaption(Xlat_0014198, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="validateSelections" id="ff78325d-5b72-4f69-91c2-f35351e0fe1c">
        <updating/>
        <source>validateSelections() : Boolean updating;
/*
Purpose:			Check Query Parameters are reasonable

Parameters:			

Return Value:		False if not reasonable, True if OK

Date		Who		Reason
16 February 2010	conkc1	Initial creation
*/
vars
	startDate : Date;
	endDate   : Date;
	today     : Date;
begin
	today := self.systemToLocalTime(app.actualTimeServer()).Date;	// 20/4/16 cnwmp6 TFS 488 - Multi timezone changes
	vFromDate := null;
	vToDate   := null;

	if self.dTpickupStart.isValid or self.dTpickupStart.isEmpty = true then
		startDate := self.dTpickupStart.getTextAsDate;
	else
		app.msgBox(app.getErrorString(Date_from_incorrect), app.getErrorString(Query_parameters), MsgBox_OK_Only);
		self.dTpickupStart.setFocus;
		return false;
	endif;

	if self.dTpickupEnd.isValid or self.dTpickupEnd.isEmpty = true then
		endDate := self.dTpickupEnd.getTextAsDate;
	else
		app.msgBox(app.getErrorString(DateTo_incorrect), app.getErrorString(Query_parameters), MsgBox_OK_Only);
		self.dTpickupEnd.setFocus;
		return false;
	endif;
	
	if endDate = null then
		endDate := today;
	endif;

	if startDate &gt; endDate then
		app.msgBox(app.getErrorString(DateFromTo), app.getErrorString(Query_parameters), MsgBox_OK_Only);
		self.dTpickupStart.setFocus;
		return false;
	endif;

	vFromDate := startDate;
	vToDate   := endDate;
	
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
