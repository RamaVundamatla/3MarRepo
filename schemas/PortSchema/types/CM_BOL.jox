    <JadeMethod name="getDisplayStringForAttribute" id="d1c9437f-dc77-4e61-b942-fe47d78c81ed">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------------------
//Created: 13 May 2002 By: cnwgd1
//--------------------------------------------------------------
// 24/02/2010	cnwcs5	par 22193 - iso group
// 27/05/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
// 25/11/2013	cnwdap1	PAR #33019 CCMS DPH 2285 New BOL Fields
// 03/06/2020   cnwma1 ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
// 10/06/2022	navdap1	TFS #53013 Booking and Cargo sub type in Road Operatinos column organiser
// 20/06/2022	navdap1	TFS 53362 EUP Master Data interface customers between TOS and ERP
// 13/07/2022   navmv20 ChangeRequest 54095: EUP - Outturn Remarks on BOL
// 28/07/2022 	navvt20 Bug 54199: EUP - Tables with Operator/Stevedore not adhering to the configuration
// 28 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
// 28/11/2022	jlizm1	TFS 55280 Harmonized System Codes
// 27/09/2023	navkc1	CR 60428 Task 60701: UI - Cargo Review Option in Transport UI
vars
	str  : String;
	type : String;								
	voy  : CM_Voyage;
	iConsign : CM_ConsigneeConsignor;
	dtl	 : CM_BOLDtl;
	
begin
	
	if _attrName = ETRow_CargoType or 
	   _attrName = ETRow_CargoTypeEntry then //12/01/2010 cnwdz2 21836
		return self.bolTypeDesc;
	elseif _attrName = ETRow_Info then
		return self.getInfoStr(false);
	elseif _attrName = ETRow_TargetLocation then // AKB testing 761 PAR 16224
		return "";
	elseif _attrName = ETRow_CargoTypeDescr then // AKB testing 761 PAR 16224
		return self.cargoBOLTypeDescr;
	elseif _attrName = ETRow_Commodity then
		return self.cargoBOLTypeDescr;
	elseif _attrName.cnContains(ETRow_DebtorTypes) then //PAR 18008  
		return null;
	elseif _attrName = ETRow_Stevedore then
		return null;
	elseif _attrName = ETRow_Voyage then
		return null;		
	elseif _attrName = ETRow_QuantityBBLK then
		return self.getTotalTIQty().String;		
	elseif _attrName = ETRow_TiWeight then
		return self.getTotalTIWeight().String;
	elseif _attrName = ETRow_TiVolume then
		return self.getTotalTIVolume().String;
	elseif _attrName = ETRow_OnSite then
		return self.getNumItemsForSite(TI_SITE_ONSITE).String;
	elseif _attrName = ETRow_OnShip then
		return self.getNumItemsForSite(TI_SITE_ONSHIP).String;
	elseif _attrName = ETRow_MyManifest then
		if self.myManifest &lt;&gt; null then
			return self.myManifest.id;		
		else
			return null;
		endif;
	elseif _attrName = ETRow_Consignee or
	   _attrName = ETRow_ConsigneeCode then
	   	//TFS#53362 navsp1 20Jun2022
		if app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean then  
			iConsign := app.myRoot.allConsigneeConsignors[self.consignee];
			if iConsign &lt;&gt; null then
				return iConsign.description;
			endif;
		endif;
		return self.consignee;
	elseif _attrName = ETRow_Consignor or
	   _attrName = ETRow_ConsignorCode or
	   _attrName = ETRow_ConsignorTop then
	   	//TFS#53362 navsp1 20Jun2022
		if app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean then  
			iConsign := app.myRoot.allConsigneeConsignors[self.consignor];
			if iConsign &lt;&gt; null then
				return iConsign.description;
			endif;
		endif;
		return self.consignor;	
	elseif _attrName = ETRow_Date then
		return self.systemToLocalTime(self.dateTime).date.shortFormatJMT();	// 19/04/2016 cnwmp6 TFS 488 - Multi timezone support
		
	elseif _attrName = ETRow_DocketError then		///ccms 1110 begins		
		return null;	
	elseif _attrName = ETRow_DriversPieceCount then		
		return null;	
	elseif _attrName = ETRow_PieceCountError then		
		return null;					///ccms 1110 ends											
	elseif _attrName = ETRow_Id then
		return self.number;
	elseif _attrName = ETRow_Info then
		return null;
	elseif _attrName = ETRow_QuantityTotal then
		return self.getQuantitiesInCargoTotal().String;
	elseif _attrName = ETRow_JobNumber or
		_attrName = ETRow_LocationId or
	   _attrName = ETRow_MachineId or
		_attrName = ETRow_DwellTime then
		if self.myYardJob &lt;&gt; null then
			return self.myYardJob.getDisplayStringForAttribute(_attrName, _short);			
		else
			return null;
		endif;
	elseif _attrName = ETRow_RegNumber then
		return self.vehicle;
	elseif _attrName = ETRow_RadioTelemetry then
		if self.myPlannedLocation &lt;&gt; null then
			return 'P';
		else
			return null;
		endif;		
	elseif _attrName = ETRow_Supplier then
		if self.myOperator &lt;&gt; null then
			return self.myOperator.code;
		endif;
		return null;
	elseif _attrName = ETRow_OperatorDescr then
		return self.getOperatorDescription;		
	elseif _attrName = ETRow_DocketNumber or
		_attrName = ETRow_BolNumber then
		return self.number;
	elseif _attrName = ETRow_OperatorCode then
		//return self.myOperator.code;								//28.07.2022 navvt20 TFS 54199
		
		// START 28.07.2022 navvt20 TFS 54199
		if app.myRoot.getConfig(ComboByNameOperator).Boolean and self.myOperator &lt;&gt; null then    
            return self.myOperator.description;                                                    
        endif;                                                                                   
        return self.myOperator.code;
		// END 28.07.2022 navvt20 TFS 54199
	elseif _attrName = ETRow_MyOperator then						// TFS 53362
		if app.myRoot.getConfig(ComboByNameOperator).Boolean then	// TFS 53362
			return self.myOperator.description;						// TFS 53362
		else														// TFS 53362
			return self.myOperator.code;
		endif;													    // TFS 53362
	elseif _attrName = ETRow_Id then
		return null;		
	elseif _attrName = ETRow_HandlingContractor1 then
		return self.handlingContractor1Code;
	elseif _attrName = ETRow_HandlingContractor2 then
		return self.handlingContractor2Code;
	elseif _attrName = ETRow_HandlingSubContractor1 then
		return self.handlingSubContractor1Code;
	elseif _attrName = ETRow_Location then
		if self.myPlannedLocation &lt;&gt; null then
			return self.myPlannedLocation.getID;
		else
			return null;
		endif;
	elseif _attrName = ETRow_IsoType or
		_attrName = ETRow_IsoGroup then	// 24/02/2010 cnwcs5 par 22193
		return 'undefined';
	elseif _attrName = ETRow_IsReleaseDocket then
		if self.isReleaseDocket then
			return 'Release';
		else
			return 'Receipt';
		endif;	
	elseif _attrName = ETRow_NoLogs						// cnwmc5 - 16 April 2014 - CCMS 2352
		or _attrName = ETRow_Items						// cnwmc5 - 16 April 2014 - CCMS 2352
		or _attrName = ETRow_BolItems then				// cnwmc5 - 16 April 2014 - CCMS 2352
		return self.numItems.asStringJMT;				
	elseif _attrName = ETRow_Status then
		return 'undefined';
	elseif _attrName = ETRow_LogData then
		return self.getProductCode();
	elseif _attrName = ETRow_MatchFound then
		return app.getYesNo(self.matchTime.isValid);	
	elseif _attrName = ETRow_MyTerminal  or
	       _attrName = ETRow_MyReleaseTerminal then
		if self.myTerminal &lt;&gt; null then
			return self.myTerminal.name;
		else
			return null;
		endif;
	elseif _attrName = ETRow_MyJobReceive then
		if self.myYardJob &lt;&gt; null then
			return self.myYardJob.jobId;
		else
			return null;
		endif;

	elseif _attrName = ETRow_MyProduct then
		if self.myProduct &lt;&gt; null then 
			
			return self.myProduct.description;
		else
			if self.myManifest &lt;&gt; null // is GC Voyage so check first ti product
			and self.allTrackedItems.isNotEmpty and
			self.allTrackedItems.first().myProduct &lt;&gt; null then 
				return self.allTrackedItems.first().myProduct.description; 
			endif;
			return null;
		endif;
				
	elseif _attrName = ETRow_ImexStatus then
		return 'undefined';
	elseif _attrName = ETRow_IsoType then
		return 'undefined';
	elseif _attrName = ETRow_QueuedLocnId or
		   _attrName = ETRow_PlannedLocnId then
		return self.getPlannedLocnDesc();
	elseif _attrName = ETRow_SssBOLNumber then
		return self.number;		
	elseif _attrName = ETRow_SssOpt then
		return 'true';		
	elseif _attrName = ETRow_Status then
		return app.bolStatusEnumToString(self.status);
		
	elseif _attrName = ETRow_SssDateTime then
		return self.systemToLocalTime(self.dateTime).shortCurrentLocaleFormat();	// 19/04/2016 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_SssNumItems then
		return self.numTIs.String;
	elseif _attrName = ETRow_SssLOFile then
		return self.remarks;
	elseif _attrName = ETRow_MySubTerminal then
		if self.mySubTerminal = null then
			return null;
		else
			return self.mySubTerminal.code;
		endif;
	elseif _attrName = ETRow_TopID then
		return self.number;
	elseif _attrName = ETRow_TransportMode then
		return self.getTransModeDescr();
	elseif _attrName = ETRow_VoyageCode then
		return null;																	
	elseif _attrName = ETRow_WeighbridgeNo then
		if self.myLogDocketData &lt;&gt; null then
			return self.myLogDocketData.docketNumberWeigh;
		else
			return 'No weighbridge found';
		endif;
	elseif _attrName = ETRow_OutturnRemarks then // 13/07/2022 navmv20 Tfs 54095 
	   return self.getOutturnRemarks();	// 13/07/2022 navmv20 Tfs 54095
	elseif _attrName = ETRow_HsCode 
		or _attrName = ETRow_HsCodeDescription then				// TFS 55280
		dtl := self.allBOLDtls.first;
		if dtl &lt;&gt; null then
			return dtl.getDisplayStringForAttribute(_attrName, _short);
		endif;
		return null;
	endif; 
	
	
	if _attrName = ETRow_Activity or
	   _attrName = ETRow_Backload or
	   _attrName = ETRow_ChhSupplier or
	   _attrName = ETRow_Customer or
	   _attrName = ETRow_FellDate or
	   _attrName = ETRow_GangNumber or
	   _attrName = ETRow_IsHazardous or // AKB2005MAR added during testing
	   _attrName = ETRow_JasScaled or
	   _attrName = ETRow_JasVolume or
	   _attrName = ETRow_LengthCode or
	   _attrName = ETRow_LengthRandom or		   
	   _attrName = ETRow_LoaderNumber or
	   _attrName = ETRow_LogGradeCode or
	   _attrName = ETRow_LogSpeciesCode or
	   _attrName = ETRow_LogTreatmentCode or
	   _attrName = ETRow_LogTypeCode or
	   _attrName = ETRow_LogLocation or
	   _attrName = ETRow_Nightshift or
	   _attrName = ETRow_NumberOfLifts or
	   _attrName = ETRow_NumberTicketed or
	   _attrName = ETRow_PercentScaled or
	   _attrName = ETRow_PickupPoint or
	   _attrName = ETRow_ScalerCode or
	   _attrName = ETRow_Specifications or
	   _attrName = ETRow_TicketedAll or
	   _attrName = ETRow_Weighbridge then
		if self.myExtension &lt;&gt; null then
			return self.myExtension.getDisplayStringForAttribute(_attrName, _short);
		else
			return null;
		endif;
	elseif _attrName = ETRow_StatusDesc then				//+cnwml2 MSL CCMS 1071
		return self.statusDescription;
	elseif _attrName = ETRow_Reconciled then				//+cnwml2 MSL CCMS 1071
		if self.reconciledDate &lt;&gt; null then
			return "Yes";
		else
			return "No";
		endif;
	elseif _attrName = ETRow_NumOnsiteTIs then				//+cnwml2 MSL CCMS 1071
		return self.allTrackedItems.size.asStringJMT();
	elseif _attrName = ETRow_LoadPort then					//
		return self.loadPortCode;
	elseif _attrName = ETRow_Mark then
		return null;
	elseif _attrName = ETRow_Quantity then
		return self.allTrackedItems.size.asStringJMT();
	elseif _attrName = ETRow_TotalWeight then
		return self.weightTotal.asStringJMT();
	elseif _attrName = ETRow_Received then
		return self.getNumReceived.asStringJMT;
	elseif _attrName = ETRow_Released then
		return self.getNumReleased.asStringJMT;
		
	elseif _attrName = ETRow_ClientRef1 then										// PAR #33019
		return self.clientRef1;														// PAR #33019
	elseif _attrName = ETRow_ClientRef2 then										// PAR #33019
		return self.clientRef2;														// PAR #33019
	elseif _attrName = ETRow_TotalQuantity then										// cnwmc5 - 11 April 2014 - PAR 33958
		return self.numItems.asStringJMT;											// cnwmc5 - 11 April 2014 - PAR 33958
	elseif _attrName = ETRow_Stops then												// cnwmc5 - 11 April 2014 - CCMS 2352
		return self.allStops.size().asStringJMT();									// cnwmc5 - 11 April 2014 - CCMS 2352
	elseif _attrName = ETRow_CargoItems then										// cnwmc5 - 16 April 2014 - CCMS 2352
		return self.getTotalCargoItems().asStringJMT();								// cnwmc5 - 16 April 2014 - CCMS 2352		//cnwmc5 - 20 May 2014 - PAR 34185
	elseif  _attrName = ETRow_VoyageInward then
		voy :=self.getMyVoyage;
		if voy &lt;&gt; null then
			return voy.inwardCode;
		endif;
		return null;
	elseif  _attrName = ETRow_VoyageGroupCode then                                 //03/06/2020 cnwma1 Bug #49400
		return self.getVoyageGroupCode();
		
	// TFS 53013 start
	elseif _attrName = ETRow_Booking then
		return null;
	elseif _attrName = ETRow_CargoSubType then
		return null;
	// TFS 53013 end
	// Start 20.10.2022 navtnr20 TFS 54967
	elseif _attrName = ETRow_InstructionInternal then		
		if self.myInstructions &lt;&gt; null then
			return self.myInstructions.internalInstructions.formatWithEllipsis(1,50,true);
		endif;
		return null;
	elseif _attrName = ETRow_InstructionExternal then
		if self.myInstructions &lt;&gt; null then
			return self.myInstructions.externalInstruction.formatWithEllipsis(1,50,true);
		endif;
		return null;
	elseif _attrName = ETRow_InstructionCode then
		if self.myInstructions &lt;&gt; null then
			return self.myInstructions.getInstructionCode();
		endif;
		return null;
	elseif _attrName = ETRow_InstructionDesc then		
		if self.myInstructions &lt;&gt; null then
			return self.myInstructions.getInstructionDesc();
		endif;
		return null;
	// End 20.10.2022 navtnr20 TFS 54967
	elseif _attrName = ETRow_CustomStatus then
		return self.getCustomStatus(); //27/09/2023	navkc1	CR 60428 Task 60701
	endif;
	
	if _attrName.isMeasurementType then												// PAR #31155
		_attrName.getRowNameMeasureType(str, type);									// PAR #31155
		return self.getMeasurementStringForAttrib(str, type, _short);				// PAR #31155
	endif;																			// PAR #31155
	
	return inheritMethod(_attrName, _short);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
