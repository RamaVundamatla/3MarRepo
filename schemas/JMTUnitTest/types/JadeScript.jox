    <JadeMethod name="rsFreeUpPins" id="63f7268d-1a84-413a-910c-7d964f30501a">
        <source>rsFreeUpPins();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 November 2023	jlirs1	Initial creation

*/

vars
	pin : CM_PinNo;
	term : CM_Terminal;
	objArray : CM_ObjectArray;
	removeTIs : CM_TISet;
	ti : CM_TrackedItem;
	count : Integer;
	aTime : TimeStamp;
	object : Object;
begin
	term := app.myRoot.getTerminalByName("Unit Test");
	create objArray transient;
	create removeTIs transient;
	foreach pin in term.allPinNos do
		beginTransaction;
		if pin.canDelete(removeTIs) then
			objArray.add(pin);
			if not removeTIs.isEmpty then
				foreach ti in removeTIs do
					write ti.String&amp;"--"&amp;ti.creationTime.String;
//					ti.inspect;
				endforeach;
			endif;
		endif;
		abortTransaction;
		if pin.allItems.isEmpty then
			if pin.creationTime &lt; aTime then
				aTime := pin.creationTime;
			endif;
			count := count + 1;
		endif;
	endforeach;
	foreach object in objArray do
//		write object.creationTime.date.year.String;
//		break;
		if object.creationTime.date.year &lt; 2023 then
			write object.String&amp;' '&amp;object.creationTime.date.year.String;
			beginTransaction;
			delete object;
			commitTransaction;
		endif;
	endforeach;
	
	write ' allPins used='&amp;term.allPinNos.size.String&amp;' toDelete='&amp;objArray.size.String&amp;' not used='&amp;count.String&amp;' oldest='&amp;aTime.String;
epilog
	delete objArray;
	delete removeTIs;
end;</source>
    </JadeMethod>
