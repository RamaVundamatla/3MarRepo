    <JadeMethod name="assignValueSpecial" id="1e4f08aa-9345-44d0-b6d3-1fca5fb954ca">
        <updating/>
        <source>assignValueSpecial(_propName: String; _processedValue: String; _xlationOperator: CM_Operator): Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
/* ----------	--------	-----------------------------------------------------
  28/11/2013	cnwdap1		Initial creation PAR #33019 CCMS DPH 2285 New BOL Fields
  04/05/2016	cnwdap1		TFS #1699 Verified Gross Mass changes
  20/05/2022	jlika1		TFS 53316 - EUP - GEN - Additional Dimensions For Cargo - PortSchema
  08 Aug 2023	jlirs1		TFS 59187 (59019) EUP
  07 Aug 2023	jlirs1		TFS 59148 Port of Origin BOP
  21 Nov 2023	jlika1		TFS 61135 61013 CUX | Cargo Priority - User Defined EDI
  3 Sept 2024 	navsaa30	Bug 63853: EUP | FR 53158 (CARGO ON SHIP) - Additional Fields - EDI loaded dimensions are not processed correctly (Precision issue)
  17 Oct 2024	navcs2		MTN-33066 EUP - NTO-980 - "89636: Total Weight Should Not be Zero" Error when Uploading Transport Manifest with weights in kilograms only
  07 Nov 2024	navdap1		MTN-33400 MTN - User Defined EDI is not longer loading Volume details
  20-May-2025 	naviv1		MTN-34238 PRP - Dimension Conversion Issue when loading Vessel Manifest Template
*/
vars	
	isWeightZero,							// 17 Oct 2024		navcs2	MTN-33066
	isKg,									// 17 Oct 2024		navcs2	MTN-33066
	shouldChange		: Boolean;			// 17 Oct 2024		navcs2	MTN-33066
	value,									// 17 Oct 2024		navcs2	MTN-33066
	str,									// 17 Oct 2024		navcs2	MTN-33066
	type				: String;			// 17 Oct 2024		navcs2	MTN-33066
begin
	if _propName = ETRow_SalesOrderNbr then
		self.setSalesOrderNbr(_processedValue);
		return true;
	endif;
	
	if _propName = ETRow_IsCertifiedWeight then							// TFS #1699
		self.isWeightCertified := _processedValue.asBooleanJMT();		// TFS #1699
		return true;													// TFS #1699
	endif;																// TFS #1699
	
	//15 Nov 2016	NDL	TFS 2959 / 2420
	if _propName = ETRow_CargoWeight then
		if _processedValue.asDecimalJMT() &lt;&gt; null then
			self.cargoWeight := _processedValue.asDecimalJMT();         //3/9/24   navsaa30  #63853
		endif;
		return true;
	endif;
	
	//15 Nov 2016	NDL	TFS 2959 / 2420
	if _propName = ETRow_TareWeight then
		self.tareWeight := _processedValue.asDecimalJMT();         //3/9/24   navsaa30  #63853
		return true;
	endif;
	// jlika1 TFS 53316 --&gt;
	if _propName = ETRow_Diameter then				
		self.diameter := _processedValue.asDecimalJMT();			//3/9/24   navsaa30  #63853
		return true;
	endif;	
	
	if _propName = ETRow_RollingLength then
		self.rollingLength := _processedValue.asDecimalJMT();		//3/9/24   navsaa30  #63853
		return true;
	endif;
	// jlika1 TFS 53316 &lt;--
	if _propName = ETRow_ContainerNumberText then		//08 Aug 2023	jlirs1	TFS 59187 (59019) EUP
		self.setContainerNumberText(_processedValue);
		return true;
	endif;
	
	if _propName = ETRow_PortOfOrigin then		//07 Aug 2023	jlirs1	TFS 59148 Port of Origin BOP
		self.setPortOfOrigin(_processedValue);
		return true;
	endif;
	
	if _propName = ETRow_CustomerPriorityCode then
		self.setCustomerPriorityCode(_processedValue, _xlationOperator);
		return true;
	endif;
	
	// 17 Oct 2024		navcs2	MTN-33066 Start
	if _propName.isMeasurementType then	
		_propName.getRowNameMeasureType(str, type);	
		
		if (str = ETRow_Weight or str = ETRow_WeightTons or str = ETRow_TotalWeight) then
			return inheritMethod(_propName, _processedValue, _xlationOperator);
		endif;
		
		if str = ETRow_CargoWeight or str = ETRow_TareWeight then
			if str = ETRow_CargoWeight then
				isWeightZero 		:= self.getCargoWeight = 0;
			else 
				isWeightZero 		:= self.getTareWeight = 0;
			endif;
			isKg				:= type = self.KGString;
			value 				:= app.convertMeasurementForStorage(type, _processedValue.Decimal).asStringJMT;
			shouldChange		:= (isWeightZero and not value = null) or (isKg and not value = null);
		endif;
		
		if str = ETRow_CargoWeight then
			if shouldChange then
				if value = null then
					self.setPropertyValue(ETRow_CargoWeight, NULL_WEIGHT);
				else
					self.setPropertyValue(ETRow_CargoWeight, value.asDecimalJMT); 
				endif;
			endif;
			return true;																										
		elseif str = ETRow_TareWeight then											// MTN-33400
			if shouldChange then
				if value = null then
					self.setPropertyValue(ETRow_TareWeight, NULL_WEIGHT);
				else
					self.setPropertyValue(ETRow_TareWeight, value.asDecimalJMT); 
				endif;
			endif;
			return true;
		elseif str.isOneOf(ETRow_Height, ETRow_Length, ETRow_Width,ETRow_OverHeight, ETRow_OverLength, ETRow_OverLengthBack,ETRow_OverLengthFront,ETRow_OverWidth, ETRow_OverWidthLeft,ETRow_OverWidthRight, ETRow_Diameter, ETRow_RollingLength) then		//MTN-34238
			value 	:= app.convertMeasurementForStorage(type, _processedValue.Decimal).asStringJMT;
			return self.assignValueSpecial(str, value, _xlationOperator);
		else																		// MTN-33400
			return self.assignValueSpecial(str, _processedValue, _xlationOperator);	// MTN-33400
		endif;
	endif;
	// 17 Oct 2024		navcs2	MTN-33066 End

	
	return inheritMethod(_propName, _processedValue, _xlationOperator);

epilog

end;</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_processedValue" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canUserSet" id="e7950d1c-7bea-45ce-94b0-2398a8e19435">
        <source>canUserSet(_propName: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Sep 2014	cnwkpd1	PAR #34713 - .NET EDI transform integration
15 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
21 Nov 2022	navma1	ChangeRequest 55424: MTN - Improve the performance of Edi file loading
*/
vars

begin
	if _propName = CM_EDICargoTI::imCodes.name    or 
	   _propName = CM_EDICargoTI::clientRef.name then			//21.11.2022 navma1 #55424
		return false;
	elseif _propName = CM_EDICargoTI::directDelivery.name then	// Cargo Ti is allowed to use this field
		return true;
	else
		return inheritMethod(_propName);
	endif;
end;
</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="1d40abbb-3141-4ddf-93d6-15b116f63bc8">
        <updating/>
        <source>create() updating;
/*
----------   ----------  --------------------------------------------------
Created:	22 March 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
11 Apr 2012	cnwrs1		Par 29396 - sort Ship Cargo by messgaenum
14 Sep 2012	cnwkpd1	PAR #29274 - Replace Object::getInstanceIdForObjectXX with RootSchema methods

*/

vars

begin
	self.messageMode := CM_EDITrackedItem.EDI_ACTION_ADD;
	//th2 for PAR 13691 for when temperature is not a field in the file the user is loading
	//and therefore should be null (-273K) by default.
	self.temperature := NULL_TEMPERATURE;
	self.setCarbonDioxide( NULL_CARBON_DIOXIDE );
	self.setOxygen( NULL_OXYGEN );
	self.setHumidity( NULL_HUMIDITY ); //par18451 nov 2008 cnwrs1
	self.vent := NULL_VENTILATION; //par18451 nov 2008 cnwrs1
	self.cargoType := TI_CargoType_Container;
	self.messageNum := self.getInstanceIdForObject64(self).Integer;	//11 Apr 2012	cnwrs1		Par 29396 - sort Ship Cargo by messgaenum
	
	//cnwmc5 - 10 March 2014 - PAR 33001
	self.overHeight := NULL_INTEGER;
	self.overLengthBack := NULL_INTEGER;
	self.overLengthFront := NULL_INTEGER;
	self.overWidthLeft := NULL_INTEGER;
	self.overWidthRight := NULL_INTEGER;
end;


</source>
    </JadeMethod>
    <JadeMethod name="createProxy" id="0591b9b7-1fcd-41de-8da2-34df9596f097">
        <updating/>
        <source>createProxy(_terminal :CM_Terminal; _realTI :CM_TrackedItem output; _passport :CM_Passport input):CM_TrackedItem updating;
/*
Date		Who		Reason
20/06/2012	cnwcs5	Initial creation - par 29747
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
*/
vars
	proxy	: CM_TrackedItem;
begin
	_realTI := self.myEDIData.getRealCargoItem (self);
	
	if _realTI &lt;&gt; null then
		proxy := _realTI.pxyGetProxyObject().CM_TrackedItem;
		
		if proxy &lt;&gt; null then
			app.raiseCMException1(Cargo_item_already_being, proxy.id, ETRow_Id, self);write '1';
			return null;
		endif;
	endif;
		
	if self.messageMode = CM_EDITrackedItem.EDI_ACTION_ADD or self.messageMode = CM_EDITrackedItem.EDI_ACTION_UPDATE then
		if _realTI = null then
			proxy := _terminal.createTI(self.myCargoType, true);
			
			self.setProxy(proxy, self.site, _terminal, null, _passport);
			proxy.setSubTerminal(null,null);		
		else
			beginLoad;
			proxy := _realTI.pxyCreateUpdateProxy();
			self.setProxy(proxy, self.site, _terminal, null, _passport);
			proxy.setSubTerminal(null,null);
			endLoad;
		endif;
	//cnwmc5 - 15 April 2014 - CCMS 2352
	elseif self.messageMode = CM_EDITrackedItem.EDI_ACTION_MODIFY then
		//cnwmc5 - 22 May 2014 - PAR 34191 - if we can't find the cargo item on ship, check on site for it..
		if _realTI = null then
			_realTI := self.myEDIData.getRealCargoItemForModify (self);
		endif;
		
		if _realTI &lt;&gt; null then
			beginLoad;
			proxy := _realTI.pxyCreateUpdateProxy();
			self.setProxyForModify(proxy, _terminal, _passport);
			//proxy.setSubTerminal(null);		//is this needed?
			endLoad;
		else
			app.raiseCMException1(Cargo_item_not_found, self.id, ETRow_Id, self);		//cnwmc5 - 22 May 2014 - PAR 34191
			return null;																//cnwmc5 - 22 May 2014 - PAR 34191
		endif;
	else 
		// should not be here
	endif;
		
	return proxy;
epilog
	endLoad;											// 19/04/2013 cnwmh5 #31457
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_realTI" type="CM_TrackedItem" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="createTIHazardsFromEdiHaz" id="8aec82e0-38ee-4c2b-bae1-29361080a6ae">
        <source>createTIHazardsFromEdiHaz( _tmpHazards : ObjectArray input ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 November 2016	cnwndl1	Initial creation	TFS 2843 / 2604

*/

vars

	retValue : Boolean;
	edi : CM_EDITrackedItem;
	tiHaz : CM_TIHazard;

begin

	if self.myAttachedItems.isEmpty then
		return false;
	endif;
	
	foreach edi in self.myAttachedItems where edi.isEDIHazDetails do
		create tiHaz transient;
		tiHaz.setPxyFromEDI( edi.CM_EDIHazDetailsTI );
		_tmpHazards.add( tiHaz );
		retValue := true;
	endforeach;
	
	return retValue;

epilog

end;</source>
        <Parameter name="_tmpHazards" type="ObjectArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createUpdateTrackedItem" id="29fb0934-a408-4798-bb10-383330f8b022">
        <updating/>
        <source>createUpdateTrackedItem(_terminal :CM_Terminal input; _coll :CM_TIByCargoTypeIdDict; _validateOnly :Boolean; _updateController :CMIF_TIUpdateController input; _passport :CM_Passport input):CM_TrackedItem updating;
/*

Date		Who		Reason
21/06/2012	cnwcs5	Initial creation - par 29747
27 Sep 2012	cnwkpd1	PAR #30400 - SFW 1290 - Transaction EDI file type
29 May 2013	cnwcs5	par 31521
11 Dec 2014	cnwkpd1	PAR #35306 - Create Move transactions in an update with the current time
02 Dec 2018	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 7
17 Jun 2020 jlgmd1	TFS 49599 STWR Cargo Update EDI messages locking
17 Nov 2021 navma1	ChangeRequest 52330: SAL - EDI operations - Cargo On Site
13 Nov 2023	navdap1	TFS 59458 EUP | EDI Specific Performance
*/
vars
	mode				:String;
	proxy, realTI,
	parentTI			:CM_TrackedItem;
	location			:CM_LocationsController;
	startPos, height	:Integer;
	locationID			:String;
	strArray, strArray2	:StringArray;
	moveController		:CMIF_MoveController;
	cargoType			:CM_CargoType;
	proxyLoc,
	realLoc				: CM_LocationsController;	// PAR #35306
	tiUpdateExtraParams : CMIF_TIUpdateExtraParams;
	trans				: CM_TITransaction;
begin
	// TFS 49599 17/06/2020
	// Disabled, in favour of the web service retry loop taking care of any exceptions instead - as this was causing too many deadlocks by locking allOnsiteTIsByIdCargoType.
	// The deadlocks were between CargoOnSite and CargoFieldUpdate messages (utlProcessEDITICargo)
	
	// 02 Dec 2018	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 7	
	/*if not self.tryLock(_terminal.allTITransactions, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
		self.exclusiveLock(_terminal.allTITransactions);
	endif;
	if not self.tryLock(_terminal.allTITransactionsByTypeDate, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
		self.exclusiveLock(_terminal.allTITransactionsByTypeDate);
	endif;
	if not self.tryLock(_terminal.allTITransactionsByCamsTS, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
		self.exclusiveLock(_terminal.allTITransactionsByCamsTS);
	endif;
	if self.site = TI_SITE_ONSITE then
		if not self.tryLock(_terminal.allOnsiteTIsByIdCargoType, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
			self.exclusiveLock(_terminal.allOnsiteTIsByIdCargoType);
		endif;
	endif;*/

	proxy 	:= self.createProxy (_terminal, realTI, _passport);	
	
	//cnwmc5 - 15 April 2014 - CCMS 2352
	if proxy = null then
		return null;
	endif;
	
	if realTI &lt;&gt; null then
		mode 	:= CM_EDITrackedItem.EDI_ACTION_UPDATE; 
	else
		mode 	:= CM_EDITrackedItem.EDI_ACTION_ADD; 
	endif;
	
	// validation is same for add/update
	proxy.validateTrackedItem(_updateController, _passport);
	
	// if we get any errors doing a DBLoad then we stop 
	// on verify if we continue after getting error can get exceptions on creating the TI e.g. error raised because trailer doesn't have trailer type if we continue will
	// get a 1090 exception
	if _passport.hasErrors then	
		return realTI;
	endif;
			
	if mode = CM_EDITrackedItem.EDI_ACTION_ADD then
		// create the cargo
		realTI := _terminal.createTrackedItem(proxy, _passport);

		if realTI = null then 
			// must have been a problem
			return realTI;
		endif;
		// Centreport - ugly hack to auto create a BOL for each car entered
		if _terminal.getConfig(AutoCreateCusCarBOL).Boolean and CM_Car.hasInstance(realTI) then
			app.myUtilityUA.utlUpdateBOLInCusCar(realTI.CM_Car, _passport);
		endif;
	else
		//epr par 37446 1/2/16
		if _validateOnly then
			create tiUpdateExtraParams transient;
			tiUpdateExtraParams.isAuditNotRequired:=true;
			tiUpdateExtraParams.dontCreateTransCM_Edit:=true;
		endif;
		
		
		app.myUtilityUA.utlUpdateTrackedItem(proxy, null, TI_UPDMODE_NORMAL, null, tiUpdateExtraParams, self, _passport);
		
		//17.11.2021 navma1 #52330
		if not _validateOnly then
			if realTI &lt;&gt; null then
				if realTI.receivedDT.isValid and proxy.receivedDT.isValid then
					if realTI.receivedDT &lt;&gt; proxy.receivedDT then
						trans	:=	 realTI.findLastReceivalTrans();
						if trans &lt;&gt; null then
							trans.updateDateTimeFromEDI(proxy.receivedDT);
						endif;
					endif;
				endif;
			endif;	
		endif;
		//17.11.2021 navma1 #52330
		
	endif;
	
	if _coll &lt;&gt; null and self.parentCargoID &lt;&gt; null then
		cargoType	:= app.myRoot.getCargoTypeFromAbbrevOrDescr(self.parentCargoType);
		
		if cargoType &lt;&gt; null then
			parentTI 	:= _coll[cargoType.id, self.parentCargoID];
		endif;
		
		if parentTI &lt;&gt; null then
			if _terminal.getConfig(MoveTIToParentTrailer).Boolean // ### TFS CR 56806 TASK 56807 03MAR2023 NAVAB1
			and parentTI.isChassis() then // ### TFS CR 56806 TASK 56807 03MAR2023 NAVAB1
				realTI.moveToLocation(parentTI.CM_TILC.allLCs.first, null,null,null,0, true,true,false,false,false,true,0,0,null,null,null, app.myPassport); // ### TFS CR 56806 TASK 56807 03MAR2023 NAVAB1
			else
				if realTI.myParent = null or realTI.myParent &lt;&gt; parentTI then
					parentTI.attachChild(realTI, _passport);
				endif;
			endif;
		else
			// error parent does not exist
			app.raiseCMException2(CargoInvalidParent, self.id, self.parentCargoID, null, self);
		endif;
	endif;
			
	if _passport.hasErrors then
		return realTI;
	endif;
	
	// don't move TI if we don't have to
	if mode = CM_EDITrackedItem.EDI_ACTION_UPDATE then
		// PAR #35306 - If string location ids are the same, then don't need to move
		if proxy.locationId = realTI.locationId then 	
			return realTI;
		endif;
		
		if realTI.site = TI_SITE_ONSITE then
			// PAR #35306 - For onsite containers, check for a real change of location (ignoring height)
			_terminal.findLocationFromString(realTI.locationId, true, realLoc, height);
			_terminal.findLocationFromString(proxy.locationId, true, proxyLoc, height);
			
			// If there is no real change in location, then don't need to move
			if proxyLoc = realLoc then
				return realTI;
			endif;
		endif;
		
		realTI.setLocationId(proxy.locationId);

	elseif realTI.isChild then 
		// dont' move child - only parent
		return realTI;
	elseif parentTI &lt;&gt; null then
		// if the real TI in on a trailer then there is nothing more to do as the rest of the code is about moving the TI.
		if _terminal.getConfig(MoveTIToParentTrailer).Boolean // ### TFS CR 56806 TASK 56807 03MAR2023 NAVAB1
		and parentTI.isChassis() then // ### TFS CR 56806 TASK 56807 03MAR2023 NAVAB1
			if realTI.locationId.pos(parentTI.id,1) &gt; 0 then
				return realTI;
			endif;
		endif;
	
	endif;
	// --------------
	// Move the cargo
	//---------------
	_passport.warningsAcknowledged 	:= true;

	if _validateOnly then
		// sometimes gets reset as part of other validation/updates
		app.setContinueCMExceptions(true);
	endif;
	
	location := null; 
	
	if realTI.site = TI_SITE_ONSHIP then
		
		startPos := realTI.myVoyage.code.length + 2;
			
		create strArray transient;
		
		if realTI.myVoyage.isGeneralCargoVoyage then   // PAR 31866
			if realTI.locationId.pos(realTI.myVoyage.code,1) = 1 then	//16 July 2013	NDL	Par 31965
				//the voyage code portion of the location id needs to be stripped off.
				if (startPos &lt;= realTI.locationId.length) then //PAR 32705 cnwgb1 11.11.2013
					strArray2 := realTI.locationId[startPos:end].getTokens();
				endif;
			else
				strArray2 := realTI.locationId.getTokens();
			endif;
			if strArray2 &lt;&gt; null then
				strArray2.copy(strArray);
			endif;
			realTI.myVoyage.findLocation(strArray, false, location, height);
		endif;
        
		if location = null then
			if realTI.myVoyage.myShipBlockStack = null and realTI.locationId &lt;&gt; null then
				locationID	:=	realTI.locationId;		// cnwdad1 01/07/2010 - PAR #24177.
							
				if realTI.locationId.length &gt;= startPos then
					strArray.add(realTI.locationId[startPos:end]);
				else
					strArray.add(realTI.locationId);
				endif;
			endif;
			
			realTI.myVoyage.findLocation(strArray, false, location, height);
		endif;
		
		if location = null then
			app.raiseCMException1(ERR_INVALID_STOWAGE,  locationID &amp; ", for ti "&amp; realTI.id, ETRow_LocationId, self);
			return realTI;
		endif;
	elseif realTI.site = TI_SITE_ONSITE then
		realTI.myTerminal.findLocationFromString(realTI.locationId, false, location, height);
		
		if location = null then
			app.raiseCMException1(ERR_INVALID_LOCN,  realTI.locationId &amp; ", for ti " &amp; realTI.id, ETRow_LocationId, self);
			return realTI;
		endif;
	endif;
	
	create moveController transient;
	
	moveController.setMoveMode(REAL_MODE);
	moveController.isSystemMove := true;
	moveController.setMyToPrimaryLocation(location);
	moveController.setMyToSecondaryLocations(null);
	moveController.setMyTrackedItem(realTI);
	// TFS 59458 Don't do Cargo Group Details udpates if this is a Transport Manifest Ship Cargo TI
	if self.isTransportManifestRelated() and self.isEDICargoOnShipTI() then
		moveController.suppressCargoGroupDetailUpdate := true;
	endif;
	// TFS 59458 end
	
	// SFW 1290, PAR #30400 - if this is part of an Onsite Cargo load, then the receivedDT will already be set, 
	// so "back-date" the Receival and Move transaction to that time
	if mode = CM_EDITrackedItem.EDI_ACTION_ADD and realTI.receivedDT &lt;&gt; null then		// PAR #35306 - only do this for an add
		moveController.setEffectiveTimeStampOverride(realTI.receivedDT);
	endif;
	
	app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);	
	
	return realTI;
epilog
	delete strArray;
	delete strArray2;
	delete moveController;	
	delete proxy;
	delete tiUpdateExtraParams;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal" usage="input"/>
        <Parameter name="_coll" type="CM_TIByCargoTypeIdDict"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_updateController" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="delete" id="bfabf146-2957-4163-a070-4384efb8e697">
        <updating/>
        <source>delete() updating;
//
// 20 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
//
vars
	ediTI : CM_EDITrackedItem;
begin
	foreach ediTI in self.myAttachedItems do
		if ediTI.isEDISealDetails then
			delete ediTI;
		endif;
	endforeach;
end;
</source>
    </JadeMethod>
