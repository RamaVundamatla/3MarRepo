/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2014	cnwndl1	Initial creation	Par 34142
21/07/2014	cnwjre1 34580 extend to get from cargo if not on receipt
*/

vars
	vesselName	: String;
begin

	if self.myTrackedItem &lt;&gt; null then
		vesselName := self.myTrackedItem.vesselName;
	endif;

	if vesselName = null and
	   self.myCashReceipt &lt;&gt; null then
		vesselName := self.myCashReceipt.getVesselName();
	endif;
	
	return vesselName;

epilog

end;</source>
