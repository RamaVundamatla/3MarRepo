<Class name="HandHeldGateAgent" id="878e2183-6f56-4af9-951c-a00124cbcd71">
    <superclass name="HandHeldAgent"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="mobileServer"/>
    <JadeMethod name="createHandHeldAlert" id="ff57a9e0-b122-44f1-ad51-0f825d5d1c7f">
        <source>createHandHeldAlert(_vehicleID, _descr : String);
/*
----------   ----------  --------------------------------------------------
Created:	15 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
----------   ----------  --------------------------------------------------
15 Mar 2010	consw1		PAR #23020 - Allow for vehicle that is defined with a state
*/
vars
	vehicle			: CM_Vehicle;
	linkedObj		: CM_Object;
begin
	vehicle := self.getVehicle(_vehicleID);
	if vehicle &lt;&gt; null then
		linkedObj := vehicle.allRoadJobs.first;
	endif;
	
	if linkedObj = null then
		linkedObj := self.myRTDevice;	
	endif;
	
	if app.myPassport.myTerminal = null then
		app.myPassport.setMyTerminal(self.myTerminal);
	endif;
	
	app.myPassport.createAlert(SEVERE_ERROR, 
				'Sent from hand held ' &amp; self.myRTDevice.id &amp; ': ' &amp; _descr,
				EVENT_AT_HandHeldAlert,
				linkedObj);
	
	beginTransaction;
	app.commitAlert();
	commitTransaction;

end;


</source>
        <Parameter name="_vehicleID" type="String"/>
        <Parameter name="_descr" type="String"/>
    </JadeMethod>
    <JadeMethod name="displayEntryRemarks" id="992fad4d-77ec-4ed9-bb08-c5986ef8fa5e">
