    <JadeMethod name="validateForCreate" id="d64369e3-7f80-42ef-9bd7-55806ac5d367">
        <source>validateForCreate();
// CCMS 1131 PAR 23715 
// 21/12/2017	jlgdap1	TFS 36347 STWR validateForUpdate no longer required - it was ensuring a seal type couldn't 
//						allow multiple seals AND save previous seals, but standard release sets both these to true for 
//						system seal types, and the code copes with multiple seals and saving previous seals quite happily
vars
begin
	if app.myRoot.getSealType(self.sealType) &lt;&gt; null then
		app.raiseCMException1(ERR_SEALTYPE_EXISTS, self.sealType, null, null);
		return;
	endif;
	
	//self.validateForUpdate;				// TFS 36347
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="ce447508-f0ca-41db-b201-e2fb9815e852">
        <source>validateForDelete();
vars
begin

	if self.isInUse then
		app.raiseCMException1(ERR_CANNOT_CHG_IN_USE, self.sealType, null, null);
	endif;
	
	//14 Sep 2010	NDL Par 25608
	if self.isSystemSealType then
		app.raiseCMException(System_based_seal_type, null, null);
	endif;
	
	//17 Mar 2015	NDL	Par 35828
	if not self.allWagonClasses.isEmpty then
		app.raiseCMException2(Seal_type_wagon_class, self.sealType, self.allWagonClasses.first.code, null, null);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="6fbe4bf1-08a2-4fdb-b398-cc0f8d8bad40">
        <source>validateForUpdate();
// CCMS 1131 PAR 23715 
// 07 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
// 21 Dec 2017	jlgdap1	TFS 36347 STWR This validation no longer required - the system copes with multiple seals 
//						and saving previous seals quite happily
vars

begin
	//+cnwml2 PAR23715 SFW CCMS 1131
	/*if not app.isConverting and
	   self.allowMultipleSealNums and self.savePreviousSeal then
		app.raiseCMException( SealTypeOptions, null, self );
	endif;
	
	//04 Oct 2010	NDL	Par 25608
	if  not app.isConverting and
		(self.sealType = SealType_Operator
	or self.sealType = SealType_Shipper
	or self.sealType = SealType_Vent
	or self.sealType = SealType_TerminalOperator
	or self.sealType = SealType_Unknown)
	then
		if self.allowMultipleSealNums then
//			app.raiseCMException1( Syste_seal_type_not_permi_mult, self.description, null, self );
		endif;
	endif;*/
	
end;</source>
    </JadeMethod>
