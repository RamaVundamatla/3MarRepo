// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.myCurrentTrade := self.cmbTrades.listObject.CM_ShippingLine;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="b5d2964a-147b-438e-82a9-35da4bb7b25b">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.permissionView  := PmAdmRatetableView;
	self.permissionMaint := PmAdmRatetableMaint;
	
	self.helpFileName := HelpFile_Invoicing;

end;</source>
    </JadeMethod>
    <JadeMethod name="displayBerth" id="f28e8afb-8cd7-4a3e-af73-1abda238b174">
        <source>displayBerth(_obj : Object) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jun 2018 cnwma1	ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types

*/

vars

begin
	if _obj = null then
		return null;
	else
		return _obj.HMS_Berth.description;
	endif;
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayCell" id="25b8b126-0dbd-44a3-b02e-fab002e078f7">
        <updating/>
        <source>displayCell() updating;
/*

Purpose:			

Parameters:			

Date		Who		Reason
Aug 2010	cnwjre1	Par 25384 based on code by Kevin C

*/

vars
	column	: JadeTableColumn;
	row		: JadeTableRow;
begin
	// keep column selection from fixed rows
	if tblData.row &lt;= tblData.fixedRows then
		return;
	endif;
	tblData.clearAllSelected;
	if tblData.row &lt;= tblData.rows then
		// reset prior selected row
		if self.colouredRow &gt; 0 and self.colouredRow &lt;= tblData.rows then
			row := tblData.accessRow(self.colouredRow);
			row.backColor := self.colouredRowColour;
		endif;
		
		// highlight new row
		row := tblData.accessRow(tblData.row);
		self.colouredRowColour := row.backColor;
		row.backColor := LightYellow;
		self.colouredRow   := tblData.row;
		
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="displayDebtor" id="abb704ef-916a-4818-96b4-3cdecde12207">
        <source>displayDebtor(_theObject : Object) : String;
// ---------------------------------------------------------------------------
// Created:		July 2010 cnwjre1 par 24052 multi-select debtors
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	debtor : CM_DebtorNode;
begin
	if _theObject = null then
		return null;
	else
		debtor := _theObject.CM_DebtorNode;
		if debtor.isRootDebtorGroup then
			return "&lt;" &amp; debtor.getListName() &amp; "&gt;";
		else
			return debtor.name;
		endif;
	endif;
end;</source>
        <Parameter name="_theObject" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayExtraInfo" id="f6d01632-f2be-4774-af40-663678ae62fa">
        <source>displayExtraInfo();
// July 2010 cnwjre1	24018 show macro info for rates
vars
	parent	: CM_DebtorNode;
	dataContainer : CM_DataContainer;
	rate	: CM_Rate;
begin

	self.tblInfo.clear();
	self.tblInfo.rows := 0;
	if self.mnuContextHide.caption = self.MNU_MACRO_SHOW then
		return;
	endif;
	
	if self.myCurrentLineGroupDebtor &lt;&gt; null then
		rate := self.myCurrentLineGroupDebtor.serviceRates[self.myCurrentService];
	elseif self.myCurrentDebtor &lt;&gt; null then
		rate := self.myCurrentDebtor.serviceRates[self.myCurrentService];
	elseif self.myCurrentBerth &lt;&gt; null then // TFS 39198
		rate := self.myCurrentBerth.allServiceRates[self.myCurrentService]; // TFS 39198
	elseif self.myCurrentVessel &lt;&gt; null then // TFS 39198
		rate := self.myCurrentVessel.allServiceRates[self.myCurrentService]; // TFS 39198
	elseif self.myCurrentVesselType &lt;&gt; null then // TFS 39198
		rate := self.myCurrentVesselType.allServiceRates[self.myCurrentService]; // TFS 39198
	elseif self.myCurrentVisitType &lt;&gt; null then // TFS 39198
		rate := self.myCurrentVisitType.allServiceRates[self.myCurrentService]; // TFS 39198
	endif;
	if rate &lt;&gt; null then
		create dataContainer transient;
		dataContainer.headerColour := self.colorHeadingColumn;
		dataContainer.valueColour := self.colorValueColumn;
			
		rate.getExtraInfo(dataContainer);
	endif;
	if self.myCurrentLineGroupDebtor &lt;&gt; null and
	   self.myCurrentLineGroupDebtor.debtor &lt;&gt; null then
		parent := self.myCurrentLineGroupDebtor.debtor.myParentDebtorNode;
	endif;
	if self.myCurrentDebtor &lt;&gt; null then
		parent := self.myCurrentDebtor.myParentDebtorNode;
	endif;
	if parent &lt;&gt; null then
		while parent &lt;&gt; null do
			rate := parent.serviceRates[self.myCurrentService];
			if rate &lt;&gt; null then
				if dataContainer = null then
					create dataContainer transient;
					dataContainer.headerColour := self.colorHeadingColumn;
					dataContainer.valueColour := self.colorValueColumn;
				endif;
				rate.getExtraInfo(dataContainer);
			endif;
			parent := parent.myParentDebtorNode;
		endwhile;
	endif;
	if dataContainer &lt;&gt; null then
		self.showExtraInformation(dataContainer, self.tblInfo, true, false, 4, 1, 1, 1, 1);
		self.doResizeColumnWidths(self.tblInfo, true);
	endif;
epilog
	delete dataContainer;
end;</source>
    </JadeMethod>
    <JadeMethod name="displayService" id="ed458062-413a-412f-b9bf-d23701038d15">
