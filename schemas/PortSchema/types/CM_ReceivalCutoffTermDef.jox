    <JadeMethod name="persistCriteria" id="8adcf91b-2114-4fca-9464-760e11962d00">
        <updating/>
        <source>persistCriteria( _allTransientCriteriaObj : CMIF_Array; _passport : CM_Passport input) updating;

/*
Date		Who		Reason
21 May 2009	cnwar2	Initial creation

*/
vars
	cmifObject			: CMIF_Object;
	transientObj		: CMIF_YACriteriaPriority;
	proxyObj			: CM_YACriteriaPriority;
	realCPObj			: CM_YACriteriaPriority;
	
begin
	// Persist, update or delete the Criteria.
	foreach cmifObject in _allTransientCriteriaObj do
		transientObj	:=	cmifObject.CMIF_YACriteriaPriority;
		proxyObj		:=	transientObj.myProxy;
		realCPObj		:=	transientObj.myCriteriaPriority;
		proxyObj.CM_ReceivalCutoffCriteria.setReceivalCutoffDef(self);
		
		// Do "New" first, because the "changed" flag can be set if a new Criteria/Priority
		// is changed after it is added, but before it is saved to the database.
		if transientObj.isNew then
			app.myUtilityCA.utlCreateYACriteriaPriority(proxyObj, realCPObj, _passport);
		elseif transientObj.isChanged then
			app.myUtilityUA.utlUpdateYACriteriaPriority(realCPObj, proxyObj, _passport);
		elseif transientObj.isDeleted then
			if realCPObj &lt;&gt; null then
				app.myUtilityDA.utlDeleteYACriteriaPriority(realCPObj, _passport);
			endif;			
		endif;
	endforeach;

	self.validateCriteria();
end;</source>
        <Parameter name="_allTransientCriteriaObj" type="CMIF_Array"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="deb58887-85a3-43a8-b46a-668f13971085">
        <source>pxyCreateUpdateProxy(): SelfType;

/*
Date		Who		Reason
24 May 2009	cnwar2	Initial creation
20/04/2011	cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
					trying to create the proxy
23/02/2012	cnwcs5	par 29158 - CCMS CPL 2085 - EDI Booking cutoff
17/03/2012	cnwcs5	par 29257 - conversion of extension object properties
*/
vars
	proxy 			: CM_ReceivalCutoffTermDef;
	completedOK		: Boolean;
	
begin
	proxy :=  inheritMethod();
	
	proxy.criteriaType	:= self.criteriaType;			// par 29257 - march 2012
		
	proxy.allEDIDataTypes.clear;						// par 29257 - march 2012
	self.allEDIDataTypes.copy (proxy.allEDIDataTypes);	// par 29257 - march 2012
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	
	return proxy;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="5bfea8d9-c5d2-4515-a427-9566dca9df1f">
        <updating/>
        <source>setForCreate(_pxyRecCutoffDef : CM_ReceivalCutoffTermDef) updating;

/*
Date		Who		Reason
20 May 2009	cnwar2	Initial creation

*/
vars

begin
	_pxyRecCutoffDef.raiseExceptionIfNotTransient(method);
	
	self.setForUpdate(_pxyRecCutoffDef);
end;</source>
        <Parameter name="_pxyRecCutoffDef" type="CM_ReceivalCutoffTermDef"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="abad1987-a1fa-4289-a6da-834579e32bad">
        <updating/>
        <source>setForUpdate(_proxy : CM_ReceivalCutoffTermDef) updating;
/*
Purpose:	When the default cutoff for a terminal is updated, make sure any voyages that do not override the
			terminal default cutoffs, have their cutoff times updated based on the new offsets
			
Date		Who		Reason
20 May 2009	cnwar2	Initial creation
23/02/2012	cnwcs5	par 29158 - CCMS CPL 2086 - EDI Booking Cutoff
17/03/2012	cnwcs5	par 29257 - conversion of extension object properties
30 Apr 2012		cnwer1		PAR 29487 - default cutoff and earliest is derived on the ti if not overridden no need to update all voyages in the system
*/
vars
	
begin
	self.code 						:= _proxy.code;
	self.description 				:= _proxy.description;
	self.sortKey 					:= _proxy.sortKey;
	self.defaultRelativeTo 			:= _proxy.defaultRelativeTo;
	self.defaultCutoff 				:= _proxy.defaultCutoff;
	self.defaultEarliestReceival	:= _proxy.defaultEarliestReceival;
	self.isAvailableForEntry 		:= _proxy.isAvailableForEntry;
	self.myTerminal 				:= _proxy.myTerminal;
	self.defaultCutoffPN 			:= _proxy.defaultCutoffPN;	//04/03/2025	navkc1 JIRA Story MTN-34227
	self.defaultEarliestReceivalPN 	:= _proxy.defaultEarliestReceivalPN; //04/03/2025	navkc1 JIRA Story MTN-34227
	
	self.criteriaType := _proxy.criteriaType;			// par 29257 - march 2012
	
	self.allEDIDataTypes.clear;							// par 29257 - march 2012
	_proxy.allEDIDataTypes.copy (self.allEDIDataTypes);	// par 29257 - march 2012
	
epilog

end;</source>
        <Parameter name="_proxy" type="CM_ReceivalCutoffTermDef"/>
    </JadeMethod>
    <JadeMethod name="setValues" id="511b1402-ed16-4567-8cb7-0b293fb94311">
        <updating/>
        <source>setValues(	_code 				: String; 
			_description	 	: String; 
			_sortKey 			: Integer;
			_defaultRelativeTo 	: Integer;
			_defaultCutoff 		: Decimal; 
			_defaultEarliest 	: Decimal; 
			_isAvailable 		: Boolean; 
			_type				: Integer;	// par 29158 - Feb 2012
			_terminal			: CM_Terminal;
			_defaultCutoffPN	: Decimal; 	//04/03/2025	navkc1 JIRA Story MTN-34227
			_defaultEarliestPN	: Decimal		//04/03/2025	navkc1 JIRA Story MTN-34227
			) updating;

/*
Date		Who		Reason
20 May 2009	cnwar2	Initial creation
23/02/2012	cnwcs5	par 29158 - CCMS 2086 - EDI Booking Cutoff
17/03/2012	cnwcs5	par 29257 - conversion of extension object properties
*/
vars

begin
	self.code 						:= _code;
	self.description				:= _description;
	self.sortKey					:= _sortKey;
	self.defaultRelativeTo			:= _defaultRelativeTo;
	self.defaultCutoff				:= _defaultCutoff;
	self.defaultEarliestReceival	:= _defaultEarliest;
	self.isAvailableForEntry 		:= _isAvailable;
	self.criteriaType 				:= _type;	// par 29257 - march 2012
	self.myTerminal 				:= _terminal;
	self.defaultCutoffPN			:= _defaultCutoffPN; //04/03/2025	navkc1 JIRA Story MTN-34227
	self.defaultEarliestReceivalPN	:= _defaultEarliestPN; //04/03/2025	navkc1 JIRA Story MTN-34227
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_sortKey" type="Integer"/>
        <Parameter name="_defaultRelativeTo" type="Integer"/>
        <Parameter name="_defaultCutoff" type="Decimal"/>
        <Parameter name="_defaultEarliest" type="Decimal"/>
        <Parameter name="_isAvailable" type="Boolean"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_defaultCutoffPN" type="Decimal"/>
        <Parameter name="_defaultEarliestPN" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="validateCriteria" id="7c82d32d-06dc-41d5-9978-479be3e6c264">
        <source>validateCriteria();

/*
Date		Who		Reason
21 May 2009	cnwar2	Initial creation

*/
vars
	criteria			: CM_ReceivalCutoffCriteria;
	criteriaType 		: CM_YACriteriaType;
	criteriaTypeColl	: ObjectSet;

begin
	create criteriaTypeColl transient;
	
	// Ensure there is only one criteria object for any criteria type
	foreach criteria in self.allCriteria do
		criteriaType := criteria.myYACriteriaType;
		if criteriaTypeColl.includes(criteriaType) then
			//app.raiseCMException1(Err_YA_CriteriaWithSameType, criteriaType.description, null, null);
			app.raiseCMException1(Err_YA_CriteriaWithSameType, criteriaType.description, null, null);	//09 Oct 2013	NDL	Par 32456
		else
			criteriaTypeColl.add(criteriaType);
		endif;
	endforeach;

epilog
	delete criteriaTypeColl;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="709ff4d3-cd08-4bef-9a07-f63f2cd546ac">
        <source>validateForCreate();

/*
Date		Who		Reason
20 May 2009	cnwar2	Initial creation

*/
vars
		
begin
	if self.myTerminal.allReceivalCutoffDefs[self.code] &lt;&gt; null then 
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	endif;
		
	self.validateMe();
end;</source>
    </JadeMethod>
