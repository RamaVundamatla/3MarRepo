    <JadeMethod name="getNumErrors" id="52af3c37-0903-4744-925e-6b9a85a790ef">
        <source>getNumErrors() : Integer;
/*
Purpose - 	
Who - NAVAB1
Date - 16JUL2024
ADO -  CR 64617 TASK 64637
*/


vars
	ediError : CM_EDIError;
	idx : Integer;
begin
	foreach ediError in self.allErrorWarnings do
		if not ediError.warningOnly then
			idx +=1;
		endif;
	endforeach;
	
	return idx;
epilog

end;</source>
