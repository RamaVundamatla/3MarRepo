    <JadeMethod name="doChangeReqCargoType" id="b6312096-4827-43f1-9346-9d6c7a65f370">
        <source>doChangeReqCargoType();
// -----------------------------------------------------------------------------
// Created:		03 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	cargoType : CM_CargoType;
	isoContainer : Boolean;
	
begin
	cargoType := self.cmbReqCargoType.listObject.CM_CargoType;

	if cargoType &lt;&gt; null then
		isoContainer := cargoType.isISOType();
	endif;
	
	self.cmbReqISOType.visible := isoContainer;
	self.lblReqISOType.visible := isoContainer;
	self.cmbISOGroup.visible := isoContainer;
	self.lblISOGroup.visible := isoContainer;
	self.cmbReqAvailGrade.visible := isoContainer;
	self.lblReqAvailGrade.visible := isoContainer;
	self.chkReqClean.visible := isoContainer;
	self.lblReqClean.visible := isoContainer;
	self.chkReqHeavyDuty.visible := isoContainer;	
	self.lblReqHeavyDuty.visible := isoContainer;	
	self.cmbSourceArea.visible := isoContainer;	
	self.lblSourceArea.visible := isoContainer;	
	
	if cargoType &lt;&gt; null and cargoType.isDynamicallyCreated then
		self.cmbReqProduct.setCargoType(cargoType);
		self.cmbReqProduct.setOperator(self.cmbReqOperator.listObject.CM_Operator);
		self.cmbReqProduct.setObject(self.cmbReqProduct.listObject.CM_Product);
		self.cmbReqProduct.visible := true;
	else
		self.cmbReqProduct.clear();
		self.cmbReqProduct.visible := false;
	endif;
	
	self.lblReqProduct.visible := self.cmbReqProduct.visible;

	if isoContainer then
		self.btnAddRequest.top := self.cmbSourceArea.top + 45;
	else
		self.btnAddRequest.top := self.cmbReqAvailGrade.top;
	endif;

	self.btnDelRequest.top := self.btnAddRequest.top;
	self.btnUpdRequest.top := self.btnAddRequest.top;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doDeleteRequest" id="a7c5f406-71b6-4255-a3d2-58ef4fb9b6ba">
        <updating/>
        <source>doDeleteRequest() updating;
// -----------------------------------------------------------------------------
// Created:		04 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	woRequest : CM_WorkOrderRequestByType;
	
begin
	woRequest := self.lstSources.listObject.CM_WorkOrderRequestByType;

	if self.myProxySource.pxyGetRealObject() = null then
		self.myProxySource.proxyDeleteWoRequest( woRequest );
	else
		self.myProxySource.proxyRemoveWoRequest( woRequest );
		self.allWORequestsToBeDeleted.add( woRequest );
	endif;
	
	self.loadSources( self.headingRequests );
	
epilog

end;</source>
