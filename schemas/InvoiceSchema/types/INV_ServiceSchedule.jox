    <JadeMethod name="doLstDataMouseDown" id="ee006684-8630-420f-a12e-0f6518c494eb">
        <updating/>
        <source>doLstDataMouseDown(listbox: ListBox input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     26 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	if button = Window.MouseButton_Left then
		self.doLstDataClick(listbox);
	endif;

	self.dragMode := DragMode_None;	
	if button = 1 then
		self.origXPos := x;
		self.origYPos := y;
	endif;

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
