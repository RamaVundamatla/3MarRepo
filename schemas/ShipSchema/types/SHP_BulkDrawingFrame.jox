    <JadeMethod name="selectObject" id="78533822-f06c-46d6-be6a-59cb3edd8dc6">
        <updating/>
        <source>selectObject(_obj : Object; _startObj : Object io; _isAlt : Boolean) protected, updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars

begin
	if _obj = null then
		return;
	endif;

	if _isAlt then
		self.myBulkDrawingController.selectObjectAlt(_obj, self, true);
	else
		self.myBulkDrawingController.selectObject(_obj, self, true);
	endif;
	
	_startObj := _obj;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_startObj" type="Object" usage="io"/>
        <Parameter name="_isAlt" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDrawingPositions" id="ecb6df27-51d4-4bbd-bef5-cff6392f4c49">
        <updating/>
        <source>setDrawingPositions(_controller : SHP_BulkDrawingController) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
