    <JadeMethod name="jhpSchemaExtract" id="5a90ae09-07b9-481d-8700-8e5aaf79a55c">
        <source>jhpSchemaExtract(schemaName:String; option:String);

vars
	s,t,schemaPath,result,param,path,cmdLine,suffix:String;
	retCode:Integer;
begin
	if option = "encrypt" then
		suffix:="_Encrypted";
		t:=' "&lt;encrypt&gt;"';
	elseif option = "partial" then
		suffix:="_Partial";
	endif;
	path:=app.getJadeInstallDirAppServer;
	//schemaPath:=app.dbPath.atcgReplace("server\c_system", "schemaExtracts\");
	schemaPath:="u:\SchemaExtracts\";
	s:=schemaPath&amp;schemaName&amp;suffix;
	if option = "partial" then
		param:=" File "&amp;s&amp;".scm "&amp;s&amp;".ddb "&amp;s&amp;".unl "&amp;schemaName;
	else
		param:=" Single "&amp;s&amp;".scm "&amp;s&amp;".ddb "&amp;schemaName&amp;t;
	endif;
	cmdLine:=path&amp;"\jadclient ini="&amp;app.getIniFileNameAppServer&amp;" path="&amp;app.dbPath&amp;" server=multiUser"
					&amp;" schema=JadeSchema app=JadeBatchExtract"&amp;" endJade"&amp;param;
	//write cmdLine;
	node.createExternalProcess(null,'cmd /c '&amp;cmdLine,null,null,false,true,retCode);
end;
</source>
        <Parameter name="schemaName" type="String"/>
        <Parameter name="option" type="String"/>
    </JadeMethod>
    <JadeMethod name="jhpSchemaExtracts" id="4e6673e1-66de-4409-8d70-895836b3c9c0">
        <source>jhpSchemaExtracts();
//	use this to extract all schemas for banking
vars
	s,t,sq:String;
begin
	jhpSchemaExtract("JtdCommonSchema", null);
	jhpSchemaExtract("JtdDriverSchema", null);
	jhpSchemaExtract("JtdMobileCommonSchema", null);
	jhpSchemaExtract("JtdMobileDriverSchema", null);
	jhpSchemaExtract("NodeControlSchema", null);  // BGP_Manager auto-start
	jhpSchemaExtract("PortDumpLoadSchema", null);  // edi load csv file generation
end;
</source>
    </JadeMethod>
    <JadeMethod name="jhpStatsAnalysis" id="2fa9f7c2-931d-4383-b8c3-75af252805ef">
        <source>jhpStatsAnalysis();

vars
	i,j:Integer; s,t:String; sa:StringArray; ia:IntegerArray;
	user:CM_User; userTerminal:CM_UserTerminal; bookingRef:CM_BookingRef;
begin
	app.initialize;
	create sa transient;
	create ia transient;
//	app.myRoot.allISOTypes.inspectModal;
//	jmtCreateRandomFiles;
	foreach bookingRef in CM_BookingRef.instances do
		s:=bookingRef.operatorCode;
//		s:=bookingRef.isoType;
		i:=sa.indexOf(s);
		if i = 0 then
			sa.add(s);
			ia.add(1);
		else
			ia[i]:=ia[i]+1;
		endif;
		j:=j+1;
	endforeach;
	foreach i in 1 to sa.size do
		write sa[i]&amp;Tab&amp;ia[i].String;
	endforeach;
	write sa.size;
epilog
	delete ia;
	delete sa;
	app.finalize;
end;
</source>
    </JadeMethod>
