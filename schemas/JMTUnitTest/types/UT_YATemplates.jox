    <JadeMethod name="iAddYATemplateWithObjectErrs" id="984b5bf6-d949-455e-b6fb-aca469991e5a">
        <updating/>
        <source>iAddYATemplateWithObjectErrs() updating;
//17 July 2008	cnwdw1	
//
vars
	yATemplate: CM_YATemplate;
	patterns: StringArray;
	pattern: String;
begin
	create patterns transient;
	patterns.add("DUG");
	patterns.add("DOUG, DUG");
	patterns.add("DUG, DOUG");
	
	foreach pattern in patterns do
		yATemplate := self.addYATemplate("YATemplate",  YACriteriaType_OperatorItem, pattern);
		self.assertTrueMsg(not app.myPassport.trxCompletedOK, "YATemplate did not give expected error for "&amp;pattern);
		self.assertEqualMsg(app.myPassport.allErrors.size, 1, "Error count");
		self.assertEqualMsg(app.myPassport.allErrors.first.errorCode, ErrYACriteriaNotFound, "Wrong error");
	endforeach;
	
epilog
	delete patterns;
end;</source>
    </JadeMethod>
    <JadeMethod name="iAddYATemplate_ContLenErr" id="3b31f56f-07bc-4208-b3de-634603c02005">
        <source>iAddYATemplate_ContLenErr();
//17 July 2008	cnwdw1	
//
vars
	yATemplate: CM_YATemplate;
	containers: String;
begin
	containers := "20,60";
	yATemplate := self.addYATemplate("YATemplate",  YACriteriaType_ContainerLength, containers);
	self.assertTrueMsg(not app.myPassport.trxCompletedOK, "YATemplate succeeded");
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="tAddYATemplate" id="c4b7e70a-8778-4184-ad97-efe7770e0d70">
        <source>tAddYATemplate();
// cnwndl1
//17 July 2008	cnwdw1	
//
vars
	yATemplate: CM_YATemplate;
begin
	yATemplate := self.addYATemplate("YATemplate",  YACriteriaType_Clean, CM_YADataBoolean.VALUE_TRUE);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "YATemplate failed");
	self.assertTrueMsg(yATemplate &lt;&gt; null, "yATemplate is null");
	self.assertTrueMsg(yATemplate.myYardAllocation &lt;&gt; null, "yATemplate.myTemplate is null");
	self.assertTrueMsg(yATemplate.myYardAllocation.myTerminal = null, "yATemplate.myTemplate.myTerminal is not null");
	self.assertTrueMsg(app.getMyTerminalDO_NOT_USE.getYATemplate("YATemplate") &lt;&gt; null, "YATemplate is not in Terminal collection");
	self.assertTrueMsg(app.getMyTerminalDO_NOT_USE.allYardAllocations.includes(yATemplate.myYardAllocation) = null, "YATemplate is in Terminal::allYardAllocations");
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="tAddYATemplateNotes" id="a1e2d53f-a7dd-4051-8a48-0dbf553389c9">
        <source>tAddYATemplateNotes();
// cnwndl1
//17 July 2008	cnwdw1	
//
vars
	yATemplate: CM_YATemplate;
begin
	registerNote(Event_YATemplateCreate);
	
	yATemplate := self.addYATemplate("YATemplate",  YACriteriaType_Clean, CM_YADataBoolean.VALUE_TRUE);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "YATemplate failed");
	self.assertTrueMsg(yATemplate &lt;&gt; null, "yATemplate is null");
	self.assertTrueMsg(yATemplate.myYardAllocation &lt;&gt; null, "yATemplate.myTemplate is null");
	self.assertTrueMsg(yATemplate.myYardAllocation.myTerminal = null, "yATemplate.myTemplate.myTerminal is not null");
	self.assertTrueMsg(app.getMyTerminalDO_NOT_USE.getYATemplate("YATemplate") &lt;&gt; null, "YATemplate is not in Terminal collection");

	self.assertNote(Event_YATemplateCreate, "Didn't get Create event");

epilog
	self.endNotificationForSubscriber(self);
end;</source>
    </JadeMethod>
    <JadeMethod name="tAddYATemplateWithObject" id="8fa203a7-b286-44fa-8838-0de7822c2769">
        <source>tAddYATemplateWithObject();
// cnwndl1
//17 July 2008	cnwdw1	
//
vars
	yATemplate: CM_YATemplate;
	patterns: StringArray;
	pattern: String;
begin
	create patterns transient;
	patterns.add("DOUG");
	patterns.add("DOUG, DOUG");
	
	foreach pattern in patterns do
		yATemplate := self.addYATemplate("YATemplate",  YACriteriaType_OperatorItem, pattern);
		self.assertTrueMsg(app.myPassport.trxCompletedOK, "YATemplate failed");
		self.assertTrueMsg(yATemplate &lt;&gt; null, "yATemplate is null");
		self.assertTrueMsg(yATemplate.myYardAllocation &lt;&gt; null, "yATemplate.myTemplate is null");
		self.assertTrueMsg(yATemplate.myYardAllocation.allCriteria.first.myYAData.isKindOf(CM_YADataObjects), "Not a CM_YADataObjects");
	
		self.deleteYATemplate("YATemplate");
	endforeach;
	
epilog
	delete patterns;
end;</source>
    </JadeMethod>
    <JadeMethod name="tAddYATemplate_AvGrade" id="a8187089-9372-43ff-8402-ab515224fb47">
        <source>tAddYATemplate_AvGrade();
// cnwndl1
//17 July 2008	cnwdw1	
//
vars
	yATemplate: CM_YATemplate;
	grade: CM_MTGrade;
	description: String;
begin
	grade := app.myRoot.allAvailabilityGrades.first;
	
	yATemplate := self.addYATemplate("YATemplate",  YACriteriaType_AvGrade, grade.code);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "YATemplate failed");
	self.assertTrueMsg(yATemplate &lt;&gt; null, "yATemplate is null");
	self.assertTrueMsg(yATemplate.myYardAllocation &lt;&gt; null, "yATemplate.myTemplate is null");
	self.assertTrueMsg(yATemplate.myYardAllocation.allCriteria.first.myYAData.isA(CM_YADataObjects), "Incorrect criteria myYAData");
	self.assertEqualMsg(yATemplate.myYardAllocation.allCriteria.first.myYAData.CM_YADataObjects.allObjects.size, 1, "allObjects size incorrect");
	self.assertTrueMsg(yATemplate.myYardAllocation.allCriteria.first.myYAData.CM_YADataObjects.allObjects.first = grade, "allObjects first not correct");
	description := yATemplate.myYardAllocation.allCriteria.first.getDescription();
	self.assertTrueMsg(description.pos(grade.code.String, 1) &gt; 1, "Incorrect criteria description "&amp;description&amp;" "&amp;grade.code.String);
	self.assertTrueMsg(yATemplate.myYardAllocation.myTerminal = null, "yATemplate.myTemplate.myTerminal is not null");
	self.assertTrueMsg(app.getMyTerminalDO_NOT_USE.getYATemplate("YATemplate") &lt;&gt; null, "YATemplate is not in Terminal collection");
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="tAddYATemplate_AvailableFalse" id="9121ebf8-f53c-46ad-9128-c89f1fcee7f7">
        <source>tAddYATemplate_AvailableFalse();
// jlgmd1
//10 Sep 2009	cnwkpd1
//
vars
	yATemplate: CM_YATemplate;
	description: String;
begin
	yATemplate := self.addYATemplate("YATemplate",  YACriteriaType_IsAvailable, CM_YADataBoolean.VALUE_FALSE);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "YATemplate failed");
	self.assertTrueMsg(yATemplate &lt;&gt; null, "yATemplate is null");
	self.assertTrueMsg(yATemplate.myYardAllocation &lt;&gt; null, "yATemplate.myTemplate is null");
	self.assertTrueMsg(yATemplate.myYardAllocation.allCriteria.first.myYAData.isA(CM_YADataBoolean), "Incorrect criteria myYAData");
	self.assertEqualMsg(yATemplate.myYardAllocation.allCriteria.first.myYAData.CM_YADataBoolean.value, CM_YADataBoolean.VALUE_FALSE, "allObjects size incorrect");
	description := yATemplate.myYardAllocation.allCriteria.first.getDescription();
	self.assertTrueMsg(description.pos("No", 1) &gt; 1, "Incorrect criteria description "&amp;description&amp;" "&amp;"No");
	self.assertTrueMsg(yATemplate.myYardAllocation.myTerminal = null, "yATemplate.myTemplate.myTerminal is not null");
	self.assertTrueMsg(self.getTerminal().getYATemplate("YATemplate") &lt;&gt; null, "YATemplate is not in Terminal collection");
epilog
end;
</source>
    </JadeMethod>
