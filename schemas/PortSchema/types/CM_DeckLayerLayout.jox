    <JadeMethod name="setProxyNewItem" id="d9ead744-b2b9-4b38-aa9e-60b542eb80b1">
        <source>setProxyNewItem() : CM_DeckItemLayout;
// ---------------------------------------------------------------------------
// Created:     06 April 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	pxyItemLayout: CM_DeckItemLayout;
	pointsPolygon : PointArray;

begin
	
	// ### BASIC GRAPHIC
	create pointsPolygon transient;
	create pxyItemLayout transient;
	pxyItemLayout.setDefaultOutline4(0,0, 100, 100,pointsPolygon);
	
	pxyItemLayout.setProxyRORO(DEFAULT_YARD_X, DEFAULT_YARD_Y, null, Black, 0, 0, null, pointsPolygon,self.code, self, Black, Frame.DrawFillStyle_Transparent, 1, true, DeckItemLayoutType_Graphic);
	
	return pxyItemLayout;// PAR 27509
epilog
	delete pointsPolygon;
	// ### DO NOT DELETE others as they are handled by the TRX

end;</source>
        <ReturnType type="CM_DeckItemLayout"/>
    </JadeMethod>
    <JadeMethod name="setProxyNewItemGC" id="0189b876-8565-4abe-afa9-b6c019ec3865">
        <source>setProxyNewItemGC(_isLoad : Boolean; _proxy : Boolean; _xMetres, _yMetres : Decimal; _code : String; _fillColour : Integer) : CM_DeckItemLayout;
/*
Purpose:			
Date				Who			Reason
JUNE 2011		CNWAB1		Initial creation
*/

vars
	pxyItemLayout: CM_DeckItemLayout;
	pointsPolygon : PointArray;
	layoutType, xPixel, yPixel : Integer;
begin
	
	// ### BASIC GRAPHIC
	if _proxy then
		create pointsPolygon transient;
		create pxyItemLayout transient;
	else
		create pointsPolygon;
		create pxyItemLayout;
	endif;
	
	xPixel := ((_xMetres * ROROStructurePixelsPerMetre) + ROROStructureRearLine).Integer;
	yPixel := ((_yMetres * ROROStructurePixelsPerMetre) + ROROStructureCentreLine).Integer;
	
	pxyItemLayout.setDefaultOutline4(xPixel,yPixel, xPixel + 200, yPixel + 100,pointsPolygon);
	
	if _isLoad then
		layoutType := DeckItemLayoutType_GCLoad;
	else
		layoutType := DeckItemLayoutType_GCDischarge;
	endif;
	pxyItemLayout.setProxyRORO(DEFAULT_YARD_X, DEFAULT_YARD_Y, null, Black, 0, 0, null, pointsPolygon,_code, self, _fillColour, Frame.DrawFillStyle_Solid, 1, true,layoutType);
	
	return pxyItemLayout;
epilog
	delete pointsPolygon;
	// ### DO NOT DELETE others as they are handled by the TRX

end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_proxy" type="Boolean"/>
        <Parameter name="_xMetres" type="Decimal"/>
        <Parameter name="_yMetres" type="Decimal"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_fillColour" type="Integer"/>
        <ReturnType type="CM_DeckItemLayout"/>
    </JadeMethod>
    <JadeMethod name="setProxyNewItemLoadCC" id="e0dd61d6-f77b-404e-bdcd-07b8080754a2">
        <source>setProxyNewItemLoadCC(_proxy : Boolean; _sides : Integer; _xMetres, _yMetres : Decimal; _code : String; _fillColour : Integer) : CM_DeckItemLayout;
/*
Purpose:	Creates a layout for the GC actual location defn, the load CC layout is done when the request is created.
Date				Who			Reason
JUNE 2011		CNWAB1		Initial creation
*/

vars
	pxyItemLayout: CM_DeckItemLayout;
	pointsPolygon : PointArray;
	xPixel, yPixel : Integer;
begin
	
	// ### BASIC GRAPHIC
	if _proxy then
		create pointsPolygon transient;
		create pxyItemLayout transient;
	else
		create pointsPolygon;
		create pxyItemLayout;
	endif;
	xPixel := ((_xMetres * ROROStructurePixelsPerMetre) + ROROStructureRearLine).Integer;
	yPixel := ((_yMetres * ROROStructurePixelsPerMetre) + ROROStructureCentreLine).Integer;

	if _sides = 4 then
		pxyItemLayout.setDefaultOutline4(xPixel,yPixel, xPixel + 200, yPixel + 200,pointsPolygon);
	elseif _sides = 6 then
		pxyItemLayout.setDefaultOutline6(xPixel,yPixel, 200, pointsPolygon); // PAR 28925
	elseif _sides = 8 then
		pxyItemLayout.setDefaultOutline8(xPixel,yPixel, 200, pointsPolygon); // PAR 28925
	endif;
	

	pxyItemLayout.setProxyRORO(DEFAULT_YARD_X, DEFAULT_YARD_Y, null, Black, 0, 0, null, pointsPolygon,_code, self, _fillColour, Frame.DrawFillStyle_Solid, 1, true, DeckItemLayoutType_GCLoad);
	
	return pxyItemLayout;
epilog
	delete pointsPolygon;
	// ### DO NOT DELETE others as they are handled by the TRX

end;</source>
        <Parameter name="_proxy" type="Boolean"/>
        <Parameter name="_sides" type="Integer"/>
        <Parameter name="_xMetres" type="Decimal"/>
        <Parameter name="_yMetres" type="Decimal"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_fillColour" type="Integer"/>
        <ReturnType type="CM_DeckItemLayout"/>
    </JadeMethod>
    <JadeMethod name="setProxyNewItemOOTL" id="622239b3-d55e-4cfd-939e-66c638cd4aee">
        <source>setProxyNewItemOOTL(_proxy : Boolean; _xMetres, _yMetres : Decimal; _is40 : Boolean; _horiz : Boolean; _code : String; _fillColour : Integer; _locnHeight, _locnWidth, _locnGap : Decimal io) : CM_DeckItemLayout;
/*
Purpose:			
Date				Who			Reason
JUNE 2011		CNWAB1		Initial creation
*/

vars
	pxyItemLayout: CM_DeckItemLayout;
	pointsPolygon : PointArray;
	xPixel, yPixel : Integer;
	allStateData : CM_StateDataDict;
	aVes : CM_Vessel;
	lblStr : String;
	locnHeight, locnWidth, locnGap : Decimal[12,2];
begin
/*
	aVes := self.getVessel();
	if aVes &lt;&gt; null then
		allStateData:= aVes.allStateData;
	endif;
	
//	deck:=self.myDeckLayout.myDeck;
	if allStateData.size= 0 then
		allStateData:= app.myRoot.getStateObject(ConfigGrp_System).allStateData;
	endif;
	lblStr := "OOTLLOCN";
	if _horiz then
		global.getExtraData(allStateData,RoRoLocationWidth,locnHeight);
		global.getExtraData(allStateData,RoRoLocationLength,locnWidth);
		global.getExtraData(allStateData,RoRoLocationGap,locnGap);
	else
		global.getExtraData(allStateData,RoRoLocationWidth,locnWidth);
		global.getExtraData(allStateData,RoRoLocationLength,locnHeight);
		global.getExtraData(allStateData,RoRoLocationGap,locnGap);
	endif;
	*/
	locnWidth := _locnWidth * 10;
	locnHeight := _locnHeight * 10;
	locnGap := _locnGap * 10;

	if _is40 then
		if _horiz then
			locnWidth := locnWidth * 2;
		else
			locnHeight := locnHeight * 2;
		endif;
	
	endif;
	
	// ### BASIC GRAPHIC
	if _proxy then
		create pointsPolygon transient;
		create pxyItemLayout transient;
	else
		create pointsPolygon;
		create pxyItemLayout;
	endif;
	
	xPixel := ((_xMetres * ROROStructurePixelsPerMetre) + ROROStructureRearLine).Integer;
	yPixel := ((_yMetres * ROROStructurePixelsPerMetre) + ROROStructureCentreLine).Integer;
	
	pxyItemLayout.setDefaultOutline4(xPixel,yPixel, (xPixel + locnWidth).Integer, (yPixel + locnHeight).Integer,pointsPolygon);
	
	pxyItemLayout.setProxyRORO(DEFAULT_YARD_X, DEFAULT_YARD_Y, null, Black, 0, 0, null, pointsPolygon,_code, self, _fillColour, Frame.DrawFillStyle_Solid, 1, true, DeckItemLayoutType_Locn);
	
	return pxyItemLayout;
epilog
	delete pointsPolygon;
	// ### DO NOT DELETE others as they are handled by the TRX

end;</source>
        <Parameter name="_proxy" type="Boolean"/>
        <Parameter name="_xMetres" type="Decimal"/>
        <Parameter name="_yMetres" type="Decimal"/>
        <Parameter name="_is40" type="Boolean"/>
        <Parameter name="_horiz" type="Boolean"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_fillColour" type="Integer"/>
        <Parameter name="_locnHeight" type="Decimal" usage="io"/>
        <Parameter name="_locnWidth" type="Decimal" usage="io"/>
        <Parameter name="_locnGap" type="Decimal" usage="io"/>
        <ReturnType type="CM_DeckItemLayout"/>
    </JadeMethod>
