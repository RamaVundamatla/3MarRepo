    <JadeMethod name="getMarksForCentringOnBerth" id="dc2b8e76-100c-4111-9c60-7864a091a804">
        <source>getMarksForCentringOnBerth(_loa : Decimal; _sideTo : Integer; _bowMark, _sternMark : Decimal output);
//--------------------------------------------------
// Created:	19 August 2004 By: cnwgd1
//--------------------------------------------------
vars
	adjustment,	
	availLength,
	centreOfBerth,	
	berthStart			: Integer;
	shipStartOnWharf,
	shipEndOnWharf		: Decimal[12,2];
	waterOnLeftmyWharf	: Boolean;	
	tmpWharf			: HMS_Wharf;	
begin
	// This method returns bow and stern marks for the ship that are centred on the berth.
	tmpWharf := self.myWharf;
	
	if tmpWharf = null then
		return;
	endif;
		
	berthStart := self.startPosition;
	centreOfBerth := berthStart + (self.length/2).Integer;
	shipStartOnWharf := centreOfBerth - (_loa/2);
	shipEndOnWharf := centreOfBerth + (_loa/2);

	if shipStartOnWharf &lt; (-tmpWharf.overhangZeroMetreEnd) then
		// ship too large for berth, adjust marks to fit	
		shipStartOnWharf := (-tmpWharf.overhangZeroMetreEnd);
		shipEndOnWharf := (shipStartOnWharf + _loa);
	endif;

	if shipEndOnWharf &gt; (tmpWharf.length + tmpWharf.overhangMaxMetreEnd) then
		// ship too large for berth, adjust marks to fit	
		shipEndOnWharf := (tmpWharf.length + tmpWharf.overhangMaxMetreEnd);
		shipStartOnWharf := (shipEndOnWharf - _loa);
	endif;

	// Determine whether bow or stern of ship is closest to start of wharf
 	// This takes the start and end positions of a ship along the wharf and returns its bow and stern marks
 	// based on the orientation of the ship:wharf:sea

 	waterOnLeftmyWharf := tmpWharf.waterOnLeft;

    if waterOnLeftmyWharf = true and _sideTo = OrientPortSideTo then
    	// CASE A: Water on left of wharf, ship is PortSideTo, bowMark=min, sternMark=max
		_bowMark := shipStartOnWharf;
		_sternMark := shipEndOnWharf;
    elseif waterOnLeftmyWharf = true and _sideTo = OrientStarboardSideTo then
    	// CASE B: Water on left of wharf, ship is StarboardSideTo, bowMark=max, sternMark=min
		_bowMark := shipEndOnWharf;
		_sternMark := shipStartOnWharf;
    elseif waterOnLeftmyWharf=false and _sideTo = OrientPortSideTo then
    	// CASE C: Water on right of wharf, ship is PortSideTo, bowMark=max, sternMark=min
		_bowMark := shipEndOnWharf;
		_sternMark := shipStartOnWharf;
    elseif waterOnLeftmyWharf = false and _sideTo = OrientStarboardSideTo then
    	 // CASE D: Water on right of wharf, ship is StarboardSideTo, bowMark=min, sternMark=max
		_bowMark := shipStartOnWharf;
		_sternMark := shipEndOnWharf;
    endif;

end;</source>
        <Parameter name="_loa" type="Decimal"/>
        <Parameter name="_sideTo" type="Integer"/>
        <Parameter name="_bowMark" type="Decimal" usage="output"/>
        <Parameter name="_sternMark" type="Decimal" usage="output"/>
    </JadeMethod>
