    <JadeMethod name="getCargoSubType" id="1651b2a0-9023-46d4-9c6b-50994aef16db">
        <source>getCargoSubType():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Oct 2023 navhl20 ChangeRequest 60033: EUP | Ship Operations in DD - [54176.010] - [Receive] Ship Job List 
29 Jan 2023 navhl20 ChangeRequest 62166: EUP | 53729 - Delivery Dispatch Screen - outstanding issues
08 Apr 2024 navhl20 ChangeRequest 63251: FR | 53729 - Delivery Dispatch screen - Further issues and Remedial work - 1
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	ti 				: CM_TrackedItem;
	request			: CM_Request;
	wle				: CM_WorkListEntry;
	invalid			: Boolean;
	objset			: CM_ObjectSet;
begin
	on Exception do app.handleDeletedObject(exception, ti, invalid);		//29.01.2023 navhl20 #62166
	
	create objset transient;
	foreach wle in self.workListEntries discreteLock do						//29.01.2023 navhl20 #62166
		invalid := false;
		ti 	    := wle.myTrackedItem;
	
		if ti &lt;&gt; null then
			ti.edition;
			if invalid then
				continue;
			endif;
		
			objset.tryAddIfNotNull(ti.myProduct);

		endif;
	endforeach;
	
	if objset.isNotEmpty then
		return objset.listString(Comma,CM_Product::description.name);
	endif;
	
	request := self.getRequest();
	if request &lt;&gt; null and request.myReserveDetail &lt;&gt; null then
		return request.myReserveDetail.getCargoSubType();
	endif;
	
	return null;
epilog
	delete objset;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCommodity" id="a49ac201-d194-4280-b103-c79d1bba5dc9">
        <source>getCommodity():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Oct 2023 navhl20 ChangeRequest 60033: EUP | Ship Operations in DD - [54176.010] - [Receive] Ship Job List 
28 Nov 2023 navhl20 ChangeRequest 61508: EUP | Ship Operations in DD - [54176.010] - [Release] Ship Job List 
29 Jan 2023 navhl20 ChangeRequest 62166: EUP | 53729 - Delivery Dispatch Screen - outstanding issues
25 Mar 2024 navhl20 ChangeRequest 62300: EUP | 53729 - Delivery Dispatch Screen - outstanding issues - 2
08 Apr 2024 navhl20 ChangeRequest 63251: FR | 53729 - Delivery Dispatch screen - Further issues and Remedial work - 1
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	ti 			: CM_TrackedItem;
	request		: CM_Request;
	wle			: CM_WorkListEntry;
	invalid		: Boolean;
	commodityObj: CM_Commodity;
	objset	    : CM_ObjectSet;
begin
	on Exception do app.handleDeletedObject(exception, ti, invalid);		//29.01.2023 navhl20 #62166
	
	create objset transient;
	foreach wle in self.workListEntries discreteLock do						//29.01.2023 navhl20 #62166
		invalid := false;
		ti      := wle.myTrackedItem;
	
		if ti &lt;&gt; null then
			ti.edition;
			if invalid then
				continue;
			endif;
			
			commodityObj := ti.getCommodityObject();						//08.04.2024 navhl20 #63251
			objset.tryAddIfNotNull(commodityObj);

		endif;
	endforeach;
	
	if objset.isNotEmpty then
		return objset.listString(Comma,CM_Commodity::code.name);
	endif;
	
	request := self.getRequest();
	if request &lt;&gt; null  then
		if self.isKindOf(CM_WOPackJob) then				//25.03.2024 navhl20 #62300
			return request.getReqCommodity(false);
		else
			return request.getReqCommodity(true);
		endif;
	endif;
	return null;
epilog
	delete objset;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCountIncompleteWLE" id="6cf51904-db10-42a0-a164-0669f3ffb53a">
        <source>getCountIncompleteWLE() : Integer;
// -----------------------------------------------------------------------------
// Created:		22 July 2009 by consw1
//
// Purpose:		Count number of WLE remaining to be completed
//
// Parameters:	None
//
// Returns:		Count
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 06 Mar 2025 navma1		 MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
// -----------------------------------------------------------------------------

vars
	count : Integer;
	wle	: CM_WorkListEntry;
	
begin
	foreach wle in self.workListEntries discreteLock where wle.status &lt;&gt; WLE_COMPLETED do
		count := count + 1;
	endforeach;

	return count;
	
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCountRTQueuedWLE" id="87c6e233-c1d5-46ec-be20-12370686461c">
        <source>getCountRTQueuedWLE() : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 August 2009	cnwrd1	Initial creation

*/

vars
	wle : CM_WorkListEntry;
	count : Integer;
begin
	
	foreach wle in self.workListEntries discreteLock do
		if not wle.allRTQueueEntries.isEmpty() then
			count := count + 1;
		endif;
	endforeach;
	return count;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCountUnactionedWLE" id="72ece151-d76c-4c62-8404-592d1241e220">
        <source>getCountUnactionedWLE() : Integer;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 25/10/2019	jlgdap1		Initial creation TFS 47079 PRP Release Qty Issue
// 06 Mar 2025 navma1 		MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
//
vars
	count : Integer;
	wle	: CM_WorkListEntry;
	
begin
	foreach wle in self.workListEntries discreteLock where wle.status &lt;&gt; WLE_COMPLETED and wle.status &lt;&gt; WLE_PART_COMPLETE do
		count := count + 1;
	endforeach;

	return count;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCountUnallocatedWLE" id="f9b5628f-ebc9-45d7-a0ff-51d927f0c1fb">
        <source>getCountUnallocatedWLE() : Integer;
// -----------------------------------------------------------------------------
// Created:		22 July 2009 by consw1
//
// Purpose:		Count number of WLE remaining to be completed without a TI allocated
//
// Parameters:	None
//
// Returns:		Count
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 06 Mar 2025 navma1 MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
// -----------------------------------------------------------------------------

vars
	count : Integer;
	wle	: CM_WorkListEntry;
	
begin
	foreach wle in self.workListEntries discreteLock where wle.status &lt;&gt; WLE_COMPLETED do
		if wle.myTrackedItem = null then
			count := count + 1;
		endif;
	endforeach;

	return count;
	
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
