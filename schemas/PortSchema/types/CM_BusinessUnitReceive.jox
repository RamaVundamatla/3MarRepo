    <JadeMethod name="getChargeableBusinessUnit" id="9f2926d1-0cb6-4713-a1d4-e934fc9062e9">
        <source>getChargeableBusinessUnit() : CM_Bank;

vars
	term				: CM_Terminal;
	termDict			: CM_TerminalByCodeDict;
	bank				: CM_Bank;	
begin
	termDict := app.myRoot.allTerminals;
	foreach term in termDict do
		bank := term.companies[releasingCompanyCode];
		if bank &lt;&gt; null then
			break;
		endif;
	endforeach;
	
	return bank;
	
end;</source>
        <ReturnType type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="a62610b0-05a4-46f5-ba70-9a89f5696962">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498

*/

vars
	lDetail : String;
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
		else
			lDetail := "Releasing Business Unit: " &amp; self.releasingCompanyCode.trimBlanks;

			if lDetail &lt;&gt; "" then
				lDetail := lDetail &amp; " " &amp; self.urNumber.String;
			else
				lDetail := self.urNumber.String;
			endif;			
			
			return lDetail;
			
		endif;
		
	elseif _attrName = ETRow_ReceiveBusinessUnit then
		return releasingCompanyCode;
	
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="a714f522-7a17-45ba-a45f-2cdc11f90a3b">
        <source>getEnquiryRow(): String;
// ---------------------------------------------------------------------------
// Created:  May  2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lDetail : String;
begin
	lDetail := inheritMethod();
	lDetail := lDetail &amp; "Releasing Business Unit: " &amp; self.releasingCompanyCode.trimBlanks;

	if lDetail &lt;&gt; "" then
		lDetail := lDetail &amp; " " &amp; self.urNumber.String;
	else
		lDetail := self.urNumber.String;
	endif;			
	
	return lDetail;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
