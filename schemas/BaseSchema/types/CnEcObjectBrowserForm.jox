end;</source>
    </JadeMethod>
    <JadeMethod name="loadInstances" id="4c2f7ea7-36dd-4d0a-a2fb-16c047671897">
        <source>loadInstances(pClass:Class) protected;
// --------------------------------------------------------------------------------
// Created:		09 January 1999 by cnwdad1
//
// Purpose:		Loads all instances of a Class into the JAC Design Table.
//
// Parameters:	pClass (Class) - The class whose instances to load.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 16/2/1999	cnwdad1		Remove check of 'getProperties' being empty and doing a
//							return if so.  This method doesn't include inherited
//							properties, so if a subclass had no properties but did
//							inherit properties, it showed up as having no properties.
//
// --------------------------------------------------------------------------------
vars
	thePropertyColl	: PropertyColl;
	property		: Property;
	index			: Integer;

begin
	tblObjects.CnEcDesignTable.clear();
	lblClass.caption	:=	pClass.name;
	lblCount.caption	:=	pClass.instances.size.String;
	tblObjects.rows		:=	1;
	tblObjects.columns	:=	2;	// Column 1 is the JACDesign tables hidden column, column 2 is for the OID.

	/*
		Note that the JAC Design Table has 1 hidden column (column 1).
		One additional column (column 2) is added to display the object
		OID, which will always display as column 1 (because the real
		column 1 is hidden).  Additional columns will be dynamically
		added for each of the class's properties - references to these
		columns is therefore offset by 2.
	*/

	tblObjects.setCellText(1, 2, "Object OID");

	if tblObjects.columnWidth[2] &lt; (tblObjects.getTextExtent(tblObjects.getCellText(1, 2)) + 10) then
		tblObjects.columnWidth[2]	:=	tblObjects.getTextExtent(tblObjects.getCellText(1, 2)) + 10;
	endif;

	index			:=	2;
	thePropertyColl	:=	pClass.allProperties();
	
	foreach property in thePropertyColl do 
		// If it's not a System Class, then we don't want to see the System properties,
		// but if it is a System Class, then we want to see all of the properties.
		if (not self.myClass.isSystemObject
		and not property.isSystemObject())
		or (self.myClass.isSystemObject())
		then
			index	:=	index + 1;

			if tblObjects.columns &lt; index then
				tblObjects.columns	:=	index;
			endif;

			tblObjects.setCellText(1, (index), property.name);

			if tblObjects.columnWidth[index] &lt; (tblObjects.getTextExtent(tblObjects.getCellText(1, index)) + 10) then
				tblObjects.columnWidth[index]	:=	tblObjects.getTextExtent(tblObjects.getCellText(1, index)) + 10;
			endif;

			if property.isUsedAsKey then
				tblObjects.cnEcSetCellForeColor(1, index, Red);
			endif;
		endif;
	endforeach;

	btnEdit.enabled		:=	false;
	btnDelete.enabled	:=	false;

	if pClass.instances.isEmpty() then
		return;
	endif;

	tblObjects.sizeColumnArrays();
	tblObjects.rebuildColumnHeadingArray();
	self.myObjectSet.clear();
	pClass.instances.copy(self.myObjectSet);
	tblObjects.listCollection(self.myObjectSet, false, 0);
	tblObjects.clearAllSelected();
epilog
	delete thePropertyColl;
end;</source>
        <access>protected</access>
        <Parameter name="pClass" type="Class"/>
    </JadeMethod>
    <JadeMethod name="mnuPopupBrowse_click" id="ecc3ac68-1237-480b-b875-f21c967b2ee3">
