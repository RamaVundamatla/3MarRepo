        <updating/>
        <source>trxCreateSavedConflictReport( _cmif_hms_conflictManager : CMIF_HMS_ConflictsManager; _realSavedConflictReport : HMS_SavedConflictReport output; _passport : CM_Passport input) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
08 March 2008	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
