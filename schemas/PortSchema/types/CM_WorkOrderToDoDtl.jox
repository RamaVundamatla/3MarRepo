    <JadeMethod name="setProxyToDoTaskDetails" id="4a14f90b-406c-4908-a772-2a40b153bc9f">
        <updating/>
        <source>setProxyToDoTaskDetails(_remarks				: String; 
						_priority				: Integer;
						_allToDoTasksDescs		: CM_ToDoTaskDescSet)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Mar 2023 navma1 ChangeRequest 56840:[54265] EUP - [Framework] - VAS Work Order Maintenance Screen
20 Mar 2023 navhl20 Defect 57233: MTN - Editing Vas Tasks is not working correctly
06 Apr 2023 navhl20 ChangeRequest 57477:[57478] EUP - Moving No charge Option to be under Financial Tab
*/

vars

begin
	self.priority 				:= _priority;
	self.remarks 				:= _remarks;
	self.allToDoTasksDescs.clear();											//20.3.2023 navhl20	#57233
	_allToDoTasksDescs.copyNoDuplicates(self.allToDoTasksDescs, false);
epilog

