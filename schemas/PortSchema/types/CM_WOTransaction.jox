    <JadeMethod name="getDescription" id="2bec1d6f-f1ae-42f8-b5c9-a28bbb7aadd9">
        <source>getDescription() : String;
/*

Purpose:		TFS 39237	

Parameters:			

Return Value:		

Date		Who		Reason
26 June 2018	jlgab1	Initial creation

*/

vars
	desc : String;
begin
	 // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
	if self.myWorkOrderDetail &lt;&gt; null then
		desc := self.myWorkOrderDetail.myParent.id &amp; " " &amp;  self.myWorkOrderDetail.getDisplayString(true);  // ### TFS CR 54345 TASK 58281 01JUN2023 NAVAB1
	else
		desc := self.myWorkOrder.getDisplayString();
	endif;
	
	if self.myToDoTask &lt;&gt; null then
		desc := desc &amp; " (" &amp; self.myToDoTask.toDoTaskDescDesc &amp;")";
	endif;
	
	
	return desc;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDetailType" id="ccb86432-29f5-4916-8873-1c118a33ac43">
        <source>getDetailType():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 April 2023	navhl20	Bug 57453: EUP - Duplicate Complete Transaction when completing ToDo &amp; Cargo Work Orders

*/

vars

begin
	if self.myWorkOrderDetail &lt;&gt; null then
		return self.myWorkOrderDetail.getDisplayString(true);
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="2fe79422-e66b-44ba-8b6a-71cd8d461f41">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/* TFS 39237
Purpose:			
Date				Who			Reason
JUNE 2018		CNWAB1		Initial creation
17 Jan 2023 	navhl20 	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query
20/03/2023		navcs2		Defect 57184: MTN - WO - Resources Used and Special Rates columns are missing on the Work Order Transactions form
21 Mar 2023		navhl20		Defect 57184: MTN - WO - Resources Used and Special Rates columns are missing on the Work Order Transactions form
06 Apr 2023 	navhl20 	Bug 57453: EUP - Duplicate Complete Transaction when completing ToDo &amp; Cargo Work Orders
12 Apr 2023 	navma1 		ChangeRequest 57569:[57570] EUP - [Framework] Refactor Actioning Work Order Tasks
07 Jul 2023 	navhl20 	Bug 59042: EUP | Pack Release Request is Missing From Work Order Selector Query
20 Jun 2024 	navhl20 	Bug 64718: EUP | 53812 - VAS Work Order - WO Transactions Report issues
*/

vars
	debtor	: CM_Debtor;
	voyage	: CM_Voyage;
	ts		: TimeStamp;
begin
	if _attrName = ETRow_Charged then
		return app.getYesBlank(not self.allInvoiceLines.isEmpty());
	elseif _attrName = ETRow_NoCharge then
		return app.getYesBlank(self.noCharge);
		
	elseif _attrName = ETRow_Date then
		return self.systemToLocalTime(self.dateTime).date.asStringJMT();
		
	elseif _attrName = ETRow_Time then
		return self.systemToLocalTime(self.dateTime).time.asStringJMT();
	elseif _attrName = ETRow_TransactionDT then
		return self.systemToLocalTime(self.dateTime).shortCurrentLocaleFormat;
	elseif _attrName = ETRow_TypeString then
		return self.getTranTypeString();
	elseif _attrName = ETRow_MyHMSVoyageData then	
		voyage := self.getMyVoyageObject();
		if voyage &lt;&gt; null then	
			return voyage.code;
		endif;
		return null;
	elseif _attrName = ETRow_Debtor then
		debtor := self.getMyDebtor();
		if debtor &lt;&gt; null then
			return debtor.name;
		endif;
		return null;
	
	elseif _attrName = ETRow_User or
		   _attrName = ETRow_UserName then
		return self.getMyUserCode();
	
	elseif _attrName = ETRow_MyTerminal or 
	   _attrName = ETRow_Terminal then
		if self.myTerminal &lt;&gt; null then
			return self.myTerminal.name;
		endif;
		return null;
		
	elseif _attrName = ETRow_Description then
		return self.getDescription();
	elseif _attrName = ETRow_ResourcesUsed then		// 20.03.2023	navcs2	#57184		//06.4.2023 navhl20	#57453
		return self.getResourceUsageQuantStringJRW();	// 20.03.2023	navcs2	#57184
	 // ### TFS CR 54345 TASK 58281 01JUN2023 NAVAB1 - start
	elseif _attrName = ETRow_UsesResources  then
		return self.hasTaskThatAllowsResources.getYes();
	elseif _attrName = ETRow_HasResources then
		return self.allResourceUsages.isNotEmpty.getYes();
	 // ### TFS CR 54345 TASK 58281 16JUN2023 NAVAB1 - end
 // ### TFS CR 56814 TASK 56813 07JUL2023 NAVAB1	elseif _attrName = ETRow_SpecialRate then			// 20.03.2023	navcs2	#57184
 // ### TFS CR 56814 TASK 56813 07JUL2023 NAVAB1		return self.getSpecialRate();					// 20.03.2023	navcs2	#57184
	//Start 17.01.2023 navhl20 #54350[54269]
	elseif _attrName = ETRow_InvoiceNumber then
		return self.getInvoiceNumber();
	elseif _attrName = ETRow_DetailType then											//06.4.2023 navhl20	#57453
		return getDetailType();
	elseif _attrName = ETRow_WorkOrderNumber then
		return self.getWONumber();
	elseif _attrName = ETRow_WorkOrderOperator then
		return self.getMyWOOper();
	elseif _attrName = ETRow_WorkOrderReqDT then
		return self.systemToLocalTime(self.getMyWOReqDT).shortCurrentLocaleFormat;
	elseif _attrName = ETRow_WorkOrderType then
		return self.getMyWOType();
	elseif _attrName = ETRow_MyProduct then
		return self.getCargoSubTypes();
	elseif _attrName = ETRow_Commodity then
		return self.getCargoCommodity();
	elseif _attrName = ETRow_CargoMarks then
		return self.getCargoMarks();
	elseif _attrName = ETRow_CargoMarkNumber then
		return self.getCargoMarkNumbers();
	elseif _attrName = ETRow_CargoPurchaseOrder then
		return self.getCargoPOs();
	elseif _attrName = ETRow_CargoServiceOrder then
		return self.getCargoSOs();
	elseif _attrName = ETRow_CargoBol then
		return self.getCargoBOLs();
	elseif _attrName = ETRow_CargoColour then
		return self.getCargoColours();
	elseif _attrName = ETRow_CargoTypeDescr then
		if self.getCargoTypes() &lt;&gt; null then
			return app.myRoot.allCargoTypesById[self.getCargoTypes().Integer].description;
		endif;
		return null;
	//End 17.01.2023 navhl20 #54350[54269]
	
	elseif _attrName = ETRow_WagonNumber then		//Start 21.3.2023 navhl20 #57184
		return self.getWagonCode();
	elseif _attrName = ETRow_Consignee then
		return self.getCargoConsignees();
	elseif _attrName = ETRow_Consignor then
		return self.getCargoConsignors();
	elseif _attrName = ETRow_DestinationPort then
		return self.getCargoDestPorts();
	elseif _attrName = ETRow_DischargePort then
		return self.getCargoDischPorts();
	elseif _attrName = ETRow_FreightForwarderCode then
		return self.getCargoFForwarders();
	elseif _attrName = ETRow_CargoGrpId then
		return self.getCargoGroupIds();
	elseif _attrName = ETRow_VoyageCode then
		return self.getVoyageCode();
	elseif _attrName = ETRow_VbsRef then
		return self.getVBSCode();
	elseif _attrName = ETRow_ToDoTask then												//06.4.2023 navhl20	#57453
		return self.getTodoTaskDesc();
	elseif _attrName = ETRow_TruckLicensePlate then
		return self.getRegNumber();		
	elseif _attrName = ETRow_VvrCode then												//20.06.2024 navhl20 #64718
		return self.getVVRCode();
	elseif _attrName = ETRow_TrainCode then
		return self.getTrainCode();
	elseif _attrName = ETRow_TotalQuant then
		return self.getTotalQuantity().asStringJMT;
	elseif _attrName = ETRow_RelCargoRelReqNumber then
		return self.getReleaseRequestRef();
	elseif _attrName = ETRow_ReceiveCargoBookRef then
		return self.getRecieveBookingRef();
	elseif _attrName = ETRow_OperatorCode then
		return self.getCargoOperators();
	elseif _attrName = ETRow_ImexStatus then
		if self.getCargoIMEX() &lt;&gt; null then
			return self.getCargoIMEX().description;
		endif;
		return null;								//End 21.3.2023 navhl20	#57184
	elseif _attrName= ETRow_CargoWOId then
		return self.getCargoIds;
	
	elseif _attrName = ETRow_TransDetails then		//12.04.2023 navma1 #57569:[57570]
		return null;
	elseif _attrName = ETRow_PackRelReqNumber then										//07.7.2023 navhl20 #59042
		return self.getPackRelReqNumber();
	endif;
	
	return inheritMethod(_attrName, _short);
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
