    <JadeMethod name="thZShowRTGLane1GridArea" id="09c408ac-81e0-443d-b724-172213c02f36">
        <source>thZShowRTGLane1GridArea();

vars
	frm		: CM_BaseForm;
	lst		: CMUI_MultiSelectGroupBox;
	objArray		: ObjectArray;
	btnShow			: Button;
begin
	frm := self.myGridAreaForm;
	lst := frm.getPropertyValue('msgSelectAreas').CMUI_MultiSelectGroupBox;
	create objArray transient;
	objArray.add(app.myPassport.myTerminal.allTerminalAreasByTypeId[TA_TYPE_RTG, 'Y']);
	
	lst.setSelected(objArray);
	btnShow := frm.getPropertyValue('btnSelectAreasSh').Button;
	btnShow.click(btnShow);
	
	
epilog
	delete objArray;
end;
</source>
