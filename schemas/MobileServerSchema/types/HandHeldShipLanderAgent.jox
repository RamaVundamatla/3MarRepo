    <JadeMethod name="getWhoAmIInfo" id="594fd232-2ffb-45c6-bf34-a8550b9febf7">
        <source>getWhoAmIInfo() : String;
// ---------------------------------------------------------------------------
// Created:		24 October 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	mess : String;
begin
	
	mess := inheritMethod();
	
	if self.myMachine &lt;&gt; null then
		mess := mess &amp; "Machine :"  &amp; self.myMachine.id &amp; CrLf;
		if self.myMachine.myPrimaryQueue &lt;&gt; null then
			mess := mess &amp; "Queue :"  &amp; self.myMachine.myPrimaryQueue.id;
		endif;
								
	endif;
	
	return mess;
end;</source>
