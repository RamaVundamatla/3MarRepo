<Class name="CM_JRWVehicleBookings" id="a95e4635-1336-4f3f-8b42-895ca2a40345">
    <superclass name="CM_JRWTransient"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <ImplicitInverseRef name="allVehicleBookings" id="03c6231f-8a00-4551-a006-1b722e789525">
        <memberTypeInverse/>
        <type name="CM_VehicleBookingByTs"/>
    </ImplicitInverseRef>
    <PrimAttribute name="dateFrom" id="4f1f6a1d-aa88-49ee-bfee-28fc38b4b45a">
        <embedded/>
        <type name="Date"/>
    </PrimAttribute>
    <PrimAttribute name="dateTo" id="a3d21638-520e-4d38-8837-31d8fa540757">
        <embedded/>
        <type name="Date"/>
    </PrimAttribute>
    <PrimAttribute name="inclUnBooked" id="e02e0bb0-49f8-42fe-ab02-070d58d7bc23">
