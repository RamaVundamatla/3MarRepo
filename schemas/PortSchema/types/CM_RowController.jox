    <JadeMethod name="validateForDelete" id="e1fb0469-6303-424d-961c-cb9bb11066ad">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 10/06/2020	jlgdap1		TFS 49453 ASPA Satellite Area Screen for Flexible Terminal Areas
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod();
	if self.myRow = null then
		app.raiseCMException1(RemoveLogRowError, self.id &amp; "'s Row is null. Cannot Delete.",null, null);	
	endif;	
	//if self.myRowArea = null then															// TFS 49453
	if self.myRowArea = null and not self.isKindOf(CM_GeneralCargoAllocController) then		// TFS 49453
		app.raiseCMException1(RemoveLogRowError, self.id &amp; "'s Row Area is null. Cannot Delete.",null, null);	
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateID" id="ede282be-2c40-4224-b3ab-e39b108a77a7">
        <source>validateID();
// ---------------------------------------------------------------------------
// Created:     06 June 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	rowController	: CM_RowController;
	//iterator		: Iterator;

begin
	rowController := self.myTerminalArea.CM_RowArea.allRowControllersById[self.id].CM_RowController;
	if rowController &lt;&gt; null then
		app.raiseCMException2(ERR_INVALID_VALUE, "the row controller id is already in use and therefore ", null, null, null);
	endif;

	/*
	iterator := self.myTerminalArea.CM_RowArea.allRowControllersById.createIterator;
	while  iterator.next(rowController) do
		if rowController = self then
			continue;
		endif;
		if rowController.id = self.id then			
			app.raiseCMException2(ERR_INVALID_VALUE, "the row controller id is already in use and therefore ", null, null, null);
		endif;
	endwhile;	
epilog
	delete iterator;
	*/
end;</source>
    </JadeMethod>
    <JadeMethod name="validateMoveTo" id="4c559b93-6d40-4f8f-a77c-ec0f03b9cb6f">
        <source>validateMoveTo(control: CMIF_MoveController input);
// ---------------------------------------------------------------------------
// Created:     15 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tAutoPlanMove : CMIF_AutoMovePlan;
begin

	if control.isForcedMove then
		return;
	endif;
	inheritMethod(control);
	//------------------
	//  Creat a transient automoveplan from our moveController so we can share
	//  same code as the autoPlan tests.
	//------------------
	tAutoPlanMove := control.createAsAutoMovePlan();
	tAutoPlanMove.setOriginatingController(self);
	
	self.testIsControllerLocnRestricted(tAutoPlanMove);	//This will raise warnings etc

epilog
	delete tAutoPlanMove;

end;</source>
        <Parameter name="control" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
</Class>
