    <JadeMethod name="doMnuHideClick" id="039806c7-a55d-4911-858c-fe0a1319d3a0">
        <updating/>
        <source>doMnuHideClick(_menuItem :MenuItem input)updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
// 10/03/2011	cnwcs5	CCMS CPL 2017/PAR 27126 - pass menuitem as parameter
vars

begin
	if _menuItem.caption = self.MNU_MACRO_HIDE then
		_menuItem.caption := self.MNU_MACRO_SHOW;
		self.splMain.hideRightControl(true);
	else
		_menuItem.caption := self.MNU_MACRO_HIDE;
		self.splMain.showRightControl(30, true);
		self.frmPopupInfo.visible := false;
	endif;




end;</source>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuInspectObject" id="d5ed120f-a721-4f86-a1ff-666560c207f0">
        <source>doMnuInspectObject();
//--------------------------------------------------
// Created:	12 December 2003 By: cnwgd1
//--------------------------------------------------
vars
	anObject : Object;
begin
	if self.myCurrentTrackedItem &lt;&gt; null then
		self.myCurrentTrackedItem.inspectModal;
	elseif self.tblData.row &gt; self.tblData.fixedRows then
		anObject := self.tblData.accessRow(self.tblData.row).itemObject;
		if anObject &lt;&gt; null then
			anObject.inspect;
		endif;
	endif;
end;</source>
    </JadeMethod>
