    <JadeMethod name="setXMLData" id="bda47c7d-54ab-42ce-9580-5784ea4fdb36">
        <updating/>
        <source>setXMLData(_theXMLData : String) updating;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theXMLTagValue : String;
	inTransState : Boolean;
begin
	inTransState:=process.isInTransactionState;
	if not inTransState then
		beginTransaction;
	endif;
	self.allCommandsAft.purge;
	self.allCommandsBridge.purge;
	self.allCommandsForward.purge;
	self.allCommandsCrane1.purge;

	theXMLTagValue := _theXMLData.cnEcGetTagValueOfName("maxAft"); 
	self.maxXAft := theXMLTagValue.Integer;
	theXMLTagValue := _theXMLData.cnEcGetTagValueOfName("maxBridge"); 
	self.maxXBridge := theXMLTagValue.Integer;
	theXMLTagValue := _theXMLData.cnEcGetTagValueOfName("maxForward"); 
	self.maxXForward := theXMLTagValue.Integer;
	theXMLTagValue := _theXMLData.cnEcGetTagValueOfName("maxCrane1"); 
	self.maxXCrane1 := theXMLTagValue.Integer;
	if not inTransState then
		commitTransaction;
	endif;

	theXMLTagValue := _theXMLData.cnEcGetTagValueOfName("AFT"); 
	self.setXMLSub(theXMLTagValue,self.INDEX_AFT);
	theXMLTagValue := _theXMLData.cnEcGetTagValueOfName("FWD"); 
	self.setXMLSub(theXMLTagValue,self.INDEX_FORWARD);
	theXMLTagValue := _theXMLData.cnEcGetTagValueOfName("BRD"); 
	self.setXMLSub(theXMLTagValue,self.INDEX_BRIDGE);
	theXMLTagValue := _theXMLData.cnEcGetTagValueOfName("CRN1"); 
	self.setXMLSub(theXMLTagValue,self.INDEX_CRANE1);
	
	
epilog
end;</source>
        <Parameter name="_theXMLData" type="String"/>
    </JadeMethod>
    <JadeMethod name="setXMLSub" id="c88bdc33-e423-4f6e-979c-5f7e5b469032">
        <source>setXMLSub(_theXMLData : String;_index : Integer);
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aCommand : CM_GraphicCommand;
	theXMLTagValue : String;
	idx,pos: Integer;
	inTransState : Boolean;
begin
	inTransState:=process.isInTransactionState;
	if not inTransState then
		beginTransaction;
	endif;
	pos := 1;
	while (pos &gt; 0) do
		theXMLTagValue := _theXMLData.cnEcGetNextTagValueOfName("CMD",pos); 
		if theXMLTagValue = null then
			break;
		endif;
		
		create aCommand;
		aCommand.setXMLData(theXMLTagValue);
		
		if _index = self.INDEX_AFT then
			aCommand.myVLGAft := self;
		elseif _index = self.INDEX_CRANE1 then
			aCommand.myVLGCrane1 := self;
		elseif _index = self.INDEX_BRIDGE then
			aCommand.myVLGBridge := self;
		elseif _index = self.INDEX_FORWARD then
			aCommand.myVLGForward := self;
		endif;
		
	endwhile;
	if not inTransState then
		commitTransaction;
	endif;
epilog
end;</source>
        <Parameter name="_theXMLData" type="String"/>
        <Parameter name="_index" type="Integer"/>
    </JadeMethod>
</Class>
