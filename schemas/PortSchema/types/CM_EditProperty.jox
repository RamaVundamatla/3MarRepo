        <source>setForCreate(_attrName, _beforeValue, _afterValue : String; _editTrans : CM_Edit) updating;
// ---------------------------------------------------------------------------
// Created:     14 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.attrName		:= _attrName;
