    <JadeMethod name="getPreGateCompleteTime" id="4887a0f2-5e04-4a33-9a7d-77b730acf859">
        <source>getPreGateCompleteTime() : TimeStamp;
// ---------------------------------------------------------------------------
// Created:     02 April 2008 by cnwrs2
//
// Purpose:     Used from Report Writer
// ---------------------------------------------------------------------------
/* 	Date		User	Reason
   ---------------------------------------------------------------------------
	19/05/2009	concms1	Par 19715 - Changed code to be compatible with changed collection keys
*/
vars
	tmpDtl	: CM_VehicleVisitRecordDetail;
	
begin
	//tmpDtl := self.allVehicleVisitRecordDetails[VisitRecord_PreGate];
	tmpDtl := self.getFirstPreGateVVRD;	// par 19715
	
