    <JadeMethod name="tCreateLogDocketData" id="7a347ce4-c77d-4fc1-b460-90ac34cae9d6">
        <source>tCreateLogDocketData();
// cnwns1
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 April 2014	cnwmc5	Initial creation	CCMS 1127

*/
constants

	DOCK_NO			: String = "UT_DOCK";
	LOG_AREA		: String = "UT_LOGA1";
	LOG_AREA_COMM	: String = "UT Log Area 1";
	
	OPERATOR		: String = "DOUG";
	
vars
	
	dockNo 			: String;
	
	terminal		: CM_Terminal;
	logDocketData	: CM_LogDocketData;
	operator		: CM_Operator;
	
	cmif_LogRow		: CMIF_LogRowRestriction;
	
	logModule		: UT_LogModule;
	
	tmpCodeGroup	: CM_CodeGroup;
	
	originalWeighBridgeEnable : Boolean;
	
begin
	terminal := self.getTerminal();
	
	//Set config
	self.setTerminalConfig(WeighBridgeEnabled, true);
	
	//Delete old Log Docket Data objects
	dockNo := DOCK_NO;
	foreach logDocketData in terminal.allLogDocketDataByOidString do
		if logDocketData.docketNumber = dockNo then
			app.myTrxDA.trxDeleteLogDocketData(logDocketData, app.myPassport);
			self.assertNoTrxErrorsOrWarnings();
		endif;
	endforeach;
	
	create logModule transient;
	logModule.setActiveProfileMDHONLY();
	
	logModule.deleteLogArea(LOG_AREA);
	logModule.addLogArea(LOG_AREA, LOG_AREA_COMM);
	
	create cmif_LogRow transient;
	self.xCreateProxyLogRow(cmif_LogRow, LOG_AREA);
	logModule.addLogRow(cmif_LogRow);
	
	//Call web service to create new Log Docket Data
	self.webServiceCallWithParams( CM_UnitTestAgent::wsCreateLogDocketData.name, dockNo );
	
	//Ensure Log Docket Data created OK
	logDocketData := null;
	
	logDocketData := terminal.allLogDocketDataByDocketNo[dockNo];
	self.assertNotNull(logDocketData);
	
epilog
	
	delete logModule;
	delete cmif_LogRow;
end;</source>
    </JadeMethod>
