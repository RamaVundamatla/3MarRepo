    <JadeMethod name="clearBelowLevel" id="021ef5fb-3dda-4512-811f-1755cd2880c7">
        <source>clearBelowLevel(pIndex : Integer);
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------

vars
	lListCount : Integer;
	lLevel : Integer;
begin
	lListCount := self.listCount;
	lLevel := self.itemLevel[pIndex];
	
	if pIndex &lt;= lListCount then
		while true do
			// Something with the same level as us or above us, so stop
			if pIndex + 1 &gt; self.itemLevel.size then
				break;
			endif;
			if self.itemLevel[pIndex + 1] &lt;= lLevel then
				break;
			endif;
			self.removeItem(pIndex + 1);
			lListCount := lListCount - 1;
			// check that we have not just got rid of the bottom item
			if pIndex + 1 &gt; lListCount then 
				break;
			endif;
		endwhile;
	endif;



end;</source>
        <Parameter name="pIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doDragOverSelect" id="b2f21522-f509-4469-af84-873a088face7">
        <updating/>
        <source>doDragOverSelect(pX, pY, _origYPos : Real) updating;
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		NOTE Must have MultiSelect set to greater than zero
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	goingUp : Boolean;
	seleSize,
	topIdx,
	indexOver,
	indexBefore : Integer;
begin
	
	indexBefore := self.currentlyHightlighted;
	
	self.clearAllSelected();
	seleSize := self.itemSelected.size;
	
	if self.currentlyHightlighted &gt; 0 and self.currentlyHightlighted &lt;= seleSize then
		self.itemSelected[self.currentlyHightlighted] := false;
	endif;
	indexOver := self.getListIndex(pX,pY);

	if indexOver &lt;&gt; indexBefore and indexOver &gt; 1 then
		//set below
	else
		if pY &gt; _origYPos then
			// dragging down the tree
			if self.topIndex &lt; self.listCount then
				self.topIndex := self.topIndex + 1;
			endif;
		else
			// dragging up the tree
			goingUp := true;
			topIdx := self.topIndex;
			if topIdx &gt; 1 then
				topIdx := topIdx - 1;
				self.topIndex := topIdx;
			endif;
		endif;
	endif;

	if indexOver &lt; 1 then
		indexOver := indexBefore;
	endif;
	
	if indexOver &gt; 0
	and indexOver &lt;= seleSize then
		self.currentlyHightlighted := indexOver;
		self.itemSelected[indexOver] := true;
		self.refreshNow;
	endif;

	
	if goingUp and indexOver &gt; topIdx then
		while true do
			if self.topIndex = 1 then
				break;
			endif;
			self.mouseMove(self, 1, 0, pX, pY+1);
			self.dragOver(self, self.form, pX, pY+1, null);
			if self.topIndex = topIdx then
				break;
			endif;			
		endwhile;
	endif;						
end;</source>
        <Parameter name="pX" type="Real"/>
        <Parameter name="pY" type="Real"/>
        <Parameter name="_origYPos" type="Real"/>
    </JadeMethod>
    <JadeMethod name="getBottomIndexForLevel" id="4a361c03-68bc-4dfd-a9c3-1836e5919de6">
        <source>getBottomIndexForLevel(_itemIdx : Integer) : Integer;
//-----------------------------------------
// Created: June 2004 By: cnwgd1
//-----------------------------------------
//29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	lstCount,
	tmpIdx,
	tmpLevel : Integer;
begin
	lstCount := self.listCount;

	if _itemIdx &gt; lstCount then
		return null;
	endif;

	tmpLevel := self.itemLevel[_itemIdx];	
	tmpIdx := _itemIdx+1;

	while true do
		if tmpIdx &gt; lstCount then 
			break;
		endif;
		if self.itemLevel[tmpIdx] = tmpLevel then
			break;
		endif;
		tmpIdx := tmpIdx + 1;		
	endwhile;
	
	return tmpIdx;
	
end;</source>
        <Parameter name="_itemIdx" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getListIndexOver" id="c66cfe7c-2d18-4aed-a3a7-5318fd901659">
        <source>getListIndexOver(pXPos : Real) : Integer;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lLineHeight : Integer;
begin

	lLineHeight := self.defaultLineHeight;
	if lLineHeight &gt; 0 then
		return pXPos.Integer div lLineHeight;
	else
		return null;
	endif;
end;</source>
        <Parameter name="pXPos" type="Real"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="pictureClick" id="72f3333d-504e-4334-8089-8d8ef2b20a95">
        <updating/>
        <source>pictureClick(listbox: ListBox input; picIndex: Integer; whatClicked: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     04 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.expandItem(picIndex);
	
	inheritMethod(listbox, picIndex, whatClicked);

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="picIndex" type="Integer"/>
        <Parameter name="whatClicked" type="Integer"/>
    </JadeMethod>
