    <JadeMethod name="doExit" id="36267bb8-856f-4cb6-abbd-61a95eca6e65">
        <updating/>
        <source>doExit() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     19 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	if app.msgBox(app.getErrorString(ConfirmExit), app.getErrorString(ConfirmExitHeading), MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second) &lt;&gt; MB_YES then
