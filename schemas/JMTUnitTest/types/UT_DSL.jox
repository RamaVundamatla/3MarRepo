	objects: CM_ObjectSet;
	itemCode : String;
	value: Any;
begin
	if _value.isKindOf(CM_Object) then
		create objects transient;
		objects.add(_value.CM_Object);
		value := objects;
	else
		value := _value;
	endif;
	// Add Criteria
	create proxyCriteria transient;
	criteriaType := app.myRoot.allYACriteriaTypes[_criteria];
	itemCode := criteriaType.description.cnEcUpto(CM_YACriteriaPriority::code.getLengthForString);
	proxyCriteria.setProxy(criteriaType, value, itemCode);
	cmifCriteria := proxyCriteria.getTransient();
	cmifCriteria.setFlag(true, false, false);	
	return cmifCriteria;
epilog
	delete objects;
end;</source>
        <Parameter name="_criteria" type="Integer"/>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="CMIF_YACriteriaPriority"/>
    </JadeMethod>
    <JadeMethod name="createYAWithGroups" id="1c8861d0-4452-4a39-aff2-0b516ef317a2">
        <source>createYAWithGroups(name: String; _terminal: CM_Terminal; _groupIn, _groupOut: CM_YABlockGroupArray; _fillOptionIn, _fillOptionOut: Integer) : CM_YardAllocation;
//16 July 2008	cnwdw1	
// Create a YA with grouped loczations
vars
	proxyYA : CM_YardAllocation;
begin
	create proxyYA transient;
	
	proxyYA.setProxy(name,
						name&amp;" Description",
						name&amp;" Remarks",
						_fillOptionIn,  //YAFillOption_Alternating,
						_fillOptionOut, //YAFillOption_Alternating,
						YAExpiryType_Never,
						null,
						1000,  // colour
						null,  //cnwjo3 par 24145
						YAOverlap_Always,
						YANoLocation_Continue,
						null,
						0,
						false,
						false,
						_groupIn,
						_groupOut,
						false,
						_terminal);

	return proxyYA;
	
epilog
end;</source>
        <Parameter name="name" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_groupIn" type="CM_YABlockGroupArray"/>
        <Parameter name="_groupOut" type="CM_YABlockGroupArray"/>
        <Parameter name="_fillOptionIn" type="Integer"/>
        <Parameter name="_fillOptionOut" type="Integer"/>
        <ReturnType type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="createYAWithOneCriteria" id="61e25b3e-3fca-4e4f-afbc-02d51dd0eccf">
        <source>createYAWithOneCriteria(_name: String; _terminal: CM_Terminal; _criteria: Integer; _value: Any; _locations: CM_LCArray; proxyYACriteria: CMIF_Array output) : CM_YardAllocation;
//17 July 2008	cnwdw1	
//
begin
	proxyYACriteria := self.createYACriterias( _criteria, _value, 0, 0, 0, 0);
	return self.createYA(_name, _terminal, _locations, YAFillOption_InOrder, YAFillOption_InOrder,false);
end;</source>
