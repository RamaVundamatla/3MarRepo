    <JadeMethod name="getData" id="c2d8475d-ef04-4905-a9bf-0b0311f16133">
        <updating/>
        <source>getData(pText: String input; pType: Integer input) updating;
// ---------------------------------------------------------------------------
// Created:		SEPT 2013 By Andrew Bishop cnwab1
//
// Purpose:		CALLED by CMUI_GetData -  no references. See doGetQuantity()
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	obj : Object;
	theReturn, numItems : Integer;
	shelves: CM_RackShelfControllerSet;
begin

	app.mousePointer := Window.MousePointer_HourGlass;

	if pType = self.GetData_Quantity then
		numItems := pText.Integer;
		if numItems &lt;= 0 then
			numItems := 1;
		endif;
	endif;
	
	create shelves transient;
	foreach obj in self.myCurrentDrawingController.allSelectedObjects discreteLock do
		if obj.isKindOf(CM_RackShelfController) then
			//23 Jul 2020 TFS 49775 - Don't allow update of YA value for shelf without a YA.
			if obj.CM_RackShelfController.allYardAllocations.isEmpty then
				continue;
			endif;
			shelves.add(obj.CM_RackShelfController);
		endif;
	endforeach;
	
	while true do
		app.myTrxUA.trxUpdateRackShelfMaxCapacity(shelves,numItems);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Max Capacity", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;	

epilog
	delete shelves;
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="pText" type="String" usage="input"/>
        <Parameter name="pType" type="Integer" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDisplayMode" id="cce372da-ad19-4a98-bd8e-4dd9ba0d88f1">
