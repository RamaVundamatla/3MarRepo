    <JadeMethod name="setMyCurrentTrain" id="b8620e76-dc6a-414a-8682-a9a170fe2861">
        <updating/>
        <source>setMyCurrentTrain( _train : CM_Train )updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 July 2009	cnwndl1	Initial creation

*/

vars

begin

	self.myCurrentTrain := _train;
	
epilog

