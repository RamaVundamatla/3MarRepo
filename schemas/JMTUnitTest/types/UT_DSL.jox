    <JadeMethod name="deleteAlert" id="ea50eeb1-6abb-420e-815f-eba580d440ba">
        <source>deleteAlert(alert: CM_SystemAlert);
//10 November 2008	cnwdw1	
// Delete all System Alerts for current Termninal
vars
	allAlerts: CM_SystemAlertByDateTime;
begin
	create allAlerts transient;
	allAlerts.add(alert);
	app.myTrxDA.trxDeleteSystemAlert(allAlerts,app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
epilog
	delete allAlerts;
end;</source>
