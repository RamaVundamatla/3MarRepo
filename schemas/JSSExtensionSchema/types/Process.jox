<Class name="Process">
    <JadeMethod name="jssEvaluate" id="be150ef0-7cc1-4690-8e9a-bd0ba39f9008">
        <source>jssEvaluate(pExpression:String; pReturnType:Type; pTheReceiver:Object; pReturnValue:Any io):String;
// --------------------------------------------------------------------------------
// Created:		27 August 2001 by cnwdad1
//
// Purpose:		Evaluates an expression based upon JADE syntax.  The string to be
//				evaluated need only be expressed in simplistic terms, for example:
//
//					"(22/7) * 20 ^ 2"
//
//				...note that there is no need to append the expression with a
//				semi-colan (;).
//
//				Refer to the Process::jssExecute method for handling the execution
//				of full method source.
//
// Parameters:	None
//
// Returns:		The result of the evaluation is returned by the pReturnValue io
//				parameter.  The method itself will return a null value if the
//				expression is successfully evaluated, otherwise an error message
//				will be returned.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theMethod		: JadeMethod;
	sourceCode		: String;
	errorCode		: Integer;
	errorPosition	: Integer;
	errorLength		: Integer;
	errorMessage	: String;

begin
	sourceCode	:=	"return " &amp; pExpression &amp; ";";
	theMethod	:=	process.createTransientMethod(	"evaluate",
													pTheReceiver.class(),
													currentSchema,
													sourceCode,
													true,
													pReturnType,
													errorCode,
													errorPosition,
													errorLength);
	
	if theMethod = null then
		errorMessage	:=	errorCode.String &amp;
							" - " &amp; process.getErrorText(errorCode) &amp;
							" (Position=" &amp; errorPosition.String &amp;
							":" &amp; errorLength.String &amp; ")";
		
		return errorMessage;
	else
		pReturnValue	:=	process.executeTransientMethod(theMethod, pTheReceiver);
		return null;
	endif;
epilog
	process.deleteTransientMethod(theMethod);
end;</source>
        <Parameter name="pExpression" type="String"/>
        <Parameter name="pReturnType" type="Type"/>
        <Parameter name="pTheReceiver" type="Object"/>
        <Parameter name="pReturnValue" type="Any" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssExecute" id="3bd962f1-78d3-4166-b0f4-e6a8d9d7ac32">
        <source>jssExecute(	pSource:String;
			pReturnType:Type;
			pTheReceiver:Object;
			pReturnValue:Any io
//			pAllParameters:ParamListType
			):String;
// --------------------------------------------------------------------------------
// Created:		27 August 2001 by cnwdad1
//
// Purpose:		Executes JADE source code based upon JADE syntax.
//
//				Refer to the Process::jssEvaluate method for handling the execution
//				of simple expressions.
//
// Parameters:	None
//
// Returns:		The result of the execution is returned by the pReturnValue io
//				parameter.  The method itself will return a null value if the
//				source is successfully executed, otherwise an error message will
//				be returned.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theMethod		: JadeMethod;
	sourceCode		: String;
	errorCode		: Integer;
	errorPosition	: Integer;
	errorLength		: Integer;
	errorMessage	: String;

begin
	sourceCode	:=	"return " &amp; pSource &amp; ";";
	theMethod	:=	process.createTransientMethod(	"evaluate",
													pTheReceiver.class(),
													currentSchema,
													sourceCode,
													false,
													pReturnType,
													errorCode,
													errorPosition,
													errorLength);
	
	if theMethod = null then
		errorMessage	:=	errorCode.String &amp;
							" - " &amp; process.getErrorText(errorCode) &amp;
							" (Position=" &amp; errorPosition.String &amp;
							":" &amp; errorLength.String &amp; ")";
		
		return errorMessage;
	else
		pReturnValue	:=	process.executeTransientMethod(theMethod, pTheReceiver);
		return null;
	endif;
epilog
	process.deleteTransientMethod(theMethod);
end;</source>
        <Parameter name="pSource" type="String"/>
        <Parameter name="pReturnType" type="Type"/>
        <Parameter name="pTheReceiver" type="Object"/>
        <Parameter name="pReturnValue" type="Any" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssGetUserInfoFieldValue" id="7e5cf8c6-de8a-40f4-9e4c-a1a7a86d5e88">
        <source>jssGetUserInfoFieldValue(pFieldName:String):String;
// --------------------------------------------------------------------------------
// Created:		01 December 2000 by cnwdad1
//
// Purpose:		This method will fetch the value of a "field" within the UserInfo
//				property.
//
// Parameters:	pFieldName (String) - The name of the field whose value to return.
//
// Returns:		The string value of the requested field.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	userInfoData	: String;
	dataLength		: Integer;
	fieldPos		: Integer;
	nextFieldPos	: Integer;
	valuePos		: Integer;
	valueLength		: Integer;
	
begin
	userInfoData	:=	self.userInfo;
	
	fieldPos		:=	userInfoData.pos(pFieldName &amp; JSS_PROCESS_FIELD_ASSIGNMENT, 1);
	
	if fieldPos &gt; 0 then
		dataLength	:=	userInfoData.length();
		valuePos	:=	fieldPos + (pFieldName.length() + JSS_PROCESS_FIELD_ASSIGNMENT.String.length());
		
		if valuePos &lt;= dataLength then
			nextFieldPos	:=	userInfoData.pos(JSS_PROCESS_FIELD_DELIMITER, valuePos);
			
			if nextFieldPos = 0 then
				// There are no (more) fields, so return the remainder of the User Info data.
				return userInfoData[valuePos:end];
			else
				// Return the value for the field.
				valueLength	:=	nextFieldPos - valuePos;
				return userInfoData[valuePos:valueLength];
			endif;
		endif;
	endif;

	return null;
end;</source>
        <Parameter name="pFieldName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssSetUserInfoFieldValue" id="552a2abc-271d-4c6d-bb5b-d7b807ea8c0e">
        <updating/>
        <source>jssSetUserInfoFieldValue(pFieldName:String; pFieldValue:String) updating;
// --------------------------------------------------------------------------------
// Created:		01 December 2000 by cnwdad1
//
// Purpose:		This method will set the value of a "field" within the UserInfo
//				property.  It is assumed that the calling method has taken care
//				of obtaining a lock on this object, as well as the transaction.
//
// Parameters:	pFieldName (String) - The name of the field to update.
//				pFieldValue (String) - The value to et the field to.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	userInfoData	: String;
	dataLength		: Integer;
	newFieldValue	: String;
	fieldPos		: Integer;
	nextFieldPos	: Integer;
	valuePos		: Integer;
	fieldWithAssign	: String;
	fieldWithValue	: String;
	
begin
	userInfoData	:=	self.userInfo;
	newFieldValue	:=	pFieldValue;
	fieldWithAssign	:=	pFieldName &amp; JSS_PROCESS_FIELD_ASSIGNMENT;
	fieldWithValue	:=	fieldWithAssign &amp; newFieldValue;

	fieldPos		:=	userInfoData.pos(pFieldName &amp; JSS_PROCESS_FIELD_ASSIGNMENT, 1);
	
	if fieldPos = 0 then
		if userInfoData = null then
			userInfoData	:=	fieldWithValue;
		else
			userInfoData	:=	userInfoData &amp; JSS_PROCESS_FIELD_DELIMITER &amp; fieldWithValue;
		endif;
	else
		// First, check whether the field needs to be updated.
		
		if self.jssGetUserInfoFieldValue(pFieldName) = newFieldValue then
			return;
		endif;
	
		// Proceed to update the field's value.
	
		dataLength	:=	userInfoData.length();
		valuePos	:=	fieldPos + (pFieldName.length() + JSS_PROCESS_FIELD_ASSIGNMENT.String.length());
		
		if valuePos &lt;= dataLength then
			nextFieldPos	:=	userInfoData.pos(JSS_PROCESS_FIELD_DELIMITER, valuePos);
		endif;

		if nextFieldPos = 0 then
			userInfoData	:=	userInfoData.jssInsertInto(newFieldValue,
															valuePos,
															0);
		else
			userInfoData	:=	userInfoData.jssInsertInto(newFieldValue,
															valuePos,
															nextFieldPos);
		endif;
	endif;

	self.userInfo	:=	userInfoData;
end;</source>
        <Parameter name="pFieldName" type="String"/>
        <Parameter name="pFieldValue" type="String"/>
    </JadeMethod>
</Class>
