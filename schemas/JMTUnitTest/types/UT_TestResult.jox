    </JadeMethod>
    <JadeMethod name="setFromUmResult" id="543f9eda-36f6-4785-af61-179da9dc98ed">
        <updating/>
        <source>setFromUmResult(_umResult : UM_UnitTestResult) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2025	navpw1	Initial creation

*/

begin
	self.elapsedTime.set(0, (_umResult.elapsedTime.asRealJMT()*1000).Integer);
	self.errorText	:= _umResult.details.uncompressToString().trimBlanks();
	self.ignored	:= _umResult.hasBeenIgnored();
	self.owner		:= _umResult.ownerName;
	self.passed		:= _umResult.hasPassed;
	self.profile	:= null;
	self.runTime	:= _umResult.methodRunStartTS;
	self.terminals	:= null;
	self.testClass	:= _umResult.myClassMethod.className;
	self.testMethod	:= _umResult.myClassMethod.methodName;
	
end;</source>
        <Parameter name="_umResult" type="UM_UnitTestResult"/>
    </JadeMethod>
    <JadeMethod name="summaryDetails" id="ec8c547a-3b2f-4255-be1b-c057663b9088">
        <source>summaryDetails(_byTeam: Boolean): String;
//24 April 2009	cnwdw1	
//
vars
	message: String;
	emailedTo : String;
	ownerStr : String;
begin
	if self.ignored then
		message := message &amp; "IGNORED";
	elseif self.passed then
		message := message &amp; "PASS";
	else
		message := message &amp; "FAIL";
	endif;
	
	emailedTo := self.getUserFailEmailedTo().trimBlanks();			// 10/09/2013 cnwmh5
	if emailedTo &lt;&gt; null and emailedTo &lt;&gt; self.owner then
		emailedTo := "(Emailed to " &amp; emailedTo &amp; ") ";
	endif;
	
	
	if _byTeam then
		ownerStr := self.getTeamName();
	else
		ownerStr := self.owner;
	endif;
	
	if _byTeam then
		message := message &amp; Tab &amp; self.formatElapsedTime(self.elapsedTime) &amp; Tab &amp; self.runTime.date.String &amp; " " &amp; 
			self.runTime.time.String &amp; Tab &amp; self.testClass &amp; "::" &amp; self.testMethod &amp; Tab &amp; emailedTo;
	else
		message := message &amp; " " &amp; self.testClass &amp; "::" &amp; self.testMethod &amp; " " &amp; ownerStr &amp; " " &amp; emailedTo &amp; " " &amp;  
			self.formatElapsedTime(self.elapsedTime) &amp; " " &amp; self.runTime.date.String &amp; " " &amp; self.runTime.time.String;
	endif;
	
	return message;
end;</source>
        <Parameter name="_byTeam" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
