    <JadeMethod name="loadCmbCheckScaleReports" id="bd619d38-47b0-4490-94da-56b7403d8f89">
        <updating/>
        <source>loadCmbCheckScaleReports(_rptName : String; _cmb : ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     20 May 2003		cnwth2	
//
// Purpose:     		 
//
// Changed On	Changed By	Reason
// ----------	----------	--------------------------------------------------
// 17 Mar 2010	consw1		PAR #22886 - Leaking report transients
// ---------------------------------------------------------------------------
vars
	menuItem			: CM_MenuItem;
	menuDict			: CM_MenuItemByTypeMenuIdDict;
	report 				: JadeReportWriterReport;
	reportManager		: JadeReportWriterManager;
	viewName			: String;
	foundIdx,
	idx					: Integer;
	
begin
	_cmb.clear();
	
	reportManager := app.createReportWriterManager();
	
	menuDict := app.myRoot.myReportMenuRoot.allMenuItems;
	
	foreach menuItem in menuDict do
		if not menuItem.isKindOf(CM_QryReport) then
			continue;
		endif;

		report := reportManager.getReport(menuItem.CM_QryReport.jrwReportName[1]);
		if report = null then
			continue;
		endif;
		
		viewName := report.getReportingViewName();
		
		if viewName = CM_LogCheckScaleView then
			idx := _cmb.addItem(menuItem.CM_QryReport.reportName);
			_cmb.itemObject[idx] := menuItem.CM_QryReport;
			
			if _rptName = menuItem.CM_QryReport.reportName then
				foundIdx := idx;
			endif;
		endif;
		
		delete report;
	endforeach;

	if foundIdx &gt; 0 then
		_cmb.listIndex := foundIdx;
	endif;
	
epilog
	delete reportManager;
	delete report;
end;</source>
        <Parameter name="_rptName" type="String"/>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="loadCmbContext" id="dfd46d69-8280-437e-a710-be433e0909c1">
        <source>loadCmbContext(_context : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		 Reason
11 October 2022	navhl20	 ChangeRequest 53424: MTN - MOB - Input Remarks - Jade
27 February 2023 navdp20 ChangeRequest 56847:[56848] EUP | Outturn Remarks on BOL - Predefined Text
*/

vars
	cmb : CMUI_ComboBox;
begin
	cmb := self.cmbContext;
	cmb.clear;
	
	cmb.addItem(DefText_WPDescPrenote);
	cmb.addItem(DefText_WPDescReleaseRequest);
	cmb.addItem(DefText_WPDescBookings);              
	cmb.addItem(DefText_WPDescVehicleBooking);     
	cmb.addItem(DefText_WPDescCargoNotifReq);       
	cmb.addItem(DefText_WPDescCargoUpdateReq);
	if self.myTerminal.getConfig(DefaultVoyageProcess).String = VoyageProcessWO then
		cmb.addItem(DefText_WPDescVoyageRequest);              
		cmb.addItem(DefText_WPDescInvRejection);     
	endif;
	cmb.addItem(DefText_MOBDescAssignTask);       
	cmb.addItem(DefText_MOBDescCompleteTask);       
	cmb.addItem(DefText_MOBDescCargoMaint);      
	cmb.addItem(DefText_MOBDescDelayVoyage);         
	cmb.addItem(DefText_MOBDescDelayMachine); 
	cmb.addItem(DefText_MTNDescBolOutturn); 	//27.02.2023 navdp20 #56847[56848]
	
	if _context &lt;&gt; null then
		cmb.listIndex := cmb.findString(1,app.getDefTextIntToStr(_context));
	endif;
epilog

end;</source>
        <Parameter name="_context" type="Integer"/>
    </JadeMethod>
