        <source>clearTableFilter() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 August 2014	cnwndl1	Initial creation

*/

vars

begin

	if self.allColumnFilters &lt;&gt; null and not self.allColumnFilters.isEmpty then
		self.allColumnFilters.replaceAllFiltersForTable( self.tblCompare, null );
		self.applyColumnFilter( self.tblCompare );
	endif;

epilog

end;</source>
