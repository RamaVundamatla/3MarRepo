    <JadeMethod name="updateProgressBar" id="07d0106d-31a6-478e-9b2d-8214100efc0c">
        <source>updateProgressBar(_count, _max : Integer) protected;
/*

Purpose:			Updates the progress bar

Parameters:			_count:	How many objects we have processed
					_max:	Maximum amouint of objects we need to process

Return Value:		

Date		Who		Reason
28 October 2021	navpw1	Initial creation TFS: 52202

*/

begin
	self.pbFileProgress.visible		:= true;
	self.pbFileProgress.left 		:= self.lblSlFile.left + self.lblSlFile.width + 5;
	self.pbFileProgress.partsDone	:= _count;
	self.pbFileProgress.partsInJob	:= _max;
	self.pbFileProgress.foreColor	:= Cn_Orange;

end;</source>
        <access>protected</access>
        <Parameter name="_count" type="Integer"/>
        <Parameter name="_max" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateStatusLine" id="5ea667f8-ab18-4561-8b4d-3b2c14d542b8">
        <source>updateStatusLine(_destination, _fileName : String) protected;
/*

Purpose:			Updates the status line

Parameters:			_destination:	The type of destination we are processing (DMast/WMast)
					_fileName:		The file name we are processing

Return Value:		

Date		Who		Reason
28 October 2021	navpw1	Initial creation TFS: 52202

*/

begin
	if(_destination = "") then
		self.lblSlDestination.caption := "";
	else
		//self.lblSlDestination.caption := "Processing: " &amp; _destination;
		self.lblSlDestination.caption := "Processing Files in Folder";
	endif;
	
	self.lblSlFile.left := self.lblSlDestination.left + self.lblSlDestination.width + 5;
	
	if(_fileName = "") then
		self.lblSlFile.caption := "";
	else
		self.lblSlFile.caption := "File: " &amp; _fileName;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_destination" type="String"/>
        <Parameter name="_fileName" type="String"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="91a27faa-d55e-4494-a5dc-e49ae1be31d2">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(_eventType: Integer; _theObject: Object; _eventTag: Integer; _userInfo: Any) updating;
/*

Purpose:			Notification event

Parameters:			_eventType:	The event type we are processing
					_theObject:	The object we are processing
					_eventTag:	The event tag we have received from the event
					_userInfo:	The user information to process

Return Value:		

Date		Who		Reason
28 October 2021	navpw1	Initial creation TFS: 52202

*/

begin
	self.notificationReceieved(_eventType, _theObject, _eventTag);

end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
        <Parameter name="_userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="writeConsoleText" id="907398db-1d41-4fdd-a255-baffb0d5e66e">
        <source>writeConsoleText(_text : String) protected;
/*

Purpose:			Writes text to our Console textbox

Parameters:			_text:	The text to write

Return Value:		

Date		Who		Reason
28 October 2021	navpw1	Initial creation TFS: 52202

*/

begin
	if (self.txtConsole.text = "") then
		self.txtConsole.text := _text;
	else
		self.txtConsole.text := self.txtConsole.text &amp; CrLf &amp; _text;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_text" type="String"/>
    </JadeMethod>
</GUIClass>
