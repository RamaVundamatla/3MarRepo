    <JadeMethod name="getDisplayStringForAttribute" id="54eefb18-a643-4af2-a4cf-e721c75f83e8">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 May 2021	navndl1	Initial creation	TFS 50906

*/

vars
	oldQuantity : Integer;
	oldWeight : Decimal[14,4];
	oldVolume : Decimal[14,4];
	lDetail : String;
	oldAmount,
	newAmount,
	amountChange : String;
begin
	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
		else
			oldQuantity := newTotalQuantity - quantityChange;
			oldWeight := newTotalWeight - weightChange;	
			oldVolume := newTotalVolume - volumeChange;

			if quantityChange &lt;&gt; null then
				lDetail := lDetail &amp; "Old Total Quantity " &amp; oldQuantity.asStringJMT &amp; ", Change " &amp; self.quantityChange.asStringJMT &amp; ", New Total Quantity " &amp; self.newTotalQuantity.asStringJMT ;
			endif;
			if weightChange &lt;&gt; null then
				if self.myTrackedItem &lt;&gt; null  and self.myTrackedItem.myCargoType.isBulkMulti then
					if lDetail &lt;&gt; null then
						lDetail := lDetail &amp; CrLf;
					endif;
					oldAmount := self.myTrackedItem.myCargoType.getConvertedWeightDisplay(oldWeight, true );
					newAmount := self.myTrackedItem.myCargoType.getConvertedWeightDisplay(self.newTotalWeight, true );
					amountChange := self.myTrackedItem.myCargoType.getConvertedWeightDisplay(self.weightChange, true );	
				else
					if lDetail &lt;&gt; null then
						lDetail := lDetail &amp; CrLf;
					endif;
					oldAmount := app.getWeightForDefaultDisplay( oldWeight );
					newAmount := app.getWeightForDefaultDisplay( newTotalWeight);
					amountChange := app.getWeightForDefaultDisplay( self.weightChange );
				endif;
				lDetail := lDetail &amp; "Old Total Weight " &amp; oldAmount &amp; ", Change " &amp; amountChange &amp; ", New Total Weight " &amp; newAmount &amp; ' ';
			endif;
			if volumeChange &lt;&gt; null then
				if self.myTrackedItem &lt;&gt; null  and self.myTrackedItem.myCargoType.isBulkMulti then
					if lDetail &lt;&gt; null then
						lDetail := lDetail &amp; CrLf;
					endif;
					oldAmount := self.myTrackedItem.myCargoType.getConvertedVolumeDisplay( oldVolume, true );
					newAmount := self.myTrackedItem.myCargoType.getConvertedVolumeDisplay( self.newTotalVolume, true );
					amountChange := self.myTrackedItem.myCargoType.getConvertedVolumeDisplay( self.volumeChange, true );
					lDetail := lDetail &amp; "Old Total Volume " &amp; oldAmount &amp; ", Change " &amp; amountChange &amp; ", New Total Volume " &amp; newAmount &amp; ' ';
				endif;
			endif;
			
			if self.reason &lt;&gt; null then
				lDetail := lDetail &amp; CrLf &amp;  'Reason : ' &amp; self.reason;
			endif;
			
			return lDetail;
		endif;
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="7f6b2cf8-7c9b-4650-a1c2-a939abb568e9">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_BBDiscrepancyController; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 May 2021	navndl1	Initial creation	TFS 50906

*/

vars

begin
	inheritMethod(_tiTransCntrl, _passport);
	
	self.newTotalVolume := _tiTransCntrl.newTotalVolume;
	self.volumeChange := _tiTransCntrl.volumeChange;
	self.myLocationActivity := _tiTransCntrl.myLocationActivity;
	
	if self.myTrackedItem &lt;&gt; null
	and self.myTrackedItem.myPrimaryActualLocation &lt;&gt; null
	and self.myTrackedItem.myPrimaryActualLocation.isActivityTrackingLocation
	then
		self.myLocation := self.myTrackedItem.myPrimaryActualLocation;
	endif;

epilog

end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_BBDiscrepancyController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
