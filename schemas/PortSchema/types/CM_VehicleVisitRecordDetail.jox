    <JadeMethod name="addAdjustmentComment" id="d1c46566-0243-47f4-9082-e86e4c0ab8e8">
        <updating/>
        <source>addAdjustmentComment( _str : String ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2018	jlgndl1	Initial creation	TFS 41180

*/

vars

begin
	
	if _str &lt;&gt; null then
		self.extraInfo := self.extraInfo &amp; "^" &amp; _str;
	endif;

epilog

end;</source>
