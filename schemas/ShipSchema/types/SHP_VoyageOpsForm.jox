    <JadeMethod name="doTransactionLoopCompleted" id="34f17c5d-3476-4fba-8f42-8111f1a9ac26">
        <source>doTransactionLoopCompleted(_errorMessage : String) : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/12/2014	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394 Voyage Rationalisation
//
vars
	result : Integer;
	
begin
	if app.myPassport.trxCompletedOK then
		// Clear errors/warnings from form and err/warnings window
		self.clearErrorWarnings();
		return true;
	else
		result := app.showErrorWarningDialog(_errorMessage, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
		if app.myPassport.noErrors and
			result = IDOK then
			// there must have just been warnings that the user has acknowledged so ..
			app.myPassport.warningsAcknowledged	:= true;
			return false;
		else
			return true;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_errorMessage" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUnassignTBAs" id="438c7a14-9d1f-4b20-8c7b-0aeeae29c46c">
        <updating/>
        <source>doUnassignTBAs() updating;
/*
Purpose:			
Date				Who		Reason
13 February 2017	cnwab1	Initial creation
28 October 2025		jlizm1	MTN 36255 Rotabox Assign Release To Vessel
*/

vars
	wle : CM_WorkListEntry;
	req : CM_Request;
	result : Integer;
	theJob : CM_Job;
	theJobs : CM_VoyageJobSet;
	ti : CM_TrackedItem;
	tis : CM_TISet;
begin

	create tis transient;
	self.getCurrentlySelectedTIs(tis);

	if tis = null or tis.isEmpty() then
		app.msgBox(app.getErrorString(Please_select_cargo_itemPOP), app.getErrorString(Voyage_issue), MsgBox_OK_Only);
		return;
	endif;
	
	create theJobs transient;
	foreach ti in tis discreteLock do
		if ti.isTBAorIsRRP() then
			foreach	wle in ti.allWorklistEntries discreteLock do
				if wle.myRequest &lt;&gt; null and wle.myRequest.isHoldRequest() then
					theJob := wle.myRequest.myJob;
					if theJob &lt;&gt; null and theJob.isVoyageHoldJob() then
						theJobs.addNoDuplicates(theJob.CM_VoyageJob, false);
					endif;
				endif;
			endforeach;
		endif;
	endforeach;

	if theJobs.isEmpty() then
		return;	
	endif;

	app.mousePointer := MousePointer_HourGlass;	

	while true do
		app.myTrxDA.trxDeleteVoyageJobs(theJobs, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Erase Job', app.myPassport,  ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;

epilog 
	delete theJobs;
	delete tis;
	app.mousePointer := MousePointer_Default;	




end;</source>
    </JadeMethod>
    <JadeMethod name="doUnqueueTI" id="862f9b49-5d96-4080-955c-42c71919dff6">
        <updating/>
        <source>doUnqueueTI(_theTI : CM_TrackedItem input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/02/2015	cnwdap1		Initial creation PAR #35397 CCMS SFW 1392 Voyage Ratinoalisation
//
vars
	idx : Integer;
	lTI	: CM_TrackedItem;
	aStr : String;
	lResult : Integer;
	lMoveControl : CMIF_MoveController;
	lTransferArea : CM_TerminalArea;
	lQEntry : CM_RTQueueEntry;
	result	: Integer;

begin
	mousePointer := MousePointer_HourGlass;	
	
	if _theTI = null then
		app.msgBox(app.getErrorString(Please_Select_A_Tracked_Item),"Unqueuing", MsgBox_OK_Only +MsgBox_Information_Icon);
		return;
	endif;
	
	create lMoveControl transient;
	lMoveControl.setMoveMode(QUEUE_MODE);
	lMoveControl.setMyTrackedItem(_theTI);
	lMoveControl.setMyWorkListEntry(_theTI.allWorklistEntries.last);
	
	if lMoveControl.myWorkListEntry &lt;&gt; null and lMoveControl.myWorkListEntry.myFutureMove = null then
		lMoveControl.setMyWorkListEntry(null);
	endif;
	
	while true do
		app.myTrxUA.trxUpdateMoveTIUndo(lMoveControl, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Unqueue', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;

epilog 
	if lMoveControl &lt;&gt; null then
		delete lMoveControl;
	endif;
	mousePointer := MousePointer_Default;	

end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doUpdateCurrentViewTi" id="4795c858-079e-4114-9218-0ece94ceb8a0">
        <updating/>
        <source>doUpdateCurrentViewTi( _ti : CM_TrackedItem io; _updateTable : CM_DataTable input; _isHidden : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
15 March 2021		navndl1	Initial creation	TFS 50935
08 November	2022	navkc1	Bug 54927: MTN - Loading a cargo on ship edi file freeze the system if the New version of the voyage operation screen is opened
08 November 2022	navmd1	TFS 55379 Refactor VoyageOpsCG Form
*/

vars

	rowStr : String;
	rowIdx : Integer;
	cg		: CM_CargoGroup;
	
begin

	if _updateTable.allViewObjects.includes( _ti ) then
		//actually, in the same table
		if _isHidden then
			// the table is hidden don't do any more it just wastes resources.
			return;
		endif;
		rowStr := _ti.getAttributeStringForDefArray( _updateTable.allTblDataEntRows );
		//now update it, but only if in the current view, i.e. actually visible
		_updateTable.updateViewObject( _ti, rowStr );
	else
		// it has moved tables, so add it
		self.loadCargoForTable(_ti, rowIdx, _updateTable, _isHidden, true);
		//and now remove it from where it was, it will onlly be in one
		cg	:= _ti.myCargoGroup;
		rowIdx := 0;
		if _updateTable &lt;&gt; self.tblOnship and self.tblOnship.allViewObjects.includes( _ti ) then
			self.tblOnship.clearViewObject( _ti, Any_System_Event );
			if cg &lt;&gt; null and self.tblOnship.findObjectInRow(cg, rowIdx) then
				// 08/11/2022	navkc1	#54927 - update cargo group details
				self.populateCargoGroupDetails(-1, cg, self.tblOnship.allTblDataEntRows, self.tblOnship, rowIdx);
			endif;
			self.colourTableRows(tblOnship);	// navkc1	18/11/2022 #54927 colour the table after removing a ti
			return;
		elseif _updateTable &lt;&gt; self.tblOnsite and self.tblOnsite.allViewObjects.includes( _ti ) then
			self.tblOnsite.clearViewObject( _ti, Any_System_Event );
			if cg &lt;&gt; null and self.tblOnsite.findObjectInRow(cg, rowIdx) then
				// 08/11/2022	navkc1	#54927 - update cargo group details
				self.populateCargoGroupDetails(-1, cg, self.tblOnsite.allTblDataEntRows, self.tblOnsite, rowIdx);
			endif;
			self.colourTableRows(tblOnsite);	// navkc1	18/11/2022 #54927 colour the table after removing a ti
			return;
		elseif _updateTable &lt;&gt; self.tblOffsite and self.tblOffsite.allViewObjects.includes( _ti ) then
			self.tblOffsite.clearViewObject( _ti, Any_System_Event );
			if cg &lt;&gt; null and self.tblOffsite.findObjectInRow(cg, rowIdx) then
				// 08/11/2022	navkc1	#54927 - update cargo group details
				self.populateCargoGroupDetails(-1, cg, self.tblOffsite.allTblDataEntRows, self.tblOffsite, rowIdx);
			endif;
			self.colourTableRows(tblOffsite);	// navkc1	18/11/2022 #54927 colour the table after removing a ti
			return;
		elseif _updateTable &lt;&gt; self.tblPreNote and self.tblPreNote.allViewObjects.includes( _ti ) then
			self.tblPreNote.clearViewObject( _ti, Any_System_Event );
			if cg &lt;&gt; null and self.tblPreNote.findObjectInRow(cg, rowIdx) then
				// 08/11/2022	navkc1	#54927 - update cargo group details
				self.populateCargoGroupDetails(-1, cg, self.tblPreNote.allTblDataEntRows, self.tblPreNote, rowIdx);
			endif;
			self.colourTableRows(tblPreNote);	// navkc1	18/11/2022 #54927 colour the table after removing a ti
			return;
		endif;
		
	endif;

epilog
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
        <Parameter name="_updateTable" type="CM_DataTable" usage="input"/>
        <Parameter name="_isHidden" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="dragTrackedItem" id="15060c57-f01e-4d34-95f0-eef2aa3fcfef">
        <updating/>
        <source>dragTrackedItem(_ti : CM_TrackedItem; _table : CM_DataTable input)updating;		//29.06.2022 navsrk20 Bug 53905
//--------------------------------------------------
// Created:	17 October 2003 By: cnwgd1
//29 June 2022		navsrk20	Bug 53905: EUP - Planning issues for Cargo Groups in Voyage Operations screen
//08 November 2022	navmd1		TFS 55379 Refactor VoyageOpsCG Form
//--------------------------------------------------
vars
	picture 		: Picture;
	wle 			: CM_WorkListEntry;
	tmpTi, ctrlTi 	: CM_TrackedItem;
	moveController	: CMIF_MoveController;
begin

	if _ti = null then
		return;
	endif;
	
	create moveController transient;
	if global.isValidObject(app.myMoveController) then
		delete app.myMoveController;
	endif;
	app.myMoveController := moveController;	
	
	// Add all non-cargo group items to the controller
	moveController.setMyTrackedItem(_ti);
	if _ti.isCargoGroupItem then
		self.getDragDropTIsForController(moveController);
	endif;
	
	// Keep track of what the first TI is
	ctrlTi := moveController.myTrackedItem;
	
	foreach tmpTi in _table.allSelectedObjects as CM_TrackedItem do
		if tmpTi = _ti then
			continue;
		endif;
		
		if tmpTi.isCargoGroupItem then
			moveController.setMyTrackedItem(tmpTi);
			self.getDragDropTIsForController(moveController);
		else
			moveController.allOtherTrackedItems.tryAdd(tmpTi);
		endif;
	endforeach;
	
	// And now set it back
	moveController.setMyTrackedItem(ctrlTi);
	
	moveController.setMoveMode(self.moveModeForm);	//19 Nov 2009	NDL	CCMS 1031
	moveController.transferType := self.getVoyJobTransferType();	//12 Mar 2018	NDL	TFS 37444
	moveController.isRehandleMove := _ti.isRehandle;		// TFS 2228 28/06/2016 enable planning for DLR cargo
	moveController.myOriginatingForm := self;	//12 Apr 2017	NDL	TFS 4078
	
	//No Queuing or planning from non-planned non-worked voyages
	//moveController.setMoveMode(REAL_MODE);
	if self.cbRetrospective.value and self.myTerminal.getConfig(VoyageRetroDefault).Boolean and self.myCurrentVoyage.shipExchangeCompleteDT.isValid then	//17 May 2021	NDL	TFS 51199
		moveController.setEffectiveTimeStampOverride(self.myCurrentVoyage.shipExchangeCompleteDT);
	elseif _ti.myVoyage.nonPlannedEffectiveDT.isValid and self.cbRetrospective.value then
		moveController.setEffectiveTimeStampOverride(_ti.myVoyage.nonPlannedEffectiveDT);
	endif;
	_table.dragMode := DragMode_Drag;
	
	create picture transient;
	self.setPictureDragCursor(picture);
	if picture &lt;&gt; null then
		_table.dragCursor := picture.picture;
	endif;

epilog
	if picture &lt;&gt; null then
		delete picture;
	endif;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="enableVoyageButtons" id="21697b30-a2ef-427d-956b-4835f65dff29">
        <updating/>
        <source>enableVoyageButtons() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 12/12/2014	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394 Voyage Rationalisation
//
vars
	enableButtons : Boolean;
	
begin
	enableButtons := self.myCurrentVoyage &lt;&gt; null;
	self.btnVesselDef.enabled := enableButtons;
	self.btnVoyageDef.enabled := enableButtons;
	
	self.btnLOLODef.enabled := self.myCurrentVoyage &lt;&gt; null and self.myCurrentVoyage.myCellularVoyageStructure &lt;&gt; null;
	self.btnRORODef.enabled := self.myCurrentVoyage &lt;&gt; null and self.myCurrentVoyage.myROROStructure &lt;&gt; null;
	self.btnHoldsDef.enabled := self.myCurrentVoyage &lt;&gt; null and self.myCurrentVoyage.myGeneralCargoVoyage &lt;&gt; null;
	
	self.btnOrderOfWorks.enabled := enableButtons;
	self.btnJobOps.enabled := enableButtons;
	
	self.btnLoadList.enabled := self.btnLOLODef.enabled;
epilog

end;</source>
    </JadeMethod>
