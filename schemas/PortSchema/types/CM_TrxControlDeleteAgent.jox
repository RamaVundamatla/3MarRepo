    <JadeMethod name="trxDeleteFaultResponses" id="62d6a043-50f3-40b7-924a-5eadd025389c">
        <updating/>
        <source>trxDeleteFaultResponses(_faults : ObjectArray input; _passport : CM_Passport input) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
11 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	obj : Object;

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	foreach obj in _faults discreteLock do
		exclusiveLock(obj);
	
		obj.CM_FaultResponse.erase(NORMAL_ERASE);
	endforeach;

epilog		
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_faults" type="ObjectArray" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
