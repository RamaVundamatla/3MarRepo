    <JadeMethod name="updateBasicsFromController" id="9328e439-81f4-4032-8cba-02887da50948">
        <updating/>
        <source>updateBasicsFromController( _controller : CMIF_InvoiceSystemDefaults;  _passport : CM_Passport ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 March 2015	cnwndl1	Initial creation	Par 35816

*/

vars

begin

	if self.exportPath &lt;&gt; _controller.exportPath then
		self.addActivityRecord( "exportPath", self.exportPath,  _controller.exportPath, _passport );
		self.exportPath := _controller.exportPath;
	endif;
	if self.firstMonthOfFinYear &lt;&gt; _controller.firstMonthOfFinYear then
		self.addActivityRecord( "firstMonthOfFinYear", self.firstMonthOfFinYear.String,  _controller.firstMonthOfFinYear.String, _passport );
		self.firstMonthOfFinYear := _controller.firstMonthOfFinYear;
	endif;
	if self.glPeriod &lt;&gt; _controller.glPeriod.String then
		self.addActivityRecord( "glPeriod", self.glPeriod,  _controller.glPeriod.String, _passport );
		self.glPeriod := _controller.glPeriod.String;
	endif;
	if self.glYear &lt;&gt; _controller.glYear.String then
		self.addActivityRecord( "glYear", self.glYear,  _controller.glYear.String, _passport );
		self.glYear := _controller.glYear.String;
	endif;
	if self.name &lt;&gt; _controller.name then
		self.addActivityRecord( "name", self.name,  _controller.name, _passport );
		self.name := _controller.name;
	endif;
	if self.remarks &lt;&gt; _controller.remarks then
		self.addActivityRecord( "remarks", self.remarks,  _controller.remarks, _passport );
		self.remarks := _controller.remarks;
	endif;
	
epilog

end;</source>
        <Parameter name="_controller" type="CMIF_InvoiceSystemDefaults"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
