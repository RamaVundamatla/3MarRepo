    <JadeMethod name="checkIfTLHeightDiff" id="9e92caed-120b-478f-aa18-29b1bd5f9b00">
        <source>checkIfTLHeightDiff( _shipSLiftIfDiffHeights : Boolean) : Boolean;
// ---------------------------------------------------------------------------
// Created:		16 August 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	fwdReq, aftReq : CM_SlotRequest;
	fwdWLE : CM_WorkListEntry;
	fwdTI : CM_TrackedItem;
	reason : String;
	theReq: CM_SlotRequest;
begin
	if not _shipSLiftIfDiffHeights then
	//	app.writeStatement(method.qualifiedName &amp; " TL not _shipSLiftIfDiffHeights" );
		app.writeLog(method.qualifiedName &amp; " TL not _shipSLiftIfDiffHeights" ,LogINFO); // PAR 26858
		return false;
	endif;
	theReq := self.myRequest;
	
	if theReq &lt;&gt; null then
		if not theReq.isAftBay then
			//app.writeStatement(method.qualifiedName &amp; " TL not theReq.isAftBay" );
			app.writeLog(method.qualifiedName &amp; " TL not theReq.isAftBay" ,LogINFO); // PAR 26858
			return false;
		endif;
		/* // ### TFS BUG 65584 16AUG2024 NAVAB1

		if theReq.isFwdSlotReqSameHeightBelow(reason) then
			//app.writeStatement(method.qualifiedName &amp; ' TL HEIGHT EXCEEDED');
			app.writeLog(method.qualifiedName &amp; " TL HEIGHT EXCEEDED" ,LogINFO); // PAR 26858
			return false;
		endif;
		*/
		if not theReq.isFwdSlotReqSameHeightBelow(reason) then
			//app.writeStatement(method.qualifiedName &amp; ' TL HEIGHT EXCEEDED');
			app.writeLog(method.qualifiedName &amp; " TL HEIGHT EXCEEDED in slot " &amp; reason ,LogINFO); 
			//return false;
			return true; // ### JIRA 33035 08OCT2024 NAVAB1
		endif;
	endif;
	return false; // ### JIRA 33035 08OCT2024 NAVAB1

end;</source>
        <Parameter name="_shipSLiftIfDiffHeights" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkIfTLWeightExceed" id="f3a1ef4e-04b0-495f-8d43-3cd9b563c7a4">
        <source>checkIfTLWeightExceed(_theTI : CM_TrackedItem; _shipSLiftIfTLWgtExced : Boolean; _maxLiftWeightTL : Integer; _maxTwinLiftDiff : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:		16 August 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	fwdReq, aftReq : CM_SlotRequest;
	fwdWLE : CM_WorkListEntry;
	fwdTI : CM_TrackedItem;
begin
	if _theTI &lt;&gt; null then
		if _shipSLiftIfTLWgtExced and _maxLiftWeightTL &lt;&gt; 0 then
			if _theTI.totalWeight &gt; _maxLiftWeightTL then
				app.writeLog(method.qualifiedName &amp; _theTI.id &amp; " TL WEIGHT EXCEEDED" ,LogINFO); // PAR 26858
				return true;
			endif;
			aftReq := self.myRequest;
			fwdReq := aftReq.getForwardSlotRequest();
		
			if fwdReq &lt;&gt; null and fwdReq.myJob = aftReq.myJob then
				fwdWLE := fwdReq.allWorkListEntries.first.CM_VoyageWLE;
				fwdTI := fwdWLE.myTrackedItem;
				//epr par 17784 30/9/08
				if (fwdTI &lt;&gt; null) then
					if ( fwdTI.totalWeight &gt; _maxLiftWeightTL) then
						app.writeLog(method.qualifiedName &amp; fwdTI.id &amp; " TL WEIGHT EXCEEDED" ,LogINFO); // PAR 26858
						return true;
					endif;
				endif;
			endif;

		endif;
		
		//14 June 2010	NDL	Par 24108
		if _maxTwinLiftDiff &gt; 0 then

			if fwdTI = null then
				aftReq := self.myRequest;
				fwdReq := aftReq.getForwardSlotRequest();
				if fwdReq &lt;&gt; null and fwdReq.myJob = aftReq.myJob then
					fwdWLE := fwdReq.allWorkListEntries.first.CM_VoyageWLE;
					if fwdWLE &lt;&gt; null then
						fwdTI := fwdWLE.myTrackedItem;
					endif;
				endif;
			endif;
			
			if fwdTI &lt;&gt; null then
				if ((_theTI.totalWeight - fwdTI.totalWeight).abs &gt; _maxTwinLiftDiff) then
					app.writeLog(method.qualifiedName &amp; fwdTI.id &amp; " TL WEIGHT DIFFERENCE EXCEEDED" ,LogINFO); // PAR 26858
					return true;
				endif;
			endif;
			
		endif;
		
	endif;
	
	return false;

end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_shipSLiftIfTLWgtExced" type="Boolean"/>
        <Parameter name="_maxLiftWeightTL" type="Integer"/>
        <Parameter name="_maxTwinLiftDiff" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getName" id="5b20de9f-4f31-49d7-a933-665c49880469">
        <source>getName(): String;
// -------------------------------------------
// Created 25 August 2005 by cnwdvb1
// -------------------------------------------
vars
	displayValue	: String;
	optionDisplay	: String;
	
begin
	if self.isTwinLiftProperty then
		optionDisplay	:=	optionDisplay &amp; " T";
	endif;
	
	if self.is40 then
		optionDisplay	:=	optionDisplay &amp; " 4";
	endif;
	
	displayValue	:=	inheritMethod() &amp; " " &amp;
						self.mySlotController.ordinalDeck.String &amp; 'D ' &amp;
						self.mySlotController.ordinalTier.String &amp; 'T ' &amp; 
						self.mySlotController.ordinalCell.String &amp; 'C ' &amp; 
						self.mySlotController.myBayVoyage.ordinalBay.String &amp; 'B ' &amp;
						" " &amp; self.mySlotController.getFullId() &amp;
						optionDisplay;
						
	return displayValue;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOverheadSorter" id="fa4f178c-cf61-4c83-8728-77300fea0844">
        <source>getOverheadSorter(_sorterDict	: CMIF_CustomSequencesBySlot input) : SelfType;

// Created by cnwdvb1 on 27 August 2007

vars

	slotAbove,
	slotController	: CM_SlotController;
	otherSorter		: SelfType;

begin

	slotController := self.mySlotController;
	slotAbove := slotController.myOverheadSlot;
	if slotAbove &lt;&gt; null then
		otherSorter := _sorterDict[slotAbove];
		return otherSorter;
	endif;
	
	return null;

end;</source>
        <Parameter name="_sorterDict" type="CMIF_CustomSequencesBySlot" usage="input"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="getUnderfootSorter" id="3d798f75-6252-4f9b-8435-067b04b439c8">
        <source>getUnderfootSorter(_sorterDict	: CMIF_CustomSequencesBySlot input) : SelfType;

// Created by cnwdvb1 on 27 August 2007

vars

	slotUnder,
	slotController	: CM_SlotController;
	otherSorter		: SelfType;

begin

	slotController := self.mySlotController;
	slotUnder := slotController.myUnderfootSlot;
	if slotUnder &lt;&gt; null then
		otherSorter := _sorterDict[slotUnder];
		return otherSorter;
	endif;
	
	return null;

end;</source>
        <Parameter name="_sorterDict" type="CMIF_CustomSequencesBySlot" usage="input"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="isTLByISOType" id="e74bd978-b281-42d9-b054-51cd7181c42b">
        <source>isTLByISOType(_theTI : CM_TrackedItem) : Boolean;
// ---------------------------------------------------------------------------
// Created:     June 2008 ANDREW BISHOP
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	isoType	: CM_ISOType;
begin
	if _theTI &lt;&gt; null then
		if not _theTI.isTwenty() then // 30 40 45 53
			return false; 
		endif;
		
		isoType := _theTI.getISOTypeObject();
			
		// ## 20s only and iso type says YES ; Check actual ti attributes as well.
		if isoType &lt;&gt; null then
			app.writeLog(method.qualifiedName &amp; "TWINLIFT: ISO Type twin capable check: " &amp; (not(isoType.isNotTwinLiftCapable)).String ,LogINFO);
			return not(isoType.isNotTwinLiftCapable);
		else
			return false;
		endif;
	endif;
	
	return false;


end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTwinLift" id="226e298d-a830-4465-b77e-764f2dcbcecf">
        <source>isTwinLift(_cmif : SelfType; _shipSLiftIfTLWgtExced : Boolean; _maxLiftWeightTL : Integer; _shipSLiftIfDiffHeights : Boolean; _maxTwinLiftDiff : Integer) : Boolean;
// -------------------------------------------
// Created 29 August 2005 by cnwdvb1
// -------------------------------------------
vars

	isoType	: CM_ISOType;
	theTI : CM_TrackedItem;
begin
	// We have a null or invalid cmif so we can't tell.
	if not global.isValidObject(_cmif) then
		return false;
	endif;
	
	// Two items are the same position but different bays.
	if	self.mySlotController.ordinalCell = _cmif.mySlotController.ordinalCell and
		self.mySlotController.ordinalDeck = _cmif.mySlotController.ordinalDeck and
		self.mySlotController.ordinalTier = _cmif.mySlotController.ordinalTier and
		self.mySlotController.myBayVoyage.ordinalBay &lt;&gt; _cmif.mySlotController.myBayVoyage.ordinalBay then

		// If no tis then load.
		
		if self.myRequest.isLoad then
			if self.myRequest.getAttrIs40() or (self.myRequest.getAttrHalfHeight() or _cmif.myRequest.getAttrHalfHeight()) then
				return false;
			endif;
			
			theTI := self.myRequest.getTrackedItem();
			if theTI &lt;&gt; null then
				if self.checkIfTLWeightExceed(theTI, _shipSLiftIfTLWgtExced, _maxLiftWeightTL, _maxTwinLiftDiff) then
					return false;
				endif;
				
				if self.checkIfTLHeightDiff(_shipSLiftIfDiffHeights) then
					return false;
				endif;
				/* WAS PAR 17344
				isoType := theTI.getISOTypeObject();
				// ## 20s only and iso type says YES ; Check actual ti attributes as well.
				if isoType &lt;&gt; null and not isoType.isNotTwinLiftCapable and not theTI.isAttributeTrue(TI_Attrib_IsForty) then
					return true;
				endif;
				NOW PAR 17344 */
				isoType := theTI.getISOTypeObject();
					
				// ## 20s only and iso type says YES; Check actual ti attributes as well.
//				if not (isoType &lt;&gt; null and not isoType.isNotTwinLiftCapable and not theTI.isAttributeTrue(TI_Attrib_IsForty)) then // PAR 17813 removed
				if not (isoType &lt;&gt; null and not isoType.isNotTwinLiftCapable and  theTI.isTwenty()) then // PAR 17813 changed to isTwenty()
					app.writeLog(method.qualifiedName &amp; "TWINLIFT: 1 ISO Type is NOT twin capable" ,LogINFO);
					return false;
				endif;
				app.writeLog(method.qualifiedName &amp; "TWINLIFT: 1 ISO Type IS twin capable" ,LogINFO);
				//return self.isTLByISOType(theTI); // PAR 17813 removed

			elseif self.myRequest.useVoyageAllocations then // PAR 34834
				if _shipSLiftIfDiffHeights then
					return self.myRequest.isFwdSlotReqSameHeight();
				endif;
			endif;
			
			theTI := null;
			
			theTI := _cmif.myRequest.getTrackedItem();
			if theTI &lt;&gt; null then
				if self.checkIfTLWeightExceed(theTI, _shipSLiftIfTLWgtExced, _maxLiftWeightTL, _maxTwinLiftDiff) then
					return false;
				endif;
				
				if self.checkIfTLHeightDiff(_shipSLiftIfDiffHeights) then
					return false;
				endif;
					
				/* WAS PAR 17344
				isoType := theTI.getISOTypeObject();
				// ## 20s only and iso type says YES ; Check actual ti attributes as well.
				if isoType &lt;&gt; null and not isoType.isNotTwinLiftCapable and not theTI.isAttributeTrue(TI_Attrib_IsForty) then
					return true;
				endif;
				NOW PAR 17344 */
				/* PAR 17813  return self.isTLByISOType(theTI);
				NOW */
				isoType := theTI.getISOTypeObject();
					
				// ## 20s only and iso type says YES; Check actual ti attributes as well.
//				if not (isoType &lt;&gt; null and not isoType.isNotTwinLiftCapable and not theTI.isAttributeTrue(TI_Attrib_IsForty)) then // PAR 17813 removed
				if not (isoType &lt;&gt; null and not isoType.isNotTwinLiftCapable and  theTI.isTwenty()) then // PAR 17813 changed to isTwenty()
					app.writeLog(method.qualifiedName &amp; "TWINLIFT: 2 ISO Type is NOT twin capable" ,LogINFO);
					return false;
				endif;
				app.writeLog(method.qualifiedName &amp; "TWINLIFT: 2 ISO Type IS twin capable" ,LogINFO);
			endif;	
			
			return true;

		// ### DISCHARGE
		elseif self.myRequest.isDischarge and self.mySlotController.allTrackedItems.size = 1 then  
			theTI := self.mySlotController.allTrackedItems.first;
			if theTI &lt;&gt; null then
				if self.checkIfTLWeightExceed(theTI, _shipSLiftIfTLWgtExced, _maxLiftWeightTL, _maxTwinLiftDiff) then
					return false;
				endif;
				if self.checkIfTLHeightDiff(_shipSLiftIfDiffHeights) then
					return false;
				endif;

				
				/* WAS PAR 17344
				// ## 20s only and iso type says YES ; Check actual ti attributes as well.
				isoType := theTI.getISOTypeObject();
				if isoType &lt;&gt; null and not isoType.isNotTwinLiftCapable and not theTI.isAttributeTrue(TI_Attrib_IsForty) then
					return true;
				endif;
				NOW PAR 17344 */
				
				/* PAR 17813  return self.isTLByISOType(theTI);
				NOW */
				isoType := theTI.getISOTypeObject();
					
				// ## 20s only and iso type says YES; Check actual ti attributes as well.
//				if not (isoType &lt;&gt; null and not isoType.isNotTwinLiftCapable and not theTI.isAttributeTrue(TI_Attrib_IsForty)) then // PAR 17813 removed
// PAR 18415				if not (isoType &lt;&gt; null and not isoType.isNotTwinLiftCapable and  theTI.isTwenty()) then // PAR 17813 changed to isTwenty()
				if isoType &lt;&gt; null and not isoType.isNotTwinLiftCapable and  theTI.isTwenty() then // PAR 18415 removed 'not'
					app.writeLog(method.qualifiedName &amp; "TWINLIFT: 3 ISO Type IS twin capable" ,LogINFO);
					return true;
				endif;
			endif;
		endif;
	endif;
	
	return false;


end;</source>
        <Parameter name="_cmif" type="SelfType"/>
        <Parameter name="_shipSLiftIfTLWgtExced" type="Boolean"/>
        <Parameter name="_maxLiftWeightTL" type="Integer"/>
        <Parameter name="_shipSLiftIfDiffHeights" type="Boolean"/>
        <Parameter name="_maxTwinLiftDiff" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFromRequest" id="e657fe86-d189-4e9c-a62a-db12d61f3cae">
        <updating/>
        <source>setFromRequest(_req : CM_SlotRequest; _isStarboard : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     17 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
begin
	self.expectedEdition	:= _req.mySlotController.edition;
	self.myRequest			:= _req;
	self.mySlotController	:= _req.mySlotController;
//	self.is40				:=	_req.fortyFront;
	self.is40				:=	not _req.is20(); // PAR 21917
	
	if _isStarboard then
		//self.seqNum	:= _req.numSeqStarBoard;
		self.seqNum	:= _req.numSeqStarboardCustom;
		//self.seqNumOther := _req.numSeqPort;
		self.seqNumOther := _req.numSeqPortCustom;
		
		self.seqNumTwin 		:= _req.numSeqStarboardTwinCustom;
		self.seqNumOtherTwin	:= _req.numSeqPortTwinCustom;
		self.isTwinLiftProperty := _req.isTwinLiftStarboard;
		self.nextCraneLane		:= _req.defaultCraneLoadLaneStarboard;
		self.nextCraneLaneOther := _req.defaultCraneLoadLanePort;
	
	else
		//self.seqNum	:= _req.numSeqPort;
		self.seqNum	:= _req.numSeqPortCustom;
		//self.seqNumOther := _req.numSeqStarBoard;
		self.seqNumOther := _req.numSeqStarboardCustom;
		
		self.seqNumTwin 		:= _req.numSeqPortTwinCustom;
		self.seqNumOtherTwin	:= _req.numSeqStarboardTwin;
		self.isTwinLiftProperty	:= _req.isTwinLiftPort;
		self.nextCraneLane		:= _req.defaultCraneLoadLanePort;
		self.nextCraneLaneOther := _req.defaultCraneLoadLaneStarboard;
	endif;
//	self.useBold := _req.
end;</source>
        <Parameter name="_req" type="CM_SlotRequest"/>
        <Parameter name="_isStarboard" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tmpPortDischargeSeq" id="282eedd1-df93-43a7-914f-620d700ef276">
        <methodInvocation>mapping</methodInvocation>
        <source>tmpPortDischargeSeq(set: Boolean; _value: Integer io) mapping;
// -------------------------------------------
// Created 06 October 2005 by cnwdvb1
// -------------------------------------------
vars

begin
	if set then
		return;
		// set code here
	else
		if self.is40 and self.isUsingDifferentLengths then
			_value := self.mySlotController.mySlotDefnVoyage.sequenceNumPortDis40;
		else
			_value := self.mySlotController.mySlotDefnVoyage.sequenceNumPortDis;
		endif;
		// get code here
	endif;



end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
