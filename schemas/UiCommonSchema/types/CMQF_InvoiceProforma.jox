<Class name="CMQF_InvoiceProforma">
    <JadeMethod name="setFromAgent" id="ea97196e-607c-489c-81e9-fb9fe3aa3260">
        <updating/>
        <source>setFromAgent(_agent: CMUI_ReportAgent input) updating;
/*

Date		Who		Reason
18/08/2015	cnwer1	Initial creation PAR 36778
13/02/2018	jlgdap1	TFS 37030 SSL Demurrage Report
07/10/2019	jlgdap1	TFS 46315 JMT Proforma Report Issue
*/

vars
	cashDebtorType		: CM_DebtorType;
	dac		: CM_DataAccessController;
	clearingAgent	: Object;
	obj		: Object;
	terminal	: CM_Terminal;
	query : CM_MenuUserQuery;				// TFS 37030
begin
	inheritMethod(_agent);
	if _agent.isRowIncluded(ETRow_EffectiveDate) then
		self.effectiveDate := _agent.getValueByNameIfVisible(ETRow_EffectiveDate).Date;
	endif;
	if _agent.isRowIncluded(ETRow_InwardCode) then
		self.voyageInwardCode := _agent.getValueByNameIfVisible(ETRow_InwardCode).String;
	endif;
	if _agent.isRowIncluded(ETRow_CustomsEntryNumber) then
		self.customsEntryNumber := _agent.getValueByNameIfVisible(ETRow_CustomsEntryNumber).String.toUpper;	// Par 37730
	endif;
	if _agent.isRowIncluded(ETRow_SelectorQueryIds) then			// TFS 37030
		if _agent.isKindOf(CMUI_ReportAgentStd) then									// TFS 46315
			query := _agent.CMUI_ReportAgentStd.getSelectedQuery();	// TFS 37030
		else																			// TFS 46315
			query := null;																// TFS 46315
		endif;																			// TFS 46315
		if query &lt;&gt; null then										// TFS 37030
			self.setMyQuery(query);									// TFS 37030
		else														// TFS 37030
			self.setMyQuery(null);									// TFS 37030
		endif;														// TFS 37030
	endif;															// TFS 37030
	if _agent.isRowIncluded(ETRow_Agent) then
		clearingAgent := _agent.getSelectedClearingAgent();
		if clearingAgent &lt;&gt; null then
			if clearingAgent.isKindOf(CM_CustomsAgent) then
				self.setMyCustomsAgent( clearingAgent.CM_CustomsAgent );
				self.setMyDebtor( clearingAgent.CM_CustomsAgent.myDebtor );
			elseif clearingAgent.isKindOf(CM_ConsigneeConsignor) then
				self.setMyConsignee( clearingAgent.CM_ConsigneeConsignor );
				self.setMyDebtor( clearingAgent.CM_ConsigneeConsignor.debtor );
			endif;
		else
			// if run from the RIA get the agent from the user
			if currentSchema.name = "WebServicesSchema" then
				terminal := self.allTerminals.first;
				if terminal &lt;&gt; null then
					cashDebtorType := terminal.getConfig(CashDebtorType).CM_DebtorType;
				endif;
				if cashDebtorType = null then
					cashDebtorType := app.myRoot.allDebtorTypes["SDT6"];	// default to customs agent
				endif;
				if cashDebtorType.isCustomsAgent then
					dac := app.myPassport.myUser.allDataAccessControllers[CM_CustomsAgent.name];
					if dac &lt;&gt; null and not dac.allObjects.isEmpty then
						obj := dac.allObjects.first;
						if obj &lt;&gt; null then
							self.setMyCustomsAgent( obj.CM_CustomsAgent );
							self.setMyDebtor( self.getMyCustomsAgent.myDebtor );
						endif;
					endif;
				else
					dac := app.myPassport.myUser.allDataAccessControllers[CM_ConsigneeConsignor.name];
					if dac &lt;&gt; null and not dac.allObjects.isEmpty then
						obj := dac.allObjects.first;
						if obj &lt;&gt; null then
							self.setMyConsignee( obj.CM_ConsigneeConsignor );
							self.setMyDebtor( self.getMyConsignee.debtor );
						endif;
					endif;
				endif;
			endif;
		endif;
	endif;
epilog

end;
</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
