    <JadeMethod name="doMatch" id="8f26c307-6156-4225-b514-962f62e94e64">
        <source>doMatch(_value: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2013	cnwndl1	Initial creation	Par 31506

*/

vars

begin

	if _value.trimBlanks.startsWith(self.searchValue) then
		return true;
	elseif _value.trimBlanks.endsWith(self.searchValue) then
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_value" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaLineDefinitionForRT" id="07147663-0673-49fd-b624-9c0f56f3862e">
        <source>getCriteriaLineDefinitionForRT(_prop: CM_QueryProperty; _searchValueA: String output; _searchValueB: String output; _searchValueBoolean: Boolean output; _isStringProperty: Boolean output; _isStringBetweenProperty: Boolean output; _isBooleanProperty: Boolean output);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2013	cnwndl1	Initial creation

*/

vars

begin

	_searchValueA			:= self.searchValue.asStringJMT();
	_searchValueB			:= null;
	_searchValueBoolean		:= null;
	_isStringProperty		:= true;
	_isStringBetweenProperty:= false;
	_isBooleanProperty		:= false;

epilog

end;</source>
        <Parameter name="_prop" type="CM_QueryProperty"/>
        <Parameter name="_searchValueA" type="String" usage="output"/>
        <Parameter name="_searchValueB" type="String" usage="output"/>
        <Parameter name="_searchValueBoolean" type="Boolean" usage="output"/>
        <Parameter name="_isStringProperty" type="Boolean" usage="output"/>
        <Parameter name="_isStringBetweenProperty" type="Boolean" usage="output"/>
        <Parameter name="_isBooleanProperty" type="Boolean" usage="output"/>
    </JadeMethod>
