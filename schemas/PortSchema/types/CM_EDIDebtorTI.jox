    <JadeMethod name="createAddressProxy" id="8389f7a1-6313-49ab-b6d7-ea60748c657e">
        <source>createAddressProxy(ediAddress: CM_EDIAddressTI; 
				   realAddress: CM_Address; 
				   debtor: CM_Debtor ): CM_Address;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Nov 2025 navlc30 JIRA 36357 - LINX - Enable importing debtor addresses via EDI
*/

vars
    proxyAddress : CM_Address;
begin
    proxyAddress := null;
    
    //create proxy from existing address - Update scenario
    if realAddress &lt;&gt; null then
        proxyAddress := realAddress.pxyCreateUpdateProxy();
    endif;
    
    //If proxyAddress is null Create new transient proxy - Add scenario
    if proxyAddress = null then
        create proxyAddress transient;
    endif;
    
    // Set proxy properties from EDI
    proxyAddress.setProxy(
        ediAddress.id,
        ediAddress.description,
        ediAddress.address1,
        ediAddress.address2,
        ediAddress.address3,
        ediAddress.region,
        ediAddress.postCode,
        ediAddress.countryCode,
        ediAddress.city,
        ediAddress.emailAddress,
        null,
        ediAddress.isDefault,
        ediAddress.isAlternate,
        debtor
    );
    
    return proxyAddress;
end;</source>
        <Parameter name="ediAddress" type="CM_EDIAddressTI"/>
        <Parameter name="realAddress" type="CM_Address"/>
        <Parameter name="debtor" type="CM_Debtor"/>
        <ReturnType type="CM_Address"/>
    </JadeMethod>
    <JadeMethod name="createCMIF_Debtor" id="7b3a2c3b-a939-4619-96a8-448976f3a210">
        <source>createCMIF_Debtor() : CMIF_DebtorNode;
/*

Date		Who		Reason
02/06/2015	cnwer1	Initial creation PAR
09/08/2018	jlgdap1	TFS 40092 New parameter for CM_DebtorNode::setProxy
28/03/2020  cnwma1	Bug 48994: ASPA - Debtor Uploads missing Attributes
12 Nov 2025 navlc30 JIRA 36357 - LINX - Enable importing debtor addresses via EDI
*/

vars
	cmifDebtor   : CMIF_DebtorNode;
	parentDebtor : CM_DebtorNode;
	realDebtor   : CM_Debtor;
	termsOfTrade : CM_InvoiceTermsOfTrade;

begin
	create cmifDebtor transient;
	realDebtor := self.getDebtor;
	if realDebtor &lt;&gt; null then
		cmifDebtor.setFromDebtor(realDebtor);
		cmifDebtor.myPxyDebtorNode:=realDebtor.pxyCreateUpdateProxy();
	endif;
	
	if self.myParentDebtorNode &lt;&gt; null then
		parentDebtor := app.myRoot.myRootCompany.debtorNodes[self.myParentDebtorNode];
	endif;
	
	if self.termsOfTrade &lt;&gt; null then //28.03.2020 cnwma1 #48994
		termsOfTrade :=  app.myRoot.myRootCompany.allInvoiceTermsOfTrade[self.termsOfTrade];
	endif;
	
	if self.action = self.EDI_ACTION_ADD then
		create cmifDebtor.myPxyDebtorNode as CM_Debtor transient;
		//cmifDebtor.myPxyDebtorNode.setProxy(self.name);				// TFS 40092
		cmifDebtor.myPxyDebtorNode.setProxy(self.name, self.code);		// TFS 40092    //28.03.2020 cnwma1 #48994
	endif;
	
	
	
	if self.action = self.EDI_ACTION_ADD or self.action = self.EDI_ACTION_UPDATE then
		cmifDebtor.setForImport(self.name,
								self.billingAddress,
								self.remarks,
								self.decfinName,
								self.purchaseOrderCode,
								self.isPurchaseOrderMandatory.asBooleanJMT,
								self.isZeroRatedTax.asBooleanJMT,
								self.isSuspended.asBooleanJMT,
								parentDebtor,
								termsOfTrade,                                     //28.03.2020 cnwma1 #48994
								null,
								null,
								null,
								null,
								null,
								self.longName,
								self.externalReference,
								self.badDebtor.asBooleanJMT,
								self.code,                                       //28.03.2020 cnwma1 #48994
								self.additionalInformation1,                     //28.03.2020 cnwma1 #48994
								self.additionalInformation2);                    //28.03.2020 cnwma1 #48994
	elseif  self.action = self.EDI_ACTION_MODIFY then
		
		if self.badDebtor &lt;&gt; null then
			cmifDebtor.badDebtor	 	    := self.badDebtor.asBooleanJMT;
		endif;
		
		if self.billingAddress &lt;&gt; null then
			cmifDebtor.billingAddress		:= self.billingAddress;
		endif;
		
		if self.decfinName &lt;&gt; null then
			cmifDebtor.decfinName	   		:= self.decfinName;
		endif;
		
		if self.externalReference &lt;&gt; null then
			cmifDebtor.externalReference	:= self.externalReference;
		endif;
		
		if self.isPurchaseOrderMandatory &lt;&gt; null then
			cmifDebtor.isPurchaseOrderMandatory := self.isPurchaseOrderMandatory.asBooleanJMT;
		endif;
		
		if self.isSuspended &lt;&gt; null then
			cmifDebtor.isSuspended	:= self.isSuspended.asBooleanJMT;
		endif;
		
		if self.isZeroRatedTax &lt;&gt; null then
			cmifDebtor.isZeroRated := self.isZeroRatedTax.asBooleanJMT;
		endif;
		
		if self.longName &lt;&gt; null then
			cmifDebtor.longName := self.longName;
		endif;
		
		if self.purchaseOrderCode &lt;&gt; null then
			cmifDebtor.purchaseOrderCode := self.purchaseOrderCode;
		endif;
		
		if self.remarks &lt;&gt; null then
			cmifDebtor.remarks := self.remarks;
		endif;
		
		if self.code &lt;&gt; null then					//15.11.2025 navlc30 #36357
			cmifDebtor.code := self.code;			//15.11.2025 navlc30 #36357
		endif;										//15.11.2025 navlc30 #36357
		
	endif;
		
	
	return cmifDebtor;
epilog

end;</source>
        <ReturnType type="CMIF_DebtorNode"/>
    </JadeMethod>
    <JadeMethod name="getDebtor" id="ce963c0f-aa14-4103-a1b0-053d0e21b7e0">
        <source>getDebtor() : CM_Debtor;
/*

Date		Who		Reason
03 June 2015	cnwer1	Initial creation PAR

*/

vars
	debtorNode : CM_DebtorNode;
begin
	debtorNode:=app.myRoot.myRootCompany.debtors[self.name];
	
	if debtorNode &lt;&gt; null and debtorNode.isKindOf(CM_Debtor) then
		
		return debtorNode.CM_Debtor;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
