    <JadeMethod name="txtRateTime_lostFocus" id="09ad4ea4-8515-41fc-9a26-7d8eb7aeb97d">
        <controlMethod name="CMUI_TimeMask::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtRateTime_lostFocus(editMask: JadeEditMask input) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
/* moved to chkIgnoreEntry lostFocus
	if self.tblCost.visible then // PAR 13250
		self.tblCost.setFocus();
		self.tblCost.moveFirst();
	endif;
	*/
end;</source>
