        <Parameter name="_str" type="String"/>
    </JadeMethod>
    <JadeMethod name="sendCallBackMsg" id="6e49ca73-03ee-4464-9108-23718c608e6c">
        <source>sendCallBackMsg(_process : Process; _msg : String) protected;
// -------------------------------------------
// Created 11 February 2004 by cnwdvb1
// -------------------------------------------
vars

	oid	: String;

begin

	if _process &lt;&gt; null then
		oid := _process.getOidString() &amp; '~*~';
	endif;
	self.causeEvent(BGP_Object.BGP_CallBackMsg, true, oid &amp; _msg);
end;</source>
        <access>protected</access>
        <Parameter name="_process" type="Process"/>
        <Parameter name="_msg" type="String"/>
    </JadeMethod>
    <JadeMethod name="terminateProcessing" id="f357fddf-df21-46b5-ad98-7a4345bd9da4">
        <updating/>
        <source>terminateProcessing(_userCode : String) updating;
// -------------------------------------------
// Created 11 November 2003 by cnwdvb1
// -------------------------------------------
// 01/10/2018	jlgmd1	TFS 41133 SNO - Make it easier to see who terminated the BGP by sending the usercode through with the notification
vars


begin

	self.causeEvent(BGP_Object.BGP_TerminateAppRequest, true, _userCode);
	app.writeLog(method.qualifiedName, LogTRACE);	//25 Nov 2019	NDL	TFS 47053
	self.causeEvent(BGP_Object.BGP_DisplayUpdate, false, null);	

end;</source>
        <Parameter name="_userCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="xHandlerGlobal" id="294b8603-c236-405e-a7ad-e681e38ed6ef">
        <source>xHandlerGlobal(_exception : Exception) : Integer;
// -------------------------------------------
// Created 10 March 2005 by cnwdvb1
// -------------------------------------------
/*

Date		Who		Reason
01 Dec 2016	cnwkpd1	Must always abortTransaction before returning Ex_Abort_Action
// 04 Jul 2019	jlgrs1	TFS45051 JMT terminate on a SDS secondary exception ie a takeover has happened.
*/

vars
	msg : String;
	obj : BGP_Object;
begin
	if _exception.errorCode = 1228 or 
	   _exception.errorCode = 1295 or 
	   _exception.errorCode = 3015 or 
	   _exception.errorCode = 3037 then
		abortTransaction;
		abortTransientTransaction;
		msg := class.name&amp;'::'&amp;method.name&amp;' SDS Exception, cant continue,'&amp;_exception.errorCode.String&amp;' '&amp;_exception.extendedErrorText&amp;' processApp= '&amp;process.persistentApp.name&amp;' '&amp;process.userInfo&amp;' ('&amp;process.node.String&amp;", "&amp;process.String&amp;')';
		app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		if self.isKindOf(BGP_Controller) then
			app.writeLog('terminateProcessing user='&amp;process.userCode&amp;' app='&amp;app.name&amp;' '&amp;msg, LogFATAL);	//25 Nov 2019	NDL	TFS 47053
			self.BGP_Controller.terminateProcessing(process.userCode);
		endif;
		terminate;
	endif;

	msg := _exception.errorCode.String &amp; ' ' &amp; _exception.extendedErrorText &amp; ' INFO &gt;&gt; Exception handled by global BGP Exception handler. Stack set to idle';
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	app.doDumpStack(_exception);
	
	abortTransaction;
	abortTransientTransaction;
	
	return Ex_Abort_Action;


end;</source>
        <Parameter name="_exception" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
