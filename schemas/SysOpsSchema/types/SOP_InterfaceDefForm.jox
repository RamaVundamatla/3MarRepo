    <JadeMethod name="btnNew_click" id="732a30c0-3b3d-43c2-8bc3-88db0d481494">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnNew_click(btn: CMUI_Button input) updating;
// --------------------------------------------------------------------------------
// Created:		04 September 2008 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	
	if self.isFormChanged then
		if not self.askUserToAbandonChanges( true ) then
			return;
		endif;
	endif;
	
	self.doPopulateWithDefinition(null, true);
	self.doEnableControls();
epilog
	app.mousePointer	:=	Idle;
end;</source>
