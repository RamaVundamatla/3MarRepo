    <JadeMethod name="availableTransactions" id="fa18ea62-523b-4172-b908-b29bb8481377">
        <source>availableTransactions(_classColl: ClassColl input);
/*****************************************************
Date		Name	TFS#	Description
17 Aug 2017	jlgrs1	TFS 6560 SNO Damaged/Repair
31 Oct 2019	jlgdi1	46578	Added CM_ReceiveRoadCancelled transaction
******************************************************/

begin
	inheritMethod(_classColl);
	_classColl.add(CM_Repair);
