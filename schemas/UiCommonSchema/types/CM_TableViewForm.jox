    <JadeMethod name="zAutomationAction" id="b6d42ea3-9975-4adc-a26d-a566bb7bc520">
        <updating/>
        <source>zAutomationAction(_dataKey: String; _mode : String; _tableName: String; _rowName: String; _newValue: String; _result : String output) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/03/2020	jlgdap1		Initial creation TFS 48992 MTN Automation Testing - Table Navigation
//
vars
	idx : Integer;
	cntrl, entControl : Control;
	table : CM_EntryTable;
	obj : Object;
	entRow : EntTableRowTransient;
	rows, data : HugeStringArray;
	newRow, newData : String;
	isMeasurement : Boolean;
	measureTable : CMUI_MeasurementTable;
	str : String;
	entText : EntTableTextBox;

begin
	inheritMethod(_dataKey, _mode, _tableName, _rowName, _newValue, _result);
	
	create rows transient;
	create data transient;
	
	// set up the enquiry data
	self.zAutomationDoEnquiry(_dataKey);
	
	// do the search
	self.btnSearchTV_click(self.btnSearchTV);
	
	// do the query if that's what were doing
	if _mode = "Q" then
		self.zAutomationQuery(_dataKey, _tableName, _rowName, _result);
		return;
	endif;
	
	// just updates left - go in to edit mode
	self.btnEditTV_click(self.btnEditTV);
	
	// find the table 
	foreach idx in 1 to self.controlCount do
		cntrl := self.controls(idx);
		if cntrl.isKindOf(CM_EntryTable) and cntrl.name = _tableName then
			table := cntrl.CM_EntryTable;
			break;
		endif;
	endforeach;
	if table = null then 
		return;
	endif;
	
	// set focus to the sheet the table is on
	table.parent.setFocus();
	cntrl := table;
	self.zAutomationShowData(cntrl);
	
	// we can have more than one row - pipe delimited
	if _rowName.pos("|", 1) &lt;&gt; null then
		_rowName.getTokensForDelimiterHuge("|", rows);
	else
		rows.add(_rowName);
	endif;
	// if we hav more than one row, we better have the same number of data elements
	if _newValue.pos("|", 1) &lt;&gt; null then
		_newValue.getTokensForDelimiterHuge("|", data);
	else
		data.add(_newValue);
	endif;
	if rows.size &lt;&gt; data.size then
		return;
	endif;
	
	// now process each row and new data value
	foreach idx in 1 to rows.size do
		newRow := rows[idx];
		newData := data[idx];
		entControl := null;
		isMeasurement := false;
		
		// see if we have a control associated with the row
		foreach obj in table.allEntRowTransients do
			entRow := obj.EntTableRowTransient;
			str := entRow.name;
			if entRow.name = newRow and entRow.controlName &lt;&gt; null then
				entControl := self.getControlByName(entRow.controlName);
				break;
			elseif entRow.name[2:4] ="TRow" and entRow.name.pos(newRow, 1) &gt; 0 then
				isMeasurement := true;
				newRow := entRow.name;
				break;
			elseif entRow.myEntTableCellControl &lt;&gt; null and entRow.myEntTableCellControl.isKindOf(EntTableTextBox) then
				entText := entRow.myEntTableCellControl.EntTableTextBox;
				// check new data is appropriate
				if entText.maxLength &lt; newData.length then
					_result := "String too long";
					return;
				endif;
			endif;
		endforeach;
		table.row := table.getRowByName(newRow);
		table.column := table.ColumnValue;
		table.setFocus;
		
		if newData &lt;&gt; null then 
			if entControl &lt;&gt; null then
				if entControl.isKindOf(TextBox) then
					entControl.TextBox.text := newData;
					entControl.TextBox.lostFocus(entControl.TextBox);
				elseif entControl.isKindOf(CMUI_ComboBox) then
					entControl.CMUI_ComboBox.listIndex := entControl.CMUI_ComboBox.findString(1, newData);
					entControl.CMUI_ComboBox.lostFocus(entControl.CMUI_ComboBox);
				endif;
				
			elseif isMeasurement then
				measureTable := table.accessCell(table.row, table.ColumnValue).cellControl.CMUI_MeasurementTable;
				measureTable.setValue(newData.Decimal);
				measureTable.lostFocus(measureTable);
			else
				table.accessCell(table.row, table.column).text := newData;
			endif;
		endif;
	endforeach;
	
	// now save
	self.btnSaveBase_click(self.btnSaveBase);
epilog
	delete rows;
	delete data;
end;</source>
        <Parameter name="_dataKey" type="String"/>
        <Parameter name="_mode" type="String"/>
        <Parameter name="_tableName" type="String"/>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_newValue" type="String"/>
        <Parameter name="_result" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="zAutomationSetSearchTable" id="361db388-cb2a-462c-9744-166c5a8390f1">
        <source>zAutomationSetSearchTable(_queryKey, _queryHeading : String);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 30/11/2020	jlgdap1		Initial creation TFS 48992 Automated Testing - Table navigation
//
vars
	idx : Integer;
	cell, dataCell : JadeTableCell;

begin
	foreach idx in 1 to self.tblSearch.rows do
		cell := self.tblSearch.accessCell(idx, 1);
		if cell.text = _queryHeading then
			dataCell := self.tblSearch.accessCell(idx, 2);
			dataCell.text := _queryKey;
			if dataCell.cellControl.isKindOf(CMUI_ComboBox) then
				dataCell.cellControl.CMUI_ComboBox.listIndex := dataCell.cellControl.CMUI_ComboBox.findStringExact(1, _queryKey);
				dataCell.cellControl.CMUI_ComboBox.lostFocus(dataCell.cellControl.CMUI_ComboBox);
			endif;
			break;
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_queryKey" type="String"/>
        <Parameter name="_queryHeading" type="String"/>
    </JadeMethod>
    <JadeMethod name="zBeginTimerForRefresh" id="943dd851-0dd0-43f7-a784-58d31d4736b3">
        <updating/>
        <source>zBeginTimerForRefresh() updating, protected;
// ---------------------------------------------------------------------------
// Created:     14 May 2001 by cnwrs2
//
// Purpose:     When we receive notification of an delete/add event of the object
//				class we start a timer to do a refresh.  This is so that if another
//				process creates/deletes a large number of objects we only reduce the
//				number of refreshes required.  The timer delay is designed to allow
//				the other create/delete notifications to be received.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if (not self.timerRefreshActive) then
		self.timerRefreshActive := true;
		self.needTblDataRefresh := true;
		self.beginTimer(2000, Timer_OneShot, Timer_Refresh);
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zCheckTblDataRowChange" id="a61291cb-1767-447b-a90e-21346bf4797a">
        <updating/>
        <source>zCheckTblDataRowChange() : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     23 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	result	: Integer;

begin

	if self.mode = self.Mode_View then
		// viewing so no check needed.
		return true;
	endif;

	result := app.msgBox(app.getErrorString(QueryRowChange),  app.getErrorString(Warning), MsgBox_Yes_No_Cancel + MsgBox_Question_Mark_Icon);
	
	if result = MsgBox_Return_Cancel then
		// do NOT move to new row.
		return false;
	elseif result = MsgBox_Return_No then
		// cancel changes to existing item and move to the next row
		self.zDoCancel();
		return true;
	elseif result = MsgBox_Return_Yes then
		// save the existing item, if successful then move to the new row;
		return self.zDoSave();
	endif;

	return false;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="zClearPlaceHolderObject" id="44b3f672-dba7-45ac-831f-dd769594b541">
        <updating/>
        <source>zClearPlaceHolderObject() updating, protected;
// ---------------------------------------------------------------------------
// Created:     13 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if (not self.useTblData) then
		return;
	endif;

	if global.isValidObject(self.myPlaceHolderObject) then  //no overhead for transient
		tblData.removeItemObject(self.myPlaceHolderObject);
		delete self.myPlaceHolderObject;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zClearProxyArray" id="332a5c21-357d-45e9-a8d0-e28841376c9a">
        <updating/>
        <source>zClearProxyArray() updating, protected;
// ---------------------------------------------------------------------------
// Created:     31 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpProxy	: Object;
	
begin

	foreach tmpProxy in self.allProxyObjects do
		self.allProxyObjects.remove(tmpProxy);
		if global.isValidObject( tmpProxy ) then //no overhead for transient
			tmpProxy.CM_Object.erase(NORMAL_ERASE);
		endif;
	endforeach;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zClearProxyDetails" id="12215e23-7655-4742-a9e8-3fb37cfd178a">
        <updating/>
        <source>zClearProxyDetails() updating, protected;
// ---------------------------------------------------------------------------
// Created:     31 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/01/2010	cnwrl1		PAR 21889 - CCMS 1002 = Stops and Italian Customs - T1015 = Expiry Date for Stops Clearance
// ---------------------------------------------------------------------------
vars
//	tmpProxy	: Object;
	allStops	: CM_StopsByIdDict;
	
begin
	create allStops transient;				// cnwrl1 29/01/2010 PAR 21889
	
	if global.isValidObject( self.myProxyObject ) then //no overhead for transient
		// cnwrl1 29/01/2010 PAR 21889 - start of coding
		// Make sure the transient CM_Stops are purged.
		if self.myProxyObject.isKindOf( CM_TrackedItem ) then
			allStops.clear;
			self.myProxyObject.CM_TrackedItem.getAllActiveStopsAsAtDate( allStops, CM_Stops.Away_In_The_Future_Date );
			allStops.purge();
		endif;
		// cnwrl1 29/01/2010 PAR 21889 - end of coding
		if not self.allProxyObjects.includes( self.myProxyObject ) then
			self.myProxyObject.erase( NORMAL_ERASE );
		endif;
		self.myProxyObject := null;
	else
		self.myProxyObject := null;
	endif;
	
	self.zClearProxyArray();

epilog
	delete allStops;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zClearSortColumns" id="cacbc30c-9318-4e8d-a83e-8cfd5564b02c">
