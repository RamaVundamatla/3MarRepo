		_obj.handleChildDeleteAudits(self.myDeleteAuditAgent);
		app.myEventManager.createSingleObjInfoNoteEvt(_obj.myInvoiceContract,app.myPassport.myTerminal.getTerminalEvent(Event_InvContractDtlDelete),_obj);	//02-02-2023 navtnr20 TFS CR 55646 TASK 55664
	endif;

	if _passport.noErrors then
