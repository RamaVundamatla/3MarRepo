    <JadeMethod name="displaySealValues" id="a16b3ccf-2e98-47ab-856f-6a88c88556b1">
        <updating/>
        <source>displaySealValues(	_sealObject : CM_SealObject ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 July 2015	cnwndl1	Initial creation	Par 36658

*/

vars

	sealType : CM_SealType;
	sealNum : String;
	index : Integer;

begin

	self.txtValues.text := null;
	self.tblValues.clear;
	self.tblValues.clearAllSelected();

	if _sealObject &lt;&gt; null then
		sealType := _sealObject.getMySealTypeObj;
		
		if sealType &lt;&gt; null and sealType.allowMultipleSealNums then
			index := 1;
			foreach sealNum in _sealObject.allSealNums do
				index := index + 1;
				if index &gt; self.tblValues.rows then
					self.tblValues.addItem(sealNum);
				else
					self.tblValues.setCellText(index,1,sealNum);
				endif;
			endforeach;
		else
			self.txtValues.text := _sealObject.getSealValueAsString;
		endif;
	endif;
	
	self.tblValues.topRow := 2;
	self.tblValues.row := 2;

epilog

end;</source>
        <Parameter name="_sealObject" type="CM_SealObject"/>
    </JadeMethod>
