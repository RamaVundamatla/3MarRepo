    <JadeMethod name="buildExtractTransientMethod" id="b644e708-5d54-45f7-bd37-c78a7dd39a10">
        <executionLocation>server</executionLocation>
        <source>buildExtractTransientMethod(_dict : CM_DataExtractTransMethodDict input)serverExecution;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 May 2011	#cnwdz2	 

*/

vars
	transientMethod : JadeMethod;
	errorCode       : Integer;
	errorPosition   : Integer;
	errorLength	    : Integer;
	generatedMethod : CM_DataExtractTransientMethod;
	classNumber     : Integer;
begin
	transientMethod := process.createTransientMethod(CM_DataExtractClass.ExtractFieldValueMethodName, CM_DataExtractField, currentSchema , self.getPropertyMethodSource, false, null, errorCode, errorPosition, errorLength);
	if errorCode &lt;&gt; null then
		app.raiseCMException3(ERR_DataExtractTransCreateFail, errorCode.String, self.getDataExtractClass.getMyClass.name&amp;"::"&amp;self.name, self.getPropertyMethodSource,null, null);
		return;
	endif;
		
	create generatedMethod transient;
	classNumber := self.getDataExtractClass.classNumber;
	generatedMethod.initProperties(classNumber, self.name, transientMethod);
	if _dict.includesKey(classNumber, self.name) then
		return;
	endif;
	_dict.add(generatedMethod);
epilog

end;</source>
        <Parameter name="_dict" type="CM_DataExtractTransMethodDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createPersistentField" id="24b4c632-8f0b-4290-8bf0-34301cd57aba">
        <source>createPersistentField() : CM_DataExtractField;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2011	#cnwdz2	 

*/

vars
	field : CM_DataExtractField;
begin
	create field persistent;
	field.setForCreate(self);
	
	return field;
epilog

end;</source>
        <ReturnType type="CM_DataExtractField"/>
    </JadeMethod>
    <JadeMethod name="createTransientFieldWithName" id="b2c10638-13e6-4398-9255-5e1128f22ec6">
        <source>createTransientFieldWithName(_fieldName: String) : CM_DataExtractField;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2011	#cnwdz2	 

*/

vars
	field : CM_DataExtractField;
begin
	create field transient;
	field.setProxy(_fieldName, self);
	
	return field;

epilog

end;</source>
        <Parameter name="_fieldName" type="String"/>
        <ReturnType type="CM_DataExtractField"/>
    </JadeMethod>
    <JadeMethod name="doExtractData" id="9508d3a2-0650-462e-ad23-7eb79548dcc4">
        <source>doExtractData(_object : CM_Object; _outputFile : File) : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2011	#cnwdz2	 

*/

vars
	methodSource : String;
	classNumber  : Integer;
	transMethod  : CM_DataExtractTransientMethod;
	me           : SelfType;
begin
	classNumber := self.getDataExtractClass.classNumber;
	//transMethod := app.myDataExtractAgent.allDataExtractTransientMethods.getAtKey(classNumber, self.name);	
	transMethod := app.myDataExtractAgent.allDataExtractTransientMethods.getAtKey(classNumber, self.name);
	me := self;	
	return process.executeTransientMethod(transMethod.myJadeMethod, me, _object).String;
epilog

end;</source>
        <Parameter name="_object" type="CM_Object"/>
        <Parameter name="_outputFile" type="File"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doExtractDoc" id="20bf77dc-3098-4771-bdae-39e3b5e35239">
        <source>doExtractDoc(_outputFile: File);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2011	#cnwdz2	 

*/

vars
	docLine   : String;
begin
	docLine := self.getDataExtractClass().tidyUpStringForCSVOutput(self.niceName) &amp; ",";
	docLine := docLine &amp; self.getDataExtractClass.tidyUpStringForCSVOutput(self.description) &amp; ",";
	docLine := docLine &amp; self.type &amp; ",";
	docLine := docLine &amp; self.getDataExtractClass.tidyUpStringForCSVOutput(self.possibleValues);
	_outputFile.writeLine(docLine);
epilog

end;</source>
        <Parameter name="_outputFile" type="File"/>
    </JadeMethod>
    <JadeMethod name="getDataExtractClass" id="110d9ec5-9653-4dde-b473-067eb0bd15d8">
        <source>getDataExtractClass():CM_DataExtractClass;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2011	#cnwdz2	 

*/

vars

begin
	if self.myDataExtractClass = null then
		return self.myParentFeild.myDataExtractClass;
	else
		return self.myDataExtractClass;
	endif;
epilog

end;</source>
        <ReturnType type="CM_DataExtractClass"/>
    </JadeMethod>
    <JadeMethod name="initProperties" id="743c1e42-4b00-408f-b719-bbd91d4fc140">
        <updating/>
        <source>initProperties(_name, _niceName, _description, _type, _possibleValues, _getPropertyMethodSource : String) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 April 2011	#cnwdz2	 

*/

vars

begin
	self.name  := _name;

	if _niceName &lt;&gt; null then
		self.niceName  := _niceName;
	else
		self.niceName  := _name;
	endif;
	
	self.description := _description;
	self.type := _type;
	self.possibleValues := _possibleValues;
	self.getPropertyMethodSource := _getPropertyMethodSource;	
epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_niceName" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_possibleValues" type="String"/>
        <Parameter name="_getPropertyMethodSource" type="String"/>
    </JadeMethod>
