    <JadeMethod name="getRelativeWindowPosition" id="50f74f4d-d618-491d-9b2c-49ffa3e889a5">
        <updating/>
        <source>getRelativeWindowPosition(pTheWindow:Window input; pXposition:Real io; pYposition:Real io) updating, protected;
// --------------------------------------------------------------------------------
// Created:		16 November 2001 by cnwdad1
//
// Purpose:		Updates the X-Y coordinates of a window relative to the screen.
//				This is used for determining the position for a popup-menu over a
//				control that is on top of another control (the coordinates must be
//				relative to the parent form, not a parent control).
//
// Parameters:	pTheWindow - The window whose coordinates to set.
//				pXposition - The X coordinate of the window.
//				pYposition - The Y coordinate of the window.
//
// Returns:		The X-Y coordinates after being converted to screen coordinates.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	pTheWindow.windowToScreen(pXposition, pYposition);
	self.screenToWindow(pXposition, pYposition);
end;</source>
        <access>protected</access>
        <Parameter name="pTheWindow" type="Window" usage="input"/>
        <Parameter name="pXposition" type="Real" usage="io"/>
        <Parameter name="pYposition" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getServiceInterfaceSettings" id="0ca767e3-d101-43ca-ac2d-2cc4897bd377">
        <updating/>
        <source>getServiceInterfaceSettings() updating, protected;
// --------------------------------------------------------------------------------
// Created:		12 July 2002 by cnwdad2
//
// Purpose:		Refreshes the interface options/settings from the peer schema's
//				Service Object (interface).
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theService		: JSSFMFileManagerService;
	
begin
	theService	:=	self.aMyServiceObject;
	
	if theService &lt;&gt; null then
		self.aAllDriveNamesAppServer.purge();
		self.aAllDriveNamesDbServer.purge();
		self.aAllPathNamesAppServer.purge();
		self.aAllPathNamesDbServer.purge();
		
		self.aIsAllowAppServer	:=	theService.isAllowAppServer;
		self.aFileChunkSize		:=	theService.fileChunkSize;
		
		theService.allDriveNamesAppServer.copy(self.aAllDriveNamesAppServer);
		theService.allDriveNamesDbServer.copy(self.aAllDriveNamesDbServer);
		theService.allPathNamesAppServer.copy(self.aAllPathNamesAppServer);
		theService.allPathNamesDbServer.copy(self.aAllPathNamesDbServer);
	endif;
	
	self.getFileAgent().setFileChunkSize(self.aFileChunkSize);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getUnixFlag" id="caac45ab-d6d3-4c8e-a52d-d54e7e497b84">
        <source>getUnixFlag():Boolean protected;
// --------------------------------------------------------------------------------
// Created:		20 August 2002 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the exeuction platform
//				is running the Unix operating System.
//
// Parameters:	None
//
// Returns:		True if the OS is Unix, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	osPlatform		: Integer;
	osVersion		: String;
	osArchitecture	: Integer;
	
begin
	osPlatform	:=	node.getOSPlatform(osVersion, osArchitecture);
epilog
	return (osPlatform.bitAnd(Node.OSUnix) &lt;&gt; 0);
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getUnixFlagServer" id="211ee39a-f467-44d5-a8ef-5f4547677d41">
