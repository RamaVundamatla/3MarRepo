<Schema name="PortTestSchema" id="c450ac6f-c240-408f-a4fe-638b44cd2587">
    <primaryLocale name="5129"/>
    <superschema name="PortSchema"/>
    <ConstantCategory name="ERR_Exceptions" id="f17c1f21-f0ca-45dd-91bd-df0b1a9bbd8b">
        <text>Testing for Loading Centrports External Error Messages with new XLAT_ structure
</text>
    </ConstantCategory>
    <Database name="PortTestSchemaDb" id="2e6e439d-0a9e-4d3d-8f59-37ac2715f932">
        <defaultFile name="porttesting"/>
        <DbFile name="porttesting" id="a1196098-430d-4510-a83d-be4d41116bf4"/>
    </Database>
    <GlobalConstant name="CMW_AnotherError" id="511c0a9c-a9c2-42d4-a11d-a6457a580be1">
        <category name="ERR_Exceptions"/>
        <constantUsages>
            <GlobalConstant name="ExtDev_BaseErrorNo"/>
        </constantUsages>
        <source>935066 + ExtDev_BaseErrorNo</source>
        <type name="Integer"/>
        <text>&lt;?xml version="1.0"?&gt;
&lt;ErrorMsg&gt;
&lt;LocaleMsg LocaleName="0000"&gt;
&lt;Msg&gt;Pack %1 cannot be moved from order %2 as it has already been packed.&lt;/Msg&gt;
&lt;ShortMsg&gt;&lt;/ShortMsg&gt;
&lt;/LocaleMsg&gt;
&lt;/ErrorMsg&gt;
</text>
    </GlobalConstant>
    <GlobalConstant name="CMW_NewError" id="969fb3c6-36d1-4743-986a-04fde3d40335">
        <category name="ERR_Exceptions"/>
        <constantUsages>
            <GlobalConstant name="ExtDev_BaseErrorNo"/>
        </constantUsages>
        <source>935033 + ExtDev_BaseErrorNo</source>
        <type name="Integer"/>
        <text>&lt;?xml version="1.0"?&gt;
&lt;ErrorMsg&gt;
&lt;LocaleMsg LocaleName="0000"&gt;
&lt;Msg&gt;This move cannot be deleted because it is already completed.&lt;/Msg&gt;
&lt;ShortMsg&gt;&lt;/ShortMsg&gt;
&lt;/LocaleMsg&gt;
&lt;/ErrorMsg&gt;
</text>
    </GlobalConstant>
</Schema>
