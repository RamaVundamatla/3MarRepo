    <JadeMethod name="validateForUpdate" id="bfce139c-10d0-401e-92be-6772f47757d9">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 December 2016	cnwndl1	Initial creation	TFS 3024 / 2370

*/

vars

	iter : Iterator;
	entRow : EntTableRow;
	hasColour : EntTableRow;
	hasColourList : EntTableRow;

begin

	iter := self.allVisibleSearchRows.createIterator;
	
	while iter.next( entRow ) do
		if entRow.name = ETRow_FilterColour then
			hasColour := entRow;
		elseif entRow.name = ETRow_FilterColourList then
			hasColourList := entRow;
		endif;
	endwhile;
	
	if hasColour &lt;&gt; null and hasColourList &lt;&gt; null then
		app.raiseCMException2(Only_select_items_mutual_exclu, hasColour.getRawHeadingValue, hasColourList.getRawHeadingValue, 'Colour rows', null);
	endif;

epilog

	delete iter;

end;</source>
    </JadeMethod>
</Class>
