    <JadeMethod name="doContextMenuSetup" id="20a43adf-0e55-4c97-b256-58a1e79e159e">
        <updating/>
        <source>doContextMenuSetup(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

	userObject : Object;
	cell : JadeTableCell;
	row : Integer;
	col : Integer;
	entTableRow : EntTableRow;
	enquiryLine : CM_MTPoolingEnquiryLine;
	allTisInArea : CM_TIArray;
	invalidObject : Boolean;

begin

	table.getCellFromPosition(x,y, row,col);
	table.clearAllSelected();
	if row &gt; table.fixedRows and row &lt;= table.rows then
		if col &gt; table.fixedColumns and col &lt;= table.columns then
			table.row := row;
			table.column := col;
			cell := table.accessCell( row, col );	
			if cell &lt;&gt; null then
				cell.selected := true;
				userObject := cell.itemObject;
				
				on Exception do app.handleDeletedObject( exception, userObject, invalidObject );
				
				self.doSelectDataCell();
				
				if invalidObject then
					return false;
				endif;
				
			endif;
		endif;
	endif;
	
	self.mnuSepOne.visible := false;
	self.mnuInspectObj.visible := false;
	self.mnuSepTwo.visible := false;
	self.mnuThreshold.visible := false;
	self.mnuShowRels.visible := false;
	self.mnuShowCargo.visible := false;
	self.mnuShowInArea.visible := false;
	
	on Exception do app.handleDeletedObject( exception, userObject, invalidObject );
	
	if userObject &lt;&gt; null then
	
		self.mnuInspectObj.userObject := userObject;
		self.mnuInspectObj.visible :=  app.isAllowedToInspect();
		self.mnuSepTwo.visible := app.isAllowedToInspect();
		
		if userObject.isKindOf( CM_MTThreshold ) then
			self.mnuThreshold.userObject := userObject;
			self.mnuThreshold.visible := app.getMyUser.canDo( self.myTerminal, PmAdmThresholdView);
		elseif userObject.isKindOf( CM_BulkReleaseSet ) then
			self.mnuShowRels.userObject := userObject;
			self.mnuShowRels.visible := app.getMyUser.canDo( self.myTerminal, PmGteMTReleaseView);
		elseif userObject.isKindOf( CM_TIArray ) then
			if not userObject.CM_TIArray.isEmpty then
				entTableRow := table.CM_DataTable.allTblDataEntRows[col];
				if entTableRow &lt;&gt; null then
					if entTableRow.name = ETRow_PreTrip
					or entTableRow.name = ETRow_Wash
					or entTableRow.name = ETRow_Repair
					then
						enquiryLine := table.accessRow( row ).itemObject.CM_MTPoolingEnquiryLine;
						allTisInArea := enquiryLine.getTisInAreaObject(entTableRow.name);
						if allTisInArea &lt;&gt; null and not allTisInArea.isEmpty then
							self.mnuShowInArea.userObject := allTisInArea;
							self.mnuShowInArea.visible := app.getMyUser.canDo( self.myTerminal, PmAdmCargoEnquiryView);
						endif;
					endif;
				endif;
				self.mnuShowCargo.userObject := userObject;
				self.mnuShowCargo.visible := app.getMyUser.canDo( self.myTerminal, PmAdmCargoEnquiryView);
			endif;
		else
		endif;
		
	endif;
	
	if invalidObject then
		self.mnuThreshold.visible := false;
		self.mnuShowRels.visible := false;
		self.mnuShowInArea.visible := false;
		self.mnuShowCargo.visible := false;
	endif;
	
	self.mnuSepOne.visible := self.mnuThreshold.visible or 	self.mnuShowRels.visible or self.mnuShowCargo.visible or self.mnuShowInArea.visible;
	
	self.mnuColumnOrganiser.visible := true;
	self.mnuShowExtra.visible := true;
	
	self.mnuShowExtra.checked := self.tblInfo.visible;
	

	return self.showContextMenu(mnuContext, table, conwin, mouse, x, y);
	

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDataDoubleClick" id="d1491e9a-3dc0-43e2-9bb2-37ffd6ffa209">
        <source>doDataDoubleClick( table: Table input );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

	cell : JadeTableCell;
	row : Integer;
	col : Integer;
	userObject : Object;
	entTableRow : EntTableRow;
	enquiryLine : CM_MTPoolingEnquiryLine;
	allTisInArea : CM_TIArray;
	invalidObject : Boolean;
	areaName : String;

begin

	row := table.row;
	col := table.column;

	if row &gt; table.fixedRows and row &lt;= table.rows then
		if col &gt; table.fixedColumns and col &lt;= table.columns then
			cell := table.accessCell( row, col );	
			if cell &lt;&gt; null then
				cell.selected := true;
				userObject := cell.itemObject;
			endif;
		endif;
	endif;
	
	if userObject = null then
		return;
	endif;

	
	on Exception do app.handleDeletedObject( exception, userObject, invalidObject );
	on Exception do app.handleDeletedObject( exception, allTisInArea, invalidObject );

	if userObject.isKindOf( CM_MTThreshold ) then
		if app.getMyUser.canDo( self.myTerminal, PmAdmThresholdView) then
			self.mnuThreshold.userObject := userObject;
			self.doMnuThresholdMaint( self.mnuThreshold );
		endif;
	elseif userObject.isKindOf( CM_BulkReleaseSet ) then
		if app.getMyUser.canDo( self.myTerminal, PmGteMTReleaseView) then
			self.mnuShowRels.userObject := userObject;
			self.doMnuRelaseReqsEnq( self.mnuShowRels );
		endif;
	elseif userObject.isKindOf( CM_TIArray ) then
		if not userObject.CM_TIArray.isEmpty then
			entTableRow := table.CM_DataTable.allTblDataEntRows[col];
			if entTableRow &lt;&gt; null then
				if entTableRow.name = ETRow_PreTrip
				or entTableRow.name = ETRow_Wash
				or entTableRow.name = ETRow_Repair
				then
					enquiryLine := table.accessRow( row ).itemObject.CM_MTPoolingEnquiryLine;
					allTisInArea := enquiryLine.getTisInAreaObject(entTableRow.name);
					if allTisInArea &lt;&gt; null and not allTisInArea.isEmpty then
						if app.getMyUser.canDo( self.myTerminal, PmAdmCargoEnquiryView) then
							areaName := entTableRow.getHeading(null, null, app.myCurrentLocale);
							if app.msgBox( app.getErrorString1(Only_show_cargo_in_task_area, areaName), areaName, MsgBox_Yes_No) = MsgBox_Return_Yes then
								self.mnuShowInArea.userObject := allTisInArea;
								self.doMnuCargoEnquiry( self.mnuShowInArea );
								return;
							endif;
						endif;
					endif;
				endif;
			endif;
			if app.getMyUser.canDo( self.myTerminal, PmAdmCargoEnquiryView) then
				self.mnuShowCargo.userObject := userObject;
				self.doMnuCargoEnquiry( self.mnuShowCargo );
			endif;
		endif;
	else
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMTPoolingQuery" id="7541bd4f-f378-4ab9-af84-e9714e3086c9">
        <updating/>
        <source>doMTPoolingQuery() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/06/2011	cnwndl1	Initial creation	Par 27731
14/04/2016	cnwdap1	PAR #37677 Clear the info table
03 May 2016	cnwns1	TFS 488 - Multi Timezone Support
05 Sep 2019	jlgdi1	46124 Pass in the sub terminal parameter on the following methods
					myMTThresholdAgent.processEmpties, processBulkReleases and processPreNotes
*/

vars
	mtPoolEnqLine : CM_MTPoolingEnquiryLine;
	str : String;
	ts : TimeStamp;
	systemFilterReceivalTS :TimeStamp;
	systemFilterReleaselTS :TimeStamp;
	endOfDay : Time;
	
begin
	self.mousePointer := Window.MousePointer_HourGlass;
	
	//03 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	ts := app.actualTimeServer;
	
	//set the search criteria.
	self.myFiltOperator := self.cmbOperator.listObject.CM_Operator;
	self.myFiltIsoGroup := self.cmbISOGroup.listObject.CM_ISOTypeGroup;
	self.myFiltGrade := self.cmbGrade.listObject.CM_MTGrade;
	self.myFiltSubTerminal := self.cmbSubTerminal.listObject.CM_SubTerminal;	// 46124
	
	//03 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	systemFilterReceivalTS.cnEcSetDateAndTime(self.txtReceivalDate.getDate,TimeEndOfDay);
	systemFilterReleaselTS.cnEcSetDateAndTime(self.txtReleaseDate.getDate,TimeEndOfDay);	
	self.myFiltReceivalDate := self.localToSystemTime(systemFilterReceivalTS).date();
	self.myFiltReleaseDate := self.localToSystemTime(systemFilterReleaselTS).date();
	self.myFiltBaseDate := ts.Date;
	
	//clear the results table
	self.tblData.rows := self.tblData.fixedRows;
	// clear the info table as well								// PAR #37677
	self.tblInfo.rows := self.tblInfo.fixedRows;				// PAR #37677
	
	//set up the query agent
	if self.myMTThresholdAgent = null then
		create self.myMTThresholdAgent transient;
	endif;
	self.myMTThresholdAgent.clear();
	self.myMTThresholdAgent.setBaseData(	self.myTerminal,	//_terminal : CM_Terminal;	
											self.myFiltOperator,	//_operator : CM_Operator;
											self.myFiltIsoGroup,	//_isoGroup : CM_ISOTypeGroup;
											self.myFiltGrade,	//_grade : CM_MTGrade;
											self.myFiltReceivalDate,	//_receivalDate : Date;
											self.myFiltReleaseDate	//_releaseDate : Date
											);
									
	self.myMTThresholdAgent.processEmpties(self.myFiltSubTerminal);
	self.myMTThresholdAgent.processBulkReleases(self.myFiltSubTerminal);
	self.myMTThresholdAgent.processPreNotes(self.myFiltSubTerminal);
	
	//populate the table.
	foreach mtPoolEnqLine in myMTThresholdAgent.allMTPoolingEnquiryLines do
		addTableData(mtPoolEnqLine);
	endforeach;
	
	self.tblData.colourRows(self.colorRow1, self.colorRow2);
	
	//03 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	lblLastUpdated.caption := app.getErrorString(Last_updated) &amp; " " &amp; self.systemToLocalTime(ts).asStringJMT();
	
epilog
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuCargoEnquiry" id="f74a46cb-2e96-42d4-b718-adb118cc3606">
        <source>doMnuCargoEnquiry( menuItem: MenuItem input );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

	objArray : ObjectArray;

begin

	create objArray transient;
	if menuItem.userObject &lt;&gt; null then
		if menuItem.userObject.isKindOf(CM_TIArray) then
			if not menuItem.userObject.CM_TIArray.isEmpty then
				 menuItem.userObject.CM_TIArray.copy( objArray );
			endif;
		endif;
	endif;
	
	if not objArray.isEmpty then	
		self.myAssistant.showCargoEnquiryForTIs(objArray.first.CM_TrackedItem, objArray, self.myMasterMenuAction, false);
	endif;
	
epilog

	delete objArray;

end;</source>
