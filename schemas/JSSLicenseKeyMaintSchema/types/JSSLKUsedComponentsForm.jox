    <JadeMethod name="cmbCustomer_click" id="b78363fc-1c97-4bac-b3bd-29e2711ae73a">
        <controlMethod name="ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCustomer_click(combobox: ComboBox input) updating;
// --------------------------------------------------------------------------------
// Created:		24 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	self.populateUsedProductComponents();
	self.selectUsedProductComponents();
	
	if cmbCustomer.listIndex &lt;&gt; JSS_NULL_INDEX then
		self.resynchObjectAndSetEdition(cmbCustomer.listObject);
	endif;
	
	self.doEnableControls();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbCustomer_displayEntry" id="afb83f30-89a9-46d6-99ce-2db5c1756493">
