        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateText" id="f350a7a1-76a8-4b1b-a4af-f70d9d9f81cb">
        <source>validateText(_textboxObj:TextBox; _text:String):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		03 August 2006 by cnwdad1
//
// Purpose:		Validates whether text is valid for a textbox control.
//
// Parameters:	_textboxObj - A reference to the textbox control.
//				_text - The text to set in the control.
//
// Returns:		True if the text is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if _text.length() &gt; _textboxObj.maxLength then
		return false;
	endif;
	
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_textboxObj" type="TextBox"/>
        <Parameter name="_text" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
