        <updating/>
        <source>mSortColumnDesc_click(menuItem: MenuItem input) updating;

begin
	transientTable.sortColumn[1] := transientTable.column;
	transientTable.sortAsc[1] := false;
	transientTable.sortColumn[2] := 0;
	transientTable.resort;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="moveColumn" id="1a6b9186-7dc1-45c1-842b-04d818eb441b">
        <updating/>
        <source>moveColumn(fromCol : Integer; toCol : Integer) updating;

vars
	booleanInstance				: Boolean;
	stringInstance				: String;
	integerInstance				: Integer;
begin
	stringInstance := transientTable.columnHeadingArray.removeAt(fromCol);
	transientTable.columnHeadingArray.insert(toCol, stringInstance);

	stringInstance := transientTable.columnAlignmentArray.removeAt(fromCol);
	transientTable.columnAlignmentArray.insert(toCol, stringInstance);

	stringInstance := transientTable.columnInputTypeArray.removeAt(fromCol);
	transientTable.columnInputTypeArray.insert(toCol, stringInstance);

	stringInstance := transientTable.columnVisibleArray.removeAt(fromCol);
	transientTable.columnVisibleArray.insert(toCol, stringInstance);

	booleanInstance := transientTable.columnPictureArray.removeAt(fromCol);
	transientTable.columnPictureArray.insert(toCol, booleanInstance);

	integerInstance := transientTable.columnLengthArray.removeAt(fromCol);
	transientTable.columnLengthArray.insert(toCol, integerInstance);

	integerInstance := transientTable.columnWidthArray.removeAt(fromCol);
	transientTable.columnWidthArray.insert(toCol, integerInstance);
end;</source>
        <Parameter name="fromCol" type="Integer"/>
        <Parameter name="toCol" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="resize" id="e6ef9b75-2a63-4807-8b40-c05861e2bdea">
        <controlMethod name="Form::resize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>resize() updating;

begin
	barLabel.width := self.clientWidth - (columnTable.left * 2);
	self.height := bCancel.top + 70;
end;</source>
    </JadeMethod>
    <JadeMethod name="saveTable" id="7f5e28e1-a49e-4ac1-82e6-6f1b354a3a15">
        <updating/>
        <source>saveTable() updating;

vars
	loopIndex					: Integer;
	maxIndex					: Integer;
begin
	maxIndex := transientTable.columnHeadingArray.size();
	loopIndex := 1;
	while loopIndex &lt;= maxIndex do
		transientTable.columnAlignmentArray.replace(loopIndex, transientTable.columnAlignmentArray[loopIndex] 	&amp; '\' &amp;
																headerAlignmentArray[loopIndex] 				&amp; '\' &amp;
																headerBoldArray[loopIndex].String				&amp; '\'
																);

//		transientTable.columnHeadingArray.replace(loopIndex, columnTable.getCellText(loopIndex + 1, 2));
//		transientTable.columnWidthArray.replace(loopIndex, columnTable.getCellText(loopIndex + 1, 3).Integer);
//		transientTable.columnAlignmentArray.replace(loopIndex, columnTable.getCellText(loopIndex + 1, 4));
//		transientTable.columnInputTypeArray.replace(loopIndex, columnTable.getCellText(loopIndex + 1, 5));

		loopIndex := loopIndex + 1;
	endwhile;
end;</source>
    </JadeMethod>
    <JadeMethod name="setAlignmentChecked" id="dbb61cda-c39a-4386-bbed-44391c6c29d3">
        <updating/>
        <source>setAlignmentChecked() updating;

begin
	mAlignDefault.checked	:= bAlignDefault.value;
	mAlignLeft.checked		:= bAlignLeft.value;
	mAlignCentre.checked	:= bAlignCentre.value;
	mAlignRight.checked		:= bAlignRight.value;
end;</source>
    </JadeMethod>
    <JadeMethod name="setAlignmentCheckedHeader" id="82397431-359a-41c0-8947-c1c0d9d38387">
        <updating/>
        <source>setAlignmentCheckedHeader() updating;

begin
	mAlignDefault.checked	:= bAlignDefaultH.value;
	mAlignLeft.checked		:= bAlignLeftH.value;
	mAlignCentre.checked	:= bAlignCentreH.value;
	mAlignRight.checked		:= bAlignRightH.value;
end;</source>
    </JadeMethod>
    <JadeMethod name="setColumnAttributes" id="9c5c93c4-e554-4d6b-924b-6e35b7c4617f">
        <updating/>
        <source>setColumnAttributes() updating;

vars
	col				: Integer;
begin
	col := columnTable.column;

	columnHeading.caption := columnTable.text;

	attributeTable.setCellText(1, 2, transientTable.columnVisibleArray[col]);
	attributeTable.setCellText(2, 2, transientTable.columnWidthArray[col].String);
	attributeTable.setCellText(3, 2, transientTable.columnHeight.String);
	attributeTable.setCellText(4, 2, transientTable.columnLengthArray[col].String);
	if transientTable.columnPictureArray[col] then
		attributeTable.setCellText(5, 2, '1 - True');
	else
		attributeTable.setCellText(5, 2, '0 - False');
	endif;

	inputControlArray[transientTable.columnInputTypeArray[col].Integer + 1].Button.value := true;
	alignControlArray[transientTable.columnAlignmentArray[col].Integer + 1].Button.value := true;
	alignControlHeaderArray[headerAlignmentArray[col].Integer + 1].Button.value := true;
	bFontBoldH.value := headerBoldArray[col];

	self.setInputTypeChecked();
	self.setAlignmentChecked();
end;</source>
    </JadeMethod>
    <JadeMethod name="setInputTypeChecked" id="d9b3c8dc-b654-4b9c-b0bc-b22c90f17351">
        <updating/>
        <source>setInputTypeChecked() updating;

begin
	mInputNone.checked			:= bInputNone.value;
	mInputCheckBox.checked		:= bInputCheckBox.value;
	mInputTextBox.checked		:= bInputTextBox.value;
	mInputComboBox.checked		:= bInputComboBox.value;
	mInputNumericBox.checked	:= bInputNumericBox.value;
end;</source>
    </JadeMethod>
</GUIClass>
