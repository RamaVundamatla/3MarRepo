    <JadeMethod name="hasTIs" id="c0c0f36a-5011-475d-a356-e4f00de4ce95">
        <source>hasTIs() : Boolean;
// ---------------------------------------------------------------------------
// Created:     28 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if (not self.allTrackedItems.isEmpty) or
	   (not self.allPlannedFutureMoves.isEmpty) or
	   (not self.allQueuedFutureMoves.isEmpty) then
	   	return true;
	endif;
	
	return false;
		
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasTIsOfMode" id="73fbf007-45af-4d89-8598-798250e4eb2e">
        <source>hasTIsOfMode(_mode : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:     28 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if _mode = REAL_MODE then
		if self.allTrackedItems.isEmpty then
			return false;
		else
			return true;
		endif;
	elseif _mode = QUEUE_MODE then
		if self.allQueuedFutureMoves.isEmpty then
			return false;
		else
			return true;
		endif;
	elseif _mode = PLANNING_MODE then
		if self.allPlannedFutureMoves.isEmpty then
			return false;
		else
			return true;
		endif;
	endif;
	
	return false;
	
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasTIsOfMode40" id="aa256091-b487-4c2f-9a7e-9eacd16e0358">
        <source>hasTIsOfMode40(_mode : Integer; _frontEnd : Boolean) : Boolean;
// ---------------------------------------------------------------------------
// Created:		March 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aTI : CM_TrackedItem;
begin

	if _mode = REAL_MODE then
		foreach aTI in self.allTrackedItems do
			// PAR 30022 if aTI.isAttributeTrue(TI_Attrib_IsForty) then
			if not aTI.isTwenty() then
				if _frontEnd then
					if (aTI.myPrimaryActualLocation = self) then
						return true;
					endif;
				else
					if (aTI.myPrimaryActualLocation &lt;&gt; self) then
						return true;
					endif;
				endif;
			endif;
		endforeach;
		return false;
	elseif _mode = QUEUE_MODE then
	elseif _mode = PLANNING_MODE then
	endif;
	
	return false;
	
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_frontEnd" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="identity" id="bafbb7c1-77d0-42f9-adfe-84787b39ee37">
