    <JadeMethod name="doHandleCalendarNote" id="71643f9f-4605-49f9-a3c5-9e46fd2b888f">
        <updating/>
        <source>doHandleCalendarNote( eventType: Integer; _calendar : CM_Calendar ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 March 2011	cnwndl1	Initial creation

*/

vars
	
	tmpStr : String;
	idx : Integer;
	selObj : CM_Object;
	doRefresh : Boolean;

begin

	if _calendar = null then
		return;
	endif;
	
	if eventType = Object_Create_Event then
		//its an add, might need it in the filter
		if self.myTerminal &lt;&gt; null then
			if not self.myTerminal.allCalendars.includes( _calendar ) then 
				//its new but not associated with our terminal.
				return;
			endif;
		endif;
		tmpStr := self.mulCalendar.displayEntry(_calendar);
		if tmpStr &lt;&gt; null then
			idx := self.mulCalendar.myAvailableListBox.addItem(tmpStr);
			self.mulCalendar.myAvailableListBox.itemObject[idx] := _calendar;
		endif;
		
		
	elseif eventType = Object_Update_Event then
		//its an update, might have had 'allTerminals' changed
		if self.myTerminal &lt;&gt; null then
			if not self.myTerminal.allCalendars.includes( _calendar ) then 
				//take it out if we are using it, cos it is no longer associated with our terminal
				idx := self.mulCalendar.mySelectedListBox.findObject(_calendar);
				if idx &gt; 0 then
					self.mulCalendar.mySelectedListBox.removeItem(idx);
				endif;
				idx := self.mulCalendar.myAvailableListBox.findObject(_calendar);
				if idx &gt; 0 then
					self.mulCalendar.myAvailableListBox.removeItem(idx);
					doRefresh := true;
				endif;
				if self.allSelectedCalendars.includes(_calendar) then
					app.msgBox( _calendar.description &amp; " is no longer associated with " &amp; self.myTerminal.code, app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
					self.allSelectedCalendars.clear();
					self.mulCalendar.getSelected(self.allSelectedCalendars);	
					self.doRefreshCalendar( false );
					return;
				elseif doRefresh then	// we were showing them all
					app.msgBox( _calendar.description &amp; " is no longer associated with " &amp; self.myTerminal.code, app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
					self.doRefreshCalendar( false );
					return;
				endif;
				
				
			elseif self.myTerminal.allCalendars.includes( _calendar ) then 
				//add it to available if not already showing in selected or available, cos its allowed for us now.
				idx := self.mulCalendar.mySelectedListBox.findObject(_calendar);
				if idx &gt; 0 then
					//it was already selected, no problem
					return;
				endif;
				idx := self.mulCalendar.myAvailableListBox.findObject(_calendar);
				if idx &gt; 0 then
					//it was already available, no problem
					return;
				endif;
				// it wasn't showing, make it available
				tmpStr := self.mulCalendar.displayEntry(_calendar);
				if tmpStr &lt;&gt; null then
					idx := self.mulCalendar.myAvailableListBox.addItem(tmpStr);
					self.mulCalendar.myAvailableListBox.itemObject[idx] := _calendar;
				endif;
			endif;
		endif;
		
	elseif eventType = Object_Delete_Event then
		//its a delete, make sure its not in the filter.
		idx := self.mulCalendar.mySelectedListBox.findObject(_calendar);
		if idx &gt; 0 then
			self.mulCalendar.mySelectedListBox.removeItem(idx);
		endif;
		idx := self.mulCalendar.myAvailableListBox.findObject(_calendar);
		if idx &gt; 0 then
			self.mulCalendar.myAvailableListBox.removeItem(idx);
		endif;
		
		if not self.allSelectedCalendars.isEmpty then
			foreach selObj in self.allSelectedCalendars do
				if selObj = _calendar then
					app.msgBox( "Refreshing the form, a calendar you were displaying has been deleted", app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
					self.allSelectedCalendars.clear();
					self.mulCalendar.getSelected(self.allSelectedCalendars);	
					self.doRefreshCalendar( false );
					return;
				endif;
			endforeach;
		else
			app.msgBox( "Refreshing the form, a calendar you were displaying has been deleted", app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);	
			self.doRefreshCalendar( false );
			return;
		endif;
		
	endif;
		
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="_calendar" type="CM_Calendar"/>
    </JadeMethod>
    <JadeMethod name="doHandleDayTypeNote" id="4f42cdf0-031e-40df-b45b-c6a392e18e9b">
        <updating/>
        <source>doHandleDayTypeNote( eventType: Integer; _dayType : CM_DayType ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 March 2011	cnwndl1	Initial creation

*/

vars
	
	tmpStr : String;
	idx : Integer;
	selObj : CM_Object;

begin

	if _dayType = null then
		return;
	endif;
	
	
	if eventType = Object_Create_Event then
		//its an add, might need it in the filter
		tmpStr := self.mulDayType.displayEntry(_dayType);
		if tmpStr &lt;&gt; null then
			idx := self.mulDayType.myAvailableListBox.addItem(tmpStr);
			self.mulDayType.myAvailableListBox.itemObject[idx] := _dayType;
		endif;
		
		
	elseif eventType = Object_Update_Event then
		//nothing to do here at the moment.
		
		
	elseif eventType = Object_Delete_Event then
		//its a delete, make sure its not in the filter.
		idx := self.mulDayType.mySelectedListBox.findObject(_dayType);
		if idx &gt; 0 then
			self.mulDayType.mySelectedListBox.removeItem(idx);
		endif;
		idx := self.mulDayType.myAvailableListBox.findObject(_dayType);
		if idx &gt; 0 then
			self.mulDayType.myAvailableListBox.removeItem(idx);
		endif;
		
		if not self.allSelectedDayTypes.isEmpty then
			foreach selObj in self.allSelectedDayTypes do
				if selObj = _dayType then
					app.msgBox( "Refreshing the form, a day type you were displaying has been deleted", app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
					self.allSelectedDayTypes.clear();
					self.mulDayType.getSelected(self.allSelectedDayTypes);	
					self.doRefreshCalendar( false );
					return;
				endif;
			endforeach;
		else
			app.msgBox( "Refreshing the form, a day type you were displaying has been deleted", app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);	
			self.doRefreshCalendar( false );
			return;
		endif;
		
	endif;
	
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="_dayType" type="CM_DayType"/>
    </JadeMethod>
    <JadeMethod name="doHandleNotification" id="0d81d7db-2469-46ce-bc04-93586dd1f919">
        <updating/>
        <source>doHandleNotification( eventType: Integer; theObject: Object ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 December 2010	cnwndl1	Initial creation

*/

vars

	calendarDate : CM_CalendarDate;
	calendar : CM_Calendar;
	dayType : CM_DayType;
	tmpStr : String;
	idx : Integer;
	selObj : CM_Object;

begin

	if theObject = null then
		return;
	endif;
	
	if theObject.isKindOf( CM_Calendar ) then
		calendar := theObject.CM_Calendar;
		self.doHandleCalendarNote( eventType, calendar );
		
	elseif theObject.isKindOf( CM_DayType ) then
		dayType := theObject.CM_DayType;
		self.doHandleDayTypeNote( eventType, dayType );
		
	elseif theObject.isKindOf( CM_CalendarDate ) then
		if self.allCalendarDatesDisplayed.includes( theObject.CM_CalendarDate ) then
			// must be an update or a delete of an existing object.
			self.doRefreshCalendar( false );
			return;
			
		else
			if eventType = Object_Create_Event then
				//its an add.  Do we care??
				calendarDate := theObject.CM_CalendarDate;
				
				if not self.allSelectedCalendars.isEmpty then
					// we are only displaying a use selected subset o fcalendars
					if not self.allSelectedCalendars.includes( calendarDate.myCalendar ) then
						// not for us
						return;
					endif;
					
				elseif self.myTerminal &lt;&gt; null then
					if not self.myTerminal.allCalendars.includes( calendarDate.myCalendar ) then
						// not for us
						return;
					endif;
					
				endif;
				
				if not self.allSelectedDayTypes.isEmpty then
					// we are only displaying a use selected subset of day types
					if not self.allSelectedDayTypes.includes( calendarDate.myCalendar.myDayType ) then
						// not for us
						return;
					endif;
				endif;
				
				//OK, it seems we do care
				self.doRefreshCalendar( false );
				return;
				
			endif;
			
		endif;
	endif;


epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doMaintainDay" id="e807d4dc-8908-486c-8911-3ad13e4ff1ff">
        <source>doMaintainDay();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 November 2010	cnwndl1	Initial creation
// 23 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	form : CMUI_CalendarDateDayMaintForm;
	date : Date;
	timeStampSystem : TimeStamp;
begin

	if not app.getMyUser.canDo(self.myTerminal, PmAdmCalTermMaint) then
		return;
	endif;

	date := self.getDateFromTable();
	if not date.isValid then //in theory can't happen...
		return;
	endif;
	timeStampSystem.cnEcSetDateAndTime(date,TimeStartOfDay);// 23 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	date := self.systemToLocalTime(timeStampSystem).date();// 23 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	form := app.getForm(CMUI_CalendarDateDayMaintForm.name).CMUI_CalendarDateDayMaintForm;
	form := app.loadForm(CMUI_CalendarDateDayMaintForm, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_CalendarDateDayMaintForm;
	
	form.setFilterData( self.allSelectedCalendars, self.allSelectedDayTypes, date );

	form.show;

epilog

end;</source>
    </JadeMethod>
