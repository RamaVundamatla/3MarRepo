    <JadeMethod name="btnDone_click" id="36018cf1-7e0e-4c97-bd02-00756981c561">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDone_click(_btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	ts: TimeStamp;
	i: Integer;
	secBackupPathChanged: Boolean; //set if the path on sec db is changed 
begin
	if not self.valDate then
		return;
	endif;
	if not self.valTime then
		return;
	endif;
	if not self.valSplits then
		return;
	endif;
	if not self.validPaths then
		return;
	endif;

	beginTransaction;
	if self.mySchedule = null then
		create self.mySchedule;
	endif;
	// Set the modified/created values.
	self.mySchedule.setBooleans(self.chkVerify.value, self.chkCompress.value, self.chkOverwrite.value, self.chkQuiesce.value, self.chkExclude.value);
	self.mySchedule.setNumSplits(self.tbxSplits.text.Integer);
	ts.setDate(self.tbxDate.text.Date);
	ts.setTime(self.tbxTime.text.Time);
	self.mySchedule.setStartTS(ts);
	self.mySchedule.setRecur(self.cbxRecur.text);
	self.mySchedule.setMyRoot(app.myServerAppObject);

	// Set the split paths
	secBackupPathChanged := false;
	foreach i in 1 to 9 do
		if i &gt; self.mySchedule.numSplits then
			break;
		endif;
		if app.isSDSSecondaryBackup then
			self.mySchedule.setSplitSecPath(i, self.getControlWithName("tbxPath"&amp;i.String).TextBox.text);
			if self.mySchedule.splitPaths.size &lt; i then
				self.mySchedule.setSplitPath(i, ' ');
				secBackupPathChanged := true;
			endif;
		else
			self.mySchedule.setSplitPath(i, self.getControlWithName("tbxPath"&amp;i.String).TextBox.text);
			if self.mySchedule.splitSecPaths.size &lt; i then
				self.mySchedule.setSplitSecPath(i, ' ');
			endif;
		endif;
	endforeach;
	commitTransaction;
	if secBackupPathChanged then
		//force the change to be transferred to the secondary.
		app.myDBA.closeCurrentJournal;
	endif;

	self.unloadForm;
end;</source>
        <Parameter name="_btn" type="Button" usage="input"/>
    </JadeMethod>
