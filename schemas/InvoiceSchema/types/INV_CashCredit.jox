    <JadeMethod name="btnSave_click" id="a5a5e5ad-53a8-4687-9017-4fee9a7362b4">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSave_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 July 2012	cnwndl1	Initial creation
26 Jul 2019	jlgsl4	TFS 44274 - Cash Credit
16 Oct 2019 cnwma1 ChangeRequest 46984: JMT - Refactor Cash Credit UI and Tax
*/

vars
	table			  : CM_DataTable;
begin
	table := self.tblCharges;
	
	if self.creditTotal &lt;= 0 then
		return;
	endif;

	if not self.doValidate() then
		return;
	endif;
	
	if doSave() then
		self.unloadForm();
		self.setDefaultCargoDebtorDetails();
	endif;

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
