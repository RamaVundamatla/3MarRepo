    <JadeMethod name="getVoyageOpsCounts" id="095f3f34-eb78-4d45-86d5-55971b6c8516">
        <executionLocation>server</executionLocation>
        <source>getVoyageOpsCounts(_dict: CM_TrackedItemDicts; _baseCount, _tiCount: Integer output; _weight, _freightTons: Decimal output) serverExecution;
/*

Purpose:			
	Performance improvements.
Parameters:			

Return Value:		

Date		Who		Reason
17 January 2023	navsp1	Initial creation - TFS 56054.

*/

vars
	ti			:CM_TrackedItem;
	tiDict		:CM_TrackedItemDicts;
	baseAllCount:Integer;
	tiCount		:Integer;
	weight		:Decimal[18,4];
	freightTons	:Decimal[14,4];
begin
	tiDict := _dict;
	baseAllCount := tiDict.size;
	foreach ti in tiDict do
		if ti.isChild then
			baseAllCount := baseAllCount - 1;
			continue;
		endif;
		tiCount		  := tiCount + ti.totalQuantity;
		weight		  := weight + ti.totalWeight;
		freightTons   := freightTons + ti.freightTons;
	endforeach;
	_baseCount		:= baseAllCount;
	_tiCount		:= tiCount;
	_weight			:= weight;
	_freightTons	:= freightTons;
end;</source>
        <Parameter name="_dict" type="CM_TrackedItemDicts"/>
        <Parameter name="_baseCount" type="Integer" usage="output"/>
        <Parameter name="_tiCount" type="Integer" usage="output"/>
        <Parameter name="_weight" type="Decimal" usage="output"/>
        <Parameter name="_freightTons" type="Decimal" usage="output"/>
    </JadeMethod>
