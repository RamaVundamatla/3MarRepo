    </JadeMethod>
    <JadeMethod name="btnStop_click" id="3d4a13c7-fadc-4133-8d80-6cb849cdc780">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnStop_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		18 September 2002 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	
	self.stopBackgroundCopy();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doEnableControls" id="c8c763d3-d92a-4bd5-ae96-139560179ce9">
        <source>doEnableControls() protected;
// --------------------------------------------------------------------------------
// Created:		18 September 2002 by cnwdad1
//
// Purpose:		Enables/Disables the Stop button according to whether a Background
//				Copy object has been selected in the table.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theTable	: Table;
	rowPointer	: Integer;
	
begin
	theTable	:=	tblCopies;
	rowPointer	:=	theTable.row;
	
	if rowPointer &gt; theTable.fixedRows and rowPointer &lt;= theTable.rows then
		btnStop.enabled	:=	true;
	else
		btnStop.enabled	:=	false;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormInitialize" id="ff49713d-a4eb-4cbb-bfd3-8dc793559565">
        <updating/>
        <source>doFormInitialize() updating, protected;
// --------------------------------------------------------------------------------
// Created:		17 September 2002 by cnwdad1
//
// Purpose:		The standard JSS CoreSchema form initialization event method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	
	self.initializeTable();
	self.populateTable();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="5a26e264-30fa-4124-8bdd-8ba7197260e5">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		18 September 2002 by cnwdad1
//
// Purpose:		The standard JSS CoreSchema form load event method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	
	self.aMyRoot	:=	JSSFMRoot.firstInstance();
	
	beginClassNotification(JSSFMBackgroundCopy, false, Object_Create_Event, Response_Continuous, 0);
	beginClassNotification(JSSFMBackgroundCopy, false, Object_Delete_Event, Response_Continuous, 0);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormUnload" id="f3e1b5b9-58b1-4dc8-acf8-8f747f53ebaa">
        <updating/>
        <source>doFormUnload() updating, protected;
// --------------------------------------------------------------------------------
// Created:		18 September 2002 by cnwdad1
//
// Purpose:		The standard JSS CoreSchema form unload event method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	endNotificationForSubscriber(self);
	
	if self.aMyBrowserForm &lt;&gt; null then
		// There will not be a reference to a File Browser form if the Monitor was
		// started directly from the File Manager public interface.
		self.aMyBrowserForm.clearMonitorForm();
	endif;
	
	self.aMyServiceManager.setMonitorForm(null);
	
	inheritMethod();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initializeTable" id="01daf883-57b9-4c39-b183-4d5871e588f4">
        <source>initializeTable() protected;
// --------------------------------------------------------------------------------
// Created:		17 September 2002 by cnwdad1
//
// Purpose:		Initializes the table of Background Copy objects.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theTable	: Table;
	
begin
	theTable			:=	tblCopies;
	theTable.rows		:=	1;
	theTable.selectMode	:=	Table.SelectMode_CurrentRow;
	theTable.partialTextIndication	:=	true;
	theTable.setCellText(1, 1, "Computer" &amp; Tab &amp; "From" &amp; Tab &amp; "To" &amp; Tab &amp; "% Done");
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateTable" id="45fb6104-f57e-4eab-86de-eda154e63992">
        <source>populateTable() protected;
// --------------------------------------------------------------------------------
// Created:		18 September 2002 by cnwdad1
//
// Purpose:		Populates the table with a row for each Background Copy object.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theTable	: Table;
	theCopy		: JSSFMBackgroundCopy;
	rowPointer	: Integer;
	
begin
	theTable	:=	tblCopies;
	
	foreach theCopy in self.aMyRoot.allBackgroundCopies do
		rowPointer	:=	theTable.addItem(theCopy.getTableDisplay());
		theTable.accessRow(rowPointer).itemObject	:=	theCopy;
		
		beginNotification(theCopy, JSSFMBackgroundCopy.EVENT_PROGRESS, Response_Continuous, 0);
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="refreshProgress" id="7c15ce7d-86f4-4eb6-b8ac-4ef27de67fd8">
        <source>refreshProgress(pProgressInfo:String) protected;
// --------------------------------------------------------------------------------
// Created:		18 September 2002 by cnwdad1
//
// Purpose:		Refreshes the progress of a Background Copy.
//
// Parameters:	pProgressInfo - Broadcast by the progress notification, it contains
//					the OID of the Background Copy object, and the percent done
//					(as an integer).  The string is formatted as: &lt;OID&gt;|&lt;integer&gt;
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	separatorPos	: Integer;
	theCopy			: JSSFMBackgroundCopy;
	percentDone		: String;
	rowPointer		: Integer;
	theTable		: Table;
	
begin
	separatorPos	:=	pProgressInfo.pos("|", 1);
	
	if separatorPos &gt; 0 then
		theCopy		:=	pProgressInfo[1:(separatorPos-1)].asOid().JSSFMBackgroundCopy;
		
		if theCopy &lt;&gt; null then
			theTable	:=	tblCopies;
			
			if theTable.accessSheet(1).findRowObject(theCopy, rowPointer) then
				percentDone	:=	pProgressInfo[(separatorPos + 1):end];
				theTable.setCellText(rowPointer, 1, theCopy.getTableDisplay &amp; Tab &amp; percentDone &amp; "%");
			endif;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pProgressInfo" type="String"/>
    </JadeMethod>
    <JadeMethod name="resize" id="859ef442-ae73-49cd-a800-c24ee1d5095c">
        <controlMethod name="Form::resize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>resize() updating;
// --------------------------------------------------------------------------------
// Created:		17 September 2002 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	btnClose.move((self.width - btnClose.width - 18), (self.height - btnClose.height - 36), btnClose.width, btnClose.height);
	btnStop.move((btnClose.left - btnStop.width - 3), btnClose.top, btnStop.width, btnStop.height);
	tblCopies.move(tblCopies.left, tblCopies.top, (self.width - tblCopies.left - 18), (self.height - tblCopies.top - 67));
end;</source>
    </JadeMethod>
    <JadeMethod name="setBrowserForm" id="fff7894c-b57f-44ee-b30b-dfd89fcbb8fd">
        <updating/>
        <source>setBrowserForm(pTheForm:JSSFMFileBrowserForm) updating;
// --------------------------------------------------------------------------------
// Created:		20 September 2002 by cnwdad1
//
// Purpose:		Updates a reference to the File Browser form so that when this form
//				unloads itself we can clear its reference to this form.
//
// Parameters:	pTheForm - A reference to the File Browser form.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aMyBrowserForm	:=	pTheForm;
end;</source>
        <Parameter name="pTheForm" type="JSSFMFileBrowserForm"/>
    </JadeMethod>
    <JadeMethod name="setMdiChild" id="3e6873bd-2e32-4280-b984-d6f8f9c88755">
        <updating/>
        <source>setMdiChild(pMdiChildFlag:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		22 September 2002 by cnwdad1
//
// Purpose:		Sets the receiver's MDI Child flag.
//
// Parameters:	pMdiChildFlag - This will be the value of a Form class constant for
//					the Form.mdiChild property.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.mdiChild	:=	pMdiChildFlag;
end;</source>
        <Parameter name="pMdiChildFlag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="stopBackgroundCopy" id="f46d3adc-c469-4f95-9ff1-cd61074922cc">
        <source>stopBackgroundCopy() protected;
// --------------------------------------------------------------------------------
// Created:		18 September 2002 by cnwdad1
//
// Purpose:		Sends a notification to the selected Background Copy object to stop
//				copying the files/directories.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theCopy		: JSSFMBackgroundCopy;
	theTable	: Table;
	rowPointer	: Integer;
	
begin
	theTable	:=	tblCopies;
	rowPointer	:=	theTable.row;
	
	if rowPointer &gt; theTable.fixedRows and rowPointer &lt;= theTable.rows then
		theCopy	:=	theTable.accessRow(rowPointer).itemObject.JSSFMBackgroundCopy;
		
		if theCopy &lt;&gt; null then
			theCopy.causeEvent(JSSFMBackgroundCopy.EVENT_STOP_COPY, true, null);
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="da2af02b-4d03-4d1c-a872-0e6f844125c8">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		18 September 2002 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theCopy		: JSSFMBackgroundCopy;
	theLastCopy	: JSSFMBackgroundCopy;
	theRoot		: JSSFMRoot;
	theTable	: Table;
	rowPointer	: Integer;
	lastRow		: Integer;
	
begin
	theRoot		:=	self.aMyRoot;
	theTable	:=	tblCopies;
	
	if eventType = Object_Create_Event then
		foreach theCopy in theRoot.allBackgroundCopies do
			if not theTable.accessSheet(1).findRowObject(theCopy, rowPointer) then
				if lastRow &gt; theTable.fixedRows then
					rowPointer	:=	lastRow;
				else
					rowPointer	:=	theTable.fixedRows + 1;
				endif;
				
				theTable.addItemAt(theCopy.getTableDisplay(), rowPointer);
				theTable.accessRow(rowPointer).itemObject	:=	theCopy;
				beginNotification(theCopy, JSSFMBackgroundCopy.EVENT_PROGRESS, Response_Continuous, 0);
				
				break;
			endif;
			
			theLastCopy	:=	theCopy;
			lastRow		:=	rowPointer;
		endforeach;
		
	elseif eventType = Object_Delete_Event then
		self.initializeTable();
		self.populateTable();
		
	endif;
	
	self.doEnableControls();
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblCopies_click" id="43cb4a61-c661-4189-8e93-5b6f2b59e3e1">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCopies_click(table: Table input) updating;
// --------------------------------------------------------------------------------
// Created:		18 September 2002 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.doEnableControls();
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="0099af54-54d0-48d8-aabf-e28dd59ae352">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// --------------------------------------------------------------------------------
// Created:		18 September 2002 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if eventType = JSSFMBackgroundCopy.EVENT_PROGRESS then
		self.refreshProgress(userInfo.String);
	endif;
	
	self.doEnableControls();
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
