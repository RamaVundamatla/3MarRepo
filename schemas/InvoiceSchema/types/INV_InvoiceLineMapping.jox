    <JadeMethod name="doExportMappings" id="e8c016c7-d7ac-4011-856a-19f8a04df117">
        <source>doExportMappings();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 March 2023	navmk20	Bug 56954: FR | 53978 - EUP - Invoicing - Configuration Enhancements - User Story 050 issues

*/
vars
	cmifInvoiceLineMapping		: CMIF_InvoiceLineMapping;
	exportFile					: File;
	fileSave					: CMDFileSave;
	cmifMonitor					: CMIF_Monitor;
	selectedInvLineTypes		: CM_InvLineDescByNarrDupsADict;
	selectedDebtors				: CM_DebtorNodeByNameDict;
	bank						: CM_Bank;
	exportPath					: String;	
	
begin
	bank := self.cmbBank.listObject.CM_Bank;
	
	if bank = null then
		bank := self.myCurrentBank;
	endif;
	
	if self.myCurrentBank = null then
		app.msgBox(app.getErrorString(Bank_selected), app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	create fileSave transient;
	fileSave.dialogTitle := app.getErrorString(INV_InvLineMappingDesc);
	fileSave.resetCurrentPath := true;
	exportPath := "%MiscDir%\"&amp; app.getErrorString(INV_InvLineMappingDesc) &amp; "\";
	fileSave.initDir := self.getExportFileNameBase(exportPath);
	fileSave.fileName := self.getExportFileName(app.actualTimeAppServer,CSV_Filetype);
	
	if fileSave.open = 0 then
		create exportFile transient;
		
		if fileSave.fileName.toUpper().pos(".CSV",1) = 0  // 20 March 2023	navmk20	Bug 56954, No CSV
		and fileSave.fileName.pos(".",1) = 0 then // 20 March 2023	navmk20	Bug 56954, no suffix
			exportFile.fileName := fileSave.fileName &amp; ".csv"; // 20 March 2023	navmk20	Bug 56954
		else // 20 March 2023	navmk20	Bug 56954
			exportFile.fileName := fileSave.fileName;
		endif;
		exportFile.mode := File.Mode_Output;

		if (not exportFile.tryOpen) then
			app.raiseCMException1(FileUnavailable, exportFile.fileName, null, null);	
		endif;
	endif;
	
	if exportFile = null then
		return;
	endif;
	
	self.initModalDialog();
	self.lblModalMessage.caption := Cr &amp; (app.getErrorString(Exporting) &amp; ' ' &amp; app.getErrorString(INV_InvLineMappingDesc));
	
	create cmifMonitor transient;
	cmifMonitor.myParent := self;
	
	if cmifMonitor &lt;&gt; null then
		cmifMonitor.updateProgress(app.getErrorString(Writing_export_file), 100, 0);
	endif;
	
	self.frmModalDialog.visible := true;
	self.doWindowEvents(2);
	if self.frmModalDialog.visible then
		self.frmModalDialog.doWindowEvents(2);
	endif;
	
	create selectedDebtors transient;
	self.mulDebtors.getSelected(selectedDebtors); 
	
	create selectedInvLineTypes transient;
	self.mulInvLineTypes.getSelected(selectedInvLineTypes);
	
	create cmifInvoiceLineMapping transient;
	
	cmifInvoiceLineMapping.doExtractQueriedMappingCSVFile(exportFile, bank, selectedDebtors, selectedInvLineTypes, cmifMonitor);
	
epilog
	app.mousePointer := MP_DEFAULT;
	delete cmifInvoiceLineMapping;
	delete exportFile;
	delete fileSave;
	delete cmifMonitor;
	delete selectedDebtors;
	delete selectedInvLineTypes;
	self.frmModalDialog.visible := false;
end;</source>
    </JadeMethod>
    <JadeMethod name="doImportMappings" id="265721d1-da89-4c0c-bcaa-3912475eafbe">
        <updating/>
        <source>doImportMappings() protected, updating;
/*

Purpose:			Used to import invoice line type mappings for debtors and invoice types

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
20 March 2023	navmk20	Bug 56954
*/

vars
	impFile 		: File;
	fileGet 		: CMDFileOpen;
	cmifMonitor		: CMIF_Monitor;
	warningsResult	: Integer;
	
begin
	create impFile transient;
	impFile.kind := File.Kind_Unknown_Text;
	
	if impFile = null then
		app.raiseUnexpectedProgramError(class.name, method.name, " file is null - create file before calling ");
	endif;
	
	create fileGet transient;
	fileGet.filter 		:= '.csv|*.csv';
	fileGet.fileName 	:= '';
	fileGet.initDir 	:= "C:\";
	
	if fileGet.open = 0 then
		impFile.fileName := fileGet.fileName;
	endif;
	
	if impFile.fileName = null then
		return;
	endif;
	
	self.initModalDialog();
	self.lblModalMessage.caption := Cr &amp; (app.getErrorString(Importing) &amp; ' ' &amp; app.getErrorString(INV_InvLineMappingDesc));
	
	if app.myPassport.myCMIFMonitor = null then
		create cmifMonitor transient;
		cmifMonitor.myParent := self;
		//cmifMonitor.callBackMethodName := "updateProgress";
		app.myPassport.setMyCMIFMonitor(cmifMonitor);
		
	endif;
	
	if cmifMonitor &lt;&gt; null then
		cmifMonitor.updateProgress(app.getErrorString(Reading_import_file), 100, 0);
		
	endif;
	
	self.frmModalDialog.visible := true;
	self.doWindowEvents(2);
	
	if self.frmModalDialog.visible then
		self.frmModalDialog.doWindowEvents(2);
	endif;
	
	while true do
		app.myTrxCA.trxImportInvLnMappingFromFile(impFile, self.myCurrentBank, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			break;
		endif;
		
		warningsResult := app.showErrorWarningDialog(app.getErrorString(Invoice_line_type_narra), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
		
		if app.myPassport.noErrors and
		   warningsResult = IDOK then
			// there must have just been warnings that the user has acknoledged so ..
			app.myPassport.warningsAcknowledged	:= true;
			continue;
		endif;
		
		break;
		
	endwhile;
	
	self.doQuery();
	
epilog
	delete impFile;
	self.frmModalDialog.visible := false;
	delete cmifMonitor;
	delete fileGet;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
