    <JadeMethod name="dataDumpBuildOIDValue" id="c81e21a8-9a5c-4286-abb4-f75bb3efd646">
        <updating/>
        <source>dataDumpBuildOIDValue(_oidFormat : Integer; _o : Object) : Any updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
26 April 2010	conkc1	Initial creation

*/
vars

	columnString    : String;
	columnBinary    : Binary[6]; //02/09/2010 cnwdz2 par25621
    cnt : Integer;
begin
	//
	//  Ensure that null references send null values to SQL
	//
	if _o = null then
		return null;
	endif;
	
	if _oidFormat = CM_DataDumpExtractDef.OIDFormatHex then
		columnBinary[1:2] := self.getClassNumberForObject(_o).asBinary(2); //02/09/2010 cnwdz2 par25621
		columnBinary[3:4] := self.getInstanceIdForObject(_o).Integer.asBinary(4); //02/09/2010 cnwdz2 par25621
		return  columnBinary;

	elseif _oidFormat = CM_DataDumpExtractDef.OIDFormatString then
		columnString := self.getClassNumberForObject(_o).String;
		columnString := columnString &amp; "." &amp; self.getInstanceIdForObject(_o).String;
		return columnString;

	elseif _oidFormat = CM_DataDumpExtractDef.OIDFormatIntegers then
		return self.getClassNumberForObject(_o);
	endif;

epilog

end;</source>
        <Parameter name="_oidFormat" type="Integer"/>
        <Parameter name="_o" type="Object"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="dataDumpInstall" id="ad2cb100-ccae-48c8-bc50-ef7631965b2f">
        <source>dataDumpInstall();
// rs may 2005 to run any datadump script as needed
vars
	agent : CM_DataDumpMaintenanceAgent;
	file : File; //add application file for Jari
	fileMessage : String;
	userExitCode: Integer;
begin
	
	userExitCode := 63;
	app.initialize();
	create file transient;
	file.mode := File.Mode_Output;	// 4/3/16 cnwmp6 PAR 36286 unicode version
	file.fileName := app.myCnCntrl.logPath&amp;"\app_upgrade.log";
	if file.isAvailable then
		file.purge;
	endif;
	fileMessage := "UpgradeError";

	create agent transient;
	agent.maintainDataDumpClasses();
	agent.maintainDataDumpFeatureUpdate();	//PAR19114 DSS speed up cnwrs1 apr 2009
	agent.maintainDataDumpDefStoredProcs(); //par 32645 set flags to rebuild stored procs on next execution	
	if app.myPassport.trxCompletedOK then	
		app.writeStatement("End dataDumpInstall");	
		userExitCode := 0;	
		fileMessage := "completedOK";
	endif;
	file.writeLine(fileMessage);
	///////////////////////////////////////
epilog
	file.close;
	delete file;
	delete agent;
	beginTransaction;
	node.userExitCode := userExitCode;
	commitTransaction;
	terminate;
end;</source>
    </JadeMethod>
    <JadeMethod name="dataDumpUpdateTITransactions" id="f88b1f70-ac21-4d79-a391-ca26898b0bc9">
        <source>dataDumpUpdateTITransactions();

// 05/03/2015	cnwmh5	Transient Leak

vars
	tr : CM_TITransaction;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	startDate, endDate : Date;
	number : Integer;
	iter : Iterator;
	form : CMS_Modal;
	txtStartDate, txtEndDate : JadeEditMask;
	label1, label2, label3 : Label;
	terminal : CM_Terminal;
	str : String;
begin
	app.initialize;
	create form transient;
	form.caption:= "Set Transactions to start and end from.";
	create label1 transient;
	label1.caption := "Start date:=";
	label1.parent := form;
	label1.transparent := true;
	form.addControl(label1);
	label1.move(5, 1, 200, label1.height);
	create txtStartDate transient;
	txtStartDate.parent := form;
	txtStartDate.mask := "dd/MM/yyyy";
	txtStartDate.visible := true;
	txtStartDate.tabIndex := 0;
	form.addControl(txtStartDate);
	txtStartDate.move(label1.width+20, 1, txtStartDate.width, txtStartDate.height);
	create label2 transient;
	label2.caption := "End date:=";
	label2.parent := form;
	label2.transparent := true;
	form.addControl(label2);
	label2.move(5, label1.height + 10, 200, label2.height);
	create txtEndDate transient;
	txtEndDate.parent := form;
	txtEndDate.mask := "dd/MM/yyyy";
	txtEndDate.visible := true;
	txtEndDate.tabIndex := 1;
	form.addControl(txtEndDate);
	txtEndDate.move(label1.width+20, label1.height + 10, txtEndDate.width, txtEndDate.height);
	create label3 transient;
	label3.caption := "First up go from say 01/06/2013 to 31/06/2013, second time run from 01/07/2013 to 31/07/2013 etc";
	label3.wordWrap := true;
	label3.parent := form;
	label3.transparent := true;
	form.addControl(label3);
	label3.move(10, label2.top + 50, 200, 50);
	txtStartDate.setFocus();
	form.showModal();
	startDate := txtStartDate.text.Date;
	endDate := txtEndDate.text.Date;
	if (not startDate.isValid()) or (not endDate.isValid()) or (startDate &gt; endDate) then
		app.msgBox("Start Date ="&amp;startDate.String&amp;' End Date ='&amp;endDate.String ,"Error Invalid Date",0);
		return;
	endif;
	startDateTime.setDate(startDate);
	startDateTime.setTime("0.0.0.0".Time);
	endDateTime.setDate(endDate);
	endDateTime.setTime("23.59.59.999".Time);
	foreach terminal in app.myRoot.allTerminals do 
		number := 0;
		delete iter;
		iter := terminal.allTITransactions.createIterator;
		terminal.allTITransactions.startKeyGeq(startDateTime, 0, iter);
		while iter.next(tr) do
			if tr.dateTime &gt; endDateTime then
				break;
			endif;
			number := number + 1;
			beginTransaction;
			//tr.updateEdition();
			app.myTrxUA.updateObjectEdition(tr);
			commitTransaction;
		endwhile;
		str := str &amp;"Terminal "&amp;terminal.code&amp;' '&amp;(number).String&amp;CrLf;
	endforeach;
	app.msgBox(str ," Warning.", 0);
epilog
	delete txtStartDate;
	delete txtEndDate;
	delete label1;
	delete label2;
	delete label3;
	delete form;
	delete iter;
end;</source>
    </JadeMethod>
