<Class name="CMUI_IconFile" id="0d829cbc-c8fc-4676-91f6-2b6800add935">
    <superclass name="CMUI_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmui"/>
    <ExplicitInverseRef name="allDisabledToolbarIcons" id="3cabff45-3869-49dc-a865-e12bddc2a121">
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <type name="CMUI_ToolbarIconSet"/>
        <Inverse name="CMUI_ToolbarIcon::myDisabledIconFile"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="allEnabledToolbarIcons" id="29e7a6cd-12b8-45c8-9410-c7f9ea14e7fe">
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <type name="CMUI_ToolbarIconSet"/>
        <Inverse name="CMUI_ToolbarIcon::myEnabledIconFile"/>
    </ExplicitInverseRef>
    <PrimAttribute name="icon" id="8212a995-379d-4702-8eb4-debeb33e20ff">
        <type name="Binary"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="keybinary" id="b2ba203e-5f89-4fc6-a459-c75b8951092e">
        <length>500</length>
        <embedded/>
        <type name="Binary"/>
    </PrimAttribute>
    <PrimAttribute name="keyname" id="040b79b1-21c7-4a8c-bd79-19b954862c06">
        <length>201</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myRoot" id="db2fd9ff-5a44-49ca-a263-29ab464d7784">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CMUI_Root"/>
        <Inverse name="CMUI_Root::allIconFilesByName"/>
        <Inverse name="CMUI_Root::allIconFilesByBinary"/>
    </ExplicitInverseRef>
    <PrimAttribute name="name" id="0d429779-7071-4c5c-9784-b6b3139b7515">
        <length>201</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="year" id="7a8e04fe-0900-40b7-a999-8e8436c1c3a3">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="setForCreate" id="6cdb1522-6358-4c6d-a926-50154e26ad3c">
        <updating/>
        <source>setForCreate(_root : CMUI_Root; _name : String; _keyname : String; _icon : Binary; _year : Integer; _key : Binary) updating;

vars
 // ### TFS 50421 17SEP2021 NAVAB1
begin
	self.myRoot := _root;
	self.name := _name;
	self.keyname := _keyname;
	self.icon := _icon;
	self.year := _year;

	self.keybinary := _key;

end;
</source>
        <Parameter name="_root" type="CMUI_Root"/>
        <Parameter name="_name" type="String"/>
        <Parameter name="_keyname" type="String"/>
        <Parameter name="_icon" type="Binary"/>
        <Parameter name="_year" type="Integer"/>
        <Parameter name="_key" type="Binary"/>
    </JadeMethod>
