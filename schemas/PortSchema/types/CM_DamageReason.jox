    <JadeMethod name="cnEcGetDuplicate" id="90fe442a-bd33-41dc-b5e0-ab2b6a42ed15">
        <source>cnEcGetDuplicate(pFormat: CnEcXmlFormat; pInput: CnEcXmlStructureInstance): Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2022	navak20	53862: EUP - WMS - Damage Recording Extra Details

*/

vars
	code : String;
	damage : CM_DamageReason;
begin

	code := self.cnEcXMLGetTheAttributeValue( pFormat, pInput, self.class.name, "code" ).String; 
	
	if code &lt;&gt; null then
		damage := self.myTerminal.allDamageReasons.getAtKey( code );
	endif;

epilog

	return damage;
end;</source>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <ReturnType type="Object"/>
    </JadeMethod>
