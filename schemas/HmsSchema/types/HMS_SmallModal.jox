    <JadeMethod name="keyDown" id="8eab83c9-4f86-4a17-b51d-a82fda402aaa">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;

constants
	Esc_Key = 27;
	Enter_Key = 13;
vars

begin
 	if keyCode = Esc_Key then
 		self.modalResult := IDCANCEL;
 		self.unloadForm;

	elseif keyCode = Enter_Key then
		self.doOK();
	
	else
		inheritMethod(keyCode, shift);
	endif;	
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="2aedc362-e4cc-4354-b95a-cd7118e5f686">
