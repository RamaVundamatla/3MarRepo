        <source>utlUpdateInterfaceHistory(
	_pxyObject	: CM_InterfaceHistory;
	_passport	: CM_Passport input ) updating;
	
/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
15 May 2009			cnwrl1	Initial creation as part of PAR 19668 - CCMS 1814 - Interface History

*/
	
vars
	realObject			: CM_InterfaceHistory;
	expectedEdition		: Integer;
	
begin
	self.initialiseActivity();
	
