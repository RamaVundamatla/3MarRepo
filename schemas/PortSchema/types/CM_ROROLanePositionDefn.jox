    <JadeMethod name="getCargoDetails" id="648fafc8-b5f4-442a-8cf8-00e74c73974d">
        <source>getCargoDetails(_mode, _modeView, _modeViewSubSub: Integer): String;
/*
Purpose:			
Date		Who		Reason
14 December 2011	cnwab1	Initial creation
*/

vars
	tiStr, lenStr : String;	
begin
	
	if _mode = ShpDisplayMode_Actual then
		tiStr := self.myLanePositionController.getCargoDetail(REAL_MODE);
	elseif _mode = ShpDisplayMode_Proposed then
		tiStr := self.myLanePositionController.getCargoDetail(PLANNING_MODE);
	endif;	
	
	lenStr := self.myLayout.getLengthInMetres().String;
	
	return self.myLanePositionController.getFullId() &amp; " | " &amp; lenStr &amp; "m | " &amp; tiStr ;

epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_modeView" type="Integer"/>
        <Parameter name="_modeViewSubSub" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
