    <JadeMethod name="tPEN_X12322_Chassis_Ship" id="ccef96bb-28c2-49b9-9de4-e98d571936be">
        <updating/>
        <source>tPEN_X12322_Chassis_Ship() updating;
//cnwrs1
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 January 2015	cnwrd1	Initial creation

*/
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rather than current date time
// 09 Aug 2017	cnwrs1	TFS 5727 Penn Seaboard fixups
//15 May 2018	jlgsl4	TFS 38636 - PEN - K1 maximum 30 chars data

constants
	VoyageName1		= '123456';	
	InVoyName1		= '654321';				// all upper case!
	VoyageName1Tr	= '616263';				    // all upper case!
	BlockStackName	= 'BS34159';
	TestOperator	= 'UTOP';
	CamGroup = "P34159";
	CamProtocol = "X12322";
    CarrierCode = "UT_CA1";
    CarrierCodeTr = "CA1";
	BoatCode		= 'VSPAR27653';
    BoatCodeTrans   = 'TVS27653';
    BoatName        = 'My Vessel';
	DischargeBox		= "UTDR1234562";
	LoadBox				= "UTDR6543213";
	BlockStack1			= "UT_RDBS1";
	YardIC				= "UT_RD_IC";
	Ship				= "UTRDSHIP";
	Voyage1				= "UTRDVOYAGE";
	CraneTransferAreaId	= "CTRD";
	CraneId				= "CRR1";
vars
	dischargeTi,
	loadTi,
	ti4				: CM_TrackedItem;
	bs				: CM_BlockStack;
	yardIC			: CM_InterchangeArea;
	wle				: CM_WorkListEntry;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	slots 			: CM_SlotControllerArray;
	voyageJob		: CM_VoyageJob;
	job				: CM_Job;
	request			: CM_Request;
	voyageQueue		: CM_VoyageQueue;
	craneQueue		: CM_VoyageCraneQueue;
	crane			: CM_Machine;
	operator		: CM_Operator;
	bayName			: String;
	loadPort,
	dischargePort	: CM_Port;
	jobs			: CM_JobArray;
	voyAlloc		: CM_VoyageAllocation;
	wles 			: CM_WLEArray;
	straddle		: CM_Machine;
	tas				: StringArray;
	cta				: CM_CraneTransferArea;
	tempStr	: String;
	idx : Integer;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	emailEntity : CM_EmailEntity;
	camProtocolDesc : CM_CamProtocolDesc;
	registeredTransactions : StringArray;
	lRegisteredCargoTypes : IntegerArray;
	scheduleTimes : TimeArray;
	freightForwarders : CM_ConsigneeConsignorSet;
	allCoarriExportPorts : CM_PortByCodeDict;
	emailCopyAddresses : CM_EmailEntityByTypeNameDict;
	emailCarrierAddresses : CM_EmailEntityByTypeNameDict;
	packOperators : CM_OperatorByCodeDict;
	packExportConsignees : CM_ConsignByCodeDict;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	camTrainEventTypes : CM_EventTypeByNameDict;
	allPackAreas : CM_TAByIdDict;
	objArray : CM_ObjectArray;	//transaction are added to this array and this array is purged at the end to ensure the transactions dont affect other unit tests
	transObj : CM_TITransaction;
	strArray : HugeStringArray;
	str : String;
	trxDate	: Date;
	trxTime	:Time;
	runDateTime : TimeStamp;
	theLines : HugeStringArray;
begin
	self.setTerminalConfig(GateInAutoBOLNumber, true);
	self.setTerminalConfig(AllowRTSwithoutVGM, true);					// 10/06/2016 cnwmh5
	
	startDateTime := app.actualTimeServer;
	create theLines transient;
	create jobs transient;
	create wles transient;

	// delete everything first
	self.deleteContainer(DischargeBox);
	self.deleteContainer(LoadBox);
	self.deleteTerminalArea(BlockStack1);
	self.deleteTerminalArea(YardIC);
	self.deleteVoyage(Voyage1);
	self.deleteVessel(Ship);
	self.deleteMachine(CraneId);
	self.deleteTerminalArea(CraneTransferAreaId);
	
	// create the terminal areas - gridded block stack, block stack and interchange
	self.opts.purge;
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("HideOverview", true);
	yardIC := self.addInterchangeArea(YardIC, null);
	self.opts.purge;
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("StockControlled", true);
	self.opts.addAssoc("DefaultYIC", yardIC);
	bs := self.addBlockStack(BlockStack1, 20, null);		
	
	
	// create the crane transfer area
	cta := self.addCraneTransferArea(CraneTransferAreaId);
	self.assertNotNull(cta);
		
	operator := self.getOperator(TestOperator);
		
	//create vessel and voyage
	self.opts.addAssoc("inwardCode", "UTRDIN");
	vessel := addVesselCellular(Ship, operator);
	voyage := self.addVoyageWithContainerStructur(Voyage1, Ship, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNull(vessel);
	self.assertNotNull(voyage);
	
	// create the crane
	create tas transient;
	tas.add(cta.id);
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta);
	self.opts.addAssoc("MachineLiftType", TWIN_LIFT);
	crane := self.addCrane(CraneId, null, tas, null);
	self.assertNotNull(crane);
	delete tas;

	
	loadPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;

	//create discharge job
	bayName := '01';
	create slots transient;
	self.getJobSlotControllers(Voyage1, bayName, DeckOnDeck, 1, 1, 1, slots);
	assertEqual(slots.size, 1);
	self.opts.purge();
	self.opts.addAssoc("DontAddCrLf", true);
	dischargeTi := self.addContainerAtLocnDisch(DischargeBox , "2200", "GENL", TI_IMEX_STATUS_IMPORT, slots[1], loadPort, voyage);
	// Color code and Create Discharge Jobs
	self.voyageDischargeColourCode(voyage);
	
	voyageJob := self.addVoyageJob(voyage, CraneId, slots, true);
	assertTrueMsg(voyageJob &lt;&gt; null, "Voyage job 1 not created");
	jobs.add(voyageJob);
	
	foreach wle in voyageJob.workListEntries do
		self.movePlannedWLE(wle.myTrackedItem, 	bs.myLocationsController, wle);
	endforeach;
	delete slots;
	
	self.opts.purge;																				// cnwmk3 6/01/2016
	self.opts.addAssoc("DontAddCrLf", true);
	voyAlloc := self.addVoyageAllocation(voyage, dischargePort.code,"GEN2",null,1,false,false);
	bayName :='01';

	create slots transient;
	self.getJobSlotControllers(voyage.code, bayName, DeckOnDeck, 1, 2, 1, slots);
	assertEqual(slots.size, 1);

	self.addLCsToLOLOAllocation(true, voyAlloc, slots, null);
	
	voyageJob := self.addVoyageJob(voyage, CraneId, slots, false);
	assertTrueMsg(voyageJob &lt;&gt; null, "Voyage job not created");
	jobs.add(voyageJob);	
	loadTi := self.addContainerForExport(LoadBox, operator,
				"2200",	"GENL",	TI_IMEX_STATUS_EXPORT,	null, voyage.code, dischargePort.code, null).CM_Container;
	self.move(loadTi, bs.getLocationsController);
	self.setCargoReadyToShip(loadTi);
	self.deleteStops(loadTi);
	self.movePlannedRequestToJob(loadTi, slots[1], slots[1].getRequest(true));
	delete slots;

	// ok have my load and discharge jobs now
	
	//load to ops
	self.loadAllJobsToOps(voyage, true);				
	
	self.addMachineRule( bs, crane.CM_Crane.transferArea, RTMoveMethod_23); //simple single straddle moves
	self.addMachineRule( crane.CM_Crane.transferArea, bs, RTMoveMethod_23); 
		
	voyageQueue := self.addVoyageQueue(voyage);
	craneQueue := self.addVoyageCraneQueue(voyage, voyageQueue, crane);
	
	// Create Queues
	foreach job in jobs do
		foreach request in job.allRequests do
			foreach wle in request.allWorkListEntries do
				wles.add(wle);
				self.queueWLE(wle);
			endforeach;
		endforeach;
	endforeach;
	
	// workJob using straddle
	self.deleteMachine("UTS1");
	self.deleteRTDevice("91");
	create tas transient;
	tas.add(bs.id); 
	tas.add(yardIC.id); 
	tas.add(crane.CM_Crane.transferArea.id); 
	self.addStraddle("UTS1", 91, tas, null);
	straddle := self.getMachine("UTS1");
	assertNotNull(straddle);
	if craneQueue &lt;&gt; null then
		beginTransaction;
		straddle.addToQueue(craneQueue, true, 0); //add straddle to crane queue
		commitTransaction;
	endif;
	delete tas;
	
	app.isRTApp:=true;  
	self.machineLogon(straddle);

	foreach wle in wles do
		self.machineAcceptTask(straddle, wle.allRTQueueEntries.first.allTasks.first);
		
		if wle.isReceipt and wle.job.isVoyageJob then 
			//crane := wle.job.CM_VoyageJob.getJobCrane();
			self.machineCraneActionPickup(straddle, dischargeTi, ti4);
			self.machinePickup(straddle);			
			self.machineSetdownTask(straddle, wle.allRTQueueEntries.first.allTasks.last, bs.id);	
		else
			self.machinePickup(straddle);
			self.machineSetdownTask(straddle, wle.allRTQueueEntries.first.allTasks.last, wle.allRTQueueEntries.first.allTasks.last.targetLocationId);
		endif;
		
	endforeach;	
	
	self.assertTrue( dischargeTi.myPrimaryActualLocation.isYardLocation);
	self.assertTrue( loadTi.myPrimaryActualLocation.isVoyageController);
	
	// check txns created correctly for the following
	self.checkTIForTxnOfType(dischargeTi, TRANS_TYPE_REC_SHIP);			// 15/08/2012 cnwmh5
	self.checkTIForTxnOfType(dischargeTi, TRANS_TYPE_WHARFAGE);			// 15/08/2012 cnwmh5
	self.checkTIForTxnOfType(loadTi, TRANS_TYPE_REL_SHIP);				// 15/08/2012 cnwmh5
	self.checkTIForTxnOfType(loadTi, TRANS_TYPE_WHARFAGE);				// 15/08/2012 cnwmh5

	//cams X21 bit

	create objArray transient;
	
	objArray.add(transObj);
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, "SMLU", "TIDEWORKS", "NZCHC", "JAXT0", false, false, false, operatorDict, freightForwarders, 16, "SHIP");
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveShip).asStringJMT);
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReleaseShip).asStringJMT);
	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	camProtocolDesc := app.myRoot.allCamProtocolDescs["X12 322 - Chassis"];
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	camProtocol := self.addCamProtocol(CamProtocol, CamProtocol, allCoarriExportPorts, camGroup, "JAXT0", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, false, false, false, false, false, false, false, false, false, false, true/*BGM per movement*/, true, 
									   false, false, false, false, false, false, false, false, false, false, false, false, 
									   0, 0, 0, 0, '', '', '', camEditTriggerFields, camTrainEventTypes, null, false, 0, self.getTerminal, true, true, false, false, false, false, false, true, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	if camProtocol &lt;&gt; null then
	beginTransaction;
	camProtocol.setIncludeChassis(true);
	camProtocol.setPropertyValue(CM_CamProtocol::isSingleTransPerFile.name, true);
	commitTransaction;
	endif;
	tempStr	:= 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(camProtocol, tempStr);
	self.assertNotNull(camProtocol);

	endDateTime := startDateTime.addMinutes(1);
//	runDateTime := app.actualTimeServer;
	self.runCamsAdhoc(startDateTime, app.actualTimeServer, runDateTime, camProtocol);
//	self.runCamsNow(startDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	////camProtocol.inspectModal;
	self.assertNotNull(camTaskHistory);

	camTaskHistory.rawDataToHSA(theLines);

	create strArray transient;
	
		
	trxDate := dischargeTi.getTransReceive.camsTimeStamp.date;
	trxTime := 	dischargeTi.getTransReceive.camsTimeStamp.time;
	
	strArray.add("ISA*00*          *00*          *ZZ*TIDEWORKS      *ZZ*SMLU           *" &amp;  runDateTime.date.formatAsYYMMDD &amp; "*" &amp; runDateTime.time.shortFormatEDI &amp; "*U*00401*000000101*0*P*&gt;~");
	strArray.add("GS*SO*TIDEWORKS*SMLU*"  &amp;  runDateTime.date.formatAsYYYYMMDD &amp;  "*" &amp; runDateTime.time.shortFormatEDI &amp; "*000000101*X*004010~");
	strArray.add("ST*322*000000101~");                             
	strArray.add("Q5*UV*" &amp;  trxDate.formatAsYYYYMMDD &amp;  "*"&amp;  trxTime.shortFormatEDI  &amp; "*LT**************~");
	strArray.add("N7*UTDR*123456*4000*G*4000******CN*SHIP***02000*A*K*2*HH***2200*SHIP*");
	strArray.add("V4*010682~");
	strArray.add("DTM*152*" &amp;  trxDate.formatAsYYYYMMDD &amp;  "*"&amp;  trxTime.shortFormatEDI  &amp; "*LT**~");
	strArray.add("W2*UTDR*123456**CN*L********2***~");
	strArray.add("V1**UTRDSHIP**UTRDI");		// TFS 1839 was UTRDV now uses inwardCode as this is an import
	strArray.add("R4*D*UN*NZPOE*****~");
	strArray.add("R4*L*UN*NZPOE*****~");
	strArray.add("R4*I*UN*JAXT0*****~");
	strArray.add("N1*MC**2*SMLU~");
	strArray.add("K1**" &amp; self.createdByUnitTest(null)[1:30] &amp; "~"); // TFS 38636
	strArray.add("N9*BM*" &amp; dischargeTi.billOfLading &amp; "*****~");
	strArray.add("SE*14*000000101~");
	strArray.add("GE*1*000000101~");
	strArray.add("IEA*1*000000101~");
	
	strArray.add("ISA*00*          *00*          *ZZ*TIDEWORKS      *ZZ*SMLU           *" &amp;  runDateTime.date.formatAsYYMMDD &amp; "*" &amp; runDateTime.time.shortFormatEDI &amp; "*U*00401*000000102*0*P*&gt;~");
	strArray.add("GS*SO*TIDEWORKS*SMLU*"  &amp;  runDateTime.date.formatAsYYYYMMDD &amp;  "*" &amp; runDateTime.time.shortFormatEDI &amp; "*000000102*X*004010~");
	strArray.add("ST*322*000000102~");                             
	strArray.add("Q5*AE*" &amp;  trxDate.formatAsYYYYMMDD &amp;  "*"&amp;  trxTime.shortFormatEDI  &amp; "*LT**************~");
	strArray.add("N7*UTDR*654321*4000*G*2000******CN*SHIP***02000*A*K*3*HH***2200*SHIP*");
	strArray.add("V4*010684~");
	strArray.add("DTM*152*" &amp;  trxDate.formatAsYYYYMMDD &amp;  "*"&amp;  trxTime.shortFormatEDI  &amp; "*LT**~");
	strArray.add("W2*UTDR*654321**CN*L********3***~");
	strArray.add("V1**UTRDSHIP**UTRDV");		// TFS 1839 is still UTRDV as this is an export
	strArray.add("R4*D*UN*NZAKL*****~");
	strArray.add("R4*L*UN*NZPOE*****~");
	strArray.add("R4*I*UN*JAXT0*****~");
	strArray.add("N1*MC**2*SMLU~");
	strArray.add("K1**" &amp; self.createdByUnitTest(null)[1:30] &amp; "~"); // TFS 38636
	strArray.add("N9*BM*" &amp; loadTi.billOfLading &amp; "*****~");
	strArray.add("SE*14*000000102~");
	strArray.add("GE*1*000000102~");
	strArray.add("IEA*1*000000102~");
	
	self.assertEqualMsg(theLines.size.String, strArray.size.String, "Cams has not run correctly.");
	
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		idx := idx + 1;
		str := strArray[idx];
		self.assertEqualMsg(tempStr[1:str.length], str, "Line " &amp; idx.String);
//		if idx = 36 then
//			break;
//		endif;
	endforeach;  
    
	beginTransaction;
	objArray.purge;
	commitTransaction;
epilog
	app.isRTApp:=false;  
	delete jobs;
	delete slots;
	delete wles;
	delete tas;	
	delete operatorDict;
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete emailCarrierAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete registeredTransactions;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
	delete lRegisteredCargoTypes;
	delete objArray;
	delete strArray;
	delete theLines;
end;


</source>
    </JadeMethod>
    <JadeMethod name="tPEN_X12322_Gate" id="7c0e8bc7-f595-46c2-9d72-c824f830f038">
        <source>tPEN_X12322_Gate();
//cnwrs1
/*
Purpose:			
Parameters:			
Return Value:		
Date		Who		Reason
17 March 2014	cnwrd1	Initial creation
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
// 09 Aug 2017	cnwrs1	TFS 5727 Penn Seaboard fixups
//15 May 2018	jlgsl4	TFS 38636 - PEN - K1 maximum 30 chars data
//23 May 2018	jlgsl4	TFS 38793 - PEN - H1 not covered by unit tests, added here
10/09/2019 	JLGNS1	Bug 46446: ADP - RE: JMT Error
*/

constants
	VoyageName1		= '123456';	
	InVoyName1		= '654321';				// all upper case!
	VoyageName1Tr	= '616263';				    // all upper case!
	BlockStackName	= 'BS34159';
	TestOperator	= 'UTOP';
	CamGroup = "P34159";
	CamProtocol = "X12322";
    ReleaseNumber = "1234";
    CarrierCode = "UT_CA1";
    CarrierCodeTr = "CA1";
	Cargo_Type = "UTCHAS";
	TrailerType ="UTTT20";
	TruckID = "UTCHAS";
	CargoID = "UTC14120103";
	BoatCode		= 'VSPAR27653';
    BoatCodeTrans   = 'TVS27653';
    BoatName        = 'My Vessel';
vars
	count	: Integer;
	ct : CM_CargoType;
	tt	: CM_TILCType;
	bs1 : CM_BlockStack;
	vvr : CM_VehicleVisitRecord;
	truck : CM_Vehicle;
	tiTrans : CM_TITransaction;
	container : CM_Container;
	ti	: CM_TrackedItem;
	vessel : CM_Vessel;
	voyage1 : CM_Voyage;
	tempStr	: String;
	idx : Integer;
	operator : CM_Operator;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	emailEntity : CM_EmailEntity;
	camProtocolDesc : CM_CamProtocolDesc;
	registeredTransactions : StringArray;
	lRegisteredCargoTypes : IntegerArray;
	scheduleTimes : TimeArray;
	freightForwarders : CM_ConsigneeConsignorSet;
	allCoarriExportPorts : CM_PortByCodeDict;
	emailCopyAddresses : CM_EmailEntityByTypeNameDict;
	emailCarrierAddresses : CM_EmailEntityByTypeNameDict;
	packOperators : CM_OperatorByCodeDict;
	packExportConsignees : CM_ConsignByCodeDict;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	camTrainEventTypes : CM_EventTypeByNameDict;
	allPackAreas : CM_TAByIdDict;
	objArray : CM_ObjectArray;	//transaction are added to this array and this array is purged at the end to ensure the transactions dont affect other unit tests
	transObj : CM_TITransaction;
	strArray : HugeStringArray;
	str : String;
    thisTerminal : String;
    carrier : CM_Carrier;
	cargoType : CM_CargoType;
	dualGate : CM_Gate;
	pin : CM_GateArea;
	trxDate	:Date;
	trxTime	:Time;
	runDateTime : TimeStamp;
	theLines : HugeStringArray;
begin
	self.setTerminalConfig(GateInAutoBOLNumber, true);
	startDateTime := app.actualTimeServer;
	create theLines transient;
	self.deleteAllCargo(CargoID,app.myRoot.getCargoTypeFromAbbrevOrDescr("CONT"));

	
	operator := self.getOperator(TestOperator);
	
	
	dualGate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	pin := self.getPGate(self.getProfileSetting(UT_Profile.P_DGATE_PIN).asString);
	
	    //Delete the Carrier and Translation
    self.deleteEDIOutwardXlation(CarrierCodeTr, XLATION_TYPE_CARRIER_BYOP, operator, null);
    self.deleteEDIInwardXlation(CarrierCode, XLATION_TYPE_CARRIER_BYOP, operator, null);
    self.deleteCarrier(CarrierCode);
    carrier := self.getCarrier(CarrierCode);
    self.assertIsDeleted(carrier);
	
	self.deleteEDIInwardXlation(VoyageName1,XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIOutwardXlation(VoyageName1,XLATION_TYPE_VOYAGETERMINAL, operator, null);
	
	self.deleteVoyage(VoyageName1);
	voyage1 := self.getVoyage(VoyageName1);
	self.assertIsDeleted(voyage1);
	
	self.deleteVessel(BoatCode);
	vessel := self.getVessel(BoatCode);
	self.assertIsDeleted(vessel);

	// Now create the required voyages and vessels
	vessel := self.addVesselCellularWithCode(BoatCode, BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatCode.display &amp; ' failed');
	
	self.opts.addAssoc(ETRow_LloydsNumber,'123454321');//Bug 46446
		
	voyage1 := self.addVoyageWithInwardCode(        VoyageName1, 
                                                    InVoyName1,
													BoatCode,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
									
	
    self.createEDIXlation(BoatCodeTrans, BoatCode,    XLATION_TYPE_VESSEL_BYOP,    true, operator, null );
	self.createEDIXlation(VoyageName1Tr, VoyageName1, XLATION_TYPE_VOYAGETERMINAL, true, operator, null );
	
	    // Add the Carrier &amp; Translation
	create emailCarrierAddresses transient;
    carrier := self.addCarrier(CarrierCode, "A Unit Test Carrier", emailCarrierAddresses, false, false, true, null);
    self.assertNotNullMsg( carrier, 'Add carrier ' &amp; CarrierCode &amp; ' failed' );
    self.createEDIXlation(CarrierCodeTr, CarrierCode,    XLATION_TYPE_CARRIER_BYOP,    true, operator, null );
	
	bs1:=self.addBlockStack("BSCHAS",999,null);

	self.opts.purge();									// 21/09/2015 cnwmk3
	self.opts.addAssoc("DontAddCrLf", true);
	container:=self.addContainerAtLocation(CargoID,operator,"2200","MT",TI_IMEX_STATUS_STORAGE,bs1.myLocationsController);
	
	addTIHazard(container, "2", false); // TFS 38793

	beginTransaction;
    container.setDeliveryRelease(ReleaseNumber);
	container.setClientRef("CR001");
    container.setReleaseCarrier(CarrierCode);
	container.setCarrier(CarrierCode);
	container.setVoyageCode(voyage1.code,app.myPassport);
	container.allTIHazards.first.CM_TIHazard.allUNDGCodes.add('1234'); // TFS 38793	
    commitTransaction;
	
	self.deleteVehicle(TruckID);

	vvr:=self.gateOutContainer(TruckID,'','UTDRIVER',container,false,dualGate,null);
	
	
	truck:=self.getTerminal.vehicles[TruckID,null];
	self.assertNotNull(truck);
	self.moveVehicleToLane(vvr.vehicle, pin, 1);
	assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(pin, 1));
		
	self.moveVehicleToYard(vvr.vehicle);
	
	self.moveQueuedCargo(vvr.myRoadJob.workListEntries.first);
	
	self.roadExit(vvr);

	// 35202 check that the VVR allReleasedTIs is still populated
	foreach ti in vvr.allReleasedTrackedItems do
		count := count + 1;
	endforeach;
	self.assertEqualMsg(count, 1, "Vehicle Visit allReleasedTrackedItem count");
	
	
	create objArray transient;
	
	objArray.add(transObj);
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, "SMLU", "TIDEWORKS", "NZCHC", "JAXT0", false, false, false, operatorDict, freightForwarders, 16, "SHIP");
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveRoad).asStringJMT);
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReleaseRoad).asStringJMT);
	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	lRegisteredCargoTypes.add(TI_CargoType_Chassis);
	camProtocolDesc := app.myRoot.allCamProtocolDescs["X12 322 - Operations Activity"];
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	camProtocol := self.addCamProtocol(CamProtocol, CamProtocol, allCoarriExportPorts, camGroup, "JAXT0", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, false, false, false, false, false, false, false, false, false, false, true/*BGM per movement*/, false, 
									   false, false, false, false, false, false, false, false, false, false, false, false, 
									   0, 0, 0, 0, '', '', '', camEditTriggerFields, camTrainEventTypes, null, false, 0, self.getTerminal, true, true, false, false, false, false, false, true, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	if camProtocol &lt;&gt; null then
	beginTransaction;
	camProtocol.setIncludeChassis(true);
	commitTransaction;
	endif;
	tempStr	:= 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(camProtocol, tempStr);
	self.assertNotNull(camProtocol);

	endDateTime := startDateTime.addMinutes(1);
//	runDateTime := app.actualTimeServer;
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

	camTaskHistory.rawDataToHSA(theLines);

	create strArray transient;
	
		
	/*today := app.actualTimeServer.date;
	nowTime := 	container.getTransRelease.createdTime.time;*/
	
 	trxDate := container.getTransRelease.camsTimeStamp.date;
	trxTime := 	container.getTransRelease.camsTimeStamp.time;
	
	strArray.add("ISA*00*          *00*          *ZZ*TIDEWORKS      *ZZ*SMLU           *" &amp;  runDateTime.date.formatAsYYMMDD &amp; "*" &amp; runDateTime.time.shortFormatEDI &amp; "*U*00401*000000101*0*P*");
	strArray.add("GS*SO*TIDEWORKS*SMLU*"  &amp;  runDateTime.date.formatAsYYYYMMDD &amp;  "*" &amp; runDateTime.time.shortFormatEDI &amp; "*000000101*X*004010~");
	strArray.add("ST*322*000000101~");                             
	strArray.add("Q5*OA*" &amp;  trxDate.formatAsYYYYMMDD &amp;  "*"&amp;  trxTime.shortFormatEDI  &amp; "*LT**************~");
	strArray.add("N7*UTC*1412010*2000*G*400******CN*SHIP***02000*A*K*3*HH***2200*SHIP*~");
	strArray.add("DTM*152*" &amp;  trxDate.formatAsYYYYMMDD &amp;  "*"&amp;  trxTime.shortFormatEDI  &amp; "*LT**~");
	strArray.add("W2*UTC*1412010**CN*E********3***~");
	strArray.add("NA***UTC*1412010*F~");
	strArray.add("V1*123454321*My Vessel**616263*DOUG***L*~");
	strArray.add("R4*L*UN*NZPOE*****~");
	strArray.add("R4*I*UN*JAXT0*****~");
	strArray.add("N1*MC*DOUG*94*DOUG~");
	strArray.add("K1**" &amp; self.createdByUnitTest(null)[1:30] &amp; "~"); // TFS 38636
	strArray.add("N9*BM*" &amp; container.billOfLading &amp; "*****~");
	strArray.add("L0*1***2000*N***1*CNT~");
	strArray.add("L5*1*1 PCS**~");
	strArray.add("H1*1234*2*I*HAZARD*****~"); // TFS 38793
	strArray.add("SE*16*000000101~"); // TFS 38793
	strArray.add("GE*1*000000101~");
	strArray.add("IEA*1*000000101~");
	
	self.assertEqualMsg(theLines.size.String, strArray.size.String, "Cams has not run correctly.");
	
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		idx := idx + 1;
		str := strArray[idx];
		self.assertEqual(tempStr[1:str.length], str);
//		if idx = 19 then
//			break;
//		endif;
	endforeach;  
    
	beginTransaction;
	objArray.purge;
	commitTransaction;
epilog
	delete operatorDict;
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete emailCarrierAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete registeredTransactions;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
	delete lRegisteredCargoTypes;
	delete objArray;
	delete strArray;
	delete theLines;
end;


</source>
    </JadeMethod>
    <JadeMethod name="tPEN_X12322_GateReef" id="622f8010-bf91-4073-89bd-98c49f50c0e4">
        <source>tPEN_X12322_GateReef();
//cnwrs1
// cnwrd1
/*
Purpose:			
Parameters:			
Return Value:		
Date		Who		Reason
17 March 2014	cnwrd1	Initial creation
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
// 09 Aug 2017	cnwrs1	TFS 5727 Penn Seaboard fixups
//15 May 2018	jlgsl4	TFS 38636 - PEN - K1 maximum 30 chars data
10/09/2019 	JLGNS1	Bug 46446: ADP - RE: JMT Error
*/
constants
	VoyageName1		= '123456';	
	InVoyName1		= '654321';				// all upper case!
	VoyageName1Tr	= '616263';				    // all upper case!
	BlockStackName	= 'BS34159';
	TestOperator	= 'UTOP';
	CamGroup = "P34159";
	CamProtocol = "X12322";
    ReleaseNumber = "1234";
    CarrierCode = "UT_CA1";
    CarrierCodeTr = "CA1";
	Cargo_Type = "UTCHAS";
	TrailerType ="UTTT20";
	TruckID = "UTCHAS";
	CargoID = "UTC14120104";
	BoatCode		= 'VSPAR27653';
    BoatCodeTrans   = 'TVS27653';
    BoatName        = 'My Vessel';
vars
	count	: Integer;
	ct : CM_CargoType;
	tt	: CM_TILCType;
	bs1 : CM_BlockStack;
	vvr : CM_VehicleVisitRecord;
	truck : CM_Vehicle;
	tiTrans : CM_TITransaction;
	container : CM_Container;
	ti	: CM_TrackedItem;
	vessel : CM_Vessel;
	voyage1 : CM_Voyage;
	tempStr	: String;
	idx : Integer;
	operator : CM_Operator;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	emailEntity : CM_EmailEntity;
	camProtocolDesc : CM_CamProtocolDesc;
	registeredTransactions : StringArray;
	lRegisteredCargoTypes : IntegerArray;
	scheduleTimes : TimeArray;
	freightForwarders : CM_ConsigneeConsignorSet;
	allCoarriExportPorts : CM_PortByCodeDict;
	emailCopyAddresses : CM_EmailEntityByTypeNameDict;
	emailCarrierAddresses : CM_EmailEntityByTypeNameDict;
	packOperators : CM_OperatorByCodeDict;
	packExportConsignees : CM_ConsignByCodeDict;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	camTrainEventTypes : CM_EventTypeByNameDict;
	allPackAreas : CM_TAByIdDict;
	objArray : CM_ObjectArray;	//transaction are added to this array and this array is purged at the end to ensure the transactions dont affect other unit tests
	transObj : CM_TITransaction;
	strArray : HugeStringArray;
	str : String;
    thisTerminal : String;
    carrier : CM_Carrier;
	cargoType : CM_CargoType;
	dualGate : CM_Gate;
	pin : CM_GateArea;
	trxDate	: Date;
	trxTime	:Time;
	runDateTime : TimeStamp;
	theLines : HugeStringArray;
begin
	self.setTerminalConfig(GateInAutoBOLNumber, true);
	startDateTime := app.actualTimeServer;
	create theLines transient;
	self.deleteAllCargo(CargoID,app.myRoot.getCargoTypeFromAbbrevOrDescr("CONT"));

	
	operator := self.getOperator(TestOperator);
	
		
/*	beginTransaction;
	operator.setPropertyValue (CM_Operator::displayTempFahrenheit.name, true);
	commitTransaction;*/

	dualGate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	pin := self.getPGate(self.getProfileSetting(UT_Profile.P_DGATE_PIN).asString);
	
	    //Delete the Carrier and Translation
    self.deleteEDIOutwardXlation(CarrierCodeTr, XLATION_TYPE_CARRIER_BYOP, operator, null);
    self.deleteEDIInwardXlation(CarrierCode, XLATION_TYPE_CARRIER_BYOP, operator, null);
    self.deleteCarrier(CarrierCode);
    carrier := self.getCarrier(CarrierCode);
    self.assertIsDeleted(carrier);
	
	self.deleteEDIInwardXlation(VoyageName1,XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIOutwardXlation(VoyageName1,XLATION_TYPE_VOYAGETERMINAL, operator, null);
	
	self.deleteVoyage(VoyageName1);
	voyage1 := self.getVoyage(VoyageName1);
	self.assertIsDeleted(voyage1);
	
	self.deleteVessel(BoatCode);
	vessel := self.getVessel(BoatCode);
	self.assertIsDeleted(vessel);

	// Now create the required voyages and vessels
	vessel := self.addVesselCellularWithCode(BoatCode, BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatCode.display &amp; ' failed');
	
	self.opts.addAssoc(ETRow_LloydsNumber,'123454321');//Bug 46446
		
	voyage1 := self.addVoyageWithInwardCode(        VoyageName1, 
                                                    InVoyName1,
													BoatCode,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
									

    self.createEDIXlation(BoatCodeTrans, BoatCode,    XLATION_TYPE_VESSEL_BYOP,    true, operator, null );
	self.createEDIXlation(VoyageName1Tr, VoyageName1, XLATION_TYPE_VOYAGETERMINAL, true, operator, null );
	
	    // Add the Carrier &amp; Translation
	create emailCarrierAddresses transient;
    carrier := self.addCarrier(CarrierCode, "A Unit Test Carrier", emailCarrierAddresses, false, false, true, null);
    self.assertNotNullMsg( carrier, 'Add carrier ' &amp; CarrierCode &amp; ' failed' );
    self.createEDIXlation(CarrierCodeTr, CarrierCode,    XLATION_TYPE_CARRIER_BYOP,    true, operator, null );
	
	bs1:=self.addBlockStack("BSCHAS",999,null);

	self.opts.purge();									// 21/09/2015 cnwmk3
	self.opts.addAssoc("DontAddCrLf", true);
	container:=self.addContainerAtLocation(CargoID,operator,"2232","REEF",TI_IMEX_STATUS_EXPORT,bs1.myLocationsController);
	
	
	
	beginTransaction;
    container.setDeliveryRelease(ReleaseNumber);
	container.setOperatorImportDeliveryRel('1234');
	container.setCustomsEntryNumber('1234');
	
	container.setClientRef("CR001");
    container.setReleaseCarrier(CarrierCode);
	container.setCarrier(CarrierCode);
	container.setVoyageCode(voyage1.code,app.myPassport);
    commitTransaction;	
	
	

	
	self.deleteVehicle(TruckID);
	self.deleteStops(container);

		
	vvr:=self.gateOutContainer(TruckID,'','UTDRIVER',container,false,dualGate,null);
	
	
	truck:=self.getTerminal.vehicles[TruckID,null];
	self.assertNotNull(truck);
	self.moveVehicleToLane(vvr.vehicle, pin, 1);
	assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(pin, 1));
		
	self.moveVehicleToYard(vvr.vehicle);
	
	
	self.moveQueuedCargo(vvr.myRoadJob.workListEntries.first);
	


	self.roadExit(vvr);

	// 35202 check that the VVR allReleasedTIs is still populated
	foreach ti in vvr.allReleasedTrackedItems do
		count := count + 1;
	endforeach;
	self.assertEqualMsg(count, 1, "Vehicle Visit allReleasedTrackedItem count");
	
	
	create objArray transient;
	
	objArray.add(transObj);
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, "SMLU", "TIDEWORKS", "NZCHC", "JAXT0", false, false, false, operatorDict, freightForwarders, 16, "SHIP");
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveRoad).asStringJMT);
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReleaseRoad).asStringJMT);
	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	lRegisteredCargoTypes.add(TI_CargoType_Chassis);
	camProtocolDesc := app.myRoot.allCamProtocolDescs["X12 322 - Operations Activity"];
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	camProtocol := self.addCamProtocol(CamProtocol, CamProtocol, allCoarriExportPorts, camGroup, "JAXT0", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, false, false, false, false, false, false, false, false, false, false, true/*BGM per movement*/, false, 
									   false, false, false, false, false, false, false, false, false, false, false, false, 
									   0, 0, 0, 0, '', '', '', camEditTriggerFields, camTrainEventTypes, null, false, 0, self.getTerminal, true, true, false, false, false, false, false, true, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	if camProtocol &lt;&gt; null then
	beginTransaction;
	camProtocol.setIncludeChassis(true);
	commitTransaction;
	endif;
	tempStr	:= 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(camProtocol, tempStr);
	self.assertNotNull(camProtocol);

	endDateTime := startDateTime.addMinutes(1);
//	runDateTime := app.actualTimeServer;
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

	camTaskHistory.rawDataToHSA(theLines);

	create strArray transient;
	
		
	/*today := app.actualTimeServer.date;
	//nowTime := 	container.allTransactions.last.createdTime.time;
	nowTime := 	container.getTransRelease.createdTime.time;*/
	
 	trxDate := container.getTransRelease.camsTimeStamp.date;
	trxTime := 	container.getTransRelease.camsTimeStamp.time;
	
	strArray.add("ISA*00*          *00*          *ZZ*TIDEWORKS      *ZZ*SMLU           *" &amp;  runDateTime.date.formatAsYYMMDD &amp; "*" &amp; runDateTime.time.shortFormatEDI &amp; "*U*00401*000000101*0*P*");
	strArray.add("GS*SO*TIDEWORKS*SMLU*"  &amp;  runDateTime.date.formatAsYYYYMMDD &amp;  "*" &amp; runDateTime.time.shortFormatEDI &amp; "*000000101*X*004010~");
	strArray.add("ST*322*000000101~");                             
	strArray.add("Q5*OA*" &amp;  trxDate.formatAsYYYYMMDD &amp;  "*"&amp;  trxTime.shortFormatEDI  &amp; "*LT**************~");
	strArray.add("N7*UTC*1412010*2000*G*400******CN*SHIP***02000*A*K*4*HH***2232*SHIP*~");
	strArray.add("DTM*152*" &amp;  trxDate.formatAsYYYYMMDD &amp;  "*"&amp;  trxTime.shortFormatEDI  &amp; "*LT**~");
	strArray.add("W09*CZ*4*CE**CE****~");	
	strArray.add("W2*UTC*1412010**CN*L********4***~");
	strArray.add("NA***UTC*1412010*F~");
	strArray.add("V1*123454321*My Vessel**616263*DOUG***L*~");
	strArray.add("R4*L*UN*NZPOE*****~");
	strArray.add("R4*I*UN*JAXT0*****~");
	strArray.add("N1*MC*DOUG*94*DOUG~");
	strArray.add("K1**" &amp; self.createdByUnitTest(null)[1:30] &amp; "~"); // TFS 38636
	strArray.add("N9*BM*" &amp; container.billOfLading &amp; "*****~");
	strArray.add("L0*1***2000*N***1*CNT~");
	strArray.add("L5*1*1 PCS**~");
	strArray.add("SE*16*000000101~");
	strArray.add("GE*1*000000101~");
	strArray.add("IEA*1*000000101~");
	
	self.assertEqualMsg(theLines.size.String, strArray.size.String, "Cams has not run correctly.");
	
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		idx := idx + 1;
		str := strArray[idx];
		self.assertEqual(tempStr[1:str.length], str);
//		if idx = 20 then
//			break;
//		endif;
	endforeach;  
    
	beginTransaction;
	objArray.purge;
	commitTransaction;
epilog

	beginTransaction;
	operator.setPropertyValue (CM_Operator::displayTempFahrenheit.name, false );
	commitTransaction;
	
	delete operatorDict;
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete emailCarrierAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete registeredTransactions;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
	delete lRegisteredCargoTypes;
	delete objArray;
	delete strArray;
	delete theLines;
end;


</source>
    </JadeMethod>
    <JadeMethod name="tPEN_X12322_Pack" id="f8629024-5350-48bd-be99-65349620410f">
        <updating/>
        <source>tPEN_X12322_Pack() updating;
//cnwrs1
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 January 2015	cnwrd1	Initial creation

*/
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
// 09 Aug 2017	cnwrs1	TFS 5727 Penn Seaboard fixups
// 06 Nov 2023	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests

constants
	BlockStackName	= 'BS34159';
	TestOperator	= 'UTOP';
	CamGroup = "P34159";
	CamProtocol = "X12322";
    CarrierCode = "UT_CA1";
    CarrierCodeTr = "CA1";
	BoatCode		= 'VSPAR27653';
    BoatCodeTrans   = 'TVS27653';
    BoatName        = 'My Vessel';
	PackBox			= "UTDR1234562";
	Child1				= "MATCHILD001";
	Child2				= "MATCHILD002";
	BlockStack1			= "UT_RDBS1";
vars
	operator		: CM_Operator;
	container1: CM_TrackedItem;
	trx : CM_TITransaction;
	trxSet1 : CM_TITransactionSet;
	trxSet2 : CM_TITransactionSet;
	trxSet3 : CM_TITransactionSet;
	packTIs, unpackTIs: CM_TIArray;
	wh: CM_IrregularBlockArea;
	cargo, cargo1: CM_TrackedItem;
	tempStr	: String;
	idx : Integer;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	emailEntity : CM_EmailEntity;
	camProtocolDesc : CM_CamProtocolDesc;
	registeredTransactions : StringArray;
	lRegisteredCargoTypes : IntegerArray;
	scheduleTimes : TimeArray;
	freightForwarders : CM_ConsigneeConsignorSet;
	allCoarriExportPorts : CM_PortByCodeDict;
	emailCopyAddresses : CM_EmailEntityByTypeNameDict;
	emailCarrierAddresses : CM_EmailEntityByTypeNameDict;
	packOperators : CM_OperatorByCodeDict;
	packExportConsignees : CM_ConsignByCodeDict;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	camTrainEventTypes : CM_EventTypeByNameDict;
	allPackAreas : CM_TAByIdDict;
	objArray : CM_ObjectArray;	//transaction are added to this array and this array is purged at the end to ensure the transactions dont affect other unit tests
	transObj : CM_TITransaction;
	strArray : HugeStringArray;
	str : String;
	trxDate	: Date;
	trxTime	:Time;
	runDateTime : TimeStamp;
	theLines : HugeStringArray;
	orderNum : Integer;
begin
	self.setTerminalConfig(GateInAutoBOLNumber, true);
	startDateTime := app.actualTimeServer;
	create theLines transient;
	operator := self.getOperator(TestOperator);
		

	self.deleteContainer(PackBox);

	container1 := self.addContainerOpts(PackBox, "2200", "MT", operator );	
	
	self.deleteContainer(Child1);
	self.deleteContainer(Child2);
	wh := self.getTerminal.allTerminalAreas[self.getProfileSetting(UT_Profile.P_WAREHOUSE).asString].CM_IrregularBlockArea;
	cargo := self.addContainerAtLocation(Child1, null, "2200", "GENL", 1, wh.allLocationsControllers.first);
	cargo1 := self.addContainerAtLocation(Child2, null, "2200", "GENL", 1, wh.allLocationsControllers.first);
	self.assertLocationHasTI(wh.allLocationsControllers.first, cargo);

	//first pack in 1 child container
	create packTIs transient;
	packTIs.add(cargo);
	self.packContainer(container1.CM_Container, packTIs);
	self.packCompleteContainer(container1.CM_Container);

	self.assertEqualMsg(container1.numChildren, 1, "Container children incorrect");
	self.assertNullMsg(container1.unpackedDT, "Unpack date, first pack");
	self.assertNotNullMsg(container1.packedDT, "Pack date, first pack");

	//unpack this container
	create unpackTIs transient;
	unpackTIs.add(cargo);
	self.unpackContainer(container1, unpackTIs);
	self.unpackCompleteContainer(container1);

	self.assertEqualMsg(container1.numChildren, 0, "Container children incorrect");
	self.assertNotNullMsg(container1.unpackedDT, "Unpack date, first unpack");
	self.assertNotNullMsg(container1.packedDT, "Pack date, first unpack");
	
	// pack the second child
	packTIs.clear();
	packTIs.add(cargo1);
	self.packContainer(container1.CM_Container, packTIs);
	self.packCompleteContainer(container1.CM_Container);

	self.assertEqualMsg(container1.numChildren, 1, "Container children incorrect");
	self.assertNotNullMsg(container1.unpackedDT, "Unpack date, second pack");
	self.assertNotNullMsg(container1.packedDT, "Pack date, second pack");

	// fixup trx order
	create trxSet1 transient;
	create trxSet2 transient;
	create trxSet3 transient;
	foreach trx in cargo1.allTransactions where (trx.type = TRANS_TYPE_PACK or trx.type= TRANS_TYPE_UNPACK) do
		if orderNum = 0 or
		   orderNum &lt; trx.orderNo then
			orderNum := trx.orderNo;
		endif;
		trxSet1.add(trx);
	endforeach;
	foreach trx in cargo.allTransactions where (trx.type = TRANS_TYPE_PACK or trx.type= TRANS_TYPE_UNPACK) do
		if orderNum = 0 or
		   orderNum &lt; trx.orderNo then
			orderNum := trx.orderNo;
		endif;
		trxSet2.add(trx);
	endforeach;
	foreach trx in container1.allTransactions where (trx.type = TRANS_TYPE_PACK or trx.type= TRANS_TYPE_UNPACK) do
		if orderNum = 0 or
		   orderNum &lt; trx.orderNo then
			orderNum := trx.orderNo;
		endif;
		trxSet3.add(trx);
	endforeach;
	beginTransaction;
	orderNum := orderNum +4;
	foreach trx in trxSet1 do
		trx.setOrderNo(orderNum);
	endforeach;
	orderNum := orderNum -1;
	foreach trx in trxSet2 do
		trx.setOrderNo(orderNum);
	endforeach;
	orderNum := orderNum -1;
	foreach trx in trxSet3 do
		trx.setOrderNo(orderNum);
	endforeach;
	commitTransaction;

	//cams X21 bit

	create objArray transient;
	
	objArray.add(transObj);
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, "SMLU", "TIDEWORKS", "NZCHC", "JAXT0", false, false, false, operatorDict, freightForwarders, 16, "SHIP");
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_Pack).asStringJMT);
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_Unpack).asStringJMT);
	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	camProtocolDesc := app.myRoot.allCamProtocolDescs["X12 322 - Operations Activity"];
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	camProtocol := self.addCamProtocol(CamProtocol, CamProtocol, allCoarriExportPorts, camGroup, "JAXT0", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, false, false, false, false, false, false, false, false, false, false, true/*BGM per movement*/, false, 
									   false, false, false, false, false, false, false, false, false, false, false, false, 
									   0, 0, 0, 0, '', '', '', camEditTriggerFields, camTrainEventTypes, null, false, 0, self.getTerminal, true, true, false, false, false, false, false, true, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	if camProtocol &lt;&gt; null then
	beginTransaction;
	camProtocol.setIncludeChassis(true);
	commitTransaction;
	endif;
	tempStr	:= 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(camProtocol, tempStr);
	self.assertNotNull(camProtocol);

	endDateTime := startDateTime.addMinutes(1);
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

	camTaskHistory.rawDataToHSA(theLines);

	create strArray transient;
	
		
	/*today := app.actualTimeServer.date;
	nowTime := 	container1.allTransactions.last.createdTime.time;*/
	
 	trxDate := container1.getTransactionOfType(TRANS_TYPE_PACK).camsTimeStamp.date;
	trxTime := 	container1.getTransactionOfType(TRANS_TYPE_PACK).camsTimeStamp.time;	
	
	
	strArray.add("ISA*00*          *00*          *ZZ*TIDEWORKS      *ZZ*SMLU           *" &amp;  runDateTime.date.formatAsYYMMDD &amp; "*" &amp; runDateTime.time.shortFormatEDI &amp; "*U*00401*000000101*0*P*&gt;~");		//01
	strArray.add("GS*SO*TIDEWORKS*SMLU*"  &amp;  runDateTime.date.formatAsYYYYMMDD &amp;  "*" &amp; runDateTime.time.shortFormatEDI &amp; "*000000101*X*004010~");															//02
	strArray.add("ST*322*000000101~");                             
	strArray.add("Q5*ST*" &amp;  trxDate.formatAsYYYYMMDD &amp;  "*"&amp;  trxTime.shortFormatEDI  &amp; "*LT**************~");
	strArray.add("N7*UTDR*123456*6000*G*4000******CN*SHIP***02000*A*K*2*HH***2200*SHIP*");																													//05
	strArray.add("DTM*152*" &amp;  trxDate.formatAsYYYYMMDD &amp;  "*"&amp;  trxTime.shortFormatEDI  &amp; "*LT**~");
	strArray.add("W2*UTDR*123456**CN*E********2***~");
	strArray.add("R4*L*UN*NZPOE*****~");
	strArray.add("R4*I*UN*JAXT0*****~");
	strArray.add("SE*8*000000101~");																																										//10
	strArray.add("GE*1*000000101~");
	strArray.add("IEA*1*000000101~");
	
	strArray.add("ISA*00*          *00*          *ZZ*TIDEWORKS      *ZZ*SMLU           *" &amp;  runDateTime.date.formatAsYYMMDD &amp; "*" &amp; runDateTime.time.shortFormatEDI &amp; "*U*00401*000000102*0*P*&gt;~");
	strArray.add("GS*SO*TIDEWORKS*SMLU*"  &amp;  runDateTime.date.formatAsYYYYMMDD &amp;  "*" &amp; runDateTime.time.shortFormatEDI &amp; "*000000102*X*004010~");
	strArray.add("ST*322*000000102~");                             																																			//15
	strArray.add("Q5*ST*" &amp;  trxDate.formatAsYYYYMMDD &amp;  "*"&amp;  trxTime.shortFormatEDI  &amp; "*LT**************~");
	strArray.add("N7*MATCHILD*00*2000*G*400******CN*SHIP***02000*A*K*1*HH***2200*SHIP*~");
	strArray.add("DTM*152*" &amp;  trxDate.formatAsYYYYMMDD &amp;  "*"&amp;  trxTime.shortFormatEDI  &amp; "*LT**~");
	strArray.add("W2*MATCHILD*00**CN*L********1***~");
	strArray.add("R4*L*UN*NZPOE*****~");																																									//20
	strArray.add("R4*I*UN*JAXT0*****~");
	strArray.add("N9*BM*" &amp; cargo.billOfLading  &amp; "*****~");
	strArray.add("SE*9*000000102~");
	strArray.add("GE*1*000000102~");
	strArray.add("IEA*1*000000102~");
	
	strArray.add("ISA*00*          *00*          *ZZ*TIDEWORKS      *ZZ*SMLU           *" &amp;  runDateTime.date.formatAsYYMMDD &amp; "*" &amp; runDateTime.time.shortFormatEDI &amp; "*U*00401*000000103*0*P*&gt;~");
	strArray.add("GS*SO*TIDEWORKS*SMLU*"  &amp;  runDateTime.date.formatAsYYYYMMDD &amp;  "*" &amp; runDateTime.time.shortFormatEDI &amp; "*000000103*X*004010~");															//40
	strArray.add("ST*322*000000103~");                             
	strArray.add("Q5*SP*" &amp;  trxDate.formatAsYYYYMMDD &amp;  "*"&amp;  trxTime.shortFormatEDI  &amp; "*LT**************~");
	strArray.add("N7*UTDR*123456*6000*G*4000******CN*SHIP***02000*A*K*2*HH***2200*SHIP*~");
	strArray.add("DTM*152*" &amp;  trxDate.formatAsYYYYMMDD &amp;  "*"&amp;  trxTime.shortFormatEDI  &amp; "*LT**~");
	strArray.add("W2*UTDR*123456**CN*E********2***~");																																						//45
	strArray.add("R4*L*UN*NZPOE*****~");
	strArray.add("R4*I*UN*JAXT0*****~");
	strArray.add("SE*8*000000103~");
	strArray.add("GE*1*000000103~");
	strArray.add("IEA*1*000000103~");																																										//50
	
	strArray.add("ISA*00*          *00*          *ZZ*TIDEWORKS      *ZZ*SMLU           *" &amp;  runDateTime.date.formatAsYYMMDD &amp; "*" &amp; runDateTime.time.shortFormatEDI &amp; "*U*00401*000000104*0*P*&gt;~");
	strArray.add("GS*SO*TIDEWORKS*SMLU*"  &amp;  runDateTime.date.formatAsYYYYMMDD &amp;  "*" &amp; runDateTime.time.shortFormatEDI &amp; "*000000104*X*004010~");
	strArray.add("ST*322*000000104~");                             
	strArray.add("Q5*SP*" &amp;  trxDate.formatAsYYYYMMDD &amp;  "*"&amp;  trxTime.shortFormatEDI  &amp; "*LT**************~");
	strArray.add("N7*MATCHILD*00*2000*G*400******CN*SHIP***02000*A*K*1*HH***2200*SHIP*~");																													//30
	strArray.add("DTM*152*" &amp;  trxDate.formatAsYYYYMMDD &amp;  "*"&amp;  trxTime.shortFormatEDI  &amp; "*LT**~");
	strArray.add("W2*MATCHILD*00**CN*L********1***~");
	strArray.add("R4*L*UN*NZPOE*****~");
	strArray.add("R4*I*UN*JAXT0*****~");
	strArray.add("N9*BM*" &amp; cargo.billOfLading  &amp; "*****~");
	strArray.add("SE*9*000000104~");
	strArray.add("GE*1*000000104~");
	strArray.add("IEA*1*000000104~");
	
	strArray.add("ISA*00*          *00*          *ZZ*TIDEWORKS      *ZZ*SMLU           *" &amp;  runDateTime.date.formatAsYYMMDD &amp; "*" &amp; runDateTime.time.shortFormatEDI &amp; "*U*00401*000000105*0*P*&gt;~");
	strArray.add("GS*SO*TIDEWORKS*SMLU*"  &amp;  runDateTime.date.formatAsYYYYMMDD &amp;  "*" &amp; runDateTime.time.shortFormatEDI &amp; "*000000105*X*004010~");
	strArray.add("ST*322*000000105~");
	strArray.add("Q5*ST*" &amp;  trxDate.formatAsYYYYMMDD &amp;  "*"&amp;  trxTime.shortFormatEDI  &amp; "*LT**************~");
	strArray.add("N7*UTDR*123456*6000*G*4000******CN*SHIP***02000*A*K*2*HH***2200*SHIP*~");																													//55
	strArray.add("DTM*152*" &amp;  trxDate.formatAsYYYYMMDD &amp;  "*"&amp;  trxTime.shortFormatEDI  &amp; "*LT**~");
	strArray.add("W2*UTDR*123456**CN*E********2***~");
	strArray.add("R4*L*UN*NZPOE*****~");
	strArray.add("R4*I*UN*JAXT0*****~");
	strArray.add("SE*8*000000105~");																																										//60
	strArray.add("GE*1*000000105~");
	strArray.add("IEA*1*000000105~");

	strArray.add("ISA*00*          *00*          *ZZ*TIDEWORKS      *ZZ*SMLU           *" &amp;  runDateTime.date.formatAsYYMMDD &amp; "*" &amp; runDateTime.time.shortFormatEDI &amp; "*U*00401*000000106*0*P*&gt;~");
	strArray.add("GS*SO*TIDEWORKS*SMLU*"  &amp;  runDateTime.date.formatAsYYYYMMDD &amp;  "*" &amp; runDateTime.time.shortFormatEDI &amp; "*000000106*X*004010~");
	strArray.add("ST*322*000000106~");																																										//65
	strArray.add("Q5*ST*" &amp;  trxDate.formatAsYYYYMMDD &amp;  "*"&amp;  trxTime.shortFormatEDI  &amp; "*LT**************~");
	strArray.add("N7*MATCHILD*00*2000*G*400******CN*SHIP***02000*A*K*2*HH***2200*SHIP*~");
	strArray.add("DTM*152*" &amp;  trxDate.formatAsYYYYMMDD &amp;  "*"&amp;  trxTime.shortFormatEDI  &amp; "*LT**~");
	strArray.add("W2*MATCHILD*00**CN*L********2***~");
	strArray.add("R4*L*UN*NZPOE*****~");																																									//70
	strArray.add("R4*I*UN*JAXT0*****~");
	strArray.add("N9*BM*" &amp; (cargo.billOfLading.asIntegerJMT+1).String  &amp; "*****~");
	strArray.add("SE*9*000000106~");
	strArray.add("GE*1*000000106~");
	strArray.add("IEA*1*000000106~");																																										//74
	
	self.assertEqualMsg(theLines.size.String, strArray.size.String, "Cams has not run correctly.");

	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		idx := idx + 1;
		str := strArray[idx];
		self.assertEqualMsg(tempStr[1:str.length], str, "Failed in position "&amp;idx.String);
	endforeach;  
    
	beginTransaction;
	objArray.purge;
	commitTransaction;
epilog
	delete trxSet1;
	delete trxSet2;
	delete trxSet3;
	delete unpackTIs;
	delete packTIs;
	delete operatorDict;
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete emailCarrierAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete registeredTransactions;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
	delete lRegisteredCargoTypes;
	delete objArray;
	delete strArray;
	delete theLines;
end;


</source>
    </JadeMethod>
    <JadeMethod name="tPEN_X12322_Ship" id="330d75d2-d3c1-4843-81be-f45e31140227">
        <updating/>
        <source>tPEN_X12322_Ship() updating;
//cnwrs1
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 January 2015	cnwrd1	Initial creation

*/
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rather than current date time
// 09 Aug 2017	cnwrs1	TFS 5727 Penn Seaboard fixups
//15 May 2018	jlgsl4	TFS 38636 - PEN - K1 maximum 30 chars data
//11 Nov 2019	jlgsl4	TFS 46767 - PEN - GenSet Trailer Linking

constants
	VoyageName1		= '123456';	
	InVoyName1		= '654321';				// all upper case!
	VoyageName1Tr	= '616263';				    // all upper case!
	BlockStackName	= 'BS34159';
	TestOperator	= 'UTOP';
	CamGroup = "P34159";
	CamProtocol = "X12322";
    CarrierCode = "UT_CA1";
    CarrierCodeTr = "CA1";
	BoatCode		= 'VSPAR27653';
    BoatCodeTrans   = 'TVS27653';
    BoatName        = 'My Vessel';
	DischargeBox		= "UTDR1234562";
	LoadBox				= "UTDR6543213";
	BlockStack1			= "UT_RDBS1";
	YardIC				= "UT_RD_IC";
	Ship				= "UTRDSHIP";
	Voyage1				= "UTRDVOYAGE";
	CraneTransferAreaId	= "CTRD";
	CraneId				= "CRR1";
vars
	dischargeTi,
	loadTi,
	ti4				: CM_TrackedItem;
	bs				: CM_BlockStack;
	yardIC			: CM_InterchangeArea;
	wle				: CM_WorkListEntry;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	slots 			: CM_SlotControllerArray;
	voyageJob		: CM_VoyageJob;
	job				: CM_Job;
	request			: CM_Request;
	voyageQueue		: CM_VoyageQueue;
	craneQueue		: CM_VoyageCraneQueue;
	crane			: CM_Machine;
	operator		: CM_Operator;
	bayName			: String;
	loadPort,
	dischargePort	: CM_Port;
	jobs			: CM_JobArray;
	voyAlloc		: CM_VoyageAllocation;
	wles 			: CM_WLEArray;
	straddle		: CM_Machine;
	tas				: StringArray;
	cta				: CM_CraneTransferArea;
	tempStr	: String;
	idx : Integer;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	emailEntity : CM_EmailEntity;
	camProtocolDesc : CM_CamProtocolDesc;
	registeredTransactions : StringArray;
	lRegisteredCargoTypes : IntegerArray;
	scheduleTimes : TimeArray;
	freightForwarders : CM_ConsigneeConsignorSet;
	allCoarriExportPorts : CM_PortByCodeDict;
	emailCopyAddresses : CM_EmailEntityByTypeNameDict;
	emailCarrierAddresses : CM_EmailEntityByTypeNameDict;
	packOperators : CM_OperatorByCodeDict;
	packExportConsignees : CM_ConsignByCodeDict;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	camTrainEventTypes : CM_EventTypeByNameDict;
	allPackAreas : CM_TAByIdDict;
	objArray : CM_ObjectArray;	//transaction are added to this array and this array is purged at the end to ensure the transactions dont affect other unit tests
	transObj : CM_TITransaction;
	strArray : HugeStringArray;
	str : String;
	trxDate	: Date;
	trxTime	:Time;
	runDateTime : TimeStamp;
	theLines : HugeStringArray;
begin
	self.setTerminalConfig(GateInAutoBOLNumber, true);
	self.setTerminalConfig(AllowRTSwithoutVGM, true);					// 10/06/2016 cnwmh5
	self.setTerminalConfig(AutoLinkRefTraGen, true); // TFS 46767

	startDateTime := app.actualTimeServer;
	create theLines transient;
	create jobs transient;
	create wles transient;

	// delete everything first
	self.deleteContainer(DischargeBox);
	self.deleteContainer(LoadBox);
	self.deleteTerminalArea(BlockStack1);
	self.deleteTerminalArea(YardIC);
	self.deleteVoyage(Voyage1);
	self.deleteVessel(Ship);
	self.deleteMachine(CraneId);
	self.deleteTerminalArea(CraneTransferAreaId);
	
	
	// create the terminal areas - gridded block stack, block stack and interchange
	self.opts.purge;
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("HideOverview", true);
	yardIC := self.addInterchangeArea(YardIC, null);
	self.opts.purge;
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("StockControlled", true);
	self.opts.addAssoc("DefaultYIC", yardIC);
	bs := self.addBlockStack(BlockStack1, 20, null);		
	
	
	// create the crane transfer area
	cta := self.addCraneTransferArea(CraneTransferAreaId);
	self.assertNotNull(cta);
		
	operator := self.getOperator(TestOperator);
		
	//create vessel and voyage
	self.opts.addAssoc("inwardCode", "UTRDIN");
	vessel := addVesselCellular(Ship, operator);
	voyage := self.addVoyageWithContainerStructur(Voyage1, Ship, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNull(vessel);
	self.assertNotNull(voyage);
	
	// create the crane
	create tas transient;
	tas.add(cta.id);
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta);
	self.opts.addAssoc("MachineLiftType", TWIN_LIFT);
	crane := self.addCrane(CraneId, null, tas, null);
	self.assertNotNull(crane);
	delete tas;

	
	loadPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;

	//create discharge job
	bayName := '01';
	create slots transient;
	self.getJobSlotControllers(Voyage1, bayName, DeckOnDeck, 1, 1, 1, slots);
	assertEqual(slots.size, 1);
	self.opts.purge();
	self.opts.addAssoc("DontAddCrLf", true);
	dischargeTi := self.addContainerAtLocnDisch(DischargeBox , /*"2200"*/"2231", "GENL", TI_IMEX_STATUS_IMPORT, slots[1], loadPort, voyage); // TFS 46767
	// Color code and Create Discharge Jobs
	self.voyageDischargeColourCode(voyage);
	self.deleteTIMaster(dischargeTi); // TFS 46767
	
	voyageJob := self.addVoyageJob(voyage, CraneId, slots, true);
	assertTrueMsg(voyageJob &lt;&gt; null, "Voyage job 1 not created");
	jobs.add(voyageJob);
	
	foreach wle in voyageJob.workListEntries do
		self.movePlannedWLE(wle.myTrackedItem, 	bs.myLocationsController, wle);
	endforeach;
	delete slots;
	
	self.opts.purge;																				// cnwmk3 6/01/2016
	self.opts.addAssoc("DontAddCrLf", true);
	voyAlloc := self.addVoyageAllocation(voyage, dischargePort.code,"GEN2",null,1,false,false);
	bayName :='01';

	create slots transient;
	self.getJobSlotControllers(voyage.code, bayName, DeckOnDeck, 1, 2, 1, slots);
	assertEqual(slots.size, 1);

	self.addLCsToLOLOAllocation(true, voyAlloc, slots, null);
	
	voyageJob := self.addVoyageJob(voyage, CraneId, slots, false);
	assertTrueMsg(voyageJob &lt;&gt; null, "Voyage job not created");
	jobs.add(voyageJob);	
	loadTi := self.addContainerForExport(LoadBox, operator,
				"2200",	"GENL",	TI_IMEX_STATUS_EXPORT,	null, voyage.code, dischargePort.code, null).CM_Container;
	self.move(loadTi, bs.getLocationsController);
	self.setCargoReadyToShip(loadTi);
	self.deleteStops(loadTi);
	self.movePlannedRequestToJob(loadTi, slots[1], slots[1].getRequest(true));
	delete slots;

	// ok have my load and discharge jobs now
	
	//load to ops
	self.loadAllJobsToOps(voyage, true);				
	
	self.addMachineRule( bs, crane.CM_Crane.transferArea, RTMoveMethod_23); //simple single straddle moves
	self.addMachineRule( crane.CM_Crane.transferArea, bs, RTMoveMethod_23); 
		
	voyageQueue := self.addVoyageQueue(voyage);
	craneQueue := self.addVoyageCraneQueue(voyage, voyageQueue, crane);
	
	// Create Queues
	foreach job in jobs do
		foreach request in job.allRequests do
			foreach wle in request.allWorkListEntries do
				wles.add(wle);
				self.queueWLE(wle);
			endforeach;
		endforeach;
	endforeach;
	
	// workJob using straddle
	self.deleteMachine("UTS1");
	self.deleteRTDevice("91");
	create tas transient;
	tas.add(bs.id); 
	tas.add(yardIC.id); 
	tas.add(crane.CM_Crane.transferArea.id); 
	self.addStraddle("UTS1", 91, tas, null);
	straddle := self.getMachine("UTS1");
	assertNotNull(straddle);
	if craneQueue &lt;&gt; null then
		beginTransaction;
		straddle.addToQueue(craneQueue, true, 0); //add straddle to crane queue
		commitTransaction;
	endif;
	delete tas;
	
	app.isRTApp:=true;  
	self.machineLogon(straddle);

	foreach wle in wles do
		self.machineAcceptTask(straddle, wle.allRTQueueEntries.first.allTasks.first);
		
		if wle.isReceipt and wle.job.isVoyageJob then 
			//crane := wle.job.CM_VoyageJob.getJobCrane();
			self.machineCraneActionPickup(straddle, dischargeTi, ti4);
			self.machinePickup(straddle);			
			self.machineSetdownTask(straddle, wle.allRTQueueEntries.first.allTasks.last, bs.id);	
		else
			self.machinePickup(straddle);
			self.machineSetdownTask(straddle, wle.allRTQueueEntries.first.allTasks.last, wle.allRTQueueEntries.first.allTasks.last.targetLocationId);
		endif;
		
	endforeach;	
	
	self.assertTrue( dischargeTi.myPrimaryActualLocation.isYardLocation);
	self.assertTrue( loadTi.myPrimaryActualLocation.isVoyageController);
//	self.assertNotNull(self.getTIMaster(dischargeTi)); // TFS 46767 - 21 July 2021	NDL TFS 51570
	
	// check txns created correctly for the following
	self.checkTIForTxnOfType(dischargeTi, TRANS_TYPE_REC_SHIP);			// 15/08/2012 cnwmh5
	self.checkTIForTxnOfType(dischargeTi, TRANS_TYPE_WHARFAGE);			// 15/08/2012 cnwmh5
	self.checkTIForTxnOfType(loadTi, TRANS_TYPE_REL_SHIP);				// 15/08/2012 cnwmh5
	self.checkTIForTxnOfType(loadTi, TRANS_TYPE_WHARFAGE);				// 15/08/2012 cnwmh5

	//cams X21 bit

	create objArray transient;
	
	objArray.add(transObj);
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, "SMLU", "TIDEWORKS", "NZCHC", "JAXT0", false, false, false, operatorDict, freightForwarders, 16, "SHIP");
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveShip).asStringJMT);
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReleaseShip).asStringJMT);
	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	camProtocolDesc := app.myRoot.allCamProtocolDescs["X12 322 - Operations Activity"];
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	camProtocol := self.addCamProtocol(CamProtocol, CamProtocol, allCoarriExportPorts, camGroup, "JAXT0", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, false, false, false, false, false, false, false, false, false, false, true/*BGM per movement*/, true, 
									   false, false, false, false, false, false, false, false, false, false, false, false, 
									   0, 0, 0, 0, '', '', '', camEditTriggerFields, camTrainEventTypes, null, false, 0, self.getTerminal, true, true, false, false, false, false, false, true, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	if camProtocol &lt;&gt; null then
	beginTransaction;
	camProtocol.setIncludeChassis(true);
	camProtocol.setPropertyValue(CM_CamProtocol::isSingleTransPerFile.name, true);
	commitTransaction;
	endif;
	tempStr	:= 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(camProtocol, tempStr);
	self.assertNotNull(camProtocol);

	endDateTime := startDateTime.addMinutes(1);
//	runDateTime := app.actualTimeServer;
	self.runCamsAdhoc(startDateTime, app.actualTimeServer, runDateTime, camProtocol);
//	self.runCamsNow(startDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	////camProtocol.inspectModal;
	self.assertNotNull(camTaskHistory);

	camTaskHistory.rawDataToHSA(theLines);

	create strArray transient;
	
		
	trxDate := dischargeTi.getTransReceive.camsTimeStamp.date;
	trxTime := 	dischargeTi.getTransReceive.camsTimeStamp.time;
	
	strArray.add("ISA*00*          *00*          *ZZ*TIDEWORKS      *ZZ*SMLU           *" &amp;  runDateTime.date.formatAsYYMMDD &amp; "*" &amp; runDateTime.time.shortFormatEDI &amp; "*U*00401*000000101*0*P*&gt;~");
	strArray.add("GS*SO*TIDEWORKS*SMLU*"  &amp;  runDateTime.date.formatAsYYYYMMDD &amp;  "*" &amp; runDateTime.time.shortFormatEDI &amp; "*000000101*X*004010~");
	strArray.add("ST*322*000000101~");                             
	strArray.add("Q5*UV*" &amp;  trxDate.formatAsYYYYMMDD &amp;  "*"&amp;  trxTime.shortFormatEDI  &amp; "*LT**************~");
	strArray.add("N7*UTDR*123456*4000*G*4000******CN*SHIP***02000*A*K*2*HH***2231*SHIP*"); // TFS 46767, 2200 -&gt; 2231
	strArray.add("V4*010682~");
	strArray.add("DTM*152*" &amp;  trxDate.formatAsYYYYMMDD &amp;  "*"&amp;  trxTime.shortFormatEDI  &amp; "*LT**~");
	strArray.add("W2*UTDR*123456**CN*L********2***~");
	strArray.add("V1**UTRDSHIP**UTRDI");		// TFS 1839 was UTRDV now uses inwardCode as this is an import
	strArray.add("R4*D*UN*NZPOE*****~");
	strArray.add("R4*L*UN*NZPOE*****~");
	strArray.add("R4*I*UN*JAXT0*****~");
	strArray.add("N1*MC*SMLU*94*SMLU~");
	strArray.add("K1**" &amp; self.createdByUnitTest(null)[1:30] &amp; "~"); // TFS 38636
	strArray.add("N9*BM*" &amp; dischargeTi.billOfLading &amp; "*****~");
	strArray.add("SE*14*000000101~");
	strArray.add("GE*1*000000101~");
	strArray.add("IEA*1*000000101~");
	
	strArray.add("ISA*00*          *00*          *ZZ*TIDEWORKS      *ZZ*SMLU           *" &amp;  runDateTime.date.formatAsYYMMDD &amp; "*" &amp; runDateTime.time.shortFormatEDI &amp; "*U*00401*000000102*0*P*&gt;~");
	strArray.add("GS*SO*TIDEWORKS*SMLU*"  &amp;  runDateTime.date.formatAsYYYYMMDD &amp;  "*" &amp; runDateTime.time.shortFormatEDI &amp; "*000000102*X*004010~");
	strArray.add("ST*322*000000102~");                             
	strArray.add("Q5*AE*" &amp;  trxDate.formatAsYYYYMMDD &amp;  "*"&amp;  trxTime.shortFormatEDI  &amp; "*LT**************~");
	strArray.add("N7*UTDR*654321*4000*G*2000******CN*SHIP***02000*A*K*3*HH***2200*SHIP*");
	strArray.add("V4*010684~");
	strArray.add("DTM*152*" &amp;  trxDate.formatAsYYYYMMDD &amp;  "*"&amp;  trxTime.shortFormatEDI  &amp; "*LT**~");
	strArray.add("W2*UTDR*654321**CN*L********3***~");
	strArray.add("V1**UTRDSHIP**UTRDV");		// TFS 1839 is still UTRDV as this is an export
	strArray.add("R4*D*UN*NZAKL*****~");
	strArray.add("R4*L*UN*NZPOE*****~");
	strArray.add("R4*I*UN*JAXT0*****~");
	strArray.add("N1*MC*SMLU*94*SMLU~");
	strArray.add("K1**" &amp; self.createdByUnitTest(null)[1:30] &amp; "~"); // TFS 38636
	strArray.add("N9*BM*" &amp; loadTi.billOfLading &amp; "*****~");
	strArray.add("SE*14*000000102~");
	strArray.add("GE*1*000000102~");
	strArray.add("IEA*1*000000102~");
	
	self.assertEqualMsg(theLines.size.String, strArray.size.String, "Cams has not run correctly.");
	
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		idx := idx + 1;
		str := strArray[idx];
		self.assertEqualMsg(tempStr[1:str.length], str, "Line " &amp; idx.String);
//		if idx = 36 then
//			break;
//		endif;
	endforeach;  
    
	beginTransaction;
	objArray.purge;
	commitTransaction;
epilog
	app.isRTApp:=false;  
	delete jobs;
	delete slots;
	delete wles;
	delete tas;	
	delete operatorDict;
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete emailCarrierAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete registeredTransactions;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
	delete lRegisteredCargoTypes;
	delete objArray;
	delete strArray;
	delete theLines;
end;


</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;Fails1006&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
