    <JadeMethod name="redrawSelectLayer" id="cd231824-b9c7-4f2d-b10a-2a29d354b67e">
        <source>redrawSelectLayer(_deckItemLayout : CM_DeckItemLayout) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 June 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars

begin
	if self.frmDeck.myDrawingFrame = null then
		return;
	endif;
	if not _deckItemLayout.isMoveable() then
		return;
	endif;
	self.frmDeck.myDrawingFrame.clearGraphics;
	if self.modeView = ShpDisplayMode_ColCodeLoad or self.modeView = ShpDisplayMode_ColCodeDisch then
		self.myROROPlanDrawController.getAllPolygonsColourCoding(self.frmDeck.myDrawingFrame.CMUI_PointDrawingFrame,null,self.modeView = ShpDisplayMode_ColCodeLoad,White);	
	elseif self.modeView = ShpDisplayMode_Actual or self.modeView =  ShpDisplayMode_Defn then
		self.myROROPlanDrawController.getAllPolygonsActual(self.frmDeck.myDrawingFrame.CMUI_PointDrawingFrame,null, White);
	elseif self.modeView = ShpDisplayMode_Proposed then
		self.myROROPlanDrawController.getAllPolygonsProposed(self.frmDeck.myDrawingFrame.CMUI_PointDrawingFrame,null, White);
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_deckItemLayout" type="CM_DeckItemLayout"/>
    </JadeMethod>
