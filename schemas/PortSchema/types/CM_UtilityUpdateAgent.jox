        <source>utlUpdateLogCheckScalerCode(_realCheckScalingHdr : CM_LogCheckScaleHdr input; 
					_scaler : CM_User; 
					_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     22 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _realCheckScalingHdr = null then	
	//	app.raiseCMException1(REQUIRED_FIELD, 'Check scaling header', null, null);
		app.raiseCMException(Input_required_field_chkScalin, null, null);// cnwdb2	PAR 35364
		return;
	endif;
	
	if _scaler = null then	
	//	app.raiseCMException1(REQUIRED_FIELD, 'Check scaler', ETRow_ScalerCode, null);
		app.raiseCMException(Input_required_field_chkScaler, ETRow_ScalerCode, null); // cnwdb2	PAR 35364
		return;
	endif;
		
	exclusiveLock(_realCheckScalingHdr);
	_realCheckScalingHdr.setUserCode(_scaler.code);
	
