    <JadeMethod name="extractInvoiceLineTypes" id="d09c8795-aa05-458d-8b83-30dccdccf3d1">
        <source>extractInvoiceLineTypes(_file : File input; _bank : CM_Bank input) : Integer;

/*

Purpose:		Extract all invoice line types

Parameters:			

Return Value:		


Date		Who		Reason
9 May 2013	cnwjre1	Initial creation for DPH copy from test to UAT
16 Nov 2018 cnwma1	ChangeRequest 42059: Extract/Load Invoicing Data - Invoice Line Type - Currency conversion
02 Feb 2023 navvt20  TFS 56132 Task 56134: UI - Invoice Line Type - UOM

*/

vars
	count	: Integer;
	msg		: String;
	invLineType	: CM_InvoiceLineDesc;
	calcType	: CM_CalculationType;
	invType		: CM_InvoiceDesc;
	debtorType	: CM_DebtorType;
	service		: CM_Service;
	uom			: CM_InvoiceUnitOfMeasure; // 2 Feb 2023 navvt20 TFS 56134
begin

	msg := '&lt;invoiceLineTypes&gt;';
	_file.writeLine(msg);
	foreach invLineType in _bank.invoiceLineDescriptors do
		count := count + 1;
		msg := '&lt;lineType&gt;';
		_file.writeLine(msg);
		msg := self.formatAsXML("oneLinePerFP", invLineType.bOneLinePerFinancialPeriod.String);
		_file.writeLine(msg);
		msg := self.formatAsXML("printTrackedItems", invLineType.bPrintTrackedItems.String);
		_file.writeLine(msg);
		msg := self.formatAsXML("chargeByUnits", invLineType.chargeByUnits.String);
		_file.writeLine(msg);
		msg := self.formatAsXML("isVoid", invLineType.isVoid.String);
		_file.writeLine(msg);
		msg := self.formatAsXML("narration", invLineType.narration);
		_file.writeLine(msg);
		msg := self.formatAsXML("printingOrder", invLineType.printingOrder.String);
		_file.writeLine(msg);
		msg := self.formatAsXML("remarks", invLineType.remarks);
		_file.writeLine(msg);
		msg := self.formatAsXML("unitNarration", invLineType.unitNarration);
		_file.writeLine(msg);
		msg := self.formatAsXML("currencyConversionNotRequired", invLineType.currencyConversionNotRequired.String);  //16.11.2018 cnwma1 TFS #42059
		_file.writeLine(msg);                                                                                        //16.11.2018 cnwma1 TFS #420598
		calcType := invLineType.myCalculationType;
		if calcType &lt;&gt; null then
			msg := self.formatAsXML("myCalculationType", calcType.code);
			_file.writeLine(msg);
		endif;
		invType := invLineType.invoiceType;
		if invType &lt;&gt; null then
			msg := self.formatAsXML("invoiceType", invType.description);
			_file.writeLine(msg);
		endif;
		//Start 31 Jan 2023 navvt20 TFS 56134
		uom := invLineType.myUOM;
		if uom &lt;&gt; null then
			msg := self.formatAsXML("myUOM", uom.code);
			_file.writeLine(msg);
		endif;
		// End 31 Jan 2023 navvt20 TFS 56134
		debtorType := invLineType.myDebtorType;
		if debtorType &lt;&gt; null then
			msg := self.formatAsXML("myDebtorType", debtorType.code);
			_file.writeLine(msg);
		endif;
		if not invLineType.services.isEmpty() then
			msg := '&lt;services&gt;';
			_file.writeLine(msg);
			foreach service in invLineType.services do
				msg := self.formatAsXML("service", service.name);
				_file.writeLine(msg);
			endforeach;
			msg := '&lt;/services&gt;';
			_file.writeLine(msg);
		endif;
		msg := '&lt;/lineType&gt;';
		_file.writeLine(msg);
	endforeach;
	msg := '&lt;/invoiceLineTypes&gt;';
	_file.writeLine(msg);
	
	return count;

end;</source>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_bank" type="CM_Bank" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="extractInvoiceTypes" id="53c18eb3-b122-4d9d-b92f-015c614bed3d">
        <source>extractInvoiceTypes(_file : File input; _bank : CM_Bank input) : Integer;

/*

Purpose:		Extract all invoice types

Parameters:			

Return Value:		


Date		Who		Reason
27 May 2015	cnwjre1	Initial creation for ADP copy from UAT to production

*/

vars
	count	: Integer;
	msg		: String;
	str		: String;
	terms	: CM_InvoiceTermsOfTrade;
	invType	: CM_InvoiceDesc;
	finPE	: CM_FinancialPeriodEnd;
begin

	msg := '&lt;invoiceTypes&gt;';
	_file.writeLine(msg);
	foreach invType in _bank.invoiceTypes do
		count := count + 1;
		msg := '&lt;type&gt;';
		_file.writeLine(msg);
		msg := self.formatAsXML("accrualType", invType.accrualType.String);
		foreach str in invType.arrNarrationDesc do
			msg := self.formatAsXML("narration", str);
			_file.writeLine(msg);
		endforeach;
		msg := self.formatAsXML("description", invType.description);
		_file.writeLine(msg);
		msg := self.formatAsXML("externalReference", invType.externalReference);
		_file.writeLine(msg);
		msg := self.formatAsXML("invoiceKey", invType.invoiceKey.String);
		_file.writeLine(msg);
		msg := self.formatAsXML("invoiceType", invType.invoiceType.String);
		_file.writeLine(msg);
		msg := self.formatAsXML("isNotAvailableForEntry", invType.isNotAvailableForEntry.String);
		_file.writeLine(msg);
		msg := self.formatAsXML("number", invType.number.String);
		_file.writeLine(msg);
		msg := self.formatAsXML("printSingleLineForDayType", invType.printSingleLineForDayType.String);
		_file.writeLine(msg);
		msg := self.formatAsXML("triggerOnAction", invType.triggerOnAction.String);
		_file.writeLine(msg);
		finPE := invType.myFinancialPeriodEnd;
		if finPE &lt;&gt; null then
			msg := self.formatAsXML("myFinancialPeriodEnd", finPE.description);
			_file.writeLine(msg);
		endif;
		terms := invType.myInvTermsOfTrade;
		if terms &lt;&gt; null then
			msg := self.formatAsXML("myInvTermsOfTrade", terms.code);
			_file.writeLine(msg);
		endif;
		msg := '&lt;/type&gt;';
		_file.writeLine(msg);
	endforeach;
	msg := '&lt;/invoiceTypes&gt;';
	_file.writeLine(msg);
	
	return count;

end;</source>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_bank" type="CM_Bank" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="extractPaymentTypes" id="5c083172-f058-456f-9578-41878a1b5f41">
        <source>extractPaymentTypes(_debtor : CM_Debtor; _file : File input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/08/2018	jlgsl4	TFS 40294 PEL1 - extract new fields incl. Payment Type details
*/

vars
	terminal : CM_Terminal;
	debtorTerminal : CM_DebtorTerminal;
	isCashOnly : Boolean;
	paymentType : Integer;
	output : String;
	dict : CM_InvTermsOfTradeByCode;
	invTerm	: CM_InvoiceTermsOfTrade;
	paymentTerms : StringArray;
	
begin
	create paymentTerms transient;
	paymentTerms.add(app.getErrorString(PaymentType_NoneStr));
	paymentTerms.add(app.getErrorString(PaymentType_AutoCollectionStr));
	paymentTerms.add(app.getErrorString(PaymentType_PrePayStr));
	paymentTerms.add(app.getErrorString(PaymentType_PostPayStr));
	foreach terminal in app.myRoot.allTerminals do
		if terminal.isCashOnlyEnabled then
			isCashOnly := false;
			paymentType := null;
			if _debtor &lt;&gt; null then
				debtorTerminal := terminal.allDebtorTerminals.getAtKey(_debtor);
			endif;
			if debtorTerminal &lt;&gt; null then
				isCashOnly := debtorTerminal.isCashOnly.Boolean;
				if isCashOnly then // TFS 40294 - 11/9/18
					paymentType := debtorTerminal.paymentType;					
					output := self.formatAsXML("terminalCode", terminal.code);
					_file.writeLine(output);
					output := self.formatAsXML("isCashOnly", isCashOnly.String);
					_file.writeLine(output);
					output := self.formatAsXML("paymentTypeDesc", paymentTerms[paymentType + 1]);
					_file.writeLine(output);					
				endif; // TFS 40294 - 11/9/18
			endif;
		endif;
	endforeach;
epilog
	delete paymentTerms;
end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_file" type="File" usage="input"/>
    </JadeMethod>
    <JadeMethod name="extractRateDebtor" id="7be28020-ba43-4a6f-8a7d-5346d5e046bc">
        <source>extractRateDebtor(_effectiveDate : Date; _debtorNode : CM_DebtorNode input; _services : ObjectArray; _file : File input; _progress 	: CMS_Progress input) protected;
// Aug 2012 from 30204 copied from INV_RateTable
vars
	obj		: Object;
	service : CM_Service;
	debtorNode : CM_DebtorNode;
	iter : Iterator;

begin
	if _progress &lt;&gt; null then
		_progress.setAction(_debtorNode.name &amp; " - getting rates:");
		_progress.progress.partsDone := _progress.progress.partsDone  + 1;
		_progress.doWindowEvents(0);
	endif;

	foreach obj in _services do
		service := obj.CM_Service;
		self.extractRateDebtorService(_effectiveDate, _debtorNode, service, _file);
	endforeach;
	
	// CCMS-1604 (Debtor groups) include children
	// 30204 but not from the root debtor to avoid double-extracting the children
	if _debtorNode.isRootDebtorGroup then
		return;
	endif;
	if (not _debtorNode.allChildDebtorNodes.isEmpty) then
		iter := _debtorNode.allChildDebtorNodes.createIterator;
		while iter.next(debtorNode) do	
			self.extractRateDebtor(_effectiveDate, debtorNode, _services, _file, _progress);
		endwhile;
	endif;
epilog
	delete iter;
end;
</source>
        <access>protected</access>
        <Parameter name="_effectiveDate" type="Date"/>
        <Parameter name="_debtorNode" type="CM_DebtorNode" usage="input"/>
        <Parameter name="_services" type="ObjectArray"/>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_progress" type="CMS_Progress" usage="input"/>
    </JadeMethod>
    <JadeMethod name="extractRateDebtorService" id="a5ad0b27-19c4-44a6-9227-1f153221decf">
        <source>extractRateDebtorService(_effectiveDate : Date; _debtorNode : CM_DebtorNode input; _service : CM_Service input; _file : File input) protected;
// Aug 2012 from 30204 move from INV_RateTable
vars
	debtorCode			: String;
	debtorName			: String;
	derivedDebtorCode	: String;
	serviceName			: String;
	effectiveDate		: String;
	effectiveTime		: String;
	expiryDate			: String;
	expiryTime			: String;
	glCode				: String;
	rateEntry			: CM_RateEntry;
	ts					: TimeStamp;
	isOverRidingValue	: Boolean;
	extractLine			: CnStringArray;
	costPerUnitLabels	: StringArray;
	costPerUnitLabel	: String;
	i					: Integer;
	iter				: Iterator;
	debtorGroup			: String;
	calculationType : CM_CalculationType;	//29 Jun 2018	NDL	TFS 39338
	calcType : Integer;	//29 Jun 2018	NDL	TFS 39338
	subTerm : CM_SubTerminal;	//29 Jun 2018	NDL	TFS 39338
	tidalClass : HMS_TidalClass;	//29 Jun 2018	NDL	TFS 39338
	
begin
	ts.setDate(_effectiveDate);
	rateEntry	:=	_debtorNode.getServiceTimeRate(_service, ts);
	
	if rateEntry &lt;&gt; null then
	
		//29 Jun 2018	NDL	TFS 39338
		if _service &lt;&gt; null then
			calculationType := _service.myCalculationType;
			if calculationType&lt;&gt; null then
				calcType := calculationType.calculationType;
			endif;
		endif;
	
		if _debtorNode.isKindOf(CM_Debtor) then
			debtorCode			:=	_debtorNode.CM_Debtor.decfinName;
			derivedDebtorCode	:=	debtorCode;
			
			debtorGroup := 'D';
		else
			debtorGroup := 'G';
			
			if _debtorNode.myParentDebtorNode &lt;&gt; null then
				derivedDebtorCode	:=	_debtorNode.myParentDebtorNode.name;
			endif;
		endif;
		
		debtorName	:=	_debtorNode.name;
		
		isOverRidingValue	:=	rateEntry.rate.CM_DebtorRate.debtorNode = _debtorNode;
		serviceName			:=	_service.name;
		effectiveDate		:=	rateEntry.startTimestamp.date.String;
		effectiveTime		:=	rateEntry.startTimestamp.time.String;
		expiryDate			:=	rateEntry.expiryTimestamp.date.String;
		expiryTime			:=	rateEntry.expiryTimestamp.time.String;
		
		if _service.genLCode &lt;&gt; null then
			glCode	:=	_service.genLCode.code.String;
		endif;

		create costPerUnitLabels transient;
		rateEntry.getCostPerUnitLabels(costPerUnitLabels);
		
		i		:=	1;
		iter	:=	costPerUnitLabels.createIterator();
		
		while iter.next(costPerUnitLabel) do	
			create extractLine transient;
			extractLine[10]	:=	null;			
			extractLine[1]	:=	debtorGroup;
			extractLine[2]	:=	debtorName;
			extractLine[3]	:=	derivedDebtorCode;
			extractLine[4]	:=	isOverRidingValue.getYesNo;
			extractLine[5]	:=	serviceName;
			extractLine[6]	:=	effectiveDate;
			extractLine[7]	:=	effectiveTime;
			extractLine[8]	:=	expiryDate;
			extractLine[9]	:=	expiryTime;
			
			if costPerUnitLabel = serviceName then
				extractLine[10]	:=	null;
			else
				extractLine[10]	:=	costPerUnitLabel;	// Non-null will indicate a multi-line rate.
			endif;
			
			if calcType = INV_CALC_TYPE_DAYSINCE_SUBTERM then	//29 Jun 2018	NDL	TFS 39338
				subTerm := rateEntry.getMyTerminal.allSubTerminals.getMatchingDesc( costPerUnitLabel );
				extractLine[11] :=	rateEntry.getCPUforObject( subTerm ).String;
				
			elseif calcType = INV_CALC_TYPE_TIDAL_CLASS then	//29 Jun 2018	NDL	TFS 39338
				tidalClass := app.myRoot.allTidalClasses.getMatchingDesc( costPerUnitLabel );
				extractLine[11] :=	rateEntry.getCPUforObject( tidalClass ).String;
				
			else
				if rateEntry.allCostPerUnits.size &lt; i then 
					extractLine[11]	:=	"0";
				else
					extractLine[11]	:=	rateEntry.allCostPerUnits[i].String;
				endif;
			endif;
			
			extractLine[12]	:=	glCode;	
			_file.writeLine(extractLine.asCSV(true));	
			delete extractLine;
			i	:=	i + 1;
		endwhile;
		
		delete iter;			
	endif;
	
epilog
	delete costPerUnitLabels;
	delete extractLine;
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_effectiveDate" type="Date"/>
        <Parameter name="_debtorNode" type="CM_DebtorNode" usage="input"/>
        <Parameter name="_service" type="CM_Service" usage="input"/>
        <Parameter name="_file" type="File" usage="input"/>
    </JadeMethod>
    <JadeMethod name="extractRates" id="78134901-ab65-4d21-af66-e222b4508ff6">
        <source>extractRates(_effectiveDate : Date; _debtors : ObjectArray; _services : ObjectArray; _file : File input; _progress : CMS_Progress input);
// Aug 2012 from 30204 moved from INV_RateTable
vars
	obj : Object;
	dn : CM_DebtorNode;
	
begin
	if _file = null then
		return;
	endif;
	
	_file.writeLine('"Row Type","Debtor name","Debtor Code","Override flag","Service name","Effective Date","Effective time","Expiry Date","Expiry time","Cost per unit","All unit costs","GL code"');
	
	foreach obj in _debtors do
		dn := obj.CM_DebtorNode;
		self.extractRateDebtor(_effectiveDate, dn, _services, _file, _progress);
	endforeach;
	
	if _progress &lt;&gt; null then
		_progress.progress.partsDone := _progress.progress.partsInJob;
		_progress.doWindowEvents(0);
	endif;
end;
</source>
        <Parameter name="_effectiveDate" type="Date"/>
        <Parameter name="_debtors" type="ObjectArray"/>
        <Parameter name="_services" type="ObjectArray"/>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_progress" type="CMS_Progress" usage="input"/>
    </JadeMethod>
    <JadeMethod name="extractServiceObject" id="e912f96a-aa8a-4dba-9bfa-b39d014cda72">
        <source>extractServiceObject(_file : File input; _serviceObj : CM_ServiceObject) protected;

/*

Purpose:	extract the given debtor node plus all children		

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2012	cnwjre1	Initial creation for DOHA copy from test to UAT
15 Dec 2023 navbs1  ChangeRequest 61770: SAL - Service Schedule Data

*/

vars
	msg		: String;
	service	: CM_Service;
	serviceGroup	: CM_ServiceGroup;
	child	: CM_ServiceObject;

begin
	msg := '&lt;service class="' &amp; _serviceObj.class.name &amp; '"&gt;';
	_file.writeLine(msg);
	msg := self.formatAsXML("name", _serviceObj.name);
	_file.writeLine(msg);
	msg := self.formatAsXML("remarks", _serviceObj.remarks);
	_file.writeLine(msg);
	msg := self.formatAsXML("isNotAvailableForEntry", _serviceObj.isNotAvailableForEntry.String);
	_file.writeLine(msg);
	if _serviceObj.genLCode &lt;&gt; null then
		msg := self.formatAsXML("genLCode", _serviceObj.genLCode.code);
		_file.writeLine(msg);
	endif;
	if _serviceObj.myTaxCode &lt;&gt; null then
		msg := self.formatAsXML("taxCode", _serviceObj.myTaxCode.code);
		_file.writeLine(msg);
	endif;
	if _serviceObj.isKindOf(CM_Service) then
		service := _serviceObj.CM_Service;
		msg := self.formatAsXML("chargeByOpCon", service.chargeByOpCon.String);
		_file.writeLine(msg);
		msg := self.formatAsXML("chargeByUnits", service.chargeByUnits.String);
		_file.writeLine(msg);
		msg := self.formatAsXML("defaultRateTable", service.defaultRateTable.String);
		_file.writeLine(msg);
		if service.myCalculationType &lt;&gt; null then
			msg := self.formatAsXML("calculationType", service.myCalculationType.code);
			_file.writeLine(msg);
		endif;
		msg := self.formatAsXML("externalReference1", service.externalReference1);    		//15.12.2023 navbs1 #61770 
		_file.writeLine(msg);
		msg := self.formatAsXML("externalReference2", service.externalReference2);    		//15.12.2023 navbs1 #61770 
		_file.writeLine(msg);
	endif;

	if _serviceObj.isKindOf(CM_ServiceGroup) then
		serviceGroup := _serviceObj.CM_ServiceGroup;
		if not serviceGroup.groupMembers.isEmpty() then
			msg := '&lt;children&gt;';
			_file.writeLine(msg);
			foreach child in serviceGroup.groupMembers do
				self.extractServiceObject(_file, child);
			endforeach;
			msg := '&lt;/children&gt;';
			_file.writeLine(msg);
		endif;
	endif;

	msg := '&lt;/service&gt;';
	_file.writeLine(msg);
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_serviceObj" type="CM_ServiceObject"/>
    </JadeMethod>
    <JadeMethod name="extractServicePaymentTypes" id="acde8df4-307b-4ca8-ae66-314ab7cf7c53">
        <source>extractServicePaymentTypes(_file : File input; _bank : CM_Bank input) : Integer;
/*
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2018	jlgndl1	Initial creation	TFS 42060

*/

vars

	servicePayTypeMapping : CM_ServicePayTypeMapping;
	count : Integer;
	msg : String;

begin

	msg := '&lt;servicePaymentTypeMappings&gt;';
	_file.writeLine(msg);
	
	foreach servicePayTypeMapping in _bank.allServicePayTypeMappings do
	
		count := count + 1;
		
		msg := '&lt;servicePaymentTypeMapping&gt;';
		_file.writeLine(msg);
		
		if servicePayTypeMapping.myDebtor &lt;&gt; null then
			msg := self.formatAsXML("myDebtorName", servicePayTypeMapping.myDebtor.name);
			_file.writeLine(msg);
		endif;
		
		if servicePayTypeMapping.myService &lt;&gt; null then
			msg := self.formatAsXML("myServiceName", servicePayTypeMapping.myService.name);
			_file.writeLine(msg);
		endif;
		
		msg := self.formatAsXML("paymentType", servicePayTypeMapping.paymentType.String);
		_file.writeLine(msg);
		
		msg := '&lt;/servicePaymentTypeMapping&gt;';
		_file.writeLine(msg);
	
	endforeach;
	
	msg := '&lt;/servicePaymentTypeMappings&gt;';
	_file.writeLine(msg);
	
	return count;

epilog

end;</source>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_bank" type="CM_Bank" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="extractServices" id="2ced4893-55a4-4095-9b36-dfa63320a356">
        <source>extractServices(_file : File input; _bank : CM_Bank input) : Integer;

/*

Purpose:		Extract all services keeping the service group/children relationships	

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2012	cnwjre1	Initial creation for DOHA copy from test to UAT

*/

vars
	rootSG : CM_ServiceGroup;

begin

	rootSG := _bank.getRootServiceGroup();

	self.extractServiceObject(_file, rootSG);
	
	return _bank.serviceObjects.size;
end;</source>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_bank" type="CM_Bank" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="extractShippingAgents" id="14702be9-6bca-4073-bfea-9707123bbf57">
        <source>extractShippingAgents(_file : File input);

/*

Purpose:		Extract all shipping agents

Parameters:			

Return Value:		


Date		Who		Reason
23 April 2012	cnwjre1	Initial creation for DOHA copy from test to UAT

*/

vars
	msg		: String;
	root	: CM_Root;
	agent	: CM_ShippingAgent;
begin
	root := CM_Root.firstInstance;

	msg := '&lt;agents&gt;';
	_file.writeLine(msg);
	foreach agent in root.allShippingAgentsByCode do
		msg := '&lt;shippingAgent&gt;';
		_file.writeLine(msg);
		msg := self.formatAsXML("code", agent.code);
		_file.writeLine(msg);
		msg := self.formatAsXML("description", agent.description);
		_file.writeLine(msg);
		msg := self.formatAsXML("notAvailableForEntry", agent.notAvailableForEntry.String);
		_file.writeLine(msg);
		// do contacts as well if needed
		msg := '&lt;/shippingAgent&gt;';
		_file.writeLine(msg);
	endforeach;
	msg := '&lt;/agents&gt;';
	_file.writeLine(msg);

end;</source>
        <Parameter name="_file" type="File" usage="input"/>
    </JadeMethod>
    <JadeMethod name="extractStorageConfiguration" id="8f64c60c-6445-4ec9-b8a3-11d047275ed3">
        <source>extractStorageConfiguration(_file : File input; _terminal : CM_Terminal input):Integer;
/*
Purpose:			
Date		Who		Reason
03 July 2017	cnwab1	Initial creation
21 Jul 2017		cnwma1	TFS #5409:STWO - Storage Slab Auto Commercial Hold
14/06/2023		navkc1	CR 58024 Task 58025: JADE - Storage Config - Future Storage Mapping Import Export
16/06/2023		navkc1	CR 58221 Task 58222: UI - Ownership Change Free Days
29/02/2023		navkc1 	CR 61899 Task 61903: Jade - Storage Extract
*/


vars
	count	: Integer;
	msg		: String;
	yaCriteria : CM_YACriteria;
	yact : CM_YACriteriaType;
	qtyMap : CM_QuantityMap;
	qtyRangeMap : CM_QuantityRangeMap;
	invLineMap	: CM_TranMapInvoiceLineMapping;
	qtyMapChild : CM_QuantityMap;					//14/06/2023	navkc1	CR 58024 Task 58025
	qtyRangeMapChild : CM_QuantityRangeMap;			//14/06/2023	navkc1	CR 58024 Task 58025
	invLineMapChild	: CM_TranMapInvoiceLineMapping;	//14/06/2023	navkc1	CR 58024 Task 58025
	obj : Object;
	strData: String;
	term : CM_Terminal;
	config : CM_StorageConfig;
	sdetail : CM_StorageDetail;
	fsm : CM_FutureStorageMapping;
	strigger : CM_StorageTrigger;
	allocCount  : Integer;
	fsStop :String;
	calendar : CM_Calendar;
begin
	
	term := _terminal;
	config := term.myStorageConfig;

	
	msg := '&lt;storageConfiguration&gt;';  								//Header
	_file.writeLine(msg);
	msg := self.formatAsXML("name","StorageConfig");  	 	//name
	_file.writeLine(msg);

				
	msg := self.formatAsXML("firstDayTimeCutoff", config.firstDayTimeCutoff .String);
	_file.writeLine(msg);
				
	msg := self.formatAsXML("includeFirstDay", config.includeFirstDay.String);
	_file.writeLine(msg);
				
	msg := self.formatAsXML("includeLastDay", config.includeLastDay.String);
	_file.writeLine(msg);
				
	msg := self.formatAsXML("shipReceivalType", config.shipReceivalType.String);
	_file.writeLine(msg);
				
	msg := self.formatAsXML("shipReleaseType", config.shipReleaseType.String);
	_file.writeLine(msg);
	
	//14/06/2023	navkc1	CR 58024 Task 58025
	msg := self.formatAsXML("truckReceivalType", config.roadReceivalType.String);
	_file.writeLine(msg);
	
	//14/06/2023	navkc1	CR 58024 Task 58025
	msg := self.formatAsXML("wagonReceivalType", config.railReceivalType.String);
	_file.writeLine(msg);
	
	//14/06/2023	navkc1	CR 58024 Task 58025
	msg := self.formatAsXML("childReceivalType", config.unpackReceivalType.String);
	_file.writeLine(msg);
	
	if config.myWorkingDaysCalendar &lt;&gt; null then
		msg := '&lt;myWorkingDaysCalendar&gt;';  								//Header
		_file.writeLine(msg);
		
			msg := '&lt;CM_Calendar&gt;';  								
			_file.writeLine(msg);
					
			msg := self.formatAsXML("code", config.myWorkingDaysCalendar.code.String);
			_file.writeLine(msg);
			
			msg := self.formatAsXML("description", config.myWorkingDaysCalendar.description.String);
			_file.writeLine(msg);
			
			msg := '&lt;/CM_Calendar&gt;';  								
			_file.writeLine(msg);
		
		msg := '&lt;/myWorkingDaysCalendar&gt;';  								
		_file.writeLine(msg);
	
	endif;
	
	//20 Sep 2017	NDL	TFS 7032
	if config.getMyCompulsoryCalendar &lt;&gt; null then
		msg := '&lt;myCompulsoryCalendar&gt;';  							
		_file.writeLine(msg);
		
			msg := '&lt;CM_Calendar&gt;';  								
			_file.writeLine(msg);
					
			msg := self.formatAsXML("code", config.getMyCompulsoryCalendar.code.String);
			_file.writeLine(msg);
			
			msg := self.formatAsXML("description", config.getMyCompulsoryCalendar.description.String);
			_file.writeLine(msg);
			
			msg := '&lt;/CM_Calendar&gt;';  								
			_file.writeLine(msg);
		
		msg := '&lt;/myCompulsoryCalendar&gt;';  								
		_file.writeLine(msg);
	
	endif;
	
	if not config.allStorageTriggers.isEmpty then
			msg := '&lt;allStorageTriggers&gt;';					//allStorageTriggers
			_file.writeLine(msg);
			
			foreach strigger in config.allStorageTriggers do
				msg := '&lt;CM_StorageTrigger&gt;';
				_file.writeLine(msg);
				
				
				msg := self.formatAsXML("attributeType", strigger.attributeType.String);
				_file.writeLine(msg);
				
				msg := self.formatAsXML("resetFreeStorageDays", strigger.resetFreeStorageDays.String);
				_file.writeLine(msg);
				
				
				msg := '&lt;/CM_StorageTrigger&gt;';
				_file.writeLine(msg);
			endforeach;
			
			
			
			msg := '&lt;/allStorageTriggers&gt;';					//allStorageTriggers
			_file.writeLine(msg);
	endif;	

	if not config.allYACriteriaTypes.isEmpty then
			msg := '&lt;allYACriteriaTypes&gt;';					//allStorageTriggers
			_file.writeLine(msg);
			
			foreach yact in config.allYACriteriaTypes do
				msg := '&lt;CM_YACriteriaType&gt;';
				_file.writeLine(msg);
				
				
				msg := self.formatAsXML("description", yact.description.String);
				_file.writeLine(msg);
				
				msg := self.formatAsXML("isUsed", yact.isUsed.String);
				_file.writeLine(msg);
				
				msg := self.formatAsXML("type", yact.type.String);
				_file.writeLine(msg);
				
				
				msg := '&lt;/CM_YACriteriaType&gt;';
				_file.writeLine(msg);
			endforeach;
			
			
			
			msg := '&lt;/allYACriteriaTypes&gt;';					//allStorageTriggers
			_file.writeLine(msg);
	endif;	
	
	if not config.allStorageDetails.isEmpty then
			msg := '&lt;allStorageDetails&gt;';					//allStorageDetails
			_file.writeLine(msg);
			
			foreach sdetail in config.allStorageDetails do
				allocCount := allocCount +1;
				msg := '&lt;CM_StorageDetail&gt;';
				_file.writeLine(msg);
				
				
				msg := self.formatAsXML("chargeDays", sdetail.chargeDays.String);
				_file.writeLine(msg);
				
				msg := self.formatAsXML("chargedDaysType", sdetail.chargedDaysType.String);
				_file.writeLine(msg);
				
				msg := self.formatAsXML("chargedDaysWorking", sdetail.chargedDaysWorking.String);
				_file.writeLine(msg);
				
				msg := self.formatAsXML("freeDaysType", sdetail.freeDaysType.String);
				_file.writeLine(msg);
				
				msg := self.formatAsXML("freeDaysWorking", sdetail.freeDaysWorking.String);
				_file.writeLine(msg);
				
				msg := self.formatAsXML("freeStorageDays", sdetail.freeStorageDays.String);
				_file.writeLine(msg);
				
				msg := self.formatAsXML("noCharge", sdetail.noCharge.String);
				_file.writeLine(msg);
				
				msg := self.formatAsXML("noStorageIfNotFullyReceived", sdetail.noStorageIfNotFullyReceived.String);
				_file.writeLine(msg);
				
				msg := self.formatAsXML("receivalDateRule", sdetail.receivalDateRule.String);
				_file.writeLine(msg);
				
				msg := self.formatAsXML("stopCompletionFreeDays", sdetail.stopCompletionFreeDays.String);
				_file.writeLine(msg);
				
				//21.07.2017 cnwma1 TFS #5409
				if sdetail.myFutureStorageStop&lt;&gt;null then
					fsStop :=sdetail.myFutureStorageStop.id.String;
				else
					fsStop:="";
				endif;
				msg := self.formatAsXML("futureStorageStop", fsStop.String);
				_file.writeLine(msg);
				//21.07.2017 cnwma1 TFS #5409
				
				msg := self.formatAsXML("allowMultiRangeSplit", sdetail.allowMultiRangeSplit.String);
				_file.writeLine(msg);
				
				msg := self.formatAsXML("allowOthersOption", sdetail.allowOthersOption.String);
				_file.writeLine(msg);
				
				msg := self.formatAsXML("code", sdetail.code.String);
				_file.writeLine(msg);
				
				msg := self.formatAsXML("color", sdetail.color.String);
				_file.writeLine(msg);
			
				msg := self.formatAsXML("description", sdetail.description.String);
				_file.writeLine(msg);
								
				msg := self.formatAsXML("expiryDate", sdetail.expiryDate.String);
				_file.writeLine(msg);
				
				msg := self.formatAsXML("expiryType", sdetail.expiryType.String);
				_file.writeLine(msg);
				
				//14/06/2023	navkc1	CR 58024 Task 58025
				msg := self.formatAsXML("detailTruckReceivalType", sdetail.roadReceivalType.String);
				_file.writeLine(msg);
				
				//14/06/2023	navkc1	CR 58024 Task 58025
				msg := self.formatAsXML("detailShipReceivalType", sdetail.shipReceivalType.String);
				_file.writeLine(msg);
				
				//14/06/2023	navkc1	CR 58024 Task 58025
				msg := self.formatAsXML("detailWagonReceivalType", sdetail.railReceivalType.String);
				_file.writeLine(msg);
				
				//14/06/2023	navkc1	CR 58024 Task 58025
				msg := self.formatAsXML("detailChildReceivalType", sdetail.unpackReceivalType.String);
				_file.writeLine(msg);
				
				//16/06/2023	navkc1	CR 58221 Task 58222
				msg := self.formatAsXML("cooFreeDays", sdetail.cooFreeStorageDays.String);
				_file.writeLine(msg);
				
				//16/06/2023	navkc1	CR 58221 Task 58222
				msg := self.formatAsXML("cooFreeDaysType", sdetail.cooFreeDaysType.String);
				_file.writeLine(msg);
				
				//29/02/2023	navkc1 CR 61899 Task 61903
				msg := self.formatAsXML("stoDtlIncludeFirstDay", sdetail.includeFirstDay.String);
				_file.writeLine(msg);
				
				//29/02/2023	navkc1 CR 61899 Task 61903
				msg := self.formatAsXML("stoDtlIncludeLastDay", sdetail.includeLastDay.String);
				_file.writeLine(msg);
				
				if not sdetail.allCriteria.isEmpty then
					msg := '&lt;allCriteria&gt;';
					_file.writeLine(msg);
					foreach yaCriteria in sdetail.allCriteria do 
						msg := '&lt;CM_YACriteria&gt;';
						_file.writeLine(msg);
						msg := self.formatAsXML("myYACriteriaType", yaCriteria.myYACriteriaType.type.String);
						_file.writeLine(msg);
						if yaCriteria.myYAData &lt;&gt; null then
							if yaCriteria.myYAData.isKindOf(CM_YADataBoolean) then
								msg := self.formatAsXML("myYAData", yaCriteria.myYAData.CM_YADataBoolean.getDataValue().asStringJMT);
							elseif yaCriteria.myYACriteriaType.isKindOf(CM_YATypeProduct) then
								strData :=null;
								foreach obj in yaCriteria.myYAData.CM_YADataObjects.allObjects do
										strData := obj.CM_Product.getYAIdentifier &amp;"," &amp; strData; 
								endforeach;
								strData:=strData.truncatedAt(strData.length-1);
								msg := self.formatAsXML("myYAData", strData.toUpper);
							
							elseif yaCriteria.myYACriteriaType.isKindOf(CM_YATypeContentsStatus) then
								strData :=null;
								foreach obj in yaCriteria.myYAData.CM_YADataObjects.allObjects do
										strData := obj.CM_ContentsStatus.getYAIdentifier &amp;"," &amp; strData; 
								endforeach;
								strData:=strData.truncatedAt(strData.length-1);
								msg := self.formatAsXML("myYAData", strData.toUpper);
								
							elseif yaCriteria.myYACriteriaType.isKindOf(CM_YATypeSrcTermAreaType) then
								strData :=null;
								foreach obj in yaCriteria.myYAData.CM_YADataObjects.allObjects do
										strData := obj.CM_TerminalAreaType.getYAIdentifier &amp;"," &amp; strData; 
								endforeach;
								strData:=strData.truncatedAt(strData.length-1);
								msg := self.formatAsXML("myYAData", strData.toUpper);
							
							elseif yaCriteria.myYACriteriaType.isKindOf(CM_YATypeSrcTermArea) then
								strData :=null;
								foreach obj in yaCriteria.myYAData.CM_YADataObjects.allObjects do
										strData := obj.CM_TerminalArea.getYAIdentifier &amp;"," &amp; strData; 
								endforeach;
								strData:=strData.truncatedAt(strData.length-1);
								msg := self.formatAsXML("myYAData", strData.toUpper);
							
							elseif yaCriteria.myYACriteriaType.isKindOf(CM_YATypeStops) then
								strData :=null;
								foreach obj in yaCriteria.myYAData.CM_YADataObjects.allObjects do
										strData := obj.CM_StopsTable.getYAIdentifier &amp;"," &amp; strData; 
								endforeach;
								strData:=strData.truncatedAt(strData.length-1);
								msg := self.formatAsXML("myYAData", strData.toUpper);
						
							elseif yaCriteria.myYACriteriaType.isKindOf(CM_YATypeToDoTasks) then
								strData :=null;
								foreach obj in yaCriteria.myYAData.CM_YADataObjects.allObjects do
										strData := obj.CM_ToDoTaskDesc.getYAIdentifier &amp;"," &amp; strData; 
								endforeach;
								strData:=strData.truncatedAt(strData.length-1);
								msg := self.formatAsXML("myYAData", strData.toUpper);	
							else
								msg := self.formatAsXML("myYAData", yaCriteria.myYAData.getDataDisplay(yaCriteria.myYACriteriaType).toUpper);
							endif;
							_file.writeLine(msg);
						endif;
						if yaCriteria.myYAData &lt;&gt; null then
							msg := self.formatAsXML("priorityValue", yaCriteria.priorityValue.String);
							_file.writeLine(msg);
						endif;
						if yaCriteria.myYAData &lt;&gt; null then
							msg := self.formatAsXML("code", yaCriteria.code);
							_file.writeLine(msg);
						endif;
						
						msg := '&lt;/CM_YACriteria&gt;';
						_file.writeLine(msg);
					endforeach;
					msg := '&lt;/allCriteria&gt;';
					_file.writeLine(msg);
				endif;
				
				if not sdetail.allFutureStorageMappings.isEmpty then
					msg := '&lt;allFutureStorageMappings&gt;';
					_file.writeLine(msg);
					
					foreach fsm in sdetail.allFutureStorageMappings do
						msg := '&lt;CM_FutureStorageMapping&gt;';
						_file.writeLine(msg);
					
						if fsm.myQuantityMap &lt;&gt; null then
							qtyMap := fsm.myQuantityMap;
							msg := '&lt;CM_QuantityMap&gt;';
							_file.writeLine(msg);
							msg := self.formatAsXML("chargeZero", qtyMap.chargeZero.String);
							_file.writeLine(msg);
							msg := self.formatAsXML("mappingType", qtyMap.mappingType.String);
							_file.writeLine(msg);
							if qtyMap.myCalculationType &lt;&gt; null then
								msg := self.formatAsXML("myCalculationType", qtyMap.myCalculationType.code.String);
							else
								msg := self.formatAsXML("myCalculationType", null);
							endif;
							_file.writeLine(msg);
							
							if not qtyMap.allQuantityRanges.isEmpty then
								msg := '&lt;allQuantityRanges&gt;';
								_file.writeLine(msg);
								
								foreach qtyRangeMap in qtyMap.allQuantityRanges do
									msg := '&lt;CM_QuantityRangeMap&gt;';
									_file.writeLine(msg);
									msg := self.formatAsXML("rangeStart",qtyRangeMap.rangeStart.String);
									_file.writeLine(msg);
									
									msg := self.formatAsXML("rangeEnd",qtyRangeMap.rangeEnd.String);
									_file.writeLine(msg);
									
									msg := self.formatAsXML("rangeType",qtyRangeMap.rangeType.String);
									_file.writeLine(msg);
									
									if not qtyRangeMap.allTMInvoiceLineMappings.isEmpty then
										msg := '&lt;allTMInvoiceLineMappings&gt;';
										_file.writeLine(msg);
										foreach invLineMap in  qtyRangeMap.allTMInvoiceLineMappings do
											msg := '&lt;CM_TranMapInvoiceLineMapping&gt;';
											_file.writeLine(msg);
											msg := self.formatAsXML("mapValue",invLineMap.mapValue.String);
											_file.writeLine(msg);
											if invLineMap.myTMInvoiceLineDesc &lt;&gt; null then
												msg := self.formatAsXML("myTMInvoiceLineDesc",invLineMap.myTMInvoiceLineDesc.narration.String);
												_file.writeLine(msg);
											endif;
											
											if invLineMap.myTMInvoiceLineGroupType &lt;&gt; null then
												
												msg := '&lt;CM_TranMapInvoiceLineGroupType&gt;';
												_file.writeLine(msg);
												msg := self.formatAsXML("type",invLineMap.myTMInvoiceLineGroupType.type.String);
												_file.writeLine(msg);
												
												msg := self.formatAsXML("name",invLineMap.myTMInvoiceLineGroupType.name.String);
												_file.writeLine(msg);
												msg := '&lt;/CM_TranMapInvoiceLineGroupType&gt;';
												_file.writeLine(msg);
												
											endif;
											msg := '&lt;/CM_TranMapInvoiceLineMapping&gt;';
										   _file.writeLine(msg);
												
										endforeach;
										msg := '&lt;/allTMInvoiceLineMappings&gt;';
										_file.writeLine(msg);
									endif;
									
									//14/06/2023	navkc1	CR 58024 Task 58025 - Child Quantity Map
									qtyMapChild := qtyRangeMap.myChildQuantityMap;
									
									if qtyMapChild &lt;&gt; null then
										msg := '&lt;CM_QuantityMapSub&gt;';
										_file.writeLine(msg);
										msg := self.formatAsXML("chargeZero", qtyMapChild.chargeZero.String);
										_file.writeLine(msg);
										msg := self.formatAsXML("mappingType", qtyMapChild.mappingType.String);
										_file.writeLine(msg);
										
										if qtyMapChild.myCalculationType &lt;&gt; null then
											msg := self.formatAsXML("myCalculationType", qtyMapChild.myCalculationType.code.String);
										else
											msg := self.formatAsXML("myCalculationType", null);
										endif;
										_file.writeLine(msg);
										
										// Child map ranges
										if not qtyMapChild.allQuantityRanges.isEmpty() then
											msg := '&lt;allQuantitySubRanges&gt;';
											_file.writeLine(msg);
											
											foreach qtyRangeMapChild in qtyMapChild.allQuantityRanges do
												msg := '&lt;CM_QuantityRangeMap&gt;';
												_file.writeLine(msg);
												msg := self.formatAsXML("rangeStart",qtyRangeMapChild.rangeStart.String);
												_file.writeLine(msg);
												msg := self.formatAsXML("rangeEnd",qtyRangeMapChild.rangeEnd.String);
												_file.writeLine(msg);
												msg := self.formatAsXML("rangeType",qtyRangeMapChild.rangeType.String);
												_file.writeLine(msg);
												
												if not qtyRangeMapChild.allTMInvoiceLineMappings.isEmpty then
													msg := '&lt;allTMInvoiceLineMappings&gt;';
													_file.writeLine(msg);
													
													// Child Map Ranges Invoice Map
													foreach invLineMapChild in  qtyRangeMapChild.allTMInvoiceLineMappings do
														msg := '&lt;CM_TranMapInvoiceLineMapping&gt;';
														_file.writeLine(msg);
														msg := self.formatAsXML("mapValue",invLineMapChild.mapValue.String);
														_file.writeLine(msg);
														
														if invLineMapChild.myTMInvoiceLineDesc &lt;&gt; null then
															msg := self.formatAsXML("myTMInvoiceLineDesc",invLineMapChild.myTMInvoiceLineDesc.narration.String);
															_file.writeLine(msg);
														endif;
														
														if invLineMapChild.myTMInvoiceLineGroupType &lt;&gt; null then
															msg := '&lt;CM_TranMapInvoiceLineGroupType&gt;';
															_file.writeLine(msg);
															msg := self.formatAsXML("type",invLineMapChild.myTMInvoiceLineGroupType.type.String);
															_file.writeLine(msg);
															msg := self.formatAsXML("name",invLineMapChild.myTMInvoiceLineGroupType.name.String);
															_file.writeLine(msg);
															msg := '&lt;/CM_TranMapInvoiceLineGroupType&gt;';
															_file.writeLine(msg);
														endif;
														msg := '&lt;/CM_TranMapInvoiceLineMapping&gt;';
													   _file.writeLine(msg);
													endforeach;
													msg := '&lt;/allTMInvoiceLineMappings&gt;';
													_file.writeLine(msg);
												endif;
												msg := '&lt;/CM_QuantityRangeMap&gt;';
												_file.writeLine(msg);
											endforeach;
											msg := '&lt;/allQuantitySubRanges&gt;';
											_file.writeLine(msg);
										endif;
										msg := '&lt;/CM_QuantityMapSub&gt;';
										_file.writeLine(msg);												
									endif;
									//14/06/2023	navkc1	CR 58024 Task 58025 - Child Map end
									msg := '&lt;/CM_QuantityRangeMap&gt;';
									_file.writeLine(msg);
								endforeach;
									
								msg := '&lt;/allQuantityRanges&gt;';
								_file.writeLine(msg);
							endif;
							msg := '&lt;/CM_QuantityMap&gt;';
							_file.writeLine(msg);
						endif;
							
						if fsm.myStorageGroup &lt;&gt; null then
							msg := '&lt;CM_TerminalAreaStorageGroup&gt;';
							_file.writeLine(msg);
							
					
							msg := self.formatAsXML("code", fsm.myStorageGroup.code.String);
							_file.writeLine(msg);
						
							msg := self.formatAsXML("description", fsm.myStorageGroup.description.String);
							_file.writeLine(msg);
									
							
							
							msg := '&lt;/CM_TerminalAreaStorageGroup&gt;';
							_file.writeLine(msg);
						
						endif;
						
						msg := '&lt;/CM_FutureStorageMapping&gt;';
						_file.writeLine(msg);
						
					endforeach;
					
					msg := '&lt;/allFutureStorageMappings&gt;';
					_file.writeLine(msg);
				endif;	
				// //14/06/2023	navkc1	CR 58024 Task 58025 Additional Calendars in Storage Details
				msg := '&lt;allAdditionalCalendars&gt;';
				_file.writeLine(msg);
				
				foreach calendar in sdetail.allAdditionalCalendars discreteLock do
					msg := '&lt;CM_Calendar&gt;';
					_file.writeLine(msg);
					
					msg := self.formatAsXML("code", calendar.code.String);
					_file.writeLine(msg);
					
					msg := self.formatAsXML("description", calendar.description.String);
					_file.writeLine(msg);
					
					msg := '&lt;/CM_Calendar&gt;';
					_file.writeLine(msg);
				endforeach;
				
				msg := '&lt;/allAdditionalCalendars&gt;';
				_file.writeLine(msg);
				// //14/06/2023	navkc1	CR 58024 Task 58025 Additional Calendars in Storage Details End
				
				msg := '&lt;/CM_StorageDetail&gt;';
				_file.writeLine(msg);
			endforeach;
			msg := '&lt;/allStorageDetails&gt;';
			_file.writeLine(msg);
	endif;
	msg := '&lt;/storageConfiguration&gt;';
	_file.writeLine(msg);

	count := allocCount;
	
	return count;
epilog

end;</source>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="extractSurcharges" id="e987c7b9-023a-48a3-aa19-606c73a9d003">
        <source>extractSurcharges(_file : File input; _bank : CM_Bank input) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 December 2018	jlgndl1	Initial creation	TFS 42061

*/

vars
	count	: Integer;
	msg		: String;

	invType : CM_InvoiceDesc;
	invTypeSurchargeExempt : CM_InvoiceTypeSurchargeExempt;
	invalid : Boolean;
	edition : Integer;
	currency : CM_CurrencyType;
	myMinChargeInvLineType  : CM_InvoiceLineDesc;
	drSurchargeRate : CM_DebtorSurchargeRate;
	externalTax : CM_InvoiceTypeExternalTax;
	additionalFee : CM_InvTypeAdditionalCharges;
	addFeeInvLineType  : CM_InvoiceLineDesc;
	cargoSurcharge : CM_InvTypeCargoSurcharge;
	cargoSurcahrgeInvLineType  : CM_InvoiceLineDesc;
	vesselMinCharge : CM_InvTypeVesselMinCharge;
	drMinCharge : CM_InvTypeDebtorMinCharge;
	pilotSurcharge : CM_InvTypePilotSurcharge;
	
begin

	on Exception do app.handleDeletedObject( exception, invTypeSurchargeExempt, invalid);

	msg := '&lt;invoiceTypeSurcharges&gt;';
	_file.writeLine(msg);
	
	foreach invType in _bank.invoiceTypes do
	
		invTypeSurchargeExempt := invType.mySurchargeAndExemptions;
		if invTypeSurchargeExempt = null then
			continue;
		endif;
		edition := invTypeSurchargeExempt.edition;
		if invalid then
			invalid := false;
			continue;
		endif;
		
		currency := invTypeSurchargeExempt.myCurrencyType;
		myMinChargeInvLineType := invTypeSurchargeExempt.myMinimumChargeInvoiceLineType;
		
		count := count + 1;
		
		msg := '&lt;invType&gt;';
		_file.writeLine(msg);
		
		msg := self.formatAsXML("myInvoiceTypeDescription", invType.description.String);
		_file.writeLine(msg);
		msg := self.formatAsXML("minimumChargeAmount", invTypeSurchargeExempt.minimumChargeAmount.String);
		_file.writeLine(msg);
		if currency &lt;&gt; null then
			msg := self.formatAsXML("myCurrencyTypeCode", currency.code.String);
			_file.writeLine(msg);
		endif;
		if myMinChargeInvLineType &lt;&gt; null then
			msg := self.formatAsXML("myMinChargeInvLineTypeNarr", myMinChargeInvLineType.narration.String);
			_file.writeLine(msg);
		endif;
		//07 May 2019	NDL	TFS 44651
		if invTypeSurchargeExempt.myInvoiceDescForSeperateTax &lt;&gt; null then
			msg := self.formatAsXML("mySepTaxInvTypeDesc", invTypeSurchargeExempt.myInvoiceDescForSeperateTax.description);
			_file.writeLine(msg);
		endif;
		
		
		if not invTypeSurchargeExempt.allDebtorSurchargeRates.isEmpty() then
			msg := '&lt;drSurchargeRates&gt;';
			_file.writeLine(msg);
			foreach drSurchargeRate in invTypeSurchargeExempt.allDebtorSurchargeRates do
				if drSurchargeRate.myDebtor = null or drSurchargeRate.mySurchargeInvoiceLineType = null then
					continue;
				endif;
				msg := '&lt;drSurchargeRateObj&gt;';
				_file.writeLine(msg);
				msg := self.formatAsXML("drSurchargeDebtorName", drSurchargeRate.myDebtor.name);
				_file.writeLine(msg);
				msg := self.formatAsXML("drSurchargeRate", drSurchargeRate.surchargeRate.String);
				_file.writeLine(msg);
				msg := self.formatAsXML("drSurchargeInvLineTypeNarr", drSurchargeRate.mySurchargeInvoiceLineType.narration);
				_file.writeLine(msg);
				msg := '&lt;/drSurchargeRateObj&gt;';
				_file.writeLine(msg);
			endforeach;
			msg := '&lt;/drSurchargeRates&gt;';
			_file.writeLine(msg);
		endif;
		
		if not invTypeSurchargeExempt.allInvTypeExternalTax.isEmpty() then
			msg := '&lt;externalTaxs&gt;';
			_file.writeLine(msg);
			foreach externalTax in invTypeSurchargeExempt.allInvTypeExternalTax do
				if externalTax.myDebtor = null then
					continue;
				endif;
				msg := '&lt;externalTax&gt;';
				_file.writeLine(msg);
				msg := self.formatAsXML("extTaxDebtorName", externalTax.myDebtor.name);
				_file.writeLine(msg);
				msg := self.formatAsXML("extTaxCode", externalTax.externalTaxCode);
				_file.writeLine(msg);
				msg := self.formatAsXML("extTaxRule", externalTax.externalTaxRule.String);
				_file.writeLine(msg);
				msg := self.formatAsXML("extTaxRangeStart", externalTax.rangeStart.String);
				_file.writeLine(msg);
				msg := self.formatAsXML("extTaxRangeEnd", externalTax.rangeEnd.String);
				_file.writeLine(msg);
				msg := '&lt;/externalTax&gt;';
				_file.writeLine(msg);
			endforeach;
			msg := '&lt;/externalTaxs&gt;';
			_file.writeLine(msg);
		endif;
		
		if not invTypeSurchargeExempt.allInvTypeAdditionalCharges.isEmpty() then
			msg := '&lt;additionalFees&gt;';
			_file.writeLine(msg);
			foreach additionalFee in invTypeSurchargeExempt.allInvTypeAdditionalCharges do
				if additionalFee.myDebtor = null or additionalFee.allAdditionChargeInvTypes.isEmpty then
					continue;
				endif;
				msg := '&lt;additionalFee&gt;';
				_file.writeLine(msg);
				msg := self.formatAsXML("addFeeDebtorName", additionalFee.myDebtor.name);
				_file.writeLine(msg);
				msg := self.formatAsXML("addFeeRangeStart", additionalFee.rangeStart.String);
				_file.writeLine(msg);
				msg := self.formatAsXML("addFeeRangeEnd", additionalFee.rangeEnd.String);
				_file.writeLine(msg);
				msg := '&lt;addFeeLineTypes&gt;';
				_file.writeLine(msg);
				foreach addFeeInvLineType in additionalFee.allAdditionChargeInvTypes do	
					msg := self.formatAsXML("addFeeInvLineTypeNarr", addFeeInvLineType.narration);
					_file.writeLine(msg);	
				endforeach;
				msg := '&lt;/addFeeLineTypes&gt;';
				_file.writeLine(msg);
				msg := '&lt;/additionalFee&gt;';
			_file.writeLine(msg);
			endforeach;
			msg := '&lt;/additionalFees&gt;';
			_file.writeLine(msg);
		endif;
		
		if not invTypeSurchargeExempt.allInvTypeCargoSurcharges.isEmpty() then
			msg := '&lt;cargoSurcharges&gt;';
			_file.writeLine(msg);
			foreach cargoSurcharge in invTypeSurchargeExempt.allInvTypeCargoSurcharges do
 // ### TFS 51219 03JUN2021 NAVAB1				if cargoSurcharge.myCargoType = null 
 // ### TFS 51219 03JUN2021 NAVAB1				or cargoSurcharge.allSelectedInvLineTypes.isEmpty then
				if cargoSurcharge.allSelectedInvLineTypes.isEmpty then // ### TFS 51219 03JUN2021 NAVAB1 allow for ALL CARGO TYPES
					continue;
				endif;
				msg := '&lt;cargoSurcharge&gt;';
				_file.writeLine(msg);				
				if cargoSurcharge.myCargoSurchargeInvLineType &lt;&gt; null then
					msg := self.formatAsXML("cargoSurchgInvLineTypeNarrCreate", cargoSurcharge.myCargoSurchargeInvLineType.narration);
					_file.writeLine(msg);
				endif;			
				
				if cargoSurcharge.myCargoType = null then  // ### TFS 51219 03JUN2021 NAVAB1
					msg := self.formatAsXML("cargoSurchargeCargoTypeAbbr", "ALLCARGOTYPES"); // ### TFS 51219 03JUN2021 NAVAB1
				
				else
					msg := self.formatAsXML("cargoSurchargeCargoTypeAbbr", cargoSurcharge.myCargoType.abbreviation);
				endif;
				_file.writeLine(msg);
				if cargoSurcharge.mySubCargoType &lt;&gt; null then
					msg := self.formatAsXML("cargoSurchargeSubCargoTypeCode", cargoSurcharge.mySubCargoType.code);
					_file.writeLine(msg);
				endif;
				if cargoSurcharge.myCommodity &lt;&gt; null then
					msg := self.formatAsXML("cargoSurchargeCommCode", cargoSurcharge.myCommodity.code);
					_file.writeLine(msg);
				endif;
				msg := self.formatAsXML("cargoSurchargeRate", cargoSurcharge.surchargeRate.String);
				_file.writeLine(msg);
				msg := '&lt;cargoSurchargeLineTypes&gt;';
				_file.writeLine(msg);
				foreach cargoSurcahrgeInvLineType in cargoSurcharge.allSelectedInvLineTypes do	
					msg := self.formatAsXML("cargoSurchargeInvLineTypeNarr", cargoSurcahrgeInvLineType.narration);
					_file.writeLine(msg);	
				endforeach;
				msg := '&lt;/cargoSurchargeLineTypes&gt;';
				_file.writeLine(msg);
				msg := '&lt;/cargoSurcharge&gt;';
				_file.writeLine(msg);
			endforeach;
			msg := '&lt;/cargoSurcharges&gt;';
			_file.writeLine(msg);
		endif;
		
		if not invTypeSurchargeExempt.allInvTypeVesselMinCharges.isEmpty() then
			msg := '&lt;vesselMinCharges&gt;';
			_file.writeLine(msg);
			foreach vesselMinCharge in invTypeSurchargeExempt.allInvTypeVesselMinCharges do
				if vesselMinCharge.myVessel = null or vesselMinCharge.myMinimumChargeInvoiceLineType = null then
					continue;
				endif;
				msg := '&lt;vesselMinCharge&gt;';
				_file.writeLine(msg);
				msg := self.formatAsXML("vesselMinVesselName", vesselMinCharge.myVessel.name);
				_file.writeLine(msg);
				msg := self.formatAsXML("vesselMinChgAmount", vesselMinCharge.minimumChargeAmount.String);
				_file.writeLine(msg);
				msg := self.formatAsXML("vesselMinInvLineTypeNarr", vesselMinCharge.myMinimumChargeInvoiceLineType.narration);
				_file.writeLine(msg);
				msg := '&lt;/vesselMinCharge&gt;';
				_file.writeLine(msg);
			endforeach;
			msg := '&lt;/vesselMinCharges&gt;';
			_file.writeLine(msg);
		endif;
		
		if not invTypeSurchargeExempt.allInvTypeDebtorMinCharges.isEmpty() then
			msg := '&lt;drMinCharges&gt;';
			_file.writeLine(msg);
			foreach drMinCharge in invTypeSurchargeExempt.allInvTypeDebtorMinCharges do
				if drMinCharge.myDebtor = null or drMinCharge.myMinimumChargeInvoiceLineType = null then
					continue;
				endif;
				msg := '&lt;drMinCharge&gt;';
				_file.writeLine(msg);
				msg := self.formatAsXML("drMinDebtorName", drMinCharge.myDebtor.name);
				_file.writeLine(msg);
				msg := self.formatAsXML("drMinChgAmount", drMinCharge.minimumChargeAmount.String);
				_file.writeLine(msg);
				msg := self.formatAsXML("drMinInvLineTypeNarr", drMinCharge.myMinimumChargeInvoiceLineType.narration);
				_file.writeLine(msg);
				msg := '&lt;/drMinCharge&gt;';
				_file.writeLine(msg);
			endforeach;
			msg := '&lt;/drMinCharges&gt;';
			_file.writeLine(msg);
		endif;
		
		if not invTypeSurchargeExempt.allInvTypePilotSurcharges.isEmpty() then
			msg := '&lt;pilotSurcharges&gt;';
			_file.writeLine(msg);
			foreach pilotSurcharge in invTypeSurchargeExempt.allInvTypePilotSurcharges do
				if pilotSurcharge.myPilotSurchargeInvLineTypeRTS = null and pilotSurcharge.myPilotSurchargeInvLineTypeVNR = null then
					continue;
				endif;
				msg := '&lt;pilotSurcharge&gt;';
				_file.writeLine(msg);
				if pilotSurcharge.myPilotSurchargeInvLineTypeRTS &lt;&gt; null then
					msg := self.formatAsXML("rtsInvLineTypeNarr", pilotSurcharge.myPilotSurchargeInvLineTypeRTS.narration);
					_file.writeLine(msg);
				endif;
				if pilotSurcharge.myPilotSurchargeInvLineTypeVNR &lt;&gt; null then
					msg := self.formatAsXML("vnrInvLineTypeNarr", pilotSurcharge.myPilotSurchargeInvLineTypeVNR.narration);
					_file.writeLine(msg);
				endif;
				msg := '&lt;/pilotSurcharge&gt;';
				_file.writeLine(msg);
			endforeach;
			msg := '&lt;/pilotSurcharges&gt;';
			_file.writeLine(msg);
		endif;
		
		msg := '&lt;/invType&gt;';
		_file.writeLine(msg);
		
	endforeach;
	
	msg := '&lt;/invoiceTypeSurcharges&gt;';
	_file.writeLine(msg);
	
	return count;

end;</source>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_bank" type="CM_Bank" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="extractUserCargoConfig" id="d13d7eb9-fb0c-479e-91cb-b6305a123b9c">
        <source>extractUserCargoConfig(_file : File input; _user : CM_User; _cargoTypes : CM_CargoBOLTypeArray);
// 1776
constants
	Delim = ",";

vars
	heading		: String;
	cargoType	: CM_CargoBOLType;
	ucType		: CM_UserConfigCargoType;
	ucTab		: CM_UserConfigTab;
	ucAttr		: CM_UserConfigAttribute;
begin
	// file header
	_file.writeLine("User,Cargo Type Id, Cargo Type Description,Default,Tab name, Tab Description, Tab Type,Attribute Number,Attribute Description");
	// csv content
	foreach cargoType in _cargoTypes do
		ucType := _user.allUserCargoTypes[_user, cargoType];
		if ucType = null then
			_file.writeLine(_user.code.csvFormat() &amp; Delim &amp; cargoType.id.String &amp; Delim &amp; cargoType.description.csvFormat() &amp; Delim &amp; "true"
							&amp; Delim &amp; Delim &amp; Delim &amp; Delim &amp; Delim);
		else
			heading := ucType.myUser.code.csvFormat() &amp; Delim &amp; ucType.myCargoBOLType.id.String &amp; Delim
						&amp; ucType.myCargoBOLType.description.csvFormat() &amp; Delim &amp; "false";
			foreach ucTab in ucType.allUserConfigTabs do
				foreach ucAttr in ucTab.allAttributes do
					_file.writeLine(heading &amp; Delim &amp; ucTab.name.csvFormat() &amp; Delim &amp; ucTab.description.csvFormat() &amp; Delim &amp;
									ucTab.tabType.String &amp; Delim &amp; ucAttr.myEntTableRow.number.String &amp; Delim &amp;
									ucAttr.myEntTableRow.getHeadingUnaltered.csvFormat());
				endforeach;
			endforeach;
		endif;
	endforeach;

end;
</source>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_cargoTypes" type="CM_CargoBOLTypeArray"/>
    </JadeMethod>
    <JadeMethod name="extractVesselData" id="7a96249c-37e2-4701-864b-b4b62e6ffa5c">
        <source>extractVesselData(_vessel : CM_Vessel; _dirName : String) : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 03/04/2017	cnwdap1		Initial creation TFS 3930 LNX Bulk Vessel Extract
//
vars
	errMsg : String;
	xMLFile : File;
	fileName : String;

begin
	create xMLFile transient;
	//xMLFile.usePresentationFileSystem := false;
	fileName := _vessel.code;
	fileName.replaceChar("\", "_");
	fileName.replaceChar("/", "_");
	xMLFile.openOutput(_dirName &amp; fileName &amp; ".xml");
	
	if not xMLFile.isAvailable then
		errMsg := "File on the server could not be created for " &amp; _vessel.code &amp; " - file name was " &amp; xMLFile.fileName;
		
	else
		
		xMLFile.writeLine('&lt;?xml version="1.0"?&gt;');
		xMLFile.writeLine(J_key_LessThan.Character &amp; _vessel.class.name &amp; " " &amp; 'type="' &amp;  _vessel.class.name &amp; '"' &amp; J_key_GreaterThan.Character);
		_vessel.exportAsXMLDoc(xMLFile);
		xMLFile.writeString(self.formatAsXMLSuffix(_vessel.class.name));

	endif;
	
epilog
	if xMLFile &lt;&gt; null then
		xMLFile.close;
	endif;
	delete xMLFile;
	return errMsg;
end;</source>
        <Parameter name="_vessel" type="CM_Vessel"/>
        <Parameter name="_dirName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="formatAsXML" id="158ba98a-fcfa-4154-87fc-ad2ac2c9e6fc">
        <source>formatAsXML(_tag: String; _value: String): String;
// with XML entity replacement
vars
	work,
	result	: String;
begin
	work := _value.xmlReplaceReservedChars(true);
	result := '&lt;' &amp; _tag &amp; '&gt;' &amp; work &amp; '&lt;/' &amp; _tag &amp; '&gt;';
	return result;
end;
</source>
        <Parameter name="_tag" type="String"/>
        <Parameter name="_value" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
