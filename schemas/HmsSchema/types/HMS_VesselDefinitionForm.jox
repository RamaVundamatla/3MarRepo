    <JadeMethod name="clearForm" id="228b4ecd-1f16-4085-9e32-09029e57a5f0">
        <updating/>
        <source>clearForm() updating;
//-----------------------------------------
// Created: 6 April 2005 By: cnwgd1
//-----------------------------------------
vars
	int:	Integer;
	ctl:	Control;
begin
	int:=1;
	while int&lt;=self.controlCount do
		ctl:=controls(int);
		if ctl.isKindOf(TextBox) then
			ctl.TextBox.text := null;
		elseif ctl.isKindOf(CheckBox) then
			ctl.CheckBox.value := false;		
		endif;
		int := int+1;
	endwhile;
	self.tblBasicDimension.rows := 1;
	self.tblKeyDistances.rows := 1;
	self.picShipBitmap.picture := null;
	self.tblPrefBerth.rows := 1;
	self.allClonedControls.purge;
	newIndex := 1;

end;</source>
    </JadeMethod>
