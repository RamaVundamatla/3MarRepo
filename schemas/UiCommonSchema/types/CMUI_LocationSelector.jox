    <JadeMethod name="getMoveMethodRule" id="5ce113bc-df1f-4a54-9f4d-61a0c324f560">
        <source>getMoveMethodRule() : CM_RTMoveMethodRule;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 March 2011	cnwer1	Initial creation

*/

vars

begin
	if not self.frmMoveMethod.visible then
		return null;
	endif;
	
	if not self.cmbMoveMethod.visible then
		return null;
	endif;
	
	return self.cmbMoveMethod.listObject.CM_RTMoveMethodRule;
epilog

end;</source>
        <ReturnType type="CM_RTMoveMethodRule"/>
    </JadeMethod>
    <JadeMethod name="initForm" id="51b95ee7-f36d-43b6-8831-a0711c857aca">
        <updating/>
        <source>initForm(	_location,
			_twinLocation : CM_LocationsController;
			_id,
			_twinId : String;
			_ti,
			_twinTI		: CM_TrackedItem;
			_isTarget : Boolean;
			_isDirectorTask : Boolean;
			_allFilterInterchangeAreas : CM_TerminalAreaSet;
			_rtQueueEntry : CM_RTQueueEntry) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 February 2009	cnwer1	Initial creation

*/
// adm 130509 Par 19651
vars
	baseStr,
	str,
	twinStr,
	locStr	: String;
	wle : CM_WorkListEntry;
begin
	self.myLoc:=_location;
	self.myTwinLoc :=_twinLocation;
	self.myTrackedItem:=_ti;
	self.myTwinTI:=_twinTI;
	if _isTarget then
		baseStr	:= app.getErrorString(Amend_target_locatio_from);
	else
		baseStr	:= app.getErrorString(Amend_source_location);
	endif;
	if _location &lt;&gt; null then
		locStr:=_location.getFullId;
	else
		locStr:="";
	endif;
	self.caption:=baseStr &amp; " " &amp; _id;
	
	str:= baseStr &amp; " " &amp; _id &amp; " " &amp; app.getErrorString1(CMUI_from_to, locStr);
	//epr par 32440 12/3/15
	if _isTarget and self.myTrackedItem = null and self.myLoc = null then
		str:= app.getErrorString(Bulk_amend_target);
		self.caption:=str;
	endif;
	self.lblAmendTarget.caption:=str;
		
	if _twinLocation &lt;&gt; null and _twinId  &lt;&gt; null then
		if _twinLocation &lt;&gt; null then
			locStr:=_twinLocation.getFullId;
		else
			locStr:="";
		endif;
		twinStr:=baseStr &amp; " " &amp; _twinId &amp; " " &amp; app.getErrorString1(CMUI_from_to, locStr);
		self.lblAmendTargetTw.caption:=twinStr;
		
		self.txtTwinLoc.text:=_twinLocation.getFullId;
	endif;

	// 23099 director tasks source from gridded areas - only enable the terminal area for source
	if _isDirectorTask and not _isTarget then
		//self.cmbLoc.enabled := false; //cnwrd1 par 28628 removed so user can select a grid row/column 21.11.11
		self.txtLoc.enabled := false;
		self.txtLoc.userObject := _location;
	endif;
	
	// allFilterTAs is only used for setting the target Interchange Area
	self.allFilterTAs.clear;
	if _allFilterInterchangeAreas &lt;&gt; null then
		_allFilterInterchangeAreas.copy(self.allFilterTAs);
	endif;
	
	// if _rtQueueEntry is passed in we need to check that the move method might of changed
	if _rtQueueEntry &lt;&gt; null then
		self.myTerminal:=_rtQueueEntry.getMyTerminal;
		self.myRTQueueEntry:=_rtQueueEntry;
		//get the original move method 
		self.myOrigMoveMethod:=_rtQueueEntry.getRTMoveMethod;
		
		// get the original source location from the wle - used later on to determine if new target changes the move method
		self.myWLE:=_rtQueueEntry.myWorkListEntry;
		self.myOrigSourceLoc:=self.myWLE.getOriginalTaskSourceLoc;
	
	endif;
	
epilog

end;</source>
        <Parameter name="_location" type="CM_LocationsController"/>
        <Parameter name="_twinLocation" type="CM_LocationsController"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_twinId" type="String"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_twinTI" type="CM_TrackedItem"/>
        <Parameter name="_isTarget" type="Boolean"/>
        <Parameter name="_isDirectorTask" type="Boolean"/>
        <Parameter name="_allFilterInterchangeAreas" type="CM_TerminalAreaSet"/>
        <Parameter name="_rtQueueEntry" type="CM_RTQueueEntry"/>
    </JadeMethod>
    <JadeMethod name="isTandemLift" id="74cacd04-023e-4da4-b706-f9ed619bbc96">
        <source>isTandemLift() : Boolean;

/*

Purpose:	for par 27649 tandem lifting
		

Parameters:			

Return Value:		


Date		Who		Reason
08 June 2011	cnwrd1	Initial creation

*/

vars
	aMachine 	: CM_Machine;
	aTask	 	: CM_RTQueueTask;
	queueEntry	: CM_RTQueueEntry;
begin
	
	queueEntry := self.myRTQueueEntry;
	
	//epr par 32440 12/3/15
	if queueEntry = null then
		return false;
	endif;
	
	aTask	 := queueEntry.findTaskOfType(TASK_SETDOWN,NULL_INTEGER);
	
	if aTask &lt;&gt; null then
		aMachine := aTask.machine;
	endif;
	
	if aMachine = null then
		return false;
	endif;
	
	if aMachine.allCurrentWorkingQueueTasks.size = 1 then
		return false;
	endif;
	
	if not aMachine.isTandemLift then
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadMoveMethodCombo" id="1fc47d17-88bf-429c-b105-a5d799686309">
        <source>loadMoveMethodCombo(_toLoc : CM_LocationsController) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 March 2011	cnwer1	Initial creation

*/

vars
	allPossibleMoveMethodRules : CM_RTMoveMethodRuleSet;
	moveMethodRule 		: CM_RTMoveMethodRule;
begin

	create allPossibleMoveMethodRules transient;
	self.myWLE.getMoveMethodRulesForNewTarget(_toLoc,allPossibleMoveMethodRules);
	
	foreach moveMethodRule in allPossibleMoveMethodRules do
		self.cmbMoveMethod.addItemObject(moveMethodRule.getDisplayDetails(false),moveMethodRule);
	endforeach;
	
	if self.cmbMoveMethod.listCount = 1 then
	 self.cmbMoveMethod.listIndex:=1;
	endif;
	
epilog
	delete allPossibleMoveMethodRules;

end;</source>
        <access>protected</access>
        <Parameter name="_toLoc" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="loadTACombos" id="cc17fa9e-712b-4a27-acbc-3ab060640f08">
        <updating/>
        <source>loadTACombos() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 Feb 2009	cnwer1	Initial creation
03 Feb 2011 cnwer1 	PAR  26495 added allFilterTAs
*/

vars
	ta : CM_TerminalArea;
	locs : Collection;
	str : String;
begin

	if self.myLoc &lt;&gt; null then
		ta := self.myLoc.myTerminalArea;
	endif;
	self.myAssistant.comboBoxTerminalArea(self.cmbTA, TA_TYPE_NULL, ta);	
	
	if ta &lt;&gt; null then
		locs:=ta.getLCsCollectionForDisplay();
	endif;
	
	if self.allFilterTAs.isEmpty then	
		self.myAssistant.comboBoxTerminalArea(self.cmbTA, TA_TYPE_NULL, ta);	
	else
		self.cmbTA.listCollection(self.allFilterTAs, false, 0);
	
		if ta &lt;&gt; null then
			str :=  self.myAssistant.displayEntryTerminalArea(self.myTerminal, ta);
			if str &lt;&gt; null then
				self.cmbTA.cnEcSetObjectIndex(ta);		// cnwdad1 14/10/2009 - PAR #21312.
			endif;
		endif;
	endif;
	
	
	if ta &lt;&gt; null then
		locs:=ta.getLCsCollectionForDisplay();
	endif;
	
	self.myAssistant.comboBoxLocationControllers(self.cmbLoc, locs, false);	
	
	if self.myLoc &lt;&gt; null then
		if self.cmbLoc.findObject(self.myLoc) &lt;&gt; -1 then		
			self.cmbLoc.listObject := self.myLoc;
		endif;
	endif;
	self.setLocationFromCombo;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setLocationFromCombo" id="2cef4397-37e6-492f-b53b-e9c57ea7fefc">
        <updating/>
        <source>setLocationFromCombo() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 February 2009	cnwer1	Initial creation

*/

vars
	loc : CM_LocationsController;
begin
	loc:= self.cmbLoc.listObject.CM_LocationsController;
	if loc &lt;&gt; null then
		self.txtLoc.text:=loc.getFullId();
		self.txtLoc.userObject:=loc;
	else
		self.txtLoc.text:=null;
		self.txtLoc.userObject:=null;
	endif;
		
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setLocationFromText" id="4008a6c2-ed5c-423f-83e8-106bb5c33c1c">
        <updating/>
        <source>setLocationFromText() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 February 2009	cnwer1	Initial creation

*/

vars
	locationString: String;
	location : CM_LocationsController;
	foundHeight : Integer;
begin
		
	locationString:=self.txtLoc.text;
	self.myTerminal.findLocationFromString( locationString, false, location, foundHeight);
	if location &lt;&gt; null
	and cmbTA.findObject(location.myTerminalArea) &gt; -1 then		// 14/02/2011 cnwar2 #26995
		if self.cmbTA.listObject &lt;&gt; location.myTerminalArea then
			self.cmbTA.listObject:=location.myTerminalArea;
			self.cmbTA.click(self.cmbTA);
		endif;
		if self.cmbLoc.listObject &lt;&gt; location then
			self.cmbLoc.listObject:=location;
		endif;
	else
		app.msgBox(app.getErrorString1(Err_InvalidLocation, locationString), 'Location', MsgBox_OK_Only + MsgBox_Information_Icon);
	endif;
	
	self.setLocationFromCombo();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="429e2d4b-059b-4de6-8d6d-3a1000ce726a">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 February 2009	cnwer1	Initial creation

*/

vars

begin
	inheritMethod();
	self.frmDetails.transparent:=true;
	self.frmMoveMethod.transparent:=true;
	self.createMyAssistant(CMUI_Assistant);
	self.loadTACombos;
	
	self.lblTwinTargetLoc.visible:=self.myTwinLoc &lt;&gt; null;
	self.txtTwinLoc.visible:=self.myTwinLoc &lt;&gt; null;
	self.lblAmendTargetTw.visible:=self.myTwinLoc &lt;&gt; null;
	if not lblTwinTargetLoc.visible then
		self.frmDetails.height:=lblAmendTargetTw.top;
	endif;
	
	self.frmMoveMethod.top:=self.frmDetails.clientHeight;
	//epr par 32440 12/3/15
	self.height:=self.frmDetails.clientHeight + self.btnCancel.clientHeight;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="ed47a54e-c74b-432e-bbbf-4ab86d97cd8b">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
//	self.translateCaption(Xlat_0017423, locale);
//	lblAmendTarget.translateCaption(Xlat_0013458, locale);
//	lblAmendTargetTw.translateCaption(Xlat_0013459, locale);
	lblLoc.translateCaption(Xlat_0009941, locale);
	lblMoveMethod.translateCaption(Xlat_0016086, locale);
	lblTA.translateCaption(Xlat_0009942, locale);
	lblTargetLoc.translateCaption(Xlat_0009943, locale);
	lblTwinTargetLoc.translateCaption(Xlat_0009944, locale);
	lblWarnMoveMeth.translateCaption(Xlat_0016087, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="txtLoc_lostFocus" id="b438f83b-0119-4595-b2b1-58fb28d32b69">
