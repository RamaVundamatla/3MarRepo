    <JadeMethod name="doRefresh" id="60e887f5-0fc0-44c9-a212-fa5ec62dbef2">
        <updating/>
        <source>doRefresh() updating, protected;
//-----------------------------------------------------------------------
//  Created by: cnwsh3
//
//	Date: 11 August 2003
//-----------------------------------------------------------------------
// 22/10/2024	navcs2		MTN-28961 EUP | Transaction Instrumentation - Voyage Planning
// 23/01/2025	navcs2		MTN-33841 MTN | Instrumentation Exception Voyage Planning
// 14 Jan 2026 	navhl20 	Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
vars
	et	: Integer;
begin
	inheritMethod();

	app.mousePointer := Window.MousePointer_HourGlass;
//process.profilerStart;

	self.dkbGridArea.myScrollableFrame.visible := false;
	self.myBayDrawingController.drawSelf(false);
	self.dkbGridArea.myScrollableFrame.visible := true;

//process.profilerStop;
//process.profilerReport('d:\cnwdmast\shipNEW.log');
//	et := app.clock;
//	self.frmStatusLine.myFrameCaption.caption := ((et - st) / 1000).Integer.String &amp; " seconds to refresh";

epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResetWorkingButtons" id="c5199701-5bea-45bc-8b7a-d6a06a754992">
        <source>doResetWorkingButtons(_resetJ, _resetP, _resetS : Boolean);
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
