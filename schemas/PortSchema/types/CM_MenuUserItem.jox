    <JadeMethod name="getUserCargoReportHdr" id="e417288a-ce68-4077-8b9c-011278027bdc">
        <source>getUserCargoReportHdr():CM_MenuUserHdr;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 November 2015	cnwndl1	Initial creation	Par 36846

*/

vars

	menuEntity : CM_MenuEntity;
	menuUserItem : CM_MenuUserItem;
	iter : Iterator;

begin

	if self.myMenuRoot = null or not self.myMenuRoot.isKindOf(CM_MenuRootReportUserTerminal) then
		return null;
	endif;
	
	iter := self.myMenuRoot.allChildren.createIterator;
	while iter.next( menuEntity ) do
		if menuEntity.isUserDefinedReportsHeader then
			return menuEntity.CM_MenuUserHdr;
		endif;
	endwhile;
	delete iter;
	
	iter := self.myMenuRoot.allMenuUserItemsWithAMenuItem.createIterator;
	while iter.next( menuUserItem ) do
		if menuUserItem.isUserDefinedReportsHeader then
			return menuUserItem.CM_MenuUserHdr;
		endif;
	endwhile;
	
	return null;

epilog

	delete iter;

end;</source>
        <ReturnType type="CM_MenuUserHdr"/>
    </JadeMethod>
