    <JadeMethod name="validateMe" id="d478e07f-297e-4bf5-9e42-f9932ff89566">
        <source>validateMe();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
14 March 2014	cnwndl1	Initial creation	Par 33268
//24/01/17 		cnwns1 	TFS3153:PKT - Bulk Process - WeighBridge Integration
//11/07/2017 	cnwma1 	TFS # 4737:Fix the field names in the error messages for the Weigh Bridge code table
28 July 2022	navmd1	TFS 52773 Tidy up/review code

*/

vars

	real : CM_WeighBridgeObj;
	weighBridge : CM_WeighBridgeObj;
	iter : Iterator;

begin

	if self.myWeighBridgeType = null then
		app.raiseCMException1(Input_required_field_Required,app.getErrorString(Weightbridgetype), null, null); // cnwdb2	PAR 35364 //11.07.2017 cnwma1 TFS #4737
		return;
	endif;
	
	if self.name = null then
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Name), null, null); // cnwdb2	PAR 35364 //11.07.2017 cnwma1 TFS #4737
		return;
	endif;
	
	if self.myTerminal = null then
		app.raiseCMException(ERROR_NULL_Terminal, null, null);
		return;
	endif;
	
	if self.isSerialPort then
		if self.computerName = null then
			app.raiseCMException1(Input_required_field_Required,  app.getErrorString(Associated_computer)  , null, null);  //11.07.2017 cnwma1 TFS #4737
			return;
		endif;
		
		if self.myWeightType = null and self.myWeighBridgeType.code &lt;&gt; CM_WeighBridgeObjType.Kubota then
			app.raiseCMException1(Input_required_field_Required,  app.getErrorString(Weight_unit), null, null);   //11.07.2017 cnwma1 TFS #4737
			return;
		endif;
		
	// ### TFS 52773 1APR2022 NAVPW1
	elseif self.isGenericScanAPI then
		//Check for empty fields		
		if self.myWeightType = null then
			app.raiseCMException1(Input_required_field_Required, app.getErrorString(Weight_unit), null, null);
		endif;
		
		if self.deviceId = null then
			app.raiseCMException1(Input_required_field_Required, app.getErrorString(Device_id), null, null);
		endif;
		
		if self.myTerminal &lt;&gt; null and self.myTerminal.allWeighBridges.size &gt; 0 then
			iter := self.myTerminal.allWeighBridges.createIterator;
			while iter.next( weighBridge ) do
				if weighBridge.name = self.name then //If name matches then ignore as this is our current one
					continue;
				endif;
				
				if weighBridge.deviceId = self.deviceId then //If deviceId doesn't match continue
					app.raiseCMException1(VB_DUPLICATED_ITEM, self.deviceId, null, null); //If deviceId matches then raise an exception
					break;
				endif;
			endwhile;
			delete iter;
		endif;
	// ### TFS 52773 1APR2022 NAVPW1
	
	else
		if self.ipAddress = null then
			app.raiseCMException(Input_required_field_IPAddress, null, null); // cnwdb2	PAR 35364
			return;
		endif;
		
		if self.portNumber = null then
			app.raiseCMException(Input_required_field_portNumb, null, null); // cnwdb2	PAR 35364
			return;
		endif;
	endif;
	
	//19 Jul 2021	NDL	TFS 51575
	if self.computerName &lt;&gt; null then
		if self.isTransient then
			real := self.pxyGetRealObject();
		else
			real := self;
		endif;
		iter := self.myTerminal.allWeighBridges.createIterator;
		while iter.next( weighBridge ) do
			if weighBridge = real then
				continue;
			endif;
			if weighBridge.computerName.trimBlanks.toUpper = self.computerName.trimBlanks.toUpper then
				app.raiseCMWarning2( Weigh_bridg_alrea_assoc_comp, weighBridge.name, weighBridge.computerName, null, null, null );
			endif;
		endwhile;
	endif;

epilog

	delete iter;

end;</source>
    </JadeMethod>
</Class>
