    <JadeMethod name="cnEcResizeContents" id="0f063c84-e58a-4e30-9562-3ad36c39fe5b">
        <updating/>
        <source>cnEcResizeContents() updating;
// ---------------------------------------------------------------------------
// Created:     30 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 02 Jul 2008	cnwkpd1		PAR #14904 - Use parent's client height and width
//							for resize
// ---------------------------------------------------------------------------
vars
	parentWidth,
   	parentHeight	: Real;
	
begin
	if self.stretchToParent then
		if self.parent.isKindOf(Form) then
			parentWidth  := self.parent.Form.clientWidth;
			parentHeight := self.parent.Form.clientHeight;
		elseif self.parent.isKindOf(Control) then
			parentWidth  := self.parent.Control.clientWidth;
			parentHeight := self.parent.Control.clientHeight;
		else
			parentWidth  := self.parent.width;
			parentHeight := self.parent.height;
		endif;
	
		self.move(0, 0, parentWidth, parentHeight);			// PAR #14904
//		self.left	:= 0;
//		self.top 	:= 0;
//		self.width 	:= parent.width;
//		self.height	:= parent.height;
	endif;

	self.resizeChildren(self);

end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="be0d990a-505c-487c-a956-b75a05070537">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     10 April 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.tabsStyle := self.TabsStyle_RightSloped;

end;</source>
    </JadeMethod>
    <JadeMethod name="hideSheetByIndex" id="d50eb708-470c-4dba-9b67-5218530c5530">
        <source>hideSheetByIndex(_idx: Integer);
vars
	idx		: Integer;
	cntrl	: Control;
begin

	foreach idx in 1 to form.controlCount do
		cntrl := form.controls(idx);
		if cntrl.parent = self then
			if Sheet.hasInstance(cntrl) 
			and cntrl.Sheet.index = _idx then
				cntrl.visible := false;
			endif;
		endif;
	endforeach;
end;</source>
        <Parameter name="_idx" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initSheetBackColors" id="ac0e0900-af74-467f-8904-b98b3ab2cf6e">
        <source>initSheetBackColors();
// ---------------------------------------------------------------------------
// Created:     04 November 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpTopSheet	: Sheet;
	tmpCntrl	: Control;
	tmpSheet	: Sheet;
	idx,
	numControls,
	tmpSelectedColor,
	tmpUnselectedColor	: Integer;
	tmpForm		: Form;
begin
	if (not self.useSheetBackColors) then
		return;
	endif;
	tmpForm := self.form;
	if tmpForm = null then
		return;
	endif;
	tmpTopSheet := self.topSheet;
	tmpSelectedColor	:= self.sheetBackColorSelected;
	tmpUnselectedColor	:= self.sheetBackColorUnselected;

	numControls := tmpForm.controlCount;
	
	foreach idx in 1 to numControls do
		tmpCntrl := tmpForm.controls(idx);
		if tmpCntrl.parent = self and
		   Sheet.hasInstance(tmpCntrl) then
			if tmpCntrl = tmpTopSheet then
				tmpCntrl.backColor := tmpSelectedColor;
			else
				tmpCntrl.backColor := tmpUnselectedColor;
			endif;
		endif;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="querySheetChg" id="4d6d8f37-0909-4387-9336-3ac22f18f385">
        <controlMethod name="Folder::querySheetChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>querySheetChg(folder: Folder; newSheet: Sheet): Boolean updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:     04 November 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpSheet	: Sheet;

begin

	if self.isInPainter or
	   (not self.useSheetBackColors) then
		return inheritMethod(folder, newSheet);
	endif;

	if (not inheritMethod(folder, newSheet)) then
		return false;
	endif;
	tmpSheet := folder.topSheet;
	if tmpSheet &lt;&gt; null then
		tmpSheet.backColor := self.sheetBackColorUnselected;
	endif;

	tmpSheet := newSheet;
	if tmpSheet &lt;&gt; null then
		tmpSheet.backColor := self.sheetBackColorSelected;
		tmpSheet.cnEcResizeContents();
	endif;
	
	return true;
end;</source>
        <Parameter name="folder" type="Folder"/>
        <Parameter name="newSheet" type="Sheet"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="repositionAfterResize" id="37103825-cddd-487d-9093-1bf3dd680742">
        <updating/>
        <source>repositionAfterResize() updating;
// ---------------------------------------------------------------------------
// Created:     30 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
   	newLeft, newTop, newWidth, newHeight	: Real;
   	parentWidth,
   	parentHeight	: Real;

begin

	if self.parent.isKindOf(Form) then
		parentWidth  := self.parent.Form.clientWidth;
		parentHeight := self.parent.Form.clientHeight;
	elseif self.parent.isKindOf(Control) then
		parentWidth  := self.parent.Control.clientWidth;
		parentHeight := self.parent.Control.clientHeight;
	else
		parentWidth  := self.parent.width;
		parentHeight := self.parent.height;
	endif;
	
	inheritMethod();
	
	if self.stretchToParent then
		newLeft	:= 0;
		newTop 	:= 0;
		newWidth 	:= parentWidth;
		newHeight	:= parentHeight;
	else
		newLeft := self.left;
		newTop := self.top;
		newWidth := self.width;
		newHeight := self.height;

	
		if self.lockRight then
			newLeft := (parentWidth - newWidth - self.distanceFromRight).max(0);
		endif;
		if lockBottom then
			newTop := (parentHeight - newHeight - self.distanceFromBottom).max(0);
		endif;
		if stretchWidth then
			newWidth := (parentWidth - newLeft - self.distanceFromRight).max(0);
		endif;
		if stretchHeight then
			newHeight := (parentHeight - newTop - self.distanceFromBottom).max(0);
		endif;
	endif;
	
	if newLeft &lt;&gt; self.left or newTop &lt;&gt; self.top or newWidth &lt;&gt; self.width or newHeight &lt;&gt; self.height then
		self.move(newLeft, newTop, newWidth, newHeight);
		self.cnEcResizeContents;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="resizeChildren" id="72f1377c-c3f2-4c41-ae12-57badb780570">
        <source>resizeChildren(pParent : Window) protected;
// ---------------------------------------------------------------------------
// Created:     16 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx		: Integer;
	cntrl	: Control;
	
begin

	// now we resize the sheets only when we change to
	// them so only resize the topSheet here
	cntrl := self.topSheet;
	if cntrl &lt;&gt; null then
		cntrl.cnEcResizeContents();
	endif;
/*
	foreach idx in 1 to form.controlCount do
		cntrl := form.controls(idx);
		if cntrl.parent = pParent then
			cntrl.cnEcResizeContents();
		endif;
	endforeach;
*/
end;</source>
        <access>protected</access>
        <Parameter name="pParent" type="Window"/>
    </JadeMethod>
    <JadeMethod name="setDefaultSheetBackColors" id="35323576-46ea-4efc-bc05-086ec3fbda2e">
        <updating/>
        <source>setDefaultSheetBackColors() updating;
// ---------------------------------------------------------------------------
// Created:     04 November 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpForm	: CM_BaseForm;
begin

	if (not CM_BaseForm.hasInstance(self.form)) then
		// self.sheetBackColorSelected		:= LightBlue;
		// self.sheetBackColorUnselected	:= self.getSystemColor(Window.Color_InfoBk);
		return;
	endif;
	tmpForm := self.form.CM_BaseForm;
	self.sheetBackColorSelected		:= tmpForm.backColor;
	self.sheetBackColorUnselected	:= tmpForm.colorControlBack;	//self.getSystemColor(Window.Color_InfoBk);
	
	//cnwmc5 - PAR #31051
	if not self.isInPainter then
		if app.isUsingSkin() then
			self.sheetBackColorSelected	:= app.convertRGBToColor(230, 230, 230);
			self.sheetBackColorUnselected := app.convertRGBToColor(250, 250, 250);
			self.borderColorSingle := app.convertRGBToColor(141, 141, 141);
		endif;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setSheetBackColor" id="2c9dd5f2-97b5-4b7d-8587-ee8a71228d7b">
        <updating/>
        <source>setSheetBackColor(_sheet : Sheet input; _selected : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     04 November 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if _sheet = null or
	   self.isInPainter or
	   (not self.useSheetBackColors) then
		return;
	endif;
	
	if _selected then
		_sheet.backColor := self.sheetBackColorSelected;
	else
		_sheet.backColor := self.sheetBackColorUnselected;
	endif;
	
end;</source>
        <Parameter name="_sheet" type="Sheet" usage="input"/>
        <Parameter name="_selected" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showSheetByIndex" id="83794bb2-4238-4649-a40f-755d56acb729">
        <source>showSheetByIndex(_idx: Integer);
vars
	idx		: Integer;
	cntrl	: Control;
begin

	foreach idx in 1 to form.controlCount do
		cntrl := form.controls(idx);
		if cntrl.parent = self then
			if Sheet.hasInstance(cntrl) 
			and cntrl.Sheet.index = _idx then
				cntrl.visible := true;
			endif;
		endif;
	endforeach;
end;</source>
        <Parameter name="_idx" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="topSheet" id="d0e82adf-07c4-4897-9292-3c240eaf9d1f">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>topSheet(set: Boolean; value: Sheet io) updating, mapping, clientExecution;
// ---------------------------------------------------------------------------
// Created:     04 November 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	currentTopSheet	: Sheet;
begin

	if (not set) or 
	   self.isInPainter or
	   (not self.useSheetBackColors) then
		inheritMethod(set, value);
		return;
	endif;

	currentTopSheet := self.topSheet;
	if currentTopSheet &lt;&gt; null and
	   currentTopSheet &lt;&gt; value then
		currentTopSheet.backColor := self.sheetBackColorUnselected;
	endif;

	inheritMethod(set, value);

	if value &lt;&gt; null then
		value.backColor := self.sheetBackColorSelected;
		value.cnEcResizeContents();
	endif;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="Sheet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="8f4df15b-e363-49cc-a6d5-e419718823b9">
        <controlMethod name="Control::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 February 2013	cnwmc5	Initial creation		PAR 31501

*/

vars

begin
	inheritMethod(cntrl, persistCntrl);
	
	if not self.isInPainter then
		if app.isUsingSkin then
			self.tabsStyle := self.TabsStyle_RightSloped;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
