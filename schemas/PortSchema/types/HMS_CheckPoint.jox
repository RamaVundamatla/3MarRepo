    <JadeMethod name="getDisplayStringForAttribute" id="54b2035f-9ab1-436c-8a5b-8e49d08041d9">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
----------   ----------  --------------------------------------------------
Created:	10 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
2 May 2015   cnwdb2      PAR 33977
*/
vars

begin

	if _attrName = ETRow_CheckPointType then
		return app.chkPointTypeEnumToString(self.checkPointType);

	elseif _attrName = ETRow_TidalModel then
		if self.myTidalModel &lt;&gt; null then
			return self.myTidalModel.description;
		else
			return null;
		endif;
	elseif _attrName = ETRow_GapCheckArrivals then
		return self.gapCheckArrivals.asStringJMT;
	elseif _attrName = ETRow_GapCheckDepartures then
		return self.gapCheckDepartures.asStringJMT;
		
	// cnwdb2 PAR 33977
	elseif _attrName = ETRow_HookCode then
		if self.myHookCode &lt;&gt; null then
			return self.myHookCode.code ; 	
		endif ; 
		return " " ;   
	elseif _attrName = ETRow_GapBetweenMovements then
		if self.gapTimeDifference = null then
			return " " ; 
		else
			return self.gapTimeDifference.String ; 
		endif  ;
	elseif _attrName = ETRow_ShipsDepartTimings then
		if self.shipDepartTimings &lt;&gt; null then
			return self.shipDepartTimings.String ; 
		endif ; 
		return "" ; 
	elseif _attrName = ETRow_TideRangeAmount then
		if self.tideRangeAmount = null then
			return "" ; 
		endif	;
		
	elseif _attrName = ETRow_RelativeToTide then
		return self.hiLoTideReference.String ; 
		
	elseif _attrName = ETRow_RelativeToTime then
		if self.hiLoRelativeTimeTo &lt;&gt; null then
			return self.hiLoRelativeTimeTo.String ; 
		endif ; 
			return  " " ; 
			
			
	elseif _attrName = ETRow_RelativeFromTime then
		if self.hiLoRelativeTimeFrom &lt;&gt; null then
			return self.hiLoRelativeTimeFrom.String  ;
		endif	; 
			return "" ; 
	elseif _attrName = ETRow_RelativeToTide2 then
		return self.hiLoTideReference2.String  ;
		
	elseif _attrName = ETRow_RelativeFromTime2 then
		if self.hiLoRelativeTimeFrom2 &lt;&gt; null then
			return self.hiLoRelativeTimeFrom2.String  ;
		endif ; 
		return "" ; 
		
	elseif _attrName = ETRow_RelativeToTime2 then
		if hiLoRelativeTimeTo2 &lt;&gt; null then
			return self.hiLoRelativeTimeTo2.String ;
		endif  ;
		return "" ; 
	elseif _attrName = ETRow_TideRangeAmount2 then
		if self.tideRangeAmount = null then	
			return "" ;
		endif ; 
	elseif _attrName = ETRow_TideState then
		if self.tideState = null then
			return "" ; 
		endif  ;
	endif;
	
	return inheritMethod(_attrName, _short);


end;


</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getJadeCode" id="f034c7b6-7b66-477f-a773-ee496ff3cfe4">
        <source>getJadeCode() : String;
// ---------------------------------------------------------------------------
// Created:     15 January 2008 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if self.myHookCode = null then
		return null;
	endif;
	
	return self.myHookCode.getCurrentJadeCode();

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getShipsDepartTime" id="20b4d44d-6b03-4315-b0ea-d269ec515a74">
        <source>getShipsDepartTime( numberOfShips : Integer; integerArray : IntegerArray input) : Boolean;
//-----------------------------------------------------------------------
//	Created:	26 April 2007 Lorcan Bolster  (cnwlb1/lorcan)
//
//				This method parses the shipsDepart string and returns
//				the numberOfMinutes (before HT or LT) dependent on the ship
//				number given
//				Assuming the format is &lt;number ship&gt;:&lt;numites&gt;,&lt;minutes&gt;;&lt;number ship&gt;:&lt;numites&gt;;
//				e.g 1:75;2:90,60;3:120,90,50
//-----------------------------------------------------------------------
vars
	i,
	n,
	idx				: Integer;
	array 			: StringArray;
	str, str2		: String;
begin

	if self.shipDepartTimings = null then	//14131 cnwvu1
		return false;
	endif;

	i := 1;
	self.shipDepartTimings.scanWhile("0123456789;,:", i);
	if i &lt;&gt; 0 then
		return false;
	endif;
	
	create array transient;
	
	i := 1;
	idx := 1;
	while true do
		array[i] := self.shipDepartTimings.scanUntil(";", idx);
		if idx = 0 then 
			break; 
		endif;
		idx := idx + 1;
		i := i + 1;
	endwhile;
	
	foreach i in 1 to array.size do
	
		str := array[i];
		if str.Integer = 0 then
			return false;
		endif;
		
		idx := str.pos (i.String &amp; ":", 1);
		if idx = 0 then
			return false;
		endif;
		
		idx := idx + i.String.length + 1;
		
		str2 := str[idx:end];
		
		foreach n in 1 to array[i].Integer do
			if str2.Integer = 0 and str2 &lt;&gt; "0" then
				return false;
			endif;
			
			if integerArray &lt;&gt; null and numberOfShips = i or 
				( i = array.size and numberOfShips &gt; i ) then
				integerArray[n] := str2.Integer;
			endif;
			
			if n &lt; i then
				idx := str.pos (",", idx);
				idx := idx + 1;
			endif;
			str2 := str[idx:end];
		endforeach;
	endforeach;
		
	return true;
epilog
	delete array;
end;</source>
        <Parameter name="numberOfShips" type="Integer"/>
        <Parameter name="integerArray" type="IntegerArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getTidalDataType" id="a53d8f1f-68ec-46e9-9b92-7230a225a8dd">
        <source>getTidalDataType() : Integer;
/*
----------   ----------  --------------------------------------------------
Created:	12 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.myTidalModel &lt;&gt; null then
		return self.myTidalModel.dataType;
	endif;
	
	return null;

end;


</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
