    <JadeMethod name="getStevedoreCode" id="2e7da30a-6bc6-4dda-add8-41747e26ebb1">
        <source>getStevedoreCode():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
*/

vars
	voyage 			: CM_Voyage;
	hmsVoyage		: HMS_VoyageData;
	stevedore   	: CM_Stevedore;
	stevedoreCode	: String;
begin
	
	if self.myTransactionTI &lt;&gt; null then
		
		if self.myTransactionTI .isKindOf (CM_ReleaseShip) or self.myTransactionTI.isKindOf(CM_ReceiveShip)  then
			voyage 		:= self.getMyVoyageObject();
			hmsVoyage	:= voyage.myHMSVoyageData;
			
			if hmsVoyage &lt;&gt; null then
				
				if self.myTransactionTI.isKindOf(CM_ReceiveShip)  then
					if hmsVoyage.allStevedoresDischarge.size &gt; 0 then
						stevedore := hmsVoyage.allStevedoresDischarge.first.CM_Stevedore;
					endif;
				elseif self.myTransactionTI .isKindOf (CM_ReleaseShip) then
				
					if hmsVoyage.allStevedoresLoad.size &gt; 0 then
						stevedore := hmsVoyage.allStevedoresLoad.first.CM_Stevedore;
					endif;
				endif;
				
				if stevedore &lt;&gt; null then
					return	stevedore.code;
				endif;
			endif;
			
	   
		endif;
	
	endif;
	
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
