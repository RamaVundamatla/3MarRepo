    <JadeMethod name="queryUnload" id="d9b7044b-24b3-4671-b734-69fe0daf3bd7">
        <controlMethod name="Form::queryUnload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>queryUnload(cancel: Integer io; reason: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2008	cnwer1	Initial creation

*/

vars
	result : Integer;
begin
	if not hasChanged then
		hasChanged:=self.checkHasChanged();
		if hasChanged then
			result := app.msgBox(app.getErrorString(EditChangedAndClosing), self.caption &amp; " Window Closing !", MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
			if result &lt;&gt; MsgBox_Return_Yes then
				cancel:=1;
			endif;	
		endif;
	endif;
epilog

end;</source>
        <Parameter name="cancel" type="Integer" usage="io"/>
        <Parameter name="reason" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="saveProxyBookingRefItem" id="7c5b1550-d33c-49e6-83bd-b606193a019c">
        <source>saveProxyBookingRefItem(_proxyBookingRefItem : CM_BookingRefItem input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 November 2008	cnwer1	Initial creation
11 September 2009	cnwjo3	fixed some more issues, par 20644
12/03/2010			cnwcs5	par 22775 - save type as value
16/03/2010 			adm		Par 22937 remove bolType
24/03/2010			cnwdap1	PAR #22938 Reefer details are not exclusively container-based
19/03/2013			cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
13/08/2013			cnwdap1	PAR #32123 Colour picker
03/03/2014			cnwdap1	PAR #33193 CCMS DPH 2285 Added Purchase Order and Service Order fields
20/03/2014			cnwdap1	PAR #33606 CCMS SFW 1366 Bulk - default quantity to 1 for Bulk
01/10/2019			jlgzm1	TFS 46575 Display Reefer options for non-containers
07/11/2022 			navrk21 Bug 55167: MTN - Booking Item not saving CO2, O2 and Curtains In/Out unless a commodity is specified
13/12/2022			jlika1	TFS 55590 HS Codes to Column Organizers
*/
vars
	cargoType 	: CM_CargoType;
	theRemarks,
	theIsoType,
	theCommodity,
	theIsoGroup	: String;									//+cnwml2 PAR20173 SFW CCMS 1091
	allHazards   : CM_HazardByCodeDict;
	theCarbonDioxide,
	theOxygen,
	theHumidity : Decimal[6,2];	//02 Apr 2020	NDL	TFS 47958
	theQuantity,
	theMaxToRelease,
	theVentilationUnits,
	theGradeValue: Integer;
	theWeight : Decimal[14,4];
	theTemperature,
	theVentilation : Decimal[14,4]; //par19252 cnwrs1 may 2009
	grade 			: CM_MTGrade;
	theProduct : CM_Product;
	theHeight : Decimal[14,4];
	theWidth : Decimal[14,4];
	theLength : Decimal[14,4];
	theVolume : Decimal[14,4];
	theType : String;
	theDensity : Decimal[14,4];				// ### TFS 52193 22Nov2021 NAVPW1
	theProductQuantity : Integer;
	theProductWeight : Decimal[14,4];
	theProductVolume : Real;
	theSpecialStow : CM_SpecialStow;
	theShippingMarks : String;
	theId : String;
	theColour : String;
	theWidthString: String;
	theHeightString : String;
	theLengthString : String;
	allSpecialLifts : CM_SpecialLiftByCodeDict;
	generatorType : String;
	trailerType : String;
	commodity : CM_Commodity;
	isoType   : CM_ISOType;
	isReefer : Boolean;
	purchaseOrder, serviceOrder	: String;												// PAR #33193
	hsCode : String;
	matchMode : Integer;	

begin
	cargoType 		:= self.cmbCargoType.myObject.CM_CargoType; 
	
	theRemarks	:= self.txtRemarks.text;
	create allHazards transient;
	self.lstHazards.allSelectedObjects.copy(allHazards);

	theQuantity		:= self.txtTotalUnits.text.asRealJMT.Integer;
	theWeight		:= self.tblWeight.getConvertedValue;								// PAR #31155
	theVolume		:= self.tblVolume.getConvertedValue;								// PAR #31155
	
	//navra1 - CR 63764/Task 64227 - 22nd May 2024 - start
	if self.cmbMatchMode.listIndex = 2 then
		matchMode := CM_BookingRefItem.STRICT_MATCH;
	else
		matchMode := CM_BookingRefItem.BASIC_MATCH;
	endif;	
	//navra1 - CR 63764/Task 64227 - 22nd May 2024 - end
	
	if self.cmbCommodity.listObject &lt;&gt; null then
		theCommodity 	:= self.cmbCommodity.listObject.CM_Commodity.code;
	endif;
	
	if self.cmbHsCode.listObject &lt;&gt; null then
		hsCode 	:= self.cmbHsCode.listObject.CM_HarmonizedSystem.id;
	endif;	
	
	theSpecialStow := self.cmbSpecialStow.listObject.CM_SpecialStow;
	
	create allSpecialLifts transient;
	self.lstSpecialLift.allSelectedObjects.copy(allSpecialLifts);
	
	generatorType := null;
	trailerType := null;
	
	purchaseOrder := self.txtPurchaseOrder.text.trimBlanks;								// PAR #33193
	serviceOrder := self.txtServiceOrder.text.trimBlanks;								// PAR #33193
	
	if self.cmbCargoType.myObject.CM_CargoType.id = TI_CargoType_Container then
	/***************************************************************************
								ISO Contrainers
	***************************************************************************/
		//10/03/2010 cnwdz2 22550
		isoType := self.cmbIsoType.listObject.CM_ISOType;
		if isoType &lt;&gt; null then
			theIsoType	:= isoType.code;
		endif;	
		
		commodity := self.cmbCommodity.listObject.CM_Commodity; //10/03/2010 cnwdz2 22550
		if (isoType &lt;&gt; null and isoType.isReefer) or (commodity &lt;&gt; null and commodity.hasTemp) then//commodity &lt;&gt; null and commodity.hasTemp then
			if self.txtCO2.text.trimBlanks &lt;&gt; null then
				theCarbonDioxide := self.txtCO2.text.asDecimalJMT;
			else
				theCarbonDioxide := NULL_CARBON_DIOXIDE;
			endif;
			if self.txtO2.text.trimBlanks &lt;&gt; null then
				theOxygen		:= self.txtO2.text.asDecimalJMT;
			else
				theOxygen := NULL_OXYGEN;
			endif;
		else
			theCarbonDioxide := NULL_CARBON_DIOXIDE;
			theOxygen := NULL_OXYGEN;
			theTemperature := NULL_TEMPERATURE;
			theVentilation := NULL_VENTILATION;
			theHumidity := NULL_HUMIDITY;
		endif;
		
		theMaxToRelease := self.txtMaxRel.text.asRealJMT.Integer;
		if self.myBookingItem &lt;&gt; null and self.myBookingItem.myReserveDetail &lt;&gt; null then
			if self.myBookingItem.myReserveDetail.maxToRelease &lt;&gt; 0 and theMaxToRelease = 0 then
				theMaxToRelease := -1;
			endif;
		endif;
		
		if self.cmbIsoGroup.listObject &lt;&gt; null then
			theIsoGroup		:= self.cmbIsoGroup.listObject.CM_ISOTypeGroup.code;
		endif;

		if self.txtHumidity.text.length = 0 then
			theHumidity		:= NULL_HUMIDITY;
		else
			theHumidity		:= self.txtHumidity.text.asDecimalJMT;
		endif;
		
		if self.txtTemperature.text.length = 0 then
			theTemperature  := NULL_TEMPERATURE;
		else
			if self.optFahr.value then																	// PAR #31155
				theTemperature := app.temperatureConversion(false, self.txtTemperature.text.asRealJMT);	// PAR #31155
			else																						// PAR #31155
				theTemperature  := self.txtTemperature.text.asRealJMT;
			endif;																						// PAR #31155
		endif;
		
		//if self.txtVentilation.text.length = 0 then									// PAR #31155
		if self.tblVentilation.getConvertedValue = 0 then								// PAR #31155
			theVentilation  := NULL_VENTILATION;
		else
			theVentilation	:= self.tblVentilation.getConvertedValue;					// PAR #31155
		endif;

		theVentilationUnits := self.myAssistant.getVentilationUnitFromDesc(self.tblVentilation.getUnit);	// PAR #31155
		
		grade:=self.cmbAvalGrade.listObject.CM_MTGrade;
		if grade &lt;&gt; null then
			theGradeValue 		:= grade.code;
		else
			theGradeValue := NULL_INTEGER;
		endif;
	elseif self.cmbCargoType.myObject.CM_CargoType.id = TI_CargoType_Generator then						//Generator Field
		if self.cmbGeneratorType.myObject &lt;&gt; null then
			generatorType := self.cmbGeneratorType.myObject.CM_GeneratorType.code;
		else
			generatorType := null;
		endif;
		
		theShippingMarks := self.txtMarks.text;
		theId := self.txtId.text;
	elseif self.cmbCargoType.myObject.CM_CargoType.productType = ProductType_Trailer then
		if self.cmbTrailerType.myObject &lt;&gt; null then
			trailerType := self.cmbTrailerType.myObject.CM_TILCType.code;
		else
			trailerType := null;
		endif;
		
		theShippingMarks := self.txtMarks.text;
		theId := self.txtId.text;
		
		commodity := self.cmbCommodity.listObject.CM_Commodity;
		
		// TFS 46575 Start
		//check for reefer from commodity
		//if (commodity &lt;&gt; null and commodity.hasTemp) then												//07.11.2022 navrk21 TFS 55167
		if (isoType &lt;&gt; null and isoType.isReefer) or (commodity &lt;&gt; null and commodity.hasTemp) then		//07.11.2022 navrk21 TFS 55167
			isReefer := true;
			//if (commodity &lt;&gt; null and commodity.hasTemp) then											//07.11.2022 navrk21 TFS 55167
			if (isoType &lt;&gt; null and isoType.isReefer) or (commodity &lt;&gt; null and commodity.hasTemp) then	//07.11.2022 navrk21 TFS 55167
				if self.txtCO2.text.trimBlanks &lt;&gt; null then
					theCarbonDioxide := self.txtCO2.text.asDecimalJMT;
				else
					theCarbonDioxide := NULL_CARBON_DIOXIDE;
				endif;
				if self.txtO2.text.trimBlanks &lt;&gt; null then
					theOxygen		:= self.txtO2.text.asDecimalJMT;
				else
					theOxygen := NULL_OXYGEN;
				endif;
			endif;
			if self.txtHumidity.text.length = 0 then
				theHumidity		:= NULL_HUMIDITY;
			else
				theHumidity		:= self.txtHumidity.text.asDecimalJMT;
			endif;
			if self.txtTemperature.text.length = 0 then
				theTemperature  := NULL_TEMPERATURE;
			else
				theTemperature  := self.txtTemperature.text.asRealJMT;
			endif;
			if self.tblVentilation.getConvertedValue = 0 then
				theVentilation  := NULL_VENTILATION;
			else
				theVentilation  := self.tblVentilation.getConvertedValue;
			endif;
			theVentilationUnits := self.myAssistant.getVentilationUnitFromDesc(self.tblVentilation.getUnit);
		endif;
		// TFS 46575 End
	else
	/***************************************************************************
								Products/General Cargo
	***************************************************************************/
		theCarbonDioxide := NULL_CARBON_DIOXIDE;
		theGradeValue := NULL_INTEGER;
		theHumidity := NULL_HUMIDITY;
		theOxygen := NULL_OXYGEN;
		theTemperature := NULL_TEMPERATURE;
		theVentilation := NULL_INTEGER;
		theHumidity := NULL_HUMIDITY;

		theProduct := self.cmbProduct.myObject.CM_Product;
		commodity := self.cmbCommodity.listObject.CM_Commodity; // TFS 46575
		
		// PAR #22938 check for reefer from cargo type or cargo subtype
		if (cargoType.mySystemProductType &lt;&gt; null and cargoType.mySystemProductType.isReefer) or
				(theProduct &lt;&gt; null and theProduct.isReefer) or
				(commodity &lt;&gt; null and commodity.hasTemp) then // TFS 46575
			isReefer := true;
			//commodity := self.cmbCommodity.listObject.CM_Commodity;
			//if (commodity &lt;&gt; null and commodity.hasTemp) then												//07.11.2022 navrk21 TFS 55167
			if (isoType &lt;&gt; null and isoType.isReefer) or (commodity &lt;&gt; null and commodity.hasTemp) then		//07.11.2022 navrk21 TFS 55167
				if self.txtCO2.text.trimBlanks &lt;&gt; null then
					theCarbonDioxide := self.txtCO2.text.asDecimalJMT;
				else
					theCarbonDioxide := NULL_CARBON_DIOXIDE;
				endif;
				if self.txtO2.text.trimBlanks &lt;&gt; null then
					theOxygen		:= self.txtO2.text.asDecimalJMT;
				else
					theOxygen := NULL_OXYGEN;
				endif;
			endif;
			if self.txtHumidity.text.length = 0 then
				theHumidity		:= NULL_HUMIDITY;
			else
				theHumidity		:= self.txtHumidity.text.asDecimalJMT;
			endif;
			if self.txtTemperature.text.length = 0 then
				theTemperature  := NULL_TEMPERATURE;
			else
				theTemperature  := self.txtTemperature.text.asRealJMT;
			endif;
			//if self.txtVentilation.text.length = 0 then									// PAR #31155
			if self.tblVentilation.getConvertedValue = 0 then								// PAR #31155
				theVentilation  := NULL_VENTILATION;
			else
				//theVentilation  := self.txtVentilation.text.asDecimalJMT;					// PAR #31155
				theVentilation  := self.tblVentilation.getConvertedValue;					// PAR #31155
			endif;
			//theVentilationUnits := self.myAssistant.getVentilationUnitFromDesc(self.cmbVentUnits.text);		// PAR #31155
			theVentilationUnits := self.myAssistant.getVentilationUnitFromDesc(self.tblVentilation.getUnit);	// PAR #31155
		endif;			
		

		if self.tblCDDensity.visible then
			theDensity := self.tblCDDensity.getConvertedValue.Decimal;				// ### TFS 52193 22Nov2021 NAVPW1
		endif;
		if cargoType &lt;&gt; null then
			if cargoType.isBulkMulti then
				theQuantity:=1;
			endif;
			if 	cargoType.isBulkByVolume then
				if theDensity = null then
					// can we get it off the cargotype / product?
					if cargoType.mySystemProductType &lt;&gt; null then
						theProduct := cargoType.mySystemProductType;
					else
						theProduct := self.cmbProduct.listObject.CM_Product;
					endif;
					if theProduct &lt;&gt; null and theProduct.myDensityDec &lt;&gt; null then	// ### TFS 52193 22Nov2021 NAVPW1
						theDensity := theProduct.myDensityDec.value;				// ### TFS 52193 22Nov2021 NAVPW1
					endif;
				endif;
				theWeight:=theVolume * theDensity;
			endif;
		endif;
		
		// PAR #33606
		theShippingMarks := self.txtMarks.text;
		theId := self.txtId.text;
		theColour := self.myAssistant.getColourString(self.lstColour, self.txtColour);		// PAR #32123
		
		theHeight := self.tblCDHeight.getConvertedValue;									// PAR #31155
		theWidth := self.tblCDWidth.getConvertedValue;										// PAR #31155
		theLength := self.tblCDLength.getConvertedValue;									// PAR #31155
		
		if self.cmbCDType.visible then		// 12/03/2010 cnwcs5 par 22775 - handle type as value
			if (self.cmbCDType.text.pos(Tab,1)-1) &gt; 0 then
				theType := self.cmbCDType.text[1:self.cmbCDType.text.pos(Tab,1)-1].asStringJMT;
			else
				theType := self.cmbCDType.text.asStringJMT;
			endif;
		elseif self.txtCDType.visible then	// 12/03/2010 cnwcs5 par 22775 - handle type as value
			theType	:= self.txtCDType.text;	// 12/03/2010 cnwcs5 par 22775 - handle type as value
		endif;								// 12/03/2010 cnwcs5 par 22775 - handle type as value
		
		theProductVolume := self.tblCDVolume.getConvertedValue;								// PAR #31155
		theProductQuantity := self.txtCDQuantity.text.Integer;
		theProductWeight := self.tblCDWeight.getConvertedValue;								// PAR #31155
		theHeightString := self.txtCDHeightText.text;
		theWidthString := self.txtCDWidthText.text;
		theLengthString := self.txtCDLengthText.text;
	endif;
	
	
	//do the actual save, another if condition here to make it easier to find instead of placing above
	if self.cmbCargoType.myObject.CM_CargoType.id = TI_CargoType_Container then
		//iso container
		_proxyBookingRefItem.setProxy(cargoType.id,
				 theCommodity,
				 null,
				 theRemarks,
				 allHazards,
				 theIsoType,
				 theQuantity,
				 theWeight.Integer,
				  theMaxToRelease,
				  theGradeValue,
				  theHumidity,
				 theTemperature,
				 theVentilation,
				 theVentilationUnits,
				 theCarbonDioxide,
				 theOxygen,
				 self.chkCurtainsIn.value,
				 self.chkIsClean.value,
				 self.chkHeavy.value,
				 theSpecialStow,
				 theIsoGroup,
				 self.chkPreTripInspec.value,
				 allSpecialLifts,
				 purchaseOrder,															// PAR #33193
				 serviceOrder,															// PAR #33193
				 matchMode);															//navra1 - CR 63764/Task 64227 - 22nd May 2024							
				 //special stows aren't saved for this method
	else
		_proxyBookingRefItem.setProxyForCargo(
								cargoType.id,
								theCommodity,
								//null,
								self.txtDescription.text,
								allHazards,
								theQuantity,
								theRemarks, //already have description, don't need remarks as well
								theHeight,
								theLength,
								theWidth,
								theHeightString,
								theLengthString,
								theWidthString,
								theType,
								theDensity,
								theVolume,
								theProductQuantity,
								theShippingMarks,
								theWeight,
								theProduct,
								null,
								null,
								generatorType,   
								theSpecialStow,
								theId,
								theColour,
								self.txtMarkNumber.text,		//+cnwml2 PAR20173 SFW CCMS 1091
								allSpecialLifts,
								theProductWeight,
								theProductVolume,				//+cnwml2 PAR20229 SFW CCMS 1091
								trailerType,
								purchaseOrder,										// PAR #33193
								serviceOrder,										// PAR #33193
								matchMode);											//navra1 - CR 63764/Task 64227 - 22nd May 2024				
								
		// PAR #22938 udpate reefer values if required
		if isReefer then
			_proxyBookingRefItem.setCarbonDioxide(theCarbonDioxide);
			_proxyBookingRefItem.setOxygen(theOxygen);
			_proxyBookingRefItem.setHumidity(theHumidity);
			_proxyBookingRefItem.setTemperature(theTemperature);
			_proxyBookingRefItem.setVentilation(theVentilation);
			_proxyBookingRefItem.setVentilationUnits(theVentilationUnits);
			_proxyBookingRefItem.setCurtainsIn(self.chkCurtainsIn.value);
		endif;
	endif;
	
	_proxyBookingRefItem.setHSCode(hsCode); //jlika1 TFS 55590
epilog
	delete allHazards;
	delete allSpecialLifts;
end;</source>
        <Parameter name="_proxyBookingRefItem" type="CM_BookingRefItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="selectCargoType" id="2b42dbc5-7351-4d82-833f-f0e1c02b9664">
        <updating/>
        <source>selectCargoType() updating;
// --------------------------------------------------------------------------------
// Created:		21 May 2009 by cnwjo3
//
// Purpose:		Set the cmbCargoType and possible show/hide controls
//
// 04/03/2010	cnwcs5	par 22762
// 30/11/2015   cnwma1 	PAR #36947 Temperature conversion issue
// 14/03/2016	cnwdap1	PAR #37606 Set up iso fields correctly in specific circumstance
//21 Dec 2016	cnwrs1	TFS 3151 all vehicles to have subcargotype when adding bookings
vars
	cargoType	:CM_CargoType;	// par 22762 - use local variable instead of goiing to proxy or combo
	commodity   : CM_Commodity;
begin
	//	*** DO NOT USE THIS METHOD EXCEPT WHEN FORM IS BEING LOADED ***
	//  *** IT DOES NOT TAKE INTO ACCOUNT CHANGES THE USER HAS MADE SINCE LOADING THE FORM ***
	cargoType := self.myProxyBookingRefItem.myCargoType;	// par 22762
	
	if cargoType = null then												// 08/02/2010 cnwcs5 par 22762
		cargoType := app.myRoot.allCargoTypesById [TI_CargoType_Container];	// 08/02/2010 cnwcs5 par 22762
	endif;																	// 08/02/2010 cnwcs5 par 22762
	
	self.cmbCargoType.setObject(cargoType);

	if app.isValidObject (self.myProxyBookingRefItem.myProduct) then		// par 22762
		self.cmbProduct.setObject(self.myProxyBookingRefItem.myProduct);  //cnwjo3 par 20615 need to set Product combo object too
	else																	// par 22762
		self.cmbProduct.setObject (null);									// par 22762
	endif;																	// par 22762
	
	self.width 	:= 840;
	self.height := 680;
	
	self.centreWindow();  //cnwjo3, par 20606.  need to centreWindow again after width change


	if cargoType.id = TI_CargoType_Container then	// par 22762
	
		if (self.cmbCommodity.listObject &lt;&gt; null and self.cmbCommodity.listObject.CM_Commodity.isEmpty) or 
			self.myProxyBookingRefItem.commodity = "MT" then
			// setup for empty
			self.setupISOEmptyControls();
		elseif (self.cmbIsoType.listObject &lt;&gt; null and self.cmbIsoType.listObject.CM_ISOType.isReefer) or 
			(self.myProxyBookingRefItem.myISOType &lt;&gt; null and self.myProxyBookingRefItem.myISOType.isReefer()) then
			// setup for Reefer
			self.setupISOReeferControls();
		elseif (self.cmbCommodity.listObject&lt;&gt; null) or      															//30/11/2015 cnwma1 PAR #36947
			(self.myProxyBookingRefItem.commodity &lt;&gt; null and self.myProxyBookingRefItem.isoTypeGroup &lt;&gt; null) then		//30/11/2015 cnwma1 PAR #36947
			commodity:=app.myRoot.allCommodities[self.myProxyBookingRefItem.commodity];									//30/11/2015 cnwma1 PAR #36947
			if commodity &lt;&gt; null then																					//30/11/2015 cnwma1 PAR #36947
				if commodity.hasTemp then																			    //30/11/2015 cnwma1 PAR #36947
					self.setupISOReeferControls();																		//30/11/2015 cnwma1 PAR #36947
				else											// PAR #37606
					// everything else							// PAR #37606
					self.setupISOControls();					// PAR #37606
				endif;																									//30/11/2015 cnwma1 PAR #36947
			endif;																										//30/11/2015 cnwma1 PAR #36947
		else
			// everything else
			self.setupISOControls();
		endif;
		
	elseif cargoType.productType = ProductType_Vehicle then
		// setup for vehicles
		self.setupCarControls(cargoType);
		
	elseif cargoType.id = TI_CargoType_Generator then						
		// setup Generator Fields
		self.setupGeneratorControls(self.cmbCargoType.myObject.CM_CargoType);
		
	elseif cargoType.productType = ProductType_Trailer then
		// setup for Trailers
		self.setupTrailerControls(self.cmbCargoType.myObject.CM_CargoType);
	
	else
		// General cargo (other)
		self.setupCargoControls(cargoType);
	endif;	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setCorrectComboStyle" id="fe58cbed-dd4a-4729-a9aa-8a2e7b4c56ee">
        <updating/>
        <source>setCorrectComboStyle() updating;
/*
Purpose:	During the change to 22.0.24 some combo boxes had their STYLE set to zero, this is a patchable way to fix that.				

Date		Who		Reason
11 June 2024	navab1	BUG 64462
*/

vars

begin
	inheritMethod();

	self.cmbCDType.style := 2;
	self.cmbCommodity.style := 3;
	self.cmbIsoType.style := 3;
	self.cmbSpecialStow.style := 3;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setFormObject" id="e49d5ba1-a90a-49b1-9f78-d303223ea484">
        <updating/>
        <source>setFormObject(_obj: Object) updating;
//28 September 2009	cnwml2


vars

begin
	//inheritMethod(_obj);
	self.setMyBooking(_obj.CM_BookingRefItem);
	self.setMyProxyBookingRefItem(_obj.CM_BookingRefItem);
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setMyBooking" id="e0e6ce24-db79-48f8-a807-47f17b712438">
        <updating/>
        <source>setMyBooking(_bookingItem : CM_BookingRefItem)updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 August 2009	cnwml2	Initial creation

*/

vars

begin
	self.myBookingItem := _bookingItem;
epilog

end;</source>
        <Parameter name="_bookingItem" type="CM_BookingRefItem"/>
    </JadeMethod>
    <JadeMethod name="setMyProxyBookingRefItem" id="81f43194-1abe-47dc-ba26-1051cd50dd91">
        <updating/>
        <source>setMyProxyBookingRefItem(_pxyBookingRefItem : CM_BookingRefItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
12 November 2008	cnwer1	Initial creation
8 June 2009			cnwjo3	changed from CM_BRefItemContainer to CM_BookingRefItem to handle Products + Containers (par 19840)
*/

vars

begin
	if _pxyBookingRefItem &lt;&gt; null then
		self.myProxyBookingRefItem := _pxyBookingRefItem;
	endif;
epilog

end;</source>
        <Parameter name="_pxyBookingRefItem" type="CM_BookingRefItem"/>
    </JadeMethod>
    <JadeMethod name="setProductCombo" id="95287f2a-e747-43a8-a300-d1123bb4f66b">
        <updating/>
        <source>setProductCombo() updating;
// --------------------------------------------------------------------------------
// Created:		1 Janurary 2009 by cnwjo3
//
// Purpose:		set up all products in combo box
vars

begin

	self.cmbProduct.setOperator(self.myProxyBookingRefItem.myBookingReference.myOperator);
	self.cmbProduct.setCargoType(self.cmbCargoType.myObject.CM_CargoType);

end;</source>
    </JadeMethod>
    <JadeMethod name="setSpecialStow" id="e6aac064-7c7a-49d7-ae8e-b74e839c1279">
        <source>setSpecialStow();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2009	cnwml2	Initial creation

*/

vars

begin
	self.cmbSpecialStow.listObject := self.myProxyBookingRefItem.mySpecialStow; 
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupCarControls" id="7eac4f81-f4c2-40e8-a1a2-f9e4180560bd">
        <updating/>
        <source>setupCarControls(_cargoType : CM_CargoType) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
02 July 2009	cnwml2	Initial creation
24/03/2010		cnwdap1	PAR #22938 Booking a reefer vehicle didn't display reefer details
25/03/2013		cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
03/03/2014		cnwdap1	PAR #33193 CCMS DPH 2285 Added Purchase Order and Service Order fields
15/11/2016		cnwdap1	TFS 2842 STWR Hazardous Details Enhancements
//21 Dec 2016	cnwrs1	TFS 3151 all vehicles to have subcargotype when adding bookings
01/10/2019		jlgzm1	TFS 46575 Display Reefer options for non-containers
08/02/2023		jlika1	TFS 56450 MTN - HS Code on Booking Item form
*/
constants
	MoveControl = 25;
vars
	saveTop	: Real;
	numbControlsCol2,
	ctrlNumb,
	ctrlNumb2				: Integer;
	cargoType				: CM_CargoType;
	operator				: CM_Operator; // TFS 46575
begin
	//make general group box visible
	self.grpGeneral.visible := true;
	self.showGrpGeneral();
	
	//make appropriate controls invisible
	self.lblProduct.visible := false;
	self.cmbProduct.visible := false;
	if _cargoType.isSubCargoTypeRequired then
		self.lblProduct.visible := true;
		self.cmbProduct.visible := true;
	endif;
	self.lblGeneratorType.visible := false;
	self.cmbGeneratorType.visible := false;
	self.lblTrailerType.visible := false;
	self.cmbTrailerType.visible := false;
	self.lblIsoGroup.visible := false;
	self.cmbIsoGroup.visible := false;
	self.lblIsoType.visible := false;
	self.cmbIsoType.visible := false;
	self.lblVolume.visible := false;
	//self.txtVolume.visible := false;							// PAR #31155
	self.tblVolume.visible := false;							// PAR #31155
	self.lblHsCode.visible := false;
	self.cmbHsCode.visible := false;
	self.btnHSCode.visible := false;
	
	//set controls on page
	ctrlNumb := 1;
	self.lblCargoType.top := MoveControl * ctrlNumb;
	self.cmbCargoType.top := MoveControl * ctrlNumb;
	ctrlNumb := ctrlNumb + 1;
	if _cargoType.isSubCargoTypeRequired then
		self.lblProduct.top := MoveControl * ctrlNumb;
		self.cmbProduct.top := MoveControl * ctrlNumb;
		ctrlNumb := ctrlNumb + 1;
	endif;
	self.lblCommodity.top := MoveControl * ctrlNumb;
	self.cmbCommodity.top := MoveControl * ctrlNumb;
	ctrlNumb := ctrlNumb + 1;
	if not app.myRoot.allHSCodesActive.isEmpty then
		self.lblHsCode.visible := true;
		self.cmbHsCode.visible := true;
		self.btnHSCode.visible := true;
		self.lblHsCode.top := MoveControl * ctrlNumb;
		self.cmbHsCode.top := MoveControl * ctrlNumb;
		self.btnHSCode.top := MoveControl * ctrlNumb;
		ctrlNumb := ctrlNumb + 1;
	else
		self.lblHsCode.visible := false;
		self.cmbHsCode.visible := false;
		self.btnHSCode.visible := false;
	endif;
	self.lblTotalUnits.top := MoveControl * ctrlNumb;
	self.txtTotalUnits.top := MoveControl * ctrlNumb;
	ctrlNumb := ctrlNumb + 1;
	self.lblWeight.top := MoveControl * ctrlNumb;
	//self.txtWeight.top := MoveControl * ctrlNumb;				// PAR #31155
	self.tblWeight.top := MoveControl * ctrlNumb;				// PAR #31155
	ctrlNumb := ctrlNumb + 1;
	self.lblDocStopAction.top := MoveControl * ctrlNumb;	//14 Sep 2016	NDL	TFS 2644 / 2001
	self.txtDocStopAction.top := MoveControl * ctrlNumb;	//14 Sep 2016	NDL	TFS 2644 / 2001
	self.btnDocStopAction.top := MoveControl * ctrlNumb;	//14 Sep 2016	NDL	TFS 2644 / 2001
	ctrlNumb := ctrlNumb + 1;	//14 Sep 2016	NDL	TFS 2644 / 2001
	self.lblDocTaskAction.top := MoveControl * ctrlNumb;	//14 Sep 2016	NDL	TFS 2644 / 2001
	self.txtDocTaskAction.top := MoveControl * ctrlNumb;	//14 Sep 2016	NDL	TFS 2644 / 2001
	self.btnDocTaskAction.top := MoveControl * ctrlNumb;	//14 Sep 2016	NDL	TFS 2644 / 2001
	ctrlNumb := ctrlNumb + 1;	//14 Sep 2016	NDL	TFS 2644 / 2001
	self.lblDescription.top := MoveControl * ctrlNumb;
	self.txtDescription.top := MoveControl * ctrlNumb;
	ctrlNumb := ctrlNumb + 3;										//navra1 - CR 63764/Task 64227 - 22nd May 2024
	
	self.lblMatchMode.top := MoveControl * ctrlNumb;				//navra1 - CR 63764/Task 64227 - 22nd May 2024
	self.cmbMatchMode.top := MoveControl * ctrlNumb;				//navra1 - CR 63764/Task 64227 - 22nd May 2024
	ctrlNumb 				:= ctrlNumb + 2;						//navra1 - CR 63764/Task 64227 - 22nd May 2024	
	self.txtMatchModeDetails.top := MoveControl * ctrlNumb;			//navra1 - CR 63764/Task 64227 - 22nd May 2024
	ctrlNumb := ctrlNumb + 1;
	
	//make Release and Reefer groupboxes invisible
	self.grpRelease.visible := false;
	self.grpReefer.visible := false;
	// PAR #22938 except for vehicles that can be reefers
	cargoType := self.cmbCargoType.myObject.CM_CargoType;
	
	if (cargoType &lt;&gt; null and cargoType.mySystemProductType &lt;&gt; null and cargoType.mySystemProductType.isReefer)
	or (self.cmbCommodity.listObject &lt;&gt; null and self.cmbCommodity.listObject.CM_Commodity.hasTemp) then // TFS 46575
		self.grpReefer.visible := true;
		self.grpReefer.top := self.txtMatchModeDetails.top + MoveControl * 3;					//navra1 - CR 63764/Task 64227 - 22nd May 2024
		self.grpReefer.left := 0; 	// TFS 46575
		ctrlNumb := ctrlNumb + 11;
		
		// TFS 46575
		//decide whether we display Celcius or Fahrenheit option button
		if self.myProxyBookingRefItem &lt;&gt; null and self.myProxyBookingRefItem.myBookingReference &lt;&gt; null and self.myProxyBookingRefItem.myBookingReference.myOperator &lt;&gt; null then
			operator := self.myProxyBookingRefItem.myBookingReference.myOperator;
			if operator.displayTempFahrenheit then
				self.optFahr.visible := true;
				self.optFahr.value := true;
				self.optCel.visible := false;
				self.optFahr.move(self.optCel.left, self.optCel.top, self.optCel.width, self.optCel.height);
			else
				self.optFahr.visible := false;
				self.optCel.visible := true;
				self.optCel.value := true;
			endif;
		else
			self.optCel.visible := true;
			self.optCel.value := true;
		endif;
	endif;
	// PAR #23938 end

	//make Cargo Details General group box controls invisible
	self.grpCDGeneral.visible := true;
	self.grpCDGeneral.top := 0;
	
	ctrlNumb2 := self.displaySoftAttributeOnSysProd(cargoType, cargoType.mySystemProductType, numbControlsCol2);
	self.grpCDGeneral.height := MoveControl * ctrlNumb2;
			
	//make Cargo Details controls invisible
	self.grpCargoDetails.top := MoveControl * ctrlNumb2;
	self.grpCargoDetails.visible := true;
	self.showGrpCargoDetails();
	ctrlNumb2 := ctrlNumb2 + 1;				//allow for heading
	self.lblId.top := MoveControl * 1;
	self.txtId.top := MoveControl * 1;
	ctrlNumb2 := ctrlNumb2 + 1;
	self.lblMarks.top := MoveControl * 2;
	self.txtMarks.top := MoveControl * 2;
	ctrlNumb2 := ctrlNumb2 + 1;
	self.lblMarksNumber.top := MoveControl * 3;
	self.txtMarkNumber.top := MoveControl * 3;
	ctrlNumb2 := ctrlNumb2 + 1;
	self.lblColour.top := MoveControl * 4;
	self.txtColour.top := MoveControl * 4;
	ctrlNumb2 := ctrlNumb2 + 1;
	self.lblPurchaseOrder.top := MoveControl * 5;							// PAR #33193
	self.txtPurchaseOrder.top := MoveControl * 5;							// PAR #33193
	ctrlNumb2 := ctrlNumb2 + 1;												// PAR #33193
	self.lblServiceOrder.top := MoveControl * 6;							// PAR #33193
	self.txtServiceOrder.top := MoveControl * 6;							// PAR #33193
	ctrlNumb2 := ctrlNumb2 + 1;												// PAR #33193
	//self.chkPreTripInspec.visible := false;
	//numbControlsCol2 := numbControlsCol2 + 1;
	self.lblHazards.top := MoveControl * 7;
	self.txtHazards.top := MoveControl* 7;
	self.btnHazards.top := MoveControl* 7;					// TFS 2842
	ctrlNumb2 := ctrlNumb2 + 1;
	self.lblSpecialStow.top := MoveControl * 8;
	self.cmbSpecialStow.top := MoveControl * 8;
	ctrlNumb2 := ctrlNumb2 + 1;
	self.lblSpecialLift.top := MoveControl * 9;
	self.txtSpecialLift.top := MoveControl * 9;
	ctrlNumb2 := ctrlNumb2 + 1;
	self.lblRemarks.top := MoveControl * 10;
	self.txtRemarks.top := MoveControl * 10;
	ctrlNumb2 := ctrlNumb2 + 3;
	self.grpCargoDetails.height := MoveControl * 12;
		
	//calculate how much space is needed to resize the form and buttons  
	if ctrlNumb &gt; ctrlNumb2 then
		self.btnSave.top := ctrlNumb * MoveControl;
		self.btnNext.top :=	ctrlNumb * MoveControl;
		self.btnCancel.top := ctrlNumb * MoveControl;
		self.height := self.btnSave.top + (MoveControl * 6);						//navra1 - CR 63764/Task 64227 - 22nd May 2024
	else
		self.btnSave.top := ctrlNumb2 * MoveControl;
		self.btnNext.top := ctrlNumb2 * MoveControl;
		self.btnCancel.top := ctrlNumb2 * MoveControl;
		self.height := self.btnSave.top + (MoveControl * 6);						//navra1 - CR 63764/Task 64227 - 22nd May 2024
	endif;
	// 35000 lost buttons if form is too large
	if (self.btnSave.top + MoveControl) &gt; self.grpDetail.height then
		saveTop := self.btnSave.top;
		self.grpDetail.height := self.btnSave.top + MoveControl;
		self.btnSave.top := saveTop;	// restore after parent height change because of button parentAspect setting
		self.btnNext.top := saveTop;
		self.btnCancel.top := saveTop;
	endif;
	
epilog

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="setupCargoControls" id="3236d051-4a96-448a-b192-fd7d8c47005f">
        <updating/>
        <source>setupCargoControls(_cargoType : CM_CargoType) updating;
// --------------------------------------------------------------------------------
// Created:		21 May 2009 by cnwjo3
//
// Purpose:		Set up all the controls needed for an Products and/or custom Cargo
//
//Date				Who			Reason
//11 September 2009	cnwjo3		fixed some more issues, par 20644
//25 March 2013		cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
//03 March 2014		cnwdap1		PAR #33193 CCMS DPH 2285 Added Purchase Order and Servioce Order fields
//20 March 2014		cnwdap1		PAR #33606 CCMS SFW 1366 Bulk
//20 November 2014  cnwma1      PAR #35250 1090 : Unhandled Exception while adding Booking Item
//15 November 2016	cnwdap1		TFS 2842 STWR Hazardous Details Enhancements
//01 October 2019	jlgzm1		TFS 46575 Display Reefer options for non-containers
//29 January 2020	jlgdap1		TFS 47457 JMT Web Portal Bookings - prevent booking weight / volume table from being overwritten
//13 December 2022	jlika1		TFS 55590 HS Codes to Column Organizers
//08/02/2023		jlika1		TFS 56450 MTN - HS Code on Booking Item form
constants
	MoveControl = 25;
vars
	saveTop	: Real;
	numbControlsCol2,
	ctrlNumb,
	ctrlNumb2				: Integer;
	cargoType : CM_CargoType;
	product : CM_Product;
	isBulk	: Boolean;														// PAR #33606
	cargoNumb : Integer;													// PAR #33606
	operator	: CM_Operator; // TFS 46575
	
begin
	//make general group box visible
	self.grpGeneral.visible := true;
	self.showGrpGeneral();
	cargoType	:= self.cmbCargoType.listObject.CM_CargoType;
	isBulk := _cargoType &lt;&gt; null and _cargoType.isBulkMulti;				// PAR #33606
	
	//make appropriate controls invisible
	self.lblGeneratorType.visible := false;
	self.cmbGeneratorType.visible := false;
	self.lblTrailerType.visible := false;
	self.cmbTrailerType.visible := false;
	self.lblIsoGroup.visible := false;
	self.cmbIsoGroup.visible := false;
	self.lblIsoType.visible := false;
	self.cmbIsoType.visible := false;
	self.lblHsCode.visible := false;
	self.cmbHsCode.visible := false;
	self.btnHSCode.visible := false;
	
	//set controls on page
	ctrlNumb := 1;
	self.lblCargoType.top := MoveControl * ctrlNumb;
	self.cmbCargoType.top := MoveControl * ctrlNumb;
	ctrlNumb := ctrlNumb + 1;
	if _cargoType &lt;&gt; null and 	// par 22762
		_cargoType.isSubCargoTypeRequired then
		self.lblProduct.visible := true;
		self.cmbProduct.visible := true;
		self.lblProduct.top := MoveControl * ctrlNumb;
		self.cmbProduct.top := MoveControl * ctrlNumb;
		ctrlNumb := ctrlNumb + 1;
	else
		self.lblProduct.visible := false;
		self.cmbProduct.visible := false;
	endif;
	
	if _cargoType &lt;&gt; null and 	// par 22762
		_cargoType.isCommodityRequired then
		self.lblCommodity.visible := true;
		self.cmbCommodity.visible := true;
		self.lblCommodity.top := MoveControl * ctrlNumb;
		self.cmbCommodity.top := MoveControl * ctrlNumb;
		ctrlNumb := ctrlNumb + 1;
	else
		self.lblCommodity.visible := false;
		self.cmbCommodity.visible := false;
	endif;
	
	if not app.myRoot.allHSCodesActive.isEmpty then
		self.lblHsCode.visible := true;
		self.cmbHsCode.visible := true;
		self.btnHSCode.visible := true;
		self.lblHsCode.top := MoveControl * ctrlNumb;
		self.cmbHsCode.top := MoveControl * ctrlNumb;
		self.btnHSCode.top := MoveControl * ctrlNumb;
		ctrlNumb := ctrlNumb + 1;
	else
		self.lblHsCode.visible := false;
		self.cmbHsCode.visible := false;
		self.btnHSCode.visible := false;
	endif;
	
	if isBulk then 																		// PAR #33606
		self.lblTotalUnits.visible := false;											// PAR #33606
		self.txtTotalUnits.visible := false;											// PAR #33606
	else																				// PAR #33606
		self.lblTotalUnits.visible := true;												// PAR #33606
		self.txtTotalUnits.visible := true;												// PAR #33606
		self.lblTotalUnits.top := MoveControl * ctrlNumb;
		self.txtTotalUnits.top := MoveControl * ctrlNumb;
		ctrlNumb := ctrlNumb + 1;
	endif;	
	
	//epr par 32951
	product:=null;
	if self.cmbProduct.visible then
		product 	:= self.cmbProduct.listObject.CM_Product;
		self.setProductCombo();
		
		if product &lt;&gt; null and _cargoType.allProducts.includes(product)  then
			self.cmbProduct.setObject( product);
		else
			self.cmbProduct.setObject( _cargoType.allProducts.first);
			product 	:= self.cmbProduct.listObject.CM_Product;
		endif;
	else 																					//cnwmc5 - 24 Nov 2015 - PAR 37120
		self.cmbProduct.setObject(null);													//cnwmc5 - 24 Nov 2015 - PAR 37120
	endif;
	if _cargoType&lt;&gt; null and _cargoType.isBulkMulti and product = null then					// PAR #33606  PAR #35250 
		product := _cargoType.mySystemProductType;											// PAR #33606
	endif;		
	
	// PAR #33606
	if _cargoType &lt;&gt; null and not _cargoType.isBulkByVolume then
		self.lblWeight.top := MoveControl * ctrlNumb;
		self.tblWeight.top := MoveControl * ctrlNumb;							// PAR #31155
		if _cargoType.isBulkByWeight then
			if self.tblWeight.accessCell(1,1).text = null then		// TFS 47457
				self.tblWeight.setValues(Space &amp; _cargoType.myWeightMeasurementType.shortName);	// PAR #33606
			endif;													// TFS 47457
		else
			if product &lt;&gt; null then																	// PAR #33606
				if self.tblWeight.accessCell(1,1).text = null then	// TFS 47457
					self.tblWeight.setValues(Space &amp; product.getMyWeight.myMeasurementType.shortName);	// PAR #33606
				endif;												// TFS 47457
			endif;
		endif;
		self.tblWeight.enabled:=true;		
		ctrlNumb := ctrlNumb + 1;
	else
		self.lblWeight.visible:=false;
		self.tblWeight.visible:=false;
	endif;
	
	if _cargoType &lt;&gt; null and _cargoType.isBulkByVolume then																// PAR #33606
		self.lblVolume.visible := true;
		self.tblVolume.visible := true;											// PAR #31155
		self.lblVolume.top := MoveControl * ctrlNumb;
		self.tblVolume.top := MoveControl * ctrlNumb;							// PAR #31155
		if self.tblVolume.accessCell(1,1).text = null then			// TFS 47457
			self.tblVolume.setValues(Space &amp; _cargoType.myVolumeMeasurementType.shortName);	// PAR #33606
		endif;														// TFS 47457
		ctrlNumb := ctrlNumb + 1;
	else
		self.lblVolume.visible := false;
		self.tblVolume.visible := false;										// PAR #31155
	endif;
	self.lblDocStopAction.top := MoveControl * ctrlNumb;	//14 Sep 2016	NDL	TFS 2644 / 2001
	self.txtDocStopAction.top := MoveControl * ctrlNumb;	//14 Sep 2016	NDL	TFS 2644 / 2001
	self.btnDocStopAction.top := MoveControl * ctrlNumb;	//14 Sep 2016	NDL	TFS 2644 / 2001
	ctrlNumb := ctrlNumb + 1;	//14 Sep 2016	NDL	TFS 2644 / 2001
	self.lblDocTaskAction.top := MoveControl * ctrlNumb;	//14 Sep 2016	NDL	TFS 2644 / 2001
	self.txtDocTaskAction.top := MoveControl * ctrlNumb;	//14 Sep 2016	NDL	TFS 2644 / 2001
	self.btnDocTaskAction.top := MoveControl * ctrlNumb;	//14 Sep 2016	NDL	TFS 2644 / 2001
	ctrlNumb := ctrlNumb + 1;	//14 Sep 2016	NDL	TFS 2644 / 2001
	self.lblDescription.top := MoveControl * ctrlNumb;
	self.txtDescription.top := MoveControl * ctrlNumb;
	ctrlNumb := ctrlNumb + 3;										//navra1 - CR 63764/Task 64227 - 22nd May 2024
	
	self.lblMatchMode.top := MoveControl * ctrlNumb;				//navra1 - CR 63764/Task 64227 - 22nd May 2024
	self.cmbMatchMode.top := MoveControl * ctrlNumb;				//navra1 - CR 63764/Task 64227 - 22nd May 2024
	ctrlNumb 				:= ctrlNumb + 2;						//navra1 - CR 63764/Task 64227 - 22nd May 2024	
	self.txtMatchModeDetails.top := MoveControl * ctrlNumb;			//navra1 - CR 63764/Task 64227 - 22nd May 2024
	ctrlNumb := ctrlNumb + 1;										//navra1 - CR 63764/Task 64227 - 22nd May 2024

	//make Release and Reefer groupboxes invisible
	self.grpRelease.visible := false;
	
	// TFS 46575 Start
	if self.cmbCommodity.listObject &lt;&gt; null and self.cmbCommodity.listObject.CM_Commodity.hasTemp then 
		self.grpReefer.visible := true;
		self.grpReefer.top := self.txtMatchModeDetails.top + MoveControl * 3;									//navra1 - CR 63764/Task 64227 - 22nd May 2024
		self.grpReefer.left := 0;
		ctrlNumb := ctrlNumb + 11;
		
		if self.myProxyBookingRefItem &lt;&gt; null and self.myProxyBookingRefItem.myBookingReference &lt;&gt; null and self.myProxyBookingRefItem.myBookingReference.myOperator &lt;&gt; null then
			operator := self.myProxyBookingRefItem.myBookingReference.myOperator;
			if operator.displayTempFahrenheit then
				self.optFahr.visible := true;
				self.optFahr.value := true;
				self.optCel.visible := false;
				self.optFahr.move(self.optCel.left, self.optCel.top, self.optCel.width, self.optCel.height);
			else
				self.optFahr.visible := false;
				self.optCel.visible := true;
				self.optCel.value := true;
			endif;
		else
			self.optCel.visible := true;
			self.optCel.value := true;
		endif;
	else
		self.grpReefer.visible := false;
	endif;
	// TFS 46575 end
	
	//make Cargo Details General group box with correct controls
	self.grpCDGeneral.visible := true;
	self.grpCDGeneral.top := 3;
	

	if cargoType = null then	// par 22762
		ctrlNumb2 := self.displaySoftAttributeOnSysProd(cargoType, null, numbControlsCol2);	// par 22762
	elseif (cargoType &lt;&gt; null and 	// par 22762
		cargoType.isSubCargoTypeRequired = false) then
		ctrlNumb2 := self.displaySoftAttributeOnSysProd(cargoType, cargoType.mySystemProductType, numbControlsCol2);
	else
		if product &lt;&gt; null then
			ctrlNumb2 := self.displaySoftAttributeOnSysProd(cargoType, product, numbControlsCol2);
		endif;
	endif;
	
	self.grpCDGeneral.height := MoveControl * ctrlNumb2;
	
	//make Cargo Details with correct controls
	self.grpCargoDetails.top := MoveControl * ctrlNumb2;
	self.grpCargoDetails.visible := true;
	self.showGrpCargoDetails();
	ctrlNumb2 := ctrlNumb2 + 1;				//allow for heading
	cargoNumb := 1;
	self.lblId.visible := true;
	self.txtId.visible := true;
	self.lblId.top := MoveControl;
	self.txtId.top := MoveControl;
	ctrlNumb2 := ctrlNumb2 + 1;
	cargoNumb := cargoNumb + 1;
	if cargoType &lt;&gt; null and cargoType.isBulkProduct then				// PAR #33606
		self.lblMarks.visible := false;									// PAR #33606
		self.txtMarks.visible := false;									// PAR #33606
	else																// PAR #33606
		self.lblMarks.visible := true;
		self.txtMarks.visible := true;
		self.lblMarks.top := MoveControl * cargoNumb;//2;				// PAR #33606
		self.txtMarks.top := MoveControl * cargoNumb;//2;				// PAR #33606
		ctrlNumb2 := ctrlNumb2 + 1;
		cargoNumb := cargoNumb + 1;										// PAR #33606
	endif;																// PAR #33606
	if cargoType &lt;&gt; null and cargoType.isBulkProduct then				// PAR #33606
		self.lblMarksNumber.visible := false;							// PAR #33606
		self.txtMarkNumber.visible := false;							// PAR #33606
	else																// PAR #33606
		self.lblMarksNumber.visible := true;
		self.txtMarkNumber.visible := true;
		self.lblMarksNumber.top := MoveControl * cargoNumb;//3;			// PAR #33606
		self.txtMarkNumber.top := MoveControl * cargoNumb;//3;			// PAR #33606
		ctrlNumb2 := ctrlNumb2 + 1;
		cargoNumb := cargoNumb + 1;										// PAR #33606
	endif;																// PAR #33606
	if cargoType &lt;&gt; null and cargoType.isBulkProduct then				// PAR #33606
		self.lblColour.visible := false;								// PAR #33606
		self.txtColour.visible := false;								// PAR #33606
	else																// PAR #33606
		self.lblColour.visible := true;
		self.txtColour.visible := true;
		self.lblColour.top := MoveControl * cargoNumb;//4;				// PAR #33606
		self.txtColour.top := MoveControl * cargoNumb;//4;				// PAR #33606
		ctrlNumb2 := ctrlNumb2 + 1;
		cargoNumb := cargoNumb + 1;										// PAR #33606
	endif;																// PAR #33606
	self.chkPreTripInspec.visible := false;
	numbControlsCol2 := numbControlsCol2 + 1;
	self.lblPurchaseOrder.top := MoveControl * cargoNumb;//5;				// PAR #33193
	self.txtPurchaseOrder.top := MoveControl * cargoNumb;//5;				// PAR #33193
	ctrlNumb2 := ctrlNumb2 + 1;												// PAR #33193
	cargoNumb := cargoNumb + 1;											// PAR #33606
	self.lblServiceOrder.top := MoveControl * cargoNumb;//6;				// PAR #33193
	self.txtServiceOrder.top := MoveControl * cargoNumb;//6;				// PAR #33193
	ctrlNumb2 := ctrlNumb2 + 1;												// PAR #33193
	cargoNumb := cargoNumb + 1;											// PAR #33606
	self.lblHazards.top := MoveControl * cargoNumb;//7;
	self.txtHazards.top := MoveControl * cargoNumb;//7;
	self.btnHazards.top := MoveControl * cargoNumb;			/// TFS 2842
	ctrlNumb2 := ctrlNumb2 + 1;
	cargoNumb := cargoNumb + 1;											// PAR #33606
	self.lblSpecialStow.top := MoveControl * cargoNumb;//8;
	self.cmbSpecialStow.top := MoveControl * cargoNumb;//8;
	ctrlNumb2 := ctrlNumb2 + 1;
	cargoNumb := cargoNumb + 1;											// PAR #33606
	self.lblSpecialLift.top := MoveControl * cargoNumb;//9;
	self.txtSpecialLift.top := MoveControl * cargoNumb;//9;
	ctrlNumb2 := ctrlNumb2 + 1;
	cargoNumb := cargoNumb + 1;											// PAR #33606
	self.lblRemarks.top := MoveControl * cargoNumb;//10;
	self.txtRemarks.top := MoveControl * cargoNumb;//10;
	ctrlNumb2 := ctrlNumb2 + 3;
	cargoNumb := cargoNumb + 3;											// PAR #33606
	self.grpCargoDetails.height := MoveControl * cargoNumb;//12;
		
	//calculate how much space is needed to resize the form and buttons  
	if ctrlNumb &gt; ctrlNumb2 then
		self.btnSave.top := ctrlNumb * MoveControl;
		self.btnNext.top :=	ctrlNumb * MoveControl;
		self.btnCancel.top := ctrlNumb * MoveControl;
		self.height := self.btnSave.top + (MoveControl * 6);				//navra1 - CR 63764/Task 64227 - 22nd May 2024
	else
		self.btnSave.top := ctrlNumb2 * MoveControl;
		self.btnNext.top := ctrlNumb2 * MoveControl;
		self.btnCancel.top := ctrlNumb2 * MoveControl;
		self.height := self.btnSave.top + (MoveControl * 6);				//navra1 - CR 63764/Task 64227 - 22nd May 2024
	endif;
	// 35000 lost buttons if form is too large
	if (self.btnSave.top + MoveControl) &gt; self.grpDetail.height then
		saveTop := self.btnSave.top;
		self.grpDetail.height := self.btnSave.top + MoveControl;
		self.btnSave.top := saveTop;	// restore after parent height change because of button parentAspect setting
		self.btnNext.top := saveTop;
		self.btnCancel.top := saveTop;
	endif;
	
epilog

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="13d82d1d-69cb-4f40-a86e-9abbc0e34665">
        <updating/>
        <source>setupForm() updating;
//
// 17/02/2010	cnwdap1	PAR #22397 Move cmbCommodity.click to before loadBookingRefItem - was resetting type combo
// 25/03/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
//
vars
	captionStr	: String;
	co2,
	o2 : StringUtf8;
	commodity : CM_Commodity;
	isoType   : CM_ISOType;
begin
	inheritMethod();
	
	self.cmbCargoType.filterIgnore := true;  // ### BUG 56854 08MAR2023 NAVAB1
	self.cmbCommodity.filterIgnore := true;  // ### BUG 56854 08MAR2023 NAVAB1
	
	self.grpGeneral.enabled := true;
	self.grpRelease.enabled := true;
	self.grpDetail.enabled := true;
	self.grpReefer.enabled := true;
	self.grpCargoDetails.enabled := true;
	self.grpCDGeneral.enabled := true;
	
	if self.isNewItem then
		captionStr	:= app.getErrorString( Adding_Booking_Item );
	else
		captionStr	:= app.getErrorString( Editing_Booking_Item );
	endif;
	
	captionStr	:= captionStr &amp; self.myProxyBookingRefItem.myBookingReference.bookingReference;	
	
	
	//self.optPound.visible:=false;							// PAR #31155
	self.optFahr.visible:=false;
	self.txtCO2.text:=null;
	self.txtTemperature.text:=null;
	self.txtO2.text:=null;

	self.centreWindow();
	self.grpDetail.left := 10;
	self.grpDetail.width := self.width-35;
	self.borderStyle := Window.BorderStyle_Single;  //in painter have it Resizable for design purposes
	
	self.setupMeasurementControls();						// PAR #31155

	self.setCaption(captionStr);
	self.selectCargoType();						
	self.loadCombos(self.myProxyBookingRefItem.myCargoType);  //+cnwml2 PAR22590
	self.loadBookingRefItem();	
	
	// TFS 46575 jlgzm1 02/10/2019
	if not isNewItem then
		// will reset controls based on new information from loading booking item
		self.changeGenCombo(false);
	endif;

	co2:=@"C0&amp;#x2082;%:"; //would work if it was a unicode system
	o2:=@"0&amp;#x2082;%:";
	self.optCel.caption:=Degrees_C;
	self.optFahr.caption:=Degrees_F;
	self.lblCO2.caption:=co2.String;
	self.lblO2.caption:=o2.String;
		
	
	if isReadOnly then
		self.grpGeneral.enabled := false;
		self.grpRelease.enabled := false;
		self.grpReefer.enabled := false;
		self.grpCargoDetails.enabled := false;
		self.grpCDGeneral.enabled := false;
		self.btnSave.enabled := false;
		self.btnNext.enabled := false;
	endif;

	self.modalResult := IDCANCEL;	// set this her in case they use cntrl_F4 to close the form
end;</source>
    </JadeMethod>
    <JadeMethod name="setupGeneratorControls" id="74d09a32-e599-4bdd-b2d3-ec7cb81d9f10">
        <updating/>
        <source>setupGeneratorControls(_cargoType : CM_CargoType) updating;
//16 October 2009	cnwml2
// Changed On	By			Reason
// ----------	---------	------------------------------------------------------------------
// 03/03/2014	cnwdap1		PAR #33193 CCMS DPH 2284 Added Purchase Order and Service Order fields
// 15/11/2016	cnwdap1		TFS 2842 STWR Hazardous Details Enhancements
//08/02/2023	jlika1		TFS 56450 MTN - HS Code on Booking Item form
constants
	MoveControl = 25;
vars
	ctrlNumb, ctrlNumb2 : Integer;
begin
//make general group box visible
	self.grpGeneral.visible := true;
	self.showGrpGeneral();
	
	//make appropriate controls invisible
	self.lblTrailerType.visible := false;
	self.cmbTrailerType.visible := false;
	self.lblProduct.visible := false;
	self.cmbProduct.visible := false;
	self.lblIsoGroup.visible := false;
	self.cmbIsoGroup.visible := false;
	self.lblIsoType.visible := false;
	self.cmbIsoType.visible := false;
	self.lblCommodity.visible := false;
	self.cmbCommodity.visible := false;
	self.lblHsCode.visible := false;
	self.cmbHsCode.visible := false;
	self.btnHSCode.visible := false;
	
	//set controls on page
	ctrlNumb := 1;
	self.lblCargoType.top := MoveControl * ctrlNumb;
	self.cmbCargoType.top := MoveControl * ctrlNumb;
	ctrlNumb := ctrlNumb + 1;
	self.lblGeneratorType.top := MoveControl * ctrlNumb;
	self.cmbGeneratorType.top := MoveControl * ctrlNumb;
	ctrlNumb := ctrlNumb + 1;

	self.lblTotalUnits.top := MoveControl * ctrlNumb;
	self.txtTotalUnits.top := MoveControl * ctrlNumb;
	ctrlNumb := ctrlNumb + 1;
	self.lblWeight.top := MoveControl * ctrlNumb;
	//self.txtWeight.top := MoveControl * ctrlNumb;							// PAR #31155
	self.tblWeight.top := MoveControl * ctrlNumb;							// PAR #31155
	ctrlNumb := ctrlNumb + 1;
	if _cargoType.allAttributesOnProduct.includes(ETRow_MyVolume) then	
		self.lblVolume.visible := true;
		//self.txtVolume.visible := true;									// PAR #31155
		self.tblVolume.visible := true;										// PAR #31155
		self.lblVolume.top := MoveControl * ctrlNumb;
		//self.txtVolume.top := MoveControl * ctrlNumb;						// PAR #31155
		self.tblVolume.top := MoveControl * ctrlNumb;						// PAR #31155
		ctrlNumb := ctrlNumb + 1;
	else
		self.lblVolume.visible := false;
		//self.txtVolume.visible := false;									// PAR #31155
		self.tblVolume.visible := false;									// PAR #31155
	endif;
	self.lblDocStopAction.top := MoveControl * ctrlNumb;		//14 Sep 2016	NDL	TFS 2644 / 2001
	self.txtDocStopAction.top := MoveControl * ctrlNumb;		//14 Sep 2016	NDL	TFS 2644 / 2001
	self.btnDocStopAction.top := MoveControl * ctrlNumb;	//14 Sep 2016	NDL	TFS 2644 / 2001
	ctrlNumb := ctrlNumb + 1;		//14 Sep 2016	NDL	TFS 2644 / 2001
	self.lblDocTaskAction.top := MoveControl * ctrlNumb;	//14 Sep 2016	NDL	TFS 2644 / 2001
	self.txtDocTaskAction.top := MoveControl * ctrlNumb;	//14 Sep 2016	NDL	TFS 2644 / 2001
	self.btnDocTaskAction.top := MoveControl * ctrlNumb;	//14 Sep 2016	NDL	TFS 2644 / 2001
	ctrlNumb := ctrlNumb + 1;	//14 Sep 2016	NDL	TFS 2644 / 2001
	self.lblDescription.top := MoveControl * ctrlNumb;
	self.txtDescription.top := MoveControl * ctrlNumb;
	ctrlNumb := ctrlNumb + 3;										//navra1 - CR 63764/Task 64227 - 22nd May 2024
	
	self.lblMatchMode.top := MoveControl * ctrlNumb;				//navra1 - CR 63764/Task 64227 - 22nd May 2024
	self.cmbMatchMode.top := MoveControl * ctrlNumb;				//navra1 - CR 63764/Task 64227 - 22nd May 2024
	ctrlNumb 				:= ctrlNumb + 2;						//navra1 - CR 63764/Task 64227 - 22nd May 2024	
	self.txtMatchModeDetails.top := MoveControl * ctrlNumb;			//navra1 - CR 63764/Task 64227 - 22nd May 2024
	ctrlNumb := ctrlNumb + 1;										//navra1 - CR 63764/Task 64227 - 22nd May 2024

	//make Release, Reefer and Cargo Details General groupboxes invisible
	self.grpRelease.visible := false;
	self.grpReefer.visible := false;
	self.grpCDGeneral.visible := false;
	

	ctrlNumb2 := 0;
	self.grpCargoDetails.top := MoveControl * ctrlNumb2;
	self.grpCargoDetails.visible := true;
	self.showGrpCargoDetails();
	
	//make colour invisible
	self.lblColour.visible := false;
	self.txtColour.visible := false;
	
	//align controls
	ctrlNumb2 := ctrlNumb2 + 1;				//allow for heading
	self.lblId.top := MoveControl * ctrlNumb2;
	self.txtId.top := MoveControl * ctrlNumb2;
	ctrlNumb2 := ctrlNumb2 + 1;
	self.lblMarks.top := MoveControl * ctrlNumb2;
	self.txtMarks.top := MoveControl * ctrlNumb2;
	ctrlNumb2 := ctrlNumb2 + 1;
	self.lblMarksNumber.top := MoveControl * ctrlNumb2;
	self.txtMarkNumber.top := MoveControl * ctrlNumb2;
	ctrlNumb2 := ctrlNumb2 + 1;
	self.lblPurchaseOrder.top := MoveControl * ctrlNumb2;					// PAR #33193
	self.txtPurchaseOrder.top := MoveControl * ctrlNumb2;					// PAR #33193
	ctrlNumb2 := ctrlNumb2 + 1;												// PAR #33193
	self.lblServiceOrder.top := MoveControl * ctrlNumb2;					// PAR #33193
	self.txtServiceOrder.top := MoveControl * ctrlNumb2;					// PAR #33193
	ctrlNumb2 := ctrlNumb2 + 1;												// PAR #33193
	self.lblHazards.top := MoveControl * ctrlNumb2;
	self.txtHazards.top := MoveControl* ctrlNumb2;
	self.btnHazards.top := MoveControl* ctrlNumb2;			// TFS 2842
	ctrlNumb2 := ctrlNumb2 + 1;
	self.lblSpecialStow.top := MoveControl * ctrlNumb2;
	self.cmbSpecialStow.top := MoveControl * ctrlNumb2;
	ctrlNumb2 := ctrlNumb2 + 1;
	self.lblSpecialLift.top := MoveControl * ctrlNumb2;
	self.txtSpecialLift.top := MoveControl * ctrlNumb2;
	ctrlNumb2 := ctrlNumb2 + 1;
	self.lblRemarks.top := MoveControl * ctrlNumb2;
	self.txtRemarks.top := MoveControl * ctrlNumb2;
	ctrlNumb2 := ctrlNumb2 + 3;
	self.grpCargoDetails.height := MoveControl * 12;
		
	//calculate how much space is needed to resize the form and buttons  
	if ctrlNumb &gt; ctrlNumb2 then
		self.btnSave.top := ctrlNumb * MoveControl;
		self.btnNext.top :=	ctrlNumb * MoveControl;
		self.btnCancel.top := ctrlNumb * MoveControl;
		self.height := self.btnSave.top + (MoveControl * 4);						//navra1 - CR 63764/Task 64227 - 22nd May 2024
	else
		self.btnSave.top := ctrlNumb2 * MoveControl;
		self.btnNext.top := ctrlNumb2 * MoveControl;
		self.btnCancel.top := ctrlNumb2 * MoveControl;
		self.height := self.btnSave.top + (MoveControl * 4);						//navra1 - CR 63764/Task 64227 - 22nd May 2024
	endif;

epilog

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="setupISOControls" id="7c32fb2f-37c9-4e74-b96d-a42f758feda0">
        <updating/>
        <source>setupISOControls() updating;
// --------------------------------------------------------------------------------
// Created:		21 May 2009 by cnwjo3
//
// Purpose:		Set up all the controls needed for an ISO Container
//
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------------
// 25/03/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// 03/03/2014	cnwdap1		PAR #33193 CCMS DPH 2285 Added Purchase Order and Service Order fields
// 15/11/2016	cnwdap1		TFS 2842 STWR Hazardous Details Enhancements
// 13/12/2022	jlika1		TFS 55590 HS Codes to Column Organizers
// 08/02/2023	jlika1		TFS 56450 MTN - HS Code on Booking Item form
constants
	MoveControl = 25;
vars
	ctrlNumb,
	ctrlNumb2		: Integer;
begin
	//self.setProductCombo(false);							//-cnwml2 PAR20173 SFW CCMS 1091
	//self.showHideControls(true,false);					//-cnwml2 PAR20173 SFW CCMS 1091
	//self.setupGroupBoxes();								//-cnwml2 PAR20173 SFW CCMS 1091

	//+cnwml2 PAR20173 SFW CCMS 1091 start
	
	//make general group box visible
	self.grpGeneral.visible := true;
	self.showGrpGeneral();
	
	//make appropriate controls invisible
	self.lblGeneratorType.visible := false;
	self.cmbGeneratorType.visible := false;
	self.lblTrailerType.visible := false;
	self.cmbTrailerType.visible := false;
	self.lblProduct.visible := false;
	self.cmbProduct.visible := false;
	self.lblVolume.visible := false;
	//self.txtVolume.visible := false;										// PAR #31155
	self.tblVolume.visible := false;										// PAR #31155
	self.lblDescription.visible := false;
	self.txtDescription.visible := false;
	self.lblHsCode.visible := false;
	self.cmbHsCode.visible := false;
	self.btnHSCode.visible := false;
	
	ctrlNumb := 1;				//include heading
	//set controls on the page
	self.lblCargoType.top := MoveControl;
	self.cmbCargoType.top := MoveControl;
	ctrlNumb := ctrlNumb + 1;
	self.lblIsoGroup.top :=  MoveControl * ctrlNumb;
	self.cmbIsoGroup.top :=  MoveControl * ctrlNumb;
	ctrlNumb := ctrlNumb + 1;
	self.lblIsoType.top :=  MoveControl * ctrlNumb;
	self.cmbIsoType.top :=  MoveControl * ctrlNumb;
	ctrlNumb := ctrlNumb + 1;
	self.lblCommodity.top :=  MoveControl * ctrlNumb;
	self.cmbCommodity.top :=  MoveControl * ctrlNumb;
	ctrlNumb := ctrlNumb + 1;
	
	if not app.myRoot.allHSCodesActive.isEmpty then
		self.lblHsCode.visible := true;
		self.cmbHsCode.visible := true;
		self.btnHSCode.visible := true;
		self.lblHsCode.top := MoveControl * ctrlNumb;
		self.cmbHsCode.top := MoveControl * ctrlNumb;
		self.btnHSCode.top := MoveControl * ctrlNumb;
		ctrlNumb := ctrlNumb + 1;
	else
		self.lblHsCode.visible := false;
		self.cmbHsCode.visible := false;
		self.btnHSCode.visible := false;
	endif;
	
	self.lblTotalUnits.top :=  MoveControl * ctrlNumb;
	self.txtTotalUnits.top := MoveControl * ctrlNumb;
	ctrlNumb := ctrlNumb + 1;
	self.lblWeight.top :=  MoveControl * ctrlNumb;
	//self.txtWeight.top :=  MoveControl * ctrlNumb;						// PAR #31155
	self.tblWeight.top :=  MoveControl * ctrlNumb;							// PAR #31155
	ctrlNumb := ctrlNumb + 1;
	
	self.lblDocStopAction.top :=  MoveControl * ctrlNumb;	//14 Sep 2016	NDL	TFS 2644 / 2001
	self.txtDocStopAction.top := MoveControl * ctrlNumb;	//14 Sep 2016	NDL	TFS 2644 / 2001
	self.btnDocStopAction.top := MoveControl * ctrlNumb;	//14 Sep 2016	NDL	TFS 2644 / 2001
	ctrlNumb := ctrlNumb + 1;	//14 Sep 2016	NDL	TFS 2644 / 2001
	self.lblDocTaskAction.top := MoveControl * ctrlNumb;	//14 Sep 2016	NDL	TFS 2644 / 2001
	self.txtDocTaskAction.top := MoveControl * ctrlNumb;	//14 Sep 2016	NDL	TFS 2644 / 2001
	self.btnDocTaskAction.top := MoveControl * ctrlNumb;	//14 Sep 2016	NDL	TFS 2644 / 2001
	ctrlNumb := ctrlNumb + 1;	//14 Sep 2016	NDL	TFS 2644 / 2001
	
	self.lblMatchMode.top := MoveControl * ctrlNumb;				//navra1 - CR 63764/Task 64227 - 22nd May 2024
	self.cmbMatchMode.top := MoveControl * ctrlNumb;				//navra1 - CR 63764/Task 64227 - 22nd May 2024
	ctrlNumb 				:= ctrlNumb + 2;						//navra1 - CR 63764/Task 64227 - 22nd May 2024	
	self.txtMatchModeDetails.top := MoveControl * ctrlNumb;			//navra1 - CR 63764/Task 64227 - 22nd May 2024
	ctrlNumb := ctrlNumb + 5;										//navra1 - CR 63764/Task 64227 - 22nd May 2024
	
	self.grpGeneral.height := MoveControl * ctrlNumb;
	
	//move release group box up the page and make visible
	if self.txtMaxRel.enabled then
		self.grpRelease.top := ctrlNumb * MoveControl;
		self.grpRelease.height := 150;
		self.grpRelease.visible := true;
		ctrlNumb := ctrlNumb + 6;  //6 controls including heading
		if self.txtMaxRel.text.Integer &lt; 1 then
			self.chkIsClean.enabled := false;
			self.chkHeavy.enabled := false;
			self.chkPreTripInspec.enabled := false;
			self.lblAvaliabilityG.enabled := false;
			self.cmbAvalGrade.enabled := false;
		else
			self.chkIsClean.enabled := true;
			self.chkHeavy.enabled := true;
			self.chkPreTripInspec.enabled := true;
			self.lblAvaliabilityG.enabled := true;
			self.cmbAvalGrade.enabled := true;
		endif;
	else
		self.grpRelease.visible := false;
	endif;
	
	//make reefer groupbox invisible with 9 controls
	self.grpReefer.visible := false;
	
	//move to Column 2
	//make Cargo Details General group box invisible with 15 controls adjust groupbox height
	ctrlNumb2 := 1; 				//take into account heading
	self.hideCDGeneralGroupBox();
	self.grpCDGeneral.height := MoveControl * ctrlNumb;
	
	
	//make appropriate controls visible/invisible
	self.showGrpCargoDetails();
	self.lblId.visible := false;
	self.txtId.visible := false;
	self.lblMarks.visible := false;
	self.txtMarks.visible := false;
	self.lblMarksNumber.visible := false;
	self.txtMarkNumber.visible := false;
	self.lblColour.visible := false;
	self.txtColour.visible := false;

	
	//move Cargo Details group box to appropriate place
	self.grpCargoDetails.top := 3;
	self.grpCargoDetails.visible := true;
	self.lblPurchaseOrder.top := MoveControl * ctrlNumb2;					// PAR #33193
	self.txtPurchaseOrder.top := MoveControl * ctrlNumb2;					// PAR #33193
	ctrlNumb2 := ctrlNumb2 + 1;												// PAR #33193
	self.lblServiceOrder.top := MoveControl * ctrlNumb2;					// PAR #33193
	self.txtServiceOrder.top := MoveControl * ctrlNumb2;					// PAR #33193
	ctrlNumb2 := ctrlNumb2 + 1;												// PAR #33193
	self.lblHazards.top := MoveControl * ctrlNumb2;
	self.txtHazards.top := MoveControl* ctrlNumb2;
	self.btnHazards.top := MoveControl* ctrlNumb2;				// TFS 2842
	ctrlNumb2 := ctrlNumb2 + 1;
	self.lblSpecialStow.top := MoveControl * ctrlNumb2;
	self.cmbSpecialStow.top := MoveControl * ctrlNumb2;
	ctrlNumb2 := ctrlNumb2 + 1;
	self.lblSpecialLift.top := MoveControl * ctrlNumb2;
	self.txtSpecialLift.top := MoveControl * ctrlNumb2;
	ctrlNumb2 := ctrlNumb2 + 1;
	self.lblRemarks.top := MoveControl * ctrlNumb2;
	self.txtRemarks.top := MoveControl * ctrlNumb2;
	ctrlNumb2 := ctrlNumb2 + 3;	
	
	self.grpCargoDetails.height := MoveControl * ctrlNumb2;
	
	//calculate how much space is needed to resize the form and buttons  
	if ctrlNumb &gt; ctrlNumb2 then
		self.btnSave.top := ctrlNumb * MoveControl;
		self.btnNext.top :=	ctrlNumb * MoveControl;
		self.btnCancel.top := ctrlNumb * MoveControl;
		self.height := btnSave.top + (MoveControl * 3);
	else
		self.btnSave.top := ctrlNumb2 * MoveControl;
		self.btnNext.top := ctrlNumb2 * MoveControl;
		self.btnCancel.top := ctrlNumb2 * MoveControl;
		self.height := btnSave.top + (MoveControl * 3);
	endif;
	//+cnwml2 PAR20173 SFW CCMS 1091 end
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupISOEmptyControls" id="07e0b146-3448-4313-a1f8-49158784a2c3">
        <updating/>
        <source>setupISOEmptyControls() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02/07/2009	cnwml2	Initial creation
25/03/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
03/03/2014	cnwdap1	PAR #33193 CCMS DPGH 2285 Added Purchase Order and Service Order fields
15/11/2016	cnwdap1	TFS 2842 STWR Hazardous Details Enhancements
08/02/2023	jlika1	TFS 56450 MTN - HS Code on Booking Item form
*/

constants
	MoveControl = 25;
vars
	ctrlNumb,
	ctrlNumb2			: Integer;
begin

	
	//make general group box visible
	self.grpGeneral.visible := true;
	self.showGrpGeneral();
	
	//make appropriate controls invisible
	self.lblGeneratorType.visible := false;
	self.cmbGeneratorType.visible := false;
	self.lblTrailerType.visible := false;
	self.cmbTrailerType.visible := false;
	self.lblProduct.visible := false;
	self.cmbProduct.visible := false;
	self.lblVolume.visible := false;
	//self.txtVolume.visible := false;									// PAR #31155
	self.tblVolume.visible := false;									// PAR #31155
	self.lblDescription.visible := false;
	self.txtDescription.visible := false;
	self.lblHsCode.visible := false;
	self.cmbHsCode.visible := false;
	self.btnHSCode.visible := false;
	
	ctrlNumb := 1;
	//set controls on the page
	self.lblCargoType.top := MoveControl * ctrlNumb;
	self.cmbCargoType.top := MoveControl * ctrlNumb;
	ctrlNumb := ctrlNumb + 1;
	self.lblIsoGroup.top :=  MoveControl * ctrlNumb;
	self.cmbIsoGroup.top :=  MoveControl * ctrlNumb;
	ctrlNumb := ctrlNumb + 1;
	self.lblIsoType.top :=  MoveControl * ctrlNumb;
	self.cmbIsoType.top :=  MoveControl * ctrlNumb;
	ctrlNumb := ctrlNumb + 1;
	self.lblCommodity.top :=  MoveControl * ctrlNumb;
	self.cmbCommodity.top :=  MoveControl * ctrlNumb;
	ctrlNumb := ctrlNumb + 1;
	if not app.myRoot.allHSCodesActive.isEmpty then
		self.lblHsCode.visible := true;
		self.cmbHsCode.visible := true;
		self.btnHSCode.visible := true;
		self.lblHsCode.top := MoveControl * ctrlNumb;
		self.cmbHsCode.top := MoveControl * ctrlNumb;
		self.btnHSCode.top := MoveControl * ctrlNumb;
		ctrlNumb := ctrlNumb + 1;
	else
		self.lblHsCode.visible := false;
		self.cmbHsCode.visible := false;
		self.btnHSCode.visible := false;
	endif;
	self.lblTotalUnits.top :=  MoveControl * ctrlNumb;
	self.txtTotalUnits.top := MoveControl * ctrlNumb;
	ctrlNumb := ctrlNumb + 1;
	self.lblWeight.top :=  MoveControl * ctrlNumb;
	//self.txtWeight.top :=  MoveControl * ctrlNumb;					// PAR #31155
	self.tblWeight.top :=  MoveControl * ctrlNumb;						// PAR #31155
	ctrlNumb := ctrlNumb + 1;	
	
	self.lblDocStopAction.top :=  MoveControl * ctrlNumb;	//14 Sep 2016	NDL	TFS 2644 / 2001
	self.txtDocStopAction.top := MoveControl * ctrlNumb;	//14 Sep 2016	NDL	TFS 2644 / 2001
	self.btnDocStopAction.top := MoveControl * ctrlNumb;	//14 Sep 2016	NDL	TFS 2644 / 2001
	ctrlNumb := ctrlNumb + 1;	//14 Sep 2016	NDL	TFS 2644 / 2001
	self.lblDocTaskAction.top := MoveControl * ctrlNumb;	//14 Sep 2016	NDL	TFS 2644 / 2001
	self.txtDocTaskAction.top := MoveControl * ctrlNumb;	//14 Sep 2016	NDL	TFS 2644 / 2001
	self.btnDocTaskAction.top := MoveControl * ctrlNumb;	//14 Sep 2016	NDL	TFS 2644 / 2001
	ctrlNumb := ctrlNumb + 1;	//14 Sep 2016	NDL	TFS 2644 / 2001
	
	self.lblMatchMode.top := MoveControl * ctrlNumb;				//navra1 - CR 63764/Task 64227 - 22nd May 2024
	self.cmbMatchMode.top := MoveControl * ctrlNumb;				//navra1 - CR 63764/Task 64227 - 22nd May 2024
	ctrlNumb 				:= ctrlNumb + 2;						//navra1 - CR 63764/Task 64227 - 22nd May 2024	
	self.txtMatchModeDetails.top := MoveControl * ctrlNumb;			//navra1 - CR 63764/Task 64227 - 22nd May 2024
	ctrlNumb := ctrlNumb + 1;										//navra1 - CR 63764/Task 64227 - 22nd May 2024
	
	//move release group box invisible
	self.grpRelease.visible := false;
	
	//make reefer groupbox invisible 
	self.grpReefer.visible := false;
	
	//move to Column 2
	//make Cargo Details General group box invisible with 15 controls adjust groupbox height
	self.hideCDGeneralGroupBox();
	self.grpCDGeneral.top := 3;
	self.grpCDGeneral.height := MoveControl * ctrlNumb2;
	
	
	//make appropriate controls invisible
	self.grpCargoDetails.visible := true;
	self.showGrpCargoDetails();
	self.grpCargoDetails.top := 3;
	self.lblId.visible := false;
	self.txtId.visible := false;
	self.lblMarks.visible := false;
	self.txtMarks.visible := false;
	self.lblMarksNumber.visible := false;
	self.txtMarkNumber.visible := false;
	self.lblColour.visible := false;
	self.txtColour.visible := false;
	self.lblHazards.visible := false;
	self.txtHazards.visible := false;
	self.btnHazards.visible := false;					// TFS 2842
	self.lblSpecialStow.visible := false;
	self.cmbSpecialStow.visible := false;
	self.lblSpecialLift.visible := false;
	self.txtSpecialLift.visible := false;
	
		
	//set controls on the page
	ctrlNumb2 := 1;
	//self.chkPreTripInspec.top := MoveControl;
	//ctrlNumb2 := ctrlNumb2 + 1;
	self.lblPurchaseOrder.top := MoveControl * ctrlNumb2;					// PAR #33193
	self.txtPurchaseOrder.top := MoveControl * ctrlNumb2;					// PAR #33193
	ctrlNumb2 := ctrlNumb2 + 1;												// PAR #33193
	self.lblServiceOrder.top := MoveControl * ctrlNumb2;					// PAR #33193
	self.txtServiceOrder.top := MoveControl * ctrlNumb2;					// PAR #33193
	ctrlNumb2 := ctrlNumb2 + 1;												// PAR #33193
	self.lblRemarks.top := MoveControl * ctrlNumb2;
	self.txtRemarks.top := MoveControl * ctrlNumb2;
	ctrlNumb2 := ctrlNumb2 + 3;		//equivalent of 3 controls
	self.grpCargoDetails.height := MoveControl * ctrlNumb2;

	
	//calculate how much space is needed to resize the form and buttons  
	if ctrlNumb &gt; ctrlNumb2 then
		self.btnSave.top := ctrlNumb * MoveControl;
		self.btnNext.top :=	ctrlNumb * MoveControl;
		self.btnCancel.top := ctrlNumb * MoveControl;
		//self.height := MoveControl * (ctrlNumb + 3);//(numbControlsCol1 - 2));
		self.height := btnSave.top + (MoveControl * 3);
	else
		self.btnSave.top := ctrlNumb2 * MoveControl;
		self.btnNext.top := ctrlNumb2 * MoveControl;
		self.btnCancel.top := ctrlNumb2 * MoveControl;
		self.height := self.btnSave.top + (MoveControl * 3);
	endif;
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupISOReeferControls" id="47c8f777-e537-4bed-b654-03f5a2e41332">
        <updating/>
        <source>setupISOReeferControls()updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02/07/2009	cnwml2	Initial creation
25/03/2013	cnwdap1 PAR #31155 CCMS SFW 1321 Imperial Measurements
03/03/2014	cnwdap1	PAR #33193 CCMS DPH 2285 Added Purchase Order and Service Order fields
20/06/2014 	cnwma1  PAR #34268 Fail in updating Booking Item for a Reefer
15/11/2016	cnwdap1	TFS 2842 STYWR Hazardous Details Enhancements
13/12/2022	jlika1	TFS 55590 HS Codes to Column Organizers
08/02/2023	jlika1	TFS 56450 MTN - HS Code on Booking Item form
*/
constants
	MoveControl = 25;
vars
	ctrlNumb,
	ctrlNumb2				: Integer;
	operator				: CM_Operator;			// PAR #31155
begin

	//make general group box visible 
	self.grpGeneral.visible := true;
	self.showGrpGeneral();

	//make appropriate controls invisible
	self.lblGeneratorType.visible := false;
	self.cmbGeneratorType.visible := false;
	self.lblTrailerType.visible := false;
	self.cmbTrailerType.visible := false;
	self.lblProduct.visible := false;
	self.cmbProduct.visible := false;
	self.lblVolume.visible := false;
	//self.txtVolume.visible := false;								// PAR #31155
	self.tblVolume.visible := false;								// PAR #31155
	self.lblDescription.visible := false;
	self.txtDescription.visible := false;
	self.lblHsCode.visible := false;
	self.cmbHsCode.visible := false;
	self.btnHSCode.visible := false;
	
	ctrlNumb := 1;
	//set controls on the page
	self.lblCargoType.top := MoveControl * ctrlNumb;
	self.cmbCargoType.top := MoveControl * ctrlNumb;
	ctrlNumb := ctrlNumb + 1;
	self.lblIsoGroup.top :=  MoveControl * ctrlNumb;
	self.cmbIsoGroup.top :=  MoveControl * ctrlNumb;
	ctrlNumb := ctrlNumb + 1;
	self.lblIsoType.top :=  MoveControl * ctrlNumb;
	self.cmbIsoType.top :=  MoveControl * ctrlNumb;
	ctrlNumb := ctrlNumb + 1;
	self.lblCommodity.top :=  MoveControl * ctrlNumb;
	self.cmbCommodity.top :=  MoveControl * ctrlNumb;
	ctrlNumb := ctrlNumb + 1;
	
	if not app.myRoot.allHSCodesActive.isEmpty then
		self.lblHsCode.visible := true;
		self.cmbHsCode.visible := true;
		self.btnHSCode.visible := true;
		self.lblHsCode.top := MoveControl * ctrlNumb;
		self.cmbHsCode.top := MoveControl * ctrlNumb;
		self.btnHSCode.top := MoveControl * ctrlNumb;
		ctrlNumb := ctrlNumb + 1;
	else
		self.lblHsCode.visible := false;
		self.cmbHsCode.visible := false;
		self.btnHSCode.visible := false;
	endif;
	
	self.lblTotalUnits.top :=  MoveControl * ctrlNumb;
	self.txtTotalUnits.top := MoveControl * ctrlNumb;
	ctrlNumb := ctrlNumb + 1;
	self.lblWeight.top :=  MoveControl * ctrlNumb;
	//self.txtWeight.top :=  MoveControl * ctrlNumb;				// PAR #31155
	self.tblWeight.top :=  MoveControl * ctrlNumb;					// PAR #31155
	ctrlNumb := ctrlNumb + 1;	
	
	self.lblDocStopAction.top :=  MoveControl * ctrlNumb;	//14 Sep 2016	NDL	TFS 2644 / 2001
	self.txtDocStopAction.top := MoveControl * ctrlNumb;	//14 Sep 2016	NDL	TFS 2644 / 2001
	self.btnDocStopAction.top := MoveControl * ctrlNumb;	//14 Sep 2016	NDL	TFS 2644 / 2001
	ctrlNumb := ctrlNumb + 1;	//14 Sep 2016	NDL	TFS 2644 / 2001
	self.lblDocTaskAction.top := MoveControl * ctrlNumb;	//14 Sep 2016	NDL	TFS 2644 / 2001
	self.txtDocTaskAction.top := MoveControl * ctrlNumb;	//14 Sep 2016	NDL	TFS 2644 / 2001
	self.btnDocTaskAction.top := MoveControl * ctrlNumb;	//14 Sep 2016	NDL	TFS 2644 / 2001
	ctrlNumb := ctrlNumb + 1;	//14 Sep 2016	NDL	TFS 2644 / 2001
	
	self.lblMatchMode.top := MoveControl * ctrlNumb;				//navra1 - CR 63764/Task 64227 - 22nd May 2024
	self.cmbMatchMode.top := MoveControl * ctrlNumb;				//navra1 - CR 63764/Task 64227 - 22nd May 2024
	ctrlNumb 				:= ctrlNumb + 2;						//navra1 - CR 63764/Task 64227 - 22nd May 2024	
	self.txtMatchModeDetails.top := MoveControl * ctrlNumb;			//navra1 - CR 63764/Task 64227 - 22nd May 2024
	ctrlNumb := ctrlNumb + 1;										//navra1 - CR 63764/Task 64227 - 22nd May 2024
	
	self.grpGeneral.height := MoveControl * ctrlNumb;
	
	//make Release groupbox visible
	if self.txtMaxRel.enabled then
		self.grpRelease.top := ctrlNumb * MoveControl;
		self.grpRelease.height := 150;
		self.grpRelease.visible := true;
		ctrlNumb := ctrlNumb + 6;  //6 controls including heading
		if self.txtMaxRel.text.Integer &lt; 1 then
			self.chkIsClean.enabled := false;
			self.chkHeavy.enabled := false;
			self.chkPreTripInspec.enabled := false;
			self.lblAvaliabilityG.enabled := false;
			self.cmbAvalGrade.enabled := false;
		else
			self.chkIsClean.enabled := true;
			self.chkHeavy.enabled := true;
			self.chkPreTripInspec.enabled := true;
			self.lblAvaliabilityG.enabled := true;
			self.cmbAvalGrade.enabled := true;
		endif;
	else
		self.grpRelease.visible := false;
	endif;
	
	//make reefer groupbox visible with 9 controls in column 2
	self.grpReefer.top := 0;
	self.grpReefer.left := 380;
	self.grpReefer.visible := true;
	ctrlNumb2 := 8;							//8 controls including heading
	
	// PAR #31155 decide whether we display Celcius or Fahrenheit option button
	if self.myProxyBookingRefItem &lt;&gt; null and self.myProxyBookingRefItem.myBookingReference &lt;&gt; null and self.myProxyBookingRefItem.myBookingReference.myOperator &lt;&gt; null then
		operator := self.myProxyBookingRefItem.myBookingReference.myOperator;
		if operator.displayTempFahrenheit then // epr 32714 3/12/13 config never used removing and self.myTerminal.getConfig(TempFahForFahOperator).Boolean then
			self.optFahr.visible := true;
			self.optFahr.value := true;
			self.optCel.visible := false;
			self.optFahr.move(self.optCel.left, self.optCel.top, self.optCel.width, self.optCel.height);
		else
			self.optFahr.visible := false;
			self.optCel.visible := true;
			self.optCel.value := true;
		endif;
	else
		self.optCel.visible := true;
		self.optCel.value := true;
	endif;
	
	//make Cargo Details General group box invisible with 11 controls adjust groupbox height also adjust position of groupbox
	self.hideCDGeneralGroupBox();
	self.grpCDGeneral.top := MoveControl * (ctrlNumb2 - 1);
	self.grpCDGeneral.height := self.grpCDGeneral.height - (MoveControl * 11);
		
	//move Cargo Details group box to appropriate place
	self.grpCargoDetails.top := MoveControl * ctrlNumb2;
	self.grpCargoDetails.visible := true;
	self.showGrpCargoDetails();
	 
	 
	self.lblId.visible := false;
	self.txtId.visible := false;
	self.lblMarks.visible := false;
	self.txtMarks.visible := false;
	self.lblMarksNumber.visible := false;
	self.txtMarkNumber.visible := false;
	self.lblColour.visible := false;
	self.txtColour.visible := false;
	 
	//set controls on the page
	ctrlNumb2 := ctrlNumb2 + 1;						//add in heading control
	self.lblPurchaseOrder.top := MoveControl;								// PAR #33193
	self.txtPurchaseOrder.top := MoveControl;								// PAR #33193
	ctrlNumb2 := ctrlNumb2 + 1;												// PAR #33193
	self.lblServiceOrder.top := MoveControl * 2;							// PAR #33193
	self.txtServiceOrder.top := MoveControl * 2;							// PAR #33193
	ctrlNumb2 := ctrlNumb2 + 1;												// PAR #33193
	self.lblHazards.top := MoveControl * 3;
	self.txtHazards.top := MoveControl * 3;
	self.btnHazards.top := MoveControl * 3;					// TFS 2842
	ctrlNumb2 := ctrlNumb2 + 1;
	self.lblSpecialStow.top := MoveControl * 4;
	self.cmbSpecialStow.top := MoveControl * 4;
	ctrlNumb2 := ctrlNumb2 + 1;
	self.lblSpecialLift.top := MoveControl * 5;
	self.txtSpecialLift.top := MoveControl * 5;
	ctrlNumb2 := ctrlNumb2 + 1;
	self.lblRemarks.top := MoveControl * 6;
	self.txtRemarks.top := MoveControl * 6;
	ctrlNumb2 := ctrlNumb2 + 3;
	
	//calculate how much space is needed to resize the form and buttons  
	if ctrlNumb &gt; ctrlNumb2 then
		self.btnSave.top := ctrlNumb * MoveControl;
		self.btnNext.top :=	ctrlNumb * MoveControl;
		self.btnCancel.top := ctrlNumb * MoveControl;
		self.height := self.btnSave.top + (MoveControl * 3);
	else
		self.btnSave.top := ctrlNumb2 * MoveControl;
		self.btnNext.top := ctrlNumb2 * MoveControl;
		self.btnCancel.top := ctrlNumb2 * MoveControl;
		//self.height := self.height - (MoveControl * (numbControlsCol2 + 1));
		self.height := btnSave.top + (MoveControl * 3);
	endif;
	self.btnSave.zOrder(1); // PAR #34268
	self.btnNext.zOrder(1);
	self.btnCancel.zOrder(1);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupMeasurementControls" id="f130ab9a-ce99-493d-aaa7-abc70895225b">
        <source>setupMeasurementControls();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25/03/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars

begin
	self.tblCDDensity.setup(Type_Density, self.backColor);
	self.tblCDDensity.tabKey := J_key_Tab;
	
	self.tblCDLength.setup(Type_Length, self.backColor);
	self.tblCDLength.tabKey := J_key_Tab;
	
	self.tblCDHeight.setup(Type_Height, self.backColor);
	self.tblCDHeight.tabKey := J_key_Tab;
	
	self.tblCDWidth.setup(Type_Width, self.backColor);
	self.tblCDWidth.tabKey := J_key_Tab;
	
	self.tblCDWeight.setup(Type_Weight, self.backColor);
	self.tblCDWeight.tabKey := J_key_Tab;
	
	self.tblWeight.setup(Type_Weight, self.backColor);
	self.tblWeight.tabKey := J_key_Tab;
	
	self.tblVentilation.setup(Type_Displacement, self.backColor);
	self.tblVentilation.tabKey := J_key_Tab;
	
	self.tblCDVolume.setup(Type_Volume, self.backColor);
	self.tblCDVolume.tabKey := J_key_Tab;
	
	self.tblVolume.setup(Type_Volume, self.backColor);
	self.tblVolume.tabKey := J_key_Tab;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupTrailerControls" id="8f590d37-9c8e-4407-b1c9-85132edd4cd9">
        <updating/>
        <source>setupTrailerControls(_cargoType : CM_CargoType)updating;
// 16 October 2009	cnwml2
// 25/03/2010		cnwcs5	par 23338
// 12/12/2012		CNWCS5	PAR 30852
// 25/03/2013		cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
// 03/03/2014		cnwdap1	PAR #33193 CCMS DPH 2285 Added Purchase Order and Service Order fields
// 15/11/2016		cnwdap1	TFS 2842 STWR Hazardous Details Enhancements
// 01/10/2019		jlgzm1	TFS 46575 Display Reefer options for non-containers
// 08/02/2023		jlika1	TFS 56450 MTN - HS Code on Booking Item form
constants
	MoveControl = 25;
vars
	ctrlNumb, ctrlNumb2 : Integer;
	operator			: CM_Operator; // TFS 46575
begin
	// make general group box visible
	self.grpGeneral.visible := true;
	
	self.showGrpGeneral();
	
	// par 23338 - start
	if _cargoType &lt;&gt; self.cmbTrailerType.myCargoType then
		self.cmbTrailerType.clear;
		
		self.cmbTrailerType.myCargoType := _cargoType;
	endif;
	
	//make appropriate controls invisible
	self.lblGeneratorType.visible 	:= false;
	self.cmbGeneratorType.visible 	:= false;
	self.lblProduct.visible 		:= false;
	self.cmbProduct.visible 		:= false;
	self.lblIsoGroup.visible 		:= false;
	self.cmbIsoGroup.visible 		:= false;
	self.lblIsoType.visible 		:= false;
	self.cmbIsoType.visible 		:= false;
	self.lblHsCode.visible := false;
	self.cmbHsCode.visible := false;
	self.btnHSCode.visible := false;
	
	//set controls on page
	ctrlNumb := 1;
	self.lblCargoType.top := MoveControl * ctrlNumb;
	self.cmbCargoType.top := MoveControl * ctrlNumb;
	
	ctrlNumb := ctrlNumb + 1;
	self.lblTrailerType.top := MoveControl * ctrlNumb;
	self.cmbTrailerType.top := MoveControl * ctrlNumb;
	
	if _cargoType &lt;&gt; null and _cargoType.isCommodityRequired then	// TFS 46575
		ctrlNumb := ctrlNumb + 1;									// TFS 46575
		self.lblCommodity.visible := true;							// TFS 46575
		self.cmbCommodity.visible := true;							// TFS 46575
		self.lblCommodity.top := MoveControl * ctrlNumb;			// TFS 46575
		self.cmbCommodity.top := MoveControl * ctrlNumb;			// TFS 46575
	else
		self.lblCommodity.visible 		:= false;
		self.cmbCommodity.visible 		:= false;
	endif;
	
	ctrlNumb := ctrlNumb + 1;
	self.lblTotalUnits.top := MoveControl * ctrlNumb;
	self.txtTotalUnits.top := MoveControl * ctrlNumb;
	
	ctrlNumb := ctrlNumb + 1;
	self.lblWeight.top := MoveControl * ctrlNumb;
	//self.txtWeight.top := MoveControl * ctrlNumb;						// PAR #31155
	self.tblWeight.top := MoveControl * ctrlNumb;						// PAR #31155
	
	ctrlNumb := ctrlNumb + 1;
	
	if _cargoType.allAttributesOnProduct.includes(ETRow_MyVolume) then	
		self.lblVolume.visible 	:= true;
		//self.txtVolume.visible := true;								// PAR #31155
		self.tblVolume.visible 	:= true;								// PAR #31155
		self.lblVolume.top 		:= MoveControl * ctrlNumb;
		//self.txtVolume.top 		:= MoveControl * ctrlNumb;			// PAR #31155
		self.tblVolume.top 		:= MoveControl * ctrlNumb;				// PAR #31155
		ctrlNumb 				:= ctrlNumb + 1;
	else
		self.lblVolume.visible := false;
		//self.txtVolume.visible := false;								// PAR #31155
		self.tblVolume.visible := false;								// PAR #31155
	endif;
	
	self.lblDocStopAction.top :=  MoveControl * ctrlNumb;	//14 Sep 2016	NDL	TFS 2644 / 2001
	self.txtDocStopAction.top := MoveControl * ctrlNumb;	//14 Sep 2016	NDL	TFS 2644 / 2001
	self.btnDocStopAction.top := MoveControl * ctrlNumb;	//14 Sep 2016	NDL	TFS 2644 / 2001
	ctrlNumb := ctrlNumb + 1;	//14 Sep 2016	NDL	TFS 2644 / 2001
	self.lblDocTaskAction.top := MoveControl * ctrlNumb;	//14 Sep 2016	NDL	TFS 2644 / 2001
	self.txtDocTaskAction.top := MoveControl * ctrlNumb;	//14 Sep 2016	NDL	TFS 2644 / 2001
	self.btnDocTaskAction.top := MoveControl * ctrlNumb;	//14 Sep 2016	NDL	TFS 2644 / 2001
	ctrlNumb := ctrlNumb + 1;	//14 Sep 2016	NDL	TFS 2644 / 2001
	
	self.lblDescription.top := MoveControl * ctrlNumb;
	self.txtDescription.top := MoveControl * ctrlNumb;
	ctrlNumb 				:= ctrlNumb + 3;						//navra1 - CR 63764/Task 64227 - 22nd May 2024

	self.lblMatchMode.top := MoveControl * ctrlNumb;				//navra1 - CR 63764/Task 64227 - 22nd May 2024
	self.cmbMatchMode.top := MoveControl * ctrlNumb;				//navra1 - CR 63764/Task 64227 - 22nd May 2024
	ctrlNumb 				:= ctrlNumb + 2;						//navra1 - CR 63764/Task 64227 - 22nd May 2024
	self.txtMatchModeDetails.top := MoveControl * ctrlNumb;			//navra1 - CR 63764/Task 64227 - 22nd May 2024
	ctrlNumb := ctrlNumb + 1;										//navra1 - CR 63764/Task 64227 - 22nd May 2024
		
	//make Release, Reefer and Cargo Details General groupboxes invisible
	self.grpRelease.visible 	:= false;
	self.grpReefer.visible 		:= false;
	self.grpCDGeneral.visible 	:= false;	
	
	// TFS 46575 Start
	if self.cmbCommodity.listObject &lt;&gt; null and self.cmbCommodity.listObject.CM_Commodity.hasTemp then 
		self.grpReefer.visible := true;
		self.grpReefer.top := self.txtDescription.top + MoveControl * 3;
		self.grpReefer.left := 0;
		ctrlNumb := ctrlNumb + 11;

		// decide whether we display Celcius or Fahrenheit option button
		if self.myProxyBookingRefItem &lt;&gt; null and self.myProxyBookingRefItem.myBookingReference &lt;&gt; null and self.myProxyBookingRefItem.myBookingReference.myOperator &lt;&gt; null then
			operator := self.myProxyBookingRefItem.myBookingReference.myOperator;
			if operator.displayTempFahrenheit then
				self.optFahr.visible := true;
				self.optFahr.value := true;
				self.optCel.visible := false;
				self.optFahr.move(self.optCel.left, self.optCel.top, self.optCel.width, self.optCel.height);
			else
				self.optFahr.visible := false;
				self.optCel.visible := true;
				self.optCel.value := true;
			endif;
		else
			self.optCel.visible := true;
			self.optCel.value := true;
		endif;
	endif;
	// TFS 46575 End

	ctrlNumb2 := 0;
	self.grpCargoDetails.top 		:= MoveControl * ctrlNumb2;
	self.grpCargoDetails.visible	:= true;
	
	self.showGrpCargoDetails();
	
	//make colour invisible
	self.lblColour.visible := false;
	self.txtColour.visible := false;
	
	//align controls
	ctrlNumb2 := ctrlNumb2 + 1;				//allow for heading
	self.lblId.top := MoveControl * ctrlNumb2;
	self.txtId.top := MoveControl * ctrlNumb2;
	
	ctrlNumb2 := ctrlNumb2 + 1;
	self.lblMarks.top := MoveControl * ctrlNumb2;
	self.txtMarks.top := MoveControl * ctrlNumb2;
	
	ctrlNumb2 := ctrlNumb2 + 1;
	self.lblMarksNumber.top := MoveControl * ctrlNumb2;
	self.txtMarkNumber.top := MoveControl * ctrlNumb2;
	
	ctrlNumb2 := ctrlNumb2 + 1;												// PAR #33193
	self.lblPurchaseOrder.top := MoveControl * ctrlNumb2;					// PAR #33193
	self.txtPurchaseOrder.top := MoveControl * ctrlNumb2;					// PAR #33193
	ctrlNumb2 := ctrlNumb2 + 1;												// PAR #33193
	self.lblServiceOrder.top := MoveControl * ctrlNumb2;					// PAR #33193
	self.txtServiceOrder.top := MoveControl * ctrlNumb2;					// PAR #33193
	
	ctrlNumb2 := ctrlNumb2 + 1;
	self.lblHazards.top := MoveControl * ctrlNumb2;
	self.txtHazards.top := MoveControl* ctrlNumb2;
	self.btnHazards.top := MoveControl* ctrlNumb2;					// TFS 2842
	
	ctrlNumb2 := ctrlNumb2 + 1;
	self.lblSpecialStow.top := MoveControl * ctrlNumb2;
	self.cmbSpecialStow.top := MoveControl * ctrlNumb2;
	
	ctrlNumb2 := ctrlNumb2 + 1;
	self.lblSpecialLift.top := MoveControl * ctrlNumb2;
	self.txtSpecialLift.top := MoveControl * ctrlNumb2;
	
	ctrlNumb2 := ctrlNumb2 + 1;
	self.lblRemarks.top := MoveControl * ctrlNumb2;
	self.txtRemarks.top := MoveControl * ctrlNumb2;
	
	ctrlNumb2 := ctrlNumb2 + 3;
	self.grpCargoDetails.height := MoveControl * 11;
		
	//calculate how much space is needed to resize the form and buttons  
	if ctrlNumb &gt; ctrlNumb2 then
		self.btnSave.top 	:= ctrlNumb * MoveControl;
		self.btnNext.top 	:=	ctrlNumb * MoveControl;
		self.btnCancel.top 	:= ctrlNumb * MoveControl;
		self.height 		:= self.btnSave.top + (MoveControl * 6);			//navra1 - CR 63764/Task 64227 - 22nd May 2024
	else
		self.btnSave.top 	:= ctrlNumb2 * MoveControl;
		self.btnNext.top 	:= ctrlNumb2 * MoveControl;
		self.btnCancel.top 	:= ctrlNumb2 * MoveControl;
		self.height 		:= self.btnSave.top + (MoveControl * 6);			//navra1 - CR 63764/Task 64227 - 22nd May 2024
	endif;

epilog

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="showGrpCargoDetails" id="3728f36c-1024-4f5d-86e6-63f0a947a43a">
        <source>showGrpCargoDetails();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06/07/2009	cnwml2	Initial creation
03/03/2014	cnwdap1	PAR #33193 CCMS DPH 2285 Added Purchase Order and Service Order fields
15/11/2016	cnwdap1	TFS 2842 STWR Hazardous Details Enhancements
*/

vars

begin
	self.lblCargoDTitle.visible := true;
	self.lblId.visible := true;
	self.txtId.visible := true;
	self.lblMarks.visible := true;
	self.txtMarks.visible := true;
	self.lblMarksNumber.visible := true;
	self.txtMarkNumber.visible := true;
	self.lblColour.visible := true;
	self.txtColour.visible := true;
	
	//self.chkPreTripInspec.visible := true;
	self.lblPurchaseOrder.visible := true;						// PAR #33193
	self.txtPurchaseOrder.visible := true;						// PAR #33193
	self.lblServiceOrder.visible := true;						// PAR #33193
	self.txtServiceOrder.visible := true;						// PAR #33193
	self.lblHazards.visible := true;
	self.txtHazards.visible := true;
	self.btnHazards.visible := true;					// TFS 2842
	self.lblSpecialStow.visible := true;
	self.cmbSpecialStow.visible := true;
	self.lblSpecialLift.visible := true;
	self.txtSpecialLift.visible := true;
	self.lblRemarks.visible := true;
	self.txtRemarks.visible := true;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showGrpGeneral" id="36cc274b-6e8c-4046-b5ea-f933376c54cf">
        <source>showGrpGeneral();

/*

