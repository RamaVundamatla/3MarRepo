    <JadeMethod name="addCargoListTableLine" id="27625c05-e0df-45f7-91a3-05ea52dcbb8e">
        <source>addCargoListTableLine( theTable : CM_DataTable input; _ti : CM_TrackedItem )protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2020	jlgndl1	Initial creation	TFS 49963

*/

vars

	theLine : String;
	hazs : StringArray;
	haz : CM_Hazard;
	locationID : String;

begin

	if _ti = null then
					
		theTable.rows := 1;
		theTable.fixedRows := 1;
		theTable.fontName := "Helvetica"; 
		theTable.fontSize := 7;
		theTable.columns := 15;
		theTable.fixedColumns := 0;
		theTable.accessColumn(1).width := 50;	// Stowage
		theTable.accessColumn(2).width := 30;	// ISO
		theTable.accessColumn(3).width := 80;	// ID
		theTable.accessColumn(4).width := 300;	// Contents
		theTable.accessColumn(5).width := 80;	// Temp
		theTable.accessColumn(6).width := 40;	// Weight 50
		theTable.accessColumn(7).width := 30;	// Op 40
		theTable.accessColumn(8).width := 30;	// Disch 40
		theTable.accessColumn(9).width := 30;	// Load 40
		theTable.accessColumn(10).width := 85;	// IMCO
		theTable.accessColumn(11).width := 85;	// IMCO
		theTable.accessColumn(12).width := 85;	// IMCO
		theTable.accessColumn(13).width := 25;	// O/H 30
		theTable.accessColumn(14).width := 25;	// O/L
		theTable.accessColumn(15).width := 25;	// O/W
		
		theLine := 	app.getErrorString(Stowage)
			&amp; Tab &amp; app.getErrorString(CM_ISO)
			&amp; Tab &amp; app.getErrorString(Cargo)
			&amp; Tab &amp; app.getErrorString(Remarks_GC)
			&amp; Tab &amp; app.getErrorString(Temp_ScanPlan)
			&amp; Tab &amp; app.getErrorString(CM_Weight)
			&amp; Tab &amp; app.getErrorString(Oper)
			&amp; Tab &amp; app.getErrorString(Disch)
			&amp; Tab &amp; app.getErrorString(Load)
			&amp; Tab &amp; app.getErrorString(Imco)
			&amp; Tab &amp; app.getErrorString(Imco)
			&amp; Tab &amp; app.getErrorString(Imco)
			&amp; Tab &amp; app.getErrorString(OverHeight)
			&amp; Tab &amp; app.getErrorString(OverLength)
			&amp; Tab &amp; app.getErrorString(OverWidth);
	
		theTable.accessCell( 1, 1).text := theLine;
	
	else
		
		create hazs transient;
		if _ti.allTIHazards.size &gt; 0 then
			foreach haz in _ti.allTIHazards do
				hazs.add(haz.getTableDisplay(false, true));
			endforeach;	
		endif;
		//add blanks where no hazards
		while hazs.size &lt; 3 do
			hazs.add(null);
		endwhile;
		
		if _ti.myPrimaryActualLocation.isKindOf(CM_SlotController) then
			locationID := _ti.myPrimaryActualLocation.getStowageId(_ti);
		elseif _ti.myPrimaryPlannedLocation.isKindOf(CM_SlotController) then
			locationID := _ti.myPrimaryPlannedLocation.getStowageId(_ti);
		else
			locationID := _ti.locationId;
		endif;
		
		theLine := 	locationID
			&amp; Tab &amp; _ti.getISOType()
			&amp; Tab &amp; _ti.id
			&amp; Tab &amp; _ti.remarks
			&amp;  Tab &amp; _ti.getDisplayTemperature(true, false) 
			&amp; Tab &amp; _ti.totalWeight.asStringWeightJMT()
			&amp; Tab &amp; _ti.operatorCode
			&amp; Tab &amp; _ti.dischargePort
			&amp; Tab &amp; _ti.loadPort
			&amp; Tab &amp; hazs[1]
			&amp; Tab &amp; hazs[2]
			&amp; Tab &amp; hazs[3]
			&amp; Tab &amp; app.getYesNo(_ti.height &lt;&gt; 0)
			&amp; Tab &amp; app.getYesNo(_ti.length &lt;&gt; 0)
			&amp; Tab &amp; app.getYesNo(_ti.width &lt;&gt; 0);
			  
		theTable.addItem(theLine);
		
	endif;

epilog

	delete hazs;

end;</source>
        <access>protected</access>
        <Parameter name="theTable" type="CM_DataTable" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addLegendSubHeading" id="87202f98-2bd0-4c46-98f0-5a99bb9501df">
        <source>addLegendSubHeading( _perPageLegendsUsed : CMIF_ScanPlanLegendDict input; _forColour : Boolean; _forAttribute : Boolean );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 September 2020	jlgndl1	Initial creation	TFS 49963

*/

vars

	subHeadingLegend : CMIF_ScanPlanLegend;
	subHeader : CMIF_ScanPlanLegend;
	createSubHeader : Boolean;

begin

	if _forColour then
	
		subHeader := self.allScanPlanLegends.getSubHeader(LegendColourSubHeaderType);
		if _perPageLegendsUsed &lt;&gt; null and subHeader &lt;&gt; null then
			if _perPageLegendsUsed.getSubHeader(LegendColourSubHeaderType) = null then
				if _perPageLegendsUsed &lt;&gt; null then
					_perPageLegendsUsed.add( subHeader );
				endif;
			endif;
		endif;
			
		if subHeader = null then
		
			create subHeadingLegend transient;
			subHeadingLegend.colour := White;
			subHeadingLegend.header := LegendColourSubHeaderType;
			if self.slotColour = ColourDischargePort or self.slotColour = ColourLoadPort then
				subHeadingLegend.title := " -" &amp; app.getErrorString( LL_Port ) &amp; "-";		
			elseif self.slotColour = ColourOperator then
				subHeadingLegend.title := " -" &amp; app.getErrorString( Operator_GC ) &amp; "-";	
			elseif self.slotColour = ColourCommodity then
				if  self.legend = self.LegendOne then
					subHeadingLegend.title := " -" &amp; app.getErrorString( CommodityGroup ) &amp; "-";
				else
					subHeadingLegend.title := " -" &amp; app.getErrorString( Commodity ) &amp; "-"; // space issue
				endif;
			elseif self.slotColour = ColourIsoGroup then
				if self.myTerminal.getConfig(ShipShowISOType).Boolean then
					subHeadingLegend.title := " -" &amp; app.getErrorString( CM_ISO_Type ) &amp; "-";	
				else
					subHeadingLegend.title := " -" &amp;app.getErrorString( ISO_Group ) &amp; "-";
				endif;
			endif;
			
			subHeadingLegend.myAgent := self;
			
			if _perPageLegendsUsed &lt;&gt; null then
				_perPageLegendsUsed.add( subHeadingLegend );
			endif;
		
		endif;
		
	endif;
	
	if _forAttribute then
	
		subHeader := self.allScanPlanLegends.getSubHeader(LegendAttribSubHeaderType);
		if _perPageLegendsUsed &lt;&gt; null and subHeader &lt;&gt; null then
			if _perPageLegendsUsed.getSubHeader(LegendAttribSubHeaderType) = null then
				if _perPageLegendsUsed &lt;&gt; null then
					_perPageLegendsUsed.add( subHeader );
				endif;
			endif;
		endif;
		
		if subHeader = null then
	
			create subHeadingLegend transient;
			subHeadingLegend.colour := White;
			subHeadingLegend.title := "-" &amp; app.getErrorString(Attributes) &amp; "-";
			subHeadingLegend.header := LegendAttribSubHeaderType;
			subHeadingLegend.myAgent := self;
			
			if _perPageLegendsUsed &lt;&gt; null then
				_perPageLegendsUsed.add( subHeadingLegend );
			endif;
		
		endif;
		
	endif;

epilog

end;</source>
        <Parameter name="_perPageLegendsUsed" type="CMIF_ScanPlanLegendDict" usage="input"/>
        <Parameter name="_forColour" type="Boolean"/>
        <Parameter name="_forAttribute" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createCMIFObjsForPrint" id="8f7563ab-c3fd-4838-8615-77c941447e28">
        <updating/>
        <source>createCMIFObjsForPrint()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 September 2020	jlgndl1	Initial creation	TFS 49963

*/

vars

	bay : CM_BayVoyage;
	bayCMIF : CMIF_ScanPlanReportBay;

begin

	//clear any existing data
	if not self.allScanPlanLegends.isEmpty then
		self.allScanPlanLegends.purge();
		self.myROBGrey := null;
	endif;
	
	if not self.allScanPlanReportBays.isEmpty then
		self.allScanPlanReportBays.purge();
	endif;

	//create the new CMIF data
	foreach bay in self.allSelectedBays discreteLock do
		create bayCMIF transient;
		bayCMIF.setFromBay( bay, self );
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doPrint" id="d4b174dc-d90d-4288-9eeb-a27af8ddc295">
        <updating/>
        <source>doPrint():Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 September 2020	jlgndl1	Initial creation	TFS 49963

*/

vars

	report : CMUI_ScanPlanReport;
	cmifBay : CMIF_ScanPlanReportBay;
	cmifSlot : CMIF_ScanPlanReportSlot;
	printerName: String;
	dt : TimeStamp;
	rem : Integer;
	index : Integer;
	retValue : Boolean;
	perPageLegendsUsed : CMIF_ScanPlanLegendDict;
	lastCmifBay : CMIF_ScanPlanReportBay;	//12 Jan 2021	NDL	TFS 50541
	
begin

	//setup the printer
	app.printer.abort();
//	printerName := "Microsoft Print to PDF";
	printerName := app.printer.getPrinterName;	//05 Jan 2021	NDL	TFS 50537 - will just use the one set up in MTN
	app.printer.setPrinter( printerName );
	app.printer.printPreview := self.preview;
	if self.paperSize = self.PaperA4 then
		app.printer.documentType := Print_A4;
	elseif self.paperSize = self.PaperA3 then
		app.printer.documentType := Print_A3;
	endif;
	app.printer.setMargins( Print_Landscape, 0, 0, 2, 2 );
	
	dt := app.systemToLocalTime( app.actualTimeServer() );
	
	// create the report instance
	create report transient;
	
	//create the images for the individual cell slots and the fixed attributes for the legend.
	self.populateCMIFPictures( report );
	
	//Set up the frame sizes the user selected i.e. 1, 2, 3, 2x3 or 3x4.
	self.setFrameSizes( report );
	
	//populate the repetitive data frames
	self.populateFrmHeader( report );
		
	if self.legend = self.LegendOne and not self.allScanPlanLegends.isEmpty then
		//They want the first page with just a legend on it, (and we have legend data) so do that and then hide the legend
		self.populateFrmLegend( report, null );
		self.populateFrmFooter( report, dt );
		app.printer.print( report.frmMain );
		app.printer.newPage();
		report.frmLegend.visible := false;
	elseif self.legend = self.LegendAll then
		//they want a legend on every page, with just the items that are used on that page.
		create perPageLegendsUsed transient;
	endif;
	
	foreach cmifBay in self.allScanPlanReportBays do
	
		
		if index = 0 then	//12 Jan 2020	NDL	TFS 50541 - moved up from being peformed in frame 1 to allow for potential for blank first frame when doing single and triple bays
			self.allClonedControls.purge();	//clear all the cloned controls before we atart a new page
			if self.printCargoList then
				self.allCurrentCargoToList.clear(); //clear all the cargo to print before we start a new page.
			endif;
			if perPageLegendsUsed &lt;&gt; null then	// clear all the legends used on the previous page
				perPageLegendsUsed.clear();
			endif;
		endif;
		
		index := index + 1;
		
		//12 Jan 2020	NDL	TFS 50541 - skip a frame in the 2x3 and 3x4 layout after a single bay hold, and after a triple bay hold.
		if self.baysPerPage &gt; 5 and lastCmifBay &lt;&gt; null then
			if lastCmifBay.myBay &lt;&gt; cmifBay.myBay then
				if not lastCmifBay.isTwinBayHold then
					//the last bay printed was from a single or triple bay and is not the same hold as this one so skip a frame
					index := index + 1;
				endif;
			endif;
		endif;
		lastCmifBay := cmifBay; 
		
		self.setFrameFromIndex( index, report, cmifBay ); //12 Jan 2020	NDL	TFS 50541 to draw frames top to bottom going left to right, instead of the more natural left to right going top to bottom...
		/*
		if index = 1 then
			report.frmBay1.visible := true;
			self.populateFrmBay( 	report.frmBay1,	//_bayFrame : CMUI_Frame;
								report.lblBayId1,	//_bayIdLbl : CMUI_Label input;
								report.lblColId1,	//_colIdLbl : CMUI_Label input;
								report.lblTierId1,	//_tierIdLbl : CMUI_Label input;
								report.picCell1,	//_cellPic : CMUI_Picture input;
								report.frmHatch1,	//_hatchFrm : CMUI_Frame input;
								cmifBay	//_cmifBay : CMIF_ScanPlanReportBay
								);
		elseif index = 2 then
			report.frmBay2.visible := true;	
			self.populateFrmBay( 	report.frmBay2,	//_bayFrame : CMUI_Frame;
								report.lblBayId2,	//_bayIdLbl : CMUI_Label input;
								report.lblColId2,	//_colIdLbl : CMUI_Label input;
								report.lblTierId2,	//_tierIdLbl : CMUI_Label input;
								report.picCell2,	//_cellPic : CMUI_Picture input;
								report.frmHatch2,	//_hatchFrm : CMUI_Frame input;
								cmifBay	//_cmifBay : CMIF_ScanPlanReportBay
								);
		elseif index = 3 then
			report.frmBay3.visible := true;	
			self.populateFrmBay( 	report.frmBay3,	//_bayFrame : CMUI_Frame;
								report.lblBayId3,	//_bayIdLbl : CMUI_Label input;
								report.lblColId3,	//_colIdLbl : CMUI_Label input;
								report.lblTierId3,	//_tierIdLbl : CMUI_Label input;
								report.picCell3,	//_cellPic : CMUI_Picture input;
								report.frmHatch3,	//_hatchFrm : CMUI_Frame input;
								cmifBay	//_cmifBay : CMIF_ScanPlanReportBay
								);
		elseif index = 4 then
			report.frmBay4.visible := true;	
			self.populateFrmBay( 	report.frmBay4,	//_bayFrame : CMUI_Frame;
								report.lblBayId4,	//_bayIdLbl : CMUI_Label input;
								report.lblColId4,	//_colIdLbl : CMUI_Label input;
								report.lblTierId4,	//_tierIdLbl : CMUI_Label input;
								report.picCell4,	//_cellPic : CMUI_Picture input;
								report.frmHatch4,	//_hatchFrm : CMUI_Frame input;
								cmifBay	//_cmifBay : CMIF_ScanPlanReportBay
								);
		elseif index = 5 then
			report.frmBay5.visible := true;	
			self.populateFrmBay( 	report.frmBay5,	//_bayFrame : CMUI_Frame;
								report.lblBayId5,	//_bayIdLbl : CMUI_Label input;
								report.lblColId5,	//_colIdLbl : CMUI_Label input;
								report.lblTierId5,	//_tierIdLbl : CMUI_Label input;
								report.picCell5,	//_cellPic : CMUI_Picture input;
								report.frmHatch5,	//_hatchFrm : CMUI_Frame input;
								cmifBay	//_cmifBay : CMIF_ScanPlanReportBay
								);
		elseif index = 6 then
			report.frmBay6.visible := true;	
			self.populateFrmBay( 	report.frmBay6,	//_bayFrame : CMUI_Frame;
								report.lblBayId6,	//_bayIdLbl : CMUI_Label input;
								report.lblColId6,	//_colIdLbl : CMUI_Label input;
								report.lblTierId6,	//_tierIdLbl : CMUI_Label input;
								report.picCell6,	//_cellPic : CMUI_Picture input;
								report.frmHatch6,	//_hatchFrm : CMUI_Frame input;
								cmifBay	//_cmifBay : CMIF_ScanPlanReportBay
								);
		elseif index = 7 then
			report.frmBay7.visible := true;	
			self.populateFrmBay( 	report.frmBay7,	//_bayFrame : CMUI_Frame;
								report.lblBayId7,	//_bayIdLbl : CMUI_Label input;
								report.lblColId7,	//_colIdLbl : CMUI_Label input;
								report.lblTierId7,	//_tierIdLbl : CMUI_Label input;
								report.picCell7,	//_cellPic : CMUI_Picture input;
								report.frmHatch7,	//_hatchFrm : CMUI_Frame input;
								cmifBay	//_cmifBay : CMIF_ScanPlanReportBay
								);
		elseif index = 8 then
			report.frmBay8.visible := true;	
			self.populateFrmBay( 	report.frmBay8,	//_bayFrame : CMUI_Frame;
								report.lblBayId8,	//_bayIdLbl : CMUI_Label input;
								report.lblColId8,	//_colIdLbl : CMUI_Label input;
								report.lblTierId8,	//_tierIdLbl : CMUI_Label input;
								report.picCell8,	//_cellPic : CMUI_Picture input;
								report.frmHatch8,	//_hatchFrm : CMUI_Frame input;
