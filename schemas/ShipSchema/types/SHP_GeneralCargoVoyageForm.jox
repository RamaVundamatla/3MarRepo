    <JadeMethod name="doMnuSetStopsClick" id="6b7d6d77-8b05-4de5-82b6-855dd5d9d7fa">
        <updating/>
        <source>doMnuSetStopsClick(_menuItem: MenuItem input) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	23 May 2006 By cnwth2

Purpose:	PAR 11791 - Bulk update of tasks and stops - overhaulled

Changed On	Changed By  Reason
28/01/2010	cnwrl1		PAR 21889 - CCMS 1002 = Stops and Italian Customs - T1015 = Expiry Date for Stops Clearance
16/06/2010	cnwcs5		par 24342 - new form for maintaining stops
----------   ----------  --------------------------------------------------
*/
vars
	result		: Integer;
	lTI			: CM_TrackedItem;
	stopsTable	: CM_StopsTable;
	tiSet		: CM_TISet;
	
begin
// just maintains the last ti selected
	lTI := _menuItem.userObject.CM_TrackedItem;
	
	self.myAssistant.showStopsForm_TI (lTI, null, app.getMyUser.canUpdateStops( self.myTerminal) );	//cnwrd1 par 29440 27.4.2012
	
	return;
	
/*	app.mousePointer	:= Busy;						// cnwrl1 27/01/2010 PAR 21889
	
	lTI := self.mnuCargo.userObject.CM_TrackedItem;
	if lTI = null then
//		app.msgBox('Cannot update stop as you have not selected a cargo item.', 'Select Cargo Item(s)', MsgBox_Stop_Icon+MsgBox_OK_Only);	// cnwrl1 28/01/2010 PAR 21889 - what it was
		app.msgBox(	app.getString( CannotUpdateStopNothingSelectd ),
					app.getString( Please_Select_Cargo_Items ),
					MsgBox_Stop_Icon + MsgBox_OK_Only );
		return;
	endif;
	
	stopsTable	:= _menuItem.userObject.CM_StopsTable;
	
	// cnwrl1 27/01/2010 PAR 21889 - start of coding
	// NOTE: This reproduces the release 7.7.3 behaviour - ie it only handles the last TrackedItem clicked on.
	create tiSet transient;
	while true do : update_TrackedItems
		self.myAssistant.contextMenuTIsStop( stopsTable, lTI, tiSet );
		
		if app.myPassport.noErrors then
			self.clearErrorWarnings();
			return;
		endif;
		result	:= app.showErrorWarningDialog(	app.getString( EWD_Cannot_Continue, app.getString( HeadingSaved ) ),
												app.myPassport,
												ErrWarnMode_Add + ErrWarnMode_CanAckWarnings );
		if app.myPassport.noErrors and result = IDOK then
			app.myPassport.warningsAcknowledged	:= true;
			continue update_TrackedItems;
		endif;
		self.setAllErrorWarnings( app.myPassport );	// copies errors to this form and shows in err/warnings window
		return;
	endwhile update_TrackedItems;*/
	// cnwrl1 27/01/2010 PAR 21889 - end of coding
	
	/* cnwrl1 28/01/2010 PAR 21889 - what it was
	//CCMS1200 Can't add a CEDO stop or customs stop to a child as it may interfere with the parent discharge.	
//	if (tmpStop.allProcessAreas.includes(StopProcessRemoveWhenChild) or tmpStop.allSetAreas.includes(StopApplyExport)) and ti.isChild then
//	if not tmpStopTable.isStopRelevant(ti.cargoType, ti) then //cnwrs1 May 2007 Par13378 stops
//		app.msgBox(app.getErrorString(CannotSetStop), app.getErrorString(UnableToPerformOperation), MsgBox_OK_Only + MsgBox_Information_Icon);
//		return;
//	endif;
	
	// get all selected cargo items to add or remove stop from all.
	create tiSet transient;
	self.getCurrentlySelectedTIs(tiSet);
	
	if (not tiSet.includes(ti)) then
		tiSet.add(ti);
	endif;
			
	create stopArr transient;
	stopArr.add(tmpStopTable.id);

	if (not ti.hasStopOfType(tmpStopTable)) then //must be adding
		// create stop for selected cargo items...
		while true do
			app.myTrxCA.trxCreateStopsForTIs(tiSet, stopArr, app.myPassport);
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				break;
			else
				result := app.showErrorWarningDialog('Add Stops ', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					// there must have just been warnings that the user has acknowledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			endif;
			
			break;
		endwhile;
	
	else
		// remove stop for selected cargo items...
		if tmpStopTable.requiresInfo then
			// check stop requires extra info. before it can be cleared...
			create inputBox;
			inputBox.setAssistantAndTerminalRefs(self.myAssistant, self.myTerminal);
//			inputBox.init(app.getErrorString(LBLCustoms_entry_number), app.getErrorString(LBLEnterCustomsEntryNum),	// cnwrl1 05/06/2009 PAR 19574 - what it was
//				"", 11, TextBox.DataType_AlphaNumeric, false);				// cnwrl1 05/06/2009 PAR 19574 - what it was
			inputBox.init(	app.getErrorString(LBLCustoms_entry_number),
							app.getErrorString(LBLEnterCustomsEntryNum),
							"", 11, TextBox.DataType_AlphaNumeric, TextBox.Case_None, false );
			
			inputBox.showModal;
			if inputBox.modalResult &lt;&gt; IDOK then
				self.clearErrorWarnings();
				return;
			endif;
			tmpCENumber := inputBox.txtInput.text.trimBlanks;
		endif;
		
		while true do
			app.myTrxDA.trxDeleteStopForTIsBulk(tiSet, tmpStopTable, tmpCENumber, app.myPassport);
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				break;
			else
				result := app.showErrorWarningDialog('Remove Stops ', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					// there must have just been warnings that the user has acknowledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			endif;
			
			break;
		endwhile;
	endif;
	
	_menuItem.checked := not _menuItem.checked;

epilog
	delete tiSet;
	delete stopArr;
	mousePointer := MousePointer_Default;
end;
	cnwrl1 28/01/2010 PAR 21889 - end of what it was */
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
