    <JadeMethod name="populateBOLDetails" id="9524cd6d-3d91-4afe-b30f-796ee737bce9">
        <updating/>
        <source>populateBOLDetails() updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 22 January 2019
TFS#		: 41708
Function	: Populate Bill of Lading Item Details Combobox 
			  based from the current selected Bill of Lading.

*** Changes ***
Date			Name		TFS#		Description
05/04/2019		jlgka1		44197		Added UseTotReqAllowedFld in the condition.
****************************************************/
vars
	bolIn			: CM_BOLIn;
	bolDetail		: CM_BOLDtl;
	currBOLDetail	: CM_BOLDtl;
begin	
	if self.myMasterProxyObject.CM_BulkRelease &lt;&gt; null and self.myTerminal.getConfig(UseTotReqAllowedFld).Boolean then	
		bolIn := self.myMasterProxyObject.CM_BulkRelease.myBOLIn;
		currBOLDetail := self.cmbBOLItems.listObject.CM_BOLDtl;
			
		if bolIn &lt;&gt; null then
			self.cmbBOLItems.listCollection(bolIn.allBOLDtls, true, 0);
			
			foreach bolDetail in bolIn.allBOLDtls where bolDetail = currBOLDetail do
				if bolIn.allBOLDtls.includes(bolDetail) then
					self.cmbBOLItems.text := bolDetail.cargoTypeDescr &amp; Tab &amp; bolDetail.commodity &amp; Tab &amp; bolDetail.quantity.asStringJMT ;
					self.cmbBOLItems.listObject := bolDetail;
					return;
				endif;
			endforeach;
			
			self.cmbBOLItems.listIndex := -1;
			self.cmbBOLItems.text := null;
		else
			self.cmbBOLItems.clear;
			return;
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateHeaderBillOfLading" id="5de28d4c-d0b0-4632-b0bd-581718ceca4b">
        <source>populateHeaderBillOfLading(releaseType : Integer);
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 18 January 2019
TFS#		: 41708
Function	: Populate Bill of Lading Combobox when 
			  Release Type are Rail, Road, Ship or Unknown
			  When Release By Type is False.

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	voyageCode	: String;
	bolInNumber	: String;
	voyage		: CM_Voyage;
	bolIn		: CM_BOLIn;
	index		: Integer;
begin		
	
	if self.mySelectedObject.CM_BulkRelease &lt;&gt; null and
	   releaseType &lt;&gt; BR_TYPE_PACKING 
	   and not self.tblEntry.getValueByName(ETRow_ReleaseByType).Boolean
	   and self.myTerminal.getConfig(UseTotReqAllowedFld).Boolean then	
		voyage:= self.mySelectedObject.CM_BulkRelease.myVoyage;
		bolIn := self.mySelectedObject.CM_BulkRelease.myBOLIn;
		if bolIn &lt;&gt; null then
			if voyage = null or (not voyage.allBOLInByTypeStatusNumDT.includes(bolIn)) then
				bolIn := null;	
				self.myMasterProxyObject.CM_BulkRelease.setMyBOLIn(null);
			endif;
		endif;
		
		self.myAssistant.comboBoxBOLInsForVoyage(self.cmbBOLAnyId, voyage, bolIn);
		self.setTotReqFldFieldsVisibility(self.tblEntry.getValueByName(ETRow_ReleaseByType).Boolean);
	endif;
end;</source>
        <Parameter name="releaseType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="saveUserEntry" id="c30fdfce-0bce-4ff4-842e-8f6443f3401e">
        <updating/>
        <source>saveUserEntry() updating;
/*
----------   ----------  --------------------------------------------------
Created:	03 May 2007 By cnwth2

Changed On  Changed By  Reason
18/02/2013	cnwcs5		Minor changes to use local variables	
----------  ----------  --------------------------------------------------
*/
vars
	idx				: Integer;
	invalidObject 	: Boolean;
	obj				: CM_Object;
	listbox			: CMUI_ListBox;
begin
	obj := self.mySelectedObject;

	on Exception do app.handleDeletedObject( exception, obj, invalidObject );	//25 Feb 2011	NDL	Par 27056
		
	if CM_BulkRelease.hasInstance(obj) then
		self.saveUserEntryBulkRelease();
		
	elseif CM_ReserveSelection.hasInstance(obj) then
		self.saveUserEntryReserveSelection();
	elseif obj.isKindOf(CM_TrackedItem) then //cnwrd1 ccms 2274 break bulk
		self.saveUserEntryTrackedItem();
	elseif obj.isKindOf(CM_ReserveTI) then //epr par 32330 29/8/13
		self.saveUserEntryReserveTI();
	else
		return; //epr par 35154 18//14
	endif;

	//update the tree text and/or picture
	listbox	:= self.lstTree;
	idx 	:= listbox.findObject(obj);
	
	if idx &gt; 0 then		
		listbox.itemText[idx] 		:= self.getTreeCaptionForObj(obj);
		listbox.itemPicture[idx] 	:= self.getItemPictureForObj(obj);
	endif;
		
end;


</source>
    </JadeMethod>
    <JadeMethod name="saveUserEntryBulkRelease" id="d80d0bdb-f6a5-4fd3-a882-0afc9792174e">
        <updating/>
        <source>saveUserEntryBulkRelease() updating, protected;
/*
----------  ----------  --------------------------------------------------
Created:	22 May 2007 By cnwth2
/* Changes

Date		Name	TFS#			Description
============================================================================
31/07/2009	cnwdad1	PAR #20381 		Entry Table was losing Sub-Terminal after changing selected object in tree.
24/11/2011	cnwcs5	CCMS POL 2122 / 
					PAR28696 - 		NeedsReview property						
07/11/2011	cnwrs1	CCMS POL 2122 / 
					PAR 28696 - 	New property allEDIFiles
23/04/2012	cnwcs5	CCMS POL 2172 / 
					par 29480 - 	Coparn release updates
18/02/2013	cnwcs5	par 30970 - 	Delivery reason not being saved correctly
15/01/2015  cnwma1	PAR #35462 		Carrier Drop-down Fields	
24/01/2019	jlgka1	41708			Release Request Header BOL to be saved if the config is true.
============================================================================*/
vars
	release					: CM_BulkRelease;
	terminal				: CM_Terminal;
	subTerminal				: CM_SubTerminal;
	subTerminalTarget		: CM_SubTerminal;
	tbl						: CM_EntryTable;
	releaseTS				: TimeStamp;
	requiredTS				: TimeStamp;
	doorsDir				: Integer;
	packLocs				: StringArray;
	mtGrades				: IntegerArray;
	obj						: Object;
	consigneeCode			: String;
	consignorCode			: String;
	freightForwarderCode	: String;
	deliveryReason			: String;
	customsAgentStr			: String;
	stCode					: String;
	carrierCode				: String;
	isWaybill				: Boolean;
	canBeHiLoCube			: Boolean;
	expiryTimeStamp 		: TimeStamp;	//13 Feb 2017	NDL	TFS 3368
	bolIn					: CM_BOLIn;	 // jlgka1 TFS 41708
	
begin
	tbl 		:= self.tblEntry;
	release 	:= self.myMasterProxyObject.CM_BulkRelease;
	terminal	:= self.myTerminal;
	
	releaseTS.setDate(tbl.getValueAsDate(ETRow_RequestDate));
	releaseTS.setTime(tbl.getValueByName(ETRow_RequestTime).Time);
	requiredTS.setDate(tbl.getValueAsDate(ETRow_EstimatedRequiredDate));
	requiredTS.setTime(tbl.getValueByName(ETRow_EstimatedRequiredTime).Time);
	
	//jlgka1 TFS 41708 --&gt;
	if tbl.getValueByName(ETRow_BillOfLadingCmbAnyId) &lt;&gt; null and 
	   self.myTerminal.getConfig(UseTotReqAllowedFld).Boolean then	
		obj := self.cmbBOLAnyId.listObject;		
		if obj &lt;&gt; null then
			bolIn := obj.CM_BOLIn;
		endif;		
	endif;
	//jlgka1 TFS 41708 &lt;--
	
	if tbl.getValueByName(ETRow_DoorsForward).Boolean then
		doorsDir := TI_DOORSDIRN_FWD;
	endif;
	
	create packLocs transient;
	self.lstPackLocn.getSelectedAsStringArray(packLocs);
	
	create mtGrades transient;
	self.myAssistant.saveListTableMTGrades(self.lstMTGrade, mtGrades);
	
//	Consignee
	obj := self.cmbConsignee.listObject;
	
	if obj &lt;&gt; null then
		consigneeCode := obj.CM_ConsigneeConsignor.code;
	endif;

// 	Consignor
	obj := self.cmbConsignor.listObject;
	
	if obj &lt;&gt; null then
		consignorCode := obj.CM_ConsigneeConsignor.code;
	endif;
	
//	Freight Forwarder
	obj := self.cmbFreightFwdr.listObject;
	
	if obj &lt;&gt; null then								// PAR 20646
		freightForwarderCode := obj.CM_ConsigneeConsignor.code;
	endif;
//  Carrier 											// 12/01/2015 cnwma1 PAR #35462
	obj := self.cmbCarrier.listObject;
	if obj &lt;&gt; null then
		carrierCode :=obj.CM_Carrier.code;
	endif;
	
	isWaybill 		:= tbl.getValueByName(ETRow_AllowCargoOnMultiRel).Boolean;
	canBeHiLoCube 	:= tbl.getValueByName(ETRow_HiLowCube ).Boolean;
	
// cnwdad1 31/07/2009 - PAR #20381.
	if app.isSubTerminalsOn(terminal) then
		stCode	:=	tbl.getValueByName(ETRow_MySubTerminal).String;
		
		if stCode &lt;&gt; null then
			subTerminal	:= terminal.allSubTerminals[stCode];
		endif;
		
		//cnwrd1 par 23219 17.3.2010
		stCode	:=	tbl.getValueByName(ETRow_MySubTerminalTarget).String;	
		
		if stCode &lt;&gt; null then
			subTerminalTarget := terminal.allSubTerminals[stCode];
		endif;		
	endif;
	
//	Customs Agent	
	obj := self.cmbCustomsAgent.listObject;
	
	if obj  &lt;&gt; null then
		customsAgentStr	:= obj.CM_CustomsAgent.code;
	endif;
	
	//13 Feb 2017	NDL	TFS 3368
	expiryTimeStamp.setDate(tbl.getValueAsDate(ETRow_ExpiryDate));
	expiryTimeStamp.setTime(tbl.getValueByName(ETRow_ExpiryTime).Time);
	
// 	DeliveryReason	
	deliveryReason := tbl.getValueByName(ETRow_DeliveryReason).String;
	
	if release &lt;&gt; null then//added by cnwyl1 for par15721
		/* 16 Jun 2021 - TFS 51340 - removed again.  app.doWindowsEvents caused a second proces to kick in before this one was done, clearing the field and re-processing with
													the cleared value.
		app.doWindowEvents(1);	// 21 Jan 2021	NDL	TFS 50692 - Grasping at straws here, but 'tbl.getValueByName(ETRow_ReleaseNo)' returns null here, but by the time the 
								// dump occurs in 'doSave' the value is visible in the screen shot and showing in the dump. Feels like a refresh issue.
		*/
		release.setProxy(tbl.getValueByName(ETRow_ReleaseNo).String,
						self.cmbBRType.listData(),
						tbl.getValueByName(ETRow_ReleaseByType).Boolean,
						app.releaseStatusStringToEnum(tbl.getValueByName(ETRow_StatusBulkRelease).String),
						mtGrades,
						tbl.getValueByName(ETRow_BookingConfirmation).String,
						//tbl.getValueByName(ETRow_CarrierCode).String,		// 12/01/2015 cnwma1 PAR #35462
						carrierCode,										// 12/01/2015 cnwma1 PAR #35462
						tbl.getValueByName(ETRow_Remarks).String,
						consigneeCode,
						null,
						consignorCode,
						null,
						tbl.getValueByName(ETRow_ConsignorVoyageCode).String,
						self.localToSystemTime(releaseTS),									// 15/4/16 cnwmp6 TFS 488 - Multi timezone support
						self.localToSystemTime(requiredTS),									// 15/4/16 cnwmp6 TFS 488 - Multi timezone support
						app.deliveryReasonStringToEnum (deliveryReason),					// delivery reason code (par 30970)
						deliveryReason,														// delivery reasons description (par 30970)
						tbl.getValueByName(ETRow_DeliveryReleaseNumber).String,
						doorsDir,
						tbl.getValueByName(ETRow_FreightPayerCode).String,
						self.cmbBookingRef.listObject.CM_BookingRef,
						self.cmbLoadPort.listObject.CM_Port,
						self.cmbDestination.listObject.CM_Port,								//_destinationPort	//04 Nov 2009	NDL Par 21519
						self.cmbDischarge.listObject.CM_Port,
						freightForwarderCode,												// PAR 20646 - was self.cmbFreightFwdr.listObject.CM_ConsigneeConsignor,
						self.cmbDestTerminal.listObject.CM_Terminal,
						terminal,													
						self.cmbOperator.listObject.CM_Operator,
						self.cmbOperatorGroup.listObject.CM_OperatorGroup,
						self.cmbVoyage.listObject.CM_Voyage,
						self.cmbBizUnit.listObject.CM_Bank,
// TFS 2686						tbl.getValueByName(ETRow_RemoveStops).Boolean,
						(not tbl.getValueByName(ETRow_MtRelease).Boolean),
						packLocs,
						null,
						null,
						subTerminal,
						subTerminalTarget, 													// subterm target//cnwrd1 par 23219 17.3.2010
						self.cmbTrainAssigned.listObject.CM_Train,							//_assignedTrain : CM_Train	//04 Nov 2009	NDL Par 21519
						isWaybill,
						customsAgentStr,													// cnwrl1 19/02/2010 PAR 22393
						tbl.getValueByNameIfVisible( ETRow_CustomsAssistance ).Boolean,		// cnwrl1 19/02/2010 PAR 22393
						canBeHiLoCube,														// May 2011 cnwjre1 27097 POL CCMS 2043
						tbl.getValueByName(ETRow_NeedsReviewCB ).Boolean,					// par 28696
						tbl.getValueByName (ETRow_BlockEDIUpdatesCB).Boolean, 				// par 29480
						null,																// CCMS POL 2122 / PAR 28696 cnwrs1
						expiryTimeStamp,
						bolIn,																// jlgka1 TFS 41708
						release.context		 // ### TFS BUG 56530 21FEB2023 NAVAB1														// ### TFS 53953 27June2022 NAVPW1
						);
		release.setRemarksAdditionals(	tbl.getValueByName( ETRow_RemarksAdditional1 ).String,	//_remAdd1 : String;
										tbl.getValueByName( ETRow_RemarksAdditional2 ).String	//_remAdd2 : String
										);
	endif;
epilog
	delete packLocs;
	delete mtGrades;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="saveUserEntryReserveSelection" id="8e2713be-f7c2-47f3-8717-64ffefefcb51">
        <source>saveUserEntryReserveSelection() protected;
/*
----------   ----------  --------------------------------------------------
Created:	22 May 2007 By cnwth2

Changed On	Changed By  Reason
27/11/2009	cnwmh5		PAR 21492 - Make sure that type is save correctly	
18/09/2012	cnwcs5		par 30390 - change of signature for CM_ReserveSelection setProxy
23/08/2013	cnwdap1		PAR #32331 Added Colour Picker
10/12/2013	cnwdap1		PAR #33169 Correct handling of measurement fields
09/09/2014	cnwrs1		CCMS 2351 att Sequence to Release request 
01/07/2015	cnwma1		PAR #36555 CCMS 2509 TFS - Multi-location selection for MTs for vessel release
20/09/2018	jlgka1		TFS 40022 To address ISO Group field not being cleared when a Cargo Type 
						is change into a different Cargo Type where an ISO Group is not needed.
20/02/2019 jlger1			TFS 41398 -fixed issues with bulk cargo
14 Jun 2022 jlier1		TFS 53678
//19/07/2022	navtnr20	ChangeRequest 53974: EUP - OUT - Additional Fields on Release Line Level
//19 Dec 2022   navsa20     Bug 55878: SNO - Error 4033 happens while trying to update a Release Request
14/03/2023		navkc1		Bug 56937: MTN - Release Request - 1090 occurring when saving Release by Type with no Cargo Type specified
//22/06/2023	navkc1	CR 57496 Task 58405: UI - Release Request Cargo Group
28 June 2023 navmv20 CR 58410 Task 58411: UI - Cargo Review - Release Request
19/07/2023	jlizm1		TFS 58461 Change release mark number to string
6/12/2023	navcs2	ChangeRequest 57537: EUP | Release Request By Type - with Weight
07 Oct 2024	navbs1	Bug MTN-32769 TPT | 1011 with 2 x Group Group ID's on a Release Request
24/04/2025	navrv30	MTN 34319 EUP | Creating a Release Request from Cargo Review - Validation
23/10/2025	jlizm1		MTN 36255 Rotabox Assign Release To Vessel
----------   ----------  --------------------------------------------------
*/
vars
	reserveSelection			: CM_ReserveSelection;
	packType					: Integer;
	cargoType					: CM_CargoType;
	byTypeByWeight 				: Boolean;
	isoType						: CM_ISOType;
	isoGroup					: CM_ISOTypeGroup;
	product						: CM_Product;
	bookingItem					: CM_BookingRefItem;
	mtGrades					: IntegerArray;
	idMasks 					: String;
	array						: StringArray;
	
	desciptionSelection			: String; //cnwjo3 par 20522 ccms1071 start
	heightSelection				: Decimal[12,2];
	lengthSelection				: Decimal[12,2];
	markNumber					: String;
	quantitySelection			: Integer;
	remarksSelection			: String;
	volumeSelection				: Decimal[12,2];
	weightSelection				: Decimal[12,2];
	widthSelection				: Decimal[12,2]; 
	table						: CM_EntryTable;
	markSelection				: String;
	densitySelection			: Integer;
	typeSelection				: String; //cnwjo3 par 20522 ccms1071 end
	terminalArea				: CM_TerminalArea;	// 15/02/2010 cnwjre1	CCMS 1101/ par 22634
	bestPick					: Boolean;		// CCMS 1101
	receivalBOL					: CM_BOLIn;
	colour						: String;				// PAR #32331
	allTermAreaDict				: CM_TAByIdDict; 	   // 01/07/2015 cnwma1 PAR #36555
	deliveryParty 				: CM_DeliveryParty;
	deliveryAddress 			: CM_Address;
	deliveryFromDT,
	deliveryToDT,
	receivedDT,
	releasedDT 					: TimeStamp;
	vesselCode					: String;
	lineNumber					: Integer;	//20-07-2022 navtnr20 53974
	customerReference			: String;	//20-07-2022 navtnr20 53974
	cargoGroup					: CM_CargoGroup; //22/06/2023	navkc1	CR 57496 Task 58405
	quantitySelected			: Integer;		//6/12/2023 navcs2 ChangeRequest 57537
	locnByOldest				: Boolean; //19/02/2023	navkc1 CR 60078 Task 62450
	heavyRated					: Boolean;
	commodity 					: CM_Commodity;
	contentsType				: CM_CargoType;
	
begin
	
	table := self.tblEntry;
	reserveSelection := self.mySelectedObject.CM_ReserveSelection;
	if self.myMasterProxyObject.CM_BulkRelease.type = BR_TYPE_PACKING then
		packType := self.cmbPackType.listData();
	else
		packType := CM_ReserveDetail.PackType_Parent;
	endif;
	
	bookingItem	:=	cmbBRItem.listObject.CM_BookingRefItem;
	cargoType	:=	self.cmbTiType.listObject.CM_CargoType;
	cargoGroup := self.cmbCargoGroup.listObject.CM_CargoGroup; //22/06/2023	navkc1	CR 57496 Task 58405
	commodity := self.cmbCommodity.listObject.CM_Commodity;  //24/04/2025	navrv30	MTN 34319
	if cargoType &lt;&gt; null and (cargoType.id = TI_CargoType_Container or cargoType.id = TI_CargoType_Generator) then
		isoType := self.cmbISOType.listObject.CM_ISOType;
		
		create mtGrades transient;
		self.myAssistant.saveListTableMTGrades(self.lstMTGrade, mtGrades);
		
		isoGroup 	:= self.cmbISOGroup.listObject.CM_ISOTypeGroup;  //jlgka1 TFS 40022 //cnwrd1 par 20810 9/10/9
		
		heavyRated := table.getValueByName(ETRow_HeavyRated).Boolean;		//07.10.2024 navbs1 #32769
		
		if isoType &lt;&gt; null and isoType.isRotatable then
			contentsType := self.cmbContentsCargoType.listObject.CM_CargoType;
			product := self.cmbContentsCargoSubType.listObject.CM_Product;
		endif;
	else
		product := self.cmbProduct.listObject.CM_Product;
	endif;
	
	if product &lt;&gt; null then
		desciptionSelection:=product.description;
	endif;
	
	
	idMasks		:= table.getValueByName(ETRow_IdMask).String;  // dh 25/1/2008 par 15489 added
	
	create array transient; // adm 110708 Par 17520 unconditionally create array 
	
	if idMasks &lt;&gt; "" then
		idMasks.convertToDelimitedArray(",", array);
	endif;
	
	heightSelection 	:= table.getMeasurementValueByName(ETRow_MyHeight).Decimal;
	lengthSelection 	:= table.getMeasurementValueByName(ETRow_MyLength).Decimal;
	markNumber 			:= table.getValueByName(ETRow_MarkNumber).asStringJMT();
	markSelection 		:= table.getValueByName(ETRow_Mark).asStringJMT();
	quantitySelection 	:= table.getValueByName(ETRow_MyQuantity).Integer;
	remarksSelection 	:= table.getValueByName(ETRow_CargoRemarks).asStringJMT();
	volumeSelection 	:= table.getMeasurementValueByName(ETRow_MyVolume).Decimal;
	weightSelection 	:= table.getMeasurementValueByName(ETRow_MyWeight).Decimal;
	widthSelection 		:= table.getMeasurementValueByName(ETRow_MyWidth).Decimal;
	densitySelection 	:= table.getMeasurementValueByName(ETRow_MyDensity).Integer;
	byTypeByWeight 		:= table.getValueByName(ETRow_ByTypeByWeight).Boolean;
	if byTypeByWeight then															// 6/12/2023 navcs2 ChangeRequest 57537
		quantitySelected := 0;														// 6/12/2023 navcs2 ChangeRequest 57537
	else																			// 6/12/2023 navcs2 ChangeRequest 57537
		quantitySelected := table.getValueByName(ETRow_TotalRequested).Integer;		// 6/12/2023 navcs2 ChangeRequest 57537
	endif;																			// 6/12/2023 navcs2 ChangeRequest 57537
	// START navtnr20 12-070-2022 53974
	//lineNumber			:= table.getValueByName(ETRow_LineNumber).Integer;          //navtnr20 12-07-2022 53974	//navsa20 19-12-2022 TFS 55878
	lineNumber			:= table.getValueByName(ETRow_LineNumberHdr).Integer;           //navsa20 19-12-2022 TFS 55878
	if lineNumber = 0 then 
		lineNumber := reserveSelection.myReserveHeader.allReserveDetails.indexOf(reserveSelection);
	endif;
	customerReference	:= table.getValueByName(ETRow_CustomerReference).asStringJMT; //navtnr20 12-070-2022 53974
	
	//END navtnr20 12-070-2022 53974
	typeSelection 		:= self.myAssistant.mainExtraGetValue(table, table, ETRow_MyType).String;	// 27/11/2009 cnwmh5 #2i492
	
	//terminalArea 		:= self.cmbTermArea.listObject.CM_TerminalArea;	// 15/02/2010 cnwjre1 CCMS 1101 + 22634    // 01/07/2015 cnwma1 PAR #36555
	create allTermAreaDict transient;									// 01/07/2015 cnwma1 PAR #36555
	self.allSelectedTAs.copy(allTermAreaDict);							// 01/07/2015 cnwma1 PAR #36555
	
	
	bestPick 			:= table.getValueByName(ETRow_BestPick).Boolean;		// CCMS 1101
	receivalBOL 		:= self.cmbBOL.listObject.CM_BOLIn; //#24351	03/06/2010
	locnByOldest		:= table.getValueByName(ETRow_LocnByOldestTransArrival).Boolean; //19/02/2023	navkc1 CR 60078 Task 62450
	if self.myTerminal.getConfig(ValidateColour).Boolean then							// PAR #32331
		colour			:= self.myAssistant.getColourString(self.lstColour, null);		// PAR #32331
	else																				// PAR #32331
		colour			:= table.getValueByName(ETRow_Colour).asStringJMT();			// PAR #32331
	endif;	// PAR #32331
	
	deliveryParty:=self.cmbDeliveryParty.listObject.CM_DeliveryParty;
	deliveryAddress:=self.cmbDeliveryAddress.listObject.CM_Address;
	deliveryFromDT.setDate(table.getValueByName(ETRow_DeliveryFromDate).Date);
	deliveryFromDT.setTime(table.getValueByName(ETRow_DeliveryFromTime).Time);
	deliveryToDT.setDate(table.getValueByName(ETRow_DeliveryToDate).Date);
	deliveryToDT.setTime(table.getValueByName(ETRow_DeliveryToTime).Time);
	
	receivedDT.setDate(table.getValueByName(ETRow_ReceivedDate).Date);
	receivedDT.setTime(table.getValueByName(ETRow_ReceivedTime).Time);
	releasedDT.setDate(table.getValueByName(ETRow_ReleasedDT).Date);
	releasedDT.setTime(table.getValueByName(ETRow_ReleasedTime).Time);
	
	if self.cmbVessel.listObject &lt;&gt; null then
		vesselCode:=self.cmbVessel.listObject.CM_Vessel.code;
	endif;
	
	reserveSelection.setProxy(packType,
							cargoType,
							bookingItem,
							isoType,
							isoGroup,  //cnwrd1 par 20810 9/10/9
							product,
							desciptionSelection,
							table.getValueByName(ETRow_Remarks).asStringJMT(),
							quantitySelected,									// 6/12/2023 navcs2 ChangeRequest 57537
							mtGrades,
							table.getValueByName(ETRow_Clean).Boolean,
							table.getValueByName(ETRow_DoISOGroupCheck).Boolean,
							heavyRated,											//07.10.2024 navbs1 #32769
							array,
							null,
							//table.getValueByName(ETRow_Colour).asStringJMT(),			// PAR #32331
							colour,														// PAR #32331
							desciptionSelection,
							heightSelection,
							lengthSelection,
							markNumber,
							quantitySelection,									
							remarksSelection,
							volumeSelection,
							weightSelection,
							widthSelection,
							markSelection,
							densitySelection,
							typeSelection,												// 01/07/2015 cnwma1 PAR #36555
							//terminalArea,												// 01/07/2015 cnwma1 PAR #36555
							allTermAreaDict, 
							receivalBOL,
							bestPick,
							null,
							deliveryParty,
							deliveryAddress
							,table.getValueByName(ETRow_DeliveryInstructions).String
							,deliveryFromDT,deliveryToDT,
							table.getValueByName(ETRow_DefaultAnyAmount).Boolean,
							table.getValueByName(ETRow_DeliveryAnyId).Boolean,
							table.getValueByName(ETRow_ClientRef).String,
							table.getValueByName(ETRow_UndgCode).String,
							table.getValueByName(ETRow_OrderNumber).String,
							table.getValueByName(ETRow_PurchaseOrder).String,receivedDT,releasedDT,
							table.getValueByName(ETRow_Remark).String,vesselCode,
							null,	// ### TFS 53953 11July2022 NAVPW1
							lineNumber,customerReference,	//12-0702022 	navtnr20 53974
							cargoGroup, //28/06/2023 navmv20 CR 58410 Task 58411 //22/06/2023	navkc1	CR 57496 Task 58405
							byTypeByWeight,
							locnByOldest,	//19/02/2023	navkc1 CR 60078 Task 62450
							commodity,   //24/04/2025	navrv30	MTN 34319
							contentsType);
	// 15/03/2023	navkc1	#56937 - cargoType null check
	//epr TFS 41398 20/2/19
	if cargoType &lt;&gt; null and cargoType.isBulkByWeight then
		reserveSelection.setWeightRequested(table.getMeasurementValueByName(ETRow_WeightRequested).Decimal);
	elseif cargoType &lt;&gt; null and cargoType.isBulkByVolume then
		reserveSelection.setWeightRequested(table.getMeasurementValueByName(ETRow_VolumeRequested).Decimal * reserveSelection.getDensity);
	else
		if table.isMeasurementRowVisible(ETRow_WeightRequested) then
			reserveSelection.setWeightRequested(table.getMeasurementValueByName(ETRow_WeightRequested).Decimal);
		endif;
		if not byTypeByWeight then // ### TFS BUG 62755 05MAR2024 NAVAB1
			reserveSelection.setWeightRequested(0); // ### TFS BUG 62755 05MAR2024 NAVAB1
		endif;	
	endif;
	
	//table.setProxyFromMeasureTables(reserveSelection);			// PAR #33169
epilog
	delete mtGrades;
	delete array;
	delete allTermAreaDict;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="saveUserEntryReserveTI" id="8c20f086-af1c-40d4-b8ed-e50a10353932">
        <source>saveUserEntryReserveTI() protected;
/* Changes

Date		Name	TFS#		Description
============================================================================
29/08/2013	cnwer1	PAR 32330	Initial creation 
05/05/2014	cnwdap1	PAR #34058 	Get weight / volume for Bulk release by ID
09/09/2014	cnwrs1	CCMS 2351 	Att Sequence to Release request
24/01/2019	jlgka1	TFS 41708	STWO CCRO Management.
12/04/2019	jlgka1	44369		STWO - Bug from Functional Review of 7058 Warning Quantities Incorrect
13 Jan 2025	navhl20 CR MTN-33695: TPT | Release Request Delivery Party Info for Unique IDs
============================================================================*/
vars
	ti 							: CM_TrackedItem;
	theReserveTI				: CM_ReserveTI;
	quantitySelection			: Integer;	
	table						: CM_EntryTable;
	row							: Integer;					// PAR #34058
	obj 						: Object;					// PAR #34058
	entRow						: EntTableRowTransient;		// PAR #34058
	weight, volume				: Decimal [22,10];			// PAR #34058
	left, top, width, height	: Real;						// PAR #34058
	cellControl					: Control;					// PAR #34058
	headerBOLIn					: CM_BOLIn;					// jlgka1 TFS 41708
	totalReqAllowed				: Integer;					// jlgka1 TFS 41708
	bolDtl						: CM_BOLDtl;				// jlgka1 TFS 41708
	bolItems					: String;					// jlgka1 TFS 41708
	index						: Integer;					// jlgka1 TFS 41708
	deliveryParty 				: CM_DeliveryParty;
	deliveryAddress 			: CM_Address;
	deliveryInstruction			: String;
	deliveryFromDT,
	deliveryToDT 				: TimeStamp;
begin

	theReserveTI := self.mySelectedObject.CM_ReserveTI;
	if theReserveTI = null then
		return;
	endif;
	
	ti:=theReserveTI.getTI();
	//if not ti.myCargoType.isBreakBulkMulti then									// PAR #34058
	/*if not ti.myCargoType.isBreakBulkMulti and not ti.myCargoType.isBulkMulti then	// PAR #34058	//27.01.2025 navhl20 #33695
		return;
	endif;*/
		
	table := self.tblEntry;
	
	quantitySelection 	:= table.getValueByName(ETRow_TotalQuantity).Integer;
	
	//jlgka1 TFS 41708 --&gt;
	if self.myTerminal.getConfig(UseTotReqAllowedFld).Boolean then
		headerBOLIn		:= self.cmbBOLAnyId.listObject.CM_BOLIn; 
		//jlgka1 TFS 44369 --&gt;
		/*totalReqAllowed := table.getValueByName(ETRow_TotalRequestedAllowed).Integer;
		bolItems		:= table.getValueByName(ETRow_BolItems).asStringJMT;*/
		totalReqAllowed := theReserveTI.anyAmtAnyIdAllowedAmount;
		if theReserveTI.myBOLDtl &lt;&gt; null then
			bolItems		:= theReserveTI.myBOLDtl.cargoTypeDescr &amp; Tab &amp; theReserveTI.myBOLDtl.commodity &amp; Tab &amp; theReserveTI.myBOLDtl.quantity.asStringJMT;
		endif;
		//jlgka1 TFS 44369 &lt;--
		index := self.cmbBOLItems.findString(1, bolItems);
		self.cmbBOLItems.listIndex := index;
		bolDtl			:= self.cmbBOLItems.listObject.CM_BOLDtl; 		
	endif;
	//jlgka1 TFS 41708 &lt;--
	
	if ti.myCargoType.isTrackByWeight then																		// PAR #34058
		foreach obj in table.allEntRowTransients do																// PAR #34058
			entRow := obj.EntTableRowTransient;																	// PAR #34058
			if entRow.name[1:6] = Prefix_Weight then															// PAR #34058
				row := table.getRowByName(entRow.name);															// PAR #34058
				if table.accessCell(row, table.ColumnValue).cellControl &lt;&gt; null then							// PAR #34058
					cellControl := table.accessCell(row, table.ColumnValue).cellControl;						// PAR #34058
					cellControl.CMUI_MeasurementTable.setValues(table.accessCell(row, table.ColumnValue).text);	// PAR #34058
					weight := cellControl.CMUI_MeasurementTable.getConvertedValue;								// PAR #34058
				endif;																							// PAR #34058
				break;																							// PAR #34058
			endif;																								// PAR #34058
		endforeach;																								// PAR #34058
	elseif ti.myCargoType.isTrackByVolume then																	// PAR #34058
		foreach obj in table.allEntRowTransients do																// PAR #34058
			entRow := obj.EntTableRowTransient;																	// PAR #34058
			if entRow.name[1:6] = Prefix_Volume then															// PAR #34058
				row := table.getRowByName(entRow.name);															// PAR #34058
				if table.accessCell(row, table.ColumnValue).cellControl &lt;&gt; null then							// PAR #34058
					cellControl := table.accessCell(row, table.ColumnValue).cellControl;						// PAR #34058
					cellControl.CMUI_MeasurementTable.setValues(table.accessCell(row, table.ColumnValue).text);	// PAR #34058
					volume := cellControl.CMUI_MeasurementTable.getConvertedValue;								// PAR #34058
				endif;																							// PAR #34058
				weight := volume * ti.getDensity;																// PAR #34058
				break;																							// PAR #34058
			endif;																								// PAR #34058
		endforeach;																								// PAR #34058
	endif;																										// PAR #34058
	
	//Start 13.01.2025 navhl20 #33695
	deliveryParty		:= self.cmbDeliveryParty.listObject.CM_DeliveryParty;
	deliveryAddress		:= self.cmbDeliveryAddress.listObject.CM_Address;
	deliveryInstruction := table.getValueByName(ETRow_DeliveryInstructions).String;
	deliveryFromDT.setDate(table.getValueByName(ETRow_DeliveryFromDate).Date);
	deliveryFromDT.setTime(table.getValueByName(ETRow_DeliveryFromTime).Time);
	deliveryToDT.setDate(table.getValueByName(ETRow_DeliveryToDate).Date);
	deliveryToDT.setTime(table.getValueByName(ETRow_DeliveryToTime).Time);
	//End 13.01.2025 navhl20 #33695
	
	theReserveTI.setProxy( null,
							null,
							null,
							null,
							quantitySelection,
							null,
							headerBOLIn,
							weight,
							null,				// PAR #34058
							totalReqAllowed,	//jlgka1 TFS 41708
							bolDtl,				//jlgka1 TFS 41708
							deliveryParty,deliveryAddress,deliveryInstruction,deliveryFromDT,deliveryToDT				//13.01.2025 navhl20 #33695
							);								
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="saveUserEntryTrackedItem" id="5d467d96-1646-4ad3-8ffb-a92920fe5f2e">
        <source>saveUserEntryTrackedItem() protected;
/*
Purpose:			

Parameters:			

Return Value:		

/* Changes

Date		Name	TFS#		Description
============================================================================
15/05/2013	cnwrd1				Initial creation
05/05/2014	cnwdap1	PAR #34058 	Added a total weight parameter to CM_ReserveTI.setProxy
09/09/2014	cnwrs1	CCMS 2351 	att Sequence to Release request 
24/01/2019	jlgka1	TFS 41708	STWO - CCRO Management. Added totalReqAllowed
								and BOLDtl parameter to CM_ReserveTI.setProxy.
13 Jan 2025	navhl20 CR MTN-33695: TPT | Release Request Delivery Party Info for Unique IDs
============================================================================*/

vars
	ti 					: CM_TrackedItem;
	aReserveTI			: CM_ReserveDetail;
	theReserveTI		: CM_ReserveTI;
	quantitySelection	: Integer;	
	table				: CM_EntryTable;
	headerBOLIn			: CM_BOLIn;			//jlgka1 TFS 41708
	totalReqAllowed		: Integer; 			//jlgka1 TFS 41708
	bolDtl				: CM_BOLDtl;		//jlgka1 TFS 41708
begin

	ti := self.mySelectedObject.CM_TrackedItem;
		
	if not ti.isKindOf(CM_BreakBulkGeneric) then
		return;
	endif;
	
	foreach aReserveTI in self.myMasterProxyObject.CM_BulkRelease.allReserveDetails do
		if not aReserveTI.isKindOf(CM_ReserveTI) then
			continue;
		endif;
		if aReserveTI.allTrackedItems.includes(ti)  then
			theReserveTI := aReserveTI.CM_ReserveTI;
		endif;
	endforeach;
	
	if theReserveTI = null then
		return;
	endif;
		
	table := self.tblEntry;
	
	//jlgka1 TFS 41708 --&gt;
	if self.myTerminal.getConfig(UseTotReqAllowedFld).Boolean then
		headerBOLIn		:= self.cmbBOLAnyId.listObject.CM_BOLIn; 		
		totalReqAllowed := table.getValueByName(ETRow_TotalRequestedAllowed).Integer;
		bolDtl			:= self.cmbBOLItems.listObject.CM_BOLDtl;
	endif;
	//jlgka1 TFS 41708 &lt;--
	
	quantitySelection 	:= table.getValueByName(ETRow_TotalQuantity).Integer;
	
	
	theReserveTI.setProxy( null,
							null,
							null,
							null,
							quantitySelection,
							null,
							headerBOLIn,
							null,
							null,				// PAR #34058
							totalReqAllowed,	//jlgka1 TFS 41708
							bolDtl,				//jlgka1 TFS 41708
							null,null,null,null,null						//13.01.2025 navhl20 #33695
							);					
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setContext" id="f62efd7d-0e79-4bf8-a1aa-d42c3a8e3e33">
        <updating/>
        <source>setContext(_context: Integer)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 June 2023	navhl20	Bug 58634: MTN - Release by Type option should be disabled if there is no VAS subscription 

*/

vars

begin
	self.context := _context;

epilog

end;</source>
        <Parameter name="_context" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="fb6a5aa0-f5d7-4cb3-a72f-f3088d246878">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*
----------   ----------  --------------------------------------------------
Created:	16 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
04/09/2023	jlizm1		TFS 59568 Add instructions to release lines
14/05/2024	navnk30		ChangeRequest 63607: FR | 53127 - Additional Operational Instructions on the Order - Remedial
*/
vars
	cellControl		: Control;
	release			: CM_BulkRelease;
begin
	inheritMethod();
	release := self.myMasterProxyObject.CM_BulkRelease;
	if self.mode = Mode_Add then
		self.setCaption(app.getErrorString(Adding_New_Request) &amp; '...');
	elseif self.mode = Mode_Update and release &lt;&gt; null then
		self.setCaption(app.getErrorString(Editing_Request) &amp; ' ' &amp; release.code &amp; '...');
		self.currentCarrierId		:= release.carrierId;		//Par19427 April 2009 cnwvu1
		self.currentConsigneeCode	:= release.consigneeCode;	//Par19427 April 2009 cnwvu1
		
		//cnwmc5 - 30 July 2013 - PAR 31461
		if release.myVoyage &lt;&gt; null then
			self.cmbDischarge.setInitialised(false);
			self.cmbDischarge.myVoyage := release.myVoyage;
		endif;
	endif;
	
	
	self.btnAddChild.enabled := true;
	self.btnNext.enabled := true;
	self.btnAddParent.enabled := false;
	//self.btnInstruction.enabled := false;		//14.05.2024 navnk30 #63607
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="setControlsForView" id="6550d4a4-24c6-4be8-b1ff-ceb941788baf">
        <updating/>
        <source>setControlsForView() updating;
/*
----------   ----------  --------------------------------------------------
Created:	16 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

	release			: CM_BulkRelease;
begin
	inheritMethod();
	release := self.myMasterObject.CM_BulkRelease;
	if app.isValidObject(release) and release &lt;&gt; null then
		self.setCaption(app.getErrorString(Viewing_Request) &amp; ' ' &amp; release.code &amp; '...');
	endif;
	
	self.btnDelete.enabled := false;
	self.btnAddChild.enabled := false;
	self.btnNext.enabled := false;
	self.btnAddParent.enabled := false;
	self.btnInstruction.enabled := false; // TFS 59568 jlizm1 31/08/2023
	
end;


</source>
    </JadeMethod>
    <JadeMethod name="setDefaultsForNewMaster" id="1b77219b-70c5-4b00-bc83-6a3f1a50cb01">
        <source>setDefaultsForNewMaster(_newReleaseRequest : CM_BulkRelease input);
/*
----------   ----------  --------------------------------------------------
Created:	29 May 2007 By cnwth2

Purpose:	

/* Changes

Date		Name	TFS#			Description
============================================================================
24/11/2011	cnwcs5	CCMS POL 2122 
					/ PAR28696 - 	needsReview property		
07/11/2011	cnwrs1	CCMS POL 2122 
					/ PAR 28696 - 	New property allEDIFiles
23/04/2012	cnwcs5	CCMS POL 2172 
					/ par 29480 - 	Coparn release updates
12 May 2016	cnwns1	TFS 488 - 		Multi Timezone Support
24/01/2019	jlgka1	41708			STWO - CCRO Management changes. Set myBOLIn
									to null in CM_BulkRelease.setProxy.
14 Dec 2023 navhl20 ChangeRequest 61092:[61621] EUP | Ship Operations in DD - [54176.050] Mobile App changes - Pack Load by Request
30 Jun 2025	navah1	Bug 35230: MTN - Cargo Review - Release line is not deleted when unchecking the Release By Type Checkbox
============================================================================*/
vars
	terminal			: CM_Terminal;
	today				: TimeStamp;
	pxyReserveSelection	: CM_ReserveSelection;
	releaseByType		: Boolean;
	carrierID			: String;
	loadPort			: CM_Port;				//+cnwml2 PAR22459
	defReleaseSubTerm,
	defTargetSubTerm	: CM_SubTerminal;	
begin
	terminal		:= self.myTerminal;
	today 			:= app.actualTimeServer();	// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
	loadPort 		:= app.myRoot.allPorts[terminal.getConfig(PortDestCode).String];	//+cnwml2 PAR22459
	//releaseByType 	:= app.getMyTerminalConfigDO_NOT_USE(GateOutReleaseByISOType).Boolean;  //30.06.2025	navah1	#35230
	if _newReleaseRequest.context = RelReqContext_CargoGroupReview then							//30.06.2025	navah1	#35230
		releaseByType := _newReleaseRequest.releaseByType;
	else
		releaseByType := terminal.getConfig(GateOutReleaseByISOType).Boolean; 
	endif;
	
	if self.defaultReleaseType = BR_TYPE_RAIL then
		carrierID := terminal.getConfig(DefRailCarrier).String;
	endif;
	
	//cnwrd1 par 26664 16.5.2011
	if app.isSubTerminalsOn(terminal) then
		defReleaseSubTerm 	:= terminal.getDefaultSubTerminalForRel(self.defaultReleaseType);
		defTargetSubTerm 	:= terminal.getConfig(MySubTerminalForTargetBulk).CM_SubTerminal;
	endif;
	
	_newReleaseRequest.setProxy(null,
								self.defaultReleaseType,
								releaseByType,
								BR_ACTIVE,
								null,	// availability grades
								null,
								carrierID,
								null,
								null,
								null,
								null,
								null,
								null,//consign voyage
								today,
								null, //today,		// cnwdad1 30/05/2007 - PAR #14132: Do not default required date to today.
								null,
								null,
								null,
								null, //door dir
								null,
								null,
								loadPort,//load port				
								null,//_destinationPort	//04 Nov 2009	NDL Par 21519
								null,
								null,//freightForwarder
								null,
								terminal,
								null,
								null,
								_newReleaseRequest.myVoyage,//voyage			//14.12.2023 navhl20 #61092[61621]
								null,//bank
// TFS 2686								false,
								false,
								null,				// pack locations
								null,				// pool partner
								null,				// dispatch location
								defReleaseSubTerm,
								defTargetSubTerm,
								null,				//04 Nov 2009	NDL Par 21519
								false,
								null,				// cnwrl1 19/02/2010 PAR 22393
								false,				// cnwrl1 19/02/2010 PAR 22393
								false,				// May 2011 cnwjre1 27097 POL CCMS 2043
								false,				// par 28696
								false,				// stopEDIUpdates - par 29480 April 2012
								null,	// CCMS POL 2122
								null,
								null,	//jlgka1 TFS 41708
								_newReleaseRequest.context		 // ### TFS BUG 56530 21FEB2023 NAVAB1 null	// ### TFS 53953 27June2022 NAVPW1
								);	 
								
	if _newReleaseRequest.allReserveDetails.isEmpty  and releaseByType then
		create pxyReserveSelection transient;
		pxyReserveSelection.setMyHeader(_newReleaseRequest);
		pxyReserveSelection.setPxyDefaults();
	endif; 
epilog
	
end;</source>
        <Parameter name="_newReleaseRequest" type="CM_BulkRelease" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setEntTblFromRelease" id="24c83b4a-41b8-4dd5-a84a-dcdf53561282">
        <updating/>
        <source>setEntTblFromRelease(_tbl : CM_EntryTable input; _attrName : String; _row : Integer; _obj : CM_Object) : Boolean updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	01 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
31/07/2009	cnwdad1		PAR #20381 - Sub-Terminal was lost after switching
						selected rows in the tree.
dec 2011	cnwcs5		CCMS POL 2122 / par 28696
16/06/2022	navdap1		TFS 53362 EUP Master Data interface customers between TOS and ERP
*/
vars
	release			: CM_BulkRelease;
	taSet			: ObjectSet;
	customsAgent	: CM_CustomsAgent;		// cnwrl1 19/02/2010 PAR 22393
	
begin
	release := _obj.CM_BulkRelease;
	
	if _attrName = ETRow_AllMTGrades then
		self.lstMTGrade.clearSelected();
		self.myAssistant.listTableMTGrade(self.lstMTGrade, release.myOperator, release.myOperatorGroup);
		self.myAssistant.setListTableMTGrade(self.lstMTGrade, release.allAvailabilityGrades);
		self.lstMTGrade.lostFocus(self.lstMTGrade);
		return true;
		
	elseif _attrName = ETRow_AddAttachment then
		_tbl.setValue(_row,app.getErrorString(Dbl_Click_To_Add_Update));
		return true;
		
	elseif _attrName = ETRow_MyBookingRefStock then
		self.cmbBookingRef.setObject(release.myBookingRefStock);
		
		if release.myBookingRefStock &lt;&gt; null then
			_tbl.setValue(_row, release.myBookingRefStock.bookingReference);
		endif;
		
		return true;
		
	elseif _attrName = ETRow_BrType then
		_tbl.setValue(_row, release.getTypeDescription());
		self.cmbBRType.text := release.getTypeDescription();
		self.myAssistant.setCarrierTransportMode(self.cmbCarrier,self.cmbBRType.text);//cnwas3 par 24344
		return true;
	
	elseif _attrName = ETRow_BusinessUnit then
		self.cmbBizUnit.setObject(release.myBusinessUnit);
		if release.myBusinessUnit &lt;&gt; null then
			_tbl.setValue(_row, release.myBusinessUnit.code);
		endif;
		return true;
		
	elseif _attrName = ETRow_CarrierCode then
		self.cmbCarrier.setObject(release.getCarrier());
		_tbl.setValue(_row, release.carrierId);
		return true;
		
	elseif _attrName = ETRow_ConsigneeCode then
		self.cmbConsignee.setObject(release.myConsignee);
		_tbl.setValue(_row, release.consigneeCode);//badly named
		return true;
	
	elseif _attrName = ETRow_ConsignorCode then
		self.cmbConsignor.setObject(release.myConsignor);
		_tbl.setValue(_row, release.consignorCode);//badly named
		return true;
		
	elseif _attrName = ETRow_DeliveryReason then
		self.myAssistant.comboBoxDeliveryReason(self.tblEntry, ETRow_DeliveryReason, DELSTR_SNT);
		if release.deliveryReasonDescr &lt;&gt; null then
			_tbl.setValue(_row, release.deliveryReasonDescr);
		endif;
		
		return true;
	
	elseif _attrName = ETRow_DoorsForward then
		_tbl.setValue(_row, (release.doorsDirection = TI_DOORSDIRN_FWD).Boolean.cnEcGetTableCheckBoxValue());
		return true;
		
	elseif _attrName = ETRow_DischargePort then
		self.cmbDischarge.setObject(release.myDischargePort);
		if release.myDischargePort &lt;&gt; null then
			_tbl.setValue(_row, release.myDischargePort.code);
		endif;
		return true;
	
	elseif _attrName = ETRow_EstimatedRequiredDate then
		if (not release.dateEstimatedRequired.isValid) then
			_tbl.setValue(_row, null);
		else
			_tbl.setValue(_row, self.systemToLocalTime(release.dateEstimatedRequired).date.shortFormatJMT());	// 15/4/16 cnwmp6 TFS 488 - Multi timezone support
		endif;
		return true;
	
	elseif _attrName = ETRow_EstimatedRequiredTime then
		if (not release.dateEstimatedRequired.isValid) then
			_tbl.setValue(_row, null);
		else
			_tbl.setValue(_row, self.systemToLocalTime(release.dateEstimatedRequired).time.String);	// 15/4/16 cnwmp6 TFS 488 - Multi timezone support
		endif;
		return true;
		
	//13 Feb 2017	NDL	TFS 3368
	elseif _attrName = ETRow_ExpiryDate then
		if (not release.expiryTimeStamp.isValid) then
			_tbl.setValue(_row, null);
		else
			_tbl.setValue(_row, self.systemToLocalTime(release.expiryTimeStamp).date.shortFormatJMT());	
		endif;
		return true;
	
	elseif _attrName = ETRow_ExpiryTime then
		if (not release.expiryTimeStamp.isValid) then
			_tbl.setValue(_row, null);
		else
			_tbl.setValue(_row, self.systemToLocalTime(release.expiryTimeStamp).time.String);
		endif;
		return true;
		
	elseif _attrName = ETRow_FreightForwarderCode then
		self.cmbFreightFwdr.setObject(release.myFreightForwarder);
		if release.myFreightForwarder &lt;&gt; null then
			_tbl.setValue(_row, release.myFreightForwarder.code);
		endif;
		return true;
	
	elseif _attrName = ETRow_LoadPort then
		self.cmbLoadPort.setObject(release.myLoadPort);
		_tbl.setValue(_row, self.cmbLoadPort.text);
		return true;
		
	elseif _attrName = ETRow_DestinationPort then	//04 Nov 2009	NDL Par 21519
		self.cmbDestination.setObject(release.myDestinationPort);
		_tbl.setValue(_row, self.cmbDestination.text);
		return true;
	
	elseif _attrName = ETRow_MyTrainAssigned then	//04 Nov 2009	NDL Par 21519
		if release.myAssignedTrain &lt;&gt; null then
			if self.cmbTrainAssigned.findObject(release.myAssignedTrain) &lt; 1 then
				self.cmbTrainAssigned.itemObject[self.cmbTrainAssigned.addItem(self.myAssistant.displayEntryTrain(release.myAssignedTrain))] := release.myAssignedTrain;
			endif;	
		endif;
		self.cmbTrainAssigned.listObject := release.myAssignedTrain;
		_tbl.setValue(_row, self.cmbTrainAssigned.text);
		return true;
	
	elseif _attrName = ETRow_MtRelease then
		_tbl.setValue(_row, not release.fullRelease);
		return true;
		
	elseif _attrName = ETRow_MyTransferToTerminal then
		if not app.myRoot.isInterTerminalTransferEnabled then	//09 Jul 2012	NDL	Par 29703
			_tbl.hideRowByName(ETRow_MyTransferToTerminal,false);
			self.cmbDestTerminal.listIndex := -1;
		else
			_tbl.showRowByName(ETRow_MyTransferToTerminal,false);//09 Jul 2012	NDL	Par 29703
			if release.myTransferToTerminal &lt;&gt; null then
				if self.cmbDestTerminal.findObject(release.myTransferToTerminal) &gt; 0 then // PAR 17132
					self.cmbDestTerminal.listObject := release.myTransferToTerminal;
					_tbl.setValue(_row, self.cmbDestTerminal.text);
				endif;
			endif;
		endif;
		return true;
		
	elseif _attrName = ETRow_OperatorCode then
		self.cmbOperator.setObject(release.myOperator);
		if release.myOperator &lt;&gt; null then
			if app.myRoot.getConfig(ComboByNameOperator).Boolean then	// TFS 53362
				_tbl.setValue(_row, release.myOperator.description);	// TFS 53362
			else														// TFS 53362
				_tbl.setValue(_row, release.myOperator.code);
			endif;														// TFS 53362
		endif;
		return true;
	
	elseif _attrName = ETRow_OperatorGroupCode then
		self.cmbOperatorGroup.listObject := release.myOperatorGroup;
		if release.myOperatorGroup &lt;&gt; null then
			_tbl.setValue(_row, release.myOperatorGroup.code);
		endif;
		return true;
	
	elseif _attrName = ETRow_PackLocation then
		self.lstPackLocn.clearSelected();
		create taSet transient;
		release.getPackLocations(taSet);
		self.lstPackLocn.setSelected(taSet);
		_tbl.setValue(_row, self.lstPackLocn.getSelectedFromDisplay());

		return true;
		
	elseif _attrName = ETRow_ReleaseByType then
		_tbl.setValue(_row, release.releaseByType.Boolean);
		return true;
		
	elseif _attrName = ETRow_ReleaseNo then
		_tbl.setValue(_row, release.code);
		return true;
	
	elseif _attrName = ETRow_Remarks then
		_tbl.setValue(_row, release.cargoRemarks);
		return true;
/* TFS 2686		
	elseif _attrName = ETRow_RemoveStops then
		_tbl.setValue(_row, release.removeStops.cnEcGetTableCheckBoxValue());
		return true;
	*/
	elseif _attrName = ETRow_RequestDate then
		if (not release.dateRequested.isValid) then
			_tbl.setValue(_row, null);
		else
			_tbl.setValue(_row, self.systemToLocalTime(release.dateRequested).date.shortFormatJMT());	// 15/4/16 cnwmp6 TFS 488 - Multi timezone support
		endif;
		return true;
	
	elseif _attrName = ETRow_RequestTime then
		if (not release.dateRequested.isValid) then
			_tbl.setValue(_row, null);
		else
			_tbl.setValue(_row, self.systemToLocalTime(release.dateRequested).time.shortFormatJMT());	// 15/4/16 cnwmp6 TFS 488 - Multi timezone support
		endif;
		return true;
		
	elseif _attrName = ETRow_StatusBulkRelease then
		self.myAssistant.comboBoxBulkReleaseStatus(_tbl, ETRow_StatusBulkRelease, release.statusString);
		_tbl.setValue(_row, release.statusString);
		return true;
		
	// cnwdad1 31/07/2009 - PAR #20381.
	elseif _attrName = ETRow_MySubTerminal then
		if release.mySubTerminal &lt;&gt; null then
			_tbl.setValue(_row, release.mySubTerminal.code);
			return true;
		endif;
		
	elseif _attrName = ETRow_VoyageCode then
		if release.myVoyage &lt;&gt; null then
			//th2 for PAR 14855 - changed to lookup by text as there seemed to be a problem
			//with the list object being listed twice, once with inward code and once with code
			if self.cmbVoyage.findString(1, release.myVoyage.displayEntry()) &lt; 1 then 
				self.cmbVoyage.addItemObject(release.myVoyage.displayEntry(), release.myVoyage);
			endif;
				
			self.cmbVoyage.text := release.myVoyage.displayEntry;
			_tbl.setValue(_row, self.cmbVoyage.text);
		endif;
		
		return true;
	
	elseif _attrName = ETRow_CustomsAgent then
		if release.customsAgent &lt;&gt; null then
			customsAgent	:= app.myRoot.allCustomsAgents[ release.customsAgent ];
			if customsAgent &lt;&gt; null then
				self.cmbCustomsAgent.setObject( customsAgent );
				_tbl.setValue( _row, release.customsAgent );	// the actual string value
			endif;
		endif;
		return true;
		
	elseif _attrName = ETRow_CustomsAssistance then
		_tbl.setValue( _row, release.customsAssistance.cnEcGetTableCheckBoxValue() );
		return true;
	
	elseif _attrName = ETRow_HiLowCube then		// May 2011 cnwjre1 27097 POL CCMS 2043
		_tbl.setValue( _row, release.canBeHiLoCube.cnEcGetTableCheckBoxValue() );
		return true;
		
	elseif _attrName = ETRow_ViewEDIMessages then	// par 28696
		_tbl.setValue (_row, app.getErrorString (Dbl_Click_To_View));
		return true;
		
	elseif _attrName = ETRow_RemarksAdditional1 then	//03 May 2018	NDL	TFS 37795
		_tbl.setValue (_row, release.remarksAdditional1);
		return true;
		
	elseif _attrName = ETRow_RemarksAdditional2 then	//03 May 2018	NDL	TFS 37795
		_tbl.setValue (_row, release.remarksAdditional2);
		return true;
	endif;
	
	return false;
epilog
	delete taSet;
end;
</source>
        <access>protected</access>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_obj" type="CM_Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setEntTblFromReserveSelection" id="b246eb2f-e269-4d7a-bf73-5df98d9c565f">
        <updating/>
        <source>setEntTblFromReserveSelection(_tbl : CM_EntryTable input; _attrName : String; _row : Integer; _obj : CM_Object) : Boolean updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	01 May 2007 By cnwth2

Purpose:	

Changed On	Changed By  Reason
----------	----------  --------------------------------------------------
27/11/2009	cnwmh5		PAR 21492 - Add loading of Type details	
10/12/2013	cnwdap1		PAR #33169 Set measurement values
01/07/2015	cnwma1		PAR #36555 CCMS 2509 TFS - Multi-location selection for MTs for vessel release
21/03/2016	cnwdap1		PAR #37606 "Not available for entry" iso types
19/07/2022	navtnr20	ChangeRequest 53974: EUP - OUT - Additional Fields on Release Line Level
19/12/2022	navsa20		Bug 55878: SNO - Error 4033 happens while trying to update a Release Request
22/06/2023	navkc1		CR 57496 Task 58405: UI - Release Request Cargo Group
//24/04/2025	navrv30	MTN 34319 EUP | Creating a Release Request from Cargo Review - Validation
23/10/2025	jlizm1		MTN 36255 Rotabox Assign Release To Vessel
*/
vars
	bulkRelease	: CM_BulkRelease;
	reserve		: CM_ReserveSelection;
	grade		: CM_MTGrade;
	idx,
	avGrade		: Integer;
	value		: String;					// PAR #33169
	vessel 		: CM_Vessel;
	terminal	: CM_Terminal;
begin	
	reserve := _obj.CM_ReserveSelection;
	
	if _attrName = ETRow_AllMTGrades then
		if self.mode = self.Mode_View then
			bulkRelease := self.myMasterObject.CM_BulkRelease;
		else
			bulkRelease := self.myMasterProxyObject.CM_BulkRelease;
		endif;
		self.lstMTGrade.clearSelected();
		self.myAssistant.listTableMTGrade(self.lstMTGrade, bulkRelease.myOperator, bulkRelease.myOperatorGroup);
		self.myAssistant.setListTableMTGrade(self.lstMTGrade, reserve.allAvailabilityGrades);
		self.lstMTGrade.lostFocus(self.lstMTGrade);
		return true;
	
	elseif _attrName = ETRow_AddAttachment then
		_tbl.setValue(_row,app.getErrorString(Dbl_Click_To_Add_Update));
		return true;
		
	elseif _attrName = ETRow_CargoType then
		self.cmbTiType.setObject(reserve.myCargoType);
		_tbl.setValue(_row, self.cmbTiType.text);
		return true;
	
	elseif _attrName = ETRow_Remarks then
		_tbl.setValue(_row, reserve.remarks);
		return true;
		
	elseif _attrName = ETRow_Clean then
		_tbl.setValue(_row, reserve.clean.cnEcGetTableCheckBoxValue());
		return true;
	elseif _attrName = ETRow_ByTypeByWeight then
		_tbl.setValue(_row, reserve.byTypeByWeight.cnEcGetTableCheckBoxValue());
		return true;
	elseif _attrName = ETRow_DoISOGroupCheck then
		//_tbl.setValue(_row, reserve.doISOGroupCheck.cnEcGetTableCheckBoxValue);
		if reserve.myISOGroup &lt;&gt; null then
			_tbl.setValue(_row, true);
		else
			_tbl.setValue(_row, false);
		endif;
		return true;
	
	elseif _attrName = ETRow_IsoTypeGroup then
		////self.cmbISOGroup.setObject(reserve.myISOGroup);
		self.cmbISOGroup.listObject := reserve.myISOGroup;		// 09/03/2010 cnwmh5 #21921
		_tbl.setValue(_row, self.cmbISOGroup.text);
		return true;//cnwas3rr	
	
	elseif _attrName = ETRow_IsoType then
		///self.cmbISOType.setObject(reserve.myISOType);
		if self.cmbISOType.findObject(reserve.myISOType) &gt; 0 then
			self.cmbISOType.listObject := reserve.myISOType;		// 09/03/2010 cnwmh5 #21921
			_tbl.setValue(_row, self.cmbISOType.text);
			return true;
		else
			if reserve.myISOType &lt;&gt; null and reserve.myISOType.isNotAvailableForEntry then																	// PAR #37606
				// add it in - it was available when the release was created																				// PAR #37606
				self.cmbISOType.listIndex := self.cmbISOType.addItemObject(reserve.myISOType.code &amp; Tab &amp; reserve.myISOType.description, reserve.myISOType);// PAR #37606
				self.cmbISOType.listObject := reserve.myISOType;																							// PAR #37606
				_tbl.setValue(_row, self.cmbISOType.text);																									// PAR #37606
				return true;																																// PAR #37606
			endif;																																			// PAR #37606
			return false;
		endif;
	
	elseif _attrName = ETRow_PackingType then
		idx := self.cmbPackType.findString(1, app.packingTypeEnumToString(reserve.packType));
		if idx &gt; 0 then
			 self.cmbPackType.listIndex := idx;
		else
			self.cmbPackType.listIndex := 1;
		endif;
		_tbl.setValue(_row, self.cmbPackType.text);
		return true;
		
	elseif _attrName = ETRow_MyProduct then
		self.myAssistant.comboBoxProduct(self.cmbProduct, reserve.myCargoType, null, reserve.myProduct);
		if self.cmbProduct.listObject &lt;&gt; null then //cnwjo3 par 20522
			self.cmbProduct.setObject(self.cmbProduct.listObject.CM_Product);  
		endif;
		_tbl.setValue(_row, self.cmbProduct.text);
		
		return true;
	elseif _attrName = ETRow_ProductDescr then
		_tbl.setValue(_row, reserve.productStr);
		return true;

	elseif _attrName = ETRow_IdMask then 				// dh 24/1/2008 par 15409
		_tbl.setValue(_row, reserve.getIdsAsString);	//
		return true;									//
		
	elseif _attrName = ETRow_TotalRequested then
		if reserve.totalRequested &gt; 0 then
			_tbl.setValue(_row, reserve.totalRequested);
		endif;
		
		return true;
	elseif _attrName = ETRow_MyType then				// 27/11/2009 cnwmh5 #2a492
	
		return true;
		
	elseif _attrName = ETRow_TerminalArea then		// 15/02/2010	cnwjre1	CCMS 1101 + 22643
		//self.myAssistant.comboBoxSourceArea2(self.cmbTermArea, reserve.getTerminalArea(), true, false);   // 01/07/2015 cnwma1 PAR #36555
		//_tbl.setValue(_row, self.cmbTermArea.text);													    // 01/07/2015 cnwma1 PAR #36555
	/*	_tbl.setValue(_row, reserve.getYardSourceText);												        // 01/07/2015 cnwma1 PAR #36555
		self.allSelectedTAs.clear();																        // 01/07/2015 cnwma1 PAR #36555
		reserve.allTerminalAreas.copy(self.allSelectedTAs);												    // 01/07/2015 cnwma1 PAR #36555
		return true;*/
		if reserve.getYardSourceText &lt;&gt; null then
			_tbl.setValue(_row, reserve.getYardSourceText);												        // 01/07/2015 cnwma1 PAR #36555
			self.allSelectedTAs.clear();																        // 01/07/2015 cnwma1 PAR #36555
			reserve.allTerminalAreas.copy(self.allSelectedTAs);												    // 01/07/2015 cnwma1 PAR #36555
		else
			_tbl.setValue(_row,app.getErrorString(Dbl_Click_To_Add_Update));
		endif;
		return true;
	
	elseif _attrName.isMeasurementType() then														// PAR #33169
		value := reserve.getDisplayStringForAttribute(_attrName, false);							// PAR #33169
		_tbl.setValue(_row, value);																	// PAR #33169
		_tbl.accessCell(_row, _tbl.ColumnValue).cellControl.CMUI_MeasurementTable.setValues(value);	// PAR #33169
		return true;																				// PAR #33169
																									// PAR #33169
	elseif _attrName = ETRow_MyQuantity then														// PAR #33169
		if reserve.quantitySelection &lt;&gt; 0 then														// PAR #33169
			_tbl.setValue(_row, reserve.quantitySelection);											// PAR #33169
		endif;																						// PAR #33169
		return true;																				// PAR #33169
	elseif _attrName = ETRow_DeliveryParty then //jlier1 TFS 53678 27/6/22
		if reserve.myDeliveryParty &lt;&gt; null then
			self.cmbDeliveryParty.setIndexFromObject(reserve.myDeliveryParty);
			self.cmbDeliveryParty.lostFocus(self.cmbDeliveryParty);
		endif;
	//elseif _attrName = ETRow_LineNumber then		//navtnr20 11-07-2022 53974		//navsa20 19-12-2022 TFS 55878
	elseif _attrName = ETRow_LineNumberHdr then     //navsa20 19-12-2022 TFS 55878
		_tbl.setValue(_row, reserve.lineNumber);
		return true;
	elseif _attrName = ETRow_CustomerReference then		//navtnr20 11-07-2022 53974
		_tbl.setValue(_row, reserve.customerReference);
		return true;
		
	elseif _attrName = ETRow_MyVessel then
		if reserve.cargoMatchVesselCode &lt;&gt; null then
			vessel:=app.myRoot.allVessels[reserve.cargoMatchVesselCode];
		endif;
		if vessel &lt;&gt; null then
			self.cmbVessel.setIndexFromObject(vessel);
		endif;
	elseif _attrName = ETRow_CargoGroup then
		self.myAssistant.comboBoxCargoGroup(self.cmbCargoGroup); //22/06/2023	navkc1	CR 57496 Task 58405
		self.cmbCargoGroup.findObjectFromListCollection(reserve.myCargoGroup);
		_tbl.setValue(_row, self.cmbCargoGroup.text);
		return true;
	//24/04/2025	navrv30	MTN 34319
	elseif _attrName = ETRow_Commodity then
		self.myAssistant.comboBoxAllCommodity(self.cmbCommodity, self.cmbCommodity.listObject.CM_Commodity);
		self.cmbCommodity.findObjectFromListCollection(reserve.myCommodity);
		_tbl.setValue(_row, self.cmbCommodity.text);
		return true;
	elseif _attrName = ETRow_LocnByOldestTransArrival then //19/02/2023	navkc1 CR 60078 Task 62450
		
		// If user has changed it in ADD mode, or if we are in update mode, then we set the field from the latest proxy
		if self.hasChangedLocnByOldest or self.mode = Mode_Update then
			return false;
		endif;
		
		// Otherwise, we set it from Terminal Config
		terminal := self.getMyTerminal();
		
		if terminal &lt;&gt; null then
			_tbl.setValue(_row, terminal.getConfig(LocnByOldestTransArrival).Boolean);
			return true;
		endif;
		
	elseif _attrName = ETRow_CargoTypeCodeForCntnt then
		self.cmbContentsCargoType.setObject(reserve.myContentsCargoType);
		_tbl.setValue(_row, self.cmbContentsCargoType.text);
		return true;
		
	elseif _attrName = ETRow_CargoSubTypeCodeForCntnt then
		self.myAssistant.comboBoxProduct(self.cmbContentsCargoSubType, reserve.myContentsCargoType, null, reserve.myProduct);
		if self.cmbContentsCargoSubType.listObject &lt;&gt; null then
			self.cmbContentsCargoSubType.setObject(self.cmbContentsCargoSubType.listObject.CM_Product);  
		endif;
		_tbl.setValue(_row, self.cmbContentsCargoSubType.text);
		
		return true;
		
	endif;
	
	return false;
end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_obj" type="CM_Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setEntTblFromRuntimeValue" id="50b27cae-321c-43e8-92bc-fa3a21bfd411">
        <updating/>
        <source>setEntTblFromRuntimeValue(_tbl : CM_EntryTable input; _attrName : String; _row : Integer; _obj : CM_Object) : Boolean updating, protected;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 26 February 2019
TFS#		: 41708
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	reserveDet	 	: CM_ReserveDetail;
	bulkRelease	 	: CM_BulkRelease;
	totalAllowed 	: Integer;
	totalRequested	: Integer;
	cargoType	 	: CM_CargoType;	
	cmifGrouping	: CMIF_ReserveTIGrouping;
	bolItems		: CM_BOLDtl;
begin
	cmifGrouping := self.myCMIFGrouping;
	if _attrName = ETRow_CargoTypeDescr then
		_tbl.setValue(_row, cmifGrouping.getCargoProductDescription(self.mySelectedObject));
		_tbl.accessCell(_row, CM_EntryTable.ColumnValue).backColor := Gray;
		return true;
	endif;
	
	if _attrName = ETRow_TotalRequestedAllowed then			
		_tbl.setValue(_row, cmifGrouping.getTotalAllowed(self.mySelectedObject));					
		return true;	
	endif;	
	
	if _attrName = ETRow_TotalRequested then			
		_tbl.setValue(_row, cmifGrouping.getTotalRequested(self.mySelectedObject));		
		_tbl.accessCell(_row, CM_EntryTable.ColumnValue).backColor := LightGray;			
		self.tblEntry.disableRowByName(ETRow_TotalRequested);				
		return true;	
	endif;	
	
	if _attrName = ETRow_TotalReleased then			
		_tbl.setValue(_row, cmifGrouping.getTotalReleased(self.mySelectedObject));		
		_tbl.accessCell(_row, CM_EntryTable.ColumnValue).backColor := LightGray;
		self.tblEntry.disableRowByName(ETRow_TotalReleased);			
		return true;	
	endif;	
	
	if _attrName = ETRow_TotalOnsiteWOStops then			
		_tbl.setValue(_row, cmifGrouping.getTotalOnsiteWOStops(self.mySelectedObject));		
		_tbl.accessCell(_row, CM_EntryTable.ColumnValue).backColor := LightGray;
		self.tblEntry.disableRowByName(ETRow_TotalOnsiteWOStops);		
		return true;	
	endif;	
	
	if _attrName = ETRow_BolItems then	
		self.cmbBOLAnyId.text := "";
		bolItems := cmifGrouping.getBOLItems(self.mySelectedObject);
		
		if bolItems &lt;&gt; null then
			if self.cmbBOLItems.findString(1, bolItems.cargoTypeDescr &amp; Tab &amp; bolItems.commodity &amp; Tab &amp; bolItems.quantity.asStringJMT) &lt; 1 then 
				self.cmbBOLAnyId.addItemObject(bolItems.cargoTypeDescr &amp; Tab &amp; bolItems.commodity &amp; Tab &amp; bolItems.quantity.asStringJMT, bolItems);
			endif;
			
			self.cmbBOLItems.text := bolItems.cargoTypeDescr &amp; Tab &amp; bolItems.commodity &amp; Tab &amp; bolItems.quantity.asStringJMT;
			_tbl.setValue(_row, self.cmbBOLItems.text);
		endif;
			
		return true;	
	endif;		
	return false;
end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_obj" type="CM_Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setEntTblFromTI" id="3ecda6dd-9a57-455d-a6bb-fc3cd0bfb47c">
        <updating/>
        <source>setEntTblFromTI(_tbl : CM_EntryTable input; _attrName : String; _row : Integer; _obj : CM_Object) : Boolean updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	24 May 2007 By cnwth2

Purpose:	

/* Changes

Date		Name	TFS#		Description
============================================================================
05/05/2014	cnwdap1	PAR #34058 	Cater for total weight / volume for Bulk Cargo
26/6/2014	cnwer1	par 34406 	changes for bulk
15 Jan 2025	navhl20 CR MTN-33695: TPT | Release Request Delivery Party Info for Unique IDs
22 Jan 2025	navhl20 Bug MTN-33844: MTN - 1086 Error when Editing a Request Request Release By Type Items Assigned
============================================================================*/
vars
	str				 	: String;
	lastYardLocation 	: String;
	ti 					: CM_TrackedItem;
	aReserveTI			: CM_ReserveDetail;
	theReserveTI		: CM_ReserveDetail;	
	value				: String;								// PAR #34058
	rowName				: String;
	type				: String;								// PAR #34058
	req 				: CM_DeliveryRequest;
begin

	if _obj.isKindOf(CM_ReserveTI) then
		//epr par 32330 29/8/13
		theReserveTI:=_obj.CM_ReserveTI;
		ti:=theReserveTI.CM_ReserveTI.getTI();
	elseif _obj.isKindOf(CM_TrackedItem) then
		ti := _obj.CM_TrackedItem;
		if self.myMasterObject &lt;&gt; null then
			foreach aReserveTI in self.myMasterObject.CM_BulkRelease.allReserveDetails do			
				if aReserveTI.allTrackedItems.includes(ti)  then
					theReserveTI := aReserveTI;		
					req:=theReserveTI.getDeliveryRequestForTI(ti);
					break;
				endif;
				
				if aReserveTI.allTrackedItemsReleased.includes(ti) then
					theReserveTI := aReserveTI;
					break;
				endif;
			endforeach;
		endif;
	endif;

	
	if _attrName = ETRow_Info then
		str := ti.getInfoStr(false);
		
		lastYardLocation:=ti.getLastLocationBeforeRoadRel();
		
		if lastYardLocation &lt;&gt; null then
			str := str &amp; " Moved from " &amp; lastYardLocation &amp; " to " &amp; ti.priorLocation;
		endif;
		if str &lt;&gt; null then//do same as cargo enquiry
			_tbl.accessCell(_row, CM_EntryTable.ColumnValue).backColor := Red;
			_tbl.accessedCell.foreColor := White;	
		endif;
		
		_tbl.setValue(_row, str);
		return true;
	elseif _attrName = ETRow_AddAttachment then
		_tbl.setValue(_row,app.getErrorString(Dbl_Click_To_Add_Update));
		return true;
	elseif _attrName = ETRow_TotalQuantity then
		//epr par 34623 24/7/14
		if self.mySelectedObject.isKindOf(CM_ReserveTI) then
			_tbl.setValue(_row, self.mySelectedObject.CM_ReserveTI.getTotalRequested.asStringJMT);
		else
			_tbl.setValue(_row, self.getAmountForTI(ti,true) );
		endif;
		return true;
	elseif _attrName = ETRow_MyProduct then		
		// PAR #34058
		_tbl.setValue(_row, ti.productCode);																// PAR #34058
		//epr par 34623 23/7/14
		return true;																						// PAR #34058
																											// PAR #34058
	elseif _attrName.isMeasurementType then																	// PAR #34058
		_attrName.getRowNameMeasureType(rowName, type);	
		//epr par 34406 24/6/14
		if (rowName = ETRow_TotalWeight or rowName = ETRow_TotalVolume ) 
			 and ti.myCargoType.isBulkMulti then
			
			
			//if self.mySelectedObject.isKindOf(CM_ReserveTI) then
			//	value:= self.mySelectedObject.CM_ReserveTI.weightRequested;
			//else
				value:=self.getAmountForTI(ti,true);
			//endif;
		
			
			
			
			_tbl.setValue(_row, value);																			// PAR #34058
			_tbl.accessCell(_row, _tbl.ColumnValue).cellControl.CMUI_MeasurementTable.setValues(value);			// PAR #34058
			return true;
		endif;
	
		if theReserveTI &lt;&gt; null and theReserveTI.isKindOf(CM_ReserveTI) then
			// PAR #34058
			value := theReserveTI.getMeasurementStringForAttrib(rowName, type, false);							// PAR #34058
		else
			value:=ti.getMeasurementStringForAttrib(rowName, type, false) &amp; Space &amp; type;							// PAR #34058
		endif;
		
		_tbl.setValue(_row, value);																			// PAR #34058
		_tbl.accessCell(_row, _tbl.ColumnValue).cellControl.CMUI_MeasurementTable.setValues(value);			// PAR #34058
	
	elseif _attrName = ETRow_StopsToApply then	//16 Sep 2016	NDL	TFS 2646 / 2001
		_tbl.setValue(_row, null);
		return true;
	elseif _attrName = ETRow_TaskToApply then	//16 Sep 2016	NDL	TFS 2646 / 2001
		_tbl.setValue(_row, null);
		return true;
	elseif _attrName = ETRow_DeliveryAddress then		//15.01.2025 navhl20 #33695
		_tbl.setValue(_row, null);
		return true;
	elseif _attrName = ETRow_DeliveryParty then			//15.01.2025 navhl20 #33695
		_tbl.setValue(_row, null);
		return true;
	elseif _attrName = ETRow_DeliveryInstructions then	//15.01.2025 navhl20 #33695
		if self.mySelectedObject.isKindOf(CM_ReserveTI) then	//22.01.2025 navhl20 #33844
			_tbl.setValue(_row, self.mySelectedObject.CM_ReserveTI.deliveryInstructions);
		else
			_tbl.setValue(_row, null);
		endif;
		return true;
	elseif _attrName = ETRow_DeliveryFromDate then		//15.01.2025 navhl20 #33695
		if self.mySelectedObject.isKindOf(CM_ReserveTI) then	//22.01.2025 navhl20 #33844
			_tbl.setValue(_row, self.mySelectedObject.CM_ReserveTI.deliveryFrom.Date);
		else
			_tbl.setValue(_row, null);
		endif;
		return true;
	elseif _attrName = ETRow_DeliveryFromTime then		//15.01.2025 navhl20 #33695
		if self.mySelectedObject.isKindOf(CM_ReserveTI) then	//22.01.2025 navhl20 #33844
			_tbl.setValue(_row, self.mySelectedObject.CM_ReserveTI.deliveryFrom.Time);
		else
			_tbl.setValue(_row, null);
		endif;
		return true;
	elseif _attrName = ETRow_DeliveryToDate then		//15.01.2025 navhl20 #33695
		if self.mySelectedObject.isKindOf(CM_ReserveTI) then	//22.01.2025 navhl20 #33844
			_tbl.setValue(_row, self.mySelectedObject.CM_ReserveTI.deliveryTo.Date);
		else
			_tbl.setValue(_row, null);
		endif;
		return true;
	elseif _attrName = ETRow_DeliveryToTime then		//15.01.2025 navhl20 #33695
		if self.mySelectedObject.isKindOf(CM_ReserveTI) then	//22.01.2025 navhl20 #33844
			_tbl.setValue(_row, self.mySelectedObject.CM_ReserveTI.deliveryTo.Time);
		else
			_tbl.setValue(_row, null);
		endif;
		return true;
	endif;
	
	return false;
end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_obj" type="CM_Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFrameCaptions" id="01e34e51-207b-4bf7-8eae-f91bd9a5a8a4">
        <source>setFrameCaptions();
/*
----------   ----------  --------------------------------------------------
Created:	27 April 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.dkcLeftMain.caption 	:= 'Left side frame';
	self.dkcRightMain.caption 	:= 'Right side frame';
	self.dkbTopLeft.caption 	:= 'Release request tree frame';
	self.dkbBottomLeft.caption 	:= 'Release summary frame';
	self.dkbTopRight.caption 	:= 'Release macro info frame';
	self.dkbBottomRight.caption := 'Release entry frame';


end;


</source>
    </JadeMethod>
    <JadeMethod name="setGroupLabel" id="1d1ceb91-1c8a-467f-854a-ea053fc29992">
        <source>setGroupLabel();
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 27 February 2019
TFS#		: 41708
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	obj		: CM_Object;
	listbox	: CMUI_ListBox;
	idx		: Integer;
begin
	listbox	:= self.lstTree;
	idx 	:= listbox.findObject(self.mySelectedObject);
	
	if idx &gt; 0 then		
		listbox.itemText[idx] 		:= self.getTreeCaptionForObj(self.mySelectedObject);
		listbox.itemPicture[idx] 	:= self.picRequestLine.picture;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setMeasurementValues" id="6e84aa4f-f6ea-47cc-a0bb-86cbdb9e75d3">
        <source>setMeasurementValues();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/12/2013	cnwdap1		Initial creation PAR #33169 Measurements not showing
//
vars
	obj			: Object;
	row 		: EntTableRowTransient;
	tbl			: CM_EntryTable;
	rowname,
	measure,
	value		: String;
	reserve		: CM_ReserveSelection;
	tableRow	: Integer;

begin
	tbl := self.tblEntry;
	foreach obj in tbl.allEntRowTransients do
		row := obj.EntTableRowTransient;
		if not row.name.isMeasurementType then
			continue;
		endif;
		row.name.getRowNameMeasureType(rowname, measure);
		if self.mySelectedObject.isKindOf(CM_ReserveSelection) then
			reserve := self.mySelectedObject.CM_ReserveSelection;
			value := reserve.getDisplayStringForAttribute(row.name, false) &amp; Space &amp; measure;
			tableRow := tbl.getRowByName(row.name);
			tbl.setValue(tableRow, value);
			tbl.accessCell(tableRow, tbl.ColumnValue).cellControl.CMUI_MeasurementTable.setValues(value);
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setReserveTICustomsFieldValue" id="51f2a920-8641-4e4a-83e5-b5eff37edff4">
        <updating/>
        <source>setReserveTICustomsFieldValue(cargoType : CM_CargoType; isProduct : Boolean; product : CM_Product) updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 27 February 2019
TFS#		: 41708
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	reserveDet		: CM_ReserveDetail;
	bulkRelease		: CM_BulkRelease;
	totalReqAllowed : Integer;
	bolItems		: String;
	index			: Integer;
	bolDtl			: CM_BOLDtl;
	table			: CM_EntryTable;
begin
	table := self.tblEntry;
	
	totalReqAllowed := table.getValueByName(ETRow_TotalRequestedAllowed).Integer;
	bolItems		:= table.getValueByName(ETRow_BolItems).asStringJMT;
	index 			:= self.cmbBOLItems.findString(1, bolItems);
	self.cmbBOLItems.listIndex := index;
	bolDtl			:= self.cmbBOLItems.listObject.CM_BOLDtl; 		
	
	if self.myMasterProxyObject.isKindOf(CM_BulkRelease) then
		bulkRelease := self.myMasterProxyObject.CM_BulkRelease;
		foreach reserveDet in bulkRelease.allReserveDetails do
			if isProduct then
				if reserveDet.isKindOf(CM_ReserveTI) and reserveDet.getMyProduct() = product then
					reserveDet.CM_ReserveTI.setTotalRequestedAllowed(totalReqAllowed);
					reserveDet.CM_ReserveTI.setMyBOLDtl(bolDtl);
				endif;
			else
				if reserveDet.isKindOf(CM_ReserveTI) and reserveDet.getCargoType() = cargoType then
					reserveDet.CM_ReserveTI.setTotalRequestedAllowed(totalReqAllowed);
					reserveDet.CM_ReserveTI.setMyBOLDtl(bolDtl);
				endif;
			endif;
		endforeach;
	endif;	
end;</source>
        <Parameter name="cargoType" type="CM_CargoType"/>
        <Parameter name="isProduct" type="Boolean"/>
        <Parameter name="product" type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="setTotReqAllowedDefault" id="34a2d693-b28c-4d6f-88bd-8461f44d5ede">
        <source>setTotReqAllowedDefault(currentReserveTI : CM_ReserveTI; 
						bulkRelease 	 : CM_BulkRelease;
						addedQuantity	 : Integer);
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 27 February 2019
TFS#		: 41708
Function	:

*** Changes ***
Date		Name	TFS#	Description
26/04/2019	jlgka1	44427	Resolve issue with totalRequestedAllowed value that's
							causing problems with the Warning Message not properly
							displayed in Road Gate.
****************************************************/
vars
//	cmifDetail		: CMIF_ReserveTIDetail;
	object			: Object;
	cargoType		: CM_CargoType;
	product			: CM_Product;
	reserveTI		: CM_ReserveTI;
	totalRequested	: Integer;
begin
	product   := currentReserveTI.getMyProduct();
	cargoType := currentReserveTI.getMyCargoType();
	//get total
	foreach object in bulkRelease.allReserveDetails do
		if object.isKindOf(CM_ReserveTI) then
			reserveTI := object.CM_ReserveTI;
			if product &lt;&gt; null then
				if reserveTI.getMyProduct() = product then
					if reserveTI.anyAmtAnyIdAllowedAmount = 0 and totalRequested &lt;&gt; 0 then
						totalRequested := totalRequested;
					else
						totalRequested := reserveTI.anyAmtAnyIdAllowedAmount + addedQuantity;
					endif;
				endif;
			elseif cargoType &lt;&gt; null then
				if reserveTI.getMyCargoType() = cargoType then
					if reserveTI.anyAmtAnyIdAllowedAmount = 0 and totalRequested &lt;&gt; 0 then
						totalRequested := totalRequested;
					else
						totalRequested := reserveTI.anyAmtAnyIdAllowedAmount + addedQuantity;					
					endif;
				endif;
			endif;				
		endif;
	endforeach;		
	//update each item 
	foreach object in bulkRelease.allReserveDetails do
		if object.isKindOf(CM_ReserveTI) then
			reserveTI := object.CM_ReserveTI;
			if product &lt;&gt; null then
				if reserveTI.getMyProduct() = product then					
					reserveTI.setTotalRequestedAllowed(totalRequested);
				endif;
			elseif cargoType &lt;&gt; null then
				if reserveTI.getMyCargoType() = cargoType then					
					reserveTI.setTotalRequestedAllowed(totalRequested);
				endif;
			endif;				
		endif;
	endforeach;		
	
end;</source>
        <Parameter name="currentReserveTI" type="CM_ReserveTI"/>
        <Parameter name="bulkRelease" type="CM_BulkRelease"/>
        <Parameter name="addedQuantity" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setTotReqFldFieldsVisibility" id="d3ac82a9-c15a-485f-86d6-fd04d559e868">
        <source>setTotReqFldFieldsVisibility(releaseByType : Boolean);
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 25 January 2019
TFS#		: 41708
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	// jlgka1 TFS 41708 --&gt;
	if self.myTerminal.getConfig(UseTotReqAllowedFld).Boolean and not releaseByType then
		self.tblEntry.showRowByName(ETRow_BillOfLadingCmbAnyId,true);		
		self.tblEntry.showRowByName(ETRow_TotalRequestedAllowed,true);
		self.tblEntry.showRowByName(ETRow_BolItems,true);				
	else
		self.tblEntry.hideRowByName(ETRow_BillOfLadingCmbAnyId,true);		
		self.tblEntry.hideRowByName(ETRow_TotalRequestedAllowed,true);
		self.tblEntry.hideRowByName(ETRow_BolItems,true);		
	endif;
	// jlgka1 TFS 41708 &lt;--
end;</source>
        <Parameter name="releaseByType" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setViewForReleaseLineType" id="23ee3869-15b1-4f04-8ca6-d9cde320ea2d">
        <source>setViewForReleaseLineType(_cargoType : Integer) protected;
/*
----------   ----------  --------------------------------------------------
Created:	08 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	
	entView				: EntTableView;
	releaseType			: Integer;
begin
	if self.mode = self.Mode_View then
		releaseType := self.myMasterObject.CM_BulkRelease.type;
	else
		releaseType := self.myMasterProxyObject.CM_BulkRelease.type;	
	endif;
	
	if _cargoType = TI_CargoType_Container or _cargoType = TI_CargoType_Generator then
		if releaseType = BR_TYPE_PACKING then
			entView := self.tblEntry.myEntTableDef.allEntTableViews['RequestLineContPack'];
		else
			entView := self.tblEntry.myEntTableDef.allEntTableViews['RequestLineContainer'];
		endif;
	else
		if releaseType = BR_TYPE_PACKING then
			entView := self.tblEntry.myEntTableDef.allEntTableViews['RequestLineCargoPack'];		
		else
			entView := self.tblEntry.myEntTableDef.allEntTableViews['RequestLineCargo'];
		endif;
	endif;
	
	if entView = null then
		return;
	endif;
	
	self.tblEntry.showHideRowsByView(entView, CM_EntryTable.ShowHideRows, false);

	
	//par 20522 cnwjo3
	//duplicate condition from above.  makes it easier to read i guess
	if _cargoType = TI_CargoType_Container or _cargoType = TI_CargoType_Generator then
	else
		//if its a non-container
		self.setupFieldsForCargoType(_cargoType);
	endif;
end;


</source>
        <access>protected</access>
        <Parameter name="_cargoType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setViewForReleaseType" id="95ac845f-8f71-4d5b-992b-4e40a55b370e">
        <source>setViewForReleaseType(_releaseType : Integer; _releaseByType : Boolean) protected;
/*
----------   ----------  --------------------------------------------------
Created:	08 May 2007 By cnwth2

Purpose:	

/* Changes

Date		Name	TFS#			Description
============================================================================
24/11/2011	cnwcs5	CCMS POL 2122
					/ par 28696 - 	New type of Unknown
24/01/2019	jlgka1	41708			STWO CCRO Management. Hide the ff fields
									ETRow_BillOfLadingCmbAnyId, ETRow_BolItems
									and ETRow_TotalRequestedAllowed depends on the config.						
============================================================================*/
vars
	table	: CM_EntryTable;
	entView	: EntTableView;
begin
	if _releaseType &lt; 1 then
		return;
	endif;
	
	table := self.tblEntry;
		
	if _releaseByType then
		if _releaseType = BR_TYPE_ROAD then
			entView := table.myEntTableDef.allEntTableViews['RoadRelByType'];
			
		elseif _releaseType = BR_TYPE_RAIL then
			entView := table.myEntTableDef.allEntTableViews['RailRelByType'];	
			
		elseif _releaseType = BR_TYPE_SHIP then
			entView := table.myEntTableDef.allEntTableViews['ShipRelByType'];	
			
		elseif _releaseType = BR_TYPE_PACKING then
			entView := table.myEntTableDef.allEntTableViews['PackingRelByType'];	
			
		elseif _releaseType = BR_TYPE_UNKNOWN then
			entView := table.myEntTableDef.allEntTableViews['UnknownRelByType'];
		endif;
	else
			
		if _releaseType = BR_TYPE_ROAD then
			entView := table.myEntTableDef.allEntTableViews['RoadRelease'];	
			
		elseif _releaseType = BR_TYPE_RAIL then
			entView := table.myEntTableDef.allEntTableViews['RailRelease'];	
			
		elseif _releaseType = BR_TYPE_SHIP then
			entView := table.myEntTableDef.allEntTableViews['ShipRelease'];	
			
		elseif _releaseType = BR_TYPE_PACKING then
			entView := table.myEntTableDef.allEntTableViews['PackingRelease'];	
			
		elseif _releaseType = BR_TYPE_UNKNOWN then
			entView := table.myEntTableDef.allEntTableViews['UnknownRelease'];	
		endif;
	endif;
	
	if entView = null then
		return;
	endif;
	
	
	table.showHideRowsByView(entView, CM_EntryTable.ShowHideRows, false);
	
	// jlgka1 TFS 41708 --&gt;
	self.setTotReqFldFieldsVisibility(_releaseByType);
	// jlgka1 TFS 41708 &lt;--
	
	if _releaseType &lt;&gt; BR_TYPE_ROAD then //26529 14/01/2011	
		table.setValueByName(ETRow_AllowCargoOnMultiRel, false);
	endif;
	
end;


</source>
        <access>protected</access>
        <Parameter name="_releaseType" type="Integer"/>
        <Parameter name="_releaseByType" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupFieldsForCargoType" id="c973d9ed-aed2-45de-ba18-b67d0eb3cf48">
        <source>setupFieldsForCargoType(_cargoTypeID : Integer);
// --------------------------------------------------------------------------------
// Created:		26 August 2009 by cnwjo3
//
// Purpose:		remove fields from View, for example Height, Weight, Sub-Cargo, etc
//
vars
	cargoType	: CM_CargoType;
begin
	//epr par 35154 13/11/14
	cargoType:=app.myRoot.allCargoTypesById[_cargoTypeID];	
	if cargoType = null then
		return;
	endif;
	//maybe show/hide sub-cargo description here
	if cargoType.isSubCargoTypeRequired = false then
		 self.tblEntry.hideRowByName(ETRow_ProductType,false);
		 self.tblEntry.hideRowByName(ETRow_MyProduct,false);
	else
		//get Is Viewable, etc from CM_Product
		 self.tblEntry.showRowByName(ETRow_ProductType,false);
		 self.tblEntry.showRowByName(ETRow_MyProduct,false);
	endif;

end;</source>
        <Parameter name="_cargoTypeID" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="d84b4ed2-1c22-436d-9a42-f0a470d7cce7">
        <updating/>
        <source>setupForm() updating;
/*
----------   ----------  --------------------------------------------------
Created:	01 May 2007 By cnwth2

/* Changes

Date		Name	TFS#			Description
============================================================================
22/11/2011	cnwcs5	CCMS POL 2122 	par 28696  	new type Unknown
23/08/2013	cnwdap1	PAR #32331 		Added Colour picker
21/03/2016	cnwdap1	PAR #37606 		"Not available for entry" iso types
24/01/2019	jlgka1	41708			STWO CCRO Management. Added cmbBOLAnyId	and cmbBOLItems.		
14 Jun 2023 navhl20 Bug 58634: 		MTN - Release by Type option should be disabled if there is no VAS subscription 
28 Jul 2025 navma1  MTN-35577  		MTN - Error 1081 While doing Road Receive Transaction with CM_BulkReleaseByCodeDict
23/10/2025	jlizm1	MTN 36255 		Rotabox Assign Release To Vessel
============================================================================*/
vars
	release		: CM_BulkRelease;
	booking		: CM_BookingRef;
	terminal	: CM_Terminal;			// par 28696
	assistant	: CMUI_Assistant;		// par 28696
begin
	terminal 	:= self.myTerminal;		// par 28696
	assistant	:= self.myAssistant;	// par 28696
	
	assistant.comboBoxReleaseType(self.cmbBRType,
										app.myCurrentUserCan(terminal, PmGteMTReleaseViewRd),
										app.myCurrentUserCan(terminal, PmGteMTReleaseViewRail),
										app.myCurrentUserCan(terminal, PmGteMTReleaseViewGen),
										app.myCurrentUserCan(terminal, PmGteMTReleaseViewShip),
										app.myCurrentUserCan(terminal, PmGteMTReleaseViewUnknown), // par 28696
										false);
	
	self.cmbDischarge.myAssistant := assistant;

	assistant.comboBoxVoyageCurrent(self.cmbVoyage,
											null,
											true,
											false,
											true,
											true,
											true,
											false,
											true,
											false,
											false);
											
	assistant.comboBoxOperatorGroup(self.cmbOperatorGroup, null, true);
	assistant.comboBoxDestTerminal(self.cmbDestTerminal, terminal, null);
	assistant.comboBoxPackType(self.cmbPackType, null);
	assistant.comboBoxBusinessUnit(self.cmbBizUnit, null);
	assistant.comboBoxTrain(self.cmbTrainAssigned, null, false, false, false);	//04 Nov 2009	NDL	Par 21519
	assistant.comboBoxCustomsAgent( self.cmbCustomsAgent, null );				// cnwrl1 19/02/2010 PAR 22393
	assistant.comboBoxCargoTypes(self.cmbContentsCargoType, null);
	
	self.cmbLoadPort.myAssistant 	:= assistant;
	self.cmbDestination.myAssistant := assistant;			//03 Nov 2009	NDL	Par 21519
	self.cmbDestination.isRail 		:= true;				//06 Nov 2009	NDL	Par 21519
	self.cmbDestination.showAllDestinations := true;		//+cnwml2 PAR25721
	self.cmbDischarge.myAssistant 	:= assistant;	
	
	assistant.listTablePackLocations(self.lstPackLocn);
	assistant.comboBoxSubTerminal(cmbSubTerminal, null, terminal);
	assistant.comboBoxSubTerminal(cmbSubTermTarget, null, terminal);  //cnwrd1 par 23219 17.3.2010
	
	self.cmbSubTerminal.automaticCellControl	:=	true;
	self.cmbSubTermTarget.automaticCellControl	:=	true;//cnwrd1 par 23219 17.3.2010
	
	self.cmbConsignee.setType(CONSIGNEE);
	self.cmbConsignor.setType(CONSIGNOR);
	self.cmbFreightFwdr.setType(FREIGHT_FORWARDER);
	
	self.cmbBRItem.automaticCellControl	:=	true;
	
	self.allowFrameTopLeft		:=	true;
	self.allowFrameBottomLeft	:=	false;
	self.allowFrameTopRight		:=	false;
	self.allowFrameBottomRight	:=	true;
	
	//self.checkBulkReleaseIterator	 := terminal.allBulkReleasesByCodeDate.createIterator();		//28.07.2025 navma1 #MTN-35577
	
	if self.defaultReleaseType = null then
		self.defaultReleaseType := BR_TYPE_PACKING;
	endif;
	
	assistant.listTableColour(self.lstColour);				// PAR #32331
	
	inheritMethod();
	
	//#26289 26/01/2011. Need to set current booking for the cmbBookingRef for the selected release
	release := self.mySelectedObject.CM_BulkRelease;
	
	if release &lt;&gt; null then		// when Edit mode, there is a release selected
		booking := release.myBookingRefStock;
	endif;
	
	assistant.comboBoxBookingRef(self.cmbBookingRef, booking);	// Can have a booking assigned and to be included inot the combobx despite booking status.
	assistant.comboBoxDeliveryParty(self.cmbDeliveryParty); 	//jlier1 TFS 53678 27/6/22
	assistant.comboBoxVessel(self.cmbVessel,null); 				//jlier1 TFS 53678 27/6/22
	if self.mode = self.Mode_Add then
		self.setDefaultsForNewMaster(self.myMasterProxyObject.CM_BulkRelease);
	endif;
	
	self.btnAddChild.caption 		:= app.getErrorString(Add_Request_Line);
	self.btnAddChild.bubbleHelp 	:= app.getErrorString(Add_Request_Line).removeString('&amp;') &amp; ' (Alt-A)';

	self.dkbTopRight.visible 		:= false;
	self.dkbBottomRight.foreColor 	:= self.backColor;																						// PAR #37606
	
	self.cmbBOL.automaticCellControl 		:=	true;	//#24351	03/06/2010
	self.cmbBOLAnyId.automaticCellControl 	:= true; 	//jlgka1 TFS 41708
	self.cmbBOLItems.automaticCellControl	:= true;	//jlgka1 TFS 41708
	
	create self.allPinNumbers transient;  //cnwrd1 par 25594 ccms 2032
	
	self.beginClassNotification(CM_BulkRelease, false, Any_System_Event, Response_Continuous, 0);
	
	if self.context = self.CONTEXT_WORKORDER and not app.myPassport.isVASEnabled then											//14.6.2023 navhl20 #58634
		self.tblEntry.disableRowByName(ETRow_ReleaseByType);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupMeasurementFields" id="c65c175d-c21b-4d6e-b74c-0e5b3241cbbe">
        <updating/>
        <source>setupMeasurementFields() protected, updating;
/*

Date		Who		Reason
17 October 2013	cnwer1	Initial creation PAR 32262
20 Feb 2019 	jlger1	TFS fixed issues with bulk cargo
*/

vars
	cargoType	: CM_CargoType;
	entRow			: EntTableRow;
	prod : CM_Product;
	prodAttr : CM_ProductAttr;
	obj 	: Object;
	controlPrefix	: String;
//	controlName		: String;							// PAR #32426
	rowName			: String;
	rowHeading		: String;
	measure 		: CM_MeasurementType;
	visibleRows 	: EntTableRowArray;
	row 			: EntTableRowTransient;
begin
	cargoType := self.cmbTiType.listObject.CM_CargoType;
	if cargoType = null then
		return;
	endif;

	prod := self.getProductForMeasurementTypes();
	//epr par 32842
	self.resetMeasurementRows(self.tblEntry);
	
	//get all the visible rows before the loadMeasurementTypes
	create visibleRows transient;
	self.tblEntry.myEntTableDef.allEntTableRows.copy(visibleRows);
	foreach entRow in self.tblEntry.myEntTableDef.allEntTableRows do
		if not self.tblEntry.isRowVisible(entRow.name) then
			visibleRows.remove(entRow);	
			continue;
		endif;
		
		if not cargoType.isEntTableSpecialProductAttr( entRow.name ) then
			continue;
		endif;
		
		if cargoType.allAttributesOnProduct.includes(entRow.name) then
			if prod &lt;&gt; null then
				prodAttr := prod.getProdAttrFromName(entRow.name);
			endif;
			if prodAttr &lt;&gt; null and not prodAttr.isViewable then
				visibleRows.remove(entRow);
				self.tblEntry.hideRowByName(entRow.name, false);
			endif;
		else
			visibleRows.remove(entRow);
			self.tblEntry.hideRowByName(entRow.name, false);
		endif;
	endforeach;
	
	self.loadMeasurementTypes(self.tblEntry, self.tblEntry.myEntTableDef.name, visibleRows, true);	// PAR #31155

	if prod &lt;&gt; null then
		//this is just to set the default value and for not measurement types sets the row heading 
		foreach entRow in self.tblEntry.myEntTableDef.allEntTableRows do
			if not cargoType.isEntTableSpecialProductAttr( entRow.name ) then
				continue;
			endif;
			rowName:=null;
			measure:=null;
			if cargoType.allAttributesOnProduct.includes(entRow.name) then
				prodAttr := prod.getProdAttrFromName(entRow.name);
				if prodAttr &lt;&gt; null and prodAttr.isViewable then
					self.tblEntry.showRowByName(entRow.name, false);
					measure:=prodAttr.myMeasurementType; 
					if measure &lt;&gt; null then
						app.getRowHeadingFromMeasure(entRow, measure, controlPrefix, rowHeading, rowName);			
					endif;
					if rowName &lt;&gt; null then			
						self.tblEntry.setValueByName(rowName, prodAttr.getDisplayValueString() &amp; Space &amp; measure.shortName);
					else	
						self.tblEntry.setCellText(self.tblEntry.accessedRow.row, self.tblEntry.ColumnHeading, prodAttr.displayName);		
						self.tblEntry.setValueByName(entRow.name, prodAttr.getDisplayValueString());
					endif;
				endif;	
			endif;
		endforeach;
	endif;
	
	/*foreach obj in self.tblEntry.allEntRowTransients do
		row := obj.EntTableRowTransient;
		if not row.name.isMeasurementType then
			continue;
		endif;
		if row.name[1:6] = Prefix_Weight and row.name[7:8] = ETRow_MyWeight and not cargoType.isTrackByWeight then
			self.tblEntry.hideRowByName(row.name, false);
		elseif row.name[1:6] = Prefix_Volume and row.name[7:8] = ETRow_MyVolume and cargoType.isTrackByWeight then
			self.tblEntry.hideRowByName(row.name, false);
		endif;
//		if row.name = ETRow_MyWeight and not cargoType.isTrackByWeight then
//			self.tblEntry.hideRowByName(ETRow_MyWeight, false);
//		elseif row.name = ETRow_MyVolume and cargoType.isTrackByWeight then
//			self.tblEntry.hideRowByName(ETRow_MyVolume, false);
//		endif;
	endforeach;
	*/
	
	if cargoType.isBulkByWeight then
		self.tblEntry.hideRowByName(ETRow_VolumeRequested, false);
		self.tblEntry.hideRowByName(ETRow_TotalRequested, false);
		self.tblEntry.showRowByName(ETRow_WeightRequested, false);
	elseif cargoType.isBulkByVolume then
		self.tblEntry.showRowByName(ETRow_VolumeRequested, false);
		self.tblEntry.hideRowByName(ETRow_WeightRequested, false);
		self.tblEntry.hideRowByName(ETRow_TotalRequested, false);
	else
		self.tblEntry.hideRowByName(ETRow_VolumeRequested, false);
		if self.mySelectedObject &lt;&gt; null 
		and self.mySelectedObject.isKindOf(CM_ReserveSelection)
		and self.mySelectedObject.CM_ReserveSelection.myReserveHeader.context = RelReqContext_CargoGroupReview then
			self.tblEntry.showRowByName(ETRow_WeightRequested, false);// ### BUG 56533 21FEB2023 NAVAB1
		else
			self.tblEntry.hideRowByName(ETRow_WeightRequested, false);
		endif;
		self.tblEntry.showRowByName(ETRow_TotalRequested, false);
	endif;
	
	
	tblEntry.repositionAfterResize();
epilog
	delete visibleRows;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showDuplicateBRs" id="43217a73-3c96-4475-88fd-1a93db5a1940">
        <updating/>
        <source>showDuplicateBRs(_releaseNo : String) updating;
/*
----------   ----------  --------------------------------------------------
Created:	31 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
28 Jul 2025  navma1 	 MTN-35577  MTN - Error 1081 While doing Road Receive Transaction with CM_BulkReleaseByCodeDict
----------   ----------  --------------------------------------------------
*/
vars
	
	str 		: String;
	anObj 		: Object;
	release 	: CM_BulkRelease;
	
begin
	if self.checkBulkReleaseIterator = null then															//28.07.2025 navma1 #MTN-35577
		self.checkBulkReleaseIterator	 := self.myTerminal.allBulkReleasesByCodeDate.createIterator();		//28.07.2025 navma1 #MTN-35577
	endif;
	
	self.myTerminal.getBulkReleasesFromCode(_releaseNo, self.checkBulkReleaseIterator, self.checkBulkReleasesArray);
	
	if self.mode = self.Mode_View or self.checkBulkReleasesArray.isEmpty then
		return;
	endif;
	
	foreach anObj in self.checkBulkReleasesArray do
		release := anObj.CM_BulkRelease;
		if release = self.myMasterObject then
			continue;
		endif;
		
		str := str &amp; release.code &amp; '  ' &amp; release.statusString &amp; '  ' &amp; release.dateRequested.asStringJMT &amp; Cr;
	endforeach;
	
	if str = null then
		return;
	endif;

	app.msgBox(str, app.getErrorString(Duplicate_Releases), MsgBox_Exclamation_Mark_Icon);

end;</source>
        <Parameter name="_releaseNo" type="String"/>
    </JadeMethod>
    <JadeMethod name="showEmailFormForCarrierChanged" id="678a1356-097c-44da-ab5f-f8624f6b6218">
        <updating/>
        <source>showEmailFormForCarrierChanged(_emailTemplate : CM_EmailTemplate input) updating, protected;
/* ---------------------------------------------------------------------------
Created:	29 April 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	pxyEmailDefaults,
	termEmailDefaults	: CM_PINObjectDefaultEmail;
	carrier				: CM_Carrier;
	consignee			: CM_ConsigneeConsignor;

begin
	// cnwrl1 31/07/2009 PAR 20349 - start of coding
	termEmailDefaults := self.myTerminal.getEmailDefaultsSettings( PINEmail_ReleaseRequest );
	if termEmailDefaults = null then			// this should always exist but...
		return;
	endif;
	// cnwrl1 31/07/2009 PAR 20349 - end of coding
	
	carrier 	:= self.cmbCarrier.myObject.CM_Carrier;
	consignee	:= self.cmbConsignee.myObject.CM_ConsigneeConsignor;
	
//	if carrier = null and self.myTerminal.getConfig(DefaultCarrierEmail).Boolean then	// cnwrl1 30/07/2009 PAR 20349 - what it was
	if carrier = null and termEmailDefaults.sendToCarrier then
		app.msgBox(app.getErrorString(Warn_EmailDefaultsCarrier),"E-mail Options",null);
		return;
	endif;
//	if consignee = null and self.myTerminal.getConfig(DefaultConsignorEmail).Boolean then	// cnwrl1 30/07/2009 PAR 20349 - what it was
	if consignee = null and termEmailDefaults.sendToConsignee then
		app.msgBox( app.getErrorString(Warn_EmailDefConsigneeChanged),"E-mail Options",null);
		return;
	endif;
	
//	termEmailDefaults := self.myTerminal.getCarrierEmailDefaultsForType(PINEmail_ReleaseRequest);	// cnwrl1 30/07/2009 PAR 20349 - what it was
	// preparing a copy of the pxy email info for the Email modal form. The same is repeating, see below where modalResult &lt;&gt; IDOK
	pxyEmailDefaults := termEmailDefaults.cloneSelf(true);
	pxyEmailDefaults.setFromEmailTemplate(_emailTemplate);	//prepare self.myEmailDefaults from email template. Note - myEmailController = null thus all addresses are null - what we need when carrier is changed
//	pxyEmailDefaults.setAddresses(self.myTerminal, carrier, consignee);	// new adresses for the new carrier	// cnwrl1 30/07/2009 PAR 20349 - what it was
	pxyEmailDefaults.setAddresses( self.myTerminal, carrier, consignee, PINEmail_ReleaseRequest );	// new adresses for the new carrier
	
	// calling the Email Options form
	modalResult := self.myAssistant.showCarrierEmailOptions(carrier, pxyEmailDefaults, false, app.getErrorString2(Warn_EmailChangedCarrierConsig,CrLf,CrLf) );
	
	if modalResult = IDOK then
		_emailTemplate.setFromObjectEmail(pxyEmailDefaults);	//saving email info on the bulk release. Par 19427 April 2009
		
	else	//Cancel - to take email info before starting the email form
		// preparing a copy of the pxy email info for opening state. If a user presses Cancel, new carrier will have email info as it was before start of the Email modal form
		delete pxyEmailDefaults;
		pxyEmailDefaults := termEmailDefaults.cloneSelf(true);
		pxyEmailDefaults.setFromEmailTemplate(_emailTemplate);	//prepare self.myEmailDefaults from email template. Note - myEmailController = null thus all addresses are null - what we need when carrier is changed
//		pxyEmailDefaults.setAddresses(self.myTerminal, carrier, consignee);	// new adresses for the new carrier	// cnwrl1 30/07/2009 PAR 20349 - what it was
		pxyEmailDefaults.setAddresses( self.myTerminal, carrier, consignee, PINEmail_ReleaseRequest );	// new adresses for the new carrier
		
		_emailTemplate.setFromObjectEmail(pxyEmailDefaults);	//saving unedited email info on the bulk release. Par 19427 April 2009
	endif;
	
epilog
	delete pxyEmailDefaults;

end;
</source>
