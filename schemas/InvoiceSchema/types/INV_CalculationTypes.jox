    <JadeMethod name="doBtnAddRangeClick" id="01ac4dd5-03cd-41ae-abaf-09aa66b69d1d">
        <source>doBtnAddRangeClick();
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	row, idx, value, newValue : Integer;
	
begin

	if self.isEscalatingCharge then
		newValue := 0;
		row := self.tblRange.rows;
		if row &gt; self.tblRange.fixedRows then
			value := self.tblRange.accessCell(row, COLUMN_TO).text.Integer;
			if value &lt; MAX_VALUE then
				newValue := value + 1;
			endif;
		endif;
		idx := self.tblRange.addItem(newValue.String &amp; Tab &amp; Tab);
		self.tblRange.accessCell(idx, self.COLUMN_FROM).cellControl.TextBox.selectionStyle := TextBox.SelectionStyle_SelectAll;
		self.tblRange.accessCell(idx, self.COLUMN_TO).cellControl.TextBox.selectionStyle := TextBox.SelectionStyle_SelectAll;
	else
		idx := self.tblRange.addItem(0.String &amp; Tab);
		self.tblRange.accessCell(idx, self.COLUMN_TO).cellControl.TextBox.selectionStyle := TextBox.SelectionStyle_SelectAll;
	endif;
	
	//27 Jan 2015	NDL	Par 31381
	if idx = self.tblRange.rows then
		self.tblRange.topRow := idx;
	endif;


end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnDeleteRangeClick" id="8c963247-7b2a-49e7-b52c-b073c1aabbcd">
        <source>doBtnDeleteRangeClick();
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theReturn,theRow, theX, theY, idx : Integer;
begin
	if self.tblRange.row &gt; self.tblRange.fixedRows then
		if self.tblRange.rows = 3 and
		   not self.isEscalatingCharge then
			app.msgBox("You must have at least 1 range","Remove Error",MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		theRow := self.tblRange.row;
		if theRow = 2 and
		   not self.isEscalatingCharge then
			app.msgBox("You must have the first range","Remove Error",MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		
		
		theX := self.tblRange.accessCell(theRow,self.COLUMN_FROM).text.Integer;
		theY := self.tblRange.accessCell(theRow,self.COLUMN_TO).text.Integer;
		theReturn := app.msgBox("Remove Row - "  &amp; theX.String &amp; " to " &amp; theY.String &amp; "?", "Remove Confirmation", MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
		if theReturn = MsgBox_Return_Yes then
			if theRow &lt; self.tblRange.rows and
			   not self.isEscalatingCharge then
				self.tblRange.accessCell(theRow + 1,1).text := self.tblRange.accessCell(theRow,1).text;
			endif;
			self.tblRange.deleteRow(theRow);
		endif;
	endif;


end;</source>
    </JadeMethod>
