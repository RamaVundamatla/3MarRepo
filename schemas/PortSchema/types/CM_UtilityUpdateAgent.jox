    <JadeMethod name="utlUpdateYAOverstowRule" id="fa5a35e3-94c6-4b60-9e36-0667ebc7b03c">
        <source>utlUpdateYAOverstowRule(_pxyRule : CM_YAOverstowRule;  _passport : CM_Passport input);
// -------------------------------------------
// Created 21 September 2005 by cnwdvb1
// -------------------------------------------
vars

	realRule	: CM_YAOverstowRule;
	edition		: Integer;
	obj			: Object;
	
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	_pxyRule.pxyGetRealObjectAndEdition(realRule, edition);
	
	app.myValUA.valYAOverstowRule(_pxyRule, realRule, _passport.myTerminal);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	self.exclusiveLock(realRule);
	
	if _passport.noErrors and realRule.edition &lt;&gt; edition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Overstow rule', null, null);
		return;
	endif;
	
	realRule.setForUpdate(_pxyRule);
	
	
end;</source>
        <Parameter name="_pxyRule" type="CM_YAOverstowRule"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateYARemoveLCs" id="74155c2f-df69-4dfe-bf10-a260f5a689c9">
        <updating/>
        <source>utlUpdateYARemoveLCs(_realYA : CM_YardAllocation input; _lcsToRemove : CM_YardControllerSet;  _passport : CM_Passport input) updating;
vars
	ya : CM_YardAllocation;
	ylc : CM_YardController;
begin
	// Always initialize the activity first
	self.initialiseActivity();

	exclusiveLock(_realYA);

	app.setContinueCMExceptions(false);
	
	ya := _realYA;
	if _passport.noErrors() then
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(ya, true);
	endif;

	if _passport.noErrors() then
		foreach ylc in _lcsToRemove discreteLock do
			_realYA.allYardControllers.removeIfPresent(ylc);
		endforeach;
	endif;
	
	if _passport.noErrors() then
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(ya, false);

		// ### NOTES
		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(Event_YardAllocationUpdate), false, ya);
	endif;

end;</source>
        <Parameter name="_realYA" type="CM_YardAllocation" usage="input"/>
        <Parameter name="_lcsToRemove" type="CM_YardControllerSet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateYATemplate" id="0970a596-7b58-473f-8c79-607f1da96a30">
        <updating/>
        <source>utlUpdateYATemplate(_proxyYATemplate: CM_YATemplate;
						_yATemplate : CM_YATemplate io;
						_passport : CM_Passport input) updating;
vars
begin
	// Always initialize the activity first
	self.initialiseActivity();

	_proxyYATemplate.raiseExceptionIfNotProxy(method);
	app.setContinueCMExceptions(true);
	
	app.myValUA.valYATemplate(_yATemplate, _proxyYATemplate);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(_yATemplate);

	// ====================================================
	// now do the update
	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_yATemplate, true);
	endif;

	if _passport.noErrors() then
		_yATemplate.setForUpdate(_proxyYATemplate);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_yATemplate, false);
	endif;

	if _passport.noErrors() then
		// ### NOTES
		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(Event_YATemplateUpdate), false, _yATemplate);
	endif;

end;</source>
        <Parameter name="_proxyYATemplate" type="CM_YATemplate"/>
        <Parameter name="_yATemplate" type="CM_YATemplate" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateYardAllocation" id="ab6adabe-7147-464d-ade1-777dfbcc0d9b">
        <updating/>
        <source>utlUpdateYardAllocation(pProxyObj:CM_YardAllocation;
						pAllTransientCriteriaObj:CMIF_Array;
						yardAllocationObj : CM_YardAllocation io;
						_passport : CM_Passport input) updating;

// Changed On	Changed By	Reason
// ----------	----------	--------------------------------------------------------
// 21/08/2008	Simon Ward	SFW1030 - Allow for a YA that belongs to a YA template.
// 17/06/2020	jlgdap1		TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
// 10/12/2020	jlgdap1		TFS 50110 ASPA General Cargo Allocation Row - Label
// 10/03/2021	navdap1		TFS 50889 PRP Yard Allocation Performance Improvement
// ---------------------------------------------------------------------------------
vars
	aTA : CM_TerminalArea;
	tmpTerm : CM_Terminal;
	oldAreas : CM_TerminalAreaArray;	// TFS 49453
	tis : CM_TIArray;							// TFS 50110
	newGroups : StringArray;					// TFS 50110
	block : CM_YABlock;							// TFS 50110
	gcBlock : CM_YAGCAllocRowBlock;				// TFS 50110
	lc : CM_LocationsController;				// TFS 50110
	gcLc : CM_GeneralCargoAllocController;		// TFS 50110
	groupId : String;							// TFS 50110
	ti : CM_TrackedItem;						// TFS 50110
	
begin
	// Always initialize the activity first
	self.initialiseActivity();

	pProxyObj.raiseExceptionIfNotProxy(method);
	app.setContinueCMExceptions(true);
	
	app.myValUA.valYardAllocation(yardAllocationObj, pProxyObj);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	// TFS 50110 start
	// We need to see if the groups in the terminal area have changed, so we know whether we need to 
	// mov some TIs around later (TIs have the first column in a group as their location, so if a group 
	// changes its first column, we need to move the TIs
	create tis transient;
	create newGroups transient;
	foreach block in pProxyObj.allYABlocksIn where block.isKindOf(CM_YAGCAllocRowBlock) do
		gcBlock := block.CM_YAGCAllocRowBlock;
		if gcBlock.allYardControllers.first.ident = gcBlock.allYardControllers.last.ident then
			groupId := gcBlock.allYardControllers.first.ident;
		else
			groupId := gcBlock.allYardControllers.first.ident &amp; Hyphen &amp; gcBlock.allYardControllers.last.ident;
		endif;
		foreach lc in gcBlock.allYardControllers do
			gcLc := lc.CM_GeneralCargoAllocController;
			if gcLc.myGroup.ident &lt;&gt; groupId then
				foreach ti in gcLc.allTrackedItems do
					if not tis.includes(ti) then
						tis.add(ti);
						newGroups.add(groupId);
					endif;
				endforeach;
			endif;
		endforeach;
	endforeach;
	// TFS 50110 end
	
	app.setContinueCMExceptions(false);

	exclusiveLock(yardAllocationObj);

	// ====================================================
	// now do the update
	app.setContinueCMExceptions(false);
	
	if _passport.noErrors() and not yardAllocationObj.isYATemplate() then	// SFW1030 21/08/2008
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(yardAllocationObj, true);
	endif;

	if _passport.noErrors() then
		yardAllocationObj.terminalMarkDictRemove(pProxyObj, pAllTransientCriteriaObj);			// TFS 50889
		yardAllocationObj.setForUpdate(pProxyObj);
	endif;
	
	// Persist the YA Criteria.
	
	if _passport.noErrors() then
		yardAllocationObj.persistCriteria(pAllTransientCriteriaObj, _passport);
	endif;
	
	if _passport.noErrors() and not yardAllocationObj.isYATemplate() then	// SFW1030 21/08/2008
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(yardAllocationObj, false);

		// ### NOTES
		tmpTerm	:=	yardAllocationObj.myTerminal;
		tmpTerm.causeEvent(tmpTerm.getTerminalEvent(Event_YardAllocationUpdate), false, yardAllocationObj);
	endif;

	// TFS 49453 if the terminal area is a General Allocation area, we need to update the terminal area as well
	if _passport.noErrors and not yardAllocationObj.isYATemplate then
		foreach aTA in yardAllocationObj.allTerminalAreas where aTA.isGeneralCargoAllocArea do
			//app.myUtilityUA.utlUpdateGCAllocTAFromYA(aTA, yardAllocationObj, _passport);					// TFS 50110
			app.myUtilityUA.utlUpdateGCAllocTAFromYA(aTA, yardAllocationObj, tis, newGroups, _passport);	// TFS 50110
		endforeach;
		// send a note for each General Allocation area no longer covered by this yard allocation
		create oldAreas transient;
		pProxyObj.allTerminalAreas.copy(oldAreas);
		foreach aTA in oldAreas where not yardAllocationObj.allTerminalAreas.includes(aTA) do
			aTA.causeEvent(aTA.myTerminal.getTerminalEvent(Event_TerminalAreaUpdate), false, aTA);
		endforeach;
	endif;
	// TFS 49453 end
epilog
	delete oldAreas;			// TFS 49453
	delete tis;				// TFS 50110
	delete newGroups;		// TFS 50110
end;</source>
        <Parameter name="pProxyObj" type="CM_YardAllocation"/>
        <Parameter name="pAllTransientCriteriaObj" type="CMIF_Array"/>
        <Parameter name="yardAllocationObj" type="CM_YardAllocation" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateYardDeliveryRequest" id="22b1af64-2a29-4555-bf5d-bd0f17fc155f">
        <source>utlUpdateYardDeliveryRequest(_proxyReq  : CM_YardDeliveryRequest input; 
							 _addToRTQ  : Boolean;
							 _passport  : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//31 Mar 2025 	navma1  	MTN-34387 MTN - Removing Unnecessary Audits
// ---------------------------------------------------------------------------
vars
	realYardDeliveryRequest : CM_YardDeliveryRequest;
	expectedEdition			: Integer;
	
begin

	self.initialiseActivity();

	_proxyReq.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxyReq.pxyGetRealObjectAndEdition(realYardDeliveryRequest, expectedEdition);
	
	if realYardDeliveryRequest = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_YardDeliveryRequest.name, null, null);
		return;
	endif;

	app.myValUA.valYardDeliveryRequest(realYardDeliveryRequest, _proxyReq);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realYardDeliveryRequest);

	if _passport.noErrors and realYardDeliveryRequest.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'YardDeliveryRequest', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		realYardDeliveryRequest.setForUpdate(_proxyReq);
		if _passport.noErrors then
			if _addToRTQ then
				realYardDeliveryRequest.myJob.enqueueJob();
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="_proxyReq" type="CM_YardDeliveryRequest" usage="input"/>
        <Parameter name="_addToRTQ" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateYardInternalDelivery" id="8b77d29f-7b88-4d9b-b3b3-05e4666dfe64">
        <updating/>
        <source>utlUpdateYardInternalDelivery(pProxyYardInternalJob:CM_YardInternalJob;  _passport : CM_Passport input) updating;
