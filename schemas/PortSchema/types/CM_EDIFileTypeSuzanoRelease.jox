<Class name="CM_EDIFileTypeSuzanoRelease" id="a03c2e17-c9cd-44a4-bd87-1d2b17b26675">
    <superclass name="CM_EDIFileTypeSuzano"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
