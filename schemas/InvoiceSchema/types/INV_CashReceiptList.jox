    <JadeMethod name="doAgentChange" id="5821dfd8-05df-4c03-abcc-9c386ff79dad">
        <updating/>
        <source>doAgentChange() updating, protected;
//  change debtor from agent combo change on edit
vars
	agent	: CM_Object;
	consignee	: CM_ConsigneeConsignor;
	customsAgent	: CM_CustomsAgent;
	operator : CM_Operator;
begin

	agent := self.cmbAgent.listObject.CM_Object;
	if agent.isKindOf(CM_ConsigneeConsignor) then
		consignee := agent.CM_ConsigneeConsignor;
		self.myDebtor := consignee.debtor;
		self.lblDrName.caption := self.myDebtor.getListName;
	elseif agent.isKindOf(CM_CustomsAgent) then
		customsAgent := agent.CM_CustomsAgent;
		self.myDebtor := customsAgent.myDebtor;
		self.lblDrName.caption := self.myDebtor.getListName;
	elseif agent.isKindOf(CM_Operator) then // TFS 37454
		operator := agent.CM_Operator;
		self.myDebtor := operator.debtor;
		self.lblDrName.caption := self.myDebtor.getListName;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBOLSearch" id="d61ed1d7-d15b-4292-ad96-cdad0ffc925f">
        <updating/>
        <source>doBOLSearch(_voyage : CM_Voyage; _id : String; _objArray : ObjectArray input) protected, updating;
/*

Purpose:			Search for cargo using a BOL taking into account the parent/child options
					ONLY return parents
					35991 search onship as well as onsite

Parameters:			

Return Value:		


Date		Who		Reason
18/02/2015	cnwjre1	CCMS GPHA 2368, 34917

*/

vars
	bol			: CM_BOLIn;
	ti			: CM_TrackedItem;
	parent		: CM_TrackedItem;
	objArray	: ObjectArray;
	obj			: Object;
begin

	create objArray transient;
	self.btnEvenWeight.enabled := false;
	self.lblBOLWeight.caption  := "";

	if _voyage &lt;&gt; null then
		bol := _voyage.getBOL(_id);
		// the getBOL method returns a match or greater - only use if exact match
		if bol &lt;&gt; null then
			if not bol.number = _id then
				bol := null;
			endif;
			if bol &lt;&gt; null then
				self.myBOL := bol;
				//epr TFS 2334 18/7116
				if self.btnEvenWeight.visible then
					self.btnEvenWeight.enabled := true;
					self.lblBOLWeight.caption := bol.getBOLWeight().roundedTo(2).String  &amp; " kg";
				endif;
			endif;
		endif;
	endif;
	if bol &lt;&gt; null then
		foreach	ti in bol.allTrackedItems do
			if ti.myTerminal &lt;&gt; self.myTerminal then
				continue;
			endif;
			// only onship/onsite cargo, skips items on the BOL which have been paid for and have left
			if ti.isOnSite or
			   ti.isOnShip or
			   self.isInvoiceProforma then		// 36102
				if ti.isChild then
					parent := ti.myParent;
					if parent &lt;&gt; null and
					   not objArray.includes(parent) then
						objArray.add(parent);
					endif;
				else
					if not objArray.includes(ti) then
						objArray.add(ti);
					endif;
				endif;
			endif;
		endforeach;
	endif;
	// extend the search to handle cargo with no BOL object but a 'billOflading' value
	if bol = null and _voyage &lt;&gt; null then
		_voyage.lookupTrackedItemAnyWhereBOL(_id, self.isInvoiceProforma, objArray);
	endif;

	// copy the result to the output, adding children after each parent
	foreach obj in objArray do
		_objArray.add(obj);
		ti := obj.CM_TrackedItem;
	endforeach;

epilog
	delete objArray;
end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_objArray" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBaseFormCancel" id="9f16eb52-42bd-4043-ac16-b3182fb117a5">
        <updating/>
        <source>doBaseFormCancel() updating, protected;

