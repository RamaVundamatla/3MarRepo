    <JadeMethod name="updateDataTableObject" id="90ecd121-861d-4a44-9043-3a3125880d3f">
        <source>updateDataTableObject(_obj: CM_Object input);
/*
Date		Who		Reason
24 Aug 2007	cnwer1	Initial creation - PAR#xxxx
23/10/2012	cnwcs5	par 29653 - hide completed jobs	
*/
vars
	wle 		: CM_WorkListEntry;
	wleArray 	: CM_WLEArray;
	job			: CM_Job;
	vehicle     : CM_Vehicle;	//27 Aug 2019	NDL	TFS 42876
	vehLocation : CM_YardController;	//27 Aug 2019	NDL	TFS 42876
begin
	create wleArray transient;
	
	if _obj.isKindOf(CM_Vehicle) then
		_obj.CM_Vehicle.getAllWLEs(wleArray);
		
		foreach wle in wleArray do 
			inheritMethod(wle);
		endforeach;

	elseif _obj.isKindOf(CM_WorkListEntry) then
		// maybe we have just completed the last WLE for a job.  if we are not showing completed jobs the
		// notification for the CM_RoadJob update will have removed the job from the table so we dont want to add it back/
		if self.myRoadOpController.hideCompletedJobs then
			job := _obj.CM_WorkListEntry.job;
			
			if job &lt;&gt; null and job.isJobComplete then
				// do nothing
				return;
			endif;
		endif;
		
		//27 Aug 2019	NDL	TFS 42876
		//Can get to here via a notification, when we have multiple wles for the same break bulk
		//i.e. Rail to multiple trucks with a wle that is on a truck that is not yet in the yard.
		job := _obj.CM_WorkListEntry.job;
		if job &lt;&gt; null then
			vehicle := job.CM_RoadJob.myVehicle;
		endif;
		if vehicle &lt;&gt; null then
			vehLocation := vehicle.myPrimaryActualLocation;
			if vehLocation = null or not vehLocation.isInsideYard then
				return;
			endif;
		endif;
		
		// add or update WLE to table
		inheritMethod(_obj);
	endif;
epilog
	delete wleArray;
end;</source>
        <Parameter name="_obj" type="CM_Object" usage="input"/>
    </JadeMethod>
</Class>
