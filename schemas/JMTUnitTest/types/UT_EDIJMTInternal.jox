    <JadeMethod name="tCargoSubtypeAction" id="dd8312f5-d88c-4b11-8b44-f06e6a434abf">
        <source>tCargoSubtypeAction();
//
// 27 Aug 2014	cnwrs1	Par 34702 - Add support for JMT XML
//
constants
	USER_DEF_NAME : String = "JMTInternalWhatEver";
	CARGOTYPE1 : String = "MDF board";
	CARGOSUBTYPE1 : String = "UT MDH 15Amm";
	CARGOSUBTYPE2 : String = "UT MDH 15Bmm";
	CARGOSUBTYPE3 : String = "UT MDH 15Cmm";
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
	cargoType : CM_CargoType;
	cargoSubType : CM_Product;
	found1 : Boolean;
	found2 : Boolean;
	found3 : Boolean;
begin
	passportObj	:=	app.myPassport;
	ediText :=
'
&lt;?xml version="1.0"?&gt;
&lt;JMTInternalProduct&gt;
	&lt;AllCargoSubtype&gt;
		&lt;CargoSubtype&gt;
			&lt;length&gt;12.0000&lt;/length&gt;
			&lt;width&gt;14.0000&lt;/width&gt;
			&lt;height&gt;16.0000&lt;/height&gt;
			&lt;cargoTypeDescr&gt;'&amp;CARGOTYPE1&amp;'&lt;/cargoTypeDescr&gt;
			&lt;code&gt;'&amp;CARGOSUBTYPE1&amp;'&lt;/code&gt;
			&lt;description&gt;UT MDH 15Amm Desc&lt;/description&gt;
			&lt;id&gt;UT MDH 15Amm&lt;/id&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
		&lt;/CargoSubtype&gt;
		&lt;CargoSubtype&gt;
			&lt;length&gt;13.0000&lt;/length&gt;
			&lt;width&gt;15.0000&lt;/width&gt;
			&lt;height&gt;17.0000&lt;/height&gt;
			&lt;cargoTypeDescr&gt;'&amp;CARGOTYPE1&amp;'&lt;/cargoTypeDescr&gt;
			&lt;code&gt;'&amp;CARGOSUBTYPE2&amp;'&lt;/code&gt;
			&lt;description&gt;UT MDH 15Bmm Desc&lt;/description&gt;
			&lt;grade&gt;A&lt;/grade&gt;
			&lt;id&gt;UT MDH 15Bmm&lt;/id&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
			&lt;/CargoSubtype&gt;
			&lt;CargoSubtype&gt;
			&lt;length&gt;22.0000&lt;/length&gt;
			&lt;width&gt;24.0000&lt;/width&gt;
			&lt;height&gt;26.0000&lt;/height&gt;
			&lt;cargoTypeDescr&gt;'&amp;CARGOTYPE1&amp;'&lt;/cargoTypeDescr&gt;
			&lt;code&gt;'&amp;CARGOSUBTYPE3&amp;'&lt;/code&gt;
			&lt;description&gt;UT MDH 15Cmm Desc&lt;/description&gt;
			&lt;id&gt;UT MDH 15Cmm&lt;/id&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
		&lt;/CargoSubtype&gt;
	&lt;/AllCargoSubtype&gt;
&lt;/JMTInternalProduct&gt;
';
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 3, "incorrect number of EDI trackedItems");
	found1 := false;
	found2 := false;
	found3 := false;
	cargoType := self.getCargoType(CARGOTYPE1);
	foreach cargoSubType in cargoType.allProducts do
		if cargoSubType.code = CARGOSUBTYPE1 then
			found1 := true;
		elseif cargoSubType.code = CARGOSUBTYPE2 then
			found2 := true;
		elseif cargoSubType.code = CARGOSUBTYPE3 then
			found3 := true;
		endif;
	endforeach;
	self.assertEqualMsg(found1, true, "Cargo Sub Type 1 not found");
	self.assertEqualMsg(found2, true, "Cargo Sub Type 2 not found");
	self.assertEqualMsg(found3, true, "Cargo Sub Type 3 not found");
	
	ediText :=
'
&lt;?xml version="1.0"?&gt;
&lt;JMTInternalProduct&gt;
	&lt;AllCargoSubtype&gt;
		&lt;CargoSubtype&gt;
			&lt;length&gt;12.0000&lt;/length&gt;
			&lt;width&gt;14.0000&lt;/width&gt;
			&lt;height&gt;16.0000&lt;/height&gt;
			&lt;cargoTypeDescr&gt;'&amp;CARGOTYPE1&amp;'&lt;/cargoTypeDescr&gt;
			&lt;code&gt;'&amp;CARGOSUBTYPE1&amp;'&lt;/code&gt;
			&lt;description&gt;UT MDH 15Amm Desc&lt;/description&gt;
			&lt;id&gt;UT MDH 15Amm&lt;/id&gt;
			&lt;messageMode&gt;D&lt;/messageMode&gt;
			&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
		&lt;/CargoSubtype&gt;
		&lt;CargoSubtype&gt;
			&lt;length&gt;13.0000&lt;/length&gt;
			&lt;width&gt;15.0000&lt;/width&gt;
			&lt;height&gt;17.0000&lt;/height&gt;
			&lt;cargoTypeDescr&gt;'&amp;CARGOTYPE1&amp;'&lt;/cargoTypeDescr&gt;
			&lt;code&gt;'&amp;CARGOSUBTYPE2&amp;'&lt;/code&gt;
			&lt;description&gt;UT MDH 15Bmm Desc&lt;/description&gt;
			&lt;grade&gt;A&lt;/grade&gt;
			&lt;id&gt;UT MDH 15Bmm&lt;/id&gt;
			&lt;messageMode&gt;D&lt;/messageMode&gt;
			&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
		&lt;/CargoSubtype&gt;
		&lt;CargoSubtype&gt;
			&lt;length&gt;24.0000&lt;/length&gt;
			&lt;width&gt;26.0000&lt;/width&gt;
			&lt;height&gt;28.0000&lt;/height&gt;
			&lt;cargoTypeDescr&gt;'&amp;CARGOTYPE1&amp;'&lt;/cargoTypeDescr&gt;
			&lt;code&gt;'&amp;CARGOSUBTYPE3&amp;'&lt;/code&gt;
			&lt;description&gt;UT MDH 15Cmm Desc&lt;/description&gt;
			&lt;id&gt;UT MDH 15Cmm&lt;/id&gt;
			&lt;messageMode&gt;D&lt;/messageMode&gt;
			&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
		&lt;/CargoSubtype&gt;
	&lt;/AllCargoSubtype&gt;
&lt;/JMTInternalProduct&gt;
';
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 3, "incorrect number of EDI trackedItems");
	found1 := false;
	found2 := false;
	found3 := false;
	cargoType := self.getCargoType(CARGOTYPE1);
	foreach cargoSubType in cargoType.allProducts do
		if cargoSubType.code = CARGOSUBTYPE1 then
			found1 := true;
		elseif cargoSubType.code = CARGOSUBTYPE2 then
			found2 := true;
		elseif cargoSubType.code = CARGOSUBTYPE3 then
			found3 := true;
		endif;
	endforeach;
//	self.assertEqualMsg(found1, false, "Cargo Sub Type 1 not found");
//	self.assertEqualMsg(found2, false, "Cargo Sub Type 2 not found");
//	self.assertEqualMsg(found3, false, "Cargo Sub Type 3 not found");
	self.assertEqualMsg(found1, true, "Cargo Sub Type 1 not found");
	self.assertEqualMsg(found2, true, "Cargo Sub Type 2 not found");
	self.assertEqualMsg(found3, true, "Cargo Sub Type 3 not found");
end;
</source>
    </JadeMethod>
    <JadeMethod name="tCarrierAction" id="dcbb8d59-29eb-4ad8-bef6-31aea4992e4e">
        <source>tCarrierAction();
//
//11 August 2017	jlgrs1	Initial creation
//
constants
	USER_DEF_NAME : String = "JMTInternalCarrier";
	CARRIER01 : String = "CARRIER01";
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	passportObj : CM_Passport;
	carrier : CM_Carrier;
	ediText : String;
	errorMsg : String;
begin
	passportObj := app.myPassport;
	self.deleteCarrier(CARRIER01);
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalCarrier xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalCarrier.xsd"&gt;
	&lt;AllCarrier&gt;
		&lt;Carrier&gt;
			&lt;colour&gt;&lt;/colour&gt;
			&lt;action&gt;A&lt;/action&gt;
			&lt;cargoTypeDescr&gt;&lt;/cargoTypeDescr&gt;
			&lt;code&gt;CARRIER01&lt;/code&gt;
			&lt;debtorName&gt;&lt;/debtorName&gt;
			&lt;description&gt;Carrier number one&lt;/description&gt;
			&lt;fullOrMT&gt;&lt;/fullOrMT&gt;
			&lt;id&gt;&lt;/id&gt;
			&lt;isRail&gt;&lt;/isRail&gt;
			&lt;isRoad&gt;&lt;/isRoad&gt;
			&lt;messageMode&gt;X&lt;/messageMode&gt;
			&lt;notAvailable&gt;&lt;/notAvailable&gt;
		&lt;/Carrier&gt;
	&lt;/AllCarrier&gt;
&lt;/JMTInternalCarrier&gt;';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
