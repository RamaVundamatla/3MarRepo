        <updating/>
        <source>trxUpdateVasToDoTaskComplete(_object			 : CM_Object input; 
							_toDoCode			 : Integer;
							_passport		     : CM_Passport input;
							_resourceUsageProxys : CM_ResourceTypeUsageSet; 
							_wodtl				 : CM_WorkOrderToDoDtl) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Mar 2023	navcs2	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen
04 Apr 2023	navcs2	Bug 57455: EUP - Todo Tasks Completed without adding Mandatory resources
09 Dec 2024 navma1	MTN-19927 EUP - Error 1081 When using Rail Lander
*/

vars
	
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	beginTransaction;
	
	exclusiveLock(_object);
	
	_passport.useWOTransactionDeferUpdate := true;			//09.12.2024 navma1	#MTN-19927
	_passport.useEventDeferUpdate         := true;			//09.12.2024 navma1	#MTN-19927
	
	app.myUtilityUA.utlUpdateVasToDoTaskComplete(_object, _toDoCode, _passport, _resourceUsageProxys, _wodtl);
	
	if _passport.noErrors then								//09.12.2024 navma1	#MTN-19927
		_passport.doDeferredUpdates();	
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
