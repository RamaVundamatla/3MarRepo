    <JadeMethod name="assignValueSpecial" id="02e94aec-a157-4dee-837a-06add2e3d370">
        <updating/>
        <source>assignValueSpecial(_propName: String; _processedValue: String; _xlationOperator: CM_Operator): Boolean updating;
//
//06 August 2018	jlgrs1	TFS 40086 JMT Not all EDI TrackedItem stringArray are exposed to the EDI JMT Internal
//
vars
	strArray : StringArray;
begin
	if _propName = CM_EDIBayPlanTI::dischargePorts.name then
		self.dischargePorts.clear();
		strArray := _processedValue.getTokens();
		if strArray &lt;&gt; null and 
		   not strArray.isEmpty then
			strArray.copy(self.dischargePorts);
		endif;	
		return true;
	else
		return inheritMethod(_propName, _processedValue, _xlationOperator);
	endif;
epilog
	delete strArray;
end;</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_processedValue" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canUserSet" id="e77f3260-fb84-4933-9270-b6af1cf57ed2">
        <source>canUserSet(_propName: String): Boolean;
//----------------------------------------------------------------
//	Created:	05 August 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//06 August 2018	jlgrs1	TFS 40086 JMT Not all EDI TrackedItem stringArray are exposed to the EDI JMT Internal
vars

begin

	if _propName = CM_EDIBayPlanTI::companyCode.name 
	or _propName = CM_EDIBayPlanTI::bayPlanPrint.name
	or _propName = CM_EDIBayPlanTI::couId.name
//	or _propName = CM_EDIBayPlanTI::dischargePorts.name
	or _propName = CM_EDIBayPlanTI::imCodes.name
	or _propName = CM_EDIBayPlanTI::rawEDIData.name then
		return false;
	else
		return inheritMethod(_propName);
	endif;
end;</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="f7752371-db56-4611-8f8a-85236c5a48e5">
        <updating/>
        <source>create() updating;
/*
----------   ----------  --------------------------------------------------
Created:	18 September 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
----------   ----------  --------------------------------------------------
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
*/
vars

begin
	self.messageMode := CM_EDITrackedItem.EDI_ACTION_ADD;
	self.temperature := NULL_TEMPERATURE;
	if self.myEDIData &lt;&gt; null then //par17637(17595) cnwrs1 July 2008
		self.rawEDIData := self.myEDIData.fileVersion;
	else
		self.rawEDIData := "EDI";
	endif;
	
	//cnwmc5 - 10 March 2014 - PAR 33001
	self.overHeight := NULL_INTEGER;
	self.overLengthBack := NULL_INTEGER;
	self.overLengthFront := NULL_INTEGER;
	self.overWidthLeft := NULL_INTEGER;
	self.overWidthRight := NULL_INTEGER;
	
	//cnwmc5 - 16 September 2014 - CCMS 2381
	self.setHumidity( NULL_HUMIDITY );
	self.vent 			:= NULL_VENTILATION;
	self.setOxygen( NULL_OXYGEN );
	self.setCarbonDioxide( NULL_CARBON_DIOXIDE );
	
end;


</source>
    </JadeMethod>
    <JadeMethod name="destinationPort" id="12a0f69c-b694-44ca-8d7c-b6418aa65141">
        <methodInvocation>mapping</methodInvocation>
        <source>destinationPort(set: Boolean; _value: String io) mapping;
// cnwrs1 June 2006 protected the old 3 digit codes
vars
	port : CM_Port;
begin
	if not set then
		if self.destinationPort.length = 3 then
			port := app.myRoot.allLocodesByShortCode.getAtKeyGeq(self.destinationPort, null);
			if port &lt;&gt; null and port.portCode = self.destinationPort then
				_value := port.code;
			else
				_value := self.destinationPort;
			endif;
		else
			_value := self.destinationPort;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="dischargePort" id="9db68f29-7a99-4681-9b56-6ea8cc3b4110">
        <methodInvocation>mapping</methodInvocation>
        <source>dischargePort(set: Boolean; _value: String io) mapping;
// cnwrs1 June 2006 protected the old 3 digit codes
vars
	port : CM_Port;
begin
	if not set then
		if self.dischargePort.length = 3 then
			port := app.myRoot.allLocodesByShortCode.getAtKeyGeq(self.dischargePort, null);
			if port &lt;&gt; null and port.portCode = self.dischargePort then
				_value := port.code;
			else
				_value := self.dischargePort;
			endif;
		else
			_value := self.dischargePort;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getBayFileImCode" id="35ec0464-2238-46d2-8a64-0c975f6584d6">
        <source>getBayFileImCode(_idx: Integer): String;
//----------------------------------------------------------------
//	Created:	15 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	idx	: Integer;
begin
	idx := 1;
	if self.imCodes.size &lt; _idx then
		return "";
	else
		return self.imCodes[_idx].getNextToken(idx);
	endif;

end;</source>
        <Parameter name="_idx" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBayFileTemp" id="d883c4bf-bdff-4f55-9399-19afbf5ad005">
        <source>getBayFileTemp(): String;
//----------------------------------------------------------------
//	Created:	15 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if self.temperature = NULL_TEMPERATURE then
		return "";
	else
		return self.temperature.String;
	endif;	
		
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCarbonDioxide" id="f2a9d448-bd0a-40b5-8e27-8865b62a72be">
        <source>getCarbonDioxide():Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 April 2020	jlgndl1	Initial creation	TFS 47958

*/

vars

begin

	//All Carbon Dioxide display fields are limited to Decimal 6,2  so don't returm bigger than that
	if self.carbonDioxide &gt; 999.99 then
		return 999.99;
	endif;

	return self.carbonDioxide;

epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="28a618ad-32f5-4aab-a1df-a41874832909">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//----------------------------------------------------------------
//	Created:	03 September 2003	by Jason Chapman  (cnwjc2)
/* Changes

Date		Name	TFS#		Description
============================================================================
05 Apr 2012	cnwrs1	Par 29391 	EDI RORO Stowage Advice hazard codes
05/09/2012	cnwcs5	par 29482  	deal with all properties here rather than calling inheritMethod
23/04/2014	cnwdap1	PAR #33005 	CCMS SFW 1381 Add measurement types to EDI user-defined file types
10 Sep 2014	cnwrs1	CCMS 2381
19/05/2016	cnwdap1	TFS #1881 	BAPLIE/EDI VGM Updates
15/05/2019	jlgka1	TFS 42732	PNL - CUSCAR (Bayplan-style) add consigneeCode,	description and volume.
21/11/2022	navma1	ChangeRequest 55424: MTN - Improve the performance of Edi file loading
============================================================================*/
vars
	str			: String;
	strReturn	: String;
	strSize		: Integer;
	rowName		: String;
	type		: String;								// PAR #33005
begin
	if _attrName = ETRow_Temperature then
		if self.temperature = NULL_TEMPERATURE then
			return null;
		endif;
	elseif _attrName = ETRow_Vent then
		return self.vent.asNullDecimal;
	elseif _attrName = ETRow_Humidity then
		return self.getHumidity.asNullHumidity;
	elseif _attrName = ETRow_CarbonDioxide then
		return self.getCarbonDioxide.asNullCarbonDioxide;
	elseif _attrName = ETRow_Oxygen then
		return self.getOxygen.asNullOxygen;
	elseif _attrName = ETRow_Bol then						// par 29842 Sep 2012
		return self.bol;

	elseif _attrName = ETRow_Commodity then					// par 29842 Sep 2012
		return self.commodity;

	elseif _attrName = ETRow_CommodityDescription then		// par 29842 Sep 2012
		return self.commodityDescription;

	elseif _attrName = ETRow_CouId then			// par 29842 Sep 2012
		return self.couId;
	
	elseif _attrName = ETRow_CompanyCode then			// par 29842 Sep 2012
		return self.companyCode;

	elseif _attrName = ETRow_DestinationPort then			// par 29842 Sep 2012
		return self.destinationPort;

	elseif _attrName = ETRow_DischargePort then				// par 29842 Sep 2012
		return self.dischargePort;
		
	elseif _attrName = ETRow_DischargePorts then
		foreach str in self.dischargePorts do
			if strReturn = null then
				strReturn := str;	
			else
				strReturn := strReturn &amp; " " &amp; str;
			endif;
		endforeach;
		
		return strReturn;
	elseif _attrName = ETRow_FullOrMT then			// par 29842 Sep 2012
		return self.fullOrMT;

	elseif _attrName = ETRow_Id then			// par 29842 Sep 2012
		return self.id;

	elseif _attrName = ETRow_IsoType then			// par 29842 Sep 2012
		return self.isoType;

	elseif _attrName = ETRow_LoadPort then			// par 29842 Sep 2012
		return self.loadPort;

	elseif _attrName = ETRow_OperatorCode then			// par 29842 Sep 2012
		return self.operatorCode;
		
	elseif _attrName = ETRow_Remarks then			// par 29842 Sep 2012
		return self.remarks;

	elseif _attrName = ETRow_SealNum then			// par 29842 Sep 2012
		return self.sealNum;
		
	elseif _attrName = ETRow_TranshipToPort then	// par 29842 Sep 2012
		return self.transhipToPort;

	elseif _attrName = ETRow_LocationId then
		strSize := self.locationId.length;
		
		if strSize &gt;= 6 then
			//hide the leading zero
			return self.locationId[strSize-5:6];
		endif;
	elseif _attrName = ETRow_TotalWeight then
		return self.weight.asStringWeightJMT();
		
	elseif _attrName = ETRow_Height then
		return self.height.asStringMeasurementJMT();
		
	elseif _attrName = ETRow_Width then
		return self.width.asStringMeasurementJMT();		
		
	elseif _attrName = ETRow_Length then
		return self.length.asStringMeasurementJMT();
		
	//cnwmc5 - 23 Jan 2014 - PAR 33001
	elseif _attrName = ETRow_OverHeight then
		if self.overHeight = NULL_INTEGER then
			return null;
		else
			return self.overHeight.String;
		endif;
	//cnwmc5 - 23 Jan 2014 - PAR 33001
	elseif _attrName = ETRow_OverLengthBack then
		if self.overLengthBack = NULL_INTEGER then
			return null;
		else
			return self.overLengthBack.String;
		endif;
	//cnwmc5 - 23 Jan 2014 - PAR 33001
	elseif _attrName = ETRow_OverLengthFront then
		if self.overLengthFront = NULL_INTEGER then
			return null;
		else
			return self.overLengthFront.String;
		endif;
	//cnwmc5 - 23 Jan 2014 - PAR 33001
	elseif _attrName = ETRow_OverWidthLeft then
		if self.overWidthLeft = NULL_INTEGER then
			return null;
		else
			return self.overWidthLeft.String;
		endif;
	//cnwmc5 - 23 Jan 2014 - PAR 33001
	elseif _attrName = ETRow_OverWidthRight then
		if self.overWidthRight = NULL_INTEGER then
			return null;
		else
			return self.overWidthRight.String;
		endif;
		
	elseif _attrName = ETRow_IsCertifiedWeight then								// TFS #1881
		return self.isCertifiedWeight.getYes;									// TFS #1881
	elseif _attrName = ETRow_ImCodes or _attrName = ETRow_Hazards or _attrName = ETRow_Hazardous then		//21.11.2022 navma1 #55424
		return self.getHazardsAsString();	
	//jlgka1 TFS 42732 --&gt;	
	elseif  _attrName = ETRow_ConsigneeCode then	
		return self.consigneeCode;
	elseif  _attrName = ETRow_Description then	
		return self.description;
	//jlgka1 TFS 42732 &lt;--
	elseif _attrName.isMeasurementType then										// PAR #33005
		_attrName.getRowNameMeasureType(rowName, type);							// PAR #33005
		return self.getMeasurementStringForAttrib(rowName, type, _short);		// PAR #33005
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHazardsAsString" id="fbad8704-68da-48b8-9ca5-4a4ea2c45b61">
        <source>getHazardsAsString(): String;
//
//02 Feb 2012	cnwrs1	Par 29076 Fix up Hazard Processing in EDI
// 05/09/2012	cnwcs5	par 29842 - performance dont create colls if goiing to return null
//
vars
	tmpHazards 	: ObjectArray;
	hazards 	: CM_HazardByCodeDict;
	haz 		: CM_Hazard;
	str 		: String;
begin
	if self.imCodes.isEmpty then
		return null;
	endif; 

	create tmpHazards transient;
	create hazards transient;
	
	self.getProxyHazards(self.imCodes, tmpHazards, false);
	tmpHazards.copy(hazards);
	
	if hazards.isEmpty then
		return null;
	endif;
	
	foreach haz in hazards do
		str := str &amp; haz.getTableDisplay(false, true) &amp; ", ";
	endforeach;
	
	str := str[1:str.length - 2];
	
	return str;
epilog
	if tmpHazards &lt;&gt; null then
		tmpHazards.purge();
	endif;
	
	delete tmpHazards;
	delete hazards;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
