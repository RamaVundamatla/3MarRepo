    <JadeMethod name="makeMessageHeaderSectXML" id="7c8d5162-679e-4359-9ed6-f99948585a4a">
        <source>makeMessageHeaderSectXML( _term : CM_Terminal; _camProtocol: CM_CamProtocol; _trxTs : TimeStamp; _messHdrEventType : String; _parentElem : JadeXMLElement input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2016	cnwndl1	Initial creation	TFS 2561 / 2277
9/11/2018 	JLGNS1	Bug 41923: AAT - Time Issue in EDI Message
*/

vars

	rootElem : JadeXMLElement;
	xmlElem : JadeXMLElement;
	
	ts : TimeStamp;
	port : CM_Port;
	
	camGroup : CM_CamGroup;
	placeOfEvent : String;
	senderID : String;

begin

	rootElem := _parentElem.addElement('MessageHeader');
	
	
	//ts := app.actualTimeServer();
	ts := _term.systemToLocalTime(app.actualTimeServer());//Bug 41923
	xmlElem := rootElem.addElement('LocalDateTimeSent');
	xmlElem.setText( ts.asXMLFormat );
	
	ts := self.convertTStoUTC( _trxTs );
	xmlElem := rootElem.addElement('TransactionUTC_Time');
	xmlElem.setText( ts.asXMLFormat );
	
	//ts := _trxTs;
	ts := _term.systemToLocalTime(_trxTs);//Bug 41923
	xmlElem := rootElem.addElement('TransactionDateTime');
	xmlElem.setText( ts.asXMLFormat );
	
	xmlElem := rootElem.addElement(self.XMLTag_EventType);
	xmlElem.setText( _messHdrEventType );
	
	//16 Feb 2017	NDL	TFS 3454 - set sender id and place of event from Cam Group...
	if _camProtocol &lt;&gt; null then	//04 Apr 2017	NDL	TFS - pass it in 
		camGroup := _camProtocol.camGroup;
	endif;
	if camGroup &lt;&gt; null and camGroup.facilityCode &lt;&gt; null then
		placeOfEvent := camGroup.facilityCode;
	else
		placeOfEvent := _term.code;
	endif;
	if camGroup &lt;&gt; null and camGroup.senderCode &lt;&gt; null then
		senderID := camGroup.senderCode;
	else
		senderID := _term.code;
	endif;
	
	xmlElem := rootElem.addElement(self.XMLTag_PlaceOfEvent);
	if _term &lt;&gt; null then
		xmlElem.setText( placeOfEvent );
	endif;
	/*
	xmlElem := rootElem.addElement('DocumentReferenceNumber'); // never required
	xmlElem.setText( null );
	*/
	xmlElem := rootElem.addElement(self.XMLTag_SenderID);
	if _term &lt;&gt; null then
		xmlElem.setText( senderID );
	endif;
	
	xmlElem := rootElem.addElement('SenderName');
	if _term &lt;&gt; null then
		xmlElem.setText( _term.name );
	endif;
	/*
	xmlElem := rootElem.addElement('SenderUserName');	 // never required
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('SenderUserEmail');	 // never required
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('SenderUserPhone');	 // never required
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('SenderUserFax');	 // never required
	xmlElem.setText( null );
	*/
	xmlElem := rootElem.addElement('SenderType');
	xmlElem.setText( "C" );
	
	if _term &lt;&gt; null then
		port := _term.getDefaultPort;
	endif;
	xmlElem := rootElem.addElement('PortCode');
	if port &lt;&gt; null then
		xmlElem.setText( port.code );
	endif;
	/*
	xmlElem := rootElem.addElement('SenderEmail');	 // never required
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('SenderSMS');	 // never required
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('SenderEmailAlert');	 // never required
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('RecipientID');	 // never required
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('RecipientName');	 // never required
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('RecipientEmail');	 // never required
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('CopyRecipientName');	 // never required
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('CopyRecipientEmail');	 // never required
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('CopyRecipientID');	 // never required
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('DocumentFunction');	 // never required
	xmlElem.setText( null );
	*/

epilog

end;</source>
        <access>protected</access>
