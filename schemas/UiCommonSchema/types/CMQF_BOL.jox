<Class name="CMQF_BOL">
    <JadeMethod name="setFromAgent" id="1878b9cc-744d-4e5a-b368-90f38ea2914f">
        <updating/>
        <source>setFromAgent(_agent : CMUI_ReportAgent input) updating;
// ---------------------------------------------------------------------------
// Created:     06 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	voy		: CM_Voyage;
begin
	inheritMethod(_agent);
	
	self.docketNumber := _agent.getValueByNameIfVisible(ETRow_DocketNumber).String;
	if self.docketNumber = null then
		self.docketNumber := _agent.getValueByNameIfVisible(ETRow_BolInNumber).String;
	endif;
	if self.docketNumber = null then
		self.docketNumber := _agent.getValueByNameIfVisible(ETRow_BolOutNumber).String;
	endif;
	
	self.bolType := _agent.getSelectedBOLTypeId();
	
	if (_agent.isRowIncluded(ETRow_Voyage) or
	   _agent.isRowIncluded(ETRow_VoyageCode)) then
		voy := _agent.getSelectedCellularVoyage();
		if voy &lt;&gt; null then
			self.voyageCode := voy.code;
		endif;
	endif;

	if _agent.isRowIncluded(ETRow_DocketError) then	//#24306 01/06/2010
		self.setMyDocketErrorType( _agent.getSelectedDocketErrorType() );
	endif;

	
end;</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
