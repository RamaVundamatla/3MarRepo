    </JadeMethod>
    <JadeMethod name="manipulateCells" id="f13b064b-5e52-4f5c-b5d8-015f1689de54">
        <source>manipulateCells( 	primeRowName : String;
					secondaryRowName : String;
					columnIdx : Integer;
					heading : String;
					row2Prime : String;
					row2Second : String;
					skipColumn : String output
					) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 September 2009	cnwndl1	Initial creation

*/

vars

begin
	skipColumn := null;
	if self.tblData.allTblDataEntRows[columnIdx].EntTableRow.name = primeRowName then
		if self.tblData.allTblDataEntRows[columnIdx + 1].EntTableRow.name = secondaryRowName then
			self.tblData.accessCell(1,columnIdx).text := heading;
			self.tblData.accessCell(1,columnIdx).mergeCells := Table.MergeCells_Merge;
			self.tblData.accessCell(1,columnIdx + 1).text := null;
			self.tblData.accessCell(2,columnIdx).text := row2Prime;
			self.tblData.accessCell(2,columnIdx + 1).text := row2Second;
			skipColumn := secondaryRowName;
			
		else
			self.tblData.accessCell(1,columnIdx).text := self.tblData.allTblDataEntRows[columnIdx].EntTableRow.getHeading(null,null,app.myCurrentLocale);
			self.tblData.accessCell(1,columnIdx).gridBottom := false;
			self.tblData.accessCell(2,columnIdx).text := null;
			
		endif;
		
	elseif self.tblData.allTblDataEntRows[columnIdx].EntTableRow.name = secondaryRowName then
		if self.tblData.allTblDataEntRows[columnIdx + 1].EntTableRow.name = primeRowName then
			self.tblData.accessCell(1,columnIdx).text := heading;
			self.tblData.accessCell(1,columnIdx).mergeCells := Table.MergeCells_Merge;
			self.tblData.accessCell(1,columnIdx + 1).text := null;
			self.tblData.accessCell(2,columnIdx).text := row2Second;
			self.tblData.accessCell(2,columnIdx + 1).text := row2Prime;
			skipColumn := primeRowName;
			
		else
			self.tblData.accessCell(1,columnIdx).text := self.tblData.allTblDataEntRows[columnIdx].EntTableRow.getHeading(null,null,app.myCurrentLocale);
			self.tblData.accessCell(1,columnIdx).gridBottom := false;
			self.tblData.accessCell(2,columnIdx).text := null;
			
		endif;
		
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="primeRowName" type="String"/>
        <Parameter name="secondaryRowName" type="String"/>
        <Parameter name="columnIdx" type="Integer"/>
        <Parameter name="heading" type="String"/>
        <Parameter name="row2Prime" type="String"/>
        <Parameter name="row2Second" type="String"/>
        <Parameter name="skipColumn" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="manipulateTblDataFixedRows" id="eb7a8b45-2a64-40a0-b77c-ba470606056f">
        <source>manipulateTblDataFixedRows() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 September 2009	cnwndl1	Initial creation
14 Oct 2022 navrk21 ChangeRequest 55087: PNL - Booking Discrepancies - Can 'CA Curtains and Curtains' be renamed?
*/

vars

	entRow : EntTableRow;
	columnIdx : Integer;
	cargo : String;
	bref : String;
	skipColumn : String;
	
begin

	cargo := app.getErrorString(Cargo);
	//bref := app.getErrorString(Bref);
	bref := app.getErrorString(Book);					//+cnwml2 PAR20869

	self.tblData.accessSheet(1).fixed3D := false;
	self.tblData.fixedRows := 2;
	
	foreach entRow in self.tblData.allTblDataEntRows do
		columnIdx := columnIdx + 1;
		if entRow.name = skipColumn then
			continue;
		elseif columnIdx = self.tblData.allTblDataEntRows.size then
			//last column.
			self.tblData.accessCell(1,columnIdx).text := entRow.getHeading(null,null,app.myCurrentLocale);
			self.tblData.accessCell(1,columnIdx).gridBottom := false;
			self.tblData.accessCell(2,columnIdx).text := null;
		
		// special rows.
		elseif entRow.name = ETRow_OperatorBref or entRow.name = ETRow_OperatorTi then
			self.manipulateCells( ETRow_OperatorBref, ETRow_OperatorTi, columnIdx, app.getErrorString(Operator), bref, cargo, skipColumn);
		
		elseif entRow.name = ETRow_VoyageBref or entRow.name = ETRow_VoyageTi then
			self.manipulateCells( ETRow_VoyageBref, ETRow_VoyageTi, columnIdx, app.getErrorString(Voyage), bref, cargo, skipColumn);
			
		elseif entRow.name = ETRow_DischargeBref or entRow.name = ETRow_DischargeTi then
			self.manipulateCells( ETRow_DischargeBref, ETRow_DischargeTi, columnIdx, app.getErrorString(DischargePort), bref, cargo, skipColumn);
		
		elseif entRow.name = ETRow_DestBref or entRow.name = ETRow_DestTi then
			self.manipulateCells( ETRow_DestBref, ETRow_DestTi, columnIdx, app.getErrorString(Destination), bref, cargo, skipColumn);
		
		elseif entRow.name = ETRow_ConsigneeBref or entRow.name = ETRow_ConsigneeTi then
			self.manipulateCells( ETRow_ConsigneeBref, ETRow_ConsigneeTi, columnIdx, app.getErrorString(Consignee), bref, cargo, skipColumn);
		
		elseif entRow.name = ETRow_ConsignorBref or entRow.name = ETRow_ConsignorTi then
			self.manipulateCells( ETRow_ConsignorBref, ETRow_ConsignorTi, columnIdx, app.getErrorString(CM_Consignor), bref, cargo, skipColumn);
		
		elseif entRow.name = ETRow_IsStockBref or entRow.name = ETRow_IsStockTi then
			self.manipulateCells( ETRow_IsStockBref, ETRow_IsStockTi, columnIdx, app.getErrorString(Is_Stock), bref, cargo, skipColumn);
		
		elseif entRow.name = ETRow_CargoTypeBref or entRow.name = ETRow_CargoTypeTi then
			self.manipulateCells( ETRow_CargoTypeBref, ETRow_CargoTypeTi, columnIdx, app.getErrorString(CargoType), bref, cargo, skipColumn);
		
		elseif entRow.name = ETRow_IsoTypeBref or entRow.name = ETRow_IsoTypeTi then
			self.manipulateCells( ETRow_IsoTypeBref, ETRow_IsoTypeTi, columnIdx, app.getErrorString(ISO_Type), bref, cargo, skipColumn);
		
		// 19/02/2014 cnwar2 #33139
		elseif entRow.name = ETRow_IsoGroupBref or entRow.name = ETRow_IsoGroupTi then
			self.manipulateCells( ETRow_IsoGroupBref, ETRow_IsoGroupTi, columnIdx, app.getErrorString(ISO_Group), bref, cargo, skipColumn);
		
		elseif entRow.name = ETRow_CommodityBref or entRow.name = ETRow_CommodityTi then
			self.manipulateCells( ETRow_CommodityBref, ETRow_CommodityTi, columnIdx, app.getErrorString(CM_Commodity_GC), bref, cargo, skipColumn);
		
		elseif entRow.name = ETRow_TempBref or entRow.name = ETRow_TempTi then
			self.manipulateCells( ETRow_TempBref, ETRow_TempTi, columnIdx, app.getErrorString(CM_TemperatureExtra), bref, cargo, skipColumn);
		
		elseif entRow.name = ETRow_HumidityBref or entRow.name = ETRow_HumidityTi then
			self.manipulateCells( ETRow_HumidityBref, ETRow_HumidityTi, columnIdx, app.getErrorString(CM_Humidity), bref, cargo, skipColumn);
		
		elseif entRow.name = ETRow_VentilationBref or entRow.name = ETRow_VentilationTi then
			self.manipulateCells( ETRow_VentilationBref, ETRow_VentilationTi, columnIdx, app.getErrorString(CM_Ventilation), bref, cargo, skipColumn);
		
		elseif entRow.name = ETRow_CurtainsBref or entRow.name = ETRow_CurtainsTi then
			self.manipulateCells( ETRow_CurtainsBref, ETRow_CurtainsTi, columnIdx, app.getErrorString(Curtains), bref, cargo, skipColumn);
		
		elseif entRow.name = ETRow_HazardBref or entRow.name = ETRow_HazardTi then
			self.manipulateCells( ETRow_HazardBref, ETRow_HazardTi, columnIdx, app.getErrorString(CM_Hazardous), bref, cargo, skipColumn);
		// Start 14.10.2022 navrk21 TFS 55087
		elseif entRow.name = ETRow_CO2Bref or entRow.name = ETRow_CO2Ti then
			self.manipulateCells( ETRow_CO2Bref, ETRow_CO2Ti, columnIdx, app.getErrorString(CM_CO2), bref, cargo, skipColumn);
		
		elseif entRow.name = ETRow_O2Bref or entRow.name = ETRow_O2Ti then
			self.manipulateCells( ETRow_O2Bref, ETRow_O2Ti, columnIdx, app.getErrorString(CM_O2), bref, cargo, skipColumn);
		// End 14.10.2022 navrk21 TFS 55087
		else
			// normal row;
			self.tblData.accessCell(1,columnIdx).text := entRow.getHeading(null,null,app.myCurrentLocale);
			self.tblData.accessCell(1,columnIdx).gridBottom := false;
			self.tblData.accessCell(2,columnIdx).text := null;
			
		endif;
		
	endforeach;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="mnuAudit_click" id="44eb7973-f374-49f0-b537-0fe28d398f84">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuAudit_click(menuItem: MenuItem input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 August 2009	cnwndl1	Initial creation	CCMS 1609 Par 20521

*/

vars
	
begin
	
	app.viewAuditForm(menuItem.userObject.CM_Object, self.myAssistant.class, self.myTerminal);
epilog

end;</source>
