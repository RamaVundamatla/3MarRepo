    <JadeMethod name="getMyVoyageObject" id="816432af-d9a2-4a80-bf5f-9187aaf94304">
        <source>getMyVoyageObject(): CM_Voyage;
// ---------------------------------------------------------------------------
// Created:     24 June 2014 by cnwab1  // PAR 34535
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
 // PAR 34535
//	03 Feb 2025 	navbs1			Bug MTN-28320: MTN - EDI Cargo on Ship 1090 Errors
// ---------------------------------------------------------------------------

vars
	ediTI : CM_EDITrackedItem;
begin
	ediTI := self.allEDITrackedItems.first;
	
	 if ediTI = null then		//03.02.2025 navbs1 #28320		
        return null;
    endif;
	
	return ediTI.getVoyage();
	
epilog

end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="getParentTI" id="28af5a5b-40d0-4c1a-b2aa-d0bd5a4ddd25">
        <source>getParentTI(_childTI : CM_EDICargoTI) : CM_TrackedItem;
/* // PAR 34535
Purpose:			
Date		Who		Reason
09 July 2014	cnwab1	Initial creation
*/

vars
	tis : CM_TISet;
	parentTI : CM_TrackedItem;
	voyage : CM_Voyage;
begin
	voyage := self.getMyVoyageObject(); 
	
	if voyage = null then
		return null;
	endif;
	
	create tis transient; // PAR 34535

	voyage.searchForOnShipTIType(_childTI.parentCargoID, app.myRoot.getCargoTypeFromAbbrevOrDescr(_childTI.parentCargoType).id, tis);
	if tis.size &gt;= 1 then
		parentTI :=  tis.first;
	endif;
	
	return parentTI;
epilog
	delete tis;
end;</source>
        <Parameter name="_childTI" type="CM_EDICargoTI"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getRealBreakBulkItem" id="3df6d552-9c64-49d6-9cd6-7d5f4d39adc2">
        <source>getRealBreakBulkItem(_ediTI: CM_EDICargoTI; _cargoType: CM_CargoType; _dict: CM_TIByCargoTypeIdDict): CM_TrackedItem;
/*
Purpose:			

Date		Who		Reason
// ### TFS BUG 58101 22MAY2023 NAVAB1
*/

vars

	voyage		: CM_Voyage;
	terminal	: CM_Terminal;
	cargoType: CM_CargoType;
	locn : CM_LocationsController;
	otherTI : CM_TrackedItem;
	matches : Integer;
begin

	terminal	:= self.getMyTerminal();
	voyage 		:= terminal.lookupVoyage(_ediTI.getVoyageCode(), null, false);
	
	if voyage = null then
		// Assume invalid voyage will be caught later in validation
		return null;
	endif;

	if _ediTI.locationId &lt;&gt; null then
		voyage.findLocationFromString(_ediTI.locationId,false,locn);
	else
		locn := voyage.myShipBlockStack;
	endif;
	
	if locn &lt;&gt; null then
		otherTI := locn.searchForOnsiteTI(_ediTI.id,matches,_ediTI.cargoType,_ediTI.cargoGroupId,_ediTI.product, _ediTI.operatorCode); //03.Nov.2023 navsp TFS 61067
		return otherTI;
	endif;
	
	return inheritMethod(_ediTI, _cargoType, _dict);

epilog

end;</source>
        <Parameter name="_ediTI" type="CM_EDICargoTI"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_dict" type="CM_TIByCargoTypeIdDict"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getRealCargoItem" id="e31162ba-8ffa-42f8-9d2f-b5027d493081">
        <source>getRealCargoItem(_ediTI : CM_EDICargoTI): CM_TrackedItem;
/* ---------------------------------------------------------------------------
Created:     25 February 2010 by cnwrs2
       
Change Date	Who		Reason
20/06/2012	cnwcs5	par 29747 - no longer protected
------------------------------------------------------------------------------*/
vars
	voyage		: CM_Voyage;
	terminal	: CM_Terminal;
	cargoType: CM_CargoType;
begin

	terminal	:= self.getMyTerminal();
	voyage 		:= terminal.lookupVoyage(_ediTI.getVoyageCode(), null, false);
	
	if voyage = null then
		// Assume invalid voyage will be caught later in validation
		return null;
	endif;
		
	// PAR 32476 Allow for break bulk in different locations on ship
	cargoType := terminal.myRoot.allCargoTypesById[_ediTI.cargoType];
	if cargoType &lt;&gt; null and cargoType.isAllowDuplicates then
		return self.getRealBreakBulkItem(_ediTI, cargoType, voyage.allOnshipTIsByCargoTypeId);
	endif;
	
	return voyage.allOnshipTIsByCargoTypeId[_ediTI.cargoType, _ediTI.id];
epilog
end;</source>
        <Parameter name="_ediTI" type="CM_EDICargoTI"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
