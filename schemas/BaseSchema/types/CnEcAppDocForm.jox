    <JadeMethod name="errorAdd" id="67ad9ca1-ae51-41f3-b2d2-1cdad90d9b65">
        <updating/>
        <source>errorAdd(pError:String) updating, protected;
// --------------------------------------------------------------------------------
// Created:		22 March 2007 by cnwdad1
//
// Purpose:		Appends an error message to the form error property.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	existingError	: String;
	
begin
	existingError	:=	self.aError.trimBlanks();
	
	if existingError = null then
		existingError	:=	pError;
	else
		existingError	:=	existingError &amp; CrLf &amp; CrLf &amp; pError;
	endif;
	
	self.aError	:=	existingError;
end;</source>
        <access>protected</access>
        <Parameter name="pError" type="String"/>
    </JadeMethod>
    <JadeMethod name="errorShow" id="956966ea-c612-4bc6-8c35-f95c6d04f457">
        <updating/>
        <source>errorShow():Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		22 July 2001 by cnwdad2
//
// Purpose:		Standard method to display an error message.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorMessage	: String;
	
begin
	errorMessage	:=	self.aError;
	
	if errorMessage = null then
		return true;
	else
		self.aError	:=	null;
		app.msgBox(errorMessage, "Error", MsgBox_Stop_Icon + MsgBox_OK_Only);
		return false;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="load" id="cad2cbf4-8a39-4b71-95ed-8d86ec7d6660">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// --------------------------------------------------------------------------------
// Created:		22 March 2007 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	
	self.centreWindow();
	self.doFormLoad();
epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
</GUIClass>
