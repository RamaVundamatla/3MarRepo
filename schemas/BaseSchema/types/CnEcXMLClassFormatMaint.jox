    <JadeMethod name="sampleClick" id="da5404e3-b97a-4ff1-8b88-5c1a714a4713">
        <source>sampleClick() protected;
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 07/03/2002	cnwdad1		Changed to check whether the Class being used for the
//							sample was found, and also whether an instance of that
//							class exists.  If either check fails, then an error
//							message dialog (message box) is displayed.
vars
	sampleFormObj	: CnEcXMLSample;
	sampleObj		: Object;
	className		: String;
	sampleClassObj	: Class;
	
begin
	className		:=	lstFormatClasses.listObject.CnEcXmlFormatClass.className;
	sampleClassObj	:=	app.myCnEcXmlSchema.getClass(className);
	
	if sampleClassObj = null then
		app.msgBox(	"The '" &amp; className &amp; "' class was not found.",
					"Error",
					MsgBox_Stop_Icon + MsgBox_OK_Only);
	else
		sampleObj	:=	app.myCnEcXmlSchema.getClass(className).lastInstance;
		
		if sampleObj = null then
			app.msgBox(	"No instances of the '" &amp; className &amp; "' class were found.",
						"Error",
						MsgBox_Stop_Icon + MsgBox_OK_Only);
		else
			create sampleFormObj;
			sampleFormObj.aMyObject		:=	sampleObj;
			sampleFormObj.aFormatName	:=	cmbOutputFormats.text;
			sampleFormObj.centreWindow();
			sampleFormObj.showModal();
		endif;
	endif;
epilog
	delete sampleFormObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
