					&amp; "Are You Sure You Want To Reset?", app.getErrorString(Confirmation), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		global.beep;
		return;
	endif;
	self.doUpdateOOWReset();
end;</source>
    </JadeMethod>
