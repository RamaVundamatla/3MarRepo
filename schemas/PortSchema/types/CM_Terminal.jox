    <JadeMethod name="getIdsOfUnmatchedTickets" id="bc81a705-fc0b-43c2-95e0-1bde0e163ce3">
        <source>getIdsOfUnmatchedTickets(_pseudoIdArray : StringArray input; _bol : CM_BOL);//, serverExecution;
//--------------------------------------------------------------
//Created: 30 April 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	ext	: CM_BOLExtLogIn;
	seq : CM_TicketSequence;
	realBOL	: CM_BOL;
	ls			: Boolean;
begin

	realBOL := app.myProxyManager.getRealObject(_bol).CM_BOL;
	if realBOL = null then
		realBOL := _bol;
	endif;
	
	app.cmsBeginLoad(ls);
	foreach ext in self.allLogBOLsUnmatched do
		if realBOL &lt;&gt; null and ext.myBOL = realBOL then
			continue;
		endif;
		foreach seq in ext.allTicketSequences do
			seq.getPseudoIds(_pseudoIdArray);
			//seq.allTicketIds.copy(_pseudoIdArray);
		endforeach;
	endforeach;
epilog
	app.cmsEndLoad(ls);
end;</source>
        <Parameter name="_pseudoIdArray" type="StringArray" usage="input"/>
        <Parameter name="_bol" type="CM_BOL"/>
    </JadeMethod>
