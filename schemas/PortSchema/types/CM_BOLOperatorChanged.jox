<Class name="CM_BOLOperatorChanged" id="31f4d654-f9af-4abf-9311-d6be3d4fa4ac">
    <superclass name="CM_BOLTransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="transactbol"/>
    <PrimAttribute name="detailDescription" id="5da61fdd-e955-4055-8b61-0b5b7f37f3db">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="newOperatorCode" id="54de90cf-a573-42a2-b0ac-3df186c6bc95">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="previousOperatorCode" id="beaf972c-f9a7-4972-92c3-739bbb3a0a1c">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getDebtorFromOperator" id="45340ad2-cd53-471b-9611-368499ecb95a">
        <source>getDebtorFromOperator(): CM_Debtor;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

	debtor : CM_Debtor;
	operator : CM_Operator;

begin

	operator := app.myRoot.allOperators.getAtKey( self.newOperatorCode );
	if operator &lt;&gt; null then
		debtor := operator.debtor;
	endif;
	
	return debtor;

epilog

end;</source>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="getDisplayID" id="c60e429f-6d4b-4f6f-b60f-cb655f752344">
        <source>getDisplayID(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

begin
	return self.detailDescription;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="9a691c0e-0245-4772-973f-2233f30f6c82">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

begin
	if _attrName = ETRow_Details then
		return self.detailDescription;
	else
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setDetails" id="7be439b3-5741-42b2-a6de-9fbd2b7f1c53">
        <updating/>
        <source>setDetails( _prevOperator : String; _newOperator : String; bol : CM_BOL ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

begin

	self.previousOperatorCode := _prevOperator;
	self.newOperatorCode := _newOperator;
	self.detailDescription := bol.number &amp; " " &amp; app.getErrorString2( Operator_changed_from, _prevOperator, _newOperator );


epilog

end;</source>
        <Parameter name="_prevOperator" type="String"/>
        <Parameter name="_newOperator" type="String"/>
        <Parameter name="bol" type="CM_BOL"/>
    </JadeMethod>
</Class>
