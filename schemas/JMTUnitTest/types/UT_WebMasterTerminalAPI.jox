            "lineNumber": 3,
            "piecesRequested": 0,
            "remarks": "UT_WebMasterTerminalAPI::tGetReleaseRequest"
        },
        {
            "amounts": {
                "loaded": 0.00,
                "packed": 0.00,
                "released": 0.00,
                "remaining": 4.1234,
                "staged": 0.00
            },
            "cargoSubTypeId": "",
            "cargoTypeId": "UTBYV",
            "description": "4.1234 m3 x Unit Test - Bulk By Volume (0 m3 released )",
            "fullyLoaded": false,
            "fullyPacked": false,
            "locations": "",
            "packingType": 1,
            "quantityRequested": 0,
            "stagingComplete": false,
            "volumeRequested": 4.1234,
            "weightRequested": 4.1234,
            "bolId": "",
            "clean": false,
            "heavyDuty": false,
            "isoGroupId": "",
            "isoTypeId": "",
            "lineNumber": 201,
            "piecesRequested": 0,
            "remarks": "UT_WebMasterTerminalAPI::tGetReleaseRequest"
        },
        {
            "amounts": {
                "loaded": 0.00,
                "packed": 0.00,
                "released": 0.00,
                "remaining": 1.0000,
                "staged": 0.00
            },
            "cargoSubTypeId": "LIGNITE",
            "cargoTypeId": "COAL",
            "description": "1 x Lignite (0 released )",
            "fullyLoaded": false,
            "fullyPacked": false,
            "locations": "",
            "packingType": 1,
            "quantityRequested": 1,
            "stagingComplete": false,
            "volumeRequested": 5.1234,
            "weightRequested": 0.00,
            "bolId": "",
            "clean": false,
            "heavyDuty": false,
            "isoGroupId": "",
            "isoTypeId": "",
            "lineNumber": 100,
            "piecesRequested": 0,
            "remarks": "UT_WebMasterTerminalAPI::tGetReleaseRequest"
        }
    ],
    "totalRequested": 33,
    "totalVolumeRequested": 9.2400,
    "totalWeightRequested": 7.2400
}';
vars
	queryParams 		: String;	
	pathParams 			: String;
	releseReq 			: String;
	terminalCode,
	incomingJsonString	: String;
	expectFailure 		: Boolean;
	operator 			: CM_Operator;
	vessel 				: CM_Vessel;
	voyage				: CM_Voyage;
	dischargePort 		: CM_Port;
	ti 					: CM_TrackedItem;
	response			: String;
	pxyReleaseRequest,
	realReleaseRequest	: CM_BulkRelease;
	requestedDateTime	: TimeStamp;
	pxyReserveSelection	: CM_ReserveSelection;
	cargoType			: CM_CargoType;
	isoType				: CM_ISOType;
	isoTypeGroup		: CM_ISOTypeGroup;
	subType				: CM_Product;
	matches				: JadeRegexResult;
	expectedResponse	: String;
	terminal			: CM_Terminal;
	booking				: CM_BookingRef;//TFS 65419
begin
	// create a release request to test that it works
	self.setTerminalConfig(IsSubTerminalsOn, false);
	
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	self.assertNotNullMsg(terminalCode, "Terminal Code not set in Unit Test Profile");
	terminal := app.myRoot.allTerminals[terminalCode];
	self.assertNotNullMsg(terminal, terminalCode &amp; " Terminal not found");
	
	self.deleteCargo(CargoItem, "CONT");
	self.deleteReleaseRequest(ReleaseReqTwo);
	self.deleteReleaseRequest(ReleaseReqOne);
	self.deleteReleaseRequest(ReleaseReqThree);
	self.deleteVessel(UTVessel);
	self.deleteVoyage(UTVoyage);
	self.deleteBooking(UTBookingRef);//TFS 65419
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "Operator not found");
	
	// create the vessel and voyage
	vessel := addVesselCellular(UTVessel,operator);
	self.assertTrueMsg(vessel &lt;&gt; null, "No Vessel Created");
	voyage := addVoyageWithContainerStructur(UTVoyage, UTVessel, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertTrueMsg(voyage &lt;&gt; null, "No Voyage Created");
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;
	
	//Create Booking 																																							//TFS 65419
	booking := self.addBookingForContainer(UTBookingRef, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), voyage, dischargePort.code, "2200", "MT");	//TFS 65419
	assertNotNull(booking);																																						//TFS 65419
	
	ti := self.addContainerForExport(CargoItem, operator, "2200", "MT", TI_IMEX_STATUS_EXPORT, null, voyage.code, dischargePort.code, null).CM_Container;
	self.assertNotNullMsg(ti, " TrackedItem Created");
	
	/* Test One handle not finding the release request */
	releseReq := ReleaseReqOne;
	queryParams := "?MasterTerminalAPI";
	pathParams := "/"&amp;releseReq&amp;"/2023-03-22T10:00:00Z/";
	self.opts.purge();
	//self.opts.addAssoc("ExpectedResponse", "Code :85496. The Release Request ("&amp;releseReq&amp;") could not be found.");
	self.opts.addAssoc("ExpectedResponse", "Code :" &amp; Bulk_Release_Not_Found.asStringJMT &amp; ". " &amp; app.getErrorString1(Bulk_Release_Not_Found, releseReq));
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTGetReleaseRequest.name, queryParams, pathParams, response);
	
	/* Test Two should find the release request */
	releseReq := ReleaseReqTwo;
	queryParams := "?MasterTerminalAPI";
	pathParams := "/"&amp;releseReq&amp;"/"&amp;ReqDateEpoch.String&amp;"/";
	incomingJsonString := ReleaseById;
	expectFailure := false;
	self.opts.purge();
	// create the release request
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostReleaseRequest.name, incomingJsonString, expectFailure);
	requestedDateTime.setFromUnixEpoch(ReqDateEpoch);
	realReleaseRequest := terminal.getBulkReleaseActiveFromCode(ReleaseReqTwo, BR_TYPE_ROAD);
	self.assertNotNullMsg(realReleaseRequest, "Release Request " &amp; ReleaseReqTwo &amp; " not created");
	// call the getReleaseRequest
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTGetReleaseRequest.name, queryParams, pathParams, response);
	expectedResponse := ReleaseByIdResponse;
	expectedResponse := expectedResponse.replaceAll_regex("\r*\n[ ]*|(?&lt;=\:)[ ]", "", true);	// minimise
	expectedResponse := expectedResponse.replace('"pinNo":"&lt;REPLACEME&gt;",', '"pinNo":"' &amp; realReleaseRequest.getPinNumber() &amp; '",');
	self.assertEqualMsg(response, expectedResponse, "GET /ReleaseRequest By Id");
	
	// Test By-Type
	requestedDateTime.setDateTime(2024, 07, 25, 16, 13, 0, 0);
	create pxyReleaseRequest transient;
	pxyReleaseRequest.setProxyBasic(ReleaseReqThree, BR_TYPE_ROAD, true, BR_ACTIVE, terminal, operator, voyage, requestedDateTime, null);

	// ISO Container (isoTypeId)
	cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr("CONT");
	self.assertNotNullMsg(cargoType, "CONT Cargo Type not found");
	isoType := app.myRoot.allISOTypes["2200"];
	self.assertNotNullMsg(isoType, "2200 ISO Type not found");
	isoTypeGroup := app.myRoot.allISOTypeGroups["GEN2"];
	self.assertNotNullMsg(isoTypeGroup, "GEN2 ISO Type Group not found");
	create pxyReserveSelection transient;
	pxyReleaseRequest.allReserveDetails.add(pxyReserveSelection);
	pxyReserveSelection.setProxyFromRestAPI(cargoType, null, isoType, isoTypeGroup, null, method.qualifiedName, 1, 0, true, true, 0, 0, 0, false);
	pxyReserveSelection.setLineNumber(1);
	
	// Break-Bulk (pieces)
	cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr("UT_BB_GC");
	self.assertNotNullMsg(cargoType, "UT_BB_GC Cargo Type not found");
	create pxyReserveSelection transient;
	pxyReleaseRequest.allReserveDetails.add(pxyReserveSelection);
	pxyReserveSelection.setProxyFromRestAPI(cargoType, null, null, null, null, method.qualifiedName, 1, 10, false, false, 0, 0, 0, false);
	pxyReserveSelection.setLineNumber(2);
	
	// Break/Bulk By Quantity
	cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr("UTBYQ");
	self.assertNotNullMsg(cargoType, "UTBYQ Cargo Type not found");
	create pxyReserveSelection transient;
	pxyReleaseRequest.allReserveDetails.add(pxyReserveSelection);
	pxyReserveSelection.setProxyFromRestAPI(cargoType, null, null, null, null, method.qualifiedName, 30, 0, false, false, 0, 0, 0, false);
	pxyReserveSelection.setLineNumber(200);
	
	// Break/Bulk By Weight
	cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr("UTBYW");
	self.assertNotNullMsg(cargoType, "UTBYW Cargo Type not found");
	create pxyReserveSelection transient;
	pxyReleaseRequest.allReserveDetails.add(pxyReserveSelection);
	pxyReserveSelection.setProxyFromRestAPI(cargoType, null, null, null, null, method.qualifiedName, 1, 0, false, false, 0, 3.1234.Decimal, 3.1234.Decimal, false);
	pxyReserveSelection.setLineNumber(3);
	
	// Break/Bulk By Volume
	cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr("UTBYV");
	self.assertNotNullMsg(cargoType, "UTBYV Cargo Type not found");
	create pxyReserveSelection transient;
	pxyReleaseRequest.allReserveDetails.add(pxyReserveSelection);
	pxyReserveSelection.setProxyFromRestAPI(cargoType, null, null, null, null, method.qualifiedName, 1, 0, false, false, 4.1234.Decimal, 0, 0, false);
	pxyReserveSelection.setLineNumber(201);
	
	// Cargo Sub Type
	cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr("COAL");
	self.assertNotNullMsg(cargoType, "COAL Cargo Type not found");
	subType := cargoType.allProducts[null, "LIGNITE"];
	self.assertNotNullMsg(subType, "Lignite Cargo Subtype not found");
	create pxyReserveSelection transient;
	pxyReleaseRequest.allReserveDetails.add(pxyReserveSelection);
	pxyReserveSelection.setProxyFromRestAPI(cargoType, null, null, null, subType, method.qualifiedName, 1, 0, false, false, 5.1234.Decimal, 0, 0, false);
	pxyReserveSelection.setLineNumber(100);
	
	app.myTrxCA.trxCreateBulkRelease(pxyReleaseRequest, realReleaseRequest, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realReleaseRequest, "(Real) Release Request");
	self.assertEqualMsg(realReleaseRequest.allReserveDetails.size, 6, "Release Request Reserve Selections");
	
	queryParams := "?MasterTerminalAPI";
	pathParams := "/"&amp;ReleaseReqThree&amp;"/"&amp;requestedDateTime.asEpochFormat().String&amp;"/";
	self.opts.purge();
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTGetReleaseRequest.name, queryParams, pathParams, response);
	self.assertNotNullMsg(response, "GET /ReleaseRequest returned an empty response");
	
	expectedResponse := ReleaseByTypeResponse;
	expectedResponse := expectedResponse.replaceAll_regex("\r*\n[ ]*|(?&lt;=\:)[ ]", "", true);	// minimise
	expectedResponse := expectedResponse.replace('"requestDateTime":"&lt;REPLACEME&gt;",', '"requestDateTime":"' &amp; requestedDateTime.localToUTCTime.asJSONFormat &amp; '",');
	expectedResponse := expectedResponse.replace('"pinNo":"&lt;REPLACEME&gt;",', '"pinNo":"' &amp; realReleaseRequest.getPinNumber() &amp; '",');
	self.assertEqualMsg(response, expectedResponse, "GET /ReleaseRequest By Type");
	
	// TODO: Test various values from 'amounts'
	// TODO: Other boolean values, fullyLoaded/Packed/stagingComplete
	
epilog
	delete pxyReserveSelection;
	delete pxyReleaseRequest;
	delete matches;
end;</source>
    </JadeMethod>
    <JadeMethod name="tGetVoyage" id="574fef53-de8c-45ba-8392-245b5c335c60">
        <updating/>
        <source>tGetVoyage() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
12 December 2023	navlw1	CR 57278[Task:61566] : 57278 CUX - Process Voyage - Get Voyage UnitTest
