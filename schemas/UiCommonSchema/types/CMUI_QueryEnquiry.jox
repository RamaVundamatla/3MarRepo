    <JadeMethod name="doMnuRemarks" id="9a4e78a9-d137-43be-9d00-66eeed2aaf9a">
        <source>doMnuRemarks(_obj : CM_Object);
//--------------------------------------------------
// Created:	12 December 2003 By: cnwgd1
//--------------------------------------------------
vars
	remarksFrm	: CMUI_Remarks;
	anObject : CM_Object;
begin
	if _obj = null then
		return;
	endif;
	// Update the navigator
	create remarksFrm;
	self.setNavigatorHeading(remarksFrm.caption); 
	remarksFrm.centreWindow;
	remarksFrm.myCurrentObject := _obj;
	remarksFrm.setMyTerminal(self.myTerminal);
	remarksFrm.showModal;

end;</source>
