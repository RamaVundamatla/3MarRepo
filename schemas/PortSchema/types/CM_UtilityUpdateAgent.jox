    <JadeMethod name="utlUpdatePINEmail" id="f2c4d380-5cef-45c3-a970-f7b7527d301a">
        <updating/>
        <source>utlUpdatePINEmail(pProxyPINEmail:CM_PINObjectDefaultEmail; _passport : CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	23 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	cancelSave			: Boolean;
	realPINEmail		: CM_PINObjectDefaultEmail;
	expectedEdition		: Integer;
	
begin

	self.initialiseActivity();

	pProxyPINEmail.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyPINEmail.pxyGetRealObjectAndEdition(realPINEmail, expectedEdition);
	
	if realPINEmail = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_PINObjectDefaultEmail.name, null, null);
		return;
	endif;

	app.myValUA.valPINEmail(realPINEmail, pProxyPINEmail);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realPINEmail);

	if _passport.noErrors and realPINEmail.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Carrier PIN Email', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realPINEmail, true);
	endif;
	
	if _passport.noErrors then
		realPINEmail.setForUpdate(pProxyPINEmail);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realPINEmail, false);
	endif;
epilog	
	
end;</source>
        <Parameter name="pProxyPINEmail" type="CM_PINObjectDefaultEmail"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdatePackCargo" id="d97cbbf6-f1eb-4bc9-b3c8-9726e1f53908">
        <updating/>
        <source>utlUpdatePackCargo(	_parentCargo 			: CM_TrackedItem input;
					_packCargo 				: CM_TrackedItem io;
					_packQuantity 			: Integer;
					_packWeight 			: Decimal;
					_packRelease 			: CM_BulkRelease input; 		//epr TFS 2897 5/12/16
					_packReserve 			: CM_ReserveDetail input;		//20 Mar 2017	NDL	TFS 3667
					_updateParentCommodity	: Boolean; 						//jler1 TFS 51879 13/9/21
					_retroDT				: TimeStamp;
					_passport 				: CM_Passport input) updating;
/*

Date		Who		Reason
30/06/2014	cnwer1	Initial creation PAR 34472
11/11/2019	jlgdap1	TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
13/09/2021	jlier1	TFS 51879 - updating parent commodity after pack
31/08/222   navma1	31 Aug 2022 namva1	Bug 54297: MTN - Pack Work Order issues
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
22/08/2023	navma1  ChangeRequest 59121: EUP | Handle Work orders Packing By Type
07/08/2023 	navhl20 ChangeRequest 59121: EUP | Handle Work orders Packing  By Type
19 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
19 Aug 2024 navhl20	ChangeRequest 65650: FR | 54177 - Retrospective Operations - Packing
*/

vars
	pxyPackCargo,
	pxyParentCargo 		: CM_TrackedItem;
	tmpStr 				: String;	
	tiUpdateCntrlr		: CMIF_TIUpdateController;	
	moveController 		: CMIF_MoveController;
	packVolume,
	packWeight 			: Decimal[14,4];
	checkAssign 		: Boolean;
	wle					: CM_WorkListEntry;
	packCargoVoyage,
	parentVoyage		: CM_Voyage;
	packRequest			: CM_WOPackRequest;
begin
	self.initialiseActivity();
	
	if _parentCargo = null then
		app.raiseCMException(No_Pack_Container,  null, null);
		return;
	endif;
	
	if _packCargo = null then
		app.raiseCMException(No_Cargo_To_Pack,  null, null);
		return;
	endif;	
	
	packCargoVoyage := _packCargo.myVoyage;
	parentVoyage    := _parentCargo.myVoyage;
	
	if _packCargo =  _parentCargo then
		app.raiseCMException(Cannot_pack_cargo_inside_itsel, null, null);
		return;
	endif;	
	
	if _parentCargo.allChildren.includes(_packCargo) then
		app.raiseCMException2(ObjectAlreadyInCollection, _packCargo.id, _parentCargo.id,  'allChildren', _parentCargo);
		return;
	endif;
	
	if _packQuantity &lt;&gt; null and _packQuantity &gt; _packCargo.totalQuantity then
		app.raiseCMException3(Quantity_greater_than_cargo,"Pack",_packQuantity.asStringJMT, _packCargo.totalQuantity.asStringJMT,null,null);
		return;
	endif;
	
	if _packWeight &lt;&gt; null and _packWeight &gt; _packCargo.totalWeight then
		app.raiseCMException3(Weigh_greater_than_cargo,"Pack",_packWeight.asStringJMT,_packCargo.totalWeight.asStringJMT,null,null);
		return;
	endif;
	
	// TFS 46405 If packing flat racks to a flat rack, ends must be down on parent and child
	if _parentCargo.isFlat and _packCargo.isFlat then
		if _parentCargo.CM_Container.doorsDirn = TI_DOORSDIRN_ENDUP then
			app.raiseCMException4(Cannot_Pack_Into_Flat, _packCargo.id, _parentCargo.id, _parentCargo.id, app.getErrorString(Ends_Up), null, null);
			return;
		elseif _packCargo.CM_Container.doorsDirn = TI_DOORSDIRN_ENDUP then
			app.raiseCMException4(Cannot_Pack_Into_Flat, _packCargo.id, _parentCargo.id, _packCargo.id, app.getErrorString(Ends_Up), null, null);
			return;
		endif;
	endif;
	// TFS 46405 end
	
	if _passport.hasErrors() then
		return;
	endif;	
	
	app.setContinueCMExceptions(true);
	
	exclusiveLock(_parentCargo);
	
	app.myValUA.valPackBulkRelease(_parentCargo); 			// &lt;&lt;&lt; ### CCMS 1288 AKB2005APR

	if not self.checkValidationWithPassport(_passport) then	// &lt;&lt;&lt; ### CCMS 1288 AKB2005APR
		return;
	endif;
	
	if not packCargoVoyage.isNullVoyage then        		// 33622 
		if parentVoyage &lt;&gt; packCargoVoyage then
			if packCargoVoyage &lt;&gt; null then
				 app.raiseCMException2(Not_marked_voyage, _packCargo.id, parentVoyage.code,null,null);
			else
				app.raiseCMException2(Marked_voyage, _packCargo.id, packCargoVoyage.code,null,null);
			endif;
		endif;
		
		if _parentCargo.dischargePort &lt;&gt; _packCargo.dischargePort then
			if _parentCargo.dischargePort &lt;&gt; null then
				app.raiseCMException2(Not_marked_discharge, _packCargo.id,  _parentCargo.dischargePort,null,null);
			else
				app.raiseCMException2(Marked_discharge, _packCargo.id, _packCargo.dischargePort,null,null);
			endif;	
		endif;
	endif;
	
	if _packCargo.myBookingRef &lt;&gt; null then							//child ti has a booking
		if _packCargo.myBookingRef.isStockBookingRef then				//child ti is stock booking
			if _parentCargo.myBookingRef &lt;&gt; null and not _parentCargo.myBookingRef.isStockBookingRef then
				if _packCargo.myBookingRefItem = null or not _packCargo.myBookingRefItem.allLinkedExportBookings.includes( _parentCargo.myBookingRef ) then
					app.raiseCMException(CargoNotPartExBook,null,null);
				endif;
			endif;
		endif;
	endif;
	
	if (not _packCargo.isKindOf(CM_BreakBulkGeneric))  // PAR 18162
		and _packCargo.myOperator &lt;&gt; _parentCargo.myOperator
		then
		tmpStr := app.getTerminologyAlternate(_parentCargo.myCargoType, _passport.myTerminal, CM_TerminologyOperator, CM_TermExpressionSingular, 'Operator');
	
		app.raiseCMWarning2(WARN_CHILD_OP_DIFF,tmpStr,_packCargo.id &amp; ' (' &amp; _packCargo.myOperator.code &amp; ').',null,null,_parentCargo);	
	endif;
	
	if _packCargo.isTranshipItem and packCargoVoyage &lt;&gt; parentVoyage then
		app.raiseCMWarning2(WARN_CHILD_OP_DIFF, app.getErrorString(Voyage),  _packCargo.id &amp; ' (' &amp; packCargoVoyage.code  &amp; ').', null, null, _parentCargo);
	endif;
	
	app.setContinueCMExceptions(false);
	
	if _passport.hasErrors() then
		return;
	endif;	
	
	packWeight	:= _packCargo.totalWeight;
	packVolume	:= _packCargo.getMyTotalVolume;
	
	if _packCargo.myCargoType.isBreakBulkMulti or _packCargo.myCargoType.isBulkMulti then
		//this cargo could of been merged when unpacked so get weight from passed in quantity/weight
		if _packCargo.myCargoType.isBulkMulti then
			if _packWeight &lt;&gt; null then
				packWeight:= _packWeight;
			else
				packWeight:=_packCargo.totalWeight;
			endif;
			if _packCargo.myCargoType.isBulkByWeight then
				packVolume:=_packCargo.totalVolume;
			else
				packVolume:=packWeight/_packCargo.getDensity;
			endif;
		else
			if _packQuantity &lt;&gt; null then
				packWeight:=(_packQuantity/ _packCargo.totalQuantity) * _packCargo.totalWeight;
				packVolume:=(_packQuantity/ _packCargo.totalQuantity) * _packCargo.getMyTotalVolume;
			else
				packWeight:=_packCargo.totalWeight;
				packVolume:=_packCargo.getMyTotalVolume;
			endif;	
		endif;	
	endif;
	
	create moveController transient;
	//31.08.2022 navma1 #54297
	if _packCargo.myTerminal.isUseYardJobsForCargoWo then
		
		/*
		//19.08.2024 navhl20 #65650
		if _packCargo.allWorklistEntries.isEmpty then
			
			if _packReserve &lt;&gt; null and _packReserve.myReserveHeader.releaseByType then
				if not _packReserve.allRequests.isEmpty then
					if _packReserve.allRequests.first.isKindOf(CM_WOPackRequest) then
						packRequest := _packReserve.allRequests.first.CM_WOPackRequest;
						wle := packRequest.hasMatchingWOWLETypeStatus(null,WO_TASK_PACK,WLE_UNACTIONED);
						if wle &lt;&gt; null and wle.isKindOf(CM_WOPackChildWLE) then								//07.9.2023 navhl20 #59121
							moveController.setMyWorkListEntry(wle);
							wle.setMyTrackedItem(_packCargo);
						endif;
					endif;
				endif;
			endif;
			
		else
			foreach wle in _packCargo.allWorklistEntries discreteLock do 
				if not wle.isKindOf(CM_WOPackChildWLE) then
					continue;
				endif;
				if wle.status &lt;&gt; WLE_UNACTIONED then
					continue;
				endif;
				moveController.setMyWorkListEntry(wle);
				break;
			endforeach;
		endif;*/
		
		_packCargo.getUnactionedPackWle(moveController,_packReserve);
	endif;
	
	moveController.setMyTrackedItem(_packCargo);	// this MUST be done before call to setMyOriginatingLocation() below
	moveController.setMyOriginatingLocation(_packCargo.myPrimaryActualLocation);
	moveController.isNoChargeMove := true;
	moveController.setQuantity(_packQuantity);
	moveController.setWeight(_packWeight);
	moveController.isForcedMove:=true;
	moveController.setMyPackToTI(_parentCargo);
	moveController.updatePackToCommodity:=_updateParentCommodity;
	if _retroDT.isValid then										//19.03.2024 navhl20 #62863
		moveController.retrospectiveDT := _retroDT;
	endif;
	//epr TFS 2897 5/12/16
	moveController.setMyPackRelease(_packRelease);
	
	//20 Mar 2017	NDL	TFS 3667
	if _packReserve &lt;&gt; null then
		 moveController.myDocumentActions := _packReserve.myReserveDetailActions;
	endif;
	if app.isCargoGroupEnabled then
		 checkAssign := true;
	endif;
	
	self.utlUpdateMoveTrackedItem(moveController, _passport);
	
	if _passport.hasErrors then
		return;
	endif;
	
	
	_packCargo:=moveController.myTrackedItem;
	
	//20 Mar 2017	NDL	TFS 3667
	if checkAssign and _packReserve &lt;&gt; null then
		//if not _packReserve.allTrackedItems.includes( _packCargo ) then
		if not _packReserve.includeTrackedItem( _packCargo , false) then //23/06/2023	navkc1	CR 58406 Task 58408
			self.utlAddToReserveDetail(_packReserve, _packCargo, _passport);
		endif;
	endif;

epilog
	delete tiUpdateCntrlr;
	delete moveController;
	delete pxyPackCargo;
	delete pxyParentCargo;
end;</source>
        <Parameter name="_parentCargo" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_packCargo" type="CM_TrackedItem" usage="io"/>
        <Parameter name="_packQuantity" type="Integer"/>
        <Parameter name="_packWeight" type="Decimal"/>
        <Parameter name="_packRelease" type="CM_BulkRelease" usage="input"/>
        <Parameter name="_packReserve" type="CM_ReserveDetail" usage="input"/>
        <Parameter name="_updateParentCommodity" type="Boolean"/>
        <Parameter name="_retroDT" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdatePackUnpack" id="cad17e11-62e3-4048-b170-28c055ac3c84">
        <updating/>
        <source>utlUpdatePackUnpack(_theMoveController 	: CMIF_MoveController input;
					_noCharge 			: Boolean;
					_thePackTIs, 
					_theUnpackTIs 		: CM_TIArray;
					_unpackFromRelease	: Boolean;
					_pxyParentTI 		: CM_TrackedItem input;
					_updateMode 		: Integer;
					_passport 			: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  CNWTH2Reason
// ----------   ----------  --------------------------------------------------
// 17/02/2011	cnwdap1		PAR #27048 If child is Tranship, warn if voyages are different
// 05/08/2011	cnwdap1		PAR #27965 Move fleet file max weight valdiation to after the
//							parent has been packed / unpacked
// 22/07/2013	cnwdap1		PAR #31196 new parameter for setTranship method, cater for tranships
//							by changing child and/or parent IMEX status if necessary
// 22/07/2014	cnwma1	 	PAR# 34021 Clearing all load information following unpack
// 07/04/2015	cnwdap1		PAR #35823 Tranship children were overwriting their Storage parent's export booking 
//							with their stock booking - prevent this from happening
// 20/10/2015   cnwma1      PAR #36791 Task not added to container when Unpacked
// 3/11/2015    cnwma1		PAR #37114 Survey task not being added HF 26
// 23 Oct 2019	jlgsl4		TFS 46767 - PEN - GenSet Trailer Linking
// 11/11/2019	jlgdap1		TFS 46405 AA Flat Rack and OOG in LOLO Planning Screen
// 20/11/2019	jlgzm1		TFS 47222 Remove All Import stops is redundant
// ---------------------------------------------------------------------------

vars
	brTIs,
	theTISetAFTERPackItemsAdded,
 	deleteSet						: CM_TISet;
	idx,
	expectedEdition					: Integer;
	theTransactionController 		: CMIF_PackTransController;
	realContainer,
	childTI,
	packTI,
	pxyChildTI						: CM_TrackedItem; 
	saveForcedMoveValue,
	isNowEmpty 						: Boolean;
	tmpPackTILocations				: CM_LCArray;
	strCode,strOp,tmpStr 			: String;
	oldBR, newBR					: CM_BulkRelease;
	strVoyage						: String;			// PAR #27048
	tiUpdateCntrlr					: CMIF_TIUpdateController;		// PAR #31196
	parentToTranship				: Boolean;						// PAR #31196
	transhipChild					: CM_TrackedItem;				// PAR #31196
	transhipInterface				: CMIF_TranshipTIController;	// PAR #31196
	childBooking					: CM_BookingRef;				// PAR #35823
	parentBooking					: CM_BookingRef;				// PAR #35823
	setParentFromChild : Boolean;

begin
	self.initialiseActivity();
	
	if _theMoveController = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_theMoveController', null, null);
		return;
	endif;
	
	if _pxyParentTI = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_pxyParentTI', null, null);
		return;
	endif;
	
	if _thePackTIs = null and _theUnpackTIs = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'TIs to pack and/or unpack', null, null);
		return;
	endif;	
	
	_pxyParentTI.raiseExceptionIfNotProxy(method);
	_pxyParentTI.pxyGetRealObjectAndEdition(realContainer, expectedEdition);
	
	if _passport.hasErrors() then
		return;
	endif;	
	//Should include its original children collection prior to adding and removing packs and unpacks.	
	exclusiveLock(realContainer);

	if _passport.hasErrors() then
		return;
	endif;
	
	if realContainer.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'user', null, null);
		return;
	endif;
	
	//29 Apr 2015	NDL	Par 36111
	setParentFromChild := realContainer.allChildren.isEmptyOrContainsOnlyEquipment and realContainer.isStorage and not _thePackTIs.isEmpty;
	
	//cnwmc5 - 14 Sep 2015 - PAR 36891 (CCMS 2535)
	_pxyParentTI.setSpecialStowFromPackChild(_thePackTIs.first);
	
	app.myValUA.valPackBulkRelease(_pxyParentTI); // &lt;&lt;&lt; ### CCMS 1288 AKB2005APR
	
		// Getting old release request. #26529 05/01/2011
	oldBR := realContainer.allBulkReleasesAssigned.getAtKeyGeq(BR_TYPE_PACKING, null, null, null);
	if oldBR = null then
		oldBR := realContainer.allBulkReleasesReleased.getAtKeyGeq(BR_TYPE_PACKING, null, null, null);
	endif;

	if not self.checkValidationWithPassport(_passport) then// &lt;&lt;&lt; ### CCMS 1288 AKB2005APR
		return;
	endif;

	// PAR 9753
	foreach packTI in _thePackTIs discreteLock do 
		//cnwmc5 - 3 Dec 2015 - PAR 37213 - this is done later on.....
		//+cnwml2 PAR25330
		//if packTI.bookingReference = _pxyParentTI.bookingReference then
		//	packTI.setBookingReference(null);
		//endif;	
		
		if (not packTI.isKindOf(CM_BreakBulkGeneric))  // PAR 18162
		and packTI.myOperator &lt;&gt; _pxyParentTI.myOperator
		then
			if packTI.myOperator &lt;&gt; null then 
				strCode := packTI.myOperator.code;
			endif;
			strOp := strOp &amp; packTI.id &amp; ' (' &amp; strCode &amp; ')' &amp; ', ';
		endif;
		
		// PAR #27048 Check voyages match if child is a tranship
		if packTI.isTranshipItem and packTI.myVoyage &lt;&gt; _pxyParentTI.myVoyage then
			strCode := packTI.myVoyage.code;
			strVoyage := strVoyage &amp; packTI.id &amp; ' (' &amp; strCode  &amp; '), ';
		endif;
		
		// TFS 46405 If packing flat racks to a flat rack, ends must be down on parent and child
		if _pxyParentTI.isFlat and packTI.isFlat and _pxyParentTI.CM_Container.doorsDirn = TI_DOORSDIRN_ENDUP then
			app.raiseCMException4(Cannot_Pack_Into_Flat, packTI.id, _pxyParentTI.id, _pxyParentTI.id, app.getErrorString(Ends_Up), null, null);
		elseif _pxyParentTI.isFlat and packTI.isFlat and packTI.CM_Container.doorsDirn = TI_DOORSDIRN_ENDUP then
			app.raiseCMException4(Cannot_Pack_Into_Flat, packTI.id, _pxyParentTI.id, packTI.id, app.getErrorString(Ends_Up), null, null);
		endif;
		// TFS 46405 end
	endforeach;
	
	if  strOp  &lt;&gt; null then
		// op of one of children is diff so raise warning.
		strOp := strOp[1:(strOp.length -2)]; // take of last comma. 

		tmpStr := app.getTerminologyAlternate(_pxyParentTI.myCargoType, _passport.myTerminal, CM_TerminologyOperator, CM_TermExpressionSingular, 'Operator');
		app.raiseCMWarning2(WARN_CHILD_OP_DIFF,tmpStr,strOp &amp; '.',null,null,_pxyParentTI);	
	endif;	
	// PAR 9753 - end
	
	// PAR #27048 raise warning if any tranship children voyages differ from parent voyage
	if strVoyage &lt;&gt; null then
		strVoyage := strVoyage[1:(strVoyage.length -2)]; // take off last comma
		tmpStr := app.getErrorString(Voyage);
		app.raiseCMWarning2(WARN_CHILD_OP_DIFF, tmpStr, strVoyage &amp; '.', null, null, _pxyParentTI);
	endif;
	
	saveForcedMoveValue := _theMoveController.isForcedMove;
	// ensure this is set correctly as this is required or you get an
	// error with the child not being in the originating location
	// when you try to move it
	_theMoveController.isForcedMove := true;

	//We want to get a collection of the child first. This is used to check against which TIs already existed as children prior to adding _thePackTIs 
	//The check for unpack is done above
	create deleteSet transient;
	//Done this way as the _pxyParentTI.setChildrenForCreate detaches the children before attaching the passed in ones.
	create theTISetAFTERPackItemsAdded transient;
	_pxyParentTI.allChildren.copy(theTISetAFTERPackItemsAdded); //cnwsh3 - PAR25103 - allChildren collection has been unprotected reversing the need for changes from PAR22954
	//children.copy(theTISetAFTERPackItemsAdded);//PAR 22954

	// PAR #31196 If parent container is a tranship, there are rules for packing and unpacking				// PAR #31196
	// Packing into a Tranship parent:																		// PAR #31196
	// 1. If a Tranship item is packed in to a Storage container, the container's 							// PAR #31196
	//	  IMEX status will change to Tranship, and the Tranship details from the Tranship 					// PAR #31196
	//	  item will be copied to the container.																// PAR #31196
	// 2. If a Tranship item is packed in to an Export container,the Tranship's IMEX status will be 		// PAR #31196
	//	  changed to Export.																				// PAR #31196
	// 3. If an Import or Storage item is packed in to a Tranship container, 								// PAR #31196
	//	  the item's IMEX status will change to Export.														// PAR #31196
	foreach childTI in _thePackTIs do 																		// PAR #31196
		if childTI.isTranshipItem then																		// PAR #31196
			if realContainer.isStorage then																	// PAR #31196
				// 1. Tranship child packed in to Storage parent											// PAR #31196
				parentToTranship := true;																	// PAR #31196
				transhipChild := childTI;																	// PAR #31196
			elseif realContainer.isExport then																// PAR #31196
				// 2. Tranship child packed in Export parent												// PAR #31196
				pxyChildTI := childTI.pxyGetProxyObject;													// PAR #31196
				if pxyChildTI = null then																	// PAR #31196
					pxyChildTI := app.createUpdateProxy(childTI	).CM_TrackedItem;							// PAR #31196
					deleteSet.add(pxyChildTI);																// PAR #31196
				endif;																						// PAR #31196
				pxyChildTI.zSetPxyImexStatus(TI_IMEX_STATUS_EXPORT);										// PAR #31196
				pxyChildTI.zSetPxyRemarks(null);															// PAR #31196
				pxyChildTI.zSetImportVoyage(null);															// PAR #31196
				tiUpdateCntrlr := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);	// PAR #31196
				childTI.setTranshipToNonTranship(pxyChildTI, tiUpdateCntrlr, _passport);					// PAR #31196
				delete tiUpdateCntrlr;																		// PAR #31196
			endif;																							// PAR #31196
		elseif childTI.isImport or childTI.isStorage then													// PAR #31196
			// 3. Import or Storage child packed in to Tranship parent										// PAR #31196
			if realContainer.isTranshipItem then															// PAR #31196
				// change child to Export - use statusEvent instead of setImExStatus to get edit transaction// PAR #31196
				if childTI.myVoyage = childTI.myTerminal.getNullVoyage then									// PAR #31196
					childTI.changeVoyage(realContainer.myVoyage, _passport);								// PAR #31196
				endif;																						// PAR #31196
				childTI.statusEvent(VOYAGE_STATUS_EV, true, _passport);										// PAR #31196
			endif;																							// PAR #31196
		endif;																								// PAR #31196
	endforeach;																								// PAR #31196
		
	if _thePackTIs &lt;&gt; null then
		create tmpPackTILocations transient;
		
		foreach childTI in _thePackTIs do
			if realContainer.allChildren.includes(childTI) then //cnwsh3 - PAR25103 - allChildren collection has been unprotected reversing the need for changes from PAR22954
			//if realContainer.hasChild(childTI) then//PAR 22954
				app.raiseCMException2(ObjectAlreadyInCollection, childTI.id, realContainer.id,  'allChildren', realContainer);
			else
				
				//thePackTIs and unPackTIs need to have children created so a transient can be added to the pxy's allChildren collection.
				pxyChildTI := childTI.pxyGetProxyObject();
				if pxyChildTI = null then
					pxyChildTI := childTI.pxyCreateUpdateProxy();
					// Par 13965
					deleteSet.add(pxyChildTI);
				endif;
				
				pxyChildTI.zSetPxyLocationId(realContainer.locationId);
				if not theTISetAFTERPackItemsAdded.includes(pxyChildTI) then
					theTISetAFTERPackItemsAdded.add(pxyChildTI);
				endif;
				
				// this should add this location into the same index
				// of the array as it is in _thePackTIs.  We save this
				// away for later
				tmpPackTILocations.add(childTI.myPrimaryActualLocation);
			endif;
		endforeach;	
	endif;

	//_theUnpackTIs must exist in the realContainer collection otherwise we can't remove it.  	
	if _theUnpackTIs &lt;&gt; null then
	
		foreach childTI in _theUnpackTIs do
			if not realContainer.allChildren.includes(childTI) then //cnwsh3 - PAR25103 - allChildren collection has been unprotected reversing the need for changes from PAR22954
			//if not realContainer.hasChild(childTI) then//PAR 22954
				 app.raiseCMException2(ObjectNotFoundInCollection, childTI.id, realContainer.id,'allChildren',null);
			else
				//we now want to remove the unpack tis from the allChildren collection.
				pxyChildTI := childTI.pxyGetProxyObject();
				if pxyChildTI &lt;&gt; null then
					if theTISetAFTERPackItemsAdded.includes(pxyChildTI) then
						theTISetAFTERPackItemsAdded.remove(pxyChildTI);
					endif;
				endif;
				childTI.setUnpackedDT(app.actualTimeServer);		//+cnwml2 PAR23062
			endif;
		endforeach;
		
		if not _theUnpackTIs.isEmpty() then 
			_pxyParentTI.setTotalWeightSetFlag(false);
			// we are taking out child or adding so need to reset this flag (if set) so total weight will change
		endif;
	endif;
	
	//hadChildren := (_pxyParentTI.allChildren.size &gt; 0);	// 35362 test children directly and test moved up before changing the proxy  -// 20/10/2015 cnwma1 PAR #36791
	//hadChildren := (realContainer.allChildren.size &gt; 0);	// 20/10/2015 cnwma1 PAR #36791
	//Update the children in the _pxyParentTI to include the new packItems.  	
	_pxyParentTI.setChildrenForCreate(theTISetAFTERPackItemsAdded, _passport);	//_pxyParentTI.setTotalQVW();  // dh 13/5/2008 for ccms 1618 - added this line
	
	//28 Nov 2011	NDL	Par 28740 - moved up ahead of the parent container updating code
	if not _thePackTIs.isEmpty then
		newBR := _pxyParentTI.allBulkReleasesAssigned.getAtKeyGeq(BR_TYPE_PACKING, null, null, null);
		if newBR &lt;&gt; null then
			if newBR.myTerminal.getConfig(OnlyPackAssignedItems).Boolean then // rjs - change to use correct terminal
				foreach packTI in _thePackTIs discreteLock do
					if not packTI.allBulkReleasesAssigned.includes(newBR) then
						app.raiseCMWarning2(Not_Assigned_To_PR, packTI.id, newBR.code, null, null, null);
					endif;
				endforeach;
			endif;
		endif;
	endif;
	
	// ### JIRA 33744 21JAN2025 NAVAB1 - for the items being unpacked see if the storage configuration has any triggers
	if _theUnpackTIs &lt;&gt; null then
		tiUpdateCntrlr := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);	 
		
		foreach childTI in _theUnpackTIs do
			pxyChildTI := childTI.pxyGetProxyObject();
			pxyChildTI.pxySetMyParent(null);
			childTI.setForUpdateStorage(pxyChildTI,tiUpdateCntrlr , app.myPassport); 
		endforeach;
		delete tiUpdateCntrlr; 
	endif;
	
	///update the container 
	self.utlUpdateTrackedItem(_pxyParentTI, null, _updateMode, null, null, null, _passport);//cnwrd1 28.8.09 par 20545
	
	// PAR #31196 Convert parent to tranship if required - don't do this if we had any errors or warnings,	// PAR #31196
	// otherwise we'll end up with a transhipped proxy the next time we come through here					// PAR #31196
	if _passport.noErrors and (_passport.noWarnings or _passport.warningsAcknowledged) then					// PAR #31196
		if parentToTranship then																			// PAR #31196
			// copy tranship details from child to parent													// PAR #31196
			create transhipInterface transient;																// PAR #31196
			transhipInterface.myExportDestPort 	:= app.myRoot.allPorts[transhipChild.destinationPort];		// PAR #31196
			// TFS 2122 add null test
			if transhipChild.myTranshipDetail &lt;&gt; null then
				transhipInterface.myExportDisPort	:= transhipChild.myTranshipDetail.myDischargePort;		// PAR #31196
			endif;
			transhipInterface.myExportVoyage	:= transhipChild.myExportVoyage;							// PAR #31196
			transhipInterface.myTranshipToPort	:= transhipChild.myTranshipToPort;							// PAR #31196
			transhipInterface.remarks			:= transhipChild.remarksTranship;							// PAR #31196
			childBooking := transhipChild.myBookingRef;																		// PAR #35823
			parentBooking := realContainer.myBookingRef;																	// PAR #35823
			if parentBooking &lt;&gt; null and parentBooking.isExportBooking and childBooking &lt;&gt; null and childBooking.isStockBookingRef then	// PAR #35823
			else																											// PAR #35823
			// TFS 2122 add null test
				if transhipChild.myTranshipDetail &lt;&gt; null then
					transhipInterface.bookingRef	:= transhipChild.myTranshipDetail.exportBookingReference;	// PAR #31196	// PAR #35823
					transhipInterface.billOfLading	:= transhipChild.myTranshipDetail.exportBOL;				// PAR #31196	// PAR #35823
				endif;
			endif;																											// PAR #35823
			_pxyParentTI.setPxyFromCMIF_TranShip(transhipInterface, realContainer);							// PAR #31196
			realContainer.setMyVoyage(transhipChild.myImportVoyage, _passport);								// PAR #31196
			realContainer.setTranship(_pxyParentTI, _passport, true);										// PAR #31196 // TFS 47222
			delete transhipInterface;																		// PAR #31196
		endif;																								// PAR #31196
																											// PAR #31196
		// Unpacking from a Tranship parent:																// PAR #31196
		// 1. If all items are unpacked from a Tranship container, un-tranship it and make it Storage		// PAR #31196
		if realContainer.allChildren.isEmpty and not _theUnpackTIs.isEmpty then								// PAR #31196
			if realContainer.isTranshipItem then															// PAR #31196
				_pxyParentTI.zSetPxyImexStatus(TI_IMEX_STATUS_STORAGE);										// PAR #31196
				_pxyParentTI.zSetPxyRemarks(null);															// PAR #31196
				_pxyParentTI.zSetImportVoyage(null);														// PAR #31196
				tiUpdateCntrlr := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);	// PAR #31196
				realContainer.setTranshipToNonTranship(_pxyParentTI, tiUpdateCntrlr, _passport);			// PAR #31196
				realContainer.changeVoyage(realContainer.myTerminal.getNullVoyage, _passport);				// PAR #31196
				delete tiUpdateCntrlr;																		// PAR #31196
			endif;																							// PAR #31196
		endif;																								// PAR #31196
	endif;																									// PAR #31196
	
	// PAR #27965 NOW that the parent has its children updated, check the fleet file max weight
	// the real container at this point has had its weight changed, not the proxy
	if realContainer.myTiMaster &lt;&gt; null and realContainer.myTiMaster.isKindOf(CM_TIMasterContainer) then
		if realContainer.myTiMaster.CM_TIMasterContainer.maxKilos &gt; 0 and realContainer.totalWeight &gt; realContainer.myTiMaster.CM_TIMasterContainer.maxKilos then // TFS 46767
			//app.raiseCMWarning3(SafeWorkingLimitBreach, realContainer.id, realContainer.totalWeight.asStringMeasurementJMT(), realContainer.myTiMaster.CM_TIMasterContainer.maxKilos.asStringMeasurementJMT, null, null, null);
			//09 Aug 2011	NDL	Par 27902
			if not app.isUnitTestGarbageCollect then
				app.raiseCMException3(SafeWorkingLimitBreach, realContainer.id, realContainer.totalWeight.asStringMeasurementJMT(), realContainer.myTiMaster.CM_TIMasterContainer.maxKilos.asStringMeasurementJMT, null, null);
			endif;
		endif;
	endif;
	// PAR #27965 end
	
	// Commented out 05 July 2015	NDL	Par 36154
	// cnwma1- 18 JULY 2014 - PAR 34021
/*	if(realContainer.allChildren.isEmpty and _pxyParentTI.myReeferProperties &lt;&gt; null) then
		if realContainer.myReeferProperties &lt;&gt; null then
			realContainer.myReeferProperties.erase(NORMAL_ERASE);
		endif;
		if not _passport.noErrors() then
			return;
		endif;
	endif; */
	
	// ### CCMS 1288
	//th2 - 21/09/06 PAR 12564 - entering a bulk release number in the pack/unpack form is failing to attach the container to that release.
	//changed to getAtKey greater or equal - was doing a direcy key look up!? which always failed.
	newBR := _pxyParentTI.allBulkReleasesAssigned.getAtKeyGeq(BR_TYPE_PACKING, null, null, null);
	if newBR = null then
	//	newBR := _pxyParentTI.myBulkReleaseReleased;	// 20/05/2008 cnwar2 #16621
		newBR := _pxyParentTI.allBulkReleasesReleased.getAtKeyGeq(BR_TYPE_PACKING, null, null, null);	// cnwrd1 26.5.09 ccms 1804 -- &gt; type packing??
	endif;												// May be adding to parent which has already been packed


	//#26529 11/01/2011. Need to manage old and new release requests for parent and children when packing/unpacking
	create brTIs transient;
	brTIs.add(realContainer);
	self.utlUpdateTIsBulkReleased(brTIs, _theUnpackTIs, oldBR, newBR, _passport);	// #26529 31/12/2010. Parameters _theUnpackTIs, oldBR, newBR have been added.
	
	if not _passport.noErrors() then
		return;
	endif;

	//hadChildren := (not _pxyParentTI.isEmpty());
	////isNowEmpty := realContainer.isEmpty();
	isNowEmpty := (realContainer.allChildren.size = 0);		// 35362 test children directly
		
	// If we have emptied the box then potentially apply a list of to do tasks to it.
	if  isNowEmpty then										// 3/11/2015 cnwma1 PAR #37114 
		realContainer.assignToDoTasks(true,_passport);
	endif;

	//Need to compare the realContainer.allChildren as they are the real objects in the allChildren NOT the proxyContainer.
	if not _passport.noErrors() then
		return;
	endif;

	//Do the transactions	
	create theTransactionController transient;
	//Unpack first
	// NOTE we do Unpack first because the movecontroller locations are nulled out for the pack below
	if _theUnpackTIs &lt;&gt; null and _theUnpackTIs.isNotEmpty() then
		if _theMoveController.myToPrimaryLocation = null then
			app.raiseCMException(ERR_UNPACK_NULL_LOCATION, null, null);
			return;
		endif;
		theTransactionController.myOtherTrackedItem := null;
		
		foreach childTI in _theUnpackTIs do
			if newBR &lt;&gt; null and newBR.allTrackedItemsReleased.includes(childTI) then // dh 19/6/08 for warehousing need to be able to undo packing
				if _unpackFromRelease then
					childTI.updatePackingRequest(newBR, true);
				endif;
			endif;			
			//cnwmc5 - 8 Dec 2015 - PAR 37213 - these transactions are now handled by the moveController..

			//unpacked children
			_theMoveController.setMyTrackedItem(childTI);	// this MUST be done before call to setMyOriginatingLocation() below
			_theMoveController.setMyOriginatingLocation(null);
			_theMoveController.isNoChargeMove := true;
			//_theMoveController.myUnpackFromTI:=null;				//cnwmc5 - 3 Dec 2015 - PAR 37213
			_theMoveController.myUnpackFromTI:=realContainer;		//cnwmc5 - 3 Dec 2015 - PAR 37213 - causes an extra set of tasks to be done on the move controller..
			_theMoveController.myPackToTI:=null;
			_theMoveController.setWeight(0); //26 Nov 2015	NDL	Par 37229
			_theMoveController.setQuantity(0);//26 Nov 2015	NDL	Par 37229
			_theMoveController.isPackUnpackWeightSet:=true;			//cnwmc5 - 3 Dec 2015 - PAR 37213	
			self.utlUpdateMoveTrackedItem(_theMoveController, _passport);
			
			childTI.updateForUnpackOfChildEquip( childTI.myTerminal );	//29 Apr 2015	NDL	Par 36111 - TFS243
		
			if not _passport.noErrors() then
				return;
			endif;
		endforeach;
	endif;

	//pack
	if _thePackTIs &lt;&gt; null and _thePackTIs.isNotEmpty() then
		theTransactionController.myTrackedItem := realContainer;
		theTransactionController.myOtherTrackedItem := null;
		
		if tmpPackTILocations.size() &lt;&gt; _thePackTIs.size() then
			app.raiseUnexpectedProgramError(class.name, method.name, 
					'tmpPackTILocations.size (' &amp; tmpPackTILocations.size.String &amp; ') &lt;&gt; _thePackTIs.size (' &amp;
					_thePackTIs.size.String &amp; ')');
			return;
		endif;

		idx := 0;
		foreach childTI in _thePackTIs do
			idx := idx + 1;
			//cnwmc5 - 8 Dec 2015 - PAR 37213 - these transactions are now handled by the moveController..
			// must move the packed child to null, it will then get its location from the parent
			_theMoveController.setMyTrackedItem(childTI);	// this MUST be done before call to setMyOriginatingLocation() below
			_theMoveController.setMyToPrimaryLocation(null);
			_theMoveController.setMyOriginatingLocation(tmpPackTILocations[idx]);
			_theMoveController.isNoChargeMove := true;
			_theMoveController.myUnpackFromTI:=null;
			//_theMoveController.myPackToTI:=null;				//cnwmc5 - 3 Dec 2015 - PAR 37213
			_theMoveController.setMyPackToTI(realContainer);	//cnwmc5 - 3 Dec 2015 - PAR 37213 - causes an extra set of tasks to be done on the move controller..
			_theMoveController.setWeight(0); //26 Nov 2015	NDL	Par 37229
			_theMoveController.setQuantity(0);//26 Nov 2015	NDL	Par 37229
			_theMoveController.isPackUnpackWeightSet:=true;		//cnwmc5 - 3 Dec 2015 - PAR 37213	
			self.utlUpdateMoveTrackedItem(_theMoveController, _passport);
				
			
			childTI.updateForPackOfChildEquipment( realContainer, setParentFromChild );	//29 Apr 2015	NDL	Par 36111 - TFS243
			
			if not _passport.noErrors() then
				return;
			endif;
		endforeach;
	endif;
	
	// CCMS 1385
	// We have changed the weight so we will force a re weigh of the box.
	if realContainer.canBoxBeReweighed(_passport.myTerminal) then
		realContainer.setWeighStatus(WEIGH_STATUS_FORCED);
	endif;
	//realContainer.setTotalQVW(); // CCMS 1240
	// we are taking out child or adding so need to reset this flag (if set) so total weight will change
	realContainer.setTotalWeightSetFlag(false);
	

epilog
//Purge the collection so proxies are deleted before deleting the collection.
	if theTISetAFTERPackItemsAdded &lt;&gt; null then
		//theTISetAFTERPackItemsAdded.clear;
		delete theTISetAFTERPackItemsAdded;
	endif;
	
	delete theTransactionController;
	
	if _theMoveController &lt;&gt; null then
		_theMoveController.isForcedMove := saveForcedMoveValue;
	endif;
	
	delete tmpPackTILocations;
	delete brTIs;
	if deleteSet &lt;&gt; null then
		deleteSet.purge();
	endif;
	delete deleteSet;	
	delete tiUpdateCntrlr;														// PAR #31196
	delete transhipInterface;													// PAR #31196
end;</source>
        <Parameter name="_theMoveController" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_noCharge" type="Boolean"/>
        <Parameter name="_thePackTIs" type="CM_TIArray"/>
        <Parameter name="_theUnpackTIs" type="CM_TIArray"/>
        <Parameter name="_unpackFromRelease" type="Boolean"/>
        <Parameter name="_pxyParentTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_updateMode" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdatePackUnpackWeights" id="80e6534d-ca17-4ecd-bccb-b7e124063aed">
        <source>utlUpdatePackUnpackWeights(_pxyTI : CM_TrackedItem input; _pack : Boolean; _passport : CM_Passport input);
//07 December 2009	cnwml2
//IS THIS METHOD USED?
//IF IT IS PLEASE ADD A COMMENT AS THERE ARE NO REFERENCES TO IT - CNWSH3 26/07/2010
vars
	realTI,
	child : CM_TrackedItem;
	expectedEdition : Integer;
	theTIUpdateController			: CMIF_TIUpdateController;
	
begin
	beginTransaction;
	self.initialiseActivity();

	_pxyTI.pxyGetRealObjectAndEdition(realTI, expectedEdition);
	theTIUpdateController	:=	app.createTIUpdateControl(TI_UPDMODE_RECEIPT, _passport.userCode, null);
	
	//create children transient;//PAR 22954
	//realTI.getAllChildren(children);//PAR 22954
	if _pack then
		foreach child in realTI.allChildren do//cnwsh3 - PAR25103 - allChildren collection has been unprotected reversing the need for changes from PAR22954
			realTI.setTotalWeight(realTI.totalWeight + child.totalWeight, theTIUpdateController, _passport);
			realTI.setWeightCargo(realTI.weightCargo + child.totalWeight);
		endforeach;
	else
		//foreach child in realTI.allChildren do
		foreach child in realTI.allChildren do
			realTI.setTotalWeight(realTI.totalWeight - child.totalWeight, theTIUpdateController, _passport);
			realTI.setWeightCargo(realTI.weightCargo - child.totalWeight);
		endforeach;
	endif;
	
	commitTransaction;
epilog
	
end;</source>
        <Parameter name="_pxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_pack" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdatePackage" id="d808255e-b227-45ed-a2a6-6a611c3f27d3">
        <updating/>
        <source>utlUpdatePackage(_pxyPackage : CM_Package; _passport : CM_Passport input) updating;


// cnwdvb1 15 January 2003 

vars

	realPackage : CM_Package;
	edition		: Integer;

begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	_pxyPackage.pxyGetRealObjectAndEdition(realPackage, edition);
	
	app.myValUA.valPackage(_pxyPackage, realPackage);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
		
	self.myUpdateAuditAgent.audUpdateGeneric(realPackage, true);

	realPackage.setForUpdate(_pxyPackage);
	
	if _passport.noErrors and realPackage.edition &lt;&gt; edition then
		self.myUpdateAuditAgent.audUpdateGeneric(realPackage, false);
	endif;

end;</source>
        <Parameter name="_pxyPackage" type="CM_Package"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdatePalletType" id="1c226f6f-7ac4-468a-8da4-40ed948a68d1">
        <source>utlUpdatePalletType(pProxyPalletType : CM_PalletType; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 March 2017	cnwndl1	Initial creation

*/

vars
