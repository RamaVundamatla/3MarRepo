    <JadeMethod name="doLstDataContextMenu" id="82e87f10-965c-427d-b2a0-310bb5558ee0">
        <updating/>
        <source>doLstDataContextMenu(listbox: ListBox input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.mnuInspect.visible := app.isAllowedToInspect();
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return false;
	endif;

	return self.showContextMenu(self.mnuService, listbox, conwin, mouse, x, y);

end;</source>
