    <JadeMethod name="loadEDITDataType" id="a4b13b41-b2a5-4319-b223-52e614d57176">
        <updating/>
        <source>loadEDITDataType()updating, protected;
// ---------------------------------------------------------------------------
// Created:     23 September 2009 by cnwcs5:1
// Purpose:     Par 20320 - multiple user record types  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 13/10/2009	cnwcs5		par 21242
//11 Dec 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
// ---------------------------------------------------------------------------
vars
	coll			: StringArray;
	index, format, 
	dataType		: Integer;
	str				: String;
	etDef			: EntTableDef;
	sheet			: CMUI_Sheet;
	table			: CM_DataTable;
	ediData			: CM_EDIData;
	doResize		: Boolean;
begin
	create coll transient;
	
	if self.cmbEDIDataType.listIndex &gt; 0 then
		dataType 	:= self.cmbEDIDataType.itemData[self.cmbEDIDataType.listIndex];
		ediData 	:= self.createEDIData(dataType);
		self.getTINamesForDataType(dataType, coll);
	endif;	

	if coll.isEmpty() then
		self.loadFieldMappingTypes(null, index);
		self.shtFieldMapping.caption	:= self.grpMappings.caption;	// par 21242
		return;
	endif;
	
	if cmbFormatType.listIndex &gt; 0 then
		format := cmbFormatType.itemData[cmbFormatType.listIndex];
	endif;
	
	// coll will contain all the etDef names we have to handle
	foreach str in coll do
		sheet := self.shtFieldMapping.getControl(index);
		
		if sheet = null then
			// we may need to clone a sheet for this
			sheet := self.cloneMappingSheet(index);
			doResize := true;
		endif;
		//clear out table contents
		table		:= self.tblUserFieldCode.getControl(index);
		table.rows	:= table.fixedRows; 
		// hide/show columns based on selected format
		table		:= self.tblFieldMap.getControl(index);
		table.rows	:= table.fixedRows; 
		
		self.setTableColumnsForFormatType(format, table);
		
		sheet.visible	:= true;	// just incase it wasn't
		
		etDef := app.myController.getEntTableDef(str);
		
		self.loadFieldMappingTypes(etDef, index);
		
		if ediData &lt;&gt; null then 
			self.setSheetCaption(sheet, self.getEDIDisplayStrForDefName(etDef.name, ediData));
			
			sheet.tag := ediData.getDataTypeFromDefName(etDef.name).String;	// we need this for load/save
		else
			self.setSheetCaption(sheet, null);
			
			sheet.tag := EDIDataType_Unknown.String;
		endif;
		index 			:= index + 1;
	endforeach;
	
	// now hide any unused sheets
	while true do
		sheet := self.shtFieldMapping.getControl(index);
		
		if sheet = null then
			break;
		endif;
		
		sheet.visible 	:= false;
		index 			:= index + 1;
	endwhile;

	if ediData.isKindOf(CM_EDIDataTransManifest) or
	   ediData.isKindOf(CM_EDIDataCallOff) then		//11 Dec 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
		self.grpXlate.visible := false;
	else
		self.grpXlate.visible := true;
	endif;
	
	if doResize then
		self.resize();
	endif;

epilog
	delete coll;
	delete ediData;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadFieldMappingTypes" id="8126f0fa-e80d-4931-9a9a-3ec8161f4e8e">
        <source>loadFieldMappingTypes(_etDef :EntTableDef; _index :Integer) protected;
/*
----------   ----------  --------------------------------------------------
Created:	31 July 2006 By cnwth2

Purpose:	

Changed On	Changed By	Reason
01 Oct 2008	consw1		Par 17090 Replace app.getMyTerminal with self.myTerminal	
23/09/2009	cnwcs5		par 20320 - mulitple record types
23/04/2014	cnwdap1		PAR #33005 CCMS SFW 1381 Imperial measurements for EDI user defined layouts
09 Jan 2024	jlirs1	TFS 59171 User Defined Transport Manifest 
07 Feb 2025	navhl20 	Bug MTN-33985: MTN - Delivery Address is available under Request Detail but cannot load the EDI that includes Delivery Address
----------  ----------  --------------------------------------------------
*/
vars
	entRow		: EntTableRow;
	combo		: CMUI_ComboBox;
	table		: CM_DataTable;
	int			: Integer;
	str			: String;	
	measure		: CM_MeasurementType;						// PAR #33005
	dataType	: Integer;
	
begin

	//08 Nov 2016	NDL	TFS 2926 / 2419
	if self.cmbEDIDataType.listIndex &gt; 0 then
		dataType 	:= self.cmbEDIDataType.itemData[self.cmbEDIDataType.listIndex];
	endif;

	combo			:=	self.cmbFieldType.getControl(_index);
	table			:=	self.tblUserFieldCode.getControl(_index);
	combo.clear();
	combo.sorted 	:=	true;
	
	if _etDef = null then
		combo.addItem(app.getErrorString(No_Data_Type_Selected));
		return;
	endif;
	
	foreach entRow in _etDef.allEntTableRows do
		if entRow.name = ETRow_HasChanged then
			continue;
		endif;
		if _etDef.name = ETDef_EDIDataTransportManifest or		//09 Jan 2024	jlirs1	TFS 59171 User Defined Transport Manifest 
		   _etDef.name = ETDef_EDIDataCallOff then				//16 Jan 2024	jlirs1	TFS 59172 User Defined CallOff 
			if entRow.name = ETRow_Items or
			   entRow.name = ETRow_CreatedTime or 
			   entRow.name = ETRow_Status or 
			   entRow.name = ETRow_Receiver then
				continue;
			endif;
		endif;
		
		if _etDef.name = ETDef_EDITIRequestDetail then			//07.02.2025 navhl20 #33985
			if entRow.name = ETRow_DeliveryAddress then
				continue;
			endif;
		endif;
		
	//	str	:=	entRow.getHeading(null, self.myTerminal, app.myCurrentLocale);
		str := entRow.getRawHeadingValue();	//30 Jan 2018	NDL	TFS 36809 (resolved in ::setValuesForFieldMapping if existing stored data was translated)
		// we don't want to translate these, the user can add their own description to the mapping in the 'CM_EDIFieldMapping::userDesc' field
		
		if not self.fieldHasHookCode(str, table)  then
			if entRow.measurementType &lt;&gt; null then															// PAR #33005
				foreach measure in app.myRoot.allMeasurementTypesByShortName do								// PAR #33005
					if not measure.isDisplay or not measure.isAvailableForEntry or measure.measurementType &lt;&gt; entRow.measurementType then	// PAR #33005
						continue;																			// PAR #33005
					endif;																					// PAR #33005
					int := combo.addItem(str &amp; Space &amp; Left_Round_Bracket &amp; measure.shortName &amp; Right_Round_Bracket);	// PAR #33005
					combo.itemObject[int] := entRow;														// PAR #33005
				endforeach;																					// PAR #33005
			else																							// PAR #33005
				// add entry if it is not already there
				int						:=	combo.addItem(str);
				combo.itemObject[int] 	:=	entRow;
			endif;																							// PAR #33005
		endif;
	endforeach;
	
	//always add an ignore field option
	entRow 	:=	app.myController.getEntTableGroup(ETGrp_EdiMaint).allEntTableRowsByName[ETRow_Ignore];
	str		:=	entRow.getHeading(null, self.myTerminal, null);
	
	if combo.findStringExact(1, str) &lt; 1 then
		int						:=	combo.addItem(str);
		combo.itemObject[int]	:=	entRow;
	endif;
	
	self.showSettings();
end;</source>
        <access>protected</access>
        <Parameter name="_etDef" type="EntTableDef"/>
        <Parameter name="_index" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadFileMappings" id="86b17e38-902a-40ba-845c-c052f7180a96">
        <updating/>
        <source>loadFileMappings(_fileType : CM_EDIFileTypeUser; _index :Integer) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	31 July 2006 By cnwth2

Changed On  Changed By  Reason	
----------  ----------  --------------------------------------------------
23/09/2009	cnwcs5		Handle multiple record types
28/05/2013	cnwcs5		par 31618
// 18 Sep 2017	jlgrs1	TFS 5457 Make JMTInternal XML work
*/
vars
	sheet			: CMUI_Sheet;
	tbl				: CM_DataTable;
	numFields		: Integer;
	fieldMapping	: CM_EDIFieldMapping;
	ediDataType		: Integer;
	type			: CM_EDIFieldMappingType;
	codeMapping		: CM_EDIFieldHookCode;
	
	tmpEDIFieldHookCode : CM_EDIFieldHookCode;
	ediHookCode 		: CM_HookCode;
begin
	sheet		:= self.shtFieldMapping.getControl(_index);
	ediDataType	:= sheet.tag.Integer;
	tbl 		:= self.tblFieldMap.getControl (_index);
	tbl.rows 	:= tbl.fixedRows;
	self.txtControlColVal.getControl(_index).text := null;
	type		:= _fileType.allEDIFieldMappingTypes[ediDataType];
	if type = null then
		return;	// no mappings defined
	endif;
	
	numFields 									:= type.allEDIFieldMappings.size;
	self.txtNumFields.getControl(_index).text 	:= numFields.String;
	self.txtControlColVal.getControl(_index).text := type.controlValue.String;
	
	foreach fieldMapping in type.allEDIFieldMappings do
		self.addFieldMapping(tbl, null, fieldMapping);	// par 31618
	endforeach;
	
	// now do the code mappings
	tbl := self.tblUserFieldCode.getControl (_index);
	
	foreach codeMapping in type.allEDIFieldHookCodes do		
		create tmpEDIFieldHookCode transient;
		create ediHookCode transient;
			
		ediHookCode.setForProxy ( codeMapping.myHookCode.code, codeMapping.myHookCode.myHookType);
		ediHookCode.setJadeCodeForProxy(codeMapping.myHookCode.getCurrentJadeCode , codeMapping.myHookCode.code ) ;
		tmpEDIFieldHookCode.setProxy (ediHookCode , codeMapping.propName , codeMapping.userDesc ) ;		
		
		self.addFieldCodeMapping( tmpEDIFieldHookCode, tbl);
	endforeach;
	
	self.setTblUserCodeView(true, _index);
end;</source>
        <access>protected</access>
        <Parameter name="_fileType" type="CM_EDIFileTypeUser"/>
        <Parameter name="_index" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadFileTypeDetails" id="0c737732-cbc0-473c-a882-be0c8485b62c">
        <updating/>
        <source>loadFileTypeDetails() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	31 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
23/09/2009	cnwcs5		par 20320 - multiple record types
*/
vars
	fileType			: CM_EDIFileTypeUser;
	searchWord			: String;
	idx					: Integer;
	ediHookCode			: CM_HookCode;
	sheet				: CMUI_Sheet;
begin
	fileType := self.cmbFileDef.listObject.CM_EDIFileTypeUser;
	if fileType = null then
		self.clearForNew();	
		return;
	endif;
	
	self.txtName.text 	:= fileType.name;
	idx 				:= self.cmbFormatType.findItemData(fileType.fileType);
	
	if idx &gt; 0 then
		self.cmbFormatType.listIndex 	:= idx;
		self.cmbFormatType.click(self.cmbFormatType);
	endif;
	
	self.txtDelim.text 				:= fileType.delimiter;
	self.cmbEDIDataType.listIndex	:= self.cmbEDIDataType.findItemData(fileType.dataType);


	// set up sheets we need for this data typetry again'
	self.loadEDITDataType;			//cnwcs5 23/09/2009	self.loadFieldMappingTypes();
	
	self.txtIgnore.text 			:= fileType.numLinesToIgnore.String;
	self.cmbDateFormat.text 		:= fileType.dateFormat;
	self.cmbDateDelimiter.text 		:= fileType.dateDelimeter;
	self.txtControlCol.text			:= fileType.controlColumn.String;	// cnwcs5 24/09/2009 par 20320
	self.chkXlations.value			:= fileType.applyTranslations;
	self.cmbXlationOp.setObject(fileType.myXlationOperator);
	self.chkActive.value			:= fileType.emailActive;
	self.txtNumSearch.text 			:= fileType.emailNumLinesToSearch.String;
	
	self.txtSearchWords.text := null;
	
	foreach searchWord in fileType.emailSearchWords do
		self.txtSearchWords.text := self.txtSearchWords.text &amp; searchWord.trimBlanks.toUpper &amp; ',';
	endforeach;
	
	self.txtLoadLines.text 		:= '3';
	self.txtFileName.text 		:= null;
	self.tblSampleData.rows 	:= null;
	self.tblSampleData.columns 	:= null;
	self.blnSettingPin			:= fileType.getConfig(GeneratePins).Boolean;
	self.blnSettingSkip			:= fileType.getConfig(SkipDuplicates).Boolean;
	self.blnSettingsBookings	:= fileType.getConfig(CreateBookings).Boolean;
	self.blnSettingsVoyage		:= fileType.getConfig(InvalidVoyageDefaultNull).Boolean;	//03 Jan 2019	NDL	TFS 42303
	self.allSelectedErrors.clear();	// cnwrd1 ccms 1660 8.8.2008

	fileType.getConfigWarningsToIgnore( self.allSelectedErrors );// cnwrd1 ccms 1660 8.8.2008
	
	if fileType.myIncludeLineHookCode &lt;&gt; null then
		create ediHookCode transient;
		ediHookCode.setForProxy ( fileType.myIncludeLineHookCode.code, fileType.myIncludeLineHookCode.myHookType);
		ediHookCode.setJadeCodeForProxy(fileType.myIncludeLineHookCode.getCurrentJadeCode , fileType.myIncludeLineHookCode.code ) ;
		
		self.myFileLineHookCode := ediHookCode;		
	else
		self.myFileLineHookCode := null;
	endif;
	
// cnwcs5 par 20320 - start
	// loadEDIDataType will have set up all the sheets we need
	idx := 0;
	
	while true do
		sheet := self.shtFieldMapping.getControl (idx);
		
		if sheet = null then
			break;
		endif;
		
		
		
		self.loadFileMappings(fileType, idx);			
		self.setTblUserCodeView(true, idx);
		
		idx := idx + 1;
	endwhile;
// cnwcs5 par 20320 - end
	self.setLineHookCtrls();
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadFormatTypes" id="01db2ecb-c73c-4a6d-81e1-db1fd572fe21">
        <source>loadFormatTypes() protected;
/*
----------   ----------  --------------------------------------------------
Created:	06 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	cmb			: CMUI_ComboBox;
begin
	cmb 		:= self.cmbFormatType;
	cmb.sorted 	:= false;
	cmb.clear();
	cmb.itemData[cmb.addItem('Delimited')] 		:= CM_EDIFileType.FORMAT_DELIMITED;
	cmb.itemData[cmb.addItem('Fixed Length')] 	:= CM_EDIFileType.FORMAT_FIXEDLENGTH;	
	cmb.itemData[cmb.addItem('Simple XML')] 	:= CM_EDIFileType.FORMAT_XML;	//cnwrs1 ccms 2044 21 Apr 2011
end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadSampleData" id="37375a52-36de-46ec-8c14-da6583be55f4">
        <source>loadSampleData() protected;
/*
----------   ----------  --------------------------------------------------
Created:	05 January 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	lineStr,
	fileName	: String;
	idx,
	ignore,
	numFields,
	numLines,
	format		: Integer;
	file		: File;
	kc	        : CnKarmaCntrl;
	textbox	: CMUI_TextBox;
	sheet		:CMUI_Sheet;
begin
	kc	:= app.myCnKarmaCntrl;
	on FileException do kc.fileExceptionHandler(exception);
	
	self.tblSampleData.rows := null;
	//validate the user had made data entry sufficient for us to be able to load the selected file sample
	format := self.cmbFormatType.itemData[self.cmbFormatType.listIndex];
	if format &lt;&gt; CM_EDIFileType.FORMAT_DELIMITED and
	   format &lt;&gt; CM_EDIFileType.FORMAT_XML and	//cnwrs1 ccms 2044 21 Apr 2011
	   format &lt;&gt; CM_EDIFileType.FORMAT_FIXEDLENGTH then
		app.msgBox('You must select a format type before loading sample data.','No format type specified',MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	if format = CM_EDIFileType.FORMAT_DELIMITED then
//		numFields := self.txtNumFields.text.Integer;
		while true do //cnwrs1 Par 23424 25 Mar 2010 get number of columns in all tabs and use the largest value
			sheet := self.shtFieldMapping.getControl(idx);
			if sheet = null then
				break;
			else
				if sheet.visible = false then //there may be hidden sheets from a previous display in this session
					break;
				endif;
			endif;
			textbox := self.txtNumFields.getControl(idx);
			if textbox = null then
				break;
			endif;
			if numFields &lt; textbox.text.Integer then
				numFields := textbox.text.Integer;
			endif;
			idx := idx + 1;
		endwhile;
		if numFields = null then
			app.msgBox('Zero fields specified - you must have at least one field.','No fields specified',MsgBox_Exclamation_Mark_Icon);
			return;	
		endif;
		
		self.tblSampleData.columns := numFields;
	endif;
	
	numLines := self.txtLoadLines.text.Integer;
	if numLines = null then
		app.msgBox('Zero lines to load specified - you must specify the number of lines from the file you wish to see as a sample.','Zero number of lines specified',MsgBox_Exclamation_Mark_Icon);
		return;	
	endif;
	
	fileName := self.txtFileName.text;
	if fileName = null then
		app.msgBox('You must specify a file from which you would like to sample data.','No file name specified',MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	ignore := self.txtIgnore.text.Integer;
	create file transient;	
	file.kind := File.Kind_Unknown_Text;	// 1/3/16 cnwmp6 PAR 36286 unicode version
	file.openInput(fileName);

	if format = CM_EDIFileType.FORMAT_XML then	//cnwrs1 ccms 2044 28 Apr 2011
		self.tblSampleData.columns := 1;
		while not file.endOfFile() do
			lineStr := file.readLine();
			self.addSamplRowFreeForm(lineStr);
		endwhile;
		return;
	endif;

	foreach idx in 1 to ignore do
		if file.endOfFile() then
			return;
		endif;
		kc.setHadFileException(false);
		kc.setFileRetryNo(0);
		lineStr := file.readLine();
		if kc.hadFileException and kc.exceptionErrorCode = 5011 then
			file.maxRecordSize := file.maxRecordSize * 2;
			continue;
		endif;
	endforeach;
	
	foreach idx in 0 to numLines do
		if file.endOfFile() then
			return;
		endif;		
		lineStr := file.readLine();
		if format = CM_EDIFileType.FORMAT_DELIMITED then
			self.addSampleRowDelimited(lineStr, numFields); //cnwrs1 Par 23424 25 Mar 2010
		elseif format = CM_EDIFileType.FORMAT_FIXEDLENGTH then
			self.addSampleRowFixedLength(lineStr);
		endif;
	endforeach;
	
epilog
	delete file;
end;


</source>
        <access>protected</access>
    </JadeMethod>
