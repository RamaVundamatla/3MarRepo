    <JadeMethod name="doSave" id="275afd06-1715-444b-94af-7f1b26a239f2">
        <updating/>
        <source>doSave() updating, protected;
// ---------------------------------------------------------------------------
// Created:	16 May 2008 By Graeme Black cnwgb1 PAR 16483
// Status: Unfinished
// Updates the Gate Lane Controllers 
// ---------------------------------------------------------------------------
// 25/08/2009	cnwcs5	ccms 1061 - road ops form changes
vars
	table			: CM_DataTable;
	row, rows		: Integer;
	pxyLane   		: CM_LaneController;
	inLaneColumn 	: Integer;
	outLaneColumn 	: Integer;
	closedColumn 	: Integer;
	isClosed 		: Boolean;
	direction 		: Integer;
	result 			: Integer;
	coll 			: ObjectSet;
	
begin
	table	:= self.tblGateLanes;
	rows 	:= table.rows;
	
	create coll transient;
	
	foreach row in table.fixedRows + 1 to rows do  
		pxyLane := table.accessRow(row).itemObject.CM_LaneController;

		isClosed := table.accessCell(row, table.getColumnByRowName (ETRow_IsClosed)).text.isTrueFalse(CHECKED, UNCHECKED, null);
		
		if table.accessCell(row, table.getColumnByRowName (ETRow_IsInwards)).text.isTrueFalse(CHECKED, UNCHECKED, null) then
			direction := CM_LaneController.Is_In_Lane;
			
		elseif table.accessCell(row,table.getColumnByRowName (ETRow_IsOutwards)).text.isTrueFalse(CHECKED, UNCHECKED, null) then
			direction := CM_LaneController.Is_Out_Lane;
			
		else
			// if neither set it is a hangover from pre-conversion (7.7.3)
			isClosed 	:= true;
			direction 	:= CM_LaneController.Is_Undecided;
		endif;
		
		pxyLane.setIsUnavailable(isClosed);
		pxyLane.setLaneDirection (direction);
		
		coll.add(pxyLane);
	endforeach;
	
	// Call the helper objects to actually update using the proxy
	while true do
		
		app.myTrxUA.trxUpdateGLCList(coll, app.myPassport); 

		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			return ;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
epilog
	delete coll;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="init" id="8e467676-ee03-4a6e-b440-c74d76d30ffb">
        <updating/>
        <source>init( _area :CM_AreaWithLanes) updating;
// ---------------------------------------------------------------------------
// Created:     05 May 2008 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 17/09/2009	cnwcs5	ccms1061 - show terminal area as part of caption
vars
	table	:CM_DataTable;
begin
	if _area = null then
		return;
	endif;
	
	self.myAreaWithLanes 	:= _area;
	if _area &lt;&gt; null then
		self.myTerminal:=_area.myTerminal;
	endif;
	table					:= self.tblGateLanes;
	table.optimiseRowHeight := true;
	
	table.setTblDataEntRowsFromView (app.myController.getEntTableDef(ETDef_VTAGateMaint), "VTAGateLaneView");
	
	table.accessColumn(table.getColumnByRowName (ETRow_GateLaneId)).enabled := false;
	table.accessedColumn.backColor := self.getSystemColor(Color_BtnFace);

	self.handleMenusForModalDisplay();
	
	self.caption	:= self.caption &amp; ' ' &amp; self.myAreaWithLanes.id;	// 17/09/2009 cnwcs5
	
	self.centreOverParent (null);
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.tblGateLanes.userInputEnabled := false;
		self.btnOk.enabled:= false;
	endif;

end;</source>
        <Parameter name="_area" type="CM_AreaWithLanes"/>
    </JadeMethod>
