    <JadeMethod name="setColorsFromController" id="059648a1-4adf-4c0d-9909-9c3416b0ebec">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     02 June 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpBackColor	: Integer;

begin
	inheritMethod(_colorControl);

	tmpBackColor	:=	self.backColor;
	
	self.dkbCriteria.backColor		:=	tmpBackColor;
	self.dkbOptions.backColor		:=	tmpBackColor;
	self.dkbLocations.backColor		:=	tmpBackColor;

	self.lstCriteriaDtl.backColor	:=	self.colorControlBack;
	self.lstLocations.backColor		:=	self.colorControlBack;
	self.tblOptions.backColor		:=	self.colorControlBack;
	
	self.setColorsForTable(self.tblData);
	
	
	
	self.fldDetails.useSheetBackColors := true;
	self.fldDetails.setDefaultSheetBackColors();
	self.fldDetails.initSheetBackColors();
	
end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setEntTableTISpecial" id="6c602107-3bcc-4272-a29e-de46770cbfb4">
        <updating/>
        <source>setEntTableTISpecial(_attrName : String;
				_strValue : String;
				_obj : CM_TrackedItem input;
				_tbl : CM_EntryTable input) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     17 May 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tempObj			: Object;
	tmpStr			: String;
	tmpConsignee	: CM_ConsigneeConsignor;

begin
	// For an attribute that we handle here, then we'll do so and return 'true'.
	
	if _attrName = ETRow_CarrierCode then
		_obj.setCarrier(_strValue);
		return true;

	elseif _attrName = ETRow_Consignee then
		tmpStr	:=	_strValue;
		
		if app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean then  
			tmpConsignee	:=	app.myRoot.allConsigneeConsignorsForDescr[tmpStr];
			
			if tmpConsignee &lt;&gt; null then
				tmpStr	:=	tmpConsignee.code;
			else
				tmpStr	:=	null;
			endif;
		else
			// Assume that tmpStr is the code
		endif;
		
		_obj.setPropertyValue(CM_TrackedItem::consignee.name, tmpStr);
		return true;
	
//	elseif _attrName = ETRow_MyVoyage then
//write _strValue;
//		_obj.setVoyageCode(_strValue, app.myPassport);
		
//		foreach tempObj in self.allProxyObjects do
//			tempObj.CM_TrackedItem.setVoyageCode(_strValue, app.myPassport);
//		endforeach;
//		//_obj.setPropertyValue('voyageCode', _strValue);
		return true;
		
	endif;

	return false;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_strValue" type="String"/>
        <Parameter name="_obj" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFirstYA" id="fe844ade-bb08-4470-bd7c-66db28c186f8">
        <updating/>
        <source>setFirstYA() updating;

//par 19909 cnwjo3
//
//Purpose: When no YAs are selected when an update was occuring from a different
//user another users YA was being expanded.  Fix:  Always have a YA selected


constants
	FirstYA : Integer = 3;
begin
	if self.tblData.rows &gt;= FirstYA then
		self.tblData.row := FirstYA;
		self.tblData.selected := true;
		self.tblData.selectRow(FirstYA,false);
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="setSelectedYA" id="2a312287-d783-4c57-8491-e31fa23ee132">
        <updating/>
        <source>setSelectedYA(pAllocationObj : CM_YardAllocation) updating, protected;
// ---------------------------------------------------------------------------
// Created:     02 June 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	containerObj	: CM_DataContainer;
	
begin
	self.aMyCurrentYA	:=	pAllocationObj;
	
	if pAllocationObj = null then
		self.lstCriteriaDtl.clear();
		self.lstLocations.clear();
		self.tblOptions.clear();
		self.tblOptions.rows	:=	self.tblOptions.fixedRows;
		return;
	endif;

	self.lstLocations.listCollection(pAllocationObj.allYABlocksIn, true, Collection.CNEC_DISPLAY_ORDER_COLLECTION);
	self.lstCriteriaDtl.listCollection(pAllocationObj.allCriteria, true, Collection.CNEC_DISPLAY_ORDER_COLLECTION);

	// now display the options

	//######################
	// DISPLAY INFO
	create containerObj transient;
	containerObj.headerColour	:=	self.colorHeadingColumn;
	containerObj.valueColour	:=	self.colorValueColumn;
	
	pAllocationObj.getExtraInfo(containerObj);

	self.tblOptions.userObject	:=	pAllocationObj; // this is used to redraw this info
	self.showExtraInformation(containerObj, self.tblOptions, true, false, 2, 1, 1, 1, 1);
epilog
	delete containerObj;
	self.doEnableControls();
end;</source>
        <access>protected</access>
        <Parameter name="pAllocationObj" type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="4725639d-552e-4ecd-bba1-1f1669fd6601">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
// --------------------------------------------------------------------------------
// Created:		12 March 2009 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	//keep the search parameters
	if _theTable = self.tblData then	
		self.tblData.searchRefresh();
	else

		_theTable.refresh();
	endif;
end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupCmbTemplateTo" id="04e1c935-0bba-4e28-b92d-852e9d6d39f1">
        <source>setupCmbTemplateTo() protected;

// Created by cnwdvb1 on 07 August 2006

vars

	itemObj,
	obj : Object;

begin

	self.cmbTemplateTo.clear();
	
	itemObj := self.cmbTemplateView.listObject;
	
	// Build to combo from view combo not including what view is looking at.
	foreach obj in self.cmbTemplateView.itemObject where obj &lt;&gt; itemObj do
		if obj = self.myTerminal then
			self.cmbTemplateTo.itemObject[self.cmbTemplateTo.addItem('Current View')] := obj;
		else
			self.cmbTemplateTo.itemObject[self.cmbTemplateTo.addItem(obj.CM_YATemplateGroup.code)] := obj;
		endif;
	endforeach;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="1dc367d8-25a2-495e-ad7c-d4e5a2dc9198">
        <updating/>
        <source>setupForm() updating;
// --------------------------------------------------------------------------------
// Created:		09 May 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 10/06/2013	cnwdap1		PAR #31721 Imperial Measurements on Yard Allocation What Ifs
// 18/09/2013	cnwdap1		PAR #32215 New Car Attributes on What ifs
// 28/1/13		cnwer1		PAR #30823 moved whatif stuff in to own form 
// --------------------------------------------------------------------------------
vars
	voyageGlobalObj	: CM_VoyageGlobal;
	operatorObj		: CM_VoyageOperator;
	row				: Integer;								// PAR #32215
	entRowTrans		: EntTableRowTransient;					// PAR #32215
	anObj			: Object;								// PAR #32215
		
begin
	self.frmToolbar.alignContainer	:=	Frame.AlignContainer_Top; // this will make the dkcMain line up its top


	self.frmToolbar2.alignContainer := Frame.AlignContainer_None; 
	
	self.frmToolbarTmpl.visible := false;
	// CCMS 1013
	self.setupTemplateGrpsCombo();
	
	self.setNavigatorHeading(self.caption);
	self.toolbarStyle		:=	self.ToolbarStyle_ShowNoHide;
	self.showToolbar		:=	true;
	self.chkShowDisabled.cnEcSet(true);
	self.aIsShowDisabled	:=	true;
	self.aIsShowStats		:=	false;
	self.aLastSelectedRow	:=	tblData.fixedRows + 1;

	inheritMethod();
	
	self.tableYAInitialize();
	
	btnCancelBase.setFocus();
	
	self.beginClassNotification(CM_Terminal, false, self.myTerminal.getTerminalEvent(Event_YardAllocationUpdate), Response_Continuous, 0);
	self.beginClassNotification(CM_Terminal, false, self.myTerminal.getTerminalEvent(Event_YardAllocationCreate), Response_Continuous, 0);
	self.beginClassNotification(CM_Terminal, false, self.myTerminal.getTerminalEvent(Event_YardAllocationDelete), Response_Continuous, 0);
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnAddYA.enabled:= false;
		self.btnEditYA.enabled:= false;
		self.btnDeleteAlloc.enabled:= false;
	endif;
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupTemplateGrpsCombo" id="55c056aa-9aab-437c-806b-5b10a8f56d9f">
        <source>setupTemplateGrpsCombo() protected;

// Created by cnwdvb1 on 07 August 2006

vars

	group 	: CM_YATemplateGroup;
	foundIdx,
	count	: Integer;

begin

	// Set up view combo.
	self.cmbTemplateView.clear();
	
	self.cmbTemplateView.itemObject[self.cmbTemplateView.addItem('Current View')] := self.myTerminal;
	count := 1;
	foundIdx := count;
	
	foreach group in app.myRoot.allYATemplateGroups do
		count := count + 1;
		self.cmbTemplateView.itemObject[self.cmbTemplateView.addItem(group.code)] := group;
		if self.myCurrentTemplateGroup &lt;&gt; null and self.myCurrentTemplateGroup = group then
			foundIdx := count;
		endif;
	endforeach;
	
	self.cmbTemplateView.listIndex := foundIdx;
	
	self.setupCmbTemplateTo();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showAllocationsNoRanges" id="c54be93d-3a7a-4610-8414-7654c5aab58d">
        <updating/>
        <source>showAllocationsNoRanges(_show : Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 10/09/2025	navdap1		Initial creation MTN-35615 ENS | Bulk Creation of Yard Allocations
//
vars
	row : Integer;
	obj : Object;

begin
	foreach row in self.tblData.fixedRows + 1 to self.tblData.rows do
		if self.tblData.accessRow(row).itemObject &lt;&gt; null then
			// If _show is true, we're just showing those with no ranges
			// So any itemObject that isn't a yard allocation can be hidden
			if _show then
				obj := self.tblData.accessedRow.itemObject;
				if not obj.isKindOf(CM_YardAllocation) or (obj.isKindOf(CM_YardAllocation) and not obj.CM_YardAllocation.allYardControllers.isEmpty) then
					self.tblData.accessedRow.visible := false;
				endif;
			else
				if self.tblData.accessedRow.itemObject.isKindOf(CM_YardAllocation) then
					self.tblData.accessedRow.visible := true;
				endif;
			endif;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_show" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showColumnOrganiser" id="6961251b-ac2a-49c7-b7f7-bc3100b5ed18">
        <source>showColumnOrganiser(_dataTable : CM_DataTable input) protected;
// --------------------------------------------------------------------------------
// Created:		05 March 2009 by cnwdad1
//
// Purpose:		Method to show the column organiser for the receiver's YAM table.
//
// Parameters:	_dataTable - A reference to the table control.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if _dataTable = null then
		return;
	endif;
	
	_dataTable.showColumnOrgSizesForm(self.myTerminal, null);
end;</source>
        <access>protected</access>
        <Parameter name="_dataTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showSearchParameters" id="1f6f6850-8878-4977-a4c8-511c00921798">
        <source>showSearchParameters();

/*

Purpose:			Display current search parameters

Parameters:			

Return Value:		


Date				Who		Reason
05 September 2008	consw1	Initial creation

*/

vars
	proxyCriteria	: CM_YACriteria;
	searchParams	: CMIF_YACriteriaSearch;
	tmpObj			: CMIF_Object;

begin
	self.tblSearch.rows := 0;
	self.tblSearch.accessColumn(1).visible := false;

	if not self.tblData.hasSearchParameters() then
		self.dkbSearch.visible := false;
		return;
	endif;

	searchParams := self.tblData.mySearchParameters;
	
	foreach tmpObj in searchParams.allSearchCriteria do
		proxyCriteria := tmpObj.CMIF_YACriteriaPriority.myProxy.CM_YACriteria;
		tblSearch.addItem( Tab &amp; proxyCriteria.getDescription() );
	endforeach;

	tblSearch.addItem( Tab &amp; searchParams.getStatusDisplay() );

	tblSearch.adjustHeight(2000);

	self.dkbSearch.visible := true;
	
	tblSearch.top 	:= self.frmSearchToolbar.height;
	tblSearch.width	:= self.frmSearchToolbar.width;
	
	self.doExpandSearchParameters();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tableYAInitialize" id="99224535-0bdf-4a36-b519-5f17cdf4de4f">
        <updating/>
        <source>tableYAInitialize() updating, protected;
//15 August 2008	cnwdw1	
//
vars

begin
	self.tblData.setForm(self);
	self.tblData.initialise(false, self.fraPictures, self.pic1, self.pic2, self.pic3);
	self.showSearchParameters();
	self.setFirstYA();  //par 19909 cnwjo3
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="tblData_click" id="5bf31f2f-ca03-4cf9-9790-849d2b9c9719">
        <controlMethod name="CM_YAMTable::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_click(table: Table input) updating;
//27 March 2009	cnwdw1	
//
vars

begin
	if table.row &gt; table.fixedRows and table.row &lt;= table.rows then
		self.setSelectedYA(self.tblData.getSelectedObjectsYA());
	else
		self.setSelectedYA(null);
	endif;

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnAddYA.enabled:= false;
		self.btnEditYA.enabled:= false;
		self.btnDeleteAlloc.enabled:= false;
	endif;
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblData_contextMenu" id="bb6da12b-15b0-4b88-a63d-a321ecd5fb7a">
        <controlMethod name="CM_YAMTable::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// -------------------------------------------
// Created 27 October 2005 by cnwdvb1
// -------------------------------------------
vars

	x1, y1	: Real;
	menu	: MenuItem;

begin
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mnuYANew.visible := false;
		self.mnuYAGroupNew.visible := false;
		self.mnuYAEdit.visible := false;
		self.mnuYADelete.visible := false;
		self.mnuYADeckingOptions.visible := false;
		self.mnuRebuildStats.visible := false;
		self.mnuPurgeMovementLog.visible := false;
		self.mnuProcessMovementLog.visible := false;
	endif;

	if app.isAllowedToInspect() then
		x1 := x;
		y1 := y;
		conwin.windowToScreen(x1, y1);
		self.screenToWindow(x1, y1);   // convert x, y relative to form

		self.mnuSpecial.visible := app.isSpecial();
		self.mnuInspect.visible := app.isAllowedToInspect;
		self.popupMenu(self.mnuSpecial, x1.Integer, y1.Integer);
		return true;
	endif;

	self.mnuSpecial.visible := false;
	self.mnuInspect.visible := false;
	return false;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
