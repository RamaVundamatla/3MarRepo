<Class name="CM_VoyageToDoTask" id="601f41c2-0ea6-4f3e-a38f-f13de65f3b5c">
    <superclass name="CM_ToDoTask"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="misc"/>
    <ExplicitInverseRef name="myVoyageComplete" id="d3746969-ff87-40ca-b42d-cf1a574d158e">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Voyage"/>
        <access>readonly</access>
        <Inverse name="CM_Voyage::allToDoTasksCompleted"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myVoyageToDo" id="e5c8dd58-0988-4764-9bd5-71e95c5339d2">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Voyage"/>
        <access>readonly</access>
        <Inverse name="CM_Voyage::allToDoTasksToDo"/>
    </ExplicitInverseRef>
    <JadeMethod name="getToDoObject" id="296ea822-200b-4d80-bea3-cb69955ffcd9">
        <source>getToDoObject(): CM_Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2024 navhl20 Bug 64261: EUP | VAS - Not able to complete TODO jobs

*/

vars

begin
	return self.myVoyageToDo;
epilog

end;</source>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="myTerminal" id="81939e30-1d9a-44c4-8a42-3498184df181">
        <methodInvocation>mapping</methodInvocation>
        <source>myTerminal(set: Boolean; _value: CM_Terminal io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date  		Who	   Reason
06 Jun 2023 navma1 Bug 58265: MTN - Complete ToDo security role setting is missing for all the new event todo tasks.
*/

vars

begin
	if set then
		return;
	endif;
	
	if self.myVoyageToDo &lt;&gt; null then
		_value := self.myVoyageToDo.getMyTerminal();
	elseif self.myVoyageComplete &lt;&gt; null then 
		_value := myVoyageComplete.getMyTerminal();  
	else
		_value := null;
	endif;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_Terminal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="9d414368-2613-4619-ace3-d06cb91dc2bc">
        <updating/>
        <source>setForCreate(_status : Integer; _toDoTaskDesc : CM_ToDoTaskDesc; _toDoRemarks : String; _passport : CM_Passport input; _voyage : CM_Voyage; _wod : CM_WorkOrderToDoDtl) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 November 2022	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen

*/

vars
	transType	: Integer;
	event		: CMEVT_VoyageEvent;
begin

	self.setForCreateToDoTask(_status, _toDoTaskDesc, _toDoRemarks, _passport.userCode);
	self.myVoyageToDo := _voyage;

	transType :=  self.getToDoTaskCreateEventInt;
	
	if transType &lt;&gt; null then
		event := self.myVoyageToDo.createTransaction(transType, app.actualTime(), null, self, _wod); // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
	endif;
end;</source>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc"/>
        <Parameter name="_toDoRemarks" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_wod" type="CM_WorkOrderToDoDtl"/>
    </JadeMethod>
    <JadeMethod name="updateVoyageComplete" id="ce8e29ef-98c8-4f4c-bef2-75f0bfd70ba7">
        <updating/>
        <source>updateVoyageComplete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
30 November 2022	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen

*/

vars
	myWod 	: CM_WodToDoVoyage;
	voyage 	: CM_Voyage;
begin

	self.myVoyageComplete := self.myVoyageToDo;
	self.myVoyageToDo := null;
	
	self.myVoyageComplete.createEvent();
epilog

end;</source>
    </JadeMethod>
</Class>
