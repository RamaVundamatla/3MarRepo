    <JadeMethod name="getRequestType" id="6e0a465a-0c56-445c-8604-25db531142b1">
        <source>getRequestType(): Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 August 2009	cnwrd1	Initial creation

*/

vars

begin
	
	if self.job.myWODtl &lt;&gt; null then
		return REQ_TI_WORKORDER;
	else
		return REQ_TI_RELEASE;
	endif;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
