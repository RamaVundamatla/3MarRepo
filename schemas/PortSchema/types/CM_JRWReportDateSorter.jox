<Class name="CM_JRWReportDateSorter" id="3d65b113-107d-4e89-9eea-e9a43e8e78c6">
    <superclass name="CM_JRWTransient"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <ImplicitInverseRef name="allReportDateSorters" id="74a98e1b-741f-4356-8072-5c15a53e1a71">
        <memberTypeInverse/>
        <type name="CMIF_ReportDateSorterDict"/>
    </ImplicitInverseRef>
    <PrimAttribute name="fromDate" id="938e5ffd-fab8-45c3-8780-b3eb7847db5a">
        <embedded/>
        <type name="Date"/>
    </PrimAttribute>
    <PrimAttribute name="toDate" id="843567b7-3591-46bb-9bc6-a94059635559">
        <embedded/>
        <type name="Date"/>
    </PrimAttribute>
    <JadeMethod name="getFromDateLocalTZ" id="2db0b3b9-fe17-4c2c-9d26-531096fb93d8">
        <source>getFromDateLocalTZ() : Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2016	cnwns1	Initial creation
// 02 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	sysTS : TimeStamp;
begin
	sysTS.cnEcSetDateAndTime(self.fromDate,TimeStartOfDay);
	return self.systemToLocalTime(sysTS).date();
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getToDateLocalTZ" id="ec44067b-306c-4253-8bcb-01fc9b92d5c3">
        <source>getToDateLocalTZ() : Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2016	cnwns1	Initial creation
// 02 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	sysTS : TimeStamp;
begin
	sysTS.cnEcSetDateAndTime(self.toDate,TimeStartOfDay);
	return self.systemToLocalTime(sysTS).date();
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
</Class>
