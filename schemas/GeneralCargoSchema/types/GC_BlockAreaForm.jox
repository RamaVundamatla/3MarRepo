        <source>doMnuGridHideToolbarClick() updating, protected;

/*

Purpose:			


Return Value:		


Date		Who		Reason
16 May 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/

begin
	if self.mnuGridHideToolbar.caption = self.MNU_TOOLBAR_SHOW then
		self.mnuGridHideToolbar.caption		:=	self.MNU_TOOLBAR_HIDE;
		self.doMnuHideToolbarHide(false);
	else
		self.mnuGridHideToolbar.caption		:=	self.MNU_TOOLBAR_SHOW;
