    <JadeMethod name="getAllCARGOByContents" id="77728a63-e85a-450f-8cdc-a45502f30b80">
        <source>getAllCARGOByContents(_attr : Attribute; _contents : Integer) : Integer;
// ---------------------------------------------------------------------------
// Created:     08 June 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	kpiDetail : CM_KPIDtlEntity;
	totNum : Integer;
begin
	foreach kpiDetail in self.allKPIVoyageMoveDtls_Container discreteLock do
		if kpiDetail.CM_KPIVoyageMoveDtl_Container.contentsStatus = _contents  then
			if _attr = CM_KPIVoyageMoveDtl_Container::numTIs then
				totNum := totNum +  kpiDetail.CM_KPIVoyageMoveDtl_Container.numTIs;
			elseif _attr = CM_KPIVoyageMoveDtl_Container::numTEU then
				totNum := totNum +  kpiDetail.CM_KPIVoyageMoveDtl_Container.numTEU;
			elseif _attr = CM_KPIVoyageMoveDtl_Container::numReefer then
				totNum := totNum +  kpiDetail.CM_KPIVoyageMoveDtl_Container.numReefer;
			elseif _attr = CM_KPIVoyageMoveDtl_Container::numOverdimension then
				totNum := totNum +  kpiDetail.CM_KPIVoyageMoveDtl_Container.numOverdimension;
			endif;
		endif;
	endforeach;
	
	return totNum;
end;</source>
        <Parameter name="_attr" type="Attribute"/>
        <Parameter name="_contents" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
