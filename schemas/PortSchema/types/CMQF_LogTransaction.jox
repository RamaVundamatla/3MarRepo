    <JadeMethod name="getOIDAndDescForAttribute" id="eb930f92-cd78-4266-b3c1-1cb0af4e0266">
        <source>getOIDAndDescForAttribute(_attrName: String; _getCalculatedDate : Boolean; _oid : String output): String;
// ---------------------------------------------------------------------------
// Created:     19/07/2010 cnwdz2	
//
// Purpose:     PAR24513 extend the current existing getDisplayStringForAttribute method to return an object's oid.	
vars

begin
	if _attrName = ETRow_CarrierCode or
	   _attrName = ETRow_Carrier then
		return self.carrierCode;
		
	elseif _attrName = ETRow_LoggingOrganisation then
		return self.loggingOrganisation;
		
	elseif _attrName = ETRow_LogGrade then
		if self.gradeCode &lt;&gt; null then
			return self.gradeCode;
		else
			return Any_String;
		endif;

	elseif _attrName = ETRow_LogLength then
		if self.lengthCode &lt;&gt; null then
			return self.lengthCode;
		else
			return Any_String;
		endif;
	
	elseif _attrName = ETRow_GangNumber then
		return self.gangNumber;
		
	elseif _attrName = ETRow_Operator then
		if self.operatorCode &lt;&gt; null then
			return self.operatorCode;
		else
			return Any_String;
		endif;

	elseif _attrName = ETRow_SrcLocation then
		if self.sourceLocation &lt;&gt; null then
			return self.sourceLocation;
		else
			return Any_String;
		endif;
		
	elseif _attrName = ETRow_SrcSubLocation then
		if self.sourceSubLocation &lt;&gt; null then
			return self.sourceSubLocation;
		else
			return Any_String;
		endif;
		
	elseif _attrName = ETRow_SrcSubSubLocation then
		if self.sourceSubSubLocation &lt;&gt; null then
			return self.sourceSubSubLocation;
		else
			return Any_String;
		endif;
		
	elseif _attrName = ETRow_LogSpecies then
		if self.speciesCode &lt;&gt; null then
			return self.speciesCode;
		else
			return Any_String;
		endif;
		
	elseif _attrName = ETRow_LogTreatment then
		if self.treatmentCode &lt;&gt; null then
			return self.treatmentCode;
		else
			return Any_String;
		endif;
		
	elseif _attrName = ETRow_LogType then
		if self.typeCode &lt;&gt; null then
			return self.typeCode;
		else
			return Any_String;
		endif;
	endif;
	
	return inheritMethod(_attrName, _getCalculatedDate, _oid);


end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="fb79cffd-feec-466c-b97d-2cdd2b2183f5">
        <updating/>
        <source>includesObject(_txn : CM_TITransaction; _passport : CM_Passport; _breakOut : Boolean output): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     04 February 2003		cnwth2	
//
// Purpose:     Note that timestamp comparison has already been done in filterObjects call
//			 
// ----------   ----------  --------------------------------------------------
vars
	op					: CM_Operator;
	log					: CM_Log;
	bolIn				: CM_BOLIn;
	querySelf			: CMQF_LogTransaction;
	failedDAC  :CM_DataAccessController;

begin
	querySelf := self;
	querySelf.numSearched := querySelf.numSearched + 1;
	
	if (not CM_Log.hasInstance(_txn.myTrackedItem)) then
		return false;
	endif;
	
	log := _txn.myTrackedItem.CM_Log;
	
	if CM_EditOperator.hasInstance(_txn) then
		op := _txn.CM_EditOperator.myOperatorTo;
		if op &lt;&gt; null then
			if (querySelf.operatorCode &lt;&gt; null and (querySelf.operatorCode &lt;&gt; op.code)) then
				return false;
			endif;
		endif;
	endif;
	
	bolIn := log.myReceivalBOL;
	
	if	(querySelf.consignor &lt;&gt; null and querySelf.consignor &lt;&gt; log.consignor) or
		(querySelf.operatorCode &lt;&gt; null and querySelf.operatorCode &lt;&gt; log.operatorCode) or
		(querySelf.speciesCode &lt;&gt; null and querySelf.speciesCode &lt;&gt; log.speciesCode) or
		(querySelf.gradeCode &lt;&gt; null and querySelf.gradeCode &lt;&gt; log.gradeCode) or
		(querySelf.typeCode &lt;&gt; null and querySelf.typeCode &lt;&gt; log.typeCode) or
		(querySelf.treatmentCode &lt;&gt; null and querySelf.treatmentCode &lt;&gt; log.treatmentCode) or
		(querySelf.typeCode &lt;&gt; null and querySelf.typeCode &lt;&gt; log.typeCode) or
		(querySelf.lengthCode &lt;&gt; null and querySelf.lengthCode &lt;&gt; log.lengthCode) or
		(querySelf.getMySubTerminal &lt;&gt; null and querySelf.getMySubTerminal &lt;&gt; bolIn.mySubTerminal) or //28/04/2009 cnwdz2 ccms1735
		(querySelf.sourceLocation &lt;&gt; null and querySelf.sourceLocation &lt;&gt; bolIn.sourceLocation) or
		(querySelf.sourceSubLocation &lt;&gt; null and querySelf.sourceSubLocation &lt;&gt; bolIn.sourceSubLocation) or
		(querySelf.sourceSubSubLocation &lt;&gt; null and querySelf.sourceSubSubLocation &lt;&gt; bolIn.sourceSubSubLocation) or
		//(querySelf.loggingOrganisation &lt;&gt; null and querySelf.loggingOrganisation.toUpper &lt;&gt; bolIn.loggingOrganisation.toUpper) or //#cnwdz2	 CCMS 1108 par22177 
		(querySelf.loggingOrganisation &lt;&gt; null and querySelf.loggingOrganisation.toUpper &lt;&gt; bolIn.getLoggingOrganisation().toUpper) or
		(querySelf.gangNumber &lt;&gt; null and querySelf.gangNumber.toUpper &lt;&gt; bolIn.myExtension.CM_BOLExtLog.gangNumber.toUpper) or
		(querySelf.carrierCode &lt;&gt; null and querySelf.carrierCode.toUpper &lt;&gt; bolIn.carrierCode.toUpper) then
		return false;
	endif;
	
	if not log.canUserAccessSelf(null, failedDAC, _passport) then
		return false;
	endif;
	
	return true;		
	
end;</source>
        <access>protected</access>
        <Parameter name="_txn" type="CM_TITransaction"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
