    </JadeMethod>
    <JadeMethod name="setCaptionForHarbour" id="48d8bf17-83c9-43a4-aa80-3b6ed6e87ea0">
        <updating/>
        <source>setCaptionForHarbour(_caption : String io) updating;
//--------------------------------------------------
// Created:	09 February 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	
	if self.myAssistant.HMS_Assistant.myHarbour &lt;&gt; null then
		_caption := _caption &amp; ' ' &amp; self.myAssistant.HMS_Assistant.myHarbour.code;
	endif;

	self.setCaption(_caption);
		
end;</source>
        <Parameter name="_caption" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="c38cf9a2-cace-4401-908a-1af228b4ff5c">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------------------
//Created: 21 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	str : String;
begin
	inheritMethod();
	str := self.caption;
	self.setCaptionForHarbour(str);
	self.setNavigatorHeading(self.caption);

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="267e8d31-9862-4c18-a324-b2df6260d02a">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018159, locale);
end;</source>
    </JadeMethod>
</GUIClass>
