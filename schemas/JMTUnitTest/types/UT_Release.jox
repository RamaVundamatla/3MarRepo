    <JadeMethod name="tWayBillRelease1" id="45496b53-703c-4a65-ba4e-1488889048d4">
        <updating/>
        <source>tWayBillRelease1()updating;
// cnwdap1
//05 November 2009	cnwml2
//+cnwml2 MSL CCMS 1012
// Create a Normal Release and assign a TI
// Try to assign the TI to a Waybill release it should give an error
//23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items

vars
	releaseRequest, releaseRequest1 : CM_BulkRelease;
	ti, ti1 : CM_TrackedItem;
	bs : CM_BlockStack;
begin
	
	self.deleteReleaseRequest("UTRRRoad");
	self.deleteReleaseRequest("UTRRRoad1");
	self.deleteContainer("UUT00000001");
	self.deleteContainer("UUT00000002");
	self.deleteTerminalArea("UTBS1");

	bs := self.addBlockStack("UTBS1", 100, null);

	
	releaseRequest := addReleaseByTypeRequest("UTRRRoad", BR_TYPE_ROAD, TI_CargoType_Container, "2200");
	assertEqual(releaseRequest.status, BR_ACTIVE);
	
	ti := self.addContainer("UUT00000001", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.move(ti, bs);
	self.releaseAssignCargo(releaseRequest, null, ti);
	assertEqual(releaseRequest.allTrackedItemsAssigned.size, 1);
	assertEqual(releaseRequest.allReserveDetails.size, 1);
	//assertEqual(releaseRequest.allReserveDetails.first.CM_ReserveSelection.allTrackedItems.size, 1);
	assertEqual(releaseRequest.allReserveDetails.first.CM_ReserveSelection.getAllTrackedItemsSize(false), 1); //23/06/2023	navkc1	CR 58406 Task 58408
		
	releaseRequest1 := addReleaseByTypeRequest("UTRRRoad1", BR_TYPE_ROAD, TI_CargoType_Container, "2200");
	assertEqual(releaseRequest1.status, BR_ACTIVE);
	assertEqual(releaseRequest1.allReserveDetails.size, 1);
	
	self.expectTrxError(ERR_CARGO_MULTIPLE_REL); // Cannot assign the TI to a Waybill release because the TI is already assigned to a non waybill release
	self.releaseAssignCargoWithWaybill(releaseRequest1, ti);
	assertEqual(releaseRequest1.allTrackedItemsAssigned.size, 0);
	assertEqual(releaseRequest1.allReserveDetails.size, 1);

epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tWayBillRelease2" id="ec7d76ef-77a2-4af9-bd75-342361dc9dee">
        <updating/>
        <source>tWayBillRelease2()updating;
// cnwdap1
//05 November 2009	cnwml2
//+cnwml2 MSL CCMS 1012
// Create a Waybill Release and assign a TI
// Try to assign the TI to a normal release it should give an error
//23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items

vars
	releaseRequest, releaseRequest1 : CM_BulkRelease;
	ti, ti1 : CM_TrackedItem;
	bs : CM_BlockStack;
	
begin
	
	self.deleteReleaseRequest("UTRRRoad");
	self.deleteReleaseRequest("UTRRRoad1");
	self.deleteContainer("UUT00000001");
	self.deleteContainer("UUT00000002");
	self.deleteTerminalArea("UTBS1");

	bs := self.addBlockStack("UTBS1", 100, null);

	
	releaseRequest := addReleaseByTypeRequest("UTRRRoad", BR_TYPE_ROAD, TI_CargoType_Container, "2200");
	assertEqual(releaseRequest.status, BR_ACTIVE);
	
	ti := self.addContainer("UUT00000001", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.move(ti, bs);
	self.releaseAssignCargoWithWaybill(releaseRequest, ti);
	assertEqual(releaseRequest.allTrackedItemsAssigned.size, 1);
	assertEqual(releaseRequest.allReserveDetails.size, 1);
	//assertEqual(releaseRequest.allReserveDetails.first.CM_ReserveSelection.allTrackedItems.size, 1);
	assertEqual(releaseRequest.allReserveDetails.first.CM_ReserveSelection.getAllTrackedItemsSize(false), 1); //23/06/2023	navkc1	CR 58406 Task 58408
		
	releaseRequest1 := addReleaseByTypeRequest("UTRRRoad1", BR_TYPE_ROAD, TI_CargoType_Container, "2200");
	assertEqual(releaseRequest1.status, BR_ACTIVE);
	assertEqual(releaseRequest1.allReserveDetails.size, 1);
	
	self.expectTrxError(ERR_CARGO_MULTIPLE_REL); // Cannot assign the TI to a Waybill release because the TI is already assigned to a non waybill release
	self.releaseAssignCargo(releaseRequest1, null, ti);
	assertEqual(releaseRequest1.allTrackedItemsAssigned.size, 0);
	assertEqual(releaseRequest1.allReserveDetails.size, 1);

epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tWeightOnReleaseRequest" id="ba87a740-b06f-4ddd-809f-e486821d175c">
        <source>tWeightOnReleaseRequest();
/*

Purpose:			

Date		Who		Reason
16 Mar 2016	cnwmk3	Initial creation
14 Nov 2022	navma1	ChangeRequest 55381: MTN - Store format's decimal precision on Measurement Type
*/
constants
	TruckId							= "UT_TRK013";
vars
	measurementType					: CM_MeasurementType;
	proxyMeasurementType			: CM_MeasurementType;
	cargoType						: CM_CargoType;
	releaseRequest					: CM_BulkRelease;
	vvr								: CM_VehicleVisitRecord;
	weightAttr						: CM_ProductAttr;
	ti								: CM_TrackedItem;
	bs								: CM_BlockStack;
	reserveDetail					: CM_ReserveDetail;
	
	weight							: Decimal[14,4];
	defaultType						: CM_MeasurementType;
begin
	bs := self.addBlockStack("BS_01", 5, null);
	self.assertNotNull(bs);
	
	
	// get the dfault weight measurement type so we can restore it at the end of this test
	defaultType := app.getDefaultMeasurementForType(Type_Weight);
	// Set the Format for Pounds Measurement Type to 10.3 
	measurementType := app.myRoot.allMeasurementTypesByShortName["lbs"];
	
	beginLoad;
	proxyMeasurementType := measurementType.pxyCreateUpdateProxy();
	proxyMeasurementType.setProxy(measurementType.conversionRate, 10.3, measurementType.isAvailableForEntry, true, 
		measurementType.isDisplay, measurementType.isSystemType, measurementType.shortName, measurementType.measurementType, measurementType.name,3);		//14.11.2022 navma1 #55381
	endLoad;
	app.myTrxUA.trxUpdateMeasurementType(proxyMeasurementType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(measurementType.name, "Pounds");	

	// create a bulk cargo type tracked by weight
	self.opts.purge();
	self.opts.addAssoc("TrackAs", ProductType_Bulk);
	self.opts.addAssoc("AllowDuplicateId", true);
	cargoType := self.addCargoType("CType01", false);
	self.assertNotNull(cargoType);
	self.assertEqual(cargoType.trackByMeasureType, CargoType_TrackByWeight);
	
	weightAttr := cargoType.mySystemProductType.getProdAttrFromName(ETRow_MyWeight);
	self.assertNotNull(weightAttr);
	
	beginTransaction;
	weightAttr.setMyMeasurementType(measurementType);
	weightAttr.setDisplayName("Weight (lbs)");
	commitTransaction;
	self.assertEqual(cargoType.mySystemProductType.getMyWeight().myMeasurementType, measurementType);
	
	// Create a release request by type for the bulk cargo
	self.opts.purge();
	self.opts.addAssoc("WeightSelection", 42700.Decimal);
	self.opts.addAssoc("weightRequested", 42700.Decimal);
	self.opts.addAssoc("Product", cargoType.mySystemProductType);
	self.opts.addAssoc("MeasurementType", measurementType);
	releaseRequest := addReleaseByTypeRequest("UTRRROAD", BR_TYPE_ROAD, cargoType.id, "2200");
	assertEqual(releaseRequest.status, BR_ACTIVE);
	foreach reserveDetail in releaseRequest.allReserveDetails discreteLock do
		weight := app.convertMeasurementForDisplay(measurementType.shortName, reserveDetail.weightRequested).Decimal;
		self.assertEqual(weight.String, "42700.0000");
	endforeach;
	
	//  check that the total weight requested for the release is correct - 42,700
//	self.opts.purge();
//	self.opts.addAssoc(UTTI_TotalWeight, 42700.Decimal);
//	self.opts.addAssoc("MeasurementType", measurementType);
//	self.addReserveSelectionOpts( releaseRequest, null, cargoType.id);
	foreach reserveDetail in releaseRequest.allReserveDetails discreteLock do
		weight := app.convertMeasurementForDisplay(measurementType.shortName, reserveDetail.weightRequested).Decimal;
		self.assertEqual(weight.String, "42700.0000");
	endforeach;
	
	ti := self.addCargoAtLocation("UT00000001", cargoType, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), bs.myLocationsController);
	self.assertNotNull(ti);
	self.releaseAssignCargo(releaseRequest,null, ti);
		
	// Gate in a truck for the release and make sure the Release Cargo screen has the correct weight - 42,700lbs.
	self.opts.purge;
	self.opts.addAssoc("ReleaseRequest", releaseRequest);
	vvr := self.gateOutGC(TruckId, "", "UTDRIVER", ti,  self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString) , null);
	//self.assertEqual(vvr.myRoadJob.allRequests.first.weightRequested, 42700.Decimal);
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	self.deleteTerminalArea( "BS_01" );
	
epilog
	// set the "default" measurement type back to default
	if defaultType &lt;&gt; null then
		beginTransaction;
		if measurementType &lt;&gt; null then
			measurementType.setPropertyValue(CM_MeasurementType::isDefault.name, false);
			measurementType.setPropertyValue(CM_MeasurementType::format.name, "10.0".Decimal);
		endif;
		defaultType.setPropertyValue(CM_MeasurementType::isDefault.name, true);
		commitTransaction;
	endif;
	delete proxyMeasurementType;
end;</source>
    </JadeMethod>
    <JadeMethod name="uCarrierImportReleaseOpPin" id="037a3b6c-ffad-41ef-81c1-eb7b7a7da5ae">
        <source>uCarrierImportReleaseOpPin();
//cnwrd1
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 December 2010	cnwrd1	Initial creation

*/
constants
	AContainerID	= 'RJD01010101';	
	ThePin			= '123456';
vars
	theOperator : CM_Operator;
	ti,
	pxyTI		: CM_TrackedItem;
	selectedTypes: CM_CargoBOLTypeSet;
	stopsTable: CM_StopsTable;
	processAreas: IntegerArray;
	intFaceArray: CMIF_TIObjectArray;
	intFaceObj	: CMIF_CarrierRelease;
	tmpCarrierCode,
	operatorImpReleasePIN	: String;
	opts			: CM_AssociationDict;
begin

	create opts transient;
	theOperator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	// need an operator setup with 'Requires Import Operator PIN'
	self.opts.purge;
	self.opts.addAssoc( 'ReqOperImpPin', true);	
	self.updateOperator(theOperator);
	
	
	self.assertNotNullMsg( theOperator, 'Failed to get operator ' &amp; self.getProfileSetting(UT_Profile.P_OPERATOR).asString );
	self.assertEqual( theOperator.getRequiresImpOperatorPIN, true);
	
	self.deleteStopsTable(119);

//	ti := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), null);	
	
	opts.purge;
	// need to setup an operator import pin stop
	create selectedTypes transient;
	selectedTypes.add(app.myRoot.allCargoTypesById[TI_CargoType_Container]);
	create processAreas transient;
	processAreas.add(StopProcessOpExpReleaseNo);
	
	opts.addAssoc(ETRow_ProcessStopAreas, processAreas);
	opts.addAssoc( ETRow_RequiresInfo, true );
	opts.addAssoc( ETRow_CustomsInfoEntry, ImportReleasePIN );
	
	stopsTable := addStopsTable(119, "OP", "UT Oper Pin", selectedTypes, opts);

	// now bring some cargo onsite , import, set a PIN value
	
	self.deleteContainer(AContainerID);

	ti	:=	self.addContainer(AContainerID, theOperator, "2200", "MT", TI_IMEX_STATUS_IMPORT).CM_Container;
	
	//now create a CMIF_CarrierRelease/CMIF_TIObjectArray and run trxUpdateCarrierRelease
	self.opts.purge;
	self.opts.addAssoc('OperatorPin', ThePin);
	self.updateTI(ti);

	tmpCarrierCode 	:= self.getProfileSetting(UT_Profile.P_CARRIER).asString;
	
	create intFaceArray transient;
	create intFaceObj transient;	
	pxyTI := app.createUpdateProxy(ti).CM_TrackedItem;
	
	// test once with a bad pin
	operatorImpReleasePIN	:= '12356';		
	intFaceObj.operatorImportReleasePIN := operatorImpReleasePIN;
	intFaceObj.myProxyTrackedItem := pxyTI;
	pxyTI.setReleaseCarrier(tmpCarrierCode);
	intFaceArray.add(intFaceObj);

	self.expectTrxError(ERR_INVALID_VALUE); 
	self.updateCarrierRelease(intFaceArray);
	
	self.assertNull(ti.carrier);
	
	operatorImpReleasePIN	:= '123456';		
	intFaceObj.operatorImportReleasePIN := operatorImpReleasePIN;
	pxyTI.setReleaseCarrier(tmpCarrierCode);
	
	self.updateCarrierRelease(intFaceArray);
	self.assertEqual(ti.carrier,tmpCarrierCode );

epilog	
	self.opts.purge;
	self.opts.addAssoc( 'ReqOperImpPin', false);	
	self.updateOperator(theOperator);
	self.assertEqual( theOperator.getRequiresImpOperatorPIN, false);
	
	delete opts;
	delete selectedTypes;
	delete processAreas;
	delete intFaceArray;
	delete intFaceObj;
	delete pxyTI;
end;</source>
    </JadeMethod>
    <JadeMethod name="uMoveToWagonNoRelease" id="ac28a5ea-9b26-4318-be58-4fc0c73225f4">
        <source>uMoveToWagonNoRelease();
//cnwrd1 
/*

Purpose:			test operator (import release pin) requirement for otago that moves to wagon require rail release.

Parameters:			

Return Value:		


Date		Who		Reason
14 December 2010	cnwrd1	Initial creation
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

constants
	AContainerID1	= 'RJD99010101';	
	AContainerID2	= 'RJD99010102';	
	ThePin			= '123456';
	RelRequest		= 'UTOPPINREL';
	TrainCode1 : String = "UT-TRAIN1";
	RailAreaId : String = "UT_RA45";
	WagonClassId : String = "ZZ";
	WagonId1 : String = "ZZ12345678";
vars
	theOperator : CM_Operator;
	ti1, ti2	 : CM_TrackedItem;
	selectedTypes: CM_CargoBOLTypeSet;
	stopsTable: CM_StopsTable;
	processAreas: IntegerArray;
	opts: CM_AssociationDict;
	releaseRequest : CM_BulkRelease;
	bs : CM_BlockStack;
	allTIPins : CM_StringDict;
	aStringO 	: CM_String;
	terminal : CM_Terminal;
	railArea : CM_Rail;
	railLine : CM_RailLine;
	train1 : CM_Train;
	wagonClass : CM_WagonClass;
	wagonMaster1 : CM_WagonMaster;
	wagon1 : CM_Wagon;
	moveController : CMIF_MoveController;	
	wagonMoveController : CMIF_WagonMoveController;
	trainSet : CM_TrainSet;
	wagMoveController : CMIF_WagonMoveController;
	nullTi : CM_TrackedItem;
	
begin
	
	terminal := app.myPassport.myTerminal;
	
	railArea := terminal.allTerminalAreasByTypeId.getAtKey(TA_TYPE_RAILWAY_TRACK,RailAreaId).CM_Rail;

	create opts transient;
	theOperator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	// need an operator setup with 'Requires Import Operator PIN'
	self.opts.purge;
	self.opts.addAssoc( 'ReqOperImpPin', true);	
	self.updateOperator(theOperator);
	
	
	self.assertNotNullMsg( theOperator, 'Failed to get operator ' &amp; self.getProfileSetting(UT_Profile.P_OPERATOR).asString );
	self.assertEqual( theOperator.getRequiresImpOperatorPIN, true);
	
	self.deleteStopsTable(119);

//	ti := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), null);	
	
	opts.purge;
	// need to setup an operator import pin stop
	create selectedTypes transient;
	selectedTypes.add(app.myRoot.allCargoTypesById[TI_CargoType_Container]);
	create processAreas transient;
	processAreas.add(StopProcessOpExpReleaseNo);
	
	opts.addAssoc(ETRow_ProcessStopAreas, processAreas);
	opts.addAssoc( ETRow_RequiresInfo, true );
	opts.addAssoc( ETRow_CustomsInfoEntry, ImportReleasePIN );
	
	stopsTable := addStopsTable(119, "OP", "UT Oper Pin", selectedTypes, opts);

	// now bring some cargo onsite , import, set a PIN value
	
	self.deleteContainer(AContainerID1);
	self.deleteContainer(AContainerID2);

	ti1	:=	self.addContainer(AContainerID1, theOperator, "2200", "MT", TI_IMEX_STATUS_STORAGE).CM_Container;
	ti2	:=	self.addContainer(AContainerID2, theOperator, "2200", "MT", TI_IMEX_STATUS_STORAGE).CM_Container;
	
	//now create a CMIF_CarrierRelease/CMIF_TIObjectArray and run trxUpdateCarrierRelease
	self.opts.purge;
	self.opts.addAssoc('OperatorPin', ThePin);
	self.updateTI(ti1);
	self.updateTI(ti2);
	
	assertEqual(ti1.getOperatorImportReleasePIN(), ThePin);
	assertEqual(ti2.getOperatorImportReleasePIN(), ThePin);
	
	


	if railArea = null then	// doesn't get deleted, shouldn't need this bit again....
		railArea := self.addRailArea(RailAreaId, 4, 4);
		self.assertNotNull(railArea);
	endif;
	railLine := railArea.allRailLinesByIndex.first;
	

	opts.purge;
	opts.addAssoc( UTTI_State, 0 );

	//add train1
	self.deleteTrain(TrainCode1,null);
	train1 := self.addTrain(TrainCode1,null);
	self.assertNotNull(train1);
	

	// Set up the basic wagon class
	wagonClass := app.myRoot.allWagonClasses.getAtKey(WagonClassId);
	if wagonClass = null then
		wagonClass := addWagonClass(WagonClassId);
	endif;
	
	//ensure we have no WagonMaster1
	wagonMaster1 := app.myRoot.allWagonMasters.getAtKey(WagonId1);
	self.deleteWagonMasterAndWagons( wagonMaster1 ); // in case it was already there.


	//create a second wagoon on the train and add a container to it.
	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	wagon1 := self.addWagonToTrainOption3(	train1, WagonId1, wagonClass, nullTi, true, false);
	self.assertTrueMsg(wagon1 &lt;&gt; null, "Wagon2 '" &amp; WagonId1 &amp; "' not created.");
	wagonMaster1 := wagon1.myWagonMaster;
	
	self.expectTrxError(Operator_requires_rail_release);
	//this should fail with the error above, no release assigned.
	move(ti1, wagon1.allLocationsControllersArray[1]);
	
	
	//now create a release and set ti2 on it and move to rail.
	
	create allTIPins transient;
	
	self.deleteReleaseRequest(RelRequest);
	self.deleteTerminalArea("UTBS1");
	bs := self.addBlockStack("UTBS1", 100, null);
	
	releaseRequest := addReleaseByTypeRequest(RelRequest, BR_TYPE_RAIL, TI_CargoType_Container, "2200");
	assertEqual(releaseRequest.status, BR_ACTIVE);
	
	self.move(ti2, bs);
	
	
	create aStringO transient;
	aStringO.setMyObject(ti2);
	aStringO.string := ThePin;
	
	allTIPins.add(aStringO);
	
	self.move(ti2, bs);
	self.releaseAssignCargo(releaseRequest,allTIPins,  ti2);
	assertEqual(releaseRequest.allTrackedItemsAssigned.size, 1);
	assertEqual(releaseRequest.allReserveDetails.size, 1);
	//assertEqual(releaseRequest.allReserveDetails.first.CM_ReserveSelection.allTrackedItems.size, 1);
	assertEqual(releaseRequest.allReserveDetails.first.CM_ReserveSelection.getAllTrackedItemsSize(false), 1); //23/06/2023	navkc1	CR 58406 Task 58408
	assertEqual(releaseRequest.status, BR_ACTIVE);
	
	
	//this should pass
	move(ti2, wagon1.allLocationsControllersArray[1]);

	
	
epilog	
	self.opts.purge;
	self.opts.addAssoc( 'ReqOperImpPin', false);	
	self.updateOperator(theOperator);
	self.assertEqual( theOperator.getRequiresImpOperatorPIN, false);

	delete moveController;
	delete wagonMoveController;
	delete trainSet;
	delete wagMoveController;
	delete opts;
	
	self.deleteWagonMasterAndWagons( wagonMaster1 );

	
	self.deleteWagonClassAndWagons(wagonClass);
	
	self.deleteTrain(TrainCode1,null);
	
	if 	allTIPins &lt;&gt; null then
		allTIPins.purge;
	endif;
	
	delete opts;
	delete allTIPins;
end;</source>
    </JadeMethod>
    <JadeMethod name="uReleaseByWeightRoadGate" id="8c69ae47-6238-4e1a-9e80-823553591324">
        <source>uReleaseByWeightRoadGate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 December 2023	navsp1	Initial creation TFS 61547

*/

constants
	UniqueID						= "61547";
	TruckId							= "UT61547";
vars
	measurementType					: CM_MeasurementType;
	proxyMeasurementType			: CM_MeasurementType;
	cargoType						: CM_CargoType;
	releaseRequest					: CM_BulkRelease;
	vvr								: CM_VehicleVisitRecord;
	weightAttr						: CM_ProductAttr;
	ti								: CM_TrackedItem;
	bs								: CM_BlockStack;
	reserveDetail					: CM_ReserveDetail;
	
	weight							: Decimal[14,4];
	defaultType						: CM_MeasurementType;
	product : CM_Product;
begin
	bs := self.addBlockStack("BS47", 5, null);
	self.assertNotNull(bs);
	
	// create a break bulk cargo type tracked by weight
	self.opts.purge();
	self.opts.addAssoc("TrackAs", ProductType_BreakBulk);
	self.opts.addAssoc("AllowDuplicateId", true);
	cargoType := self.addCargoType("CT47", true);
	self.assertNotNull(cargoType);
	
	product := self.addProduct("PR47", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), cargoType);
	
	
	
	// Create a release request by type for the bulk cargo
	self.opts.purge();
	self.opts.addAssoc("WeightSelection", 42700.Decimal);
	self.opts.addAssoc("weightRequested", 42700.Decimal);
	self.opts.addAssoc("Product", cargoType.mySystemProductType);
	self.opts.addAssoc("ByTypeByWeight", true);
	
	ti := self.addCargoAtLocation("UTRR"&amp;UniqueID, cargoType, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), bs.myLocationsController);
	self.assertNotNull(ti);
	
	releaseRequest := addReleaseByTypeRequest("UTRR"&amp;UniqueID, BR_TYPE_ROAD, cargoType.id, "2200");
	assertEqual(releaseRequest.status, BR_ACTIVE);
	foreach reserveDetail in releaseRequest.allReserveDetails discreteLock do
		weight := app.convertMeasurementForDisplay(measurementType.shortName, reserveDetail.weightRequested).Decimal;
		self.assertEqual(weight.String, "42700.0000");
	endforeach;
	

	//self.releaseAssignCargo(releaseRequest,null, ti);
		
	// Gate in a truck for the release and make sure the Release Cargo screen has the correct weight - 42,700lbs.
	//self.opts.purge;
	//self.opts.addAssoc("ReleaseRequest", releaseRequest);
	//vvr := self.gateOutGC(TruckId, "", "UTDRIVER", ti,  self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString) , null);
	//self.assertEqual(vvr.myRoadJob.allRequests.first.weightRequested, 42700.Decimal);
	//self.workVehicle(vvr);
	//self.roadExit(vvr);
	
	//self.deleteTerminalArea( "BS_01" );
	
epilog
	// set the "default" measurement type back to default
	if defaultType &lt;&gt; null then
		beginTransaction;
		if measurementType &lt;&gt; null then
			measurementType.setPropertyValue(CM_MeasurementType::isDefault.name, false);
			measurementType.setPropertyValue(CM_MeasurementType::format.name, "10.0".Decimal);
		endif;
		defaultType.setPropertyValue(CM_MeasurementType::isDefault.name, true);
		commitTransaction;
	endif;
	delete proxyMeasurementType;
end;</source>
    </JadeMethod>
    <JadeMethod name="uReleaseForOperatorPin" id="e9db2c5e-b1d9-45fc-b763-870a13778adc">
        <updating/>
        <source>uReleaseForOperatorPin() updating;
//cnwrd1
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 December 2010	cnwrd1	Initial creation
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/


constants
	AContainerID1	= 'RJD99010101';	
	AContainerID2	= 'RJD99010102';	
	ThePin			= '123456';
	RelRequest		= 'UTOPPINREL';
vars
	theOperator : CM_Operator;
	ti1, ti2	 : CM_TrackedItem;
	selectedTypes: CM_CargoBOLTypeSet;
	stopsTable: CM_StopsTable;
	opts		: CM_AssociationDict;
	processAreas: IntegerArray;
	releaseRequest : CM_BulkRelease;
	bs : CM_BlockStack;
	allTIPins : CM_StringDict;
	aStringO 	: CM_String;
begin

	create opts transient;
	theOperator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	// need an operator setup with 'Requires Import Operator PIN'
	self.opts.purge;
	self.opts.addAssoc( 'ReqOperImpPin', true);	
	self.updateOperator(theOperator);
	
	
	self.assertNotNullMsg( theOperator, 'Failed to get operator ' &amp; self.getProfileSetting(UT_Profile.P_OPERATOR).asString );
	self.assertEqual( theOperator.getRequiresImpOperatorPIN, true);
	
	self.deleteStopsTable(119);

//	ti := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), null);	
	
	opts.purge;
	// need to setup an operator import pin stop
	create selectedTypes transient;
	selectedTypes.add(app.myRoot.allCargoTypesById[TI_CargoType_Container]);
	create processAreas transient;
	processAreas.add(StopProcessOpExpReleaseNo);
	
	opts.addAssoc(ETRow_ProcessStopAreas, processAreas);
	opts.addAssoc( ETRow_RequiresInfo, true );
	opts.addAssoc( ETRow_CustomsInfoEntry, ImportReleasePIN );
	
	stopsTable := addStopsTable(119, "OP", "UT Oper Pin", selectedTypes, opts);

	// now bring some cargo onsite , import, set a PIN value
	
	self.deleteContainer(AContainerID1);
	self.deleteContainer(AContainerID2);

	ti1	:=	self.addContainer(AContainerID1, theOperator, "2200", "MT", TI_IMEX_STATUS_STORAGE).CM_Container;
	ti2	:=	self.addContainer(AContainerID2, theOperator, "2200", "MT", TI_IMEX_STATUS_STORAGE).CM_Container;
	
	//now create a CMIF_CarrierRelease/CMIF_TIObjectArray and run trxUpdateCarrierRelease
	self.opts.purge;
	self.opts.addAssoc('OperatorPin', ThePin);
	self.updateTI(ti1);
	self.updateTI(ti2);
	
	assertEqual(ti1.getOperatorImportReleasePIN(), ThePin);
	assertEqual(ti2.getOperatorImportReleasePIN(), ThePin);
	

	create allTIPins transient;
	
	self.deleteReleaseRequest(RelRequest);
	self.deleteTerminalArea("UTBS1");
	bs := self.addBlockStack("UTBS1", 100, null);
	
	releaseRequest := addReleaseByTypeRequest(RelRequest, BR_TYPE_RAIL, TI_CargoType_Container, "2200");
	assertEqual(releaseRequest.status, BR_ACTIVE);
	
	self.move(ti1, bs);
	
	create aStringO transient;
	aStringO.setMyObject(ti1);
	aStringO.string := 'BADPIN';
	allTIPins.add(aStringO);
	

	
	self.expectTrxError(ERR_INVALID_VALUE); 
	self.releaseAssignCargo(releaseRequest,allTIPins,  ti1);
	assertEqual(releaseRequest.allTrackedItemsAssigned.size, 0);
	assertEqual(releaseRequest.allReserveDetails.size, 1);
	//assertEqual(releaseRequest.allReserveDetails.first.CM_ReserveSelection.allTrackedItems.size, 1);
	assertEqual(releaseRequest.allReserveDetails.first.CM_ReserveSelection.getAllTrackedItemsSize(false), 1); //23/06/2023	navkc1	CR 58406 Task 58408
		
	self.clearExpectedTrxErrors(); 
	
	allTIPins.purge;
	
	create aStringO transient;
	aStringO.setMyObject(ti2);
	aStringO.string := ThePin;
	
	allTIPins.add(aStringO);
	
	self.move(ti2, bs);
	self.releaseAssignCargo(releaseRequest,allTIPins,  ti2);
	assertEqual(releaseRequest.allTrackedItemsAssigned.size, 1);
	assertEqual(releaseRequest.allReserveDetails.size, 1);
	//assertEqual(releaseRequest.allReserveDetails.first.CM_ReserveSelection.allTrackedItems.size, 2);
	assertEqual(releaseRequest.allReserveDetails.first.CM_ReserveSelection.getAllTrackedItemsSize(false), 2); //23/06/2023	navkc1	CR 58406 Task 58408
	assertEqual(releaseRequest.status, BR_ACTIVE);
	

epilog
	self.opts.purge;
	self.opts.addAssoc( 'ReqOperImpPin', false);	
	self.updateOperator(theOperator);
	self.assertEqual( theOperator.getRequiresImpOperatorPIN, false);
	
	allTIPins.purge;
	delete opts;
	delete allTIPins;
end;</source>
    </JadeMethod>
    <JadeMethod name="uUnallocateTIAfterInternalMove" id="408c4892-3e6b-4f60-8e1d-843d20d7eb0d">
        <source>uUnallocateTIAfterInternalMove();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2013	cnwpjs1	Initial creation PAR # 31294

*/
constants

	BlockStackId1		: String = "UTBS1";
	BlockStackId2		: String = "UTBS2";
	ContainerId1		: String = "UTMCONT1";
	ContainerId2		: String = "UTMCONT2";


vars
	terminal			: CM_Terminal;
	bs1					: CM_BlockStack;
	bs2					: CM_BlockStack;
	ti1					: CM_TrackedItem;
	ti2					: CM_TrackedItem;

begin

	terminal := self.getTerminal();


	// create terminal areas
	self.deleteTerminalArea(BlockStackId1);
	bs1 := self.addBlockStack(BlockStackId1, 10, null);
	self.assertNotNull(bs1);
	self.deleteTerminalArea(BlockStackId2);
	bs2 := self.addBlockStack(BlockStackId2, 10, null);
	self.assertNotNull(bs2);
	
	// create cargo
	self.deleteContainer(ContainerId1);
	ti1 := self.addContainerAtLocation(ContainerId1, null, "2200", "MT", TI_IMEX_STATUS_STORAGE, bs1);
	//self.updateTI(ti1);  not required - no options
	
	self.deleteContainer(ContainerId2);
	ti1 := self.addContainerAtLocation(ContainerId2, null, "2200", "MT", TI_IMEX_STATUS_STORAGE, bs1);
	//self.updateTI(ti2);  not required - no options
 	
	
	// create rt stuff
	// creaet yard allocations
	// create machines
	// create rail stuff
	// packing release
	// delivery release
	// move 1 of the items
	// rail release
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="x31460AssignRRToSlots" id="98cb928f-74d1-48cf-a3b4-57446bfb1a88">
        <source>x31460AssignRRToSlots(_slotsToLoadCC : StringArray; _releaseRequest : CM_BulkRelease; _voyage : CM_Voyage; _deck : CM_DeckVoyage;  _roroLCs	: CM_LCArray io);

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
24 April 2013	cnwmh5	Initial creation

*/

vars

	slotsToLoad				: CM_LCArray;

	str 					: String;

begin

	if not _slotsToLoadCC.isEmpty() then

		create slotsToLoad transient;
	
		foreach str in _slotsToLoadCC do
			self.getJobROROControllerByID(_voyage.code, _deck.code, null, str, slotsToLoad, true, 1);
		endforeach;
		slotsToLoad.copy(_roroLCs);
	
	endif;
	
	// assign the release request
	app.myTrxUA.trxROROControlerUpdateRelease(_roroLCs, _releaseRequest.getReserveDetail(),  app.myPassport);	
	self.assertNoTrxErrorsOrWarnings();
	

epilog

	delete slotsToLoad;

end;</source>
        <Parameter name="_slotsToLoadCC" type="StringArray"/>
        <Parameter name="_releaseRequest" type="CM_BulkRelease"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_deck" type="CM_DeckVoyage"/>
        <Parameter name="_roroLCs" type="CM_LCArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="x31460CCSelectPutInJob" id="3c5063cb-885b-4bf3-817e-1135c6a7674c">
        <updating/>
        <source>x31460CCSelectPutInJob(_jobName, _isoType : String; _voyage : CM_Voyage io; _deck : CM_DeckVoyage; _slotsToLoadCC	: StringArray; _lcs	: CM_LCArray io) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
24 April 2013	cnwmh5	Initial creation

*/

vars

	realAlloc 						: CM_VoyageAllocation;
	voyageJob						: CM_VoyageJob;
	dischargePort					: CM_Port;

	slotsToLoad 					: CM_LCArray;
	altSlotsToLoad					: CM_LCArray;

	str 							: String;
	
begin

	dischargePort := app.myRoot.allPorts["NZAKL"];
	self.assertNotNull(dischargePort);

	create slotsToLoad transient;
	create altSlotsToLoad transient;
	
	foreach str in _slotsToLoadCC do
		self.getJobROROControllerByID(_voyage.code, _deck.code, null, str, slotsToLoad, true, 1);
	endforeach;
	
	self.opts.purge();
	self.opts.addAssoc("ISOType", _isoType);
	self.opts.addAssoc("Operator", _voyage.myOperator);
	realAlloc := self.addVoyageAllocation(_voyage, dischargePort.code, "", "", 1, false, false);	
	self.assertNotNull(realAlloc);
	self.addLCsToROROAllocation(true, realAlloc, slotsToLoad, altSlotsToLoad, 1);
	
	// setup the job
	slotsToLoad.copy(_lcs);
	voyageJob := self.addVoyageROROJob(_voyage, _deck, _jobName, _lcs, false);
	assertTrue(voyageJob &lt;&gt; null);

epilog

	delete slotsToLoad;
	delete altSlotsToLoad;

end;</source>
