    <JadeMethod name="addReceiveToHistory" id="062e1cd1-1f22-477e-8690-d49454ff3704">
        <source>addReceiveToHistory(_wle :CM_VoyageWLE) protected;
// ---------------------------------------------------------------------------
// Created:     07 December 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	crane		:CM_Crane;
	history		:CM_MachineMoveHistory;
begin
	crane := self.getCrane;
	
	if crane = null then
		// nowhere to add history
		return;
	endif;
	
	history := crane.addReceiveReleaseToHistory (self, _wle);	
	
	history.setMyShipReceiveTrx (self);
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_wle" type="CM_VoyageWLE"/>
    </JadeMethod>
    <JadeMethod name="canEditAmount" id="8d1ddc70-9137-4db4-9a89-7a91d06054d1">
        <source>canEditAmount(): Boolean;
/*

Date		Who		Reason
07 December 2016	cnwer1	Initial creation TFS 2996

*/

vars
	ct : CM_CargoType;
	subType : CM_Product;
begin
	
	self.getCargoTypeAndSubType(ct,subType);
	
	if ct = null or not ct.allowDuplicates then
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
