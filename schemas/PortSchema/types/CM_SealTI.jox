    <JadeMethod name="getSealValueAsString" id="d60ba194-57ef-47fb-810f-83dd991064fb">
        <source>getSealValueAsString():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 September 2010	cnwndl1	Initial creation	Par 25608

*/

vars

	token : String;
	str : String;
	
begin
	
	foreach token in self.allSealNums do
		token := token.trimWhiteSpace;
		if token = null then
			continue;
		endif;
		
		if str &lt;&gt; null then
			str := str &amp; "," &amp; token;
		else
			str := token;
		endif;			
	endforeach;
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTokens" id="951bbe06-ae5b-47d3-b3a9-db4e2a1f6ce7">
        <source>getTokens(_str : String; _tokens: HugeStringArray input);
//17 August 2010	cnwml2
//+cnwml2 PAR23715 SFW CCMS1131
/* Changes

Date		Name	TFS#		Description
============================================================================
29 Mar 2019 jlgka1	TFS 44020	Change StringArray to HugeStringArray.
============================================================================*/
constants
	Delimiters = ",";
vars
	pos: Integer;
	token: String;
	
begin
	if _str = null then	
		return;
	endif;
	
	while true do
		pos := pos + 1;
		
		if pos &gt; _str.length then // cnwrd1 18.3.09 gives error if string is 'xxx,'
			break;
		endif;
		token := _str.scanUntil( Delimiters, pos ).trimBlanks;
		if token &lt;&gt; null then
			_tokens.add( token );
		endif;
		if pos = 0 then
			break;
		endif;
	endwhile;
end;</source>
        <Parameter name="_str" type="String"/>
        <Parameter name="_tokens" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="matchesValueFromUser" id="f702fd36-6c8b-4c33-95d0-8972cef4e5b6">
        <source>matchesValueFromUser( userValue : String ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 September 2010	cnwndl1	Initial creation	Par 25608

*/

vars

	theSealType : CM_SealType;
	multiSeal : Boolean;
	strArray : CnStringArray;
	pos : Integer;
	storedValue : String;
	userPos : Integer;
	
begin

	if self.allSealNums = null or self.allSealNums.isEmpty then
		// we have no value stored
		return (userValue = null).Boolean;
	endif;
	
	// if we are here, we have a stored value. So if the incoming value is null, we have no match.
	if userValue = null then
		return false;
	endif;
	
	// so if we are this far thru, both sides must have a value...
	
	// is the seal type allowed to have multiple seal values
	theSealType := app.myRoot.getSealType(self.sealType);
	if theSealType &lt;&gt; null then
		multiSeal := theSealType.allowMultipleSealNums;
	endif;
			
	if not multiSeal then
		// only one value allowed, does it match.
		return (userValue = self.allSealNums.first).Boolean;
		
	else
		// multiples allowed, need to cross check values to make sure we have the same number of values, and
		// that the values match, but the values wont necessarily be in teh same order.
		// We only allow a single comma character "," as the delimiter. 
		
		// get a list of the comma delimited tokens, from the user entered value.
		strArray := userValue.cnGetTokens(",");
		if strArray.size &lt;&gt; self.allSealNums.size then
			// a different number of seal values, that's a mis match.
			return false;
		endif;
		
		// iterate thru the collection of recorded values, find teh matching one in our local users array
		// and remove it. (to make sure we don't compare to the same value twice.)
		foreach pos in 1 to self.allSealNums.size do
			storedValue := self.allSealNums[pos];
			userPos := strArray.indexOf(storedValue);
			if userPos &lt; 1 then
				// this value wasn't recorded by the user
				return false;
			endif;
			strArray.removeAt(userPos);
		endforeach;
		
		//they must have all matched.
		return true;
		
	endif;

epilog

	delete strArray;
	
end;</source>
        <Parameter name="userValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="6efb1128-6143-4505-a7c3-c90f247ccceb">
        <source>pxyCreateUpdateProxy(): SelfType;
//17 August 2010	cnwml2
//+cnwml2 PAR23715 SFW CCMS1131
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	pxySeal : CM_SealTI;
	completedOK		: Boolean;
begin
	pxySeal := inheritMethod();

	pxySeal.previousSeal := self.previousSeal;
	pxySeal.sealType := self.sealType;
	pxySeal.sealedDT := self.sealedDT;

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxySeal;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxySeal;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="bd901be1-bd6a-4bc9-86b0-a8198808256c">
        <updating/>
        <source>setForCreate(_pxySealTI : CM_SealTI)updating;
//17 August 2010	cnwml2
//+cnwml2 PAR23715 SFW CCMS1131

vars
	sealTypeObj : CM_SealType;
begin
	self.sealType := _pxySealTI.sealType;
	sealTypeObj := app.myRoot.allSealTypes[self.sealType];
	if sealTypeObj &lt;&gt; null and not sealTypeObj.isInUse then
		sealTypeObj.setIsInUse(true);
	endif;
//	self.setMyTrackedItem( _pxySealTI.myTrackedItem);	//07 Jan 2011	NDL	 Par 26703
	self.setForUpdate(_pxySealTI);
epilog

end;</source>
        <Parameter name="_pxySealTI" type="CM_SealTI"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="15f99f96-af0f-4351-bfdf-950bc008708c">
        <updating/>
        <source>setForUpdate(_pxySealTI : CM_SealTI)updating;
//17 August 2010	cnwml2
//+cnwml2 PAR23715 SFW CCMS1131
/* Changes

Date		Name	TFS#		Description
============================================================================
29 Mar 2019 jlgka1	TFS 44020	Change StringArray to HugeStringArray.
============================================================================*/
vars
	str 	 : String;
	strArray : HugeStringArray; //jlgka1 TFS 44020
	sealType : CM_SealType;
begin
	self.previousSeal := _pxySealTI.previousSeal;
	self.sealedDT := _pxySealTI.sealedDT;
	self.allSealNums.purge();
	sealType := app.myRoot.allSealTypes[_pxySealTI.sealType];
	if _pxySealTI.allSealNums.isEmpty then	//17 Sep 2010	NDL Par 25608
		return;
	endif;
	if sealType.allowMultipleSealNums then
		if _pxySealTI.allSealNums.first.containsOneOf(",") then
			str := _pxySealTI.allSealNums.first;
			create strArray transient;
			self.getTokens(str, strArray);
			strArray.copy(self.allSealNums);
		else
			_pxySealTI.allSealNums.copy(self.allSealNums);
		endif;
	else
		_pxySealTI.allSealNums.copy(self.allSealNums);
	endif;
epilog

	delete strArray;	//07 Jan 2011	NDL Par 26703

end;</source>
        <Parameter name="_pxySealTI" type="CM_SealTI"/>
    </JadeMethod>
