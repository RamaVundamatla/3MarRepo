    <JadeMethod name="tColourCriteria" id="7eae9fc9-5901-4856-85d4-8f87c0d155e9">
        <source>tColourCriteria();
// cnwndl1
//29 August 2008	cnwdw1	
//
vars
	locations : CM_LCArray;
	ya: CM_YardAllocation;
	ti1, ti2: CM_TrackedItem;
	location: CM_LocationsController;
	bs1, bs2 : CM_BlockStack;
begin
	bs1 := addBlockStack("UTBS1", 100, null);
	bs2 := addBlockStack("UTBS2", 100, null);

	ti1 := self.addCannonAtLocation("UCAN1", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), bs1);
	self.opts.addAssoc("Colour", "Red");
	self.opts.addAssoc("TotalWeight", 25);
	self.updateTI(ti1);
	assertEqual(ti1.getColour, "Red");
	
	ti2 := self.addCannonAtLocation("UCAN2", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), bs1);
	self.opts.addAssoc("Colour", "BLUE");
	self.opts.addAssoc("TotalWeight", 25);
	self.updateTI(ti2);
	assertEqual(ti2.getColour, "BLUE");
	
	// Create a YA to match a container colour
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_Colour, "RED", bs2.allLocationsControllers.first);
	assertEqual(ya.allCriteria.size, 1);
	assertTrue(ya.allCriteria.first.myYAData.isKindOf(CM_YADataString));

	// Test that a matching colour succeeds
	location := app.autoPlanTiYA(self.getTerminal, bs2, ti1);
	self.assertEqualMsg(location, bs2.allLocationsControllers.first, "Did not autoplan to correct location");

	// Test that a non matching colour fails
	location := app.autoPlanTiYA(self.getTerminal, bs2, ti2);
	self.assertNull(location);

epilog
end;
</source>
    </JadeMethod>
    <JadeMethod name="tContainerLengthCriteria" id="2a06b50f-364d-497c-bf2c-8fad5b5be561">
        <source>tContainerLengthCriteria();
// cnwndl1
//29 August 2008	cnwdw1	
//
vars
	containers: String;
	locations : CM_LCArray;
	ya: CM_YardAllocation;
	ti20, ti40: CM_TrackedItem;
	location: CM_LocationsController;
	ta: CM_GridArea;
begin
	deleteTerminalArea("UTSTRD");
	ta:= addStraddleStack("UTSTRD", 2, 2, 1);
	assertNotNullMsg(ta, "straddleStack");

	self.deleteContainer("TEST0000001");
	self.deleteContainer("TEST0000002");
	ti20 := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	ti40 := self.addContainerOpts("TEST0000002", "4000", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	create locations transient;
	locations.add(ta.allGridControllersByRowColumn[1, 1]);
	locations.add(ta.allGridControllersByRowColumn[1, 2]);
	
	self.deleteYA("UT");
	containers := "20";
	ya := self.addYA1("UT", YACriteriaType_ContainerLength, containers, locations);
	location := app.autoPlanTiYA(self.getTerminal, ta, ti20);
	self.assertEqualMsg(location, locations.first, "Did not autoplan 20 to correct location");

	self.deleteYA("UT");
	containers := "20";
	ya := self.addYA1("UT", YACriteriaType_ContainerLength, containers, locations);
	location := app.autoPlanTiYA(self.getTerminal, ta, ti40);
	self.assertTrueMsg(location = null, "Location not null");
	
	self.deleteYA("UT");
	containers := "20,40";
	ya := self.addYA1("UT", YACriteriaType_ContainerLength, containers, locations);
	location := app.autoPlanTiYA(self.getTerminal, ta, ti40);
	self.assertEqualMsg(location, locations.first, "Did not autoplan 40 to correct location");

	self.deleteYA("UT");
	containers := "20,40";
	ya := self.addYA1("UT", YACriteriaType_ContainerLength, containers, locations);
	location := app.autoPlanTiYA(self.getTerminal, ta, ti20);
	self.assertEqualMsg(location, locations.first, "Did not autoplan 20 to correct location");

	self.deleteYA("UT");
	containers := "40";
	ya := self.addYA1("UT", YACriteriaType_ContainerLength, containers, locations);
	location := app.autoPlanTiYA(self.getTerminal, ta, ti20);
	self.assertTrueMsg(location = null, "Location not null");

	self.deleteYA("UT");
	containers := "40";
	ya := self.addYA1("UT", YACriteriaType_ContainerLength, containers, locations);
	location := app.autoPlanTiYA(self.getTerminal, ta, ti40);
	self.assertEqualMsg(location, locations.first, "Did not autoplan 40 to correct location");

epilog
	delete locations;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tCurtainsInCriteria" id="2c911009-7b1d-4929-b2db-267e74037596">
        <source>tCurtainsInCriteria();
// cnwndl1
//29 August 2008	cnwdw1	
//
vars
	locations : CM_LCArray;
	ya: CM_YardAllocation;
	proxyTI, ti, ti2: CM_TrackedItem;
	location: CM_LocationsController;
	ta: CM_GridArea;
begin
	deleteTerminalArea("UTSTRD");
	// want to create a stack with POWER!
	self.opts.addAssoc('WITHPOWER', true);
	ta:= addStraddleStack("UTSTRD", 2, 2, 1);
	assertNotNullMsg(ta, "straddleStack");

	
	self.deleteContainer("TEST0000001");
	proxyTI := createContainer("TEST0000001", "2232", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),true); // REEFER
	proxyTI.CM_Container.setPxyControlledAtmosphere(20, 30, true);
	ti := self.addContainerFromProxy(proxyTI); 
	assertTrueMsg(ti.CM_Container.getCurtainsIn = true, "Curtains in should be true");

	self.deleteContainer("TEST0000002");
	proxyTI := createContainer("TEST0000002", "2232", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),true); // REEFER
	proxyTI.CM_Container.setPxyControlledAtmosphere(20, 30, false);
	ti2 := self.addContainerFromProxy(proxyTI); 
	assertTrueMsg(ti2.CM_Container.getCurtainsIn = false, "Curtains in should be false");

	create locations transient;
	locations.add(ta.allGridControllersByRowColumn[1, 1]);
	locations.add(ta.allGridControllersByRowColumn[1, 2]);
	
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_CurtainsIn, CM_YADataBoolean.VALUE_TRUE, locations);
	location := app.autoPlanTiYA(self.getTerminal, ta, ti);
	self.assertEqualMsg(location, locations.first, "Did not autoplan container to correct location");

	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_CurtainsIn, CM_YADataBoolean.VALUE_FALSE, locations);
	location := app.autoPlanTiYA(self.getTerminal, ta, ti);
	self.assertEqualMsg(location, null, "Should fail autoplanning");

	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_CurtainsIn, CM_YADataBoolean.VALUE_TRUE, locations);
	location := app.autoPlanTiYA(self.getTerminal, ta, ti2);
	self.assertEqualMsg(location, null, "Should fail autoplanning");

	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_CurtainsIn, CM_YADataBoolean.VALUE_FALSE, locations);
	location := app.autoPlanTiYA(self.getTerminal, ta, ti2);
	self.assertEqualMsg(location, locations.first, "Did not autoplan container to correct location");

epilog
	delete locations;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tDateRangeCriteria" id="a9fd4f4d-dad8-4f8b-bb87-f3216786b272">
        <source>tDateRangeCriteria();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 03/06/2025	navdap1		Initial creation MTN-34981 MTN -Yard Allocations - Storing Cargo Based on a Date Range
//
constants
	BS1 : String = "UT13861BS1";
	BSRecDate : String = "13861BSR";
	BSPTDate : String = "13861BSP";
	BSSTDate : String = "13861BSS";
	ContRecDate : String = "CONT13861-1";
	ContSTDate : String = "CONT13861-2";
	ContPTDate : String = "CONT13861-3";
	SubTerm1Code : String = "UT_DPTA";
	SubTerm2Code : String= "UT_DPTB";
	YARecDate : String = "YARECDATE";
	YAPTIDate : String = "YAPTIDATE";
	YASubTermDate : String = "YASUBTERMDATE";
	
vars
	terminal : CM_Terminal;
	subTerminalsEnabled : Boolean;
	subTerm1, subTerm2 : CM_SubTerminal;
	resetSubTermAreaDefined	: Boolean;
	ti1, ti2, ti3 : CM_TrackedItem;
	bs1, bsRecDate, bsPTDate, bsSubTerm : CM_BlockStack;
	operator : CM_Operator;
	pxySubTermDef, realSubTermDef : CM_SubTerminalAreaDef;
	selectedObjects : ObjectSet;
	tiTrans : CM_TITransaction;
	yaRecDate, yaPTIDate, yaSTDate : CM_YardAllocation;
	location : CM_LocationsController;
	locationId : String;
	
begin
	terminal := self.getTerminal();
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	// Ensure terminal has sub-teminals turned on
	subTerminalsEnabled := self.getTerminalConfig(IsSubTerminalsOn).Boolean;
	self.setTerminalConfig(IsSubTerminalsOn, true);
	
	self.assertTrueMsg(app.isSubTerminalsLicensed, "Not licensed for sub terminals!");
	self.assertTrueMsg(app.isSubTerminalsOn(terminal), terminal.name &amp; " not set up for sub terminals!");
	
	// Set up stuff - block stacks, containers, subterminals
	self.deleteCargo(ContRecDate, "CONT");
	self.deleteCargo(ContPTDate, "CONT");
	self.deleteCargo(ContSTDate, "CONT");
	self.deleteTerminalArea(BS1);
	self.deleteTerminalArea(BSRecDate);
	self.deleteTerminalArea(BSPTDate);
	self.deleteTerminalArea(BSSTDate);
	self.deleteSubTerminal(SubTerm1Code);
	self.deleteSubTerminal(SubTerm2Code);
	
	// Disable all yard allocations so ours are the only ones in play
	self.disableAllYA(true);
	
	// Create the block stacks
	bs1 := self.addBlockStack(BS1, 100, null);
	bsRecDate := self.addBlockStack(BSRecDate, 100, null);
	bsPTDate := self.addBlockStack(BSPTDate, 100, null);
	bsSubTerm := self.addBlockStack(BSSTDate, 100, null);
	
	// Create sub terminals
	subTerm1 := self.addSubTerminal(SubTerm1Code, SubTermType_Depot_Int);
	subTerm2 := self.addSubTerminal(SubTerm2Code, SubTermType_Depot_Int);
	if not terminal.getConfig(IsSubTerminalAreaDefined).Boolean then
		resetSubTermAreaDefined := true;
		self.setSubTerminalAreaDefined(true);	
	endif;
	
	// Add terminal areas to separate sub-terminals
	create pxySubTermDef transient;
	create selectedObjects transient;
	selectedObjects.add(bs1);
	pxySubTermDef.setProxy(subTerm1.code, subTerm1.description, false, selectedObjects, subTerm1, terminal);
	app.myTrxCA.trxCreateSubTerminalAreaDef(pxySubTermDef, realSubTermDef, app.myPassport);
	self.assertEqualMsg(bs1.mySubTerminalAreaDef, realSubTermDef, BS1 &amp; " doesn't have the right sub terminal def");
	
	delete pxySubTermDef;
	delete selectedObjects;
	create pxySubTermDef transient;
	create selectedObjects transient;
	selectedObjects.add(bsRecDate);
	pxySubTermDef.setProxy(subTerm2.code, subTerm2.description, false, selectedObjects, subTerm2, terminal);
	app.myTrxCA.trxCreateSubTerminalAreaDef(pxySubTermDef, realSubTermDef, app.myPassport);
	self.assertNoTrxErrorsPassport(app.myPassport.getAllErrorsAndWarningsAsStr);
	self.assertEqualMsg(bsRecDate.mySubTerminalAreaDef, realSubTermDef, BSRecDate &amp; " doesn't have the right sub terminal def");
	
	// Create the cargo in BS1
	ti1 := self.addContainerAtLocation(ContRecDate, operator, "22G1", "GENL", TI_IMEX_STATUS_EXPORT, bs1);
	ti2 := self.addContainerAtLocation(ContPTDate, operator, "22R1", "GENL", TI_IMEX_STATUS_EXPORT, bs1);
	ti3 := self.addContainerAtLocation(ContSTDate, operator, "22G1", "GENL", TI_IMEX_STATUS_EXPORT, bs1);
	
	// ti1 will have its receival date changed to match a Receival Date Range yard allocation
	// ti2 will have its pre-trip inspection date changed to match a Pre-Trip Inspection Date Rabge yard allocation
	// ti3 will be moved from one sub-terminal to another, then have its Sub-Terminal Move date changed
	// to match a Sub-Terminal Move Date Range yard allocation
	beginTransaction;
	ti1.setPropertyValue(CM_TrackedItem::receivedDT.name, "12/05/2025 10:30".TimeStamp);
	ti2.setPreTripDT("22/05/2025 11:00".TimeStamp);
	commitTransaction;
	
	self.moveCargo(ti3, null, bsRecDate.myLocationsController, app.myPassport);
	self.assertTrueMsg(ti3.myPrimaryActualLocation = bsRecDate.myLocationsController, ContSTDate &amp; " not moved to " &amp; BSRecDate);
	
	tiTrans := ti3.allTransactions.findLastSubTermReceivalTrans();
	self.assertNotNullMsg(tiTrans, ContSTDate &amp; " has no Sub-Terminal Received transaction");
	beginTransaction;
	tiTrans.setPropertyValue(CM_TITransaction::dateTime.name, "02/05/2025 18:00".TimeStamp);
	commitTransaction;
	self.assertEqualMsg(tiTrans.dateTime.date, "02/05/2025".Date, "Sub-Terminal receival transaction has the wrong date - " &amp; tiTrans.dateTime.date.asStringJMT);
	
	// Set up Yard Allocations
	// Delete existing
	self.deleteYA(YARecDate);
	self.deleteYA(YAPTIDate);
	self.deleteYA(YASubTermDate);
	// Create new
	yaRecDate := self.addYA1(YARecDate, YACriteriaType_RecDateRange, "10/05/2025|13/05/2025", bsRecDate.allLocationsControllers.first);
	self.assertEqualMsg(yaRecDate.allCriteria.size, 1, "Receival Date allocation has " &amp; yaRecDate.allCriteria.size.String &amp; " criteria");
	self.assertTrueMsg(yaRecDate.allCriteria.first.myYAData.isDateRangeValue, "Receival allocation criteria is the wrong kind");
	
	yaPTIDate := self.addYA1(YAPTIDate, YACriteriaType_PTIDateRange, "20/05/2025|23/05/2025", bsPTDate.allLocationsControllers.first);
	self.assertEqualMsg(yaPTIDate.allCriteria.size, 1, "Pre-Trip Inspection Date allocation has " &amp; yaPTIDate.allCriteria.size.String &amp; " criteria");
	self.assertTrueMsg(yaPTIDate.allCriteria.first.myYAData.isDateRangeValue, "Pre-Trip Inspection allocation criteria is the wrong kind");
	
	yaSTDate := self.addYA1(YASubTermDate, YACriteriaType_STDateRange, "01/05/2025|05/05/2025", bsSubTerm.allLocationsControllers.first);
	self.assertEqualMsg(yaSTDate.allCriteria.size, 1, "Sub-Terminal Receival Date allocation has " &amp; yaSTDate.allCriteria.size.String &amp; " criteria");
	self.assertTrueMsg(yaSTDate.allCriteria.first.myYAData.isDateRangeValue, "Sub-Terminal Receival allocation criteria is the wrong kind");
	
	// Actual Unit Test starts here - plan the cargo items and make sure they plan to the right places
	// CONT13861-1 should go to Block Stack 13861BSR because of its receival date
	location := app.autoPlanTiYA(terminal, null, ti1);
	if location &lt;&gt; null then
		locationId := location.ident;
	else
		locationId := null;
	endif;
	self.assertEqualMsg(location, bsRecDate.allLocationsControllers.first, "Receival Date Auto-plan failed - is planned to " &amp; locationId);
	
	// CONT13861-2 should go to Block Stack 13861BSP because of its pre-trip inspection date
	location := app.autoPlanTiYA(terminal, null, ti2);
	if location &lt;&gt; null then
		locationId := location.ident;
	else
		locationId := null;
	endif;
	self.assertEqualMsg(location, bsPTDate.allLocationsControllers.first, "Pre-Trip Inspection Date Auto-plan failed - is planned to " &amp; locationId);
	
	// CONT13861-3 should go to Block Stack 13861BSS because of its sub-terminal receival date
	location := app.autoPlanTiYA(terminal, null, ti3);
	if location &lt;&gt; null then
		locationId := location.ident;
	else
		locationId := null;
	endif;
	self.assertEqualMsg(location, bsSubTerm.allLocationsControllers.first, "Sub-Terminal Receival Date Auto-plan failed - is planned to " &amp; locationId);
	
epilog
	self.setTerminalConfig(IsSubTerminalsOn, subTerminalsEnabled);
	if resetSubTermAreaDefined then
		self.setSubTerminalAreaDefined( false );
	endif;

	// Delete the sub terminals
	self.deleteSubTerminal(SubTerm1Code);
	self.deleteSubTerminal(SubTerm2Code);
	
	// Enable all yard allocations again
	self.disableAllYA(false);
	
	delete selectedObjects;
	delete pxySubTermDef;
end;</source>
    </JadeMethod>
    <JadeMethod name="tFTAAddAlert" id="04a6c198-83ca-4a9f-acff-e74312d8f212">
        <updating/>
        <source>tFTAAddAlert() updating;
// cnwndl1
//30 September 2008	cnwdw1	
// Test that when a ti fails to autoplan, an alert is created
vars
	ya: CM_YardAllocation;
	blockStack1: CM_BlockStack;
	container1: CM_TrackedItem;
	location: CM_LocationsController;
	alert: CM_SystemAlert;
	
begin
	deleteTerminalArea("UTBS1");
	blockStack1 := addBlockStack("UTBS1", 1, null);
	assertNotNullMsg(blockStack1, "blockStack1");
	
	self.deleteContainer("TEST0000001");
	container1 := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	

	self.deleteAlerts();
	
	on Exception do self.exHandlerAssertException(exception);
	location := app.autoPlanTiYA(self.getTerminal, blockStack1, container1);
	assertExceptionRaised(79961, "autoplan didn't failed");
	assertEqualMsg(self.getTerminal().allSystemAlertsByDateTime.size, 1, "alert not created");
	alert := self.getTerminal().allSystemAlertsByDateTime.first;
	assertNotNullMsg(alert.mySystemAlertType, "alert.mySystemAlertType");
	assertEqualMsg(alert.mySystemAlertType.type, EVENT_AT_FailedAutoPlan, "alert has wrong type");
	assertTrueMsg(container1.mySystemAlerts.size = 1, "Container did not have alert set");
	
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="tFTADeleteAlert" id="7e4cb008-2dab-4164-b8d8-0614052c753f">
        <updating/>
        <source>tFTADeleteAlert() updating;
// cnwndl1
//30 September 2008	cnwdw1	
// Test that when a FTA alert is deleted in sends  a delete note
vars
	ya: CM_YardAllocation;
	blockStack1: CM_BlockStack;
	container1: CM_TrackedItem;
	location: CM_LocationsController;
	alert: CM_SystemAlert;
	
begin
	deleteTerminalArea("UTBS1");
	blockStack1 := addBlockStack("UTBS1", 1, null);
	assertNotNullMsg(blockStack1, "blockStack1");
	
	self.deleteContainer("TEST0000001");
	container1 := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	

	self.deleteAlerts();
	
	on Exception do self.exHandlerAssertException(exception);
	location := app.autoPlanTiYA(self.getTerminal, blockStack1, container1);
	assertExceptionRaised(79961, "autoplan didn't failed");
	assertEqualMsg(self.getTerminal().allSystemAlertsByDateTime.size, 1, "alert not created");
	alert := self.getTerminal().allSystemAlertsByDateTime.first;
	assertNotNullMsg(alert.mySystemAlertType, "alert.mySystemAlertType");
	assertEqualMsg(alert.mySystemAlertType.type, EVENT_AT_FailedAutoPlan, "alert has wrong type");
	
	registerNote(EventTerminalAlertDelete);
	deleteAlert(alert);
	assertNote(EventTerminalAlertDelete, "Did not get alert delete note");
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="tFTALocationFull" id="b4e11872-6168-44c9-aaaf-c7ad896f98f5">
        <updating/>
        <source>tFTALocationFull() updating;
// cnwndl1
//30 September 2008	cnwdw1	
// Test that when a ti fails to autoplan becuase the YA is full, an alert is created
// with the linkedTo field set to the YA.
vars
	ya: CM_YardAllocation;
	straddleStack: CM_StraddleStack;
	container1, container2: CM_TrackedItem;
	location: CM_LocationsController;
	alert: CM_SystemAlert;
	locations : CM_LCArray;	
begin
	deleteTerminalArea("UTSTRD");
	straddleStack := addStraddleStack("UTSTRD", 2, 2, 1);
	assertNotNullMsg(straddleStack, "straddleStack");
	
	// create a container and move to location
	self.deleteContainer("TEST0000001");
	container1 := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	move(container1,  straddleStack.allGridControllersByRowColumn[1, 1]);
	
	// Create the YA. It will be full
	create locations transient;
	locations.add(straddleStack.allGridControllersByRowColumn[1, 1]);
	locations.add(straddleStack.allGridControllersByRowColumn[1, 1]);
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_OperatorItem, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, locations);
	
	self.deleteAlerts();

	self.deleteContainer("TEST0000002");
	container2 := self.addContainerOpts("TEST0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	move(container2,  straddleStack.allGridControllersByRowColumn[2, 2]);
	
	location := app.autoPlanTiYA(self.getTerminal, straddleStack, container2);
	assertNullMsg(location, "location not null");
	assertTrueMsg(app.myYAAgent.myFirstYAFailure = ya, "YAAgent first YA failure not set");
	assertEqualMsg(self.getTerminal().allSystemAlertsByDateTime.size, 1, "alert not created");
	alert := self.getTerminal().allSystemAlertsByDateTime.first;
	assertNotNullMsg(alert.mySystemAlertType, "alert.mySystemAlertType");
	assertEqualMsg(alert.mySystemAlertType.type, EVENT_AT_FailedAutoPlan, "alert has wrong type");
	assertTrueMsg(container2.mySystemAlerts.size = 1, "Container did not have alert set");
	assertNotNullMsg(alert.getLinkedTo, "alert.getLinkedTo");
	assertTrueMsg(alert.getLinkedTo().CM_FailedToAutoplan.myFirstYAFailure = ya, "alert not linked to correct YA");
	
epilog
	delete locations;
end;</source>
    </JadeMethod>
    <JadeMethod name="tFTAReveiwByMove" id="f69d5398-7662-444b-be7d-db416b273f56">
        <updating/>
        <source>tFTAReveiwByMove() updating;
// cnwndl1
//30 September 2008	cnwdw1	
// Test that when a ti fails to autoplan, an alert is created and then if it is moved
// the alert is set to reviewed.
vars
	ya: CM_YardAllocation;
	straddleStack: CM_StraddleStack;
	container1, container2: CM_TrackedItem;
	location: CM_LocationsController;
	alert: CM_SystemAlert;
	locations : CM_LCArray;	
begin
	deleteTerminalArea("UTSTRD");
	straddleStack := addStraddleStack("UTSTRD", 2, 2, 1);
	assertNotNullMsg(straddleStack, "straddleStack");
	
	// create a container and move to location
	self.deleteContainer("TEST0000001");
	container1 := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	move(container1,  straddleStack.allGridControllersByRowColumn[1, 1]);

	// Create the YA. It will be full
	create locations transient;
	locations.add(straddleStack.allGridControllersByRowColumn[1, 1]);
	locations.add(straddleStack.allGridControllersByRowColumn[1, 1]);
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_OperatorItem, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, locations);
	
	self.deleteAlerts();

	self.deleteContainer("TEST0000002");
	container2 := self.addContainerOpts("TEST0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	
	// autoplan will fail
	location := app.autoPlanTiYA(self.getTerminal, straddleStack, container2);
	assertNullMsg(location, "location not null");
	// move the container somewhere
	move(container2,  straddleStack.allGridControllersByRowColumn[2, 2]);

	alert := self.getTerminal().allSystemAlertsByDateTime.first;
	assertNotNullMsg(alert.mySystemAlertType, "alert.mySystemAlertType");
	assertEqualMsg(alert.mySystemAlertType.type, EVENT_AT_FailedAutoPlan, "alert has wrong type");
	assertTrueMsg(alert.reviewed, "Alert not reviewed after move");
	
epilog
	delete locations;
end;</source>
    </JadeMethod>
    <JadeMethod name="tFTATestAutoPlan" id="4af236b1-cce3-42b4-8778-561f82be68ab">
        <updating/>
        <source>tFTATestAutoPlan() updating;
// cnwndl1
//30 September 2008	cnwdw1	
// Check that Test Auto Plan failure will add alert to FTA when the auto plan test is run with create alerts
vars
	ya: CM_YardAllocation;
	straddleStack: CM_StraddleStack;
	container1, container2: CM_TrackedItem;
	location: CM_LocationsController;
	alert: CM_SystemAlert;
	locations : CM_LCArray;	
begin
	deleteTerminalArea("UTSTRD");
	straddleStack := addStraddleStack("UTSTRD", 2, 2, 1);
	assertNotNullMsg(straddleStack, "straddleStack");
	
	// create a container and move to location
	self.deleteContainer("TEST0000001");
	container1 := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	move(container1,  straddleStack.allGridControllersByRowColumn[1, 1]);
	
	// Create the YA. It will be full
	create locations transient;
	locations.add(straddleStack.allGridControllersByRowColumn[1, 1]);
	locations.add(straddleStack.allGridControllersByRowColumn[1, 1]);
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_OperatorItem, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, locations);
	
	self.deleteAlerts();

	self.deleteContainer("TEST0000002");
	container2 := self.addContainerOpts("TEST0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	move(container2,  straddleStack.allGridControllersByRowColumn[2, 2]);
	
	// To the Test AP with create alert set to true
	location := app.autoPlanTiYATest(self.getTerminal, straddleStack, container2, true);
	assertNullMsg(location, "location not null");
	assertTrueMsg(app.myYAAgent.myFirstYAFailure = ya, "YAAgent first YA failure not set");
	assertEqualMsg(self.getTerminal().allSystemAlertsByDateTime.size, 1, "alert not created");
	alert := self.getTerminal().allSystemAlertsByDateTime.first;
	assertNotNullMsg(alert.mySystemAlertType, "alert.mySystemAlertType");
	assertEqualMsg(alert.mySystemAlertType.type, EVENT_AT_FailedAutoPlan, "alert has wrong type");
	assertTrueMsg(container2.mySystemAlerts.size = 1, "Container did not have alert set");
	assertNotNullMsg(alert.getLinkedTo, "alert.getLinkedTo");
	assertTrueMsg(alert.getLinkedTo().CM_FailedToAutoplan.myFirstYAFailure = ya, "alert not linked to correct YA");
	assertNotNull(alert.myTrackedItem);
	assertEqual(alert.myTrackedItem, container2);
	
epilog
	delete locations;
end;</source>
    </JadeMethod>
    <JadeMethod name="tFTAUpdateAlert" id="2d8b0641-5664-46e7-9d5f-2a9bc45a412e">
        <updating/>
        <source>tFTAUpdateAlert() updating;
// cnwndl1
//30 September 2008	cnwdw1	
// Test that when a FTA alert is deleted in sends  a delete note
vars
	ya: CM_YardAllocation;
	blockStack1: CM_BlockStack;
	container1: CM_TrackedItem;
	location: CM_LocationsController;
	alert: CM_SystemAlert;
	
begin
	deleteTerminalArea("UTBS1");
	blockStack1 := addBlockStack("UTBS1", 1, null);
	assertNotNullMsg(blockStack1, "blockStack1");
	
	self.deleteContainer("TEST0000001");
	container1 := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	

	self.deleteAlerts();
	
	on Exception do self.exHandlerAssertException(exception);
	location := app.autoPlanTiYA(self.getTerminal, blockStack1, container1);
	assertExceptionRaised(79961, "autoplan didn't failed");
	assertEqualMsg(self.getTerminal().allSystemAlertsByDateTime.size, 1, "alert not created");
	alert := self.getTerminal().allSystemAlertsByDateTime.first;
	assertNotNullMsg(alert.mySystemAlertType, "alert.mySystemAlertType");
	assertEqualMsg(alert.mySystemAlertType.type, EVENT_AT_FailedAutoPlan, "alert has wrong type");
	
	registerNote(EventTerminalAlertUpdate);
	beginTransaction;
	alert.setReviewed(true);
	commitTransaction;
	assertNote(EventTerminalAlertUpdate, "Did not get alert update note");
epilog
	abortTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="tFlexiWeight" id="10591651-81e5-4b40-88cb-3f579c554bee">
        <source>tFlexiWeight();
// cnwndl1
//29 August 2008	cnwdw1	
//
vars
	locations : CM_LCArray;
	ya: CM_YardAllocation;
	ti1, ti2, ti3, ti4: CM_TrackedItem;
	location: CM_LocationsController;
	bs: CM_BlockStack;
begin
	self.disableAllYA(true);
	deleteTerminalArea("UTBS1");
	bs:= addBlockStack("UTBS1", 100, null);

	self.deleteContainer("TEST0000001");
	self.opts.addAssoc(UTTI_TotalWeight, 5000);
	ti1 := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.deleteContainer("XXXX0000002");
	self.opts.addAssoc(UTTI_TotalWeight, 6000);
	ti2 := self.addContainerOpts("XXXX0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.deleteContainer("ABCD0000002");
	self.opts.addAssoc(UTTI_TotalWeight, 7000);
	ti3 := self.addContainerOpts("ABCD0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.deleteContainer("TEST0000004");
	self.opts.addAssoc(UTTI_TotalWeight, 5500);
	ti4 := self.addContainerOpts("TEST0000004", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_TotalWeight, "5T-6T", bs.allLocationsControllers.first);
	assertEqual(ya.allCriteria.size, 1);
	assertTrue(ya.allCriteria.first.myYAData.isKindOf(CM_YADataString));

	// Test that a matching id succeeds
	location := app.autoPlanTiYA(self.getTerminal, bs, ti1);
	self.assertEqualMsg(location, bs.allLocationsControllers.first, "Did not autoplan  to correct location");
	location := app.autoPlanTiYA(self.getTerminal, bs, ti2);
	self.assertEqualMsg(location, bs.allLocationsControllers.first, "Did not autoplan  to correct location");
	location := app.autoPlanTiYA(self.getTerminal, bs, ti4);
	self.assertEqualMsg(location, bs.allLocationsControllers.first, "Did not autoplan  to correct location");

	// Test that a non matching id fails
	location := app.autoPlanTiYA(self.getTerminal, bs, ti3);
	self.assertNull(location);
	
epilog
	self.disableAllYA(false);
end;
</source>
    </JadeMethod>
    <JadeMethod name="tGriddedBlockStack45" id="d488aef7-0dda-4e7f-8042-74406054b977">
        <source>tGriddedBlockStack45();
/*

Purpose:			

Date		Who		Reason
19 January 2016	cnwmk3	Initial creation

*/
constants
	GName	= "GRID001";
vars
	fk1			: CM_ForkLiftStack;
	locations	: CM_LCSet;
	locs		: CM_LCArray;
	params 		: CMIF_AutoplanParams;
	ya			: CM_YardAllocation;
	mode		: Integer;
	ti1, ti2, ti3, ti4, ti5, ti6, ti7, ti8	: CM_TrackedItem;
begin
	self.deleteTerminalArea(GName);
	fk1 := self.addForkLiftStack(GName, 8, 8, 8);
	
	create locations transient;
	locations.add(fk1.allGridControllersByRowColumn[1, 1]);
	locations.add(fk1.allGridControllersByRowColumn[1, 2]);
	locations.add(fk1.allGridControllersByRowColumn[1, 3]);
	updateLocationContainerLength(fk1, locations, false, true, false, false, false);
	self.assertTrueMsg(fk1.allGridControllersByRowColumn[1, 1].is45ft, "location not 45ft capable");
	
	create locs transient;
	locs.add(fk1.allGridControllersByRowColumn[1, 1]);
	locs.add(fk1.allGridControllersByRowColumn[1, 2]);
	locs.add(fk1.allGridControllersByRowColumn[1, 3]);
	
	self.deleteYA("UT");
	ya := self.addYA("UT", YACriteriaType_IsFortyFive, true, null, null, null, null, locs, null);
	
	ti1 := self.addContainer("CONTR00001", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), "45RR", "APPL", TI_IMEX_STATUS_EXPORT);
	self.assertNotNull(ti1);
	ti2 := self.addContainer("CONTR00002", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), "45RR", "APPL", TI_IMEX_STATUS_EXPORT);
	self.assertNotNull(ti2);
	ti3 := self.addContainer("CONTR00003", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), "45RR", "APPL", TI_IMEX_STATUS_EXPORT);
	self.assertNotNull(ti3);
	ti4 := self.addContainer("CONTR00004", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), "45RR", "APPL", TI_IMEX_STATUS_EXPORT);
	self.assertNotNull(ti4);
	ti5 := self.addContainer("CONTR00005", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), "45RR", "APPL", TI_IMEX_STATUS_EXPORT);
	self.assertNotNull(ti5);
	ti6 := self.addContainer("CONTR00006", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), "45RR", "APPL", TI_IMEX_STATUS_EXPORT);
	self.assertNotNull(ti6);
	ti7 := self.addContainer("CONTR00007", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), "45RR", "APPL", TI_IMEX_STATUS_EXPORT);
	self.assertNotNull(ti7);
	ti8 := self.addContainer("CONTR00008", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), "45RR", "APPL", TI_IMEX_STATUS_EXPORT);
	self.assertNotNull(ti8);
	
	//Test Auto Plan testing
	create params transient;
	params.allTrackedItems.add(ti1);
	params.allTrackedItems.add(ti2);
	params.allTrackedItems.add(ti3);
	params.allTrackedItems.add(ti4);
	params.allTrackedItems.add(ti5);
	params.allTrackedItems.add(ti6);
	params.allTrackedItems.add(ti7);
	params.allTrackedItems.add(ti8);
	
	mode := QUEUE_MODE;

	params.moveMode := mode;
	params.myTerminalArea := fk1;
	
	app.myTrxUA.trxUpdateAutoplanTrackedItems(params, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(ti1.queuedLocnId, fk1.allGridControllersByRowColumn[1, 1].terminalAreaId &amp; " " &amp; "000101" &amp; " " &amp; "000201");
	
	beginTransaction;
	ti1.doForcedUnqueue(app.myPassport);
	ti2.doForcedUnqueue(app.myPassport);
	ti3.doForcedUnqueue(app.myPassport);
	ti4.doForcedUnqueue(app.myPassport);
	ti5.doForcedUnqueue(app.myPassport);
	ti6.doForcedUnqueue(app.myPassport);
	ti7.doForcedUnqueue(app.myPassport);
	ti8.doForcedUnqueue(app.myPassport);
	commitTransaction;
	self.assertNull(ti1.queuedLocnId);
	
	//Queue tis
	mode := PLANNING_MODE;
	
	params.moveMode := mode;
	params.myTerminalArea := fk1;
	
	app.myTrxUA.trxUpdateAutoplanTrackedItems(params, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(ti1.plannedLocnId, fk1.allGridControllersByRowColumn[1, 1].terminalAreaId &amp; " " &amp; "000101" &amp; " " &amp; "1");
epilog
	delete locations;
	delete locs;
	delete params;
end;</source>
    </JadeMethod>
    <JadeMethod name="tIdCriteria" id="9ece99ab-c622-4ad7-96fd-8b5696fbd459">
        <source>tIdCriteria();
// cnwndl1
//29 August 2008	cnwdw1	
//
vars
	locations : CM_LCArray;
	ya: CM_YardAllocation;
	ti1, ti2: CM_TrackedItem;
	location: CM_LocationsController;
	bs: CM_BlockStack;
begin
	deleteTerminalArea("UTBS1");
	bs:= addBlockStack("UTBS1", 100, null);

	self.deleteContainer("TEST0000001");
	ti1 := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.deleteContainer("TEST0000002");
	ti2 := self.addContainerOpts("TEST0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	// Create a YA to match a container id
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_ID, "TEST0000001", bs.allLocationsControllers.first);
	assertEqual(ya.allCriteria.size, 1);
	assertTrue(ya.allCriteria.first.myYAData.isKindOf(CM_YADataString));

	// Test that a matching id succeeds
	location := app.autoPlanTiYA(self.getTerminal, bs, ti1);
	self.assertEqualMsg(location, bs.allLocationsControllers.first, "Did not autoplan  to correct location");

	// Test that a non matching id fails
	location := app.autoPlanTiYA(self.getTerminal, bs, ti2);
	self.assertNull(location);

epilog
end;
</source>
    </JadeMethod>
    <JadeMethod name="tIdPatternCriteria" id="2e2602a1-d762-4209-aee5-28557b67f848">
        <source>tIdPatternCriteria();
// cnwndl1
//29 August 2008	cnwdw1	
//
vars
	locations : CM_LCArray;
	ya: CM_YardAllocation;
	ti1, ti2, ti3: CM_TrackedItem;
	location: CM_LocationsController;
	bs: CM_BlockStack;
begin
	self.disableAllYA(true);
	deleteTerminalArea("UTBS1");
	bs:= addBlockStack("UTBS1", 100, null);

	self.deleteContainer("TEST0000001");
	ti1 := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.deleteContainer("XXXX0000002");
	ti2 := self.addContainerOpts("XXXX0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.deleteContainer("ABCD0000002");
	ti3 := self.addContainerOpts("ABCD0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_ID, "!TEST", bs.allLocationsControllers.first);
	assertEqual(ya.allCriteria.size, 1);
	assertTrue(ya.allCriteria.first.myYAData.isKindOf(CM_YADataString));

	
	// Create a YA to match a container id
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_ID, "TEST*", bs.allLocationsControllers.first);
	assertEqual(ya.allCriteria.size, 1);
	assertTrue(ya.allCriteria.first.myYAData.isKindOf(CM_YADataString));
	

	// Test that a matching id succeeds
	location := app.autoPlanTiYA(self.getTerminal, bs, ti1);
	self.assertEqualMsg(location, bs.allLocationsControllers.first, "Did not autoplan  to correct location");

	// Test that a non matching id fails
	location := app.autoPlanTiYA(self.getTerminal, bs, ti2);
	self.assertNull(location);

	
	// Test a list of patterns
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_ID, "TEST*,XXX*", bs.allLocationsControllers.first);
	assertEqual(ya.allCriteria.size, 1);
	assertTrue(ya.allCriteria.first.myYAData.isKindOf(CM_YADataString));

	// Test that a matching id succeeds
	location := app.autoPlanTiYA(self.getTerminal, bs, ti1);
	self.assertEqualMsg(location, bs.allLocationsControllers.first, "Did not autoplan  to correct location");

	// Test that a matching id succeeds
	location := app.autoPlanTiYA(self.getTerminal, bs, ti2);
	self.assertEqualMsg(location, bs.allLocationsControllers.first, "Did not autoplan  to correct location");

	// Test that a non matching id fails
	location := app.autoPlanTiYA(self.getTerminal, bs, ti3);
	self.assertNull(location);
	
	//08 May 2020	NDL	TFS 49291
	beginTransaction;
	ti1.setPropertyValue( CM_TrackedItem::serviceOrder.name, "SERVICE" );
	commitTransaction;
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_ServiceOrder, "!SERVICE", bs.allLocationsControllers.first);
	location := app.autoPlanTiYA(self.getTerminal, bs, ti1);
	self.assertTrueMsg(location = null, "Should not autoplan ti1 for serviceOrder NOT EQUAL(!) SERVICE");
	location := app.autoPlanTiYA(self.getTerminal, bs, ti2);
	self.assertTrueMsg(location = bs.allLocationsControllers.first, "Should still autoplan ti2 for serviceOrder NOT EQUAL(!) SERVICE");
	
	self.deleteYA("UT");
	
epilog
	self.disableAllYA(false);
end;
</source>
    </JadeMethod>
    <JadeMethod name="tIsHazLimitedCriteria" id="e6f2b85d-d525-464c-949d-22cff32c0fc3">
        <source>tIsHazLimitedCriteria();
// cnwndl1
//29 August 2008	cnwdw1	
//
vars
	locations : CM_LCArray;
	ya: CM_YardAllocation;
	ti, tiHaz, tiHazLmtd, proxyTI: CM_TrackedItem;
	location: CM_LocationsController;
	hazards	: CM_HazardByCodeDict;
	hazard: CM_TIHazard;
	ta: CM_GridArea;
begin
	deleteTerminalArea("UTSTRD");
	ta:= addStraddleStack("UTSTRD", 2, 2, 1);
	assertNotNullMsg(ta, "straddleStack");
	setTerminalConfig(IncludeLQasHazardous, false);
	
	self.deleteContainer("TEST0000001");
	ti := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	self.deleteContainer("TEST0000002");
	tiHaz := self.addContainerOpts("TEST0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	addTIHazard(tiHaz, "1.0", false);
	self.assertTrueMsg(tiHaz.isHazardous, "tiHaz is not hazardous");

	self.deleteContainer("TEST0000003");
	tiHazLmtd := self.addContainerOpts("TEST0000003", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	addTIHazard(tiHazLmtd, "1.0", true);
	self.assertFalseMsg(tiHazLmtd.isHazardous, "tiHazLmtd is hazardous");
	
	create locations transient;
	locations.add(ta.allGridControllersByRowColumn[1, 1]);
	locations.add(ta.allGridControllersByRowColumn[1, 2]);
	
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_IsHazAllLimited, CM_YADataBoolean.VALUE_TRUE, locations);
	location := app.autoPlanTiYA(self.getTerminal, ta, tiHazLmtd);
	self.assertEqualMsg(location, locations.first, "1. Did not autoplan haz lmtd to correct location");

	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_IsHazAllLimited, CM_YADataBoolean.VALUE_TRUE, locations);
	location := app.autoPlanTiYA(self.getTerminal, ta, ti);
	self.assertTrueMsg(location = null, "2. Location not null - planned non haz to haz lmtd ya");
	
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_IsHazAllLimited, CM_YADataBoolean.VALUE_TRUE, locations);
	location := app.autoPlanTiYA(self.getTerminal, ta, tiHaz);
	self.assertTrueMsg(location = null, "3. Location not null - planned haz to haz lmtd ya");


	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_IsHazAllLimited, CM_YADataBoolean.VALUE_FALSE, locations);
	location := app.autoPlanTiYA(self.getTerminal, ta, tiHazLmtd);
	self.assertTrueMsg(location = null, "4. Location not null - planned haz lmtd to non haz lmtd ya");

	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_IsHazAllLimited, CM_YADataBoolean.VALUE_FALSE, locations);
	location := app.autoPlanTiYA(self.getTerminal, ta, ti);
	self.assertEqualMsg(location, locations.first, "5. Did not autoplan non haz to non haz lmtd ya");
	
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_IsHazAllLimited, CM_YADataBoolean.VALUE_FALSE, locations);
	location := app.autoPlanTiYA(self.getTerminal, ta, tiHaz);
	self.assertEqualMsg(location, locations.first, "6. Did not autoplan haz to non haz lmtd ya");

epilog
	delete locations;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tIsHazOrLimitedCriteria" id="e6176010-c8cf-4421-8780-d0951a6734f6">
        <source>tIsHazOrLimitedCriteria();
// cnwndl1
//29 August 2008	cnwdw1	
//
vars
	locations : CM_LCArray;
	ya: CM_YardAllocation;
	ti, tiHaz, tiHazLmtd, proxyTI: CM_TrackedItem;
	location: CM_LocationsController;
	hazards	: CM_HazardByCodeDict;
	hazard: CM_TIHazard;
	ta: CM_GridArea;
begin
	deleteTerminalArea("UTSTRD");
	ta := addStraddleStack("UTSTRD", 2, 2, 1);
	assertNotNullMsg(ta, "straddleStack");

	self.setTerminalConfig(IncludeLQasHazardous, false);
	
	self.deleteContainer("TEST0000001");
	ti := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	self.deleteContainer("TEST0000002");
	tiHaz := self.addContainerOpts("TEST0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	addTIHazard(tiHaz, "1.0", false);
	self.assertTrueMsg(tiHaz.isHazardous, "tiHaz is not hazardous");

	self.deleteContainer("TEST0000003");
	tiHazLmtd := self.addContainerOpts("TEST0000003", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	addTIHazard(tiHazLmtd, "1.0", true);
	self.assertFalseMsg(tiHazLmtd.isHazardous, "tiHazLmtd is hazardous");
	
	create locations transient;
	locations.add(ta.allGridControllersByRowColumn[1, 1]);
	locations.add(ta.allGridControllersByRowColumn[1, 2]);
	
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_IsHazOrLimited, CM_YADataBoolean.VALUE_TRUE, locations);
