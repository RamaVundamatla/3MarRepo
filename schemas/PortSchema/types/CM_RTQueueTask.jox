    <JadeMethod name="getNextMachineTask" id="6b328a30-4b26-4075-add4-232db6233496">
        <source>getNextMachineTask() : CM_RTQueueTask;
//Returns the next MACHINE Dooable task in the "relatedTasks" list
//Generally, this is always the next task.
vars
	cIndex : Integer;
	tTask	:	CM_RTQueueTask;
begin
	cIndex := relatedTasks.indexOf(self); 	
	if cIndex &lt;= 0 then //We are NOT HERE!!!
		return null;
	endif;
	//------------
	//Locate next machine task
	//------------
	while true do
		cIndex := cIndex +1;
		if cIndex &gt; relatedTasks.size then
			return null;	//No more left
	  endif;
	  	tTask := relatedTasks[cIndex];
	  	if tTask.isMachineTask then
	  		//This is a machine type task, return it.
	  		return tTask;
	  	endif; 
	endwhile;
end;</source>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
