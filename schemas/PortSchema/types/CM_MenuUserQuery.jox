    <JadeMethod name="getCriteriaTerminal" id="17431318-09dc-4151-84e6-5493b67254a5">
        <source>getCriteriaTerminal() : CM_Terminal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2020	jlger1	Initial creation 47132

*/

vars
	criteriaLineHolder : CM_QueryCriteriaLineHolder;
	queryLine : CM_SelectorCriteriaLine;
	value : Any;

begin
	
	foreach criteriaLineHolder in self.allCriteriaLineHolders do
		foreach queryLine in criteriaLineHolder.allCriteriaLines do
			if queryLine.myQueryProperty.propertyName = CM_TrackedItem::myTerminal.name then
				value :=queryLine.myQueryOperator.getSearchValue;
				if value &lt;&gt; null and value.isKindOf(CM_Terminal) then
					return  value.CM_Terminal;
				endif;
			endif;
		endforeach;
	endforeach;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getFullDescription" id="ccd9c766-1a67-4a76-9133-e704102830d6">
        <source>getFullDescription() : String;
// ---------------------------------------------------------------------------
// Created:     31 October 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	str			 		: String;
	criteriaLine		: CM_SelectorCriteriaLine;
	criteriaLineHolder	: CM_QueryCriteriaLineHolder;
	
begin
	
	foreach criteriaLineHolder in self.allCriteriaLineHolders do
		foreach criteriaLine in criteriaLineHolder.allCriteriaLines do
			str := str &amp; criteriaLine.getDescriptionString &amp; CrLf;
		endforeach;
		
		if criteriaLineHolder &lt;&gt; self.allCriteriaLineHolders.last then
			str := str &amp; '-or-' &amp; CrLf;	
		endif;
	endforeach;
	
	
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLevel" id="49d5e7b5-3845-43d0-97c7-584e94c607e0">
        <source>getLevel(): Integer;
// ---------------------------------------------------------------------------
// Created:     17 April 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.myParent &lt;&gt; null then
		return self.myParent.getLevel +1;
	endif;	
	
	return 2;	


end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getQueryDefinition" id="427735ef-caed-4073-aa01-0369f0b52106">
        <source>getQueryDefinition():CM_QueryDefinition;
// ---------------------------------------------------------------------------
// Created:     12 February 2010 by cnwcs5
// Purpose:     CCMS 1925 / PAR 22295 Release Summaries
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	//return app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, self.queryMode];
	return app.myRoot.allQueryDefinitionObjects[self.getType() , self.queryMode]; //cnwrd1 par 25303 4.8.2010
epilog

end;</source>
        <ReturnType type="CM_QueryDefinition"/>
    </JadeMethod>
    <JadeMethod name="getResultStringForObject" id="8135a04c-62d1-4bbe-a064-33bb8617fd3d">
        <source>getResultStringForObject(_obj : Object) : String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01/06/2010	cnwer1	Initial creation
14/10/2013	cnwdap1	PAR #32731 Measurements not displaying correctly in queries run on the mobile apps
*/

vars
	rowStr,
	propValStr,
	attrName	: String;
	queryProp	: CM_QueryProperty;
	propVal		: Any;	
	queryDef	: CM_QueryDefinition;
	propDict	: CM_QueryPropertyDict;
	oper 		: CM_QueryOperator;
	propName	: String;							// PAR #32731
	pos, 											// PAR #32731
	revPos		: Integer;							// PAR #32731
	measureStr	: String;							// PAR #32731
	measure,										// PAR #32731
	default		: CM_MeasurementType;				// PAR #32731
begin
	queryDef	:= self.getQueryDefinition();
	propDict	:= queryDef.allQueryProperties;

	foreach attrName in self.allVisibleColumns do
		measureStr := null;														// PAR #32731
		measure := null;														// PAR #32731
		if attrName.isMeasurementType then										// PAR #32731
			pos := attrName.pos("_", 1);										// PAR #32731
			revPos := attrName.reversePos("_");									// PAR #32731
			measureStr := attrName[revPos+1:end];								// PAR #32731
			measure := app.myRoot.allMeasurementTypesByShortName[measureStr];	// PAR #32731
			propName := attrName[pos+1:revPos-pos-1];							// PAR #32731
		else																	// PAR #32731
			propName := attrName;												// PAR #32731
		endif;																	// PAR #32731
		//queryProp := propDict[attrName];										// PAR #32731
		queryProp := propDict[propName];										// PAR #32731
		
		if queryProp = null then
			propValStr := 'Could not retreive ' &amp; attrName;
		elseif (CM_QStringLookupProperty.hasInstance(queryProp)) then	//no need to translate
			propValStr := _obj.getPropertyValue(queryProp.propertyName).String;
		else
			oper := null;
			propVal := queryProp.getValueForObject(_obj,null);
			
			if propVal = null
			and (not queryProp.displayNull)
			then
				propValStr := null;
			else
				propValStr := queryProp.translateToDisplayValue(propVal);
				// For measurement types, propValStr is now in whatever unit the system default is.			// PAR #32731
				// We now need to convert that to whatever unit we're displaying here						// PAR #32731
				if measure &lt;&gt; null then																		// PAR #32731
					propValStr := propVal.String;															// PAR #32731
					default := app.getDefaultMeasurementForType(measure.measurementType);					// PAR #32731
					propValStr := app.convertMeasurementFromTo(default.shortName, measureStr, propValStr.Decimal).String;	// PAR #32731
					propValStr := measure.removeDecimalZeros(propValStr);									// PAR #32731
				endif;																						// PAR #32731
			endif;
		endif;
		
		rowStr := rowStr &amp; propValStr &amp; Tab;
	endforeach;
	
	return rowStr;
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getType" id="fbc210f6-1348-452e-96cd-ff50494fc2a7">
        <source>getType():Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 November 2009	cnwndl1	Initial creation	CCMS 1028
22 Dec 2022 		navhl20 ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query
20 Feb 2023     	navmv20 CR 55626 Task 55688: Jade - Selector Query Contracts
10 May 2023 navlw1 	ChangeRequest 53902: EUP - VBS MTN - [6] - Selector Query and JRW
*/

vars
	
begin

	if self.queryMode &gt;= BOLType_Min and self.queryMode	&lt;= BOLType_Max then
		return CM_QueryDefinition.BOL_Query_Type;
	elseif self.queryMode = CM_QueryDefinition.CargoTransaction_Query_Mode or
		   self.queryMode = CM_QueryDefinition.EventTransaction_Query_Mode or
		   self.queryMode = CM_QueryDefinition.WorkOrderTrans_Query_Mode   or				//22.12.2022 navhl20 #54350[54269]
		   self.queryMode = CM_QueryDefinition.HMSTransaction_Query_Mode or
		   self.queryMode = CM_QueryDefinition.Location_Activity_Query_Mode or // ### JIRA 14794 01NOV2024 NAVAB1
		   self.queryMode = CM_QueryDefinition.BOLTransaction_Query_Mode then // ### JIRA 14794 01NOV2024 NAVAB1
		return CM_QueryDefinition.Transaction_Query_Type;
	//14 May 2014	NDL	Par 34142
	elseif self.queryMode = CM_QueryDefinition.Invoice_Query_Mode    or
		  self.queryMode = CM_QueryDefinition.InvoiceLine_Query_Mode or 					//54269
		  self.queryMode = CM_QueryDefinition.Contract_Query_Mode    then					//17/02/2023 navmv20 TFS 55626 Task 55688
		return CM_QueryDefinition.Invoicing_Query_Type;
	//14 May 2014	NDL	Par 34142
	elseif self.queryMode = CM_QueryDefinition.CashPayment_Query_Mode or
		   self.queryMode = CM_QueryDefinition.CashReceipt_Query_Mode or
		   self.queryMode = CM_QueryDefinition.CashCredit_Query_Mode  then					// Feb 2016 37141
		return CM_QueryDefinition.Cash_Query_Type;
	elseif self.queryMode = CM_QueryDefinition.Audit_Query_Mode  then						// TFS 8390
		return CM_QueryDefinition.Audit_Query_Type;
	elseif self.queryMode = CM_QueryDefinition.VehicleBookingSlot_Query_Mode then
		return CM_QueryDefinition.VehicleBookingSlot_Query_Type; 							//10.05.2023 navlw1 #53902
	else
		return CM_QueryDefinition.TrackedItem_Query_Type;
	endif;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
