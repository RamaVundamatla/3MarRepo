    <JadeMethod name="clearData" id="c83ec347-5555-41b8-b2e6-01197cacf1ae">
        <source>clearData(_dataColumn : Integer);
/*

Date		Who		Reason
04 February 2014	cnwer1	Initial creation PAR

*/

vars
	row : Integer;
begin
	row:=1;
	while row &lt;= self.myTable.rows do
		if self.myTable.accessCell(row,_dataColumn).inputType = Table.InputType_TextBox or
			self.myTable.accessCell(row,_dataColumn).inputType =  Table.InputType_None then
			self.myTable.accessCell(row,_dataColumn).text:=null;
			
		endif;
		
		row:=row+1;
	endwhile;
	
epilog

end;</source>
        <Parameter name="_dataColumn" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="findRowWithEntRow" id="30541e05-db92-4449-8e84-913fb942cdb6">
        <source>findRowWithEntRow(_entRow : EntTableRow) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2010	cnwer1	Initial creation

*/

vars
	row : Integer;
	theRow : JadeTableRow;
begin
	row:=1;
	while row &lt;= self.myTable.rows do
		theRow:=self.myTable.accessRow(row);
		if theRow.itemObject = _entRow then
			return row;
		endif;
		row:=row+1;
	endwhile;
	
	return 0;
epilog

end;</source>
        <Parameter name="_entRow" type="EntTableRow"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="findRowWithEntRowName" id="50e6d586-bca4-4cfc-bb93-6a30667ba4d1">
        <source>findRowWithEntRowName(_entRowName : String) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2010	cnwer1	Initial creation

*/

vars
	entRow : EntTableRow;
begin
	entRow := self.myEntTableDef.getEntTableRow(_entRowName);
	if entRow = null then
		return null;
	endif;
	return self.findRowWithEntRow(entRow);
epilog

end;</source>
        <Parameter name="_entRowName" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
