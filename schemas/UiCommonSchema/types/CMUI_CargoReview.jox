    <JadeMethod name="mnuCGSEndReportAll_click" id="539e6a0e-71a7-4e0e-99ef-192fe61ca482">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuCGSEndReportAll_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01/11/2023	navkc1	Bug 61059: FR | 53715 - EUP - Customs - Cargo review screen enhancements

*/

vars
	jdo : JadeDynamicObject;
	row,
	totalRows,
	index : Integer;
	type : Type;
	value : Any;
	tiArray : CM_TIArray;
	jdoArray : JadeDynamicObjectArray;
	
begin
	
	create tiArray transient;
	create jdoArray transient;
	
	totalRows := self.tblCargoGrouped.rows;
	
	foreach row in self.tblCargoGrouped.fixedRows + 1 to totalRows do
		jdoArray.add(self.tblCargoGrouped.accessRow(row).itemObject.JadeDynamicObject);
	endforeach;
	
	foreach jdo in jdoArray do
		if jdo.getPropertyInfoByName(CMIF_CargoReviewQuery.CargoReviewAllTrackedItems,index,type,value) then
			value.CM_TIByCargoTypeIdDict.copy(tiArray);
		endif;
	endforeach;
	
	self.myAssistant.sendItemsToReport(tiArray);
	
epilog
	delete tiArray;
	delete jdoArray;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuCGSEndReport_click" id="e554befa-b0b4-40fe-a088-8a8ebebae04b">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuCGSEndReport_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 May 2022	jlier1	Initial creation
17/03/2023	navkc1	Bug 56487: EUP - Cannot send all the Search Results to a Report/Summary
*/

vars
	jdo : JadeDynamicObject;
	index : Integer;
	type : Type;
	value : Any;
	tiArray : CM_TIArray;
	jdoArray : JadeDynamicObjectArray;
	
begin
	
	create tiArray transient;
	create jdoArray transient;
	
	// 17/03/2023	navkc1	#56487
	/*
	jdo:=self.tblCargoGrouped.allSelectedObjects.first.JadeDynamicObject;
	if jdo =null then
		return;
	endif;
	*/
	
	// 17/03/2023	navkc1	#56487
	self.tblCargoGrouped.allSelectedObjects.copy(jdoArray);
	
	foreach jdo in jdoArray do
