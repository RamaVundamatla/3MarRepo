    <JadeMethod name="doAddAllItemsAction" id="0c3bbfd5-c2ea-40ff-b2d1-9df3263b4258">
        <source>doAddAllItemsAction();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Apr 2024 navlc30 ChangeRequest 63581: FR - 53429 - VBS - Adding entire release with line items

*/

vars
	itemTable : CM_DataTable;
begin
	itemTable := self.tblItems;
	
	if self.chkAddAllItems.value then
		self.cmbReserveDetail.enabled 		:= false;
		self.lblReserveDetails.enabled		:= false;
		self.txtQuantity.enabled			:= false;
		self.lblQuantity.enabled			:= false;
		self.btnNext.enabled				:= false;
		itemTable.selectAll();
	else
		self.cmbReserveDetail.enabled 		:= true;
		self.lblReserveDetails.enabled		:= true;
		self.txtQuantity.enabled			:= true;
		self.lblQuantity.enabled			:= true;		
		self.btnNext.enabled				:= true;
		itemTable.deselectAll();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnCargoSearch" id="7c382dc5-ab81-4a5b-8b14-fee8b0b133fc">
        <source>doBtnCargoSearch();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
12 July 2022	navcs2	53899 EUP - SD - VBS MTN - [3] - Maintaining VBS Slot
06 Mar 2023 	navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
17 Apr 2023 	navhl20 ChangeRequest 55443:[54991] EUP - Receive Cargo Work Order - Enhancements
*/

vars
	tiArray : CM_TIArray;
begin
	
	self.myAssistant.showCargoSearchForm(self, 
										null, 
										tiArray, 
										null,
										null,
										null,
										null,null,												//17.4.2023 navhl20 #55443[54991]
