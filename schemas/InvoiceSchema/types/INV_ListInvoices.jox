    <JadeMethod name="clearTableFilter" id="766cfaad-590a-4eb8-b02a-2d491bf262cd">
        <updating/>
        <source>clearTableFilter() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 October 2013	cnwjre1	Initial creation

*/

vars

begin
	if self.allColumnFilters &lt;&gt; null and not self.allColumnFilters.isEmpty then
		self.allColumnFilters.replaceAllFiltersForTable( self.tblData, null );
		self.applyColumnFilter( self.tblData );
	endif;

epilog

end;</source>
