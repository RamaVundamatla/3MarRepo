        <source>utlUpdateLogLoadOutRecon(_cmifLogLoadOutReconDtl : CMIF_LogLoadOutReconDtl input; 
						_passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: August 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	_cmifLogLoadOutReconDtl.validateForUpdate(_passport);
	if _cmifLogLoadOutReconDtl.myMasterLoadError &lt;&gt; null then
		if _cmifLogLoadOutReconDtl.myMasterLoadError.myLog &lt;&gt; null then
			exclusiveLock(_cmifLogLoadOutReconDtl.myMasterLoadError.myLog);
			if _passport.noErrors and _cmifLogLoadOutReconDtl.myMasterLoadError.myLog.edition &lt;&gt; _cmifLogLoadOutReconDtl.expectedEditionLog then
				app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Load Error', null, null);
				return;
			endif;
		endif;
		exclusiveLock(_cmifLogLoadOutReconDtl.myMasterLoadError);
		if _passport.noErrors and _cmifLogLoadOutReconDtl.myMasterLoadError.edition &lt;&gt; _cmifLogLoadOutReconDtl.expectedEditionLoadError then
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Load Error', null, null);
			return;
		endif;
	endif;
	
	if _passport.noErrors then
		_cmifLogLoadOutReconDtl.doUpdate(_passport);
	endif;
	
end;</source>
