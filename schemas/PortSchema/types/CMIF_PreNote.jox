    <JadeMethod name="setTrackedItemData" id="e46a8824-9bd3-442a-ba2c-045f8d8a9d9b">
        <updating/>
        <source>setTrackedItemData(isUpdateTI: Boolean;pTrackedItem: CM_TrackedItem input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     16 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
//11 Jul 2014	cnwrs1	Par 34566 CCMS 2346 Suzano - Viagram Prenote file 
//22 Feb 2016	cnwrs1	Par 37568 TFS 1177 CCMS 2158 - EDI User defined  field expansion
// 28/06/2017	cnwdap1	TFS 4492 SNO VERMAS Changes
// 17/04/2018   jlgrh7	TFS 38055 MSL - coparn deletes stop fields
// 15/06/2023	navdap1	TFS 57074 EUP Manifest EDI Operations / Load  Task 58604
// 23/06/2023	navdap1	TFS 58813 EUP - Manifest Instructions
//18 Jul 2023	jlirs1	TFS 59187 (59019) EUP - Manifest Processing - Container Reference Field
// 06 Nov 2023	navnk30	ChangeRequest 60933: EUP - Operational Instructions - CM_TrackedItem Inverse
// 12 Jun 2024 navhn30	ChangeRequest 64067: CUX | Include additional fields in APIs (Free Text)
// 28 Aug 2024	jlizm1	TFS 65873 Prenoted Customer Priority is lost when Gating In
// ---------------------------------------------------------------------------
vars
	instruction : CM_InstructionType;				// TFS 58813
	instructionIssued : CM_InstructionsIssued;		// TFS 58813
	priority	: CM_CustomerPriority;				// TFS 64067
	carType	: CM_CargoType;
	bookingRefObject : CM_BookingRef;
	terminal	: CM_Terminal;
	voyage	: CM_Voyage;
begin
	self.receiptTransportMode := app.transModeToCode(self.transportMode);
	//epr par 34945 17/10/14
	if self.receiptTransportMode = TI_TRANSMODE_SHIP then
		if self.isKindOf(CMIF_OnshipCargo) then
			if self.dischargePort = null then
				self.dischargePort := self.myTerminal.getConfig(PortDestCode).String;
			endif;
			
			if self.dischargePort = self.myTerminal.getConfig(PortDestCode).String then
				self.imExStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_IMPORT];
			else
				self.imExStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_REMAINONBOARD];
			endif;			
		endif;
	endif;
	
	inheritMethod(isUpdateTI,pTrackedItem, _passport);				//+TFS38055

	// Override state
	// ----------------
	pTrackedItem.setStatePxy(TI_STATE_NOTIFIED);
	
	pTrackedItem.setExpectedArrivalDate(self.expectedArrivalDate); //cnwrd1 par 22565 10.3.2010
	pTrackedItem.setExpectedArrivalTime(self.expectedArrivalTime); //cnwrd1 par 22565 10.3.2010
	
	// Override receiveDT
	// -------------------
	pTrackedItem.resetReceivedDT();		// 34715 call an explicit reset method to avoid accidental clearing of received date
	pTrackedItem.setOrderNumber(self.orderNumber);
	pTrackedItem.setInvoiceNumber(self.invoiceNumber);
	
	pTrackedItem.setDestinationTerminal(self.destinationTerminal);
	
	if pTrackedItem.isKindOf(CM_Container) then											// TFS 4492
		pTrackedItem.CM_Container.setMyVGMDetails(	self.weightCertifiedReference,		// TFS 4492
													self.weightCertifiedName,			// TFS 4492
													self.vgmAuthSignature,				// TFS 4492
													self.vgmCommsType,					// TFS 4492
													self.vgmDocumentDetails,			// TFS 4492
													self.vgmEDITransmission,			// TFS 4492
													self.vgmElectronicMail,				// TFS 4492
													self.vgmMail,						// TFS 4492
													self.vgmPhone,						// TFS 4492
													self.vgmTelefax,					// TFS 4492
													self.vgmTelephone,					// TFS 4492
													self.vgmDocsIssuedDT,				// TFS 4492
													self.vgmDeterminationDT,			// TFS 4492
													null	);							// TFS 4492
	endif;																				// TFS 4492
	
	// TFS 57074 start
	pTrackedItem.setItemised(self.itemised);
		
	if not self.itemised then
		terminal:= self.getMyTerminal;
		carType := app.myRoot.allCargoTypesById[self.cargoType];
		//voyage := terminal.lookupVoyage(self.voyageCode, null, null);
		//bookingRefObject := self.getMyTerminal.getBookingReference(self.operatorCode, bookingRef, self.getMyVoyage);
		if carType &lt;&gt; null and not carType.allowDuplicates  then
			pTrackedItem.setItemised(true);
		endif;
	endif;

	pTrackedItem.setSecondaryBarcodeId(self.secondaryBarcodeId);
	if self.mySortingMethod &lt;&gt; null then
		pTrackedItem.setMySortingMethod(self.mySortingMethod);
	elseif self.sortingMethod &lt;&gt; null then
		pTrackedItem.setMySortingMethod(app.myRoot.allSortingMethods[self.sortingMethod]);
	endif;
	// TFS 57074 end
	// TFS 58813 start
	pTrackedItem.setManifestNumber(self.manifestNumber);
	if self.instructionsType &lt;&gt; null then
		instruction := self.myTerminal.allInstructionTypes[self.instructionsType];  //15.Aug.2023 navsp1 TFS 59677
		if instruction &lt;&gt; null then
			create instructionIssued transient;
			instructionIssued.setProxy(	self.instructionsInternal,
										self.instructionsExternal,
										instruction,
										null	);                                  //15.Aug.2023 navsp1 TFS 59677
			//pTrackedItem.setmyInstructions(instructionIssued);					//06.11.2023 navnk30 #60933
		endif;
	endif;
	// TFS 58813 end
	pTrackedItem.setContainerNumberText(self.containerNumberText);		//18 Jul 2023	jlirs1		TFS 59187 (59019) EUP
	
	if self.myCustomerPriority = null then
		priority	:= app.myRoot.allCustomerPriorities[self.customerPriority];	// 12.06.24		navhn30		TFS #64067
		pTrackedItem.setMyCustomerPriority(priority);
	endif;
	
	pTrackedItem.setShipmentNumber(self.shipmentNumber);				//12 Jun 2024	navhn30		TFS 64067
end;</source>
        <Parameter name="isUpdateTI" type="Boolean"/>
        <Parameter name="pTrackedItem" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
