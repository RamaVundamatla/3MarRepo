/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 September 2012	cnwer1	Initial creation PAR 30364
12 Aug 2022 navtnr20 Bug 52451: MTN - WebServices not using getObjectOfTypeFromOid
*/

vars
	tmpStr			: String;
	voyage			: CM_Voyage;
	reportParam		: WS_ReportParameter;
	
begin

	reportParam := self.allWSReportParams.getAtKey(ETRow_MyVoyage);
	if reportParam &lt;&gt; null then
		tmpStr := reportParam.value;
	endif;	
	
	//voyage := tmpStr.asOid.CM_Voyage;		//12.08.2022 navtnr20 52451
	voyage := app.myPassport.getObjectOfTypeFromOid(tmpStr,CM_Voyage).CM_Voyage;		////12.08.2022 navtnr20 52451
	return voyage;

epilog

end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="getSelectedVoyageJobs" id="4f771cd2-33ed-4e6a-a786-84b980ca9d74">
        <source>getSelectedVoyageJobs(_voyageJobColl: Collection input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 September 2008	cnwkao1	Initial creation - based on WebSchema implementation
12 Aug 2022 navtnr20 Bug 52451: MTN - WebServices not using getObjectOfTypeFromOid
*/

vars

	str			: String;
	count		: Integer;
	strArray	: StringArray;
	obj			: Object;
	reportParam	: WS_ReportParameter;
	
begin

	reportParam := self.allWSReportParams.getAtKey(ETRow_ShipJob);
	if reportParam &lt;&gt; null then
		str := reportParam.value;
	endif;	
	
	_voyageJobColl.clear();
	
	if str.length &gt; 0 then
		create strArray transient;
		str.getTokensForDelimiter("|", strArray);
		
		//30/03/2009 cnwdz2 19323
		foreach str in strArray do
			//obj := str.asOid;		//12.08.2022 navtnr20 52451
			obj := app.myPassport.getObjectOfTypeFromOid(str,CM_VoyageJob).CM_VoyageJob;	//12.08.2022 navtnr20 52451
			if obj &lt;&gt; null then
				_voyageJobColl.add(obj);
			endif;
		endforeach;
	endif;

epilog
	delete strArray;

end;</source>
        <Parameter name="_voyageJobColl" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSelectorQueries" id="2fa3ecfd-929a-4d1f-b274-1faac5d21e64">
        <source>getSelectorQueries(_queries : CM_MenuEntityArray input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/10/2019	jlgdap1		Initial creation TFS 46315 JMT Proforma Report Issue
//
vars
	menuEntity : CM_MenuEntity;

begin
	foreach menuEntity in app.myRoot.myQueryMenuRoot.allChildren do
		self.doGetUserQueries(menuEntity, _queries);
	endforeach;

epilog

end;</source>
        <Parameter name="_queries" type="CM_MenuEntityArray" usage="input"/>
