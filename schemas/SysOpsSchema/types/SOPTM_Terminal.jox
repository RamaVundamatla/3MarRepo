    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="72c372cb-3f71-4ac8-98ce-fa87c5ce901e">
        <updating/>
        <source>loadDataForFirstTime() updating;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 28 May 2013	cnwrs1	ccms 1336 Par 31389 separate BGP EmailRequest to seperate read and send
// 18 Mar 2019	jlgdi1	TFS# 41721 Added load cargo 
vars
	timezone : CMIF_TimeZoneInfo;
	terminal : CM_Terminal;

begin	

	self.myForm.loadCombosRealEmail();
	self.myForm.cmbTerminalTZone.initialise(true);
	// set timezone display attributes on Settings table 
	if self.myForm.myCurrentObject.isKindOf(CM_Terminal) then
		terminal := self.myForm.myCurrentObject.CM_Terminal;
		self.myForm.tblInput2.setValueByName(ETRow_TimeZoneShortID, terminal.timeZoneShortID);
		foreach timezone in self.myForm.cmbTerminalTZone.allTimeZones do
			if timezone.id = terminal.timeZoneID then
				self.myForm.tblInput2.setValueByName(ETRow_TimeZoneID, timezone.displayName);
				self.myForm.cmbTerminalTZone.setObject(timezone);
			endif;
		endforeach;
	endif;
	self.myForm.loadComboCargoCheckOptions(null);
end;</source>
    </JadeMethod>
    <JadeMethod name="populateCmbDebtAction" id="a58cfe7d-cc44-4d7a-95c6-4fb6ef7bc6a3">
        <source>populateCmbDebtAction( _action : Integer );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2018	jlgndl1	Initial creation	TFS 38952
// ### JIRA 33806 21JAN2025 NAVAB1
*/

vars

	combo : CMUI_ComboBox;
	ref : String;

begin

	combo := self.myForm.cmbDebtAction;
	combo.clear;
	combo.itemData[ combo.addItem( " " ) ] := 0;
	combo.itemData[ combo.addItem(app.getErrorString(Cash_debtor_debt_raise_error)) ] := CashOnlyInDebtOption_ERROR;
	combo.itemData[ combo.addItem(app.getErrorString(Cash_debtor_debt_raise_warnin)) ] := CashOnlyInDebtOption_WARNING;
	combo.itemData[ combo.addItem(app.getErrorString(Cash_debtor_debt_no_action)) ] := CashOnlyInDebtOption_NOACTION;
	
	if _action &gt;= CashOnlyInDebtOption_ERROR and _action &lt;= CashOnlyInDebtOption_NOACTION then
		combo.listIndex := combo.findItemData( _action );
		combo.lostFocus( combo );
	endif;
	
	return;
	
	// For ease of finding.
	ref := ETRow_CashOnlyInDebtOption;
	ref := CashOnlyInDebtOption;

epilog

end;</source>
        <Parameter name="_action" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="populateCmbRoundInvLine" id="674c4ea9-a41f-443f-9146-1176a9768620">
        <source>populateCmbRoundInvLine(_roundValue : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Mar 2021 cnwma1 ChangeRequest 50925: ASPA - New Total Column in Invoice Form

*/

vars
	combo : CMUI_ComboBox;
begin
	combo := self.myForm.cmbRoundInvLine;

	combo.clear;
	combo.sorted := false;
	combo.itemData[ combo.addItem(CMIF_ConfigTerminal.InvLineRound_Key_NoRound)]  := CMIF_ConfigTerminal.InvLineRound_Value_NoRound; //6
	combo.itemData[ combo.addItem(CMIF_ConfigTerminal.InvLineRound_Key_Zero)]  	  := CMIF_ConfigTerminal.InvLineRound_Value_Zero;   
	combo.itemData[ combo.addItem(CMIF_ConfigTerminal.InvLineRound_Key_One)]   	  := CMIF_ConfigTerminal.InvLineRound_Value_One;
	combo.itemData[ combo.addItem(CMIF_ConfigTerminal.InvLineRound_Key_Two)]   	  := CMIF_ConfigTerminal.InvLineRound_Value_Two;
	combo.itemData[ combo.addItem(CMIF_ConfigTerminal.InvLineRound_Key_Three)] 	  := CMIF_ConfigTerminal.InvLineRound_Value_Three;
	combo.itemData[ combo.addItem(CMIF_ConfigTerminal.InvLineRound_Key_Four)]     := CMIF_ConfigTerminal.InvLineRound_Value_Four;
	combo.itemData[ combo.addItem(CMIF_ConfigTerminal.InvLineRound_Key_Five)]     := CMIF_ConfigTerminal.InvLineRound_Value_Five;
	
	if _roundValue &gt;= 0 and _roundValue &lt;= 6 then
		combo.listIndex := combo.findItemData( _roundValue );
		combo.lostFocus( combo );
	endif;

end;</source>
        <Parameter name="_roundValue" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="querySheetChange" id="cbdb2d50-e73b-4e82-942b-44ca8dee1bea">
        <updating/>
        <source>querySheetChange(folder: Folder; newSheet: Sheet): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     09 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if newSheet.caption = "RefCon" then
	//	if (not app.myRoot.canDo(PmRefCon)) then
		if (not app.myRoot.canDo(Mod_BaseSystem)) then //07 Oct 2019	NDL	TFS 46169
			return false;
		endif;
	endif;
	
	self.myForm.tblInput2.setObjectFromTable(self.myIntFaceConfig, 'setObjectFromTableSpecial', false);
	return true;

end;</source>
        <Parameter name="folder" type="Folder"/>
        <Parameter name="newSheet" type="Sheet"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setAllEntTableDefs" id="7261802d-ee69-4f37-8d95-c06ea0069c37">
        <source>setAllEntTableDefs(_constant : Constant; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     05 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str,
	defName	: String;
	pos		: Integer;
	term	: CM_Terminal;
	tmpUser : CM_User;
	noLogs,
	noContainers,
	noInvoices : Boolean;
begin

	if _constant.valueAsInteger &lt;&gt; ConfigType_Terminal then
		return;
	endif;
	
	str := _constant.text;
	
	tmpUser := app.getMyUser();
	if tmpUser &lt;&gt; null then
		term := app.getMyTerminalDO_NOT_USE();
		noLogs := (not tmpUser.canDo(term, Mod_Logs));
		noInvoices := (not tmpUser.canDo(term, Mod_Invoicing));
		noContainers := (not tmpUser.canDo(term, Mod_CargoHandling));
	endif;

	pos := 1;
	while (pos &gt; 0) do
		defName := str.cnEcGetNextTagValueOfName(XMLTag_DefName, pos);
		if defName &lt;&gt; null then
			if defName = ETDef_TerminalLogSpecific then
				if noLogs then
					continue;
				endif;
			elseif defName = ETDef_TerminalFinancial then
				if noInvoices then
					continue;
				endif;			
			elseif defName = ETDef_RefConConfig then
				if noContainers then
					continue;
				endif;							
			endif;
			self.allEntTableDefs.add(defName);
		endif;
	endwhile;
	
end;</source>
        <Parameter name="_constant" type="Constant"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setAutoTabDetails" id="a71fe5cd-f596-4356-97d1-30c4cd54cd3d">
        <source>setAutoTabDetails();
// ---------------------------------------------------------------------------
// Created:		24 January 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
vars
	theForm : SOP_TableMaintForm;
	//col     : CM_CargoBOLTypeArray;
	//cargo   : CM_CargoType;
