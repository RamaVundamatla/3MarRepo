    <JadeMethod name="getDisplayStringForAttribute" id="36db6968-b8ee-49ff-95db-0452e3dfdce1">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2022	navhl20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars

begin

	if _attrName = ETRow_DamageSeverity then
		return	self.level.String;
	elseif _attrName = ETRow_IsNotAvailableForEntry then
		return self.isNotAvalableForEntry.String;
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
