    <JadeMethod name="getSelectionStateAsString" id="41fd2cf9-07df-4043-892e-00b83ab5e3c7">
        <source>getSelectionStateAsString() : String;

// cnwdvb1 15 January 2003 

vars

begin

	if self.selectionState = State_Date then
		return 'By Month';
	elseif self.selectionState = State_Day then
		return 'By Day';
	elseif self.selectionState = State_Time then
		return 'By Time';
	else
		return 'By Event';
	endif;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="0004e945-6ba5-4a27-bbf8-6a40a570865e">
        <source>pxyCreateUpdateProxy() : SelfType;

// cnwdvb1 15 January 2003 
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars

	schedule : CM_AutoSchedule;
	completedOK		: Boolean;
	
begin

	schedule := inheritMethod();
	self.allAutoTasks.copy(schedule.allAutoTasks);
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return schedule;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete schedule;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="runTasks" id="a28dca87-c31b-42d3-bc66-96920f2f1f93">
        <source>runTasks(_transientEventDataDict : CM_EventDataByTypeDict; _requests : Collection input);
// -------------------------------------------
// Created 24 June 2004 by cnwdvb1
// _requests added Nov 2011 cnwjre1 for unit testing to access the created request instances directly instead of via notification
// -------------------------------------------
vars
	iter			: Iterator;
	task			: CM_AutoTask;
	tmpClass		: Class;
	request			: BGP_Request;

begin
	iter := self.allAutoTasks.createIterator();
	
	while iter.next(task) do
		app.sendHeartbeatIfRequired();		// TFS 43812 jlgmd1 08/07/19
		if not self.tryLock(task, Exclusive_Lock, Session_Duration, LockTimeout_Immediate) then
			// Will move on because someone is editing task.
			app.writeLog('INFO &gt;&gt; Cannot get lock for task ' &amp; task.description, LogINFO);
			continue;
		endif;
		app.writeLog('Processing task (' &amp; task.description &amp; ')', LogINFO);
		tmpClass := self.getClass(task.requestClassName);
		if tmpClass = null then
			// Class has not been correctly setup.
			app.remoteErrorWarningToAlert('INFO &gt;&gt; Error processing timer driven request ' &amp; task.requestClassName &amp; 
			'. Request class not found' , null, null, null, true,true);
			continue;
		endif;
		
		 // ### JIRA 35468 31JUL2025 NAVAB1 want to run packages when updating the status
		if process.isInTransactionState then
			app.myUtilityCA.utlCreateBGPRequest(tmpClass, request, task, _transientEventDataDict);
		else
			app.myTrxCA.trxCreateBGPRequestFromTask(tmpClass, request, task, _transientEventDataDict, app.myPassport);
		endif;
		if _requests &lt;&gt; null then
			_requests.add(request);
		endif;
		
		self.unlock(task);
	endwhile;
	
epilog	
	delete iter;
	
	if task &lt;&gt; null then
		self.unlock(task);
	endif;
end;</source>
        <Parameter name="_transientEventDataDict" type="CM_EventDataByTypeDict"/>
        <Parameter name="_requests" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="scheduleForInvoicePackage" id="352cbb1f-9c2e-4f19-b0f9-dd03d14ffecf">
        <source>scheduleForInvoicePackage() : Boolean;
// 28218 CCMS 2120 return true if all tasks are for invoice packages
// used to hide these from the regular auto-schedule processing
vars
	count	: Integer;
	task : CM_AutoTask;
begin

	foreach task in self.allAutoTasks do
		count := count + 1;
		if task.isKindOf(CM_AutoTaskPackage) then
			if not task.CM_AutoTaskPackage.myPackage.isKindOf(CM_PackageInvoice) then
				return false;
			endif;
		else
			return false;
		endif;
	endforeach;

	if count = 0 then
		return false;		// no tasks, can't be invoice package
	else
		return true;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="scheduleNeedsExtraData" id="a7b264fe-0d35-4fc3-8292-fb8fff81dc7b">
        <source>scheduleNeedsExtraData() : Boolean;

// Created by cnwdvb1 on 29 June 2006

vars

	task : CM_AutoTask;

begin

	if self.selectionState &lt;&gt; State_Event then
		return false;
	endif;
	
	foreach task in self.allAutoTasks where task.isKindOf(CM_AutoTaskPackage) do
		if task.CM_AutoTaskPackage.myPackage.isKindOf(CM_PackageSailing) then
			if task.CM_AutoTaskPackage.myPackage.CM_PackageSailing.includeBaplie then
				return true;
			endif;
		endif;
	endforeach;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="a582cf13-a4f2-4dbb-b0c0-52d1dfa51712">
        <updating/>
        <source>setForCreate(_pxySchedule : CM_AutoSchedule) updating;

// cnwdvb1 15 January 2003 

vars

begin

	_pxySchedule.allAutoTasks.copy(self.allAutoTasks);
	_pxySchedule.allRunDays.copy(self.allRunDays);
	_pxySchedule.allRunTimes.copy(self.allRunTimes);
	self.dayOfMonth := _pxySchedule.dayOfMonth;
	self.endScheduleTs		:= _pxySchedule.endScheduleTs;
	self.recurUnit			:= _pxySchedule.recurUnit;
	self.recurValue			:= _pxySchedule.recurValue;
	self.selectionState		:= _pxySchedule.selectionState;
	self.startScheduleTs	:= _pxySchedule.startScheduleTs;
	self.runTs				:= _pxySchedule.runTs;
	self.isActive			:= _pxySchedule.isActive;
	self.description		:= _pxySchedule.description;
	self.eventDataType		:= _pxySchedule.eventDataType;
	self.myRoot				:= _pxySchedule.myRoot;

end;</source>
        <Parameter name="_pxySchedule" type="CM_AutoSchedule"/>
    </JadeMethod>
    <JadeMethod name="setForDate" id="a5f146fb-21fc-41ee-a0ba-dfd979bda48c">
        <updating/>
        <source>setForDate(_description,  _day : String; _time : Time; _recurValue : Integer) updating;

// cnwdvb1 14 January 2003 

/* Changes

Date		Name	TFS#	Description
============================================================================
16/04/2019	jlgka1	43863	Add Recurring Value and Defaulted Recurring Unit to RecurUnit_Monthly.
============================================================================*/

begin

	self.selectionState := State_Date;
	self.description 	:= _description;
	self.dayOfMonth 	:= _day;
	//jlgka1 TFS 43863 --&gt;
	self.recurValue 	:= _recurValue;
	self.recurUnit		:= CM_AutoSchedule.RecurUnit_Monthly;
	//jlgka1 TFS 43863 &lt;--	
	self.allRunTimes.clear;
	self.allRunTimes.add(_time);
	self.setNextRunTs(Make_Process, false, null);
	self.myRoot := app.myRoot;

end;</source>
        <Parameter name="_description" type="String"/>
        <Parameter name="_day" type="String"/>
        <Parameter name="_time" type="Time"/>
        <Parameter name="_recurValue" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForDay" id="f23236ea-bdb8-4fc7-a24e-82af4edd6608">
        <updating/>
        <source>setForDay(_description : String; _start, _stop : TimeStamp; _allDays : BooleanArray; _allTimes : TimeArray) updating;

// cnwdvb1 18 December 2002 

vars

begin

	self.selectionState		:= State_Day;
	self.description 		:= _description;
	self.startScheduleTs	:= _start;
	self.endScheduleTs		:= _stop;
	self.allRunDays.clear;
	self.allRunTimes.clear;
	_allDays.copy(self.allRunDays);
	_allTimes.copy(self.allRunTimes);
	self.setNextRunTs(Make_Process, false, null);
	self.myRoot				:= app.myRoot;

end;</source>
        <Parameter name="_description" type="String"/>
        <Parameter name="_start" type="TimeStamp"/>
        <Parameter name="_stop" type="TimeStamp"/>
        <Parameter name="_allDays" type="BooleanArray"/>
        <Parameter name="_allTimes" type="TimeArray"/>
    </JadeMethod>
    <JadeMethod name="setForEvent" id="acf589e8-b2bb-4e9d-8503-59a55d865031">
        <updating/>
        <source>setForEvent(_description : String; _eventType : Integer) updating;
// -------------------------------------------
// Created 29 June 2004 by cnwdvb1
// -------------------------------------------
vars

	ts		: TimeStamp;

begin

	ts.setDate("01/01/2100".asDateJMT());
	ts.setTime("12:00:00".Time);
	self.selectionState		:= State_Event;
	self.description 		:= _description;
	self.eventDataType		:= _eventType;
	self.isActive			:= Schedule_Is_Active;
	self.runTs 				:= ts;
	self.myRoot				:= app.myRoot;


end;</source>
        <Parameter name="_description" type="String"/>
        <Parameter name="_eventType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForTime" id="195f1f88-5968-46e5-99b4-1cd89e6456dc">
        <updating/>
        <source>setForTime(_description : String; _start, _stop : TimeStamp; _recurValue : Integer; _recurUnit : String) updating;

// cnwdvb1 18 December 2002 

vars

begin

	self.selectionState		:= State_Time;
	self.description 		:= _description;
	self.startScheduleTs	:= _start;
	self.endScheduleTs		:= _stop;
	self.recurValue			:= _recurValue;
	self.recurUnit			:= _recurUnit;
	if self.startScheduleTs &gt; app.actualTimeServer() then
		self.runTs := self.startScheduleTs;
	else
		self.setNextRunTs(Make_Process, false, null);
	endif;
	self.isActive			:= Schedule_Is_Active;
	self.myRoot				:= app.myRoot;
	
end;</source>
        <Parameter name="_description" type="String"/>
        <Parameter name="_start" type="TimeStamp"/>
        <Parameter name="_stop" type="TimeStamp"/>
        <Parameter name="_recurValue" type="Integer"/>
        <Parameter name="_recurUnit" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="b33d3512-c075-4e75-a0a6-d304a2db6528">
        <updating/>
        <source>setForUpdate(_pxySchedule : CM_AutoSchedule) updating;

// cnwdvb1 16 January 2003 

vars

begin

	self.allAutoTasks.clear;
	self.allRunDays.clear;
	self.allRunTimes.clear;
	_pxySchedule.allAutoTasks.copy(self.allAutoTasks);
	_pxySchedule.allRunDays.copy(self.allRunDays);
	_pxySchedule.allRunTimes.copy(self.allRunTimes);
	self.dayOfMonth 		:= _pxySchedule.dayOfMonth;
	self.endScheduleTs		:= _pxySchedule.endScheduleTs;
	self.recurUnit			:= _pxySchedule.recurUnit;
	self.recurValue			:= _pxySchedule.recurValue;
	self.selectionState		:= _pxySchedule.selectionState;
	self.startScheduleTs	:= _pxySchedule.startScheduleTs;
	self.isActive			:= _pxySchedule.isActive;
	self.description		:= _pxySchedule.description;
	self.eventDataType		:= _pxySchedule.eventDataType;
	self.runTs				:= _pxySchedule.runTs;
	

end;</source>
        <Parameter name="_pxySchedule" type="CM_AutoSchedule"/>
    </JadeMethod>
    <JadeMethod name="setIsBeingActioned" id="c631866c-3233-4862-97d6-eed429a0a671">
        <updating/>
        <source>setIsBeingActioned(_isBeingActioned : Boolean) updating;
// -------------------------------------------
// Created 28 January 2005 by cnwdvb1
