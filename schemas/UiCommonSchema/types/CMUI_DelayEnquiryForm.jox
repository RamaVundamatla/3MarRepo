        <updating/>
        <source>initQueryFrame() updating, protected;
// ---------------------------------------------------------------------------
// Created:     04 April 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 31/05/2011	cnwcs5		par27612 - self.allCurrentVoyages will be loaded with current voyages if empty
// ---------------------------------------------------------------------------
vars
	now	:TimeStamp;
begin
	if not self.usesQueryFrame then
		return;
	endif;
	
	inheritMethod();
	
	self.fldQuery.visible	:= false;

	
	self.cmbVoyage.listCollection(self.allCurrentVoyages, false,0);					// 31/05/2011 cnwcs5 par 27612
	
	self.cmbMachine.listCollection(self.myTerminal.machines, false, 0);
	self.myAssistant.comboBoxDelayType (self.cmbDelayType, true, null);
	self.cmbDelayGroup.listCollection (app.myRoot.allDelayTypeGroups, false, 0);
	
	self.doResetSearch;
epilog

end;</source>
