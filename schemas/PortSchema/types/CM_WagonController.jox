    <JadeMethod name="setQueue" id="5a28aaf9-53ab-4824-8ec7-e20291ce2731">
        <updating/>
        <source>setQueue(queueObject : CM_SubQueue) updating;
//Sets a reference to the queue object.
vars
begin
	if queues.includes(queueObject) then
		//If a queue already exists, and we are trying to set something
		//else to it, stop.
		app.setContinueCMExceptions(false);
//		app.raiseCMException1(ERR_QUEUE_LC_EXISTS, "Location " &amp; id.trimBlanks, null, null);
		app.raiseCMException1(Queue_refere_alread_exists_loc, self.id.trimBlanks, null, null);
		
		return;		
	endif;
	queues.add( queueObject);
end;</source>
        <Parameter name="queueObject" type="CM_SubQueue"/>
