    <Constant name="NODE_FLAG_FILE" id="9fd22584-6c05-4505-8f05-92a93217e8fa">
        <source>2</source>
        <type name="Integer"/>
    </Constant>
    <Constant name="NODE_FLAG_FOLDER" id="283bdf81-7e5d-419f-8cf1-858b39dfa21a">
        <source>1</source>
        <type name="Integer"/>
    </Constant>
    <ExplicitInverseRef name="allFileNodes" id="55f6d6e1-5192-4178-b5cc-43eee5556e14">
        <kind>parent</kind>
        <updateMode>automatic</updateMode>
        <type name="JSSFMFileNodeByNameDict"/>
        <access>readonly</access>
        <Inverse name="myParentNode"/>
    </ExplicitInverseRef>
    <PrimAttribute name="fileName" id="a55a1cb6-ce04-4cdf-8a29-6ab500ceb474">
        <length>256</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>This is the name of the file node.  Note that the name does not include the whole
file path, just the node name (refer to the pathName attribute for the full name).</text>
    </PrimAttribute>
    <PrimAttribute name="fileNodeFlag" id="b6ef3e6f-0629-41b8-88b7-0431a658286e">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
        <text>This attribute is used to indicate whether the receiver is a directory node
or a file node.  The value will correspond to one of two class constants,
NODE_FLAG_FILE and NODE_FLAG_FOLDER.

This attribute is also a key in the JSSFMFileNodeByNameDict dictionary to
place the directories at the top of the list, followed by the files.</text>
    </PrimAttribute>
    <PrimAttribute name="fileSize" id="b8284ef2-e861-4bfd-af73-8e94c1e25cb1">
        <precision>23</precision>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
        <text>This attribute is literally the length of the disk file (directories will always be zero).
Note that when the size is displayed, it is usually shown as kilobytes or megabytes by
dividing the length by 1024 or 1048576 respectively.</text>
    </PrimAttribute>
    <PrimAttribute name="isCutAndPaste" id="ffdc4ebb-ca5b-4f67-8981-ef422ffa6485">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="isFile" id="25dff9bb-d6d9-4627-80ff-81b3ac343295">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="isFolder" id="44b03b83-e83a-4fbb-959a-1a3609b03bd4">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="isUnix" id="472ddc1a-a841-46db-83db-b377d587b025">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="lastModified" id="d0fbbd0f-46ff-49ac-9656-e69380a349e9">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myParentNode" id="a881a70d-2173-4147-8df0-92a288e6de5f">
        <kind>child</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="JSSFMFileNode"/>
        <access>readonly</access>
        <text>This reference serves no purpose other than to automatically delete its inverse
objects when the receiver is deleted.</text>
        <Inverse name="allFileNodes"/>
    </ExplicitInverseRef>
    <PrimAttribute name="nodeType" id="d498fbb2-965a-4f30-9af0-97de3a1729a0">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="pathName" id="9a04dd95-d021-46d6-838a-eab478cef57b">
        <type name="String"/>
        <access>readonly</access>
        <text>Contains the whole path and file name of the node.  For just the node name (i.e. without
the path name), refer to the fileName attribute.</text>
    </PrimAttribute>
    <JadeMethod name="addFile" id="a1c396c9-d14d-4dab-99ae-7f7f2ff8e852">
        <updating/>
        <source>addFile(pFileName:String;
		pPathName:String;
		pNodeType:Integer;
		pIsUnix:Boolean;
		pFileSize:Decimal;
		pLastModified:TimeStamp;
		pIsArchive:Boolean;
		pIsHidden:Boolean;
		pIsReadOnly:Boolean;
		pIsSystemFile:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		26 June 2002 by cnwdad1
//
// Purpose:		Adds a file node to the receiver.
//
// Parameters:	pFileName - The name of the file, exclusing the path name.
//				pPathName - The path name of the receiver, excluding the file name.
//				pNodeType - A flag to indicate the JADE node of the file.
//				pIsUnix - True if the file node's OS platform is Unix.
//				pFileSize - Integer - The size (in bytes) of the file.
//				pLastModified - A timestamp of when the file was last changed.
//				pIsArchive - A boolean flag to indicate whether the file's Archive
//					attribute is set.
//				pIsHidden - A boolean flag to indicate whether the file's Hidden
//					attribute is set.
//				pIsReadOnly - A boolean flag to indicate whether the file's Read Only
//					attribute is set.
//				pIsSystemFile - A boolean flag to indicate whether the file's System
//					File attribute is set.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theFile	: JSSFMFile;
	
begin
	create theFile transient;
	
	theFile.updateMe(	self,
						pFileName,
						pPathName,
						pNodeType,
						pIsUnix,
						pFileSize,
						pLastModified,
						pIsArchive,
						pIsHidden,
						pIsReadOnly,
						pIsSystemFile);
end;</source>
        <Parameter name="pFileName" type="String"/>
        <Parameter name="pPathName" type="String"/>
        <Parameter name="pNodeType" type="Integer"/>
        <Parameter name="pIsUnix" type="Boolean"/>
        <Parameter name="pFileSize" type="Decimal"/>
        <Parameter name="pLastModified" type="TimeStamp"/>
        <Parameter name="pIsArchive" type="Boolean"/>
        <Parameter name="pIsHidden" type="Boolean"/>
        <Parameter name="pIsReadOnly" type="Boolean"/>
        <Parameter name="pIsSystemFile" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addFolder" id="dabdb94c-6b3c-4071-b58c-d186f04f9e26">
        <source>addFolder(pFileName:String; pPathName:String; pNodeType:Integer; pIsUnix:Boolean);
// --------------------------------------------------------------------------------
// Created:		26 June 2002 by cnwdad1
//
// Purpose:		Adds a directory node to the receiver.
//
// Parameters:	pFileName - The name of the file, exclusing the path name.
//				pPathName - The path name of the receiver, excluding the file name.
//				pNodeType - A flag to indicate the JADE node of the file.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theFolder	: JSSFMFolder;
	
begin
	create theFolder transient;
	theFolder.updateMe(self, pFileName, pPathName, pNodeType, pIsUnix, 0, null, false, false, false, false);
end;</source>
        <Parameter name="pFileName" type="String"/>
        <Parameter name="pPathName" type="String"/>
        <Parameter name="pNodeType" type="Integer"/>
        <Parameter name="pIsUnix" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAttributes" id="e6e52b01-c0d2-4de4-bd1b-078cdfee2d1b">
        <source>getAttributes():String;
// --------------------------------------------------------------------------------
// Created:		26 June 2002 by cnwdad1
//
// Purpose:		Returns a string of the node's file system attributes.
//
// Parameters:	None
//
// Returns:		A string of file system attributes.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return null;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTableDisplay" id="9e65afaa-3627-4134-9174-067f56c13bfe">
        <source>getTableDisplay():String abstract;</source>
        <abstract/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setAttributes" id="348cbe38-e650-4d05-b47e-aa6190c94233">
        <updating/>
        <source>setAttributes(pIsArchive:Boolean; pIsHidden:Boolean; pIsReadOnly:Boolean; pIsSystemFile:Boolean) updating, protected;
// --------------------------------------------------------------------------------
// Created:		26 June 2002 by cnwdad1
//
// Purpose:		Sets the file node's attributes.
//
// Parameters:	pIsArchive - A boolean flag to indicate whether the file's Archive
//					attribute is set.
//				pIsHidden - A boolean flag to indicate whether the file's Hidden
//					attribute is set.
//				pIsReadOnly - A boolean flag to indicate whether the file's Read Only
//					attribute is set.
//				pIsSystemFile - A boolean flag to indicate whether the file's System
//					File attribute is set.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
end;</source>
        <access>protected</access>
        <Parameter name="pIsArchive" type="Boolean"/>
        <Parameter name="pIsHidden" type="Boolean"/>
        <Parameter name="pIsReadOnly" type="Boolean"/>
        <Parameter name="pIsSystemFile" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setIsCutAndPaste" id="e1ecfdce-ddd3-40a0-82d3-e65ea2ecc8ee">
        <updating/>
        <source>setIsCutAndPaste(pIsCutAndPaste:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		11 July 2002 by cnwdad2
//
// Purpose:		Updates the receiver's boolean cut and paste flag.
//
// Parameters:	pIsCutAndPaste - The value of the cut and paste flag.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isCutAndPaste &lt;&gt; pIsCutAndPaste then
		self.isCutAndPaste	:=	pIsCutAndPaste;
	endif;
end;</source>
        <Parameter name="pIsCutAndPaste" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setNodeFlag" id="c69b227b-03f2-45ef-957f-bc4ab059051c">
        <updating/>
        <source>setNodeFlag() updating, protected, abstract;</source>
        <abstract/>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updateMe" id="a229a499-224a-4131-97b4-fe0bb4b20428">
        <updating/>
        <source>updateMe(	pTheParentNode:JSSFMFileNode;
			pFileName:String;
			pPathName:String;
			pNodeType:Integer;
			pIsUnix:Boolean;
			pFileSize:Decimal;
			pLastModified:TimeStamp;
			pIsArchive:Boolean;
			pIsHidden:Boolean;
			pIsReadOnly:Boolean;
			pIsSystemFile:Boolean) updating, protected;
// --------------------------------------------------------------------------------
// Created:		26 June 2002 by cnwdad1
//
// Purpose:		Sets the properties and references on the receiver.
//
// Parameters:	pTheParentNode - The object's parent file node object.
//				pFileName - The name of the file, exclusing the path name.
//				pPathName - The path name of the receiver, excluding the file name.
//				pNodeType - A flag to indicate the JADE node of the file.
//				pIsUnix - True if the file node's OS platform is Unix.
//				pFileSize - Integer - The size (in bytes) of the file.
//				pLastModified - A timestamp of when the file was last changed.
//				pIsArchive - A boolean flag to indicate whether the file's Archive
//					attribute is set.
//				pIsHidden - A boolean flag to indicate whether the file's Hidden
//					attribute is set.
//				pIsReadOnly - A boolean flag to indicate whether the file's Read Only
//					attribute is set.
//				pIsSystemFile - A boolean flag to indicate whether the file's System
//					File attribute is set.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	filePathName	: String;
	
begin
	filePathName	:=	pPathName;
	
	// Make sure that the path name's file separator is correct for its OS platform.
	
	if pIsUnix then
		filePathName.replaceChar(JSS_SEPARATOR_WIN.Character, JSS_SEPARATOR_UNIX.Character);
	else
		filePathName.replaceChar(JSS_SEPARATOR_UNIX.Character, JSS_SEPARATOR_WIN.Character);
	endif;
	
	// Update property values.
	
	self.pathName		:=	filePathName;
	self.nodeType		:=	pNodeType;
	self.isUnix			:=	pIsUnix;
	self.fileSize		:=	pFileSize;
	self.lastModified	:=	pLastModified;
	
	self.setAttributes(pIsArchive, pIsHidden, pIsReadOnly, pIsSystemFile);
	
	// Update any key values.
	
	self.setNodeFlag();
	self.fileName	:=	pFileName;
	
	// Update any inverses.
	
	self.myParentNode	:=	pTheParentNode;
end;</source>
        <access>protected</access>
        <Parameter name="pTheParentNode" type="JSSFMFileNode"/>
        <Parameter name="pFileName" type="String"/>
        <Parameter name="pPathName" type="String"/>
        <Parameter name="pNodeType" type="Integer"/>
        <Parameter name="pIsUnix" type="Boolean"/>
        <Parameter name="pFileSize" type="Decimal"/>
        <Parameter name="pLastModified" type="TimeStamp"/>
        <Parameter name="pIsArchive" type="Boolean"/>
        <Parameter name="pIsHidden" type="Boolean"/>
        <Parameter name="pIsReadOnly" type="Boolean"/>
        <Parameter name="pIsSystemFile" type="Boolean"/>
    </JadeMethod>
</Class>
