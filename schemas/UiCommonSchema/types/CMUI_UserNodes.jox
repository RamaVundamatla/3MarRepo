    <JadeMethod name="doTerminateNode" id="3ed811e7-b866-483b-a127-ba129a7132b7">
        <source>doTerminateNode();
// ---------------------------------------------------------------------------
// Created:     27 December 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
02 Apr 2008	cnwkpd1	PAR #16421 - Add in exception handler to deal with deleted process,
					and stop extended locks on system objects
23 Mar 2018	jlgkpd1	TFS 8044 - Additional logging of terminate requests for JADE PAR #65768

*/

vars
	theProcesses	: ProcessDict;
	aNode 			: Node;
	aResult, 
	aRow 			: Integer;
	aUser, 
	anApp 			: String;
	aProcess		: Process;
	tmpCode			: String;
	str 			: String;
	invalidNode,
	invalidProcess	: Boolean;
	
begin
	if (not self.validateTerminate(aRow)) then
		return;
	endif;

	if process.isInTransactionState then		// PAR #16421
		app.raiseUnexpectedProgramError(class.name, method.name, 'Already in transaction state');
    	return;
    endif;
	
	if process.isInLoadState then				// PAR #16421
		endLoad;
    endif;

	aUser := self.tblNodes.accessCell(aRow,2).text.trimBlanks;
	anApp := self.tblNodes.accessCell(aRow,3).text.trimBlanks;
	
	on Exception do app.handleDeletedObject(exception, aNode, invalidNode);				// PAR #16421
	on Exception do app.handleDeletedObject(exception, aProcess, invalidProcess);
	
	aProcess := self.tblNodes.accessRow(aRow).itemObject.Process;
	
	if aProcess = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Process object not found!');		// PAR #16421
    	return;
    endif;
	
	aNode := aProcess.node;
	
	// Do nothing if the process is now gone - refresh note will fix this
	if invalidProcess then
		return;
	endif;
	
	if aNode = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Node object not found!');
    	return;
    endif;
    
	str := app.getErrorString1(ForceOffUser, aUser);
	aResult := app.msgBox(str,  "Confirm Process Termination",  MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon);
	if aResult = MsgBox_Return_No then
		return;
	endif;
	
	theProcesses := aNode.processes.cloneSelf(true);
	
	// Do nothing if the node is now gone - refresh note will handle this
	if invalidNode then
		return;
	endif;
	
	foreach aProcess in theProcesses do					// PAR #16421
		invalidProcess := false;
		
		tmpCode := aProcess.userCode.toUpper;
		if invalidProcess or							// PAR #16421 - Also skip processes now gone
		   tmpCode = CLIENT_BACKGROUND_PROCNAME or
		   tmpCode = SRVR_BACKGROUND_PROCNAME then
			continue;
		endif;
		
		app.createAndCommitStringAlert("Node Terminated", "As a remove node has been called, user " &amp; aUser &amp; " has been forced off by " &amp; app.myPassport.myUser.userName);
		
		app.writeLog(method.qualifiedName &amp; " system.forceOffUser(" &amp; aNode.String &amp; ", " &amp; aProcess.String &amp; ")", LogINFO);	//25 Nov 2019	NDL	TFS 47053
		system.forceOffUser(aNode, aProcess);
    endforeach;
	
	app.createAndCommitStringAlert("Node Removed", "Node " &amp; aNode.name &amp; " has been terminated by " &amp; app.myPassport.myUser.userName);
	app.writeLog( method.qualifiedName &amp; " system.removeNode(" &amp; aNode.String &amp; ")", LogINFO);	//25 Nov 2019	NDL	TFS 47053
	system.removeNode(aNode);

	
epilog
	delete theProcesses;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doTerminateProcess" id="7ab05091-54d5-488f-816c-f1fd7c62fba9">
        <source>doTerminateProcess();
// ---------------------------------------------------------------------------
// Created:     27 December 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
02 Apr 2008	cnwkpd1	PAR #16421 - Add in exception handler to deal with deleted process
23 Mar 2018	jlgkpd1	TFS 8044 - Additional logging of terminate requests for JADE PAR #65768
16 Aug 2019 jlgmd1	TFS 46092 - Log to the users app log, similar to when terminating a BGP process

*/

vars
	aResult, 
	aRow 			: Integer;
	aUser, 
	anApp 			: String;
	aProcess		: Process;
	str 			: String;
	invalidProcess	: Boolean;
	
begin

	if (not self.validateTerminate(aRow)) then
		return;
	endif;

	aUser := self.tblNodes.accessCell(aRow,2).text.trimBlanks;
	anApp := self.tblNodes.accessCell(aRow,3).text.trimBlanks;
	aProcess := self.tblNodes.accessRow(aRow).itemObject.Process;
	
	if aProcess = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Process object not found!');		// PAR #16421
    	return;
    endif;
    
	str := app.getErrorString1(ForceOffUser, aUser);
	aResult := app.msgBox(str,  "Confirm Process Termination",  MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon);
	if aResult = MsgBox_Return_Yes	then
		app.createAndCommitStringAlert("User Process Removed", "The Process for " &amp; aUser &amp; " was terminated by " &amp; app.myPassport.myUser.userName);
		on Exception do app.handleDeletedObject(exception, aProcess, invalidProcess);		// PAR #16421

		app.writeLog("The Process (" &amp; aProcess.String &amp; ") for " &amp; aUser &amp; " was terminated by " &amp; app.myPassport.myUser.userName, LogINFO);
		system.forceOffUser(aProcess.node, aProcess);
	endif;

	
end;</source>
    </JadeMethod>
