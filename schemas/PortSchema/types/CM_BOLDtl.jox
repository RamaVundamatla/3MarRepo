    </JadeMethod>
    <JadeMethod name="initializeForActivity" id="fbfb75e5-18e1-4b47-84c5-cb5e988840b4">
        <source>initializeForActivity(_ewsOpsView: CM_EWSActivityOpsview; _opsViewTable : CMIF_OpsViewTables);
/*
Purpose:			

Date		Who		Reason
30 May 2022	navab1	TFS 53105
05 Jun 2025 navma1  MTN-34114  MTN - Performance Improvements - Remove Class::FirstInstance usage  
*/

vars
	opsviewtable     : CMIF_CrgBlItem;
	product 		 : CM_Product;
	cargotype 		 : CM_CargoType;
	terminal		 : CM_Terminal;
	measurementtype  : CM_MeasurementType;
begin
	
	opsviewtable := _opsViewTable.CMIF_CrgBlItem;

	product 						:= self.myBOL.myProduct;
	cargotype 						:= self.myCargoType;
	terminal 						:= self.myBOL.myTerminal;
	measurementtype 				:= terminal.getDefaultMeasurementForType(Type_Weight);
	
	opsviewtable.gkey 				 := opsviewtable.generateFullGKey(self, "");
	opsviewtable.nbr 				 := self.myBOL. allBOLDtls.indexOf(self).String;
	opsviewtable.client_id 			 := app.myRoot.companyCode;								//05.06.2025 navma1 #MTN-34114
	opsviewtable.bl_gkey 		     := opsviewtable.generateFullGKey(self.myBOL, "");
	opsviewtable.product_type_gkey   := opsviewtable.generateFullGKey(product, "");
	opsviewtable.commodity_gkey 	 := opsviewtable.generateFullGKey(cargotype, "");
	opsviewtable.quantity 			 := self.quantity;
	opsviewtable.docType 			 := "BOLITEM";
	
	if cargotype &lt;&gt; null then
		opsviewtable.is_bulk := cargotype.isBulk();
		opsviewtable.piece_is_bulk := cargotype.isBulk();
		opsviewtable.piece_weight_kg := cargotype.getDefautlValueForAttr(ETRow_TotalWeight);
		opsviewtable.piece_length_cm := cargotype.getDefautlValueForAttr(ETRow_Length);
		opsviewtable.piece_width_cm := cargotype.getDefautlValueForAttr(ETRow_Width);
		opsviewtable.piece_height_cm := cargotype.getDefautlValueForAttr(ETRow_Height);
		
		measurementtype := cargotype.myWeightMeasurementType;
		
		if measurementtype &lt;&gt; null then
			opsviewtable.bulk_unit := measurementtype.shortName;
			opsviewtable.piece_bulk_unit := measurementtype.shortName;
		elseif terminal &lt;&gt; null then
			measurementtype := terminal.getDefaultMeasurementForType(Type_Weight);
			opsviewtable.bulk_unit := measurementtype.shortName;
			opsviewtable.piece_bulk_unit := measurementtype.shortName;
		endif;
		
		opsviewtable.package_type_gkey := opsviewtable.generateFullGKey(cargotype.myDefaultHandlingType,"");
	endif;
	
	
	opsviewtable.temp_max_C := self.getMaximumTemperature();
	opsviewtable.temp_min_C := self.getMinimumTemperature();
	opsviewtable.temp_show_fahrenheit := self.myBOL.myOperator.displayTempFahrenheit;
	opsviewtable.weight_total_kg := self.weight;
	opsviewtable.is_direct := self.myBOL.directDelivery;
	
	opsviewtable.sequence := self.myBOL.allBOLDtls.indexOf(self);
	

	opsviewtable.handling_code_gkey:= 0;
	opsviewtable.equipment_handling_code_gkey := 0;
	opsviewtable.temp_reqd_C := 0;
	opsviewtable.package_volume_cu_cm := 0;
	opsviewtable.brand := "";
	opsviewtable.model := "";
	opsviewtable.package_weight_kg := 0;
	opsviewtable.package_length_cm := 0;
	opsviewtable.package_width_cm := 0;
	opsviewtable.package_height_cm := 0;
	opsviewtable.piece_quantity := 0;
	opsviewtable.piece_package_type_gkey := 0;

	
end;
</source>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <Parameter name="_opsViewTable" type="CMIF_OpsViewTables"/>
    </JadeMethod>
