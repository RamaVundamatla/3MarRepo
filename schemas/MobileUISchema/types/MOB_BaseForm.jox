    <JadeMethod name="gotoForm" id="3bcad7f4-2e49-4574-8236-467f08132390">
        <updating/>
        <source>gotoForm(formClass : Class; goingBack : Boolean) : Form updating, protected;

vars
	form : Form;
begin
	create form as formClass transient; 
	self.setSessionParameters();
	if not goingBack then
		if self.getSessionAgent.peekAtPreviousForm = formClass then
			// This means that we are actually going back, just through a method other than the back button
			// so we will need to pop off the final form (self). This prevents circular movement through the menus
			// that could result in the previous forms array growing huge and the user having to go back through a
			// large number of forms before getting back to the menu
			self.getSessionAgent.getPreviousForm(); // pops the calling form off the stack
		else
			self.getSessionAgent.addPreviousForm(self.class);
		endif;
	endif;
	
	
	
	form.show();
	
	// epr par 25901 29/9/10 an issue with the LXE app locker if the form was unloaded before the new one the LXE device thinks there is no app 
	// and displays an message "there are no applications running", it will then try to relaunce JadeMOB_BaseF.
	self.unloadForm;
	
	return form;
	
	
end;
</source>
        <access>protected</access>
        <Parameter name="formClass" type="Class"/>
        <Parameter name="goingBack" type="Boolean"/>
        <ReturnType type="Form"/>
    </JadeMethod>
