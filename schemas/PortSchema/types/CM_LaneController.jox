    <JadeMethod name="getLaneDevice" id="37405164-78fd-484f-847c-774efc38ff3e">
        <source>getLaneDevice(_type :Integer):CM_LaneDevice protected;
// ---------------------------------------------------------------------------
// Created:     24 June 2009 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
//				Returns first device of _type.  We really only
//				expect one of each type
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	iter	:Iterator;
	ld		:CM_LaneDevice;
begin
	iter := self.allLaneDevices.createIterator;
	
	self.allLaneDevices.startKeyGeq (_type, iter);

	while iter.next (ld) do
		if ld.type &lt;&gt; _type then
			break;
		endif;
		return ld;
	endwhile;
	
	return null;
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="CM_LaneDevice"/>
    </JadeMethod>
    <JadeMethod name="getLaneDevice_Boom" id="83466a1a-4497-4f8d-9f07-01d0eefbcb4d">
