    <JadeMethod name="tblAttachments_queryRowColChg" id="59b474b9-4feb-42fd-b9de-481baf6013d2">
        <controlMethod name="CM_DataTable::queryRowColChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblAttachments_queryRowColChg(table: CM_DataTable input; newSheet: Integer; newRow: Integer; newCol: Integer):Boolean updating;
/*
----------   ----------  --------------------------------------------------
Created:	28 March 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.trackedItemDetailsChanged and (not self.checkDoAbandonTIChanges()) then
		return false;
	endif;
	
	self.doSelectTI(table.accessRow(newRow).itemObject.CM_TrackedItem);
	return true;
end;


</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
        <Parameter name="newSheet" type="Integer"/>
        <Parameter name="newRow" type="Integer"/>
        <Parameter name="newCol" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="30983f94-8b35-48b6-a232-4a6c3dc058fa">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 26 June 2024 11:15:56.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008031, locale);
	btnAttach.translateBubbleHelp(Xlat_0005131, locale);
	btnAttach.translateCaption(Xlat_0005132, locale);
	btnDelete.translateCaption(Xlat_0005133, locale);
	btnEdit.translateCaption(Xlat_0005134, locale);
	btnNew.translateCaption(Xlat_0005135, locale);
	btnNext.translateCaption(Xlat_0005136, locale);
	btnNowIn.translateBubbleHelp(Xlat_0005137, locale);
	btnNowIn.translateCaption(Xlat_0005138, locale);
	btnNowOut.translateBubbleHelp(Xlat_0005139, locale);
	btnNowOut.translateCaption(Xlat_0005140, locale);
	btnRemove.translateBubbleHelp(Xlat_0005141, locale);
	btnRemove.translateCaption(Xlat_0005142, locale);
	btnUpdate.translateBubbleHelp(Xlat_0005143, locale);
	btnUpdate.translateCaption(Xlat_0005144, locale);
	grpItemDetails.translateCaption(Xlat_0005145, locale);
	grpReleaseDetail.translateCaption(Xlat_0005146, locale);
	grpTrackedItems.translateCaption(Xlat_0005147, locale);
	lblCargoId.translateCaption(Xlat_0005148, locale);
	lblCargoType.translateCaption(Xlat_0005149, locale);
	lblCarrier.translateCaption(Xlat_0005150, locale);
	lblCommodity.translateCaption(Xlat_0005151, locale);
	lblConsignee.translateCaption(Xlat_0005152, locale);
	lblDateIn.translateCaption(Xlat_0005153, locale);
	lblDateOut.translateCaption(Xlat_0005154, locale);
	lblDeliveredBy.translateCaption(Xlat_0005155, locale);
	lblDescription.translateCaption(Xlat_0005156, locale);
	lblDriverCode.translateCaption(Xlat_0026864, locale);
	lblExceptions.translateCaption(Xlat_0005157, locale);
	lblGate.translateCaption(Xlat_0005158, locale);
	lblLoader.translateCaption(Xlat_0005160, locale);
	lblMark.translateCaption(Xlat_0005161, locale);
	lblMarkNumber.translateCaption(Xlat_0005162, locale);
	lblProduct.translateCaption(Xlat_0005163, locale);
	lblQuantity.translateCaption(Xlat_0005164, locale);
	lblReceivedBy.translateCaption(Xlat_0005165, locale);
	lblState.translateCaption(Xlat_0005166, locale);
	lblVehicle.translateCaption(Xlat_0005167, locale);
	lblVisitNumber.translateCaption(Xlat_0013480, locale);
	lblVolume.translateCaption(Xlat_0005168, locale);
	lblVoyage.translateCaption(Xlat_0005169, locale);
	lblWeight.translateCaption(Xlat_0005170, locale);
	lblWorkNumber.translateCaption(Xlat_0005171, locale);
end;</source>
