    </JadeMethod>
    <JadeMethod name="populateEntDetailTable" id="b6c13a59-dfaa-43de-aec2-0413093b6118">
        <updating/>
        <source>populateEntDetailTable()updating;
// ---------------------------------------------------------------------------
// Created:     02 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
// 10/03/2010	cnwdap1		PAR #22938 Display/hide reefer definition lines as appropriate for cargo/track as type selected
// 22/03/2010	cnwdap1		PAR #22995 Break-Bulk with no cargo sub-types needs reefer properties as well
// 19/04/2014	cnwdap1		PAR #33606 CCMS SFW 1366 Bulk
// 18.05.2022 	navds20 	ChangeRequest 53508: EUP - Cargo Uniqueness - UI
// 21 July 2022 navvt20 	ChangeRequest 53917 - Cargo Types TEUs for GC
// 10/08/2022   navds20		ChangeRequest 54219: EUP - Cargo Group to be mandatory
// 01/05/2023	jlizm1		TFS 55453 Cargo uniqueness by subtype
// 11 July 2023 navmv20 CR 58244 Task 58245: UI - Multiple Operators
// 12 Mar 2024 	navhn30		ChangeRequest 55213: GPHA - "Weight can be certified" config option can be deselected for ISO-Containers
// 09 Apr 2024	navmd1		TFS 63565 1090 when adding new cargo type
constants

	YES = 'Yes';
	NO	= 'No';
vars
	entRow			: EntTableRow;
	cargoType		: CM_CargoType;
	displayValue	: String;	
	handlingType	: CM_HandlingType;
	drawAttr		: CM_DrawingAttribute;
	indx 			: Integer;
	_productType 	: Integer;

begin
	cargoType := self.myCurrentObject.CM_CargoType;
	
	if cargoType &lt;&gt; null and 
	   cargoType.isSystemCargoBOLType then						// PAR #33606
		self.lblSysType.visible := true;
		_productType := cargoType.productType; //20 May 2022 navds20 TFS 53508 
	else
		self.lblSysType.visible := false;
	endif;

	// PAR 33532
	if cargoType &lt;&gt; null and cargoType.id = TI_CargoType_Container then
		self.tblEntDetail.hideRowByName(ETRow_TeuConversionGC, false);
		self.tblEntDetail.hideRowByName(ETRow_TeuConversionGCBreakBulk, false); // 21 JULY 2022 navvt20 53917
		self.tblEntDetail.hideRowByName(ETRow_TeuConversionGCBulk, false);		// 21 July 2022 navvt20 53917
		self.tblEntDetail.showRowByName(ETRow_TeuConversion20, false);
		self.tblEntDetail.showRowByName(ETRow_TeuConversion30, false);
		self.tblEntDetail.showRowByName(ETRow_TeuConversion40, false);
		self.tblEntDetail.showRowByName(ETRow_TeuConversion45, false);
		self.tblEntDetail.showRowByName(ETRow_TeuConversion53, false);
		self.tblEntDetail.hideRowByName(ETRow_SaveLocationActivity, false);		//13 Apr 2021	NDL	TFS 50906
	else
		self.tblEntDetail.showRowByName(ETRow_TeuConversionGC, false);
		self.tblEntDetail.hideRowByName(ETRow_TeuConversion20, false);
		self.tblEntDetail.hideRowByName(ETRow_TeuConversion30, false);
		self.tblEntDetail.hideRowByName(ETRow_TeuConversion40, false);
		self.tblEntDetail.hideRowByName(ETRow_TeuConversion45, false);
		self.tblEntDetail.hideRowByName(ETRow_TeuConversion53, false);
		self.tblEntDetail.showRowByName(ETRow_SaveLocationActivity, false);		//13 Apr 2021	NDL	TFS 50906
	endif;

	if cargoType &lt;&gt; null and cargoType.type = TI_CargoType_Container  then		//12.03.24	navhn30		TFS #55213
		self.tblEntDetail.disableRowByName(ETRow_CanWeightBeCertified);
	else
		self.tblEntDetail.enableRowByName(ETRow_CanWeightBeCertified);
	endif;
	
	//02 Jun 2015	NDL	Par 36338
	if cargoType &lt;&gt; null and cargoType.productType = ProductType_CargoGroup then
		self.tblEntDetail.hideRowByName(ETRow_IsCommodityRequired, false);
		self.tblEntDetail.hideRowByName(ETRow_DefaultCommodityCode, false);
		self.tblEntDetail.hideRowByName(ETRow_IsSubCargoTypeRequired, false);										
		self.tblEntDetail.hideRowByName(ETRow_NumberOfProducts, false);
		self.tblEntDetail.hideRowByName(ETRow_IsWeighable, false);
		self.tblEntDetail.hideRowByName(ETRow_IsCheckMaxLift, false);
		self.tblEntDetail.hideRowByName(ETRow_IncludeInStorage, false);
		self.tblEntDetail.hideRowByName(ETRow_ShowDamageCodes, false);
		self.tblEntDetail.hideRowByName(ETRow_AllowDuplicates, false);
		self.tblEntDetail.hideRowByName(ETRow_UseCGForUniqueness, false);	//20 May 2022 navds20 TFS 53508 
		self.tblEntDetail.hideRowByName(ETRow_DefaultWeightType, false);
		self.tblEntDetail.hideRowByName(ETRow_DefaultVolumeType, false);
		self.tblEntDetail.hideRowByName(ETRow_DrawAttribute, false);
		self.tblEntDetail.hideRowByName(ETRow_CreateBOL, false);		
		self.tblEntDetail.hideRowByName(ETRow_ChgToStorageOnUnpack, false);
		self.tblEntDetail.hideRowByName(ETRow_UseTareCargoWeight, false);
		self.tblEntDetail.hideRowByName(ETRow_AutoTareCargoWeightCalc, false);					//navra1 - TFS 63624 - 15th Apr 2024
		self.tblEntDetail.hideRowByName(ETRow_CanWeightBeCertified, false);
		self.tblEntDetail.hideRowByName(ETRow_BehaviourType, false);
		self.tblEntDetail.hideRowByName(ETRow_TeuMultiplier, false);
		self.tblEntDetail.hideRowByName(ETRow_TeuConversionGC, false);
		self.tblEntDetail.hideRowByName(ETRow_SaveLocationActivity, false);	//13 Apr 2021	NDL	TFS 50906
		
	else
		self.tblEntDetail.showRowByName(ETRow_IsCommodityRequired, false);
		self.tblEntDetail.showRowByName(ETRow_DefaultCommodityCode, false);
		self.tblEntDetail.showRowByName(ETRow_IsSubCargoTypeRequired, false);											
		self.tblEntDetail.showRowByName(ETRow_NumberOfProducts, false);
		self.tblEntDetail.showRowByName(ETRow_IsWeighable, false);
		self.tblEntDetail.showRowByName(ETRow_IsCheckMaxLift, false);
		self.tblEntDetail.showRowByName(ETRow_IncludeInStorage, false);
		self.tblEntDetail.showRowByName(ETRow_ShowDamageCodes, false);
		self.tblEntDetail.showRowByName(ETRow_AllowDuplicates, false);
		self.tblEntDetail.showRowByName(ETRow_DefaultWeightType, false);
		self.tblEntDetail.showRowByName(ETRow_DefaultVolumeType, false);
		self.tblEntDetail.showRowByName(ETRow_DrawAttribute, false);
		self.tblEntDetail.showRowByName(ETRow_CreateBOL, false);		
		self.tblEntDetail.showRowByName(ETRow_ChgToStorageOnUnpack, false);
		self.tblEntDetail.showRowByName(ETRow_UseTareCargoWeight, false);
		self.tblEntDetail.showRowByName(ETRow_CanWeightBeCertified, false);
		self.tblEntDetail.showRowByName(ETRow_BehaviourType, false);
		self.tblEntDetail.showRowByName(ETRow_TeuMultiplier, false);
		self.tblEntDetail.showRowByName(ETRow_SaveLocationActivity, false);	//13 Apr 2021	NDL	TFS 50906
	endif;
		
	foreach entRow in self.getEntTableDef.allEntTableRows do
		if cargoType &lt;&gt; null then
			displayValue := cargoType.getDisplayStringForAttribute(entRow.name, false).String;
			
			//navra1 - TFS 63624 - 15th Apr 2024 - start
			if entRow.name = ETRow_UseTareCargoWeight then
				if displayValue = NO then
					self.tblEntDetail.hideRowByName(ETRow_AutoTareCargoWeightCalc, false);
				else
					self.tblEntDetail.showRowByName(ETRow_AutoTareCargoWeightCalc, false);
				endif;
			endif;
			//navra1 - TFS 63624 - 15th Apr 2024 - end
		else
			displayValue := null;
		endif;
		
		
		if entRow.name = ETRow_ProductType and cargoType &lt;&gt; null then
			self.cmbChar.listIndex := displayValue.Integer + 1;	
			self.cmbProductType.setIndexForItemData(cargoType.productType); //epr par 35062 14/10/14
		endif;

		//cnwjo3 ccms 1018
		if entRow.name = ETRow_BehaviourType then
			self.loadBehaviourTypes();
			indx := self.cmbBehaviourType.findString(1,displayValue);
			if indx &gt; 0 then
				self.cmbBehaviourType.setIndex(indx);
			endif;
			
			//cnwjo3, shame CM_Car is not called CM_MotorVehicle
			if cargoType &lt;&gt; null then
				if cargoType.productType = ProductType_Vehicle or
					cargoType.productType = ProductType_Trailer then  //i believe this to be the offical way
					self.tblEntDetail.showRowByName(ETRow_BehaviourType,false);
					indx := self.tblEntDetail.getRowByName(ETRow_BehaviourType);
					if indx &gt; 0 then
						self.tblEntDetail.accessRow(indx).height := 20;
					endif;
				else
					self.tblEntDetail.hideRowByName(ETRow_BehaviourType,false);
				endif;
			else
				self.tblEntDetail.showRowByName(ETRow_BehaviourType,false);
			endif;
		endif;		
		
		
	   if entRow.name = ETRow_IsWeighable or
		   entRow.name = ETRow_IsCheckMaxLift or
		   entRow.name = ETRow_ShowDamageCodes or
		   entRow.name = ETRow_IsCargoGroupRequired or		 //09/08/2022 navds20 TFS 54219
		   entRow.name = ETRow_AllowMultiOperators or //11/07/2023 navmv20 CR 58244 Task 58245
		   entRow.name = ETRow_IsBulkProduct or 			 // R Barr 2/11/2006 Comalco
		   entRow.name = ETRow_IsDynamicallyCreated then 	 //AER Nelson 12/05/2008
			self.tblEntDetail.setValueByName(entRow.name, displayValue.isTrueFalse(YES, NO, false).Integer);	
		else
			self.tblEntDetail.setValueByName(entRow.name, displayValue);
		endif;
		
		if entRow.name = ETRow_AllowDuplicates then
			if cargoType &lt;&gt; null and cargoType.id &lt; TI_CargoType_Max then
				self.tblEntDetail.hideRowByName(entRow.name, false);
			else
				self.tblEntDetail.showRowByName(entRow.name, false);
				if cargoType &lt;&gt; null then
					self.tblEntDetail.setValueByName(entRow.name, cargoType.allowDuplicates);		
				endif;
			endif;
		endif;
		
		//13 Apr 2021	NDL	TFS 50906
		if entRow.name = ETRow_SaveLocationActivity then
			if cargoType &lt;&gt; null and cargoType.id &lt; TI_CargoType_Max then
				self.tblEntDetail.hideRowByName(entRow.name, false);
			else
				self.tblEntDetail.showRowByName(entRow.name, false);
				if cargoType &lt;&gt; null then
					self.tblEntDetail.setValueByName(entRow.name, cargoType.saveLocationActivity);		
				endif;
			endif;
		endif;
		
		// PAR #22938 allow reefer definition properties for vehicles
		// PAR #22995 allow reefer definition properties for Break-Bulk with no subcargo types
		if entRow.name.isOneOf(ETRow_Reefer, ETRow_Powered, ETRow_Integral, ETRow_Fan) then
			if cargoType = null then
				if cmbProductType.listIndex &gt; 0 and (cmbProductType.listIndex - 1) = ProductType_Vehicle then
					self.tblEntDetail.showRowByName(entRow.name, false);
				elseif self.tblEntDetail.getValueByName(ETRow_ProductType).String = ProductType_BreakBulkStr 
					and self.tblEntDetail.getValueByName(ETRow_IsSubCargoTypeRequired).Boolean = false then	// PAR #22995
					self.tblEntDetail.showRowByName(entRow.name, false);
				elseif self.tblEntDetail.getValueByName(ETRow_ProductType).String = ProductType_PieceBreakBulkStr 
					and self.tblEntDetail.getValueByName(ETRow_IsSubCargoTypeRequired).Boolean = false then	// PAR #22995
					self.tblEntDetail.showRowByName(entRow.name, false);
				else
					self.tblEntDetail.hideRowByName(entRow.name, false);
				endif;
			else
				if cargoType.mySystemProductType &lt;&gt; null then
					self.tblEntDetail.showRowByName(entRow.name, false);
				else
					self.tblEntDetail.hideRowByName(entRow.name, false);
				endif;
			endif;
		endif;
		//Start 20.05.2022 navds20 TFS 53508
		if entRow.name = ETRow_UseCGForUniqueness then
			if app.isCargoGroupEnabled and cargoType &lt;&gt; null and cargoType.allowDuplicates
				and (_productType = ProductType_Bulk or _productType = ProductType_BreakBulk) then
				self.tblEntDetail.showRowByName(entRow.name,false);
			else
				self.tblEntDetail.hideRowByName(entRow.name,false);
			endif;
		endif;
		//End 20.05.2022 navds20 TFS 53508 
		
		//Start 21 july 2022 navvt20 53917
		if entRow.name = ETRow_TeuConversionGCBreakBulk then 
		     if app.isCargoGroupEnabled and  _productType = ProductType_BreakBulk then
			     self.tblEntDetail.showRowByName(entRow.name,false);
			else
				self.tblEntDetail.hideRowByName(entRow.name,false);
			 endif;
	     endif;
		 if entRow.name = ETRow_TeuConversionGCBulk then 
		     if app.isCargoGroupEnabled and  _productType = ProductType_Bulk then
			     self.tblEntDetail.showRowByName(entRow.name,false);
			else
				self.tblEntDetail.hideRowByName(entRow.name,false);
			 endif;
	     endif;
		 //End 21 july 2022 navvt20 53917
		 
		 // TFS 55453
		 if entRow.name = ETRow_UseSubTypeForUniqueness then
			if cargoType &lt;&gt; null and cargoType.allowDuplicates 
			and (_productType = ProductType_Bulk or _productType = ProductType_BreakBulk) then
				self.tblEntDetail.showRowByName(entRow.name,false);
				self.tblEntDetail.setValueByName(entRow.name, displayValue);
			else
				self.tblEntDetail.hideRowByName(entRow.name,false);
			endif;
		 endif;
	endforeach;
	
	if cargoType &lt;&gt; null then
		handlingType := cargoType.myDefaultHandlingType;
		// This is the new one for after 7.4.1 release	
		//handlingType := cargoType.getAttributeValue(CM_CargoTypeExtBreakBulkGen::myDefaultHandlingType.name).CM_HandlingType;
		if handlingType &lt;&gt; null then
			self.cmbHandling.listObject := handlingType;
			self.tblEntDetail.setValueByName(ETRow_DefaultHandlingType, handlingType.description);
		endif;
		
		drawAttr := cargoType.myDrawingAttribute;
		if drawAttr &lt;&gt; null then
			self.tblEntDetail.accessCell(self.tblEntDetail.getRowByName(ETRow_DrawColour), CM_EntryTable.ColumnValue).backColor := drawAttr.colour;
			self.tblEntDetail.accessCell(self.tblEntDetail.getRowByName(ETRow_Character), CM_EntryTable.ColumnValue).fontName := drawAttr.fontName;
			
			if drawAttr.fontCharacter &gt;= 1 and drawAttr.fontCharacter &lt;= 255 then
				self.cmbChar.listIndex := drawAttr.fontCharacter;
			endif;
			self.tblEntDetail.setValueByName(ETRow_Character, self.cmbChar.text);			
			self.tblEntDetail.setValueByName(ETRow_CharacterNumber, drawAttr.fontCharacter);			
		endif;
	endif;
	
	self.populateHandlingSubTypes( cargoType );	//31 Mar 2017	NDL	TFS 3414
	
	if cargoType &lt;&gt; null then
		self.displayProductDefaultsNew(cargoType, cargoType.productType);
	else
		self.displayProductDefaultsNew(null,null);
	endif;
	
	if cargoType &lt;&gt; null and cargoType.isSystemCargoBOLType then
		self.tblEntDetail.disableRowByName(ETRow_Abbreviation);
		self.tblEntDetail.disableRowByName(ETRow_Description);
		self.tblEntDetail.disableRowByName(ETRow_DefaultHandlingType);
		self.tblEntDetail.disableRowByName(ETRow_IsBulkProduct);		// R Barr 2/11/2006 Comalco
		self.tblEntDetail.disableRowByName(ETRow_ProductType);
	else
		self.tblEntDetail.enableRowByName(ETRow_Abbreviation);
		self.tblEntDetail.enableRowByName(ETRow_Description);
		self.tblEntDetail.enableRowByName(ETRow_DefaultHandlingType);
		self.tblEntDetail.enableRowByName(ETRow_IsBulkProduct);		// R Barr 2/11/2006 Comalco
		self.tblEntDetail.enableRowByName(ETRow_ProductType);
		if cargoType &lt;&gt; null and cargoType.hasProductTypes() then	// don't allow cahnge, when there are data in DB. CCMS 1080 PAR19704 July 2009
			self.tblEntDetail.disableRowByName(ETRow_ProductType);	
		endif;
	endif;	
	
	//25 Jan 2018 - TFS 36697
	if cargoType &lt;&gt; null and ( not cargoType.isBulkMulti and not cargoType.isBreakBulkMulti ) then
		self.tblEntDetail.setValueByName(ETRow_AllowAutoWeightCalc,false);
		self.tblEntDetail.disableRowByName(ETRow_AllowAutoWeightCalc);
	else
		self.tblEntDetail.enableRowByName(ETRow_AllowAutoWeightCalc);
	endif; 
	
	// 10/09/2009 	cnwsh3 		CCMS SFW1044 PAR20300 - AMS changes.  Now need the ability to create
	//BOLs no matter what kind of cargo type it is.  There is a terminal config flag called 'createBOLForOnshipItems' 
	//that will check see whether the system wants BOLs created in conjunction with this setting.
	/*if cargoType &lt;&gt; null and cargoType.id = TI_CargoType_Car then //ccms 1100 cnwrs1 mar 2008
	self.tblEntDetail.showRowByName(ETRow_CreateBOL, false);
	else
		self.tblEntDetail.hideRowByName(ETRow_CreateBOL, false);
	endif; */
	self.tblEntDetail.showRowByName(ETRow_CreateBOL, false);
	
	self.showHideControlsTblEntDetail(-1);	// -1 means NULL for integer parameter. PAR 19704, CCMS 1080. May 2009 cnwvu1

	
end;</source>
    </JadeMethod>
    <JadeMethod name="populateHandlingSubTypes" id="ff1c8cfa-8f9c-49ff-b34e-67a4bf37f1a6">
        <updating/>
        <source>populateHandlingSubTypes( _cargoType : CM_CargoType )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 March 2017	cnwndl1	Initial creation	TFS 3414
13 Jun 2017	NDL	- Seesaw seesaw.... Olivier and the magic roundabout... Now we want no default

*/

vars

	handlingType : CM_HandlingType;
	handlingSubType : CM_HandlingSubType;
	index : Integer;
	obj : Object;

begin

	self.allHandlingSubTypes.clear();
	self.cmbSubHandl.clear();
	
	handlingType := self.cmbHandling.listObject.CM_HandlingType;
	
	if handlingType = null then
		//do nothing
	else
		handlingType.getValidSubTypes( self.allHandlingSubTypes, false );
	endif;
	
	if self.allHandlingSubTypes.isEmpty then
		self.tblEntDetail.hideRowByName(ETRow_DefHandlingSubType,false);
		self.tblEntDetail.setValueByName(ETRow_DefHandlingSubType, null);
	else
		self.tblEntDetail.showRowByName(ETRow_DefHandlingSubType,false);
		self.tblEntDetail.refresh;
	//	self.cmbSubHandl.listCollection(self.allHandlingSubTypes, false, 0);
	
		self.myAssistant.comboBoxSubHandlingTypes( self.cmbSubHandl, handlingType );	//13 Jun 2017
		
		if _cargoType &lt;&gt; null and _cargoType.myDefHandlingSubType &lt;&gt; null then
			handlingSubType := _cargoType.myDefHandlingSubType;
	//	else
	//		handlingSubType := handlingType.getDefaultSubHandlingType;
		endif;
		if handlingSubType &lt;&gt; null then
			self.cmbSubHandl.listObject := handlingSubType;
			self.tblEntDetail.setValueByName(ETRow_DefHandlingSubType, handlingSubType.description);
		else
			self.tblEntDetail.setValueByName(ETRow_DefHandlingSubType, null);
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="resetRecipeButtons" id="8ee877de-6826-4d94-8791-22a2eb72d5d6">
        <source>resetRecipeButtons();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	canMaintain : Boolean;
	canView : Boolean;
	recipe : CM_Recipe;
	rowIndex : Integer;

begin

	canMaintain := app.myPassport.myUser.canDo( null, PmAdmCargoTypeMaint );
	canView := app.myPassport.myUser.canDo( null, PmAdmCargoTypeView );
	
	rowIndex := self.tblRecipes.row;
	if rowIndex &gt; self.tblRecipes.fixedRows and rowIndex &lt;= self.tblRecipes.rows then
		recipe := self.tblRecipes.accessRow(rowIndex).itemObject.CM_Recipe;
	endif;
	
	if self.mode = Mode_View then
		self.btnUpdRecipe.caption := app.getErrorString(View);
	else
		self.btnUpdRecipe.caption := app.getErrorString(UpdateUpper);
	endif;

	self.btnAddRecipe.enabled := canMaintain and self.mode &lt;&gt; Mode_View;
	self.btnUpdRecipe.enabled := ( canMaintain or canView ) and recipe &lt;&gt; null;
	self.btnDelRecipe.enabled := canMaintain and recipe &lt;&gt; null and self.mode &lt;&gt; Mode_View;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="resizeShtDamageContents" id="816f1fc1-b3fd-420c-b232-e57ca9425dca">
        <source>resizeShtDamageContents();
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 24 July 2009
//
// Implemented version: 7.7.3
// CCMS SFW1066  - Recording Damage Details Changes.
//----------------------------------------------------------------------
constants
	LeftMargin :Integer = 10;
	TopMargin : Integer = 10;
	VerticalSpacting : Integer = 10;
vars
	sheet : CMUI_Sheet;
	currentTop : Real;
begin
	sheet := self.shtDmgePosition;
	self.shtDmgePosition.cnEcResizeContents();
	currentTop := 2;
	self.mulDmgeDefCode.top 	:= currentTop;
	self.mulDmgeDefCode.left	:= LeftMargin;
	self.mulDmgeDefCode.width 	:= self.mulDmgeDefCode.parent.width - 10;
	self.mulDmgeDefCode.height 	:= ((self.mulDmgeDefCode.parent.height - self.mulDmgeDefCode.top)/2).Integer -20;
	mulDmgeDefCode.cnEcResizeContents();
	
	currentTop := self.mulDmgeDefCode.top + self.mulDmgeDefCode.height + VerticalSpacing;
	self.mulDmgePosition.top 	:= currentTop;
	self.mulDmgePosition.left	:= LeftMargin;
	self.mulDmgePosition.width 	:= self.mulDmgePosition.parent.width - 10;
	self.mulDmgePosition.height 	:= self.mulDmgePosition.parent.height - self.mulDmgePosition.top -20 ;
	mulDmgePosition.cnEcResizeContents();
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="3570a515-438f-4eac-9547-b5b2f0ee5eaf">
