    </PrimAttribute>
    <JadeMethod name="getDisplayStringForAttribute" id="b1840b8b-8904-477e-a35c-ec15d6c8ae57">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Aug 2020	jlgndl1	Initial creation	TFS 49869
21 Sep 2020 cnwma1  ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data
15 Nov 2021 navmd1	TFS 49052 Refactor ExtWSDef attributes post JADE2020 src comparison
*/

vars

begin

	if _attrName = ETRow_WebServiceType then
		return ExternalWebServiceAllotrac;
	endif;
	
	if _attrName = ETRow_SendOnReceive then
		return self.sendJobCompleteOnReceive.getYesNo;
	elseif _attrName = ETRow_SendOnRelease then
		return self.sendJobCompleteOnRelease.getYesNo;
	endif;
		
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setExtras" id="2e785606-2d5b-46cb-9a3d-7e16225c9011">
        <updating/>
        <source>setExtras(	_deviceID : String;
			_sendJobCompleteOnReceive : Boolean;
			_sendJobCompleteOnRelease : Boolean
			)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 August 2020	jlgndl1	Initial creation	TFS 49869

*/

vars

begin

	self.deviceID := _deviceID;
	self.sendJobCompleteOnReceive := _sendJobCompleteOnReceive;
	self.sendJobCompleteOnRelease := _sendJobCompleteOnRelease;

epilog

end;</source>
        <Parameter name="_deviceID" type="String"/>
        <Parameter name="_sendJobCompleteOnReceive" type="Boolean"/>
        <Parameter name="_sendJobCompleteOnRelease" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="4e1ddac1-2afd-4194-b061-370b2ec29452">
        <updating/>
        <source>setForUpdate( _extWebService: CM_AllotracServiceDef ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 August 2020	jlgndl1	Initial creation	TFS 49869

*/

vars

begin

	self.deviceID := _extWebService.deviceID;
	self.sendJobCompleteOnReceive := _extWebService.sendJobCompleteOnReceive;
	self.sendJobCompleteOnRelease := _extWebService.sendJobCompleteOnRelease;

	inheritMethod(_extWebService);

epilog

end;</source>
        <Parameter name="_extWebService" type="CM_AllotracServiceDef"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="94cf7050-b053-4729-ac33-e916624e7992">
        <source>validateMe() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 August 2020	jlgndl1	Initial creation	TFS 49869

*/

vars

	wsDef : CM_AllotracServiceDef;
	realObj : CM_AllotracServiceDef;

begin
	inheritMethod();
	
	wsDef := app.myRoot.getFirstActiveExtWebService( CM_AllotracServiceDef ).CM_AllotracServiceDef;
	if wsDef &lt;&gt; null then
		//Only one active at a time.
		if self.isTransient then
			realObj := self.pxyGetRealObject();
		else
			realObj := self;
		endif;
		
		if wsDef &lt;&gt; realObj then
			app.raiseCMException2( ERR_Active_ExtWebDef, ExternalWebServiceAllotrac, wsDef.name, null, null );
		endif;
	
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
