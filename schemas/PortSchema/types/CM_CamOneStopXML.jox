    <JadeMethod name="makeLineOperatorSectXML" id="0eccd064-5e43-4235-b3ea-1ce8010a0224">
        <source>makeLineOperatorSectXML( _oper : CM_Operator; _parentElem : JadeXMLElement input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2016	cnwndl1	Initial creation	TFS 2561 / 2277

*/

vars

	rootElem : JadeXMLElement;
	xmlElem : JadeXMLElement;
	foundMatch : Boolean;
	fCode : String;

begin

	rootElem := _parentElem.addElement('LineOperator');
	
	if _oper = null then
		return;
	endif;
	
	//12 Jun 2017	NDL	TFS 4751
	fCode := app.myRoot.getXlationForeignOperatorCode( _oper, _oper.code, foundMatch );
	
	xmlElem := rootElem.addElement('LineOperatorCode');
	xmlElem.setText( fCode );
/*	
	xmlElem := rootElem.addElement('LineOperatorDescription');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('InboundLineOpCode');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('InboundLineOpDescription');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('ABN_Number');
	xmlElem.setText( null );
*/	
	self.makeLineOpAddrSubSectXML( _oper, rootElem );
	

epilog

end;</source>
