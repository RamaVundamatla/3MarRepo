*/

vars

begin
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setObjectAndHarbour" id="bfe0971a-4c76-4c33-8f9c-641a07844f21">
        <updating/>
        <source>setObjectAndHarbour(_pilotLaunch : HMS_PilotLaunch; _harbour : HMS_Harbour) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

*/

vars

begin
	self.amInitialised := false;
	self.myHarbour := _harbour;
	self.setObject(_pilotLaunch);
epilog

end;</source>
        <Parameter name="_pilotLaunch" type="HMS_PilotLaunch"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
    </JadeMethod>
