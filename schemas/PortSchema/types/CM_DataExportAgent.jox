<Class name="CM_DataExportAgent" id="a2a60651-917f-454e-bf48-ef8c73b90ab4">
    <superclass name="CM_ExportImportAgent"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="exportImport"/>
    <JadeMethod name="exportAttribute" id="0e6a5e9f-b690-4d2c-8ad3-1031bb2ae087">
        <source>exportAttribute(_obj: Object; _property: Property): String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2026	naviv1	Initial creation MTN-36788 - JADE Core Framework - Export Engine - XML Generation

*/

vars
    message: String;
    str: String;
    intVal: Integer;
    realVal: Real;
    booleanVal: Boolean;
    binaryVal: Binary;
    pointVal: Point;
    timeVal: Time;
begin
    message := "";

    if _obj = null or _property = null then return message; endif;

    if _property.type = StringArray then
        foreach str in _obj.getPropertyValue(_property.name).StringArray do
            if str &lt;&gt; null then
                if message = "" then message := str; else message := message &amp; ":" &amp; str; endif;
            endif;
        endforeach;
        return message;
    endif;

    if _property.type = CM_StringArray then
        foreach str in _obj.getPropertyValue(_property.name).CM_StringArray do
            if str &lt;&gt; null then
                if message = "" then message := str; else message := message &amp; ":" &amp; str; endif;
            endif;
        endforeach;
        return message;
    endif;

    if _property.type = CM_LabelArray then
        foreach str in _obj.getPropertyValue(_property.name).CM_LabelArray do
            if str &lt;&gt; null then
                if message = "" then message := str; else message := message &amp; ":" &amp; str; endif;
            endif;
        endforeach;
        return message;
    endif;

    if _property.type = CM_ConsignCodeArray then
        foreach str in _obj.getPropertyValue(_property.name).CM_ConsignCodeArray do
            if str &lt;&gt; null then
                if message = "" then message := str; else message := message &amp; ":" &amp; str; endif;
            endif;
        endforeach;
        return message;
    endif;

    if _property.type = HugeStringArray then
        foreach str in _obj.getPropertyValue(_property.name).HugeStringArray do
            if str &lt;&gt; null then
                if message = "" then message := str; else message := message &amp; ":" &amp; str; endif;
            endif;
        endforeach;
        return message;
    endif;

    if _property.type = IntegerArray then
        foreach intVal in _obj.getPropertyValue(_property.name).IntegerArray do
            if message = "" then message := intVal.String; else message := message &amp; ":" &amp; intVal.String; endif;
        endforeach;
        return message;
    endif;

    if _property.type = CM_IntegerArray then
        foreach intVal in _obj.getPropertyValue(_property.name).CM_IntegerArray do
            if message = "" then message := intVal.String; else message := message &amp; ":" &amp; intVal.String; endif;
        endforeach;
        return message;
    endif;

    if _property.type = PointArray then
        foreach pointVal in _obj.getPropertyValue(_property.name).PointArray do
            if message = "" then message := pointVal.String; else message := message &amp; ":" &amp; pointVal.String; endif;
        endforeach;
        return message;
    endif;

    if _property.type = CM_PointArray then
        foreach pointVal in _obj.getPropertyValue(_property.name).CM_PointArray do
            if message = "" then message := pointVal.String; else message := message &amp; ":" &amp; pointVal.String; endif;
        endforeach;
        return message;
    endif;

    if _property.type = TimeArray then
        foreach timeVal in _obj.getPropertyValue(_property.name).TimeArray do
            if message = "" then message := timeVal.String; else message := message &amp; ":" &amp; timeVal.String; endif;
        endforeach;
        return message;
    endif;

    if _property.type = DecimalArray then
        foreach realVal in _obj.getPropertyValue(_property.name).DecimalArray do
            if message = "" then message := realVal.String; else message := message &amp; ":" &amp; realVal.String; endif;
        endforeach;
        return message;
    endif;

    if _property.type = BooleanArray then
        foreach booleanVal in _obj.getPropertyValue(_property.name).BooleanArray do
            if message = "" then message := booleanVal.String; else message := message &amp; ":" &amp; booleanVal.String; endif;
        endforeach;
        return message;
    endif;

    if _property.type = BinaryArray then
        foreach binaryVal in _obj.getPropertyValue(_property.name).BinaryArray do
            if binaryVal &lt;&gt; null then
                if message = "" then message := binaryVal.ansiToString(); else message := message &amp; ":" &amp; binaryVal.ansiToString(); endif;
            endif;
        endforeach;
        return message;
    endif;

    return message;
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="exportAttributes" id="d853f4e7-4d97-404d-a06a-da4b7d386940">
        <updating/>
        <source>exportAttributes(_obj: Object) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2026	naviv1	Initial creation MTN-36788 - JADE Core Framework - Export Engine - XML Generation

*/

vars
    exportProp: CM_ExportImportProperty;
    attrVal: String;
    tagName: String;
begin
    foreach exportProp in self.attributes do
        // Use virtual mapping - exportProp.myProperty
        if exportProp.myProperty = null then
            continue;
        endif;
		
		if exportProp.myProperty.isA(CompAttribute) then
			attrVal := self.exportAttribute(_obj,exportProp.myProperty);
		else
        // Get attribute value
        attrVal := _obj.getPropertyValue(exportProp.myProperty.name).String;
        endif;
        // Use display name for XML tag
        tagName := self.removeSpaces(exportProp.displayName);
        //self.appendXmlTag(tagName, self.escapeXml(attrVal));
		self.appendXmlLine("&lt;" &amp; tagName &amp; "&gt;" &amp; self.escapeXml(attrVal) &amp; "&lt;/" &amp; tagName &amp; "&gt;");
    endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="exportClassInstances" id="f41f4c0b-caa7-441f-951b-32eacc175c15">
        <updating/>
        <source>exportClassInstances(_maxNumber: Integer; _keyFilter: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2026	naviv1	Initial creation MTN-36788 - JADE Core Framework - Export Engine - XML Generation

*/
constants
	EXPORT_START_TAG = "&lt;ExportData&gt;";
	EXPORT_END_TAG = "&lt;/ExportData&gt;";
vars
    obj: Object;
    count: Integer;
    keyValue: String; 
    className: String;
	objArr : ObjectArray;
begin
    // Step 1: Categorize configured properties
    self.categorizeClassProperties();
    
    // Step 2: Open root collection element (e.g., &lt;Commoditys&gt;)
    className := self.removeSpaces(self.myExportImportClass.displayName);
	
	create self.lookupAgent transient;

	objArr := self.lookupAgent.resolveCollectionMember(self.myExportImportClass.className);
	
    
    // Step 3: Iterate through all persistent instances
    count := 0;
   // foreach obj in self.myExportImportClass.myClass.instances do
   foreach obj in objArr do
        // Skip transient objects
        if obj.isTransient then
            continue;
        endif;
        
        // Step 4: Apply business key filter if specified
        if _keyFilter &lt;&gt; null and _keyFilter &lt;&gt; "" then
            keyValue := obj.getPropertyValue(self.myExportImportClass.myKeyName).String;
            if keyValue &lt;&gt; _keyFilter then
                continue;
            endif;
        endif;
        
        // Step 5: Apply terminal filter for terminal-scoped classes
        if self.myExportImportClass.category = ExportImportTerminalAdmin or self.myExportImportClass.category = ExportImportTerminalScreen then
            if obj.getMyTerminal() &lt;&gt; app.myPassport.myTerminal then
                continue;
            endif;
        endif;
		
		 count := count + 1;
		if count = 1 then
			self.appendXmlLine(EXPORT_START_TAG);
			self.appendXmlLine("&lt;" &amp; className &amp; "s&gt;");
		endif;
        // Step 6: Export individual object
        self.appendXmlLine("&lt;" &amp; className &amp; "&gt;");
        self.exportObjectToXML(obj);
        self.appendXmlLine("&lt;/" &amp; className &amp; "&gt;");
        
        // Step 7: Check max records limit
        count := count + 1;
        if _maxNumber &gt; 0 and count &gt;= _maxNumber then
            break;
        endif;
    endforeach;
    
	if count &gt; 0 then
		// Step 8: Close root collection element
		self.appendXmlLine("&lt;/" &amp; className &amp; "s&gt;");
		self.appendXmlLine(EXPORT_END_TAG);
	endif;
	write "Exported " &amp; count.String &amp; " objects";
epilog
	
	delete self.lookupAgent;
end;</source>
        <Parameter name="_maxNumber" type="Integer"/>
        <Parameter name="_keyFilter" type="String"/>
    </JadeMethod>
    <JadeMethod name="exportCollectionExpanded" id="c14ec906-5a3c-4f06-b4ce-2d5e11878a31">
        <updating/>
        <source>exportCollectionExpanded(_obj: Object; _property: CM_ExportImportProperty; _coll: Collection) updating, protected;
/*

Purpose:			
	* Exports collection members as fully expanded objects with parent key
	 * 
	 * @param _obj The parent object
	 * @param _property The collection property configuration
	 * @param _coll The collection to export
	 * 
	 * Example output (SatelliteViewDefinition -&gt; TerminalAreaViewPositions):
	 * &lt;TerminalAreaViewPositions&gt;
	 *   &lt;TerminalAreaViewPosition&gt;
	 *     &lt;SatelliteViewDefinition_Key&gt;DDDD&lt;/SatelliteViewDefinition_Key&gt;
	 *     &lt;DisplayBottomColumnLabels&gt;true&lt;/DisplayBottomColumnLabels&gt;
	 *     &lt;Height&gt;148&lt;/Height&gt;
	 *     &lt;Width&gt;264&lt;/Width&gt;
	 *     &lt;TerminalArea&gt;TESTD&lt;/TerminalArea&gt;
	 *   &lt;/TerminalAreaViewPosition&gt;
	 * &lt;/TerminalAreaViewPositions&gt;
	 * 
	 * Creates a temporary export agent for each member to handle its full export
Parameters:			

Return Value:		

Date		Who		Reason
06 January 2026	naviv1	Initial creation MTN-36788 - JADE Core Framework - Export Engine - XML Generation

*/

vars
    member: Object;
    subAgent: CM_DataExportAgent;
    memberExportClass: CM_ExportImportClass;
    iter: Iterator;
    ownerKey: String;
    ownerProp: CM_ExportImportProperty;
begin  
	if not self.checkIfCMObject(_coll.class.name) then
		// Get parent object's business key
		ownerKey := _obj.getPropertyValue(self.myExportImportClass.myKeyName).String;
		ownerProp := self.myExportImportClass.allProperties[self.myExportImportClass.myKeyName];
    endif;
    // Iterate through collection members
    iter := _coll.createIterator();
    while iter.next(member) do
        // Skip transient members
        if not member.isTransient then
            // Get export configuration for member class
            memberExportClass := app.myRoot.allExportImportClasses[member.class.name];
            
            if memberExportClass &lt;&gt; null then
                // Create temporary agent to export member
                create subAgent transient;
                subAgent.setExportImportClass(memberExportClass);
                subAgent.categorizeClassProperties();
                subAgent.xmlStr := "";
                
                // Open member element
                self.appendXmlLine("&lt;" &amp; self.removeSpaces(memberExportClass.displayName) &amp; "&gt;");
                
                // Export member's full attributes/references
                subAgent.exportObjectToXML(member);
                
                // Add parent key reference (establishes relationship)
				if ownerProp &lt;&gt; null then
					self.appendXmlTag(self.removeSpaces(ownerProp.displayName) &amp; "_Key", ownerKey);
				endif;
                
                // Append member's XML
                self.appendXmlLine(subAgent.xmlStr);
                
                // Close member element
                self.appendXmlLine("&lt;/" &amp; self.removeSpaces(memberExportClass.displayName) &amp; "&gt;");
                
                delete subAgent;
            endif;
        endif;
    endwhile;
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_property" type="CM_ExportImportProperty"/>
        <Parameter name="_coll" type="Collection"/>
    </JadeMethod>
    <JadeMethod name="exportCollectionKeys" id="62ab5968-4385-40a6-8954-ee71c3c50cf7">
        <updating/>
        <source>exportCollectionKeys(_obj: Object; _property: CM_ExportImportProperty; _coll: Collection) updating, protected;
/*

Purpose:			
	* Exports collection members with parent key and member key only
	 * 
	 * @param _obj The parent object
	 * @param _property The collection property configuration
	 * @param _coll The collection to export
	 * 
	 * Example output (Commodity -&gt; CargoTypes):
	 * &lt;CargoTypes&gt;
	 *   &lt;CargoType&gt;
	 *     &lt;CommodityCode_Key&gt;STEEL&lt;/CommodityCode_Key&gt;
	 *     &lt;Description&gt;ISO Container&lt;/Description&gt;
	 *   &lt;/CargoType&gt;
	 *   &lt;CargoType&gt;
	 *     &lt;CommodityCode_Key&gt;STEEL&lt;/CommodityCode_Key&gt;
	 *     &lt;Description&gt;Break-Bulk Cargo&lt;/Description&gt;
	 *   &lt;/CargoType&gt;
	 * &lt;/CargoTypes&gt;
	 * 
	 * The "_Key" suffix on parent key distinguishes it from member properties
Parameters:			

Return Value:		

Date		Who		Reason
06 January 2026	naviv1	Initial creation MTN-36788 - JADE Core Framework - Export Engine - XML Generation

*/

vars
    member: Object;
    ownerKey: String;
    memberKey: String;
    iter: Iterator;
    memExportClass: CM_ExportImportClass;
    memClassName: String;
    memKeyProp, ownerKeyProp: CM_ExportImportProperty;
begin
	if not self.checkIfCMObject(_coll.class.name) then
		// Get parent object's business key
		ownerKey := _obj.getPropertyValue(self.myExportImportClass.myKeyName).String;
		ownerKeyProp := self.myExportImportClass.allProperties[self.myExportImportClass.myKeyName];
	endif;

    // Get member class export configuration
    memClassName := _coll.cnEcGetMemberType.name;
	memExportClass := app.myRoot.allExportImportClasses[memClassName];
	if memExportClass &lt;&gt; null then
		memKeyProp := memExportClass.allProperties[memExportClass.myKeyName];
		
		// Iterate through collection members
		iter := _coll.createIterator();
		while iter.next(member) do
			// Skip transient members
			if not member.isTransient then
				//memberKey := member.getPropertyValue(_property.myKeyName).String;
				memberKey := member.getPropertyValue(memKeyProp.propertyName).String;
				if memberKey &lt;&gt; null then
					// Export member with parent key reference
					self.appendXmlLine("&lt;" &amp; self.removeSpaces(memExportClass.displayName) &amp; "&gt;");
					if ownerKeyProp &lt;&gt; null then
						self.appendXmlTag(self.removeSpaces(ownerKeyProp.displayName) &amp; "_Key", ownerKey);
					endif;
					self.appendXmlTag(self.removeSpaces(memKeyProp.displayName), memberKey);
					self.appendXmlLine("&lt;/" &amp; self.removeSpaces(memExportClass.displayName) &amp; "&gt;");
				endif;
			endif;
		endwhile;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_property" type="CM_ExportImportProperty"/>
        <Parameter name="_coll" type="Collection"/>
    </JadeMethod>
    <JadeMethod name="exportCollections" id="8641835a-d929-44e5-a05f-6ac3bc4fc65e">
        <updating/>
        <source>exportCollections(_obj: Object) updating, protected;
/*

Purpose:			
	* Exports all collection properties for an object
	 * 
	 * @param _obj The object whose collections to export
	 * 
	 * Two modes:
	 * 1. Key-only: Exports just the member keys with parent key
	 *    Example: 
	 *    &lt;CargoTypes&gt;
	 *      &lt;CargoType&gt;
	 *        &lt;CommodityCode_Key&gt;STEEL&lt;/CommodityCode_Key&gt;
	 *        &lt;Description&gt;ISO Container&lt;/Description&gt;
	 *      &lt;/CargoType&gt;
	 *    &lt;/CargoTypes&gt;
	 * 
	 * 2. Expanded: Exports full member objects with parent key
	 *    Example:
	 *    &lt;TerminalAreaViewPositions&gt;
	 *      &lt;TerminalAreaViewPosition&gt;
	 *        &lt;SatelliteViewDefinition_Key&gt;DDDD&lt;/SatelliteViewDefinition_Key&gt;
	 *        &lt;Height&gt;148&lt;/Height&gt;
	 *        &lt;Width&gt;264&lt;/Width&gt;
	 *      &lt;/TerminalAreaViewPosition&gt;
	 *    &lt;/TerminalAreaViewPositions&gt;
Parameters:			

Return Value:		

Date		Who		Reason
06 January 2026	naviv1	Initial creation MTN-36788 - JADE Core Framework - Export Engine - XML Generation

*/

vars
    property: CM_ExportImportProperty;
    coll: Collection;
    tagName: String;
begin
    // Export collections as key references
    foreach property in self.collections do
        coll := _obj.getPropertyValue(property.propertyName).Collection;
        if coll &lt;&gt; null and coll.size &gt; 0 then
            tagName := self.removeSpaces(property.displayName);
            self.appendXmlLine("&lt;" &amp; tagName &amp; "&gt;");
            self.exportCollectionKeys(_obj, property, coll);
            self.appendXmlLine("&lt;/" &amp; tagName &amp; "&gt;");
        endif;
    endforeach;
    
    // Export collections as expanded objects
    foreach property in self.collectionsToExpand do
        coll := _obj.getPropertyValue(property.propertyName).Collection;
        if coll &lt;&gt; null and coll.size &gt; 0 then
            tagName := self.removeSpaces(property.displayName);
            self.appendXmlLine("&lt;" &amp; tagName &amp; "&gt;");
            self.exportCollectionExpanded(_obj, property, coll);
            self.appendXmlLine("&lt;/" &amp; tagName &amp; "&gt;");
        endif;
    endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="exportObjectToXML" id="9764c403-bc30-4a08-aaed-7b7a29f5b348">
        <updating/>
        <source>exportObjectToXML(_obj: Object) updating, protected;
/*

Purpose:			
	* Orchestrates the export of a single object to XML
	 * 
	 * @param _obj The JADE object to export
	 * 
	 * Exports in order:
	 * 1. Simple attributes (strings, numbers, booleans, dates)
	 * 2. References (inline keys or expanded nested objects)
	 * 3. Collections (member keys or expanded member objects)
	 * 
	 * Output structure:
	 * &lt;Commodity&gt;
	 *   &lt;CommodityCode&gt;STEEL&lt;/CommodityCode&gt;       &lt;!-- attributes --&gt;
	 *   &lt;Description&gt;Steel Products&lt;/Description&gt;
	 *   &lt;CommodityGroup&gt;HAZ1&lt;/CommodityGroup&gt;      &lt;!-- reference key --&gt;
	 *   &lt;CargoTypes&gt;                                &lt;!-- collection --&gt;
	 *     &lt;CargoType&gt;...&lt;/CargoType&gt;
	 *   &lt;/CargoTypes&gt;
	 * &lt;/Commodity&gt;
Parameters:			

Return Value:		

Date		Who		Reason
06 January 2026	naviv1	Initial creation MTN-36788 - JADE Core Framework - Export Engine - XML Generation

*/

begin
    // Export simple properties
    self.exportAttributes(_obj);
    
    // Export object references (inline keys or nested objects)
    self.exportReferences(_obj);
    
    // Export collections (member keys or expanded members)
    self.exportCollections(_obj);
end;
</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="exportReferenceExpanded" id="4ae6bbdd-2c41-4977-a3b5-3c0f085620b3">
        <updating/>
        <source>exportReferenceExpanded(_obj: Object; _exportProp: CM_ExportImportProperty) updating, protected;
/*

Purpose:			
	* Exports a reference property as a fully expanded nested object
	 * 
	 * @param _obj The parent object
	 * @param _exportProp The reference property configuration
	 * 
	 * Example output:
	 * &lt;CommodityGroup&gt;
	 *   &lt;CommodityGroupCode&gt;HAZ1&lt;/CommodityGroupCode&gt;
	 *   &lt;Description&gt;Hazardous Materials Class 1&lt;/Description&gt;
	 * &lt;/CommodityGroup&gt;
	 * 
	 * Creates a temporary export agent to handle the referenced object's export
Parameters:			

Return Value:		

Date		Who		Reason
06 January 2026	naviv1	Initial creation MTN-36788 - JADE Core Framework - Export Engine - XML Generation

*/

vars
    refObj: Object;
    refExportClass: CM_ExportImportClass;
    refAgent: CM_DataExportAgent;
begin
    // Validate property exists
    if _exportProp.myProperty = null then
        return;
    endif;
    
    // Get referenced object
    refObj := _obj.getPropertyValue(_exportProp.myProperty.name).Object;
    if refObj = null then
        return; // Null reference - skip
    endif;
    
    // Get export configuration for referenced class
    refExportClass := app.myRoot.allExportImportClasses[refObj.class.name];
    if refExportClass = null then
        return; // Referenced class not configured for export
    endif;
    
    // Create temporary agent to export referenced object
    create refAgent transient;
    refAgent.setExportImportClass(refExportClass);
    refAgent.categorizeClassProperties();
    refAgent.xmlStr := "";
    
    // Export referenced object (attributes + references, no collections)
    refAgent.exportObjectToXML(refObj);
    
    // Append nested XML to main output
    self.appendXmlLine(refAgent.xmlStr);
    
epilog
    delete refAgent;
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_exportProp" type="CM_ExportImportProperty"/>
    </JadeMethod>
    <JadeMethod name="exportReferenceKey" id="7c95ac1b-1414-4879-a374-7d935350d19c">
        <updating/>
        <source>exportReferenceKey(_obj: Object; _property: CM_ExportImportProperty) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2026	naviv1	Initial creation MTN-36788 - JADE Core Framework - Export Engine - XML Generation

*/

vars
    refObj: Object;
    keyValue: String;
    tagName: String;
begin
    // Validate property exists
    if _property.myProperty = null then
        return;
    endif;
    
    // Get referenced object
    refObj := _obj.getPropertyValue(_property.myProperty.name).Object;
    if refObj = null then
        return; // Null reference - skip
    endif;
    
    // Get referenced object's business key
    keyValue := self.getObjectKey(refObj, _property);
    if keyValue = null or keyValue = "" then
        app.writeLog("WARNING: Cannot get key value for " &amp; _property.displayName,LogWARN);
        return;
    endif;
    
    // Build XML tag using property's display name
    tagName := self.removeSpaces(_property.displayName);
    self.appendXmlLine("&lt;" &amp; tagName &amp; "&gt;" &amp; self.escapeXml(keyValue) &amp; "&lt;/" &amp; tagName &amp; "&gt;");
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_property" type="CM_ExportImportProperty"/>
    </JadeMethod>
    <JadeMethod name="exportReferences" id="2e09c9c7-dfb0-45e6-a917-5cec09232077">
        <updating/>
        <source>exportReferences(_obj: Object) updating, protected;
/*

Purpose:			
	* Exports all reference properties for an object
	 * 
	 * @param _obj The object whose references to export
	 * 
	 * Two modes:
	 * 1. Key-only: Exports just the referenced object's key
	 *    Example: &lt;CommodityGroup&gt;HAZ1&lt;/CommodityGroup&gt;
	 * 
	 * 2. Expanded: Exports the full referenced object inline
	 *    Example: &lt;CommodityGroup&gt;&lt;Code&gt;HAZ1&lt;/Code&gt;&lt;Description&gt;...&lt;/Description&gt;&lt;/CommodityGroup&gt;
Parameters:			

Return Value:		

Date		Who		Reason
06 January 2026	naviv1	Initial creation MTN-36788 - JADE Core Framework - Export Engine - XML Generation

*/

vars
    exportProp: CM_ExportImportProperty;
begin
    // Export references as keys only (inline)
    foreach exportProp in self.references do	
        self.exportReferenceKey(_obj, exportProp);
    endforeach;
    
    // Export references as expanded nested objects
    foreach exportProp in self.referencesToExpand do	
        self.exportReferenceExpanded(_obj, exportProp);
    endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="exportToXml" id="1e552d41-4916-4fe5-8e73-9b5785d8e126">
        <updating/>
        <source>exportToXml( _dataEntity : String; _maxObjects: Integer; _key : String) : String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2026	naviv1	Initial creation MTN-36788 - JADE Core Framework - Export Engine - XML Generation

*/

vars
	exportClass : CM_ExportImportClass;
	category : String;
	term : CM_Terminal;
	user : CM_User;
	permission : Integer;
begin

	exportClass := app.myRoot.allExportImportClasses.getByDisplayName(_dataEntity);
	
	if exportClass = null then
		write "Export class not found";
		return "";
	endif;
	
	category := exportClass.category;
	term := app.myPassport.myTerminal;
	if category.isOneOf(ExportImportTerminalAdmin, ExportImportTerminalScreen) then
		
		permission := PmAdmTerminalExportMaint;
	else
		permission := PmAdmSystemExportMaint;
	endif;
	user := app.myPassport.myUser;	
	
	
	if user = null or not user.canDo(term, permission) then
		app.raiseCMException1( NotLicensedToPerformAction, app.getLicenseName(Mod_WebPortal), null, null );
		return app.myPassport.getErrorsAsString();
	endif;
	
   self.setExportImportClass(exportClass);
   self.exportClassInstances(_maxObjects,_key);
   write _key;
   return self.xmlStr;
epilog

end;</source>
        <Parameter name="_dataEntity" type="String"/>
        <Parameter name="_maxObjects" type="Integer"/>
        <Parameter name="_key" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getObjectKey" id="7355f1a0-a7c2-445c-9504-91f21faed8f7">
        <source>getObjectKey(_obj: Object; _property: CM_ExportImportProperty): String protected;
/*

Purpose:			
	* Gets object key using property's key name or class's default
Parameters:			

Return Value:		

Date		Who		Reason
06 January 2026	naviv1	Initial creation MTN-36788 - JADE Core Framework - Export Engine - XML Generation

*/

vars
    keyVal: String;
    keyName: String;
begin
    if _obj = null then
        return "";
    endif;
    
    // Determine key property name
    if _property &lt;&gt; null and _property.myKeyName &lt;&gt; null and _property.myKeyName &lt;&gt; "" then
        // Use property's specific key name
        keyName := _property.myKeyName;
    else
        // Use class's default key name
        keyName := self.myExportImportClass.myKeyName;
    endif;
    
    // Get key value
    if keyName &lt;&gt; null and keyName &lt;&gt; "" then
        keyVal := _obj.getPropertyValue(keyName).String;
        if keyVal &lt;&gt; null and keyVal &lt;&gt; "" then
            return keyVal;
        endif;
    endif;
    
    // Fallback to standard key method
    if _obj.isKindOf(CM_Object) then
        return _obj.CM_Object.theKeyForJMT();
    else
        return _obj.String;
    endif;
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_property" type="CM_ExportImportProperty"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
