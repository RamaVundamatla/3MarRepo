<Class name="UT_ZJMTLogicalCertifyConstXLAT" id="07196c52-1d23-4979-82f0-a650541fb974">
    <superclass name="UT_ZJMTLogicalCertify"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Unit Tests that check Constants / Ent Tables / Translations</text>
    <DbClassMap file="unitTest"/>
    <JadeMethod name="tCheckETRowGlobalConstants" id="6d39de0d-244f-47df-a8d1-887510d6f3df">
        <source>tCheckETRowGlobalConstants();
// cnwrs1
/*
Purpose:  	Check all ETRow global constants to ensure that the constant value is the same as the rowName in the XML text.
			This can cause problems, e.g. getDisplayStringForAttribute where the parameter value is the row name but 
			code like 
				if _attrName = ETRow_Something
			compares the row name with the constant value and if the two are out of sync we get unexpected results
			
			I think we can just change the constant value to fix this ???
			
Date		Who		Reason
02 Aug 2013	cnwcs5		CCMS POL 2221 / par 32094
*/
vars
	category 	:ConstantCategory;
	coll		:ConstantNDict;
	constant	:Constant;
	str, text	:String;
	count :Integer;
begin
	category := currentSchema.getConstantCategory ("EntTableRows");
	
	if category = null then
		return;
	endif;
	
	coll := category.cnEcGetConstants;	// persistent collection
		
	foreach constant in coll do
		count := count + 1;
		
		str := constant.getSource;
		str := str.removeString ("'");
		str := str.removeString ('"').trimBlanks;
		
		text := constant.text.trimBlanks;
		
		self.assertTrueMsg (text.pos ('&lt;RowName&gt;' &amp; str &amp; '&lt;/RowName&gt;', 1) &gt; 0, constant.name &amp; ' does not match ETRow name');
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckEntTableConstants" id="1e1b55a1-d00c-4198-858c-c59448844ddd">
        <source>tCheckEntTableConstants();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 May 2012	cnwndl1	Initial creation	Par 29574
21 May 2021	navmd1	TFS 50455 - look for any ETRow_ constants that are missing a &lt;GroupRow&gt; for a ETDef_ that includes them

*/

vars

	dataRoot : CM_EntTableDataRoot;
	entTableAgent : EntTableAgent;
	xmlDoc : JadeXMLDocument;
	etRowXMLDoc : JadeXMLDocument;
	baseScm : Schema;
	categoryRow : ConstantCategory;
	constRow : Constant;
	constDictRow : ConstantNDict;
	constByValueDict : CM_ObjectByStringDict;
	categoryDef : ConstantCategory;
	constDef : Constant;
	constDictDef : ConstantNDict;
	rawXmlStr : String;
	xmlGroupArray : JadeXMLElementArray;
	xmlRowArray : JadeXMLElementArray;
	xmlRootElement : JadeXMLElement;
	xmlGroup : JadeXMLElement;
	xmlRowName : JadeXMLElement;
	rowName : String;
	grpName : String;
	defName : String;
	categoryGrp : ConstantCategory;
	constGrp : Constant;
	constDictGrp : ConstantNDict;
	entGroup : EntTableGroup;
	entDef : EntTableDef;
	rowHeader : EntTableRowHeader;
	entRow : EntTableRow;
	defGrpName : String;
	foundMatchingGrpRow : Boolean;
	
	errorString1 : String;
	errorString2 : String;
	errorString3 : String;
	errorString4 : String;
	errorString5 : String;
	errorString6 : String;
	errorString7 : String;
	errorString8 : String;
	errorString9 : String;
	errorString10 : String;
	errorString11 : String;
	errorString12 : String;
	errorString13 : String;
	errorString14 : String;
	errorString15 : String;
	errorString16 : String;
	errorString17 : String;
	errorStrings : String;
	
	count : Integer;

begin

	dataRoot := CM_EntTableDataRoot.firstInstance;
	create entTableAgent transient;
	create xmlDoc transient;
	baseScm := rootSchema.getSchema(dataRoot.schemaName);
	categoryRow := baseScm.getCategory(dataRoot.rowCategory);
	constDictRow := categoryRow.getConstants();
	
	create constByValueDict transient;
	
	foreach constRow in constDictRow do
		if constRow.text = null then
			errorString1 := errorString1 &amp; 'Constant text is null for ' &amp; constRow.name &amp; '  - consider deleting the constant' &amp; CrLf;
			continue;
		endif;
		rawXmlStr := null;
		rawXmlStr := entTableAgent.getConstantTextXML(constRow.text, entTableAgent.XMLTag_EntTableRow);
		if rawXmlStr = null then
			errorString2 := errorString2 &amp; 'Text of ' &amp; constRow.name &amp; ' has no XML  - consider deleting the constant' &amp; CrLf;
			continue;
		endif;
		
		xmlDoc.parseString(rawXmlStr);
		xmlRootElement := xmlDoc.rootElement;
		rowName := xmlRootElement.getTagValueOfName(entTableAgent.XMLTag_RowName);
		
		if rowName = null then
			errorString3 := errorString3 &amp; 'Row name is null for ' &amp; constRow.name &amp; '  - consider deleting the constant' &amp; CrLf;
			continue;
		endif;
		
		constByValueDict.putAtKey( rowName, constRow );
		
		delete xmlGroupArray;
		create xmlGroupArray transient;
		xmlRootElement.getElementsByTagName(entTableAgent.XMLTag_GroupRow, xmlGroupArray);
		
		foreach xmlGroup in xmlGroupArray do
			grpName := xmlGroup.getTagValueOfName(entTableAgent.XMLTag_GroupName);
			if grpName = null then
				errorString4 := errorString4 &amp; 'No ' &amp; entTableAgent.XMLTag_GroupName &amp; ' in XML for ' &amp; constRow.name &amp; '  - consider deleting the constant' &amp; CrLf;
				continue;
			endif;
			entGroup := null;
			entGroup := dataRoot.allEntTableGroups[grpName];
			if entGroup = null then
				errorString5 := errorString5 &amp; 'Entable Group ' &amp; grpName &amp; ' not found for ' &amp; constRow.name &amp; '  - consider removing the XML for this GroupRow' &amp; CrLf;
				continue;
			endif;
		endforeach;
		
	endforeach;	
	
	categoryDef := baseScm.getCategory(dataRoot.defCategory);
	constDictDef := categoryDef.getConstants();
	
	foreach constDef in constDictDef do
		// Check Text exists
		if constDef.text = null then
			errorString6 := errorString6 &amp; 'Constant text is null for ' &amp; constDef.name &amp; '  - consider deleting the constant' &amp; CrLf;
			continue;
		endif;
		
		// Make sure its XML
		rawXmlStr := null;
		rawXmlStr := entTableAgent.getConstantTextXML(constDef.text, entTableAgent.XMLTag_EntTableDef);
		if rawXmlStr = null then
			errorString7 := errorString7 &amp; 'No XML found in text for ' &amp; constDef.name &amp; '  - consider deleting the constant' &amp; CrLf;
			continue;
		endif;
		
		// Make sure it has a Def Name
		xmlDoc.parseString(rawXmlStr);
		xmlRootElement := xmlDoc.rootElement;
		defName := xmlRootElement.getTagValueOfName(entTableAgent.XMLTag_DefName);
		if defName = null then
			errorString8 := errorString8 &amp; 'Def name is null in XML for  ' &amp; constDef.name &amp; CrLf;
			continue;
		endif;
		
		// Make sure EntTableGroup instance exists
		grpName := xmlRootElement.getTagValueOfName(entTableAgent.XMLTag_GroupName);
		entGroup := null;
		entGroup := dataRoot.allEntTableGroups.getAtKey(grpName);
		if entGroup = null then
			errorString9 := errorString9 &amp; 'Def  ' &amp; constDef.name &amp; "  Associated EntTable Group object not found - consider deleting the constant." &amp; CrLf;
			continue;
		endif;
		
		// Make sure EntTableDef instance exists
		entDef := entGroup.allEntTableDefsByName.getAtKey(defName);
		if entDef = null then
			errorString10 := errorString10 &amp; 'Def  ' &amp; constDef.name &amp; '  No EntTable Definition object found - consider deleting the constant.' &amp; CrLf;
			continue;
		endif;
		
		// Check Rows...
		delete xmlRowArray;
		create xmlRowArray transient;
		xmlRootElement.findAllElementsByTagName(entTableAgent.XMLTag_RowName, xmlRowArray);
		
		if xmlRowArray.isEmpty then
			errorString11 := errorString11 &amp; 'Def  ' &amp; constDef.name &amp; '  XML has no rows i.e. Def is empty- consider deleting the constant.' &amp; CrLf;
			continue;
		else		
			foreach xmlRowName in xmlRowArray do
				rowName := xmlRowName.textData;
				constRow := null;
				constRow := constByValueDict.getAtKey(rowName).Constant;
				
				if constRow = null then
					errorString12 := errorString12 &amp; 'Def  ' &amp; constDef.name &amp; '  includes XML for  ' &amp; rowName &amp; '  which has no matching row - consider deleting the XML row in the text of the constant' &amp; CrLf;
					continue;
				endif;

				// For each row on the def - make sure there is an XML &lt;GroupRow&gt; entry for the def on the respective ETRow_&lt;name&gt; constant
				// We can do this by checking each &lt;GroupRow&gt; section and seeing if its &lt;GroupName&gt; attribute matches our entDef.myEntTableGroup.name
				foundMatchingGrpRow := false;
				defGrpName := entDef.myEntTableGroup.name;		// invalid groups should have been skipped already
				
				rawXmlStr := null;
				rawXmlStr := entTableAgent.getConstantTextXML(constRow.text, entTableAgent.XMLTag_EntTableRow);
				if rawXmlStr = null then continue; endif;	// already raised an error, skip
				
				delete xmlGroupArray;
				create xmlGroupArray transient;
				
				delete etRowXMLDoc;
				create etRowXMLDoc transient;
				
				etRowXMLDoc.parseString(rawXmlStr);
				etRowXMLDoc.rootElement.getElementsByTagName(entTableAgent.XMLTag_GroupRow, xmlGroupArray);
		
				foreach xmlGroup in xmlGroupArray do
					grpName := xmlGroup.getTagValueOfName(entTableAgent.XMLTag_GroupName);
					if defGrpName = grpName then
						foundMatchingGrpRow := true;
					endif;
				endforeach;
				
				if not foundMatchingGrpRow then
					errorString17 := errorString17 &amp; 'Def ' &amp; constDef.name &amp; ' includes XML for ' &amp; rowName &amp; ' but ETRow_' &amp; rowName &amp; ' is missing the corrosponding &lt;GroupRow&gt; element - has the ETRow constant been updated correctly?' &amp; CrLf;
				endif;
				
			endforeach;
		endif;
		
	endforeach;
	
	categoryGrp := baseScm.getCategory(dataRoot.groupCategory);
	constDictGrp := categoryGrp.getConstants();
	
	foreach constGrp in constDictGrp do
		if constGrp.text = null then
			errorString13 := errorString13 &amp; 'Constant text is null for ' &amp; constGrp.name &amp; '  - consider deleting the constant.' &amp; CrLf;
			continue;
		endif;
		rawXmlStr := null;
		rawXmlStr := entTableAgent.getConstantTextXML(constGrp.text, entTableAgent.XMLTag_EntTableGroup);
		if rawXmlStr = null then
			errorString14 := errorString14 &amp; 'No XML found in text for ' &amp; constGrp.name &amp; '  - consider deleting the constant.' &amp; CrLf;
			continue;
		endif;
		xmlDoc.parseString(rawXmlStr);
		xmlRootElement := xmlDoc.rootElement;
		grpName := xmlRootElement.getTagValueOfName(entTableAgent.XMLTag_GroupName);
		
		if grpName = null then
			errorString15 := errorString15 &amp; 'Group name is null for  ' &amp; constGrp.name &amp; '  - consider deleting the constant.' &amp; CrLf;
			continue;
		endif;
		
		entGroup := dataRoot.allEntTableGroups.getAtKey(grpName);
		if entGroup = null then
			errorString16 := errorString16 &amp; 'No EntTable Group object found for  ' &amp; constGrp.name &amp; '  - consider deleting the constant' &amp; CrLf;
			continue;
		endif;
		
	endforeach;
	
	if errorString1 &lt;&gt; null or errorString2 &lt;&gt; null or errorString3 &lt;&gt; null or errorString4 &lt;&gt; null or errorString5 &lt;&gt; null then
		errorStrings := errorStrings &amp; CrLf &amp; entTableAgent.RowPrefix &amp; " Issues:" &amp; CrLf;
		if errorString1 &lt;&gt; null then
			errorStrings := errorStrings &amp; errorString1;
		endif;
		if errorString2 &lt;&gt; null then
			errorStrings := errorStrings &amp; errorString2;
		endif;
		if errorString3 &lt;&gt; null then
			errorStrings := errorStrings &amp; errorString3;
		endif;
		if errorString4 &lt;&gt; null then
			errorStrings := errorStrings &amp; errorString4;
		endif;
		if errorString5 &lt;&gt; null then
			errorStrings := errorStrings &amp; errorString5;
		endif;
	endif;
	
	if errorString6 &lt;&gt; null or errorString7 &lt;&gt; null or errorString8 &lt;&gt; null or errorString9 &lt;&gt; null or errorString10 &lt;&gt; null or errorString11 &lt;&gt; null or errorString12 &lt;&gt; null or errorString17 &lt;&gt; null then
		errorStrings := errorStrings &amp; CrLf &amp; entTableAgent.DefPrefix &amp; " Issues:" &amp; CrLf;
		if errorString6 &lt;&gt; null then
			errorStrings := errorStrings &amp; errorString6;
		endif;
		if errorString7 &lt;&gt; null then
			errorStrings := errorStrings &amp; errorString7;
		endif;
		if errorString8 &lt;&gt; null then
			errorStrings := errorStrings &amp; errorString8;
		endif;
		if errorString9 &lt;&gt; null then
			errorStrings := errorStrings &amp; errorString9;
		endif;
		if errorString10 &lt;&gt; null then
			errorStrings := errorStrings &amp; errorString10;
		endif;
		if errorString11 &lt;&gt; null then
			errorStrings := errorStrings &amp; errorString11;
		endif;
		if errorString12 &lt;&gt; null then
			errorStrings := errorStrings &amp; errorString12;
		endif;
		if errorString17 &lt;&gt; null then
			errorStrings := errorStrings &amp; errorString17;
		endif;
	endif;
	
	if errorString13 &lt;&gt; null or errorString14 &lt;&gt; null or errorString15 &lt;&gt; null or errorString16 &lt;&gt; null then
		errorStrings := errorStrings &amp; CrLf &amp; entTableAgent.GroupPrefix &amp; " Issues:" &amp; CrLf;
		
		if errorString13 &lt;&gt; null then
			errorStrings := errorStrings &amp; errorString13;
		endif;
		if errorString14 &lt;&gt; null then
			errorStrings := errorStrings &amp; errorString14;
		endif;
		if errorString15 &lt;&gt; null then
			errorStrings := errorStrings &amp; errorString15;
		endif;
		if errorString16 &lt;&gt; null then
			errorStrings := errorStrings &amp; errorString16;
		endif;
	endif;
	
	self.assertTrueMsg( errorStrings.trimBlanks = null, errorStrings );

epilog

	delete entTableAgent;
	delete xmlDoc;
	delete xmlGroupArray;
	delete xmlRowArray;
	delete constByValueDict;
	delete etRowXMLDoc;

end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckEntViewsAndDefs" id="58ebdc29-c872-4cf2-9cb3-4aeeb2d1f2d1">
        <source>tCheckEntViewsAndDefs();
//
// Purpose:			Check that each row in a view is also in the view's def
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/06/2014	cnwdap1		Initial creation PAR #34314
//
vars
	entRoot 	: EntTableDataRoot;
	def 		: EntTableDef;
	view 		: EntTableView;
	row 		: EntTableRow;
	
begin
	entRoot := app.myRoot.myEntTableDataRoot;
	foreach def in entRoot.allEntTableDefs discreteLock do
		foreach view in def.allEntTableViews do
			foreach row in view.allEntTableRows do
				assertTrueMsg(def.allEntTableRows.includes(row), "Row " &amp; row.name &amp; " is in View " &amp; view.name &amp; ", but not in parent def " &amp; def.name &amp; ", Group " &amp; def.myEntTableGroup.name);
			endforeach;
		endforeach;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckForDupTranslationConstID" id="1c9b98b8-e225-4d08-83f9-e663a547de13">
        <source>tCheckForDupTranslationConstID();

/*

Purpose:		Check the XLAT translatable string for no text.

Date			Who		Reason
16 July 2012	cnwmh5	Initial creation

*/

vars
	constantCategory		: ConstantCategory;
	constant				: Constant;
	meth					: Method;
	category				: XLAT_Category;
	tmpConstantDict			: ConstantNDict;
	portScm					: Schema;
	
	alreadyReadArray		: IntegerArray;
	constantDupArray		: IntegerArray;
	
	allMethodRefs			: MethodSet;
	
	hasReferences			: Boolean;
	constantId				: Integer;
	textNull				: Boolean;
	bad						: Integer;
	indexOf					: Integer;
	
begin
	
	portScm := rootSchema.getSchema("PortSchema");
	
	create alreadyReadArray transient;
	create allMethodRefs transient;
	create constantDupArray transient;
	
	foreach category in app.myRoot.allXLAT_Categories do
	
		if category.constantCategoryName = XLAT_Menus or
		   category.constantCategoryName = XLAT_ReportNames or
		   category.constantCategoryName = EntTableRows then
			continue;
		endif;

		constantCategory := portScm.getCategory(category.constantCategoryName);
	
		tmpConstantDict := constantCategory.getConstants();
		
		alreadyReadArray.clear();
		constantDupArray.clear();
	
		// work out the duplicate ids and add to duplicate array
		foreach constant in tmpConstantDict do
			constantId := constant.valueAsInteger;
			indexOf := alreadyReadArray.indexOf(constantId);
			//textNull := constant.text = null;
			if indexOf &gt; 0 then
				if not constantDupArray.includes(constantId) then
					constantDupArray.add(constantId);
					bad := bad + 1;
				endif;
			else
				alreadyReadArray.add(constantId);
			endif;
		
		endforeach;
			
		// now have the duplicates get the details for the duplicate
		foreach constant in tmpConstantDict do
			constantId := constant.valueAsInteger;
			
			if not constantDupArray.includes(constantId) then
				continue;
			endif;
			
			constantCategory := constant.GlobalConstant.getCategory();
			
			// if has methods then write details
			allMethodRefs.clear();
			constant.getMethodRefs(allMethodRefs);
			hasReferences := false;
			foreach meth in allMethodRefs do
				hasReferences := true;
				app.writeStatement(constantCategory.name &amp; Tab &amp; constant.name &amp; Tab &amp; constantId.String &amp; Tab &amp; meth.getSchemaType().name &amp; Tab &amp; meth.name);
			endforeach;
			
			// if doesn't have any methods then write details
			if not hasReferences then
				app.writeStatement(constantCategory.name &amp; Tab &amp; constant.name &amp; Tab &amp; constantId.String &amp; Tab &amp; Tab);
			endif;
						
		endforeach;

	endforeach;
	
	self.assertEqual(bad, 0);
	
epilog

	delete alreadyReadArray;
	delete allMethodRefs;
	delete constantDupArray;
	
end;
</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;fails16092014&lt;/Category&gt;
    &lt;Category CanDelete="true"&gt;fails16092014_2&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tCheckGlobalConstantCategories" id="e52c71ca-33d9-41de-b9f1-e20374106480">
        <source>tCheckGlobalConstantCategories();
// jlgmd1
// cnwkpd1
/*

Purpose:			Check the Global Constants for any that appear to be in a state where their owning category os not in the
					schema they belog to.
					Written in response to JADE PAR #54826 where locking issues caused a number of corrupt Global Constants 
					in the development environment, which can cause problems in deployment.
					
Parameters:			

Return Value:		


Date		Who		Reason
31 Aug 2010	cnwkpd1	JADE PAR #54826 - Corrupted Global Constants

*/

vars
	badOnes			: ObjectSet;
	gc 				: GlobalConstant;
	
begin
	create badOnes transient;
	
	foreach gc in GlobalConstant.instances do
		if gc.getPropertyValue("category").ConstantCategory.getPropertyValue("schema").Schema.getPropertyValue("name") &lt;&gt; gc.getPropertyValue("schema").Schema.getPropertyValue("name") then
			badOnes.add(gc);
			app.writeLog(method.qualifiedName &amp; " " &amp; gc.getPropertyValue("name").String &amp; " - " &amp; gc.getOidAsString, LogINFO);
		endif;
	endforeach;
	
	self.assertEqualMsg(badOnes.size, 0, "Global Constant check failed, JADE Logical Certify fix required");
	

epilog
	delete badOnes;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckTransTypeConstantsValid" id="796b189c-7929-419d-b29b-ec310cc10ba5">
        <source>tCheckTransTypeConstantsValid();
/*

Purpose:			Check for internal corruption in TransactionType Global Constants

Date		Who		Reason
27/07/2022	navmd1	Discovered meta data corruption in TransactionType global constants

*/

vars
	constantCategory		: ConstantCategory;
	constant,
	xlatConstant,
	lastConstant			: Constant;
	tmpConstantDict			: ConstantNDict;
	portScm					: Schema;
	checked,
	bad,
	value,
	maxVal,
	globalVal				: Integer;
	text					: String;
	cls						: Class;
	
begin
	portScm := rootSchema.getSchema("PortSchema");
	constantCategory := portScm.getCategory(TransactionTypeConstant);
	tmpConstantDict := constantCategory.getConstants();
	
	foreach constant in tmpConstantDict do
		checked := checked + 1;
		
		if	constant.name = 'TRANS_TYPE_NULL' or
			constant.name = 'TRANS_TYPE_MAX' or
			constant.name = 'TRANS_TYPE_JMTMax'
		then
			continue;	// skip
		endif;
		
		// Skip HMS trans type constants
		if constant.name = 'TRANS_TYPE_ArchiveMovement' 
		or constant.name = 'TRANS_TYPE_AddVoyageDelay' 
		or constant.name = 'TRANS_TYPE_AddMovement' 
		or constant.name = 'TRANS_TYPE_ConfirmActualMove' 
		or constant.name = 'TRANS_TYPE_ConfirmPlanMove'
		or constant.name = 'TRANS_TYPE_DeleteVoyageDelay'
		or constant.name = 'TRANS_TYPE_EditMovement'
		or constant.name = 'TRANS_TYPE_EditMovementTime'
		or constant.name = 'TRANS_TYPE_EditVoyageDelay'
		or constant.name = 'TRANS_TYPE_HMSVoyageAdd'
		or constant.name = 'TRANS_TYPE_HMSVoyageArchive'
		or constant.name = 'TRANS_TYPE_HMSVoyageDeleted'
		or constant.name = 'TRANS_TYPE_HMSVoyageEdit'
		or constant.name = 'TRANS_TYPE_ResourceBooked'
		or constant.name = 'TRANS_TYPE_ResourceCancelled' 
		or constant.name = 'Trans_Type_ResourceCharged' then
			continue;
		endif;
		
		value := constant.valueAsInteger;
		text := constant.getSource().trimBlanks();
		
		// Check the XML structure
		if text.pos(' ', 1) &gt; 0
			// and ... ?
		then
			bad += 1;
			self.logMessage("XML with spaces found");
			self.logMessage(constant.name &amp; Tab &amp; constant.valueAsInteger.String &amp; Tab &amp; constant.getSource());
		endif;
		
		// Check for the equivalent XLAT
		xlatConstant := portScm.getConstant("TransType_" &amp; value.String);
		if xlatConstant = null then
			bad += 1;
			self.logMessage("No XLAT/Translation constant found [TransType_" &amp; value.String &amp; " not found]");
			self.logMessage(constant.name &amp; Tab &amp; constant.valueAsInteger.String &amp; Tab &amp; constant.getSource());
		endif;
		
		// Check to see if MAX hasn't been updated
		if value &gt; TRANS_TYPE_MAX then
			bad += 1;
			self.logMessage("Transaction Type after MAX value!");
			self.logMessage(constant.name &amp; Tab &amp; constant.valueAsInteger.String &amp; Tab &amp; constant.getSource());
		endif;
		
		// Check for a corresponding CM_TransactionType object
		if app.getMyRoot.allTransactionTypes[value] = null then
			bad += 1;
			self.logMessage("No CM_TransactionType object found! Has the Release or Backpatch app been run?");
			self.logMessage(constant.name &amp; Tab &amp; constant.valueAsInteger.String &amp; Tab &amp; constant.getSource());
		endif;
		
		// Check the mapping Constant -&gt; Class
		cls := global.getTiTxnClassForType(value, false);
		if cls = null then
			cls := global.getTiTxnClassForType(value, true);
		endif;
		
		if cls = null then
			bad += 1;
			// TODO: Work out what to do with TRANS_TYPES 66 through 94
			// and skip them if we don't care.
			self.logMessage("No CM_Transaction class found. Has GPortSchema::getTiTxnClassForType been updated?");
			self.logMessage(constant.name &amp; Tab &amp; constant.valueAsInteger.String &amp; Tab &amp; constant.getSource());
		endif;
		
		// Check the mapping Constant &lt;- Class
		if cls &lt;&gt; null then
			globalVal := global.getTiTxnTypeForClass(cls);
			if globalVal = null then
				bad += 1;
				self.logMessage("No TRANS_TYPE constant found. Has GPortSchema::getTiTxnTypeForClass been updated?");
				self.logMessage(constant.name &amp; Tab &amp; constant.valueAsInteger.String &amp; Tab &amp; constant.getSource());
			endif;
		endif;
		
		if value = TRANS_TYPE_MAX then
			lastConstant := constant;
		endif;
	endforeach;
	
	// Make sure the highest TRANS_TYPE constant has the same number as MAX
	if lastConstant = null then
		bad += 1;
		self.logMessage("The latest Transaction Type is not the same value as TRANS_TYPE_MAX");
	endif;
	
	self.assertEqual(bad, 0);
	
	return;
	
	write TRANS_TYPE_NULL;
	write TRANS_TYPE_MAX;
	write TRANS_TYPE_JMTMax;
	
epilog
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="tCheckTranslationConstants" id="60a15a9a-79b6-40c5-807d-40083d57a082">
        <source>tCheckTranslationConstants();
// jlgmd1
/*	cnwkpd1

Purpose:			Check for internal corruption in Global Constants

Date		Who		Reason
27 Mar 2012	cnwkpd1	Discovered meta data corruption in Translation global constants

*/

vars
	constantCategory		: ConstantCategory;
	constant				: Constant;
	locale					: CM_Locale;
	existingTranslations	: XLAT_TranslatableTextByCatNmbr;
	translatableText		: XLAT_TranslatableText;
	category				: XLAT_Category;
	tmpCategoryDict,
	tmpConstantDict			: ConstantNDict;
	portScm					: Schema;
	checked,
	bad						: Integer;
	
begin
	portScm := rootSchema.getSchema("PortSchema");
	
	foreach category in app.myRoot.allXLAT_Categories do
	
		if category.constantCategoryName = XLAT_Menus or
		   category.constantCategoryName = XLAT_ReportNames or
		   category.constantCategoryName = EntTableRows then
			continue;
		endif;

		constantCategory := portScm.getCategory(category.constantCategoryName);
	
		tmpConstantDict := constantCategory.getConstants();
	
		foreach constant in tmpConstantDict do
			checked := checked + 1;
		
			if constant.valueAsInteger.String &lt;&gt; constant.getSource().trimBlanks() then
				bad := bad + 1;
				self.logMessage(constant.name &amp; Tab &amp; constant.valueAsInteger.String &amp; Tab &amp; constant.getSource());
			endif;
	
		endforeach;
	
	endforeach;
	
	self.assertEqual(bad, 0);
	
epilog
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="tCheckXLATFormCaptionsValid" id="4478def8-8190-41bc-b810-7d8de7d44749">
        <source>tCheckXLATFormCaptionsValid();

/*

Purpose:		Check that XLAT_FormCaptions are valid
				That the following aren't blanks
				- controlName
				- controlProperty
				- formClass
				- schemaName
				Get the details of the methods used in
				This method runs a validation version of the DevSchema::JadeScript::verifyXLATFormCaptions,

Date			Who		Reason
26/11/2014		cnwmh5	Initial creation

*/

vars

	category					: XLAT_Category;
	translatableText 			: XLAT_TranslatableText;
	xmlDoc						: JadeXMLDocument;
	xmlAttribute				: JadeXMLAttribute;
	globalConstant				: GlobalConstant;
	meth						: Method;
	constant					: Constant;
	schema						: Schema;
	klass						: Class;
	
	errorTextArray				: StringArray512;
	tagsToCheckFor				: StringArray;
	methodsSet					: MethodSet;
	constantsToIgnore			: StringArray;
	
	errorText					: String;
	str							: String;
	index						: Integer;
	lastModified				: TimeStamp;
	author						: String;
	methodsUsedIn				: String;
	version						: String;
	versionChangedTS841			: TimeStamp;
	version841OrGreater			: Boolean;

begin

	category := app.myRoot.allXLAT_Categories[XLAT_FormCaptions];
	self.assertNotNull(category);

	create errorTextArray transient;
	create methodsSet transient;
	
	create tagsToCheckFor transient;
	tagsToCheckFor.add("ControlName");
	tagsToCheckFor.add("ControlProperty");
	tagsToCheckFor.add("FormClass");
	tagsToCheckFor.add("SchemaName");
	
	create constantsToIgnore transient;
	constantsToIgnore.add("ERR_MachineNotOnInterface");
	constantsToIgnore.add("USED");
	constantsToIgnore.add("Controlled_atmosphere");
	constantsToIgnore.add("Director_fields");
	constantsToIgnore.add("WagonPos");
	constantsToIgnore.add("LEFT");
	
	// Check to see if running 841 or greater
	versionChangedTS841.setDate("30/09/2014".Date);
	versionChangedTS841.setTime("16:40:11".Time);
	schema := rootSchema.getSchema("PortSchema");
	self.assertNotNull(schema);
	klass := schema.getClass("CM_Version");
	self.assertNotNull(klass);
	constant := klass.getConstant("VERSION");
	self.assertNotNull(constant);
	version841OrGreater := constant.cnGetModifiedTimeStamp &gt;= versionChangedTS841;
		
	foreach translatableText in category.allTranslatableText discreteLock do
		
		// if running version earlier than 8.4.1 then ignore constants in constantsToIgnore
		if not version841OrGreater then
			if constantsToIgnore.includes(translatableText.vConstantName) then
				continue;
			endif;
		endif;
		
		globalConstant := translatableText.myGlobalConstant;
		if not global.isValidObject(globalConstant) then
			continue;
		endif;
			
		delete xmlDoc;
		create xmlDoc transient;
		xmlDoc.parseString(globalConstant.text);
		
		errorText := null;
		foreach index in 1 to tagsToCheckFor.size do
			xmlAttribute := xmlDoc.getElementByTagName("ErrorMsg").getAttributeByName(tagsToCheckFor[index]);
			if xmlAttribute &lt;&gt; null then
				str := xmlAttribute.value;
			endif;
			if xmlAttribute = null or str = null then
				if errorText &lt;&gt; null then
					errorText := errorText.trimBlanks() &amp; ", ";
				endif;
				str := tagsToCheckFor[index];
				str.firstCharToLower();
				errorText := errorText &amp; str;
			endif;
		endforeach;
		
		methodsUsedIn := null;
		if errorText &lt;&gt; null then
			// check to see where the constant is used
			methodsSet.clear();
			if globalConstant &lt;&gt; null then
				globalConstant.getMethodRefs(methodsSet);
			endif;
			foreach meth in methodsSet do //where meth.getSchemaType().name &lt;&gt; "JadeScript" do
				if methodsUsedIn &lt;&gt; null then
					methodsUsedIn := methodsUsedIn.trimBlanks() &amp; ", ";
				endif;
				methodsUsedIn := methodsUsedIn &amp; meth.getSchema().name &amp; "::" &amp; meth.name;
			endforeach;
			
			// write the details out
			lastModified := translatableText.myGlobalConstant.cnGetModifiedTimeStamp();
			author := translatableText.myGlobalConstant.cnGetModifierName();
			errorTextArray.add(translatableText.vConstantName &amp; " (" &amp; "oid: " &amp; translatableText.String &amp; 
				" created: " &amp; translatableText.creationTime.date.format("dd/MM/yyyy") &amp; " - " &amp;
				translatableText.createdTime.time.String &amp; " id: " &amp; translatableText.vConstantValue.String &amp; 
				" last modified: " &amp; lastModified.date.format("dd/MM/yyyy") &amp; " by " &amp; author &amp; "): " &amp; errorText &amp; 
				", methods used in: " &amp; methodsUsedIn);
		endif;
		
	endforeach;
	
	if not errorTextArray.isEmpty() then
		app.writeLog("The following Form Caption details are invalid: ", LogINFO);
		errorText := errorTextArray.concatenate(CrLf);
		write errorText; 
		app.writeLog(errorText, LogINFO);
	endif;
	
	self.assertEqualMsg(errorTextArray.size, 0, 'Translation Form Captions Verify test failed - run DevSchema::JadeScript::verifyXLATFormCaptions to fix (Change updateRequired to actually update)' );
	
epilog

	delete errorTextArray;
	delete xmlDoc;
	delete tagsToCheckFor;
	delete methodsSet;
	delete constantsToIgnore;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tVerifyTextTranslations" id="1ae27778-627e-4a28-b251-6edb6b871a72">
        <source>tVerifyTextTranslations();
// cnwmh5 - for emails

/*
Purpose:	This method runs a validation version of the JadeScript verifyXLAT,
			- which checks that the translations are valid.
			It is possible for the Global Constants that are referred to by
			XLAT_TranslatableText myGlobalConstant get deleted,
			and then an invalid object reference is left behind.
			This has been done as part of PAR 16722.
*/
	
vars
	root	: CM_Root;
	xlat	: XLAT_TranslatableText;
	stuffed	: XLAT_TranslatableTextByNumber;
	
begin
	create stuffed transient;
	root := self.getRoot();
	
	foreach xlat in root.allXLAT_TranslatableText discreteLock do : text_loop
		if xlat.myGlobalConstant = null or app.isValidObject( xlat.myGlobalConstant ) then
			continue text_loop;
		endif;
		stuffed.addNoDuplicates( xlat, false );
	endforeach text_loop;
	
	// this test has passed if the stuffed collection is empty else display the errors.
	if stuffed.isEmpty then
		// test has passed ok.
		return;
	endif;
	
	// to help find the text translations in error display some details on them.
	// To fix run the DevSchema JadeScript verifyXLAT in an update mode.
	foreach xlat in stuffed discreteLock do : stuffed_loop
		///app.writeStatement( 'ERROR' &amp; Tab &amp; xlat.myConstantCategoryName &amp; Tab &amp; xlat.number.display &amp; Tab &amp; xlat.vConstantName &amp; Tab &amp; xlat.vDefaultMessage );
		app.writeLog('ERROR' &amp; Tab &amp; xlat.myConstantCategoryName &amp; Tab &amp; xlat.number.display &amp; Tab &amp; xlat.vConstantName &amp; Tab &amp; xlat.vDefaultMessage, LogINFO);		// 29/11/2012 cnwmh5
	endforeach stuffed_loop;
	
	// now indicate this test has failed.
	self.assertEqualMsg( stuffed.isEmpty, true, 'Translation Verify test failed - run DevSchema JadeScript verifyXLAT to fix (Change updateRequired to actually update)' );
	
epilog
	delete stuffed;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="uCheckConstantReferences" id="66c92098-56c6-45d3-a9a3-78ce02bbc2c5">
        <source>uCheckConstantReferences();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 May 2017	cnwns1	Initial creation

*/

vars

	portSchema : Schema;
	conSchema : Schema;
	conClass : Class;
	//conSchema : Schema;
	
	
	constantCategory : ConstantCategory;
	constOb : Constant;
	meths : MethodSet;
	meth : Method;
	xmlDoc		: JadeXMLDocument;
	xmlElement	: JadeXMLElement;
//	textElement	: JadeXMLElement;
	xmlAttribute: JadeXMLAttribute;
//	text : String;
	schemaName : String;
	className : String;
	freePassList : StringArray;
	methNameString : String;
	methodNameArray : HugeStringArray;
	
begin

	create freePassList transient;

	portSchema:=rootSchema.getSchema(PortSchemaName);
	constantCategory:=portSchema.getConstantCategory(XLAT_FormCaptions);
	
		freePassList.add("CMUI_ConnectAttachOld");
		freePassList.add("CMUI_ContainerEnqTransactions");
		freePassList.add("CMUI_JobCalendarForm");
		freePassList.add("CMUI_JobRequestForm_Work");
		freePassList.add("CMUI_MachineRulesConfigForm");
