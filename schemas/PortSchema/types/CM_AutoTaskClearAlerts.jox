    <JadeMethod name="getEntryTableViewName" id="38a7a0ab-7819-4adb-9da5-a86684137fb8">
        <source>getEntryTableViewName(): String;

// cnwdvb1 16 January 2003 

vars

begin
	return 'bgpAutoViewClearAlerts';

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getValueForRow" id="e05a31b8-5107-4112-8a0b-39ede839c27f">
        <source>getValueForRow(_rowName: String; _obj : Object output): Any;

// cnwdvb1 16 January 2003 

vars

begin

	if _rowName = ETRow_BgpClearSystemAlerts then
		return self.clearSystemAlerts.Integer;
	elseif _rowName = ETRow_BgpAutoNumberOfDaysOld then
		return self.numberOfDaysOld;
	elseif _rowName = ETRow_BgpAutoNoDaysOldRpts then
		return self.numberOfDaysOldRpts;
	endif;
	return inheritMethod(_rowName, _obj);

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_obj" type="Object" usage="output"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="1c738996-f341-470e-9987-fc6d46ac6e27">
        <updating/>
        <source>setForCreate(_pxyAutoTask: CM_AutoTaskClearAlerts) updating;

// cnwdvb1 16 January 2003 

vars

begin
	inheritMethod(_pxyAutoTask);
	self.requestClassName 	:= BGP_ClearAlertsRequest.name;
	self.clearSystemAlerts	:= _pxyAutoTask.clearSystemAlerts;
	self.numberOfDaysOld	:= _pxyAutoTask.numberOfDaysOld;
	self.numberOfDaysOldRpts:= _pxyAutoTask.numberOfDaysOldRpts;

end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskClearAlerts"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="d3690ec2-5ae5-4283-a24b-42365ae57a8b">
        <updating/>
        <source>setForUpdate(_pxyAutoTask: CM_AutoTaskClearAlerts) updating;

// cnwdvb1 16 January 2003 

vars

begin
	inheritMethod(_pxyAutoTask);
	self.clearSystemAlerts	:= _pxyAutoTask.clearSystemAlerts;
	self.numberOfDaysOld	:= _pxyAutoTask.numberOfDaysOld;
	self.numberOfDaysOldRpts:= _pxyAutoTask.numberOfDaysOldRpts;

end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskClearAlerts"/>
    </JadeMethod>
    <JadeMethod name="setValueForRow" id="442836e4-2ffc-47b1-a56e-7148b60ee3cb">
        <updating/>
        <source>setValueForRow(_rowName: String; _value: Any) updating;

// cnwdvb1 16 January 2003 

vars

begin

	if _rowName = ETRow_BgpClearSystemAlerts then
		self.clearSystemAlerts := _value.Integer.Boolean;
	elseif _rowName = ETRow_BgpAutoNumberOfDaysOld then
		self.numberOfDaysOld := _value.Integer;
	elseif _rowName = ETRow_BgpAutoNoDaysOldRpts then
		self.numberOfDaysOldRpts := _value.Integer;
	else
		inheritMethod(_rowName, _value);
	endif;

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validate" id="dec6fcfa-d980-415a-bb61-09f5c5448293">
        <source>validate();

// cnwdvb1 17 January 2003 
// 12/12/2014  cnwdb2	PAR 35364

vars

begin
	inheritMethod();
	if self.myTerminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Terminal', ETRow_BgpAutoTerminals, null); 
		app.raiseCMException(Input_required_field_terminal, ETRow_BgpAutoTerminals, null); // cnwdb2	PAR 35364

	endif;
	

end;</source>
    </JadeMethod>
</Class>
