    <JadeMethod name="utlDeleteTerminalBRXref" id="cad84eae-2bc8-43f0-9c85-e1c9bf24fee1">
        <source>utlDeleteTerminalBRXref(_terminal : CM_Terminal input;
						_brXref : CM_TerminalTIsByBR io;
						_passport : CM_Passport input);

/*

Purpose:			Delete the passed in Booking Ref cross reference, and set the Terminal's 
					extra data pointer to it to null

Parameters:			Terminal, cross reference

Return Value:		None


Date		Who		Reason
01 Sep 2009	cnwkpd1	PAR #20398 - Add Booking Reference cross reference functionality

*/

vars

begin
	self.initialiseActivity();

	// Delete the cross reference header
	delete _brXref;
	
	// And set the matching Terminal extra data value to null
	_terminal.setExtraData(XrefTIByBookingRef, null);
	
	
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal" usage="input"/>
        <Parameter name="_brXref" type="CM_TerminalTIsByBR" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteTerminalSubArea" id="50f1ecb7-2e08-45ca-9402-c8df3e09365a">
        <source>utlDeleteTerminalSubArea(_pxyTerminalSubArea : CM_TerminalSubArea; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     03 May 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	termSubAreaToDelete	: CM_TerminalSubArea;
	cancelSave	: Boolean;
	aTermSubArea : CM_TerminalSubArea;
	aTA : CM_TerminalArea;
begin

	termSubAreaToDelete := _pxyTerminalSubArea;

	if not self.exclusiveLockObjectToDelete(termSubAreaToDelete) then
	    // toDelete is null, invalid or has already been deleted
	    return;
	endif;

	app.setContinueCMExceptions(true);
	app.myValDA.valTerminalSubArea(termSubAreaToDelete);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;

	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(termSubAreaToDelete);
	endif;

	if _passport.noErrors then
		aTA := termSubAreaToDelete.myTerminalArea;
		termSubAreaToDelete.erase(NORMAL_ERASE);
		aTA.causeEvent(aTA.myTerminal.getTerminalEvent(Event_TALocation_Delete),true,termSubAreaToDelete);
	endif;

epilog
	return;
	
end;</source>
        <Parameter name="_pxyTerminalSubArea" type="CM_TerminalSubArea"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
