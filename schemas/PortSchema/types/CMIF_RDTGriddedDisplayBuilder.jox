<Class name="CMIF_RDTGriddedDisplayBuilder" id="f53de752-4bf9-4ab3-b445-87ff8b266d4d">
    <superclass name="CMIF_RDTDisplayBuilder"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <JadeMethod name="build" id="13fae3b9-ff00-4525-b4a0-ffc55e7e9a6d">
        <updating/>
        <source>build(_mode : Integer; _lc : CM_LocationsController; _ta : CM_TerminalArea; _leftCol, _rightCol, _topRow, _bottomRow : Integer; _scaleFactor : Real; _isLandscape, _flipH, _flipV : Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 May 2010	cnwjk3	Initial creation

*/

vars

begin
	if not _ta.isKindOf(CM_GridArea) then
		app.raiseUnexpectedProgramError(class.name, method.name, "Expecting gridded area type");
		return;
	endif;
	
	if not _lc.isKindOf(CM_GridController) then
		app.raiseUnexpectedProgramError(class.name, method.name, "Expecting grid controller type");
		return;
	endif;

	inheritMethod(_mode, _lc, _ta, _leftCol, _rightCol, _topRow, _bottomRow, _scaleFactor, _isLandscape, _flipH, _flipV);	
epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <Parameter name="_leftCol" type="Integer"/>
        <Parameter name="_rightCol" type="Integer"/>
        <Parameter name="_topRow" type="Integer"/>
        <Parameter name="_bottomRow" type="Integer"/>
        <Parameter name="_scaleFactor" type="Real"/>
        <Parameter name="_isLandscape" type="Boolean"/>
        <Parameter name="_flipH" type="Boolean"/>
        <Parameter name="_flipV" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="buildLandscapeEnd" id="803d432e-d669-4f74-a9bd-018a537d11d5">
        <updating/>
        <source>buildLandscapeEnd(_lc: CM_LocationsController; _ta: CM_TerminalArea; _leftCol: Integer; _rightCol: Integer; _topRow: Integer; _bottomRow: Integer; _scaleFactor: Real) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 June 2010	cnwjk3	Initial creation

*/

vars
	gridArea 		: CM_GridArea;
	gridRow 		: CM_GridRow;
	gc				: CM_GridController;
	ti				: CM_TrackedItem;
	tiDraw			: CMIF_RDTTIDrawElement;
	lcDraw			: CMIF_RDTLocationDrawElement;
	maxStackHeight,
	height,
	targetCol,
	col, row		: Integer;
begin
	gridArea := _ta.CM_GridArea;
	gc := _lc.CM_GridController;
	
	targetCol := gc.column;
	maxStackHeight := gridArea.getHeightOfStack();
	
	col := 1;
	foreach gridRow in gridArea.allGridRows do
	
		gc := gridRow.allControllersByColumn[targetCol];
		
		// Add the same location controller for each stack position
		row := 1;
		foreach height in 1 to maxStackHeight  reversed do
			create lcDraw transient;
			lcDraw.setLocationsController(gc);
			lcDraw.setStackHeight(height);
			self.addLocationWithHeight(row, col, height, lcDraw);
			row := row + 1;
		endforeach;
		
		// Add the tis if any
		row := maxStackHeight;
		foreach ti in gc.allTrackedItems do
			if ti.myPrimaryActualLocation &lt;&gt; gc then
				
				// Maybe want to draw back-ends of TIs in the future??
				continue;
			endif;
			
			create tiDraw transient;
			tiDraw.setTI(ti);
			self.addTI(row, col, tiDraw);
			row := row - 1;
		endforeach;

		col := col + 1;
	endforeach;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <Parameter name="_leftCol" type="Integer"/>
        <Parameter name="_rightCol" type="Integer"/>
        <Parameter name="_topRow" type="Integer"/>
        <Parameter name="_bottomRow" type="Integer"/>
        <Parameter name="_scaleFactor" type="Real"/>
    </JadeMethod>
    <JadeMethod name="buildLandscapeFace" id="2efae7ad-65fa-4fa4-a7e1-7070ac1366f5">
        <updating/>
        <source>buildLandscapeFace(_lc: CM_LocationsController; _ta: CM_TerminalArea; _leftCol: Integer; _rightCol: Integer; _topRow: Integer; _bottomRow: Integer; _scaleFactor: Real) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2010	cnwjk3	Initial creation

*/

vars
	gridArea 		: CM_GridArea;
	gridRow 		: CM_GridRow;
	gc,
	gcToUse,
	tmpGC			: CM_GridController;
	ti				: CM_TrackedItem;
	tiDraw			: CMIF_RDTTIDrawElement;
	lcDraw,
	tmpLcDraw		: CMIF_RDTLocationDrawElement;
	maxStackHeight,
	height,
	col, row,
	tmpRow			: Integer;
begin	
	gridArea := _ta.CM_GridArea;
	gc := _lc.CM_GridController;
	
	gridRow := gc.myGridRow;
	
	maxStackHeight := gridArea.getHeightOfStack();
	col := 1;
	foreach gc in gridRow.allControllersByColumn do 
	
		// Add the same location controller for each stack position
		row := 1;
		foreach height in 1 to maxStackHeight  reversed do
			create lcDraw transient;
			lcDraw.setLocationsController(gc);
			lcDraw.setStackHeight(height);
			self.addLocationWithHeight(row, col, height, lcDraw);
			row := row + 1;
		endforeach;

		//20/04/2011 cnwdz2 par27313 start
		gcToUse := gc;
		
		if self.drawForkLiftStack then
			if self.lookForkLiftStackFromBottom then
				//inFrontOf := true;
				foreach tmpGC in gc.myGridColumn.allControllersByRow reversed do
				/*
					if tmpGC = gc then
						inRow := true;
					elseif inRow then
						behind := true;
					endif;
					*/
					// find first location with a container in it
					if (not tmpGC.allTrackedItems.isEmpty) then
						gcToUse := tmpGC;
						break;
					endif;
				endforeach;
			else			
				foreach tmpGC in gc.myGridColumn.allControllersByRow do
					// find first location with a container in it
					if (not tmpGC.allTrackedItems.isEmpty) then
						gcToUse := tmpGC;
						break;
					endif;
				endforeach;
			endif;
		endif;
		
		// Add the tis if any
		row := maxStackHeight;		
		tmpRow := row;
		
		//foreach ti in gc.allTrackedItems do
		foreach ti in gcToUse.allTrackedItems do		
			//if ti.myPrimaryActualLocation &lt;&gt; gc then					
			if ti.myPrimaryActualLocation &lt;&gt; gcToUse then	
				// Do this to stop labels being drawn on the backend.				
				if self.drawForkLiftStack and not ti.is20() then					
					tmpLcDraw := self.getLocationDrawWithHeight(tmpRow, col, gcToUse.getActualStackPositionOfTI(ti));
					if tmpLcDraw &lt;&gt; null then				
						tmpLcDraw.setIsBackEnd(true);
						//tmpLcDraw.setLocationsController(gcToUse);
					endif;
					tmpRow := tmpRow - 1;
				endif;											
				continue;
			endif;			
			//20/04/2011 cnwdz2 par27313 end
			
			create tiDraw transient;
			tiDraw.setTI(ti);
			self.addTI(row, col, tiDraw);
			row := row - 1;
			tmpRow := row;
		endforeach;
		
		col := col + 1;	
	endforeach;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <Parameter name="_leftCol" type="Integer"/>
        <Parameter name="_rightCol" type="Integer"/>
        <Parameter name="_topRow" type="Integer"/>
        <Parameter name="_bottomRow" type="Integer"/>
        <Parameter name="_scaleFactor" type="Real"/>
    </JadeMethod>
    <JadeMethod name="buildLandscapeTopDown" id="551ef594-933d-4162-be9a-4500238bebf4">
        <updating/>
        <source>buildLandscapeTopDown(_lc : CM_LocationsController; _ta: CM_TerminalArea; _leftCol: Integer; _rightCol: Integer; _topRow: Integer; _bottomRow: Integer; _scaleFactor : Real) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 May 2010	cnwjk3	Initial creation

*/

vars
	gridArea 	: CM_GridArea;
	gridRow		: CM_GridRow;
	lc			: CM_GridController;
	tiDraw		: CMIF_RDTTIDrawElement;
	lcDraw		: CMIF_RDTLocationDrawElement;
	ti			: CM_TrackedItem;
	colFrom, colTo,
	rowFrom, rowTo,
	col,
	row	,
	rowCount,
	colCount,
	numCols,
	numRows 	: Integer;
	colIter,
	rowIter 		: Iterator;
begin
	
	if _leftCol &lt;= _rightCol then
		colFrom := _leftCol;
		colTo := _rightCol;
	else
		colFrom := _rightCol;
		colTo := _leftCol;
	endif;
	
	if _topRow &lt;= _bottomRow then
		rowFrom := _topRow;
		rowTo := _bottomRow;
	else
		rowFrom := _bottomRow;
		rowTo := _topRow;
	endif;

	
	gridArea := _ta.CM_GridArea;
	
	
	numRows:=rowTo-rowFrom + 1;
	numCols:= colTo - colFrom + 1;
	
	
	rowIter:=gridArea.allGridRows.createIterator;
	gridArea.allGridRows.startKeyGeq(rowFrom,rowIter);
	rowCount:=0;
	row:=rowFrom;
	while rowIter.next(gridRow) do	
		
		delete colIter;
		colIter:=gridRow.allControllersByColumn.createIterator;
		gridRow.allControllersByColumn.startKeyGeq(colFrom,colIter);
		colCount:=0;
		col:=colFrom;
		while colIter.next(lc) do : innerLoop
		

			create lcDraw transient;
			lcDraw.setLocationsController(lc);
			
			self.addLocation(row, col, lcDraw);
			ti := lc.getTopTI(REAL_MODE);
			if ti &lt;&gt; null and ti.myPrimaryActualLocation = lc then
				create tiDraw transient;
				tiDraw.setTI(ti);			
				self.addTI(row, col, tiDraw);
			endif;
				
			
			col:=col+1;
			colCount:=colCount + 1;
			if colCount &gt; numCols then
				break innerLoop;
			endif;
		endwhile;
	//endforeach;
		
		
		
		row:=row+1;
		rowCount:=rowCount + 1;
		if rowCount &gt; numRows then
			break;
		endif;
	endwhile;
//	endforeach;
	
	
epilog
	delete rowIter;
	delete colIter;
end;</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <Parameter name="_leftCol" type="Integer"/>
        <Parameter name="_rightCol" type="Integer"/>
        <Parameter name="_topRow" type="Integer"/>
        <Parameter name="_bottomRow" type="Integer"/>
        <Parameter name="_scaleFactor" type="Real"/>
    </JadeMethod>
    <JadeMethod name="buildPortraitTopDown" id="88b4230c-f3cc-4562-8b02-dabea018ade9">
        <updating/>
        <source>buildPortraitTopDown(_lc : CM_LocationsController; _ta: CM_TerminalArea; _leftCol: Integer; _rightCol: Integer; _topRow: Integer; _bottomRow: Integer; _scaleFactor : Real) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 May 2010	cnwjk3	Initial creation

*/

vars
	gridArea 	: CM_GridArea;
	gridRow		: CM_GridRow;
	tiDraw		: CMIF_RDTTIDrawElement;
	lcDraw		: CMIF_RDTLocationDrawElement;
	lc			: CM_GridController;
	ti			: CM_TrackedItem;
	colFrom, colTo,
	rowFrom, rowTo,
	col,
	row,
	rowCount,
	colCount,
	numCols,
	numRows 	: Integer;
	colIter,
	rowIter 		: Iterator;
begin
	
	if _leftCol &lt;= _rightCol then
		colFrom := _leftCol;
		colTo := _rightCol;
	else
		colFrom := _rightCol;
		colTo := _leftCol;
	endif;
	
	if _topRow &lt;= _bottomRow then
		rowFrom := _topRow;
		rowTo := _bottomRow;
	else
		rowFrom := _bottomRow;
		rowTo := _topRow;
	endif;
		
	gridArea := _ta.CM_GridArea;
	numRows:=rowTo-rowFrom + 1;
	numCols:= colTo - colFrom + 1;
	
	
	// portrait, so rows = cols and cols = rows
	
	rowIter:=gridArea.allGridRows.createIterator;
	gridArea.allGridRows.startKeyGeq(colFrom,rowIter);
	colCount:=0;
	col:=colFrom;
	while rowIter.next(gridRow) do
	
	
	// Note that for gridded areas I am assuming a 1-to-1 mapping of grid square to location
	/*foreach col in colFrom to colTo do
		gridRow := gridArea.allGridRows[col];
		if gridRow = null then
			continue;
		endif;*/
		
		delete colIter;
		colIter:=gridRow.allControllersByColumn.createIterator;
		gridRow.allControllersByColumn.startKeyGeq(rowFrom,colIter);
		rowCount:=0;
		row:=rowFrom;
		while colIter.next(lc) do : innerLoop
		
	/*	foreach row in rowFrom to rowTo do
			
			lc := gridRow.allControllersByColumn[row];*/
			create lcDraw transient;
			lcDraw.setLocationsController(lc);
			//lcDraw.initSizesOffsets(self.lcLeftGridOffsetFt, self.lcTopGridOffsetFt, self.lcWidthFt, self.lcHeightFt);
			
			self.addLocation(row, col, lcDraw);			
			
			
			ti := lc.getTopTI(REAL_MODE);
			if ti &lt;&gt; null and ti.myPrimaryActualLocation = lc then
				create tiDraw transient;
				tiDraw.setTI(ti);
				//tiDraw.initSizesOffsets(self.tiLeftGridOffsetFt, self.tiTopGridOffsetFt, self.getWidthOfTIInFt(ti), self.getLengthOfTIInFt(ti));
				self.addTI(row, col, tiDraw);
			endif;
			
			row:=row+1;
			rowCount:=rowCount + 1;
			if rowCount &gt; numRows then
				break innerLoop;
			endif;
		endwhile;
			
		//endforeach;
		
		col:=col+1;
		colCount:=colCount + 1;
		if colCount &gt; numCols then
			break;
		endif;
	endwhile;
		
	//endforeach;
	
	
epilog
	delete rowIter;
	delete colIter;
end;</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <Parameter name="_leftCol" type="Integer"/>
        <Parameter name="_rightCol" type="Integer"/>
        <Parameter name="_topRow" type="Integer"/>
        <Parameter name="_bottomRow" type="Integer"/>
        <Parameter name="_scaleFactor" type="Real"/>
