    <JadeMethod name="checkTimeOffPower" id="02128712-91f5-4ccd-b106-9de37896d5e6">
        <source>checkTimeOffPower(_ti : CM_TrackedItem io; _passport : CM_Passport input);
/*
Purpose:	If time off power is greater than allowable time of power then
			1. Create an alert and email
			2. Create a CM_ReceivedPowerOffExceeded transaction which will be used by the report

Parameters:			

Return Value:		

Date		Who		Reason
07 May 2010	cnwmd1	Initial creation
18/04/2013	cnwdap1	PAR #31450 Update remaining time off power
08/06/2015	cnwdap1	PAR #36219 Raise "Time Off Power Exceeded" alerts as Reefer Alerts, not Warnings
*/

vars
	timeOffPower, allowableTimeOffPower : Decimal[12,2];
	commodity : CM_Commodity;
	alert : CM_SystemAlert;
	allowableMins, timeOffMins, diff : Integer;					// PAR #31450
	remaining : Decimal [12,2];									// PAR #31450
begin
	commodity := _ti.getCommodityObject;
	//08/03/2011 cnwdz2 27119
	if commodity = null then
		return;
	endif;
	
	if not commodity.requiresMAFFields or not commodity.requiresPower then
		return;
	endif;
	
	allowableTimeOffPower := _ti.getAllowableTimeOffPower;
	
	//epr par 32424 17/9/13 allowable time not set then return
	if allowableTimeOffPower = NULL_ALLOWABLE_TIME_OFF_POWER then
		return;
	endif;
	
	timeOffPower := _ti.getTimeOffPowerAtReceival;
	
	allowableMins := ((allowableTimeOffPower.Integer * 60) + ((allowableTimeOffPower - allowableTimeOffPower.Integer) * 100)).Integer;	// PAR #31450
	timeOffMins := ((timeOffPower.Integer * 60) + ((timeOffPower - timeOffPower.Integer) * 100)).Integer;								// PAR #31450
	diff := allowableMins - timeOffMins;																								// PAR #31450
	remaining := (diff / 60).Integer;																									// PAR #31450
	remaining := remaining + (diff mod 60 / 100);																						// PAR #31450
	// Create an alert and a TIme Exceeded transaction only if we don't already have one												// PAR #31450
	//if timeOffPower &gt; allowableTimeOffPower then																						// PAR #31450
	if remaining &lt; 0 and _ti.getLastTransOfType(TRANS_TYPE_POWER_OFF_EXCEEDED) = null then												// PAR #31450
		//Create alert and email
		//alert := _passport.createAlert(SEVERE_WARNING,					// PAR #36219
		alert := _passport.createAlert(SEVERE_REEFER_ALERT,					// PAR #36219
								//app.getErrorString3(Cargo_Time_Off_Power_Exceeded, _ti.id.String, timeOffPower.asHrsMins, allowableTimeOffPower.asHrsMins),
								app.getErrorString6(Cargo_Time_Off_Power_Exceeded, _ti.id.String, timeOffPower.asHrsMins, allowableTimeOffPower.asHrsMins, _ti.consignor, _ti.getCommodityDesc, _ti.remarks), //cnwrd1 par 31336
								EVENT_POWER_OFF_EXCEEDED,
								_ti);
					
		if alert &lt;&gt; null then
			app.commitAlert;
		endif;
		
		//Create txn for report
		_ti.addAllowTimeOffPowerExcededTxn(_passport);
	endif;
	_ti.setRemainingTimeOffPower(remaining);																							// PAR #31450

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getCCEventProperties" id="a7bcc4d7-4eda-4a2b-9bcd-f014c60ba94a">
        <source>getCCEventProperties(ccEvent: CMIF_CCEvent) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2019	jlgndl1	Initial creation	TFS 45963

*/

vars

	receiveType : String;
	
begin

	receiveType := self.getReceiveTypeforCC();

	inheritMethod(ccEvent);
	
	ccEvent.addText( "receiveType", receiveType ) ;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="ccEvent" type="CMIF_CCEvent"/>
    </JadeMethod>
