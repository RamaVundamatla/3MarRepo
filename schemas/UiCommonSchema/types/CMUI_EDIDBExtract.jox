vars

begin
	return self.myAssistant.displayEntryOperator(_obj);
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_obj" type="CM_Operator"/>
        <Parameter name="_index" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
