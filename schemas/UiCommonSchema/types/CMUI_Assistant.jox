Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 December 2009	cnwndl1	Initial creation

*/

vars

begin

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doTaskProxySetForComplete" id="3a2894d9-38a6-4f0e-aa1f-c8f584077fe0">
        <source>doTaskProxySetForComplete( 	_taskDescCodeToMatch : Integer;
							_pxyTiSet : CM_TISet io;
							_ti : CM_TrackedItem;
							_tiArray : CM_TISet;
							_resourceUsageProxys : CM_ResourceTypeUsageSet output ):Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 Dec 2009	cnwndl1	Initial creation	CCMS MES 1006
					(Common code from several forms united and migrated up to the assistant for ease of maintenance)
5 Dec 2011	cnwkpd1	PAR #28778 - To Do Task array extended locks (problem caused by modal form opening inside
					foreach loop)
25 Sep 2013	cnwdap1	PAR #32552 Weight form now uses a measurement table to get weight
24 Oct 2013	NDL		Par 32646  And now dimensions form does too.
21 Dec 2015 cnwjre1 37244 added damages form
29 Jun 2017	cnwdap1	TFS 4492 SNO VERMAS Changes
28 Aug 2017	jlgdap1	TFS 6563 VERMAS Outwards can have invalid DOC segment
27 June 2018	jlgrh7 	TFS #39152 VERMAS Message Failures - String Too Long
05 Jul 2024 navbs1  CR 64901 Task 64903: UI - Show Cargo Ids in To Do Complete Thin Client
*/
constants
	RecEscapChc  = "?";
vars

	totalWeight         : Decimal[14,4];
	isWeightCertified   : Boolean;
	tiOverHeight		: Decimal[14,4];
	tiOverlengthFront	: Decimal[14,4];
	tiOverlengthRear	: Decimal[14,4];
	tiOverWidthLeft		: Decimal[14,4];
	tiOverWidthRight	: Decimal[14,4];
	tiLength         	: Decimal[14,4];
	tiWidth         	: Decimal[14,4];
	tiHeight         	: Decimal[14,4];
	tiVolume         	: Decimal[16,4];
	specialLifts : CM_SpecialLiftByCodeDict;
	
	weighedBy : String;
	authorisedBy : String;

	tiTask : CM_ToDoTask;
	pxyTI : CM_TrackedItem;
	damageTaskForm : CMUI_ToDoDamageTask;
	weighTaskForm : CMUI_ToDoWeighTask;
	dimensionForm : CMUI_ToDoDimensionTask;
	sealsTaskForm : CMUI_ToDoSeals;
	specialLiftsForm : CMUI_ToDoSpecialLiftTaskForm;
	
	damageInterface : IF_DamageDetails;
	firstTi : CM_TrackedItem;
	ti : CM_TrackedItem;
	errors : String;
	doSpecialLifts : Boolean;
	doWeights : Boolean;
	doDimensions : Boolean;
	resourceUsageResult : Boolean;
	
	row 		: Integer;
	obj 		: Object;
	sealTI		: CM_SealTI;
	sealType	: CM_SealType;
	sealValue 	: String;
	vgmDetails : CM_VGMDetails;							// TFS 4492
	authSig, commsType, docDetails, ediTrans, email, 	// TFS 4492
	mail, phone, fax, telephone : String;				// TFS 4492
	docsIssued, determination : TimeStamp;				// TFS 4492
	
	weighAuth : CM_WeighAuthority;				// TFS 6563
	
	cargoWeight         : Decimal[14,4];	//03 Apr 2018	NDL	TFS 37621
	tareWeight         : Decimal[14,4];	//03 Apr 2018	NDL	TFS 37621
	trnType : CM_TransactionType;
begin

	firstTi := _ti;
	if firstTi = null then
		if _tiArray &lt;&gt; null and not _tiArray.isEmpty then
			firstTi := _tiArray.first;
		endif;
	endif;
	
	if firstTi = null then
		//nothing to process
		return 0;
	endif;

	// use the nominated 'ti' to gather the common values against.
	foreach tiTask in firstTi.allToDoTasksToDo discreteLock do		// PAR #28778

		if tiTask.toDoTaskDescCode &lt;&gt; _taskDescCodeToMatch then
			continue;	
		endif;

		pxyTI := app.createUpdateProxy(_ti).CM_TrackedItem;
		_pxyTiSet.add(pxyTI);

		if tiTask.toDoTaskDesc.requiredExtraInfo = EXTRA_INFO_SPECIAL_LIFT then	//31 May 2010	NDL	Par 23903
			create specialLifts transient;
			create specialLiftsForm transient;
			
			specialLiftsForm.init(firstTi, tiTask.toDoTaskDesc);
			specialLiftsForm.showModal();
			
			if specialLiftsForm.modalResult = IDOK then
				doSpecialLifts := true;
				if not specialLiftsForm.allSelectedSpecLifts.isEmpty then
					specialLiftsForm.allSelectedSpecLifts.copy(specialLifts);
				endif;
				pxyTI.zSetPxySpecialLifts(specialLifts);
			else
				return specialLiftsForm.modalResult;
			endif; 
		
		elseif tiTask.toDoTaskDesc.requiredExtraInfo = EXTRA_INFO_WEIGHT then
			create weighTaskForm transient;
			
			weighTaskForm.init(firstTi);
			weighTaskForm.showModal();
			
			if weighTaskForm.modalResult = IDOK then
				doWeights := true;
				//totalWeight := weighTaskForm.txtWeight.text.asDecimalJMT();			// PAR #32552
				totalWeight := weighTaskForm.txtWeight.getConvertedValue();				// PAR #32552
				isWeightCertified := weighTaskForm.chkCertified.value;
				weighedBy := weighTaskForm.cmbWeightBy.text;	//03 Jun 2016	NDL	TFS 2099
				authorisedBy := weighTaskForm.cmbAuthor.text;	//03 Jun 2016	NDL	TFS 2099
				weighAuth := weighTaskForm.cmbWeightBy.listObject.CM_WeighAuthority;			// TFS 6563
				
				//03 Apr 2018	NDL	TFS 37621
				if pxyTI.myCargoType.useTareCargoWeight then
					cargoWeight := weighTaskForm.txtCargoWeight.getConvertedValue();
					tareWeight := weighTaskForm.txtTareWeight.getConvertedValue();
					pxyTI.setWeightCargo( cargoWeight );
					pxyTI.setWeightTare( tareWeight );
				endif;
				
				pxyTI.setTotalWeight(totalWeight, null, app.myPassport);
				pxyTI.setIsWeightCertified(isWeightCertified, null, app.myPassport);
				//pxyTI.setWeightCertifiedReference(weighedBy, null, app.myPassport);	//03 Jun 2016	NDL	TFS 2099	// TFS 4492
				//pxyTI.setWeightCertifiedName(authorisedBy, null, app.myPassport);	//03 Jun 2016	NDL	TFS 2099		// TFS 4492
				docsIssued := null;																				// TFS 6563
				determination := null;																			// TFS 6563
				vgmDetails := pxyTI.getMyVGMDetails();																	// TFS 4492
				if vgmDetails &lt;&gt; null then																				// TFS 4492
					authSig := vgmDetails.vgmAuthSignature;																// TFS 4492
					commsType := vgmDetails.vgmCommsType;																// TFS 4492
					docDetails := vgmDetails.vgmDocumentDetails;														// TFS 4492
					ediTrans := vgmDetails.vgmEDITransmission;															// TFS 4492
					email := vgmDetails.vgmElectronicMail;																// TFS 4492
					mail := vgmDetails.vgmMail;																			// TFS 4492
					phone := vgmDetails.vgmPhone;																		// TFS 4492
					fax := vgmDetails.vgmTelefax;																		// TFS 4492
					telephone := vgmDetails.vgmTelephone;																// TFS 4492
					docsIssued := vgmDetails.vgmDocsIssuedDT;															// TFS 4492
					determination := vgmDetails.vgmDeterminationDT;														// TFS 4492
				endif;																									// TFS 4492
				// TFS 6563 If selected details are blank, default them from the Weigh Authority				// TFS 6563
				if isWeightCertified and determination = null then												// TFS 6563
					determination := app.actualTimeServer;														// TFS 6563
				endif;																							// TFS 6563
				if weighAuth &lt;&gt; null then																		// TFS 6563
					if commsType = null then																	// TFS 6563
						commsType := weighAuth.solasMethod;														// TFS 6563
					endif;																						// TFS 6563
					if email = null then																		// TFS 6563
						email := weighAuth.email1;																// TFS 6563
					endif;																						// TFS 6563
					if mail = null then																			// TFS 6563
						//mail := weighAuth.address1 &amp; Space &amp; weighAuth.address2 &amp; Space &amp; weighAuth.address3;	// TFS 6563		//-TFS39152
						mail := weighAuth.address1 &amp;RecEscapChc&amp; weighAuth.address2 &amp;RecEscapChc&amp; weighAuth.address3;				//+TFS39152
						mail := mail.trimBlanks;																																											
					endif;																						// TFS 6563
					if phone = null then																		// TFS 6563
						phone := weighAuth.phone1;																// TFS 6563
					endif;																						// TFS 6563
				endif;																							// TFS 6563
				pxyTI.setMyVGMDetails(	weighedBy, authorisedBy,  														// TFS 4492
										authSig, commsType, docDetails, ediTrans, email, mail, 							// TFS 4492
										phone, fax, telephone, docsIssued, determination, null	);						// TFS 4492
			else
				return weighTaskForm.modalResult;
			endif;
		
		elseif tiTask.toDoTaskDesc.requiredExtraInfo = EXTRA_INFO_DIMENSION then	
			create dimensionForm transient;
			
			dimensionForm.init(firstTi);
			dimensionForm.showModal();
			
			if dimensionForm.modalResult = IDOK then
				doDimensions := true;
			//	tiOverHeight := dimensionForm.txtHeight.text.asDecimalJMT();
				tiOverHeight := dimensionForm.txtHeight.getConvertedValue();	//24 Oct 2013	NDL	Par 32646
			//	tiOverlengthFront := dimensionForm.txtFront.text.asDecimalJMT();
				tiOverlengthFront := dimensionForm.txtFront.getConvertedValue();	//24 Oct 2013	NDL	Par 32646
			//	tiOverlengthRear := dimensionForm.txtBack.text.asDecimalJMT();
				tiOverlengthRear := dimensionForm.txtBack.getConvertedValue();	//24 Oct 2013	NDL	Par 32646
			//	tiOverWidthLeft := dimensionForm.txtLeft.text.asDecimalJMT();
				tiOverWidthLeft := dimensionForm.txtLeft.getConvertedValue();	//24 Oct 2013	NDL	Par 32646
			//	tiOverWidthRight := dimensionForm.txtRight.text.asDecimalJMT();
				tiOverWidthRight := dimensionForm.txtRight.getConvertedValue();	//24 Oct 2013	NDL	Par 32646
			//	tiLength := dimensionForm.txtLength.text.asDecimalJMT();
				tiLength := dimensionForm.txtLength.getConvertedValue();	//24 Oct 2013	NDL	Par 32646
			//	tiWidth := dimensionForm.txtWidth.text.asDecimalJMT();
				tiWidth := dimensionForm.txtWidth.getConvertedValue();	//24 Oct 2013	NDL	Par 32646
			//	tiHeight := dimensionForm.txtHeight.text.asDecimalJMT();
				tiHeight := dimensionForm.txtHeight.getConvertedValue();	//24 Oct 2013	NDL	Par 32646
			//	tiVolume := dimensionForm.txtVolume.text.asDecimalJMT();
				tiVolume := dimensionForm.txtVolume.getConvertedValue();	//24 Oct 2013	NDL	Par 32646
				
				if firstTi.myCargoType.id = TI_CargoType_Container then
					pxyTI.CM_Container.setOverDimensions(	tiOverHeight,	//_overHeight : Decimal;
															tiOverlengthFront,	//_overLengthFront : Decimal;
															tiOverlengthRear,	//_overLengthRear : Decimal;
															tiOverWidthLeft,	//_overWidthLeft : Decimal;
															tiOverWidthRight,	//_overWidthRight : Decimal;
															null,	//_tiUpdateCntrlr : CMIF_TIUpdateController input;
															app.myPassport	//_passport : CM_Passport input
															);
				else
					pxyTI.setLength(tiLength);
					pxyTI.setWidth(tiWidth);
					pxyTI.setHeight(tiHeight);
					pxyTI.setMyTotalVolume(tiVolume); // cnwdw1 27868
				endif;
			else
				return dimensionForm.modalResult;
			endif;
		elseif tiTask.toDoTaskDesc.requiredExtraInfo = EXTRA_INFO_SEALS then //cnwrd1 par 29028 9.2.12
		
			if _tiArray &lt;&gt; null and _tiArray.size &gt; 1 then
			// we cant update seal info on more than 1 item, this would be wrong.
				app.msgBox(app.getErrorString(Canno_updat_more_than_cargo_it),app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Stop_Icon);
				return IDCANCEL;
			endif;
			
			//have to record some seal information.		
			create sealsTaskForm transient;
			
			sealsTaskForm.init(pxyTI);
			sealsTaskForm.showModal();
			
			if sealsTaskForm.modalResult = IDOK then
				//we have a table of info c1 = seal dwesc, c2 = value
				// object is either a CM_SealTI if it existed already or a CM_SealType if not.
				row := 1;
				while row &lt; sealsTaskForm.tblSeals.rows do
					row := row +1;
					obj := sealsTaskForm.tblSeals.accessRow(row).itemObject;
					if obj = null then
						continue;
					endif;
					
					sealValue := sealsTaskForm.tblSeals.accessCell(row,2).text;
					
					if obj.isKindOf(CM_SealTI) then
						sealTI := obj.CM_SealTI;
						
						if not sealTI.matchesValueFromUser(sealValue) then
							sealTI.setProxy(	sealValue.trimBlanks[1:62],	//_sealNum : String;
								null,	//_sealNumArray : StringArray;
								sealTI.getSealValueAsString(),	//_prevSeal : String;
								sealTI.sealType,	//_sealType : String;
								app.actualTimeServer(),	//_sealedDT : TimeStamp;
								sealTI.myTrackedItem	//_myTrackedItem : CM_TrackedItem
								);
						endif;
						
					elseif obj.isKindOf(CM_SealType) then
						sealType := obj.CM_SealType;
						pxyTI.setSealNumberValueDirect(sealType,sealValue,null);					
					else
						//?
					endif;
				endwhile;
			else
				return sealsTaskForm.modalResult;
			endif;
					
		elseif tiTask.toDoTaskDesc.requiredExtraInfo = EXTRA_INFO_DAMAGE then // cnwjre1 Dec 2015 37244 add damage
		
			if _tiArray &lt;&gt; null and _tiArray.size &gt; 1 then
			// we cant update damage on more than 1 item?? (Copied from check for seals - remove if not true).
				app.msgBox(app.getErrorString(Cannot_update_damage),app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Stop_Icon);
				return IDCANCEL;
			endif;
			
			create damageTaskForm transient;
			
			damageTaskForm.init(pxyTI);
			damageTaskForm.showModal();
			
			if damageTaskForm.modalResult = IDOK then
				damageInterface := pxyTI.IF_DamageDetails;
				// this creates CM_DamageInstances from the table values and links them to the TI proxy
				damageTaskForm.tblDamages.setProxyFromTable(damageInterface, errors, null);
			else
				return damageTaskForm.modalResult;
			endif;
			
		elseif tiTask.toDoTaskDesc.allResourceTypes.size &gt; 0 then
			trnType := tiTask.toDoTaskDesc.myTransactionType; // ### TFS CR 57926 TASK 57923 25MAY2023 NAVAB1
			if trnType &lt;&gt; null // ### TFS CR 57926 TASK 57923 25MAY2023 NAVAB1
			and not trnType.isForWorkOrder() then // ### TFS CR 57926 TASK 57923 25MAY2023 NAVAB1
				create _resourceUsageProxys transient;	// will be populated with template versions of the resources to apply..
				resourceUsageResult := self.showResourceTypeUsageForTxn(null, null, tiTask.toDoTaskDesc, tiTask.CM_TiToDoTask.myTrackedItem, _resourceUsageProxys, true, null);		// 11/01/2011 cnwar2 #26691	//05.07.2024  navbs1  CR 64901 Task 64903
				if resourceUsageResult = false then
					// failed to create the form or was cancelled.
					app.msgBox(app.getErrorString(Resource_Usage_Form_Not_shown),app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Stop_Icon);
					return IDCANCEL;
				endif;
			endif;
		endif;
		
		// Only allowed one of each type of task per ti, and we have just processed it, so look no further.
		break;
		
	endforeach;
	
	if _tiArray = null or _tiArray.isEmpty then
		return IDOK;
	endif;
	
	foreach ti in _tiArray do
		if ti = firstTi then
			//already done this one.
			continue;
		endif;
		
		foreach tiTask in ti.allToDoTasksToDo do

			if tiTask.toDoTaskDescCode &lt;&gt; _taskDescCodeToMatch then
				continue;	
			endif;
		
			pxyTI := app.createUpdateProxy(ti).CM_TrackedItem;
			_pxyTiSet.add(pxyTI);
	
	
			if tiTask.toDoTaskDesc.requiredExtraInfo = EXTRA_INFO_SPECIAL_LIFT then	//31 May 2010	NDL	Par 23903
				if doSpecialLifts then
					pxyTI.zSetPxySpecialLifts(specialLifts);
				endif; 
			
			elseif tiTask.toDoTaskDesc.requiredExtraInfo = EXTRA_INFO_WEIGHT then
				if doWeights then
				
					//03 Apr 2018	NDL	TFS 37621
					if pxyTI.myCargoType.useTareCargoWeight then
						pxyTI.setWeightCargo( cargoWeight );
						pxyTI.setWeightTare( tareWeight );
					endif;
				
					pxyTI.setTotalWeight(totalWeight, null, app.myPassport);
					pxyTI.setIsWeightCertified(isWeightCertified, null, app.myPassport);
					//pxyTI.setWeightCertifiedReference(weighedBy, null, app.myPassport);	//03 Jun 2016	NDL	TFS 2099	// TFS 4492
					//pxyTI.setWeightCertifiedName(authorisedBy, null, app.myPassport);	//03 Jun 2016	NDL	TFS 2099	// TFS 4492
				vgmDetails := pxyTI.getMyVGMDetails();																	// TFS 4492
				if vgmDetails &lt;&gt; null then																				// TFS 4492
					authSig := vgmDetails.vgmAuthSignature;																// TFS 4492
					commsType := vgmDetails.vgmCommsType;																// TFS 4492
					docDetails := vgmDetails.vgmDocumentDetails;														// TFS 4492
					ediTrans := vgmDetails.vgmEDITransmission;															// TFS 4492
					email := vgmDetails.vgmElectronicMail;																// TFS 4492
					mail := vgmDetails.vgmMail;																			// TFS 4492
					phone := vgmDetails.vgmPhone;																		// TFS 4492
					fax := vgmDetails.vgmTelefax;																		// TFS 4492
					telephone := vgmDetails.vgmTelephone;																// TFS 4492
					docsIssued := vgmDetails.vgmDocsIssuedDT;															// TFS 4492
					determination := vgmDetails.vgmDeterminationDT;														// TFS 4492
				endif;																									// TFS 4492
				pxyTI.setMyVGMDetails(	weighedBy, authorisedBy,  														// TFS 4492
										authSig, commsType, docDetails, ediTrans, email, mail, 							// TFS 4492
										phone, fax, telephone, docsIssued, determination, null	);						// TFS 4492
				endif;
				
			elseif tiTask.toDoTaskDesc.requiredExtraInfo = EXTRA_INFO_DIMENSION then	
				
				if doDimensions then
					if ti.myCargoType.id = TI_CargoType_Container then
						pxyTI.CM_Container.setOverHeight(tiOverHeight, null, app.myPassport);
						pxyTI.CM_Container.setOverLengthFront(tiOverlengthFront, null, app.myPassport);
						pxyTI.CM_Container.setOverLengthRear(tiOverlengthRear, null, app.myPassport);
						pxyTI.CM_Container.setOverWidthLeft(tiOverWidthLeft, null, app.myPassport);
						pxyTI.CM_Container.setOverWidthRight(tiOverWidthRight, null, app.myPassport);
					else
						pxyTI.setLength(tiLength);
						pxyTI.setWidth(tiWidth);
						pxyTI.setHeight(tiHeight);
						pxyTI.setMyTotalVolume(tiVolume);
					endif;
				endif;
				// seals and damage only valid for one item, already done above
			endif;
			
			// Only allowed one of each type of task per ti, and we have just processed it, so look no further.
			break;
			
		endforeach;
	endforeach;
	
	return IDOK;
			
epilog

	delete weighTaskForm;
	delete dimensionForm;
	delete specialLiftsForm;
	delete specialLifts;
	delete damageTaskForm;
	
end;</source>
        <Parameter name="_taskDescCodeToMatch" type="Integer"/>
        <Parameter name="_pxyTiSet" type="CM_TISet" usage="io"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiArray" type="CM_TISet"/>
        <Parameter name="_resourceUsageProxys" type="CM_ResourceTypeUsageSet" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doToDoTaskProxySetForComplete" id="41c0d829-1839-4355-9d7c-f687edb02cc0">
        <source>doToDoTaskProxySetForComplete(_toDoTaskDesc : Integer; _toDoTask : CM_ToDoTask; _resourceUsageProxys : CM_ResourceTypeUsageSet output; objString : String): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
12 Dec 2022  navcs2   ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen
05/04/2023	navcs2	Bug 57455: EUP - Todo Tasks Completed without adding Mandatory resources

*/

vars
	resourceUsageResult : Boolean;
begin
	if _toDoTask.toDoTaskDesc.allResourceTypes.isNotEmpty then
		create _resourceUsageProxys transient;					// will be populated with template versions of the resources to apply..
		resourceUsageResult := self.showResourceUsageToDoTxn(null, null, _toDoTask.toDoTaskDesc, _resourceUsageProxys, true, objString);		//05/04/2023	navcs2	Bug 57455
		
		if resourceUsageResult = false then
			// failed to create the form or was cancelled.
			app.msgBox(app.getErrorString(Resource_Usage_Form_Not_shown),app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Stop_Icon);
			return IDCANCEL;
		endif;
		
	endif;
	
	return IDOK;

epilog

end;</source>
        <Parameter name="_toDoTaskDesc" type="Integer"/>
        <Parameter name="_toDoTask" type="CM_ToDoTask"/>
        <Parameter name="_resourceUsageProxys" type="CM_ResourceTypeUsageSet" usage="output"/>
        <Parameter name="objString" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doUnassignReleasesFromWagons" id="f53994c7-782a-4c19-ae22-14497ad37951">
        <source>doUnassignReleasesFromWagons( menuItem: MenuItem input; wleArray : CM_WLEArray; wagonArray : CM_WagonArray );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 August 2009	cnwndl1	Initial creation	CCMS 1094

*/

vars

begin
	// re-implemented on YRD_Assistant
epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
        <Parameter name="wleArray" type="CM_WLEArray"/>
        <Parameter name="wagonArray" type="CM_WagonArray"/>
    </JadeMethod>
    <JadeMethod name="entryTableVesselStructureType" id="7a6b2a7f-ff2a-49db-9150-acb647d7f1cf">
        <updating/>
        <source>entryTableVesselStructureType(pTable : CM_EntryTable io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Mar 2013	cnwpjs1	Initial creation PAR # 31232

*/


vars

begin
		
	
//	if not  app.getMyUser.canDo(self.myTerminal, PmShipPlanning) and
	// ### JIRA 33505 30DEC2024 NAVAB1 (Mod_CargoShip in part of base now)if not  app.getMyUser.canDo(self.myTerminal, Mod_CargoShip) and	//07 Oct 2019	NDL	TFS 46169
	if   not app.getMyUser.canDo(self.myTerminal, Mod_CargoHandling) then
		pTable.hideRowByName(ETRow_IncludesLOLO, false);
		pTable.hideRowByName(ETRow_IncludesRORO, false);
	endif;

	if not app.getMyUser.canDo(self.myTerminal, Mod_GeneralCargo) then
		pTable.hideRowByName(ETRow_IncludesHolds, false);
	endif;

	
//	if app.getMyUser.canDo(self.myTerminal, PmVTMISMod) or app.isVoyageCommodityPlanning then
//		_cmb.addItem(StructureTypeNullStr);
//	endif;		
	
//
	
end;</source>
        <Parameter name="pTable" type="CM_EntryTable" usage="io"/>
    </JadeMethod>
    <JadeMethod name="fieldPathSegment" id="d556bf95-c0f8-4e9e-ac70-d066e598c709">
        <source>fieldPathSegment(_fieldObj:CMUI_FieldComboBox; _pathSegmentObj:HMS_PathSegment; startOfSegment : HMS_HarbourRegion);
//-----------------------------------------------------------------------
//	Created:	24 August 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	user			: CM_User;
	userPathSegment	: HMS_PathSegment;

begin
	_fieldObj.clear();
	user	:=	app.getMyUser();
	
	foreach userPathSegment in app.myRoot.allPathSegments do
		if userPathSegment.myRegionFrom = startOfSegment then
			_fieldObj.addItemObject(self.displayEntryHMSPathSegment(userPathSegment), userPathSegment);
		endif;
	endforeach;
	
	if _pathSegmentObj &lt;&gt; null then
		_fieldObj.setForObject(_pathSegmentObj);
	endif;
end;</source>
        <Parameter name="_fieldObj" type="CMUI_FieldComboBox"/>
        <Parameter name="_pathSegmentObj" type="HMS_PathSegment"/>
        <Parameter name="startOfSegment" type="HMS_HarbourRegion"/>
    </JadeMethod>
    <JadeMethod name="fieldTerminal" id="8db521ea-1fe5-47b1-97d0-03e12fbca3f4">
        <source>fieldTerminal(_fieldObj:CMUI_FieldComboBox; _terminalObj:CM_Terminal);
// --------------------------------------------------------------------------------
// Created:		22 February 2006 by cnwdad1
//
// Purpose:		Populates a Terminal field.
//
// Parameters:	_fieldObj - The combobox field to populate.
//				_terminalObj - A reference to the default terminal.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	user			: CM_User;
	userTerminal	: CM_UserTerminal;
	tmpTerminal		: CM_Terminal;

begin
	_fieldObj.clear();
	user	:=	app.getMyUser();
	
	foreach userTerminal in user.allUserTerminals do
		tmpTerminal := userTerminal.getMyTerminal;
		_fieldObj.addItemObject(self.displayEntryTerminal(tmpTerminal), tmpTerminal);
	endforeach;
	
	if _terminalObj &lt;&gt; null then
		_fieldObj.setForObject(_terminalObj);
	endif;
end;</source>
        <Parameter name="_fieldObj" type="CMUI_FieldComboBox"/>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="findLocationsFromObject" id="4ff4c17d-4528-48cd-959f-db0594c8d985">
        <updating/>
        <source>findLocationsFromObject( _object : Object; _objArray : CM_ObjectArray io ) updating;


/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 September 2011	cnwndl1	Initial creation	Par 28236

*/

vars

	termArea : CM_TerminalArea;
	gridObject : CM_GridObject;

begin

	if _object = null then
		return;
	endif;
	
	if _object.isKindOf(CM_TerminalArea) then
		termArea := _object.CM_TerminalArea;
		if termArea.isKindOf(CM_GridArea) then
			_objArray.add( termArea.CM_GridArea.allGridControllersByRowColumn.first );
			_objArray.add( termArea.CM_GridArea.allGridControllersByRowColumn.last );
		else
		endif;
		
	elseif _object.isKindOf(CM_GridObject) then
		gridObject := _object.CM_GridObject;
		if gridObject.isKindOf( CM_GridRow ) then
			_objArray.add( gridObject.CM_GridRow.allControllersByColumn.first );
			_objArray.add( gridObject.CM_GridRow.allControllersByColumn.last );	
		elseif gridObject.isKindOf( CM_GridColumn ) then
			_objArray.add( gridObject.CM_GridColumn.allControllersByRow.first );
			_objArray.add( gridObject.CM_GridColumn.allControllersByRow.last );
		endif;
		
	endif;

epilog

end;</source>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_objArray" type="CM_ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="generateCargoIdForBargeCargo" id="a48c31d4-87d1-4f5f-8019-2e4d8ce44a8e">
        <source>generateCargoIdForBargeCargo(_voyageCode : String; _number : Integer; _vessel : CM_Vessel) : String;
//
// Purpose:				Generate the cargo ID for bulk barge cargo - made from Voyage Code Prefix + Barge ID, 
//						where Barge ID is the 3-digitnumber at the end of the vessel name, 
//						or the entire vessel name if it doesn't end in 3 digits
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 28/05/2021	navdap1		Initial creation TFS 50878 ASPA Bulk Barge Cargo Creation
//
vars
	prefix, vesselName, vesselChar : String;
	number, padLength : Integer;
	cargoId : String;

begin
	prefix := _voyageCode.trimBlanks.toUpper;
	number := _number;
	if number &lt; 10 then
		padLength := 1;
	else
		padLength := 2;
	endif;
	
	vesselName := _vessel.code;
	vesselChar := vesselName[vesselName.length-2:end];
	if vesselChar.isInteger then
		cargoId := (prefix &amp; vesselChar);
		cargoId.replaceChar(Space.Character, CN_UNDERSCORE);
	else
		cargoId := (prefix &amp; vesselName);
		cargoId.replaceChar(Space.Character, CN_UNDERSCORE);
	endif;
	
	return cargoId[1:20];
epilog

end;</source>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_number" type="Integer"/>
        <Parameter name="_vessel" type="CM_Vessel"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllAttribNamesForProductTyp" id="11294d91-9de0-476a-aa0a-d765b54f0788">
        <source>getAllAttribNamesForProductTyp(_cargoType : CM_CargoType; _allAttribNamesForProdType : StringArray input);
/* ---------------------------------------------------------------------------
Created:	27 May 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	entDef	: EntTableDef;
	entRow	: EntTableRow;
	invalidObject	: Boolean;
begin
	on Exception do app.handleDeletedObject (exception, _cargoType, invalidObject);	//05/11/2009 cnwdz2 par20811
	
	if _cargoType &lt;&gt; null and _cargoType.isSubCargoTypeRequired then
		_cargoType.allAttributesOnProduct.copy(_allAttribNamesForProdType);
		
	else	// when cargo type is to be created, all attributes retrieved from EntTableDef
	
		entDef := app.myController.getEntTableDef(ETDef_AllAttributes);
		_allAttribNamesForProdType.clear();
		
		foreach entRow in entDef.allEntTableRows do
			_allAttribNamesForProdType.add(entRow.name);
		endforeach;
	
	endif;

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_allAttribNamesForProdType" type="StringArray" usage="input"/>
    </JadeMethod>
