    <JadeMethod name="jssUnqualName" id="6cb502e5-dabb-4da2-ab50-349dafb0d7e6">
        <source>jssUnqualName() :String;
// Return only the unqualified filename (after the FINAL "\").
vars
	charIndex	: Integer;
	lastCharPos	: Integer;

begin
	charIndex	:=	1;

	while charIndex &lt;&gt; 0 do
		lastCharPos	:=	charIndex;
		charIndex	:=	fileName.pos("\", (lastCharPos + 1));
	endwhile;

	return fileName[(lastCharPos + 1):end];	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
