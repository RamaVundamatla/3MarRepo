    <JadeMethod name="benchmarkingScript" id="2a8223c5-bdba-416d-a10e-e5c23606f1f8">
        <source>benchmarkingScript();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2025		navma1	Initial creation

*/

vars
    oldWay    	 : Boolean;
    dts,dte   	 : Decimal[19];
    s,t,u,v      : String;
    i,j,reps   	 : Integer;
	root	   	 : CM_Root;
	voyageProc 	 : CM_VoyageProcess;
	term	  	 : CM_Terminal;
	jobSheetDict : CM_WPJobSheetByDate;
	jobsheet	 : CM_WorkPointJobSheet;
	jobSheetSize : Integer;
	jobDict      : CM_JobsByRequiredDTPriority;
begin
	app.initialize;
	term := app.myRoot.allTerminals['WO'];
	
	
    write CrLf &amp; "Starting...";
    reps   := 100000;  // adjust this to get a run length of 1 to 10 seconds
    oldWay := true;
    dts    := app.relativeMachineTime;
    
	create jobSheetDict transient;
	create jobDict transient;
	if oldWay then

		write app.actualTimeServer.asStringJMT;
	
		
		
	else
	
		
		write app.actualTimeAppServer.asStringJMT;
		

		
	endif;
	/*
	foreach i in 1 to reps do
        if oldWay then
           //voyageProc := CM_VoyageProcessDefault.firstInstance;
		    app.actualTimeServer;
        else
			//voyageProc := app.myRoot.allVoyageProcesses['MTN'];
			app.actualTimeAppServer;
        endif;
    endforeach;
	*/
    dte := app.relativeMachineTime;
	write "OLD WAY  : " &amp;oldWay.asStringJMT(); 
    write "&lt;" &amp; s &amp; "&gt;" &amp; "&lt;" &amp; t &amp; "&gt;";  // to verify the functional results
    write ((dte-dts)/reps).roundedTo(6).String &amp; " ms/rep";
	write ((dte-dts)).roundedTo(6).String &amp; " ms";
	
epilog
    delete jobSheetDict;
	delete jobDict;
	write "Finished";
	
end;</source>
    </JadeMethod>
    <JadeMethod name="benchmarkingScriptCloneSelf" id="1d851cc0-3413-4f41-b77d-d26fcb3582c8">
        <source>benchmarkingScriptCloneSelf();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2025		navma1	Initial creation

*/

vars
    oldWay    	 : Boolean;
    dts,dte   	 : Decimal[19];
    s,t,u,v      : String;
    i,j,reps   	 : Integer;
	root	   	 : CM_Root;
	voyageProc 	 : CM_VoyageProcess;
	term	  	 : CM_Terminal;
	jobSheetDict : CM_WPJobSheetByDate;
	jobsheet	 : CM_WorkPointJobSheet;
	jobSheetSize : Integer;
	jobDict      : CM_JobsByRequiredDTPriority;
	woSet : CM_WorkOrderDtlSet;
begin
	app.initialize;
	term := app.myRoot.allTerminals['WO'];
	
	
    write CrLf &amp; "Starting...";
    reps   := 100000;  // adjust this to get a run length of 1 to 10 seconds
    oldWay := false;
    dts    := app.relativeMachineTime;
    
	create jobSheetDict transient;
	create woSet transient;
	if oldWay then
		/*
		term.allJobSheetsForWorkPoints.copy(jobSheetDict);
		foreach jobsheet in jobSheetDict discreteLock do
			jobSheetSize := jobSheetSize +1;
		endforeach;
		write "JobSheet Size : " &amp; jobSheetSize.String;
		*/
		woSet := term.myWOJobSheet.allWorkOrderDetails.cloneSelf(true);
		
		write "JobSheet Size : " &amp; woSet.size.String;
	else
		 term.myWOJobSheet.allWorkOrderDetails.copy(woSet);
		
		write "JobSheet Size : " &amp; woSet.size.String;
		
	endif;
	/*
	foreach i in 1 to reps do
        if oldWay then
           //voyageProc := CM_VoyageProcessDefault.firstInstance;
		    app.actualTimeServer;
        else
			//voyageProc := app.myRoot.allVoyageProcesses['MTN'];
			app.actualTimeAppServer;
        endif;
    endforeach;
	*/
    dte := app.relativeMachineTime;
	write "OLD WAY  : " &amp;oldWay.asStringJMT(); 
    write "&lt;" &amp; s &amp; "&gt;" &amp; "&lt;" &amp; t &amp; "&gt;";  // to verify the functional results
    write ((dte-dts)/reps).roundedTo(6).String &amp; " ms/rep";
	write ((dte-dts)).roundedTo(6).String &amp; " ms";
	
epilog
    delete jobSheetDict;
	delete jobDict;
	write "Finished";
	
end;</source>
    </JadeMethod>
