    <JadeMethod name="btnFind_click" id="300c48c2-23ec-4f7b-a32d-3ca4810b9ad3">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnFind_click(btn: Button input) updating;

begin
	self.jtdFindClassOrMethodByName(1);
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnNext_click" id="b9226984-358b-4a5a-b3ff-d20df0a2b1dc">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnNext_click(btn: Button input) updating;

begin
	self.jtdFindClassOrMethodByName(self.lstMethods.listIndex + 1);
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="chkRunOnce_click" id="644bccf8-06ef-40c6-8cce-eacac24bb96e">
        <controlMethod name="CheckBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkRunOnce_click(checkbox: CheckBox input) updating;

begin
	if self.jtdMySelectedDriverProfile &lt;&gt; null then
		self.jtdMySelectedDriverProfile.jtdSetStopWhenAllRun(checkbox.value);
		self.jtdUnsavedChanges := true;
	endif;
end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="chkStatusEnabled_click" id="682784e1-fb32-4709-a08c-eb3dfee61f5f">
        <controlMethod name="CheckBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkStatusEnabled_click(checkbox: CheckBox input) updating;

begin
	self.jtdUnsavedChanges := true;
end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="fraSplitterHorz_mouseDown" id="ee0251c0-0190-4271-941f-e6383199d39a">
        <controlMethod name="Frame::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>fraSplitterHorz_mouseDown(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;

begin
	self.jtdSplitterMoving := true;
	self.drawMode := 7; // xor
	self.autoRedraw := false;
	self.clipControls := false;
	self.drawWidth := 4;
	self.drawStyle := 0;
	self.jtdMouseMileage := self.fraSplitterHorz.top;
	self.drawLine(0, self.jtdMouseMileage + 3, self.fraSplitterVert.left, self.jtdMouseMileage + 3, White);
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="fraSplitterHorz_mouseMove" id="d7e91d6f-29e7-42a7-9d7b-597b4e84588c">
        <controlMethod name="Frame::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>fraSplitterHorz_mouseMove(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;

vars
	pos : Integer;

begin
	if not self.jtdSplitterMoving then
		return;
	endif;
	
	pos := (self.fraSplitterHorz.top + y).Integer;
	if pos &lt; 10 or pos &gt; (self.clientHeight - 10) then
		return;
	endif;
	
	self.drawLine(0, self.jtdMouseMileage + 3, self.fraSplitterVert.left, self.jtdMouseMileage + 3, White);
	self.jtdMouseMileage := pos;
	self.drawLine(0, self.jtdMouseMileage + 3, self.fraSplitterVert.left, self.jtdMouseMileage + 3, White);
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="fraSplitterHorz_mouseUp" id="5f5f5d4f-b59f-4d13-a568-fe9798ccd9bc">
        <controlMethod name="Frame::mouseUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>fraSplitterHorz_mouseUp(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;

begin
	if not self.jtdSplitterMoving then
		return;
	endif;
	
	self.drawLine(0, self.jtdMouseMileage + 3, self.fraSplitterVert.left, self.jtdMouseMileage + 3, White);
	self.fraSplitterHorz.top := self.jtdMouseMileage;
	self.jtdSplitterMoving := false;

	self.jtdResizeTheLot;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="fraSplitterVert_mouseDown" id="ba000770-8a22-4690-8e0e-67f4c27f3782">
        <controlMethod name="Frame::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>fraSplitterVert_mouseDown(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;

begin
	self.jtdSplitterMoving := true;
	self.drawMode := 7; // xor
	self.autoRedraw := false;
	self.clipControls := false;
	self.drawWidth := 4;
	self.drawStyle := 0;
	self.jtdMouseMileage := self.fraSplitterVert.left;
	self.drawLine(self.jtdMouseMileage + 3, 0, self.jtdMouseMileage + 3, self.clientHeight, White);
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="fraSplitterVert_mouseMove" id="192a6b3c-a777-47ae-baa9-3f8b8d6bf6d1">
        <controlMethod name="Frame::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>fraSplitterVert_mouseMove(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;

vars
	pos : Integer;

begin
	if not self.jtdSplitterMoving then
		return;
	endif;
	
	pos := (self.fraSplitterVert.left + x).Integer;
	if pos &lt; 10 or pos &gt; (self.clientWidth - 10) then
		return;
	endif;

	self.drawLine(self.jtdMouseMileage + 3, 0, self.jtdMouseMileage + 3, self.clientHeight, White);
	self.jtdMouseMileage := pos;
	self.drawLine(self.jtdMouseMileage + 3, 0, self.jtdMouseMileage + 3, self.clientHeight, White);
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="fraSplitterVert_mouseUp" id="8832d9bb-d8ed-4c3e-80bd-5bc99b7ff803">
        <controlMethod name="Frame::mouseUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>fraSplitterVert_mouseUp(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;

begin
	if not self.jtdSplitterMoving then
		return;
	endif;
	
	self.drawLine(self.jtdMouseMileage + 3, 0, self.jtdMouseMileage + 3, self.clientHeight, White);
	self.fraSplitterVert.left := self.jtdMouseMileage;
	self.jtdSplitterMoving := false;

	self.jtdResizeTheLot;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="jtdAddMethodProfile" id="7cf2c9b0-6931-4494-8ed2-68ab474e58f3">
        <updating/>
        <source>jtdAddMethodProfile(pos : Integer) updating, protected;

vars
	clsName, mthName : String;
	mp : JtdMethodProfile;
	dp : JtdDriverProfile;
	idx, n : Integer;
	tbl : Table;
	
begin
	dp := self.jtdMySelectedDriverProfile;

	if dp = null or self.jtdMySelectedMethod = null then
		return;
	endif;
	
	if not self.jtdGetSelectedClsAndMthName(clsName, mthName) then
		app.msgBox("The selected method is no longer valid. It may have been deleted." &amp;
			CrLf &amp; CrLf &amp; "The class and method list will be refreshed.", "Invalid Method",
			MsgBox_OK_Only + MsgBox_Information_Icon);
		self.jtdLoadMethodList(false);
		return;
	endif;
	
	if clsName = null or mthName = null then
		return;
	endif;

	create mp transient;
	mp.jtdSetClassAndMethodNames(clsName, mthName);
	mp.jtdSetNumCalls(1);

	tbl := self.jtdGetActiveProfileTable;
	
	if tbl = self.tblMthProfiles then
		n := dp.jtdAllMethodProfiles.size;
	elseif tbl = self.tblProlog then
		n := dp.jtdAllPrologProfiles.size;
	elseif tbl = self.tblEpilog then
		n := dp.jtdAllEpilogProfiles.size;
	else
		n := 0; // belts and braces
	endif;

	if tbl.row &lt;= tbl.fixedRows or tbl.row &gt; tbl.rows then
		// belts and braces: add the method profile at the end
		idx := n + 1;
	else
		if pos = self.JtdBeforeSelection then
			idx := tbl.row - tbl.fixedRows;
			if idx &gt; n then
				idx := n + 1;
			endif;
		elseif pos = self.JtdAfterSelection then
			idx := (tbl.row - tbl.fixedRows) + 1;
			if idx &gt; n then
				idx := n + 1;
			endif;
		else
			// add the new method profile at the end
			idx := n + 1;
		endif;
	endif;

	if tbl = self.tblMthProfiles then			
		dp.jtdAddMethodProfile(mp, idx);
	elseif tbl = self.tblProlog then
		dp.jtdAddPrologProfile(mp, idx);
	elseif tbl = self.tblEpilog then
		dp.jtdAddEpilogProfile(mp, idx);
	else
		// belts and braces: do nothing
	endif;

	self.jtdLoadMethodProfileTables;
	self.jtdSelectMethodProfileTableRow(tbl, idx + tbl.fixedRows);

	self.jtdUpdateSelDrvProfileMthCount;
			
	self.jtdUnsavedChanges := true;
end;</source>
        <access>protected</access>
        <Parameter name="pos" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jtdAddMethodProfileTableRow" id="691b2df5-16fb-45f4-8557-357884748a48">
        <source>jtdAddMethodProfileTableRow(mp : JtdMethodProfile; tbl : Table input; atRow : Integer) protected;

vars
	mth : Method;
	cls : Class;
		
begin
	if tbl = null then
		return;
	endif;
	
	tbl.addItemAt(Tab &amp; mp.jtdClassName &amp; "::" &amp; mp.jtdMethodName &amp; Tab &amp;
		mp.jtdNumCalls.String &amp; Tab &amp; mp.jtdThinkSecs.String, atRow);
			
	tbl.accessCell(atRow, self.JtdColMethodProfileObj).itemObject := mp;
		
	mth := null;
	cls := self.jtdMyDriverSchema.jtdGetClasses[mp.jtdClassName];
	if cls &lt;&gt; null then
		mth := cls.jtdGetMethods[mp.jtdMethodName];
	endif;
		
	if mth = null then
		tbl.accessedCell.picture := self.picCross.picture;
	else
		tbl.accessedCell.picture := self.picTick.picture;
		tbl.accessCell(atRow, self.JtdColMethodObj).itemObject := mth;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="mp" type="JtdMethodProfile"/>
        <Parameter name="tbl" type="Table" usage="input"/>
        <Parameter name="atRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jtdCreateDriverProfiles" id="eb070a04-85db-49d5-b014-b6ab6fb751a5">
        <updating/>
        <source>jtdCreateDriverProfiles() updating, protected;
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

begin
	self.jtdMyDefaultDriverProfile := null;
	self.jtdAllDriverProfiles.purge;

	// save the method text from which we build our profiles so we
	// can check whether or not it's been changed prior to saving
	self.jtdOriginalProfileText := self.jtdMyProfileTextMethod.text;

	app.createDriverProfilesFromMethod(self.jtdMyProfileTextMethod,
		self.jtdAllDriverProfiles, true);
		
	self.jtdMyDefaultDriverProfile :=
		self.jtdAllDriverProfiles[self.jtdGetDefaultProfileName];
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="jtdDeleteSelectedDriverProfile" id="00fcf015-dca7-41f5-90c8-fdc28ff56897">
        <updating/>
        <source>jtdDeleteSelectedDriverProfile() updating, protected;

vars
	dp : JtdDriverProfile;
	
begin
	dp := self.jtdMySelectedDriverProfile;
	if dp = null then
		return;
	endif;
	
	if app.msgBox("Are you sure you want to delete the currently selected profile?",
		"Please Confirm", MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_Yes
	then
		return;
	endif;

	if self.jtdMyDefaultDriverProfile = dp then
		self.jtdMyDefaultDriverProfile := null;
	endif;
	
	self.jtdAllDriverProfiles.remove(dp);
	delete dp;

	self.jtdSetSelectedDriverProfile(null);
	
	self.jtdLoadDriverProfileList;
	self.jtdUnsavedChanges := true;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="jtdDeleteSelectedMethodProfile" id="cb34149b-7524-4b41-80ea-2f828d6ff542">
        <updating/>
        <source>jtdDeleteSelectedMethodProfile() updating, protected;

vars
	mp : JtdMethodProfile;
	
begin
	mp := self.jtdMySelectedMethodProfile;
	if mp = null then
		return;
	endif;
	
	if app.msgBox("Are you sure you want to remove the currently selected method from the profile?",
		"Please Confirm", MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_Yes
	then
		return;
	endif;

	self.jtdMySelectedMethodProfile := null;
	
	delete mp;
	
	self.jtdLoadMethodProfileTables;
	
	self.jtdUpdateSelDrvProfileMthCount;
	
	self.jtdUnsavedChanges := true;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="jtdDeleteUnresolvedMthProfiles" id="80028272-c6a6-410f-8550-a764619cffbe">
        <updating/>
        <source>jtdDeleteUnresolvedMthProfiles() updating, protected;

vars
	mpa : JtdMethodProfileArray;
	mp : JtdMethodProfile;
	oa : ObjectArray;
	cls : Class;
	tbl : Table;
	
begin
	tbl := self.jtdGetActiveProfileTable;
	
	if self.jtdMySelectedDriverProfile = null or self.jtdMyDriverSchema = null or tbl = null then
		return;
	endif;

	if app.msgBox("Are you sure you want to remove all unresolved methods from the profile?",
		"Please Confirm", MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_Yes
	then
		return;
	endif;

	self.jtdMySelectedMethodProfile := null;
	
	if tbl = self.tblMthProfiles then
		mpa := self.jtdMySelectedDriverProfile.jtdAllMethodProfiles;
	elseif tbl = self.tblProlog then
		mpa := self.jtdMySelectedDriverProfile.jtdAllPrologProfiles;
	elseif tbl = self.tblEpilog then
		mpa := self.jtdMySelectedDriverProfile.jtdAllEpilogProfiles;
	else
		mpa := null;
	endif;

	if mpa &lt;&gt; null then
		create oa transient;
		
		foreach mp in mpa do
			cls := self.jtdMyDriverSchema.jtdGetClasses[mp.jtdClassName];
			if cls = null or cls.jtdGetMethods[mp.jtdMethodName] = null then
				oa.add(mp);
			endif;
		endforeach;

		// delete method profiles via a temporary array as arrays cannot be updated
		// during iteration (deleting mp within the above foreach loop would cause
		// an automatic update to jtdAllMethodProfiles, jtdAllPrologProfiles and/or
		// jtdAllEpilogProfiles through inverse maintenance)
		oa.purge;
	endif;

	self.jtdLoadMethodProfileTables;

	self.jtdUpdateSelDrvProfileMthCount;
	
	self.jtdUnsavedChanges := true;
	
epilog
	delete oa;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="jtdDoAddProfile" id="241186ec-deec-4b83-a794-59503eb8e219">
        <updating/>
        <source>jtdDoAddProfile() updating, protected;

vars
	dp : JtdDriverProfile;
	s : String;
	
begin
	if not app.readString("Enter a name for the new profile", 50, s) then
		return;
	endif;

	s := s.trimBlanks;
	
	if s = null then
		app.msgBox("Profile names cannot be null." &amp; CrLf &amp; CrLf &amp;
			"The new profile will not be created.",	"Invalid Profile Name",
			MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
		
	dp := self.jtdAllDriverProfiles[s];
	
	if dp &lt;&gt; null then
		app.msgBox("A profile already exists with this name." &amp; CrLf &amp; CrLf &amp;
			"The new profile will not be created.",	"Name Already Used",
			MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	create dp transient;
	dp.jtdSetName(s);
	self.jtdAllDriverProfiles.add(dp);

	self.jtdLoadDriverProfileList;
	
	self.jtdSetSelectedDriverProfile(dp);

	self.jtdUnsavedChanges := true;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="jtdDoRenameProfile" id="48a377e6-5bf8-421f-ac66-35df020dcd60">
        <updating/>
        <source>jtdDoRenameProfile() updating, protected;

vars
	dp : JtdDriverProfile;
	s : String;
	
begin
	if self.jtdMySelectedDriverProfile = null then
		return;
	endif;

	if not app.readString("Enter a new name for '" &amp;
		self.jtdMySelectedDriverProfile.jtdName &amp; "'", 50, s)
	then
		return;
	endif;
	
	s := s.trimBlanks;
	
	if s = null then
		app.msgBox("Profile names cannot be null." &amp; CrLf &amp; CrLf &amp;
			"The currently selected profile will not be renamed.",
			"Invalid Profile Name", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	dp := self.jtdAllDriverProfiles[s];
	
	if dp = self.jtdMySelectedDriverProfile then
		return;
	endif;
	
	if dp &lt;&gt; null then
		app.msgBox("A profile already exists with this name." &amp; CrLf &amp; CrLf &amp;
			"The currently selected profile will not be renamed.",
			"Name Already Used", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	dp := self.jtdMySelectedDriverProfile;
	self.jtdAllDriverProfiles.remove(dp);
	dp.jtdSetName(s);
	self.jtdAllDriverProfiles.add(dp);

	self.jtdLoadDriverProfileList;
	
	self.jtdSetSelectedDriverProfile(dp);

	self.jtdUnsavedChanges := true;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="jtdDoSetDefaultProfile" id="f3739120-653b-41d5-8905-9d7dd57d2b1b">
        <updating/>
        <source>jtdDoSetDefaultProfile() updating, protected;

vars
	dp, dpDefault : JtdDriverProfile;
	i, n : Integer;
	lst : ListBox;
	obj : Object;
	s : String;

begin
	if self.jtdMySelectedDriverProfile = null then
		return;
	endif;
	
	if self.jtdMyDefaultDriverProfile = self.jtdMySelectedDriverProfile then
		self.jtdMyDefaultDriverProfile := null;
	else
		self.jtdMyDefaultDriverProfile := self.jtdMySelectedDriverProfile;
	endif;
	
	self.jtdUnsavedChanges := true;

	dpDefault := self.jtdMyDefaultDriverProfile;
	lst := self.lstDrvProfiles;
	n := lst.listCount;
	
	foreach i in 1 to n do
		obj := lst.itemObject[i];
		
		if obj = null or (not JtdDriverProfile.hasInstance(obj)) then
			continue;
		endif;
		
		dp := obj.JtdDriverProfile;

		s := dp.jtdName &amp; " [" &amp; dp.jtdGetTotalMethods.String &amp; ']';
		if dpDefault &lt;&gt; null and dpDefault = dp then
			s := s &amp; " (Default)";
		endif;

		lst.itemText[i] := s;
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="jtdDoTableChange" id="f607f535-6137-4990-a8f2-46a45274b25a">
        <updating/>
        <source>jtdDoTableChange(table : Table input) updating, protected;

vars
	n : Integer;
	
begin
	if self.jtdMySelectedMethodProfile &lt;&gt; null then
		if table.column = 3 then
			self.jtdMySelectedMethodProfile.jtdSetNumCalls(table.text.Integer);
			self.jtdUnsavedChanges := true;

		elseif table.column = 4 then
			n := table.text.Integer;
			self.jtdMySelectedMethodProfile.jtdSetThinkSecs(n);
			if self.jtdMySelectedMethodProfile.jtdThinkSecs &lt;&gt; n then
				table.text := self.jtdMySelectedMethodProfile.jtdThinkSecs.String;
			endif;
			self.jtdUnsavedChanges := true;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="jtdDoTableKeyDown" id="8c1158c4-8d04-4b94-89e1-b512ba2e02b4">
        <updating/>
        <source>jtdDoTableKeyDown(table : Table input; keyCode : Integer io; shift : Integer) updating, protected;

begin
	if keyCode = 46 then                    // delete key
		if table.column &lt; 3 then
			self.jtdDeleteSelectedMethodProfile;
			keyCode := 0;
		endif;

	elseif keyCode = 38 then                // up arrow
		if shift.bitAnd(2) &lt;&gt; 0 then        // is ctrl key down?
			self.jtdMoveSelectedMthProfileUp;
			keyCode := 0;
		endif;
	
	elseif keyCode = 40 then                // down arrow
		if shift.bitAnd(2) &lt;&gt; 0 then        // is ctrl key down?
			self.jtdMoveSelectedMthProfileDown;
			keyCode := 0;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jtdDoTableMouseDown" id="aeb5c611-5f63-4b7e-a19d-2691fb4d0983">
        <updating/>
        <source>jtdDoTableMouseDown(table : Table input; button, shift : Integer; x, y : Real) updating, protected;

vars
	r, c : Integer;
	
begin
	if button &lt;&gt; Window.MouseButton_Right then
		return;
	endif;

	self.jtdMySelectedMethodProfile := null;	
	table.clearAllSelected;
	
	if not table.getCellFromPosition(x, y, r, c) then
		return;
	endif;

	if r &lt; 1 or r &lt;= table.fixedRows or r &gt; table.rows then
		return;
	endif;
	
	self.jtdSelectMethodProfileTableRow(table, r);
	
	self.popupMenu(self.mnuProfile, (self.fldProfiles.left + table.parent.left + table.left + x).Integer,
		(self.fldProfiles.top + table.parent.top + table.top + y).Integer);
end;</source>
        <access>protected</access>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="jtdEnableMenuItems" id="c3ee4052-f189-4398-b039-faa2ebe6e69a">
        <source>jtdEnableMenuItems() protected;

vars
	b : Boolean;
	
begin
	b := self.jtdMySelectedMethodProfile &lt;&gt; null;
	
	self.mnuProfileAddAfter.enabled := b and self.jtdMySelectedMethod &lt;&gt; null;
	self.mnuProfileAddBefore.enabled := b and self.jtdMySelectedMethod &lt;&gt; null;
	self.mnuProfileMoveDown.enabled := b and not self.jtdMySelectedMethodProfile.jtdIsLast;
	self.mnuProfileMoveEnd.enabled := b and not self.jtdMySelectedMethodProfile.jtdIsLast;
	self.mnuProfileMoveStart.enabled := b and not self.jtdMySelectedMethodProfile.jtdIsFirst;
	self.mnuProfileMoveUp.enabled := b and not self.jtdMySelectedMethodProfile.jtdIsFirst;
	self.mnuProfileRemove.enabled := b;
	self.mnuProfileAddAtEnd.enabled := self.jtdMySelectedMethod &lt;&gt; null;

	b := self.jtdMySelectedDriverProfile &lt;&gt; null;
	
	self.mnuProfileDefault.enabled := b;
	self.mnuProfileDefault.checked := self.jtdMySelectedDriverProfile = self.jtdMyDefaultDriverProfile;

	self.mnuFileDeleteProfile.enabled := b;
	self.mnuFileRenameProfile.enabled := b;
	
	self.mnuProfilePopupDelete.enabled := b;
	self.mnuProfilePopupRename.enabled := b;
	self.mnuProfilePopupDefault.enabled := b;
	self.mnuProfilePopupDefault.checked := self.mnuProfileDefault.checked;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="jtdFindClassOrMethodByName" id="ca754481-465b-476f-ab57-261b3488d54f">
        <updating/>
        <source>jtdFindClassOrMethodByName(startIndex : Integer) updating, protected;

vars
	lst : ListBox;
	n : Integer;
	s : String;
	
begin
	s := self.txtFind.text.trimBlanks;
	
	if s = null then
		return;
	endif;
	
	lst := self.lstMethods;
	
	if lst.listCount &lt; 1 or startIndex &gt; lst.listCount then
		return;
	endif;

	if startIndex &lt;= 1 then
		n := lst.findString(1, s);
	else
		n := lst.findString(startIndex, s);
	endif;
	
	if n &gt; 0 and n &lt;= lst.listCount then
		lst.listIndex := n;
		self.jtdMySelectedMethod := lst.itemObject[n].Method;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="startIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jtdGetActiveProfileTable" id="e6e6e338-c091-4016-be3c-7486d0dc3f8e">
        <source>jtdGetActiveProfileTable() : Table protected;

vars
	sht : Sheet;
	
begin
	sht := self.fldProfiles.topSheet;
	
	if sht = self.shtMain then
		return self.tblMthProfiles;
	endif;
	
	if sht = self.shtProlog then
		return self.tblProlog;
	endif;
	
	if sht = self.shtEpilog then
		return self.tblEpilog;
	endif;
	
	return null; // belts and braces
end;</source>
        <access>protected</access>
        <ReturnType type="Table"/>
    </JadeMethod>
    <JadeMethod name="jtdGetDefaultAutoPingInterval" id="e3f114f9-ddf3-490b-866f-d674ae1546a3">
        <source>jtdGetDefaultAutoPingInterval() : Integer protected;

vars
	n, startPos : Integer;
	s : String;
	
begin
	if self.jtdMyProfileTextMethod = null then
		return 0;
	endif;
	
	s := self.jtdMyProfileTextMethod.text.trimBlanks;
	
	if s = null then
		return 0;
	endif;

	n := s.pos(JtdDriverProfile.JtdTagDefaultAutoPingInterval, 1);
	
	if n &lt; 1 then
		return 0;
	endif;
	
	startPos := s.pos(' ', n);
	
	if startPos &lt;= n then
		return 0;
	endif;
	
	n := s.pos(';', startPos);
	
	if n &lt;= startPos then
		return 0;
	endif;
	
	return s[startPos : n - startPos].trimBlanks.Integer;
end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jtdGetDefaultProfileName" id="43158ef8-daf7-4800-959d-9005b4507316">
        <source>jtdGetDefaultProfileName() : String protected;
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

vars
	n, startPos : Integer;
	s : String;
	
begin
	if self.jtdMyProfileTextMethod = null then
		return null;
	endif;


	s := self.jtdMyProfileTextMethod.text.trimBlanks;
	
	if s = null then
		return null;
	endif;

	n := s.pos(JtdDriverProfile.JtdTagDefaultProfileName, 1);
	
	if n &lt; 1 then
		return null;
	endif;
	
	startPos := s.pos(' ', n);
	
	if startPos &lt;= n then
		return null;
	endif;
	
	n := s.pos(';', startPos);
	
	if n &lt;= startPos then
		return null;
	endif;
	
	return s[startPos : n - startPos].trimBlanks;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jtdGetDefaultStatusDisplay" id="707d2930-e76a-4083-b48c-8c9cc5442671">
        <source>jtdGetDefaultStatusDisplay() : Boolean protected;

vars
	n, startPos : Integer;
	s : String;
	
begin
	if self.jtdMyProfileTextMethod = null then
		return null;
	endif;

	s := self.jtdMyProfileTextMethod.text.trimBlanks;
	
	if s = null then
		return true;
	endif;

	n := s.pos(JtdDriverProfile.JtdTagDefaultStatusDisplay, 1);
	
	if n &lt; 1 then
		return true;
	endif;
	
	startPos := s.pos(' ', n);
	
	if startPos &lt;= n then
		return true;
	endif;
	
	n := s.pos(';', startPos);
	
	if n &lt;= startPos then
		return true;
	endif;

	return s[startPos : n - startPos].trimBlanks.toLower = "on";
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jtdGetSelectedClsAndMthName" id="5481ee75-e793-491e-81e1-f80fc197799e">
        <source>jtdGetSelectedClsAndMthName(clsName, mthName : String output) : Boolean protected;

vars
	errNo : Integer;
	
begin
	clsName := null;
	mthName := null;
	
	if self.jtdMySelectedMethod = null then
		return true;
	endif;

	errNo := 0;
	
	on Exception do self.jtdResumeNextExHandler(exception, errNo);

	clsName := self.jtdMySelectedMethod.jtdGetSchemaTypeName;
	
	mthName := self.jtdMySelectedMethod.name;
	
	return errNo = 0;
end;</source>
        <access>protected</access>
        <Parameter name="clsName" type="String" usage="output"/>
        <Parameter name="mthName" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jtdHandleMethodCreated" id="c30f887a-35c4-4e06-b2de-c26158a346eb">
        <updating/>
        <source>jtdHandleMethodCreated(mth : Method) updating, protected;

vars
	clsName, mthName : String;
	mp : JtdMethodProfile;
	i, j, n : Integer;
	rootCls : Class;
	scmType : Type;
	tbl : Table;
	
begin
	if mth = null then
		return;
	endif;

	scmType := mth.schemaType;
	
	if scmType = null or
	   scmType.schema &lt;&gt; self.jtdMyDriverSchema or (not scmType.isKindOf(Class))
	then
		return;
	endif;

	rootCls:= scmType.Class.rootType;

	if rootCls.abstract then
		return;
	endif;
	
	if rootCls = self.jtdMyTrxGenRootClass or rootCls = self.jtdMyReadTrxGenRootClass or
	   rootCls = self.jtdMyUpdTrxGenRootClass
	then
		return;
	endif;
	
	if (not rootCls.inheritsFrom(self.jtdMyReadTrxGenRootClass)) and
	   (not rootCls.inheritsFrom(self.jtdMyUpdTrxGenRootClass))
	then
		return;
	endif;

	clsName := rootCls.name;
	mthName := mth.name;

	foreach j in 1 to 3 do
		if j = 1 then				
			tbl := self.tblMthProfiles;
		elseif j = 2 then
			tbl := self.tblProlog;
		else
			tbl := self.tblEpilog;
		endif;
		
		n := tbl.rows;

		foreach i in tbl.fixedRows + 1 to n do
			if tbl.accessCell(i, self.JtdColMethodObj).itemObject = null then
				mp := tbl.accessCell(i, self.JtdColMethodProfileObj).itemObject.JtdMethodProfile;
			
				if mp &lt;&gt; null and mp.jtdClassName = clsName and mp.jtdMethodName = mthName then
					tbl.accessCell(i, 1).picture := self.picTick.picture;
					tbl.accessCell(i, self.JtdColMethodObj).itemObject := mth;
				endif;
			endif;
		endforeach;
	endforeach;

	self.jtdLoadMethodList(true);
end;</source>
        <access>protected</access>
        <Parameter name="mth" type="Method"/>
    </JadeMethod>
    <JadeMethod name="jtdHandleMethodDeleted" id="ea6be2d5-5337-430b-b792-6d3f89566663">
        <updating/>
        <source>jtdHandleMethodDeleted(obj : Object) updating, protected;

vars
	i, j, n, clsRow : Integer;
	lst : ListBox;
	tbl : Table;
	
begin
	if obj = null then
		return;
	endif;

	foreach j in 1 to 3 do
		if j = 1 then				
			tbl := self.tblMthProfiles;
		elseif j = 2 then
			tbl := self.tblProlog;
		else
			tbl := self.tblEpilog;
		endif;
			
		n := tbl.rows;

		foreach i in tbl.fixedRows + 1 to n do
			if tbl.accessCell(i, self.JtdColMethodObj).itemObject = obj then
				tbl.accessedCell.itemObject := null;
				tbl.accessCell(i, 1).picture := self.picCross.picture;
			endif;
		endforeach;
	endforeach;

	lst := self.lstMethods;
	clsRow := 0;
	n := lst.listCount;

	foreach i in 1 to n do
		if lst.itemLevel[i] = 1 then
			clsRow := i;
		elseif lst.itemObject[i] = obj then
			lst.removeItem(i);
			if clsRow = i - 1 and (i &gt; lst.listCount or lst.itemLevel[i] = 1) then
				lst.removeItem(clsRow);
			endif;
			self.jtdMySelectedMethod := null;
			return;
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="jtdLoadDriverProfileList" id="3f9194ba-e03d-4a55-9591-dac4665ef7cc">
        <updating/>
        <source>jtdLoadDriverProfileList() updating, protected;

vars
	dp : JtdDriverProfile;
	s : String;
	
begin
	self.lstDrvProfiles.clear;
	
	foreach dp in self.jtdAllDriverProfiles do
		s := dp.jtdName &amp; " [" &amp; dp.jtdGetTotalMethods.String &amp; ']';
		
		if self.jtdMyDefaultDriverProfile = dp then
			s := s &amp; " (Default)";
		endif;
			
		self.lstDrvProfiles.addItem(s);
		self.lstDrvProfiles.itemObject[self.lstDrvProfiles.newIndex] := dp;
		self.lstDrvProfiles.itemPicture[self.lstDrvProfiles.newIndex] := self.lstDrvProfiles.pictureLeaf;
	endforeach;
	
	self.jtdSetSelectedDriverProfile(null);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="jtdLoadMethodList" id="aeae1940-7acd-402c-aeb7-2c7ef76debc4">
        <updating/>
        <source>jtdLoadMethodList(keepSelection : Boolean) updating, protected;

vars
	mthDict : MethodNDict;
	clsArray : ClassColl;
	clsDict : ClassNDict;
	selText : String;
	n, d : Integer;
	lst : ListBox;	
	mth : Method;
	cls : Class;

begin
	lst := self.lstMethods;
	
	selText := lst.text;
	d := lst.listIndex - lst.topIndex;
	
	lst.clear;
	self.jtdMySelectedMethod := null;
	
	create clsArray transient;
	
	self.jtdMyReadTrxGenRootClass.allSubclasses(clsArray);
	self.jtdMyUpdTrxGenRootClass.allSubclasses(clsArray);
	
	if clsArray.size &lt; 1 then
		return;
	endif;

	// we want the classes in alphabetical order
	create clsDict transient;
	clsArray.copy(clsDict);
	
	foreach cls in clsDict where not cls.abstract do
		mthDict := cls.jtdGetMethods;
		
		if mthDict.size &lt; 1 then
			continue;
		endif;
		
		lst.addItem(cls.name);
		lst.itemLevel[lst.newIndex] := 1;
		
		foreach mth in mthDict do
			lst.addItem(mth.name);
			lst.itemObject[lst.newIndex] := mth;
			lst.itemLevel[lst.newIndex] := 2;
		endforeach;
	endforeach;

	foreach n in 1 to lst.listCount do
		lst.itemExpanded[n] := true;
	endforeach;

	if keepSelection and selText &lt;&gt; null and lst.listCount &gt; 0 then
		n := lst.findStringExact(1, selText);

		if n &gt; 0 then
			lst.listIndex := n;
			if lst.itemLevel[n] = 2 then
				self.jtdMySelectedMethod := lst.itemObject[n].Method;
			endif;

			if d &lt;= 0 or n &lt;= d then
				lst.topIndex := n;
			else
				lst.topIndex := n - d;
			endif;
		endif;
	endif;
		
epilog
	delete clsArray;
	delete clsDict;
end;</source>
        <access>protected</access>
        <Parameter name="keepSelection" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jtdLoadMethodProfileTables" id="d03edab1-17fb-4ab1-bcce-87167a293db0">
        <source>jtdLoadMethodProfileTables() protected;

vars
	mpa : JtdMethodProfileArray;
	dp : JtdDriverProfile;
	mp : JtdMethodProfile;
	i, n : Integer;
	tbl : Table;
	
begin
	dp := self.jtdMySelectedDriverProfile;
	
	if dp = null then
		return;
	endif;

	foreach i in 1 to 3 do
		if i = 1 then
			tbl := self.tblMthProfiles;
			mpa := dp.jtdAllMethodProfiles;
		elseif i = 2 then
			tbl := self.tblProlog;
			mpa := dp.jtdAllPrologProfiles;
		else
			tbl := self.tblEpilog;
			mpa := dp.jtdAllEpilogProfiles;
		endif;
				
		n := tbl.fixedRows;
		tbl.rows := n;
	
		foreach mp in mpa do
			n := n + 1;
			self.jtdAddMethodProfileTableRow(mp, tbl, n);
		endforeach;
	endforeach;

	self.optRandom.value := dp.jtdRandomSelection;
	self.optInSequence.value := not self.optRandom.value;
	
	self.chkRunOnce.value := dp.jtdStopWhenAllRun;
	
	self.txtDefaultSecs.text := dp.jtdDefaultThinkSecs.String;
	
	self.shtMain.caption := self.JtdMainSheetCaption &amp; " [" &amp; dp.jtdAllMethodProfiles.size.String &amp; ']';
	self.shtProlog.caption := self.JtdPrologSheetCaption &amp; " [" &amp; dp.jtdAllPrologProfiles.size.String &amp; ']';
	self.shtEpilog.caption := self.JtdEpilogSheetCaption &amp; " [" &amp; dp.jtdAllEpilogProfiles.size.String &amp; ']';
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="jtdMoveSelectedMthProfileDown" id="f9b09806-395e-435f-94b5-4e1d634b2a12">
        <updating/>
        <source>jtdMoveSelectedMthProfileDown() updating, protected;

vars
	mp : JtdMethodProfile;
	dp : JtdDriverProfile;
	row : Integer;
	idx : Integer;
	tbl : Table;
	
begin
	tbl := self.jtdGetActiveProfileTable;
	row := tbl.row;
	idx := row - tbl.fixedRows;
	mp := self.jtdMySelectedMethodProfile;
	dp := self.jtdMySelectedDriverProfile;
	
	if dp = null or mp = null or tbl = null or row &lt;= tbl.fixedRows or row &gt;= tbl.rows or idx &lt; 1 then
		return;
	endif;

	if tbl = self.tblMthProfiles then
		dp.jtdRemoveMethodProfile(mp);
		dp.jtdAddMethodProfile(mp, idx + 1);

	elseif tbl = self.tblProlog then
		dp.jtdRemovePrologProfile(mp);
		dp.jtdAddPrologProfile(mp, idx + 1);
	
	elseif tbl = self.tblEpilog then
		dp.jtdRemoveEpilogProfile(mp);
		dp.jtdAddEpilogProfile(mp, idx + 1);
	endif;
	
	tbl.deleteRow(row);
	self.jtdAddMethodProfileTableRow(mp, tbl, row + 1);

	self.jtdSelectMethodProfileTableRow(tbl, row + 1);
		
	self.jtdUnsavedChanges := true;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="jtdMoveSelectedMthProfileToEnd" id="850f135f-ee6a-44e8-9a5a-4243aa174147">
        <updating/>
        <source>jtdMoveSelectedMthProfileToEnd() updating, protected;

vars
	mp : JtdMethodProfile;
	dp : JtdDriverProfile;
	tbl : Table;
	
begin
	mp := self.jtdMySelectedMethodProfile;
	dp := self.jtdMySelectedDriverProfile;
	tbl := self.jtdGetActiveProfileTable;
	
	if dp = null or mp = null or tbl = null then
		return;
	endif;

	if tbl = self.tblMthProfiles then
		dp.jtdRemoveMethodProfile(mp);
		dp.jtdAddMethodProfile(mp, 0);
		
	elseif tbl = self.tblProlog then
		dp.jtdRemovePrologProfile(mp);
		dp.jtdAddPrologProfile(mp, 0);
	
	elseif tbl = self.tblEpilog then
		dp.jtdRemoveEpilogProfile(mp);
		dp.jtdAddEpilogProfile(mp, 0);
	endif;

	self.jtdLoadMethodProfileTables;
		
	self.jtdSelectMethodProfileTableRow(tbl, tbl.rows);
		
	self.jtdUnsavedChanges := true;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="jtdMoveSelectedMthProfileToTop" id="cb08c60f-2cee-436b-88ae-04300e363fbc">
        <updating/>
        <source>jtdMoveSelectedMthProfileToTop() updating, protected;

vars
	mp : JtdMethodProfile;
	dp : JtdDriverProfile;
	tbl : Table;
	
begin
	mp := self.jtdMySelectedMethodProfile;
	dp := self.jtdMySelectedDriverProfile;
	tbl := self.jtdGetActiveProfileTable;
	
	if dp = null or mp = null or tbl = null then
		return;
	endif;

	if tbl = self.tblMthProfiles then
		dp.jtdRemoveMethodProfile(mp);
		dp.jtdAddMethodProfile(mp, 1);
		
	elseif tbl = self.tblProlog then
		dp.jtdRemovePrologProfile(mp);
		dp.jtdAddPrologProfile(mp, 1);
	
	elseif tbl = self.tblEpilog then
		dp.jtdRemoveEpilogProfile(mp);
		dp.jtdAddEpilogProfile(mp, 1);
	endif;

	self.jtdLoadMethodProfileTables;
		
	self.jtdSelectMethodProfileTableRow(tbl, tbl.fixedRows + 1);
		
	self.jtdUnsavedChanges := true;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="jtdMoveSelectedMthProfileUp" id="e8cc2f83-fd94-40cd-ae1e-48d816e62e28">
        <updating/>
        <source>jtdMoveSelectedMthProfileUp() updating, protected;

vars
	mp : JtdMethodProfile;
	dp : JtdDriverProfile;
	row : Integer;
	idx : Integer;
	tbl : Table;
	
begin
	tbl := self.jtdGetActiveProfileTable;
	row := tbl.row;
	idx := row - tbl.fixedRows;
	mp := self.jtdMySelectedMethodProfile;
	dp := self.jtdMySelectedDriverProfile;
	
	if dp = null or mp = null or tbl = null or row &lt;= tbl.fixedRows + 1 or row &gt; tbl.rows or idx &lt; 2 then
		return;
	endif;

	if tbl = self.tblMthProfiles then
		dp.jtdRemoveMethodProfile(mp);
		dp.jtdAddMethodProfile(mp, idx - 1);
		
	elseif tbl = self.tblProlog then
		dp.jtdRemovePrologProfile(mp);
		dp.jtdAddPrologProfile(mp, idx - 1);
	
	elseif tbl = self.tblEpilog then
		dp.jtdRemoveEpilogProfile(mp);
		dp.jtdAddEpilogProfile(mp, idx - 1);
	endif;

	tbl.deleteRow(row);
	self.jtdAddMethodProfileTableRow(mp, tbl, row - 1);

	self.jtdSelectMethodProfileTableRow(tbl, row - 1);
		
	self.jtdUnsavedChanges := true;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="jtdReload" id="0e34d040-2978-4b91-8c3e-c7e4ed77019c">
        <updating/>
        <source>jtdReload() updating, protected;
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

begin

	self.jtdDefaultAutoPingInterval := 0;
	self.jtdMySelectedMethodProfile := null;
	self.jtdSetSelectedDriverProfile(null);
	self.jtdMySelectedMethod := null;
	
	self.jtdCreateDriverProfiles;
	self.jtdLoadDriverProfileList;
	self.jtdLoadMethodList(false);

	self.jtdDefaultAutoPingInterval := self.jtdGetDefaultAutoPingInterval;
	self.txtDefAutoPing.text := self.jtdDefaultAutoPingInterval.String;

	self.chkStatusEnabled.value := self.jtdGetDefaultStatusDisplay;

	self.jtdUnsavedChanges := false;

	self.caption := "Profile Editor: " &amp; self.jtdMyDriverSchema.name;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="jtdResizeTheLot" id="17cd935d-885e-492a-a32a-da0e0fd4eb77">
        <source>jtdResizeTheLot() protected;

vars
	r : Real;
	
begin
	self.fraSplitterVert.top := 0;
	self.fraSplitterVert.height := self.clientHeight;
	
	self.fraSplitterHorz.left := 0;
	self.fraSplitterHorz.width := self.fraSplitterVert.left;

	self.lstDrvProfiles.move(0, 0, self.fraSplitterVert.left, self.fraSplitterHorz.top);

	r := self.fraSplitterHorz.top + self.fraSplitterHorz.height;
	self.lstMethods.move(0, r, self.fraSplitterVert.left, self.clientHeight - r - self.txtFind.height - 1);

	self.btnNext.top := self.lstMethods.top + self.lstMethods.height + 1;
	self.btnNext.left := self.fraSplitterVert.left - self.btnNext.width;
	self.btnFind.top := self.btnNext.top;
	self.btnFind.left := self.btnNext.left - self.btnFind.width;
	self.txtFind.move(0, self.btnNext.top, self.btnFind.left, self.txtFind.height);

	r := self.fraSplitterVert.left + self.fraSplitterVert.width;	

	self.fldProfiles.move(r - 1, 0, self.clientWidth - (r - 1), self.clientHeight - self.grpGlbDefaults.height -
		self.grpDefaultDelay.height - 10);
	
	self.tblMthProfiles.move(0, 0, self.shtMain.clientWidth, self.shtMain.clientHeight -
		self.grpMthSelection.height - 8);

	self.lblProlog.top := self.shtProlog.clientHeight - self.lblProlog.height - 2;
	self.tblProlog.move(0, 0, self.shtProlog.clientWidth, self.lblProlog.top - 2);

	self.lblEpilog.top := self.shtEpilog.clientHeight - self.lblEpilog.height - 2;
	self.tblEpilog.move(0, 0, self.shtEpilog.clientWidth, self.lblEpilog.top - 2);

	self.grpMthSelection.move(-1, self.tblMthProfiles.height + 3, self.grpMthSelection.width,
		self.grpMthSelection.height);

	self.grpDefaultDelay.move(r, self.clientHeight - self.grpGlbDefaults.height - self.grpDefaultDelay.height - 4,
		self.grpDefaultDelay.width, self.grpDefaultDelay.height);
		
	self.grpGlbDefaults.move(r, self.grpDefaultDelay.top + self.grpDefaultDelay.height + 5,
		self.grpGlbDefaults.width, self.grpGlbDefaults.height);

	self.jtdSetTableColumnWidths(self.tblMthProfiles);
	self.jtdSetTableColumnWidths(self.tblProlog);
	self.jtdSetTableColumnWidths(self.tblEpilog);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="jtdRestoreSessionState" id="2f8f4a8f-0732-464f-afa1-53720207bc27">
        <updating/>
        <source>jtdRestoreSessionState() : Boolean updating, protected;

vars
	screenWidth, screenHeight : Integer;
	ss : SessionState;
	
begin
	ss := global.allSessionStates[app.computerName];
	
	if ss = null or
	   ss.peFormHeight &lt;= 0 or ss.peFormWidth &lt;= 0 or
	   ss.peFontName = null
	then
		// assume no session state or an invalid one
		return false;
	endif;

	screenWidth := self.getSystemMetrics(Window.SM_cxFullScreen);
	screenHeight := self.getSystemMetrics(Window.SM_cyFullScreen);

	if ss.peFormWindowState = Form.WindowState_Minimized then
		self.windowState := Form.WindowState_Normal;
		self.move(10, 10, screenWidth - 20, screenHeight - 20);
	elseif ss.peFormWindowState = Form.WindowState_Maximized then
		self.windowState := Form.WindowState_Maximized;
		self.move(10, 10, screenWidth - 20, screenHeight - 20);
	else
		self.windowState := Form.WindowState_Normal;
		self.move(ss.peFormLeft, ss.peFormTop, ss.peFormWidth, ss.peFormHeight);
	endif;
	
	self.fraSplitterHorz.top := ss.peSplitHorzTop;
	self.fraSplitterVert.left := ss.peSplitVertLeft;
	
	self.tblMthProfiles.fontName := ss.peFontName;
	self.tblMthProfiles.fontSize := ss.peFontSize;
	self.tblMthProfiles.fontBold := ss.peFontBold;
	self.tblMthProfiles.fontItalic := ss.peFontItalic;
		
	self.tblProlog.fontName := ss.peFontName;
	self.tblProlog.fontSize := ss.peFontSize;
	self.tblProlog.fontBold := ss.peFontBold;
	self.tblProlog.fontItalic := ss.peFontItalic;

	self.tblEpilog.fontName := ss.peFontName;
	self.tblEpilog.fontSize := ss.peFontSize;
	self.tblEpilog.fontBold := ss.peFontBold;
	self.tblEpilog.fontItalic := ss.peFontItalic;

	self.lstDrvProfiles.fontName := ss.peFontName;
	self.lstDrvProfiles.fontSize := ss.peFontSize;
	self.lstDrvProfiles.fontBold := ss.peFontBold;
	self.lstDrvProfiles.fontItalic := ss.peFontItalic;

	self.lstMethods.fontName := ss.peFontName;
	self.lstMethods.fontSize := ss.peFontSize;
	self.lstMethods.fontBold := ss.peFontBold;
	self.lstMethods.fontItalic := ss.peFontItalic;

	return true;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jtdResumeNextExHandler" id="4f1a1ef0-17b5-4c86-9f04-2328e2d1e961">
        <source>jtdResumeNextExHandler(exObj : Exception; errNo : Integer output) : Integer protected;

begin
	errNo := exObj.errorCode;
	return Ex_Resume_Next;
end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="errNo" type="Integer" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jtdSaveAllProfiles" id="b0be4361-e921-4f14-b713-6c2517182441">
        <updating/>
        <source>jtdSaveAllProfiles() updating, protected;

vars
	s, newOriginalProfileText : String;
	dp : JtdDriverProfile;
	mth : Method;
	
begin
	// get the method object on which profile text is saved
	mth := self.jtdMyProfileTextMethod;

	// build the profile string we're about to save
	s := null;
	
	if self.jtdMyDefaultDriverProfile &lt;&gt; null then
		s := s &amp; JtdDriverProfile.JtdTagDefaultProfileName &amp; ' ' &amp;
			self.jtdMyDefaultDriverProfile.jtdName &amp; ';' &amp; CrLf &amp; CrLf;
	endif;
	
	if self.jtdDefaultAutoPingInterval &gt; 0 then
		s := s &amp; JtdDriverProfile.JtdTagDefaultAutoPingInterval &amp; ' ' &amp;
			self.jtdDefaultAutoPingInterval.String &amp; ';' &amp; CrLf &amp; CrLf;
	endif;

	if self.chkStatusEnabled.value then
		s := s &amp; JtdDriverProfile.JtdTagDefaultStatusDisplay &amp; ' ' &amp;
			"on;" &amp; CrLf &amp; CrLf;
	else
		s := s &amp; JtdDriverProfile.JtdTagDefaultStatusDisplay &amp; ' ' &amp;
			"off;" &amp; CrLf &amp; CrLf;
	endif;
	
	foreach	dp in self.jtdAllDriverProfiles do
		s := s &amp; dp.jtdAsString &amp; CrLf &amp; CrLf;
	endforeach;

	// save the profile definitions
	while true do
		// we need an exclusive lock on our profile text method in order to save
		if not tryLock(mth, Exclusive_Lock, Transaction_Duration, LockTimeout_Immediate) then
			if app.msgBox("The object in which profiles are saved is locked by another process." &amp;
				CrLf &amp; CrLf &amp; "Your changes cannot be saved until this lock is released." &amp; CrLf &amp;
				CrLf &amp; "Select Retry to try again, or Cancel to abort.", "Object Locked - Cannot Save",
				MsgBox_Retry_Cancel + MsgBox_Exclamation_Mark_Icon) &lt;&gt; MsgBox_Return_Retry
			then
				// the user wants to abort
				return;
			endif;
			// try again to acquire the lock
			continue;
		endif;
		// When we get to here we have the method object exclusively locked.
		// This will have brought the latest edition of the object into cache.

		if mth.text &lt;&gt; self.jtdOriginalProfileText then
			// Another user or process has updated the method text since we loaded
			// our profiles or last saved. The save we're about to do will overwrite
			// this text. Confirm that this is ok. Release our method lock before
			// showing the message box so we don't hold it for a long time.
			newOriginalProfileText := mth.text;
			unlock(mth);
			if app.msgBox("Another user or process has updated the profiles since the start of " &amp;
				"your edit session or since you last saved." &amp; CrLf &amp; CrLf &amp; "The changes you are " &amp;
				"about to save will overwrite the current profiles." &amp; CrLf &amp; CrLf &amp; "Continue?",
				"Confirm", MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon) &lt;&gt; MsgBox_Return_Yes
			then
				// they don't want to save
				return;
			endif;
			// they want to save; go around the loop again to re-acquire the lock
			self.jtdOriginalProfileText := newOriginalProfileText;
			continue;
		endif;

		// save the profiles and tell any running drivers to reload their profile
		beginTransaction;
		mth.jtdSetText(s);
		system.causeEvent(CmdEventNumber, false, CmdReloadProfile);
		commitTransaction;

		// remember the updated method text so we can check subsequent saves
		self.jtdOriginalProfileText := s;
		
		self.jtdUnsavedChanges := false;
		return;
	endwhile;
	
epilog
	// Make sure we unlock our method object before returning.
	// In normal circumstances, the commitTransaction will already have
	// unlocked it. This is belts and braces in case of abnormal exit.
	// Unlocking an object we don't have locked does nothing.
	if mth &lt;&gt; null then
		unlock(mth);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="jtdSaveSessionState" id="89fc5107-2ea2-4b03-bd2f-cb3472f8f26a">
        <updating/>
        <source>jtdSaveSessionState() updating, protected;

// assumes the caller is controlling the transaction

vars
	ss : SessionState;
	
begin
	ss := global.allSessionStates[app.computerName];
	
	if ss = null then
		create ss persistent;
	endif;
	
	ss.peFormTop := self.top;
	ss.peFormLeft := self.left;
	ss.peFormHeight := self.height;
	ss.peFormWidth := self.width;
	ss.peFormWindowState := self.windowState;
	ss.peSplitHorzTop := self.fraSplitterHorz.top;
	ss.peSplitVertLeft := self.fraSplitterVert.left;

	ss.peFontName := self.tblMthProfiles.fontName;
	ss.peFontSize := self.tblMthProfiles.fontSize;
	ss.peFontBold := self.tblMthProfiles.fontBold;
	ss.peFontItalic := self.tblMthProfiles.fontItalic;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="jtdSelectDriverSchema" id="840d248c-b816-4ccf-8a31-81d8a74a928e">
        <updating/>
        <source>jtdSelectDriverSchema() : Boolean updating, protected;

vars
	dsdDict : DriverSchemaDescriptorNameDict;
	f : SchemaSelectionForm;
	scm : Schema;
	cls : Class;
	n : Integer;
	
begin
	create dsdDict transient;
	rootSchema.getAllDriverSubschemaDescs(dsdDict);

	n := dsdDict.size;

	if n &lt; 1 then
		app.msgBox("No Driver Framework Schemas can be found in the system." &amp; CrLf &amp;
			CrLf &amp; "The Profile Editor cannot be run.", "Cannot Run Profile Editor",
			MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	endif;
	
	if n = 1 then
		scm := dsdDict.first.mySchema;
	else
		create f transient;
		f.myDriverSchemaDescNameDict := dsdDict;
		f.lblPrompt.caption := "Please select the Driver Schema for which to run the Profile Editor:";
		
		if f.showModal &lt;&gt; 0 then
			return false;
		endif;
		
		scm := f.mySelectedSchema;
	endif;

	if scm = null then
		app.msgBox("No Driver Framework Schema has been selected." &amp; CrLf &amp; CrLf &amp;
			"The Profile Editor cannot be run.", "Cannot Run Profile Editor",
			MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	endif;
	
	self.jtdMyDriverSchema := scm;
	
	self.jtdMyProfileTextMethod := scm.getProfileTextMethod;
	
	if self.jtdMyProfileTextMethod = null then
		app.msgBox("Cannot find method jtdAllProfileText on class JtdContext in schema " &amp;
			scm.name &amp; '.' &amp; CrLf &amp; CrLf &amp; "The Profile Editor cannot be run.",
			"Cannot Run Profile Editor", MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	endif;

	cls := scm.jtdGetClasses[TrxGenClassName];
	
	if cls = null then
		app.msgBox("Cannot find " &amp; TrxGenClassName &amp; " class in schema " &amp;
			scm.name &amp; '.' &amp; CrLf &amp; CrLf &amp; "The Profile Editor cannot be run.",
			"Cannot Run Profile Editor", MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	endif;

	self.jtdMyTrxGenRootClass := cls.rootType;
	
	if self.jtdMyTrxGenRootClass = null then
		// belts and braces - should never occur
		app.msgBox("Cannot find " &amp; TrxGenClassName &amp; " root class in schema " &amp;
			scm.name &amp; '.' &amp; CrLf &amp; CrLf &amp; "The Profile Editor cannot be run.",
			"Cannot Run Profile Editor", MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	endif;
	
	cls := scm.jtdGetClasses[ReadTrxGenClassName];
	
	if cls = null then
		app.msgBox("Cannot find " &amp; ReadTrxGenClassName &amp; " class in schema " &amp;
			scm.name &amp; '.' &amp; CrLf &amp; CrLf &amp; "The Profile Editor cannot be run.",
			"Cannot Run Profile Editor", MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	endif;

	self.jtdMyReadTrxGenRootClass := cls.rootType;
	
	if self.jtdMyReadTrxGenRootClass = null then
		// belts and braces - should never occur
		app.msgBox("Cannot find " &amp; ReadTrxGenClassName &amp; " root class in schema " &amp;
			scm.name &amp; '.' &amp; CrLf &amp; CrLf &amp; "The Profile Editor cannot be run.",
			"Cannot Run Profile Editor", MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	endif;

	cls := scm.jtdGetClasses[UpdateTrxGenClassName];
	
	if cls = null then
		app.msgBox("Cannot find " &amp; UpdateTrxGenClassName &amp; " class in schema " &amp;
			scm.name &amp; '.' &amp; CrLf &amp; CrLf &amp; "The Profile Editor cannot be run.",
			"Cannot Run Profile Editor", MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	endif;

	self.jtdMyUpdTrxGenRootClass := cls.rootType;
	
	if self.jtdMyUpdTrxGenRootClass = null then
		// belts and braces - should never occur
		app.msgBox("Cannot find " &amp; UpdateTrxGenClassName &amp; " root class in schema " &amp;
			scm.name &amp; '.' &amp; CrLf &amp; CrLf &amp; "The Profile Editor cannot be run.",
			"Cannot Run Profile Editor", MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	endif;

	return true;
	
epilog
	if dsdDict &lt;&gt; null then
		dsdDict.purge;
		delete dsdDict;
	endif;
	
	delete f;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jtdSelectMethodProfileTableRow" id="7e9a30ae-1426-4d24-ac26-63b8e2cb9173">
        <updating/>
        <source>jtdSelectMethodProfileTableRow(tbl : Table input; selRow : Integer) updating, protected;

begin
	if tbl = null then
		return;
	endif;
	
	if selRow &lt;= tbl.fixedRows or selRow &gt; tbl.rows then
		self.jtdMySelectedMethodProfile := null;
		tbl.clearAllSelected;
		return;
	endif;

	tbl.row := selRow;
	tbl.accessRow(selRow).selected := true;
	tbl.accessCell(selRow, 1).selected := false;

	self.jtdMySelectedMethodProfile :=
		tbl.accessCell(selRow, self.JtdColMethodProfileObj).itemObject.JtdMethodProfile;
end;</source>
        <access>protected</access>
        <Parameter name="tbl" type="Table" usage="input"/>
        <Parameter name="selRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jtdSetSelectedDriverProfile" id="505d6710-2749-4d97-aa84-f6d3a4e5ca8d">
        <updating/>
        <source>jtdSetSelectedDriverProfile(dp : JtdDriverProfile) updating, protected;

begin
	if dp = null then
		self.jtdMySelectedDriverProfile := null;
		self.jtdMySelectedMethodProfile := null;
		self.tblMthProfiles.rows := self.tblMthProfiles.fixedRows;
		self.tblProlog.rows := self.tblProlog.fixedRows;
		self.tblEpilog.rows := self.tblEpilog.fixedRows;
		self.lstDrvProfiles.listIndex := -1;
		self.optInSequence.value := false;
		self.optRandom.value := false;
		self.chkRunOnce.value := false;
		self.grpMthSelection.enabled := false;
		self.grpDefaultDelay.enabled := false;
		self.shtMain.caption := self.JtdMainSheetCaption;
		self.shtProlog.caption := self.JtdPrologSheetCaption;
		self.shtEpilog.caption := self.JtdEpilogSheetCaption;
		return;
	endif;

	self.lstDrvProfiles.listIndex := self.lstDrvProfiles.findObject(dp);
	
	if dp &lt;&gt; self.jtdMySelectedDriverProfile then
		self.jtdMySelectedDriverProfile := dp;
		self.jtdMySelectedMethodProfile := null;
		self.jtdLoadMethodProfileTables;
		self.grpMthSelection.enabled := true;
		self.grpDefaultDelay.enabled := true;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="dp" type="JtdDriverProfile"/>
    </JadeMethod>
    <JadeMethod name="jtdSetTableColumnWidths" id="4807fcff-ab6e-44f6-beb3-bfec0594d044">
        <source>jtdSetTableColumnWidths(tbl : Table) protected;

begin
	if tbl = null then
		return;
	endif;
	
	tbl.columnWidth[1] := 16;
	tbl.columnWidth[2] := ((tbl.clientWidth - 16) * 0.68).Integer;
	tbl.columnWidth[3] := ((tbl.clientWidth - 16) * 0.16).Integer;
	tbl.columnWidth[4] := tbl.clientWidth - 16 - tbl.columnWidth[2] - tbl.columnWidth[3];
end;</source>
        <access>protected</access>
        <Parameter name="tbl" type="Table"/>
    </JadeMethod>
    <JadeMethod name="jtdSetupTable" id="c1bae716-44d0-42de-af18-cf3ed8a8a5f9">
        <source>jtdSetupTable(tbl : Table input) protected;

begin
	if tbl = null then
		return;
	endif;
	
	tbl.rows := tbl.fixedRows;
	tbl.accessCell(1, 2).text := "Method" &amp; Tab &amp; "Calls" &amp; Tab &amp; "Delay";
	tbl.accessColumn(3).alignment := Table.Alignment_Center;
	tbl.accessedColumn.inputType := Table.InputType_TextNumeric;
	tbl.accessColumn(4).alignment := Table.Alignment_Center;
	tbl.accessedColumn.inputType := Table.InputType_TextNumeric;
	tbl.maxLength := 8;
end;</source>
        <access>protected</access>
        <Parameter name="tbl" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="jtdUnsavedChanges" id="5ffbc50d-1001-45e7-a391-7112882c9f16">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>jtdUnsavedChanges(set: Boolean; _value: Boolean io) mapping, updating, protected;

begin
	if set and _value &lt;&gt; self.jtdUnsavedChanges then
		if _value then
			self.caption := "Profile Editor: " &amp; self.jtdMyDriverSchema.name &amp; " - Unsaved Changes";
		else
			self.caption := "Profile Editor: " &amp; self.jtdMyDriverSchema.name;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="jtdUpdateSelDrvProfileMthCount" id="c115b297-59d7-43f4-a656-937ac30cd66e">
        <source>jtdUpdateSelDrvProfileMthCount() protected;

vars
	dp : JtdDriverProfile;
	lst : ListBox;
	
begin
	dp := self.jtdMySelectedDriverProfile;

	if dp = null then
		return;
	endif;
	
	lst := self.lstDrvProfiles;
	
	lst.listIndex := lst.findObject(dp);
	
	if lst.listIndex &gt; 0 and lst.listIndex &lt;= lst.listCount then
		lst.text := dp.jtdName &amp; " [" &amp; dp.jtdGetTotalMethods.String &amp; ']';
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="keyDown" id="c838d37f-3da1-46f7-a7ef-61db7c0ecf3e">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;

begin
	if keyCode = 114 then // F3
		if shift.bitAnd(1) &lt;&gt; 0 then
			self.jtdFindClassOrMethodByName(self.lstMethods.listIndex + 1);
		else
			self.jtdFindClassOrMethodByName(1);
		endif;
		keyCode := 0;	
	endif;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="load" id="a9ceceed-894a-4937-8a98-75ba66c3df66">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

vars
	sessionStateRestored : Boolean;
	
begin
	self.mnuProfilePopup.enabled := false;
	self.mnuProfilePopup.visible := false;
	
	if not self.jtdSelectDriverSchema then
		terminate;
		return;
	endif;
	
	self.picTick.visible := false;
	self.picTick.enabled := false;
	
	self.picCross.visible := false;
	self.picCross.enabled := false;

	self.lstDrvProfiles.autoRedraw := false;

	self.jtdSetupTable(self.tblMthProfiles);
	self.jtdSetupTable(self.tblProlog);
	self.jtdSetupTable(self.tblEpilog);

	beginClassNotification(Method, false, Object_Delete_Event, Response_Continuous, 0);
	beginClassNotification(Method, false, Object_Create_Event, Response_Continuous, 0);

	sessionStateRestored := self.jtdRestoreSessionState;

	if not sessionStateRestored then		
		self.fraSplitterHorz.top := (self.clientHeight / 2) - (self.fraSplitterHorz.height / 2);
	endif;

	self.jtdResizeTheLot;

	self.jtdReload;

	if not sessionStateRestored then
		self.centreWindow;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="lstDrvProfiles_click" id="c94e7d94-115a-459c-8ff7-990185ac43f3">
        <controlMethod name="ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstDrvProfiles_click(listbox: ListBox input) updating;

begin
	if listbox.listIndex &lt; 1 or listbox.listIndex &gt; listbox.listCount then
		// belts and braces
		self.jtdSetSelectedDriverProfile(null);
		return;
	endif;
	self.jtdSetSelectedDriverProfile(listbox.listObject.JtdDriverProfile);
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstDrvProfiles_contextMenu" id="358049f0-253b-42b9-9aa9-c359f38c7cfa">
