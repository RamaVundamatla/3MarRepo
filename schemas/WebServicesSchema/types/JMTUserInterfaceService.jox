    <JadeWebServicesMethod name="getWorkOrderTypes" id="d6e06c5b-77d4-4f42-96f2-456694599ba1">
        <source>getWorkOrderTypes() : WS_CodeResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2018	jlger1	Initial creation 38520
31 May 2021 navma1  ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
29 Sep 2021 navma1  ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
*/

vars
	response		   : WS_CodeResponse;
	completedOK		   : Boolean;
	proxyWorkOrderType : WS_Code;
	workOrderTaskType  : CM_WorkOrderDetailType;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passDelayType for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;		
	
	//29.09.2021 navma1 #51925
	foreach workOrderTaskType in app.myRoot.allWorkOrderTaskTypes discreteLock do
		
		if workOrderTaskType.type &lt;&gt; WorkOrderMode_Cargo then
			continue;
		endif;
		
		create proxyWorkOrderType transient;
		proxyWorkOrderType.setProxyDetails(null,workOrderTaskType.id.String,workOrderTaskType.description);
		response.allCodes.add(proxyWorkOrderType);
	endforeach;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <ReturnType type="WS_CodeResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getWorkOrderVoyageByType" id="c02ec77e-9798-4c00-b4f0-34ff2bc667ca">
        <source>getWorkOrderVoyageByType(_request : WS_WorkOrderDetailQueryRequest) : WS_WorkOrderDetailResponse webService;
/*

Purpose:			

Parameters:	_request.voyageOid, _request.type (work order detail type)	

Return Value:		

Date		Who		Reason
16/05/2018	jlger1	Initial creation 38520
30/10/2018	jlgdap1	TFS 41305 PEL1 Voyage and Cargo Operator in Web Portal
09/10/2019  cnwma1	Bug 46917: PEL1 - [Top Urgent] - No WO Additional Cargo appears on The Web Portal
*/

vars
	response 	    : WS_WorkOrderDetailResponse;
	completedOK 	: Boolean;
	voyage 			: CM_Voyage;
	workOrderDetail : CM_WorkOrderVoyageDtl;
	workOrder       : CM_WorkOrder;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	
	// Check security access to this message
	//app.checkCurrentUserHasAccess(PmWebWorkOrdersView);			// TFS 41305
	app.checkCurrentUserHasAccess(PmWebWorkOrdersVoyView);			// TFS 41305
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;

	if _request.voyageOid &lt;&gt; null then
		voyage := app.myPassport.getObjectOfTypeFromOid(_request.voyageOid,CM_Voyage).CM_Voyage;
	endif;
	
	if voyage = null then
		completedOK := true;
		return response;
	endif;
	
	workOrderDetail :=  _request.getWOVoyageDtlType (voyage);    //09.10.2019 cnwma1 #46917
	
	if workOrderDetail = null then
		completedOK := true;
		return response;
	
	endif;
	
	if workOrderDetail &lt;&gt; null  then
		//response.createWorkOrderDetail(workOrderDetail, 1);     //09.10.2019 cnwma1 #46917
		//epr TFS 48179 29/1/2020
		workOrder := workOrderDetail.getMyParent.CM_WorkOrder;
		
		if workOrder.canAccessOnWeb then   //09.10.2019 cnwma1 #46917 //30.12.2019 cnwma1 #48082
			response.createWsDetails(workOrderDetail, 1);
			
		//	response.createWsWorkOrderDtl(workOrder,_request,1);  //09.10.2019 cnwma1 #46917
		endif;
		
	endif;
		
	completedOK := true;
	return response;
		

	
	
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <Parameter name="_request" type="WS_WorkOrderDetailQueryRequest"/>
        <ReturnType type="WS_WorkOrderDetailResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getWorkOrderVoyages" id="e3fafc9e-18b1-48af-b66a-a8c25831d131">
        <source>getWorkOrderVoyages() : WS_VoyagesResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2018	jlger1	Initial creation 38520

*/

vars

	response		: WS_VoyagesResponse;
	completedOK		: Boolean;
	proxyVoyage : WS_Voyage;
	noInfoVoyage,
	holdVoyage,
	nullVoyage : CM_Voyage;
	noInfoCode,
	holdCode : String;
	terminal : CM_Terminal;
begin
// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passDelayType for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;		
	
	terminal:=app.myPassport.myTerminal;
	if terminal = null then
		completedOK := true;
		return response;
	endif;
	// TFS 38501 Populate voyage, release and booking combos
	nullVoyage := terminal.getNullVoyage;
	if nullVoyage &lt;&gt; null then
		create proxyVoyage transient;
		proxyVoyage.setProxyFromObject(nullVoyage);
		response.allVoyages.add(proxyVoyage);
	endif;
	
	holdCode := terminal.getConfig(HoldVoyageCode).String;
	if holdCode &lt;&gt; null then
		holdVoyage := terminal.allVoyagesByCode.getAtKeyGeq(holdCode, null);
		if holdVoyage &lt;&gt; null and holdVoyage.code = holdCode and holdVoyage &lt;&gt; nullVoyage then
			create proxyVoyage transient;
			proxyVoyage.setProxyFromObject(holdVoyage);
			response.allVoyages.add(proxyVoyage);
		endif;
	endif;
	noInfoCode := terminal.getConfig(DefVoyage).String;
	if noInfoCode &lt;&gt; null then
		noInfoVoyage := terminal.allVoyagesByCode.getAtKeyGeq(noInfoCode, null);
		if noInfoVoyage &lt;&gt; null and noInfoVoyage.code = noInfoCode and noInfoVoyage &lt;&gt; nullVoyage then
			create proxyVoyage transient;
			proxyVoyage.setProxyFromObject(noInfoVoyage);
			response.allVoyages.add(proxyVoyage);
		endif;
	endif;

	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <ReturnType type="WS_VoyagesResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getWorkPoints" id="390b50fa-4ecb-4e06-835e-65e7f458181d">
        <source>getWorkPoints(workPointsRequest : WS_WorkPointsRequest) : WS_WorkPointsResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 Sep 2011	cnwer1	Initial creation CCMS MES 1033
11 Jul 2012 cnwer1	PAR 29962 - Work with LOLO now returning cranes aswell as workpoints
15 Feb 2016	cnwkpd1	PAR #35261 - Changes required for JADE 7.1 

*/

vars
	response		: WS_WorkPointsResponse;
	completedOK		: Boolean;
	terminal		: CM_Terminal;
	voyage 			: CM_Voyage;
	jobSheet 		: CM_VoyageJobSheet;
	workPoint 		: CM_WorkPoint;
	workPointProxy 	: WS_WorkPoint;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
		
	terminal := app.myPassport.myTerminal;
	
	voyage:=terminal.lookupVoyage(workPointsRequest.voyageCode,null,false);
	
	if voyage = null then
		completedOK := true;
		return response;
	endif;
	
	foreach jobSheet in voyage.allJobSheets do
		workPoint:= jobSheet.getMyWorkPoint;
		if workPoint = null then
			continue;
		endif;
		create workPointProxy transient;
		workPointProxy.setProxyFromObject(workPoint);
		response.allWorkPoints.add(workPointProxy);
	endforeach;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up any local transients
	// ...
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <Parameter name="workPointsRequest" type="WS_WorkPointsRequest"/>
        <ReturnType type="WS_WorkPointsResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getWorkPointsAll" id="a574f624-190a-4347-891c-6839b76c6cdb">
        <source>getWorkPointsAll() : WS_WorkPointsResponse webService;
/*
Purpose:			
Date				Who			Reason
JUNE 2015		CNWAB1		Initial creation
15 Feb 2016	cnwkpd1	PAR #35261 - Changes required for JADE 7.1 

*/

vars
	response		: WS_WorkPointsResponse;
	completedOK		: Boolean;
	terminal		: CM_Terminal;
	workPoint 		: CM_WorkPoint;
	workPointProxy 	: WS_WorkPoint;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
		
	terminal := app.myPassport.myTerminal;
	
	foreach workPoint in terminal.allWorkPointsByCode  discreteLock do
		if workPoint.isNotAvailableForEntry then
			continue;
		endif;
		
		create workPointProxy transient;
		workPointProxy.setProxyFromObject(workPoint);
		response.allWorkPoints.add(workPointProxy);
	endforeach;
	
	// Got to here, everything is ok
