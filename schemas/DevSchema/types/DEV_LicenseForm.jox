    <JadeMethod name="addLicenseToTable" id="6f8b5fb7-d4a3-4e87-a22a-9b81e367affd">
        <source>addLicenseToTable(_globalConst : Integer; _licenseDtl : DEV_LicenseDtl; _canDoStr : String);
/*
Purpose:			
Date		Who		Reason
04 April 2017	cnwab1	Initial creation
*/

vars
	permAgent	: CM_PermissionAgent;
	permObj		: CM_PermissionObject;
	canDoStr	: String;
	tmpIgnore	: Boolean;
	idx,
	color1,
	color2,
	theColor,
	tmpValue	: Integer;

begin
	permAgent := self.myPermissionAgent;
	permObj := permAgent.allPermissionsByConstValue[_globalConst];
	tmpValue := permObj.constValue;
	tblLicense.addItemObject(permObj, permObj.description &amp; Tab &amp; _canDoStr);

epilog

end;</source>
        <Parameter name="_globalConst" type="Integer"/>
        <Parameter name="_licenseDtl" type="DEV_LicenseDtl"/>
        <Parameter name="_canDoStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="addToChangeNote" id="7cd58183-6a5c-4806-ad3d-e36239297d42">
        <updating/>
        <source>addToChangeNote(_newChange : String; _changeNote  : String io) updating;
/*
Purpose:	

Date		Who		Reason
07 January 2026	navab1	JIRA 36920
*/

vars

begin
	if _changeNote = null then
		_changeNote := _newChange;
	else	
		_changeNote := _changeNote &amp; CrLf &amp; _newChange;
	endif;
epilog

end;</source>
        <Parameter name="_newChange" type="String"/>
        <Parameter name="_changeNote" type="String" usage="io"/>
    </JadeMethod>
