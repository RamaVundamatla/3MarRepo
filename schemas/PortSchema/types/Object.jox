    <JadeMethod name="outputConfigMyReferencesXML" id="5179715a-1fb0-4dac-b634-286407a92e57">
        <source>outputConfigMyReferencesXML(_file: File; _objArray: ObjectArray io; _property: Property; _object: Object);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 April 2009	cnwjk3	Initial creation

*/

vars

begin
//write("&lt;"&amp;property.getName&amp;"&gt;"&amp;object.Object.theKey&amp;"&lt;/"&amp;property.getName&amp;"&gt;");
	_file.writeLine("&lt;"&amp;_property.getName&amp;"&gt;"&amp;_object.Object.theConfigKey&amp;"&lt;/"&amp;_property.getName&amp;"&gt;");
end;</source>
