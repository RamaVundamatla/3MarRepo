    <JadeMethod name="clickDisplayPerformanceModeOpt" id="627bd078-8b2b-44b1-b37b-aae948acb610">
        <updating/>
        <source>clickDisplayPerformanceModeOpt( _control : Control )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
04 March 	2021	navndl1	Initial creation	TFS 50796
08 December	2022	navkc1	ChangeRequest 55409: MTN - Voyage Ops Form - Pagination of tables
*/

begin

	self.performLimitNumOfRow 	:= self.chkNumOfRowPerTable.value; //30/07/2025	navkc1 JIRA MTN 35478
	self.performTableCount 		:= self.chkTableCount.value; //30/07/2025	navkc1 JIRA MTN 35478
	self.performAllowFilter 	:= self.chkAllowFilter.value; //30/07/2025	navkc1 JIRA MTN 35478
	self.performAllowMore20 	:= self.chkAllowMore20.value; //30/07/2025	navkc1 JIRA MTN 35478
	
	self.chkNumOfRowPerTable.visible := not self.isCargoGroupForm(); //30/07/2025	navkc1 JIRA MTN 35478
	self.txtNumOfRow.visible := self.chkNumOfRowPerTable.visible and self.performLimitNumOfRow;	// 08/12/2022	navkc1	#55409
	self.lblNumOfRow.visible := self.chkNumOfRowPerTable.visible and self.performLimitNumOfRow;	// 08/12/2022	navkc1	#55409
	
	self.validatePeformance( true, _control );
	
epilog

end;</source>
