    <JadeMethod name="addLocale" id="7937154d-7db6-4ebd-9e14-289f34c63430">
        <source>addLocale();

// add a new row, and fill the combo with available locales, skip those already used
vars
	locale 	: CM_Locale;
	str		: String;
	row		: Integer;
begin
	table.rows := table.rows + 1;
	table.accessCell(table.rows, 1).inputType := Table.InputType_ComboBox;
	foreach locale in app.myRoot.allLocales do :localeLoop
		foreach row in table.fixedRows + 1 to table.rows where table.getCellText(row,1) = locale.localeId do
			continue localeLoop;
		endforeach;
		str := str &amp; Tab &amp; locale.localeId;
	endforeach;
	table.accessCell(table.rows, 1).comboList := str;
	
	table.accessCell(table.row, table.column).selected := false;
	table.accessCell(table.rows, 1).selected := true;
end;</source>
    </JadeMethod>
