    <JadeMethod name="setCanLoadAll" id="64730e7f-3db9-440c-b9b8-38e93cc43b3e">
        <updating/>
        <source>setCanLoadAll(roadJob : WS_RoadJob) updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 12 July 2019
TFS#		: 45289
Function	: Set flag value to true if the following condition is met.
			   1. User has PmHHAllowLoadAll permission
			   2. No cargo checks required for the release (on any items)
			   3. No break bulk (ie that would require a quantity or volume).

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	terminal 	  : CM_Terminal;
	cargoCheck	  : CM_CargoCheck;
	wsTrackedItem : WS_TrackedItem;
	trackedItem	  : CM_TrackedItem;
	setToFalse	  : Boolean;
	roadWLEArray  : WS_RoadWLEArray;
	roadWLE		  : WS_RoadWLE;
begin	
	terminal 	:= app.myPassport.myTerminal;
	roadWLEArray := roadJob.allWLEsToLoad;
	
	if terminal &lt;&gt; null then
		if app.getMyUser.canDo(terminal, PmHHAllowLoadAll) then // got access
			
			cargoCheck := terminal.allCargoChecks[CARGO_CHECK_CONTEXT_TRUKLOAD];
			
			if cargoCheck.allCargoCheckItems.isEmpty then // no cargo check
				if roadWLEArray.isEmpty then
					setToFalse := true;
				else					
					foreach roadWLE in roadWLEArray do
						wsTrackedItem	:= roadWLE.myTrackedItem;						
						if wsTrackedItem &lt;&gt; null then							
							trackedItem	:= app.myPassport.getObjectOfTypeFromOid(wsTrackedItem.cmObjectId, CM_TrackedItem).CM_TrackedItem;	
							if trackedItem.myCargoType &lt;&gt; null then
								if trackedItem.myCargoType.allowDuplicates then						   							   
									setToFalse := true;
									break;
								endif;
							endif;
						else
							setToFalse := true;
							break;
						endif;
					endforeach;
				endif;
			else // with cargo checks, match with each tracked item
				setToFalse := withCargoCheck(roadWLEArray, cargoCheck);
			endif;
		else // no access set setToFalse is true
			setToFalse := true;
		endif;			
	endif;
	if setToFalse then
		self.canLoadAll := false;
	else
		self.canLoadAll := true;
	endif;
end;</source>
        <Parameter name="roadJob" type="WS_RoadJob"/>
    </JadeMethod>
    <JadeMethod name="withCargoCheck" id="52a2f0c0-10ad-4033-b5ac-3d4ab978faa8">
        <source>withCargoCheck(roadWLEArray  : WS_RoadWLEArray; cargoCheck : CM_CargoCheck) : Boolean;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 17 July 2019
TFS#		: 45289
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	trackedItem 	: CM_TrackedItem;
	cmifAutoPlan	: CMIF_YAAutoPlan;
	check 			: CM_CargoCheckItem;
	cargoCheckArray : CM_CargoCheckItemArray;
	setToFalse		: Boolean;
	roadWLE		    : WS_RoadWLE;
	wsTrackedItem   : WS_TrackedItem;
begin
	if roadWLEArray.size &lt; 1 then
		setToFalse := true;
		return setToFalse;
	endif;
	
	cargoCheckArray := cargoCheck.allCargoCheckItems;
	
	foreach roadWLE in roadWLEArray do
		wsTrackedItem	:= roadWLE.myTrackedItem;
		if wsTrackedItem &lt;&gt; null then
			trackedItem := app.myPassport.getObjectOfTypeFromOid(wsTrackedItem.cmObjectId, CM_TrackedItem).CM_TrackedItem;
			if trackedItem &lt;&gt; null then
				// create an auto plan for checking criteria
				create cmifAutoPlan as CMIF_YAAutoPlanNormal transient;
				cmifAutoPlan.attachTI(trackedItem);		
				if trackedItem.myCargoType &lt;&gt; null then
					if trackedItem.myCargoType.allowDuplicates then
						setToFalse := true;
						return setToFalse;
					endif;
				endif;
				
				foreach check in cargoCheckArray do
					if cmifAutoPlan &lt;&gt; null and check.doesTIMatchMe(cmifAutoPlan) then				
						setToFalse := true;
						return setToFalse;
					endif;			
				endforeach;					
				
				delete cmifAutoPlan;
			else// cannot find tracked item object
				setToFalse := true;
				return setToFalse;
			endif;
		else// no tracked item
			setToFalse := true;
			return setToFalse;
		endif;
	endforeach;
	setToFalse := false;
	
	return setToFalse;
end;</source>
        <Parameter name="roadWLEArray" type="WS_RoadWLEArray"/>
        <Parameter name="cargoCheck" type="CM_CargoCheck"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
