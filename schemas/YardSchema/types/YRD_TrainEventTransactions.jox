    <JadeMethod name="addEventRow" id="8aaee8ae-6ba5-43e6-a257-228509f1867e">
        <source>addEventRow( _event : CM_EventTransaction ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

	rowStr			: String;
	entRow			: EntTableRow;
	idx				: Integer;
	
begin

	if _event = null then
		return;
	endif;
	
	foreach entRow in self.tblEvents.allTblDataEntRows do
		rowStr := rowStr &amp; _event.getDisplayStringForAttribute(entRow.name, false) &amp; Tab;
	endforeach;
	
	idx := self.tblEvents.addItem(rowStr);
	self.tblEvents.accessRow(idx).itemObject := _event;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_event" type="CM_EventTransaction"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="ceeaa5aa-c8e0-497c-b615-7348421d3106">
        <updating/>
        <source>addToolbarControls() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

	toolbar		: CMUI_Toolbar;
	
begin

	toolbar := self.frmToolbar;
	
	toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnExport, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnNewEvent, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnEditEvent, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnInvoiceLine, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);

	toolbar.positionToolbarControls();
	toolbar.visible := true;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnDelete_click" id="9be2d739-b2f7-40a1-a4e3-0c62f2c49e30">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDelete_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

	event : CM_EventTransaction;
	result : Integer;
	
begin

	event := self.tblEvents.accessRow(self.tblEvents.row).itemObject.CM_EventTransaction;
	
	if event &lt;&gt; null and event.canBeDeleted() then
		
		while true do
			app.myTrxDA.trxDeleteTrainEvent( event, app.myPassport);
			
			if app.myPassport.trxCompletedOK then
				self.clearEditControls();
				self.loadTblEvents();
				return;
			else
				result := app.showErrorWarningDialog(app.getErrorString(Train_user_event) &amp; " " &amp; app.getErrorString(Delete), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
	
			endif;
			self.clearEditControls();
			self.loadTblEvents();
			return;
		endwhile;		
		
	endif;

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
