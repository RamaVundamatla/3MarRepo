    <JadeMethod name="serializePropToJSON" id="473f406d-98ab-4b4d-9ca7-9f601898f28d">
        <source>serializePropToJSON(_name : String; _strVal : String; _type : Type) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 July 2015	cnwgb1	Initial creation CCMS JMT 1354 JMT in the Cloud

*/

vars
    result : String;
    timeStamp : TimeStamp;
    bool : Boolean;
begin
    result := '{ "' &amp; _name &amp; '" : ';
    if _type = String or _type = Integer or _type = Decimal or _type = Real or _type = TimeStamp then
        if _strVal.cnIsNumeric then
            result := result &amp; _strVal &amp; ' }';
        else 
            result := result &amp; '"' &amp; _strVal &amp; '" }';
        endif;
    elseif _type = TimeStamp then
        timeStamp := _strVal.asTimeStampJMT();
        result := result &amp; timeStamp.asStringJSON() &amp; ' }';
    elseif _type = Boolean then
        if _strVal.asBooleanJMT() then 
            result := result &amp; 'true }';
        else
            result := result &amp; 'false }';
        endif;
    else
        result := result &amp; '"' &amp; _strVal &amp; ' ('&amp; _type.name &amp;')" }';
   endif;
    return result;
epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_strVal" type="String"/>
        <Parameter name="_type" type="Type"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFieldValueFromAuditObject" id="735957eb-8b3d-45f6-a689-a5b9b8ad02ce">
        <source>setFieldValueFromAuditObject(pAudit : CM_AuditObject; pFieldName, pFieldHeading : String) protected;
// ---------------------------------------------------------------------------
// Created:     26 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
	
vars
	oldValue,
	newValue	: String;

begin

	if pAudit.getOldNewValueForTag(pFieldName, oldValue, newValue) then
		// for some codes we need to translate the value
		if pFieldName = 'status' then
		/*!!!!! no no!!! We shouldnt be fdoing this. DQ
			oldValue := app.myRoot.allStatusesByValue[oldValue.Integer].description;
			newValue := app.myRoot.allStatusesByValue[newValue.Integer].description;*/
			oldValue := app.getIMEXStringFromIMEXStatus(oldValue.Integer);
			newValue := app.getIMEXStringFromIMEXStatus(newValue.Integer);
		elseif pFieldName = 'imExStatus' then
			oldValue := app.getIMEXStringFromIMEXStatus(oldValue.Integer);
			newValue := app.getIMEXStringFromIMEXStatus(newValue.Integer);
		endif;
		//self.fieldsValues.add(pFieldHeading &amp; " " &amp; oldValue &amp; " " &amp;
		//		self.S_EDIT_THING &amp; " " &amp; newValue);
		self.fieldsValues.add(app.formatForEditTransaction(pFieldHeading, oldValue, newValue));
	endif;		

end;</source>
        <access>protected</access>
        <Parameter name="pAudit" type="CM_AuditObject"/>
        <Parameter name="pFieldName" type="String"/>
        <Parameter name="pFieldHeading" type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TIUpdateController" id="39f37020-a969-4824-9705-bfc568df43b8">
        <updating/>
        <source>setFromCMIF_TIUpdateController(_tiUpdateCntrlr: CMIF_TIUpdateController; _passport : CM_Passport) updating;
//--------------------------------------------------------------
// Created: 01 October 2002 By: cnwgd1
//--------------------------------------------------------------
// 27/02/2013	cnwcs5	Minor local variable tweaks plus comments
// 2/10/2019	JLGNS1	ChangeRequest 45790: JMT - Refactor - Seal Transactions
// 07/01/2019   cnwma1	Bug 48219	JMT - Audits for Edit transactions not working properly	
vars
	afterText, 
	deltaBefore,
	deltaAfter		: String;
	tiAuditCntrl, 
	tiSubAuditCntrl	: CM_TIAuditController;
	ti				: CM_TrackedItem;
begin
	inheritMethod(_tiUpdateCntrlr, _passport);
	
	// the audit controller shoudl have all the relevant before values stored on ti
	tiAuditCntrl 	:= _passport.myTIAuditController;
	ti				:= self.myTrackedItem;
	
	// 18/05/2010 cnwar2 #18507
	tiSubAuditCntrl := tiAuditCntrl.mySubAuditController;
	
	if tiSubAuditCntrl &lt;&gt; null and tiSubAuditCntrl.myTrackedItem = ti then
		// auditing for this ti is done buy the audit sub-controller
		tiSubAuditCntrl.setAuditAttributeValues(ti,false); //epr par 32291 8/1/14
		tiSubAuditCntrl.getChangedValuesAsStrings(ti, AuditUpdated, self.fieldsValues,false);
		
		// we are done with this - 
		delete tiSubAuditCntrl;
		
		tiAuditCntrl.mySubAuditController := null;
	else
		// auditing for this ti is done by the passport audit controller
		tiAuditCntrl.setAuditAttributeValues(ti,false);//epr par 32291 8/1/14
		tiAuditCntrl.getChangedValuesAsStrings(ti, AuditUpdated, self.fieldsValues,false);
		
		tiAuditCntrl.myTrackedItem := null;
	endif;
	
	self.fromQuantity := _tiUpdateCntrlr.quantity;
	
	if _tiUpdateCntrlr.volume &lt;= 99999999.999 then	//24 May 2012 Par 28364
		self.fromVolume := _tiUpdateCntrlr.volume;
	endif;
	
	self.fromWeight 		:= _tiUpdateCntrlr.totalWeight;
	//self.isWeightCertified 	:= _tiUpdateCntrlr.isWeightCertified;						//+cnwml2 MSL CCMS 1017   -//09/05/2016 cnwma1 TFS 
	
	if _tiUpdateCntrlr.comment &lt;&gt; null then
		self.setExtraData(TrnsExtraDataComment, _tiUpdateCntrlr.comment);
	endif;
	
	self.addInvoiceAudit(ti);       //07.01.2019 cnwma1 #48219
	
	//01 Feb 2021	NDL	TFS 50152
	self.addTIAudit();
	
end;</source>
        <Parameter name="_tiUpdateCntrlr" type="CMIF_TIUpdateController"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="56e13a66-b3c2-476f-955e-ea835cce9761">
        <updating/>
        <source>setMyTrackedItem(pTI: CM_TrackedItem; _tiTransCntrl: CMIF_TITransactionController ) updating;
/* ---------------------------------------------------------------------------
Created:     28 June 2010 by cnwrs2

Purpose:     CCMS JMT 1956 - RJS - set numOverstows
        
Change Date	Who		Reason
-----------	-------	----------------------------------------------------------
20/09/2011	cnwdap1	PAR #28223 CCMS MSL 1024 calculate and store Overstow and Yard Allocation
					match information, based on Operator Terminal settings
------------------------------------------------------------------------------*/
vars
	lc			: CM_LocationsController;
	op			: CM_Operator;				// PAR #28223
	ot			: CM_OperatorTerminal;		// PAR #28223
	yc			: CM_YardController;		// PAR #28223
	ya			: CM_YardAllocation;		// PAR #28223
	cmifValMove	: CMIF_YAAutoPlanNormal;	// PAR #28223
	match		: Boolean;					// PAR #28223
	overstows	: CM_TIArray;				// PAR #28223
	sideAccess	: Integer;					// PAR #28223
begin
	inheritMethod(pTI, _tiTransCntrl);
	
	// PAR #28223 set number of overstows and allocation match if operator terminal setting says so
	if pTI = null then
		return;
	endif;
	op := pTI.myOperator;
	if op &lt;&gt; null then
		ot := pTI.myTerminal.allOperatorTerminals[op];
		if ot &lt;&gt; null 											//cnwmc5 - 10 Dec 2015 - PAR 37216
		and ot.recordExtraLiftInfo(self.imExStatus) then
			// record number of overstows
			lc := pTI.myPrimaryActualLocation;
			if lc &lt;&gt; null then
				if CM_StackController.hasInstance(lc) then
					create overstows transient;
					pTI.getAllOverstowedTIs(overstows, true, sideAccess,null);
					self.numOverstows := overstows.size;
				else
					self.numOverstows := lc.getNumOverstowsForTI(pTI);
				endif;
			endif;
			
			// get yard allocation match
			if CM_YardController.hasInstance(lc) then
				yc := lc.CM_YardController;
				if yc.allYardAllocations.isEmpty then
					self.yardAllocationMatch := AllocationStatus_NoAlloc;
				else
					// check each yard allocation to see if the TI now matches it
					create cmifValMove transient;
					cmifValMove.attachTI(pTI);
					cmifValMove.raiseWarning := false;
					match := false;
					foreach ya in yc.allYardAllocations discreteLock where not ya.isDisabled do
						match := ya.compareCriteriaToCMIF(null, cmifValMove);
						if match then
							break;
						endif;
					endforeach;
					
					if match then
						self.yardAllocationMatch := AllocationStatus_Matched;
					else
						self.yardAllocationMatch := AllocationStatus_OutOf;
					endif;
				endif;
			endif;
		else
			self.yardAllocationMatch := AllocationStatus_Undefined;
		endif;
	endif;

epilog
	delete cmifValMove;
	delete overstows;
end;</source>
        <Parameter name="pTI" type="CM_TrackedItem"/>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
    </JadeMethod>
    <JadeMethod name="splitEditChangeForSQL" id="2a6dfc92-bd7b-43bb-b7a2-5a5f7e8c8836">
        <source>splitEditChangeForSQL(_change : String;
				_propertyName : String output;
				_beforeValue : String output;
				_afterValue : String output) ;
				
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2017	cnwma1	Initial creation
25 May 2017 cnwma1 TFS #4547:POL - [Fwd: ##4542## : 8.5.1.060 Testing - TFS 2807 Edit transactions missing]
*/

vars
	len,
	newPos,
	pos				: Integer;
	
begin
	len := _change.length();
	
	// Token to first space is the property name
	pos := 1;
	if pos &lt;= len then
		_propertyName := _change.scanUntil(Space, pos);
	endif;
	pos := pos + 1;
	
	// Data between the property name and the =&gt; is the before value
	if pos &lt;= len then
		newPos := _change.pos(Space &amp; CM_Edit.S_EDIT_THING, pos);
		if newPos &lt;&gt; 0 then
			_beforeValue := _change[pos:newPos - pos];
			pos := newPos + 4;
		endif;
	endif;
	
	// Data after the =&gt; is the after value
	if pos &lt;= len then
		_afterValue := _change[pos:end];
	endif;
		
epilog

end;</source>
        <Parameter name="_change" type="String"/>
        <Parameter name="_propertyName" type="String" usage="output"/>
        <Parameter name="_beforeValue" type="String" usage="output"/>
        <Parameter name="_afterValue" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="tiDeleted" id="932f39de-4fb6-4c6e-8b3b-fb1d45d967ef">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>tiDeleted(set: Boolean; _value: Boolean io) mapping, updating;
/*
 ------------------------------------------------------------------------
Created:			05 April 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	if set then
		if _value then
			flags := flags.bitOr(EditTIDeleted);
		else
			flags := flags.getValueWithBitUnset(EditTIDeleted);
		endif;
	else
		_value := (flags.bitAnd(EditTIDeleted) &lt;&gt; 0);
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
