    <JadeMethod name="getMenuTranslationNumber" id="18ea84a7-938a-408d-8a44-c8cc92e52c68">
        <source>getMenuTranslationNumber() : Integer;
// ---------------------------------------------------------------------------
// Created:     13 September 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpType	: Integer;
	
begin

	// need to fix up type here at some stage and sort out
	// meaning of "system" which in this method refers to
	// being on the system menu on the navigator, but on 
	// this class refers to being a jmt menu as opposed
	// to a user menu.

	if self.isKindOf(CM_MenuDtl) then
		tmpType := XLAT_Menu.MenuType_Detail;
	elseif self.isKindOf(CM_MenuHdrSystem) then
		// need to determine if system or terminal
		if self.isOnNavTerminalMenu then
			tmpType := XLAT_Menu.MenuType_TerminalHdr;
		elseif self.isOnNavSystemMenu then
			tmpType := XLAT_Menu.MenuType_SystemHdr;
		elseif self.isReportMenu then					// PAR 17779 
			tmpType := XLAT_Menu.MenuType_ReportHdr;	// PAR 17779 
		endif;
	endif;
	
	if tmpType = 0 then
		return 0;
	endif;
	
	return (tmpType * 10000000) + self.constantValue; 

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
