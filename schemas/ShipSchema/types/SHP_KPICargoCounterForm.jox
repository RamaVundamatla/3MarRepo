    <JadeMethod name="addToolbarControls" id="a4b0d051-83d0-4055-963e-ec9f0b54f159">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*

Date		    Who			Reason
09 September 2010	cnwas3	  Initial creation

*/

vars
	toolbar			: CMUI_Toolbar;
	showCaptions	: Boolean;
	offset			: Real;
begin
	inheritMethod();

	toolbar := self.frmToolbar;

	showCaptions := toolbar.showCaptions;	
	if not self.isChildForm then	
		toolbar.addButton(self.btnSearcher, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	endif;
	toolbar.addButton(self.btnUserColours,CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnExportCSV, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCargoEnquiry,CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSummariseAll,CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	if not self.isChildForm then
		toolbar.addButton(self.btnUpdate,CMUI_Toolbar.Control_Alignment_Left);
	endif;
	toolbar.addButton(self.btnCancelForm,CMUI_Toolbar.Control_Alignment_Right);
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;	

	offset := self.tblCargoCounter.top - self.frmToolbar.height;
	self.tblCargoCounter.top := self.tblCargoCounter.top - offset;
	self.tblCargoCounter.height := self.tblCargoCounter.height + offset;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
