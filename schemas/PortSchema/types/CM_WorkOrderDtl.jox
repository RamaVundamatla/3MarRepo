    <JadeMethod name="getTrainsCode" id="16795259-3e74-44ff-a001-29f0e9038898">
        <source>getTrainsCode() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/11/2024	navkc1 JIRA Story MTN-19092: EUP | 54014 - Work Orders Enhancements - Improved Search and usability

*/

vars
	trains 		: CM_TrainSet;
	code, 
	str			: String;
	train		: CM_Train;
begin
	
	create trains transient;
	
	self.getTrains(trains);
	
	foreach train in trains do
		code := train.code;
		
		if code = null then
			continue;
		endif;
		
		/*
		if str = null then
			str &amp;= train.code;
		else
			if str.pos(code, 1) &gt; null then
				continue;
			else
				str &amp;= Comma &amp; code;
			endif;
		endif;
		*/
		
		str.addStringToList(code, Comma); //04/04/2025	navkc1 JIRA Story MTN-33940
	endforeach;	
	
	return str;
epilog
	delete trains;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
