    <JadeMethod name="getDisplayStringForAttribute" id="7e5d4eb5-8502-4223-8ac0-4dc6481ade7f">
        <source>getDisplayStringForAttribute( _attrName : String; _short : Boolean ) : String;

/*
Date			Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498
31/08/2010		cnwrl1	PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
*/

vars
	returnStr	: String;
	
begin
	if _attrName = ETRow_Details then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
		else
			returnStr	:= app.getErrorString( TransType_99 ) &amp; ColonAndSpace &amp; self.stopDescription;
			
			if self.isEventRequestStopClearance then
				returnStr	:=	returnStr &amp;
								app.getString( Stop_Request_Entered ) &amp;
								self.eventRequestEnteredDT.shortCurrentLocaleFormat;
			endif;
			// ### TFS CR 59942 TASK 59943 04SEP2023 NAVAB1
			if self.custDocType &lt;&gt; null then
				returnStr	:=	returnStr &amp; " (" &amp; self.custDocType &amp; ") ";
			endif;
			
			if self.clearanceExpiryDate &lt;&gt; null then
				returnStr	:=	returnStr &amp; Space &amp; Hyphen &amp; Space &amp;
								app.getString( Clearance_Expiry_Date ) &amp; Space &amp; CM_Edit.S_EDIT_THING &amp; Space &amp;
								self.clearanceExpiryDate.shortFormatJMT();
			endif;
			
			if self.requiredInfo &lt;&gt; null then
				
				//09 Feb 2011	NDL	Par 26936
				if self.requiresInfoType = ImportReleasePIN then	
					returnStr := returnStr &amp; CrLf&amp;  //epr tfs 1013 23/6/16 so i can read it in the transaction history
								app.getString( Required_Info_Entered ) &amp; Space &amp;
								app.myRoot.getTranslatedRequiredInfoType( self.requiresInfoType ).display &amp; Space &amp;
								CM_Edit.S_EDIT_THING &amp; Space &amp; self.getImportReleasePIN();
				else
					returnStr := returnStr &amp; CrLf &amp; //epr tfs 1013 23/6/16 so i can read it in the transaction history
								app.getString( Required_Info_Entered ) &amp; Space &amp;
								app.myRoot.getTranslatedRequiredInfoType( self.requiresInfoType ).display &amp; Space &amp;
								CM_Edit.S_EDIT_THING &amp; Space &amp;
								self.requiredInfo.display;
				endif;
			endif;
			
			returnStr	:= returnStr &amp; Period &amp; Space &amp; self.remarks;
			return returnStr;
		endif;
		
	elseif _attrName = ETRow_StopRequestEntered then
		if self.isEventRequestStopClearance then
			returnStr := self.eventRequestEnteredDT.shortCurrentLocaleFormat;
		endif;
		return returnStr;
	
	elseif _attrName = ETRow_StopClearanceExpiry then
		if self.clearanceExpiryDate &lt;&gt; null then
			returnStr := self.clearanceExpiryDate.shortFormatJMT();
		endif;
		return returnStr;
	
	else
		return inheritMethod( _attrName, _short );
	endif;
	
epilog
	
end;
</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="07780795-f8e2-4f89-a374-97bc0b421c4d">
        <source>getEnquiryRow(): String;
//--------------------------------------------------
// Created:	30 May 2005 By: cnwgd1
//--------------------------------------------------
vars

	rowString: String;
begin
	// ### TFS CR 59942 TASK 59943 04SEP2023 NAVAB1
	if self.custDocType &lt;&gt; null then
		rowString := "(" &amp; self.custDocType &amp; ") ";
	endif;

	if self.isEventRequestStopClearance then
		return inheritMethod() &amp; app.getErrorString(TransType_99) &amp; ": " &amp; self.stopDescription &amp; '. Stop request entered ' &amp; self.eventRequestEnteredDT.shortCurrentLocaleFormat &amp; ' ' &amp; self.remarks;	
	else
		return inheritMethod() &amp; app.getErrorString(TransType_99) &amp; ": " &amp; self.stopDescription &amp; 
					rowString &amp; '. ' &amp; self.remarks;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
