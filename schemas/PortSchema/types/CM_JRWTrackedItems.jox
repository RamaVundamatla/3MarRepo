    <JadeMethod name="clearReportingCollection" id="2cd8deeb-550c-48d6-beed-e449bffebeae">
        <source>clearReportingCollection();
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		14 April 2010
//
// Implemented version: JMT 7.8.2
// Date  		User  		Change
// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface
//----------------------------------------------------------------------
vars

begin
	self.allTrackedItems.clear();

epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="copyReportItemsToCollection" id="cb97d4c0-7502-43a0-af4f-6637f84b05bd">
        <source>copyReportItemsToCollection(_collection: Collection; _collectionItem : Integer);  
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		14 April 2010
//
// Implemented version: JMT 7.8.2
// Date  		User  		Change
// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface
// Copy items to a collection on the JRWTransient.
// This is the collection we use to throw at the report desgin.  We assume we have
// already filtered the objects in the collection
// 
// Parameters: 	_collection - the collecton of objects we're reporting on
//				
//				_collectionItem - a way of identifying which collection we're going to be using.  This is arbitrary and 
//								  and is dependent on what collections exist on the JRWTransient.  There are some JRWTransients
//								  that have more than one collection that can be used for reporting.
//----------------------------------------------------------------------
vars

begin
	_collection.copy(self.allTrackedItems);

epilog
end;</source>
        <Parameter name="_collection" type="Collection"/>
        <Parameter name="_collectionItem" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="delete" id="6c01d418-0751-4148-9864-64bedc09e37a">
        <source>delete();
// -------------------------------------------
// Created 02 March 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	self.allSummaryTIs.purge();
	self.allStorageLines.purge();
	self.allOrganisationCargo.purge();

end;</source>
    </JadeMethod>
    <JadeMethod name="getQryEndDateLocalTZ" id="3a5b2655-d263-469f-b12d-d259afc8770d">
        <source>getQryEndDateLocalTZ() : Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2016	cnwns1	Initial creation
// 03 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	sysTS : TimeStamp;
begin
	sysTS.cnEcSetDateAndTime(self.qryEndDate,TimeEndOfDay);
	return self.systemToLocalTime(sysTS).date();
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getQryReceivedDTLocalTZ" id="3a28afd4-5577-46d1-9403-120c54b9ee69">
        <source>getQryReceivedDTLocalTZ(): TimeStamp;
/*

Purpose:			Return the local timezone version of the receiver's dateTime (for JRW)

Parameters:			None

Return Value:		

Date		Who		Reason
02 Jun 2016	cnwmp6	TFS 488 - Multi Timezone Support

*/
vars

begin
	return self.systemToLocalTime(self.qryReceivedDT);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getQryStartDateLocalTZ" id="fee98d6c-5b60-4da7-bb92-8147d916b0b0">
        <source>getQryStartDateLocalTZ():Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2016	cnwns1	Initial creation
// 03 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	sysTS : TimeStamp;
begin
	sysTS.cnEcSetDateAndTime(self.qryStartDate,TimeStartOfDay);
	return self.systemToLocalTime(sysTS).date();
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="noOutputReturned" id="f8002607-47c2-4b6a-b231-14d63a5616b6">
        <source>noOutputReturned(): Boolean;
// -------------------------------------------
// Created 21 September 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	if self.allTrackedItems.isEmpty() 
	and self.allStorageLines.isEmpty()
	and self.allSummaryTIs.isEmpty()
	and self.allOrganisationCargo.isEmpty() then
		return true;
	endif;
	return false;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="selectionCriteria" id="7eb6b8ac-de41-41ef-921d-ce1523d529fa">
        <methodInvocation>mapping</methodInvocation>
        <source>selectionCriteria(set: Boolean; _value: String io) mapping;
//----------------------------------------------------------------
//	Created:	04 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	str	: String;
begin
	inheritMethod(set, _value);

	if set then
		return;
	endif;
	
	str :=_value;
	
	if self.qryCargoType &lt;&gt; null then
		
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; "Cargo Type:";
		else
			str :=              "Cargo Type:";
		endif;
	endif;
	
	if self.qryDischargePort &lt;&gt; null then
		
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; "Disch. Port:";
		else
			str :=              "Disch. Port:";
		endif;
	endif;
	
	if self.qryTranshipToPort &lt;&gt; null then
		
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; "Transh. Port:";
		else
			str :=              "Transh. Port:";
		endif;
	endif;
	
	if self.myTerminalArea &lt;&gt; null then
		
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; "Term. Area:";
		else
			str :=              "Term. Area:";
		endif;
	endif;
	
	if self.qrySiteStateString &lt;&gt; null then
		
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; "Site:";
		else
			str :=              "Site:";
		endif;
	endif;

	if self.qryVoyageJobs &lt;&gt; null then
		
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; "Voyage Jobs:";
		else
			str :=              "Voyage Jobs:";
		endif;
	endif;
	
	if self.myISOTypeGroup &lt;&gt; null then
		
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; "ISOType Group:";
		else
			str :=              "ISOType Group:";
		endif;
	endif;
	
	if self.myOperatorGroup &lt;&gt; null then
		
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; "Operator Group:";
		else
			str :=              "Operator Group:";
		endif;
	endif;
	
	if self.myVoyage &lt;&gt; null then
		
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; "Voyage:";
		else
			str :=              "Voyage:";
		endif;
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; "Vessel:";
		else
			str :=              "Vessel:";
		endif;
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; "Est. Arrival:";
		else
			str :=              "Est. Arrival:";
		endif;
		
	endif;
		
	if self.myLoadPort &lt;&gt; null then
		
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; "Load Port:";
		else
			str :=              "Load Port:";
		endif;
		
	endif;

// Par10508
	if self.qryStartDate &lt;&gt; null then
		
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; "Start Date:";
		else
			str :=              "Start Date:";
		endif;
		
	endif;	
	
	if self.qryEndDate &lt;&gt; null then
		
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; "End Date:";
		else
			str :=              "End Date:";
		endif;
		
	endif;
	
	
	if self.qryId &lt;&gt; null then
		
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; "Container Id:";
		else
			str :=              "Container Id:";
		endif;
		
	endif;

epilog
	_value := str;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="selectionCriteriaValues" id="2699e891-db43-4215-ac39-1b24fa852db6">
        <methodInvocation>mapping</methodInvocation>
        <source>selectionCriteriaValues(set: Boolean; _value: String io) mapping;
//----------------------------------------------------------------
//	Created:	05 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//05/06/19	JLGNS1	Bug 45031: LNX - Date format on the No Data Report is not as expected
vars
	str,
	strArrDate	: String;
begin
	inheritMethod(set, _value);

	if set then
		return;
	endif;
	
	str :=_value;
	
	if self.qryCargoType &lt;&gt; null then
		
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; self.qryCargoType;
		else
			str := self.qryCargoType;
		endif;
	endif;
	
	if self.qryDischargePort &lt;&gt; null then
		
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; self.qryDischargePort;
		else
			str := self.qryDischargePort;
		endif;
	endif;
	
	if self.qryTranshipToPort &lt;&gt; null then
		
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; self.qryTranshipToPort;
		else
			str := self.qryTranshipToPort;
		endif;
	endif;
	
	if self.myTerminalArea &lt;&gt; null then
		
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; self.myTerminalArea.id;
		else
			str := self.myTerminalArea.id;
		endif;
	endif;
	if self.qrySiteStateString &lt;&gt; null then
		
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; self.qrySiteStateString;
		else
			str := self.qrySiteStateString;
		endif;
	endif;

	if self.qryVoyageJobs &lt;&gt; null then
		
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; self.qryVoyageJobs;
		else
			str := self.qryVoyageJobs;
		endif;
	endif;
	
	if self.myISOTypeGroup &lt;&gt; null then
		
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; self.myISOTypeGroup.code;
		else
			str := self.myISOTypeGroup.code;
		endif;
	endif;
	
	if self.myOperatorGroup &lt;&gt; null then
		
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; self.myOperatorGroup.code;
		else
			str := self.myOperatorGroup.code;
		endif;
	endif;
		
	
	if self.myVoyage &lt;&gt; null then
		
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; self.myVoyage.code;
		else
			str := self.myVoyage.code;
		endif;
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; self.myVoyage.vesselName;
		else
			str := self.myVoyage.vesselName;
		endif;
		if self.myVoyage.departedDT.isValid then
			strArrDate := self.myVoyage.arrivedDT.shortCurrentLocaleFormat;
		else
			strArrDate := "Unknown";
		endif;
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; strArrDate;
		else
			str := strArrDate;
		endif;
	endif;

	if self.myLoadPort &lt;&gt; null then
		
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; self.myLoadPort.code &amp; " - " &amp; self.myLoadPort.description;
		else
			str :=              self.myLoadPort.code &amp; " - " &amp; self.myLoadPort.description;
		endif;
		
	endif;
	
	if self.qryStartDate.isValid() then
		
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; self.qryStartDate.userFormat($CnDD_MMM_YY);	//Bug 45031
		else
			str := self.qryStartDate.userFormat($CnDD_MMM_YY);				//Bug 45031
		endif;
		
	endif;
			
	if self.qryEndDate.isValid() then
		
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; self.qryEndDate.userFormat($CnDD_MMM_YY);	//Bug 45031
		else
			str := self.qryEndDate.userFormat($CnDD_MMM_YY);				//Bug 45031
		endif;
		
	endif;
	
	if self.qryId &lt;&gt; null then
		
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; self.qryId;
		else
			str := self.qryId;
		endif;
		
	endif;
	
epilog
	_value := str;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="thisPort" id="d74e64a3-0ee0-4f29-9b48-68693c7ba100">
        <methodInvocation>mapping</methodInvocation>
        <source>thisPort(set: Boolean; _value: CM_Port io) mapping;
// ---------------------------------------------------------------------------
// Created:     22 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	portCode		:	String;
	terminal		: CM_Terminal;
begin
	if set then
		return;
	endif;
	
	if self.myVoyage &lt;&gt; null then
		portCode := self.myVoyage.myTerminal.getConfig(PortDestCode).String.trimBlanks;
		//_value := app.myRoot.allPorts[portCode];
		_value := app.myRoot.allPorts[portCode];
	elseif self.allTerminals.size = 1 then
		terminal := self.allTerminals.first;
		portCode := terminal.getConfig(PortDestCode).String.trimBlanks;
		//_value := app.myRoot.allPorts[portCode];
		_value := app.myRoot.allPorts[portCode];
	endif;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_Port" usage="io"/>
    </JadeMethod>
</Class>
