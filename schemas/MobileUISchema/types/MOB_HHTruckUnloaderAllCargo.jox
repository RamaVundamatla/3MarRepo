    <JadeMethod name="getMultiObjectCaption" id="ad86ac60-a363-436c-87f2-60749942e832">
        <source>getMultiObjectCaption( _tiArray : CM_TIArray ):String protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 September 2011	cnwndl1	Initial creation	Par 28285

*/

vars

	ti : CM_TrackedItem;
	lastTi : CM_TrackedItem;
	pos : Integer;
	rangeId : String;

begin

	ti := _tiArray.first.CM_TrackedItem;
	lastTi := _tiArray.last.CM_TrackedItem;
	
	// find the first pos of the id that differs
	foreach pos in 1 to ti.id.length do
		if ti.id[pos] &lt;&gt; lastTi.id[pos] then
			break;
		endif;
	endforeach;
	// get the remainder of the id
	rangeId := lastTi.id[pos:end];
			
	return "(" &amp; _tiArray.size.String &amp; "x) " &amp; ti.cargoTypeDescr &amp; CrLf &amp; ti.id &amp; " - " &amp; rangeId;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_tiArray" type="CM_TIArray"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMultiSize" id="e25ecc12-89a1-4133-8d91-8effee6470eb">
