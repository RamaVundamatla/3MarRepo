    <JadeMethod name="setCurrentTotalOfPorts" id="ab887348-0181-455a-85f1-03fa57d8851f">
        <updating/>
        <source>setCurrentTotalOfPorts( _value : Integer ) updating;

vars
	
begin
	if self.currentTotalOfPorts &lt;&gt; _value then
		self.currentTotalOfPorts	:= _value;
	endif;
	
epilog
	
end;
</source>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="2616ddf4-5ef6-4f47-9e46-f8e57454b987">
        <updating/>
        <source>setupForm() updating;

// 03 Jun 2009	concms1	Par 19013 - Filter by Rail
vars
	tempStr		: String;
	
begin
	inheritMethod();
	
//	self.caption := 'Port Code Finder';	// cnwrl1 27/05/2009 PAR 19672 - what it was
	
	self.autoRedraw			:= true;
	self.tblLocodes.columns	:= 6;	// changed from 5
	self.tblLocodes.row		:= 1;

	// par 19013 - start
	if self.isRail then
		lblRailOnly.visible 	:= true;
		chkRailOnly.visible		:= true;
		chkRailOnly.value 		:= true;
		tblLocodes.columnVisible[5]	:= true;
	else
		lblRailOnly.visible 	:= false;
		chkRailOnly.visible		:= false;
		chkRailOnly.value 		:= false;	
		tblLocodes.columnVisible[5]	:= false;
	endif;
	// par 19013 - end
	
	tempStr						:=	app.getErrorString( Info_PortCode ) &amp; Tab &amp;
									app.getErrorString( Location ) &amp; Tab &amp;
									app.getErrorString( Country_Code ) &amp;  Tab &amp;
									app.getErrorString( Is_A_Port ) &amp; Tab &amp;
									app.getErrorString( Is_Rail ) &amp; Tab &amp;		// par 19013
									app.getErrorString( Active ); 
	self.tblLocodes.text		:= tempStr;
	self.frmToolbarBtns.visible	:= false;
	
	if self.multiSelect then												// par 19013
		self.tblLocodes.multiSelect	:= CM_DataTable.MultiSelect_Simple;
		self.btnAdd.visible			:= true;								// par 19013
	else																	// par 19013
		self.tblLocodes.multiSelect	:= CM_DataTable.MultiSelect_None;		// par 19013
		self.btnAdd.visible			:= false;								// par 19013
	endif;																	// par 19013
	
	self.tblLocodes.selectionType	:= CM_DataTable.SelectionType_Row;
	
	// cnwrl1 27/05/2009 PAR 19672
	self.centreOverParent( 400 );			// keeps the form on the same monitor as the parent form.
	self.txtPortCode.setFocus;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tblLocodes_dblClick" id="2ae8437f-4700-44d6-890e-2e1f67913160">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblLocodes_dblClick(table: Table input) updating;

// Created by cnwdvb1 on 07 April 2006

// 03 Jun 2009	concms1	par 19013 - use interface if we have one

vars

begin

	if table.row = table.fixedRows then
		table.sortColumn[ 1 ]	:= table.column;
		table.sortType[ 1 ]		:= table.SortType_Alpha;
		table.sortAsc[ 1 ]		:= not table.sortAsc[ 1 ];
		table.resort();
		return;
	endif;
	
	// par 19013
	if self.myInterfaceObject &lt;&gt; null then
		self.addPorts;
		self.unloadForm;
		return;
	endif;
	// otherwise make this port active and add it to the calling form
	self.makeActive();
	self.btnAdd.click( self.btnAdd );
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="ef58ab74-59f0-4b9e-be09-96bc3187b474">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0010901, locale);
	btnAdd.translateCaption(Xlat_0010469, locale);
	btnAddClose.translateCaption(Xlat_0010470, locale);
	btnClose.translateCaption(Xlat_0010471, locale);
	btnSearch.translateCaption(Xlat_0010902, locale);
	lblActiveOnly.translateCaption(Xlat_0010468, locale);
	lblCountry.translateCaption(Xlat_0010903, locale);
	lblPortCode.translateCaption(Xlat_0010904, locale);
	lblPortDesc.translateCaption(Xlat_0010905, locale);
	lblRailOnly.translateCaption(Xlat_0012009, locale);
end;</source>
    </JadeMethod>
</GUIClass>
