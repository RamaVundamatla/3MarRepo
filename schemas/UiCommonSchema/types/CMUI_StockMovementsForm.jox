    <JadeMethod name="setQueryParametres" id="51a35834-b52e-4758-99eb-19c24dde0494">
        <updating/>
        <source>setQueryParametres() updating;
// ---------------------------------------------------------------------------
// Created:     31 July 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	self.filtOpenDate	:=	tblEntQuery.getValueByName(ETRow_OpenDate).Date;
	self.filtCloseDate	:=	tblEntQuery.getValueByName(ETRow_CloseDate).Date;
