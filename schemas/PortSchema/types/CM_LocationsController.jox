    <JadeMethod name="setHazardLocations" id="75f1e574-a180-4c7e-92b8-8536fb13a8fb">
        <updating/>
        <source>setHazardLocations(_ti : CM_TrackedItem) updating;

// NOT USED anymore, except of oringinal upgrade scripts.
// Used setHazardLocationsForMode instead

/*
----------   ----------  --------------------------------------------------
Created:	27 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason

23 July 2015	NDL	Par 36568	- remove use of LC collection with 'myTerminalArea' as key, replace with LC Set
	
----------   ----------  --------------------------------------------------
*/
vars
	vertSpan,
	horzSpan,
	depthSpan			: Integer;
	notSameArea			: Boolean;
	lc					: CM_LocationsController;
	lcDict 				: CM_LCSet;
begin
	if _ti = null or (not _ti.isHazardous) then
		return;
	endif;
	
	if self &lt;&gt; _ti.myPrimaryActualLocation then
		app.raiseUnexpectedProgramError(class.name, method.name, 'self. does not equal the TIs primary actual location (' &amp; self.String &amp; ')');
		return;
	endif;
	
	_ti.getLargestHazardArea(self.getHazardSegregationRuleType(), vertSpan, horzSpan, depthSpan, notSameArea);
	if notSameArea then
		if (not self.myTerminalArea.allHazardousTIs.includes(_ti)) then
			self.myTerminalArea.allHazardousTIs.add(_ti);
		endif;
	endif;
	
	if vertSpan = null and horzSpan = null and depthSpan = null then
		return;
	endif;
	
	create lcDict transient;
	self.getLocationsForSpan(vertSpan, horzSpan, depthSpan, lcDict);
	
	foreach lc in lcDict do
		if (not lc.allHazardousTIs.includes(_ti)) then
			lc.allHazardousTIs.add(_ti);
		endif;
	endforeach;
	
epilog
	delete lcDict;
end;


</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setHazardLocationsForMode" id="c9763b29-5dda-4a50-99c8-13071f1569e3">
        <updating/>
        <source>setHazardLocationsForMode(_ti : CM_TrackedItem; _mode : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		April 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

//23 July 2015	NDL	Par 36568	- remove use of LC collection with 'myTerminalArea' as key, replace with LC Set
vars
	vertSpan,
	horzSpan,
	depthSpan			: Integer;
	notSameArea			: Boolean;
	lc					: CM_LocationsController;
	lcDict 				: CM_LCSet;
	tiCol : CM_TISet;
	tmpStr : String;
begin
	if _ti = null or (not _ti.isHazardous) then
		return;
	endif;
	
	if _mode = REAL_MODE then
		lc := _ti.myPrimaryActualLocation;
		tmpStr := "actual";
	elseif _mode = PLANNING_MODE then
		lc := _ti.myPrimaryPlannedLocation;
		tmpStr := "planned";
	elseif _mode = QUEUE_MODE then
		lc := _ti.myPrimaryQueuedLocation;
		tmpStr := "queued";
	endif;

	if self &lt;&gt; lc then
		app.raiseUnexpectedProgramError(class.name, method.name, 'self. does not equal the TIs primary ' &amp; tmpStr &amp; ' location (' &amp; self.String &amp; ')');
		return;
	endif;
	
	
	_ti.getLargestHazardArea(self.getHazardSegregationRuleType(), vertSpan, horzSpan, depthSpan, notSameArea);
	
	if notSameArea then
		if _mode = REAL_MODE then
			if (not self.myTerminalArea.allHazardousTIs.includes(_ti)) then
				self.myTerminalArea.allHazardousTIs.add(_ti);
			endif;
		endif;
	endif;
	
	if vertSpan = null and horzSpan = null and depthSpan = null then
		return;
	endif;
	
	create lcDict transient;
	self.getLocationsForSpan(vertSpan, horzSpan, depthSpan, lcDict);
	
	foreach lc in lcDict do
		if _mode = REAL_MODE then
			if (not lc.allHazardousTIs.includes(_ti)) then
				lc.allHazardousTIs.add(_ti);
			endif;
		elseif _mode = QUEUE_MODE then
			if (not lc.allHazardousTIsQueued.includes(_ti)) then
				lc.allHazardousTIsQueued.add(_ti);
			endif;
		elseif _mode = PLANNING_MODE then
			if (not lc.allHazardousTIsPlanned.includes(_ti)) then
				lc.allHazardousTIsPlanned.add(_ti);
			endif;
		endif;
	endforeach;
	
epilog
	delete lcDict;
end;


</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
