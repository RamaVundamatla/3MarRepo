    <JadeMethod name="load" id="27adddad-7a7c-4f73-8135-f948fd292424">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
08 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars
	control			: TestAppControl;
	
begin
	app.cnActivateKarmaControl(Cn_Fat_Client, null, null);

	myControl := TestAppControl.firstInstance;
	beginNotification(myControl, Object_Update_Event, Response_Continuous, null);
	
	logMessage("Registered for updates to " &amp; myControl.String);
	
	setCaption;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="logMessage" id="30e0f86d-2202-463c-a3d3-73be8ae64260">
        <source>logMessage(msg : String);

/*

Purpose:			


Return Value:		


Date		Who		Reason
09 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	
begin
	if runningSilent then
		return;
	endif;
	
	inheritMethod(msg);
	
	listBox1.addItemAt(app.actualTimeServer.time.displayWithMilliseconds &amp; " " &amp; msg.truncateWithEllipsis(100), 1);// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	listBox1.topIndex := 1;
	listBox1.refreshNow;
	

epilog

end;</source>
        <Parameter name="msg" type="String"/>
    </JadeMethod>
    <JadeMethod name="setCaption" id="fea40f2d-56eb-4511-9c02-64647066d713">
        <updating/>
        <source>setCaption() updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
09 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars
	pid, 
	result			: Integer;
	
begin
	caption := "TCP Listener Test";
		
	result := app.myCnKarmaCntrl.getProcessId(pid);
	if result = 0 then
		caption := caption &amp; " - PID " &amp; pid.String;
	endif;
	refreshNow;	
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupMyTCPSession" id="dcb69e88-24c0-4412-bbd1-0dcfa5ca6c40">
        <updating/>
        <source>setupMyTCPSession() : Boolean updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
09 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars
	tcpScript		: TCPSessionScript;
		
begin
	// Handle errors - relinquish control of current session script
	if myTCPSessionScript &lt;&gt; null then
		unlock(myTCPSessionScript);
		myTCPSessionScript := null;
	endif;
	
	foreach tcpScript in myControl.allTCPSessionScripts discreteLock do
		if tryLock(tcpScript, Reserve_Lock, Session_Duration, LockTimeout_Immediate) then
			myTCPSessionScript := tcpScript;
			logMessage("Processing script " &amp; myTCPSessionScript.String);
			break;
		endif;
	endforeach;
	
	if myTCPSessionScript = null then
		logMessage("No script found");
		return false;
	endif;
	
	return true;
	

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="844ab76b-db88-484f-8f91-46ea3b0c911f">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
09 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition


*/

vars
	i				: Integer;
	returnedMsg,
	tcpMessage		: String;
	payload			: TCPMessagePayload;

begin
	if eventType = Object_Update_Event and theObject = myControl then
		runningSilent := false;
		
		self.logMessage("Update notification received");
		
		if self.myControl.state = TestAppControl.STATE_GO then
		
			if not self.setupMyTCPSession() then
				return;
			endif;

			setCaption;			
		
			runningSilent := self.myControl.silentMode;
			
			while i &lt; self.myControl.numMessages do : outerLoop
	
				logMessage("Starting script iteration " &amp; (i + 1).String &amp; " of " &amp; self.myControl.numMessages.String);

				foreach payload in self.myTCPSessionScript.allTCPMessages do
	
					// Need to get latest version of control object
					// in case we've been told to stop
					sharedLock(self.myControl);
					unlock(self.myControl);
		
					if self.myControl.state = TestAppControl.STATE_STOP then
						self.logMessage("Told to stop processing");
						break outerLoop;
					elseif self.myControl.state = TestAppControl.STATE_TERMINATE then
						break outerLoop;
					endif;
					
					// Must be a go, so send message
					self.sendTCPMessage(payload);
					
				endforeach;
				
				i := i + 1;
			endwhile;
		endif;
		
		runningSilent := false;
		
		if self.myControl.state = TestAppControl.STATE_TERMINATE then
			self.logMessage("Terminate requested");
			terminate;
		endif;
		
		self.logMessage("Stopped processing");
		
	endif;


epilog
	if self.myTCPSessionScript &lt;&gt; null then
		unlock(self.myTCPSessionScript);
	endif;
	
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
</GUIClass>
