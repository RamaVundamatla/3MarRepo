    <JadeMethod name="openRulesConfigForm" id="874f4b5a-7721-4586-9897-0c7c4a3d5068">
        <updating/>
        <source>openRulesConfigForm(_isEdit : Boolean) protected, updating;
// -------------------------------------------
// Created 30 November 2005 by cnwdvb1
// -------------------------------------------
vars

	form			: CMUI_MachineRulesConfigFormNew;
	rule			: CM_RTQueueMultiRule;

begin

	if not app.myCurrentUserCan( self.myTerminal, PmAdmMachineRulesMaint ) then	//PAR 19657, 04 Sep 2009
		return;
	endif;
	
	if _isEdit then
		rule := self.myCurrentRule;
		if rule = null then
			return;
		endif;
	endif;
	
	form := app.loadForm(CMUI_MachineRulesConfigFormNew, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_MachineRulesConfigFormNew;

	if form = null then
		return;
	endif;

	form.setMyRule(rule);
	form.centreWindow;

	form.showModal;
	

end;</source>
        <access>protected</access>
        <Parameter name="_isEdit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="queryMachineTypeGrpFilter" id="5efa2df5-a569-467a-910c-36e38729d3d5">
        <source>queryMachineTypeGrpFilter(_rule :  CM_RTQueueMultiRule ) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	cnwer1	Initial creation

*/

vars
	hasRule : Boolean;
begin
	hasRule:=false;
	
	if _rule.allDefaultRTMoveMethodRules.isEmpty then
		return true;
	endif;
	
	if  self.chkStrad.value then
		hasRule:= _rule.includesRTMoveMethodRuleOfType(MACHINETYPEGRP_STRADDLE);
	endif;
	if  self.chkFork.value then
		hasRule:=hasRule or _rule.includesRTMoveMethodRuleOfType(MACHINETYPEGRP_LIFTER);
			
	endif;
	if  self.chkRTG.value then
		hasRule:=hasRule or _rule.includesRTMoveMethodRuleOfType(MACHINETYPEGRP_RTG);
			
	endif;
	if  self.chkIMV.value then
		hasRule:=hasRule or  _rule.includesRTMoveMethodRuleOfType(MACHINETYPEGRP_IMV) ;
		
	endif;
	//jlier1 TFS 54701 16/9/22
	if self.chkMAFI.value then
			hasRule:=hasRule or  _rule.includesRTMoveMethodRuleOfType(MACHINETYPEGRP_MAFI) ;
	endif;
	//jlier1 TFS  54701 16/9/22
	if self.chkTractor.value then
		hasRule:=hasRule or  _rule.includesRTMoveMethodRuleOfType(MACHINETYPEGRP_TRACTOR) ;
	endif;
	return hasRule;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rule" type="CM_RTQueueMultiRule"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
