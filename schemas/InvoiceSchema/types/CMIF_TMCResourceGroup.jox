<Class name="CMIF_TMCResourceGroup" id="b95833db-4430-4965-aa1d-92e04259111f">
    <superclass name="CMIF_TMCGroup"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="invoice"/>
    <ImplicitInverseRef name="myResource" id="c55a8252-e699-4570-9d53-381ef694b2e2">
        <embedded/>
        <type name="HMS_Resource"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myResourceBroker" id="8888dd13-8f42-445e-844a-92e868cbf129">
        <embedded/>
        <type name="CM_ResourceServiceBroker"/>
    </ImplicitInverseRef>
    <JadeMethod name="getPicture" id="da3f5b3a-dd41-4346-a4dd-c0456d58894a">
        <source>getPicture(form: INV_TransactionMap): Picture;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if self.hidePictures then
		return null;
	endif;
	return form.picTrans;
end;</source>
        <Parameter name="form" type="INV_TransactionMap"/>
        <ReturnType type="Picture"/>
    </JadeMethod>
    <JadeMethod name="getRealMapObject" id="d6caf104-509e-4c13-b2b4-3fde26ac608b">
        <source>getRealMapObject(): Object;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	return self.myResourceBroker;

end;</source>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="060b6383-d9ff-42d1-a4b8-7decf14f367b">
        <updating/>
        <source>initialise(_groupCount : Integer io) updating;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmcDebtor : CMIF_TMCDebtorGroup;
	aDM : CM_DebtorMap;
begin
	self.myTMCController := self.myGroup.myTMCController;	// April 2010, cnwjre1, par 23659, invoice transaction map extract enhancements for Tranship IMEX status
	self.hidePictures := self.myTMCController.hidePictures;
	create tmcDebtor as CMIF_TMCDebtorGroupDefault;
	tmcDebtor.myDebtor := null;
	tmcDebtor.myDebtorMap := null;
	tmcDebtor.myServiceBroker := self.myResourceBroker;
	tmcDebtor.itemName := tmcDebtor.getItemName();
	tmcDebtor.extractName := tmcDebtor.getItemCode();	// 23659
	tmcDebtor.myGroup := self;
	tmcDebtor.initialise(_groupCount);

	foreach aDM in self.myResourceBroker.allDebtorMapsByDebtor do
		create tmcDebtor;

		tmcDebtor.myDebtor := aDM.myDebtorNode;
		tmcDebtor.myDebtorMap := aDM;
		tmcDebtor.itemName := tmcDebtor.getItemName();
		tmcDebtor.extractName := tmcDebtor.getItemCode();	// 23659
		tmcDebtor.myGroup := self;
		tmcDebtor.initialise(_groupCount);
	endforeach;
	
	_groupCount:= _groupCount + 1;
end;</source>
        <Parameter name="_groupCount" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setControllerCurrent" id="7dad814e-8752-4baf-b374-274b68a17201">
        <source>setControllerCurrent() ;
// April 2010, cnwjre1, par 23659, invoice transaction map extract enhancements for Tranship IMEX status
vars

begin
	inheritMethod();
	
	myTMCController.myCurrentMapTMVoyage := self.myResourceBroker.myTransMap;
	myTMCController.myCurrentMapServiceBroker := self.myResourceBroker;

end;</source>
    </JadeMethod>
    <JadeMethod name="setEnableObjects" id="7474b0a9-a167-4e51-abc0-7fca5ead368b">
        <source>setEnableObjects(form: INV_TransactionMap io);
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(form);

	form.menuTMVnew.visible := true;  // MAIN VTMIS NEW MENU
	form.menuSItemNew.visible := false;  // MAIN CARGO NEW MENU	
	form.mnuTMExport.visible := false;
	form.menuMappingSetActive.visible := false;
	form.modePropertyNew := INV_TransactionMap.ModeProperty_Debtor;
	form.modePropertyUpdate := INV_TransactionMap.ModeProperty_TransType;
	form.modePropertyDelete := INV_TransactionMap.ModeProperty_Resource;

	form.menuTMVnew.enabled := true;
	form.menuTMVDebtor.visible := true;
	form.menuTMVDebtor.enabled := true; // TFS 2994
	form.menuSItemDelete.visible := true;
	
	form.btnDelete.enabled := true;
	form.btnNew.enabled := true;

end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrent" id="681500a3-b8b7-4937-adc6-9d4dfdddd75d">
        <updating/>
        <source>setMyCurrent(form: INV_TransactionMap io) updating;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(form);
	
	form.myCurrentMapTMVoyage := self.myResourceBroker.myTransMap;
	form.myCurrentMapServiceBroker := self.myResourceBroker;

end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
</Class>
