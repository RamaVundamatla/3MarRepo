		) updating;
//18 January 2010	cnwml2
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------------
// 27/11/2013	cnwdap1		PAR #33019 CCMS DPH 2285 New BOL Fields
// 20/07/2022   navgm20     ChangeRequest 54095: EUP - Outturn Remarks on BOL
vars

begin
	//inheritMethod(_bolNumber, _voyage, _operator, _notifyParty, _numItems, _bolType, _terminal, _subTerminal, _destination, _dischargePort, _loadPort, _directDelivery);
	inheritMethod(	_bolNumber, 
					_voyage, 
					_operator, 
					_notifyParty, 
