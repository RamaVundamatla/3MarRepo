vars

begin

	self.drawFillColor := Black;
	self.drawFilledRectangle(20, 20, 100, 100, Black);
	self.drawRectangle(20, 20, 100, 100, Black);
	self.drawLine(20, 20, 100, 100, Black);
	
	self.frame2.zOrder(2);
	self.frame1.zOrder(1);
	self.frame3.zOrder(3);
	
	self.frame1.drawFillColor := Black;
	self.frame1.drawFilledRectangle(100, 100, 200, 200, Black);
	
	self.frame1.drawFillColor := Green;
	self.frame2.drawFilledRectangle(100, 100, 200, 200, Green);
	
epilog

end;</source>
