    <JadeMethod name="doFrameDrawMouseDownOther" id="d02bfa41-eaf4-429f-bb51-57cb630dca86">
        <updating/>
        <source>doFrameDrawMouseDownOther(_frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     January 2010 ANDREW BISHOP
//
// CALLED BY CALLED BY CMUI_POINTDRAWINGFRAME, no references
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	frame : CMUI_PointDrawingFrame;
	now : Time;
	nowInt : Integer;

begin
	now := app.actualTimeServer().time();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	//	all the frames are stacked on top of each other.
	//	when the user clicks on the drawing frame we pass the click through to the current back frame.
	// if there is no current back frame then we iterate through all the back frames checking if the click can find a poly to select
	frame := self.myCurrentDrawingFrame;
	if frame = null then
		while true do
			backFrameIndex := backFrameIndex + 1;
			if backFrameIndex &gt; self.myROROPlanDrawController.allBackFrames.size then
				backFrameIndex := 0;

// PAR 29608				if self.modeWork &lt;&gt; self.WorkMode_Job then // PAR 29608
// PAR 29608					self.doMnuDeselectAll(); // CLICKING ON NOTHING so DE SELECT
// PAR 29608				else
					// PAR 29608 - users clicking very, ends up de selecting. So we have 'turned it off', unless it is more than 1.5 seconds since last click.
					nowInt := now.getTotalMilliseconds;
					
					if lastClickMilliseconds = 0 or ((nowInt - lastClickMilliseconds) &gt; 1500) then
						lastClickMilliseconds := 0;
						self.doMnuDeselectAll(); // CLICKING ON NOTHING so DE SELECT
					endif;
	// PAR 29608			endif;
				
				return;
			endif;
			frame := self.myROROPlanDrawController.allBackFrames[backFrameIndex].CMUI_PointDrawingFrame;
			if frame = null then
				backFrameIndex := 0;
				return;
			elseif frame.userObject.CM_DeckLayerLayout.type = ROROLayerType_Structure then
				continue;
			elseif not frame.userObject.CM_DeckLayerLayout.isVisible then
				continue;
			elseif not frame.visible then
				continue;
			else
				break;
			endif;
		endwhile;
	else
		if backFrameIndex= -99 then
			backFrameIndex := 0;
			return;
		endif;
		backFrameIndex := -99;
	endif;
//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1. ' &amp; frame.name);
	frame.doFrameMouseDownLeft(frame, button, shift, x, y);
end;</source>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doFrameDrawMouseMoveDisplay" id="fd61a2c3-c925-4b76-bd7d-dd33eea1f236">
        <updating/>
        <source>doFrameDrawMouseMoveDisplay(_frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*
Purpose:	CALLED BY CMUI_POINTDRAWINGFRAME, no references		
Date		Who		Reason
19 September 2011	cnwab1	Initial creation
*/

vars
	dragCursorObj	: Picture;
	tmpDrawController : SHP_ROROPlanDrawingController;
	tmpObj : Object;
	theLC : CM_LocationsController;
	theFrame : Frame;
	theTI : CM_TrackedItem;
	theWLE : CM_WorkListEntry;
begin
	tmpDrawController := self.myROROPlanDrawController;
	theFrame := self.frmDeck.myDrawingFrame;



	if button = Window.MouseButton_Left 
	and (self.modeView = ShpDisplayMode_Actual or self.modeView = ShpDisplayMode_ColCodeDisch) // PAR 31870
	and shift.hasNoKeyboardPressed() 
	and app.dragDetected(x, y, self.origXPos, self.origYPos)
	then
		// initiate a drag/drop
		tmpObj := tmpDrawController.getLCFromXYWithTI(self.origXPos, self.origYPos, self.moveModeForm);

		if tmpObj = null  then
			return;
		endif;
		theLC := tmpObj.CM_LocationsController;
		
		theTI := theLC.getNextTIToBeOfMode(self.moveModeForm);
		if theTI = null then
			return;
		endif;
		
		theWLE := theTI.getVoyageWLEUnactioned(false);
		
		app.myDraggedTrackedItem := theTI;
		app.isDragging := true;
		
		self.setMoveControllerSource(theTI); // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;
		
		theLC.getAllTIToBeOfMode(self.moveModeForm,app.myMoveController.allOtherTrackedItems, app.myMoveController.allOtherWLEs, false); // PAR 31870
		app.myMoveController.allOtherTrackedItems.removeIfPresent(theTI); // PAR 31870 PAR32216 changed to removeIfPresent
		app.myMoveController.allOtherWLEs.removeIfPresent(theWLE); // PAR 31870 PAR32216 changed to removeIfPresent
		app.myMoveController.setMyWorkListEntry(theWLE); // PAR 31870

		theFrame.dragMode	:=	self.DragMode_Drag;
		create dragCursorObj transient;

		self.setPictureDragCursor(dragCursorObj);
		if dragCursorObj &lt;&gt; null then
			theFrame.dragCursor	:=	dragCursorObj.picture;
			theFrame.CMUI_PointDrawingFrame.setPropertyValue("dragging",true);
		endif;
	endif;
epilog
	delete dragCursorObj;

end;</source>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doFrameDrawMouseUpEvent" id="b1fde2e7-dfcc-4a56-b845-8d617ef83dac">
        <updating/>
        <source>doFrameDrawMouseUpEvent(_frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     January 2010 ANDREW BISHOP
//
// CALLED BY CMUI_POINTDRAWINGFRAME, no references
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
		now : Time;
begin
	now := app.actualTimeServer().time();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	app.isDragging := false;
	self.origXPos := 0;
	self.origYPos := 0;
	
	self.backFrameIndex := 0;
	
	self.lastClickMilliseconds := now.getTotalMilliseconds(); // PAR 29608

end;</source>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
