    <JadeMethod name="isUsedForCurrentVoyage" id="eb55db0d-c1c6-4f84-9779-40200b67ccc9">
        <source>isUsedForCurrentVoyage() : String;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 07 April 2008
//
//	Check any current voyages on machine's terminal to see if it is still
//  in use.  
//  Checks all current voyages on the terminal for any job sheets that
//  are using this crane.  The check is due to the attribute being relational.
//	
//	Returns the voyage code the jobsheet belongs to.
//
//----------------------------------------------------------------------

vars
	terminal 	: CM_Terminal;
	voyageSet	: CM_VoyageSet;
	voyage 		: CM_Voyage;
	jobSheet 	: CM_JobSheet;
begin
	create voyageSet transient;
	terminal := self.myTerminal;
	
	//GET ALL CURRENT VOYAGES FOR THE TERMINAL
	terminal.getAllCurrentCellularVoyages(voyageSet, false, false);
	
	//ARE THERE ANY JOBSHEETS THAT HAVE THIS CRANE ASSIGNED??
	foreach voyage in voyageSet discreteLock where voyage.allJobSheets.isNotEmpty do 
		jobSheet := voyage.allJobSheets[self.id];
		if jobSheet &lt;&gt; null then
			return voyage.code;
		endif;
	endforeach;
	
	//NO JOBSHEETS FOUND.
	return null;
epilog
	delete voyageSet;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="myPrimaryQueue" id="bd9f38f6-54cb-49fb-b210-c2de87602acc">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>myPrimaryQueue(set: Boolean; _value: CM_RadioTelemetryQueue io) updating, mapping;
// ---------------------------------------------------------------------------
// Created:     09 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set then
		self.myPrimaryCraneQueue := _value;
	else
		_value := self.myPrimaryCraneQueue;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_RadioTelemetryQueue" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="93e54b14-c0ff-4755-ae6b-3cd2fb548744">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:		26 March 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 03/03/2010	par 22718 	Fix exception
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxyMachine : CM_Crane;
	proxyCraneMoveRates	: CM_CraneMoveRates;
	completedOK		: Boolean;
	
begin	
	
	proxyMachine := inheritMethod();
	proxyMachine.transferArea := self.transferArea;
	self.allHatchJobTypes.copy(proxyMachine.allHatchJobTypes);
	
	if self.myMoveRate &lt;&gt; null then	// 03/03/2010 par 22718 cnwcs5
		proxyCraneMoveRates := self.myMoveRate.pxyCreateUpdateProxy();
		proxyCraneMoveRates.setMyCrane(proxyMachine);
	endif;							// 03/03/2010 par 22718 cnwcs5
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyMachine;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyMachine;
	endif;
	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="queueId" id="7b14d7f5-dd35-4f30-a5bd-105a309e1e20">
        <methodInvocation>mapping</methodInvocation>
        <source>queueId(set: Boolean; value: String io) mapping;
vars
	cq : CM_VoyageCraneQueue;

begin
	value := null;
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;

	
	foreach cq in self.allCraneQueues discreteLock do // PAR 20474
		if cq.status = QSTATUS_RUNNING then
			value := cq.id;
		endif;
	endforeach;
	if self.myPrimaryQueue &lt;&gt; null then
		value := self.myPrimaryQueue.id;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="releaseToShip" id="4daf1565-eac5-45aa-a218-45a7e2bde514">
        <source>releaseToShip(_ti : CM_TrackedItem; _wle : CM_WorkListEntry; _slotController : CM_LocationsController);
// -------------------------------------------
// Created 19 September 2003 by cnwdvb1
// -------------------------------------------
vars

	moveController	: CMIF_MoveController;
	startTime		: TimeStamp;
	lockKeeperStarted	: Boolean;

begin
	if _slotController = null then
		app.setContinueCMExceptions(false);
		app.raiseUnexpectedProgramError(class.name, method.name, 'To Location is null');
		return;
	endif;

	if self.hasRadioTelemetry and self.useRTForPickup and self.useRTForSetDown then
		return;
	endif;
	
	startTime := app.actualTimeServer();
//	lockKeeperStarted := true;
//	app.lockKeeperNotifyStartActivity(startTime, method, null, 'Executing Release to Ship for Crane ' &amp; self.id);
//	beginTransaction;
	
	create moveController transient;
	
	moveController.isForcedMove		:= true;
	moveController.isSystemMove 	:= true;
	moveController.isRehandleMove 	:= _ti.isRehandle;
	moveController.setMyWorkListEntry(_wle);		
	moveController.setMoveMode(REAL_MODE);
	moveController.setMyTrackedItem(_ti);
	moveController.isOverstowMove := false;
	moveController.setMyToPrimaryLocation(_slotController);

	// Using teklogix exception handlers.
	app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, app.myPassport);	
//	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
//	if not app.myPassport.trxCompletedOK then
//		process.debug;
//	endif;
//	app.cmsCommitTransaction(app.myPassport);	

epilog
//	abortTransaction;
//	if lockKeeperStarted then
//		app.lockKeeperNotifyEndActivity(startTime);
//	endif;
	delete moveController;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_slotController" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="a51a2dac-bc68-4feb-8d61-8427321a2974">
        <updating/>
        <source>setForUpdate(pProxyMachine: CM_Crane; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:		25 March 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	transArea : CM_CraneTransferArea;
	pxyCraneRate, 
	newCraneRate : CM_CraneMoveRates;
	passport : CM_Passport;
begin
	inheritMethod(pProxyMachine, _passport);
	transArea := 	pProxyMachine.transferArea;
	if transArea &lt;&gt; null then
		self.transferArea := null;
		transArea.crane := self;
	endif;
	self.minItemsForTLJob := pProxyMachine.minItemsForTLJob;
	self.maxLiftWeightTL := pProxyMachine.maxLiftWeightTL;
	self.useRTForPickup := pProxyMachine.useRTForPickup;
	self.useRTForSetDown := pProxyMachine.useRTForSetDown;
	self.targetRatePH := pProxyMachine.targetRatePH;
	self.jobSeed := pProxyMachine.jobSeed;
	self.allHatchJobTypes.clear;
	pProxyMachine.allHatchJobTypes.copy(self.allHatchJobTypes);
	
	// 31/12/2013 	cnwer1	PAR 31267	edit crane rates
	if pProxyMachine.myMoveRate &lt;&gt; null then
		passport:=_passport;
		pxyCraneRate:=pProxyMachine.myMoveRate;
		if self.myMoveRate = null then
			app.myUtilityCA.utlCreateCraneMoveRates(pxyCraneRate, newCraneRate, self,null,passport);
		else
			app.myUtilityUA.utlUpdateCraneMoveRates(pxyCraneRate, passport);
		endif;
	endif;
	
end;</source>
        <Parameter name="pProxyMachine" type="CM_Crane"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
