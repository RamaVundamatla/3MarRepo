    <JadeMethod name="getValueForRow" id="a55fd12f-141c-4c72-90d4-b9077aeb8cb3">
        <source>getValueForRow(_rowName: String; _obj: Object output): Any;
//
// SFW 1121 cnwrs1  Sept 2011
////9/11/17 jlgns1 TFS 6960 QNS - Disk space issues and house keeping inside JMT
//18/11/2022 navmv20 Bug 55001: MTN - Garbage Collection - Release Requests - Not present under "Garbage Collection" Task Type list
//14 Feb 2023 navhl20 ChangeRequest 54900:[56518] EUP - Garbage Collection for Document Attachments
//21 Jul 2023 navhl20 ChangeRequest 58158: EUP | [Framework] - Delivery Dispatch Garbage Collection
//11 Aug 2025 navhl20 Story MTN-35650: TPT | Uploading of Photos into MTN Production | 2 | Thin Client Changes
vars

begin
	if _rowName = ETRow_BgpAutoDaysToKeep then
		return self.daysToKeep;
	elseif _rowName = ETRow_BgpAutoArchivedLocations then
		return self.archivedLocations;
	elseif _rowName = ETRow_BgpAutoArchivedVoyages then
		return self.archivedVoyages;
	elseif _rowName = ETRow_NavisSmartActivity then
		return self.navisSmartActivity;  				// ### TFS 50669 06AUG2021 NAVAB1
	elseif _rowName = ETRow_BgpAutoBookingRefTIs then
		return self.bookingRefTis;
	elseif _rowName = ETRow_BgpAutoCargoPhotos then
		return self.cargoPhotos;
	elseif _rowName = ETRow_BgpAutoDDExtractHistory then
		return self.dDExtractHistory;
	elseif _rowName = ETRow_BgpAutoEDIData then
		return self.eDIData;
	elseif _rowName = ETRow_BgpAutoReceivalDockets then	//25 Jul 2013	NDL	Par 31691
		return self.emptyBOLIns;	
	elseif _rowName = ETRow_BgpAutoLockTransactions then
		return self.lockTransactions;
	elseif _rowName = ETRow_BgpAutoLogCheckScaleHdr then
		return self.logCheckScaleHdr; 
	elseif _rowName = ETRow_BgpAutoMachineHistory then
		return self.machineHistory;
	elseif _rowName = ETRow_BgpAutoSavedReports then	//25 Jul 2013	NDL	Par 31691
		return self.menuUserItems;	
	elseif _rowName = ETRow_BgpAutoNonContainerDscrp then
		return self.nonContainerDscrp;
	elseif _rowName = ETRow_BgpAutoOffsiteTIs then
		return self.offsiteTis;
	elseif _rowName = ETRow_BgpAutoPrenoteTIs then
		return self.prenotedTis;
	elseif _rowName = ETRow_BgpAutoReeferTowerTrans then
		return self.reeferTowerTrans;
	elseif _rowName = ETRow_BgpAutoVehicleVisits then
		return self.vehicleVisit;
	elseif _rowName = ETRow_BgpAutoVehicleBookings then
		return self.vehicleBookings;
	elseif _rowName = ETRow_BgpAutoVoyageXlations then	//25 Jul 2013	NDL	Par 31691
		return self.xlations;
	elseif _rowName = ETRow_BgpAutoYardAllocLogTrans then
		return self.yardAllocationLogTrans; 
	elseif _rowName = ETRow_MaxDurationMinutes then
		return self.maxDurationMinutes;
	elseif _rowName = ETRow_BgpDutyDocuments then
		return self.dutyDocs;
	elseif _rowName = ETRow_BgpAutoEventRequests then	//25 Jul 2013	NDL	Par 31691
		return self.eventRequests;
	elseif _rowName = ETRow_BgpAutoSundry then			//25 Jul 2013	NDL	Par 31691
		return self.sundry;
	elseif _rowName = ETRow_ReleasedCargoGroups then	//22 Jun 2015	NDL Par 36338
		return self.purgeReleasedCargoGroups;
	elseif _rowName = ETRow_InterTermRailBOLs then
		return self.purgeInterTerminalRailBOLs;  		//epr TFS 4157 28//4/17
	elseif _rowName = ETRow_TruncateEDIInfoXML then		//13 Sep 2021	NDL	TFS 51718
		return self.truncateEDIInfoXML;
	elseif _rowName = ETRow_SecGateUnknTrucks then		// ### TFS 51994 05Oct2021 NAVPW1
		return self.purgeSecGateUnknTrucks;
	elseif _rowName = ETRow_ReleaseRequests then		//18/11/2022 navmv20 TFS 55001
		return self.releaseRequests;					//18/11/2022 navmv20 TFS 55001
	elseif _rowName = ETRow_AttachFilesCargoTypes then		//14/02/2023 navhl20 #54900[56518]
		return self.purgeAttachmentCargoTypes;				
	elseif _rowName = ETRow_AttachFilesContracts then		//14/02/2023 navhl20 #54900[56518]
		return self.purgeAttachmentContract;				
	elseif _rowName = ETRow_AttachFilesInvoices then		//14/02/2023 navhl20 #54900[56518]
		return self.purgeAttachmentInvoices;				
	elseif _rowName = ETRow_AttachFilesVoyages then			//14/02/2023 navhl20 #54900[56518]
		return self.purgeAttachmentVoyages;					
	elseif _rowName = ETRow_AttachFilesWorkOrders then		//14/02/2023 navhl20 #54900[56518]
		return self.purgeAttachmentWorkOrders;	
	elseif _rowName = ETRow_WorkOrderJobSheets then			//21.7.2023 navhl20 #58158
		return self.purgeWorkOrderJobSheets;
	elseif _rowName = ETRow_BgpAutoVisitPhotos then			//11.08.2025 navhl20 #35650
		return self.purgeVisitPhotos;
	elseif _rowName = ETRow_BgpAgGatewayEWS then			//navra1 - MTN-35875- 5th Sep 2025-2
		return self.purgeAgGatewayMessages;					//navra1 - MTN-35875- 5th Sep 2025-2
	else
		return inheritMethod(_rowName, _obj);
	endif;
end;
</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_obj" type="Object" usage="output"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="e0983ccd-17be-4592-a628-194803212007">
        <updating/>
        <source>setForCreate(_pxyAutoTask: CM_AutoTaskGarbageCollection) updating;
//
// SFW 1121 cnwrs1  Sept 2011
//
vars

begin
	inheritMethod(_pxyAutoTask);
	self.requestClassName := BGP_DatabasePurgeRequest.name;
	self.setFromProxy(_pxyAutoTask);
end;
</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskGarbageCollection"/>
    </JadeMethod>
