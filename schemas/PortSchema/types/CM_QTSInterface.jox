    <JadeMethod name="createCashCredit3" id="31433543-cf2b-43f5-b523-8b6e552e16bf">
        <source>createCashCredit3(_file : File input; _cashCredit : CM_CashCredit);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Dec 2019 cnwma1 ChangeRequest 47851: QTS - Integration with Oracle Fusion Cloud

*/

vars
	str,			 
	strGL2,
	strSeq,
	strGL3,
	strGL4		 : String;
	creditDetail : CM_CashCreditDetail;
	glCode       : CM_GLCode;
	fileEx		 : FileException;
begin
	
	on FileException do self.fileExceptionHandler(fileEx);

	foreach creditDetail in _cashCredit.allDerivedFromCreditDetails discreteLock do
		
		//Clearing First 
		
		strGL2 := null;
		strGL3 := null;
		strGL4 := null;
		
		if creditDetail.myCashPayment &lt;&gt; null then
			if creditDetail.myCashPayment.getServiceGL &lt;&gt; null then
				glCode := creditDetail.myCashPayment.getServiceGL;
				strGL2 := glCode.getSegmentValue('.',2);
				strGL3 := glCode.getSegmentValue('.',3);
				strGL4 := glCode.getSegmentValue('.',4);
			endif;
		endif;
		

		str := 
		Space                  &amp; Comma &amp;                   //01 - Business Unit Identifier
		Space                  &amp; Comma &amp;                   //02 - Salesperson Number
		Space                  &amp; Comma &amp;                   //03 - Name of Sales Credit Type
		Space                  &amp; Comma &amp;                   //04 - Sales Credit Amount Split
		Space                  &amp; Comma &amp;                   //05 - Sales Credit Percentage Split
		Space                  &amp; Comma &amp;                   //06 - Line Transactions Flexfield Context
		mapper(_cashCredit,"sequenceNum")     &amp; Comma &amp;    //07 - Line Transactions Flexfield Segment 1  - Mandatory
		strGL2                 &amp; Comma &amp;                   //08 - Line Transactions Flexfield Segment 2  - Mandatory
		strGL3                 &amp; Comma &amp;                   //09 - Line Transactions Flexfield Segment 3  - Mandatory
		strGL4                 &amp; Comma &amp;                   //10 - Line Transactions Flexfield Segment 4  - Mandatory
		Space                  &amp; Comma &amp;                   //11 - Line Transactions Flexfield Segment 5
		Space                  &amp; Comma &amp;                   //12 - Line Transactions Flexfield Segment 6
		Space                  &amp; Comma &amp;                   //13 - Line Transactions Flexfield Segment 7
		Space                  &amp; Comma &amp;                   //14 - Line Transactions Flexfield Segment 8
		Space                  &amp; Comma &amp;                   //15 - Line Transactions Flexfield Segment 9
		Space                  &amp; Comma &amp;                   //16 - Line Transactions Flexfield Segment 10
		Space                  &amp; Comma &amp;                   //17 - Line Transactions Flexfield Segment 11
		Space                  &amp; Comma &amp;                   //18 - Line Transactions Flexfield Segment 12
		Space                  &amp; Comma &amp;                   //19 - Line Transactions Flexfield Segment 13
		Space                  &amp; Comma &amp;                   //20 - Line Transactions Flexfield Segment 14
		Space                  &amp; Comma &amp;                   //21 - Line Transactions Flexfield Segment 15
		Space                  &amp; Comma &amp;                   //22 - Interface Sales Credits Flexfield Context
		Space                  &amp; Comma &amp;                   //23 - Interface Sales Credits Flexfield Segment 1
		Space                  &amp; Comma &amp;                   //24 - Interface Sales Credits Flexfield Segment 2
		Space                  &amp; Comma &amp;                   //25 - Interface Sales Credits Flexfield Segment 3
		Space                  &amp; Comma &amp;                   //26 - Interface Sales Credits Flexfield Segment 4
		Space                  &amp; Comma &amp;                   //27 - Interface Sales Credits Flexfield Segment 5
		Space                  &amp; Comma &amp;                   //28 - Interface Sales Credits Flexfield Segment 6
		Space                  &amp; Comma &amp;                   //29 - Interface Sales Credits Flexfield Segment 7
		Space                  &amp; Comma &amp;                   //30 - Interface Sales Credits Flexfield Segment 8
		Space                  &amp; Comma &amp;                   //31 - Interface Sales Credits Flexfield Segment 9
		Space                  &amp; Comma &amp;                   //32 - Interface Sales Credits Flexfield Segment 10
		Space                  &amp; Comma &amp;                   //33 - Interface Sales Credits Flexfield Segment 11
		Space                  &amp; Comma &amp;                   //34 - Interface Sales Credits Flexfield Segment 12
		Space                  &amp; Comma &amp;                   //35 - Interface Sales Credits Flexfield Segment 13
		Space                  &amp; Comma &amp;                   //36 - Interface Sales Credits Flexfield Segment 14
		Space                  &amp; Comma &amp;                   //37 - Interface Sales Credits Flexfield Segment 15
		Space                  &amp; Comma &amp;                   //38 - *Business Unit Name
		Space                  ;                		   //39 - END
		_file.writeLine(str);
	endforeach;
end;</source>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_cashCredit" type="CM_CashCredit"/>
    </JadeMethod>
    <JadeMethod name="createCashReceipt" id="03dedf34-39fc-4ccb-a4af-586b08483914">
        <source>createCashReceipt(_file : File input; _cashReceipt : CM_CashReceipt);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Dec 2019 cnwma1 ChangeRequest 47851: QTS - Integration with Oracle Fusion Cloud

*/

vars
	cashPayment : CM_CashPayment;
begin
	
	foreach cashPayment in _cashReceipt.allCashPayments discreteLock do 
	
		self.createCashReceiptRecordType1(_file,cashPayment);
		self.createCashReceiptRecordType2(_file,cashPayment);
		self.createCashReceiptRecordType3(_file,cashPayment);
		self.createCashReceiptRecordType4(_file,cashPayment);
		self.createCashReceiptRecordType5(_file,cashPayment);
		self.createCashReceiptRecordType6(_file,cashPayment);
		self.createCashReceiptRecordType7(_file,cashPayment);
		self.createCashReceiptRecordType8(_file,cashPayment);
		self.createCashReceiptRecordType9(_file,cashPayment);	
	endforeach;
epilog

end;</source>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_cashReceipt" type="CM_CashReceipt"/>
    </JadeMethod>
    <JadeMethod name="createCashReceiptRecordType1" id="11135b7f-0a48-4252-b895-ed5eb5c3a099">
        <source>createCashReceiptRecordType1(_file : File input; _cashPayment : CM_CashPayment);
/*

Purpose:			
		Mapping Record Type 1 , Col 23
		Mandatory Col: 11
		
Parameters:			

Return Value:		

Date		Who		Reason
13 Dec 2019 cnwma1 ChangeRequest 47851: QTS - Integration with Oracle Fusion Cloud

*/

vars
	strDate,
	strTime,
	strCheque,
	strBank,
	strInvNo,
	str 	: String;
	date    : Date;
	debtor  : CM_Debtor;
	cashRec : CM_CashReceipt;
	mop     : CM_PaymentMethod;
begin
	
	cashRec  	:= _cashPayment.myCashReceipt;

	str :=
	"1"                    			 &amp; Comma &amp;         //01 - Record Type                             - Mandatory
	Space               		     &amp; Comma &amp;         //02 - Destination Bank Account
	Space                  			 &amp; Comma &amp;         //03 - Bank Origination Number                 
	mapper(cashRec,"DepositDate")    &amp; Comma &amp;         //04 - Deposit Date                            - Mandatory
	Space          	       			 &amp; Comma &amp;         //05 - Deposit Time                            
	Space                  			 &amp; Comma &amp;         //06 - Transmission Record Count
	Space                  			 &amp; Comma &amp;         //07 - Transmission Amount
	mapper(cashRec,"CustomerName")   &amp; Comma &amp;         //08 - Payment Interface Flexfield Segment 1   
	mapper(cashRec,"ChequeNumber")   &amp; Comma &amp;         //09 - Payment Interface Flexfield Segment 2   
	mapper(cashRec,"ChequeBank")	 &amp; Comma &amp;         //10 - Payment Interface Flexfield Segment 3  
	mapper(cashRec,"CashInv")	     &amp; Comma &amp;         //11 - Payment Interface Flexfield Segment 4   
	mapper(cashRec,"Voyage")	     &amp; Comma &amp;         //12 - Payment Interface Flexfield Segment 5  
	Space                  			 &amp; Comma &amp;         //13 - Payment Interface Flexfield Segment 6
	Space                  			 &amp; Comma &amp;         //14 - Payment Interface Flexfield Segment 7
	Space                  			 &amp; Comma &amp;         //15 - Payment Interface Flexfield Segment 8
	mapper(cashRec,"PosRef")	     &amp; Comma &amp;         //16 - Payment Interface Flexfield Segment 9  
	mapper(cashRec,"CreatedBy")	     &amp; Comma &amp;         //17 - Payment Interface Flexfield Segment 10 
	mapper(cashRec,"MopCode")	     &amp; Comma &amp;         //18 - Payment Interface Flexfield Segment 11  
	mapper(cashRec,"MopDesc")	     &amp; Comma &amp;         //19 - Payment Interface Flexfield Segment 12  
	Space                  			 &amp; Comma &amp;         //20 - Payment Interface Flexfield Segment 13
	Space                  			 &amp; Comma &amp;         //21 - Payment Interface Flexfield Segment 14
	Space                  			 &amp; Comma &amp;         //22 - Payment Interface Flexfield Segment 15
	Space                  			 ;		           //23 - END
	
	_file.writeLine(str);
epilog

end;</source>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_cashPayment" type="CM_CashPayment"/>
    </JadeMethod>
    <JadeMethod name="createCashReceiptRecordType2" id="acd6a94d-199d-4e65-ab9b-84ff15e0f05d">
        <source>createCashReceiptRecordType2(_file : File input; _cashPayment : CM_CashPayment);
/*

Purpose:			
		Mapping Record Type 2 , Col 21
		Mandatory Col: 11	
Parameters:			

Return Value:		

Date		Who		Reason
13 Dec 2019 cnwma1 ChangeRequest 47851: QTS - Integration with Oracle Fusion Cloud

*/

vars
	strDate,
	str 		: String;
	date   		: Date;
	cashRec		: CM_CashReceipt;
begin
	cashRec  	:= _cashPayment.myCashReceipt;
	
	str := 
	"2"          		  				  &amp; Comma &amp;    //01 - Record Type                             - Mandatory
	mapper(cashRec,"DepositDate")         &amp; Comma &amp;    //02 - Deposit Date                            - Mandatory
	Space                  				  &amp; Comma &amp;    //03 - Deposit Time
	Space                 				  &amp; Comma &amp;    //04 - Destination Bank Account
	Space                  				  &amp; Comma &amp;    //05 - Bank Origination Number
	mapper(cashRec,"CustomerName")        &amp; Comma &amp;    //06 - Payment Interface Flexfield Segment 1
