    <JadeMethod name="utlUpdateQueueEntryStatus" id="47bbe114-e45d-45ce-8dee-c65417f3740d">
        <source>utlUpdateQueueEntryStatus(pEntry : CM_RTQueueEntry input; pStatus : Integer);
// ---------------------------------------------------------------------------
// Created:     10 October 2001 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
// ---------------------------------------------------------------------------
vars
	ti	: CM_TrackedItem;
begin

	self.initialiseActivity();
	
	if pEntry = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'queue entry', null, null);
		app.raiseCMException(Input_required_field_queEntry, null, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	exclusiveLock(pEntry.myQueue);
	exclusiveLock(pEntry);

	pEntry.setEntryStatus(pStatus);
	
	// sends not to ti to update display.(for held) Done here as if further anlong the 
	//	line can lead to multiple notes being sent. 
	if pEntry.myWorkListEntry &lt;&gt; null then 
		ti := pEntry.myWorkListEntry.myTrackedItem;
		
		if ti &lt;&gt; null then 
			self.updateObjectEdition (ti);	// par 30292
		endif; 
	endif;
end;</source>
        <Parameter name="pEntry" type="CM_RTQueueEntry" usage="input"/>
        <Parameter name="pStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateQueuePlanOnPickup" id="eac505d6-b45c-4668-b918-34512d65e6dc">
        <updating/>
        <source>utlUpdateQueuePlanOnPickup(params : CMIF_PlanOnPickup; _passport : CM_Passport input) : String updating;


/*

Purpose:			
//cnwrd1 par 26734 CCMS 2014 plan on pickup
Parameters:			

Return Value:		


Date		Who		Reason
11 March 2011	cnwrd1	Initial creation

*/


vars
	ti 			: CM_TrackedItem;
	job			: CM_Job;
	strMode,
	str			: String;
	term		: CM_Terminal;
	request		: CM_YardRequest;
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	app.myValUA.valPlanOnPickupJob(params);
	
	//27471 cnwrd1 24.5.2011 return if errors here
	if not self.checkValidationWithPassport(_passport) then
		return null;
	endif;
	
	term := _passport.myTerminal;

	job := params.myJob;

	foreach ti in params.allTrackedItems do
		strMode := null;
		exclusiveLock(ti);

		if  ti.isQueued() then //epr par 35597 30/1/15
			app.raiseCMException1(ERR_QUEUE_LC_EXISTS, ti.id, null, null);
		endif;
					
		ti.queuePlanOnPickup(params, job, _passport);
	
		if job &lt;&gt; null then

			
			request := job.allRequests.last.CM_YardRequest;
			if request &lt;&gt; null then
				request.setRequiredByDT(params.requiredByDT);
				request.setRemarks(params.remarks);
			endif;
		endif;
		
		if _passport.noErrors then
			str := str &amp; strMode;
		endif;
	endforeach;
	
	if job &lt;&gt; null then
		job.setRemarks(params.remarks);
	endif;
	
	return str;
epilog

end;</source>
        <Parameter name="params" type="CMIF_PlanOnPickup"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateQueuePosition" id="00bde2a9-dc62-4beb-b998-bc69bca8e519">
        <source>utlUpdateQueuePosition(pQueue : CM_RadioTelemetryQueue input; pShiftBefore : CM_RadioTelemetryQueue);
// ---------------------------------------------------------------------------
// Created:     10 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	terminal : CM_Terminal;

begin

	self.initialiseActivity();
	
	if pQueue = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'queue', null, null);
		app.raiseCMException(Input_required_field_queue, null, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	if pQueue.isKindOf(CM_MasterQueue) then
		return;
	endif;
	
	exclusiveLock(pQueue.myParentQueue);
	exclusiveLock(pQueue);

	pQueue.changeQueueOrder(pShiftBefore);
	terminal := pQueue.getMyTerminal();
	if terminal &lt;&gt; null then
		pQueue.causeEvent(terminal.getTerminalEvent(RTQueue_Update_Event), false, null);
	endif;

end;</source>
        <Parameter name="pQueue" type="CM_RadioTelemetryQueue" usage="input"/>
        <Parameter name="pShiftBefore" type="CM_RadioTelemetryQueue"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateQueueStatus" id="ba0c3f94-78a1-4d40-b134-6f085f7cb259">
        <source>utlUpdateQueueStatus(pQueue : CM_RadioTelemetryQueue input; pStatus : Integer);
// ---------------------------------------------------------------------------
// Created:     10 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.initialiseActivity();
	
	if pQueue = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'queue', null, null);
		app.raiseCMException(Input_required_field_queue, null, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	if pQueue.myParentQueue &lt;&gt; null then
		exclusiveLock(pQueue.myParentQueue);
	endif;
	exclusiveLock(pQueue);

	pQueue.setQueueStatus(pStatus);

end;</source>
        <Parameter name="pQueue" type="CM_RadioTelemetryQueue" usage="input"/>
        <Parameter name="pStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateQueueTaskStatus" id="668f7f2b-bc72-4580-ba71-59f862497466">
        <source>utlUpdateQueueTaskStatus(pTask : CM_RTQueueTask input; pStatus : Integer);
// ---------------------------------------------------------------------------
// Created:     10 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 28 May 2008	cnwkpd1		PAR #16738 - Handle deleted task object
// 16 Dec 2008	cnwer1		PAR #18665 - completing overstow moves were being moved to incorrect target location
// 24/11/2010	cnwcs5		par 23714/ccms 1132 - record status change in history
// ---------------------------------------------------------------------------
vars
	ti				: CM_TrackedItem;
	lc				: CM_LocationsController;
	machine			: CM_Machine;
	wle 			: CM_WorkListEntry;
	qfm 			: CM_FutureMoveQueued;
	invalidTask		: Boolean;
	rtqEntry		: CM_RTQueueEntry;	// 25/11/2010 cnwcs5 par 23714/ccms 1132
	rtqTask			: CM_RTQueueTask;	// 25/11/2010 cnwcs5 par 23714/ccms 1132
begin

	self.initialiseActivity();
	
	if pTask = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'task', null, null);
		app.raiseCMException(Input_required_field_task, null, null);
		return;
	endif;
	
	
	on Exception do app.handleDeletedObject(exception, pTask, invalidTask);		// PAR #16738
	
	exclusiveLock(pTask);
	
	if invalidTask then															// PAR #16738
		app.raiseCMException(Object_Deleted, 'task', null);
		return;
	endif;
	
	if pStatus = -1 then
	
		pTask.myEntry.restoreTaskStatuses();
		return;
	endif;
//	cnwcs5 24/11/2010 par 23714/ccms 1132 - start	
	if pStatus = TASK_COMPLETE and (pTask.taskType = TASK_SETDOWN or pTask.taskType = TASK_PICKUP or pTask.taskType = TASK_MOVE) then
		// we will end up completing the entire move so may need to record history for &gt; 1 machine
		wle := pTask.myEntry.myWorkListEntry;
		
		foreach rtqEntry in wle.allRTQueueEntries do
			foreach rtqTask in rtqEntry.allTasks do
				machine	:= rtqTask.machine;	
				
				if machine = null then
					machine := rtqTask.intendedMachine;
				endif;
				
				if machine = null or rtqTask.status = TASK_COMPLETE then
					continue;
				endif;
				
				// not complete and has a machine
				machine.addInfoToHistory (CM_MachineInfoHistory.InfoType_Status_Change, rtqTask, pStatus,null);
			endforeach;
		endforeach;
	else
		machine	:= pTask.machine;									
		
		if machine &lt;&gt; null then
			machine.addInfoToHistory (CM_MachineInfoHistory.InfoType_Status_Change, pTask, pStatus,null);
		endif;
	endif;
	
//	cnwcs5 24/11/2010 par 23714/ccms 1132 - end	
	if pStatus = TASK_COMPLETE and (pTask.taskType = TASK_SETDOWN or pTask.taskType = TASK_PICKUP or pTask.taskType = TASK_MOVE or pTask.taskType = TASK_BREAKBULK) then
		ti := pTask.ti;
		
		qfm:=pTask.myEntry.findQueueFutureMoveForTI(ti);
		if qfm &lt;&gt; null then
			lc := qfm.getPrimaryLocation();
			//epr par 18665 needs to be this because overstow tasks future moves do not have a wle and one is needed to complete the task 
			wle := pTask.myEntry.myWorkListEntry;
		else
			lc := ti.getPrimaryLocation(QUEUE_MODE);
			wle := null; // PAR 15431
		endif;
		
		//if pTask.taskType = TASK_SETDOWN then
			machine := pTask.machine;
		//endif;
		if lc &lt;&gt; null then
			app.myPassport.useTITransactionDeferUpdate := true; // ## PAR 10352
			
			// CCMS 1577 Not passing through WLE
			 // PAR 15431 yes we are!
			 
			 //epr par 26944 9/2/2011 changed the parameter _isRTMove to false
			//ti.moveToLocation(lc, null, wle, machine, REAL_MODE, pTask.myEntry.overRideFlags &lt;&gt; 0, false, pTask.isOverstowTask, false,  false,  false,null,null, app.myPassport);		// TFS 2651
			ti.moveToLocation(lc, null, wle, machine, REAL_MODE, pTask.myEntry.overRideFlags &lt;&gt; 0, false, pTask.isOverstowTask, false, false, false, null, null, null, null, null, app.myPassport);	// TFS 2651

			// Do those deferred updates.
			app.myPassport.doDeferredUpdates(); // ## PAR 10352
		else
app.writeStatement(class.name &amp; " " &amp; method.name &amp; " " &amp; "no queued location!!!!! - do we need to clean this up?");
//fixing up of machine below doesn't seem to work for this scenario		
		endif;
		
		if app.myPassport.hasErrors then
			return;
		else
			if machine &lt;&gt; null and machine.allCurrentQueueTasks.size = 0 then
				//write machine.statusStr;
				machine.setMachineStatus(STATUS_IDLE  , "", false);
			endif;
		endif;

	else
		pTask.setStatus(pStatus);
	endif;
	

epilog
	
	
end;</source>
        <Parameter name="pTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="pStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateQuickAccess" id="a13c60af-5deb-4e29-9e99-c04eaa6c8b84">
        <source>utlUpdateQuickAccess(pProxyQuickAccess : CM_QuickAccess; _passport : CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2014	cnwndl1	Initial creation

*/

vars

	cancelSave : Boolean;
	realQuickAccess : CM_QuickAccess;
	expectedEdition : Integer;
	
begin

	self.initialiseActivity();

	pProxyQuickAccess.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyQuickAccess.pxyGetRealObjectAndEdition(realQuickAccess, expectedEdition);
	
	if realQuickAccess = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_QuickAccess.name, null, null);
		return;
	endif;

	app.myValUA.valQuickAccess(realQuickAccess, pProxyQuickAccess);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realQuickAccess);

	if _passport.noErrors and realQuickAccess.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Special Lift', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realQuickAccess, true);
	endif;
	
	if _passport.noErrors then
		realQuickAccess.setForUpdate(pProxyQuickAccess);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realQuickAccess, false);
	endif;

epilog

end;</source>
        <Parameter name="pProxyQuickAccess" type="CM_QuickAccess"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateRFIDTag" id="8da054b9-55b1-4c27-9402-f4260bdd0b2d">
        <source>utlUpdateRFIDTag(_rfidTagProxy :CM_RFIDTag input;
				 _terminal : CM_Terminal input;
				_passport : CM_Passport input);
/*

Purpose:			


Return Value:		


Date		Who		Reason
17 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	realRFIDTag : CM_RFIDTag;
	expectedEdition : Integer;
begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_rfidTagProxy, 'RFID Tag Proxy');
	
	_rfidTagProxy.pxyGetRealObjectAndEdition(realRFIDTag, expectedEdition);
	self.raiseExceptionIfNull(realRFIDTag, 'RFID Tag');
	
	_rfidTagProxy.validateForUpdate();
	
	if _passport.noErrors then
		realRFIDTag.setForUpdate(_rfidTagProxy,_terminal);
	endif;
epilog

end;</source>
        <Parameter name="_rfidTagProxy" type="CM_RFIDTag" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
