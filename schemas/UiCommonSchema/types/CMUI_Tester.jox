    <JadeMethod name="parseXML" id="2ffc3c5e-a437-4f1b-9dad-55897e95a88f">
        <updating/>
        <source>parseXML(pTestData : CMUI_TestData io; pMsgString : String; pPos : Integer io) updating;
// ---------------------------------------------------------------------------
// Created:     18 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	len,
	pos			: Integer;
	testData	: CMUI_TestData;
	theTag		: String;
	
begin

	len := pMsgString.length;
	pos := pPos;
	
	while pos &lt; len do
		theTag := self.extractTag(pMsgString, pos);
		if theTag.length &gt; 1 and theTag[1] = '/' then
			return;
		endif;
		
		if theTag = TAG_CNTRL then
			app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '  doing next level ******* for (' &amp; pTestData.name &amp; ')');
			create testData transient;
			pTestData.allChildData.add(testData);
			parseXML(testData, pMsgString, pos);
		elseif theTag = TAG_NAME then
			pTestData.name := self.extractValue(pMsgString, pos);
		elseif theTag = TAG_VALUE then
			pTestData.value := self.extractValue(pMsgString, pos);
		elseif theTag = TAG_REF then
//			pTestControl.myRef := self.extractValue(pMsgString, pos);
		else
			app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '  unrecognised tag (' &amp; theTag &amp; ')');
		endif;
	endwhile;

epilog
	pPos := pos;
	
end;</source>
        <Parameter name="pTestData" type="CMUI_TestData" usage="io"/>
        <Parameter name="pMsgString" type="String"/>
        <Parameter name="pPos" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setAllTestControls" id="1de0a0d5-d538-4fab-874a-add1a370fdb2">
        <updating/>
        <source>setAllTestControls(pMsgString : String) updating;
// ---------------------------------------------------------------------------
// Created:     18 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	len,
	pos			: Integer;
	testData	: CMUI_TestData;
	theTag		: String;
	
begin

	self.allTestData.purge;

	len := pMsgString.length;
	pos := 1;
	
	while pos &lt; len do
		theTag 	 := self.extractTag(pMsgString, pos);

		if theTag = null or pos &lt;= 0 then
			return;
		endif;
		
		if theTag = TAG_CNTRL then
			create testData transient;
			self.allTestData.add(testData);
			parseXML(testData, pMsgString, pos);
		elseif theTag = '/' &amp; TAG_CNTRL then
			// do nothing
		else
			app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '  unrecognised tag (' &amp; theTag &amp; ')');
		endif;
		
	endwhile;
	
end;</source>
        <Parameter name="pMsgString" type="String"/>
    </JadeMethod>
    <JadeMethod name="setValues" id="04768ac2-4241-440f-8665-d69142d60df1">
        <source>setValues(pForm : Form; pTestData : CMUI_TestData);
// ---------------------------------------------------------------------------
// Created:     18 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	numControls,
	idx			: Integer;
	control		: Control;
	testData	: CMUI_TestData;
	entTable	: CM_EntryTable;
	
begin

	numControls := pForm.controlCount;
	
	foreach idx in 1 to numControls do
		control := pForm.controls(idx);
		if control.name = pTestData.name then
			if control.isKindOf(TextBox) then
				control.TextBox.text := pTestData.value;
			elseif control.isKindOf(CM_EntryTable) then
				entTable := control.CM_EntryTable;
				foreach testData in pTestData.allChildData do
					entTable.setValueByName(testData.name, testData.value);
				endforeach;
			
			elseif control.isKindOf(ComboBox) then
				control.ComboBox.text := pTestData.value;
			endif;
			break;
		endif;
	endforeach;

end;</source>
        <Parameter name="pForm" type="Form"/>
        <Parameter name="pTestData" type="CMUI_TestData"/>
    </JadeMethod>
    <JadeMethod name="unload" id="bba71b38-d5bf-47ed-a42e-ec4b388a3eda">
