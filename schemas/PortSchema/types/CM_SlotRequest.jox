    <JadeMethod name="is30FooterForReports" id="16868665-61b0-4058-89ee-ba229fa83fe3">
        <source>is30FooterForReports() : Boolean;
// ---------------------------------------------------------------------------
// Created:		22 May 2008 By cnwvu1
//
// Purpose:		Defines whether 30 footers should be included for reports.
//				According to the Terminal Config it can be:
//					included as 30' in Own column			(_isOwn := true)
//					included as part in the "Other" column	(_isOwn := false)
//					not included ( the method returns false )
// ---------------------------------------------------------------------------

vars
	isOwn : Boolean;

begin

	if self.getAttrIs30() and app.is30IncludedForReportsAsColumn( isOwn ) then
		if isOwn then
			return true;
		else
			return false;	// it means it isOtherFooterForReports
		endif;
	endif;

	return false;
	
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
