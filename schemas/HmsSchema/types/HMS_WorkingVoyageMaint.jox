    <JadeMethod name="initSummaryTable" id="dc6ccea5-1f4e-42bb-bacb-f818e43824f0">
        <updating/>
        <source>initSummaryTable() updating;
//-----------------------------------------
//Created: July 2003 By: cnwgd1
//-----------------------------------------
vars

begin
	tblSummary.columns:=2;
	// Set table input modes
	tblSummary.accessMode:=tblSummary.AccessMode_Column;
	tblSummary.column:=1;
	tblSummary.inputType:=tblSummary.InputType_None;	
	tblSummary.column:=2;
	tblSummary.inputType:=tblSummary.InputType_None;
	tblSummary.alignment:=tblSummary.Alignment_Right;	

	// Set enteries in "Titles" column
	tblSummary.addItem("Name:");
	tblSummary.addItem("Class:");
	tblSummary.addItem("Type:");
	tblSummary.addItem("LOA:");
	tblSummary.addItem("GRT:");
	tblSummary.addItem("Preferred Berth:");
	tblSummary.addItem("Shipping Line:");
	tblSummary.addItem("Agent/Rep.:");
	tblSummary.addItem("Default Tidal Classes:");

	//tblSummary.cnAdjustColumnWidths();
	
end;</source>
    </JadeMethod>
