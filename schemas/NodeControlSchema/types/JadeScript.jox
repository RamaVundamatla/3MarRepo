    <JadeMethod name="anonymise" id="83eadba8-3796-475f-873f-673f8216eb75">
        <source>anonymise();

vars
	anon:Anonymiser;
begin
	create anon;
	anon.doAllClasses;
epilog
	delete anon;
end;
</source>
    </JadeMethod>
    <JadeMethod name="anonymisePauseResume" id="b012d013-89a4-4035-8198-28918fa9a661">
        <source>anonymisePauseResume();

begin
	beginTransaction;
	global.bmkUsers := 99;  // to pause;
	global.bmkUsers := 10000;  // to resume and set new commitFrequency
	commitTransaction;
end;</source>
    </JadeMethod>
