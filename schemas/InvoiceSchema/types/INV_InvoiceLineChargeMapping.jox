    <JadeMethod name="doQueryShippingLine" id="203c016c-1aba-4e33-87dc-526a9cba773c">
        <updating/>
        <source>doQueryShippingLine() updating;
// ---------------------------------------------------------------------------
// Created:     June 20022 Aalekh Kumar
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 07/06/2022	navak20				ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
// ---------------------------------------------------------------------------

vars
	shippingLine : CM_ShippingLine;
	invoiceLineDesc : CM_InvoiceLineDesc;
	aMap : CM_InvoiceLineChargeMapping;
	row :Integer;
	column :Integer;
	count :Integer;
