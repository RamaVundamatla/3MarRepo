    <JadeMethod name="addToCollection" id="3354962e-22ac-4bea-84b0-5f3674fe611d">
        <source>addToCollection(_ti:CM_TrackedItem; _collection:Collection input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 January 2010	#cnwdz2	CCMS 1108 par22177 

*/

vars

begin
	_collection.add(_ti);
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
