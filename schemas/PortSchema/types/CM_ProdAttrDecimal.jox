    <JadeMethod name="validateForUpdate" id="d9c4b23f-8ca7-4470-b282-ca133447c33f">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     08 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod();
	//PAR18263 cnwsh3 16/3/2009
	if self.value * self.multiplier &gt; 9999999.999 then 		
		app.raiseCMException2(ERR_EXPRESSION_OVERFLOW, (self.value * self.multiplier).Decimal.String, 9999999.999.Decimal.String, null,null);
		return;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateValue" id="46652df9-ab6f-4b35-bf30-0a63442ce389">
        <source>validateValue(_value: Decimal): Boolean;
// ---------------------------------------------------------------------------
// Created:     04 November 2002		cnwth2	
//
// Purpose:     
//			 
// Changes		_value can = min or max value. PAR 22189 Feb 2010
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.minValue &lt;&gt; null and self.maxValue &lt;&gt; null then
		return (_value &gt;= self.minValue) and (_value &lt;= self.maxValue);
	else
		return true;
	endif;
	
end;</source>
        <Parameter name="_value" type="Decimal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
