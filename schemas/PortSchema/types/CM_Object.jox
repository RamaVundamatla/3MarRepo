    <JadeMethod name="eraseXlations" id="3be43812-7f4e-4bf4-aa0e-ac532da5b3f5">
        <source>eraseXlations(_coll :CM_XlationSet; _eraseLevel :Integer)protected;
/*
Date		Who		Reason
25 Mar 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars
	xlation	:CM_Xlation;
begin
	foreach xlation in _coll do
		xlation.erase (_eraseLevel);
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_coll" type="CM_XlationSet"/>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="exportAsXMLDoc" id="51e9cf8b-3a4c-43d2-9fe0-f8ee22bb099e">
        <source>exportAsXMLDoc(_file : File);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 Mar 2011	cnwer1	Initial creation
24 Apr 2012 cnwer1	ccms 1035 - changed to use passed in file for performance - directly writing to file is alot quicker thatn
					using JadeXMLElement - overhead in creating/deleting transients and another overhead writing to file
*/

vars
	allProperties : PropertyColl;
	property : Property;
begin
	
	allProperties:=self.class.allProperties();
		
	foreach property in allProperties do
		if property.isKindOf(Reference) then		
			self.exportAsXMLDocReference(property.Reference,_file);							
		elseif  property.isKindOf(Attribute) then
			self.exportAsXMLDocAttribute(property.Attribute,_file);
		endif;
	endforeach;

epilog
	delete allProperties;
end;</source>
        <Parameter name="_file" type="File"/>
    </JadeMethod>
    <JadeMethod name="exportAsXMLDocAttribute" id="9f096cc9-a2d3-472b-8bcf-39b50e0476c6">
        <source>exportAsXMLDocAttribute(_property : Attribute input; 
						_file : File) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 March 2011	cnwer1	Initial creation

*/

vars

	value, arrayValue : Any;
	iter : Iterator;
begin
	if self.exportAsXMLDocIgnoreAttr(_property) then
		return;
	endif;

	value:=self.getPropertyValue(_property.name);
	
	if value.isKindOf(Binary) then
		return;
	endif;
	if value.isKindOf(Date) then
		_file.writeString(self.formatAsXML(_property.name, value.Date.asStringJMT().xmlReplaceReservedChars(true)));
		return;
	endif;
	
	if value.isKindOf(TimeStamp) then
		_file.writeString(self.formatAsXML(_property.name, value.TimeStamp.asStringJMT().xmlReplaceReservedChars(true)));	
		return;
	endif;
	
	if value.isKindOf(Array) then
		_file.writeLine(J_key_LessThan.Character &amp; _property.name &amp; " " &amp; 'type="' &amp; value.getName &amp; '"' &amp; J_key_GreaterThan.Character );
		iter:=value.Array.createIterator;
		while iter.next(arrayValue) do
			_file.writeString(self.formatAsXML(arrayValue.getTypeJMT.name,arrayValue.String));
		endwhile;	
		_file.writeString(self.formatAsXMLSuffix(_property.name));
	else
		//_file.writeString(self.formatAsXML(_property.name,value.String));
		_file.writeString(self.formatAsXML(_property.name, value.String.xmlReplaceReservedChars(true)));	//01 Apr 2016	NDL	TFS 1764
	endif;
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Attribute" usage="input"/>
        <Parameter name="_file" type="File"/>
    </JadeMethod>
    <JadeMethod name="exportAsXMLDocChildRefValue" id="d1d4aa75-74bc-41a7-83fa-0a27c37c5bd3">
        <source>exportAsXMLDocChildRefValue(_property : Property input;
							_childProperty : Property input;
							_file : File) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 April 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars

	childObject		: Object;
begin

	_file.writeLine(J_key_LessThan.Character &amp; _property.name &amp; " " &amp; 'type="' &amp;  _property.getType.name &amp; '"' &amp; J_key_GreaterThan.Character);
	
	if _childProperty &lt;&gt; null then
		

		childObject:= self.getPropertyValue(_property.name).Object;
		_file.writeString(self.formatAsXML(_childProperty.name,childObject.getPropertyValue(_childProperty.name).String));

	else
		childObject:=self.getPropertyValue(_property.name).Object;
		_file.writeLine(childObject.getOidStringForObject(childObject));

	endif;
	
	_file.writeString(self.formatAsXMLSuffix(_property.name));
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Property" usage="input"/>
        <Parameter name="_childProperty" type="Property" usage="input"/>
        <Parameter name="_file" type="File"/>
    </JadeMethod>
