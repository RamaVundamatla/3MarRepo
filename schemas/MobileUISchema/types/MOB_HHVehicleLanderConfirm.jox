        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateROROAreasCombo" id="bf4dea56-18e6-4a60-af4e-bec4c399f5c1">
        <source>populateROROAreasCombo() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 September 2016	cnwndl1	Initial creation	TFS 2246 / 2680

*/

vars

	ta : CM_TerminalArea;
	roroArea : CM_RoRoLaneArea;
	iter : Iterator;

begin

	self.cmbROROArea.clear();
	
	self.optLeft.visible := false;
	self.optLeft.caption := app.getErrorString(Left);
	self.optRight.visible := false;
	self.optRight.caption := app.getErrorString(Right);
	
	self.cmbROROArea.addItem(self.lblROROArea.caption);
	
	iter := self.myTerminal.allTerminalAreasByTypeId.createIterator;
	while iter.next( ta ) do
		if ta.type &lt;&gt; TA_TYPE_RORO_LANE_AREA then
			continue;
		endif;
		roroArea := ta.CM_RoRoLaneArea;
		self.cmbROROArea.itemObject[self.cmbROROArea.addItem(roroArea.id)] := roroArea;
	endwhile;
	
	roroArea := null;
	ta := self.myMobileGenericAgent.myTerminalArea;
	if ta &lt;&gt; null and ta.type = TA_TYPE_RORO_LANE_AREA then
		roroArea := ta.CM_RoRoLaneArea;
	endif;
	
	if roroArea &lt;&gt; null and cmbROROArea.findObject(roroArea) &gt; 0 then
		cmbROROArea.listIndex := cmbROROArea.findObject(roroArea);
	elseif cmbROROArea.listCount = 2 then
		cmbROROArea.listIndex := 2;
		roroArea := cmbROROArea.itemObject[2].CM_RoRoLaneArea;
	else
		cmbROROArea.listIndex := 1;
	endif;
	
	self.populateROROLanesCombo( roroArea );
	
epilog

	delete iter;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateROROLanesCombo" id="c7332be2-1419-4934-be3d-0d4b2e0441b4">
        <source>populateROROLanesCombo( _roroArea : CM_RoRoLaneArea ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 September 2016	cnwndl1	Initial creation	TFS 2246 / 2680

*/

vars

	iter : Iterator;
	roroLane : CM_RoRoController;
	index : Integer;

begin

	self.cmbROROLane.clear();
	
	self.cmbROROLane.addItem(lblROROLane.caption);

	if _roroArea = null then
		return;
	endif;
	
	self.optLeft.visible := true;
	if _roroArea.leftLabel.trimBlanks &lt;&gt; null then
		self.optLeft.caption := _roroArea.leftLabel;
	else
		self.optLeft.caption := app.getErrorString(Left);
	endif;
	self.optRight.visible := true;
	if _roroArea.rightLabel.trimBlanks &lt;&gt; null then
		self.optRight.caption :=  _roroArea.rightLabel;
	else
		self.optRight.caption := app.getErrorString(Right);
	endif;

	iter := _roroArea.allLanesByLaneNumber.createIterator;
	while iter.next( roroLane ) do
		index := self.cmbROROLane.addItem( roroLane.getFullId );
		self.cmbROROLane.itemObject[index] := roroLane;
	endwhile;
	
	if self.cmbROROLane.listCount = 2 then
		self.cmbROROLane.listIndex := 2;	// only one real one to choose, select it.
	else
		self.cmbROROLane.listIndex := 1;
	endif;

epilog

	delete iter;

end;</source>
        <access>protected</access>
        <Parameter name="_roroArea" type="CM_RoRoLaneArea"/>
    </JadeMethod>
    <JadeMethod name="populateVoyagesCombo" id="69a6735a-f2ba-4e90-9fb3-32992bbdab8b">
        <source>populateVoyagesCombo()protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 September 2016	cnwndl1	Initial creation	TFS 2246 / 2680

*/

vars

	voyage : CM_Voyage;
	now : TimeStamp;

begin

	self.cmbVoyage.clear();
	
	self.myMobileGenericAgent.setCurrentVoyages();
	
	//self.cmbVoyage.addItem(self.lblVoyage.caption);
	self.cmbVoyage.addItem( "- " &amp; app.getErrorString(AnyVoyageOnSite) );
	now := app.actualTimeServer;
	
	foreach voyage in self.myMobileGenericAgent.allCurrentVoyages do
		if voyage.isNullVoyage then
			continue;
		endif;
		if voyage.status = Voyage_Status_Departed or voyage.status = Voyage_Status_Closed then
			continue;
		endif;
		if not voyage.arrivedDT.Date.isValid or voyage.arrivedDT &gt; now then
			// hasn't arrived yet
			continue;
		endif;
		if self.myMobileGenericAgent.myTerminal.getConfig(VesselNameOnVoyageCombo).Boolean then
			self.cmbVoyage.itemObject[self.cmbVoyage.addItem(voyage.code &amp; Tab &amp; voyage.vesselName )] := voyage;
		else
			self.cmbVoyage.itemObject[self.cmbVoyage.addItem(voyage.code)] := voyage;
		endif;
	endforeach;
	
	voyage := self.myMobileGenericAgent.myVoyage;
	
	if voyage &lt;&gt; null and cmbVoyage.findObject(voyage) &gt; 0 then
		cmbVoyage.listIndex := cmbVoyage.findObject(voyage);
	else
		cmbVoyage.listIndex := 1;
	endif;
	
	self.setVoyageCounts( voyage );

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setVoyageCounts" id="5d709535-d00a-4443-9c0e-e65025a7d41c">
        <source>setVoyageCounts( _voyage : CM_Voyage ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 September 2016	cnwndl1	Initial creation	TFS 2246 / 2680

*/

vars

begin

	if _voyage = null then
		self.lblOnShip.visible := false;
		self.lblInYard.visible := false;
	else
		self.lblOnShip.visible := true;
		self.lblInYard.visible := true;
		self.lblOnShip.caption := app.getErrorString1(OnShipCount, _voyage.allOnshipTIsByCargoTypeId.size.String);
		self.lblInYard.caption := app.getErrorString1(OnSiteCount, _voyage.allOnsiteTIsByCargoTypeId.size.String);
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
