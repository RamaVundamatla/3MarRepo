    <JadeMethod name="setupControls" id="d7c55c72-bd50-4623-89f3-b1b3cc30f809">
        <updating/>
        <source>setupControls()updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2010	cnwndl1	Initial creation	CCMS MES 1005
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	voyage : CM_Voyage;
	now : TimeStamp;

begin

	
						 
	self.cmbVoyage.clear();
	self.myMobileGenericAgent.setCurrentVoyages();
	self.cmbVoyage.addItem(lblVoyage.caption);
	now := app.actualTimeServer;		// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	foreach voyage in self.myMobileGenericAgent.allCurrentVoyages do
		if voyage.isNullVoyage then
			continue;
		endif;
		//06 Dec 2012	NDL	Par 29626
		if voyage.status = Voyage_Status_Departed or voyage.status = Voyage_Status_Closed then
			continue;
		endif;
		if not voyage.arrivedDT.Date.isValid or voyage.arrivedDT &gt; now then
			// hasn't arrived yet
			continue;
		endif;
		
		// nfs 
		if self.myMobileGenericAgent.myTerminal.getConfig(VesselNameOnVoyageCombo).Boolean then //cnwrd1 nfs 31095
			self.cmbVoyage.itemObject[self.cmbVoyage.addItem(voyage.code &amp; Tab &amp; voyage.vesselName )] := voyage;
		else
			self.cmbVoyage.itemObject[self.cmbVoyage.addItem(voyage.code)] := voyage;
		endif;
	endforeach;
	
	voyage := self.myMobileGenericAgent.myVoyage;
	
	if voyage &lt;&gt; null and cmbVoyage.findObject(voyage) &gt; 0 then
		cmbVoyage.listIndex := cmbVoyage.findObject(voyage);
	elseif cmbVoyage.listCount = 2 then
		cmbVoyage.listIndex := 2;
	else
		cmbVoyage.listIndex := 1;
	endif;
	
	
	self.doResizeControls(true);
	
	//24 Mar 2010 NDL Par 23316	- retain value when returning...
	if self.myMobileGenericAgent.checksState = 0 then
		return;
	elseif self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.ShipDischargeCargo then
		self.optDischarge.value := true;
		self.optDischarge.click(self.optDischarge);
	elseif self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.ShipLoadCargo then
		self.optLoad.value := true;
		self.chkSearchParam.visible := true;	//08 Feb 2017	NDL	TFS 3191/2876
		self.chkSearchParam.value := app.myMobileCargoFindAgent.reUseSearchCriteria;	//08 Feb 2017	NDL	TFS 3191/2876
	elseif self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.ShiftOnBoard then
		self.optShift.value := true;
	endif;
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="75842f35-dab5-48e9-ac4d-d7b7062d6c70">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

begin

	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	if app.myMobileCargoFindAgent = null then	//08 Feb 2017	NDL	TFS 3191/2876
		create app.myMobileCargoFindAgent transient;
	endif;
	
	//10 Jul 2012	NDL	Par 29961
	self.myMobileGenericAgent.setHHLanderGroundingOpt();
	self.toGroundAllowed := self.myMobileGenericAgent.hhLanderGroundingOpt &lt;&gt; NoOpts; // 0,2,3 all OK.

	self.setupCmdButtons( 2, app.getErrorString(Next), app.getErrorString(Menu), null, null, null );
	
	inheritMethod();
	
	self.setupControls();
	
	self.resizeCmdButtons();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="380d02ad-f957-4e0b-baea-76678a992fe3">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 23 February 2017 09:15:32.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014418, locale);
	chkSearchParam.translateCaption(Xlat_0021864, locale);
	grpDischTo.translateCaption(Xlat_0015179, locale);
	lblQueue.translateCaption(Xlat_0014419, locale);
	lblVoyage.translateCaption(Xlat_0014420, locale);
	optDischarge.translateCaption(Xlat_0014421, locale);
	optGround.translateCaption(Xlat_0015180, locale);
	optLoad.translateCaption(Xlat_0014422, locale);
	optMach.translateCaption(Xlat_0015181, locale);
	optShift.translateCaption(Xlat_0014423, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
