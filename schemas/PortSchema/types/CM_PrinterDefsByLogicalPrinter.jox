<CollClass name="CM_PrinterDefsByLogicalPrinter" id="7263c3f7-bac0-4421-91ad-59e8f13520c4">
    <memberType name="CM_PrinterDef"/>
    <superclass name="MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="misc"/>
    <MemberKey>
        <property name="CM_PrinterDef::logicalPrinterName"/>
    </MemberKey>
    <JadeMethod name="getLogicalFromPhysical" id="fcc64f82-7821-422b-8ffd-e39e0032287f">
        <source>getLogicalFromPhysical(_physicalName : String) : String;
// ---------------------------------------------------------------------------
// Created:     05 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	printerDef			: CM_PrinterDef;
	iter				: Iterator;	
begin
	
	iter := self.createIterator;
	while iter.next(printerDef) do
		if printerDef.physicalPrinterName = _physicalName then
			return printerDef.logicalPrinterName;
		endif;
	endwhile;
	
	return null;
epilog
	delete iter;
end;</source>
        <Parameter name="_physicalName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
