    <JadeMethod name="translateForm" id="31d9bfc9-53ed-45e9-842b-58a745a2d35d">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 18 December 2019 16:13:27.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0021952, locale);
	btnDelete.translateCaption(Xlat_0021953, locale);
	btnPrint.translateCaption(Xlat_0021954, locale);
	btnTBEdit.translateBubbleHelp(Xlat_0021955, locale);
	btnTBEdit.translateCaption(Xlat_0021956, locale);
	btnTBLoadToOps.translateBubbleHelp(Xlat_0021957, locale);
	btnTBLoadToOps.translateCaption(Xlat_0021958, locale);
	btnTBMoveDown.translateBubbleHelp(Xlat_0021959, locale);
	btnTBMoveDown.translateCaption(Xlat_0021960, locale);
	btnTBMoveUp.translateBubbleHelp(Xlat_0021961, locale);
	btnTBMoveUp.translateCaption(Xlat_0021962, locale);
	btnTBNew.translateBubbleHelp(Xlat_0021963, locale);
	btnTBNew.translateCaption(Xlat_0021964, locale);
	btnTBRefresh.translateBubbleHelp(Xlat_0021965, locale);
	btnTBRefresh.translateCaption(Xlat_0021966, locale);
	lblMovesDone.translateCaption(Xlat_0021967, locale);
	lblMovesDoneNum.translateCaption(Xlat_0021968, locale);
	lblMovesToDo.translateCaption(Xlat_0021969, locale);
	lblMovesToDoNum.translateCaption(Xlat_0021970, locale);
	mnuColourLegend.translateCaption(Xlat_0021971, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0021972, locale);
	mnuContext.translateCaption(Xlat_0021973, locale);
	mnuCraneHours.translateCaption(Xlat_0021974, locale);
	mnuFullLoadPlan.translateCaption(Xlat_0021975, locale);
	mnuFullLoadUnplan.translateCaption(Xlat_0021976, locale);
	mnuInspect.translateCaption(Xlat_0021977, locale);
	mnuJobCargoList.translateCaption(Xlat_0021978, locale);
