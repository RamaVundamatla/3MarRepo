    <JadeMethod name="setCurrent" id="98a37fad-91ab-4aed-bc3f-3d3d8a350886">
        <updating/>
        <source>setCurrent(_yalloc : CM_YardAllocation; _blank4New : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
begin
/*	if self.ctrlYardAlloc.myYardAllocation &lt;&gt; null and _yalloc &lt;&gt; self.ctrlYardAlloc.myYardAllocation then
		if self.allCallingForms.size &gt; 1 then
			if not app.msgBox("bALH", "Confirm Unqueue", MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes then
				return false;
			endif;
		endif;
	endif;*/
	
	// Don't want to override unless told to.
	if (_blank4New and _yalloc = null) then
		self.cmbYardAlloc.listObject := null;
		self.setupYA(null);
	endif;
	if _yalloc &lt;&gt; null and
	   global.isValidObject(_yalloc) then //it may be on a context menu but already deleted cnwrs1 july 2005
	   //par 16308
	  		//self.cmbYardAlloc.listObject := _yalloc;
				self.setupYA(_yalloc);
	endif;
end;</source>
        <Parameter name="_yalloc" type="CM_YardAllocation"/>
        <Parameter name="_blank4New" type="Boolean"/>
    </JadeMethod>
