    <JadeMethod name="userNotify" id="1a305cdc-38b4-4764-8348-c06e0d1e4a33">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;

/*

Purpose:			

Parameters:			None

Return Value:		None


Date		Who		Reason
09 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin
	self.userNotifyProcessing(eventType, theObject, eventTag, userInfo);
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="userNotifyProcessing" id="6e091f43-d409-437d-921e-d364fef291b9">
        <updating/>
        <source>userNotifyProcessing(_eventType: Integer; _theObject: Object; _eventTag: Integer; _userInfo: Any) updating;

/*

Purpose:			

Parameters:			None

Return Value:		None


Date		Who		Reason
09 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	event	: Integer;

begin
	event := self.myInterfaceDefinition.myTerminal.getEventFromTerminalEvent(_eventType);

	if event = Event_ITS_SendResponse then
		if self.chkAutoSend.value then
			while self.doSendNextResponse() do
			endwhile;
		endif;
		self.tblMachines.refreshEntries(null);
	endif;

epilog

end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
        <Parameter name="_userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="xmlAcceptJob" id="ce3b4d00-8bd1-43be-a089-8ccc515eb4bc">
        <source>xmlAcceptJob() : String;

/*

Purpose:			

Parameters:			None

Return Value:		None


Date		Who		Reason
07 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin
