    <JadeMethod name="createEDIData" id="1f725660-2274-4edf-93ff-470af10a3bcb">
        <source>createEDIData(_type :Integer):CM_EDIData protected;
// ---------------------------------------------------------------------------
// Created:     24 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ediDataClass	: Class;
	ediData			: CM_EDIData;
begin
	ediDataClass := self.myTerminal.myEdiConfig.getEDIDataClassForType(_type);
	
	create ediData as ediDataClass.firstNonAbstractSubclass() transient;
	
	return ediData;
	// REMEMBER TO DELETE THIS IN CALLING METHOD
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="CM_EDIData"/>
    </JadeMethod>
    <JadeMethod name="createMappingProxies" id="d4ef69cd-3069-4ce0-9f85-372aad4602fd">
        <source>createMappingProxies(_proxy : CM_EDIFileTypeUser input):Boolean protected;
/*
----------   ----------  --------------------------------------------------
Created:	31 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
24/09/2009	cnwcs5		par 20320 - multiple record types
21 Jan 2013	NDL			Par 29760
28 may 2013	cnwcs5		generate field number rather than using the number from the table.
23 Apr 2014	cnwdap1		PAR #33005 CCMS SFW 1381 Imperial measurements for EDI user defined layouts
//09 Jul 2014	cnwrs1	Par 34524 - measure was not being cleared so all fields after a measurement field retained the measure
*/
vars
	sheet				:CMUI_Sheet;
	table				: CM_DataTable;
	row, numRows, index, column, count,
	ediDataType 		: Integer;
	pxyType				: CM_EDIFieldMappingType;
	pxyMapping			: CM_EDIFieldMapping;
	tmpHookCode, pxytmpHookCode		: CM_EDIFieldHookCode;
	pxyHookCode 		: CM_HookCode;
	userDescr, fieldDescr, propName, 
	descr, fieldType 	: String;
	tooLong 			: Boolean;
	measure				: CM_MeasurementType;						// PAR #33005
	lPos, rPos			: Integer;
	measureName			: String;
	
begin
	while true do
		sheet := self.shtFieldMapping.getControl (index);
		
		if sheet = null or not sheet.visible then	
			// no more sheets
			break;
		endif;
		
		table 		:= self.tblFieldMap.getControl (index);
		numRows 	:= table.rows;
		ediDataType	:= sheet.tag.Integer;
		count		:= 0;	// cnwcs5	May 2013
		// first create the field mappings
		create pxyType transient;
		pxyType.setProxy (self.txtControlColVal.getControl (index).text.trimBlanks, ediDataType, _proxy);
		
		foreach row in table.fixedRows + 1 to numRows do
			count := count + 1;	// cnwcs5	May 2013
			measure := null;
			//21 Jan 2013	NDL	Par 29760
			userDescr := table.getCellValueByName(ETRow_FieldDescription, row).String; 
			
			if userDescr.length &gt; 30 then
				tooLong := true;
				column := table.getColumnByRowName(ETRow_FieldDescription);
			endif;
			
			fieldDescr := table.getCellValueByName(ETRow_FieldType, row).String;
			
			if fieldDescr.length &gt; 30 then
				tooLong := true;
				column := table.getColumnByRowName(ETRow_FieldType);
			endif;
			
			lPos := fieldDescr.pos(Left_Round_Bracket, 1);									// PAR #33005
			if lPos &lt;&gt; null then															// PAR #33005
				rPos := fieldDescr.pos(Right_Round_Bracket, 1);								// PAR #33005
				if rPos &lt;&gt; null then														// PAR #33005
					measureName := fieldDescr[lPos+1:rPos-lPos-1];							// PAR #33005
					measure := app.myRoot.allMeasurementTypesByShortName[measureName];		// PAR #33005
				endif;																		// PAR #33005
			endif;																			// PAR #33005
			
			propName := table.getCellValueByName(ETRow_PropName, row).String;
			
			if propName.length &gt; 30 then
				tooLong := true;
				column := table.getColumnByRowName(ETRow_PropName);
			endif;
			
			if tooLong then
				table.accessCell(row,column).selected := true;
				app.msgBox(app.getErrorString2(Field_Value_Too_Long, table.getCellText(1,column),"30"),app.getErrorString(Error),MsgBox_OK_Only);
				return false;
			endif;
			
			if row = numRows then
				if userDescr = null and fieldDescr = null and propName = null then
					break;
				endif;
			endif;
			
			
			create pxyMapping transient;
			pxyMapping.setProxy(pxyType,
								count,			// cnwcs5 May 2013
								ediDataType,  //ccms 1008 Messina cnwrs1 Sept 2009
								userDescr,	//table.getCellValueByName(ETRow_FieldDescription, row)[1:30].trimBlanks(),
								fieldDescr,	//table.getCellValueByName(ETRow_FieldType, row)[1:30].trimBlanks(),
								propName,	//table.getCellValueByName(ETRow_PropName, row)[1:30].trimBlanks(),
								table.getCellValueByName(ETRow_FieldStripChars, row).trimBlanks(),
								table.getCellValueByName(ETRow_Length, row).trimBlanks()[1:9].Integer,
								table.getCellValueByName(ETRow_UsePrevValIfNull, row).Boolean,
								measure);																// PAR #33005
		endforeach;
		
		// now create the user hook code mappings
		table 	:= self.tblUserFieldCode.getControl (index);
		numRows := table.rows;
		
		foreach row in table.fixedRows + 1 to numRows do
			tmpHookCode :=  table.accessRow(row).itemObject.CM_EDIFieldHookCode;
			
			
			fieldType := table.getCellValueByName(ETRow_FieldType, row).String;
			
			if fieldType.length &gt; 30 then
				tooLong := true;
				column := table.getColumnByRowName(ETRow_FieldType);
			endif;
			
			descr := table.getCellValueByName(ETRow_CodeDescription, row).String;
			
			if descr.length &gt; 30 then
				tooLong := true;
				column := table.getColumnByRowName(ETRow_CodeDescription);
			endif;
			
			if tooLong then
				table.accessCell(row,column).selected := true;
				app.msgBox(app.getErrorString2(Field_Value_Too_Long, table.getCellText(1,column),"30"),app.getErrorString(Error),MsgBox_OK_Only);
				return false;
			endif;
						
			create pxytmpHookCode transient;
			create pxyHookCode transient;
			
		
			pxyHookCode.setForProxy ( tmpHookCode.myHookCode.code, tmpHookCode.myHookCode.myHookType);
			
			pxyHookCode.setJadeCodeForProxy( tmpHookCode.myHookCode.getCurrentJadeCode,	fieldType  ) ;
											
			pxytmpHookCode.setProxy (pxyHookCode , tmpHookCode.propName , tmpHookCode.userDesc ) ;		
			
			pxytmpHookCode.setUserDesc ( descr );
			
			pxyType.allEDIFieldHookCodes.add( pxytmpHookCode );
	
			pxyHookCode.createProxyHookLinkForParent(HookType_EDIFileFieldHook, pxytmpHookCode);		
		endforeach;		
		
		index := index + 1;
	endwhile;
	
	return true;

end;</source>
        <access>protected</access>
        <Parameter name="_proxy" type="CM_EDIFileTypeUser" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doAddFieldHookCode" id="230bd697-9aa5-485d-9fa6-653b2073f589">
        <source>doAddFieldHookCode(_table :CM_DataTable input)protected;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
11 September 2008	cnwrd1	Initial creation
*/

vars
	ediHookCode				: CM_HookCode;
	tmpHookType 			: CM_HookType;
	tmpEDIFieldHookCode		: CM_EDIFieldHookCode;
	jadeCode 				: String;
	userDesc 				: String ;
	tmpComboList 			: ObjectArray;
	entFieldName ,
	entFieldHeading 		: String;
	code					: EntTableRow;
begin
	tmpHookType		:= app.myRoot.allHookTypes[HookType_EDIFileFieldHook];
	tmpComboList	:= self.buildHookFieldNewList(_table);
	
	if tmpComboList.size = 0 then
		return;
	endif;
	
	if app.showHookCodeMaintComboForm(tmpHookType, jadeCode, false, code, tmpComboList) then
		// create hook
		
		entFieldName 	:= code.getName() ;
		entFieldHeading := code.getHeading(null, self.myTerminal, app.myCurrentLocale);
		
		create tmpEDIFieldHookCode transient;
		create ediHookCode transient;
			
		ediHookCode.setForProxy ( entFieldName, tmpHookType);
		ediHookCode.setJadeCodeForProxy(jadeCode , entFieldName ) ;
		tmpEDIFieldHookCode.setProxy (ediHookCode , entFieldHeading , '' ) ;
	
		self.addFieldCodeMapping( tmpEDIFieldHookCode, _table);
		self.setTblUserCodeView(false, _table.index);
	endif;
	
epilog
	delete tmpComboList;
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBaseFormCancel" id="1d8bdf81-a48d-4f5d-ad96-f86f1358b423">
        <updating/>
        <source>doBaseFormCancel() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	20 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
30/05/2013	cnwcs5		par 31681	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if 	self.mode = self.MODE_VIEW then
		self.unloadForm();
	else
		self.loadFileTypeDetails;				// par 31618
		self.setControlsForView();
		cmbFileDef.setFocus();					// 17/02/2010 cnwmh5 #23205
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="1fb2ef88-060d-4538-a810-1dd7d27621a6">
        <updating/>
        <source>doBaseFormSave() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	31 July 2006 By cnwth2

Purpose:	

Changed On  Changed By  Reason
	
----------  ----------  --------------------------------------------------
*/
vars
	fileType		: CM_EDIFileTypeUser;
begin
	fileType := self.doSave();
	
	if fileType &lt;&gt; null then
		if self.cmbFileDef.findObject(fileType) &lt; 1 then
			self.cmbFileDef.itemObject[cmbFileDef.addItem(fileType.name)] := fileType;
		endif;
		self.cmbFileDef.listObject := fileType;
		
		self.setControlsForView();
		cmbFileDef.setFocus();					// 17/02/2010 cnwmh5 #23205
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDelete" id="3dadd0d1-85b3-4898-b573-1f0e345d254e">
        <updating/>
        <source>doDelete() protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	31 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
----------   ----------  --------------------------------------------------
13/10/2009	cnwcs5		par 21242
*/
vars

	fileType		: CM_EDIFileTypeUser;
	result			: Integer;
begin
	if self.mode &lt;&gt; self.MODE_VIEW then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Not in view mode for delete');
		return;
	endif;
			
	fileType := self.cmbFileDef.listObject.CM_EDIFileTypeUser;
	
	if fileType = null then
		app.msgBox('You must select a file definition to delete first', 'Nothing selected', MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	if 	app.msgBox('Are you sure you want delete the user-defined EDI file type "' &amp; fileType.name &amp;'"?', 'Are you sure?', MsgBox_OK_Cancel) &lt;&gt; MsgBox_Return_OK then
		return;
	endif;
	
	while true do
		app.myTrxDA.trxDeleteEDIFileTypeUser(fileType, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			self.loadCmbFileTypes();
			self.clearForNew;	// par 21242
			return;
		else
			result := app.showErrorWarningDialog('EDI File Type Delete', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings windo
		endif;
		
		return;
	endwhile;

	
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDeleteFieldMapping" id="388e964a-6dd2-4bc6-8145-71d4a2cf69ce">
        <source>doDeleteFieldMapping(_table :CM_DataTable input) protected;
/*
Date		Who		Reason
28 May 2013	cnwcs5	Initial Creation - par 31618
*/
vars
	row, fixedRows :Integer;
begin
	row 		:= _table.row;
	fixedRows	:= _table.fixedRows;
	
	if row &lt;= fixedRows then
		return;
	endif;
	
	_table.deleteRow (row);
	
	self.doRenumberRows (_table);
	
	self.txtNumFields.getControl (_table.index).text := (_table.rows - fixedRows).String;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doDeleteHookCode" id="5d3445f1-f14f-4664-81b6-630e83965e73">
        <source>doDeleteHookCode(_table :CM_DataTable input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 September 2008	cnwrd1	Initial creation

*/

vars
	hookCode : CM_EDIFieldHookCode;
begin
	hookCode := _table.accessRow(_table.row).itemObject.CM_EDIFieldHookCode;
	
	if hookCode = null  then
		return;
	endif;
	
	if self.confirmDelete( 'Hook Code', hookCode.propName) then
		// delete the hook code
		_table.deleteRow(_table.row);
		delete hookCode;
	endif;
epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doExportDefinition" id="076400ec-c8bf-453e-812e-6ed92e2894d0">
        <source>doExportDefinition() protected;
/*
----------   ----------  --------------------------------------------------
Created:	05 March 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	fileGet		 		: CMDFileSave;
	file				: File;
	def					: CM_EDIFileTypeUser;
	objArray			: ObjectArray;
	
begin
	if self.mode &lt;&gt; self.MODE_VIEW then
		return;
	endif;
	
	def := self.cmbFileDef.listObject.CM_EDIFileTypeUser;
	if def = null then
		app.msgBox(	app.getString( CMUI_MustSelect, app.getString( File_Definition ), app.getString( Export ) ),
					app.getString( NOTHING_SELECTED ),
					MsgBox_Exclamation_Mark_Icon );
		return;
	endif;
	
	create fileGet transient;
	create file transient;
	create objArray transient; 
	
	fileGet.cnEcSetFilters( CNEC_FILE_FILTER_XML, true, 1 );
	fileGet.initDir := self.myTerminal.getConfig_FileDirectory(EDIFileDirectory).String;
	fileGet.fileName := def.name &amp; XML_Filetype;	// default to the user file type name plus suffix of .xml
	
	// cnwrl1 15/03/2010 PAR 22441 - start of coding
	// The proposed file name cannot contain certain characters replace these with a hyphen now.
	if not fileGet.fileName.cnEcIsValidFileName then		// checks for \/:*?"&lt;&gt;|
		fileGet.fileName	:= fileGet.fileName.cnEcFindReplace( '\', Hyphen, true );
		fileGet.fileName	:= fileGet.fileName.cnEcFindReplace( '/', Hyphen, true );
		fileGet.fileName	:= fileGet.fileName.cnEcFindReplace( ':', Hyphen, true );
		fileGet.fileName	:= fileGet.fileName.cnEcFindReplace( '*', Hyphen, true );
		fileGet.fileName	:= fileGet.fileName.cnEcFindReplace( '?', Hyphen, true );
		fileGet.fileName	:= fileGet.fileName.cnEcFindReplace( '"', Hyphen, true );
		fileGet.fileName	:= fileGet.fileName.cnEcFindReplace( '&lt;', Hyphen, true );
		fileGet.fileName	:= fileGet.fileName.cnEcFindReplace( '&gt;', Hyphen, true );
		fileGet.fileName	:= fileGet.fileName.cnEcFindReplace( '|', Hyphen, true );
	endif;
	// cnwrl1 15/03/2010 PAR 22441 - end of coding
	
	if fileGet.open = 0 then	//user clicked OK (or the file name is invalid!)
		file.mode := File.Mode_Output;	// 1/3/16 cnwmp6 PAR 36286 unicode version
		file.fileName := fileGet.fileName;
	else
		return;
	endif;
	
	def.exportMeXML(file, objArray, true, true);
	
epilog
	delete fileGet;
	delete file;
	delete objArray;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doImportDefinition" id="884bf18c-95c3-4d60-9669-124bf707577b">
        <updating/>
        <source>doImportDefinition( _newXMLDefn : String output ) : Boolean protected, updating;

/*
----------   ----------  --------------------------------------------------
Created:	05 March 2007 By cnwth2

Purpose:	

Changed On	Changed By  Reason
18/11/2009	cnwrl1		PAR 18591 - handle UE 5030 (file in already use) plus handle filtering correctly.
27/11/2009	cnwrl1		PAR 21713 - handle removal of CargoType, also set the form to the newly loaded definition is possible.
26/05/2010	cnwrl1		PAR 24131 - EDI Release Request Type to be translatable string.
08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
23/04/2014	cnwdap1		PAR #33005 CCMS SFW 1381 Imperial measurements for EDI user defined layouts
09/03/2018	jlgmd1		TFS #37520 JMT - EDI User Defined File Type Import Bugs
----------	----------  --------------------------------------------------
*/

vars
	defName				: String;
	extension			: String;
	block				: String;
	fileGet		 		: CMDFileOpen;
	file				: File;
	fileTypeUser		: CM_EDIFileTypeUser;
	pxyFileTypeUser		: CM_EDIFileTypeUser;
	objArray			: ObjectArray;
	result				: Integer;
	
begin
	if self.mode &lt;&gt; self.MODE_VIEW then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid mode for import (' &amp; self.mode.display &amp; ')');
		return false;
	endif;
	
	// allow for UE 5030 - File is in use by another process
	app.cnFileRetryCount	:= 10;
	on FileException do app.cnFileInUseExceptionHandler( exception );
	
	create fileGet transient;
	create file transient;
	create objArray transient;
	
	fileGet.cnEcSetFilters( true, 1, CNEC_FILE_FILTER_XML );
	fileGet.fileName		:= '';
	fileGet.createPrompt	:= false;		// do not prompt to create an import file!
	fileGet.initDir			:= self.myTerminal.getConfig_FileDirectory(EDIFileDirectory).String;
	if fileGet.open = 0 then	//user clicked OK
		file.kind := File.Kind_Unknown_Text;	// 1/3/16 cnwmp6 PAR 36286 unicode version
		file.fileName := fileGet.fileName;
	else
		return false;
	endif;
	
	// if the user has not selected an xml file type then it is an error.
	extension	:= file.cnEcFileExt();
	if extension &lt;&gt; null and extension.toUpper &lt;&gt; EDIFileVersion_XML then
		app.msgBox(	app.getString( FIle_HasInvalid_Extension, file.fileName, EDIFileVersion_XML ),
					app.getString( Error ), MsgBox_OK_Only );
		return false;
	endif;
	
	block	:= file.readString(file.fileLength);
	if block = null then
		app.msgBox( app.getString( Selected_EmptyFile_ForProcess ), app.getString( Error ), MsgBox_OK_Only );
		return false;
	endif;
	
	defName			:= block.cnEcGetTagValueOfName(CM_EDIFileTypeUser::name.name);
	fileTypeUser	:= app.myRoot.allEDIFileTypes[EDIFileType_UserDefined, defName].CM_EDIFileTypeUser;
	if fileTypeUser &lt;&gt; null then
		if app.msgBox(	app.getString( Existing_FileDefn_Warning, defName ),
						app.getString( Update_Existing ),
						MsgBox_OK_Cancel + MsgBox_Default_Second ) &lt;&gt; MsgBox_Return_OK then
			return false;
		else
			beginLoad;
			pxyFileTypeUser := app.createUpdateProxy(fileTypeUser).CM_EDIFileTypeUser;
			endLoad;
			
			// As we are loading all the search words from our xml file, we don't want to start with any previous ones
			pxyFileTypeUser.emailSearchWords.purge;	// TFS 37520
		endif;
	else
		create pxyFileTypeUser transient;
	endif;
	
	pxyFileTypeUser.importMeXML(block);
	
	// If the xml to be imported contains propName of "CargoType" then need to either:
	// delete it if propName of "CargoTypeDescr" already exists else rename it to that.
	self.handlePossibleCargoTypeMapping( pxyFileTypeUser );
	
	// cnwrl1 26/05/2010 PAR 24131 - start of coding
	// If the xml to be imported contains propName of "releaseType" then need to either:
	// delete it if propName of "releaseTypeStr" already exists else rename it to that.
	self.handleReleaseTypeMappings( pxyFileTypeUser );
	// cnwrl1 26/05/2010 PAR 24131 - end of coding
	
	self.handleMeasurementTypes(pxyFileTypeUser);						// PAR #33005
	
	while true do
		if fileTypeUser = null then
			app.myTrxCA.trxCreateEDIFileTypeUser(fileTypeUser, pxyFileTypeUser, app.myPassport);
		else
			app.myTrxUA.trxUpdateEDIFileTypeUser(pxyFileTypeUser, app.myPassport);
		endif;
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			_newXMLDefn	:= defName;		// Attempt to find and set the current entry to this newly loaded one.
			return true;
		else
			result := app.showErrorWarningDialog(	app.getString( EDI_File_Type_User ),
													app.myPassport,
													ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings );
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings windo
		endif;
		
		return false;
	endwhile;
	
epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	delete fileGet;
	delete file;
	delete objArray;
	delete pxyFileTypeUser;
	
end;
</source>
        <access>protected</access>
        <Parameter name="_newXMLDefn" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doInsertFieldMapping" id="91070e71-cc33-4954-8ac8-f8ae1f92359d">
        <source>doInsertFieldMapping(_table :CM_DataTable input) protected;
/*
Date		Who		Reason
28 May 2013	cnwcs5	Initial Creation - par 31618
*/
vars
	row, fixedRows, newRow :Integer;
begin
	// we add a row BEFORE the selected row
	row 		:= _table.row;
	fixedRows	:= _table.fixedRows;
	
	if row &gt; fixedRows then
		// add row BEFORE selected row		
		_table.addItemAt (null, row);

		self.addFieldMapping (_table, row, null);	
	else
		return;
	endif;
	
	self.doRenumberRows (_table);
	
	self.txtNumFields.getControl (_table.index).text := (_table.rows - fixedRows).String;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doLineHookAdd" id="b00af200-590d-4f8a-85ed-9b304da86aa5">
        <updating/>
        <source>doLineHookAdd(_table :CM_DataTable) updating;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
12 September 2008	cnwrd1	Initial creation
*/

vars
	ediHookCode		: CM_HookCode;
	tmpHookType 	: CM_HookType;
	jadeCode 		: String;
	code, userDesc 	: String ;
	msg : String;
begin
	tmpHookType := app.myRoot.allHookTypes[HookType_EDIFileIncludeLine];
	
	code := self.txtName.text.trimBlanks();
	code := code &amp; 'lineHook'; // cnwrd1 30.10.08 par #18402 - no blank code 
	
	//04 Nov 2013	NDL	Par 32867
	if code.length &gt; 30 then
	//	msg := "Name may not be more than 22 characters when including hook code.";
		msg := app.getErrorString2(Not_more_than_chara_when_inclu, self.lblName.caption, "22");
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only);
		self.txtName.setFocus();
		return;
	endif;
	
	if app.showHookCodeMaintForm(tmpHookType, jadeCode, false) then
		// create hook
		
		create ediHookCode transient;
		
	// 04 Nov 2013	NDL	Par 32867 - moved up so we can test the length first.
	//	code := self.txtName.text.trimBlanks();
	//	code := code &amp; 'lineHook'; // cnwrd1 30.10.08 par #18402 - no blank code 
		
		ediHookCode.setForProxy ( code, tmpHookType);
		ediHookCode.setJadeCodeForProxy(jadeCode , code ) ;
	
		self.myFileLineHookCode := ediHookCode;
		
		//validate at time of edit... #18402,
		self.myFileLineHookCode.allHookCodeHistory.first.validate();
	endif;
	
	self.setLineHookCtrls();
end;</source>
        <Parameter name="_table" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="doLineHookDel" id="9b9fda8a-3824-4cb5-bf06-1fcea691b4b6">
        <updating/>
        <source>doLineHookDel(_table :CM_DataTable) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 September 2008	cnwrd1	Initial creation

*/

vars

begin
	if self.confirmDelete( 'File line', 'Hook Code') then
		// delete the hook code	
		delete self.myFileLineHookCode;
		self.myFileLineHookCode := null;
	endif;

	self.setLineHookCtrls();
epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="doLineHookEdit" id="4f3b7fa1-b893-4b49-a06c-af42a88e9304">
        <updating/>
        <source>doLineHookEdit() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 September 2008	cnwrd1	Initial creation

*/

vars
