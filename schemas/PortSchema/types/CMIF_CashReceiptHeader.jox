    <JadeMethod name="gpha_print" id="be1fcf26-5830-4da0-9164-be6f8f6d4202">
        <updating/>
        <source>gpha_print(_terminal : CM_Terminal;_isProformaPrint : Boolean) updating;
// Ghana Port cash receipt printing
// Print one copy, preview, use default printer and configured report name.
vars
	payment		: CM_CashPayment;
	termDict 	: CM_TerminalByCodeDict;
	jadeReport					: JadeReport;
	jrwManager	: JadeReportWriterManager;
	jrwReport	: JadeReportWriterReport;
	jrwInv		: CM_JRWInvoice;
	transientRep : JadeReportWriterReport;
	duplex		: Integer;
	reportString : String;
	printerName : String;

begin

	create jadeReport transient;
	jadeReport.description := app.getErrorString(CM_Default);
	app.printer.setReport(jadeReport);
		
	jrwInv := app.myQAFilter.createJRWTransient(CM_JRWInvoice).CM_JRWInvoice;

	create termDict transient;
	termDict.add(_terminal);
	jrwInv.setAllTerminals(termDict);
	jrwInv.allCashReceiptReporting.add(self);
	jrwInv.myDebtor := self.gpha_myDebtor;
	
	if _isProformaPrint then // TFS 44275
		reportString := _terminal.getConfig(CashProformaReport).String; // TFS 44275
	else
		reportString := _terminal.getConfig(GateCashReceiptReport).String;
	endif;
	
	if reportString = null then
		return;
	else
		// print to lineflow via text file
		if reportString.pos("?TXT", 1) &gt; 0 then
			app.printReportViaTextFile(reportString);
			return;
		
		elseif reportString.pos("?DOT", 1) &gt; 0 then
			app.printReportDotMatrix(reportString, self, false);
			return;
		
		endif;
	endif;
	jrwManager := app.createReportWriterManager();
	transientRep := jrwManager.getReport(reportString);
	if transientRep = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "Cash Receipt report not specified in cash config, (" &amp; reportString &amp; " does not exist)");
		return;
	endif;
	jrwReport := transientRep;

	jrwReport.setOutputDestination(JadeReportWriterReport.PRINTER);
		
	duplex := app.printer.duplex;
	jrwReport.setPageOptions(Print_A4, Print_Portrait, 1, 0, 0, 0, 20, 0, false, duplex);
	jrwReport.setPreviewOptions(false, true, false, true, null);

	jrwReport.run;

	app.printPreview(jadeReport, true);

epilog
	delete transientRep;
	delete jrwInv;	
	delete jrwManager;
	delete termDict;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_isProformaPrint" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="gpha_setHeaderDetails" id="225a50fc-142b-481f-88d0-4a8905119545">
        <updating/>
        <source>gpha_setHeaderDetails(_terminal: CM_Terminal; 
				_debtor: CM_Debtor; 
				_bol: String; 
				_voyage: CM_Voyage; 
				_effectiveDate: Date;
				_title : String) updating;
/*

Date		Who		Reason 
17 August 2015	cnwer1	Initial creation PAR 36778

*/

vars

begin
	self.gpha_myTerminal:=_terminal;
	self.gpha_myDebtor:=_debtor;
	self.gpha_bolNumber:=_bol;
	self.gpha_myVoyage:=_voyage;
	self.gpha_invoiceTitle := _title;
	
	if self.gpha_myVoyage &lt;&gt; null then
		self.gpha_vesselName := self.gpha_myVoyage.vesselName;
	endif;
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_bol" type="String"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_effectiveDate" type="Date"/>
        <Parameter name="_title" type="String"/>
    </JadeMethod>
    <JadeMethod name="gpha_updateTotalsFromDetails" id="f6ff809e-1fd2-4546-bf15-353c84e7fb4d">
        <updating/>
        <source>gpha_updateTotalsFromDetails() updating;
/*

Date		Who		Reason
17 August 2015	cnwer1	Initial creation PAR 36778
28/11/2019	jlgsl4	TFS 47529 - JMT - Decimal Values on CM_CashReceipt, CM_CashPayment, CM_CashInvoiceProformaAgent
*/

vars
	cmifDetail : CMIF_CashReceiptReporting;
	cmifGPHADetail : CMIF_CashReceiptDetail;		// 28/8/19 MAP TFS45303
	handlingType,str : String;
	packageTypes	: StringArray;
	allTaxCodes 	: ObjectArray;
	taxCode		: CM_TaxCode;
	taxRate		: CM_TaxRate;
	count 		: Integer;
	obj	 		: Object;
	effectiveTS : TimeStamp;
	ti  : CM_TrackedItem;
	voyage :  CM_Voyage;
	hookExempt : Boolean;
begin
	
	create packageTypes transient;
	
	foreach cmifDetail in self.gpha_allDetails do
		cmifGPHADetail:=cmifDetail.CMIF_CashReceiptDetail;
		ti:=cmifGPHADetail.gpha_myTrackedItem;
		if ti.isKindOf(CM_Container) then
			self.gpha_numberOfContainers:= self.gpha_numberOfContainers + 1;
		else
			self.gpha_numberOfPackages:=self.gpha_numberOfPackages + 1;
			handlingType := null;
			if ti.myProduct &lt;&gt; null then
				if ti.myProduct.myHandlingType &lt;&gt; null then
					handlingType := cmifGPHADetail.gpha_myTrackedItem.myProduct.myHandlingType.description;
				endif;
			elseif ti.myCargoType &lt;&gt; null and
				    ti.myCargoType.myDefaultHandlingType &lt;&gt; null then
					handlingType := ti.myProduct.myHandlingType.description;
			endif;
			if handlingType &lt;&gt; null then
				if not packageTypes.includes(handlingType) then
					packageTypes.add(handlingType);
				endif;
			endif;
		endif;
		self.gpha_total:=self.gpha_total + cmifGPHADetail.gpha_lineTotalLessTax;
	endforeach;
	
	foreach handlingType in packageTypes do
		if str = null then
			str := handlingType;
		else
			str := str &amp; " ," &amp; handlingType;
		endif;
	endforeach;
	self.gpha_packageType := str;
	
	effectiveTS.setDate(self.effectiveDate);
	if self.gpha_myDebtor &lt;&gt; null and
	   not self.gpha_myDebtor.isZeroRatedTax then
		create allTaxCodes transient;
		self.myTerminal.getAllCashTaxCodes(allTaxCodes);
		foreach obj in allTaxCodes do
			count := count + 1;
			taxCode := obj.CM_TaxCode;
			taxRate := taxCode.getTimeRate(effectiveTS);
			if count = 1 then
				self.gpha_totalTax1 :=((self.gpha_total * taxRate.rate) / 100);//.roundedTo(2); // TFS 47529
			elseif count = 2 then
				self.gpha_totalTax2 :=((self.gpha_total * taxRate.rate) / 100);//.roundedTo(2); // TFS 47529
			else
				break;
			endif;
		endforeach;	
		// TFS 37562 exempt by voyage
		voyage := self.gpha_myVoyage;
		if voyage &lt;&gt; null then
			hookExempt := app.myRoot.getVoyageTaxExempt( voyage.myTerminal, voyage ).Boolean;
			if hookExempt then
				self.gpha_totalTax1 := 0;
				self.gpha_totalTax2 := 0;
			endif;
		endif;
	endif;
epilog
	delete packageTypes;
	delete allTaxCodes;
end;</source>
    </JadeMethod>
    <JadeMethod name="print" id="57d05eff-0a30-410b-a434-f86ff40312c8">
        <updating/>
        <source>print(_terminal : CM_Terminal) updating;
// 31602 Gulftainer Umm Qasr cash receipt printing
// Print one copy, preview, use default printer and configured report name.
// 29 Sep 2021 navma1 ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
vars
	payment		     : CM_CashPayment;
	jadeReport		 : JadeReport;
	jrwManager	     : JadeReportWriterManager;
	jrwReport	     : JadeReportWriterReport;
	jrwInv		     : CM_JRWInvoice;
	transientRep     : JadeReportWriterReport;
	duplex		     : Integer;
	reportString	 : String;
	printerName 	 : String;
	cashRec          : CM_CashReceipt;
	voyageProcess    : CM_VoyageProcess;
begin
	
	create jadeReport transient;
	jadeReport.description := app.getErrorString(CM_Default);
	app.printer.setReport(jadeReport);
		
	jrwInv:=self.createJRWTransient(); //epr TFS 38530 15/5/18
	
	if self.invoiceNumber = CMIF_CashReceiptHeader.PROFORMA then // TFS 7557 
		reportString := _terminal.getConfig(CashProformaReport).String;  // TFS 7557
	endif;
	

	if reportString = null then  // TFS 7557
		reportString := _terminal.getConfig(GateCashReceiptReport).String;
	endif;
	
	//29.09.2021 navma1 #51925
	cashRec := self.myCashReceipt;
	if cashRec &lt;&gt; null and cashRec.myWorkOrder &lt;&gt; null then
		voyageProcess	:=cashRec.myTerminal.getDefaultVoyageProcess();
		if voyageProcess &lt;&gt; null and voyageProcess.reportInvoiceEstimate &lt;&gt; null then
			reportString := voyageProcess.reportInvoiceEstimate;
		endif;
	endif;
	//29.09.2021 navma1 #51925
	
	if reportString = null then
		reportString := "CM_ProformaInvoice";
	else
		// print to lineflow via text file
		if reportString.pos("?TXT", 1) &gt; 0 then
			app.printReportViaTextFile(reportString);
			return;
		
		elseif reportString.pos("?DOT", 1) &gt; 0 then
			app.printReportDotMatrix(reportString, self, false);
			return;
		
		endif;
	endif;
	jrwManager := app.createReportWriterManager();
	transientRep := jrwManager.getReport(reportString);
	if transientRep = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "Cash Receipt report not specified in cash config, (" &amp; reportString &amp; " does not exist)");
		return;
	endif;
	
	
	jrwReport := transientRep;

	jrwReport.setOutputDestination(JadeReportWriterReport.PRINTER);
		
	duplex := app.printer.duplex;
	jrwReport.setPageOptions(Print_A4, Print_Portrait, 1, 0, 0, 0, 20, 0, false, duplex);
	jrwReport.setPreviewOptions(false, true, false, true, null);

	jrwReport.run;

	app.printPreview(jadeReport, true);

epilog
	delete transientRep;
	delete jrwInv;	
	delete jrwManager;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="qns_print" id="e0cf11b4-ad5c-4b11-a7b6-90d6027925b2">
        <updating/>
        <source>qns_print(_isProformaPrint :Boolean) updating;
// QNS cash receipt printing
// Print one copy, preview, use default printer and configured report name.
// 07 Mar 2019	cnwma1	Bug 42198: GUQ - Proforma Invoice not Printing
vars
	payment		 : CM_CashPayment;
	termDict 	 : CM_TerminalByCodeDict;
	jadeReport	 : JadeReport;
	jrwManager	 : JadeReportWriterManager;
	jrwReport	 : JadeReportWriterReport;
	jrwInv		 : CM_JRWInvoice;
	transientRep : JadeReportWriterReport;
	duplex		 : Integer;
	reportString : String;
	printerName  : String;
	terminal     : CM_Terminal;
begin
	
	if self.qns_myCashReceipt &lt;&gt; null then
		terminal := self.qns_myBank.terminal;
	endif;
	
	create jadeReport transient;
	jadeReport.description := app.getErrorString(CM_Default);
	app.printer.setReport(jadeReport);
		
	jrwInv := app.myQAFilter.createJRWTransient(CM_JRWInvoice).CM_JRWInvoice;

	create termDict transient;
	termDict.add(terminal);
	jrwInv.setAllTerminals(termDict);
	jrwInv.allCashReceiptReporting.add(self);
	jrwInv.myDebtor := self.qns_myDebtor;
	
	if _isProformaPrint then 
		reportString := terminal.getConfig(CashProformaReport).String;  
	else
		reportString := terminal.getConfig(GateCashReceiptReport).String;
	endif;
	
	if reportString = null then
		return;
	else
		// print to lineflow via text file
		if reportString.pos("?TXT", 1) &gt; 0 then
			app.printReportViaTextFile(reportString);
			return;
		
		elseif reportString.pos("?DOT", 1) &gt; 0 then
			app.printReportDotMatrix(reportString, self, false);
			return;
		
		endif;
	endif;
	jrwManager   := app.createReportWriterManager();
	transientRep := jrwManager.getReport(reportString);
	
	if transientRep = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "Cash Receipt report not specified in cash config, (" &amp; reportString &amp; " does not exist)");
		return;
	endif;
	
	jrwReport := transientRep;
	jrwReport.setOutputDestination(JadeReportWriterReport.PRINTER);
		
	duplex := app.printer.duplex;
	jrwReport.setPageOptions(Print_A4, Print_Portrait, 1, 0, 0, 0, 20, 0, false, duplex);
	jrwReport.setPreviewOptions(false, true, false, true, null);

	jrwReport.run;

	app.printPreview(jadeReport, true);

epilog
	delete transientRep;
	delete jrwInv;	
	delete jrwManager;
	delete termDict;
end;</source>
        <Parameter name="_isProformaPrint" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="qns_printCredit" id="f14e6abf-fecc-4d4b-8469-a467928f4b95">
