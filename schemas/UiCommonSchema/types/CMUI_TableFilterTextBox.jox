<GUIClass name="CMUI_TableFilterTextBox" id="3b9cb52a-7e49-422c-992c-27c71a73fac8">
    <superclass name="CMUI_TextBox"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <Constant name="TimerConstant" id="70e63ef4-d862-407c-b4b5-a328f78942d7">
        <source>65481732</source>
        <type name="Integer"/>
    </Constant>
    <ImplicitInverseRef name="parentControl" id="541d8fd4-3832-4b26-8ef8-7d4dde66cf81">
        <embedded/>
        <type name="CMUI_ToolbarFrameTableFilter"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="keyDown" id="1367af11-648a-4120-9e61-82e1e595633f">
        <controlMethod name="TextBox::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>keyDown(textbox: TextBox input; keyCode: Integer io; shift: Integer) updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18/04/2024	navkc1 CR63736 Task 63737: Jade - New Filter Control

*/

vars
	type,
	remaining		: Integer;
begin
	if self.getTimerStatus(self.TimerConstant, type, remaining) then
		self.endTimer(self.TimerConstant);  
	endif;
			
	self.beginTimer(500, Timer_OneShot, self.TimerConstant);
	
	inheritMethod(textbox, keyCode, shift);

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setMyParent" id="42dc4661-d258-48d3-bda0-0fbee4d90352">
        <updating/>
        <source>setMyParent(_parent : CMUI_ToolbarFrameTableFilter) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18/04/2024	navkc1 CR63736 Task 63737: Jade - New Filter Control

*/

vars

begin
	self.parentControl := _parent;
epilog

end;</source>
        <Parameter name="_parent" type="CMUI_ToolbarFrameTableFilter"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="0df711c0-7c9f-4171-b208-dea6148e6927">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18/04/2024	navkc1 CR63736 Task 63737: Jade - New Filter Control

*/

vars

begin
	if self.parentControl &lt;&gt; null then
		if self.parentControl.isKindOf(CMUI_ToolbarFrameTableFilter) then
			if self.text = null then //15/01/2025	navkc1 JIRA Defect Sub-task MTN-33784
				self.parentControl.CMUI_ToolbarFrameTableFilter.doClearFilter(); //15/01/2025	navkc1 JIRA Defect Sub-task MTN-33784
			else
				self.parentControl.CMUI_ToolbarFrameTableFilter.doTableFilter();
			endif;
		endif;
		
	endif;
epilog

end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
