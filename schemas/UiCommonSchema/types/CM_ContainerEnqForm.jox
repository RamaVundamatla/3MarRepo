    <JadeMethod name="splitFilterID" id="a75d4bf7-a34d-42be-90de-d4f5d61a39bd">
        <source>splitFilterID(_tiId : String);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 May 2010	cnwrd1	Initial creation
5 July 2010 cnwas3	par 24542
*/

vars
	tokenString : String;
begin
	
	self.myFilterIDList.clear();
	
	tokenString := _tiId;
	tokenString.replaceChar(',', ' ');
	tokenString := tokenString.removeTabCrLfs();		//cnwas3 par 24542	

	tokenString.trimBlanks().getTokensForDelimiterHugeNoNul(' ',self.myFilterIDList );
epilog

end;</source>
        <Parameter name="_tiId" type="String"/>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="c3a1bccf-b543-419a-b988-4e86012ac8ed">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     03 July 2006 by cnwrs2
//
// Purpose:     
//
// Changed On  	Changed By  Reason
// 30/05/2025	jlizm1		MTN 34728 Handle notifications cargo enquiry
// ---------------------------------------------------------------------------
vars

begin
	if theObject.isKindOf(CM_TrackedItem) then
		if self.notificationLevel = self.NoteLevelDoNotes then
			self.beginTimerForNotifications(theObject, eventType, eventTag, theObject);
		endif;
		
		return;
	endif;

	if eventType = Object_Delete_Event and
	   self.filterTerminalArea &lt;&gt; null and
	   self.filterTerminalArea = theObject then
		self.setFilterTerminalArea(null);
	endif;

	inheritMethod(eventType, theObject, eventTag);

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
