    <JadeMethod name="doReeferAutoJobs" id="48572b7f-6d92-4a47-9e7d-dc4f13ee1caf">
        <source>doReeferAutoJobs();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Aug 2020	jlgndl1	Initial creation	TFS 49581
02 Nov 2022	navsp1	TFS 54899 PEM Reefer Monitor App Changes
20April2023 navsp1  TFS Bug 57667: PEN - Reefer App Un-Queueing Moves does not remove the disconnect action
25 Feb 2025 navsp1  JIRA 19238 PEN | Smart App - Reefer Monitor Application
*/

vars

	criteria : CM_ReeferJobCriteria;
	disconnTimeStamp : TimeStamp;
	lc : CM_LocationsController;
	connTimeStamp : TimeStamp;
	monTimeStamp : TimeStamp;
	ti : CM_TrackedItem;
	information : StringArray512;
	newJob : CM_YardActivity;
	yardActivity : CM_YardActivity;
	activities : CM_YardActivityArray;
begin

	if not self.myTrackedItem.isReefer then
		return;
	endif;
	
	ti := self.myTrackedItem;

	if self.mode = QUEUE_MODE then
		if self.unplan then  // ### TFS 51300 07JUL2021 NAVAB1
			
			//20.April.2023 navsp1 TFS 57667
			if ti.isConnected then
				if ti.allQueuedFutureMoves.size = 0 then //remove the disconnect activity only if the TI has no other queued moves
					create activities transient;
					self.myTrackedItem.getReeferActivity(CM_YardActivity.ReeferDisconnect, true, activities);
					foreach yardActivity in activities do
						app.myUtilityDA.utlDeleteYardActivity( yardActivity, app.myPassport );
						if app.myPassport.hasErrors then
							app.writeLog(method.qualifiedName &amp; "Errors - unable to delete the disconnect activity" ,LogERROR);
						else
							app.writeLog("Disconnect activity has been deleted",LogDEBUG);
						endif;
					endforeach;
				endif;
			endif;
			
		else
			if ti.isConnected then
				criteria := self.myTrackedItem.getMatchingReeferCriteria();
				if criteria &lt;&gt; null then
					if criteria.disconnect then
						disconnTimeStamp := criteria.getDisconnectReeferTS();	
						if disconnTimeStamp.date.isValid then
							newJob := self.myTrackedItem.createReeferJob( CM_ReeferDisconnectActivity, disconnTimeStamp, app.myPassport );
							
							ti.createReeferJobInformation(newJob,criteria,true ); // ### TFS 51300 07JUL2021 NAVAB1
							
						endif;
					endif;
				endif;
			endif;
		endif;
	endif;
	
	if self.mode = REAL_MODE then
		if not self.myTrackedItem.isConnected then
			lc := self.getTargetLocationsController;
			if (lc &lt;&gt; null and (lc.isGridLocation or (lc.isYardLocation and self.myTerminal.getConfig(AllReeferJobsForTerminal).Boolean))) then //20OCT2022 navsp1 TFS 54899  //JIRA-19238
				criteria := self.myTrackedItem.getMatchingReeferCriteria();
				if criteria &lt;&gt; null then
					if criteria.connect then
						connTimeStamp := criteria.getConnectReeferTS();	
						if connTimeStamp.date.isValid then
							newJob := ti.createReeferJob( CM_ReeferConnectActivity, connTimeStamp, app.myPassport );
							ti.createReeferJobInformation(newJob,criteria,true ); // ### TFS 51300 07JUL2021 NAVAB1

						endif;
					endif;
					if not self.myTrackedItem.hasAnyReeferMonitorJob and criteria.monitor then
						monTimeStamp := criteria.getNextReeferMonitorTS();	
						if monTimeStamp.date.isValid then
							newJob := ti.createReeferJob( CM_ReeferMonitorActivity, monTimeStamp, app.myPassport );
							ti.createReeferJobInformation(newJob,criteria,true ); // ### TFS 51300 07JUL2021 NAVAB1
						endif;
					endif;
				endif;
			endif;
		endif;
	endif;

epilog
	delete activities;
end;</source>
    </JadeMethod>
