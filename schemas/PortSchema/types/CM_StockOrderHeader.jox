    <JadeMethod name="pxyCreateUpdateProxy" id="2a5f218e-58c0-436b-8a32-d4de4586d6d5">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     26 June 2002 by cnwsb1
// ---------------------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	pxyHdr		: CM_StockOrderHeader;
	realLine	: CM_StockOrderLine;
	pxyLine		: CM_StockOrderLine;
	completedOK		: Boolean;
	
begin

	pxyHdr := inheritMethod();
	
	pxyHdr.myOperator	:= self.myOperator;
	pxyHdr.myTerminal	:= self.myTerminal;
	pxyHdr.myVoyage		:= self.myVoyage;
	
	// Now attach proxy order lines
	foreach realLine in self.allStockOrderLines do
		pxyLine := realLine.pxyCreateUpdateProxy;
		pxyHdr.allStockOrderLines.add(pxyLine);
	endforeach;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyHdr;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyHdr;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="aec8dbed-5ec2-4b59-9fec-b013d3c0ab10">
        <updating/>
        <source>setForCreate(_pxyHdr: CM_StockOrderHeader) updating;
// ---------------------------------------------------------------------------
// Created:     26 June 2002 by cnwsb1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	pxyLine 	: CM_StockOrderLine;
	realLine	: CM_StockOrderLine;
	disPort		: CM_Port;

begin
	_pxyHdr.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);
	
	// This lock will be released at the abort / commit of the transaction
	exclusiveLock(self.allStockOrderLines);

	self.type					:= _pxyHdr.type;
	self.dischargePort			:= _pxyHdr.dischargePort;	
	self.orderDate				:= _pxyHdr.orderDate;
	self.orderNo				:= _pxyHdr.orderNo;
	self.deadlineDT				:= _pxyHdr.deadlineDT;
	self.processOption			:= _pxyHdr.processOption;
	self.transportMode			:= _pxyHdr.transportMode;
	
	// set the references with inverses that will add to the appropriate collections
	self.myOperator				:= _pxyHdr.myOperator;
	self.myTerminal				:= _pxyHdr.myTerminal;
	self.myVoyage				:= _pxyHdr.myVoyage;
	
	self.isAudit				:= _pxyHdr.isAudit;
	self.isTransfer				:= _pxyHdr.isTransfer;
	
	// Create the order detail lines
	// Set same position in real array as in proxy array
	foreach pxyLine in _pxyHdr.allStockOrderLines do
		create realLine as pxyLine.class persistent;
		realLine.setForCreate(pxyLine);
		self.allStockOrderLines.add(realLine);
		realLine.setMyStockOrderSummary();
		//disPort	:= app.myRoot.allPorts[realLine.dischargePort];
		disPort	:= app.myRoot.allPorts[realLine.dischargePort];
		
		if self.myVoyage &lt;&gt; null and 
			disPort &lt;&gt; null then 
			self.myVoyage.addPortToAllPorts(disPort);
		endif;
	endforeach;

	self.fulfilledStatus := OrderStatus_Unfulfilled;
	
	app.myEventManager.createSingleObjInfoNoteEvt(self.myTerminal, Event_StockOrderHdr_Create, self);
end;</source>
        <Parameter name="_pxyHdr" type="CM_StockOrderHeader"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="5e1826cc-6562-4ed2-850d-e0cca3683aa0">
        <updating/>
        <source>setForUpdate(_pxyHdr: CM_StockOrderHeader) updating;
// ---------------------------------------------------------------------------
// Created:     26 June 2002 by cnwsb1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	disPort			: CM_Port;
	pxyLine 		: CM_StockOrderLine;
	realLine		: CM_StockOrderLine;
	deletedLines	: CM_StockOrderLineSet;
	pxyPos			: Integer;
	realPos			: Integer;
	bolOut			: CM_BOLOut;
	opChanged : Boolean;
begin
	_pxyHdr.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);
	
	// This lock will be released at the abort / commit of the transaction
	exclusiveLock(self.allStockOrderLines);
	
	self.orderDate				:= _pxyHdr.orderDate;
	self.orderNo				:= _pxyHdr.orderNo;
	self.deadlineDT				:= _pxyHdr.deadlineDT;
	self.processOption			:= _pxyHdr.processOption;
	self.transportMode			:= _pxyHdr.transportMode;
	self.dischargePort			:= _pxyHdr.dischargePort;
	
	// set the references with inverses that will add to the appropriate collections
	
	self.myOperator				:= _pxyHdr.myOperator;
	self.myTerminal				:= _pxyHdr.myTerminal;
	self.myVoyage				:= _pxyHdr.myVoyage;
	
	self.isAudit				:= _pxyHdr.isAudit;
	self.isTransfer				:= _pxyHdr.isTransfer;
	// Create/Delete/Update the order detail lines
	// Set same position in real array as in proxy array
	
	// Delete lines that do not have a proxy
	create deletedLines transient;
	foreach realLine in self.allStockOrderLines do		: loop
		foreach pxyLine in _pxyHdr.allStockOrderLines do
			if pxyLine.pxyGetRealObject = realLine then
				continue loop;
			endif;
		endforeach;
		deletedLines.add(realLine);
	endforeach;
	deletedLines.purge();

	// Create/Update remaining lines as appropriate
	foreach pxyLine in _pxyHdr.allStockOrderLines do
		realLine := pxyLine.pxyGetRealObject;
		
		if realLine = null then
			// Create new line
			create realLine as pxyLine.class persistent;
			realLine.setForCreate(pxyLine);
			// Will be added to self.allStockOrderLines further down
		else
			// Update existing line
			realLine.setForUpdate(pxyLine);
			
		endif;

		// Set same position in real array as in proxy array
		pxyPos := pxyPos + 1;
		realPos := self.allStockOrderLines.indexOf(realLine);
		if realPos = 0 then
			self.allStockOrderLines.atPut(pxyPos, realLine);
		elseif realPos &lt;&gt; pxyPos then
			self.allStockOrderLines.remove(realLine);
			self.allStockOrderLines.atPut(pxyPos, realLine);
		endif;
		realLine.setMyStockOrderSummary();
		//disPort	:= app.myRoot.allPorts[realLine.dischargePort];
		disPort	:= app.myRoot.allPorts[realLine.dischargePort];
		if disPort &lt;&gt; null then
			if self.myVoyage &lt;&gt; null then
				self.myVoyage.addPortToAllPorts(disPort);
			endif;		
		endif;
	endforeach;
	
	foreach bolOut in self.allBOLOuts do
		self.doMatch(bolOut, app.myPassport);
	endforeach;
	
	app.myEventManager.createSingleObjInfoNoteEvt(self.myTerminal, Event_StockOrderHdr_Update, self);
	
epilog
	delete deletedLines;
end;</source>
        <Parameter name="_pxyHdr" type="CM_StockOrderHeader"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_LogStockOrderLine" id="cf26ddd3-8b74-4a16-8975-d30dc3f2a6dd">
