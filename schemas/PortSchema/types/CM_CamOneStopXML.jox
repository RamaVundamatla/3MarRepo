    <JadeMethod name="makeStopSectXML" id="33e24385-4bc4-4717-bf2a-28523dc1e24d">
        <source>makeStopSectXML( _ti : CM_TrackedItem; _parentElem : JadeXMLElement input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2016	cnwndl1	Initial creation	TFS 2561 / 2277

*/

vars

	rootElem : JadeXMLElement;
	xmlElem : JadeXMLElement;
	allStops : CM_StopsByIdDict;
	stop : CM_Stops;
	workStr : String;
	
begin

	if _ti = null then
		return;
	endif;
	
	create allStops transient;
	_ti.getAllActiveStops( allStops );
	foreach stop in allStops do

		rootElem := _parentElem.addElement('Stop');
		
		workStr := "C";
		if stop.myStopsTable.requiresInfoType = 0 then
		elseif stop.myStopsTable.requiresInfoType = 1 then	//Customs Export
			workStr := "A";
		elseif stop.myStopsTable.requiresInfoType = 2 then	//Customs Import
			workStr := "A";
		elseif stop.myStopsTable.requiresInfoType = 3 then	//Operator Export
		elseif stop.myStopsTable.requiresInfoType = 4 then	//Operator Import
		elseif stop.myStopsTable.requiresInfoType = 5 then	//Delivery Release
		elseif stop.myStopsTable.requiresInfoType = 6 then	//CustomsReference
			workStr := "A";
		elseif stop.myStopsTable.requiresInfoType = 7 then	//SOLAS VGM
		endif;
		xmlElem := rootElem.addElement('Type');
		xmlElem.setText( workStr );
		
		xmlElem := rootElem.addElement('TypeDescription');
		xmlElem.setText( stop.myStopsTable.heading );
	
	endforeach;
	
epilog

	delete allStops;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_parentElem" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
