    <JadeMethod name="action" id="375afa2c-eda1-4c29-89dc-27fa1f87effd">
        <updating/>
        <source>action(): Boolean updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 29 September 2022
TFS#		: 54892
Function	:

*** Changes ***
Date			Name		TFS#		Description
08/09/2023		jlika1		60370		POB - QShips Voyage Data EDI Status Stuck at Verifying or DB Load Failed
****************************************************/

vars
	errCode	: Integer;
	errTxt	: String;
	msg 	: String;
begin
	msg := ' start';

	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;app.cnGetServerTime.formatAsYYYYMMDDHHMMSSMMM&amp;msg, LogTRACE);	//25 Nov 2019	NDL	TFS 47053
	
	on Exception do app.alertExceptionHandler(exception, null, self.getErrorDesc(), errCode, errTxt, true, true);
	on LockException do app.alertLockExceptionHandler(exception);
	
	if self.myTerminal &lt;&gt; null then
		app.myPassport.setMyTerminal(self.myTerminal);     
	endif;
	
	self.setUser();
	self.processQshipsRequest();

epilog	
	if errCode &lt;&gt; null then
		app.myTrxUA.trxUpdateBGPRequest(self, true, errCode, errTxt, app.myPassport);
	endif;
	inheritMethod();
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createAlert" id="a6c577b7-ccb1-4c17-9949-212e6d9d26be">
        <source>createAlert(_alertMsg: String; _severity: Integer);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 21 March 2023
TFS#		: 57111
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	alert: CM_SystemAlert;
	msg : String;
begin
	app.writeLog(_alertMsg, LogERROR);
	
	create alert transient;
	alert.details := _alertMsg;
	alert.setSeverity(_severity);
	alert.addLogEntry(_alertMsg);
	alert.add;
	app.commitAlert();
end;</source>
        <Parameter name="_alertMsg" type="String"/>
        <Parameter name="_severity" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="c26fa596-5d6c-40a6-9bb6-1098ab277655">
        <source>getDisplay(): String;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 29 September 2022
TFS#		: 54892
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	str, detail	: String;
begin
	str 	:= inheritMethod();
	detail 	:= 'Qships Voyage Movement Query ' &amp; self.myTerminal.code;
	
	return str &amp; Tab &amp; detail;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
