    <JadeMethod name="createMonitor" id="5c1dcb46-a74e-4a1b-b3bc-4d4e2027d3a7">
        <updating/>
        <source>createMonitor() updating;
// ---------------------------------------------------------------------------
// Created:		14 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

	cmifMonitor		: CMIF_Monitor;
	tmpHeight, idx : Integer;
	tmpOptionsUsed : IntegerArray;
	now : TimeStamp;
begin

	cmifMonitor := app.myPassport.myCMIFMonitor;
	if cmifMonitor = null then
		create cmifMonitor transient;
		cmifMonitor.myParent := self;
		app.myPassport.setMyCMIFMonitor(cmifMonitor);
	endif;

	self.modalDialogReturnValue := self.ModalDialogReturn_Null;	
	self.modalDialogShow(null, app.getErrorString(Cancel), null, null, app.getErrorString(Terminal_area_utilisatio), app.getErrorString(PleaseWait) );
	self.pbProgressBar.visible := true;


end;</source>
    </JadeMethod>
