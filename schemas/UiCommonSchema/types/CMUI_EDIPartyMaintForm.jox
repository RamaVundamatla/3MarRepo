    <JadeMethod name="userNotify" id="2242746d-471a-483b-8479-4a87f22e9a5c">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(_event: Integer; _party :CM_EDIParty; _tag: Integer; userInfo: Any) updating;
/*
Date		Who		Reason
23 November 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars

begin
	self.doUserNotify (_event, _party, _tag);
epilog

end;</source>
        <Parameter name="_event" type="Integer"/>
        <Parameter name="_party" type="CM_EDIParty"/>
        <Parameter name="_tag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="xHandlerFileOpen" id="aa5e4114-65e2-4c46-9117-632b5d021c46">
        <source>xHandlerFileOpen(_exceptionObj:Exception; _errorMsg:String output):Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 October 2024	navsp1	Initial creation MTN-33228

*/
begin
	_errorMsg	:=	process.getErrorText(_exceptionObj.errorCode);
	
	return Ex_Resume_Next;
end;</source>
        <access>protected</access>
        <Parameter name="_exceptionObj" type="Exception"/>
        <Parameter name="_errorMsg" type="String" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</GUIClass>
