    <JadeMethod name="aSPAfinancialInstance" id="f63b19da-b07c-402b-8e85-b84d7c2008c3">
        <source>aSPAfinancialInstance();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 July 2019	jlgma1	Initial creation

*/

vars
	aFIO : CM_ASPAInterface ;
begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	
	aFIO := CM_ASPAInterface .firstInstance().CM_ASPAInterface ;
	
	if aFIO = null then
		app.writeLog( method.qualifiedName &amp; " Create single instance of ASPA Interface class for 8.6.1", LogINFO);
		aFIO := app.myTrxCA.trxCreateExternalFinanceClass(CM_ASPAInterface ).CM_ASPAInterface ;
	endif;
	 
	self.addScriptRun(method.name);
	 

epilog

end;</source>
