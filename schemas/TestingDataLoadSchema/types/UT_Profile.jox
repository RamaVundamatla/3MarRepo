    <JadeMethod name="getSetting" id="3ce02fca-f6d9-45b4-bff0-a26cea3c34dd">
        <source>getSetting(_key: String): CM_Association;
//23 October 2008	cnwdw1	
//
vars

begin
	return settings[_key.toUpper()];
end;</source>
        <Parameter name="_key" type="String"/>
        <ReturnType type="CM_Association"/>
    </JadeMethod>
    <JadeMethod name="getSettingsDisplay" id="bb9723b4-54f3-41d8-a221-fcd5670a6173">
        <source>getSettingsDisplay() : String;

/*

Purpose:			Return a display string of all the settings on the receiver

Parameters:			None

Return Value:		String containing all settings and their keys


Date		Who		Reason
23 Sep 2009	cnwkpd1	Initial creation

*/

vars
	key,
	returnStr		: String;
	iter			: Iterator;
	assoc			: CM_Association;
	
begin
	iter := self.settings.createIterator();
	while iter.next(assoc) do
		iter.getCurrentKeys(key);
		returnStr := returnStr &amp; key &amp; "=" &amp; assoc.getValue.String &amp; CrLf;
	endwhile;

	return returnStr;
	
	
epilog
	delete iter;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initialize" id="e46e4005-6659-454d-b331-95c83a5f6b30">
        <source>initialize();
//23 October 2008	cnwdw1	
//
vars
	directory	: String; //cnwmc5 - 3/12/2012
begin
	self.settings.addAssociation(UT_Profile.P_CARGO_TYPE, "MDF");
	self.settings.addAssociation(UT_Profile.P_OPERATOR, "UTOP");
	self.settings.addAssociation(UT_Profile.P_CARRIER, "DOUG");
	self.settings.addAssociation(UT_Profile.P_SHIPPING_LINE, "DOUG");
	self.settings.addAssociation(UT_Profile.P_WAREHOUSE, "UTWH1");
	self.settings.addAssociation(UT_Profile.P_TERMINAL, "MH1");
	self.settings.addAssociation(UT_Profile.P_USER, "SUPERUSER");
	self.settings.addAssociation(UT_Profile.P_TRADE, "Unit Test Trade");
	self.settings.addAssociation(UT_Profile.P_DGATE, "Dual Gate");
	self.settings.addAssociation(UT_Profile.P_DGATE_PIN, "P_IN");
	self.settings.addAssociation(UT_Profile.P_DGATE_POUT, "P_OUT");
	self.settings.addAssociation(UT_Profile.P_SGATE, "Single Gate");
	self.settings.addAssociation(UT_Profile.P_BLOCKSTACK, "UT_BS1");
	self.settings.addAssociation(UT_Profile.P_YA, "UT_YA");
	self.settings.addAssociation(UT_Profile.P_INITIAL, "UT");
	self.settings.addAssociation(UT_Profile.P_CRANE, "CRN1");
	self.settings.addAssociation(UT_Profile.P_EMAILADDRESS, "Bitbucket");
	self.settings.addAssociation(UT_Profile.P_YIC, "UTYIC");
	//self.settings.addAssociation(UT_Profile.P_CAMS_DIRECTORY, "d:\cnwdmast\server\c_misc\cams\UT");
	
	//cnwmc5 - 3/12/2012 - added for local running of CAMS tests
	directory := "%MISCDIR%\cams\UT";
	directory := directory.substituteDirectory();

	if app.computerName = "CNWCHCS11" then
		self.settings.addAssociation(UT_Profile.P_CAMS_DIRECTORY, directory);
	else
		self.settings.addAssociation(UT_Profile.P_CAMS_DIRECTORY, "c" &amp; directory[2:end]);
	endif;
end;</source>
    </JadeMethod>
