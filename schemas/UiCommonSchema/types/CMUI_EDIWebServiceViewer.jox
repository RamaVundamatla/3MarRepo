    <JadeMethod name="toolbarShowCaptions" id="988d1180-fe1d-4aa1-b883-d78345b4f4d4">
        <updating/>
        <source>toolbarShowCaptions(_showCaptions: Boolean) updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 04 October 2019
TFS#		: 45332
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	currentHeight 	: Real;
	newHeight 		: Real;
	heightDiff 		: Real;
begin
	currentHeight := self.frmToolbar.height;
	inheritMethod(_showCaptions);
	newHeight := self.frmToolbar.height;
	heightDiff := newHeight - currentHeight;
end;</source>
        <Parameter name="_showCaptions" type="Boolean"/>
