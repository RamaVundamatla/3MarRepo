    <JadeMethod name="assignValueSpecial" id="4f03fd82-32c3-499a-a576-5d1a41cddde6">
        <updating/>
        <source>assignValueSpecial(_propName: String; _processedValue: String; _xlationOperator: CM_Operator): Boolean updating;

vars

begin
	if _propName = ETRow_ArriveTime or
	   _propName = ETRow_ArriveTime then
		self.setPropertyValue(_propName, _processedValue.TimeStamp);
	else
		return inheritMethod(_propName, _processedValue, _xlationOperator);
	endif;
end;
</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_processedValue" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canBeDeleted" id="58758da3-5d6a-45ce-a310-1f7b2811ce71">
        <source>canBeDeleted(_purgeDate :Date): Boolean;
//----------------------------------------------------------------
//	Created:	03 June 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 10/08/2012	cnwcs5	par 30136 - change of signature/re-worked method
vars
	voyage 		: CM_Voyage;
	terminal	: CM_Terminal;
begin
	if inheritMethod(_purgeDate)then
		return true;
	endif;
	
	terminal := self.getMyTerminal;
	
	if terminal &lt;&gt; null then
		if terminal.getConfig (EDIClearArchivedVoyEDI).Boolean then
			voyage := terminal.allVoyagesArchived[self.voyageCode, self.arriveTime];
		
			if voyage &lt;&gt; null then
				app.writeLog(self.fileVersion &amp; " (" &amp; self.createdTime.String &amp; ") voyage " &amp; self.voyageCode &amp; " is archived.", LogINFO);
				return true;	
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="_purgeDate" type="Date"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
