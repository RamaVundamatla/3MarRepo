    <JadeMethod name="setMyCurrentVoyage" id="d1745939-d2bc-4ba5-a2d2-c27c4238f7f7">
        <updating/>
        <source>setMyCurrentVoyage(_voyage : CM_Voyage) updating;
/*
Purpose:			
Date		Who		Reason
17 February 2017	cnwab1	Initial creation
*/

vars

begin
	if self.myCurrentVoyage &lt;&gt; null then
		self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Update_Event));
	endif;
	
	self.myCurrentVoyage := _voyage;
	
	self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Update_Event), Response_Continuous, null);
	
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="f58275cd-6bcf-4118-b14d-ce8fe47d4d4e">
        <updating/>
        <source>setupForm() updating;
/*
Purpose:			
Date		Who		Reason
17 February 2017	cnwab1	Initial creation
*/

vars

begin
	inheritMethod();

	self.doBuildComboVoyages();
	self.loadCombos();
//	self.loadJobs(); //17 Mar 2017	NDL	TFS 3754 - now inlcuded in loadCombos
	

	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnSave.enabled:= false;
		self.tblData.userInputEnabled := false;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblDataResort" id="7f949516-97b5-4211-b180-cb79fc383a16">
        <source>tblDataResort();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 March 2017	cnwndl1	Initial creation	TFS 3686

*/

vars

	sortColNo	: Integer;
	sortColName	: String;
	
begin

	sortColNo := tblData.column;
	
	if sortColNo &lt;= 0
	or sortColNo &gt; tblData.columns then
		return;
	endif;
	
	if self.tblData.allTblDataColPropertyNames.size &gt;= sortColNo then	
		sortColName := tblData.allTblDataColPropertyNames[sortColNo];
	endif;

	if sortColName = null then
		app.msgBox(app.getErrorString(Not_Able_To_Sort_By_Column), app.getErrorString(Info), MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;

	self.tblData.resortTableByColumn(sortColNo);

end;</source>
    </JadeMethod>
