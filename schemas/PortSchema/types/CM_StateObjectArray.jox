<CollClass name="CM_StateObjectArray" id="50d056f9-3a14-46d8-b2db-daabe1459cd0">
    <memberType name="CM_StateObject"/>
    <superclass name="CM_ObjectArray"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmstate"/>
    <JadeMethod name="hasStateDataRefToObj" id="c4ec5201-5269-4714-a65d-677c47780b8e">
        <source>hasStateDataRefToObj( _obj : Object; _key : String output ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 November 2020	jlgndl1	Initial creation	TFS 50279

*/

vars

	stateObjGroup : CM_StateObject;
	edition : Integer;
	invalid : Boolean;

begin

	on Exception do app.handleDeletedObject( exception, stateObjGroup, invalid );

	foreach stateObjGroup in self discreteLock do
		if stateObjGroup = null then
			continue;
		endif;
		edition := stateObjGroup.edition;
		if invalid then
			invalid := false;
			continue;
		endif;
		if stateObjGroup.hasStateDataRefToObj( _obj, _key ) then
			return true;
		endif;
	endforeach;
	
	return false;

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_key" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
