        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="fd0bf910-05c0-41e2-8378-8208e46fca1c">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
05 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	theXML : String;
	tmpStr : String;
	entRow : EntTableRow;
begin
	theXML:= inheritMethod();

// NOTE if these menus have a caption saying SHOW it means that the item is hidden
	if self.myJobController &lt;&gt; null then
	
		theXML := theXML &amp; 
				global.formatAsXML(XML_JobZoom, self.myJobController.voyageZoom.String)&amp; 
				global.formatAsXML(XML_TimeScale,self.myJobController.timeScale.String);
	endif;
	
	
	// Tool tips stuff.
	
	foreach entRow in self.allToolTipsEntArray do
		tmpStr	:=	tmpStr &amp; global.formatAsXML(self.XMLTag_ToolTip, entRow.name);
	endforeach;
	
	theXML	:=	theXML &amp;
				global.formatAsXMLPrefix(self.XMLTag_AllToolTips &amp; ETDef_ShipJobToolTips) &amp;
				tmpStr &amp;
				global.formatAsXMLSuffix(self.XMLTag_AllToolTips &amp; ETDef_ShipJobToolTips);
	
	return theXML;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="aa83bd0d-b6ff-4c5a-b812-063b87e17273">
        <updating/>
        <source>getXMLSettingsForSetup() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
05 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	userWindow		: CM_UserWindow;
	theXML,
	theXMLValue			: String;
	xmlDef			: String;
	tmpEntRowName	: String;
	entRow 			: EntTableRow;
	rowArray		: EntTableRowArray;
	entTableDef 	: EntTableDef;
	pos				: Integer;
begin
	userWindow := app.getUserWindow(self.name, false);

	if userWindow &lt;&gt; null then
		theXML := userWindow.xmlInfo;
	else
		self.setTimeScale(1);
		self.setVoyageZoom(1);	
		return;
	endif;
	
	
	theXMLValue := theXML.cnEcGetTagValueOfName(XML_JobZoom);
 	if theXMLValue &lt;&gt; null then
		self.setVoyageZoom(theXMLValue.Real);
	else
		self.setVoyageZoom(1);	
	endif;
	
	theXMLValue := theXML.cnEcGetTagValueOfName(XML_TimeScale);
 	if theXMLValue &lt;&gt; null then
		self.setTimeScale(theXMLValue.Real);
	else
		self.setTimeScale(1);
	endif;
	
	// ent rows used to decide what tool tips to show in bubble help.
	pos		:=	1;
	xmlDef	:=	theXML.cnEcGetNextTagValueOfName(XMLTag_AllToolTips &amp; ETDef_ShipJobToolTips, pos);
	
	if xmlDef = null then
		// no xml for def, no tool tips set up so default will be displayed.
		return;
	endif;

	entTableDef	:=	app.myController.getEntTableDef(ETDef_ShipJobToolTips);
	rowArray	:=	entTableDef.allEntTableRows;
	
	pos	:=	1;
	
	while (pos &gt; 0) do
		tmpEntRowName	:=	xmlDef.cnEcGetNextTagValueOfName(XMLTag_ToolTip, pos);
		
		if tmpEntRowName &lt;&gt; null then
			foreach entRow in rowArray do
				if entRow.name = tmpEntRowName then
					// populate collection to be used when creating bubble help for
					self.allToolTipsEntArray.add(entRow);
					break;
				endif;
			endforeach;
		endif;
	endwhile;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="keyDown" id="2fbd9c24-8052-4474-962f-20d907f2bfc4">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
/*
----------   ----------  --------------------------------------------------
Created:	12 April 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin

	if keyCode = CMUI_Key_F3 then
		self.showHideSearch(); //par13835 Mohammad 12/4/2007
	else
		inheritMethod(keyCode, shift);
	endif;

end;
</source>
