    <JadeMethod name="valROROVesselDeck" id="1aa9b6cf-8c01-4125-895e-191063fb7eb9">
        <source>valROROVesselDeck(_vesselStructure  : CM_ROROVesselStructure; 
			_proxyDeck : CM_DeckVessel input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 April 2011	cnwer1	Initial creation

*/

vars

begin
	self.raiseExceptionIfNull(_proxyDeck, " Proxy is Null" );
	self.raiseExceptionIfNull(_vesselStructure, " RORO Vessel Structure is Null" );
	
	if _vesselStructure.allDecksByCode[_proxyDeck.code] &lt;&gt; null then
		app.raiseCMException1(Duplicate_code_must_unique,"Vessel Deck",null,null);
	endif;
	
	//cnwmc5 - PAR 30103 - 10 July 2013
	_proxyDeck.validateForXMLImport();
epilog

end;</source>
        <Parameter name="_vesselStructure" type="CM_ROROVesselStructure"/>
        <Parameter name="_proxyDeck" type="CM_DeckVessel" usage="input"/>
