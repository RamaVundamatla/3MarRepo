<Class name="WS_SourceSubLocation" id="91579457-7bd1-4602-afe9-5b9aa79ae079">
    <superclass name="WS_Code"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Log Source Sub location codes, system definable values</text>
    <DbClassMap file="webservice"/>
    <ImplicitInverseRef name="allSourceSubSubLocations" id="50871dbe-018b-4986-a9f8-2626012eee6f">
        <memberTypeInverse/>
        <type name="WS_SourceSubSubLocationArray"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="isFSC" id="07374f50-ee50-4c6a-ab30-656a9a9703bc">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="delete" id="3abe4b1c-6dc2-4430-b9da-3f133b0d6dbf">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 December 2014	cnwmc5	Initial creation

*/

vars

begin
	if self.allSourceSubSubLocations &lt;&gt; null and not self.allSourceSubSubLocations.isEmpty() then
		self.allSourceSubSubLocations.purge();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="4cda9b54-5493-4b7c-bedd-bf4e410d31d3">
        <updating/>
        <source>setProxyFromObject(_object: CM_SourceSubLocation) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 December 2014	cnwmc5	Initial creation

*/

vars
	wsSourceSubSubLocation 	: WS_SourceSubSubLocation;
	sourceSubSubLocation	: CM_SourceSubSubLocation;
	code					: CM_Code;
	
begin
	inheritMethod(_object);
	
	foreach code in _object.allSubSubLocations do
		if not code.isKindOf(CM_SourceSubSubLocation) then
			continue;
		endif;
		
		sourceSubSubLocation := code.CM_SourceSubSubLocation;
		
		create wsSourceSubSubLocation transient;
		wsSourceSubSubLocation.setProxyFromObject(sourceSubSubLocation);
		self.allSourceSubSubLocations.add(wsSourceSubSubLocation);
	endforeach;
	
	self.isFSC := _object.isFSC;
	
epilog

end;</source>
        <Parameter name="_object" type="CM_SourceSubLocation"/>
    </JadeMethod>
</Class>
