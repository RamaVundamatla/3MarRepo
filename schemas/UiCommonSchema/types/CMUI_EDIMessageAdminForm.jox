    </JadeMethod>
    <JadeMethod name="getSelectedEDIData" id="442fcb1b-54dc-4927-ae4b-db7562656d53">
        <source>getSelectedEDIData():CM_EDIData protected;
// ---------------------------------------------------------------------------
// Created:     22 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Currently selected EDI Data (one only)
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	obj		:Object;
	invalid	:Boolean;
begin
	if self.tblData.row &gt; self.tblData.fixedRows then
		obj := self.tblData.accessRow(self.tblData.row).itemObject;
	endif;
	
	on Exception do app.handleDeletedObject (exception, obj, invalid);
	
	if obj &lt;&gt; null and obj.edition &gt;= 0 then	// force exception for invalid object
		return obj.CM_EDIData;
	endif;
	// we will resume here is obj is invalid
	return null;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="CM_EDIData"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="883550ec-a3f0-4f63-99c6-be93c5ba7e1b">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*

Date		Who		Reason
15 October 2015	cnwer1	Initial creation PAR
17 October 2022 navsj20	ChangeRequest 55084: EUP - EDI Administration Usability Requirements
03 Oct 2023	jlika1	TFS 60232 - EUP | FR 54871 - EDI Management for New EDI Types
*/

vars
	fileTypeAttr,
	attrNames : StringArray;
	xmlStr	: String;
	voyage	: CM_Voyage;
begin
	create attrNames transient;
	attrNames.add(CM_Association::integerValue.name);
	create fileTypeAttr transient;
	
	fileTypeAttr.add(CM_EDIFileType::name.name);
	
	xmlStr := inheritMethod() &amp; 
	  global.formatAsXML(self.XMLTag_ExcludeDeparted, self.chkExcludeDepart.value.String);
	  
	  
	if self.mulQDataType.myAvailableListBox.listCount &lt;&gt; 0 then	  
		xmlStr := xmlStr &amp; self.mulQDataType.getXMLStringForSelected(attrNames);
	endif;
	if self.mulQFileType.myAvailableListBox.listCount &lt;&gt; 0 then	  
		xmlStr := xmlStr &amp; self.mulQFileType.getXMLStringForSelected(fileTypeAttr) ;
	endif;
	
	if self.mulQStatus.myAvailableListBox.listCount &lt;&gt; 0 then	  
		xmlStr := xmlStr &amp;   self.mulQStatus.getXMLStringForSelected(attrNames);
	endif;
	
	//START 17.10.2022	navsj20	TFS 55084
	xmlStr := xmlStr &amp; global.formatAsXML(self.XMLTag_CargoGroupId, self.txtCargoGroupId.text);
	xmlStr := xmlStr &amp; global.formatAsXML(self.XMLTag_CargoOperator, self.cmbCargoOperator.text);
	xmlStr := xmlStr &amp; global.formatAsXML(self.XMLTag_CargoExpDateTime, self.txtCargoExpDate.text);
	xmlStr := xmlStr &amp; global.formatAsXML(self.XMLTag_EDIAction, self.txtEDIAction.text);
	xmlStr := xmlStr &amp; global.formatAsXML(self.XMLTag_MessageId, self.txtMessageId.text);
	xmlStr := xmlStr &amp; global.formatAsXML(self.XMLTag_MessageNumber, self.txtMessageNumber.text);
	xmlStr := xmlStr &amp; global.formatAsXML(self.XMLTag_ReceiptTransMode, self.cmbReceiptTransMode.text);
	xmlStr := xmlStr &amp; global.formatAsXML(self.XMLTag_VBSExtReference, self.txtVbsExtReference.text);
	xmlStr := xmlStr &amp; global.formatAsXML(self.XMLTag_VesselName, self.cmbVesselName.text);
	xmlStr := xmlStr &amp; global.formatAsXML(self.XMLTag_VoyageETA, self.txtVoyageETA.text);
	//END 17.10.2022  navsj20  TFS 55084
	
	//jlika1 TFS 60232 --&gt;
	xmlStr := xmlStr &amp; global.formatAsXML(self.XMLTag_MessageType, self.txtFiltMessType.text);
	xmlStr := xmlStr &amp; global.formatAsXML(self.XMLTag_Sender, self.txtSender.text);	
	if self.cmbVoyageCode.listObject &lt;&gt; null then
		voyage := self.cmbVoyageCode.listObject.CM_Voyage;
		xmlStr := xmlStr &amp; global.formatAsXML(self.XMLTag_VoyageCode, voyage.code);
	endif;	
	xmlStr := xmlStr &amp; global.formatAsXML(self.XMLTag_Vehicle, self.txtVehicle.text);
	//jlika1 TFS 60232 &lt;--
	
	return xmlStr;

epilog
	delete attrNames;
	delete fileTypeAttr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="5fae0e77-ea9d-4a2d-9bcd-e6347bdeb095">
        <source>getXMLSettingsForSetup();
/*

Date		Who		Reason
15 October 2015	cnwer1	Initial creation PAR
17 Oct 2022 navsj20	ChangeRequest 55084: EUP - EDI Administration Usability Requirements
03 Oct 2023	jlika1	TFS 60232 - EUP | FR 54871 - EDI Management for New EDI Types
*/

vars
	userWindow		: CM_UserWindow;
	theXML, 
	theXMLValue 	: String;
	lastPos 		: Integer;
	keyValue 		: String;
	selected 		: ObjectSet;
	assoc 			: CM_Association;
	assocDict 		: DynaDictionary;
	allEDIFileTypes : CM_EDIFileTypeByNameDict;
	ediFileType 	: CM_EDIFileType;
begin
	userWindow := self.myUserWindow;
	if userWindow = null then
		userWindow := app.getUserWindow(self.name, false);
		if userWindow = null then
			return;
		endif;
	endif;

	theXML := userWindow.xmlInfo;
	theXMLValue := theXML.cnEcGetTagValueOfName(self.XMLTag_ExcludeDeparted);
 	if theXMLValue.Boolean then
		self.chkExcludeDepart.value:=true;
	endif;
	
	create assocDict transient;
	assocDict.setMembership(CM_Association);
	assocDict.addMemberKey(CM_Association::integerValue.name,false,false);
	assocDict.endKeys(false);
	
	create selected transient;
	
	theXMLValue := theXML.cnEcGetTagValueOfName((CMUI_MultiSelectGroupBox.XMLTag_ListTable &amp; self.mulQStatus.name));
	if theXMLValue &lt;&gt; null then
 		theXMLValue := theXMLValue.trimCharacters(CrLf);
		assocDict.clear;
		selected.clear;
		self.allDummyEDIStatusObjects.copy(assocDict);
		lastPos := 1;
		while true do
			keyValue := theXMLValue.cnEcGetNextTagValueOfName(CMUI_MultiSelectGroupBox.XMLTag_SelectedValue, lastPos);
			
			if keyValue = null then
				break;
			endif;
					
			
			assoc:=assocDict.getAtKey(keyValue.Integer).CM_Association;
			if assoc &lt;&gt; null then
				selected.add(assoc);
			endif;
			
			if lastPos = 0 then
				break;
			endif;
		endwhile;
		
		self.mulQStatus.setSelected(selected);
	endif;
	
	theXMLValue := theXML.cnEcGetTagValueOfName((CMUI_MultiSelectGroupBox.XMLTag_ListTable &amp; self.mulQDataType.name));
	if theXMLValue &lt;&gt; null then
 		theXMLValue := theXMLValue.trimCharacters(CrLf);
		selected.clear;
		assocDict.clear;
		self.allDummyEDIDataTypeObjects.copy(assocDict);
		lastPos := 1;
		while true do
			keyValue := theXMLValue.cnEcGetNextTagValueOfName(CMUI_MultiSelectGroupBox.XMLTag_SelectedValue, lastPos);
			
			if keyValue = null then
				break;
			endif;
			
			
			assoc:=assocDict.getAtKey(keyValue.Integer).CM_Association;
			if assoc &lt;&gt; null then
				selected.add(assoc);
			endif;
			
			if lastPos = 0 then
				break;
			endif;	
		endwhile;
		
		self.mulQDataType.setSelected(selected);
	endif;
	
	theXMLValue := theXML.cnEcGetTagValueOfName((CMUI_MultiSelectGroupBox.XMLTag_ListTable &amp; self.mulQFileType.name));
	if theXMLValue &lt;&gt; null then
 		theXMLValue := theXMLValue.trimCharacters(CrLf);
		create allEDIFileTypes transient;
		app.myRoot.allEDIFileTypes.copy(allEDIFileTypes);
		selected.clear;
		lastPos := 1;
		while true do
			keyValue := theXMLValue.cnEcGetNextTagValueOfName(CMUI_MultiSelectGroupBox.XMLTag_SelectedValue, lastPos);		
			if keyValue = null then
				break;
			endif;		
			
			ediFileType:=allEDIFileTypes[keyValue ];
			if ediFileType &lt;&gt; null and not selected.includes(ediFileType) then
				selected.add(ediFileType);
			endif;
			
			if lastPos = 0 then
				break;
			endif;	
		endwhile;
		
		self.mulQFileType.setSelected(selected);
	endif;
	//START 17.10.2022	navsj20	TFS 55084
	theXMLValue := theXML.cnEcGetTagValueOfName(self.XMLTag_CargoGroupId);
	if theXMLValue &lt;&gt; null then
		self.txtCargoGroupId.text := theXMLValue;
	endif;
	theXMLValue := theXML.cnEcGetTagValueOfName(self.XMLTag_CargoOperator);
	if theXMLValue &lt;&gt; null then
		self.cmbCargoOperator.listIndex := self.cmbCargoOperator.findStringExact(1, theXMLValue);
	endif;
	theXMLValue := theXML.cnEcGetTagValueOfName(self.XMLTag_CargoExpDateTime);
	if theXMLValue &lt;&gt; null then
		self.txtCargoExpDate.text := theXMLValue;
	endif;
	theXMLValue := theXML.cnEcGetTagValueOfName(self.XMLTag_EDIAction);
	if theXMLValue &lt;&gt; null then
		self.txtEDIAction.text := theXMLValue;
	endif;
	theXMLValue := theXML.cnEcGetTagValueOfName(self.XMLTag_MessageId);
	if theXMLValue &lt;&gt; null then
		self.txtMessageId.text := theXMLValue;
	endif;
	theXMLValue := theXML.cnEcGetTagValueOfName(self.XMLTag_MessageNumber);
	if theXMLValue &lt;&gt; null then
		self.txtMessageNumber.text := theXMLValue;
	endif;
	theXMLValue := theXML.cnEcGetTagValueOfName(self.XMLTag_ReceiptTransMode);
	if theXMLValue &lt;&gt; null then
		self.cmbReceiptTransMode.listIndex := self.cmbReceiptTransMode.findStringExact(1, theXMLValue);
	endif;
	theXMLValue := theXML.cnEcGetTagValueOfName(self.XMLTag_VesselName);
	if theXMLValue &lt;&gt; null then
		self.cmbVesselName.listIndex := self.cmbVesselName.findStringExact(1, theXMLValue);
	endif;
	theXMLValue := theXML.cnEcGetTagValueOfName(self.XMLTag_VBSExtReference);
	if theXMLValue &lt;&gt; null then
		self.txtVbsExtReference.text := theXMLValue;
	endif;
	theXMLValue := theXML.cnEcGetTagValueOfName(self.XMLTag_VoyageETA);
	if theXMLValue &lt;&gt; null then
		self.txtVoyageETA.text := theXMLValue;
	endif;
	//END 17.10.2022  navsj20  TFS 55084
	
	//jlika1 TFS 60232 --&gt;
	theXMLValue := theXML.cnEcGetTagValueOfName(self.XMLTag_MessageType);
	if theXMLValue &lt;&gt; null then
		self.txtFiltMessType.text := theXMLValue;
	endif;
	
	theXMLValue := theXML.cnEcGetTagValueOfName(self.XMLTag_Sender);
	if theXMLValue &lt;&gt; null then
		self.txtSender.text := theXMLValue;
	endif;
	
	theXMLValue := theXML.cnEcGetTagValueOfName(self.XMLTag_VoyageCode);
	if theXMLValue &lt;&gt; null then
		self.cmbVoyageCode.listIndex := self.cmbVoyageCode.findStringExact(1, theXMLValue);
	endif;
	
	theXMLValue := theXML.cnEcGetTagValueOfName(self.XMLTag_Vehicle);
	if theXMLValue &lt;&gt; null then
		self.txtVehicle.text := theXMLValue;
	endif;
	//jlika1 TFS 60232 &lt;--
epilog
	delete selected;
	delete assocDict;
	delete allEDIFileTypes;
end;</source>
    </JadeMethod>
    <JadeMethod name="handle14051Error" id="2621ee83-4641-43af-8b6c-de459e9bbfe4">
        <updating/>
        <source>handle14051Error(_exObj: Exception; _table : CM_BaseTable; _exOccurred : Boolean output ): Integer updating;
//
//10 Nov 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar - dont add CrLf when doing writline
//
vars

begin
	if _exObj.errorCode = 14051 then
		_exOccurred := true;
		abortTransaction;
		abortTransientTransaction;
		if _exObj.resumable then
			return Ex_Resume_Next;
		else
			return Ex_Abort_Action;
		endif;
	endif;
	return Ex_Pass_Back;
end;</source>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_table" type="CM_BaseTable"/>
        <Parameter name="_exOccurred" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="includeObject" id="098218cf-4b82-4bdc-bab7-4aba89f98dcf">
        <source>includeObject(_ediData :CM_EDIData):Boolean protected;
// ---------------------------------------------------------------------------
// Created:     29 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	// data type does not get checked in doIncludeObject which is optimised for 
	// searching using collections with datatype as the primary key
	if not self.allFilterEDIDataTypes.includes (_ediData.ediDataType) then
		return false;
	endif;
	
	return self.doIncludeObject (_ediData, self.myFilterVoyage, self.allFilterStatuses, self.allFilterEDIFileTypes,
							self.filterStartDate, self.filterEndDate);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initEDIAgents" id="ce06a6c3-407a-45a0-8c72-e7c5629bd985">
        <updating/>
        <source>initEDIAgents() updating, protected;
// ---------------------------------------------------------------------------
// Created:     22 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.myEDIControllerAgent = null then
		create self.myEDIControllerAgent transient;
	endif;
	
	self.myEDIControllerAgent.setTerminal(self.myTerminal);
	
	if self.myEDIAgent = null then
		create self.myEDIAgent transient;
	endif;
	
	self.myEDIAgent.setMyTerminal (self.myTerminal);
	
	self.myEDIConfig := self.myTerminal.myEdiConfig;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initQueryFrame" id="57c0b959-6a26-4f0d-916b-c0e5d6c6f513">
        <updating/>
        <source>initQueryFrame() updating, protected;
// ---------------------------------------------------------------------------
// Created:     20 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
// 3 November 2022 navvt20 ChangeRequest 55084: EUP - EDI Administration Usability Requirements
// 04 Oct 2023	jlika1	TFS 60232 - EUP | FR 54871 - EDI Management for New EDI Types
constants
	GAP = 10;
	SMALLGAP	= 5;
vars
	sht			: CMUI_Sheet;
	control		: CMUI_MultiSelectGroupBox;
begin
		
	self.frmQuery.height	:= 370;
	self.frmQuery.width		:= self.frmQuery.width * 1.5;
//	DATES/ID/VOYAGE
	sht 						:= self.shtQuery1;
	sht.caption 				:= app.getErrorString(XLAT_Criteria);
	self.txtId.width			:= 300;						// cnwrl1 08/06/2010 PAR 24299
	self.txtVoyageCode.width	:= self.txtId.width;		// cnwrl1 04/06/2010 PAR 24299
	sht.visible 				:= true;
	
//	DATA TYPES	
	self.setupEDIDataTypes;
	
	sht 		:= self.shtQuery2;
	sht.caption	:= app.getErrorString(XLAT_Data_Type);
	control		:= self.mulQDataType;
	
	control.formDisplayEntryMethodName := CMUI_EDIMessageAdminForm::displayEntryEDIDataType.name;
	control.setAvailable(self.allDummyEDIDataTypeObjects, true);
	
	control.availableHeading 		:= app.getErrorString (Available);
	control.selectedHeading  		:= app.getErrorString (Selected);
	control.userInputEnabled 		:= true;
	control.multiSelect				:= ListBox.MultiSelect_Extended;
	control.left					:= SMALLGAP;
	control.top						:= SMALLGAP;
	control.width 					:= sht.clientWidth - (SMALLGAP * 2);
	control.height 					:= sht.clientHeight - (SMALLGAP * 2);
	
	control.setSorted(true);

	sht.cnEcResizeContents();
	sht.visible := true;
	
//	FILE TYPES
	sht			:= self.shtQuery3;
	sht.caption	:= app.getErrorString(File_Version);
	control		:= self.mulQFileType;
	
	control.formDisplayEntryMethodName := CMUI_EDIMessageAdminForm::displayEntryEDIFileType.name;
	
	control.setAvailable(app.myRoot.allEDIFileTypes, true);
	
	control.availableHeading 		:= app.getErrorString (Available);
	control.selectedHeading  		:= app.getErrorString (Selected);
	control.userInputEnabled 		:= true;
	control.multiSelect				:= ListBox.MultiSelect_Extended;
	control.left					:= SMALLGAP;
	control.top						:= SMALLGAP;
	control.width 					:= sht.clientWidth - (SMALLGAP * 2);
	control.height 					:= sht.clientHeight - (SMALLGAP * 2);
	
	control.setSorted(true);

	sht.cnEcResizeContents();
	sht.visible := true;
// 	STATUS	
	self.setupEDIStatus;
	
	sht := self.shtQuery4;
	sht.caption := app.getErrorString(Status);
	control	:= self.mulQStatus;
	
	control.formDisplayEntryMethodName := CMUI_EDIMessageAdminForm::displayEntryEDIStatus.name;
	
	control.setAvailable(self.allDummyEDIStatusObjects, true);
	
	control.availableHeading 		:= app.getErrorString (Available);
	control.selectedHeading  		:= app.getErrorString (Selected);
	control.userInputEnabled 		:= true;
	control.multiSelect				:= ListBox.MultiSelect_Extended;
	control.left					:= SMALLGAP;
	control.top						:= SMALLGAP;
	control.width 					:= sht.clientWidth - (SMALLGAP * 2);
	control.height 					:= sht.clientHeight - (SMALLGAP * 2);
	
	control.setSorted(true);
	
	sht.cnEcResizeContents();
	sht.visible := true;
	self.fldQuery.topSheet := self.shtQuery1; // 3 November 2022 navvt20 TFS 55084
	self.doResetSearch;
end;</source>
        <access>protected</access>
    </JadeMethod>
