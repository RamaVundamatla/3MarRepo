    <JadeMethod name="getValue" id="c9c0564e-78bf-42ec-9e95-0bebd511b234">
        <source>getValue() : Any;

/*

Purpose:			Get whatever value is set for the receiver

Parameters:			None

Return Value:		Value as appropriate


Date		Who		Reason
23 Sep 2009	cnwkpd1	Initial creation

*/

vars

begin
	if self.typeString = Boolean.name then
		return self.asBoolean;
	elseif self.typeString = String.name then
		return self.asString;
	elseif self.typeString = Integer.name then
		return self.asInteger;
	elseif self.typeString = Decimal.name then
		return self.asDecimal;
	elseif self.typeString = Real.name then
		return self.asReal;
	elseif self.typeString = Date.name then
		return self.asDate;
	elseif self.typeString = Object.name then
		return self.asObject;
	endif;
	
	
epilog

end;</source>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="set2Values" id="a7c35b1b-9e4f-4bf7-8baa-39deefca489a">
        <updating/>
        <source>set2Values(_value1, _value2: Any) updating;
//
//cnwrs1 CCMS 1137 15 June 2010	
//
vars
	
begin
	self.stringValue := null;
	self.integerValue := 0;
	self.objectValue := null;
	self.booleanValue := null;
	if _value1.isKindOf(String) then
		self.stringValue := _value1.String;
		self.typeString := String.name;
	elseif _value1.isKindOf(Integer) then
		self.integerValue := _value1.Integer;
		self.typeString := Integer.name;
	elseif _value1.isKindOf(Boolean) then
		self.booleanValue := _value1.Boolean;
		self.typeString := Boolean.name;
	elseif _value1.isKindOf(Object) then
		self.objectValue := _value1.Object;
		self.typeString := Object.name;
	endif;
	if _value2.isKindOf(String) then
		self.stringValue := _value2.String;
		self.typeString := String.name;
	elseif _value2.isKindOf(Integer) then
		self.integerValue := _value2.Integer;
		self.typeString := Integer.name;
	elseif _value2.isKindOf(Boolean) then
		self.booleanValue := _value2.Boolean;
		self.typeString := Boolean.name;
	elseif _value2.isKindOf(Object) then
		self.objectValue := _value2.Object;
		self.typeString := Object.name;
	endif;
end;
</source>
        <Parameter name="_value1" type="Any"/>
        <Parameter name="_value2" type="Any"/>
    </JadeMethod>
    <JadeMethod name="setValue" id="73521b11-4804-4e51-8fa2-f486e6747132">
        <updating/>
        <source>setValue(_value: Any) updating;
//23 October 2008	cnwdw1	
//
vars
begin
	self.stringValue := null;
	self.integerValue := 0;
	self.objectValue := null;
	self.booleanValue := null;
	self.decimalValue := 0;
	if _value.isKindOf(String) then
		self.stringValue := _value.String;
		self.typeString := String.name;
	elseif _value.isKindOf(Integer) then
		self.integerValue := _value.Integer;
		self.typeString := Integer.name;
	elseif _value.isKindOf(Boolean) then
		self.booleanValue := _value.Boolean;
		self.typeString := Boolean.name;
	elseif _value.isKindOf(Decimal) then
		self.decimalValue := _value.Decimal;
		self.typeString := Decimal.name;
	elseif _value.isKindOf(Real) then
		self.realValue := _value.Real;
		self.typeString := Real.name;
	elseif _value.isKindOf(Date) then
		self.dateValue := _value.Date;
		self.typeString := Date.name;
	elseif _value.isKindOf(TimeStamp) then
		self.timestampValue := _value.TimeStamp;
		self.typeString := TimeStamp.name;
	elseif _value.isKindOf(Object) then
		self.objectValue := _value.Object;
		self.typeString := Object.name;
	endif;
	
end;</source>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
