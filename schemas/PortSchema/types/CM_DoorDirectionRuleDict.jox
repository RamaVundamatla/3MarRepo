<CollClass name="CM_DoorDirectionRuleDict" id="0a2d52d4-e4a1-497a-a420-93fb58a2189d">
    <duplicatesAllowed/>
    <loadFactor>66</loadFactor>
    <memberType name="CM_DoorDirectionRule"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="radioTelemetry"/>
    <MemberKey>
        <property name="CM_DoorDirectionRule::myISOTypeGroup"/>
    </MemberKey>
    <JadeMethod name="getAllCodes" id="1e7b9564-c6bd-401f-b233-7499ce0ff673">
        <source>getAllCodes() : String;
// ---------------------------------------------------------------------------
// Created:		07/09/2007	by cnwvu1
// ---------------------------------------------------------------------------

vars
	ddr : CM_DoorDirectionRule;
	theCodes : String;

begin

	foreach ddr in self do
		if theCodes &lt;&gt; null then
			theCodes := theCodes &amp; " ";
		endif;
		theCodes := theCodes &amp; ddr.doorDirectionWording[1:1];
	endforeach;
	
	return theCodes;

end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
