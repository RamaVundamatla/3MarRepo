    <JadeMethod name="doMnuContextMenuLocationTbl" id="ebe7caae-4ddd-4b68-82bb-b4819bb587fb">
        <updating/>
        <source>doMnuContextMenuLocationTbl(conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     12 July 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin


	//if filter location null then will get error if no data in table for col organiser
	if self.filterLogLocation = null then 
		return false;
	else
	
		self.doMnuFormContextMenu(conwin, mouse, x, y);
	endif;
end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMnuFormContextMenu" id="4eda5931-e93e-4343-ad3a-42ab908b0e31">
        <updating/>
        <source>doMnuFormContextMenu(conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     14 April 2005	cnwhjg1
//
// Purpose:     par 9691
// ----------   ----------  --------------------------------------------------
vars
	x1, y1		: Real;
	tmpMenu,
	menuItem	: MenuItem;
	showTblDataMenus,
	makeVisible,
	tblDataValidRow	: Boolean;
	tmpTblLocDoc,
	tmpDataTbl : CM_DataTable;
begin

//	// determine what menus to show
	if conwin.isKindOf(CM_DataTable) then 
		tmpDataTbl := conwin.CM_DataTable;
		if tmpDataTbl.rows &gt; tmpDataTbl.fixedRows then  
			showTblDataMenus := true;
		else 
			return false; 
		endif;
	endif;

	if showTblDataMenus then
		self.mnuColumnOrganiser.visible := true;
	
/*	09 Sep 2021	NDL TFS 50505 - does nothing
		if app.isSpecial then
			self.mnuSeperator.visible := false;
			self.mnuInspectObject.visible := false;
// yet to implement. 
		else
			self.mnuSeperator.visible := false;
			self.mnuInspectObject.visible := false;
		endif; */
else
		self.mnuColumnOrganiser.visible := true;
	endif;
	
	// clone menus in sub-classes
//	self.setupContextMenuItems(conwin);

	x1 := x;
	y1 := y;
	if (not mouse) then  // if keyboard, use current listIndex value
	    x1 := 1;
	    y1 := 1;
	endif;

	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	
	popupMenu(self.mnuContextMenu, x1.Integer, y1.Integer);
	return false;

end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doNext" id="a8beb5d2-9005-41d3-9c35-2da04e5daf41">
        <updating/>
        <source>doNext()updating;
//--------------------------------------------------------------
//Created: 17 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	//voy : CM_Voyage;
begin
	
	if self.mode = Mode_Update then
		self.unloadForm();
		return;
	endif;
	
	self.tblHeaderDtls.goToRowByName(ETRow_Voyage);	
	self.tblHeaderDtls.setValueByName(ETRow_DocketNumber, null);
	self.clearTblItems();
	self.lblPage.caption := 'Page 1 of 1';
	self.fldMain.topSheet := shtHeader;
	
	if self.optLoadOutLocn.value then
		if self.optLocnDtlsLocn.value then
			self.myDataClass := CM_TrackedItem;	
		elseif self.optLocnDtlsLogs.value then
			self.myDataClass := CM_TrackedItem;			
		elseif self.optLocnDockets.value then
			self.myDataClass := CM_BOL;
		endif;
	else
		self.myDataClass := CM_SOHLocation;
	endif;
	
	// after loading all logs from location and hiting next button, dont want to go in here as warning 
	// can be given to user telling them this location has been used by the docket they have just loaded
	//	self.setupDynaDict(true); 

	self.myAssistant.LOG_Assistant.comboBoxAssignedLocations(self.cmbLocations, self.filterVoyage, null);
	cmbLocations.lostFocus(cmbLocations);					
end;</source>
    </JadeMethod>
    <JadeMethod name="doNextPrevSheetTblItems" id="9c149058-2055-4fda-b1f2-983145657d89">
        <updating/>
        <source>doNextPrevSheetTblItems(_next : Boolean)updating;
//--------------------------------------------------------------
//Created: 24 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	origTopSheet, newTopSheet : Integer;
begin

	origTopSheet := self.tblItems01.topSheet;
	
	if _next then
		if origTopSheet = self.tblItems01.sheets then
			return;
		endif;
	elseif origTopSheet &lt;= 1 then
		return;
	endif;
	
	if _next then
		newTopSheet := (origTopSheet + 1);
	else
		newTopSheet := (origTopSheet - 1);
	endif;
	
	self.tblItems01.accessSheet(newTopSheet).visible := true;
	self.tblItems02.accessSheet(newTopSheet).visible := true;
	self.tblItems03.accessSheet(newTopSheet).visible := true;
	self.tblItems04.accessSheet(newTopSheet).visible := true;
	self.tblItems05.accessSheet(newTopSheet).visible := true;
	self.tblItems06.accessSheet(newTopSheet).visible := true;	
	
	self.tblItems01.topSheet := newTopSheet;
	self.tblItems02.topSheet := newTopSheet;
	self.tblItems03.topSheet := newTopSheet;
	self.tblItems04.topSheet := newTopSheet;
	self.tblItems05.topSheet := newTopSheet;
	self.tblItems06.topSheet := newTopSheet;
	
	self.tblItems01.accessSheet(origTopSheet).visible := false;
	self.tblItems02.accessSheet(origTopSheet).visible := false;
	self.tblItems03.accessSheet(origTopSheet).visible := false;
	self.tblItems04.accessSheet(origTopSheet).visible := false;
	self.tblItems05.accessSheet(origTopSheet).visible := false;
	self.tblItems06.accessSheet(origTopSheet).visible := false;
	
	lblPage.caption := 'Page ' &amp; newTopSheet.String &amp; ' of ' &amp; tblItems01.sheets.String;				
	self.resizeShtItemDetail();
end;</source>
        <Parameter name="_next" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doReleaseByRail" id="ae3cda11-279a-48e9-a6fa-eec5c7215784">
        <source>doReleaseByRail(_intFaceItem : LOGIF_BOLOut input);
//--------------------------------------------------------------
//Created: 22 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	app.raiseUnexpectedProgramError(class.name, method.name, 'Rail Release not implemented yet');
end;</source>
        <Parameter name="_intFaceItem" type="LOGIF_BOLOut" usage="input"/>
