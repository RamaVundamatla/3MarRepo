    <JadeMethod name="getServiceGroupsInPlay" id="f2ffc42e-ec69-459b-8786-1e6b5317d42f">
        <source>getServiceGroupsInPlay( _params: CM_QueryCriteriaLineHolder; serviceGrpObjSet : ObjectSet input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2019	jlgndl1	Initial creation	TFS 47198

*/

vars

	bankObjSet : ObjectSet;
	obj : Object;
	bank : CM_Bank;
	service : CM_ServiceObject;

begin

	//We get service groups in play based on the banks in play.
	create bankObjSet  transient;
	self.getBanksInPlay( _params, bankObjSet );
	
	if bankObjSet.isEmpty then
		//nothing to do
		return;
	endif;
	
	//so populate the service groups based on the banks found
	foreach obj in bankObjSet do
		bank := obj.CM_Bank;
		foreach service in bank.serviceObjects discreteLock where service.isKindOf( CM_ServiceGroup ) do
			serviceGrpObjSet.addNoDuplicates( service, false );
		endforeach;
	endforeach;

epilog

	delete bankObjSet;

end;</source>
        <access>protected</access>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="serviceGrpObjSet" type="ObjectSet" usage="input"/>
    </JadeMethod>
