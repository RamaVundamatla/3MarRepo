    <JadeMethod name="setForDelete" id="02f02c16-62a1-4a83-ba85-40c222fed480">
        <source>setForDelete(_passport: CM_Passport input);
//--------------------------------------------------
// Created:	20 December 2004 By: cnwgd1
//--------------------------------------------------
vars
	resourceForWharf	: HMS_ResourceForWharf;
begin
	if self.myHarbour &lt;&gt; null then
		self.myHarbour.removeWharfFromDisplay(self);
	endif;
	
	foreach resourceForWharf in self.allResourcesForWharf do
		resourceForWharf.setForDelete(_passport);
		resourceForWharf.erase(NORMAL_ERASE);
	endforeach;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="8c130ebb-d6d7-4d98-964c-dc83e148de44">
        <updating/>
        <source>setForUpdate(_pxyWharf : HMS_Wharf; _passport : CM_Passport input)updating;
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
//--------------------------------------------------------------
// 27/09/2011	cnwcs5	CCMS 2130 / par 28261 - Minimum residence time
// 29/08/2024	navhn30 ChangeRequest 65521: NSW | OnePort Integration - Setting voyage process by wharf
vars
	updatedBerths			: Boolean;
	tmpResourcesForWharf	: HMS_ResourceForWharf;
	resourcesForWharf		: HMS_ResourceForWharf;
	pxyHookLink				: CM_HookLink;
	aTerminal				: CM_Terminal;
begin
	inheritMethod(_pxyWharf, _passport);

	self.code 				:= _pxyWharf.code.toUpper.trimBlanks;
	self.colour 			:= _pxyWharf.colour;	
	self.description 		:= _pxyWharf.description;
	self.displayLeftToRight := _pxyWharf.displayLeftToRight;
	self.isLogicalWharf 	:= _pxyWharf.isLogicalWharf;
	
	if (not self.isVisibleOnView)
	and _pxyWharf.isVisibleOnView
	then
		//Need to check/update the berth marks
		updatedBerths := true;
	endif;
	
	self.isVisibleOnView 	:= _pxyWharf.isVisibleOnView;	
	self.myHarbour 			:= _pxyWharf.myHarbour;
	self.length 			:= _pxyWharf.length;
	self.overhangMaxMetreEnd := _pxyWharf.overhangMaxMetreEnd;
	self.overhangZeroMetreEnd := _pxyWharf.overhangZeroMetreEnd;
	self.waterOnLeft 		:= _pxyWharf.waterOnLeft;
	self.width 				:= _pxyWharf.width;
	self.timeTill2ndResource:= _pxyWharf.timeTill2ndResource;	
	self.myDefaultVoyageProcess := _pxyWharf.myDefaultVoyageProcess; 	//29.08.2024	navhn30	TFS 65521
	if updatedBerths then
		self.updateBerthStartEndPos(_passport);
	endif;

	self.updateWharfSections();
	
	foreach tmpResourcesForWharf in self.allResourcesForWharf do
		tmpResourcesForWharf.setForDelete(_passport);
	endforeach;

	self.allResourcesForWharf.purge();
	
	foreach tmpResourcesForWharf in _pxyWharf.allResourcesForWharf do
		create resourcesForWharf persistent;
		resourcesForWharf.setResourceOrder(tmpResourcesForWharf.order);
		resourcesForWharf.setWharf(self);
		resourcesForWharf.setForUpdate(tmpResourcesForWharf, _passport);
	endforeach;
	
	if _pxyWharf.myHookCode &lt;&gt; null then
		pxyHookLink	:= _pxyWharf.myHookLink;
		
		if pxyHookLink &lt;&gt; null then
			// need to set to the new persistent object
			pxyHookLink.setLinkObject(self);
		endif;
		
		if self.myHookCode = null then
			create self.myHookCode persistent;
			self.myHookCode.setForCreate(_pxyWharf.myHookCode);
		else
			self.myHookCode.setForUpdate(_pxyWharf.myHookCode);
		endif;
	else
		delete self.myHookCode;
	endif;
	
	// cnwrd1 update for sql native par 34536
	foreach aTerminal in self.allTerminals do
		self.updateObjectEdition(aTerminal);
	endforeach;
	
	
	self.allTerminals.clear();
	_pxyWharf.allTerminals.copy(self.allTerminals);
	
	// cnwrd1 update for sql native par 34536
	foreach aTerminal in self.allTerminals do
		self.updateObjectEdition(aTerminal);
	endforeach;
	
	
end;</source>
        <Parameter name="_pxyWharf" type="HMS_Wharf"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="026606e4-e85b-4bb4-8de2-611a390e5554">
        <updating/>
        <source>setProxy(_harbour : HMS_Harbour; _jadeCode, _userCode :String)updating;
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
//--------------------------------------------------------------
// 27/09/2011	cnwcs5	CCMS 2130 / par 28261 - Minimum residence time
vars

begin
	self.raiseExceptionIfNotTransient(method);
	
	self.myHarbour := _harbour;
	
	if self.myHookCode &lt;&gt; null then
		self.myHookCode.setForProxy(self.code, app.myRoot.allHookTypes[HookType_HMSWharfMinWaitTime]);
		self.myHookCode.setJadeCodeForProxy(_jadeCode, _userCode);
	else
		create self.myHookCode transient;
		self.myHookCode.setForProxy(self.code, app.myRoot.allHookTypes[HookType_HMSWharfMinWaitTime]);
		self.myHookCode.createProxyHookLinkForParent(HookType_HMSWharfMinWaitTime, self);
		self.myHookCode.setJadeCodeForProxy(_jadeCode, _userCode);
	endif;
end;</source>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_jadeCode" type="String"/>
        <Parameter name="_userCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateBerthStartEndPos" id="a7669149-1a4f-4ff0-bc67-635027a100fa">
        <updating/>
        <source>updateBerthStartEndPos(_passport : CM_Passport input) updating, protected;
//--------------------------------------------------
// Created:	01 March 2005 By: cnwgd1
//--------------------------------------------------
vars
	iter : Iterator;
	newLengthOfBerth,
	lastStartPos : Integer;
	tmpBerth : HMS_Berth;
begin
	
	if self.allBerths.isEmpty then
		return;
	endif;
	
	newLengthOfBerth := (self.length/self.allBerths.size).Integer;
	iter := self.allBerths.createIterator;
	
	while iter.next(tmpBerth) do

		//Need to adjust the start pos and length
		tmpBerth.setStartPositionLength(lastStartPos, newLengthOfBerth);
		
		lastStartPos := lastStartPos + newLengthOfBerth;
	
	endwhile;
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateWharfSections" id="b7da5d0d-40bb-4ebc-84cd-7a9787c5ccc9">
        <updating/>
        <source>updateWharfSections() updating;
//--------------------------------------------------------------
//Created: 11 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	realWharfSection: HMS_Object;
	pxyWharfSection	: HMS_WharfSection;
	berth			: HMS_Berth;
	lastStartMark,
	lastEndMark		: Integer;
begin
 	// This method updates an array that contain integer pairs that define
 	// the start and end meter marks of continuous blocks of wharfage

 	// Clear all existing wharf sections
 	self.allWharfSections.purge;

    // Update start/end markers for each wharf section
 	foreach berth in self.allBerthsByStartPosnAndName do
 		// Set start and end mark to start &amp; end of first berth
 		if self.allWharfSections.isEmpty then
 			// Create first section
 			if pxyWharfSection = null then
	 			create pxyWharfSection transient;
	 		endif;
 			lastStartMark := berth.startPosition;
 			lastEndMark := berth.startPosition + berth.length;
 			// Add start and end marks to section
 			pxyWharfSection.setProxy(lastEndMark, lastStartMark, self);
 			app.myUtilityCA.utlCreateHMSObject(pxyWharfSection, realWharfSection, app.myPassport);
 		endif;	

 		// Check to see if this berth start further down the wharf 
 		// than where the last berth ended.		
 		if berth.startPosition &gt; (lastEndMark+1) then
 			// Start of new block of continuous wharfage - Set start &amp; end marks
 			// Create new section
 			if pxyWharfSection = null then
	 			create pxyWharfSection transient;
	 		endif;
 			lastStartMark := berth.startPosition;
 			lastEndMark := berth.startPosition + berth.length;
 			pxyWharfSection.setProxy(lastEndMark, lastStartMark, self);
 			app.myUtilityCA.utlCreateHMSObject(pxyWharfSection, realWharfSection, app.myPassport);
 		endif;

 		// Update end mark to end of this berth
 		lastEndMark := berth.startPosition+berth.length;
 		if realWharfSection &lt;&gt; null then
	 		realWharfSection.HMS_WharfSection.setEndMeterage(lastEndMark);
	 	endif;
 	endforeach;
 	
epilog
	delete pxyWharfSection;	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="1764eb9b-c2a4-4a95-a3ca-d31b11d90fc9">
        <source>validateForDelete(_passport: CM_Passport input);
//--------------------------------------------------
// Created:	17 November 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(_passport);
	if self.allBerths.size &gt; 0 then
		app.raiseCMException2(ObjectStillHasEntries, self.getDisplayString(), "Berth", null, null);	

	endif;
	
	//epr TFS 2285 14/7/16
	if self.allResources.size  &gt; 0 then
		app.raiseCMException2(ObjectStillHasEntries, self.getDisplayString(), "Resources", null, null);	
	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="06122ed2-b790-4d3a-bd82-3c5143d58075">
        <source>validateMe(_passport: CM_Passport input);
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
//14/06/2022    navds20     TFS 53760 DuplicateItem not Translatable
//--------------------------------------------------------------
vars
	totalBerthLength : Integer;
	tmpWharf,
 	realWharf	: HMS_Wharf;
	tmpTerminal	: CM_Terminal;
	
begin
	inheritMethod(_passport);
	
	realWharf := self.pxyGetRealObject();
	
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Code', ETRow_Code, null);
		app.raiseCMException(Input_required_field_code, ETRow_Code, null); // cnwdb2	PAR 35364


	endif;
	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Description', ETRow_Description,  null);
		app.raiseCMException(Input_required_field_Desc, ETRow_Description,  null); // cnwdb2	PAR 35364
	endif;

	if self.myHarbour = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Harbour', ETRow_MyHarbour,  null);
		app.raiseCMException(Input_required_field_harbour, ETRow_MyHarbour,  null); // cnwdb2	PAR 35364
	endif;
	
	if (not self.isLogicalWharf)
	or self.isVisibleOnView then
		if self.length = null then
//			app.raiseCMException1(REQUIRED_FIELD, 'Length', ETRow_Length,  null);
			app.raiseCMException(Input_required_field_length, ETRow_Length,  null); // cnwdb2	PAR 35364
		endif;
		totalBerthLength := self.calTotalLengthOfBerths();
		if (self.length + self.overhangZeroMetreEnd + self.overhangMaxMetreEnd) &lt; totalBerthLength then
			app.raiseCMException2(HMSWharfLength, self.code, totalBerthLength.String, ETRow_Length,  null);
		endif;		
		if (not self.isLogicalWharf) 
		and self.width = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Width', ETRow_Width,  null);
			app.raiseCMException(Input_required_field_width, ETRow_Width,  null); // cnwdb2	PAR 35364
		endif;
	endif;								
		
	if _passport.hasErrors then
		return;
	endif;

	tmpWharf := self.myHarbour.allWharves.getAtKey(self.code);
	if tmpWharf &lt;&gt; null then
		if self.isTransient and tmpWharf &lt;&gt; realWharf then
			//app.raiseCMException2(DuplicateItem, 'Wharf', self.code, ETRow_Code, null); //14.06.2022 navds20 53760
			// Wharf already exists for %1 : Wharf_already_exists
			 app.raiseCMException1(Wharf_already_exists, self.code, ETRow_Code, null);  //14.06.2022 navds20 53760
		endif;
	endif;
	
	// PAR 16411 - so graphical view only shows 1 terminal
	if self.allTerminals.size &gt; 1 then
		app.raiseCMException(Wharf_only_assigne_termina, null, null);
	endif;
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateRangeForResource" id="f63ad3eb-a89a-49a0-afd7-d54bf1b10fa1">
        <source>validateRangeForResource(_startPosnAlongWharf, _endPosnAlongWharf : Integer; _resourceCode : String; _passport : CM_Passport input);
//--------------------------------------------------
// Created:	25 January 2005 By: cnwgd1
//--------------------------------------------------
vars
 	minRange,
 	maxRange : Integer;
begin
  	// This method checks to see if the resource ranges entered are valid for the wharf 
	minRange := (0 - self.overhangZeroMetreEnd);
	maxRange := (self.length + self.overhangMaxMetreEnd);

	if _startPosnAlongWharf &lt; minRange or _startPosnAlongWharf &gt; maxRange then
		// Start of range outside valid metre range for the wharf
		app.raiseCMException4(ResourceStartRangeInvalid, _startPosnAlongWharf.String,
							_resourceCode, minRange.String &amp; ' to ' &amp; maxRange.String,
							self.code, ETRow_StartPosnAlongWharf, null);
	endif;
	
	if _endPosnAlongWharf &lt; minRange or _endPosnAlongWharf &gt; maxRange then
		// End of range outside valid metre range for the wharf
		app.raiseCMException4(ResourceEndRangeInvalid, _endPosnAlongWharf.String,
							_resourceCode, minRange.String &amp; ' to ' &amp; maxRange.String,
							self.code, ETRow_EndPosnAlongWharf, null);		
	endif;

end;</source>
        <Parameter name="_startPosnAlongWharf" type="Integer"/>
        <Parameter name="_endPosnAlongWharf" type="Integer"/>
        <Parameter name="_resourceCode" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
