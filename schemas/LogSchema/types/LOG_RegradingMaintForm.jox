    <JadeMethod name="getAvailableLocations" id="29387676-8eb1-4fb7-a318-8481fc884671">
        <source>getAvailableLocations() protected;

vars

	grade			: CM_LogGrade;
	type			: CM_LogType;
	treatment		: CM_LogTreatment;
	length			: CM_LogLength;
	operator		: CM_Operator;
	species			: CM_LogSpecies;
	logArea			: CM_LogArea;
	logController	: CM_LogController;
	tmpLCSearch		: CMIF_SearchTypes;
	listObj			: Object;
	
begin

	listObj := self.cmbTOLocation.listObject;
	
	// Clear array.
	self.allToLocations.clear;
	self.cmbTOLocation.clear;
	// Clear combo.
	self.tblActionData.setValueByName(ETRow_Location, null);
	// Get currently selected specs.
	grade := self.cmbNewGrade.listObject.CM_LogGrade;
	type := self.cmbNewType.listObject.CM_LogType;
	treatment := self.cmbNewTreatment.listObject.CM_LogTreatment;
	length := self.cmbNewLength.listObject.CM_LogLength;
	operator := self.cmbNewSupplier.myObject.CM_Operator;
//	species := self.cmbNewSpecies.listObject.CM_LogSpecies;
	species := self.cmbNewSpecies.myObject.CM_LogSpecies;

	
	create tmpLCSearch transient;
	tmpLCSearch.myOperator := operator;
	tmpLCSearch.mySpecies := species;
	tmpLCSearch.myGrade := grade;
	tmpLCSearch.myType := type;
	tmpLCSearch.myTreatment := treatment;
	tmpLCSearch.myLength := length;
	self.myTerminal.availableLocationsForType(tmpLCSearch, self.allToLocations, TA_TYPE_LOGAREA);
	// Load up combobox.	
	self.myAssistant.comboBoxAddLocationsWithNull(self.cmbTOLocation, self.allToLocations);
	
	// Par 9820
	if self.cmbTOLocation.findObject(listObj) &lt;&gt; 0 then
		self.cmbTOLocation.listObject := listObj;
	endif;

epilog
	
	delete tmpLCSearch;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getRegradingDetail" id="042a30ef-501f-46d8-ad42-b0e972194e73">
        <updating/>
        <source>getRegradingDetail() protected, updating;

vars
	operator	: CM_Operator;
	species		: CM_LogSpecies;
	grade		: CM_LogGrade;	
	type		: CM_LogType;
	treatment	: CM_LogTreatment;
	length		: CM_LogLength;

begin

	// Clear.
	self.clearCombos();
	
	// commented by ccms 1116, #26786 27/01/2011
	
	operator 	:= self.getSupplier();
	species 	:= self.getLogSpecies();
	grade 		:= self.getLogGrade();
	self.getActionFormRemaining(treatment, type, length);
	
	self.myAssistant.setLogSpeciesComboObjects(operator, species, grade, type, treatment, length,
							tblActionData, cmbNewSpecies, cmbNewGrade, cmbNewType, cmbNewTreatment, cmbNewLength);
								

	// 32210 sedMin and sedMax no longer able to be entered
	//if self.selection = LOGID and self.myLog &lt;&gt; null then
	//	self.tblActionData.setValueByName(ETRow_SedMax, self.myLog.sedMax.String);
	//	self.tblActionData.setValueByName(ETRow_SedMin, self.myLog.sedMin.String);
	//endif;

	self.reselectToCombo(self.cmbTOLocation, self.tblActionData);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getSpecs" id="117a294e-a794-4469-9063-6a97bfe87032">
        <updating/>
        <source>getSpecs() updating, protected;
// ---------------------------------------------------------------------------
// Created:     19 May 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/
vars
	lcSet		: CM_LCSet;
	tmpTA		: CM_TerminalArea;
	iter		: Iterator;
	tmpOperator	: CM_Operator;
	tmpSpecies	: CM_LogSpecies;
	tmpGrade	: CM_LogGrade;
	tmpType		: CM_LogType;
	tmpTreat	: CM_LogTreatment;
	tmpLength	: CM_LogLength;
	tmpLC		: CM_LocationsController;
	tmpSOH		: CM_SOHLocation;
	tmpLogProd	: CM_ProductLog;
	tmpTI		: CM_TrackedItem;
	tmpDef		: CMIF_DocketLogDef;
	failedDAC  :CM_DataAccessController;
		
begin

	app.mousePointer := MousePointer_HourGlass;

	self.allDocketLogDef.purge;

	create lcSet transient;
	
	iter := self.myTerminal.allTerminalAreasByTypeId.createIterator;
	self.myTerminal.allTerminalAreasByTypeId.startKeyGeq(TA_TYPE_LOGAREA, null, iter);
	while iter.next(tmpTA) do
		if tmpTA.type &gt; TA_TYPE_LOGAREA then
			break;
		endif;
		if tmpTA.isStockControlled then
			tmpTA.allLocationsControllers.copy(lcSet);
		endif;
	endwhile;

	if lcSet.isEmpty then
		return;
	endif;

	tmpOperator	:= cmbSupplier.listObject.CM_Operator;
	tmpSpecies	:= cmbSpecies.listObject.CM_LogSpecies;
	tmpGrade	:= cmbGrade.listObject.CM_LogGrade;
	tmpType		:= cmbLogType.listObject.CM_LogType;
	tmpTreat	:= cmbLogTreatment.listObject.CM_LogTreatment;
	tmpLength	:= cmbLogLength.listObject.CM_LogLength;

	foreach tmpLC in lcSet do
		foreach tmpSOH in tmpLC.allProductLocations do
			if CM_ProductLog.hasInstance(tmpSOH.myProduct) and tmpSOH.allTrackedItems.size &gt; 0 then	
				tmpLogProd := tmpSOH.myProduct.CM_ProductLog;
				if (tmpOperator = null or tmpLogProd.myOperator = tmpOperator) and
					(tmpSpecies = null or tmpLogProd.myLogSpecies = tmpSpecies) and
					(tmpGrade = null or tmpLogProd.myLogGrade = tmpGrade) and
					(tmpType = null or tmpLogProd.myLogType = tmpType) and
					(tmpTreat = null or tmpLogProd.myLogTreatment = tmpTreat) and
					(tmpLength = null or tmpLogProd.myLogLength = tmpLength) then
					if (not tmpLogProd.canUserAccessSelf(null, failedDAC, app.myPassport)) then
						continue;
					endif;
					// Store detail in cmif docket object.
					create tmpDef transient;
					tmpDef.init(tmpLC, tmpLogProd.myOperator, tmpLogProd.speciesCode, tmpLogProd.gradeCode, tmpLogProd.typeCode, tmpLogProd.treatmentCode, tmpLogProd.lengthCode, false, tmpSOH.currentQuantity, tmpSOH.currentVolume, null);
					tmpSOH.allTrackedItems.copy(tmpDef.allTi);
				//	tmpDef.copyTis(tmpSOH.allTrackedItems, false);
					self.allDocketLogDef.add(tmpDef);
				endif;
			endif;
		endforeach;
	endforeach;

	self.setSelectionData();

epilog
	delete lcSet;
	delete iter;		// PAR #26678
	app.mousePointer := MousePointer_Default;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getSupplier" id="363b4c2f-10be-4e2b-9280-d6f525da0a28">
        <source>getSupplier() : CM_Operator protected;

vars

	operator	: CM_Operator;
	display		: String;

begin

	operator	:= inheritMethod();
//	display		:= self.myAssistant.displayEntryOperator(operator);
//	if display &lt;&gt; null then
