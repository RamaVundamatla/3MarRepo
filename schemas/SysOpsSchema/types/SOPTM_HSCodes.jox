    <JadeMethod name="setupTypeComboBox" id="536ffeb0-b57c-460f-897e-5eae291079a7">
        <source>setupTypeComboBox();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 December 2022	jlier1	Initial creation 55583
26/02/2023			navkc1 	CR 59577 Task 62412: UI - HS Code Sys Admin
*/

vars	
	theForm : SOP_TableMaintForm;
begin
	theForm:=self.myForm;
	
	theForm.comboBox1.clear;
	
	//theForm.comboBox1.addItemWithData(app.getErrorString(Section),CM_HarmonizedSystem.HS_Section);
	//theForm.comboBox1.addItemWithData(app.getErrorString(Chapter),CM_HarmonizedSystem.HS_Chapter);
	//theForm.comboBox1.addItemWithData(app.getErrorString(Heading),CM_HarmonizedSystem.HS_Heading);
	theForm.comboBox1.addItemWithData(app.getErrorString(Code),CM_HarmonizedSystem.HS_Code);
	theForm.comboBox1.addItemWithData(app.getErrorString(Sub_code),CM_HarmonizedSystem.HS_SubCode);
	theForm.comboBox1.addItemWithData(app.getErrorString(Taric_code),CM_HarmonizedSystem.HS_Taric); //26/02/2023	navkc1 CR 59577 Task 62412
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showDetailsForHSType" id="6175c236-a9de-472c-aba3-05fb640dcdd1">
        <source>showDetailsForHSType(_hsType : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 December 2022	jlier1	Initial creation
26/02/2023			navkc1 	CR 59577 Task 62412: UI - HS Code Sys Admin
*/

vars

begin
	self.myForm.tblInput1.hideRowByName(ETRow_UnitQuantity,false);
	self.myForm.tblInput1.hideRowByName(ETRow_ExternalRef1,false);
	self.myForm.tblInput1.hideRowByName(ETRow_ExternalRef2,false);
	self.myForm.tblInput1.hideRowByName(ETRow_ExternalRef3,false);
	self.myForm.tblInput1.hideRowByName(ETRow_HsParentSection,false);
	self.myForm.tblInput1.hideRowByName(ETRow_HsParentChapter,false);
	self.myForm.tblInput1.hideRowByName(ETRow_HsParentHeading,false);
	self.myForm.tblInput1.hideRowByName(ETRow_HsParentCode,false);
	self.myForm.tblInput1.hideRowByName(ETRow_HsParentSubCode,false); //26/02/2023	navkc1 CR 59577 Task 62412

	
	if _hsType = CM_HarmonizedSystem.HS_Code or _hsType = CM_HarmonizedSystem.HS_SubCode then
		self.myForm.tblInput1.showRowByName(ETRow_UnitQuantity,false);
		self.myForm.tblInput1.showRowByName(ETRow_ExternalRef1,false);
		self.myForm.tblInput1.showRowByName(ETRow_ExternalRef2,false);
		self.myForm.tblInput1.showRowByName(ETRow_ExternalRef3,false);
	endif;
	if _hsType =  CM_HarmonizedSystem.HS_SubCode then
		self.myForm.tblInput1.showRowByName(ETRow_HsParentCode,false);
	elseif _hsType = CM_HarmonizedSystem.HS_Code then
		self.myForm.tblInput1.showRowByName(ETRow_HsParentHeading,false);
	elseif _hsType =  CM_HarmonizedSystem.HS_Chapter then
		self.myForm.tblInput1.showRowByName(ETRow_HsParentSection,false);
	elseif _hsType = CM_HarmonizedSystem.HS_Heading then
		self.myForm.tblInput1.showRowByName(ETRow_HsParentChapter,false);
	elseif _hsType = CM_HarmonizedSystem.HS_Taric then //26/02/2023	navkc1 CR 59577 Task 62412
		self.myForm.tblInput1.showRowByName(ETRow_HsParentSubCode,false);
	endif;
	
	self.myForm.tblInput1.repositionAfterResize;
epilog

end;</source>
        <Parameter name="_hsType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="7b07a18e-54aa-49fc-906d-f6de2a8dba68">
        <updating/>
        <source>showThumbnail(pObj: CM_Object) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 December 2022	jlier1	Initial creation 55583

*/

vars

begin
	inheritMethod(pObj);

	self.myForm.btnEditTV.enabled 			:= self.myForm.allowUpdate;
	self.myForm.btnDeleteTV.enabled 		:= self.myForm.allowDelete;
	
	if pObj.isKindOf(CM_HSCodeSection) then
		self.myForm.btnDeleteTV.enabled:=false;	
	elseif pObj.isKindOf(CM_HSCodeChapter) then
		self.myForm.btnDeleteTV.enabled:=false;	
	elseif pObj.isKindOf(CM_HSCodeHeading) then
		self.myForm.btnDeleteTV.enabled:=false;	
	endif;
	
	self.showDetailsForHSType(pObj.CM_HarmonizedSystem.getType);
		
	
	self.myForm.tblInput1.setValueByName(ETRow_HsCodeDescription,pObj.CM_HarmonizedSystem.description);
	
	self.myForm.tblInput1.optimiseValueRowHeights;
epilog

end;</source>
        <Parameter name="pObj" type="CM_Object"/>
    </JadeMethod>
</Class>
