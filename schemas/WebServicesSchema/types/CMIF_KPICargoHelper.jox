<Class name="CMIF_KPICargoHelper" id="c2cef976-492e-4491-8f18-897e4e5223b3">
    <superclass name="CMIF_KPIHelper"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <JadeMethod name="accumulateAndConvertCargo" id="8805167b-ccfd-4551-a179-6cecd9d92ca8">
        <updating/>
        <source>accumulateAndConvertCargo(kpiSet : CM_KPISet; accrualCode: String; productTypeArray: IntegerArray ; cargoTypeArray: IntegerArray ; response: WS_RestKPICounterResponse io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 December 2025	navhn30	 MTN-36753: MTN | KPI REST API - Cargo
08 Jan 2026 navma1  MTN-36897 PEN - Transient File Growth in PEN Production Environment 
*/

vars
	iterator : Iterator;
	kpi 	 : CM_KPI;	
	newKPI	:	CM_KPICargoEntity;
begin
	
	create newKPI transient; 
	iterator := kpiSet.createIterator();
	while iterator.next( kpi) do 
		newKPI.accumulate(kpi.CM_KPICargoEntity);
	endwhile;
	self.convertKPIcargo(newKPI,accrualCode,productTypeArray, cargoTypeArray,response);

epilog
	delete iterator;		//08.01.2026 navma1 #MTN-36897
	delete newKPI;
end;</source>
        <Parameter name="kpiSet" type="CM_KPISet"/>
        <Parameter name="accrualCode" type="String"/>
        <Parameter name="productTypeArray" type="IntegerArray"/>
        <Parameter name="cargoTypeArray" type="IntegerArray"/>
        <Parameter name="response" type="WS_RestKPICounterResponse" usage="io"/>
    </JadeMethod>
    <JadeMethod name="convertKPIcargo" id="c27462be-8244-4eb6-a896-180c5a0d9875">
        <updating/>
        <source>convertKPIcargo(kpi: CM_KPI; accrualCode: String; productTypeArray: IntegerArray ; cargoTypeArray: IntegerArray ; response: WS_RestKPICounterResponse io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 December 2025	navhn30	 MTN-36753: MTN | KPI REST API - Cargo

*/

vars
	wsKPICargo : WS_RestKPICounterCargoType;
	productType,
	cargoType  : Integer;
	
begin
	create wsKPICargo transient;
	
	if accrualCode &lt;&gt; null then 
		wsKPICargo.accuralType := accrualCode;
	else
		wsKPICargo.accuralType := kpi.dateTime.Date.String;
	endif;
	
	if kpi.CM_KPICargoEntity.myCargoType&lt;&gt; null then
		cargoType:= kpi.CM_KPICargoEntity.myCargoType.id;
		productType := kpi.CM_KPICargoEntity.myCargoType.productType;
	endif;

	if kpi.CM_KPICargoEntity.myCargoType&lt;&gt; null then
		if cargoTypeArray.isNotEmpty and not cargoTypeArray.includes(cargoType) or 
			productTypeArray.isNotEmpty and not productTypeArray.includes(productType) then
				return;
		else
			wsKPICargo.setProxyFromObject(kpi.CM_KPICargoEntity);
			response.allKPICounterCargoTypeArray.add(wsKPICargo);
		endif;
	endif;

epilog

end;</source>
        <Parameter name="kpi" type="CM_KPI"/>
        <Parameter name="accrualCode" type="String"/>
        <Parameter name="productTypeArray" type="IntegerArray"/>
        <Parameter name="cargoTypeArray" type="IntegerArray"/>
        <Parameter name="response" type="WS_RestKPICounterResponse" usage="io"/>
    </JadeMethod>
    <JadeMethod name="fetchCargoKPIs" id="86110a24-6cc7-442a-8b1d-f0e09b633230">
        <updating/>
        <source>fetchCargoKPIs(_terminal: CM_Terminal ; productTypes: String ; cargoTypes: String ; goodResponse: WS_RestKPICounterResponse io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 December 2025	navhn30	 MTN-36753: MTN | KPI REST API - Cargo

*/
constants
	KPI_CARGO_TYPE = 0;
vars
	iter 		: 	Iterator;
	objs 		: 	ObjectArray;
	kpi 		: 	CM_KPI;
	dynaDict	: 	DynaDictionary;
	code,
	accuralCode :	String;
	kpiSet 		: 	CM_KPISet;
	obj 		:	Object;
	terminal  	: 	CM_Terminal;
	cargoId     :   Integer;
	productId	:   Integer;
	cargoTypeArray,
	productTypeArray : IntegerArray;
	s : String;
	stringArray1,
	stringArray2	: StringArray;
begin

	terminal := app.myPassport.myTerminal;
	iter := terminal.allKPIbyTypeTSCode.createIterator();
	kpi := terminal.allKPIbyTypeTSCode.getAtKeyGeq(KPI_CARGO_TYPE,self.startDate.asTimeStamp,null);
	
	create dynaDict transient;
	
	dynaDict.setMembership(CM_KPISet);
	dynaDict.addExternalKey(Integer, 60, false, false);
	dynaDict.addExternalKey(Integer, 60, false, false);
	dynaDict.addExternalKey(String, 60, false, false);
	dynaDict.endKeys(false);
	
	create objs transient;
	
	create cargoTypeArray transient;	
	if cargoTypes &lt;&gt; null and cargoTypes &lt;&gt; "" then
		create stringArray1 transient;
		cargoTypes.convertToDelimitedArray(",",stringArray1);
		foreach s in  stringArray1 do
			if s.isInteger() then
				cargoTypeArray.add(s.Integer);
			else
				app.raiseCMException(ERR_INVALID_CARGOTYPE, null, null);
			endif;
		endforeach;
	endif;
	
	create productTypeArray transient;
	if productTypes &lt;&gt; null and productTypes &lt;&gt; "" then
		create stringArray2 transient;
		productTypes.convertToDelimitedArray(",",stringArray2);
		foreach s in  stringArray2 do
		 if s.isInteger() then
			productTypeArray.add(s.Integer);
		else
			app.raiseCMException(ERR_INVALID_PRODUCTTYPE, null, null);
		endif;
		endforeach;	
	endif;
	
	if kpi &lt;&gt; null  and kpi.type = KPI_CARGO_TYPE then
	
		iter.startAtObject(kpi);
		
		while iter.next(kpi) do
			if kpi.type &lt;&gt; KPI_CARGO_TYPE or kpi.dateTime &gt; self.endDate.lastTimeStampValue then
				break;
			endif;
			if not objs.includes(kpi) then
				objs.add(kpi);
			endif;
			if self.accuralType &lt;&gt; Accrual_Daily then 
				if kpi.CM_KPICargoEntity.myCargoType &lt;&gt; null then
					cargoId := kpi.CM_KPICargoEntity.myCargoType.id;
					productId := kpi.CM_KPICargoEntity.myCargoType.productType;
				endif;
				accuralCode :=self.getAccrualCode(kpi.dateTime);
				kpiSet := dynaDict.getAtKey(cargoId,productId,accuralCode).CM_KPISet;
				if kpiSet = null then 
					create kpiSet transient;
					kpiSet.add(kpi);
					dynaDict.putAtKey(cargoId,productId,accuralCode,kpiSet);
					
				else
					kpiSet.add(kpi);
				endif;
			endif;
		endwhile;
	endif;	
	
	
	if self.accuralType = Accrual_Daily then 
		foreach obj in objs do
		self.convertKPIcargo(obj.CM_KPI,null,productTypeArray,cargoTypeArray,goodResponse);
		endforeach;
		
	else
		objs.clear();
		iter := dynaDict.createIterator();
		while iter.next(kpiSet) do 
			accuralCode :=iter.getCurrentKey(3).String;
			productId := iter.getCurrentKey(2).Integer;
			cargoId := iter.getCurrentKey(1).Integer;
			if cargoTypeArray.isNotEmpty and not cargoTypeArray.includes(cargoId) or 
			 productTypeArray.isNotEmpty and not productTypeArray.includes(productId) then
				continue;
			else
				self.accumulateAndConvertCargo(kpiSet,accuralCode,productTypeArray,cargoTypeArray,goodResponse);
			endif;
		endwhile;
	endif;

	
epilog
	delete objs;
	delete iter;
	if dynaDict &lt;&gt; null then
		dynaDict.purge();
	endif;
	delete cargoTypeArray;
	delete productTypeArray;
	
	
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="productTypes" type="String"/>
        <Parameter name="cargoTypes" type="String"/>
        <Parameter name="goodResponse" type="WS_RestKPICounterResponse" usage="io"/>
    </JadeMethod>
