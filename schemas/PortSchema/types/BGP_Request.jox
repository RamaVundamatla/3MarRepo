    <JadeMethod name="action" id="f9bfaf74-960c-496b-aed8-275e3a2c0805">
        <updating/>
        <source>action() : Boolean updating;

/*

Date		Who		Reason
11 Jun 2010	cnwkpd1	PAR #17097 - Handle exceptions in Alert creation
07/03/2011 	cnwmh5 	PAR #27142 - Change to use local variable rather than self
*/

vars
	updateCallbackObject 	: 	Object;			// 07/03/2011 cnwmh5 #27142
	invalid					: Boolean;
	
begin

	updateCallbackObject := self.myUpdateCallbackObject;
	
	if updateCallbackObject &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, updateCallbackObject, invalid);
		updateCallbackObject.bgpRequestCallback(self);									// 07/03/2011 cnwmh5 #27142
	endif;
	
	return false;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkRequestCanBeProcessed" id="ee697899-dfb9-4ffb-a0a1-2a31b9448384">
        <updating/>
        <source>checkRequestCanBeProcessed() : Boolean protected, updating;

// cnwdvb1 07 March 2003 
/*

Date		Who		Reason
19 Feb 2010	cnwkpd1	PAR #22434 - Background Application performance - rework to 
					replace Class.allInstances
05 Mar 2010	cnwkpd1	PAR #22158 - Remove unnecessary class.instances.size for performance
//03 Jan 2013	cnwrs1	32983 crash after user deleted.

*/

vars
	request 		: BGP_Request;
	iter			: Iterator;
	
begin
	app.writeLog(method.qualifiedName, LogTRACE);	//25 Nov 2019	NDL	TFS 47053
	if app.isAppropriateBGPRunning(self.class.name) then
		return true;
	endif;

	iter := self.class.instances.createIterator;
	while iter.next(request) do
		if request.isAlerted then
			return true;
		endif;
	endwhile;
	
	self.sendAlert();
	return false;
	
epilog
	delete iter;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
