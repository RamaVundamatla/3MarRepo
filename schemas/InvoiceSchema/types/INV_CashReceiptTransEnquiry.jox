    <JadeMethod name="includeCashReceiptItem" id="ae275a34-341d-485d-9668-97f34b64a0e3">
        <source>includeCashReceiptItem( cash : CM_CashReceipt;
						bank : CM_Bank;
						dr : CM_Debtor
						):Boolean;
/*
Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 Dec 2019	NDL		TFS 47284

*/
vars

begin

	if bank &lt;&gt; null and cash.CM_CashReceipt.myBank &lt;&gt; bank then
		return false;
	endif;
	if dr &lt;&gt; null and cash.myDebtorTerminal.myDebtor &lt;&gt; dr then
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="cash" type="CM_CashReceipt"/>
        <Parameter name="bank" type="CM_Bank"/>
        <Parameter name="dr" type="CM_Debtor"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
