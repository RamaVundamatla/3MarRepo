    <JadeMethod name="filterObjects2" id="a791ae89-0614-4073-953c-4e0c8bb88bb6">
        <updating/>
        <source>filterObjects2(_jrwTrans : CM_JRWBOLTfrTransactions input; _passport: CM_Passport) updating;
// 2/5/2016  cnwjre1  TFS 980 bill of lading history
//  This method populates both allTfrsByCargoId and allTfrsByLastBol so is called instead of filterObjects which has just a single collection to populate
vars
	failedDAC	: CM_DataAccessController;
begin
	// do user access test on the originating BOL only??
	if self.getMyBOLIn &lt;&gt; null and
	   not self.getMyBOLIn.canUserAccessSelf(null, failedDAC, _passport) then
		return;
	endif;

	_jrwTrans.setMyPopulatingBOL(self.getMyBOLIn);
end;
</source>
        <Parameter name="_jrwTrans" type="CM_JRWBOLTfrTransactions" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getMyBOLIn" id="9803ea8f-ca8c-438a-9ab9-d5b4f8bd06af">
        <source>getMyBOLIn():CM_BOLIn;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

	bol : CM_BOLIn;
	edition : Integer;
	invalidObj : Boolean;

begin

	bol := self.myBOLIn;

	if bol = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, bol, invalidObj );
	edition := bol.edition;
	
	if invalidObj then
		return null;
	endif;
	
	return bol;

epilog

end;</source>
        <ReturnType type="CM_BOLIn"/>
    </JadeMethod>
    <JadeMethod name="getMyVoyage" id="2c6453da-3d11-4a76-ab08-d0b89fc61fa0">
        <source>getMyVoyage():CM_Voyage;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

	voyage : CM_Voyage;
	edition : Integer;
	invalidObj : Boolean;

begin

	voyage := self.myVoyage;

	if voyage = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, voyage, invalidObj );
	edition := voyage.edition;
	
	if invalidObj then
		return null;
	endif;
	
	return voyage;

epilog

end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
