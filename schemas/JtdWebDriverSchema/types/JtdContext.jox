    <JadeMethod name="jtdAppInit" id="6cb90d6f-695b-49d4-8b99-0ab3b07b173a">
        <updating/>
        <source>jtdAppInit(param : String) updating;

begin
	self.jtdSetDriverProfile(null);
	self.jtdSetAutoPingResponseInterval(self.jtdGetDefaultAutoPingInterval);
	self.jtdInitialStatusDisplayEnabled := self.jtdGetDefaultStatusDisplay;
end;</source>
        <Parameter name="param" type="String"/>
    </JadeMethod>
    <JadeMethod name="jtdAppInitClone" id="1b6a9984-8ac4-4279-8ca6-4eb021baea43">
        <updating/>
        <source>jtdAppInitClone(param : String) updating;

vars
	aip : JtdAppInitializationParameter;
	obj : Object;
	
begin
	self.jtdSetDriverProfile(null);

	obj := param.asOid;
	
	if obj = null or (not global.isValidObject(obj)) or
	   (not obj.isKindOf(JtdAppInitializationParameter))
	then
		return;
	endif;

	aip := obj.JtdAppInitializationParameter;

	exclusiveLock(aip);

	self.jtdInitializeFromParamObj(aip);
	
epilog
	if aip &lt;&gt; null then
		beginTransientTransaction;
		delete aip;
		commitTransientTransaction;
	endif;	
end;</source>
        <Parameter name="param" type="String"/>
    </JadeMethod>
    <JadeMethod name="jtdAppInitExternalClone" id="957860ef-3466-489b-b702-8ec2d1a435ea">
        <updating/>
        <source>jtdAppInitExternalClone(param : String) updating;

vars
	aip : JtdAppInitializationParameter;
	
begin
	self.jtdSetDriverProfile(null);
	app.logMessage(method.qualifiedName&amp;' command params '&amp;self.jtdGetUserCommandLine);

	create aip transient;

	aip.jtdSetFromString(self.jtdGetUserCommandLine.trimBlanks);
	
	self.jtdInitializeFromParamObj(aip);

epilog
	delete aip;
end;</source>
        <Parameter name="param" type="String"/>
    </JadeMethod>
