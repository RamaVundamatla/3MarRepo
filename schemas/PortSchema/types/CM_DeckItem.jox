    <JadeMethod name="getColourCoding" id="867248f1-2952-466f-b1d8-cab3d8977e67">
        <updating/>
        <source>getColourCoding(_isLoad : Boolean; _allCC : CM_RORORequestSet input; _clear : Boolean) updating;
/*
Purpose:			
Date		Who		Reason
02 November 2011	cnwab1	Initial creation
*/

vars
	lcs : CM_LCSet;
	lc : CM_LocationsController;
	roroLC : CM_VoyageROROController;
	roroREQ : CM_RORORequest;
begin
	if _clear then
		_allCC.clear();
	endif;
		
		
	create lcs transient;
	self.getLCs(lcs, false);
	
	foreach lc in lcs discreteLock do
	
		roroLC := lc.CM_VoyageROROController;
		if _isLoad then
			roroREQ := roroLC.myRORORequestLoad;
		else
			roroREQ := roroLC.myRORORequestDischarge;
		endif;
		
		if roroREQ &lt;&gt; null then
			_allCC.add(roroREQ);
		endif;
	endforeach;
epilog
	delete lcs;
end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_allCC" type="CM_RORORequestSet" usage="input"/>
        <Parameter name="_clear" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDeckItemLayoutItem" id="9cbe98c3-e8a2-4e53-b787-ab80181fd32b">
        <source>getDeckItemLayoutItem() : CM_DeckItemLayout;
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 18 October 2011
//
// Implemented version: JMT 7.9.2
// Date  		User  		Change
// 18/10/2011	cnwsh3		CCMS MES 1009 PLAN Interface PAR28479
