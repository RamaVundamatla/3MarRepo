    <JadeMethod name="doReleaseItemChange" id="fe924a2a-c292-40c5-a3d7-03b94a3f2a8f">
        <source>doReleaseItemChange();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 May 2009	cnwrd1	Initial creation

*/

vars
	obj 			: Object;
	reserveDet 		: CM_ReserveSelection;
 	checkReserve 	: CM_ReserveDetail;
	brDetail 		: CM_BookingRefItem;		
	reserveISOCode, 
	checkISOCode	: String;
	bookingRef 		: CM_BookingRef;
	bulkRel			: CM_BulkRelease;
begin
	
	
	obj := self.cmbReleaseItem.listObject;
	
	if obj.isKindOf(CM_ReserveSelection) then
		reserveDet := obj.CM_ReserveSelection;
		
		//attempt to find a booking ref item match....
		bookingRef := self.cmbBookingRef.listObject.CM_BookingRef;
		
		if bookingRef &lt;&gt; null then
			foreach brDetail in bookingRef.allBookingRefItems do
			
				if reserveDet.myISOType &lt;&gt; null then
					reserveISOCode := reserveDet.myISOType.code;
				else
					reserveISOCode := null;
				endif;
			
				if brDetail.isoType = reserveISOCode and
					brDetail.quantity = reserveDet.totalRequested then
				
					self.cmbBookingRefDet.listIndex := self.cmbBookingRefDet.findObject( brDetail );
					break;
				endif;	
			endforeach;
		endif;
		
		
		// now find a packing release item match
		bulkRel := self.cmbPackingReq.listObject.CM_BulkRelease;
		
		if bulkRel &lt;&gt; null then
			foreach checkReserve in bulkRel.allReserveDetails where checkReserve.isKindOf( CM_ReserveSelection ) do
			
				if reserveDet.myISOType &lt;&gt; null then
					reserveISOCode := reserveDet.myISOType.code;
				else
					reserveISOCode := null;
				endif;
			
			
				if checkReserve.CM_ReserveSelection.myISOType &lt;&gt; null then
					checkISOCode := checkReserve.CM_ReserveSelection.myISOType.code;
				else
					checkISOCode := null;
				endif;
			
				if checkISOCode = reserveISOCode and
					checkReserve.totalRequested = reserveDet.totalRequested then
				
					self.cmbPackingItem.listIndex := self.cmbPackingItem.findObject( checkReserve );
					break;
				endif;	
			endforeach;
		endif;
	endif;
	

	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doReleaseNumberChange" id="d409fcf7-e722-47ad-95b4-d006d9296fd5">
        <source>doReleaseNumberChange();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 May 2009	cnwrd1	Initial creation

*/

vars
	indx : Integer;
begin

	// need to set the release item combo 
	
	self.populateCmbReleaseItem();
	
	//need to try to set the booknig ref combo (and thus booking ref detail).
	
	indx := self.cmbBookingRef.findStringExact(0,self.cmbReleaseNumber.text ) ;
	if indx &gt; 0 then
		self.cmbBookingRef.listIndex := indx;
		self.doBookingRefChange();
	endif;
	
	indx := self.cmbPackingReq.findStringExact(0,self.cmbReleaseNumber.text);
	if indx &gt; 0 then
		self.cmbPackingReq.listIndex := indx;
		self.doPackingRefChange();		
	endif;
	
	self.doReleaseItemChange();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="4d17d043-ef43-4e48-8a9d-095f0a0d2c65">
        <updating/>
        <source>doSave(): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 May 2009	cnwrd1	Initial creation

*/
/*If the user clicks "Save" and the "Release" checkbox is ticked, 
1.	The cargo will be released on the Road Release, and the "Delivery Release" field will be updated with the Road Release number.
If the cargo is already assigned to the Road Release, then continue with the release.
If the cargo is already assigned to a different Road Release, remove it from that release.
	Validation:
		·	If the cargo does not match the Release Request item then display a Warning.
		·	If the cargo does not match the Booking Item, then display a Warning.
2.	The cargo will be attached to the Export Booking, and the "Booking Reference" field will be updated with the Export Booking Reference. 
	If the cargo is already attached to a booking it will be removed from that booking.
3.	The cargo will be assigned to a matching Packing Request Parent.
	If the cargo is already assigned to the Packing Request, nothing is updated.
	Validation:
		·	If the container does not match a Packing  Request Parent then display a Warning.
4.	If the checkbox is ticked, the cargo will be updated with voyage details from the export booking. This will include the Voyage, Discharge Port, Destination ???
5.	If the Voyage of the Release, Booking and Packign Request do not match display a Warning message.
6.	A CAMS message will be generated for the Shipper with Road Release number and cargo.
*/
vars
	resultDialog : Integer;
	valResult	: Boolean;
	
begin
	app.myPassport.clearErrorsWarnings();
	app.setContinueCMExceptions(true);
	on CM_Exception do addExceptionHandler(exception, app.myPassport);
	
	//only if we want to...
	if self.chkRelease.value = false then
		return true;
	endif;
	
	self.validateSave();
	
	if app.myPassport.hasErrorsOrWarnings() then
		resultDialog := app.showErrorWarningDialog('MT Update', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
		
		if app.myPassport.noErrors()
		and resultDialog = IDOK
		then
			// there must have just been warnings that the user has acknoledged so ..
			app.myPassport.warningsAcknowledged	:= true;
			valResult := true;
			//continue;
		else
			valResult :=  false;
		endif;
		
		self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
	else
		self.clearErrorWarnings();
		valResult := true;
	endif;
	
	if valResult then
	//update TI
		self.updateTI();
		return true;
	else
		return false;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initForTrackedItem" id="06538ef4-6e62-4184-9efc-555fada5b80d">
        <updating/>
        <source>initForTrackedItem() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 May 2009	cnwrd1	Initial creation

*/

vars

begin

	//self.myCurrentTrackedItem := _pxyTi;
	
	//set some captions - use text translation strings.
	self.chkRelease.caption := app.getErrorString2(Release_sub_terminal, self.myCurrentTrackedItem.id ,self.myCurrentTrackedItem.mySubTerminal.code );
	self.lUpdateIDtobe.caption := app.getErrorString1(UpdateIDToBe, self.myCurrentTrackedItem.id);
	self.lAssignTo.caption :=  app.getErrorString1(AssignTo, self.myCurrentTrackedItem.id);
	
	//load comboboxes
	self.populateCmbReleaseNumber();
	
	self.populateCmbBookingRef();
	self.populateCmbPackingReq();
	
	
	// do initial select - par 20037 do not preselect items.
	//self.cmbReleaseNumber.listIndex:= 1;
	//self.cmbReleaseNumber_closeup(self.cmbReleaseNumber);
	
//	self.cmbPackingReq.listIndex:= 1;
//	self.cmbPackingReq_closeup(self.cmbPackingReq);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateCmbBookingRef" id="1bce3418-2e12-4fbd-ad57-2138dcbfb41f">
        <source>populateCmbBookingRef();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 May 2009	cnwrd1	Initial creation

*/

vars
	//dict				: CM_BookingRefsByOperatorRefVoy;
	dict				: CM_BookingRefsByRefDups;
	iter				: Iterator;
	booking				: CM_BookingRef;

begin
	dict := self.myTerminal.allBookingRefsByRef;
	iter := dict.createIterator();
	//	dict.startKeyGeq(opCode, null, null, iter);
	
	while iter.next(booking) do
		//dict.getIteratorKeys(operatorCodeKey, bookingRefKey, voyageKey, iter); // adm 150908 Par 17936
		
		if booking.isComplete() then
			continue;
		endif;
		
		self.cmbBookingRef.addItemObject(booking.bookingReference  , booking);
	endwhile;
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateCmbBookingRefDet" id="c12af842-aa0c-4028-9afb-aab0dbf1c95d">
        <source>populateCmbBookingRefDet();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 May 2009	cnwrd1	Initial creation
18/02/2010	cnwmh5	PAR22417 - handle deleted booking ref
10/03/2011	cnwmh5	PAR #27142 - Change where handleDelteObject is armed
*/

vars

	bulkRelease			: CM_BulkRelease;
	bookingRef			: CM_BookingRef;
	bookingRefItem 		: CM_BookingRefItem;
	indx				: Integer;
	invalidObject		: Boolean;				// 08/02/2010 cnwmh5 #22147 - Added
begin

	bookingRef := self.cmbBookingRef.listObject.CM_BookingRef;

	self.cmbBookingRefDet.clear();

	if bookingRef = null then		
		self.cmbBookingRefDet.text := null;
		return;
	endif;

	on Exception do app.handleDeletedObject(exception, bookingRef, invalidObject);
	
	foreach bookingRefItem in bookingRef.allBookingRefItems do
		self.cmbBookingRefDet.addItemObject (bookingRefItem.getShortDisplay(), bookingRefItem  ) ;
	endforeach;
	
	
	/*
	indx := self.cmbBookingRefDet.findStringExact(0, ) ;
	
	if self.cmbBookingRefDet.listCount &gt; 0 then
		self.cmbReleaseItem.listIndex:= 1;
	endif;
	
		
	indx := self.cmbBookingRef.findStringExact(0,self.cmbReleaseNumber.text ) ;
	if indx &gt; 0 then
		self.cmbBookingRef.listIndex := indx;
	endif;
*/
end;</source>
    </JadeMethod>
    <JadeMethod name="populateCmbPackingItem" id="37c28ff7-dce4-4507-9ee8-2797aae6a401">
        <source>populateCmbPackingItem();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 May 2009	cnwrd1	Initial creation
18/02/2010	cnwmh5	PAR22417 - Handle deleted bulkRelease
10/03/2011	cmwmh5	PAR #27142 - Change where handleDeletedObject is armed
*/

vars

	bulkRelease			: CM_BulkRelease;
	reserveDetail 		: CM_ReserveDetail;
	invalidObject		: Boolean;				// 18/02/2010 cnwmh5 #22417
begin

	bulkRelease := self.cmbPackingReq.listObject.CM_BulkRelease;
	
	self.cmbPackingItem.clear();
	
	if bulkRelease = null then		
		self.cmbPackingItem.text := null;
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception, bulkRelease, invalidObject);	// 18/02/2010 cnwmh5 #22417
	
	// ok we have a bulkrelease now populate item combo.
	foreach reserveDetail in bulkRelease.allReserveDetails do
	
		if reserveDetail.isKindOf(CM_ReserveSelection) then
			self.cmbPackingItem.addItemObject (reserveDetail.CM_ReserveSelection.getDescription(), reserveDetail  ) ;
		endif;
	endforeach;
	
	if self.cmbPackingItem.listCount &gt; 0 then
		self.cmbPackingItem.listIndex:= 1;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="populateCmbPackingReq" id="d9c39bf7-deaf-4caf-9afb-6355e773463d">
        <source>populateCmbPackingReq();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 May 2009	cnwrd1	Initial creation

*/

vars
	dict				: CM_BulkReleaseByTypeStCodeDict;
	iter 				: Iterator;	
	bulkRelease			: CM_BulkRelease;
	releaseNoKey		: String;
	typeKey,
	statusKey			: Integer;
	tsKey				: TimeStamp;
	
begin
	dict := self.myTerminal.allBulkReleaseByTypeByStByCd;
	iter := dict.createIterator();
	
	dict.startKeyGeq(BR_TYPE_PACKING, BR_ACTIVE, null , null, iter);
	
	while iter.next(bulkRelease) do
		dict.getIteratorKeys(typeKey, statusKey, releaseNoKey, tsKey, iter);
		
		if typeKey &lt;&gt; BR_TYPE_PACKING or statusKey &lt;&gt; BR_ACTIVE then
			break;
		endif;
		
		self.cmbPackingReq.addItemObject(bulkRelease.code, bulkRelease);
	endwhile;
epilog
	delete iter;
end;</source>
    </JadeMethod>
