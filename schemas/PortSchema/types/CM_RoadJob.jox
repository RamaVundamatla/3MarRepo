    <JadeMethod name="setProxyRoadJob" id="81934829-e961-439a-bd3b-4ae7a27f810e">
        <updating/>
        <source>setProxyRoadJob(pTerm:CM_Terminal; 
				pBatNumber, 
				pCarrierId, 
				pRegNumber,
				_state,
				pArea : String;
				pIsReceiptRequired, 
				pAutoComplete : Boolean;
				pDriverId	: String;
				_driverObj : CM_DriverDetails;
				_vvr: CM_VehicleVisitRecord;
				_gateEntry: CM_Gate
				) updating;
// ---------------------------------------------------------------------------
// Created:     16 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08 Feb 2024 	navhl20 	ChangeRequest 62084:[62379] EUP | Retrospective Operations - [54177.010] - Road Entry
// ---------------------------------------------------------------------------
vars

	vehicle	: CM_Vehicle;

begin
	self.autoComplete 		:= pAutoComplete;
	self.batNumber			:= pBatNumber;
	self.carrierId			:= pCarrierId;
	self.jobNumber 			:= pRegNumber.trimRight;
	if pBatNumber.trimRight &lt;&gt; null then
		self.jobNumber:= self.jobNumber &amp; '-' &amp; pBatNumber.trimRight;
	endif;
	self.isReceiptRequired 	:= pIsReceiptRequired;
	self.regNumber			:= pRegNumber.trimRight;
	self.roadTransAreaId	:= pArea.trimRight;
	self.driverId			:= pDriverId;
	self.myDriver 			:= _driverObj; // PAR 17703
	
	if pBatNumber &lt;&gt; null then
		self.myBatNumber := pTerm.batNumbers[pBatNumber];
	endif;
	
	self.myCarrier := app.myRoot.allCarriers[pCarrierId];
	
	if self.regNumber &lt;&gt; null then

		vehicle := pTerm.vehicles[self.regNumber, _state];
		if vehicle &lt;&gt; null and vehicle.isNotAvailableForEntry then
			app.raiseCMException1(NotAvailableForEntry, app.getErrorString(Vehicle) &amp; ' (' &amp; self.regNumber &amp; ') ', null, null);
			return;
		endif;

		self.myVehicle := vehicle;
	endif;

	self.myTerminal 		:= pTerm;
	self.myVehicleVisit 	:= _vvr;
	self.myGate 			:= _gateEntry;
	
	if _vvr &lt;&gt; null and _vvr.retrospectiveDT.isValid then								//08.02.2023 navhl20 #62084[62379]
		self.setRetrospectiveDT(_vvr.timeIn);
	endif;
end;</source>
        <Parameter name="pTerm" type="CM_Terminal"/>
        <Parameter name="pBatNumber" type="String"/>
        <Parameter name="pCarrierId" type="String"/>
        <Parameter name="pRegNumber" type="String"/>
        <Parameter name="_state" type="String"/>
        <Parameter name="pArea" type="String"/>
        <Parameter name="pIsReceiptRequired" type="Boolean"/>
        <Parameter name="pAutoComplete" type="Boolean"/>
        <Parameter name="pDriverId" type="String"/>
        <Parameter name="_driverObj" type="CM_DriverDetails"/>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
        <Parameter name="_gateEntry" type="CM_Gate"/>
    </JadeMethod>
