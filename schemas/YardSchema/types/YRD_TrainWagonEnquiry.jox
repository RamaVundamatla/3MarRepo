    <JadeMethod name="doNewWagon" id="5ede76af-9dc1-4079-a3f7-e18d67da2d82">
        <source>doNewWagon();

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
29 June 2009	cnwmd1	Initial creation
31 August 2023	jlizm1	TFS 59215 If open form is for another terminal, want new one for correct terminal

*/

vars
	wagonForm : YRD_TrainWagonForm;
begin
	
	app.mousePointer := MousePointer_HourGlass;
	
	wagonForm := app.getForm(YRD_TrainWagonForm.name).YRD_TrainWagonForm;
	if wagonForm = null or wagonForm.myTerminal &lt;&gt; self.myTerminal then
		wagonForm := app.loadForm(YRD_TrainWagonForm, YRD_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).YRD_TrainWagonForm;
	endif;
	
	if wagonForm = null then
		return;
	endif;
	
	self.setNavigatorHeading(app.getErrorString(Wagon_maintenance));  //+ cnwmd1, CCMS 1067, Par 19710
	wagonForm.centreWindow;
	wagonForm.setMyTerminal(self.myTerminal);
	wagonForm.setMyTrainForWagonCombo(self.myCurrentTrain);
	wagonForm.initialiseForm(self.myCurrentTrain, null, YRD_TrainWagonForm.Mode_Add);
	wagonForm.setParentForm(self);	//26 Feb 2021	NDL	TFS 50837

	wagonForm.show;
		
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doNotableAdd" id="b12067f2-df37-4c3d-be65-c1c45ab93e0b">
        <source>doNotableAdd(_anObject: Object);
// ---------------------------------------------------------------------------
// Created:     21 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 11/03/2010		cnwmh5			PAR23141 - Add missing event tag details
// 02 May 2024 		navma1 			ChangeRequest 63936: MTN - Use Deferred Updates When Confirm Wagons
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(_anObject);

	if CM_Wagon.hasInstance(_anObject) then
		self.allNotableObjects.tryAdd(_anObject);															//02.05.2024 navma1 #63936
		beginNotification(_anObject, Object_Update_Event, Response_Continuous, self.NOTE_EVENT_TAG_WAGON);  // 11/03/2010 cnwmh5 #23141
		beginNotification(_anObject, Object_Delete_Event, Response_Continuous, self.NOTE_EVENT_TAG_WAGON);	// 11/03/2010 cnwmh5 #23141 
	endif;
epilog

end;</source>
        <Parameter name="_anObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doNotableClear" id="184e9ae2-e663-46d7-8cb1-ca69f3b35466">
        <source>doNotableClear();
// ---------------------------------------------------------------------------
// Created:     21 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	removedNotification : Integer;
	anObject : Object;
begin

	foreach anObject in self.allNotableObjects do
		if anObject.isKindOf(CM_Wagon) then
			endNotification(anObject, Object_Update_Event);
			endNotification(anObject, Object_Delete_Event);
			removedNotification := removedNotification + 1;
		endif;		
	endforeach;

	//cnwjo3 par 21915
	validateNotificationRemoval(removedNotification,self.allNotableObjects.size);	
	
	self.allNotableObjects.clear;
end;</source>
    </JadeMethod>
    <JadeMethod name="doNotableRemove" id="a75e839a-9bf0-4c15-ac85-3ae825b0c106">
        <source>doNotableRemove(_anObject: Object);
// ---------------------------------------------------------------------------
// Created:     21 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
begin
	if _anObject = null then
		return;
	endif;
	if not global.isValidObject(_anObject) then
		return;
	endif;
	if  self.allNotableObjects.includes(_anObject) then
		if _anObject.isKindOf(CM_Wagon) then
			self.allNotableObjects.remove(_anObject);
			endNotification(_anObject, Object_Update_Event);
			endNotification(_anObject, Object_Delete_Event);
		endif;
	endif;

end;</source>
        <Parameter name="_anObject" type="Object"/>
    </JadeMethod>
