<Class name="CM_DataExtractOnsiteContainers" id="5efff60a-b3d6-40dd-a7e5-266f89bf336c">
    <superclass name="CM_DataExtractClass"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <JadeMethod name="extractFieldsBody" id="b3e8d59f-04cb-4627-a543-e1a698893182">
        <source>extractFieldsBody(_terminal : CM_Terminal; _outputFile : File; _counter : Integer io; _breakOut : Boolean output) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2011	#cnwdz2	 

*/

vars
	iter	   : Iterator;
   	ti		   : CM_TrackedItem;
begin
	iter := _terminal.allOnsiteTIsByCargoTypeId.createIterator;
	_terminal.allOnsiteTIsByCargoTypeId.startKeyGeq(TI_CargoType_Container, null, iter);
	while iter.next(ti) do
		if ti = null or ti.cargoType &lt;&gt; TI_CargoType_Container then
			break;
		endif;
		self.extractFieldsFromObject(ti, _outputFile, _counter, _breakOut);		
	endwhile;
	
epilog	
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_outputFile" type="File"/>
        <Parameter name="_counter" type="Integer" usage="io"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getCollectionRefField" id="865fbd9b-2b50-43bd-a1d1-aa2eccba2f3b">
        <source>getCollectionRefField(): CM_DataExtractFieldArray;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2011	#cnwdz2	 

*/

vars
	refFields : CM_DataExtractFieldArray;
begin
	create refFields transient;
	refFields.add(self.allDataExtractFields[CM_Container::id.name]);
	return refFields;
epilog

end;</source>
        <ReturnType type="CM_DataExtractFieldArray"/>
    </JadeMethod>
