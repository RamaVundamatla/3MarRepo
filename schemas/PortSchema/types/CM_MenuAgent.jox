    <JadeMethod name="trxLoadJMTNavMenu" id="4808ab9d-bf0b-414b-a4e0-309d0b268613">
        <source>trxLoadJMTNavMenu();
// ---------------------------------------------------------------------------
// Created:     26 November 2002		cnwth2	
//
// Purpose:     
//				
// ----------   ----------  --------------------------------------------------
vars
	menuRoot	: CM_MenuRootForRoot;
	baseScm 	: Schema;
	category 	: ConstantCategory;
	const 		: Constant;
	constDict	: ConstantNDict;
	isSystemDtl	: Boolean;
begin
	app.writeStatement( 'Starting trxLoadJMTNavMenu');
	menuRoot := self.myJMTMenuRoot;
	beginTransaction;

	self.allObjectsToDelete.clear;
	menuRoot.allMenuItems.copy(self.allObjectsToDelete);

	baseScm := rootSchema.getSchema(PortSchemaName);

	category := baseScm.getCategory(MenuHdrConstants);
	constDict := category.getConstants();
	foreach const in constDict do
		self.loadJMTDefaultMenuHdrs(const, XMLTag_MenuHdr, menuRoot);
	endforeach;

	category := baseScm.getCategory(XLAT_Permissions);
	constDict := category.getConstants();
	foreach const in constDict do
		self.loadJMTDefaultMenuDetails(const, false, menuRoot);
	endforeach;

	category := baseScm.getCategory(MenuHdrConstants);
	constDict := category.getConstants();
	foreach const in constDict do
		self.loadJMTDefaultMenuChildren(const, XMLTag_MenuHdr, menuRoot);
	endforeach;

	self.allObjectsToDelete.purge;
	
	commitTransaction;
	app.writeStatement( 'Completed trxLoadJMTNavMenu');

end;</source>
    </JadeMethod>
    <JadeMethod name="trxLoadJMTReportMenu" id="d84d1f8d-efd3-461e-bd84-7575cfd9d835">
        <source>trxLoadJMTReportMenu();
// ---------------------------------------------------------------------------
// Created:     25 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	menuRoot			: CM_MenuRootReportForRoot;
	baseScm 			: Schema;
	category 			: ConstantCategory;
	const 				: Constant;
	constDict			: ConstantNDict;
	userReport			: CM_QryReportUser;
	menuItem			: CM_MenuItem;
	
begin
	beginTransaction;
	menuRoot := self.myJMTMenuReportRoot;
	
	self.allObjectsToDelete.clear;
	menuRoot.allMenuItems.copy(self.allObjectsToDelete);

	baseScm := rootSchema.getSchema(PortSchemaName);

	category := baseScm.getCategory(MenuHdrReportConstants);
	constDict := category.getConstants();
	foreach const in constDict do
		self.loadJMTDefaultMenuHdrs(const, XMLTag_MenuReportHdr, menuRoot);
	endforeach;

	category := baseScm.getCategory(CM_Report);
	constDict := category.getConstants();
	foreach const in constDict do
		self.loadJMTMenuReportDetails(const, menuRoot);
	endforeach;

	category := baseScm.getCategory(MenuHdrReportConstants);
	constDict := category.getConstants();
	foreach const in constDict do
		self.loadJMTDefaultMenuChildren(const, XMLTag_MenuReportHdr, menuRoot);
	endforeach;
	
	foreach userReport in CM_QryReportUser.instances do
		self.removeFromDeleteSet(userReport);
		userReport.setPropertyValue(CM_QryReportUser::myMenuReportRoot.name, menuRoot);
	endforeach;
	
	self.allObjectsToDelete.purge;
	
	commitTransaction;

end;</source>
    </JadeMethod>
    <JadeMethod name="trxLoadJMTSysEntMenu" id="0b3c7fc6-daf5-47dc-bc18-f97a1f769fd8">
        <source>trxLoadJMTSysEntMenu();
// ---------------------------------------------------------------------------
// Created:     10 February 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	menuRoot	: CM_MenuRootForRoot;
	baseScm 	: Schema;
	category 	: ConstantCategory;
	const 		: Constant;
	constDict	: ConstantNDict;

begin



	menuRoot := self.myJMTMenuRootForSysEntites;
	beginTransaction;

	self.allObjectsToDelete.clear;
	menuRoot.allMenuItems.copy(self.allObjectsToDelete);

	baseScm := rootSchema.getSchema(PortSchemaName);

	category := baseScm.getCategory(MenuHdrSystemConstants);
	constDict := category.getConstants();
	foreach const in constDict do
		self.loadJMTDefaultMenuHdrs(const, XMLTag_MenuSysHdr, menuRoot);
	endforeach;

	category := baseScm.getCategory(XLAT_Permissions);
	constDict := category.getConstants();
	foreach const in constDict do
		self.loadJMTDefaultMenuDetails(const, true, menuRoot);
	endforeach;

	category := baseScm.getCategory(MenuHdrSystemConstants);
	constDict := category.getConstants();
	foreach const in constDict do
		self.loadJMTDefaultMenuChildren(const, XMLTag_MenuSysHdr, menuRoot);
	endforeach;

	self.allObjectsToDelete.purge;
	
	commitTransaction;



end;</source>
    </JadeMethod>
    <JadeMethod name="trxLoadJMTToolbarMenu" id="a2f2472a-a421-492b-9da6-18c7e37dd2f9">
        <source>trxLoadJMTToolbarMenu();
// ---------------------------------------------------------------------------
// Created:     20 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	dict				: CM_MenuItemByTypeMenuIdDict;
	baseScm 			: Schema;
	category 			: ConstantCategory;
	const 				: Constant;
	constDict			: ConstantNDict;
	idStr,
	childStr,
	xmlBlock			: String;
	pos					: Integer;
	toolbarEntity		: CM_MenuToolbar;
	newTool				: CM_MenuUserToolbar;
	menuEntity			: CM_MenuEntity;
	menuDict			: CM_MenuToolbarByIdDict;
begin
	beginTransaction;
	
	baseScm := rootSchema.getSchema(PortSchemaName);
	category := baseScm.getCategory(MenuHdrToolbarConstants);
	constDict := category.getConstants();
	const := constDict.getAtKey('MenuHdrToolbar_1');
	
	if const = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Toolbar header constant was not found');
		return;
	endif;
		
	create dict transient;
	menuDict := app.myRoot.allToolbarEntities;
	
	foreach menuEntity in menuDict do
		if not menuEntity.isKindOf(CM_MenuItem) then
			continue;
		endif;
		if not dict.includesKey(menuEntity.CM_MenuItem.type, menuEntity.CM_MenuItem.menuId) then
			dict.add(menuEntity.CM_MenuItem);
		else
			delete menuEntity;
		endif;
	endforeach;
	
	self.myJMTToolbarRoot.allChildren.purge();
	
	childStr := const.text.cnEcGetTagValueOfName(XMLTag_Children);
	
	pos := 1;
	while (pos &lt;&gt; 0) do
		idStr := childStr.cnEcGetNextTagValueOfName(XMLTag_Id, pos);	
		if idStr &lt;&gt; null then
			toolbarEntity := dict[MenuType_DetailSystem, idStr].CM_MenuToolbar;
			
			if toolbarEntity &lt;&gt; null then
				create newTool persistent;
				newTool.setFromSystemToolbar(toolbarEntity.CM_MenuToolbar);
				self.myJMTToolbarRoot.allChildren.add(newTool);				
			endif;
		endif;
	endwhile;
	commitTransaction;		

epilog
	delete dict;	
end;</source>
    </JadeMethod>
    <JadeMethod name="trxRefreshAllToolbarEntities" id="27a63fb7-8cee-4153-a7fc-484994a365d0">
        <source>trxRefreshAllToolbarEntities();
// ---------------------------------------------------------------------------
// Created:     27 January 2003		cnwth2	
//
// Purpose:     Creates any toolbar system entities not already in existence. Called
//				from the permissions form when a new permission is created.
//				NB.This method will very rarely be called so erformance is not an issue
//			 
// ----------   ----------  --------------------------------------------------
// 24 Nov 2017	jlgmd1		TFS #6830 - 8.5.1.130 Release - 1310 : Key already used in this dictionary
// 05 Dec 2017	jlgkpd1		TFS #6830 - rework exception triggering

vars
	oldEntity,
	menuEntity					: CM_MenuEntity;
	found						: Boolean;
	newTool						: CM_MenuToolbar;
	root						: CM_Root;
	invalid						: Boolean;
	dtl							: CM_MenuDtlSystem;
	ed							: Integer;
	
begin
	on Exception do app.handleDeletedObject(exception, dtl, invalid);

	root := app.myRoot;
	beginTransaction;
	//purge toolbar items that have become shagged for whatever reason
	//special buttons, just delete and re-build
	foreach oldEntity in root.allToolbarEntities do
		if (not oldEntity.isKindOf(CM_MenuToolbar)) then
			continue;
		endif;
		
		//TFS6830 Starts here
		dtl := oldEntity.CM_MenuToolbar.myMenuDtlSystem.CM_MenuDtlSystem;
		if dtl &lt;&gt; null then
			ed := dtl.edition;
			if invalid then
				delete oldEntity;
				invalid := false;
			else
				//Likewise, if (after a schema load) a MenuToolbar ended up with someone elses dtl, then can it and recreate it too
				if oldEntity.CM_MenuToolbar.menuId[4:end] &lt;&gt; dtl.menuId[5:end] then
					delete oldEntity;
				endif;
			endif;
		endif;
		//TFS6830 Ends here
		
	endforeach;
	
	on Exception do null;

	foreach menuEntity in self.myJMTMenuRoot.allMenuItems do
		if (not menuEntity.isKindOf(CM_MenuDtlSystem)) then
			 continue;
		endif;
		// check that the new menuId is not already used cnwrs1 Feb 2006
		oldEntity := root.allToolbarEntities['_TB' &amp; menuEntity.CM_MenuDtlSystem.menuId[5: menuEntity.CM_MenuDtlSystem.menuId.length]];		
		if oldEntity &lt;&gt; null and
		   oldEntity.CM_MenuItem.heading &lt;&gt; menuEntity.CM_MenuItem.heading then
			// we are going to have a clash as the new menuId is already being used, so rename the old fella
			oldEntity.setPropertyValue('menuId', oldEntity.CM_MenuItem.menuId &amp; '_1');
		endif;
		found := false;
		
		foreach oldEntity in root.allToolbarEntities do : innerLoop
			if (not oldEntity.isKindOf(CM_MenuToolbar)) then
				continue;
			endif;
			
			if oldEntity.CM_MenuToolbar.myMenuDtlSystem &lt;&gt; null and
			   oldEntity.CM_MenuToolbar.myMenuDtlSystem = menuEntity then
				oldEntity.CM_MenuToolbar.setPictures(menuEntity.pictureStringButton, menuEntity.pictureStringButtonDown, menuEntity.pictureStringIcon);
				oldEntity.CM_MenuToolbar.setHeading(menuEntity.CM_MenuDtl.heading);
				oldEntity.CM_MenuToolbar.setFromMenuDtlSystem(menuEntity.CM_MenuDtlSystem);
				found := true;
				break innerLoop;
			endif;
		endforeach;
		
		if (not found) then
			create newTool persistent;
			newTool.setFromMenuDtlSystem(menuEntity.CM_MenuDtlSystem);
			newTool.setRoot(app.myRoot);	
		endif;
	endforeach;

	foreach menuEntity in self.myJMTMenuRootForSysEntites.allMenuItems do
		if menuEntity.isKindOf(CM_MenuDtlSystem) then
			// check that the new menuId is not already used cnwrs1 Feb 2006
			oldEntity := root.allToolbarEntities['_TB' &amp; menuEntity.CM_MenuDtlSystem.menuId[5: menuEntity.CM_MenuDtlSystem.menuId.length]];		
			if oldEntity &lt;&gt; null and
			   oldEntity.CM_MenuItem.heading &lt;&gt; menuEntity.CM_MenuItem.heading then
				// we are going to have a clash as the new menuId is already being used, so rename the old fella
				oldEntity.setPropertyValue('menuId', oldEntity.CM_MenuItem.menuId &amp; '_1');
			endif;
		endif;
		found := false;
		foreach oldEntity in root.allToolbarEntities do : innerLoop
			if not oldEntity.isKindOf(CM_MenuToolbar) then
				continue;
			endif;
			
			if oldEntity.CM_MenuToolbar.myMenuDtlSystem &lt;&gt; null and
				oldEntity.CM_MenuToolbar.myMenuDtlSystem = menuEntity then
				oldEntity.CM_MenuToolbar.setPictures(menuEntity.pictureStringButton, menuEntity.pictureStringButtonDown, menuEntity.pictureStringIcon);
				oldEntity.CM_MenuToolbar.setHeading(menuEntity.CM_MenuDtl.heading);
				oldEntity.CM_MenuToolbar.setFromMenuDtlSystem(menuEntity.CM_MenuDtlSystem);
				found := true;
				break innerLoop;
			endif;
		endforeach;
		
		if not found then
			if menuEntity.isKindOf(CM_MenuDtlSystem) then
				create newTool persistent;
				newTool.setFromMenuDtlSystem(menuEntity.CM_MenuDtlSystem);
				newTool.setRoot(app.myRoot);	
			endif;
		endif;
	endforeach;

	commitTransaction;

end;</source>
    </JadeMethod>
    <JadeMethod name="trxRemoveNavMenuItems" id="91315471-6656-4027-9dcc-52a0646449bf">
        <source>trxRemoveNavMenuItems(_permissions : IntegerArray);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Sep 2012	cnwpjs1	Initial creation PAR # 30391 - Voyage Rationalisation
17/01/2018 LJGNS1   Bug 36416: JMT - Container &amp; Hatch Summary missing
*/

vars

	
	permission	: Integer;
	item		: CM_MenuDtl;
	menuItem 	: CM_MenuToolbar;
begin

	beginTransaction;
	
	foreach permission in _permissions do
		
		// permssion could be for the terminal or system menu
		
		item := self.myJMTMenuRoot.allMenuDtlsByPermValue[permission];
		if item =  null then 
			item := self.myJMTMenuRootForSysEntites.allMenuDtlsByPermValue[permission];
		endif;
				
		// delete the item - parent/child relationship will remove all user dtls (via allMenuUserItems)
		if item &lt;&gt; null then 
			//BUG 36416 - remove the menuItem also as this relationship is not inversed  
			menuItem := app.myRoot.allToolbarEntities["_TB" &amp; item.constantValue.String];	//BUG 36416
			if menuItem &lt;&gt; null and	menuItem.myMenuDtlSystem = item then					//BUG 36416
				delete menuItem;															//BUG 36416
			endif;																			//BUG 36416
			
			delete item;
		endif;
			
	endforeach;


	commitTransaction;

epilog

end;</source>
        <Parameter name="_permissions" type="IntegerArray"/>
    </JadeMethod>
