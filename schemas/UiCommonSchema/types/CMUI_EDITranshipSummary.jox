    <JadeMethod name="doBtnPrint" id="489907d8-194e-4509-ad9d-9b057d11e50a">
        <updating/>
        <source>doBtnPrint() updating;
// ---------------------------------------------------------------------------
// Created:     September 2007 cnwrs1
//
// Purpose:     
// ---------------------------------------------------------------------------

vars

	reportForm : CMUI_BishPrintAndExtract;

begin

	//self.doPrintOutTable(self.tblTranship, self.caption[1:100], true, false, true, false);

	//28 Feb 2014	NDL	Par 33607
	if ( app.myRoot.client = Client_PortOtago ) or app.isDevelopmentSystem then
	
		reportForm := app.loadForm(CMUI_BishPrintAndExtract, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_BishPrintAndExtract;
	
		if reportForm = null then
			return;
		endif;
	
		reportForm.setParentForm(self);
		reportForm.setMyTerminal(self.myTerminal);	
		
		reportForm.showModal;
	
	else
	
		self.doPrintOutTable(self.tblTranship, self.caption[1:100], true, false, true, false);
		
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="a4e1b5d0-de65-4044-95b4-ef087bf8f2f4">
        <updating/>
        <source>doRefresh() updating, protected;
// ---------------------------------------------------------------------------
// Created:     September 2007 cnwrs1
//
// Purpose:     
// ---------------------------------------------------------------------------
// Date			Who			Reason
// 01 Oct 2008	consw1		Par 17090 Replace app.getMyTerminal with self.myTerminal
// 22/11/2019	jlgsl4		TFS 47678 - POL - cancelled voyages in Voyage Discharge Summary

vars

begin
	app.mousePointer := MousePointer_HourGlass;
	inheritMethod();
	self.setValidVoyages(); // TFS 47678
	//self.cmbVoyage.listCollection(self.myTerminal.allVoyagesByCode, false, 0); // TFS 47678
	if self.myCurrentVoyage = null and
	   self.myEDIDataTranship = null then
		self.showHideSelector();
	endif;
	if self.myCurrentVoyage &lt;&gt; null then
		if self.cmbVoyage.findObject(self.myCurrentVoyage) &gt; 0 then // PAR 19484
			self.cmbVoyage.listObject := self.myCurrentVoyage; // PAR 19484
		endif;
		self.displayCollectionVoyage();
	elseif self.myEDIDataTranship &lt;&gt; null then
		self.displayCollectionEDI();
	endif;
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
