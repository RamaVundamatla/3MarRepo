    <JadeMethod name="deleteOldEDIJSONClasses" id="d731c601-4748-4f85-bfd1-959649161149">
        <source>deleteOldEDIJSONClasses(_controller: CnEcReleaseController);
/*

Purpose:			CM_EDIFileTypeCallOff and CM_EDIFileTypeTransManifest have been moved to under the JSON abstract class.
					To keep EDI File Types, the old instances need to be pruged

Parameters:			

Return Value:		

Date			Who		Reason
28 August 2023	navmd1	Initial creation TFS 60061

*/

vars
	scm		: Schema;
	cls		: Class;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Purging old JSON EDI File Types", LogINFO);
	
	if _controller &lt;&gt; null then
		_controller.logEntry(" Purging old JSON EDI File Types") ;	
	endif;
	
	scm := currentSchema;
	
	beginTransaction;
	cls := scm.getClass("CM_EDIFileTypeTransManifest");
	if cls &lt;&gt; null then
		if cls.instances.size &gt; 0 then
			app.writeLog(method.qualifiedName &amp; " CM_EDIFileTypeTransManifest Found - Purging (" &amp; cls.instances.size.String &amp; ") instances", LogINFO);
			cls.instances.purge();
		endif;
	endif;
	
	cls := scm.getClass("CM_EDIFileTypeCallOff");
	if cls &lt;&gt; null then
		if cls.instances.size &gt; 0 then
			app.writeLog(method.qualifiedName &amp; " CM_EDIFileTypeCallOff Found - Purging (" &amp; cls.instances.size.String &amp; ") instances", LogINFO);
			cls.instances.purge();
		endif;
	endif;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Purging old JSON EDI File Types complete", LogINFO);
	
	if _controller &lt;&gt; null then
		_controller.logEntry(" Purging old JSON EDI File Types complete") ;	
	endif;
	
	self.addScriptRun(method.name);
epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="ediCustomsMessageTI" id="08a4e24b-8be8-4f50-a4b5-7110bccfe5a2">
        <source>ediCustomsMessageTI(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2022	navtnr20	Bug 53101: MTN US Customs Message EDI not added to collection by Voyage Code
*/

vars
	cust  : CM_EDIUSCustomsMessageTI;
	config : CM_EDIConfig;
	codeUpper : String;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; "Adding US Customs Message EDI TIs to EDI Config Voyage Code dictionary", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Adding US Customs Message EDI TIs to EDI Config Voyage Code dictionary") ;	
	endif;
	beginTransaction;
	foreach cust in CM_EDIUSCustomsMessageTI.instances do
		if cust.myEDIConfig = null then
			continue;
		endif;
		if cust.voyageCode &lt;&gt; null and cust.myEDIConfig.allEDITrackedItemsByVoyageCode &lt;&gt; null then
			codeUpper := cust.voyageCode.toUpper;
			if not cust.myEDIConfig.allEDITrackedItemsByVoyageCode.includesKey(codeUpper, cust) then
				cust.myEDIConfig.allEDITrackedItemsByVoyageCode.putAtKey(codeUpper, cust, cust);
			endif;
		endif;
	endforeach;
	commitTransaction;
	app.writeLog(method.qualifiedName &amp; "Completed Adding US Customs Message EDI TIs to EDI Config Voyage Code dictionary", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Completed Adding US Customs Message EDI TIs to EDI Config Voyage Code dictionary");
	endif;
	
	self.addScriptRun(method.name);
epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="encryptPasswords" id="6e00a3f9-dffa-4937-b8a2-ffe059095580">
        <source>encryptPasswords(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 August 2021	navndl1	Initial creation	TFS 51632

*/

vars

	size : Integer;
	objArray : CM_ObjectArray;
	boom : CM_Boom;
	obj : Object;
	cmObj : CM_Object;
	rawPw : String;
	encryptPw : String;

begin
	
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Encrypt passwords", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Encrypt passwords") ;	
	endif;
	
	//Gather up the objects that we care about.
	create objArray transient;
	
	foreach obj in CM_Boom.instances do
		objArray.addExclusive(obj);
	endforeach;
	foreach obj in CM_DataDumpExtractDef.instances do
		objArray.addExclusive(obj);
	endforeach;
	foreach obj in CM_FTPEntity.instances do
		objArray.addExclusive(obj);
	endforeach;
	foreach obj in CM_SFTPEntity.instances do
		objArray.addExclusive(obj);
	endforeach;
	foreach obj in CM_EventStreamDefinition.instances do
		objArray.addExclusive(obj);
	endforeach;
	foreach obj in CM_ExternalWebServiceDef.instances do
		objArray.addExclusive(obj);
	endforeach;	
	foreach obj in CM_AllotracServiceDef.instances do
		objArray.addExclusive(obj);
	endforeach;
	foreach obj in CM_CargoChainServiceDef.instances do
		objArray.addExclusive(obj);
	endforeach;
	foreach obj in CM_InaportnetWebService.instances do
		objArray.addExclusive(obj);
	endforeach;
	foreach obj in CM_KiwiRailCheckInWSDef.instances do
		objArray.addExclusive(obj);
	endforeach;
	foreach obj in CM_NavisMACS3Service.instances do
		objArray.addExclusive(obj);
	endforeach;
	foreach obj in CM_OpsViewServiceDef.instances do
		objArray.addExclusive(obj);
	endforeach;
	foreach obj in CM_SAPWebService.instances do
		objArray.addExclusive(obj);
	endforeach;
	foreach obj in CM_Terminal.instances do
		objArray.addExclusive(obj);
	endforeach;
	foreach obj in CM_Root.instances do
		objArray.addExclusive(obj);
	endforeach;
	
	//ready to go
	beginTransaction;
	
	//process the collection
	foreach obj in objArray do
		cmObj := obj.CM_Object;
		rawPw := null;
		encryptPw := null;
		//CM_Boom
		if cmObj.isKindOf( CM_Boom ) then
			rawPw := cmObj.CM_Boom.password.trimBlanks;
		
		//CM_DataDumpExtractDef
		elseif cmObj.isKindOf( CM_DataDumpExtractDef ) then
			rawPw := cmObj.CM_DataDumpExtractDef.edbPassword.trimBlanks;
		
		//CM_SFTPEntity
		elseif cmObj.isKindOf( CM_SFTPEntity ) then	//06 Sep 2021	NDL TFS 51165
			rawPw := cmObj.CM_SFTPEntity.passPhrase.trimBlanks;
			if rawPw &lt;&gt; null then
				encryptPw := app.pwEnCode( rawPw );
			endif;
			cmObj.setProxyPw( encryptPw, CM_SFTPEntity::passPhrase.name );
			
			rawPw := null;
			encryptPw := null;
			rawPw := cmObj.CM_SFTPEntity.password.trimBlanks;
			
		//CM_FTPEntity
		elseif cmObj.isKindOf( CM_FTPEntity ) then
			rawPw := cmObj.CM_FTPEntity.password.trimBlanks;
			
		//CM_EventStreamDefinition
		elseif cmObj.isKindOf( CM_EventStreamDefinition ) then
			rawPw := cmObj.CM_EventStreamDefinition.authToken.trimBlanks;
			
		//CM_KiwiRailCheckInWSDef
		elseif cmObj.isKindOf( CM_KiwiRailCheckInWSDef ) then
			rawPw := cmObj.CM_KiwiRailCheckInWSDef.messagePassword.trimBlanks;
			if rawPw &lt;&gt; null then
				encryptPw := app.pwEnCode( rawPw );
			endif;
			cmObj.setProxyPw( encryptPw, CM_KiwiRailCheckInWSDef::messagePassword.name );
			
			rawPw := null;
			encryptPw := null;
			rawPw := cmObj.CM_KiwiRailCheckInWSDef.password.trimBlanks;
		
		//CM_ExternalWebServiceDef, CM_AllotracServiceDef, CM_CargoChainServiceDef, CM_InaportnetWebService
		//CM_NavisMACS3Service, CM_OpsViewServiceDef, CM_SAPWebService
		elseif cmObj.isKindOf( CM_ExternalWebServiceDef ) then
			rawPw := cmObj.CM_ExternalWebServiceDef.password.trimBlanks;
		
		//CM_Terminal
		elseif cmObj.isKindOf( CM_Terminal ) then
			rawPw := cmObj.CM_Terminal.getConfig( AutoPop3Password ).String.trimBlanks;
			if rawPw &lt;&gt; null then
				encryptPw := app.pwEnCode( rawPw );
			endif;
			cmObj.CM_Terminal.setConfig( AutoPop3Password, encryptPw );
			size := size + 1;
			continue;
			
		//CM_Root
		elseif cmObj.isKindOf( CM_Root ) then
			rawPw := cmObj.CM_Root.getConfig( AutoOutwardPassword ).String.trimBlanks;
			if rawPw &lt;&gt; null then
				encryptPw := app.pwEnCode( rawPw );
			endif;
			cmObj.CM_Root.setConfig( AutoOutwardPassword, encryptPw, false );
			size := size + 1;
			continue;
		
		endif;
		
		if rawPw &lt;&gt; null then
			encryptPw := app.pwEnCode( rawPw );
		endif;
		cmObj.setProxyPw( encryptPw, null );
		size := size + 1;
	endforeach;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " " &amp; size.String &amp; " passwords encrypted", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" " &amp; size.String &amp; " passwords encrypted") ;
	endif;
	
	self.addScriptRun(method.name);

epilog

	delete objArray;

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="fixBadScanReaderETDef" id="c24936ee-4fa9-407d-aece-d04155d38e7e">
        <source>fixBadScanReaderETDef(_controller: CnEcReleaseController);
/*

Purpose:			The ETDef_ScanReader was originally part of the "ScanReader" Group and then changed to the "LaneDevicesMaint" group a few releases later
					This breaks with a duplicate key error, so lets avoid that by deleting the 'old' group just before the ET constants get reloaded.

Parameters:			

Return Value:		

Date				Who		Reason
14 February 2023	navmd1	Initial creation TFS 56560 POB - Fix Scan Reader ETDef belonging to multiple groups over various releases

*/

vars
	etRoot : EntTableDataRoot;
	etDef : EntTableDef;
	msg : String;
begin
	msg := "Fixing up ETDef_ScanReader object prior to EntTableDefs being reloaded";

	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " " &amp; msg &amp; " Starting", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(msg &amp; " Starting");
	endif;	
	
	etRoot := app.myRoot.myEntTableDataRoot;
	if etRoot = null then
		// Running in a starterDB, EntTableDataRoot might not be set up yet.
		// So, we never need to fix up anything old, so never run again
		self.addScriptRun(method.name);
		return;
	endif;
	
	etDef := etRoot.allEntTableDefs["ScanReader"];
	if etDef = null then
		// Huh? Might be renamed in the future I guess ?
		self.addScriptRun(method.name);
		return;
	endif;
	
	if etDef.myEntTableGroup &lt;&gt; null and etDef.myEntTableGroup.name = "ScanReader" then
		app.writeLog(method.qualifiedName &amp; " Bad EntTableDef found, deleting", LogINFO);
		if _controller &lt;&gt; null then
			_controller.logEntry(msg &amp; " Bad EntTableDef found, deleting");
		endif;
		
		beginTransaction;
		delete etDef;
		commitTransaction;
	endif;

	app.writeLog(method.qualifiedName &amp; " " &amp; msg &amp; " Finished", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(msg &amp; " Finished");
	endif;	
	
	self.addScriptRun(method.name);
epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="invoiceStatusColour" id="c3c7e078-a280-4787-9d33-0e4e5384b28d">
        <source>invoiceStatusColour(_controller: CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 NOV 2022 navtnr20  CR 55298 TASK 55547: Write upgrade script to set new colour attribute on CM_InvoiceStatus

*/

vars
	invoice : CM_InvoiceStatus;
	invoicecate: CM_Invoice;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " InvoiceStatus  color default ", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("InvoiceStatus  color default ") ;	
	endif;
	
	beginTransaction;
		foreach invoice in CM_InvoiceStatus.instances  do
			invoice.setColour(White);
		endforeach;
		foreach invoicecate in CM_Invoice.instances do
			invoicecate.setCategory(InvoiceCategory_Invoice);
		endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; "InvoiceStatus  color default completed ", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("  InvoiceStatus  color default completed ") ;	
	endif;	
	
	self.addScriptRun(method.name);

epilog

end;
</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="populateAllDebtorTerminals" id="73e0daf7-57cd-403a-a125-1a6f9d4a4d08">
        <source>populateAllDebtorTerminals(_updController : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
21 October 2022	navcs2	Bug 55202: SNO -- allDebtorTerminals collection is empty

*/

vars
	debtorNode				: CM_DebtorNode;
	paymentType			 	: Integer;					
	usesCash 				: Boolean;
	currencyType 			: CM_CurrencyType; 
	locale 					: CM_Locale; 		
	defaultInvoiceJRW 		: String;
	terminal				: CM_Terminal;
	theBank					: CM_Bank;
	rdg						: CM_RootDebtorGroup;
	allTerminals			: CM_TerminalByCodeDict;
begin
	if self.hasScriptBeenRunAtAll(method.name, _updController) then
		return;
	endif;
	
	
	app.writeLog(method.qualifiedName &amp; " Adding debtor terminals to all debtors", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry(" Adding debtor terminals to all debtors") ;	
	endif;
	
	theBank := app.myRoot.myRootCompany;
	rdg := theBank.getRootDebtorGroup();
	allTerminals := app.myRoot.allTerminals;
		
	foreach debtorNode in rdg.allChildDebtorNodes where debtorNode.isGroup = false do
				foreach terminal in allTerminals do
					if not debtorNode.CM_Debtor.allDebtorTerminals.includesKey( terminal ) then
						paymentType			:= PaymentType_None; 
						usesCash 			:= false;
						currencyType 		:= null; 	
						locale 				:= null; 
						defaultInvoiceJRW 	:= null; 

						beginTransaction;
						//debtorNode.CM_Debtor.createDebtorTerminal( terminal, usesCash, paymentType, currencyType, locale, defaultInvoiceJRW); 
						debtorNode.CM_Debtor.createDebtorTerminal( terminal, usesCash, paymentType, currencyType, locale, defaultInvoiceJRW, "", ""); //navra1 - TFS 57086 - 1st May 2023
						commitTransaction;
					endif;
			endforeach;
	endforeach;
	
	app.writeLog(method.qualifiedName &amp; " Adding debtor terminals to all debtors", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry(" Adding debtor terminals to all debtors") ;	
	endif;
	
	self.addScriptRun(method.name);
epilog

end;</source>
        <Parameter name="_updController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="populateAllTodoTaskDesc" id="e54568b9-af0b-4ed2-abf2-f81c6ee73a0d">
        <source>populateAllTodoTaskDesc(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 March 2023	navhl20	ChangeRequest 56614:[56616] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order

*/

vars
	todo : CM_WodToDo;
	todoTaskDesc : CM_ToDoTaskDesc;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Populate allToDoTasksDescs from myToDoTaskDesc", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Populate allToDoTasksDescs from myToDoTaskDesc") ;	
	endif;
	
	beginTransaction;
	     foreach todo in CM_WodToDo.instances do
			todoTaskDesc := todo.myToDoTaskDesc;
			 if todoTaskDesc &lt;&gt; null then
				todo.allToDoTasksDescs.addNoDuplicates(todoTaskDesc,false);
			 endif;
		 endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Populated allToDoTasksDescs from myToDoTaskDesc complete", LogINFO);
	
	if _controller &lt;&gt; null then
		_controller.logEntry(" Populated allToDoTasksDescs from myToDoTaskDesc complete");
	endif;
	
	self.addScriptRun(method.name);
epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="populateAllVehicleBookingSlots" id="ecd516fd-009e-4463-8cb8-cc3d8c3fde2f">
        <source>populateAllVehicleBookingSlots(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 March 2023	navpw1	Initial creation TFS: 54049 (55839)

*/

vars
	vehicleVisit : CM_VehicleVisitRecord;
	vbts : CM_VehicleBookingTimeSlot;
	
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;

	app.writeLog(method.qualifiedName &amp; " Populating Vehicle Booking Slots for Vehicle Visit", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Populating Vehicle Booking Slots for Vehicle Visit") ;	
	endif;
	
	beginTransaction;
	foreach vbts in CM_VehicleBookingTimeSlot.instances do
		
		vehicleVisit := vbts.myVehicleVisitRecord;
		
		if vehicleVisit = null then
			continue;
		endif;
		
		vehicleVisit.allVehicleBookingSlots.addNoDuplicates(vbts, false);
		
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Populating Vehicle Booking Slots for Vehicle Visit complete", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("  Populating Vehicle Booking Slots for Vehicle Visit complete") ;	
	endif;
	
	self.addScriptRun(method.name);
	
end;</source>
