    <JadeMethod name="doMnuContextDetailBuild" id="8cf242ea-7457-4a28-b46e-a8fe3d8893d4">
        <source>doMnuContextDetailBuild();
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.mnuDetailInspect.visible := app.isAllowedToInspect();
	self.mnuDetailInspect.userObject := self.myCurrentDetailObject;
	
	if self.mode = self.Mode_New or self.mode = self.Mode_Edit then
		self.mnuDetailOrganiser.visible := false;
	else 
		self.mnuDetailOrganiser.visible := true;
	endif;
		
	self.mnuDetailOrganiser.userObject := self.tblDataDetail;
end;</source>
