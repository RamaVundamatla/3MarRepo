    <JadeMethod name="doHideShowFailToPlan" id="3e44c828-d1be-48c8-bbd5-a40a7406bb99">
        <updating/>
        <source>doHideShowFailToPlan() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 November 2010	cnwer1	Initial creation

*/

vars

begin
	 if self.xmlFTP then
		if not self.dkbMacro.visible then 
			self.dkcExtraInfo.visible := false;
		endif;
		
		self.dkbCargoPic.visible := false;
	else
		if not self.dkcExtraInfo.visible then 
			self.dkcExtraInfo.visible := true;
		endif;

		self.dkbCargoPic.alignContainer := JadeDockBase.AlignContainer_Right;
		self.dkbCargoPic.visible := true;
	
		// We need to set this here, after the control has been positioned, so that if an adjacent
		// frame is hidden, then this frame consumes the freed-up space in the parent container
		self.dkbCargoPic.alignContainer := JadeDockBase.AlignContainer_AllVertical;
	endif;

	self.doResize();
	
	if self.dkbCargoPic.visible then
		if self.tblFailAutoPlan.myForm = null then
			self.tblFailAutoPlan.setForm(self);
			self.tblFailAutoPlan.initialise();
		endif;
		//10 Jan 2012	NDL	Par 28953
		if self.tblFailRequest.myForm = null then
			self.tblFailRequest.setForm(self);
			self.tblFailRequest.initialise();
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMachWorkzoneFindLinkOverlap" id="ba71ceb7-ed91-4500-ab35-b37e0b640471">
        <updating/>
        <source>doMachWorkzoneFindLinkOverlap(	_startX,
								_adjustment,
								_rectLeft,
								_rectWidth : Real;
								_cmifMachineWorkzone : CMIF_MachineWorkzone input;
								_resizingLeft : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 October 2009	cnwer1	Initial creation par 20853

*/

vars
	allOtherMachineWorkzones : ObjectArray;
	obj : Object;
	otherMachineWorkzone : CMIF_MachineWorkzone;
begin
	create allOtherMachineWorkzones transient;
	self.myCurrentDrawingController.YRD_GridOViewDrawingController.findOtherMachineWorkzones(_startX,_adjustment,_cmifMachineWorkzone,allOtherMachineWorkzones, not _resizingLeft,_resizingLeft);
		
	//this is not quite right if there are more than 2 RMG's overlapping

	//when resising right want to iter through this collection in reverse order
	
	if _resizingLeft then
		
		foreach obj in allOtherMachineWorkzones  do
			otherMachineWorkzone:=obj.CMIF_MachineWorkzone;
			if self.doMachWorkzoneLinkOverlap(_cmifMachineWorkzone,_rectLeft,_rectWidth,_adjustment,otherMachineWorkzone) then
				break;
			endif;
		endforeach;	
	else	
		foreach obj in allOtherMachineWorkzones  reversed do
			otherMachineWorkzone:=obj.CMIF_MachineWorkzone;
			if self.doMachWorkzoneLinkOverlap(_cmifMachineWorkzone,_rectLeft,_rectWidth,_adjustment,otherMachineWorkzone) then
				break;
			endif;
		endforeach;	
	endif;
epilog
	delete allOtherMachineWorkzones;
end;</source>
        <Parameter name="_startX" type="Real"/>
        <Parameter name="_adjustment" type="Real"/>
        <Parameter name="_rectLeft" type="Real"/>
        <Parameter name="_rectWidth" type="Real"/>
        <Parameter name="_cmifMachineWorkzone" type="CMIF_MachineWorkzone" usage="input"/>
        <Parameter name="_resizingLeft" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMachWorkzoneLinkOverlap" id="609a8a37-6342-4c4a-930b-5e86c0f164a2">
        <updating/>
        <source>doMachWorkzoneLinkOverlap(	_currentWorkzone : CMIF_MachineWorkzone input;
							_rectLeft,
							_rectWidth,
							_rectAdjustment : Real;
							_overlapWorkzone : CMIF_MachineWorkzone input ) : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 September 2009	cnwer1	Initial creation

*/

vars
	
	currentRect,
	overlapWorkZoneFrame : CMUI_ResizableRectFrame;
	oldLinkedWorkzone : CMIF_MachineWorkzone;
	foundLink : Boolean;
begin
	
	currentRect:=_currentWorkzone.myWorkzoneFrame.CMUI_ResizableRectFrame;
	overlapWorkZoneFrame:=_overlapWorkzone.myWorkzoneFrame.CMUI_ResizableRectFrame;
	if overlapWorkZoneFrame = null or currentRect = null then
		return false;
	endif;
	
	foundLink :=false;
	
	oldLinkedWorkzone:=_currentWorkzone.myLinkedMachineWorkzone;
	
	if  currentRect.resizingLeft or currentRect.resizingTop then
		if overlapWorkZoneFrame.getAdjustedRight + _rectAdjustment  &gt;= _rectLeft then
			overlapWorkZoneFrame.setResizingRight(true);
			foundLink:=true;
		endif;
	elseif currentRect.resizingRight or currentRect.resizingBottom then

		if overlapWorkZoneFrame.getAdjustedLeft -  _rectAdjustment &lt;= _rectLeft + _rectWidth then		
			overlapWorkZoneFrame.setResizingLeft(true);
			foundLink:=true;
		endif;
	endif;
	
	if foundLink  then
		_currentWorkzone.myLinkedMachineWorkzone:=_overlapWorkzone;
		if _currentWorkzone.rotated90 then
			_currentWorkzone.linkedLeft:=not currentRect.resizingTop;
		else
			_currentWorkzone.linkedLeft:=not currentRect.resizingLeft;
		endif;
		
		if oldLinkedWorkzone &lt;&gt; null and _overlapWorkzone &lt;&gt;  oldLinkedWorkzone then
			self.doMachWorkzoneSave(oldLinkedWorkzone,true);
			oldLinkedWorkzone.myWorkzoneFrame.CMUI_ResizableRectFrame.setResizingRight(false);
			oldLinkedWorkzone.myWorkzoneFrame.CMUI_ResizableRectFrame.setResizingLeft(false);
		endif;
		return true;
	else
	
		return false;
	endif;
epilog

end;</source>
        <Parameter name="_currentWorkzone" type="CMIF_MachineWorkzone" usage="input"/>
        <Parameter name="_rectLeft" type="Real"/>
        <Parameter name="_rectWidth" type="Real"/>
        <Parameter name="_rectAdjustment" type="Real"/>
        <Parameter name="_overlapWorkzone" type="CMIF_MachineWorkzone" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMachWorkzonePaint" id="c521684b-a16a-42b1-b7a5-921f59cc4c88">
        <source>doMachWorkzonePaint(_cmifMachineWorkzone :CMIF_MachineWorkzone input );
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 Aug 2009	cnwer1	Initial creation
18 Mar 2010 cnwer1	Par 20849
01 Sep 2011 cnwer1  par 28068 
*/

vars
	rect : CMUI_ResizableRectFrame;
	theColour : Integer;
	startX,endX,startY,endY,
	startXLabel,
	endXLabel : Real;
	lineTop : Real;
	textWidth,
	endBoxWidth: Integer;
	machId		: String;
begin
	
	if _cmifMachineWorkzone = null then
		return;
	endif;
	
	
	rect:=_cmifMachineWorkzone.myWorkzoneFrame.CMUI_ResizableRectFrame;

	
	theColour:=_cmifMachineWorkzone.myMachine.colour;
	
	if self.myCurrentDrawingController = null then
		return;	
	endif;
	if _cmifMachineWorkzone.lineTopPosition = null then
		//get the position 
		_cmifMachineWorkzone.lineTopPosition:=self.myCurrentDrawingController.YRD_GridOViewDrawingController.getMachineWorkzoneLinePos(_cmifMachineWorkzone);
	endif;

	//set default values
	rect.drawWidth:=(2*self.myCurrentDrawingController.scaleFactor).max(2).Integer;
	rect.boundaryWidth:=0;
	rect.transparent:=true;
	rect.visible:=true;	
	rect.drawTextAlign:=Form.DrawTextAlign_Center;
	rect.drawFontSize:=self.myCurrentDrawingController.getFontSizeLabel ;//self.myCurrentDrawingController.getFontSizeRowColHeading-2;
	rect.drawFontName:=self.myDrawingFrame.drawFontName;
	rect.drawFontBold:=true;
	
	//epr par 28068 1/9/11
	if _cmifMachineWorkzone.rotated90 then
		machId:=_cmifMachineWorkzone.myMachine.id.padWithSpaces;
	else
		machId:=_cmifMachineWorkzone.myMachine.id;
	endif;
	//epr 18/3/10 par 20849 machine labels were not resizing with zoom   * by a magic number seems to work
	textWidth:=rect.getTextExtent(machId ) + ((8* self.myCurrentDrawingController.scaleFactor)  + (self.myCurrentDrawingController.getSpaceForDifferentFonts(1) * self.myCurrentDrawingController.scaleFactor)).Integer;
		
	startX:=0;
	endX:=0;
	startY:=0;
	endY:=0;
	endBoxWidth:=(rect.drawWidth);
	if not _cmifMachineWorkzone.rotated90 then
		lineTop:= ((rect.clientHeight+ rect.drawWidth)/2)  ;
		startX:=1;

		endX:=rect.clientWidth-(rect.drawWidth -1);
		endX:=endX.min(rect.clientWidth-1);
		endY:=rect.height;
		
		lineTop:=lineTop + (_cmifMachineWorkzone.lineTopPosition * rect.drawWidth); 
		//draw left line
		rect.drawRectangle(startX,0, startX+endBoxWidth ,endY, theColour);

		//draw right line
		rect.drawRectangle(endX,startY, endX-endBoxWidth ,endY ,theColour);
		//draw the line
	
		startXLabel:=((rect.clientWidth/2) - (textWidth/2)).Integer;
		endXLabel :=((rect.clientWidth/2) + (textWidth/2)).Integer;
		
		//draw the line to start of zone to start of label
		rect.drawLine(0+endBoxWidth,lineTop,startXLabel, lineTop , theColour);
		//draw the line from end of label to end of zone
		rect.drawLine(endXLabel,lineTop,rect.clientWidth-endBoxWidth, lineTop , theColour);
		
		rect.drawTextIn(machId,startXLabel,0,endXLabel,rect.height,theColour);
		
	else
		lineTop:= (rect.clientWidth+rect.drawWidth)/2;
		startX:=0;
		endX:=rect.clientWidth;
		startY:=1;
	
		endY:=rect.clientHeight-(rect.drawWidth -1);
		endY:=endY.min(rect.clientHeight-1);
		lineTop:=lineTop + (_cmifMachineWorkzone.lineTopPosition * rect.drawWidth); 
		//draw top line
		rect.drawRectangle(startX,startY, endX ,startY+endBoxWidth, theColour);
		
		//draw  bottom line
		rect.drawRectangle(startX,endY, endX ,endY-endBoxWidth,  theColour);
		
		rect.drawTextRotation:=270;
		
		startXLabel:=((rect.clientHeight/2) - (textWidth/2));
		endXLabel:=((rect.clientHeight/2) + (textWidth/2) + (8* self.myCurrentDrawingController.scaleFactor));
		
		//draw the line to start of zone to start of label
		rect.drawLine(lineTop,startY+endBoxWidth, lineTop, startXLabel, theColour);
		
		//draw the line from end of label to end of zone
		rect.drawLine(lineTop,startY+endXLabel, lineTop, endY -endBoxWidth, theColour);
		
		//draw machine label
		rect.drawTextAlign:=Form.DrawTextAlign_Left;
		rect.drawTextAt(machId,lineTop,startXLabel,theColour);
	endif;
epilog

end;</source>
        <Parameter name="_cmifMachineWorkzone" type="CMIF_MachineWorkzone" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMachWorkzoneResizing" id="893c669a-6456-4337-9a88-837533d3bab9">
        <updating/>
        <source>doMachWorkzoneResizing(_rect: CMUI_ResizableRectFrame input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 September 2009	cnwer1	Initial creation

*/

vars
	cmifMachineWorkzone :CMIF_MachineWorkzone;
	otherWorkZoneFrame : CMUI_ResizableRectFrame;
	x ,newWidth, newLeft: Real;
	rectLeft,
	adjustment,
	rectWidth : Real;
begin
	rectLeft:=_rect.getAdjustedLeft;
	rectWidth:=_rect.getAdjustedWidth;
	
	if self.myCurrentDrawingController = null then
		return;
	endif;
	
	cmifMachineWorkzone:=_rect.userObject.CMIF_MachineWorkzone;
	if cmifMachineWorkzone = null then
		return;
	endif;	
	
	_rect.zOrder(1);
	
	
	if _rect.resizingLeft or _rect.resizingTop then
		x:=rectLeft;
		
		
	elseif _rect.resizingRight or _rect.resizingBottom  then
		x:=rectLeft + rectWidth;
		adjustment:= (_rect.getAdjustedOrigLeft  + _rect.getAdjustedOrigWidth) - x ;
		//epr par 20853 12/10/09
		//never set the adjustment less than the start left point because we want to find all zones to the left of us if we start looking before our left 
		// then we will find zones to the right of us 
		if x - adjustment &lt; rectLeft then
			adjustment:=x-rectLeft;
		endif;
	endif;

	if adjustment &lt; 0 then
		adjustment:=0;
	endif;

	
	adjustment:=adjustment + _rect.drawWidth;
	
	
	self.doMachWorkzoneFindLinkOverlap(x,adjustment,rectLeft,rectWidth,cmifMachineWorkzone,_rect.resizingLeft or _rect.resizingTop);
	
	
	if  cmifMachineWorkzone.myLinkedMachineWorkzone &lt;&gt;  null then
		otherWorkZoneFrame:=cmifMachineWorkzone.myLinkedMachineWorkzone.myWorkzoneFrame.CMUI_ResizableRectFrame;
		if  cmifMachineWorkzone.linkedLeft then
			
			if rectLeft + rectWidth &lt;= otherWorkZoneFrame.getAdjustedLeft then
				newLeft:=rectLeft + rectWidth;
				newWidth:=otherWorkZoneFrame.getAdjustedWidth + (otherWorkZoneFrame.getAdjustedLeft - newLeft);
				otherWorkZoneFrame.setAdjustedLeft(newLeft);
				otherWorkZoneFrame.setAdjustedWidth(newWidth);
				
			endif;

		else
			if rectLeft &gt;= otherWorkZoneFrame.getAdjustedRight then
				newWidth := rectLeft - otherWorkZoneFrame.getAdjustedLeft;
				otherWorkZoneFrame.setAdjustedWidth(newWidth);
			endif;
		endif;
	
	endif;
	
epilog
	_rect.zOrder(1);

end;</source>
        <Parameter name="_rect" type="CMUI_ResizableRectFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMachWorkzoneSave" id="eac5d817-cefc-42d5-b8f4-b824263d23c3">
        <updating/>
        <source>doMachWorkzoneSave(_cmifMachineWorkzone : CMIF_MachineWorkzone input; _overrideNoNote : Boolean) updating;


/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 August 2009	cnwer1	Initial creation
28 Oct 2009		cnwer1 par 21284
*/

vars
	colWidth : Integer;
	rect : CMUI_ResizableRectFrame;
	startY,
	endY,
	startX,
	endX : Real;
	closestX,
	newLeft,
	x1,x2, y1,y2,
	newWidth: Real;
	tmpIterator : Iterator;
	obj  : Object;
	gridColumn : CM_GridColumn;
	tmpGridColumn : CM_GridColumn;			// 25/11/2010 cnwmh5 #26338
	found : Boolean;
	origMachineWorkzone  : CMIF_MachineWorkzone;
	needNote : Boolean;
	machine : CM_Machine;
	result : Integer;
begin
	
	if self.myCurrentDrawingController = null then
		return;
	endif;
	if _cmifMachineWorkzone = null then
		return;
	endif;
	
	machine:=_cmifMachineWorkzone.myMachine;
	rect:=_cmifMachineWorkzone.myWorkzoneFrame.CMUI_ResizableRectFrame;
	
	colWidth:=	self.myCurrentDrawingController.getColumnWidthForScale.Integer;
	//get the bottom column row
	
	// top less the stats 
	endY:=(rect.getAdjustedTop - self.myCurrentDrawingController.getRowHeightForScale  - rect.thickness);
	//I have stored the number of rows in the RTG area that this workzone relates to in the frame tag
	// i can then work out the top row position
	startY:=(endY-(self.myCurrentDrawingController.getRowHeightForScale * _cmifMachineWorkzone.getNumberOfRows));
	
	if rect.resizingLeft or rect.resizingTop then
		// just the rect left
		startX:=rect.getAdjustedLeft;
		//don't let users save with a 0 column width workzone epr par 20853 12/10/09
		if rect.getAdjustedWidth &lt; colWidth then
			startX:=((rect.getAdjustedRight)-colWidth);
		endif;
	elseif rect.resizingRight or rect.resizingBottom then
		// because the iter starts a Geq need to plus the rect width
		startX:=rect.getAdjustedRight ;
		//don't let users save with a 0 column width workzone epr par 20853 12/10/09
		if rect.getAdjustedWidth &lt; colWidth then
			startX:=(rect.getAdjustedLeft+colWidth);
		endif;
	endif;		

	tmpIterator := self.myCurrentDrawingController.allGridObjects.createIterator;
	// because the iter starts a Geq need to minus the column width

	if _cmifMachineWorkzone.rotated90 then
		self.myCurrentDrawingController.allGridObjects.startKeyGeq(startY.Integer ,(startX-colWidth).Integer,0,0,tmpIterator);
	else
		self.myCurrentDrawingController.allGridObjects.startKeyGeq((startX-colWidth).Integer,startY.Integer,0,endY.Integer,tmpIterator);
	endif;
	
	while tmpIterator.next(obj) do
		
		if not obj.isKindOf(CM_RTGController) then
			continue;
		endif;
		 
		if not machine.allowedTAMasters.includes(obj.CM_RTGController.getMyGridArea) then
			continue;
		endif;
		
		self.myCurrentDrawingController.allGridObjects.getIteratorKeys(x1, y1, x2, y2,tmpIterator);
		
		if  _cmifMachineWorkzone.rotated90 then
			
			if x1 &gt;= startY and
				x1 &lt;=endY and
				y1 &gt;= (startX -colWidth) then
				found:=true;
				break;
			endif;
		else
			if x1 &gt;= (startX -colWidth) and
			   y1 &gt;= startY and
			   y1 &lt;= endY    then
				found:=true;
				break;
			endif;
		endif;
	endwhile;	
	

	//gone off the end
	if not found then
		tmpIterator.reset;
		if _cmifMachineWorkzone.rotated90 then
			self.myCurrentDrawingController.allGridObjects.startKeyLss((startY+colWidth).Integer,startX.Integer,0,0,tmpIterator);
		else
			self.myCurrentDrawingController.allGridObjects.startKeyLss(startX.Integer,startY.Integer,0,endY.Integer,tmpIterator);
		endif;
		while tmpIterator.back(obj) do
			if not obj.isKindOf(CM_RTGController) then
				continue;
			endif;
		
			if not machine.allowedTAMasters.includes(obj.CM_RTGController.getMyGridArea) then	
				continue;
			endif;
			
			self.myCurrentDrawingController.allGridObjects.getIteratorKeys(x1, y1, x2, y2,tmpIterator);
			if  _cmifMachineWorkzone.rotated90 then
				if x1 &gt;= startY and
					x1 &lt;=endY and
					y1 &lt;= startX then
					found:=true;
					break;
				endif;
			else
				if x1 &lt;= startX and
				   y1 &gt;= startY and
				   y1 &lt;= endY   then
					found:=true;
					break;
				endif;
			endif;
		endwhile;
	endif;
	
	if not found or obj = null then
		self.myCurrentDrawingController.YRD_GridOViewDrawingController.drawRTGMachinesWorkzone(_cmifMachineWorkzone);
		return;
	endif;

	// Get Closet column to snap to 
	gridColumn:=obj.CM_GridController.myGridColumn;
	
	//get the closest x position to snap to -- becomes problematic when x is not with in an RTG/RMG area		
	if ((rect.resizingRight  and not _cmifMachineWorkzone.flippedHorizontal) and (gridColumn.myGridArea.allGridColumns.first =  gridColumn)) then
		closestX:= x2;
	elseif ((rect.resizingRight and  _cmifMachineWorkzone.flippedHorizontal) and (gridColumn.myGridArea.allGridColumns.last =  gridColumn)) then	
		closestX:= x2;
	elseif ((rect.resizingBottom and not _cmifMachineWorkzone.flippedVertical) and gridColumn.myGridArea.allGridColumns.first =  gridColumn) then
		closestX:=y2;
	else
		
		if _cmifMachineWorkzone.rotated90 then
		
			if (startX - y1) &lt; (y2 - startX) then
				closestX:= y1;
				if rect.resizingBottom and not _cmifMachineWorkzone.flippedVertical then
					//gridColumn:=gridColumn.getPreviousColumn;
					self.getValidGridColumn(gridColumn, gridColumn.getPreviousColumn());	// 26/11/2010 cnwmh5 #26338
				elseif rect.resizingBottom and _cmifMachineWorkzone.flippedVertical then
					//if gridColumn.getNextColumn &lt;&gt; null then
					//	gridColumn:=gridColumn.getNextColumn ;
					//endif;
					self.getValidGridColumn(gridColumn, gridColumn.getNextColumn());		// 26/11/2010 cnwmh5 #26338
				endif;
			else
				closestX:= y2;
				if rect.resizingTop and not _cmifMachineWorkzone.flippedVertical then
					//gridColumn:=gridColumn.getNextColumn ;
					self.getValidGridColumn(gridColumn, gridColumn.getNextColumn());		// 26/11/2010 cnwmh5 #26338
				elseif rect.resizingTop and _cmifMachineWorkzone.flippedVertical then
					//if gridColumn.getPreviousColumn &lt;&gt; null then
					//	gridColumn:=gridColumn.getPreviousColumn;
					//endif;
					self.getValidGridColumn(gridColumn, gridColumn.getPreviousColumn());	// 26/11/2010 cnwmh5 #26338
				endif;
			endif;
		else
			if (startX- x1) &lt; (x2 - startX) then
				closestX:= x1;
				if rect.resizingRight and not _cmifMachineWorkzone.flippedHorizontal then
					//gridColumn:=gridColumn.getPreviousColumn;
					self.getValidGridColumn(gridColumn, gridColumn.getPreviousColumn());	// 26/11/2010 cnwmh5 #26338
				elseif rect.resizingRight and _cmifMachineWorkzone.flippedHorizontal then
					//gridColumn:=gridColumn.getNextColumn;
					self.getValidGridColumn(gridColumn, gridColumn.getNextColumn());		// 26/11/2010 cnwmh5 #26338
				endif;
			else
				closestX:= x2;
				if rect.resizingLeft and not _cmifMachineWorkzone.flippedHorizontal then
					//gridColumn:=gridColumn.getNextColumn;
					self.getValidGridColumn(gridColumn, gridColumn.getNextColumn());		// 26/11/2010 cnwmh5 #26338
				elseif rect.resizingLeft and _cmifMachineWorkzone.flippedHorizontal then
					//gridColumn:=gridColumn.getPreviousColumn;
					self.getValidGridColumn(gridColumn, gridColumn.getPreviousColumn());	// 26/11/2010 cnwmh5 #26338
				endif;
			endif;
		endif;
	endif;
	
	//update the CMIF with the found column	
	if rect.resizingLeft or rect.resizingTop then
		_cmifMachineWorkzone.setMyStartColumn(gridColumn.CM_RTGColumn,needNote);
		newLeft:=closestX;
		newWidth:=rect.getAdjustedRight.Integer-newLeft;
		if _cmifMachineWorkzone.rotated90 then
			rect.move(rect.left,newLeft,rect.width,newWidth);
		else
			rect.move(newLeft,rect.top,newWidth,rect.height);
		endif;
		if startX &lt;&gt; newWidth then
			app.mousePointer := Window.MousePointer_Default;
		endif;
		
	elseif rect.resizingRight or rect.resizingBottom then
		
		_cmifMachineWorkzone.setMyEndColumn(gridColumn.CM_RTGColumn,needNote);
		newLeft:=rect.getAdjustedLeft.Integer;
		newWidth:=closestX - rect.getAdjustedLeft.Integer;
		if _cmifMachineWorkzone.rotated90 then
			rect.move(rect.left,newLeft,rect.width,newWidth);
		else
			rect.move(newLeft,rect.top,newWidth,rect.height);
		endif;
		if startX &lt;&gt; newWidth then
			app.mousePointer := Window.MousePointer_Default;
		endif;
		
	endif;

	//cnwjo3 par 24371
	if _cmifMachineWorkzone.myStartColumn = null or _cmifMachineWorkzone.myEndColumn = null then
		//strange start and end columns.  Best to break out
	endif;
	
	// see if anything has actually changed
	if not needNote then
		origMachineWorkzone:=machine.getCMIFMachineWorkzone;
		if origMachineWorkzone.myStartColumn.column = _cmifMachineWorkzone.myStartColumn.column and
			origMachineWorkzone.myEndColumn.column = _cmifMachineWorkzone.myEndColumn.column then
			//turns out nothing has changed can return
			return;
		endif;
	endif;
	
	//notes are sent but if we are updating we don't want the screen refreshing 
	//only need it updated by a note in special situations i.e. passed the physical limits for example
	if not needNote or _overrideNoNote then
		self.myCurrentDrawingController.notableObjectRemove(machine);
	endif;

	//cnwjo3 par 24124.  Worst case scenario.  notification never arrives to refresh screen so may need to prompt with warning during update.
	while true do
		app.myTrxUA.trxUpdateRTGMachineWorkzones(machine,_cmifMachineWorkzone.myStartColumn,_cmifMachineWorkzone.myEndColumn,app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog(_cmifMachineWorkzone.myMachine.id, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged := true;
				continue;
			endif;
			
			//we've hit 'cancel', put everything back!
			_cmifMachineWorkzone.myStartColumn:=origMachineWorkzone.myStartColumn;
			_cmifMachineWorkzone.myEndColumn:=origMachineWorkzone.myEndColumn;
			self.myCurrentDrawingController.YRD_GridOViewDrawingController.drawRTGMachinesWorkzone(_cmifMachineWorkzone);
			
		endif;
		break;
	endwhile;
				
	
	if  not needNote  or _overrideNoNote then
		self.myCurrentDrawingController.notableObjectAdd(machine);
	endif;
	
epilog
	delete tmpIterator;
	delete origMachineWorkzone;

end;</source>
        <Parameter name="_cmifMachineWorkzone" type="CMIF_MachineWorkzone" usage="input"/>
        <Parameter name="_overrideNoNote" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMnuCapacityClick" id="cc7b8181-3deb-4ff6-a86b-24319b16d8f6">
        <updating/>
        <source>doMnuCapacityClick() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 December 2020	jlgab1	Initial creation

*/

vars

begin
	self.myCurrentDrawingController.YRD_GridOViewDrawingController.showCapacity := not self.myCurrentDrawingController.YRD_GridOViewDrawingController.showCapacity;
	
	if self.myCurrentDrawingController.YRD_GridOViewDrawingController.showCapacity then
		self.mnuCapacity.caption := app.getErrorString(Show_labels);
	
	else
		self.mnuCapacity.caption := app.getErrorString(Show_capacity);
	endif;
	
	self.doRefresh();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuEnquiryClick" id="6fefd02d-fa1a-478b-9ea9-5f6f13cd24e7">
        <updating/>
        <source>doMnuEnquiryClick() updating;

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
21 April 2009		cnwrl1	Initial creation PAR 19463

*/
	
vars
	cm_ObjectArray	: CM_ObjectArray;
	obj				: Object;
begin
	create cm_ObjectArray transient;

	// 26/05/2010 cnwmh5 #23880 - Start
	foreach obj in self.locationControllerArray do
		obj.CM_LocationsController.allTrackedItems.copy(cm_ObjectArray);
	endforeach;
	
	if cm_ObjectArray.isEmpty then
		return;
	endif;
	// 26/05/2010 cnwmh5 #23880 - End
	
	self.myAssistant.showCargoEnquiryForm(	cm_ObjectArray[1].CM_TrackedItem,
											self.myMasterMenuAction,
											true,				// thumbnail only
											false );			// not in edit mode
	
epilog
	delete cm_ObjectArray;

end;	
</source>
    </JadeMethod>
    <JadeMethod name="doMnuGridBulkEnqClick" id="d8d95e1f-daac-48b2-86de-61cf640e2b99">
        <updating/>
        <source>doMnuGridBulkEnqClick( menuItem : MenuItem input ) updating;

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
17 April 2009		cnwrl1	Initial creation PAR 19463

*/
	
vars
	cm_ObjectArray	: CM_ObjectArray;
	obj				: Object;				// 26/05/2010 cnmwh5 #23880 
	ti				: CM_TrackedItem;		// 26/05/2010 cnwmh5 #23880
begin
	//+cnwml2 PAR24701
	self.setLocationControllerArray();
	if self.locationControllerArray = null or self.locationControllerArray.isEmpty  then
		return;
	endif;		
	
	create cm_ObjectArray transient;
	
	// 26/05/2010 cnwmh5 #23880 - Start
	// read through the location controllers and if tracked item and not in cm_ObjectArray add
	foreach obj in self.locationControllerArray discreteLock do
		foreach ti in obj.CM_LocationsController.allTrackedItems discreteLock do
			if not cm_ObjectArray.includes(ti) then
				cm_ObjectArray.add(ti);
			endif;
		endforeach;
	endforeach;
	
	// no tracked items found so return
	if cm_ObjectArray.isEmpty then
		return;
	endif;
	// 26/05/2010 cnwmh5 #23880 - End
	
	/*
	// 26/05/2010 cnwmh5 #23880 - removed
	if self.myCM_LocationsController = null or self.myCM_LocationsController.allTrackedItems.isEmpty then
		return;		// should never happen but if does just return at this point.
	endif;
	
	self.myCM_LocationsController.allTrackedItems.copy( cm_ObjectArray );
	*/
	
	self.myAssistant.showCargoEnquiryForTIs(	cm_ObjectArray[1].CM_TrackedItem,
												cm_ObjectArray,
												self.myMasterMenuAction,
												false );						// not in edit mode
	
epilog
	delete cm_ObjectArray;
	delete self.locationControllerArray;				//+cnwml2 PAR24701

end;	
</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuLcnPadMainClick" id="88b8ef2b-cbf6-4f97-8109-e7a3ea321dba">
        <updating/>
        <source>doMnuLcnPadMainClick(menuItem: MenuItem input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 September 2011	cnwndl1	Initial creation	Par 28236

*/

vars

	locCont : CM_LocationsController;
	theController : CM_GridController;
	theIndex : Integer;
	theMode, theValue : Integer;

begin

	if self.allSelectedRegionLocs.isEmpty then
		inheritMethod(menuItem);	// use the functionality defined in te super class.
		
	else
	
		theIndex := menuItem.helpContextId;
		
		//31 Jul 2017	NDL	TFS 5483 - Allowing it to continue ends up firing heaps of un-needed notes
		// which caus ecopoious re-drwaing of RTG pad areas.
		if theIndex = 0 then
			//nothing to do
			return;
		endif;
		
		if theIndex = MENU_INDEX_AVAIL then
			theMode := CMIF_GridTARegion.UpdateMode_LocationAvailable;
			theValue := PAD_AVAILABLE;
		elseif theIndex = MENU_INDEX_UNAVAIL then
			theMode := CMIF_GridTARegion.UpdateMode_LocationUnavailable;
			theValue := PAD_UNAVAILABLE;
		elseif theIndex = MENU_INDEX_POWER_BAD then
			theMode := CMIF_GridTARegion.UpdateMode_PowerDamaged;
			theValue := null;
		elseif theIndex = MENU_INDEX_POWER_GOOD then
			theMode := CMIF_GridTARegion.UpdateMode_PowerGood;
			theValue := null;
		elseif theIndex &gt; MENU_INDEX_NOTHING_BASE then
			theMode := CMIF_GridTARegion.UpdateMode_HeightRestriction;
			theValue := theIndex - MENU_INDEX_NOTHING_BASE + 2;
		endif;
		
		foreach locCont in self.allSelectedRegionLocs discreteLock do
			if locCont.isKindOf( CM_GridController ) then
				theController := locCont.CM_GridController;
				self.doMnuLcnPadHeights(theController,theMode, theValue);
			endif;
		endforeach;
	
	endif;

epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuPref1" id="9453e633-d875-4afd-a5c9-b2dba707e8e2">
        <updating/>
        <source>doMnuPref1() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 September 2011	cnwndl1	Initial creation	Par 28236
20 Oct 2011	NDL		Second entry to teh form not set correctly for Failed to Plan, RTG and YAM options...

*/

vars

	prefForm : YRD_SatViewPreferenceForm;
	
	preShowColour : Boolean;
	preShowFail : Boolean;
	preShowRTG : Boolean;
	preShowSelPanel : Boolean;
	preShowYAMTable : Boolean;
	preShowHeightRestrict : Integer;
	preShowDirections: Boolean;
begin
	
	preShowColour := not self.xmlLegend;
	preShowFail := not self.xmlFTP;
	preShowRTG := not self.xmlHideRTG;
	preShowSelPanel := not self.xmlSelector;
	preShowYAMTable := not self.xmlYAM;
	preShowHeightRestrict := self.xmlHeightRestrict;
	preShowDirections := not self.xmlDirections;		// 2/10/17 MAP TFS7084
	
	create prefForm transient;
	prefForm.populateDataValues(	self.dblClickAction,	//_dblClickAction : String; 
									preShowColour,	//_showColour : Boolean;
									preShowFail,	//_showFail : Boolean;
									preShowRTG,	//_showRTG : Boolean;
									preShowSelPanel,	//_showSelPanel : Boolean;
									preShowYAMTable,	//_showYAMTable : Boolean
									preShowHeightRestrict,
									preShowDirections);
	prefForm.showModal();
	
	if prefForm.modalResult = IDOK then
		//Check for changes we may need to refresh for
		if preShowColour &lt;&gt; prefForm.chkShowColour.value then
			self.xmlLegend := not self.xmlLegend ;
			self.doHideShowLegend();
		endif;
		if preShowFail &lt;&gt; prefForm.chkShowFail.value then
			self.xmlFTP := not self.xmlFTP;	//20 Oct 2011	NDL
			self.doHideShowFailToPlan();
		endif;
		if preShowRTG &lt;&gt; prefForm.chkShowRTG.value then
			self.xmlHideRTG := not self.xmlHideRTG;	//20 Oct 2011	NDL
			self.doHideShowRTG();
		endif;
		if preShowSelPanel &lt;&gt; prefForm.chkShowSelPanel.value then
			self.xmlSelector := not self.xmlSelector;
			self.doHideShowSelectorPanel();
		endif;
		if preShowYAMTable &lt;&gt; prefForm.chkShowYAMTable.value then
			self.xmlYAM := not self.xmlYAM;	//20 Oct 2011	NDL
			self.doHideShowYAM();
		endif;
		if preShowDirections &lt;&gt; prefForm.chkShowDirections.value then		// 2/10/17 MAP TFS7084
			self.xmlDirections := not self.xmlDirections;
			self.myCurrentDrawingController.YRD_GridOViewDrawingController.showAccessDirections := prefForm.chkShowDirections.value;
			self.doRefresh();
		endif;
		//epr par 33954 24/1/15
		if preShowHeightRestrict &lt;&gt; prefForm.cmbHeightRest.listData then
			self.xmlHeightRestrict:= prefForm.cmbHeightRest.listData;
			self.myCurrentDrawingController.YRD_GridOViewDrawingController.drawSelfAllChangeHeightRest(self.xmlHeightRestrict);
		endif;
		//And the new action
		if self.dblClickAction &lt;&gt; prefForm.cmbDoubleClick.text then
			self.dblClickAction := prefForm.cmbDoubleClick.text;
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuSummariseSelected" id="3c05e173-909a-4b9a-ada0-f5906f8a2862">
        <source>doMnuSummariseSelected();

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
16 February 2009	cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)
22/04/2009			cnwrl1	PAR 19463 - Satellite View changes

*/
	
vars
	coll				: ObjectSet;
	cm_TerminalArea		: CM_TerminalArea;
	
begin
	app.mousePointer	:= Busy;
	create coll transient;
	
	// Get a collection of all the objects (containers) for the SELECTED terminal ONLY to pass to the Summary Defn form.
	if self.myCM_LocationsController &lt;&gt; null and self.myCM_LocationsController.myTerminalArea &lt;&gt; null then
		cm_TerminalArea	:=  self.myCM_LocationsController.myTerminalArea.CM_TerminalArea;
		cm_TerminalArea.getAllLocationsTrackedItems( coll );
	endif;
	self.myAssistant.showXTABSummaryDefinitionForm( coll, false, false , false, true);
	
epilog
	delete coll;
	app.mousePointer	:= Idle;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="doNewYA" id="a50a816e-85a4-4bd9-a53b-a336522c97e2">
        <source>doNewYA(_useTrackedItem: Boolean);
//08 December 2008	cnwdw1	
//
vars
	trackedItem: CM_TrackedItem;
	newYA 		: CM_YardAllocation;
begin
	if _useTrackedItem then
		trackedItem := self.tblFailAutoPlan.getSelectedObject.myTrackedItem;
	endif;
	newYA:=self.tblYAM.openYAMaintForm(null, trackedItem, 0);
	
	if newYA &lt;&gt; null then
		if self.tblYAM.mySearchParameters.isMatchingYA( newYA ) then
			self.tblYAM.addItemYardAllocation(newYA);
		endif;
		self.tblYAM.clearAllSelected();
		self.tblYAM.selectObject(newYA,true);
	endif;
end;</source>
        <Parameter name="_useTrackedItem" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPositionAt" id="5752ae0d-f28b-4ea9-8b2a-88daabb9ae37">
        <updating/>
        <source>doPositionAt() updating;
//20 February 2009	cnwdw1	
//
vars
	ya: CM_YardAllocation;
	alert:CM_SystemAlert;
	obj	: Object;
begin
	//alert := self.tblFailAutoPlan.getSelectedObject();
	alert := self.getAlert();	//10 Jan 2012	NDL	Par 28953
	if alert &lt;&gt; null then
		obj := alert.getLinkedTo();
		if obj.isKindOf(CM_FailedToAutoplan) then
			ya := obj.CM_FailedToAutoplan.myFirstYAFailure;		// 27/04/2009 cnwar2 #19401, #19524, #19522
		elseif obj.isKindOf(CM_YardAllocation) then
			ya := obj.CM_YardAllocation;
		endif;
		if ya &lt;&gt; null then
			self.doSelectYA(ya);
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doPrintSatelliteView" id="9c67d36d-426c-4902-98f8-6fa89ba9eec4">
        <updating/>
        <source>doPrintSatelliteView() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 25/06/2020	jlgdap1		Initial creation TFS 49453 ASPA satellite View Screen for Flexible Terminal Areas
//
vars
	printOptions : YRD_SatelliteViewPrint;
	headerForm : CMUI_ReportLine;
	footerForm : CM_GenericTablePrint;
	jadeReport  : JadeReport;
	now : TimeStamp;
	pageWidth, pageHeight, pointerWidth, pointerHeight : Integer;
	viewPort, mainFrame : CMUI_Frame;
	viewBin : Binary;
	picView : Picture;

begin
	create printOptions transient;
	if printOptions.showModal = IDCANCEL then
		return;
	endif;

	self.picPrint.picture := null;
	self.picPrint.width := 1;
	self.picPrint.height := 1;
	app.mousePointer := MousePointer_HourGlass;
	
	app.printer.close;
	create headerForm transient;
	create footerForm transient;
	
	if app.printer.documentType = null then
		app.printer.documentType := app.printer.getDefaultDocumentType;
	endif;
	
	if printOptions.optLandscape.value then
		app.printer.orientation := Print_Landscape;
	else
		app.printer.orientation := Print_Portrait;
	endif;
	app.printer.suppressDialog := true;
	
	headerForm.initReport;
	headerForm.initReportForOrientation();
	headerForm.lblTitle01.caption := "Satellite View : ";
	headerForm.lblTitle03.caption := self.myTerminalAreaView.name;
	headerForm.lblTitle02.caption := null;
	headerForm.lblTitle04.caption := null;
	headerForm.lblPrintedBy.caption := null;
	headerForm.lblPrintedBylbl.caption := null;
	
	create jadeReport transient;
	jadeReport.description := self.caption;
	app.printer.setReport(jadeReport);
	
	app.printer.setMargins(app.printer.orientation,5,5,5,5);
	app.printer.setHeader(headerForm.frHeader);
	
	now := app.actualTimeServer;
	
	footerForm.frFooter.width := app.printer.pageWidth-20;
	footerForm.lblTheUser.caption := app.getMyUserCode;
	footerForm.lblTheDatePrinted.caption := self.systemToLocalTime(now).asStringJMT;
	app.printer.setFooter(footerForm.frFooter);

	pageWidth := app.printer.pageWidth;
	pageHeight := app.printer.pageHeight - footerForm.frFooter.clientHeight - headerForm.frHeader.clientHeight;
	
	viewPort := self.frmPrint.cloneSelf(true);	
	self.addControl(viewPort);
	viewPort.backColor := White;
	viewPort.transparent := false;
	viewPort.borderStyle := Control.BorderStyle_None;
	viewPort.visible := true;
	viewPort.autoRedraw := true;
	viewPort.left := 0;
	viewPort.top := 0;
	viewPort.width := pageWidth;
	viewPort.height := pageHeight;
	
	mainFrame := self.frmPrint.cloneSelf(true);
	mainFrame.parent := viewPort;
	mainFrame.left := 0;
	mainFrame.top := 0;
	self.addControl(mainFrame);
	mainFrame.transparent := true;
	mainFrame.borderStyle := Control.BorderStyle_None;
	mainFrame.visible := true;
	mainFrame.autoRedraw := true;
	
	// Use myDrawingFrame.parent so we print any yard alocation cross-hatching being displayed as well
	// (yard allocations are drawn on a frame overlaying myDrawingFrame)
	viewBin := self.myDrawingFrame.parent.createPictureAsType(false, true, 24, Window.PictureType_Png);
	picView := self.picPrint.cloneSelf(true);
	self.addControl(picView);
	picView.stretch := Picture.Stretch_ControlTo;
	picView.parent := mainFrame;
	picView.useImage(viewBin);
	picView.left := 0;
	picView.top := 0;
	
	mainFrame.height := picView.height;
	mainFrame.width := self.myDrawingFrame.width;
	
	if printOptions.optNormalSize.value then
		pointerHeight := 0;
		pointerWidth := 0;
		while true do
			mainFrame.left := -pointerWidth;
			mainFrame.top := -pointerHeight;
			viewPort.zOrder(1);
			app.printer.print(viewPort);
			pointerHeight := pointerHeight + pageHeight;
			if pointerHeight  &gt; mainFrame.height then
				//goBack to top
				if pointerWidth + pageWidth &gt; mainFrame.width then
					break;
				endif;
				pointerHeight := 0;
				pointerWidth := pointerWidth + pageWidth;
			endif;
		endwhile;
	elseif printOptions.optFitToPage.value then
		self.picPrint.stretch := Picture.Stretch_ToControl;
		self.picPrint.width := pageWidth;
		self.picPrint.height := pageHeight;
		self.picPrint.useImage(mainFrame.createPictureAsType(false, true, 24, Window.PictureType_Png));
		app.printer.printActive(self.picPrint);
	endif;
	
	app.printPreview(jadeReport, true);
	
	app.printer.close;
	
epilog
	delete viewPort;
	delete headerForm;
	delete footerForm;
	delete printOptions;
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
