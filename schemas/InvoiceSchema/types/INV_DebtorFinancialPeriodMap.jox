    <JadeMethod name="setEnableObjects" id="e164af72-810a-4b79-ad49-fbb802d7cad0">
        <source>setEnableObjects();

vars
	typeTable : Table;

begin
	typeTable := self.tblData;

	if typeTable.column &gt; 1 and typeTable.row &gt; 1 then
		self.mnuInvUpdate.enabled := true;
		self.btnEditItem.enabled := true;
	else
		self.mnuInvUpdate.enabled := false;
		self.btnEditItem.enabled := false;
	endif;

	self.btnPrint.enabled := true;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnEditItem.enabled := false;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setTableAlignment" id="f7bff9dd-188e-4444-91ab-54caf9d82d8d">
        <source>setTableAlignment();

vars

	saveRow:    Integer;
	saveColumn: Integer;
	row:        Integer;
	typeTable:  Table;

begin
	typeTable := self.tblData;

	saveRow := typeTable.row;
	saveColumn := typeTable.column;

	typeTable.accessMode := Table.AccessMode_Sheet;
	typeTable.alignment := Table.Alignment_Right;

	typeTable.accessMode := Table.AccessMode_Column;
	typeTable.column := 1;
	typeTable.alignment := Table.Alignment_Left;

	typeTable.accessMode := Table.AccessMode_Row;
	row := 1;
	while row &lt;= typeTable.fixedRows do
		typeTable.row := row;
		typeTable.alignment := Table.Alignment_Left;
		row := row + 1;
	endwhile;

	typeTable.accessMode := Table.AccessMode_Cell;
	typeTable.alignment := Table.Alignment_Right;

	typeTable.row := saveRow;
	typeTable.column := saveColumn;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="1bf50a6b-66f6-4a92-9422-df167de26ba5">
        <updating/>
        <source>setupForm() updating;

vars
	
begin
	self.useCtrlScroll := true;
	// 35872 get business unit from user if more than one
	self.myCurrentBank := self.myTerminal.getDefaultCompanyBank();
	self.mode := self.Mode_Debtor;
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.usesQueryFrame := true;
	self.useTableInfo := false;
	self.mnuContextColourLegend.visible := false;
	self.mnuColumnOrganiser.visible := false;
	self.mnuInvUpdate.visible := false;
	self.doCmbBankBuild();
	
	inheritMethod();

	self.fldQuery.topSheet := self.shtQuery1;
	self.doComboDebtorBuild();
	self.doCmbDebtorBuild();
	self.doCmbPeriodsBuild();
	self.doCmbTypesBuild();
	self.loadTypes();
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_MAPPING_CREATE), Response_Continuous, null);
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_MAPPING_DELETE), Response_Continuous, null);
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_MAPPING_UPDATE), Response_Continuous, null);
	
	self.setNavigatorHeading( self.caption );

	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnDelete.enabled := false;
		self.btnEditItem.enabled := false;

	endif;
end;</source>
    </JadeMethod>
