    <JadeMethod name="mode" id="dd1b9b8b-fc8c-4b7e-98a6-1b65a2f78231">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>mode(set: Boolean; _value: Integer io) mapping, updating, protected;

vars
	inputType	: Integer;
	row			: Integer;
	locale		: CM_Locale;
begin
	if set = false then
		return;
	endif;
	
	// hide the search frame
	if frmSearch.visible = true then
		frmSearch.visible := false;
	endif;
			
	if _value = Mode_Update then

		if self.myTranslatableText = null then
			app.msgBox('Cannot perform edit as there is no translatable text selected.', 'Error', MsgBox_Stop_Icon  + MsgBox_OK_Only);	
			_value := Mode_View;
			return;
		endif;

		lMode.caption := 'Edit';
		inputType := Table.InputType_TextBox;
		tblTranslations.setFocus;
	else
		lMode.caption := 'View';
		inputType := Table.InputType_None;
	endif;	

	if self.isDeveloperMode then
		lMode.caption := ' Developer - ' &amp; lMode.caption;
	endif;

	btnSaveBase.enabled 	:= _value = Mode_Update;
	btnCancelBase.enabled 	:= _value = Mode_Update;		
	btnEdit.enabled 		:= (_value = Mode_View) and (app.myPassport.myUser.canDo(app.myPassport.myTerminal, self.permissionMaint) );  //par 21296
	btnSearch.enabled 		:= _value = Mode_View;

	
	// set table input type (TextBox or None) depending on mode.
	setTranslationTableInputType(inputType);
end;</source>
        <access>protected</access>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
