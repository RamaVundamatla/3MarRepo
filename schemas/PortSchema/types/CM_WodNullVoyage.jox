    <JadeMethod name="validate" id="4a985299-c8c6-47ba-bfb4-0c373fc89306">
        <source>validate() protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/05/2018	jlgdap1		Initial creation TFS 38501 PEL1 Work Order Changes
// 26 May 2022	navma1		ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
// 12 Apr 2023  navma1 		ChangeRequest 57569:[57570] EUP - [Framework] Refactor Actioning Work Order Tasks
//
vars

begin
	inheritMethod();
	
	if self.myNewVoyage = null then	//12.04.2023 navma1 #57569:[57570]
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Voyage), null, null); 
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateForApproval" id="e15fc975-b8aa-447d-9c89-7d6e2457e169">
        <source>validateForApproval();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/05/2018	jlgdap1		Initial creation TFS 38501 PEL1 Work Order Changes
//
vars

begin
	inheritMethod();
	
	if self.myNewVoyage = null then
		app.raiseCMException2(Work_order_task_require, self.getDisplayString(true), app.getErrorString(Voyage), null, null);
	endif;
epilog

end;</source>
    </JadeMethod>
