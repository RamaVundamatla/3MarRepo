        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="23924c2d-4639-4960-8ac8-1ec640000b88">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 24 August 2015.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0020804, locale);
	lblCargoGroupId.translateCaption(Xlat_0020805, locale);
	lblCountValue.translateCaption(Xlat_0020806, locale);
	lblMaxWeight.translateCaption(Xlat_0020807, locale);
	lblMinWeight.translateCaption(Xlat_0020808, locale);
	lblWeightValue.translateCaption(Xlat_0020809, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtCargoGroupId_gotFocus" id="934bd9c7-22a2-4e35-bcd0-414d65248745">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoGroupId_gotFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2015	cnwndl1	Initial creation	Par 36608

*/

vars

begin

	if self.txtCargoGroupId.text = self.lblCargoGroupId.caption.toUpper then
		self.txtCargoGroupId.selStart := 0;
		self.txtCargoGroupId.selLength := self.lblCargoGroupId.caption.length;
	endif;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtCargoGroupId_lostFocus" id="c3f51f0f-83b1-4642-a8a0-0f5ac9c1f947">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoGroupId_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2015	cnwndl1	Initial creation	Par 36608

*/

vars

begin
	if self.txtCargoGroupId.text.trimBlanks = null then
		self.txtCargoGroupId.text := self.lblCargoGroupId.caption.toUpper;
		self.setMyCargoGroup(null);
	else
		if self.myCargoGroup &lt;&gt; null and self.myCargoGroup.id &lt;&gt; self.txtCargoGroupId.text
		or ( self.myCargoGroup = null and self.txtCargoGroupId.text &lt;&gt; self.lblCargoGroupId.caption.toUpper )	
		then
			self.selectCargoGroupItem( false );
		endif;
	endif;
	
	self.txtCargoGroupId.selStart := 0;
	self.txtCargoGroupId.selLength := 0;
	
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
</GUIClass>
