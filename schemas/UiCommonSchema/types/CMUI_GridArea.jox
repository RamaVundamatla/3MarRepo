    <JadeMethod name="setZoomFactor" id="4bb804e6-19ac-4052-8b57-edf2f20b2cfc">
        <updating/>
        <source>setZoomFactor(pFactor : Real) updating;
// ---------------------------------------------------------------------------
// Created:     16 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.scaleXFactor := self.scaleXFactor + pFactor;
	self.scaleYFactor := self.scaleYFactor + pFactor;
	if self.scaleXFactor &lt; 0.50 then
		self.scaleXFactor := 0.50;
	endif;
	if self.scaleYFactor &lt; 0.50 then
		self.scaleYFactor := 0.50;
	endif;

end;</source>
        <Parameter name="pFactor" type="Real"/>
    </JadeMethod>
