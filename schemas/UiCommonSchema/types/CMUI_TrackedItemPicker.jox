    <JadeMethod name="setListTable" id="fb939a61-acc8-4c31-a958-2598d9c4a4f3">
        <updating/>
        <source>setListTable(_row : Integer; pObjects : ObjectArray; pStrs : HugeStringArray) updating;

vars
//	rows,
	theRow,
	idx		: Integer;
	
begin
//	rows := pObjects.size.min(pStrs.size);
	
	foreach idx in 1 to _row do
		theRow := tblList.addItem(pStrs[idx]);
		tblList.accessRow(theRow).itemObject := pObjects[idx];
	endforeach;
	
	self.defaultSelectRow();
end;</source>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="pObjects" type="ObjectArray"/>
        <Parameter name="pStrs" type="HugeStringArray"/>
    </JadeMethod>
