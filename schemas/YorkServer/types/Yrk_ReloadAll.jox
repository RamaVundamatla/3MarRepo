<GUIClass name="Yrk_ReloadAll" id="3056325a-8aa2-4b5d-9ff6-946e95ab811b">
    <superclass name="CM_BaseForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="btnCancel" id="f959561a-a3c0-4faf-bf48-72f8d860f48e">
        <embedded/>
        <type name="Button"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="btnOK" id="659115c0-f6b1-4294-9448-fa371028b3d6">
        <embedded/>
        <type name="Button"/>
    </ImplicitInverseRef>
    <JadeMethod name="btnCancel_click" id="50cac1c7-33c5-42fb-9a83-31b77076d854">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;

vars

begin
	self.unloadForm;

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnOK_click" id="9c6d0bc0-a7c7-427b-b0e9-ff8e228d91a0">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOK_click(btn: Button input) updating;

vars
	message: Binary;
begin
	exclusiveLock(app.mainForm.Yrk_RefConSimulatorForm.config);
	message := app.mainForm.Yrk_RefConSimulatorForm.recallReeferDataTelegram();
	app.mainForm.Yrk_RefConSimulatorForm.sendTelegram(message);
//	app.mainForm.Yrk_MDIFrame.myTcpMsg.cnRead(app.mainForm.Yrk_MDIFrame.myTcpMsg);
epilog
	unlock(app.mainForm.Yrk_RefConSimulatorForm.config);	
	app.mainForm.Yrk_RefConSimulatorForm.staMain.caption := "Sent Recall Reefer Data message";
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
</GUIClass>
