    <JadeMethod name="create" id="7e252c10-2bac-4506-9ca9-4a244f0002d4">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts
*/

vars
	operator : CM_QueryOperator;

begin
	if self.isTransient then
		return;
	endif;

	create operator as CM_QStringLookupIsOneOf persistent;
	self.allAllowedOperators.add(operator);
epilog

end;</source>
    </JadeMethod>
