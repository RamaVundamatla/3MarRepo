    <JadeMethod name="getTotalCount" id="5fe8aa8e-6cbd-4d8a-9a95-b72bb05c03e7">
        <source>getTotalCount(_count : Integer io);
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	shipPortGroup : CM_ShipPortGroup;

begin

	foreach shipPortGroup in shipPortGroups do
		_count := _count + shipPortGroup.lineGroupDebtors.size;
	endforeach;

end;</source>
        <Parameter name="_count" type="Integer" usage="io"/>
    </JadeMethod>
