    <JadeMethod name="initForm" id="acd2b8ee-85b1-4a47-bd73-ed3018b71456">
        <updating/>
        <source>initForm() updating;
// ---------------------------------------------------------------------------
// Created:     25 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	// jdbRight has a parent of the form to make it easier to maintain in painter.
	// at run time we want it to be a child of the deatils frame.
	jdbRight.parent	:= frmDetails;
	jdbRight.width	:= jdbRight.parent.Control.clientWidth;
	jdbRight.height := jdbRight.parent.Control.clientHeight;

	self.minimumHeight := 600;
	
	txtAreaID.automaticCellControl := true;
	
	self.initList_Gates;
	self.initTable_GateLanes(self.tblGateLanes);
	self.initTable_GateAreas;
epilog

end;</source>
