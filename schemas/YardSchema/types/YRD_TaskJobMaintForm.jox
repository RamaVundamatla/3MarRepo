    <JadeMethod name="doEditSource" id="ae8aeac6-6517-429f-83d0-66f0a97cce08">
        <updating/>
        <source>doEditSource( _obj : Object ) protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05/08/2009	cnwmd1	Initial creation
10/05/2018	jlgdap1	TFS 38501 PEL1 Work Order Changes
*/

vars
	frm : YRD_TaskJobSourceForm;
	workOrder : CM_WorkOrder;
	pxyWOSource : CM_WorkOrderTISource;
begin
	frm := app.loadForm(YRD_TaskJobSourceForm, YRD_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).YRD_TaskJobSourceForm;
	
	if frm = null then
		return;
	endif;
	
	frm.isWorkOrderBooking := self.hasWorkOrderBooking;			// TFS 38501
	frm.isWorkOrderRelease := self.hasWorkOrderRelease;			// TFS 38501
	workOrder := myCurrentProxyWorkOrder;
	self.createProxyChildren();
	frm.set(self,workOrder.CM_WorkOrderTI.mySource);
	
	frm.setInitSource( _obj);
	
	//frm.showModal();
	self.hasSourceFormBeenShown := true;
	frm.show();
	

	/*
	
	//Note: No cancel functionality for Add is allowed for. This is done on purpose.
	//Having to allow for the cancel would require a copy of the proxy to be made
	//if frm.modalResult = IDOK and self.mode = self.Mode_Add then //Persistent wodtls have NOT been updated
	if self.mode = self.Mode_Add then //Persistent wodtls have NOT been updated
		self.doWorkOrderDisplay();
	elseif self.mode = self.Mode_Update then 
		//Either cancel has been presssed or an update on the persistent source has occurred.  
		//Refresh from persistent source in both cases.  
		//This is so that:
		//1. In the event of updating a persistent object the latest edition of the real object is retreived 
		//2. In the event of a cancel, any changes to the proxies has been backed out of
		
		app.cmsBeginLoad(loadStateSet);
		
		pxyWOSource := workOrder.CM_WorkOrderTI.mySource;
		delete pxyWOSource;
		
		pxyWOSource := self.setProxyWorkOrderSource();
		self.getSourceDisplay(workOrder);
		
		app.cmsEndLoad(loadStateSet);
	endif;
	
	self.setControlsForMode(true);
	*/

epilog
	//delete frm;
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doEditTask" id="0f325cc7-cc79-44b2-af4e-e3a969bab13a">
        <updating/>
        <source>doEditTask( _task : CM_WorkOrderDtl ) protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05/08/2009	cnwmd1	Initial creation
17/05/2018	jlgdap1	TFS 38560 PEL1 Voyage Work Orders
26/05/2018	jlgdap1	TFS 39432 Prevent Unexpected program error in YRD-TaskJobTasks
*/

vars
	taskForm : YRD_TaskJobTasks;
	workOrder : CM_WorkOrder;
	task : CM_WorkOrderDtl;
	voyage : CM_Voyage;						// TFS 38560
	woDtl : CM_WorkOrderDtl;		// TFS 39432
	taskType 	: Integer;
	now : TimeStamp;
begin
	if self.workOrderMode = WorkOrderMode_Voyage then									// TFS 38560
		voyage := self.cmbVoyage.listObject.CM_Voyage;									// TFS 38560
		taskType:=self.cmbTask.listData;
		//epr TFS 41310 17/10/18 - never want users to use the new dialog from the tasks form 
		if self.cmbTask.visible and taskType = 0 then
			app.raiseCMException(Please_select_task,null,null);
			return;
		endif;
		//epr TFS 40629 7/9/18
		if voyage &lt;&gt;  null then															// TFS 38560
			if voyage.myHMSVoyageData = null then											// TFS 38560
				//epr TFS 41310 15/10/18
				if  self.cmbTask.text &lt;&gt; null then														// TFS 38560
					app.raiseCMException1(Select_voyage_task_not_app, self.cmbTask.text
					, null, null);	// TFS 38560
				endif;																		// TFS 38560
			endif;
		else
			
				app.raiseCMException(PleaseSelectAVoyage,null,null);
				return;
		endif;	
		
		// TFS 42241
		now := app.actualTimeAppServer();
		if taskType = WO_TASK_BILLINGADJ
		and voyage.departedDT &gt; now then
			app.raiseCMException(Canno_billi_adjus_unles_voyag_,null,null);
			return;
		endif;
		if taskType = WO_TASK_BILLINGADJ
		and not voyage.isWorkOrderForExtension() then
			app.raiseCMException(Only_billi_adjus_voyag_with_ex,null,null);
			return;
		endif;
		
		
		
		// TFS 38560
		self.myCurrentProxyWorkOrder.CM_WorkOrderVoyage.setMyVoyage(voyage);			// TFS 38560
		app.setMyCurrentVoyage(voyage);													// TFS 38560
		// TFS 39432 check whether the work order has types that can be edited
		// (stops the maint form raising an unexpected program error in its displayDetails method)
		if self.myCurrentProxyWorkOrder.allWoDtls.size = 1 then
			woDtl := self.myCurrentProxyWorkOrder.allWoDtls.first;
			if not self.checkWODtlCanBeEdited(woDtl) then
				app.msgBox(	app.getErrorString1(Task_type_useredi_details, woDtl.getDisplayString(true)), 
							app.getErrorString(Attention), MsgBox_OK_Only);
				return;
			endif;
		endif;
		// TFS 39432 end
	endif;																				// TFS 38560
	
	taskForm := app.loadForm(YRD_TaskJobTasks, YRD_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).YRD_TaskJobTasks;
	
	if taskForm = null then
		return;
	endif;
	
	self.createProxyChildren();
	
	workOrder := self.myCurrentProxyWorkOrder;
	
	if _task = null then
		task := workOrder.allWoDtls.first();
	else
		task := _task;
	endif;
	
	taskForm.initialise(self, workOrder, self.mode, task, self.workOrderMode, voyage);	// TFS 38560
	
	self.hasTaskFormBeenShown := true;	
	taskForm.show();
	
epilog
//	delete taskForm;
end;</source>
        <access>protected</access>
        <Parameter name="_task" type="CM_WorkOrderDtl"/>
    </JadeMethod>
    <JadeMethod name="doSchedule" id="58e494c5-f6f7-4da1-91f1-c8408fc2d12a">
        <source>doSchedule() protected;
// -----------------------------------------------------------------------------
// Created:		13 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	frm : YRD_WorkOrderScheduleForm;
	
begin
	if self.myCurrentWorkOrder = null then
		return;
	endif;

	frm := app.loadForm(YRD_WorkOrderScheduleForm, YRD_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).YRD_WorkOrderScheduleForm;
	
	if frm = null then
		return;
	endif;

	frm.set(self.myCurrentWorkOrder);
	
	frm.show();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSelectEmailAddress" id="16cc2567-0a49-4e75-a4b2-4af9d3a16c1a">
        <updating/>
        <source>doSelectEmailAddress() protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 August 2009	cnwmd1	Initial creation

*/

vars
	form : CMUI_RecipientSelector;
begin
	create form transient;
	
	self.setNavigatorHeading(form.caption);
	form.myEmailController := self.myEmailController;
	form.mode := CMUI_RecipientSelector.Mode_To;
	form.setDisable(true, true, false);
	form.centreWindow;
	form.showModal;
	
	if form.modalResult = IDOK then
		self.hasChanged := true;
		self.txtEmail.text := self.myEmailController.allToAddresses.getNames();
		self.chkSendEmail.value := not ( self.txtEmail.text = '') ; //set this to true if we've just selected an email.
	endif;
epilog
	delete form;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTaskDisplay" id="2bbf7e71-7b4e-4a92-b944-5fff53bad0e6">
        <source>doTaskDisplay(_workOrder : CM_WorkOrder) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 August 2009	cnwmd1	Initial creation

*/

vars
	task : CM_WorkOrderDtl;
	displayStr : String;
begin
	//self.txtTaskList.text := _workOrder.getTaskDisplay();
	
	self.tbTasks.rows := 0;
	
	foreach task in _workOrder.allWoDtls do
		displayStr := task.getDisplayString(true);			
		self.tbTasks.accessRow(self.tbTasks.addItem(displayStr)).itemObject := task;
		//self.tbTasks.addItemObject(task, displayStr );
	endforeach;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_workOrder" type="CM_WorkOrder"/>
    </JadeMethod>
    <JadeMethod name="doTaskdblClick" id="57603710-f830-4aa7-93e7-a9d86c3174d3">
        <updating/>
        <source>doTaskdblClick( _table : Table ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 December 2009	cnwrd1	Initial creation

*/

vars
	taskForm : YRD_TaskJobTasks;
	workOrder : CM_WorkOrder;
	task : CM_WorkOrderDtl;
	selObj : Object;
	row : Integer;
begin
	
	row := self.tbTasks.CM_DataTable.row;
	
	selObj := self.tbTasks.CM_DataTable.accessRow(row).itemObject;

	if selObj = null then
		return;
	endif;
	
	workOrder := self.myCurrentProxyWorkOrder;

	if selObj.isKindOf(CM_WorkOrderDtl) then
		task := selObj.CM_WorkOrderDtl;
	else
		app.raiseUnexpectedProgramError(self.class.name, method.name, "unexpected class type");
		return;
	endif;
	
	self.doEditTask( task );

epilog
	
end;</source>
        <Parameter name="_table" type="Table"/>
    </JadeMethod>
    <JadeMethod name="doTblSourceContexMnu" id="6fa2f6aa-7b40-4f5d-a365-139f2845a081">
        <updating/>
        <source>doTblSourceContexMnu(_cntrl: Table input; _conwin: Window input; _mouse: Boolean; _x: Integer; _y: Integer): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15/01/2010	cnwrd1	Initial creation
*/

vars
	selObj : Object;
	row : Integer;
begin

	row := self.tbCargo.CM_DataTable.row;// allSelectedObjects.first;
	
	selObj := self.tbCargo.CM_DataTable.accessRow(row).itemObject;

	self.mnuShowBooking.userObject := null;
	self.mnuShowBooking.visible := false;
	
	self.mnuShowRelease.userObject := null;
	self.mnuShowRelease.visible := false;
	
	self.mnuShowWorkOrder.userObject := null;
	self.mnuShowWorkOrder.visible := false;
		

	if selObj.isKindOf(CM_BookingRef) then
		self.mnuShowBooking.caption := app.getErrorString(View_booking) &amp; selObj.CM_BookingRef.bookingReference &amp; '...';
		self.mnuShowBooking.userObject := selObj;
		self.mnuShowBooking.visible := true;		
	elseif selObj.isKindOf(CM_BulkRelease)  then	
		self.mnuShowRelease.caption := app.getErrorString(View_release) &amp; selObj.CM_BulkRelease.code &amp; '...';
		self.mnuShowRelease.userObject := selObj;
		self.mnuShowRelease.visible := true;
	elseif selObj.isKindOf(CM_WorkOrder)  then
		self.mnuShowWorkOrder.caption := app.getErrorString(View_work_order) &amp; selObj.CM_WorkOrder.id &amp; '...';
		self.mnuShowWorkOrder.userObject := selObj;
		self.mnuShowWorkOrder.visible := true;
	else //nothing selected we can show
		return false;
	endif;
	
	return self.showContextMenu(self.mnuShowSources,_cntrl,_conwin,_mouse,_x,_y);

epilog

end;</source>
        <Parameter name="_cntrl" type="Table" usage="input"/>
        <Parameter name="_conwin" type="Window" usage="input"/>
        <Parameter name="_mouse" type="Boolean"/>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doViewSource" id="534995b1-5bac-4e42-b9e3-aa4a408060e7">
        <source>doViewSource( _obj : Object );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 January 2010	cnwrd1	Initial creation

*/

vars

begin

	if _obj = null then
		return;
	endif;

	if _obj.isKindOf(CM_BookingRef) then
		self.myAssistant.showBookingForm(_obj.CM_BookingRef,self.myMasterMenuAction , self.myTerminal );
	elseif _obj.isKindOf(CM_BulkRelease)  then	
			self.myAssistant.releaseRequestView( _obj.CM_BulkRelease, self.myMasterMenuAction );
	elseif _obj.isKindOf(CM_WorkOrder)  then
		self.myAssistant.showWorkOrderForm( _obj.CM_WorkOrder,self.myMasterMenuAction , self.myTerminal );
	else //nothing selected we can show
		return;
	endif;
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doWorkOrderDisplay" id="eed8ddaa-1ecd-4396-92ce-1a9967a4e276">
        <updating/>
        <source>doWorkOrderDisplay()updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29/07/2009	cnwmd1	Initial creation
08/05/2018	jlgdap1	TFS 38501 PEL1 Work Order Changes
23/05/2018	jlgdap1	TFS 38560 PEL1 Voyage Work Orders
15 Feb 2023 navma1  ChangeRequest 56561: FR 53944 | EUP - Simplified Voyage Work Order
*/

vars
	workOrder : CM_WorkOrder;
	email 	  : CM_EmailEntity;
begin
	workOrder := self.myCurrentProxyWorkOrder;//self.myCurrentWorkOrder;
	
	if workOrder = null then
		app.raiseUnexpectedProgramError(self.class.name, method.name, "No work order to display");
		return;
	endif;
	
	self.txtTotalRequired.userObject := workOrder; //for inspecting...
	
	self.myEmailController.clear();
	foreach email in workOrder.allEmailAddresses do
		self.myEmailController.allToAddresses.add(email);
		//addEmailAddress(email, CMIF_EmailTemplateController.Mode_To);
	endforeach;
	
	self.txtEmail.text := self.myEmailController.allToAddresses.getNames();
	
	self.txtJobID.text := workOrder.id;
	self.lProgress.caption := app.getErrorString(WordProgress) &amp; " : " &amp; workOrder.getProgressString();
	self.doTaskDisplay(workOrder);
	if self.workOrderMode = WorkOrderMode_Cargo then													// TFS 38560
		self.getSourceDisplay(workOrder);
	else																								// TFS 38560
		self.cmbVoyage.listIndex := self.cmbVoyage.findObject(workOrder.CM_WorkOrderVoyage.myVoyage);	// TFS 38560
		//epr TFS 40629 7/9/18
		if workOrder.CM_WorkOrderVoyage.myVoyage &lt;&gt; null then
			self.txtExternalVoyCode.text:=workOrder.CM_WorkOrderVoyage.myVoyage.voyageCodeExternal;
		else
			self.txtExternalVoyCode.text:=workOrder.CM_WorkOrderVoyage.voyageCodeExternal;
		endif;
	endif;																								// TFS 38560
	self.cmbOrganisation.setObject(workOrder.myOrganisation);
	self.txtTotalRequired.text := workOrder.getTotalRequired.asStringJMT();
	
	if self.workOrderMode = WorkOrderMode_Cargo then													// TFS 38560
		self.lblTotalRequest.caption := app.getErrorString(Total_Requested) &amp; ' : ' &amp; workOrder.CM_WorkOrderTI.mySource.getTotalCargoCount().String;
		
		if self.txtTotalRequired.text = null or self.txtTotalRequired.text = '0' then
			self.txtTotalRequired.text :=  workOrder.CM_WorkOrderTI.mySource.getTotalCargoCount().String;
		endif;
	endif;																								// TFS 38560
	
	self.cmbJobStatus.listIndex := self.cmbJobStatus.findString(1, app.workOrderStatusEnumToString(workOrder.taskStatus) );	//15.02.2023 navma1 #56561
	
	self.chkSendEmail.value := workOrder.emailNotification;
	self.txtEmail.text := workOrder.getEmailsString();
	self.dtJobRequiredBy.text := workOrder.getRequiredByDateString();
	self.tmJobRequiredBy.text := workOrder.getRequiredByTimeString();
	self.txtReference.text := workOrder.customerReference;
	
	self.cmbJobEnteredBy.setObject(workOrder.myEnteredByUser);
	
	self.dtEnterd.text := workOrder.getEnteredByDateString();
	self.tmEntered.text := workOrder.getEnteredByTimeString();
	self.txtApprovedBy.text := workOrder.getApprovedBy();
	self.dtApproved.text := workOrder.getApprovedByDateString();
	self.tmApproved.text := workOrder.getApprovedByTimeString();
	self.dtApprovalExpiry.text := workOrder.getApprovalExpDateString();	//11 Jun 2018	NDL	TFS 38795
	self.tmApprovalExpiry.text := workOrder.getApprovalExpTimeString();	//11 Jun 2018	NDL	TFS 38795
	self.dtJobStartDate.text := workOrder.getStartDateString();
	self.tmJobstartTime.text := workOrder.getStartTimeString();
	self.dtJobCompleted.text := workOrder.getCompletedDateString();
	self.tmJobCompleted.text := workOrder.getCompletedTimeString();
	self.txtRemarks.text := workOrder.remarks;
	
	//archived?
	self.chkSetArchived.value := workOrder.archived;
	
	if workOrder.myPinNo &lt;&gt; null then								// TFS 38501
		self.lblPin.visible := true;								// TFS 38501
		self.lblPinNo.visible := true;								// TFS 38501
		self.lblPinNo.caption := workOrder.myPinNo.pinNo.String;	// TFS 38501
	else															// TFS 38501
		self.lblPin.visible := false;								// TFS 38501
		self.lblPinNo.visible := false;								// TFS 38501
	endif;															// TFS 38501
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
