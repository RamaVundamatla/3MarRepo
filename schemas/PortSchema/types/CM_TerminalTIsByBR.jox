    <JadeMethod name="checkProgress" id="b00ebc59-7ad5-411b-8e06-3937dd8b69ca">
        <source>checkProgress(_cmifMonitor : CMIF_Monitor input) : Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 Sep 2009	cnwkpd1	PAR #20398 - Add Booking Reference cross reference functionality

*/
vars
	cnt				: Integer;
	
begin
	if _cmifMonitor = null then
		return true;
	endif;
	
	cnt := _cmifMonitor.numSearched + 1;
	
	if cnt mod 500 = 0 then
		if (not _cmifMonitor.updateProgress(null, 0, 0)) then
			return false;
		endif;
	endif;
	
	_cmifMonitor.numSearched := cnt;

	return true;


epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="41d13f5a-c7aa-49cb-9ea8-e91aa1dfe4a9">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 Aug 2009	cnwkpd1	PAR #20398 - Add Booking Reference cross reference functionality

*/

vars

begin
	// Need to instantiate collections at create to ensure parent object is not locked when first
	// cross reference is created
	self.allTIXrefsByBookingRef.instantiate();
	self.allTIXrefsByTI.instantiate();
	
	self.xrefComplete := false;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getTIsForBookingRef" id="72edd293-d5bb-4b7d-9b06-843a322289e2">
        <source>getTIsForBookingRef(_bookingReference : String;
					_includePartialMatches : Boolean;
					_tis : Btree input; 
					_cmifMonitor : CMIF_Monitor input) : Boolean;

/*

Purpose:			Add all the TIs with Booking References matching the passed in 
					value into _tis collection

Parameters:			Booking Reference to match
					if _includePartialMatches is true, then return partial matches
					
Return Value:		True if the search completed, false if it is cancelled by the user
					Also _tis populated with matches
				

Date		Who		Reason
04 Sep 2009	cnwkpd1	PAR #20398 - Add Booking Reference cross reference functionality

*/

vars
	iter			: Iterator;
	xrefObject		: CM_TrackedItemBRXref;
	bookingStr		: String;
	
begin
	iter := self.allTIXrefsByBookingRef.createIterator();
	self.allTIXrefsByBookingRef.startKeyGeq(_bookingReference, null, iter);
	
	while iter.next(xrefObject) do
		if not self.checkProgress(_cmifMonitor) then
			return false;
		endif;
		
		bookingStr := xrefObject.bookingReference.toUpper();	// 16/07/2013 cnwar2 #31683
		
		if _includePartialMatches then
			//if not xrefObject.bookingReference.startsWith(_bookingReference) then
			if not bookingStr.startsWith(_bookingReference) then	// 16/07/2013 cnwar2 #31683
				break;
			endif;
		else
			//if xrefObject.bookingReference &lt;&gt; _bookingReference then
			if bookingStr &lt;&gt; _bookingReference then		// 16/07/2013 cnwar2 #31683
				break;
			endif;
		endif;
		
		_tis.addNoDuplicates(xrefObject.myTrackedItem, false);
	endwhile;
	
	return true;
	
	
epilog
	delete iter;
	
end;</source>
        <Parameter name="_bookingReference" type="String"/>
        <Parameter name="_includePartialMatches" type="Boolean"/>
        <Parameter name="_tis" type="Btree" usage="input"/>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyTerminal" id="0a2d5dd6-f683-425c-9ffa-d2a1b53b28fc">
        <updating/>
        <source>setMyTerminal(_terminal : CM_Terminal) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 August 2009	cnwkpd1	PAR #20398 - Add Booking Reference cross reference functionality

*/

vars

begin
	self.myTerminal := _terminal;
	
	
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
