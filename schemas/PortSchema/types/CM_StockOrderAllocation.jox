    <JadeMethod name="allocQuantity" id="829a880d-895d-42cc-9db6-d581c2fc3b24">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>allocQuantity(set: Boolean; _value: Decimal io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:     07 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set then
		// allow jade to set the value
		return;
	endif;

	if self.allocType = self.AllocType_Quantity then
		_value := self.allocQuantity;
		return;
	endif;
	
	if self.allocType = self.AllocType_All then
		_value := self.mySOHLocation.currentVolume;
	elseif self.allocType = self.AllocType_Remaining then
		_value := self.mySOHLocation.calRemainingAllocAmount(self);
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="allocTypeString" id="79dc5643-5a4b-4d47-9986-12b770eb3780">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>allocTypeString(set: Boolean; _value: String io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:     05 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set then
		if _value = AllocTypeStr_All or
		   _value[1].toUpper = AllocTypeStr_All[1] then
		   	self.allocType := AllocType_All;
		elseif _value = AllocTypeStr_Remaining or
		   _value[1].toUpper = AllocTypeStr_Remaining[1] then
		   	self.allocType := AllocType_Remaining;
		else
			self.allocType := AllocType_Quantity;
		endif;
	else
		if self.allocType = AllocType_Quantity then
			_value := AllocTypeStr_Quantity;
		elseif self.allocType = AllocType_All then
			_value := AllocTypeStr_All;
		elseif self.allocType = AllocType_Remaining then
			_value := AllocTypeStr_Remaining;
		else
			_value := 'Unknown';
		endif;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAllocQuantityDisplayStr" id="7f61e44a-aef5-4ed0-ad1b-4248d1dbeda3">
        <source>getAllocQuantityDisplayStr() : String;
// ---------------------------------------------------------------------------
// Created:     10 September 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.allocType = self.AllocType_Quantity then
		return self.allocQuantity.asStringJMTWithPrecision($CM_Decimal3LeadingZero.decimalPlaces, true).String;
	else
		return self.allocTypeString;
	endif;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="2e53d760-f191-49e6-a670-b2038d98e60b">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------------------
//Created: 26 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	str : String;
begin

	if _attrName = ETRow_RowId then
		if self.myLocationsController &lt;&gt; null then							
			return self.myLocationsController.getDisplayStringForAttribute(_attrName, _short);
		endif;
	elseif _attrName = ETRow_Specifications or
			_attrName = ETRow_AvailableVolume or 			 
			_attrName = ETRow_MyOperator or 			 			
			_attrName = ETRow_AverageSED or
			_attrName = ETRow_CurrentQuantity or			
			_attrName = ETRow_CurrentVolume or						
			_attrName = ETRow_OldestFellDate or
			_attrName = ETRow_Date then
			if self.mySOHLocation &lt;&gt; null then
				return self.mySOHLocation.getDisplayStringForAttribute(_attrName, _short);
			else
				return null;
			endif;
	elseif _attrName = ETRow_AllocQuantity or 
		   _attrName = ETRow_AllocVolume then
		if self.allocType = AllocType_Quantity then
			return self.allocQuantity.jasVolumeString;						
		else
			return self.allocTypeString;
		endif;
	elseif _attrName = ETRow_Opt then
		return null; 	
	endif;
										
	return inheritMethod(_attrName, _short);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfoLogVoyOps" id="cd24ad97-7b17-4ec9-bd26-464283f4d3c3">
        <source>getExtraInfoLogVoyOps(_array: HugeStringArray input; _terminalForTerminology : CM_Terminal);
//--------------------------------------------------------------
//Created: 07 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	_array.add("Allocated Quantity" &amp; Tab &amp; self.allocQuantity.String);		
	_array.add("Allocation Type" &amp; Tab &amp; self.allocTypeString);	
	
	if self.myStockOrderHeader &lt;&gt; null then
		self.myStockOrderHeader.getExtraInfoLogVoyOps(_array,_terminalForTerminology);
	endif;			

	if self.mySOHLocation &lt;&gt; null then
		self.mySOHLocation.getExtraInfoLogVoyOps(_array);
	endif;

end;</source>
        <Parameter name="_array" type="HugeStringArray" usage="input"/>
        <Parameter name="_terminalForTerminology" type="CM_Terminal"/>
    </JadeMethod>
