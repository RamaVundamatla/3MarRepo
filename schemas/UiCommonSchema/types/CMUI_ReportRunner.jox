    <JadeMethod name="cmbDestination_click" id="2fbf87c2-a62e-4ed1-89e7-562bf83e3c48">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbDestination_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 January 2026	navsp1	Initial creation   MTN-36668

*/

vars
    destVal : String;
    index,
    newIndex,
    indexPDF : Integer;
    
    currentStatusPDF,
    currentStatusStandard,
    currentStatusCSV : Boolean;
    
begin
    destVal     := self.cmbDestination.text;
    index       := cmbFormat.findStringExact(1, self.myReportAgent.FORMAT_OPTION_STANDARD);
    indexPDF    := cmbFormat.findStringExact(1, self.myReportAgent.FORMAT_OPTION_PDF);
    
    //If FTP/SFTP Enabled
    if destVal  = self.DESTINATION_SFTP then 
        self.tblPrintOptions.showRowByName(ETRow_FTPEntity, false); //ENable FTP Entity combo
        if indexPDF &gt; 0 then
            self.cmbFormat.itemEnabled[indexPDF] := true;           //enable PDF
        endif;
        self.cmbFormat.itemEnabled[index] := false;                 //disable standard printer
        if self.cmbFormat.listIndex = index then                    //switch to next item
            newIndex    := cmbFormat.findStringExact(1, self.myReportAgent.FORMAT_OPTION_PDF);
            self.cmbFormat.listIndex := newIndex;
            self.tblPrintOptions.setValueByControlName(self.cmbFormat.name, self.cmbFormat.text);           
        endif;

    //Not SFTP/FTP 
    else
        self.tblPrintOptions.hideRowByName(ETRow_FTPEntity, false);         //Disable Entity combo
        self.cmbFormat.itemEnabled[index]       := true;                    //Enable Print Option 

        if cmbProcess.text = self.PROCESS_TEMPLATE then                     //Disable PDF if Template option
            if indexPDF &gt; 0 then
                self.cmbFormat.itemEnabled[indexPDF]    := false;
            endif;
        endif;
    endif;
   
    self.setPrintOptionsView();
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbDestination_lostFocus" id="d4cbd550-5d5c-4723-a33d-2460e5d8c8bd">
