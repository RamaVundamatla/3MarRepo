    <JadeMethod name="trxUpdateTIBooking" id="7bb8ac9a-6c68-4ea4-8c34-d8a4a8499b5a">
        <updating/>
        <source>trxUpdateTIBooking(_pxyTIs : CM_TISet input; _booking: CM_BookingRef input; _bookingItem: CM_BookingRefItem input; _useThisItem : Boolean; _passport: CM_Passport input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	04 Aug 2009 By cnwdw1

Purpose:	Move the TI to a new booking. 

Changed On  Changed By  Reason
----------  ----------  --------------------------------------------------
26/06/2012	cnwdap1		PAR #29735 New parameter for CM_TrackedUtem::setBookingRefAndItem, 
						new parameter for this method too - indicate whether we have to use
						the supplied booking item, or whether the system should find a suitable item
30 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
*/
vars
	pxyTI		: CM_TrackedItem;
	extraParams	: CMIF_TIUpdateExtraParams;			// PAR #29735
begin
	self.initialiseActivityWithPassport(_passport, method);

	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	if _useThisItem then									// PAR #29735
		create extraParams transient;						// PAR #29735
		extraParams.useSelectedBookingItem := _useThisItem;	// PAR #29735
	endif;													// PAR #29735

	beginTransaction;

	foreach pxyTI in _pxyTIs do

		pxyTI.validateBookingVoyage(_booking);
	
		// Update the TI with voyage details from the booking
		pxyTI.setBookingRefAndItem(_booking, _bookingItem, _useThisItem, _passport);	// PAR #29735
		pxyTI.setMyVoyage(_booking.myVoyage, app.myPassport);
		pxyTI.setDestinationPort(_booking.destinationPort);
		pxyTI.setDischargePort(_booking.dischargePort);	
		pxyTI.setTranshipToPort(_booking.myTranshipToPort);	
		if _booking.allTIs &lt;&gt; null and _booking.allTIs.size() &gt; 0 then
			pxyTI.setTranshipToPort(_booking.allTIs.first().myTranshipToPort);
		endif;
		
		//cnwmc5 - 9 Oct 2015 - PAR 36505
		if _passport.hasErrors() then
			return;
		endif;
		
		app.myUtilityUA.utlUpdateTrackedItem(pxyTI, null, TI_UPDMODE_BOOKINGREF, null, extraParams, null, _passport);//cnwrd1 28.8.09 par 20545	// PAR #29735
	endforeach;
	
	if _passport.hasErrors() then
		return;
	endif;
	
	self.updateObjectEdition(_booking);	// par 30292

epilog
	delete extraParams;								// PAR #29735
	self.finaliseActivityWithPassport(_passport);
end;

</source>
        <Parameter name="_pxyTIs" type="CM_TISet" usage="input"/>
        <Parameter name="_booking" type="CM_BookingRef" usage="input"/>
        <Parameter name="_bookingItem" type="CM_BookingRefItem" usage="input"/>
        <Parameter name="_useThisItem" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
