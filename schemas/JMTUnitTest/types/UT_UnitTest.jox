    <JadeMethod name="unitTestAfter" id="1523b12a-055f-4e56-9bb6-07e0ac3517f2">
        <updating/>
        <source>unitTestAfter( _test : Method ) updating, protected;
//16 July 2008	cnwdw1	
//
vars

begin
	app.myPassport.clearErrorsWarnings();
	app.alertManager.alerts.purge;		// 21/01/2011 cnwmh5
	if not app.mySaveDataObjsToRestore.allChangedStateDataDict.isEmpty() then
		app.mySaveDataObjsToRestore.restoreStateData(method, self.currentMethodBeingRun, self);	// 12/12/2014 cnmwh5
	endif;
	app.finializeYAAgent();
end;</source>
