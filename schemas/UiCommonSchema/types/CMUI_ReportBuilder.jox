    <JadeMethod name="showQueryParams" id="b2c2609b-6d9c-463d-9bd8-adbdf03aede9">
        <source>showQueryParams(_qryReport : CM_QryReport) protected;
// ---------------------------------------------------------------------------
// Created:     20 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	qryParam		: CM_QueryReportParam;
	entDef			: EntTableDef;

begin
	self.tblParamData.rows := self.tblParamData.fixedRows;
	entDef := app.myController.getEntTableDef(ETDef_ParamData);
	
	if entDef = null then
		return;
	endif;
		
	foreach qryParam in _qryReport.allQueryReportParams do
		self.addTblParamDataRow(qryParam, entDef, null);
	endforeach;
	
	self.doTblParamDataRowColChange(self.tblParamData);

end;</source>
        <access>protected</access>
        <Parameter name="_qryReport" type="CM_QryReport"/>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="b1a0a3b8-6d42-4c7e-b75b-e3c1b999a169">
        <updating/>
        <source>showThumbnailData(_qryReport: CM_QryReport) updating;
// -----------------------------------------------------------------------------
// Created:		13 June 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	
	reportNames,
	jrwReportName		: String;
	row,
	numRows				: Integer;
	tbl					: CMUI_ListTable;
	jrwRep				: CMUI_JRWEntityRepresentation;

begin

	self.myReportAgent.initQryReportForBuilder(_qryReport);
	//self.myReportAgent.myQryReport := _qryReport;
	
	self.tblReportDtl.setValueByName(ETRow_ReportName, _qryReport.reportName);
	self.tblReportDtl.setValueByName(ETRow_ReportDescription, _qryReport.reportDescription);

	self.tblReportDtl.setValueByName(ETRow_ReportType, _qryReport.getDescriptionFromType(_qryReport.reportType));
	self.cmbReportType.listIndex := self.cmbReportType.itemDataIndex(_qryReport.reportType);
	
	self.doCmbReportTypeClick();
	
	if _qryReport.jrwViewName &lt;&gt; null then
		self.cmbReportView.text := _qryReport.jrwViewName;
		self.tblReportDtl.setValueByName(ETRow_ReportView, self.cmbReportView.text);
	else
		self.tblReportDtl.setValueByName(ETRow_ReportView, CM_QryReport.ReportTypeDescr_SystemDefined);
	endif;
	
	if self.mode &lt;&gt; Mode_View then
		self.doCmbReportViewClick();//added by cnwyl1 120506
		if not _qryReport.isFormBasedReport then
			//checkbox selected designs
			tbl := self.tblDesigns;
			tbl.allSelectedObjects.clear();
			numRows := tbl.rows;
			foreach row in 1 to numRows do
				jrwRep := tbl.accessRow(row).itemObject.CMUI_JRWEntityRepresentation;
				if jrwRep = null then
					continue;
				endif;
				if _qryReport.jrwReportName.includes(jrwRep.name) then
					tbl.setCellText(row, 1, '1');
					tbl.allSelectedObjects.add(jrwRep);
				endif;
			endforeach;
			self.myAssistant.listTableLostFocus(self.tblReportDtl, self.saveRowHeight, tbl, 'name', false);
		else
			self.tblReportDtl.setValueByName(ETRow_JrwReport, 'Form based report - no associated designs');
		endif;
	else
		foreach jrwReportName in _qryReport.jrwReportName do
			reportNames := reportNames &amp; ',' &amp; jrwReportName;
		endforeach;
		
		if reportNames.length &gt; 1 then
			self.tblReportDtl.setValueByName(ETRow_JrwReport, reportNames[2:end]);
		endif;
		
	endif;

	
// cnwdad1 30/08/2006 - Constant is no longer used.
//	self.tblReportDtl.setValueByName(ETRow_SelectorEnabled, _qryReport.isSelectorAvailable);
	self.showQueryParams(_qryReport);
	
	if _qryReport.mySelectorQuery &lt;&gt; null then
		if self.cmbSelector.findObject(_qryReport.mySelectorQuery) &lt;&gt; -1 then
			self.cmbSelector.listObject := _qryReport.mySelectorQuery;
			self.tblReportDtl.setValueByName(ETRow_SelectorQuery, self.cmbSelector.text);
			self.doCmbSelectorClick();
		endif;
	endif;
	
	self.setAvailableFormats(_qryReport);	// 05/02/2013 cnwar2 #30995
	self.setSelectedFormats(_qryReport.reportFormats);
	self.myAssistant.listTableLostFocus(self.tblReportDtl, self.saveRowHeight, self.lstFormats, 'formatDescription', false);
	if _qryReport.reportAvailability &gt; 0 then
		self.cmbRptAvail.listIndex := _qryReport.reportAvailability;
	else
		self.cmbRptAvail.listIndex := -1;
	endif;
	
	if _qryReport.reportProcessType &gt; 0 then
		self.cmbBackground.listIndex := _qryReport.reportProcessType;
	else
		self.cmbBackground.listIndex := -1;
	endif;
	
	
	self.tblReportDtl.setValueByName(ETRow_ReportAvailability, self.cmbRptAvail.text);
//	self.tblReportDtl.setValueByName((ETRow_IsAvailableInBackground), _qryReport.canBeRunInBackground);
	self.tblReportDtl.setValueByName((ETRow_WebRptProcessAvail), self.cmbBackground.text);
		
	self.setNavigatorHeading(_qryReport.reportName);
	self.tblReportDtl.changeMode := self.tblReportDtl.ChangeMode_FirstOnly;
	
end;</source>
        <Parameter name="_qryReport" type="CM_QryReport"/>
    </JadeMethod>
    <JadeMethod name="showViewForReportType" id="0165770d-5398-4ee2-acad-f8edae2968fe">
        <updating/>
        <source>showViewForReportType(_categoryStr : String) protected, updating;
// ---------------------------------------------------------------------------
// Created:     31 October 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _categoryStr = CM_QryReportUser.ReportTypeDescr_Selector then
		self.tblReportDtl.showHideRowsByViewName('selectorQuery', self.tblReportDtl.ShowHideRows, false);	
		self.tblCriteria.visible := false;
		self.lblSelector.visible := true;
	else
		self.tblReportDtl.showHideRowsByViewName('default', self.tblReportDtl.ShowHideRows, false);
		self.tblCriteria.visible := true;
		self.lblSelector.visible := false;
	endif;

	self.tblReportDtl.adjustHeight(200);
	self.tblCriteria.top := self.tblReportDtl.top + self.tblReportDtl.height + self.VerticalSpacing;
end;</source>
        <access>protected</access>
        <Parameter name="_categoryStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="tblCriteriaGetValueByName" id="2ce98ba4-ca11-48ad-85ca-cb93fca615da">
        <source>tblCriteriaGetValueByName(_rowName : String) : Any;
// ---------------------------------------------------------------------------
// Created:     07 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	numRows,
	row					: Integer;
	tbl					: CM_BaseTable;
	entTableRow			: EntTableRow;
begin

	tbl := self.tblCriteria;
	if tbl = null then
		return null;
	endif;
	
	numRows := tbl.rows;
	foreach row in 1 to numRows do
		entTableRow := tbl.accessRow(row).itemObject.EntTableRow;
		if (entTableRow = null) or
		   (entTableRow.name &lt;&gt; _rowName) then
		   continue;
		endif;
		
		return tbl.getCellText(row, CMUI_ReportBuilder.Column_DefaultValue);
	endforeach;

	return null;
end;</source>
        <Parameter name="_rowName" type="String"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="tblCriteriaSetValueByName" id="2b0df6a7-65cf-4a40-9e21-7d5587c698dd">
        <source>tblCriteriaSetValueByName(_rowName : String; _value : Any) : Integer;
// ---------------------------------------------------------------------------
// Created:     06 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	numRows,
	row					: Integer;
	tbl					: CM_BaseTable;
	entTableRow			: EntTableRow;
begin
	
	tbl := self.tblCriteria;
	if tbl = null then
		return null;
	endif;
	
	numRows := tbl.rows;
	foreach row in 1 to numRows do
		entTableRow := tbl.accessRow(row).itemObject.EntTableRow;
		if (entTableRow = null) or
		   (entTableRow.name &lt;&gt; _rowName) then
		   continue;
		endif;
		
		tbl.setCellText(row, CMUI_ReportBuilder.Column_DefaultValue, _value.String);
		break;
	endforeach;
	
	return row;

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblCriteria_cellInputReady" id="4b69ce31-6f8d-4d5b-8e00-670c8ee97fd9">
        <controlMethod name="Table::cellInputReady"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCriteria_cellInputReady(table: CM_BaseTable; inputControl: Control input; cleft: Real io; ctop: Real io; cwidth: Real io; cheight: Real io) updating;
// ---------------------------------------------------------------------------
// Created:     08 January 2004	cnwth2
//
// Purpose:     
//			 
//16 Mar 2023   navhl20     Defect 57144: Send to Report showing Error
//16 Aug 2023 	navhl20 	ChangeRequest 58568: EUP - Delivery Dispatch – Reporting
// 28 Aug 2023 	navhl20 	Bug 60056: FR | 53429 - VBS Selector issues
// ----------   ----------  --------------------------------------------------
vars
	tbl	: CM_BaseTable;
begin

	if inputControl = self.lstTblLogLot or
	   inputControl = self.lstTblTransact or
	   inputControl = self.lstTblWOTransact or		//16.3.2023 navhl20	#57144
	   inputControl = self.lstTblWOStatus or		//16.8.2023 navhl20 #58568
	   inputControl = self.lstTblWOType or			//16.8.2023 navhl20 #58568
	   inputControl = self.lstTblTasks or			//20 Oct 2010	NDL	Par 23800
	   inputControl = self.lstTblCashDrs or			//14 Aug 2012	NDL	Par 29968
	   inputControl = self.lstTblSiteState or
	   inputControl = self.lstTblVoyageJob or
	   inputControl = self.lstTblStop or
	   inputControl = self.lstTblAvaGrade or
	   inputControl = self.lstTblEventTypes or
	   inputControl = self.lstUnloadEvts or			//15 Aug 2019	NDL	TFS 46131
	   inputControl = self.lstBarges or 			//15 Aug 2019	NDL	TFS 46131
	   inputControl = self.lstNonBarges or 			//21 Aug 2019	NDL	TFS 46131
	   inputControl = self.lstTblUsers or
	   inputControl = self.lstTblDelayTypGp or		// 03/12/2010	cnwsh3		
	   inputControl = self.lstTblDelayType or		// 03/12/2010	cnwsh3		
	   inputControl = self.lstTblVBSStatus or 		//28.8.2023 navhl20 #60056
	   inputControl = self.lstTblVBSTsType or 		//28.8.2023 navhl20 #60056
	   inputControl = lstTblIMEX then
		tbl := table;
		self.myAssistant.listTableCellInputReady(tbl, cheight, self.saveRowHeight);
		self.setTblCriteriaHeight();
	endif;
	
	
end;</source>
        <Parameter name="table" type="CM_BaseTable"/>
        <Parameter name="inputControl" type="Control" usage="input"/>
        <Parameter name="cleft" type="Real" usage="io"/>
        <Parameter name="ctop" type="Real" usage="io"/>
        <Parameter name="cwidth" type="Real" usage="io"/>
        <Parameter name="cheight" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="tblCriteria_click" id="7f77b8a9-e365-4983-9abb-ec2c6c99e91b">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCriteria_click(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:     06 January 2004	cnwth2
//
// Purpose:     
