    <JadeMethod name="createRoadProcessObjs" id="267c9732-1036-4554-8f85-a9491a54dfaf">
        <source>createRoadProcessObjs( _updController : CnEcReleaseController );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 October 2020	jlgndl1	Initial creation	TFS 49189

*/

vars

	pxyRoadProcess : CM_RoadProcess;
	roadProcess : CM_RoadProcess;
	terminal : CM_Terminal;
	securityRoleTerminal : CM_SecurityRoleTerminal;

begin

	if self.hasScriptBeenRunAtAll(method.name, _updController) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Creating Road Process Objects and Setting PmAdmEnterVVR", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry(" Creating Road Process Objects and Setting PmAdmEnterVVR") ;	
	endif;
	
	beginTransaction;
	
	// Default process
	if not app.myRoot.allRoadProcesses.isEmpty then
		roadProcess := app.myRoot.allRoadProcesses.getAtKey( CM_RoadProcess.DEFAULT ).CM_RoadProcess;
	endif;
	
	if roadProcess = null then
		create pxyRoadProcess transient;
		pxyRoadProcess.setCode(CM_RoadProcess.DEFAULT);
		pxyRoadProcess.setDescription("MTN Default Road Process");
		
		create roadProcess persistent;
		roadProcess.setForCreate( pxyRoadProcess );
		delete pxyRoadProcess;
		
		foreach terminal in CM_Terminal.instances do
			terminal.setPropertyValue( "myRoadProcess", roadProcess );
		endforeach;
		
		roadProcess := null;	
	endif;
	
	// ASPA Process 
	if not app.myRoot.allRoadProcesses.isEmpty then
		roadProcess := app.myRoot.allRoadProcesses.getAtKey( CM_RoadProcess.ASPA_GCI ).CM_RoadProcess;
	endif;
	
	if roadProcess = null then
		create pxyRoadProcess transient;
		pxyRoadProcess.setCode(CM_RoadProcess.ASPA_GCI);
		pxyRoadProcess.setDescription("ASPA GCI Road Process");
		
		create roadProcess persistent;
		roadProcess.setForCreate( pxyRoadProcess );
		delete pxyRoadProcess;
		
		roadProcess := null;
	endif;
	
	foreach securityRoleTerminal in CM_SecurityRoleTerminal.instances do
		if securityRoleTerminal.permissions.size &lt; PmAdmEnterVVR or not securityRoleTerminal.permissions[PmAdmEnterVVR] then
			securityRoleTerminal.permissions[PmAdmEnterVVR] := true;
		endif;
	endforeach;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Creating Road Process Objects and Setting PmAdmEnterVVR complete", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry(" Creating Road Process Objects and Setting PmAdmEnterVVR complete") ;	
	endif;
	
	self.addScriptRun(method.name);
	
epilog

	delete pxyRoadProcess;

end;</source>
        <Parameter name="_updController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="createStevedoreDebtorType" id="d031b2fd-1ec7-4c7d-a7c3-6c28128315e9">
        <source>createStevedoreDebtorType(_updController : CnEcReleaseController);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/06/2019	jlgdap1		Initial creation TFS 44554 AAT Stevedore Data Access
// 02 Oct 2020  cnwma1 		ChangeRequest 50112: ASPA - GCI Stevedores
//
vars
	debtorType : CM_DebtorType;

begin
	if self.hasScriptBeenRunAtAll(method.name, _updController) then
		return;
	endif;
	// create the new Debtor Type of "Stevedore"
	if app.myRoot.allDebtorTypes[CM_DebtorType.DT_STEVEDORE_VOYAGE] &lt;&gt; null then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Creating Stevedore Voyage Debtor Type", LogINFO);   //02.10.2020 cnwma1 TFS #50112
	if _updController &lt;&gt; null then
		_updController.logEntry(" Creating Stevedore Voyage Debtor Type") ;	                  //02.10.2020 cnwma1 TFS #50112
	endif;
	
	beginTransaction;
	create debtorType;
	//debtorType.setForCreateParam("SDT10", "Stevedore");                                     //02.10.2020 cnwma1 TFS #50112
	debtorType.setForCreateParam(CM_DebtorType.DT_STEVEDORE_VOYAGE, CM_Stevedore.STEVEDORE_VOYAGE);                     //02.10.2020 cnwma1 TFS #50112
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Creating Stevedore Voyage Debtor Type complete", LogINFO);   //02.10.2020 cnwma1 TFS #50112
	if _updController &lt;&gt; null then
		_updController.logEntry(" Creating Stevedore Voyage Debtor Type complete") ;	               //02.10.2020 cnwma1 TFS #50112
	endif;
	
	self.addScriptRun(method.name);
epilog

end;</source>
        <Parameter name="_updController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="createWOVoyageProcess" id="74a78b18-7eb7-48b4-90a7-72bbe1b80ff9">
        <source>createWOVoyageProcess(_controller: CnEcReleaseController);
/*

Purpose:			create singleton CM_VoyageProcessWO, and transfer all existing voyage statuses
					from the existing CM_VoyageProcessPEL1 instance

Parameters:			

Return Value:		

Date				Who		Reason
21 September 2021	jlizm1	Initial creation TFS 51963 SAL Voyage Request Changes

*/

vars
	converting 		: Boolean;
	pxyProcess, 
	realProcess, 
	pelProcess, 
	defaultProcess 	: CM_VoyageProcess;
	statusObj 		: CM_Object;
	pxyStatus 		: CM_VoyageStatus;
	statuses 		: CM_ObjectSetActual;
	voyages 		: CM_VoyageSet;
	voy 			: CM_Voyage;
	
begin
	converting := app.isConverting;
	app.isConverting := true;
	
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Initializing MTN Work Order voyage process", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Initializing MTN Work Order voyage process") ;	
	endif;
	
	
	defaultProcess := CM_VoyageProcessDefault.firstInstance;
	if defaultProcess &lt;&gt; null then
		// rename default voyage process
		beginTransaction;
		defaultProcess.setPropertyValue("code", "MTN");
		defaultProcess.setDescription("MTN Default");
		commitTransaction;
	endif;
	
	if CM_VoyageProcessWO.instances.isEmpty then 
		// create singleton voyage process object
		create pxyProcess as CM_VoyageProcessWO transient;
		pxyProcess.setProxy(VoyageProcessWO, "MTN Work Orders",null,null,null,null, null, null);
		
		beginTransaction;
		app.myUtilityCA.utlCreateVoyageProcess(pxyProcess, realProcess, app.myPassport);
		if not app.myPassport.noErrors then
			app.writeLog(method.qualifiedName &amp; " Failed to create CM_VoyageProcessWO!!!", LogINFO);
			return;
		endif;
		
		// copy voyage status from pelindo voyage process to wo voyage process
		pelProcess := CM_VoyageProcessPEL1.firstInstance;
		if pelProcess &lt;&gt; null then
			create statuses transient;
			pelProcess.allStatusesById.copy(statuses);
			
			foreach statusObj in statuses do
				pxyStatus := statusObj.pxyCreateUpdateProxy().CM_VoyageStatus;
				pxyStatus.setProxy(pxyStatus.id, pxyStatus.priority, pxyStatus.description, realProcess, null, pxyStatus.reportToRun,false);
				app.myUtilityUA.utlUpdateVoyageStatus(pxyStatus, app.myPassport);
				delete pxyStatus;
			endforeach;
		endif;
		commitTransaction;
		
		// transfer any existing voyages
		create voyages transient;
		pelProcess.allVoyages.copy(voyages);
		foreach voy in voyages do
			beginTransaction;
			voy.setPropertyValue("myVoyageProcess", CM_VoyageProcessWO.firstInstance);
			commitTransaction;
		endforeach;
		
	else
		app.writeLog(method.qualifiedName &amp; " MTN Work Order voyage process already exists", LogINFO);
		if _controller &lt;&gt; null then
			_controller.logEntry(" MTN Work Order voyage process already exists") ;	
		endif;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Initializing MTN Work Order voyage process COMPLETE", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Initializing MTN Work Order voyage process COMPLETE") ;	
	endif;	
	
	self.addScriptRun(method.name);
	
epilog
	delete pxyProcess;
	delete pxyStatus;
	delete statuses;
	delete voyages;
	app.isConverting := converting;
	
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
