    <JadeMethod name="errMsgTblBasicDims" id="f421ef6f-7fab-4f9b-9e29-fd3362b54a98">
        <updating/>
        <source>errMsgTblBasicDims(errorMsg: String) updating;

vars
   	dimensionTitle:	String;
   	msgTitle:		String;
   	msgBoxType:		Integer;

begin
	// Set messageBox type
	msgBoxType:=MsgBox_OK_Only+MsgBox_Stop_Icon;

	// Get dimension title from column #1 and construct error message title;
	tblBasicDimension.column:=1;
	dimensionTitle:=tblBasicDimension.text;
 	msgTitle:="WARNING: " &amp; dimensionTitle &amp;":- OUT OF RANGE";

 	// Set pointer to cell in table that is in error.
	if fldShipDetails.topSheet&lt;&gt;shtDimensions then
		// change to dimensions sheet
		fldShipDetails.topSheet:=shtDimensions;
	endif;
	tblBasicDimension.column:=2;
	tblBasicDimension.rowColumnChg(tblBasicDimension);
	if app.msgBox(errorMsg,msgTitle,msgBoxType)=MsgBox_Return_OK then
		// Set focus to cell in table that is in error.
		tblBasicDimension.setFocus;
	endif;
end;</source>
        <Parameter name="errorMsg" type="String"/>
    </JadeMethod>
    <JadeMethod name="errMsgTblKeyDistances" id="e2ded2dc-c7f5-4329-9ad4-68b53a7dbb9d">
        <updating/>
        <source>errMsgTblKeyDistances() updating;

vars
   	keyDistanceTitle:	String;
   	msgTitle:			String;
   	errorMsg:			String;
   	msgBoxType:			Integer;

begin
	// Set messageBox type
	msgBoxType:=MsgBox_OK_Only+MsgBox_Stop_Icon;

	// Get dimension title from column #1 and construct error message title;
	tblKeyDistances.column:=1;
	keyDistanceTitle:=tblKeyDistances.text;
 	msgTitle:="WARNING: " &amp; keyDistanceTitle &amp;":- OUT OF RANGE";
	errorMsg:="The '" &amp; keyDistanceTitle &amp; "' distance must be between " &amp; Distance_LowerLimit.String &amp; " and " &amp; Distance_UpperLimit.String;

 	// Set pointer to cell in table that is in error.
	if fldShipDetails.topSheet&lt;&gt;shtDimensions then
		// change to dimensions sheet
		fldShipDetails.topSheet:=shtDimensions;
	endif;
	tblKeyDistances.column:=2;
	tblKeyDistances.rowColumnChg(tblKeyDistances);
	if app.msgBox(errorMsg,msgTitle,msgBoxType)=MsgBox_Return_OK then
		// Set focus to cell in table that is in error.
		tblKeyDistances.setFocus;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="errorCheck" id="64594287-3797-4d6b-bdfc-cad9b3e5d31a">
        <updating/>
        <source>errorCheck():Boolean updating;

vars
 	msgBoxType: 	Integer;
begin
 	// Check to see that the ship code and name are not blank or
 	// already in existance

	msgBoxType:=MsgBox_OK_Only+MsgBox_Stop_Icon;
    if tbxShipName.text=null or tbxShipName.text="" then
    	if app.msgBox(app.getErrorString(MSGBOX_BlankShipNameText),app.getErrorString(MSGBOX_BlankShipNameTitle),msgBoxType)=MsgBox_Return_OK then
				// Set pointer field that is in error.
				fldShipDetails.topSheet:=shtGeneral;
				tbxShipName.setFocus;
				return false;
		endif;
	else
		return true;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="fldShipDetails_sheetChg" id="4cd1facb-ee34-45fa-90ad-a03fe5207320">
        <controlMethod name="Folder::sheetChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>fldShipDetails_sheetChg(folder: Folder input) updating;

vars

begin

	if recentTopSheet=shtDimensions then
		// Check values in table before changing sheets.
		checkTblBasicDimension;
		checkTblKeyDistances;

	elseif fldShipDetails.topSheet=shtSummary then
		loadSummaryTbl;

	elseif fldShipDetails.topSheet=shtDimensions then
		checkRowHighlighted;

	endif;
	recentTopSheet:=fldShipDetails.topSheet;

	self.doResizeTopSheet();

end;</source>
        <Parameter name="folder" type="Folder" usage="input"/>
    </JadeMethod>
