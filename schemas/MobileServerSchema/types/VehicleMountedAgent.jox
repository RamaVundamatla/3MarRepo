    <JadeMethod name="findWorkingDTORTEntries" id="7fa9812d-d457-44c0-a71e-1a7f32be66e1">
        <updating/>
        <source>findWorkingDTORTEntries(_dtoRTQueueEntryArray : DTO_RTQueueEntryArray input;
						_table : Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 Apr 2010	cnwer1	Initial creation
28 Jun 2010	cnwkpd1	PAR #24763 - Prevent 1090 and 14051 exceptions.  Ensure allAvailableRTQueueEntries
					is not populated with null objects
02 Sep 2010 cnwer1 	PAR 25206					
*/

vars
	
begin

	self.myMachQEntryTableSynchAgent.setTableDetails(_table,self.getEntTableView(_table),self.getHeaderTopRow(_table));
	self.myMachQEntryTableSynchAgent.doFindWorkingDTOEntries(_dtoRTQueueEntryArray,true,null);
	
