    <JadeMethod name="canBeUsedInKPIReporting" id="c54b5da5-b088-4e95-98b0-7ed4beefff08">
        <source>canBeUsedInKPIReporting():Boolean;
// ---------------------------------------------------------------------------
// Created:     01 December 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return self.historyVersion &gt; 0;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="07ab3983-9fb8-4fdc-9d6c-01b7321832b2">
        <updating/>
        <source>create() updating;
//Constructor - Sets the timeStamp of this object - gets overridden for delays

// 01/12/2010 	cnwcs5	par 23714/ccms 1132 - store flag for kpi reporting
begin
	self.dateTime 		:= app.actualTimeServer();
	self.historyVersion	:= 1;
end;</source>
    </JadeMethod>
