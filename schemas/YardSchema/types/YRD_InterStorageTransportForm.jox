    <JadeMethod name="getAllTrackedItemsForUpdate" id="90e21de2-fc82-4828-97d2-037f89647f48">
        <source>getAllTrackedItemsForUpdate(_tiSet : CM_TISet input) protected;
//--------------------------------------------------
// Created:	27 January 2004 By: cnwgd1
//--------------------------------------------------
vars
	numRows,
	col,
	row : Integer;
	obj	: Object;
begin
	if _tiSet = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null Set passed to method');
		return;
	endif;
	
	numRows := self.tblData.rows;
	col := self.tblData.getColumnByRowName(ETRow_InterStorageTransfer);
	
	foreach row in 1 to numRows do
		if self.tblData.accessCell(row, col).text = '1' then
			obj := 	self.tblData.accessRow(row).itemObject;
			if CM_TrackedItem.hasInstance(obj) then
				_tiSet.add(obj.CM_TrackedItem);
			endif;
		endif;				
	endforeach;	
end;</source>
        <access>protected</access>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
    </JadeMethod>
