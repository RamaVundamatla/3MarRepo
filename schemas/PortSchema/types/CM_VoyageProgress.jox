    <JadeMethod name="getLoadListForMyVoyage" id="859611bf-0f76-4aed-b443-3a38b85941bc">
        <source>getLoadListForMyVoyage() : CM_EDIDataLoadList protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 July 2024	navra1	Initial creation for //navra1 - CR-65068/Task-64641 - Auto Comparison - 15th July 2024

*/

vars
	ediDatas : CM_EDIDataArray;
	oneEdiData : CM_EDIData;
	returnEdiData : CM_EDIDataLoadList;
begin
	create ediDatas transient;
	
	self.myVoyage.getAllEDILoadLists(ediDatas);
	
	foreach oneEdiData in ediDatas do
		if oneEdiData.isKindOf(CM_EDIDataLoadList) then			//should obviously be
			if oneEdiData.CM_EDIDataLoadList.listType = 'L' then
				//just return the first LOAD list you come across, this might need to be changed
				returnEdiData := oneEdiData.CM_EDIDataLoadList;
				break;
			endif;
		endif;
	endforeach;
	
	return returnEdiData;	
	
epilog
	delete ediDatas;
end;</source>
        <access>protected</access>
        <ReturnType type="CM_EDIDataLoadList"/>
    </JadeMethod>
    <JadeMethod name="getStageForOperator" id="06962794-9c3c-4466-9a81-ec4665a43ba7">
        <source>getStageForOperator(_stageName : Integer ; _operatorCode : String; _stageType : Integer) : CM_VoyageStage;			//navra1 - MTN-34829 - 8th May 2025
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2024	navra1	Initial creation for //navra1 - CR 65374 - 26th July 2024

*/

vars
	voyageStage, vS : CM_VoyageStage;
begin
	voyageStage := null;			//just making it explicit
	
	//get the voyage stage that was created for this in the previous step
	foreach vS in self.allStages do
		if vS.stage = _stageName then
			if _operatorCode &lt;&gt; null then				//if operator is given, match with it, otherwise we dont care about the operator, so return the stage
				if vS.operatorCode = _operatorCode then
					//navra1 - MTN-34829 - 8th May 2025 - start
					if _stageType &lt;&gt; null then
						if _stageType = vS.type then					
							voyageStage := vS;
							break;						
						endif;
					else
						voyageStage := vS;
						break;
					endif;
					//navra1 - MTN-34829 - 8th May 2025 - end
				endif;
			else
				//navra1 - MTN-34829 - 8th May 2025 - start
				if _stageType &lt;&gt; null then
					if _stageType = vS.type then					
						voyageStage := vS;
						break;					
					endif;
				else
					voyageStage := vS;
					break;
				endif;
				//navra1 - MTN-34829 - 8th May 2025 - end				
			endif;
		endif;
	endforeach;
	
	return voyageStage;
	
epilog

end;</source>
        <Parameter name="_stageName" type="Integer"/>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_stageType" type="Integer"/>
        <ReturnType type="CM_VoyageStage"/>
    </JadeMethod>
    <JadeMethod name="performDischCompStg" id="a4548f34-9ea9-41b2-be1f-a6fc2e54fb86">
        <source>performDischCompStg(_operator : CM_Operator; 
					_ediData : CM_EDIData)						//navra1 - MTN-34348 - 13th March 2025
					: Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		
	A boolean return value indicates to the caller if he should proceed to the next stage or not

Date		Who		Reason
18 July 2024	navra1	Initial creation for //navra1 - CR-65068/Task-64641 - Auto Comparison - 15th July 2024
29th July 2024	navra1	//navra1 - CR 65374 - 26th July 2024
18 Sep 2025 navlc30 JIRA 33860 Unit test UT_Voyage::tVoyageProcessAutoProgress needs to be fixed
*/

vars
	voyageStage : CM_VoyageStage;
	dischargeManLoadStageComplete : Boolean;
	comparisonAgent : CM_LoadListComparisonAgent;
	dischargeList : CM_EDIDataLoadList;
	operatorSet : CM_OperatorSet;
	ignoreFields : StringArray;
	email 			: CM_EDIDefaultEmail;						//navra1 - BUG 66007  - 6th Sep 2024
	emailController	: CMIF_EmailTemplateController;				//navra1 - BUG 66007  - 6th Sep 2024
	ediConparisonConfig : CM_EDIComparisonConfig;				//navra1 - BUG 66007  - 6th Sep 2024
	failureDescription : String;								//navra1 - CR 66185 - 18th Sep 2024
	voyStatus : CM_VoyageStatus;								//navra1 - MTN-33086 - 21st Oct 2024
	compiledPattern : JadeRegexPattern;							//navra1 - MTN-34348 - 13th March 2025
    splits : JadeRegexResult;									//navra1 - MTN-34348 - 13th March 2025
    splitsCount : Integer;										//navra1 - MTN-34348 - 13th March 2025
	resultsStr : String;										//navra1 - MTN-34348 - 13th March 2025
begin

	//navra1 - CR 65823 - 6th Sep 2024 - start
	if self.pauseProgress then
		return false;
	endif;
	//navra1 - CR 65823 - 6th Sep 2024 - end
	
	if self.myVoyage.myTerminal.myEDIComparisonConfig &lt;&gt; null then
		if not self.myVoyage.myTerminal.myEDIComparisonConfig.doAutoComparison then
			//if configuration says not to perform auto comparison, wait for manual comparison to happen, so stop here				//navra1 - BUG 65924 - 30th Aug 2024
			failureDescription := "Auto comparison is switch off, waiting for manual discharge comparison";							//navra1 - CR 66185 - 18th Sep 2024
			//navra1 - BUG 65924 - 30th Aug 2024 - start
			self.createOrUpdateVoyageStage(CM_VoyageStage.VoyStage_DischCompLoad, self, _operator.code, CM_VoyageStage.STATUS_WAITING, CM_VoyageStage.Type_Discharge, null, null, null, null, "Auto comparison is switch off, waiting for manual discharge comparison", failureDescription);		//navra1 - MTN-34348 - 13th March 2025
			return false;
			//navra1 - BUG 65924 - 30th Aug 2024 - end
		endif;
	else	//you havent configured anything with relation to auto comparison, fail with this as the reason					//navra1 - BUG 65924 - 30th Aug 2024
		failureDescription := "Terminal's comparison config is missing";							//navra1 - CR 66185 - 18th Sep 2024
		//navra1 - BUG 65924 - 30th Aug 2024 - start
		self.createOrUpdateVoyageStage(CM_VoyageStage.VoyStage_DischCompLoad, self, _operator.code, CM_VoyageStage.STATUS_FAILED, CM_VoyageStage.Type_Discharge, null, null, null, null, "Terminal's comparison config is missing", failureDescription);		//navra1 - MTN-34348 - 13th March 2025
		return false;
		//navra1 - BUG 65924 - 30th Aug 2024 - end
	endif;
	
	//to perform the discharge list comparison stage, you need to check if you already have passed these 2 stages:
	//1) successful stage of a discharge manifest from this operator for this voyage 
	//AND 
	//2) successful stage of a DISCHARGE list from this operator for this voyage - this need not be checked since this stage for this operator was created since a load list specified this operator	
	voyageStage := self.getStageForOperator(CM_VoyageStage.VoyStage_DischManLoad, _operator.code, null);				//navra1 - MTN-34829 - 8th May 2025
	if voyageStage &lt;&gt; null and voyageStage.status = CM_VoyageStage.STATUS_SUCCESS then
		dischargeManLoadStageComplete := true;
	endif;
	
	if dischargeManLoadStageComplete = false then
		//the discharge list compare stage is already in waiting, nothing to update, just return false to break the recursion
		return false;
	endif;	
	
	//get the load list to perform comparison
	//navra1 - MTN-34348-1 10th Apr 2025 - start
	dischargeList := self.getLatestDischListForMyVoyage();			//navra1 - MTN-34901 - 26th May 2025
	//dischargeList := self.getDischargeListForMyVoyage();			//navra1 - MTN-34901 - 26th May 2025
	if dischargeList &lt;&gt; null then		
		create compiledPattern transient;
		compiledPattern.compile("\\");
		splitsCount := compiledPattern.splitSubstring(dischargeList.fileName, 1, dischargeList.fileName.length(), splits);
		resultsStr := splits.at(splitsCount).value;
		resultsStr := resultsStr &amp; " - " &amp; dischargeList.createdTime.String &amp; CrLf;
	endif;
	//navra1 - MTN-34348 - 13th March 2025 - start
	//dischargeList := self.getDischargeListForMyVoyage();
	/*if _ediData.isKindOf(CM_EDIDataLoadList) then
		dischargeList := _ediData.CM_EDIDataLoadList;
		create compiledPattern transient;
		compiledPattern.compile("\\");
		splitsCount := compiledPattern.splitSubstring(_ediData.fileName, 1, _ediData.fileName.length(), splits);
		resultsStr := splits.at(splitsCount).value;
		resultsStr := resultsStr &amp; " - " &amp; _ediData.createdTime.String &amp; CrLf;
	endif; */
	//navra1 - MTN-34348 - 13th March 2025 - end
	//navra1 - MTN-34348-1 10th Apr 2025 - end
	
	if dischargeList = null then
		failureDescription := "Verified Discharge List not found!";							//navra1 - CR 66185 - 18th Sep 2024
		self.createOrUpdateVoyageStage(CM_VoyageStage.VoyStage_DischCompLoad, self, _operator.code, CM_VoyageStage.STATUS_FAILED, CM_VoyageStage.Type_Discharge, null, null, null, null, "Verified Discharge List not found!", failureDescription);		//navra1 - TFS 65376 - 31st July 2024 - 2	//navra1 - MTN-34348 - 13th March 2025
		return false;
	endif;
	
	create ignoreFields transient;
	
	if self.myVoyage.myTerminal.myEDIComparisonConfig &lt;&gt; null then
		self.myVoyage.myTerminal.myEDIComparisonConfig.ignoreFields.copy(ignoreFields);
	endif;
	
	//do the comparison for this operator
	create operatorSet transient;
	create comparisonAgent transient;
	operatorSet.add(_operator);
	comparisonAgent.doComparison(dischargeList, 
								self.myVoyage, 
								ignoreFields, 
								operatorSet, 
								TI_IMEX_STATUS_IMPORT, 
								true, 
								false, 
								false, 
								app.myPassport);
	
	//navra1 - TFS 65376 - 31st July 2024 - 1 - added the extra conditions
	/*if (comparisonAgent.allDiscrepancyTIs = null or comparisonAgent.allDiscrepancyTIs.size() = 0) and
		(comparisonAgent.allUnmatchedDBTIs = null or comparisonAgent.allUnmatchedDBTIs.size() = 0) and
		(comparisonAgent.allUnmatchedLLTIs = null or comparisonAgent.allUnmatchedLLTIs.size() = 0) then*/
	if self.comparisonOKForOperator(comparisonAgent, _operator) then					//navra1 - MTN-33185 - 1th Nov 2024
		//update the stage as SUCCESS and return true to continue recursion		
		//failureDescription := null;							//navra1 - CR 66185 - 18th Sep 2024
		failureDescription := "Perfect match between discharge list and discharge manifest";							//navra1 - MTN-33017 - 11th Oct 2024
		//you will always UPDATE the comparison stage, not create a new one in the below call, The stage would have been created in the previous stage and would be in waiting
		self.createOrUpdateVoyageStage(CM_VoyageStage.VoyStage_DischCompLoad, self, _operator.code, CM_VoyageStage.STATUS_SUCCESS, CM_VoyageStage.Type_Discharge, null, null, dischargeList, dischargeList.createdTime.String, null, resultsStr &amp; failureDescription);		//navra1 - MTN-34348 - 13th March 2025
		
		//navra1 - MTN-33086 - 21st Oct 2024 - start
		if self.pauseProgress then
			voyStatus := self.myVoyage.myVoyageProcess.allStatusesById[Voyage_Status_Autoff_Auto];
		else
			voyStatus := self.myVoyage.myVoyageProcess.allStatusesById[Voyage_Status_AutoOn_Auto];
		endif;
		if process.isInTransactionState() then
			app.myUtilityUA.utlUpdateVoyageVoyageStatus(self.myVoyage, voyStatus.id,false,app.myPassport);
		else
			app.myTrxUA.trxUpdateVoyageVoyageStatus(self.myVoyage, voyStatus.id,false,app.myPassport);
		endif;
		//navra1 - MTN-33086 - 21st Oct 2024 - end
		
		return true;					//COMPARISON PASSED - CONTINUE THE RECURSION
	else
		//update the stage as FAILURE and return false to stop recursion		
		//navra1 - CR 66185 - 18th Sep 2024 - start
		/*failureDescription := "AllDiscrepancyTIs = " &amp; comparisonAgent.allDiscrepancyTIs.size().String &amp; CrLf &amp;
								"AllUnmatchedDBTIs = " &amp; comparisonAgent.allUnmatchedDBTIs.size().String &amp; CrLf &amp;
								"AllUnmatchedLLTIs = " &amp; comparisonAgent.allUnmatchedLLTIs.size().String &amp; CrLf &amp; CrLf &amp;
								"Run Manual Comparison for more details";							
		*/		
		//navra1 - CR 66185 - 18th Sep 2024 - end
		//navra1 - MTN-33017 - 11th Oct 2024 - start
		failureDescription  := self.getComparisonFailureDesc(comparisonAgent, _operator.code);		//navra1 - MTN-33017 - 11th Oct 2024		//navra1 - MTN-34829 - 8th May 2025
		
		//you will always UPDATE the comparison stage, not create a new one in the below call, The stage would have been created in the previous stage and would be in waiting
		self.createOrUpdateVoyageStage(CM_VoyageStage.VoyStage_DischCompLoad, self, _operator.code, CM_VoyageStage.STATUS_FAILED, CM_VoyageStage.Type_Discharge, null, null, dischargeList, dischargeList.createdTime.String, "Discharge List comparison failed", resultsStr &amp; failureDescription);			//navra1 - CR 66185 - 18th Sep 2024		//navra1 - MTN-34348 - 13th March 2025
		
		//navra1 - BUG 66007  - 6th Sep 2024 - start
		ediConparisonConfig := self.myVoyage.myTerminal.myEDIComparisonConfig;
		if ediConparisonConfig &lt;&gt; null then
			if ediConparisonConfig.myEmailTemplate &lt;&gt; null then
				create email transient;
				create emailController transient;
				email.setEmailController(emailController);
				email.setFromEmailTemplate(ediConparisonConfig.myEmailTemplate);													
				if dischargeList &lt;&gt; null then
					dischargeList.emailNotify(email, false, null);
				endif;				
			endif;
		endif;
		//navra1 - BUG 66007  - 6th Sep 2024 - end
		
		//navra1 - MTN-33086 - 21st Oct 2024 - start
		if self.pauseProgress then
			voyStatus := self.myVoyage.myVoyageProcess.allStatusesById[Voyage_Status_Autoff_Auto];
		else
			voyStatus := self.myVoyage.myVoyageProcess.allStatusesById[Voyage_Status_AutoOn_Auto];
		endif;
		if process.isInTransactionState() then
			app.myUtilityUA.utlUpdateVoyageVoyageStatus(self.myVoyage, voyStatus.id,false,app.myPassport);
		else
			app.myTrxUA.trxUpdateVoyageVoyageStatus(self.myVoyage, voyStatus.id,false,app.myPassport);
		endif;
		//navra1 - MTN-33086 - 21st Oct 2024 - end
		
		return false;					//COMPARISON FAILED - //STOP THE RECURSION
	endif;
epilog
	delete operatorSet;		
	delete ignoreFields;
	delete email;						//navra1 - BUG 66007  - 6th Sep 2024
	if comparisonAgent &lt;&gt; null then
		comparisonAgent.allUnmatchedDBTIs.purge;
		comparisonAgent.allDiscrepancyTIs.purge;
		comparisonAgent.allMatchingTIs.purge;
		delete comparisonAgent;
	endif;
	delete compiledPattern;				//navra1 - MTN-34348 - 13th March 2025
	delete splits;						//18.09.2025 navlc30 #33860
end;</source>
        <access>protected</access>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="performDischListLoadStg" id="1932325c-a4b8-42c1-9f95-ca9ef954dabb">
        <updating/>
        <source>performDischListLoadStg(_ediData : CM_EDIData input) : Boolean protected, updating;		//navra1 - MTN-34829 - 8th May 2025
/*

Purpose:			

Parameters:			

Return Value:		
	A boolean return value indicates to the caller if he should proceed to the next stage or not

Date		Who		Reason
18 July 2024	navra1	Initial creation for //navra1 - CR-65068/Task-64641 - Auto Comparison - 15th July 2024
29th July 2024	navra1	//navra1 - CR 65374 - 26th July 2024

*/

vars
	pxyVoyageProgress : CM_VoyageProgress;
	ediTi : CM_EDITrackedItem;
	operatorCodeArray : StringArray;
	operatorCode : String;
	operator : CM_Operator;
	newDischOps : CM_OperatorArray;
	failureDescription : String;			//navra1 - CR 66185 - 18th Sep 2024
	involvedOp : CM_Operator;				//navra1 - MTN-33185 - 1th Nov 2024-1	
	voyStage : CM_VoyageStage;				//navra1 - MTN-34829 - 8th May 2025
begin	
	if _ediData = null or _ediData.ediDataType &lt;&gt; EDIDataType_LoadList then
		app.writeLog("EDIData passed to progressStage with stage VoyStage_DischListLoad was null or not LoadList, returing!", LogERROR);
		return false;			
	endif;
	
	/****************LOADLIST WOULD HAVE MULTIPLE OPERATORS	***************/
	
	//IDEALLY if another loadlist was uploaded, create a new stage for it, dont try to update any existing stage
	//BUT FOR NOW - for now just expect one load list only - so update stage	
	
	if _ediData.status = CM_EDIFile.EDI_STATUS_VERIFIED or _ediData.status = CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS  then			//navra1 - MTN-34830 - 23rd May 2025
		//failureDescription := null;							//navra1 - CR 66185 - 18th Sep 2024
		failureDescription := "Verified discharge list containing " &amp; _ediData.allEDITrackedItems.size().String &amp; " items";							//navra1 - MTN-33017 - 11th Oct 2024
		self.createOrUpdateVoyageStage(CM_VoyageStage.VoyStage_DischListLoad, self, null, CM_VoyageStage.STATUS_SUCCESS,CM_VoyageStage.Type_Discharge, null, null, _ediData, null, null, failureDescription);		//navra1 - MTN-34348 - 13th March 2025
		
		//DONT RETURN TRUE HERE, go on and create the VoyStage_DischCompLoad stages for the different operators as WAITING and return in the end
	else
		failureDescription := "EDI Data Status was not Verified - Discharge";							//navra1 - CR 66185 - 18th Sep 2024
		self.createOrUpdateVoyageStage(CM_VoyageStage.VoyStage_DischListLoad, self, null, CM_VoyageStage.STATUS_FAILED, CM_VoyageStage.Type_Discharge, null, null, _ediData, null, "EDI Data Status was not Verified - Discharge", failureDescription);		//navra1 - MTN-34348 - 13th March 2025
		
		return false;		//STOP THE RECURSION
	endif;

	//Also here you have to create one stage per operator on the discharge list which verifies if for the operator, a dischargelist(this one), and a manifest have been received and verified
	//this stage is VoyStage_DischCompLoadStr - one per operator - created as WAITING, which then proceeds to SUCCESS or FAILURE upon processing	
	create operatorCodeArray transient;
	foreach ediTi in _ediData.allEDITrackedItems do
		//navra1 - MTN-33185 - 1th Nov 2024-1 - start
		//skip operators for who the processing has been completed
		involvedOp := app.myRoot.allOperators[ediTi.CM_EDILoadListTI.operatorCode];
		
		//navra1 - MTN-34829 - 8th May 2025 - start
		/*
		if self.allCargoDischOperComplete.includes(involvedOp) then			
			app.writeLog("Not processing completed operator " &amp; involvedOp.code &amp; ", found in discharge list(TI="&amp;ediTi.id &amp; ")", LogWARN);
			continue;
		endif;
		*/
		//navra1 - MTN-33185 - 1th Nov 2024-1 - end
		
		//DONT LOOK INTO THE allCargoDischOperComplete COLLECTION AS ABOVE, instead look for a invoiceposted Stage for discharge for the operator and if it is successful, skip this operator
		if involvedOp &lt;&gt; null then
			voyStage := self.getStageForOperator(CM_VoyageStage.VoyStage_InvoicePosted, involvedOp.code, CM_VoyageStage.Type_Discharge);			//navra1 - MTN-34829 - 8th May 2025
			//The invoice posted stage need not be successful, as log as we got to that stage, we dont want to consider this manifest, this is according to the acceptance
			//criteria on 22nd May 2025 on MTN-34829
			if voyStage &lt;&gt; null then//and voyStage.type = CM_VoyageStage.Type_Discharge and voyStage.status = CM_VoyageStage.STATUS_SUCCESS then	//getStageForOperator already get the correct type load/discharge so no need to check
				app.writeLog("Not processing completed operator " &amp; involvedOp.code &amp; ", found in discharge list(TI="&amp;ediTi.id &amp; ")", LogERROR);
				continue;
			endif;
		endif;
		//navra1 - MTN-34829 - 8th May 2025 - end
		
		if not operatorCodeArray.includes(ediTi.CM_EDILoadListTI.operatorCode) then
			operatorCodeArray.tryAdd(ediTi.CM_EDILoadListTI.operatorCode);
			operator := app.myRoot.allOperators[ediTi.CM_EDILoadListTI.operatorCode];		
			
			if operator = null then
				app.writeLog("Invalid Operator Code",  LogERROR);
				return false;
			endif;
			
			create newDischOps transient;
			newDischOps.add(operator);
			pxyVoyageProgress := app.createUpdateProxy(self).CM_VoyageProgress;
			if process.isInTransactionState() then
				app.myUtilityUA.utlUpdateVoyageProgress(pxyVoyageProgress, newDischOps, null, null, null, self.pauseProgress, app.myPassport);						//navra1 - CR 65823 - 6th Sep 2024
			else
				app.myTrxUA.trxUpdateVoyageProgress(pxyVoyageProgress, newDischOps, null, null, null, self.pauseProgress, app.myPassport);							//navra1 - CR 65823 - 6th Sep 2024
			endif;
			delete newDischOps;			
			delete pxyVoyageProgress;
			
		endif;
	endforeach;
	
	//navra1 - BUG 65924 - 30th Aug 2024 - start
	//dont create comparison stages yet, they will take care of themselves
	//navra1 - BUG 65924 - 30th Aug 2024 - end
	
	return true;		//CONTINUE THE RECURSION
epilog	
	delete operatorCodeArray;
	delete pxyVoyageProgress;
	delete newDischOps;

end;</source>
        <access>protected</access>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="performDischManifestLoadStg" id="c933165a-a234-4063-87de-be1639dc3f69">
        <source>performDischManifestLoadStg(_ediData : CM_EDIData input) : Boolean protected;		//navra1 - MTN-34829 - 8th May 2025
/*

Purpose:			

Parameters:			

Return Value:		
	A boolean return value indicates to the caller if he should proceed to the next stage or not

Date		Who		Reason
18 July 2024	navra1	Initial creation for //navra1 - CR-65068/Task-64641 - Auto Comparison - 15th July 2024
29th July 2024	navra1	//navra1 - CR 65374 - 26th July 2024

*/

vars
	failureDescription : String;			//navra1 - CR 66185 - 18th Sep 2024
	ediTI : CM_EDITrackedItem;				//navra1 - CR 66185 - 18th Sep 2024
	numOfCargoItems : Integer;				//navra1 - CR 66185 - 18th Sep 2024
	pxyVoyageProgress : CM_VoyageProgress;	//navra1 - MTN-33076 - 17th Oct 2024
	newDischOps : CM_OperatorArray;			//navra1 - MTN-33076 - 17th Oct 2024
	operator : CM_Operator;					//navra1 - MTN-33076 - 17th Oct 2024
	involvedOp : CM_Operator;				//navra1 - MTN-33185 - 1th Nov 2024-1
	voyStage : CM_VoyageStage;				//navra1 - MTN-34829 - 8th May 2025
	err : String;							//navra1 - MTN-34829 - 8th May 2025
	ediErrSet : CM_EDIErrorSet;				//navra1 - MTN-34829 - 8th May 2025	
begin
	if _ediData = null or _ediData.ediDataType &lt;&gt; EDIDataType_ShipManifest  then
		app.writeLog("EDIData passed to progressStage with stage VoyStage_DischManLoadStr was null or not ShipManifest, returing!", LogERROR);
		return false;			
	endif;	
	
	//navra1 - MTN-33185 - 1th Nov 2024-1 - start
	//if the discharge operation was complete for this operator, dont process manifest belonging to this operator anymore
	involvedOp := app.myRoot.allOperators[_ediData.CM_EDIDataShipManifest.getCargoOperatorForShipManif()];	

	//navra1 - MTN-34829 - 8th May 2025 - start
	/*
	if self.allCargoDischOperComplete.includes(involvedOp) then
		app.writeLog("Not processing discharge manifest for processed operator " &amp; involvedOp.code &amp; ", returing!", LogWARN);
		return false;								//dont continue recursion
	endif;
	*/
	//DONT LOOK INTO THE allCargoDischOperComplete COLLECTION AS ABOVE, instead look for a invoiceposted Stage for discharge for the operator and if it is successful, skip this operator
	if involvedOp &lt;&gt; null then
		voyStage := self.getStageForOperator(CM_VoyageStage.VoyStage_InvoicePosted, involvedOp.code, CM_VoyageStage.Type_Discharge);			//navra1 - MTN-34829 - 8th May 2025
		//The invoice posted stage need not be successful, as log as we got to that stage, we dont want to consider this manifest, this is according to the acceptance
		//criteria on 22nd May 2025 on MTN-34829
		if voyStage &lt;&gt; null then//and voyStage.type = CM_VoyageStage.Type_Discharge and voyStage.status = CM_VoyageStage.STATUS_SUCCESS then	//getStageForOperator already get the correct type load/discharge so no need to check
			app.writeLog("Not processing discharge manifest for processed operator " &amp; involvedOp.code &amp; ", returing!", LogERROR);
			return false;								//dont continue recursion
		endif;
	endif;
	//navra1 - MTN-34829 - 8th May 2025 - end
	
	//navra1 - MTN-33185 - 1th Nov 2024-1 - end
	
	//if another manifest is uploaded from the same operator/same voyage(this voyage), and type(discharge or load manifest), the existing manifest stage should be updated, not create a new one	
	
	/****************IFCSUM MANIFEST WOULD HAVE ONLY ONE OPERATOR,AND IT WOULD BE EITHER LOAD OR DISCHARGE	***************/
	
	if _ediData.status = CM_EDIFile.EDI_STATUS_DBLOADED then
		//failureDescription := null;							//navra1 - CR 66185 - 18th Sep 2024		
		foreach ediTI in _ediData.allEDITrackedItems where ediTI.isEDICargo() do								//navra1 - MTN-33017 - 11th Oct 2024
			numOfCargoItems := numOfCargoItems + 1;																//navra1 - MTN-33017 - 11th Oct 2024
		endforeach;																								//navra1 - MTN-33017 - 11th Oct 2024
		failureDescription := "DB Loaded " &amp; numOfCargoItems.String &amp; " discharge cargo items";					//navra1 - MTN-33017 - 11th Oct 2024
		self.createOrUpdateVoyageStage(CM_VoyageStage.VoyStage_DischManLoad, self, _ediData.CM_EDIDataShipManifest.getCargoOperatorForShipManif(), CM_VoyageStage.STATUS_SUCCESS,CM_VoyageStage.Type_Discharge, null, null, _ediData, null, null, failureDescription);		//navra1 - MTN-34348 - 13th March 2025
		
		//navra1 - MTN-33076 - 17th Oct 2024 - start		
		operator := app.myRoot.allOperators[_ediData.CM_EDIDataShipManifest.getCargoOperatorForShipManif()];
		create newDischOps transient;
		newDischOps.add(operator);
		pxyVoyageProgress := app.createUpdateProxy(self).CM_VoyageProgress;
		if process.isInTransactionState() then
			app.myUtilityUA.utlUpdateVoyageProgress(pxyVoyageProgress, newDischOps, null, null, null, self.pauseProgress, app.myPassport);						//navra1 - CR 65823 - 6th Sep 2024
		else
			app.myTrxUA.trxUpdateVoyageProgress(pxyVoyageProgress, newDischOps, null, null, null, self.pauseProgress, app.myPassport);							//navra1 - CR 65823 - 6th Sep 2024
		endif;
		delete newDischOps;			
		delete pxyVoyageProgress;		
		//navra1 - MTN-33076 - 17th Oct 2024 - end
		
		return true;			//CONTINUE THE RECURSION
	else
		failureDescription := "EDI Data Status was not DB Loaded - Discharge";							//navra1 - CR 66185 - 18th Sep 2024
		self.createOrUpdateVoyageStage(CM_VoyageStage.VoyStage_DischManLoad, self, _ediData.CM_EDIDataShipManifest.getCargoOperatorForShipManif(), CM_VoyageStage.STATUS_FAILED, CM_VoyageStage.Type_Discharge, null, null, _ediData, null, "EDI Data Status was not DB Loaded - Discharge", failureDescription);	//navra1 - MTN-34348 - 13th March 2025
		
		return false;			//STOP THE RECURSION
	endif;

epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="performDischMovesForOpStg" id="3538deaf-c9dc-40f5-aecf-9f595f324c5b">
        <source>performDischMovesForOpStg(_operator : CM_Operator) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		
	A boolean return value indicates to the caller if he should proceed to the next stage or not

Date		Who		Reason
18 July 2024	navra1	Initial creation for //navra1 - CR-65068/Task-64641 - Auto Comparison - 15th July 2024
29th July 2024	navra1	//navra1 - CR 65374 - 26th July 2024

*/

vars
	terminal : CM_Terminal;
	moveSuccessful : Boolean;
	voyage : CM_Voyage;	
	dischLocation : CM_LocationsController;
	tiSet : CM_TISet;
	tiSetTranship : CM_TISet;												//navra1 - TFS 65376 - 31st July 2024 - 1
	moveController : CMIF_MoveController;
	firstTI : CM_TrackedItem;
	ti : CM_TrackedItem;
	theTis : CM_TIByIdCargoTypeDict;
	tiSetTranshipSize, tiSetSize : Integer;	
	moveTS : TimeStamp;
	failureDescription : String;			//navra1 - CR 66185 - 18th Sep 2024
	tisMovedCnt, transhipTiMovedCnt : Integer;	//navra1 - MTN-33309- 1st Nov 2024
begin

	//navra1 - CR 65823 - 6th Sep 2024 - start
	if self.pauseProgress then
		return false;
	endif;
	//navra1 - CR 65823 - 6th Sep 2024 - end
	
	voyage := self.myVoyage;
	
	//NOTE: the edidata that came in could be either CM_EDIDataLoadList or CM_EDIShipManifest depending upon the 
	//order in which the user loaded it, so check and get the list of TI name accordingly	
	create tiSet transient;
	create tiSetTranship transient;									//navra1 - TFS 65376 - 31st July 2024 - 1	
	
	terminal := voyage.getMyTerminal();						//navra1 - TFS 65376 - 31st July 2024 - 1 - start
	
	if terminal.myEDIAutoMove &lt;&gt; null then	
		dischLocation := terminal.myEDIAutoMove.myTranshipDischargeLC;
		moveTS := terminal.myEDIAutoMove.getDateForMove(voyage); // ### TFS BUG 65730 22AUG2024 NAVAB1
	else
		moveTS := null; // ### TFS BUG 65730 22AUG2024 NAVAB1
	endif;	
	
	//navra1 - CR 65374 - 26th July 2024 - start
	theTis := voyage.allOnshipTIsByIdCargoType;
	foreach ti in theTis do
		if ti.operatorCode = _operator.code and not ti.receivedDT.isValid() then	//only discharge those belonging to this operator and have not been discharged(receivedDT not valid)
			if ti.isTranshipItem then													//navra1 - TFS 65376 - 31st July 2024 - 1
				tiSetTranship.add(ti);													//navra1 - TFS 65376 - 31st July 2024 - 1
			else																		//navra1 - TFS 65376 - 31st July 2024 - 1
				//add to tiset to discharge item found to be discharged
				tiSet.add(ti);
			endif;																		//navra1 - TFS 65376 - 31st July 2024 - 1
		endif;
	endforeach;
	//navra1 - CR 65374 - 26th July 2024 - end
	
	tiSetTranshipSize := tiSetTranship.size();
	tiSetSize := tiSet.size();
	
	if tiSetTranship.size() = 0 and tiSet.size() = 0 then
		failureDescription := "No cargo to move";							//navra1 - CR 66185 - 18th Sep 2024
		self.createOrUpdateVoyageStage(CM_VoyageStage.VoyStage_DischManMoved, self, _operator.code, CM_VoyageStage.STATUS_FAILED,CM_VoyageStage.Type_Discharge, null, null, null, null, "No cargo to move", failureDescription);	//navra1 - MTN-34348 - 13th March 2025
		
		return false;
	endif;	
	
	//if you have tranship items to move
	if tiSetTranship.size() &gt; 0 then																						//navra1 - CR 65374 - 26th July 2024 - start
		if dischLocation = null then
			failureDescription := "Disch Location is not configured for tranship cargo";							//navra1 - CR 66185 - 18th Sep 2024
			self.createOrUpdateVoyageStage(CM_VoyageStage.VoyStage_DischManMoved, self, _operator.code, CM_VoyageStage.STATUS_FAILED,CM_VoyageStage.Type_Discharge, null, null, null, null, "Disch Location is not configured for tranship cargo", failureDescription);		//navra1 - MTN-34348 - 13th March 2025
		
			return false;
		endif;
		
		transhipTiMovedCnt := tiSetTranship.size();																	//navra1 - MTN-33309- 1st Nov 2024
		
		create moveController transient;		
		firstTI := tiSetTranship.first;
		tiSetTranship.remove(firstTI);
		moveController.setMyTrackedItem(firstTI);		
		moveController.setAllOtherTrackedItems(tiSetTranship);			
		moveController.setMyToPrimaryLocation(dischLocation);														//navra1 - TFS 65376 - 31st July 2024 - 1		
		moveController.isMoveToPlanned := false;
		moveController.setMoveMode(REAL_MODE);
		moveController.isFromAutoProgression := true;																//navra1 - TFS 65376 - 31st July 2024 - 1
		moveController.retrospectiveDT := moveTS; // ### TFS BUG 65730 22AUG2024 NAVAB1
		moveController.isNonCraneVoyageMove := true; // ### TFS BUG 65730 22AUG2024 NAVAB1
		
		//navra1 - CR 65374 - 26th July 2024 - start
		app.myPassport.setWarningsIgnored(true);
		app.myPassport.warningsAcknowledged := true;		
		
		if process.isInTransactionState() then
			app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, app.myPassport);
		else
			app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
		endif;		
		
		if not app.myPassport.hasErrorsOrWarnings then	
			moveSuccessful := true;		
		endif;
		
		delete moveController;
		//navra1 - CR 65374 - 26th July 2024 - end
	else
		transhipTiMovedCnt := 0;																						//navra1 - MTN-33309- 1st Nov 2024
		moveSuccessful := true;
	endif;
	
	if moveSuccessful then
		moveSuccessful := false;							//reset the flag											//navra1 - TFS 65376 - 31st July 2024 - 1
		if tiSet.size() &gt; 0 then																						//navra1 - CR 65374 - 26th July 2024 - start
			tisMovedCnt := tiSet.size();																				//navra1 - MTN-33309- 1st Nov 2024

			create moveController transient;		
			firstTI := tiSet.first;
			tiSet.remove(firstTI);
			moveController.setMyTrackedItem(firstTI);		
			moveController.setAllOtherTrackedItems(tiSet);			
			moveController.setMyToPrimaryLocation(null);																//navra1 - TFS 65376 - 31st July 2024 - 1
			moveController.isMoveToPlanned := false;
			moveController.setMoveMode(REAL_MODE);
			moveController.isFromAutoProgression := true;																//navra1 - TFS 65376 - 31st July 2024 - 1
			moveController.retrospectiveDT := moveTS; // ### TFS BUG 65730 22AUG2024 NAVAB1
			moveController.isNonCraneVoyageMove := true; // ### TFS BUG 65730 22AUG2024 NAVAB1
			
			//navra1 - CR 65374 - 26th July 2024 - start
			app.myPassport.setWarningsIgnored(true);
			app.myPassport.warningsAcknowledged := true;
			
			if process.isInTransactionState() then
				app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, app.myPassport);
			else
				app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
			endif;
		
			if not app.myPassport.hasErrorsOrWarnings then	
				moveSuccessful := true;
			endif;
			
			delete moveController;
			//navra1 - CR 65374 - 26th July 2024 - end		
		else																											//navra1 - BUG 66173 - 17th Sep 2024
			tisMovedCnt := 0;																							//navra1 - MTN-33309- 1st Nov 2024
			moveSuccessful := true;																						//navra1 - BUG 66173 - 17th Sep 2024
		endif;	
	endif;

	if moveSuccessful then
		//failureDescription := null;							//navra1 - CR 66185 - 18th Sep 2024
		failureDescription := "Discharged " &amp; tisMovedCnt.String &amp; " import items, and " &amp; transhipTiMovedCnt.String &amp; " tranship items";				//navra1 - MTN-33017 - 11th Oct 2024	//navra1 - MTN-33309- 1st Nov 2024
		self.createOrUpdateVoyageStage(CM_VoyageStage.VoyStage_DischManMoved, self, _operator.code, CM_VoyageStage.STATUS_SUCCESS,CM_VoyageStage.Type_Discharge, null, null, null, null, null, failureDescription);		//navra1 - MTN-34348 - 13th March 2025
		
		return true;				//CONTINUE THE RECURSION
	else		
		failureDescription := "Discharge moves were not successful - " &amp; CrLf &amp; app.myPassport.getAllErrorsAndWarningsAsStr();							//navra1 - CR 66185 - 18th Sep 2024
		self.createOrUpdateVoyageStage(CM_VoyageStage.VoyStage_DischManMoved, self, _operator.code, CM_VoyageStage.STATUS_FAILED,CM_VoyageStage.Type_Discharge, null, null, null, null, "Discharge moves were not successful", failureDescription);		//navra1 - MTN-34348 - 13th March 2025
		
		return false;				//STOP THE RECURSION
	endif;	
	
epilog		
	delete tiSet;
	delete tiSetTranship;										//navra1 - TFS 65376 - 31st July 2024 - 1		
	delete moveController;
end;</source>
        <access>protected</access>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="performGenInvoicesForOpStg" id="36ed95a7-275f-42ce-89ae-be6db611a633">
        <source>performGenInvoicesForOpStg(_operator : CM_Operator; _stageType : Integer) : Boolean protected;		//navra1 - MTN-34829 - 8th May 2025
/*

Purpose:			

Parameters:			

Return Value:		
	A boolean return value indicates to the caller if he should proceed to the next stage or not

Date		Who		Reason
18 July 2024	navra1	Initial creation for //navra1 - CR-65068/Task-64641 - Auto Comparison - 15th July 2024
29th July 2024	navra1	//navra1 - CR 65374 - 26th July 2024 //navra1 - TFS 65376 - 31st July 2024 - 1

*/
vars
	debtorCode : String;									//navra1 - TFS 65376 - 31st July 2024
	invList, invListNotPosted : CM_InvoiceBySeqNumDict;		//navra1 - MTN-35009- 5th June 2025
	invoice : CM_Invoice;
	failureDescription : String;							//navra1 - CR 66185 - 18th Sep 2024	
	
begin
	
	//navra1 - CR 65823 - 6th Sep 2024 - start
	if self.pauseProgress then
		return false;
	endif;
	//navra1 - CR 65823 - 6th Sep 2024 - end	
	
	create invListNotPosted transient;						//navra1 - MTN-35009- 5th June 2025
	
	//navra1 - CR 65374 - 26th July 2024 - start
	if _operator.debtor.allInvoices = null or _operator.debtor.allInvoices.size = 0 then
		failureDescription := "No invoices found for operator - " &amp; _operator.code;							//navra1 - CR 66185 - 18th Sep 2024
		self.createOrUpdateVoyageStage(CM_VoyageStage.VoyStage_InvoiceGenerated, self, _operator.code, CM_VoyageStage.STATUS_FAILED, _stageType, null, null, null, null, "No invoices found for operator - " &amp; _operator.code, failureDescription);	//navra1 - MTN-34348 - 13th March 2025		//navra1 - MTN-34829 - 8th May 2025
		
		return false;
	endif;
	//navra1 - CR 65374 - 26th July 2024 - end
	
	//navra1 - TFS 65376 - 31st July 2024 - 1 - start
	debtorCode := _operator.debtor.code;
	if debtorCode = '' then
		debtorCode := _operator.debtor.name;
	endif;
	//navra1 - TFS 65376 - 31st July 2024 - 1 - end
	
	create invList transient;
	if _operator.debtor &lt;&gt; null then
		foreach invoice in _operator.debtor.allInvoices do
			if invoice.myTerminal &lt;&gt; self.myVoyage.myTerminal then
				continue;
			endif;
			
			if invoice.myVoyage &lt;&gt; self.myVoyage then
				continue;
			endif;
			
			invList.add(invoice);
		endforeach;
	endif;
	
	//navra1 - MTN-35009- 5th June 2025 - start
	foreach invoice in invList do
		if invoice.status &lt;&gt; CM_Invoice.INVOICE_POSTED and invoice.status &lt;&gt; CM_Invoice.INVOICE_POSTED_PENDING then
			invListNotPosted.add(invoice);
		endif;
	endforeach;
	//navra1 - MTN-35009- 5th June 2025 - end
	
	//failureDescription := null;							//navra1 - CR 66185 - 18th Sep 2024
	failureDescription := "Generated " &amp; invListNotPosted.size().String &amp; " invoices for debtor " &amp; debtorCode;							//navra1 - MTN-33017 - 11th Oct 2024		//navra1 - MTN-35009- 5th June 2025
	self.createOrUpdateVoyageStage(CM_VoyageStage.VoyStage_InvoiceGenerated, self, _operator.code, CM_VoyageStage.STATUS_SUCCESS, _stageType, invListNotPosted, debtorCode,null, null, null, failureDescription);		//navra1 - MTN-34348 - 13th March 2025		//navra1 - MTN-34829 - 8th May 2025		//navra1 - MTN-35009- 5th June 2025
		
	return true;
		
epilog	
	delete invList;
	delete invListNotPosted;						//navra1 - MTN-35009- 5th June 2025
end;</source>
        <access>protected</access>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_stageType" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="performInvoicePostForOp" id="1c4afc39-ee64-4b45-8924-88c2046fc5ed">
        <source>performInvoicePostForOp(_operator : CM_Operator; _stageType : Integer) : Boolean protected;		//navra1 - MTN-34829 - 8th May 2025
/*

Purpose:			

Parameters:			

Return Value:		
	A boolean return value indicates to the caller if he should proceed to the next stage or not

Date		Who		Reason
18 July 2024	navra1	Initial creation for //navra1 - CR-65068/Task-64641 - Auto Comparison - 15th July 2024
29th July 2024	navra1	//navra1 - CR 65374 - 26th July 2024
13 Dec 2024 navlc30 JIRA 33644 NSW | Autoclosure - Invoices Not Posted
22 Jan 2024	jlier1  33939
*/

vars
	invoice : CM_Invoice;
	//removeOps : CM_OperatorArray;
	//pxyVoyageProgress : CM_VoyageProgress;
	pxyInvoice : CM_Invoice;	
	theStatus : CMIF_InvoiceStatus;
	invList, invListPosted : CM_InvoiceBySeqNumDict;	//navra1 - MTN-35009- 5th June 2025
	debtorCode : String;								//navra1 - TFS 65376 - 31st July 2024
	failureDescription : String;						//navra1 - CR 66185 - 18th Sep 2024	
	finIOClass : CM_ExtFinanceIO;
	removeOps : CM_OperatorArray;						//navra1 - MTN-34829 - 8th May 2025
	pxyVoyageProgress : CM_VoyageProgress;				//navra1 - MTN-34829 - 8th May 2025
begin

	//navra1 - CR 65823 - 6th Sep 2024 - start
	if self.pauseProgress then
		return false;
	endif;
	//navra1 - CR 65823 - 6th Sep 2024 - end
	finIOClass := self.myVoyage.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
	create invList transient;
	create invListPosted transient;						//navra1 - MTN-35009- 5th June 2025
	
	if _operator.debtor &lt;&gt; null then
		foreach invoice in _operator.debtor.allInvoices do
			if invoice.myTerminal &lt;&gt; self.myVoyage.myTerminal then
				continue;
			endif;
			
			if invoice.myVoyage &lt;&gt; self.myVoyage then
				continue;
			endif;
			
			if invoice.status = CM_Invoice.INVOICE_OPEN then				
				pxyInvoice := app.createUpdateProxy(invoice).CM_Invoice;
	
				create theStatus transient;
				theStatus.myInvoice := pxyInvoice;
				theStatus.newStatus := CM_Invoice.INVOICE_PENDING;				
				
				if process.isInTransactionState() then
					app.myUtilityUA.utlUpdateInvStatusDetailed(theStatus, app.myPassport);
				else			
					app.myTrxUA.trxUpdateInvoiceStatus(theStatus, app.myPassport);
				endif;			
				
				delete pxyInvoice;												//navra1 - TFS 65376 - 31st July 2024 - 1
				delete theStatus;
			endif;
			
			if invoice.status = CM_Invoice.INVOICE_PENDING then			
				pxyInvoice := app.createUpdateProxy(invoice).CM_Invoice;
	
				create theStatus transient;
				theStatus.myInvoice := pxyInvoice;
				if invoice.myInvoiceProcess.isInvoiceAPIProcess then
					theStatus.newStatus := CM_Invoice.INVOICE_POSTED_PENDING;	
				else
					theStatus.newStatus := CM_Invoice.INVOICE_POSTED;								
				endif;
				
				theStatus.isZeroRatedTax := invoice.isZeroRatedTax;
				//theStatus.myTermsOfTrade := invoice.termsOfTrade;
				theStatus.purchaseOrderNumber := invoice.purchaseOrderNumber;
				theStatus.narration := invoice.narration;
				theStatus.toDT.setDate(invoice.getEndDate());
				theStatus.toDT.setTime('23:59:59.999'.Time);
				theStatus.doExport :=  true;
				
				if process.isInTransactionState() then
					app.myUtilityUA.utlUpdateInvStatusDetailed(theStatus, app.myPassport);
				else			
					app.myTrxUA.trxUpdateInvoiceStatus(theStatus, app.myPassport);
				endif;				
				
				if finIOClass &lt;&gt; null and  theStatus.newStatus = CM_Invoice.INVOICE_POSTED_PENDING then
					finIOClass.export(invoice);					
				endif;
				
				invListPosted.add(invoice);									//navra1 - MTN-35009- 5th June 2025
				
				delete pxyInvoice;											//navra1 - TFS 65376 - 31st July 2024 - 1
				delete theStatus;
			endif;
			
			invList.add(invoice);
		endforeach;
	endif;
	
	//navra1 - TFS 65376 - 31st July 2024 - 1 - start
	debtorCode := _operator.debtor.code;
	if debtorCode = '' then
		debtorCode := _operator.debtor.name;
	endif;
	//navra1 - TFS 65376 - 31st July 2024 - 1 - end
	if app.myPassport.hasErrors() then
		failureDescription := app.myPassport.getAllErrorsAndWarningsAsStr();							//navra1 - CR 66185 - 18th Sep 2024
		self.createOrUpdateVoyageStage(CM_VoyageStage.VoyStage_InvoicePosted, self, _operator.code, CM_VoyageStage.STATUS_FAILED, _stageType, invListPosted, debtorCode, null, null, app.myPassport.getAllErrorsAndWarningsAsStr(), failureDescription);		//navra1 - MTN-34348 - 13th March 2025		//navra1 - MTN-34829 - 8th May 2025		//navra1 - MTN-35009- 5th June 2025
		
		return false;			//STOP THE RECURSION
	else
		//failureDescription := app.myPassport.getAllErrorsAndWarningsAsStr();							//navra1 - CR 66185 - 18th Sep 2024
		failureDescription := "Posted " &amp; invListPosted.size().String &amp; " invoices for debtor " &amp; debtorCode;							//navra1 - MTN-33017 - 11th Oct 2024	//navra1 - MTN-35009- 5th June 2025
		self.createOrUpdateVoyageStage(CM_VoyageStage.VoyStage_InvoicePosted, self, _operator.code, CM_VoyageStage.STATUS_SUCCESS, _stageType, invListPosted, debtorCode, null, null, null, failureDescription);		//navra1 - MTN-34348 - 13th March 2025		//navra1 - MTN-34829 - 8th May 2025		//navra1 - MTN-35009- 5th June 2025
		
		//CONTINUE TO DO THE REST - UPDATE PROGRESS
	endif;
	
	
/*	Moving the below Operator deletion to performVoyageClose as we now post invoice for Manifest completed and then proceed to following Load/Dicharge  //13.12.2024 navlc30 #33644

	//invList				
	//remove this operator from load operators and discharge operators - we will come here only if load and discharge are completed for the operator, so it can be safely removed
	create removeOps transient;
	removeOps.add(_operator);
	pxyVoyageProgress := app.createUpdateProxy(self).CM_VoyageProgress;
	if process.isInTransactionState() then
		app.myUtilityUA.utlUpdateVoyageProgress(pxyVoyageProgress, null, null, removeOps, removeOps, self.pauseProgress, app.myPassport);				//navra1 - CR 65823 - 6th Sep 2024
	else
		app.myTrxUA.trxUpdateVoyageProgress(pxyVoyageProgress, null, null, removeOps, removeOps, self.pauseProgress, app.myPassport);					//navra1 - CR 65823 - 6th Sep 2024
	endif;
	delete pxyVoyageProgress;
	delete removeOps;*/	
	
	//navra1 - MTN-34829 - 8th May 2025 - start
	//remove this operator from load/discharge operators based on the _stageType since the invoice has been posted for that stageType for that operator
	create removeOps transient;
	removeOps.add(_operator);
	pxyVoyageProgress := app.createUpdateProxy(self).CM_VoyageProgress;
	if process.isInTransactionState() then
		if _stageType = CM_VoyageStage.Type_Discharge then
			app.myUtilityUA.utlUpdateVoyageProgress(pxyVoyageProgress, null, null, removeOps, null, self.pauseProgress, app.myPassport);
		else
			app.myUtilityUA.utlUpdateVoyageProgress(pxyVoyageProgress, null, null, null, removeOps, self.pauseProgress, app.myPassport);
		endif;
	else
		if _stageType = CM_VoyageStage.Type_Discharge then
			app.myTrxUA.trxUpdateVoyageProgress(pxyVoyageProgress, null, null, removeOps, null, self.pauseProgress, app.myPassport);
		else
			app.myTrxUA.trxUpdateVoyageProgress(pxyVoyageProgress, null, null, null, removeOps, self.pauseProgress, app.myPassport);
		endif;
	endif;
	//navra1 - MTN-34829 - 8th May 2025 - end
	
	return true;
	
epilog
	//delete removeOps;
	delete theStatus;
	//delete pxyVoyageProgress;
	delete pxyInvoice;				//navra1 - TFS 65376 - 31st July 2024 - 1
	delete invList;
	delete invListPosted;			//navra1 - MTN-35009- 5th June 2025
	delete removeOps;			//navra1 - MTN-34829 - 8th May 2025
	delete pxyVoyageProgress;	//navra1 - MTN-34829 - 8th May 2025
end;</source>
        <access>protected</access>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_stageType" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="performLoadCompStg" id="87728e2e-c83a-4d4d-b7b6-a6029bcd9676">
        <source>performLoadCompStg(_operator : CM_Operator; 
				   _ediData : CM_EDIData) 		//navra1 - MTN-34348 - 13th March 2025
				   : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		
	A boolean return value indicates to the caller if he should proceed to the next stage or not

Date		Who		Reason
18 July 2024	navra1	Initial creation for //navra1 - CR-65068/Task-64641 - Auto Comparison - 15th July 2024
29th July 2024	navra1	//navra1 - CR 65374 - 26th July 2024 - 1
18 Sep 2025 navlc30 JIRA 33860 Unit test UT_Voyage::tVoyageProcessAutoProgress needs to be fixed

*/

vars
	voyageStage : CM_VoyageStage;
	loadManLoadStageComplete : Boolean;
	comparisonAgent : CM_LoadListComparisonAgent;
	loadList : CM_EDIDataLoadList;
	operatorSet : CM_OperatorSet;
	ignoreFields : StringArray;
	email 			: CM_EDIDefaultEmail;						//navra1 - BUG 66007  - 6th Sep 2024
	emailController	: CMIF_EmailTemplateController;				//navra1 - BUG 66007  - 6th Sep 2024
	ediConparisonConfig : CM_EDIComparisonConfig;				//navra1 - BUG 66007  - 6th Sep 2024
	failureDescription : String;								//navra1 - CR 66185 - 18th Sep 2024
	voyStatus : CM_VoyageStatus;								//navra1 - MTN-33086 - 21st Oct 2024
	compiledPattern : JadeRegexPattern;							//navra1 - MTN-34348 - 13th March 2025
    splits : JadeRegexResult;									//navra1 - MTN-34348 - 13th March 2025
    splitsCount : Integer;										//navra1 - MTN-34348 - 13th March 2025
	resultsStr : String;										//navra1 - MTN-34348 - 13th March 2025
begin
	//navra1 - CR 65823 - 6th Sep 2024 - start
	if self.pauseProgress then
		return false;
	endif;
	//navra1 - CR 65823 - 6th Sep 2024 - end
	
	if self.myVoyage.myTerminal.myEDIComparisonConfig &lt;&gt; null then
		if not self.myVoyage.myTerminal.myEDIComparisonConfig.doAutoComparison then
			//if configuration says not to perform auto comparison, wait for manual comparison to happen, so stop here				//navra1 - BUG 65924 - 30th Aug 2024
			failureDescription := "Auto comparison is switch off, waiting for manual load comparison";							//navra1 - CR 66185 - 18th Sep 2024
			//navra1 - BUG 65924 - 30th Aug 2024 - start			
			self.createOrUpdateVoyageStage(CM_VoyageStage.VoyStage_LoadCompLoad, self, _operator.code, CM_VoyageStage.STATUS_WAITING, CM_VoyageStage.Type_Load, null, null, null, null, "Auto comparison is switch off, waiting for manual load comparison", failureDescription);	//navra1 - MTN-34348 - 13th March 2025
			return false;
			//navra1 - BUG 65924 - 30th Aug 2024 - end
		endif;
	else	//you havent configured anything with relation to auto comparison, fail with this as the reason					//navra1 - BUG 65924 - 30th Aug 2024
		failureDescription := "Terminal's comparison config is missing";							//navra1 - CR 66185 - 18th Sep 2024
		//navra1 - BUG 65924 - 30th Aug 2024 - start
		self.createOrUpdateVoyageStage(CM_VoyageStage.VoyStage_LoadCompLoad, self, _operator.code, CM_VoyageStage.STATUS_FAILED, CM_VoyageStage.Type_Load, null, null, null, null, "Terminal's comparison config is missing", failureDescription);		//navra1 - MTN-34348 - 13th March 2025
		return false;
		//navra1 - BUG 65924 - 30th Aug 2024 - end
	endif;
	
	//to perform the load list comparison stage, you need to check if you already have passed these 2 stages:
	//1) successful stage of a load manifest from this operator for this voyage 
	//AND 
	//2) successful stage of a LOAD list from this operator for this voyage - this need not be checked since this stage for this operator was created since a load list specified this operator
	voyageStage := self.getStageForOperator(CM_VoyageStage.VoyStage_LoadManLoad, _operator.code, null);				//navra1 - MTN-34829 - 8th May 2025
	if voyageStage &lt;&gt; null and voyageStage.status = CM_VoyageStage.STATUS_SUCCESS then
		loadManLoadStageComplete := true;		
	endif;	
	
	if loadManLoadStageComplete = false then
		//the load list compare stage is already in waiting, nothing to update, just return false to break the recursion
		return false;
	endif;	
	
	//you should have a found a stage, and it should be in waiting status	
	
	//get the load list to perform comparison
	//navra1 - MTN-34348-1 10th Apr 2025 - start	
	loadList := self.getLatestLoadListForMyVoyage();				//navra1 - MTN-34901 - 26th May 2025
	//loadList := self.getLoadListForMyVoyage();					//navra1 - MTN-34901 - 26th May 2025
	if loadList &lt;&gt; null then		
		create compiledPattern transient;
		compiledPattern.compile("\\");
		splitsCount := compiledPattern.splitSubstring(loadList.fileName, 1, loadList.fileName.length(), splits);
		resultsStr := splits.at(splitsCount).value;
		resultsStr := resultsStr &amp; " - " &amp; loadList.createdTime.String &amp; CrLf;
	endif;
	//navra1 - MTN-34348 - 13th March 2025 - start
	//loadList := self.getLoadListForMyVoyage();
	/*if _ediData.isKindOf(CM_EDIDataLoadList) then
		loadList := _ediData.CM_EDIDataLoadList;
		create compiledPattern transient;
		compiledPattern.compile("\\");
		splitsCount := compiledPattern.splitSubstring(_ediData.fileName, 1, _ediData.fileName.length(), splits);
		resultsStr := splits.at(splitsCount).value;
		resultsStr := resultsStr &amp; " - " &amp; _ediData.createdTime.String &amp; CrLf;
	endif; */
	//navra1 - MTN-34348 - 13th March 2025 - end
	//navra1 - MTN-34348-1 10th Apr 2025 - end
	
	if loadList = null then
		failureDescription := "Verified Load List not found!";							//navra1 - CR 66185 - 18th Sep 2024
		self.createOrUpdateVoyageStage(CM_VoyageStage.VoyStage_LoadCompLoad, self, _operator.code, CM_VoyageStage.STATUS_FAILED, CM_VoyageStage.Type_Load, null, null, null, null, "Verified Load List not found!", failureDescription);		//navra1 - TFS 65376 - 31st July 2024 - 2	//navra1 - MTN-34348 - 13th March 2025
		return false;
	endif;
	
	create ignoreFields transient;
	
	if self.myVoyage.myTerminal.myEDIComparisonConfig &lt;&gt; null then
		self.myVoyage.myTerminal.myEDIComparisonConfig.ignoreFields.copy(ignoreFields);
	endif;
	
	//do the comparison for this operator
	create operatorSet transient;
	create comparisonAgent transient;
	operatorSet.add(_operator);
	comparisonAgent.doComparison(loadList, 
								self.myVoyage, 
								ignoreFields, 
								operatorSet, 
								TI_IMEX_STATUS_EXPORT, 
								true, 
								false, 
								false, 
								app.myPassport);
	
	//navra1 - TFS 65376 - 31st July 2024 - 1 - added the extra conditions
	/*if (comparisonAgent.allDiscrepancyTIs = null or comparisonAgent.allDiscrepancyTIs.size() = 0) and
		(comparisonAgent.allUnmatchedDBTIs = null or comparisonAgent.allUnmatchedDBTIs.size() = 0) and
		(comparisonAgent.allUnmatchedLLTIs = null or comparisonAgent.allUnmatchedLLTIs.size() = 0) then*/
	if self.comparisonOKForOperator(comparisonAgent, _operator) then				//navra1 - MTN-33185 - 1th Nov 2024
		//update the stage as SUCCESS and return true to continue recursion
		//failureDescription := null;							//navra1 - CR 66185 - 18th Sep 2024
		failureDescription := "Perfect match between load list and load manifest";							//navra1 - MTN-33017 - 11th Oct 2024
		self.createOrUpdateVoyageStage(CM_VoyageStage.VoyStage_LoadCompLoad, self, _operator.code, CM_VoyageStage.STATUS_SUCCESS, CM_VoyageStage.Type_Load, null, null, loadList, loadList.createdTime.String, null, resultsStr &amp; failureDescription);		//navra1 - MTN-34348 - 13th March 2025
		
		//navra1 - MTN-33086 - 21st Oct 2024 - start
		if self.pauseProgress then
			voyStatus := self.myVoyage.myVoyageProcess.allStatusesById[Voyage_Status_Autoff_Auto];
		else
			voyStatus := self.myVoyage.myVoyageProcess.allStatusesById[Voyage_Status_AutoOn_Auto];
		endif;
		if process.isInTransactionState() then
			app.myUtilityUA.utlUpdateVoyageVoyageStatus(self.myVoyage, voyStatus.id,false,app.myPassport);
		else
			app.myTrxUA.trxUpdateVoyageVoyageStatus(self.myVoyage, voyStatus.id,false,app.myPassport);
		endif;
		//navra1 - MTN-33086 - 21st Oct 2024 - end
		
		return true;					//COMPARISON PASSED - CONTINUE THE RECURSION
	else
		//navra1 - CR 66185 - 18th Sep 2024 - start
		/*failureDescription := "AllDiscrepancyTIs = " &amp; comparisonAgent.allDiscrepancyTIs.size().String &amp; CrLf &amp;
								"AllUnmatchedDBTIs = " &amp; comparisonAgent.allUnmatchedDBTIs.size().String &amp; CrLf &amp;
								"AllUnmatchedLLTIs = " &amp; comparisonAgent.allUnmatchedLLTIs.size().String &amp; CrLf &amp; CrLf &amp;
								"Run Manual Comparison for more details";							
		*/
		//navra1 - CR 66185 - 18th Sep 2024 - end		
		failureDescription  := self.getComparisonFailureDesc(comparisonAgent, _operator.code);						//navra1 - MTN-33017 - 11th Oct 2024		//navra1 - MTN-34829 - 8th May 2025
		
		//update the stage as FAILURE and return false to stop recursion
		self.createOrUpdateVoyageStage(CM_VoyageStage.VoyStage_LoadCompLoad, self, _operator.code, CM_VoyageStage.STATUS_FAILED, CM_VoyageStage.Type_Load, null, null, loadList, loadList.createdTime.String, "Load List comparison failed", resultsStr &amp;  failureDescription);			//navra1 - MTN-34348 - 13th March 2025
		
		//navra1 - BUG 66007  - 6th Sep 2024 - start
		ediConparisonConfig := self.myVoyage.myTerminal.myEDIComparisonConfig;
		if ediConparisonConfig &lt;&gt; null then
			if ediConparisonConfig.myEmailTemplate &lt;&gt; null then
				create email transient;
				create emailController transient;
				email.setEmailController(emailController);
				email.setFromEmailTemplate(ediConparisonConfig.myEmailTemplate);									
				if loadList &lt;&gt; null then
					loadList.emailNotify(email, false, null);
				endif;				
			endif;
		endif;
		//navra1 - BUG 66007  - 6th Sep 2024 - end
		
		//navra1 - MTN-33086 - 21st Oct 2024 - start
		if self.pauseProgress then
			voyStatus := self.myVoyage.myVoyageProcess.allStatusesById[Voyage_Status_Autoff_Auto];
		else
			voyStatus := self.myVoyage.myVoyageProcess.allStatusesById[Voyage_Status_AutoOn_Auto];
		endif;
		if process.isInTransactionState() then
			app.myUtilityUA.utlUpdateVoyageVoyageStatus(self.myVoyage, voyStatus.id,false,app.myPassport);
		else
			app.myTrxUA.trxUpdateVoyageVoyageStatus(self.myVoyage, voyStatus.id,false,app.myPassport);
		endif;
		//navra1 - MTN-33086 - 21st Oct 2024 - end
		
		return false;					//COMPARISON FAILED - //STOP THE RECURSION
	endif;
epilog
	delete operatorSet;		
	delete ignoreFields;
	delete email;						//navra1 - BUG 66007  - 6th Sep 2024
	if comparisonAgent &lt;&gt; null then
		comparisonAgent.allUnmatchedDBTIs.purge;
		comparisonAgent.allDiscrepancyTIs.purge;
		comparisonAgent.allMatchingTIs.purge;
		delete comparisonAgent;
	endif;
	delete compiledPattern;				//navra1 - MTN-34348 - 13th March 2025
	delete splits;						//18.09.2025 navlc30 #33860
end;</source>
        <access>protected</access>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="performLoadListLoadStg" id="d7b6a73d-39f9-488a-80e4-1f2d5dab6bd4">
        <source>performLoadListLoadStg(_ediData : CM_EDIData) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		
	A boolean return value indicates to the caller if he should proceed to the next stage or not

Date		Who		Reason
18 July 2024	navra1	Initial creation for //navra1 - CR-65068/Task-64641 - Auto Comparison - 15th July 2024
29th July 2024	navra1	//navra1 - CR 65374 - 26th July 2024

*/

vars
	pxyVoyageProgress : CM_VoyageProgress;
	ediTi : CM_EDITrackedItem;
	operatorCodeArray : StringArray;
	operatorCode : String;
	operator : CM_Operator;
	newLoadOps : CM_OperatorArray;
	failureDescription : String;			//navra1 - CR 66185 - 18th Sep 2024
	involvedOp : CM_Operator;				//navra1 - MTN-33185 - 1th Nov 2024-1
	voyStage : CM_VoyageStage;				//navra1 - MTN-34829 - 8th May 2025
begin

	if _ediData = null or _ediData.ediDataType &lt;&gt; EDIDataType_LoadList then
		app.writeLog("EDIData passed to progressStage with stage VoyStage_LoadListLoad was null or not LoadList, returing!", LogERROR);
		return false;			
	endif;
	
	/****************LOADLIST WOULD HAVE MULTIPLE OPERATORS	***************/
	
	//IDEALLY if another loadlist was uploaded, create a new stage for it, dont try to update any existing stage
	//BUT FOR NOW - for now just expect one load list only - so update stage	
	
	if _ediData.status = CM_EDIFile.EDI_STATUS_VERIFIED or _ediData.status = CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS then			//navra1 - MTN-34830 - 23rd May 2025
		//failureDescription := null;								//navra1 - CR 66185 - 18th Sep 2024 - start
		failureDescription := "Verified load list containing " &amp; _ediData.allEDITrackedItems.size().String &amp; " items";							//navra1 - MTN-33017 - 11th Oct 2024								
		self.createOrUpdateVoyageStage(CM_VoyageStage.VoyStage_LoadListLoad, self, null, CM_VoyageStage.STATUS_SUCCESS,CM_VoyageStage.Type_Load, null, null, _ediData, null, null, failureDescription);		
		
		//DONT RETURN TRUE HERE, go on and create the VoyStage_DischCompLoad stages for the different operators as WAITING and return in the end
	else
		failureDescription := "EDI Data Status was not Verified - Load";								//navra1 - CR 66185 - 18th Sep 2024 - start
		self.createOrUpdateVoyageStage(CM_VoyageStage.VoyStage_LoadListLoad, self, null, CM_VoyageStage.STATUS_FAILED,CM_VoyageStage.Type_Load, null, null, _ediData, null, "EDI Data Status was not Verified - Load", failureDescription);		//navra1 - MTN-34348 - 13th March 2025
		
		return false;		//STOP THE RECURSION
	endif;
	
	//Also here you have to create one stage per operator on the Load list which verifies if for the operator, a loadlist(this one), and a manifest have been received and verified
	//this stage is VoyStage_LoadCompLoadStr - one per operator - created as WAITING, which then proceeds to SUCCESS or FAILURE upon processing
	create operatorCodeArray transient;	
	foreach ediTi in _ediData.allEDITrackedItems do
		//navra1 - MTN-33185 - 1th Nov 2024-1 - start
		//skip operators for who the processing has been completed
		involvedOp := app.myRoot.allOperators[ediTi.CM_EDILoadListTI.operatorCode];
		
		//navra1 - MTN-34829 - 8th May 2025 - start
		/*
		if self.allCargoLoadOperComplete.includes(involvedOp) then
			app.writeLog("Not processing completed operator " &amp; involvedOp.code &amp; ", found in load list(TI="&amp;ediTi.id &amp; ")", LogWARN);
			continue;
		endif;
		*/
		//navra1 - MTN-33185 - 1th Nov 2024-1 - end		
		
		//DONT LOOK INTO THE allCargoLoadOperComplete COLLECTION AS ABOVE, instead look for a invoiceposted Stage for load for the operator and if it is successful, skip this operator
		if involvedOp &lt;&gt; null then
			voyStage := self.getStageForOperator(CM_VoyageStage.VoyStage_InvoicePosted, involvedOp.code, CM_VoyageStage.Type_Load);					//navra1 - MTN-34829 - 8th May 2025
			//The invoice posted stage need not be successful, as log as we got to that stage, we dont want to consider this manifest, this is according to the acceptance
			//criteria on 22nd May 2025 on MTN-34829
			if voyStage &lt;&gt; null then //and voyStage.type = CM_VoyageStage.Type_Load and voyStage.status = CM_VoyageStage.STATUS_SUCCESS then		//getStageForOperator already get the correct type load/discharge so no need to check				
				app.writeLog("Not processing completed operator " &amp; involvedOp.code &amp; ", found in load list(TI="&amp;ediTi.id &amp; ")", LogERROR);
				continue;
			endif;
		endif;
		//navra1 - MTN-34829 - 8th May 2025 - end
		
		if not operatorCodeArray.includes(ediTi.CM_EDILoadListTI.operatorCode) then
			operatorCodeArray.tryAdd(ediTi.CM_EDILoadListTI.operatorCode);
			operator := app.myRoot.allOperators[ediTi.CM_EDILoadListTI.operatorCode];			
			
			if operator = null then
				app.writeLog("Invalid Operator Code",  LogERROR);
				return false;
			endif;
			
			create newLoadOps transient;
			newLoadOps.add(operator);
			pxyVoyageProgress := app.createUpdateProxy(self).CM_VoyageProgress;
			if process.isInTransactionState() then
				app.myUtilityUA.utlUpdateVoyageProgress(pxyVoyageProgress, null, newLoadOps, null, null, self.pauseProgress, app.myPassport);					//navra1 - CR 65823 - 6th Sep 2024
			else
				app.myTrxUA.trxUpdateVoyageProgress(pxyVoyageProgress, null, newLoadOps, null, null, self.pauseProgress, app.myPassport);						//navra1 - CR 65823 - 6th Sep 2024
			endif;
			delete newLoadOps;
			delete pxyVoyageProgress;
			
		endif;
	endforeach;
	
	//navra1 - BUG 65924 - 30th Aug 2024 - start	
	//dont create comparison stages yet, they will take care of themselves	
	//navra1 - BUG 65924 - 30th Aug 2024 - end
		
	return true;		//CONTINUE THE RECURSION
epilog	
	delete operatorCodeArray;
	delete newLoadOps;
end;</source>
        <access>protected</access>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="performLoadManifestLoadStg" id="1a2dd2af-005d-43bf-b127-797300b5fef2">
        <source>performLoadManifestLoadStg(_ediData : CM_EDIData) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		
	A boolean return value indicates to the caller if he should proceed to the next stage or not

Date		Who		Reason
18 July 2024	navra1	Initial creation for //navra1 - CR-65068/Task-64641 - Auto Comparison - 15th July 2024
29th July 2024	navra1	//navra1 - CR 65374 - 26th July 2024

*/

vars
	failureDescription : String;						//navra1 - CR 66185 - 18th Sep 2024	
	numOfCargoItems : Integer;							//navra1 - CR 66185 - 18th Sep 2024	
	ediTI : CM_EDITrackedItem;							//navra1 - CR 66185 - 18th Sep 2024
	pxyVoyageProgress : CM_VoyageProgress;				//navra1 - MTN-33076 - 17th Oct 2024
	newLoadOps : CM_OperatorArray;						//navra1 - MTN-33076 - 17th Oct 2024
	operator : CM_Operator;								//navra1 - MTN-33076 - 17th Oct 2024
	involvedOp : CM_Operator;							//navra1 - MTN-33185 - 1th Nov 2024-1
	voyStage : CM_VoyageStage;							//navra1 - MTN-34829 - 8th May 2025
	err : String;										//navra1 - MTN-34829 - 8th May 2025
	ediErrSet : CM_EDIErrorSet;							//navra1 - MTN-34829 - 8th May 2025
begin
	if _ediData = null or _ediData.ediDataType &lt;&gt; EDIDataType_ShipManifest then
		app.writeLog("EDIData passed to progressStage with stage VoyStage_LoadManLoadStr was null or not ShipManifest, returing!", LogERROR);
		return false;
	endif;
	
	//navra1 - MTN-33185 - 1th Nov 2024-1 - start
	//if the load operation was complete for this operator, dont process manifest belonging to this operator anymore
	involvedOp := app.myRoot.allOperators[_ediData.CM_EDIDataShipManifest.getCargoOperatorForShipManif()];
	
	//navra1 - MTN-34829 - 8th May 2025 - start
	/*
	if self.allCargoLoadOperComplete.includes(involvedOp) then
		app.writeLog("Not processing load manifest for processed operator " &amp; involvedOp.code &amp; ", returing!", LogWARN);
		return false;						//dont continue recursion
	endif;
	*/
	//DONT LOOK INTO THE allCargoLoadOperComplete COLLECTION AS ABOVE, instead look for a invoiceposted Stage for load for the operator and if it is successful, skip this operator
	if involvedOp &lt;&gt; null then
		voyStage := self.getStageForOperator(CM_VoyageStage.VoyStage_InvoicePosted, involvedOp.code, CM_VoyageStage.Type_Load);					//navra1 - MTN-34829 - 8th May 2025
		//The invoice posted stage need not be successful, as log as we got to that stage, we dont want to consider this manifest, this is according to the acceptance
		//criteria on 22nd May 2025 on MTN-34829
		if voyStage &lt;&gt; null then //and voyStage.type = CM_VoyageStage.Type_Load and voyStage.status = CM_VoyageStage.STATUS_SUCCESS then		//getStageForOperator already get the correct type load/discharge so no need to check
			app.writeLog("Not processing discharge manifest for processed operator " &amp; involvedOp.code &amp; ", returing!", LogERROR);
			return false;								//dont continue recursion
		endif;
	endif;
	//navra1 - MTN-34829 - 8th May 2025 - end
	
	//navra1 - MTN-33185 - 1th Nov 2024-1 - end
	
	//if another manifest is uploaded from the same operator/same voyage(this voyage), and type(discharge or load manifest), the existing manifest stage should be updated, not create a new one	
	
	/****************IFCSUM MANIFEST WOULD HAVE ONLY ONE OPERATOR,AND IT WOULD BE EITHER LOAD OR DISCHARGE	***************/
	
	if _ediData.status = CM_EDIFile.EDI_STATUS_DBLOADED then
		//failureDescription := null;								//navra1 - CR 66185 - 18th Sep 2024 - start
		foreach ediTI in _ediData.allEDITrackedItems where ediTI.isEDICargo() do								//navra1 - MTN-33017 - 11th Oct 2024
			numOfCargoItems := numOfCargoItems + 1;																//navra1 - MTN-33017 - 11th Oct 2024
		endforeach;																								//navra1 - MTN-33017 - 11th Oct 2024
		failureDescription := "DB Loaded " &amp; numOfCargoItems.String &amp; " load cargo items";						//navra1 - MTN-33017 - 11th Oct 2024
		self.createOrUpdateVoyageStage(CM_VoyageStage.VoyStage_LoadManLoad, self, _ediData.CM_EDIDataShipManifest.getCargoOperatorForShipManif(), CM_VoyageStage.STATUS_SUCCESS,CM_VoyageStage.Type_Load, null, null, _ediData, null, null, failureDescription);		//navra1 - MTN-34348 - 13th March 2025
		
		//navra1 - MTN-33076 - 17th Oct 2024 - start		
		operator := app.myRoot.allOperators[_ediData.CM_EDIDataShipManifest.getCargoOperatorForShipManif()];
		create newLoadOps transient;
		newLoadOps.add(operator);
		pxyVoyageProgress := app.createUpdateProxy(self).CM_VoyageProgress;
		if process.isInTransactionState() then
			app.myUtilityUA.utlUpdateVoyageProgress(pxyVoyageProgress, null, newLoadOps, null, null, self.pauseProgress, app.myPassport);					//navra1 - CR 65823 - 6th Sep 2024
		else
			app.myTrxUA.trxUpdateVoyageProgress(pxyVoyageProgress, null, newLoadOps, null, null, self.pauseProgress, app.myPassport);						//navra1 - CR 65823 - 6th Sep 2024
		endif;
		delete newLoadOps;
		delete pxyVoyageProgress;		
		//navra1 - MTN-33076 - 17th Oct 2024 - end
		
		return true;				//CONTINUE THE RECURSION
	else
		failureDescription := "EDI Data Status was not DB Loaded";								//navra1 - CR 66185 - 18th Sep 2024 - start
		self.createOrUpdateVoyageStage(CM_VoyageStage.VoyStage_LoadManLoad, self, _ediData.CM_EDIDataShipManifest.getCargoOperatorForShipManif(), CM_VoyageStage.STATUS_FAILED,CM_VoyageStage.Type_Load, null, null, _ediData, null, "EDI Data Status was not DB Loaded", failureDescription);		//navra1 - MTN-34348 - 13th March 2025
		
		return false;				//STOP THE RECURSION
	endif;

epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="performLoadMovesForOpStg" id="0ee7ef8d-8672-46c6-aebf-ef9328ab00e7">
        <source>performLoadMovesForOpStg(_operator : CM_Operator) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		
	A boolean return value indicates to the caller if he should proceed to the next stage or not

Date		Who		Reason
18 July 2024	navra1	Initial creation for //navra1 - CR-65068/Task-64641 - Auto Comparison - 15th July 2024
29th July 2024	navra1	//navra1 - CR 65374 - 26th July 2024

*/

vars
	terminal : CM_Terminal;
	moveSuccessful : Boolean;
	errMsg : String;
	voyage : CM_Voyage;
	voyageBS : CM_VoyageController;
	tiSet : CM_TISet;
	moveController : CMIF_MoveController;
	firstTI : CM_TrackedItem;
	theTis : CM_TIByIdCargoTypeDict;
	ti : CM_TrackedItem;
	moveTS : TimeStamp;
	failureDescription : String;			//navra1 - CR 66185 - 18th Sep 2024
	tisMovedCnt : Integer;					//navra1 - MTN-33309- 1st Nov 2024
begin
	//navra1 - CR 65823 - 6th Sep 2024 - start
	if self.pauseProgress then
		return false;
	endif;
	//navra1 - CR 65823 - 6th Sep 2024 - end
	
	voyage := self.myVoyage;

	//NOTE: the edidata that came in could be either CM_EDIDataLoadList or CM_EDIShipManifest depending upon the 
	//order in which the user loaded it, so check and get the list of TI name accordingly	
	create tiSet transient;
	
	terminal := voyage.getMyTerminal();				//navra1 - TFS 65376 - 31st July 2024 - 1
	
	// ### TFS BUG 65730 22AUG2024 NAVAB1
	if terminal.myEDIAutoMove &lt;&gt; null then	
		moveTS := terminal.myEDIAutoMove.getDateForMove(voyage); 
	else
		moveTS := null;
	endif;	
	
	//navra1 - CR 65374 - 26th July 2024 - start
	voyageBS := voyage.myShipBlockStack;
	theTis := voyage.allOnsiteTIsByIdCargoType;
	foreach ti in theTis do
		if ti.operatorCode = _operator.code and not ti.releasedDT.isValid() then	//only load those belonging to this operator and have not been loaded(releasedDT not valid)
			//add to tiset to discharge item found to be discharged
			tiSet.add(ti);
		endif;
	endforeach;
	//navra1 - CR 65374 - 26th July 2024 - end	
	
	if tiSet.size() &gt; 0 then															//navra1 - CR 65374 - 26th July 2024
		tisMovedCnt := tiSet.size();													//navra1 - MTN-33309- 1st Nov 2024
		
		create moveController transient;		
		firstTI := tiSet.first;
		tiSet.remove(firstTI);
		moveController.setMyTrackedItem(firstTI);
		moveController.setAllOtherTrackedItems(tiSet);		
		moveController.setMyToPrimaryLocation(voyageBS);	
		moveController.isMoveToPlanned := false;
		moveController.setMoveMode(REAL_MODE);
		moveController.isFromAutoProgression := true;							//navra1 - TFS 65376 - 31st July 2024 - 1			
		moveController.retrospectiveDT := moveTS; // ### TFS BUG 65730 22AUG2024 NAVAB1
		
		//navra1 - CR 65374 - 26th July 2024 - start
		app.myPassport.setWarningsIgnored(true);
		app.myPassport.warningsAcknowledged := true;
		
		if process.isInTransactionState() then
			app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, app.myPassport);
		else			
			app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
		endif;
		
		if not app.myPassport.hasErrorsOrWarnings then
			moveSuccessful := true;
		endif;
		//navra1 - CR 65374 - 26th July 2024 - end
	else
		tisMovedCnt := 0;														//navra1 - MTN-33309- 1st Nov 2024
		errMsg := "No cargo to move";
	endif;
	
	if moveSuccessful then		
		//failureDescription := null;								//navra1 - CR 66185 - 18th Sep 2024 - start
		failureDescription := "Loaded " &amp; tisMovedCnt.String &amp; " items";							//navra1 - MTN-33017 - 11th Oct 2024	//navra1 - MTN-33309- 1st Nov 2024
		self.createOrUpdateVoyageStage(CM_VoyageStage.VoyStage_LoadManMoved, self, _operator.code, CM_VoyageStage.STATUS_SUCCESS,CM_VoyageStage.Type_Load, null, null, null, null, null, failureDescription);		//navra1 - MTN-34348 - 13th March 2025
	
		return true;				//CONTINUE THE RECURSION
	else		
		if errMsg = '' then
			errMsg := app.myPassport.getAllErrorsAndWarningsAsStr();
		endif;
		
		failureDescription := "Load moves were not successful - " &amp; CrLf &amp; errMsg;								//navra1 - CR 66185 - 18th Sep 2024 - start
		
		self.createOrUpdateVoyageStage(CM_VoyageStage.VoyStage_LoadManMoved, self, _operator.code, CM_VoyageStage.STATUS_FAILED,CM_VoyageStage.Type_Load, null, null, null, null, errMsg &amp; "Load moves were not successful", failureDescription);	//navra1 - MTN-34348 - 13th March 2025
		
		return false;				//STOP THE RECURSION
	endif;	
	
epilog	
	
	delete tiSet;
	delete moveController;
end;</source>
        <access>protected</access>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="performVoyageClose" id="a89bac50-799f-4c14-b3cd-ef9cdaf3f114">
        <source>performVoyageClose(_operator : CM_Operator) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		
	A boolean return value indicates to the caller if he should proceed to the next stage or not

Date		Who		Reason
18 July 2024	navra1	Initial creation for //navra1 - CR-65068/Task-64641 - Auto Comparison - 15th July 2024
29th July 2024	navra1	//navra1 - CR 65374 - 26th July 2024 //navra1 - TFS 65376 - 31st July 2024 - 1
13 Dec 2024 navlc30 JIRA 33644 NSW | Autoclosure - Invoices Not Posted

*/

vars
	terminal : CM_Terminal;
	voyStatusForClose : CM_VoyageStatus;
	infoMessage : String;					//navra1 - BUG 65924 - 30th Aug 2024
	failureDescription : String;			//navra1 - CR 66185 - 18th Sep 2024
	removeOps : CM_OperatorArray;
	pxyVoyageProgress : CM_VoyageProgress;	
begin	
	
	terminal := self.myVoyage.myTerminal;

	//Below	 Code Block Moved from performInvoicePostForOp				//13.12.2024 navlc30 #33644
	//invList
	//remove this operator from load operators and discharge operators - we will come here only if load and discharge are completed for the operator, so it can be safely removed
	create removeOps transient;
	removeOps.add(_operator);
	pxyVoyageProgress := app.createUpdateProxy(self).CM_VoyageProgress;
	if process.isInTransactionState() then
		//app.myUtilityUA.utlUpdateVoyageProgress(pxyVoyageProgress, null, null, removeOps, removeOps, self.pauseProgress, app.myPassport);				//navra1 - CR 65823 - 6th Sep 2024
		//navra1 - MTN-34829 - 8th May 2025 - DONT TOUCH THE OPERATORS NOW
		app.myUtilityUA.utlUpdateVoyageProgress(pxyVoyageProgress, null, null, null, null, self.pauseProgress, app.myPassport);				//navra1 - MTN-34829 - 8th May 2025
	else
		//app.myTrxUA.trxUpdateVoyageProgress(pxyVoyageProgress, null, null, removeOps, removeOps, self.pauseProgress, app.myPassport);					//navra1 - CR 65823 - 6th Sep 2024
		//navra1 - MTN-34829 - 8th May 2025 - DONT TOUCH THE OPERATORS NOW
		app.myTrxUA.trxUpdateVoyageProgress(pxyVoyageProgress, null, null, null, null, self.pauseProgress, app.myPassport);					//navra1 - MTN-34829 - 8th May 2025
	endif;

	
	//navra1 - MTN-33076 - 17th Oct 2024 - debtor/invoices not appropriate for this stage

	if self.allCargoDischargeOperators.size() = 0 and self.allCargoLoadOperators.size() = 0 then
		if terminal.myEDIAutoMove &lt;&gt; null then
			voyStatusForClose := terminal.myEDIAutoMove.myVoyageStatusForClosure;
		else
			voyStatusForClose := self.myVoyage.myVoyageProcess.allStatusesById[Voyage_Status_Closed_Auto];
		endif;
		
		if voyStatusForClose = null then
			//navra1 - BUG 65924 - 30th Aug 2024 - start
			voyStatusForClose := self.myVoyage.myVoyageProcess.allStatusesById[Voyage_Status_Closed_Auto];
			infoMessage := "Since voyage status for close was not configured, assumed CLOSED status";
			//navra1 - BUG 65924 - 30th Aug 2024 - end		
		endif;	
		
		if process.isInTransactionState() then
			app.myUtilityUA.utlUpdateVoyageVoyageStatus(self.myVoyage, voyStatusForClose.id,false,app.myPassport);
		else
			app.myTrxUA.trxUpdateVoyageVoyageStatus(self.myVoyage, voyStatusForClose.id,false,app.myPassport);
		endif;
		
		if not app.myPassport.hasErrors() then			
			failureDescription := "Voyage state transitioned to " &amp; voyStatusForClose.description;							//navra1 - MTN-33017 - 11th Oct 2024
			self.createOrUpdateVoyageStage(CM_VoyageStage.VoyStage_VoyageClosed, self, null, CM_VoyageStage.STATUS_SUCCESS, null, null, null, null, null, infoMessage, failureDescription);			//navra1 - BUG 65924 - 30th Aug 2024 - start	//navra1 - MTN-33076 - 17th Oct 2024 - debtor/invoices not appropriate for this stage	//navra1 - MTN-34348 - 13th March 2025
			
			return true;			
			
		else
			failureDescription := "Voyage was not closed - " &amp; CrLf &amp; app.myPassport.getAllErrorsAndWarningsAsStr();								//navra1 - CR 66185 - 18th Sep 2024 - start
			
			self.createOrUpdateVoyageStage(CM_VoyageStage.VoyStage_VoyageClosed, self, null, CM_VoyageStage.STATUS_FAILED, null, null, null, null, null, "Trx to close the voyage failed", failureDescription);	//navra1 - MTN-33076 - 17th Oct 2024 - debtor/invoices not appropriate for this stage	//navra1 - MTN-34348 - 13th March 2025
			
			return false;
		endif;		
	endif;	
	
	failureDescription := "There are still operators that are processing";								//navra1 - CR 66185 - 18th Sep 2024 - start
	
	self.createOrUpdateVoyageStage(CM_VoyageStage.VoyStage_VoyageClosed, self, null, CM_VoyageStage.STATUS_WAITING, null, null, null, null, null, "There are still operators that are processing",failureDescription);	//navra1 - MTN-33076 - 17th Oct 2024 - debtor/invoices not appropriate for this stage		//navra1 - MTN-34348 - 13th March 2025
	
	return false;	
epilog
	delete pxyVoyageProgress;				//13.12.2024 navlc30 #33644
	delete removeOps;						//13.12.2024 navlc30 #33644
end;</source>
        <access>protected</access>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="progressStage" id="006cf4b5-a969-4ac1-9207-2f1711e1a84d">
        <updating/>
        <source>progressStage(_stage : Integer; _ediData : CM_EDIData input; _passedOperator : CM_Operator; _stageType : Integer) updating;		//navra1 - MTN-34829 - 8th May 2025
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 July 2024	navra1	Initial creation for //navra1 - CR-65068/Task-64641 - Auto Comparison - 15th July 2024
29th July 2024	navra1	//navra1 - CR 65374 - 26th July 2024
13 Dec 2024 navlc30 JIRA 33644 NSW | Autoclosure - Invoices Not Posted

*/

vars
	loadManifest : Boolean;
	stageSuccess : Boolean;
	loadListLoadStageSuccess,
	dischListLoadStageSuccess : Boolean;
	loadManLoadStageSuccess,
	dischManLoadStageSuccess : Boolean;
	localVarOperator : CM_Operator;
	operatorList : CM_OperatorArray;
begin
	if _stage = null then
		app.writeLog("Stage passed to progressStage was null, returing!", LogERROR);
		return;
	endif;	
	
	if _stage =  CM_VoyageStage.VoyStage_LoadManLoad then
		stageSuccess := false;
		stageSuccess := self.performLoadManifestLoadStg(_ediData);
		//check if the stage was a success, call the next stage, otherwise return			
		if stageSuccess then			
			//call the next stage, which will determine if the load manifest stage was loaded successfully and the load list stage was done successfully			
			self.progressStage(CM_VoyageStage.VoyStage_LoadCompLoad, _ediData, null, CM_VoyageStage.Type_Load);		//navra1 - MTN-34829 - 8th May 2025
		else
			return;
		endif;
	elseif _stage = CM_VoyageStage.VoyStage_DischManLoad then
		stageSuccess := false;
		stageSuccess := self.performDischManifestLoadStg(_ediData);
		//check if the stage was a success, call the next stage, otherwise return		
		if stageSuccess then
			//call the next stage, which will determine if the load manifest stage was loaded successfully and the load list stage was done successfully			
			self.progressStage(CM_VoyageStage.VoyStage_DischCompLoad, _ediData, null, CM_VoyageStage.Type_Discharge);		//navra1 - MTN-34829 - 8th May 2025
		else
			return;
		endif;		
	elseif _stage = CM_VoyageStage.VoyStage_LoadListLoad then
		stageSuccess := false;
		stageSuccess := self.performLoadListLoadStg(_ediData);
		if stageSuccess then
			//call the next stage, which will determine if the load manifest stage was loaded successfully and the load list stage was done successfully			
			self.progressStage(CM_VoyageStage.VoyStage_LoadCompLoad, _ediData, null, CM_VoyageStage.Type_Load);		//navra1 - MTN-34829 - 8th May 2025
		else
			return;
		endif;
	elseif _stage = CM_VoyageStage.VoyStage_DischListLoad then
		stageSuccess := false;
		stageSuccess := self.performDischListLoadStg(_ediData);
		if stageSuccess then
			//call the next stage, which will determine if the load manifest stage was loaded successfully and the load list stage was done successfully			
			self.progressStage(CM_VoyageStage.VoyStage_DischCompLoad, _ediData, null, CM_VoyageStage.Type_Discharge);		//navra1 - MTN-34829 - 8th May 2025
		else
			return;
		endif;
	elseif _stage = CM_VoyageStage.VoyStage_LoadCompLoad then
		//perform this stage for each localVarOperator that wants to load
		create operatorList transient;
		self.allCargoLoadOperators.copy(operatorList);
		foreach localVarOperator in operatorList do
			stageSuccess := false;			
			stageSuccess := self.performLoadCompStg(localVarOperator, _ediData);		//navra1 - MTN-34348 - 13th March 2025
			if stageSuccess then
				//call the next stage, which will determine if the load manifest stage was loaded successfully and the load list stage was done successfully			
				self.progressStage(CM_VoyageStage.VoyStage_LoadManMoved, _ediData, localVarOperator, CM_VoyageStage.Type_Load);		//navra1 - MTN-34829 - 8th May 2025
			else				
				continue;					//navra1 - TFS 65376 - 31st July 2024 - 1
			endif;			
		endforeach;	
		delete operatorList;
	elseif _stage = CM_VoyageStage.VoyStage_DischCompLoad then
		//perform this stage for each localVarOperator that wants to discharge
		create operatorList transient;
		self.allCargoDischargeOperators.copy(operatorList);
		foreach localVarOperator in operatorList do
			stageSuccess := false;
			stageSuccess := self.performDischCompStg(localVarOperator, _ediData);		//navra1 - MTN-34348 - 13th March 2025
			if stageSuccess then
				//call the next stage, which will determine if the load manifest stage was loaded successfully and the load list stage was done successfully			
				self.progressStage(CM_VoyageStage.VoyStage_DischManMoved, _ediData, localVarOperator, CM_VoyageStage.Type_Discharge);		//navra1 - MTN-34829 - 8th May 2025
			else				
				continue;					//navra1 - TFS 65376 - 31st July 2024 - 1
			endif;
		endforeach;
		delete operatorList;		
	elseif _stage = CM_VoyageStage.VoyStage_LoadManMoved then		
		//perform move stage for this localVarOperator that the comparison completed successfully			
		stageSuccess := false;
		stageSuccess := self.performLoadMovesForOpStg(_passedOperator);						//navra1 - TFS 65376 - 31st July 2024 - 1
		if stageSuccess then
			//if self.wasDischMoveStageSuccessForOp(_passedOperator) then					//13.12.2024 navlc30 #33644				
				self.progressStage(CM_VoyageStage.VoyStage_InvoiceGenerated, _ediData, _passedOperator, CM_VoyageStage.Type_Load);		//navra1 - MTN-34829 - 8th May 2025
			//endif;																		//13.12.2024 navlc30 #33644
		else
			return;
		endif;	
	elseif _stage = CM_VoyageStage.VoyStage_DischManMoved then		
		//perform move stage for this localVarOperator that the comparison completed successfully			
		stageSuccess := false;
		stageSuccess := self.performDischMovesForOpStg(_passedOperator);					//navra1 - TFS 65376 - 31st July 2024 - 1
		if stageSuccess then
			//if self.wasLoadMoveStageSuccessForOp(_passedOperator) then					//13.12.2024 navlc30 #33644					
				self.progressStage(CM_VoyageStage.VoyStage_InvoiceGenerated, _ediData, _passedOperator, CM_VoyageStage.Type_Discharge);		//navra1 - MTN-34829 - 8th May 2025
			//endif;																		//13.12.2024 navlc30 #33644
		else
			return;
		endif;
	elseif _stage = CM_VoyageStage.VoyStage_InvoiceGenerated then
		//perform generate invoice stage for this operator - if you came here, you know discharge and load were both completed successfully for this localVarOperator
		stageSuccess := false;
		stageSuccess := self.performGenInvoicesForOpStg(_passedOperator, _stageType);					//navra1 - TFS 65376 - 31st July 2024 - 1		//navra1 - MTN-34829 - 8th May 2025
		if stageSuccess then
			self.progressStage(CM_VoyageStage.VoyStage_InvoicePosted, _ediData, _passedOperator, _stageType);		//navra1 - MTN-34829 - 8th May 2025
		else
			return;
		endif;
	elseif _stage = CM_VoyageStage.VoyStage_InvoicePosted then
		stageSuccess := false;
		stageSuccess := self.performInvoicePostForOp(_passedOperator, _stageType);						//navra1 - TFS 65376 - 31st July 2024 - 1		//navra1 - MTN-34829 - 8th May 2025
		if stageSuccess then
			if self.wasDischMoveStageSuccessForOp(_passedOperator) and 						//13.12.2024 navlc30 #33644
			self.wasLoadMoveStageSuccessForOp(_passedOperator) then
				self.progressStage(CM_VoyageStage.VoyStage_VoyageClosed, _ediData, _passedOperator, _stageType);		//navra1 - MTN-34829 - 8th May 2025
			endif;	
		else
			return;
		endif;	
	elseif _stage = CM_VoyageStage.VoyStage_VoyageClosed then
		stageSuccess := false;
		stageSuccess := self.performVoyageClose(_passedOperator);								//navra1 - TFS 65376 - 31st July 2024 - 1
		if stageSuccess then
			return;
		else
			return;
		endif;	
	endif;
	
	return;

epilog
	delete operatorList;
end;</source>
        <Parameter name="_stage" type="Integer"/>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
        <Parameter name="_passedOperator" type="CM_Operator"/>
        <Parameter name="_stageType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="49b2091d-44f0-4020-a360-dc7f4e21c3df">
        <updating/>
        <source>setForCreate(_voyage : CM_Voyage) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 July 2024	navra1	Initial creation for //navra1 - CR-65068/Task-64641 - Auto Comparison - 15th July 2024

*/

vars

begin
	self.myVoyage := _voyage;	
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="f55b314a-760f-4037-8b98-01fab66f15df">
        <updating/>
        <source>setForUpdate(_pxyVoyageProgress : CM_VoyageProgress input; 						
						_dischargeOperatorsToAdd : CM_OperatorArray; 
						_loadOperatorsToAdd : CM_OperatorArray;
						_dischargeOperatorsToRemove : CM_OperatorArray;						
						_loadOperatorsToRemove : CM_OperatorArray;
						_pauseAutoProcess : Boolean) updating;						//navra1 - CR 65823 - 6th Sep 2024
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 July 2024	navra1	Initial creation for //navra1 - CR-65068/Task-64641 - Auto Comparison - 15th July 2024

*/

vars
	operator : CM_Operator;	
begin
	if _dischargeOperatorsToAdd &lt;&gt; null then
		foreach operator in _dischargeOperatorsToAdd do
			if not self.allCargoDischargeOperators.includes(operator) then
				self.allCargoDischargeOperators.add(operator);
			endif;
		endforeach;
	endif;
	
	if _loadOperatorsToAdd &lt;&gt; null then
		foreach operator in _loadOperatorsToAdd do
			if not self.allCargoLoadOperators.includes(operator) then
				self.allCargoLoadOperators.add(operator);
			endif;
		endforeach;
	endif;
	
	if _dischargeOperatorsToRemove &lt;&gt; null then
		foreach operator in _dischargeOperatorsToRemove do
			self.allCargoDischargeOperators.tryRemove(operator);
			self.allCargoDischOperComplete.tryAdd(operator);				//navra1 - MTN-33185 - 1th Nov 2024-1
		endforeach;
	endif;	
	
	if _loadOperatorsToRemove &lt;&gt; null then
		foreach operator in _loadOperatorsToRemove do
			self.allCargoLoadOperators.tryRemove(operator);
			self.allCargoLoadOperComplete.tryAdd(operator);					//navra1 - MTN-33185 - 1th Nov 2024-1
		endforeach;
	endif;	
	
	self.pauseProgress := _pauseAutoProcess;							//navra1 - CR 65823 - 6th Sep 2024
	
epilog

end;</source>
        <Parameter name="_pxyVoyageProgress" type="CM_VoyageProgress" usage="input"/>
        <Parameter name="_dischargeOperatorsToAdd" type="CM_OperatorArray"/>
        <Parameter name="_loadOperatorsToAdd" type="CM_OperatorArray"/>
        <Parameter name="_dischargeOperatorsToRemove" type="CM_OperatorArray"/>
        <Parameter name="_loadOperatorsToRemove" type="CM_OperatorArray"/>
        <Parameter name="_pauseAutoProcess" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="wasDischMoveStageSuccessForOp" id="d706062a-830f-41a0-b962-9ebd2c19ca2a">
        <source>wasDischMoveStageSuccessForOp(_operator : CM_Operator) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 July 2024	navra1	Initial creation for //navra1 - CR-65068/Task-64641 - Auto Comparison - 15th July 2024

*/

vars
	currentStages : CM_VoyageStagesbyDateTimeStage;
	oneStage : CM_VoyageStage;	
begin	
	
	//check if discharge is relevant to this operator, if not return success
	if not self.allCargoDischargeOperators.includes(_operator) then
		return true;
	endif;
	
	//since you came here, discharge is relevant to this operator, check if you have a discharge stage, which was completed successfully
	
	currentStages := self.myVoyage.myVoyageProgress.allStages;
	
	foreach oneStage in currentStages do
		if oneStage.stage = CM_VoyageStage.VoyStage_DischManMoved and oneStage.operatorCode = _operator.code then
			if oneStage.status = CM_VoyageStage.STATUS_SUCCESS then
				return true;
			endif;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="wasLoadMoveStageSuccessForOp" id="1392bd46-485b-4db6-b57f-5d8fe61b0a64">
        <source>wasLoadMoveStageSuccessForOp(_operator : CM_Operator) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 July 2024	navra1	Initial creation for //navra1 - CR-65068/Task-64641 - Auto Comparison - 15th July 2024

*/

vars
	currentStages : CM_VoyageStagesbyDateTimeStage;
	oneStage : CM_VoyageStage;	
begin
	//check if load is relevant to this operator, if not return success
	if not self.allCargoLoadOperators.includes(_operator) then
		return true;
	endif;
	
	//since you came here, load is relevant to this operator, check if you have a discharge stage, which was completed successfully
	
	currentStages := self.myVoyage.myVoyageProgress.allStages;
	
	foreach oneStage in currentStages do
		if oneStage.stage = CM_VoyageStage.VoyStage_LoadManMoved and oneStage.operatorCode = _operator.code then
			if oneStage.status = CM_VoyageStage.STATUS_SUCCESS then
				return true;
			endif;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
