    <JadeMethod name="addColumn" id="3d837f0f-194f-4f57-be3c-3b9134c8d9c9">
        <source>addColumn(_col : Integer; _labelNum : String) : CM_GridColumn;
/*
----------   ----------  --------------------------------------------------
Created:	25 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	colLabel			: String;
	pxyGridCol			: CM_GridColumn;

begin
	colLabel := self.prefixColumnLabel &amp; _labelNum;
	create pxyGridCol as self.getColumnClassToCreate transient;
	pxyGridCol.setForProxy(_col, colLabel, self.myPxyGridArea);
	return pxyGridCol;
end;</source>
        <Parameter name="_col" type="Integer"/>
        <Parameter name="_labelNum" type="String"/>
        <ReturnType type="CM_GridColumn"/>
    </JadeMethod>
    <JadeMethod name="addGridController" id="b0d73725-f8cc-4f40-88f2-08fc6bdfd1aa">
        <source>addGridController(_avail, _usage : Integer;
				_pxyGridRow : CM_GridRow; 
				_pxyGridCol : CM_GridColumn;
				_ident40ft : String) : CM_GridController;
/*
----------   ----------  --------------------------------------------------
Created:	25 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	pxyStackCntrl			: CM_GridController;
	name				: String;
begin

	name := _pxyGridRow.label &amp; _pxyGridCol.label;
	create pxyStackCntrl as self.getLCClassToCreate transient;
	pxyStackCntrl.setForProxy(_avail, 
							_usage, 
							_pxyGridRow.row, 
							_pxyGridCol.column,
							name,
							2,
							false,
							false,
							null,
							self.myPxyGridArea, false,null, false, null, false, null);
	
	if 	_ident40ft &lt;&gt; null then					
		pxyStackCntrl.setId40ft(_pxyGridRow.label &amp; _ident40ft);
	endif;
	//redundant is called in CM_GridController setForProxy
	/*
	pxyStackCntrl.setForProxyGridController(name, 
								_pxyGridCol,
								_pxyGridRow,
								2);*/
	
	return pxyStackCntrl;
	
						
end;</source>
        <Parameter name="_avail" type="Integer"/>
        <Parameter name="_usage" type="Integer"/>
        <Parameter name="_pxyGridRow" type="CM_GridRow"/>
        <Parameter name="_pxyGridCol" type="CM_GridColumn"/>
        <Parameter name="_ident40ft" type="String"/>
        <ReturnType type="CM_GridController"/>
    </JadeMethod>
    <JadeMethod name="addRow" id="866ed687-c0f7-4c1e-9b9a-8f83ec39a8fd">
        <source>addRow(_row: Integer; _rowLabelNum  : String) : CM_GridRow;
/*
----------   ----------  --------------------------------------------------
Created:	25 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	rowLabel			: String;
	pxyGridRow			: CM_GridRow;

begin
	rowLabel := self.prefixRowLabel &amp; _rowLabelNum;

	create pxyGridRow as self.getRowClassToCreate transient;
	pxyGridRow.setForProxy(_row, rowLabel, self.myPxyGridArea);
	return pxyGridRow;
	
end;</source>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_rowLabelNum" type="String"/>
        <ReturnType type="CM_GridRow"/>
    </JadeMethod>
    <JadeMethod name="create" id="0f307b6e-f603-475c-9241-c6001fe0ff0b">
        <updating/>
        <source>create() updating;

vars

begin
	self.startNumColumn := 1;
	self.startNumRow := 1;
	self.incrementColNumBy := 1;	// NEED TO SET FROM GUI //epr changed to 1 for dmast richard hard coded this to 2 for gdansk
	self.incrementRowNumBy := 1;
end;
</source>
    </JadeMethod>
    <JadeMethod name="createProxyStructure" id="5919f43b-5a9b-4c46-893c-8079a7820b51">
        <updating/>
        <source>createProxyStructure() updating;
/*
----------   ----------  --------------------------------------------------
Created:	24 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	colLabelNum,
	rowLabelNum			: String;
	col,
	row					: Integer;
	pxyGridRow			: CM_GridRow;
	pxyGridCol			: CM_GridColumn;
	pxyGridCntrl		: CM_GridController;

	firstRowLoop		: Boolean;
begin
	self.myPxyGridArea.allGridColumns.purge();
	self.myPxyGridArea.allGridRows.purge();
	self.myPxyGridArea.allGridControllersByRowColumn.purge();
	self.myPxyGridArea.allTerminalAreaGroups.purge();

	foreach row in 1 to self.numRows do
		self.getNextRowLabelNum(rowLabelNum);
		pxyGridRow := self.addRow(row, rowLabelNum);
		colLabelNum := null;
		foreach col in 1 to self.numColumns do
			self.getNextColLabelNum(colLabelNum);
			
			pxyGridCol := self.myPxyGridArea.allGridColumns[col].CM_GridColumn;
			if pxyGridCol = null then
				pxyGridCol := self.addColumn(col, colLabelNum);
			endif;
			
			pxyGridCntrl := self.addGridController(PAD_AVAILABLE,NORMAL_USE, pxyGridRow, pxyGridCol, self.get40ftColId(colLabelNum));
		endforeach;
	endforeach;

	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="createTerminalArea" id="ba748457-0fa8-4a09-b000-04f4a47c795d">
        <updating/>
        <source>createTerminalArea() updating;
/*
----------   ----------  --------------------------------------------------
Created:	25 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	errStr		: String;
	newTA		: CM_TerminalArea;
begin
	inheritMethod();

	self.myPxyGridArea.setGridAreaProxy(self.id, 
									self.comment, 
									TA_TYPE_RTG, 
									self.numRows, 
									self.numColumns,
									self.height,
									self.actAsReleasePoint,
									self.myTerminal,
									self.autoRestrictionsEnabled,
									self.stockControlled,
									self.hideFromOverview,
									self.deckingOption,
									false, false, false, false, false, null,null, false, false,
									null,null,null,null);
										
	self.validate(errStr);
	if errStr &lt;&gt; null then
		app.msgBox(errStr, 'Errors encountered', MsgBox_OK_Only);
		return;
	endif;
	
	self.createProxyStructure();

end;</source>
    </JadeMethod>
    <JadeMethod name="get40ftColId" id="8b774a99-3c79-4730-ad27-7b244501b3e9">
        <source>get40ftColId(_currentColNum: String): String;
/*
----------   ----------  --------------------------------------------------
Created:	16 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	theLength : Integer;
begin
	if not self.use40ftIds then
		return null;
	endif;
	
	theLength:=_currentColNum.length;
	if self.decrementColNums then
		return (_currentColNum.Integer - 1).String.padLeadingZeros(theLength);
	else
		return (_currentColNum.Integer + 1).String.padLeadingZeros(theLength);	
	endif;

end;


</source>
        <Parameter name="_currentColNum" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
