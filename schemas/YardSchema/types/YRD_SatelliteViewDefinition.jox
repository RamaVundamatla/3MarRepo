    <JadeMethod name="setEditMode" id="61fbe71b-d272-42db-8410-7e51d33ce575">
        <updating/>
        <source>setEditMode( _enableEdit : Boolean ) updating;

/*

Purpose:		Enable edit by creating proxy.

Parameters:			

Return Value:		


Date				Who		Reason
02 September 2008	consw1	Initial creation

*/

vars
	obj : Object;
	
begin
	self.isEditMode := _enableEdit;

	delete self.myProxyAreaView;
	
	if _enableEdit then
		self.myProxyAreaView := app.createUpdateProxy(self.myAreaView).CM_TerminalAreaView;
	endif;

	self.doEditTAView(_enableEdit);

epilog

end;</source>
        <Parameter name="_enableEdit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyAreaView" id="884841d7-2c00-49e7-9ee1-e2296553cf4c">
        <updating/>
        <source>setMyAreaView(_taView :CM_TerminalAreaView) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 November 2010	cnwer1	Initial creation

*/

vars

begin
	
	
	
	if self.myAreaView &lt;&gt; null then
		self.endNotification(self.myAreaView,self.myTerminal.getTerminalEvent(Event_TAView_Update));
		self.endNotification(self.myAreaView,self.myTerminal.getTerminalEvent(Event_TAView_Delete));
	endif;
	
	self.myAreaView:=_taView;

	if self.myAreaView &lt;&gt; null then
		self.beginNotification(self.myAreaView,self.myTerminal.getTerminalEvent(Event_TAView_Update),Response_Continuous,null);
		self.beginNotification(self.myAreaView,self.myTerminal.getTerminalEvent(Event_TAView_Delete),Response_Continuous,null);
	endif;
epilog

end;</source>
        <Parameter name="_taView" type="CM_TerminalAreaView"/>
    </JadeMethod>
