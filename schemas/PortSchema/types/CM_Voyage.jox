    <JadeMethod name="getCraneStatistics" id="71b5f5f5-9acc-407b-82e7-227680bc2784">
        <source>getCraneStatistics(_craneId : String; _totalJobs, _totalJobsDone, _totalMoves, _totalMovesDone : Integer output);
// ---------------------------------------------------------------------------
// Created:     24 May 2001 cnwdwq1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	slotReq : CM_SlotRequest;
	jobs : CM_JobArray;
	tJob : CM_Job;
	job : CM_VoyageJob;
	wle : CM_WorkListEntry;
begin

	if _craneId.trimBlanks = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_INVALID_KEY, null, null);
		return;	
	endif;
	//------------
	//Init return values
	//------------
	_totalJobs := 0;
	_totalJobsDone := 0;
	_totalMoves := 0;
	_totalMovesDone := 0;
	//------------
	//Call proxy to get Jobs for crane.
	//------------
	create jobs transient;
	
	self.getJobsForCrane(_craneId.trimBlanks.toUpper, jobs);
	foreach tJob in jobs do
		job := tJob.CM_VoyageJob;

		_totalJobs := _totalJobs + 1;		
		if job.status = JOB_COMPLETE then
			_totalJobsDone := _totalJobsDone +1;
		endif;	
		foreach wle in job.workListEntries do
			 // PAR 7231 AKB2004JAN added
			 
			if not wle.myRequest.isValidForJobStats() then
				continue;
			endif;
			
			_totalMoves := _totalMoves +1;
			if wle.status = WLE_COMPLETED then
				_totalMovesDone := _totalMovesDone +1;
			endif;
		endforeach;
	endforeach;

epilog
	delete jobs;
end;</source>
        <Parameter name="_craneId" type="String"/>
        <Parameter name="_totalJobs" type="Integer" usage="output"/>
        <Parameter name="_totalJobsDone" type="Integer" usage="output"/>
        <Parameter name="_totalMoves" type="Integer" usage="output"/>
        <Parameter name="_totalMovesDone" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getCraneWithNoJS" id="a7fefb90-06a8-441b-b523-334ab21103f8">
        <source>getCraneWithNoJS() : CM_Crane;
// ---------------------------------------------------------------------------
// Created:     18 May 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	queueObj : CM_RadioTelemetryQueue;
	queueItem	: CM_RadioTelemetryQueue;
	term : CM_Terminal;
begin

	queueObj := self.myQueue;

	if queueObj = null then
		return null;
	endif;
	
//	foreach queueItem in queueObj.allSubQueuesById do
	foreach queueItem in queueObj.allSubQueuesById where queueItem.isCraneQueue do	//23 May 2012	NDL	Par 29621
		if not self.hasCraneGotJS(queueItem.CM_VoyageCraneQueue.crane) then
			return queueItem.CM_VoyageCraneQueue.crane;
		endif;
 	endforeach;
	
	return null;
end;</source>
        <ReturnType type="CM_Crane"/>
    </JadeMethod>
    <JadeMethod name="getCurrentOnShipCargoQuantity" id="19fed49f-25bf-4274-9a24-1c56cc8951a3">
        <source>getCurrentOnShipCargoQuantity():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 August 2017	jlgndl1	Initial creation	TFS 5585

*/

vars

	iter : Iterator;
	ti : CM_TrackedItem;
	quantity : Integer;

begin

	iter := self.allOnshipTIsByIdCargoType.createIterator;
	while iter.next( ti ) do
		quantity := quantity + ti.totalQuantity.max(1);
	endwhile;
	
	return quantity;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
