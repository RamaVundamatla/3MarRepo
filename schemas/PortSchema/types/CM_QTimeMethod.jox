<Class name="CM_QTimeMethod" id="14548b7f-05c5-492b-b82a-51c2b96caff7">
    <superclass name="CM_QueryMethod"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="938fd8f0-7ede-4013-b21e-5610dea9604b">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2012	cnwndl1	Initial creation	Par 29532

*/

vars

	oper : CM_QueryOperator;

begin

	if self.isTransient then
		return;
	endif;
	
	create oper as CM_QTimeRange persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QTimeGreaterThan persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QTimeLessThan persistent;
	self.allAllowedOperators.add(oper);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getControlTypeForOperator" id="641a0a9b-4b4b-4c28-82bb-fc7875e932a8">
        <source>getControlTypeForOperator(_op: CM_QueryOperator): Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2012	cnwndl1	Initial creation	Par 29532

*/

vars

begin

	if _op.isKindOf(CM_QTimeRange) then
		return QueryControl_TimeRange;
	elseif _op.isKindOf(CM_QTimeGreaterThan) then
		return QueryControl_Time;
	elseif _op.isKindOf(CM_QTimeLessThan) then
		return QueryControl_Time;
	endif;
		
	return inheritMethod(_op);

epilog

end;</source>
        <Parameter name="_op" type="CM_QueryOperator"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getKeyLengthForXTABDictionary" id="06c4979e-51fa-48a6-af89-07700157bc0b">
