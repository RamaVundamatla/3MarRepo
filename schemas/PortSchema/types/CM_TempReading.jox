    <JadeMethod name="getDisplayTemp" id="4eb9b281-a638-4af5-8daa-a154649b9591">
        <source>getDisplayTemp(): String;
//----------------------------------------------------------------
//	Created:	26 August 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 11/12/2009	cnwdap1		CCMS MES 1007 myContainer reference now redundant, use myReeferProeprties instead
vars

begin
	if self.temperature = NULL_TEMPERATURE then
		return "null";
	endif;
	if self.temperature = NULL_DEFROST_TEMPERATURE then //Aug 2007 cnwrs1 CCMS1551
		return "Defrost";
	endif;
	
	//if self.myContainer &lt;&gt; null and 
	   //self.myContainer.myOperator &lt;&gt; null and
	   //self.myContainer.myOperator.displayTempFahrenheit then
	if self.myReeferProperties &lt;&gt; null and 
	   self.myReeferProperties.myParent.CM_TrackedItem.myOperator &lt;&gt; null and
	   self.myReeferProperties.myParent.CM_TrackedItem.myOperator.displayTempFahrenheit then
			return app.temperatureDisplayString(app.myRoot.convCelsiusToFahrenheit(self.temperature)) &amp; Degrees_F;
	endif;

	return app.temperatureDisplayString(self.temperature) &amp; Degrees_C;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLogDisplay" id="7044e58f-301d-47fc-a34d-7aac44112fcc">
        <source>getLogDisplay(): String;
// ---------------------------------------------------------------------------
// Created:		10 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 08/12/2009	cnwdap1		CCMS MES 1007 Trailers as reefers means CM_TrackedIetm can now be a reefer
//04 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	detail	: String;
begin
	//04 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	detail := self.systemToLocalTime(self.dateTime).shortCurrentLocaleFormat &amp; " " &amp; "Temp Reading" &amp; " ";
	
	
	//if self.myContainer = null then
	if self.myReeferProperties = null then
		detail := detail &amp; "           " &amp; Tab;	
	else
		//detail := detail &amp; self.myContainer.id &amp; Tab;	
		detail := detail &amp; self.myReeferProperties.myParent.CM_TrackedItem.id &amp; Tab;	
	endif;
	
	return detail &amp; self.temperature.String; 
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
