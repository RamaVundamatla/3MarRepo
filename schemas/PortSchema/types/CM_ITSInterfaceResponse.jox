    <JadeMethod name="setLocationStrForFullLocation" id="3b96c61f-e23a-4ce0-a04d-3fab1328f503">
        <source>setLocationStrForFullLocation(_ti : CM_TrackedItem; _task : CM_RTQueueTask; _location : CM_LocationsController; _locationValue : String io) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 August 2011	#cnwdz2	 27008 the height will not be displayed if the target RMG/RTG location is full and the auto-resequence config is on.

*/

vars
	rtQueueEntry 	: CM_RTQueueEntry; 
	terminal		: CM_Terminal;
	vehicleConfig	: CM_RTVehicleConfig;
	gridArea   		: CM_RTGArea;
	ta 				: CM_TerminalArea;
	gridController 	: CM_GridController;
	maxHeight,
	heightOfTI		: Integer;
	existingTI		: CM_TrackedItem;
begin 
	rtQueueEntry := _task.myEntry;
	if rtQueueEntry = null then
		return;
	endif;
	
	terminal:= rtQueueEntry.getMyTerminal();
	vehicleConfig:=terminal.getRTVehicleConfigForObject(_task.machine);
	if not vehicleConfig.autoResequenceJobs then
		return;
	endif;
			
	ta := _location.myTerminalArea;
	if not ta.isKindOf(CM_RTGArea) then
		return;
	endif;
	
	gridArea := ta.CM_RTGArea;
	gridController := _location.CM_GridController;
	maxHeight := gridArea.heightOfStack * Ti_Full_Height;
	heightOfTI := _ti.getHeightOfTI();	
	foreach existingTI in gridController.allTrackedItems discreteLock do
		heightOfTI := heightOfTI + existingTI.getHeightOfTI();	
	endforeach;
	
	if heightOfTI &gt; maxHeight then
		_locationValue	:= _location.getFullId().asXML(); 
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_task" type="CM_RTQueueTask"/>
        <Parameter name="_location" type="CM_LocationsController"/>
        <Parameter name="_locationValue" type="String" usage="io"/>
    </JadeMethod>
