    <JadeMethod name="doOK" id="d565e0b0-5ac6-4f09-9647-66cdef864b05">
        <updating/>
        <source>doOK() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 May 2010	#cnwdz2	 

*/

vars

begin
	defName := self.txtDefName.text;
	if defName = null then
		return;
	endif;
	app.mousePointer := Busy;
	inheritMethod();
epilog

end;</source>
