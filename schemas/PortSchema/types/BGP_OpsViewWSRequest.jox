    <JadeMethod name="action" id="b64f518c-5144-4c5f-9182-76480aab18a5">
        <updating/>
        <source>action(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2020 cnwma1 ChangeRequest 49906: MTN - Ops View External Webservice

*/

vars
	agent			: CM_OpsViewWSAgent;
	wsDefinition	: CM_OpsViewServiceDef;
	returnVal		: Boolean;
	errorMessage,
	logMessage		: String;
	timeoutOccurred	: Boolean;
	response		: CMIF_ExternalWSResponse;
	errCode         : Integer;
	errTxt 			: String;
	msg 			: String;
	invalid         : Boolean;
	edition         : Integer;
	request         : BGP_Request;
begin
	app.writeLog( method.qualifiedName,LogINFO);
	on Exception do app.alertExceptionHandler(exception, null, self.getErrorDesc(), errCode, errTxt, true, true);
	on LockException do app.alertLockExceptionHandler(exception);

	wsDefinition := app.myBGPObject.BGP_ExternalWSController.myExternalWSDef.CM_OpsViewServiceDef;
	
	create agent transient;
	agent.setupFromWebServiceDefinition(wsDefinition);
	agent.setOpsViewActivity(self.myEWSActivity.CM_EWSActivityOpsview); // ### TFS 50669 03AUG2021 NAVAB1
	
	on Exception do app.handleDeletedObject( exception, self.myObject, invalid );
	
	if self.myObject &lt;&gt; null then
		edition := self.myObject.edition;
	endif;
	
	if invalid then
		logMessage := "Ops View Object has been deleted.";
		app.writeLog(method.qualifiedName() &amp; Space &amp; logMessage, LogINFO);
		return true;
	endif;
	
//	returnVal := agent.sendOpsViewData(self);
	returnVal := agent.sendOpsViewDataForActivity(self.myEWSActivity.CM_EWSActivityOpsview); // ### TFS 50669 27AUG2021 NAVAB1

	return returnVal;
epilog
	delete agent;
	if errCode &lt;&gt; null  then
		app.myTrxUA.trxUpdateBGPRequest(self, true, errCode, errTxt, app.myPassport);
	endif;
	
	if invalid then
		request := self;
		app.myTrxDA.trxDeleteBGPRequest(null, request, true, app.myPassport);
	endif;

	inheritMethod();
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDesc" id="e2e7a904-ca93-427d-9d00-ae042443ddf9">
        <source>getDesc(_updateType,_updateAction,_oid : String ; _obj : Any  ): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2020 cnwma1 ChangeRequest 49906: MTN - Ops View External Webservice

*/

vars
	str     ,
	desc,
	actionStr : String;
begin
	
	if _updateAction = "C" then
		actionStr := "Create";
	elseif _updateAction = "D" then
		actionStr := "Delete";
		return  actionStr &amp; Space &amp; _updateType &amp; Space &amp; _oid;
	elseif _updateAction = "U" then
		actionStr := "Update";
	endif;
	
	if _obj &lt;&gt; null then
		if _obj.isKindOf(CM_Operator)then
			desc :=  _obj.CM_Operator.code;
		elseif _obj.isKindOf(CM_Terminal)then
			desc :=  _obj.CM_Terminal.code;
		elseif _obj.isKindOf(HMS_Berth)then
			desc :=  _obj.HMS_Berth.code;
		elseif _obj.isKindOf(CM_Machine)then
			desc :=  _obj.CM_Machine.code;
		elseif _obj.isKindOf(CM_Voyage)then
			desc :=  _obj.CM_Voyage.code;
		elseif _obj.isKindOf(CM_Delay)then
			desc :=  _obj.CM_Delay.getDescription(false);
		elseif _obj.isKindOf(CM_Vessel)then
			desc :=  _obj.CM_Vessel.name;	
		elseif _obj.isKindOf(CM_Trade)then
			desc :=  _obj.CM_Trade.description;	
		elseif _obj.isKindOf(CM_Trade)then 
			desc :=  _obj.CM_Trade.description;
		elseif _obj.isKindOf(CM_DelayType)then 
			desc :=  _obj.CM_DelayType.description;
		elseif _obj.isKindOf(CM_ISOType)then 
			desc :=  _obj.CM_ISOType.code;
		endif;
	
	endif;
	
	str := actionStr &amp; Space &amp; _updateType &amp;  Space &amp; desc;
	
	return str;
epilog

end;</source>
        <Parameter name="_updateType" type="String"/>
        <Parameter name="_updateAction" type="String"/>
        <Parameter name="_oid" type="String"/>
        <Parameter name="_obj" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="0657c0f5-201b-49ec-944d-aa3543381a49">
        <source>getDisplay(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2020 cnwma1 ChangeRequest 49906: MTN - Ops View External Webservice

*/

vars
	invalid 		: Boolean;
	termCode        : String;
	desc            : String;
	termStr         : String;
	edition         : Integer;
begin
	on Exception do app.handleDeletedObject(exception,self.myObject, invalid);
	
	if self.myObject &lt;&gt; null then
		edition := self.myObject.edition;
	endif;
	
	if invalid then
		return inheritMethod;
	endif;
	
	if self.myTerminal &lt;&gt; null then
		termCode := self.myTerminal.code;
		termStr  := 'Term ['&amp; termCode &amp;']';
	endif;
	
	desc := self.getDesc(self.updateType,self.updateAction,self.objectOid,self.myObject);	

	return inheritMethod &amp; Tab &amp;  'Navis Ops View' &amp; Space &amp; termStr &amp; Space &amp;'[' &amp; desc &amp;']';

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="f1f72e9c-83ce-48bd-aa82-92d5d8b63fc5">
        <updating/>
        <source>setForCreate(_proxySelf: SelfType input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2020 cnwma1 ChangeRequest 49906: MTN - Ops View External Webservice

*/

vars

begin
	inheritMethod(_proxySelf);
	
	self.updateAction := _proxySelf.updateAction;
	self.updateType   := _proxySelf.updateType;
	self.myObject     := _proxySelf.myObject;
	self.objectOid    := _proxySelf.objectOid;
	self.myTerminal   := _proxySelf.myTerminal;
epilog

end;</source>
        <Parameter name="_proxySelf" type="SelfType" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setRequestDetails" id="6fb0e04d-aae8-4686-84b9-4f988d4b2fdd">
        <updating/>
        <source>setRequestDetails(_updateAction : Character;
				  _updateType	: String ;
				  _objectInfo   : Any )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2020 cnwma1 ChangeRequest 49906: MTN - Ops View External Webservice
*/

vars
	terminal : CM_Terminal;
	obj      : Object;
	oid      : String;
begin
	self.updateAction := _updateAction;
	self.updateType   := _updateType;
	
	if _objectInfo.isKindOf(CM_Object) then
		obj 		:= _objectInfo.CM_Object;
		oid 		:= _objectInfo.CM_Object.getOidString;
		terminal	:= obj.getMyTerminal();
	elseif _objectInfo.isKindOf(String) then
		oid := _objectInfo.String;
	endif;
	
	if _updateAction  &lt;&gt; BGP_OpsViewWSRequest.OPS_ACTION_DELETE then
		self.myObject     := obj;
	endif;
	
	self.myTerminal  := terminal;
	self.objectOid   := oid;

	
epilog

end;</source>
        <Parameter name="_updateAction" type="Character"/>
        <Parameter name="_updateType" type="String"/>
        <Parameter name="_objectInfo" type="Any"/>
    </JadeMethod>
</Class>
