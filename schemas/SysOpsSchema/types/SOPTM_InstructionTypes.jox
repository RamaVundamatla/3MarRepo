    <JadeMethod name="includeObject" id="13c4346d-cd1a-4325-876d-ea14e92ae845">
        <updating/>
        <source>includeObject(_obj: Object; _passport: CM_Passport): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions

*/

vars

begin
	if self.includeNotAvailableEntries then
		return true;
	else
		return not _obj.CM_InstructionType.notAvailableForEntry;
	endif;

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initShtMultiSelect" id="10bbbc68-d18e-4f7e-b161-3707060c9cb0">
        <source>initShtMultiSelect();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who			Reason
03 October 2022		navtnr20	Initial creation
30 August 2023		jlizm1		TFS 59567 Kiosk instruction type maint

*/

vars
	theForm	: SOP_TableMaintForm;
	coll : CM_TILCTypeSet;
	trailerType : CM_TILCType;
	
begin
	inheritMethod();

	theForm := self.myForm;
	
	create coll transient;
	foreach trailerType in app.myRoot.allTILCTypes do
		if trailerType.isNotAvailableForEntry then
			continue;
		endif;
		coll.add(trailerType);		
	endforeach;
	
	theForm.mulSelect1.setVisibleButtons(true, true, false);
	self.setupMultiSelect1(app.getErrorString(Trailer_types), coll, SOP_TableMaintForm::displayEntryTrailerType.name);
	theForm.mulSelect1.myBaseForm := theForm;
	theForm.mulSelect1.mySelectedListBox.sorted := false;
	theForm.chkAnyTriggField.visible := false;
	
epilog
	delete coll;
	
end;</source>
    </JadeMethod>
