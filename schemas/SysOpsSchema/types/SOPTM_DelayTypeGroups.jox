    <JadeMethod name="setControlsForAddEdit" id="596522a9-05e1-41bc-9d5f-df84764be85c">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*
----------   ----------  --------------------------------------------------
Created:	01 February 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	theForm : SOP_TableMaintForm;
	theDelay : CM_DelayTypeGroup;
begin

  	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	theForm.shtMultiSelect1.visible := true;
	theForm.mulSelect1.userInputEnabled := true;

	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.mulSelect1.setSelected(null);
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		theForm.tblInput1.gotFocus(theForm.tblInput1);	// sets case etc.
		theForm.fldInput.initSheetBackColors();
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_DelayTypeGroup);
		theForm.tblInput1.enableRowByName(ETRow_Description);
	endif;
	self.enableMulSelect1Contents();
	theForm.tblInput1.cnEcResizeContents();
end;
</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="b6c7f611-3561-43ba-a688-297a9b7f7dde">
        <updating/>
        <source>setCtrlsForView() updating;
/*
----------   ----------  --------------------------------------------------
Created:	01 February 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	theForm : SOP_TableMaintForm;

begin
	inheritMethod();
	theForm := self.myForm;
	 theForm.tblInput1.userInputEnabled := false;
  	theForm.tblInput1.cnEcResizeContents();
  	theForm.shtMultiSelect1.visible := true;

end;
</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="da6c54bf-a25b-4d8c-acec-6b3f9091b6d9">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*
----------   ----------  --------------------------------------------------
Created:	01 February 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	theForm : SOP_TableMaintForm;
		delay	: 	CM_DelayTypeGroup;
begin

	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_DelayTypeGroupMain);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Description, false);
	
	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_DelayTypeGroupMain);
	theForm.shtTblInput1.visible := true;
	

	

end;
</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="9a718819-1535-4009-92fe-26560814bf5e">
        <updating/>
        <source>showThumbnail(pDelayTypeGroup: CM_DelayTypeGroup) updating;
/*
----------   ----------  --------------------------------------------------
Created:	01 February 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	theForm : SOP_TableMaintForm;
begin
	theForm := self.myForm;
	theForm.tblInput1.clearValues;
	theForm.tblInput1.setValueByName(ETRow_Description, pDelayTypeGroup.getDisplayStringForAttribute(ETRow_Description, true));
	theForm.mulSelect1.setSelected(pDelayTypeGroup.allDelayTypes);
	self.disableMulSelect1Contents();
	
end;
</source>
        <Parameter name="pDelayTypeGroup" type="CM_DelayTypeGroup"/>
    </JadeMethod>
</Class>
