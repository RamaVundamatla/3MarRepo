    <JadeMethod name="setDefaultSelectorColumns" id="a0442d35-8c93-4217-a1ad-b6e727a4c724">
        <updating/>
        <source>setDefaultSelectorColumns(_qDef : CM_QueryDefinition) updating;

vars
	qProp		: CM_QueryProperty;
	visColArray		: StringArray;
begin
	visColArray := self.allSelectorVisibleColumns;
	visColArray.clear();
	//add a few visible columns as a default - just a lame startup
	qProp := _qDef.allQueryProperties['id'];
	if qProp &lt;&gt; null then
		visColArray.add(qProp.propertyName);
	endif;
	
	qProp := _qDef.allQueryProperties['locationId'];
	if qProp &lt;&gt; null then
		visColArray.add(qProp.propertyName);
	endif;
	
	qProp := _qDef.allQueryProperties['operatorCode'];
	if qProp &lt;&gt; null then
		visColArray.add(qProp.propertyName);
	endif;
	
end;</source>
        <Parameter name="_qDef" type="CM_QueryDefinition"/>
