    <JadeMethod name="trxUpdateWagonRakePositionSwap" id="0c55ab1a-77f5-41a9-b3ed-62e84f2f6b15">
        <updating/>
        <source>trxUpdateWagonRakePositionSwap(_realWagon1 : CM_Wagon io; _realWagon2 : CM_Wagon io; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 August 2010	cnwndl1	Initial creation

*/

vars
	
	wagon1CurrentRake : CM_RailLine;
	wagon1CurrentPosition : Integer;
	wagon2CurrentRake : CM_RailLine;
	wagon2CurrentPosition : Integer;
	
	errMsg : String;
	
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	self.raiseExceptionIfNull(_realWagon1, app.getErrorString(Wagon));
	self.raiseExceptionIfNull(_realWagon2, app.getErrorString(Wagon));
		
	wagon1CurrentRake := _realWagon1.myRailLine;
	self.raiseExceptionIfNull(wagon1CurrentRake, app.getErrorString1(Rake_not_found, _realWagon1.id));
	wagon1CurrentPosition := wagon1CurrentRake.allWagons.indexOf(_realWagon1);
	
	if wagon1CurrentPosition &lt; 1 then
		app.raiseCMException1(Rake_posi_not_found, _realWagon1.id, null, null);
		return;
	endif;
	
	wagon2CurrentRake := _realWagon2.myRailLine;
	self.raiseExceptionIfNull(wagon2CurrentRake, app.getErrorString1(Rake_not_found, _realWagon2.id));
	wagon2CurrentPosition := wagon2CurrentRake.allWagons.indexOf(_realWagon2);
	
	if wagon2CurrentPosition &lt; 1 then
		app.raiseCMException1(Rake_posi_not_found, _realWagon2.id, null, null);
		return;
	endif;

	beginTransaction;

	app.myUtilityUA.utlUpdateWagonRakePositionSwap(	_realWagon1,	//_wagon1 : CM_Wagon io;
													wagon2CurrentRake,	//_wagon1NewRake : CM_RailLine io;
													wagon2CurrentPosition,	//_wagon1NewRakePos : Integer;
													_realWagon2,	//_wagon2 : CM_Wagon io;
													wagon1CurrentRake,	//_wagon2NewRake : CM_RailLine io;
													wagon1CurrentPosition,	//_wagon2NewRakePos : Integer;
													_passport	//_passport : CM_Passport input
													);

epilog
	self.finaliseActivityWithPassport(_passport);
end;
</source>
        <Parameter name="_realWagon1" type="CM_Wagon" usage="io"/>
        <Parameter name="_realWagon2" type="CM_Wagon" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
