<GUIClass name="YRD_WorkOrderGrpMethod" id="31838abf-6219-43db-b2a1-ca363552f79a">
    <superclass name="CMUI_Modal"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="cmbGrpMethod" id="8ea410b8-60f4-4aac-92a6-41afeac5d73f">
        <embedded/>
        <type name="CMUI_ComboBox"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myWorkOrder" id="9318c339-ab26-450a-bdce-919bb30b2a44">
        <embedded/>
        <type name="CM_WorkOrderTI"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myWorkOrderDetail" id="61136b98-c007-4f3c-aa19-02ccdb4109e3">
        <embedded/>
        <type name="CM_WorkOrderTIDtl"/>
    </ImplicitInverseRef>
    <JadeMethod name="create" id="14034f34-99f1-4f96-8b26-e417be082340">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Sep 2023 navhl20 ChangeRequest 60063: EUP | Ship Operations in DD - Terminal Config for grouping attributes

*/

vars

begin
	self.permissionView		:= PMAdmWOJobGroupingView;
	self.permissionMaint	:= PMAdmWOJobGroupingMaint; 
	self.helpFileName 		:= HelpFile_Yard;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadCmbGrpMethod" id="0c53551e-0053-4cfe-803e-1a316dbee501">
        <source>loadCmbGrpMethod();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Sep 2023 navhl20 ChangeRequest 60063: EUP | Ship Operations in DD - Terminal Config for grouping attributes
18 Dec 2023 navhl20 ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes

*/

vars
	grpMethod 	: CM_WorkOrderJobGroupMethod;
	myVessel	: CM_Vessel;
	myVoyage	: CM_Voyage;
	detailType	: CM_WorkOrderDetailType;
	str			: String;
begin
	self.cmbGrpMethod.clear();
	self.cmbGrpMethod.addItemWithData(app.getErrorString(No_Grouping), 1);				//18.12.2023 navhl20 #58400[61617]
	
	if self.myWorkOrder &lt;&gt; null and self.myWorkOrderDetail &lt;&gt; null then
		if self.myWorkOrderDetail.isKindOf(CM_WodReceive) then
			myVoyage := self.myWorkOrderDetail.CM_WodReceive.myVoyage;
			if myVoyage &lt;&gt; null then
				myVessel := myVoyage.myVessel;
			endif;
		else
			myVoyage := self.myWorkOrderDetail.CM_WodRelease.myVoyage;
			if myVoyage &lt;&gt; null then
				myVessel := myVoyage.myVessel;
			endif;
		endif;
		foreach grpMethod in self.myTerminal.allWOJobGroupMethods do
			if grpMethod.allVessels.includes(myVessel) then
				foreach detailType in grpMethod.allWorkOrderDetailTypes do
					if self.myWorkOrderDetail.getDisplayString(false).cnContains(detailType.description &amp; " - Ship") then
						str := grpMethod.code &amp; Hyphen &amp; grpMethod.description; 
						self.cmbGrpMethod.addItemObject(str,grpMethod);
					endif;
				endforeach;
			endif;
		endforeach;
	endif;
	self.cmbGrpMethod.listIndex := self.cmbGrpMethod.findObject(null);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="5260d749-92ca-45d1-9ac8-a65aebfe1a75">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Sep 2023 navhl20 ChangeRequest 60063: EUP | Ship Operations in DD - Terminal Config for grouping attributes

*/

vars

begin
	inheritMethod();
	self.btnOk.caption := "Approve";
	self.btnCancel.caption := app.getErrorString(Cancel);
	self.loadCmbGrpMethod();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="660885cc-3b2a-44bf-a24f-0db0c4d95e15">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 20 September 2023 14:13:15.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0026450, locale);
end;</source>
    </JadeMethod>
</GUIClass>
