    <JadeMethod name="setProxy" id="771e2143-b4e8-448a-a03a-f2f9de4bba7f">
        <updating/>
        <source>setProxy(_hide, _is40, _tranship, _isOD : Boolean;
		_id, _commodity, _loadPort, _dischPort, _operator, _type : String;
		_cargoType, _imexStatus, _contentsStatus, _transitStatus : Integer;
		
					// TFS 40336
					_isotype : String;
					_billOfLading : String;
					_cargoGroupId : String;
					_cargoSubtypeCode : String;
					_cargoSubtypeDescription : String;
					_cargoTypeCode : String;
					_cargoTypeDescription : String;
					_colour : String;
					_customsAgentCode  : String;
					_description : String;
					_destinationPortCode : String;
					_destinationPortDescription : String;
					_dischargePortDescription : String;
					_hazard  : String;
					_isotypeDescription : String;
					_loadPortDescription : String;
					_markNumber : String;
					_mark : String;
					_orderNumber : String;
					_remarks : String;
					_totalQuantity : Integer;
					_totalWeight : Decimal;
					_totalVolume : Decimal;
					_voyageCode : String;
					_temp : Decimal;
					_conee : String;
					_conor : String
					
		
		) updating;
//----------------------------------------------------------------
//	Created:	15 May 2006	by Jason Chapman  (cnwjc2)
//	13 May 2022	navgm20	53195: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - Portschema
//----------------------------------------------------------------
vars

begin

	self.ignore := _hide;
	self.isOD	:= _isOD;

	self.setProxySuperClass(_is40, _tranship, _isOD, _id, _commodity, _loadPort, _dischPort,
							_operator, _type, _cargoType, _imexStatus, _contentsStatus, _transitStatus,
							_isotype,
							_billOfLading,
							_cargoGroupId,
							_cargoSubtypeCode,
							_cargoSubtypeDescription,
							_cargoTypeCode,
							_cargoTypeDescription,
							_colour,
							_customsAgentCode ,
							_description,
							_destinationPortCode,
							_destinationPortDescription,
							_dischargePortDescription,
							_hazard ,
							_isotypeDescription,
							_loadPortDescription,
							_markNumber,
							_mark,
							_orderNumber,
							_remarks,
							_totalQuantity,
							_totalWeight,
							_totalVolume,
							_voyageCode,
							_temp,
							_conee,
							_conor
							);

end;</source>
        <Parameter name="_hide" type="Boolean"/>
        <Parameter name="_is40" type="Boolean"/>
        <Parameter name="_tranship" type="Boolean"/>
        <Parameter name="_isOD" type="Boolean"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_commodity" type="String"/>
