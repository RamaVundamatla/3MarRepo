    <JadeMethod name="setTerminalConfig" id="ab598b6c-3d7f-4a6c-8143-cb12e57bf7bb">
        <source>setTerminalConfig(_code : String; _value : Any) : Any;
//13 November 2008	cnwdw1	
//
vars
	oldSetting: Any;
begin
	oldSetting := self.getTerminalConfig(_code);
	beginTransaction;
	getTerminal.setConfig(_code, _value);
	commitTransaction;
	
	// 12/12/2014 cnwmh5 
	// NOTE: This will save what the terminal state data looked like at the time the JMTUnitTest application started
	// If you change something in JMT, you will need to restart the test app for the change to be saved/restored correctly
	app.mySaveDataObjsToRestore.saveStateData(_code, method, self.currentMethodBeingRun, self, getTerminal());
	
	return oldSetting;
epilog
	abortTransaction;	
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="setTerminalConfigPw" id="4114a0ea-5e7c-48a5-b53a-f7e305033e52">
        <source>setTerminalConfigPw(_code : String; _value : Any) : Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
07 April 2025	navpw1	Initial creation

*/

vars
	oldSetting : Any;
	
begin
	oldSetting := self.getTerminalConfig(_code);
	
	if process.isInTransactionState then
		app.cmsAbortTransaction();
		self.assertTrueMsg(false, "Unit test is in transaction state which is not expected. Aborting Transaction");
		return null;
	endif;
	
	beginTransaction;
	self.getTerminal.setConfig(_code, _value);
	app.cmsCommitTransaction(app.myPassport);
	
	return oldSetting;
	
epilog
	if process.isInTransactionState then
		app.cmsAbortTransaction();
		self.logMessagePw("Unit test is still in transaction state when running the epilog. This is not expected. The transaction has been aborted", LogDEBUG);
	endif;
	
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="setVoyageMoveResType" id="17312d5b-c95f-44fd-8927-c6af2c683457">
        <updating/>
        <source>setVoyageMoveResType(_voyage : CM_Voyage input; _movementType : String; _resType : HMS_ResourceType) updating;
/*
Purpose:			

Date		Who		Reason
13 October 2021	navab1	TFS 52132
*/

vars
	rtfm, pxyResourceType : HMS_ResourceTypeForMovement;
	coll : HMS_ResourceTypeByCodeDict;
begin

	if _voyage = null
	or _resType = null then
	
		return;
	endif;
	
	if _voyage.myHMSVoyageData = null then
		return;
	endif;
	
	rtfm := _voyage.myHMSVoyageData.allDefaultMovementResources[_movementType];
	
	if rtfm = null then
		create pxyResourceType transient;
		create coll transient;
		coll.add(_resType);
//		_voyage.myHMSVoyageData.getMyHMSVesselData().allMovementResourcesByMovement.add(pxyResourceType);  
		pxyResourceType.setProxy(_movementType, 0, _voyage.myHMSVoyageData.myHarbour, coll);
	
	
		beginTransaction;
		create rtfm;
		rtfm.setForUpdate(pxyResourceType, app.myPassport);
		_voyage.myHMSVoyageData.allDefaultMovementResources.add(rtfm);
		commitTransaction;
	endif;
	

	
	
epilog
	delete pxyResourceType;
	delete coll;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_movementType" type="String"/>
        <Parameter name="_resType" type="HMS_ResourceType"/>
    </JadeMethod>
    <JadeMethod name="setVoyageVesselCategory" id="4c6714b1-f4f0-4490-98f2-6269fb7700f4">
