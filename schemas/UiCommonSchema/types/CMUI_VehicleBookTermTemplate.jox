    <JadeMethod name="doResize" id="a7ac603b-8d34-406f-9725-eca1ec864049">
        <updating/>
        <source>doResize() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 April 2013	cnwndl1	Initial creation

*/

vars

begin

	inheritMethod();
	
	self.frmDayTemp.top := 1;
	self.frmDayTemp.left := 1;
	
	self.frmDayTemp.width := self.clientWidth;
	self.frmDayTemp.height := self.clientHeight;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initTblDays" id="bcbe9eeb-69e0-42c2-a9f6-a30d22af53c4">
        <source>initTblDays();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

	entTableDef : EntTableDef;
	iter : Iterator;
	dayTemp : CM_VehicleBookingDayTemplate;
	dynaDict : DynaDictionary;

begin

	self.tblDays.clear();
	
	entTableDef := app.myController.getEntTableDef(ETDef_DaySlotTemplate);
	self.tblDays.setTblDataEntRowsFromDef(entTableDef);
	
	create dynaDict transient;
	dynaDict.setMembership(CM_VehicleBookingDayTemplate);
	dynaDict.addMemberKey(CM_VehicleBookingDayTemplate::priority.name,false,false);
	dynaDict.endKeys(true);
	
	self.myVehicleBookingTerminal.allVehicleBookingDayTemplates.copy(dynaDict);
	
	iter := dynaDict.createIterator;
	
	while iter.next( dayTemp ) do
		self.addObjToTblDays( dayTemp );
	endwhile;

epilog

	self.setDayButtons();
	delete iter;
	delete dynaDict;

end;</source>
    </JadeMethod>
    <JadeMethod name="setDayButtons" id="7eca5aac-d99d-44e1-bc2b-d6af97ff4ccf">
        <source>setDayButtons();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

	dayTemp : CM_VehicleBookingDayTemplate;
	
begin

	if self.myVehicleBookingTerminal &lt;&gt; null then
	
		if self.tblDays.row &gt; self.tblDays.fixedRows and self.tblDays.row &lt;= self.tblDays.rows then
			dayTemp := self.tblDays.accessRow( self.tblDays.row ).itemObject.CM_VehicleBookingDayTemplate;
		endif;
	
		self.btnAddDay.enabled := true;
		self.btnDelDay.enabled := dayTemp &lt;&gt; null;
		self.btnUpdDay.enabled := dayTemp &lt;&gt; null;
		
	else
		self.btnAddDay.enabled := false;
		self.btnDelDay.enabled := false;
		self.btnUpdDay.enabled := false;
		
	endif;
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnAddDay.enabled := false;
		self.btnDelDay.enabled := false;
		self.btnUpdDay.enabled := false;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyVehicleBookingTerminal" id="ffa72bd9-835f-4808-a2d0-99403f642a51">
        <updating/>
        <source>setMyVehicleBookingTerminal( vssTerm : CM_VehicleBookingTerminal ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

begin

	self.myVehicleBookingTerminal := vssTerm;

epilog

end;</source>
        <Parameter name="vssTerm" type="CM_VehicleBookingTerminal"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="e30e5f4f-c550-4588-913e-6be8fc6899d9">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

begin
	
	inheritMethod();
	
	self.centreOverParent(0);
	
	self.txtTerminal.text := self.myVehicleBookingTerminal.myTerminal.name;
	
	self.initTblDays();
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnAddDay.enabled:= false;
	endif;

epilog

end;</source>
    </JadeMethod>
