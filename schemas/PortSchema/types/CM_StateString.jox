<Class name="CM_StateString" id="6762e313-6ba7-47ff-947a-35435e403199">
    <superclass name="CM_StateData"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmstate"/>
    <PrimAttribute name="value" id="8f021f09-9c14-4dbf-a83b-d6739ed16d3e">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getValue" id="60a2321a-7780-4599-9c2d-e2c239e801ef">
        <source>getValue(): Any;

vars

begin
	return self.value.trimBlanks;
end;</source>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="setValue" id="6ae7b268-02f6-4cd7-a8fe-4a73ea9a3274">
        <updating/>
        <source>setValue(pValue: Any) updating;

vars
	tmpValue	: String;
	
begin

	tmpValue := pValue.String;
	if self.value &lt;&gt; tmpValue then
		self.value := tmpValue;
	endif;

end;</source>
        <Parameter name="pValue" type="Any"/>
    </JadeMethod>
</Class>
