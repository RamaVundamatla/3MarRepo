    <JadeMethod name="deselectObject" id="b8e2bb85-17e5-4cf3-84e8-066711db9d37">
        <updating/>
        <source>deselectObject(_obj : Object;_redraw : Boolean; _alt : Boolean) updating;
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/

vars
	theLCs : CM_LCSet;
	deckItem : CM_DeckItem;
	anLC : CM_LocationsController;
begin
	if _obj = null then
		return;
	endif;
	if (self.allSelectedObjects.includes(_obj)) then
		self.allSelectedObjects.remove(_obj);
		self.allObjectEditions.remove(_obj);
		
		
		create theLCs transient;
		if _obj.isKindOf(CM_DeckItem) then
			deckItem := _obj.CM_DeckItem;
			deckItem.getLCs(theLCs, true);
			
			foreach anLC in theLCs  discreteLock do
				self.allObjectEditions.remove(anLC);
			endforeach;
		elseif _obj.isKindOf(CM_RORORequest) then
			anLC := _obj.CM_RORORequest.myROROController;
			if anLC &lt;&gt; null then
				self.allObjectEditions.remove(anLC);
			endif;
		endif;
		self.doDrawObject(anLC);
	endif;
epilog
	delete theLCs;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_redraw" type="Boolean"/>
        <Parameter name="_alt" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDrawAftFwdConnections" id="d4d2000c-74b8-421f-beda-b6832fa161b5">
        <source>doDrawAftFwdConnections();
/*
Purpose:			
Date		Who		Reason
21 February 2013	cnwab1	Initial creation
*/

vars
	layerFrame, tmpFrame : CMUI_PointDrawingFrame;
	obj : Object;
	deckItem, fwdDeckItem : CM_ROROLocnDefn;
	itemLayout, fwdLayout : 	CM_DeckItemLayout;
	x1, y1, x2, y2 : Integer;
	xf1, yf1, xf2, yf2 : Integer;
	midX, midY, midfX, midfY : Real;
	endPoint : Character;
	fntName : String;
begin
	fntName :=	self.myPointDrawingFrame.drawFontName;

	if self.scaleFactor &lt;&gt; 1 then
		
		return;
	endif;

	self.myPointDrawingFrame.zOrder(1);
	self.myPointDrawingFrame.clearGraphics();

	// ### CARGO
	foreach obj in self.allBackFrames discreteLock do
		tmpFrame := obj.CMUI_PointDrawingFrame;
		if tmpFrame.name = "BACKCargo" then
			layerFrame := tmpFrame;
		endif;
	endforeach;

	if layerFrame &lt;&gt; null then
			self.doDrawAftFwdConnectionsFrame(layerFrame);
	endif;

	// ### LOAD
	foreach obj in self.allBackFrames discreteLock do
		tmpFrame := obj.CMUI_PointDrawingFrame;
		if tmpFrame.name = "BACKLoad CC" then
			layerFrame := tmpFrame;
		endif;
	endforeach;

	if layerFrame &lt;&gt; null then
			self.doDrawAftFwdConnectionsFrame(layerFrame);
	endif;
epilog
	self.myPointDrawingFrame.drawFontName := fntName;

end;</source>
    </JadeMethod>
    <JadeMethod name="doDrawAftFwdConnectionsFrame" id="5a95f996-d016-42fa-9fab-7e81f7bb0eae">
        <source>doDrawAftFwdConnectionsFrame(_layerFrame : CMUI_PointDrawingFrame);
/*
Purpose:			
Date		Who		Reason
21 February 2013	cnwab1	Initial creation
*/

vars
	obj : Object;
	deckItem, fwdDeckItem : CM_ROROLocnDefn;
	itemLayout, fwdLayout : 	CM_DeckItemLayout;
	x1, y1, x2, y2 : Integer;
	xf1, yf1, xf2, yf2 : Integer;
	midX, midY, midfX, midfY : Real;
	endPoint : Character;
begin
	if _layerFrame &lt;&gt; null then
		
		foreach obj in _layerFrame.allPointGraphics discreteLock do
			if obj.isKindOf(CM_DeckItemLayout) then
				itemLayout := obj.CM_DeckItemLayout;
				
				
				if itemLayout.isLocnDefnLayout() then
				
					x2 := 0;
					x1 := 99999999;
					y2 := 0;
					y1 := 99999999;
					
					itemLayout.getExtremePoints(x1, y1, x2, y2);
					
					midX := (((x2-x1) / 2) + x1).Integer;
					midY := (((y2-y1) / 2) + y1).Integer;
				
				
					deckItem := itemLayout.myDeckItem.CM_ROROLocnDefn;
					
					
					//#### FORWARD
					fwdDeckItem := deckItem.myAdjacentSlotFwd;
					
					if fwdDeckItem = null then
					
						self.myPointDrawingFrame.drawFontName := "Wingdings";
						self.myPointDrawingFrame.drawFontSize := 14;
						endPoint := 214.Character;
						if deckItem.isVerticalOrientation() then
							self.myPointDrawingFrame.drawTextCharRotation := 270;
							self.myPointDrawingFrame.drawTextAt(endPoint,midX+10,midY+12, Red);
						else
							self.myPointDrawingFrame.drawTextCharRotation := 0;
							self.myPointDrawingFrame.drawTextAt(endPoint,midX,midY-8, Red);
						endif;
						//self.myPointDrawingFrame.drawFilledRectangle(midX-3,midY-3,midX+3,midY+3, Red);
					else
						fwdLayout := fwdDeckItem.myLayout;
			
						xf2 := 0;
						xf1 := 99999999;
						yf2 := 0;
						yf1 := 99999999;
						
						fwdLayout.getExtremePoints(xf1, yf1, xf2, yf2);
						
						midfX := (((xf2-xf1) / 2) + xf1).Integer;
						midfY := (((yf2-yf1) / 2) + yf1).Integer;
						
						self.myPointDrawingFrame.drawFillColor := Blue;
						if deckItem.isVerticalOrientation() then
						self.myPointDrawingFrame.drawWidth := 4;
							self.myPointDrawingFrame.drawLine(midX+6,midY+10,midfX+6,midfY-10, Blue);
//							self.myPointDrawingFrame.drawWidth := 7;
							
							self.myPointDrawingFrame.drawFontName := "Wingdings";
							self.myPointDrawingFrame.drawFontSize := 10;
							endPoint := 234.Character;
							self.myPointDrawingFrame.drawTextCharRotation := 0;
							self.myPointDrawingFrame.drawTextAt(endPoint,midfX+0.9999,midfY-12, Blue);
							
//							self.myPointDrawingFrame.drawPoint(midfX+4,midfY-9, Blue);
						else
						self.myPointDrawingFrame.drawWidth := 3;
							self.myPointDrawingFrame.drawLine(midX+10,midY-5,midfX-10,midfY-5, Blue);
//							self.myPointDrawingFrame.drawWidth := 7;
							
							self.myPointDrawingFrame.drawFontName := "Wingdings";
							self.myPointDrawingFrame.drawFontSize := 10;
							endPoint := 232.Character;
							self.myPointDrawingFrame.drawTextCharRotation := 0;
							self.myPointDrawingFrame.drawTextAt(endPoint,midfX-14,midfY-12, Blue);
							//self.myPointDrawingFrame.drawPoint(midfX-9,midfY-5, Blue);
						endif;
					endif;
					
					//#### AFT
					fwdDeckItem := deckItem.myAdjacentSlotAft;
					
					if fwdDeckItem = null then
				
						self.myPointDrawingFrame.drawFontName := "Wingdings";
						self.myPointDrawingFrame.drawFontSize := 14;
						endPoint := 213.Character;
						if deckItem.isVerticalOrientation() then
							self.myPointDrawingFrame.drawTextCharRotation := 270;
							self.myPointDrawingFrame.drawTextAt(endPoint,midX+10,midY-8, Red);
						else
							self.myPointDrawingFrame.drawTextCharRotation := 0;
							self.myPointDrawingFrame.drawTextAt(endPoint,midX-17,midY-8, Red);
						endif;
					
//						self.myPointDrawingFrame.drawFillColor := Yellow;
//						self.myPointDrawingFrame.drawFilledRectangle(midX-3,midY-3,midX+3,midY+3, Yellow);
					else
						fwdLayout := fwdDeckItem.myLayout;
			
						xf2 := 0;
						xf1 := 99999999;
						yf2 := 0;
						yf1 := 99999999;
						
						fwdLayout.getExtremePoints(xf1, yf1, xf2, yf2);
						
						midfX := (((xf2-xf1) / 2) + xf1).Integer;
						midfY := (((yf2-yf1) / 2) + yf1).Integer;
						
						self.myPointDrawingFrame.drawWidth := 3;
						self.myPointDrawingFrame.drawFillColor := Green;
						if deckItem.isVerticalOrientation() then
							//self.myPointDrawingFrame.drawLine(midX+5,midY+10,midfX+5,midfY-10, Blue);
							self.myPointDrawingFrame.drawLine(midX-5,midY-10,midfX-5,midfY+10, Green);
							self.myPointDrawingFrame.drawWidth := 7;
							
							self.myPointDrawingFrame.drawFontName := "Wingdings";
							self.myPointDrawingFrame.drawFontSize := 10;
							endPoint := 233.Character;
							self.myPointDrawingFrame.drawTextCharRotation := 0;
							self.myPointDrawingFrame.drawTextAt(endPoint,midfX-10,midfY+2, Green);
//							//self.myPointDrawingFrame.drawPoint(midfX-5,midfY+10, Green);
						else
							self.myPointDrawingFrame.drawLine(midX-10,midY+5,midfX+10,midfY+5, Green);
							self.myPointDrawingFrame.drawWidth := 7;
							
							self.myPointDrawingFrame.drawFontName := "Wingdings";
							self.myPointDrawingFrame.drawFontSize := 10;
							endPoint := 231.Character;
							self.myPointDrawingFrame.drawTextCharRotation := 0;
							self.myPointDrawingFrame.drawTextAt(endPoint,midfX+5,midfY-2, Green);
//							self.myPointDrawingFrame.drawPoint(midfX+10,midfY+5, Green);
						endif;
					endif;
				endif;
			
			endif;
			
			
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_layerFrame" type="CMUI_PointDrawingFrame"/>
    </JadeMethod>
    <JadeMethod name="doDrawLayer" id="6f198bc7-99ef-4681-a405-22184a056c7e">
        <updating/>
        <source>doDrawLayer(_frame : CMUI_PointDrawingFrame input;_layer : CM_DeckLayerLayout; _sdfDrawingFrame : CMUI_PointDrawingFrame) updating;
/*

Purpose:	refactored out of the SHP_ROROPlanningForm form doDrawLayer method		

Parameters:			

Return Value:		


Date		Who		Reason
20 September 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

begin
	_frame.setDefaultFont(_frame); // 29923

	_frame.showText := false;
	if self.modeView = ShpDisplayMode_Actual then
		self.doDrawLayerLayoutActual(_frame, _layer, null, _sdfDrawingFrame);
	elseif self.modeView = ShpDisplayMode_Proposed then
		self.doDrawLayerLayoutProposed(_frame, _layer, null, _sdfDrawingFrame);
	elseif self.modeView = ShpDisplayMode_Defn then
		_frame.showText := (_frame.modeViewSub = ShpDisplayModeSub_Text);
		_frame.setModeView(ShpDisplayMode_Defn);
		self.doDrawLayerLayout(_frame, _layer, null, _sdfDrawingFrame);
	elseif self.modeView = ShpDisplayMode_ColCodeDisch then
		self.doDrawLayerLayoutCCDischarge(_frame, _layer, null, _sdfDrawingFrame);
	elseif self.modeView = ShpDisplayMode_ColCodeLoad then
		self.doDrawLayerLayoutCCLoad(_frame, _layer, null, _sdfDrawingFrame);
	endif;

	_frame.enabled := false;
	_frame.visible := _layer.isVisible;
epilog

end;</source>
        <Parameter name="_frame" type="CMUI_PointDrawingFrame" usage="input"/>
        <Parameter name="_layer" type="CM_DeckLayerLayout"/>
        <Parameter name="_sdfDrawingFrame" type="CMUI_PointDrawingFrame"/>
    </JadeMethod>
    <JadeMethod name="doDrawLayerLayout" id="05ce5d95-8813-438c-92fd-476aae3cf75b">
        <updating/>
        <source>doDrawLayerLayout(_frame : CMUI_PointDrawingFrame; _layer : CM_DeckLayerLayout; _graphicToIgnore : CM_DeckItemLayout; _sdfDrawingFrame : CMUI_PointDrawingFrame) updating;
// ---------------------------------------------------------------------------
// Created:     April 2011 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// CCMS 1031 MES RORO
// ---------------------------------------------------------------------------

vars

	theRORODefn : CM_ROROVesselStructure;
	deckItemLayout : CM_DeckItemLayout;
	aGraphic : CM_Graphic;
	theFrame : CMUI_PointDrawingFrame;
	graphArray : CM_GraphicArray;
	theDeck : CM_DeckLayout;
	
begin
//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1. self.modeView: ' &amp; self.modeView.String);	
	self.myPointDrawingFrame := _frame;
	theFrame := _frame; 
	foreach deckItemLayout in _layer.allDeckItemLayouts reversed do 
	/*
		if _frame.mySDF = null then // back frame
			// If it is on the SDF's drawing frame then do not draw it on the back frame
			if _sdfDrawingFrame &lt;&gt; null then
				if _sdfDrawingFrame.allPointGraphics.includes(deckItemLayout) then
					continue;
				endif;
			endif;
		endif;
		*/
		if not deckItemLayout.isVisible then
			continue;
		endif;
		
		theFrame.doAddToArraysForProxy(deckItemLayout);
		
		// PAR 28400 Dmast only, easier to read IDs
		if self.modeView = ShpDisplayMode_Defn then
			if not deckItemLayout.myDeckItem.isKindOf(CM_ROROLocnDefn) then
				theFrame.allTexts[theFrame.allTexts.size] := "";
			endif;
		endif;
	endforeach;
	theFrame.drawAllPolygons(White);
end;</source>
        <Parameter name="_frame" type="CMUI_PointDrawingFrame"/>
        <Parameter name="_layer" type="CM_DeckLayerLayout"/>
        <Parameter name="_graphicToIgnore" type="CM_DeckItemLayout"/>
        <Parameter name="_sdfDrawingFrame" type="CMUI_PointDrawingFrame"/>
    </JadeMethod>
    <JadeMethod name="doDrawLayerLayoutActual" id="5021d837-98cf-4291-823c-5d8a51b9ed30">
        <updating/>
        <source>doDrawLayerLayoutActual(_frame : CMUI_PointDrawingFrame;_layer : CM_DeckLayerLayout; _graphicToIgnore : CM_DeckItemLayout; _sdfDrawingFrame : CMUI_PointDrawingFrame) updating;
// ---------------------------------------------------------------------------
// Created:     June 2011 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// CCMS 1035 MES RORO
// ---------------------------------------------------------------------------

vars

	theRORODefn : CM_ROROVesselStructure;
	deckItemLayout : CM_DeckItemLayout;
	aGraphic : CM_Graphic;
	theFrame : CMUI_PointDrawingFrame;
	graphArray : CM_GraphicArray;
	theDeck : CM_DeckLayout;
	allTIs : CM_TIArray;
	aColour : Integer;
	aTI : CM_TrackedItem;
	isMTLocn : Boolean;
begin

	create allTIs transient;
	self.myPointDrawingFrame := _frame;
	theFrame := _frame; 
	if _layer.type = ROROLayerType_Structure then
		foreach deckItemLayout in _layer.allDeckItemLayouts reversed do 
			
			if theFrame.mySDF = null then // back frame
				// If it is on the SDF's drawing frame then do not draw it on the back frame
				if _sdfDrawingFrame &lt;&gt; null then
					if _sdfDrawingFrame.allPointGraphics.includes(deckItemLayout) then
						continue;
					endif;
				endif;
			endif;
			if not deckItemLayout.isVisible then
				continue;
			endif;
			
			
			theFrame.doAddToArraysForProxy(deckItemLayout);
		endforeach;
		theFrame.drawAllPolygons(White);
		
		self.doDrawObjectEQUIPMENT(_layer, theFrame); // PAR 29178

		return;
	endif;
	
	theFrame.doBtnClearClickArrays();

	// ### DRAW ACTUAL CARGO
	if _layer.isActualCargoLayer() then
		foreach deckItemLayout in _layer.allDeckItemLayouts reversed do 
		

			if not self.doDrawObjectACTUAL(deckItemLayout, theFrame, _layer, _sdfDrawingFrame) then
				continue;
			endif;

		endforeach;
		self.getAllPolygonsActual(theFrame,_layer,White);
	endif;
	
epilog
	delete allTIs;
end;</source>
        <Parameter name="_frame" type="CMUI_PointDrawingFrame"/>
        <Parameter name="_layer" type="CM_DeckLayerLayout"/>
        <Parameter name="_graphicToIgnore" type="CM_DeckItemLayout"/>
        <Parameter name="_sdfDrawingFrame" type="CMUI_PointDrawingFrame"/>
    </JadeMethod>
    <JadeMethod name="doDrawLayerLayoutCCDischarge" id="ef304c1e-2b6c-4923-93ed-e03619efa2b0">
        <updating/>
        <source>doDrawLayerLayoutCCDischarge(_frame : CMUI_PointDrawingFrame;_layer : CM_DeckLayerLayout; _graphicToIgnore : CM_DeckItemLayout; _sdfDrawingFrame : CMUI_PointDrawingFrame) updating;
// ---------------------------------------------------------------------------
// Created:     June 2011 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// CCMS 1035 MES RORO
// 11/10/2022	navkc1	Bug 54935: MSL - Roro planning - Slow on big decks/large vessels
// ---------------------------------------------------------------------------

vars
	aTI :CM_TrackedItem;
	theRORODefn : CM_ROROVesselStructure;
	deckItemLayout, coveringItem : CM_DeckItemLayout;
	aGraphic : CM_Graphic;
	theFrame : CMUI_PointDrawingFrame;
	graphArray : CM_GraphicArray;
	theDeck : CM_DeckLayout;
	pxyLayout : CM_DeckItemLayout;
	allTIs : CM_TIArray;
	shouldHaveCC : Boolean;
	aColour, fillStyle : Integer;
	aWLE : CM_WorkListEntry;
	aReq : CM_RORORequest;
	allLocnDefn : ObjectSet;
	locnDefn : CM_ROROLocnDefnVoyage;
	deckItem	: CM_DeckItem; // 11/10/2022	navkc1	#54935
	coveringDeckItem	: CM_DeckItem; // 11/10/2022	navkc1	#54935
	isCoveredByOOTLValue : Boolean; // 11/10/2022	navkc1	#54935
begin
	
	self.myPointDrawingFrame := _frame;
	theFrame := _frame; 
	
	// ### STRUCTURE LAYER
	if _layer.type = ROROLayerType_Structure then
		foreach deckItemLayout in _layer.allDeckItemLayouts reversed do 
			
			if theFrame.mySDF = null then // back frame
				// If it is on the SDF's drawing frame then do not draw it on the back frame
				if _sdfDrawingFrame &lt;&gt; null then
					if _sdfDrawingFrame.allPointGraphics.includes(deckItemLayout) then
						continue;
					endif;
				endif;
			endif;
			if not deckItemLayout.isVisible then
				continue;
			endif;
			
			
			theFrame.doAddToArraysForProxy(deckItemLayout);
		endforeach;
		theFrame.drawAllPolygons(White);
		
		self.doDrawObjectEQUIPMENT(_layer, theFrame); // PAR 29178
		return;
	endif;
	
	if _layer.type = ROROLayerType_CCLoad then
		return;
	endif;
	
	
	theFrame.doBtnClearClickArrays();
	
	// ### DRAW ACTUAL CARGO
	if _layer.isActualCargoLayer() then
		create allTIs transient;
		foreach deckItemLayout in _layer.allDeckItemLayouts reversed do 
			if theFrame.mySDF = null then // back frame
				// If it is on the SDF's drawing frame then do not draw it on the back frame
				if _sdfDrawingFrame &lt;&gt; null then
					if _sdfDrawingFrame.allPointGraphics.includes(deckItemLayout) then
						continue;
					endif;
				endif;
			endif;
			if not deckItemLayout.isVisible then
				continue;
			endif;
			if deckItemLayout.myDeckItem = null then
				continue;
			endif;
			
			deckItem := deckItemLayout.myDeckItem; // 11/10/2022	navkc1	#54935

			if self.modeViewSubSub = ShpDisplayModeSub_ExportsHide then // PAR 32246
				if deckItem.hasDischargeCCIsRotatedLoad() then // PAR 32246
					continue;// PAR 32246
				endif;
			endif;
			
			
			if deckItem.isOOTL() and deckItem.isOnLayerOOTL then // PAR 31116
				if self.modeViewSubSub = ShpDisplayModeSub_ExportsHide then // PAR 31116
					if deckItem.hasTIs40Loaded(REAL_MODE, true, false)   // PAR 31376
					or deckItem.hasTIs40Loaded(REAL_MODE, false, false) then  // PAR 31376
						continue;
					endif;
				endif;
			endif;
			
			// do not draw the defn as we will be drawing the layout for the CC
 // PAR 31162			if deckItemLayout.hasCCLayout(DeckItemLayoutType_GCLoad)  // PAR 31073 added parameter
 // PAR 31162			or deckItemLayout.hasCCLayout(DeckItemLayoutType_GCDischarge) then // PAR 31152
			if deckItemLayout.hasCCLayout(DeckItemLayoutType_GCDischarge) then // PAR 31152
				continue;
			endif;
			if deckItemLayout.hasCCLayout(DeckItemLayoutType_GCLoad)  then // PAR 31162
				if self.modeViewSubSub = ShpDisplayModeSub_ExportsHide then // PAR 31162
					continue;
				endif;
			endif;
			if deckItemLayout.isCovered(DeckItemLayoutType_GCLoad, true)  then // PAR 31162
				coveringItem := deckItemLayout.getCoveredBy(DeckItemLayoutType_GCLoad, true);  // PAR 31166-2
				if coveringItem.isOnLayerGC() then  // PAR 31166-2
					if self.modeViewSubSub = ShpDisplayModeSub_ExportsShow then // PAR 31162
						continue;
					endif;
				endif;
			endif;

			if deckItemLayout.isCovered(DeckItemLayoutType_GCDischarge,false)  then
			// PAR 28990or deckItemLayout.isCovered(DeckItemLayoutType_Locn,false) then // hide any cargo positions that are under the GC cargo
				continue;
			endif;

			if deckItemLayout.isCovered(DeckItemLayoutType_CCDischarge,true) then // PAR 30265
				if self.modeViewSubSub = ShpDisplayModeSub_ExportsHide then // PAR 31162
					continue;
				endif;
			endif;

			/* This code is not needed anymore, but it might me useful elsewhere. It hides actual layouts that had had TI exports loaded
			if self.modeViewSubSub = ShpDisplayModeSub_ExportsShow then // PAR 31162
				if deckItemLayout.myDeckItem.hasTIs40Loaded(REAL_MODE, true, false) then  // PAR 31162
					continue;// PAR 31162
				endif;
			endif;
			*/
			
			// PAR 28990
			// PAR 29807if  deckItemLayout.isCovered(DeckItemLayoutType_Locn,true)  then // hide any cargo positions that are under the OOTL cargo
			// PAR 29807	if deckItemLayout.isCoveredByOOTL(DeckItemLayoutType_Locn) then
			//					continue;
			// PAR 29807	endif;
			// PAR 29807endif;

			// PAR 29979
//			if  deckItemLayout.isCovered(DeckItemLayoutType_Locn,true)  then // hide any cargo positions that are under the OOTL cargo
			isCoveredByOOTLValue := deckItemLayout.isCoveredByOOTL(DeckItemLayoutType_Locn);  // 11/10/2022	navkc1	#54935
				if isCoveredByOOTLValue then
					coveringItem := deckItemLayout.getCoveredByOOTL(DeckItemLayoutType_Locn);  // PAR 31376
					if coveringItem.isOnLayerOOTL() then
						if self.modeViewSubSub = ShpDisplayModeSub_ExportsHide then // PAR 31073
							coveringDeckItem := coveringItem.myDeckItem;  // 11/10/2022	navkc1	#54935
							if not coveringDeckItem.hasTIs40Loaded(REAL_MODE, true, false) then  // PAR 31376
								if not coveringDeckItem.hasTIs40Loaded(REAL_MODE, false, false) then  // PAR 31376
						
									continue;
								endif;
							endif;
						else  // PAR 31376
							continue;  // PAR 31376
						endif;
					endif;
				endif;
//			endif;
			
			// PAR 29807
			if deckItemLayout.isCoveredByDefnWithCCCompleted(DeckItemLayoutType_Locn, true) then
				if isCoveredByOOTLValue then
					if self.modeViewSubSub = ShpDisplayModeSub_ExportsShow then // PAR 31073 only hide the hidden if we are showing the export that is hiding it
						continue;
					endif;
				endif;
			endif;
				
			
			// PAR 29178
			if  deckItemLayout.isCovered(DeckItemLayoutType_Graphic,true)  then // hide any cargo positions that are under the Equipment or General AREA
				continue;
			endif;
			
	// PAR 30111		if deckItemLayout.isCovered(DeckItemLayoutType_CCDischarge,true) then // PAR 27749
	// PAR 30111 actually fixing 30020 - AB			continue;
	// PAR 30111		endif;
			// PAR 29478 this is much simplier now, always solid, always the TIs colour
			aColour := White;
			deckItem.getAllTIs(REAL_MODE,allTIs, true);




			
			if not allTIs.isEmpty() then
				aTI := allTIs[1];
				if aTI &lt;&gt; null then
				
					if self.modeViewSubSub = ShpDisplayModeSub_ExportsHide then
						if deckItemLayout.isGCDefnLayout or deckItemLayout.isOOTLDefn then
						if aTI.isExport then
							continue;
						endif;
						endif;
					endif;
				
					if self.modeViewSub = ShpDisplayModeSub_Colour then
						if deckItemLayout.isGCDefnLayout() then
							aColour := aTI.getDrawingColour(TI_ColourMode_DischargePort); 
						elseif deckItemLayout.isLaneDefnVoyageLayout() then // PAR 31970
							aColour := aTI.getDrawingColour(TI_ColourMode_DischargePort);  // PAR 31970
						else
							aColour := White;
						endif;
					else // TEXT MODE
					
						aColour := aTI.getDrawingColour(TI_ColourMode_DischargePort); 
						if self.modeViewSubSub = ShpDisplayModeSub_ExportsHide then // PAR 31073 
							//if aTI.isExport or aTI.isRehandle or aTI.isSOB   or aTI.isTranshipExport() then // PAR 31605
							if aTI.hasBeenLoadedToShip() then		//cnwmc5 - 11 March 2014 - PAR 33283
								aColour := White;
							endif;
						endif;
					endif;
				endif;
			endif;
			fillStyle := Frame.DrawFillStyle_Solid;
			
			theFrame.doPointArrayAdd(deckItemLayout.drawLineColour,true, fillStyle, 1, aColour, deckItemLayout);

		endforeach;
		self.getAllPolygonsActualForCC(_layer,White, false);
		return;
	endif;
	
	// ### DRAW DISCHARGE COLOUR CODING
	if _layer.type = ROROLayerType_CCDischarge then
	// PAR 31439 and self.modeViewSubSub = ShpDisplayModeSub_ExportsHide then // PAR 31162
		create allLocnDefn transient;
		foreach deckItemLayout in _layer.allDeckItemLayouts reversed do 
			if not self.doDrawObjectCCDISCHARGE(deckItemLayout, theFrame, _layer, allLocnDefn,  _sdfDrawingFrame) then
				continue;
			endif;
		endforeach;
		self.getAllPolygonsColourCoding(_frame,_layer,false, White);
	endif;
	
	
epilog
	delete allTIs;
	delete allLocnDefn;
end;</source>
        <Parameter name="_frame" type="CMUI_PointDrawingFrame"/>
        <Parameter name="_layer" type="CM_DeckLayerLayout"/>
        <Parameter name="_graphicToIgnore" type="CM_DeckItemLayout"/>
        <Parameter name="_sdfDrawingFrame" type="CMUI_PointDrawingFrame"/>
    </JadeMethod>
    <JadeMethod name="doDrawLayerLayoutCCLoad" id="57e5730b-61e3-46a7-b3f9-23c21808b828">
        <updating/>
        <source>doDrawLayerLayoutCCLoad(_frame : CMUI_PointDrawingFrame; _layer : CM_DeckLayerLayout; _graphicToIgnore : CM_DeckItemLayout; _sdfDrawingFrame : CMUI_PointDrawingFrame) updating;
// ---------------------------------------------------------------------------
// Created:     June 2011 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// CCMS 1035 MES RORO
// ---------------------------------------------------------------------------
//18 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
vars
	aTI :CM_TrackedItem;
	theRORODefn : CM_ROROVesselStructure;
	deckItemLayout, coveringObj : CM_DeckItemLayout;
	aGraphic : CM_Graphic;
	theFrame : CMUI_PointDrawingFrame;
	graphArray : CM_GraphicArray;
	theDeck : CM_DeckLayout;
	pxyLayout : CM_DeckItemLayout;
	allTIs : CM_TIArray;
	shouldHaveCC : Boolean;
	aColour, fillStyle : Integer;
	aWLE : CM_WorkListEntry;
	aReq : CM_RORORequest;
	allLocnDefn : ObjectSet;
	tmpLocnDefn : CM_ROROLocnDefn;
	deckItem : CM_DeckItem;
begin
	
	self.myPointDrawingFrame := _frame;
	theFrame := _frame; 
	
	// ### STRUCTURE LAYER
	if _layer.type = ROROLayerType_Structure then
		foreach deckItemLayout in _layer.allDeckItemLayouts reversed do 
			
			if theFrame.mySDF = null then // back frame
				// If it is on the SDF's drawing frame then do not draw it on the back frame
				if _sdfDrawingFrame &lt;&gt; null then
					if _sdfDrawingFrame.allPointGraphics.includes(deckItemLayout) then
						continue;
					endif;
				endif;
			endif;
			if not deckItemLayout.isVisible then
				continue;
			endif;
			
			
			theFrame.doAddToArraysForProxy(deckItemLayout);
		endforeach;
		theFrame.drawAllPolygons(White);
		
		self.doDrawObjectEQUIPMENT(_layer, theFrame); // PAR 29178
		return;
	endif;
	
	if _layer.type = ROROLayerType_CCDischarge then
		return;
	endif;
	
	
	theFrame.doBtnClearClickArrays();
	
	// ### DRAW ACTUAL CARGO
//	if _layer.type = ROROLayerType_Cargo // defined container locations
//	or _layer.type = ROROLayerType_GC  
//	or _layer.type = ROROLayerType_Lanes then // defined lanes
	if _layer.isActualCargoLayer() then // PAR 29990
		create allTIs transient;
		foreach deckItemLayout in _layer.allDeckItemLayouts reversed do 
			if theFrame.mySDF = null then // back frame
				// If it is on the SDF's drawing frame then do not draw it on the back frame
				if _sdfDrawingFrame &lt;&gt; null then
					if _sdfDrawingFrame.allPointGraphics.includes(deckItemLayout) then
						continue;
					endif;
				endif;
			endif;
			if not deckItemLayout.isVisible then
				continue;
			endif;
			if deckItemLayout.myDeckItem = null then
				continue;
			endif;
			
			deckItem := deckItemLayout.myDeckItem; // 11/10/2022	navkc1	#54935
			
			// do not draw the defn as we will be drawing the layout for the CC
			if deckItemLayout.hasCCLayout(DeckItemLayoutType_GCLoad)  // PAR 31073 added parameter
			or deckItemLayout.hasCCLayout(DeckItemLayoutType_GCDischarge) then // PAR 31152
				continue;
			endif;

			

			// PAR 29979 - Hide me as I am rotated on the actual layer and there are clones covering me on the load CC layer
	// PAR 31341		if deckItemLayout.myDeckItem.isKindOf(CM_ROROLocnDefnVoyage) then
				if deckItem.isPlannedRotatedMethod() then // PAR 31341 changed to new method
				// PAR 32374	if deckItemLayout.isCovered(DeckItemLayoutType_Locn,true)  then	// PAR 31341 changed to TRUE		
				// PAR 32374			coveringObj := deckItemLayout.getCoveredBy(DeckItemLayoutType_Locn,false);
				// PAR 32374			if coveringObj.myDeckLayer.type = ROROLayerType_CCLoad  then
				// PAR 32374 use new method isCoveredByOnLayer		
						if deckItemLayout.isCoveredByOnLayer(DeckItemLayoutType_Locn,ROROLayerType_CCLoad, true) then
							continue;
						endif;
				//	endif;
				
				endif;
			
	//		endif;
			
			if deckItemLayout.isCovered(DeckItemLayoutType_CCLoad,true) then // PAR 30265
				continue;
			endif;
			
			// PAR 29979
			if deckItemLayout.isCoveredByOOTL(DeckItemLayoutType_Locn) then
				//epr par 32488 18/9/13 noticed 1090 while fixing this par put the code changed here in par 32374 back to how it was
				// PAR 32374 
				coveringObj := deckItemLayout.getCoveredBy(DeckItemLayoutType_Locn,false);
				// PAR 32374 
				if coveringObj.myDeckLayer.type = ROROLayerType_OOTL  then
				// PAR 32374 use new method isCoveredByOnLayer		
				//if deckItemLayout.isCoveredByOnLayer(DeckItemLayoutType_Locn,ROROLayerType_OOTL, true) then
				
					// PAR 29979
					// PAR 11334 if coveringObj.hasNoCC(false) then // has no discharge CC so is ROB
					if not coveringObj.myDeckItem.hasTIsAllColourCoded(REAL_MODE, false,false) then // PAR 33114	
						continue;

					endif;
				endif;
			endif;
			/* PAR 33114 this is no longer needed because of the other change for 33114
			// PAR 29979
			if deckItemLayout.isCovered(DeckItemLayoutType_Locn,false)  then			
				coveringObj := deckItemLayout.allCoveringPolygons[DeckItemLayoutType_Locn];
				if coveringObj.myDeckItem.CM_ROROLocnDefn.isPlannedRotated then
				//	continue;
				endif;
			endif;
			*/
			
			if deckItemLayout.isOOTLDefn then
				if deckItemLayout.isOnLayerOOTL then
				// PAR 33114	if not deckItemLayout.hasNoCC(false) then // has discharge CC so is ROB
					
					if 	deckItem.hasTIsAllColourCoded(REAL_MODE, false,false) then // PAR 33114	
						continue;

					endif;
				
				endif;
			endif;
			
			if deckItemLayout.isCovered(DeckItemLayoutType_GCDischarge,false)  then // hide any cargo positions that are under the GC cargo
				if not deckItemLayout.isCoveredByDefnWithCC(DeckItemLayoutType_GCDischarge)  then // hide any cargo positions that are under the GC cargo
					continue;
				endif;
			endif;

			// PAR 29178
			if  deckItemLayout.isCovered(DeckItemLayoutType_Graphic,true)  then // hide any cargo positions that are under the Equipment or General AREA
				continue;
			endif;

			// PAR 29807 if deckItemLayout.isCovered(DeckItemLayoutType_Locn,false) then // hide any cargo positions that are under the rotated cloned load locn defn
			// PAR 29807 	// 29374 Mar 2012 if under OOTL discharge, show the underlying cells in load mode
			// PAR 29807 	if not deckItemLayout.isCoveredByOOTL(DeckItemLayoutType_Locn) then

			// PAR 29807 		continue;
			// PAR 29807 	endif;
			// PAR 29807 endif;
				
			// PAR 29807
			if deckItemLayout.isCoveredByDefnWithCCCompleted(DeckItemLayoutType_Locn, true) then
				if deckItemLayout.isCoveredByOOTL(DeckItemLayoutType_Locn) then
					continue;
				endif;
			endif;
			
/* PAR 29478
			shouldHaveCC := false;
			deckItemLayout.myDeckItem.getAllTIs(PLANNING_MODE,allTIs, true);
			if allTIs.isEmpty() then
				deckItemLayout.myDeckItem.getAllTIs(REAL_MODE,allTIs, true);
			endif;
			if not allTIs.isEmpty() then
				aTI := allTIs[1];
				
				if aTI &lt;&gt; null then
					aWLE := aTI.getVoyageWLEUnactioned(true);
					if aWLE = null then // no request - no colour coding
						// PAR 29050
						if self.modeViewSub = ShpDisplayModeSub_Colour then
							aColour := White;
						else
							aColour := aTI.getDrawingColour(TI_ColourMode_DischargePort); 
						endif;
						shouldHaveCC := true;
					// PAR 29050
					//	if aTI.isToBeDischargedHere() then
					//		shouldHaveCC := true;
					//		aColour := aTI.getDrawingColour(TI_ColourMode_DischargePort); //.changeColourByHSL(0,0.4,0.4);
					//	else // REMAIN ON BOARD ROB
					//		// PAR 29048 aColour := LightGray;
					//		aColour := aTI.getDrawingColour(TI_ColourMode_DischargePort);// PAR 29048 
					//		shouldHaveCC := true;// PAR 29048 
					//	endif;
						
					else
						// PAR 29050
						if self.modeViewSub = ShpDisplayModeSub_Colour then
							aColour := White;
						else
							aColour := aTI.getDrawingColour(TI_ColourMode_DischargePort); 
						endif;
						//continue; // PAR 29048 Is colour coded so do not draw the cargo, we will draw the CC next
						// PAR 29048 aColour := aWLE.myRequest.CM_RORORequest.getAllocationColour();
					endif;
				endif;
			else
				aColour := White;
			endif;
			
			if shouldHaveCC then
				fillStyle := Frame.DrawFillStyle_Solid; // PAR 29050 DrawFillStyle_DiagonalCross;  // has discharge TIs that are CCd
			elseif allTIs.isEmpty() then
				fillStyle := Frame.DrawFillStyle_Solid; //DrawFillStyle_Transparent;
			else
				fillStyle := Frame.DrawFillStyle_Solid; // has RoB TIs 
			endif;
			*/
			
			// PAR 29478 this is much simplier now, always solid, always the TIs colour
			aColour := White;
			deckItem.getAllTIs(REAL_MODE,allTIs, true);
			if not allTIs.isEmpty() then
				aTI := allTIs[1];
				if aTI &lt;&gt; null then
					if self.modeViewSub = ShpDisplayModeSub_Colour then
						if deckItemLayout.isGCDefnLayout() then
							aColour := aTI.getDrawingColour(TI_ColourMode_DischargePort); 
						elseif deckItemLayout.isLaneDefnVoyageLayout() then
							aColour := aTI.getDrawingColour(TI_ColourMode_DischargePort); 
						else
							aColour := White;
						endif;
					else
						if deckItem.hasROB(false) then// PAR 29694
							aColour := aTI.getDrawingColour(TI_ColourMode_DischargePort); 
						else
							aColour := White;// PAR 29694
						endif;
					endif;
				endif;
			endif;
			fillStyle := Frame.DrawFillStyle_Solid;
			theFrame.doPointArrayAdd(deckItemLayout.drawLineColour,true, fillStyle, 1, aColour, deckItemLayout);

		endforeach;
		self.getAllPolygonsActualForCC(_layer,White, true);
		return;
	endif;


	// ### DRAW COLOUR CODING
	if _layer.type = ROROLayerType_CCLoad then
		foreach deckItemLayout in _layer.allDeckItemLayouts reversed where deckItemLayout.isLocnDefnLayout() and deckItemLayout.isVisible do 

			// PAR 29979
			if deckItemLayout.isCoveredByOOTL(DeckItemLayoutType_Locn) then
				// PAR 32374 coveringObj := deckItemLayout.getCoveredBy(DeckItemLayoutType_Locn,false);
				// PAR 32374 if coveringObj.myDeckLayer.type = ROROLayerType_CCLoad  then
				// PAR 32374 use new method isCoveredByOnLayer		
				if deckItemLayout.isCoveredByOnLayer(DeckItemLayoutType_Locn,ROROLayerType_CCLoad, true) then

					continue;
				endif;
			endif;
			// PAR 32374 if deckItemLayout.isCovered(DeckItemLayoutType_GCLoad,false)  then			
			// PAR 32374 	coveringObj := deckItemLayout.getCoveredBy(DeckItemLayoutType_GCLoad,false);
			// PAR 32374 	if coveringObj.myDeckLayer.type = ROROLayerType_CCLoad  then
			// PAR 32374 use new method isCoveredByOnLayer		
			if deckItemLayout.isCoveredByOnLayer(DeckItemLayoutType_GCLoad,ROROLayerType_CCLoad, true) then
					continue;
			endif;
			//endif;
			
			// PAR 31172 - Messina have rotated in actual a 2X5, have not added any containers to that group, then have covered  the rotation with GC???. 
			// 					In Load they have unrotated it??? so that two of the 10 rotated are visible as unrotated, but we were displaying all the unrotated.
			//					this chnage stops the unrotated that are covered with GC from showing
			if deckItemLayout.isCovered(DeckItemLayoutType_GCDischarge,true)  then		
				coveringObj := deckItemLayout.getCoveredBy(DeckItemLayoutType_GCDischarge,true); // PAR 31786
				if coveringObj.getDeckItem().CM_ROROGCDefnVoyage.hasColourCoding(DISCHARGE_MOVETYPE) = null then // PAR 31786
					tmpLocnDefn := deckItemLayout.getDeckItem().CM_ROROLocnDefn;
					if tmpLocnDefn.hasBeenRotatedForLoad then
						continue;
					endif;
				endif;
			endif;

			//epr par 32488 18/9/13 situation where rotated in actual then unrotated in load need check its not covered
			if deckItemLayout.type = DeckItemLayoutType_Locn and deckItemLayout.myDeckItem.isKindOf(CM_ROROLocnDefn) and deckItemLayout.myDeckItem.CM_ROROLocnDefn.hasBeenRotatedForLoad then
				if deckItemLayout.isCovered(DeckItemLayoutType_GCLoad,true) or deckItemLayout.isCovered(DeckItemLayoutType_CCLoad,true) then
					continue;
				endif;
			endif;

			theFrame.doPointArrayAdd(Black,true, Frame.DrawFillStyle_Solid, 1, White, deckItemLayout);
		
		endforeach;
		self.getAllPolygonsActualForCC(_layer,White, true);

		


		// PAR 31994 draw 'empty' GC areas on the load. This means that the user has erased the CC, but the actual GC location still exists
		foreach deckItemLayout in _layer.allDeckItemLayouts reversed where (not deckItemLayout.isKindOf(CM_RORORequestLayout) and deckItemLayout.isGCDefnLayout() and deckItemLayout.isVisible) do 

			if deckItemLayout.myDeckItem.CM_ROROGCDefnVoyage.myGCController.myRORORequestLoad &lt;&gt; null then
				continue;
			endif;

			theFrame.doPointArrayAdd(Black,true, Frame.DrawFillStyle_Solid, 1, White, deckItemLayout);
		
		endforeach;
		self.getAllPolygonsActualForCC(_layer,White, true);
		
		
		
		create allLocnDefn transient;
		
		
		foreach deckItemLayout in _layer.allDeckItemLayouts reversed where deckItemLayout.isKindOf(CM_RORORequestLayout) do 
			if not self.doDrawObjectCCLOAD(deckItemLayout, theFrame, _layer, allLocnDefn,  _sdfDrawingFrame) then
				continue;
			endif;
		
		endforeach;
		self.getAllPolygonsColourCoding(_frame,_layer,true, White);
		
	endif;
	
	
epilog
	delete allLocnDefn;
	delete allTIs;
end;</source>
        <Parameter name="_frame" type="CMUI_PointDrawingFrame"/>
        <Parameter name="_layer" type="CM_DeckLayerLayout"/>
        <Parameter name="_graphicToIgnore" type="CM_DeckItemLayout"/>
        <Parameter name="_sdfDrawingFrame" type="CMUI_PointDrawingFrame"/>
    </JadeMethod>
    <JadeMethod name="doDrawLayerLayoutProposed" id="d0dab046-c74d-49d6-8685-dcf6a4d0450d">
        <updating/>
        <source>doDrawLayerLayoutProposed(_frame : CMUI_PointDrawingFrame;_layer : CM_DeckLayerLayout; _graphicToIgnore : CM_DeckItemLayout; _sdfDrawingFrame : CMUI_PointDrawingFrame) updating;
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
*/


vars

	theRORODefn : CM_ROROVesselStructure;
	deckItemLayout : CM_DeckItemLayout;
	aGraphic : CM_Graphic;
	theFrame : CMUI_PointDrawingFrame;
	graphArray : CM_GraphicArray;
	theDeck : CM_DeckLayout;
	allTIs : CM_TIArray;
	aColour : Integer;
	aTI : CM_TrackedItem;
	isMTLocn : Boolean;
begin

//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1. _layer: ' &amp; _layer.code &amp; " " &amp; _layer.type.String);


	create allTIs transient;
	self.myPointDrawingFrame := _frame;
	theFrame := _frame; 
	if _layer.type = ROROLayerType_Structure then
		foreach deckItemLayout in _layer.allDeckItemLayouts reversed do 
			
			if theFrame.mySDF = null then // back frame
				// If it is on the SDF's drawing frame then do not draw it on the back frame
				if _sdfDrawingFrame &lt;&gt; null then
					if _sdfDrawingFrame.allPointGraphics.includes(deckItemLayout) then
						continue;
					endif;
				endif;
			endif;
			if not deckItemLayout.isVisible then
				continue;
			endif;
			
			
			theFrame.doAddToArraysForProxy(deckItemLayout);
		endforeach;
		theFrame.drawAllPolygons(White);
		
		self.doDrawObjectEQUIPMENT(_layer, theFrame); // PAR 29178
		return;
	endif;
	
	theFrame.doBtnClearClickArrays();

	// ### DRAW ACTUAL CARGO
	if _layer.isActualCargoLayer() 
	or _layer.type = ROROLayerType_CCLoad then
		foreach deckItemLayout in _layer.allDeckItemLayouts reversed do 
									
			if not self.doDrawObjectPROPOSED(deckItemLayout, theFrame, _layer,  _sdfDrawingFrame) then
				continue;
			endif;
			/*
			if theFrame.mySDF = null then // back frame
				// If it is on the SDF's drawing frame then do not draw it on the back frame
				if _sdfDrawingFrame &lt;&gt; null then
					if _sdfDrawingFrame.allPointGraphics.includes(deckItemLayout) then
						continue;
					endif;
				endif;
			endif;
			if not deckItemLayout.isVisible then
				continue;
			endif;
			
			// Only show location defns, no colour coding. 
			//A GC Load CC has a GC Defn as well so use this but get the colour from the CC
			if deckItemLayout.myDeckItem = null then
				continue;
			endif;
			
			if not deckItemLayout.getProposedVisiblity(aColour) then // because of the statement above the request getProposedVisiblity method will not be called
				continue;
			endif;
			isMTLocn := (aColour = White);
	
			if self.modeViewSub = ShpDisplayModeSub_Colour then
				if not isMTLocn then
					theFrame.doPointArrayAdd(deckItemLayout.drawLineColour,true, Frame.DrawFillStyle_Transparent, 1, aColour, deckItemLayout);
				else
					theFrame.doPointArrayAdd(deckItemLayout.drawLineColour,true, Frame.DrawFillStyle_Solid, 1, aColour, deckItemLayout); 
				endif;
			else
				theFrame.doPointArrayAdd(deckItemLayout.drawLineColour,true, Frame.DrawFillStyle_Solid, 1, aColour, deckItemLayout);
			endif;
			*/
		endforeach;
		self.getAllPolygonsProposed(theFrame,_layer,White);
	endif;
	
epilog
	delete allTIs;
end;</source>
        <Parameter name="_frame" type="CMUI_PointDrawingFrame"/>
        <Parameter name="_layer" type="CM_DeckLayerLayout"/>
        <Parameter name="_graphicToIgnore" type="CM_DeckItemLayout"/>
        <Parameter name="_sdfDrawingFrame" type="CMUI_PointDrawingFrame"/>
    </JadeMethod>
    <JadeMethod name="doDrawObject" id="a8a8e2fe-92ac-440e-a40a-7514bcfee2a9">
        <updating/>
        <source>doDrawObject(_lc : CM_LocationsController) updating;
/*
Purpose:			
Date		Who		Reason
23 September 2011	cnwab1	Initial creation
*/

vars
	deckItemLayout : CM_DeckItemLayout;
	theFrame : CMUI_PointDrawingFrame;
	layer : CM_DeckLayerLayout;
	defn : CM_DeckItem;
	roroLC : CM_VoyageROROController;
	roroReq : CM_RORORequest;
begin

//	if _lc.isLanePosController() then
//		defn := _lc.CM_ROROLanePositionController.myLanePositionDefn;
//	else
		defn := _lc.getDefn();
//	endif;
	if defn = null then
		return;
	endif;
	roroLC := _lc.CM_VoyageROROController;
	
	if defn.myDeck &lt;&gt; self.myPlanningForm.myCurrentDeck then
		return;
	endif;
	
	deckItemLayout := defn.myLayout;
	if deckItemLayout = null then
		return;
	endif;
	
	// PAR 28481
//	layer := deckItemLayout.myDeckLayer;
//	theFrame := self.myPlanningForm.getFrameForLayer(layer, self.allBackFrames);
//	if theFrame = null then
//		return;
//	endif;
	
	self.myPlanningForm.doClearTopDrawingFrame(true);  // PAR 31077
	
	if self.modeView = ShpDisplayMode_Actual then
		if roroLC.isContainerLC() then
			layer := roroLC.myDeck.myDeckLayout.getCargoLayer();
		elseif roroLC.isROROVoyageLanePos() then
			layer := roroLC.myDeck.myDeckLayout.getLaneLayer();
		else
			layer := roroLC.myDeck.myDeckLayout.getGCLayer();
		endif;
		theFrame := self.myPlanningForm.getFrameForLayer(layer, self.allBackFrames);
		// PAR 28481
		if theFrame = null then
			// This happens for the first item on a layer. The layer has just been created so it does not have a frame to draw it
			self.myPlanningForm.doCloneBackFrame(layer, self.myPlanningForm.shtDeck, self.myPlanningForm.scaleFactor, self.allBackFrames, true);
			self.myPlanningForm.doDrawLayers();
			self.myPlanningForm.doResize(); // PAR 28927
		else
			self.drawNoteACTUAL(roroLC.getDefn(), theFrame,REAL_MODE);
		endif;
	elseif self.modeView = ShpDisplayMode_Proposed then
			layer := roroLC.myDeck.myDeckLayout.getCargoLayer();
			theFrame := self.myPlanningForm.getFrameForLayer(layer, self.allBackFrames);
			self.drawNoteACTUAL(roroLC.getDefn(), theFrame, PLANNING_MODE);
	elseif self.modeView = ShpDisplayMode_ColCodeLoad then
		// PAR 28544 - try 40 first
		roroReq := defn.getFirst40Request(true);
		if roroReq = null then
			roroReq := defn.hasColourCoding(LOAD_MOVETYPE);
		endif;
		if roroReq &lt;&gt; null then

			deckItemLayout := roroReq.myLayout;
			layer := deckItemLayout.myDeckLayer;

			theFrame := self.myPlanningForm.getFrameForLayer(layer, self.allBackFrames);
			// PAR 28481
			if theFrame = null then
				// This happens for the first item on a layer. The layer has just been created so it does not have a frame to draw it
				self.myPlanningForm.doCloneBackFrame(layer, self.myPlanningForm.shtDeck, self.myPlanningForm.scaleFactor, self.allBackFrames, true);
				self.myPlanningForm.doDrawLayers();
				self.myPlanningForm.doResize(); // PAR 28927
			else
// PAR 28481			if theFrame &lt;&gt; null then // PAR 28319
				self.drawNoteCOLOURCODING(deckItemLayout.CM_RORORequestLayout, theFrame,true);
			endif;
		else
		
			// PAR 28409 do not draw Discharge GC in Load CC mode. This was being drawn during load planning and load Link and delink of DLRs
			if roroLC.isKindOf(CM_ROROGCController) then
				roroReq := defn.hasColourCoding(DISCHARGE_MOVETYPE);
				if roroReq &lt;&gt; null then
					return;
				endif;
			endif;
			
			
			// PAR 31053 - if ALL the load CC for a standard location is erased, we need to draw an actual view on the load CC layer. This is the only way to 'erase' the load CC layout.
//	PAR 31053		if defn.isLocnContainer() and not defn.isOOTL() then // PAR 29132 - Erase of load CC for a define contaienr position shoudl use teh cargo layer to draw container positions
//	PAR 31053			layer := roroLC.myDeck.myDeckLayout.getCargoLayer();
//	PAR 31053		else // GC and OOTL should draw the cargo layout on the LOAD CC layer. This changes once the GC or OOTL  export has been moved to the deck, then the cargo layout are on the cargo layer.
				layer := roroLC.myDeck.myDeckLayout.getCCLoadLayer();
	// PAR 31053		endif;

			theFrame := self.myPlanningForm.getFrameForLayer(layer, self.allBackFrames);
			// PAR 28481
			if theFrame = null then
				// This happens for the first item on a layer. The layer has just been created so it does not have a frame to draw it
				self.myPlanningForm.doCloneBackFrame(layer, self.myPlanningForm.shtDeck, self.myPlanningForm.scaleFactor, self.allBackFrames, true);
				self.myPlanningForm.doDrawLayers();
				self.myPlanningForm.doResize(); // PAR 28927
			else
			
	
// PAR 28481			if theFrame &lt;&gt; null then // PAR 28319
				self.drawNoteACTUAL(roroLC.getDefn(), theFrame, REAL_MODE);
			endif;
			
		endif;
	elseif self.modeView = ShpDisplayMode_ColCodeDisch then
		// PAR 28544 - try 40 first
		roroReq := defn.getFirst40Request(false);
		if roroReq = null then
			roroReq := defn.hasColourCoding(DISCHARGE_MOVETYPE);
		endif;
		if roroReq &lt;&gt; null then
			deckItemLayout := roroReq.myLayout;
			layer := deckItemLayout.myDeckLayer;
			theFrame := self.myPlanningForm.getFrameForLayer(layer, self.allBackFrames);
			
			if theFrame = null then // PAR 29054
				// This happens for the first item on a layer. The layer has just been created so it does not have a frame to draw it
				self.myPlanningForm.doCloneBackFrame(layer, self.myPlanningForm.shtDeck, self.myPlanningForm.scaleFactor, self.allBackFrames, true); // PAR 29054
				self.myPlanningForm.doDrawLayers();
				self.myPlanningForm.doResize(); // PAR 28927
			else
			// PAR 29054 if theFrame &lt;&gt; null then // PAR 28319
				self.drawNoteCOLOURCODING(deckItemLayout.CM_RORORequestLayout, theFrame,false);
			endif;
		else
			// PAR 28409 do not draw Load GC in Load CC mode. This was being drawn during load planning plus Link and delink of DLRs
			if roroLC.isKindOf(CM_ROROGCController) then
				roroReq := defn.hasColourCoding(LOAD_MOVETYPE);
				if roroReq &lt;&gt; null then
					return;
				endif;
			endif;

			if roroLC.isContainerLC() then
				layer := roroLC.myDeck.myDeckLayout.getCargoLayer();
			else
				layer := roroLC.myDeck.myDeckLayout.getGCLayer();
			endif;
			theFrame := self.myPlanningForm.getFrameForLayer(layer, self.allBackFrames);
			if theFrame &lt;&gt; null then // PAR 28319
				self.drawNoteACTUAL(roroLC.getDefn(), theFrame, REAL_MODE);
			endif;
			
			// PAR 31937 - redraw locations on the discharge layer, if we are erasing discharge CC then need to redraw the location again.
			if roroLC.isContainerLC() then
				layer := roroLC.myDeck.myDeckLayout.getCCDischargeLayer();
				theFrame := self.myPlanningForm.getFrameForLayer(layer, self.allBackFrames);
				if theFrame &lt;&gt; null then 
					self.drawNoteACTUAL(roroLC.getDefn(), theFrame, REAL_MODE);
				endif;
			endif;
			
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_lc" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="doDrawObjectACTUAL" id="db71b2a0-0d7a-4faa-a64e-e89031318f17">
        <updating/>
        <source>doDrawObjectACTUAL(_deckItemLayout : CM_DeckItemLayout;_frame : CMUI_PointDrawingFrame;_layer : CM_DeckLayerLayout; _sdfDrawingFrame : CMUI_PointDrawingFrame) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     June 2011 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// CCMS 1035 MES RORO
// ---------------------------------------------------------------------------

vars

	theFrame : CMUI_PointDrawingFrame;
	allTIs : CM_TIArray;
	aColour : Integer;
	aTI : CM_TrackedItem;
	isMTLocn : Boolean;
	//PAR 29979 - cnwmc5
	coveringObj : CM_DeckItemLayout;
begin
	create allTIs transient;
	self.myPointDrawingFrame := _frame;
	theFrame := _frame; 

	// ### DRAW ACTUAL CARGO
	if _layer.isActualCargoLayer() then
			if theFrame.mySDF = null then // back frame
				// If it is on the SDF's drawing frame then do not draw it on the back frame
				if not _deckItemLayout.isLaneDefnVoyageLayout() then
				if _sdfDrawingFrame &lt;&gt; null then
					if _sdfDrawingFrame.allPointGraphics.includes(_deckItemLayout) then
			
					
					
					return false;
					endif;
				endif;
				endif;
			endif;
			if not _deckItemLayout.isVisible then
				return false;
			endif;
			if _deckItemLayout.myDeckItem = null then
				return false;
			endif;
			
			
			_deckItemLayout.myDeckItem.getAllTIs(REAL_MODE,allTIs,true);
			isMTLocn := allTIs.isEmpty();
			
			if not isMTLocn then
				aTI := allTIs[1];
				
				if aTI &lt;&gt; null then
					aColour := aTI.getDrawingColour(TI_ColourMode_DischargePort);
				endif;
			else
			
				aColour := White;
			endif;
			
			// PAR 29979 - cnwmc5
			if self.modeView = ShpDisplayMode_Actual then
				if _deckItemLayout.isCoveredByOOTL(DeckItemLayoutType_Locn) then
				// PAR 32374 	coveringObj := _deckItemLayout.allCoveringPolygons[DeckItemLayoutType_Locn];
				// PAR 32374 	if not coveringObj.myDeckLayer.type = ROROLayerType_CCLoad then // PAR 32374
					
				// PAR 32374 use new method isCoveredByOnLayer		
					if not _deckItemLayout.isCoveredByOnLayer(DeckItemLayoutType_Locn,ROROLayerType_CCLoad, true) then // PAR 33114 - added the 'not'
						return false;
					endif;
				endif;
			endif;
			
			if self.modeViewSub = ShpDisplayModeSub_Colour then
				if _deckItemLayout.myDeckItem.isLocnGC or _deckItemLayout.myDeckItem.isLocnLanePosition then
						theFrame.doPointArrayAdd(_deckItemLayout.drawLineColour,true, Frame.DrawFillStyle_Solid, 1, aColour, _deckItemLayout); 
				else
					if not isMTLocn then
						theFrame.doPointArrayAdd(_deckItemLayout.drawLineColour,true, Frame.DrawFillStyle_Solid, 1, White, _deckItemLayout); // PAR 29031
					else
						theFrame.doPointArrayAdd(_deckItemLayout.drawLineColour,true, Frame.DrawFillStyle_Solid, 1, aColour, _deckItemLayout); 
					endif;
				endif;
			else
				theFrame.doPointArrayAdd(_deckItemLayout.drawLineColour,true, Frame.DrawFillStyle_Solid, 1, aColour, _deckItemLayout);
			endif;
	endif;
	
epilog
	delete allTIs;
end;</source>
        <Parameter name="_deckItemLayout" type="CM_DeckItemLayout"/>
        <Parameter name="_frame" type="CMUI_PointDrawingFrame"/>
        <Parameter name="_layer" type="CM_DeckLayerLayout"/>
        <Parameter name="_sdfDrawingFrame" type="CMUI_PointDrawingFrame"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDrawObjectCCDISCHARGE" id="47db4e80-95f3-49fc-b04e-59d891e52269">
        <updating/>
        <source>doDrawObjectCCDISCHARGE(_deckItemLayout : CM_DeckItemLayout;_frame : CMUI_PointDrawingFrame;_layer : CM_DeckLayerLayout; _allLocnDefn : ObjectSet input;
	_sdfDrawingFrame : CMUI_PointDrawingFrame) : Boolean updating;
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
*/


vars
	theFrame : CMUI_PointDrawingFrame;
	allTIs : CM_TIArray;
	aReq : CM_RORORequest;

	tmpLocnDefn : CM_ROROLocnDefn;
	tmpDeckItem : CM_DeckItem;
begin
	self.myPointDrawingFrame := _frame;
	theFrame := _frame; 

	if _layer.type &lt;&gt; ROROLayerType_CCDischarge then
		return false;
	endif;

	// ### DRAW DISCHARGE COLOUR CODING

	if theFrame.mySDF = null then // back frame
		// If it is on the SDF's drawing frame then do not draw it on the back frame
		if _sdfDrawingFrame &lt;&gt; null then
			if _sdfDrawingFrame.allPointGraphics.includes(_deckItemLayout) then
				return false;
			endif;
		endif;
	endif;
	if not _deckItemLayout.isVisible then
		return false;
	endif;
	
	// Complicated to show and hide container location discharge colour coding, so if showing exports we will not show container discharge CC, just GC discharge CC
	if self.modeViewSubSub = ShpDisplayModeSub_ExportsShow then // PAR 31439
		if not _deckItemLayout.CM_RORORequestLayout.myRequest.isReqGC() then
			return false;
		endif;
	endif;
	
	// Slot request have their own layout, however we are drawing  top down view so we only need to draw 1 of them.
	// If a location can stack 4 containers there may be 4 req layouts all with the same x/ys
	// ALso if we have a 40 foot request in the stack only pass through that to draw
	tmpLocnDefn := null;
	tmpDeckItem := _deckItemLayout.CM_RORORequestLayout.myRequest.myROROController.getDefn();
	
	if tmpDeckItem.isKindOf(CM_ROROLocnDefn) then
		tmpLocnDefn := tmpDeckItem.CM_ROROLocnDefn;
		if tmpLocnDefn &lt;&gt; null then
			if _allLocnDefn &lt;&gt; null and _allLocnDefn.includes(tmpLocnDefn) then
				return false; // already looked at a request for this location
			endif;
			
			//cnwmc5 - par 30020 - was turning a 40' slot into a 20' when trying to select it.
			// PAR 30111 reversing out Michell's  'fix'
			aReq := tmpLocnDefn.getFirst40Request(false);
			if aReq &lt;&gt; null then // We have a40 req in this location so use that
				if  aReq.isBackEndRequest() then
					//cnwmc5 - 14 Oct 2014 - PAR 33972
					if not tmpDeckItem.hasDischargeCCIsRotatedLoad() then
						return false;
					endif;
				endif;
				theFrame.doAddToArraysForProxy(aReq.myLayout);
				if _allLocnDefn &lt;&gt; null then
					_allLocnDefn.add(tmpLocnDefn);
				endif;
				return false;
			endif;
			
		endif;			
		
	endif;
	

	theFrame.doAddToArraysForProxy(_deckItemLayout);
	if tmpLocnDefn &lt;&gt; null then
		if _allLocnDefn &lt;&gt; null then
			_allLocnDefn.add(tmpLocnDefn);
		endif;
	endif;

	return true;
	
epilog
	delete allTIs;

end;</source>
        <Parameter name="_deckItemLayout" type="CM_DeckItemLayout"/>
        <Parameter name="_frame" type="CMUI_PointDrawingFrame"/>
        <Parameter name="_layer" type="CM_DeckLayerLayout"/>
        <Parameter name="_allLocnDefn" type="ObjectSet" usage="input"/>
        <Parameter name="_sdfDrawingFrame" type="CMUI_PointDrawingFrame"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDrawObjectCCLOAD" id="ce9b9c83-b382-48c2-b256-8e8c8bb82fa5">
        <updating/>
        <source>doDrawObjectCCLOAD(_deckItemLayout : CM_DeckItemLayout;_frame : CMUI_PointDrawingFrame; _layer : CM_DeckLayerLayout; _allLocnDefn : ObjectSet input; _sdfDrawingFrame : CMUI_PointDrawingFrame) : Boolean updating;
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
20/04/2016          cnwma1      PAR #37720 impossible to Print Deck Details of Upper Deck
*/


vars
	aTI :CM_TrackedItem;
	theRORODefn : CM_ROROVesselStructure;
	aGraphic : CM_Graphic;
	theFrame : CMUI_PointDrawingFrame;
	graphArray : CM_GraphicArray;
	theDeck : CM_DeckLayout;
	pxyLayout : CM_DeckItemLayout;
	allTIs : CM_TIArray;
	shouldHaveCC, invalid : Boolean;
	aColour, fillStyle : Integer;
	aWLE : CM_WorkListEntry;
	aReq : CM_RORORequest;
	anLC : CM_VoyageROROController;
	tmpLocnDefn : CM_ROROLocnDefn;
	tmpDeckItem : CM_DeckItem;
begin
	if _layer.type &lt;&gt; ROROLayerType_CCLoad then
		return false;
	endif;
	
	self.myPointDrawingFrame := _frame;
	theFrame := _frame; 



	// ### DRAW COLOUR CODING
	if theFrame.mySDF = null then // back frame
		// If it is on the SDF's drawing frame then do not draw it on the back frame
		if _sdfDrawingFrame &lt;&gt; null then
			if _sdfDrawingFrame.allPointGraphics.includes(_deckItemLayout) then
				return false;
			endif;
		endif;
	endif;
	if not _deckItemLayout.isVisible then
		return false;
	endif;
	
	// Slot request have their own layout, however we are drawing  top down view so we only need to draw 1 of them.
	// If a location can stack 4 containers there may be 4 req layouts all with the same x/ys
	// ALso if we have a 40 foot request in the stack only pass through that to draw
	
	
	tmpLocnDefn := null;
	if _deckItemLayout.isKindOf(CM_RORORequestLayout) then
		// PAR 32538 WAS tmpDeckItem := _deckItemLayout.CM_RORORequestLayout.myRequest.myROROController.getDefn();
		
		aReq := _deckItemLayout.CM_RORORequestLayout.myRequest; // PAR 32538
		anLC := aReq.myROROController; // PAR 32538
		
		if anLC = null then             // 24/04/2016 cnwma1 PAR #37720
			return false;
		endif;
		
		on Exception do app.handleDeletedObject(exception, anLC, invalid); // PAR 32538
		tmpDeckItem := anLC.getDefn();
		if invalid then // PAR 32538
			return false; // PAR 32538
		endif;
		
	else
		tmpDeckItem := _deckItemLayout.myDeckItem;
	endif;


	if tmpDeckItem.isKindOf(CM_ROROLocnDefn) then
		tmpLocnDefn := tmpDeckItem.CM_ROROLocnDefn;
		if tmpLocnDefn &lt;&gt; null then
			if _allLocnDefn &lt;&gt; null then
				if _allLocnDefn.includes(tmpLocnDefn) then
					return false; // already llooked at a request for this location
				endif;
			endif;

				
			aReq := tmpLocnDefn.getFirst40Request(true);
			if aReq &lt;&gt; null then // We have a40 req in this location so use that
				if  aReq.isBackEndRequest() then
					// PAR 28883
					if not tmpLocnDefn.isOOTL() then
						return false;
					endif;
				endif;
				theFrame.doAddToArraysForProxy(aReq.myLayout);
				
				_allLocnDefn.add(tmpLocnDefn);  // PAR 28990

				return false;
			endif;
		endif;			
		
	endif;
	
	

	theFrame.doAddToArraysForProxy(_deckItemLayout);
	

	if tmpLocnDefn &lt;&gt; null then


		if _allLocnDefn &lt;&gt; null then
			_allLocnDefn.add(tmpLocnDefn);
		endif;
	endif;
	
	return true;
	
epilog

	delete allTIs;
end;</source>
        <Parameter name="_deckItemLayout" type="CM_DeckItemLayout"/>
        <Parameter name="_frame" type="CMUI_PointDrawingFrame"/>
        <Parameter name="_layer" type="CM_DeckLayerLayout"/>
        <Parameter name="_allLocnDefn" type="ObjectSet" usage="input"/>
        <Parameter name="_sdfDrawingFrame" type="CMUI_PointDrawingFrame"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDrawObjectEQUIPMENT" id="d7f6ed7a-3b9e-4967-9ddc-26932406a84b">
        <source>doDrawObjectEQUIPMENT(_layer : CM_DeckLayerLayout; _frame : CMUI_PointDrawingFrame input);
/*
Purpose:			
Date		Who		Reason
07 March 2012	cnwab1	Initial creation
*/

vars
	scale : Decimal[12,2];
	x1, y1 : Integer;
	deckItemLayout : CM_DeckItemLayout;

begin
	_frame.setDefaultFont(_frame); // 29923

	scale := self.scaleFactor;
	if scale &lt;= 0 then
		scale := 1;
	endif;

	foreach deckItemLayout in _layer.allDeckItemLayouts reversed do 
			
		if not deckItemLayout.isVisible then
			continue;
		endif;
		if deckItemLayout.myDeckItem = null then
			continue;
		endif;
		
		if deckItemLayout.myDeckItem.isMachinery() or deckItemLayout.myDeckItem.isGeneralItem() then
			// PAR 30092 add scale
			x1 := (deckItemLayout.myPolygonPixels[1].x * scale).Integer;
			y1 := (deckItemLayout.myPolygonPixels[1].y * scale).Integer;				
			
			if deckItemLayout.myDeckItem.isMachinery() then
				_frame.drawTextAt(app.getErrorString(DeckItem_Machinery), x1 + 5, y1 + 5, deckItemLayout.drawFillColour.getInverseColour());
			else
				_frame.drawTextAt(app.getErrorString(DeckItem_General_Items), x1 + 5, y1 + 5, deckItemLayout.drawFillColour.getInverseColour());
			endif;
			_frame.drawTextAt(app.getErrorString(WeightCaption) &amp; " " &amp; (deckItemLayout.myDeckItem.getWeight() / 1000).asStringWeightJMT() &amp; "t", x1 + 5, y1 + 18, deckItemLayout.drawFillColour.getInverseColour());
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_layer" type="CM_DeckLayerLayout"/>
        <Parameter name="_frame" type="CMUI_PointDrawingFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doDrawObjectPROPOSED" id="68080210-ccf1-4bda-850c-fb56920dbb14">
        <updating/>
        <source>doDrawObjectPROPOSED(_deckItemLayout : CM_DeckItemLayout;_frame : CMUI_PointDrawingFrame;_layer : CM_DeckLayerLayout; _sdfDrawingFrame : CMUI_PointDrawingFrame) : Boolean updating;
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
*/


vars

	theFrame : CMUI_PointDrawingFrame;
	allTIs : CM_TIArray;
	aColour : Integer;
	isMTLocn : Boolean;
	laneDefn : CM_ROROLaneDefnVoyage;
	lanePos : CM_ROROLanePositionDefn;
	lanePosLC : CM_ROROLanePositionController;
	coveredBy : CM_DeckItemLayout;
begin
	create allTIs transient;
	self.myPointDrawingFrame := _frame;
	theFrame := _frame; 
	
	
	// ### DRAW ACTUAL CARGO
	if _layer.isActualCargoLayer() 
	or _layer.type = ROROLayerType_CCLoad then
			if theFrame.mySDF = null then // back frame
				// If it is on the SDF's drawing frame then do not draw it on the back frame
				if _sdfDrawingFrame &lt;&gt; null then
					if _sdfDrawingFrame.allPointGraphics.includes(_deckItemLayout) then
						return false;
					endif;
				endif;
			endif;
			if not _deckItemLayout.isVisible then
				return false;
			endif;
			
			if _deckItemLayout.myDeckItem &lt;&gt; null and _deckItemLayout.myDeckItem.isPlannedRotatedMethod() then // PAR 31438 
				// PAR 32374 if _deckItemLayout.isCovered(DeckItemLayoutType_Locn,true)  then	// PAR 31438
				// PAR 32374 	coveredBy := _deckItemLayout.getCoveredBy(DeckItemLayoutType_Locn,false);	// PAR 31438
				// PAR 32374 	if coveredBy.myDeckLayer.type = ROROLayerType_CCLoad  then	// PAR 31438
				// PAR 32374 use new method isCoveredByOnLayer		
					if _deckItemLayout.isCoveredByOnLayer(DeckItemLayoutType_Locn,ROROLayerType_CCLoad, true) then
						return false;
					endif;
				// endif;
			endif;
			
			if _deckItemLayout.isCovered(DeckItemLayoutType_Locn,false) then // PAR 28990 hide any cargo positions that are under the rotated cloned load locn defn
				// PAR 30225 if _deckItemLayout.getCoveredByOOTL(DeckItemLayoutType_Locn).isOnLayerLoad() then
				coveredBy := _deckItemLayout.getCoveredByOOTL(DeckItemLayoutType_Locn);
				if coveredBy &lt;&gt; null and coveredBy.isOnLayerLoad() then
					return false;
				else
					// PAR 29979
					coveredBy := _deckItemLayout.getCoveredBy(DeckItemLayoutType_Locn,false);
					/* WAS PAR 32186
					if coveredBy &lt;&gt; null 
					and not _deckItemLayout.isPlannedRotated()		//cnwmc5 - PAR 31172
					and coveredBy.hasNoCC(false) then
						return false;
					endif;
					NOW PAR 32186 */
				// PAR 33114	if not deckItemLayout.hasNoCC(false) then // has discharge CC so is ROB
					if 	coveredBy &lt;&gt; null and not coveredBy.myDeckItem.hasTIsAllColourCoded(REAL_MODE, false,false) then // PAR 33114	
						if not coveredBy.isOnLayerLoad() then
							return false;
						elseif coveredBy.isOnLayerLoad() then
							if not _deckItemLayout.isPlannedRotated() then
								return false;
							endif;
						endif;
					endif;
				endif;
			endif;
			
			// PAR 32374 if _deckItemLayout.isCoveredByDefnWithCCCompleted(DeckItemLayoutType_GCLoad, true)  // PAR 31166
			if _deckItemLayout.isCoveredByOnLayer(DeckItemLayoutType_GCLoad, ROROLayerType_GC, true) then // PAR 32374
//			or deckItemLayout.isCoveredByDefnWithCCCompleted(DeckItemLayoutType_GCLoad, true) then // PAR 29807
				if not _deckItemLayout.isPillar() then
					return false;
				endif;
			endif;
			
			
			// PAR 29979
			if _deckItemLayout.isCovered(DeckItemLayoutType_GCDischarge,false) then // PAR 28990 hide any cargo positions that are under the rotated cloned load locn defn
				coveredBy := _deckItemLayout.getCoveredBy(DeckItemLayoutType_GCDischarge,false);
				if coveredBy.hasNoCC(false) then // is a RoB
					return false;
				endif;
			endif;

			if _deckItemLayout.isCovered(DeckItemLayoutType_CCLoad,false) then 
				coveredBy := _deckItemLayout.getCoveredBy(DeckItemLayoutType_CCLoad,false);
				if  coveredBy.getProposedVisiblity(aColour) then 
					return false;
				endif;
				
			endif;
			
			// Only show location defns, no colour coding. 
			//A GC Load CC has a GC Defn as well so use this but get the colour from the CC
			if _deckItemLayout.myDeckItem = null then
				return false;
			endif;

			
			if not _deckItemLayout.getProposedVisiblity(aColour) then // because of the statement above the request getProposedVisiblity method will not be called
				return false;
			endif;
			isMTLocn := (aColour = White);
//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1. ' &amp; _deckItemLayout.code &amp; " " &amp; aColour.String);			
	
			if _deckItemLayout.myDeckItem.isKindOf(CM_ROROLaneDefnVoyage) then
				laneDefn := _deckItemLayout.myDeckItem.CM_ROROLaneDefnVoyage;
				theFrame.doPointArrayAdd(_deckItemLayout.drawLineColour,true, Frame.DrawFillStyle_Solid, 1, aColour, _deckItemLayout);
				
				foreach lanePosLC in laneDefn.myLaneController.allLanePositionsLCs discreteLock do
					lanePos := lanePosLC.myLanePositionDefn;
					if lanePos &lt;&gt; null then
//					app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1. ' &amp; lanePos.code);
						self.doDrawObjectPROPOSED(lanePos.myLayout, theFrame, _layer, _sdfDrawingFrame);
					
					endif;
				endforeach;
			else
				if _deckItemLayout.myDeckItem.isLocnLanePosition() 
				or _deckItemLayout.myDeckItem.isLocnGC() then
					theFrame.doPointArrayAdd(_deckItemLayout.drawLineColour,true, Frame.DrawFillStyle_Solid, 1, aColour, _deckItemLayout);
				else
					if self.modeViewSub = ShpDisplayModeSub_Colour then
						if not isMTLocn then
							theFrame.doPointArrayAdd(_deckItemLayout.drawLineColour,true, Frame.DrawFillStyle_Solid, 1, White, _deckItemLayout); // PAR 30924
						else
							theFrame.doPointArrayAdd(_deckItemLayout.drawLineColour,true, Frame.DrawFillStyle_Solid, 1, aColour, _deckItemLayout); 
						endif;
					else
						theFrame.doPointArrayAdd(_deckItemLayout.drawLineColour,true, Frame.DrawFillStyle_Solid, 1, aColour, _deckItemLayout);
					endif;
				endif;
			endif;
	endif;
	
epilog
	delete allTIs;
end;</source>
        <Parameter name="_deckItemLayout" type="CM_DeckItemLayout"/>
        <Parameter name="_frame" type="CMUI_PointDrawingFrame"/>
        <Parameter name="_layer" type="CM_DeckLayerLayout"/>
        <Parameter name="_sdfDrawingFrame" type="CMUI_PointDrawingFrame"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawAPolygonAfter" id="7ace36e7-878c-4c47-9d9c-46f0fd77abb4">
        <updating/>
        <source>drawAPolygonAfter(_item : CM_DeckItemLayout; _allTIs : ObjectArray input; _numTier : Integer; _tmpPoints : PointArray; _has40s : Boolean) updating;
/*
Purpose:			
Date		Who		Reason
21 June 2011	cnwab1	Initial creation
*/
//18 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
vars
	defn : CM_DeckItem;
begin
		
	if not _item.isKindOf(CM_RORORequestLayout) then
		if _item.myDeckItem &lt;&gt; null then
		
			// ### CONTAINERS
			if _item.myDeckItem.isLocnContainer() then
				if not _allTIs.isEmpty() then
				
					// PAR 29694
					if self.modeView = ShpDisplayMode_ColCodeLoad then
						if _item.myDeckItem.hasROB(false) then
							if self.modeViewSub = ShpDisplayModeSub_Colour then
								self.drawSortTIs(_allTIs, _has40s, not _item.isRotated());
								self.drawTIsInRectangle(_item, _allTIs, _numTier,_tmpPoints, _has40s);
							else
								self.drawTIDetailsInRectangle(_item, _tmpPoints, _allTIs, _numTier, _tmpPoints);
							endif;
						endif;
					else
						if self.modeViewSub = ShpDisplayModeSub_Colour then
							self.drawSortTIs(_allTIs, _has40s, not _item.isRotated()); // PAR 28991
							self.drawTIsInRectangle(_item, _allTIs, _numTier,_tmpPoints, _has40s);
						else
							self.drawTIDetailsInRectangle(_item, _tmpPoints, _allTIs, _numTier, _tmpPoints);
						endif;
					endif;
				else // CCMS 1009 28479
					self.drawMTLocation(_item, _allTIs, _numTier,_tmpPoints, _has40s);
				endif;
			// ### GENERAL CARGO
			elseif _item.myDeckItem.isLocnGC() then
	
				self.drawTIDetailsInPolygon(_item, _allTIs, _numTier);
			// ### LANES
			elseif _item.myDeckItem.isLocnLane() then 
				self.drawTIDetailsInPolygon(_item, _allTIs, _numTier);
			endif;
		endif;
	// Colour Coding
	elseif _item.isKindOf(CM_RORORequestLayout) then
		defn := _item.CM_RORORequestLayout.myRequest.myROROController.getDefn();
		if defn.isLocnContainer()  then
			self.drawReqInRectangle(defn, _numTier, (self.modeView = ShpDisplayMode_ColCodeLoad), _has40s, _tmpPoints);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_item" type="CM_DeckItemLayout"/>
        <Parameter name="_allTIs" type="ObjectArray" usage="input"/>
        <Parameter name="_numTier" type="Integer"/>
        <Parameter name="_tmpPoints" type="PointArray"/>
        <Parameter name="_has40s" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawAttribute" id="4483cf22-01a5-4f35-93a8-46badf3e824d">
        <source>drawAttribute(_ti : CM_TrackedItem; _req : CM_RORORequest; _frame: CMUI_Frame input;_x1,_y1 :Real; _theAttColour: Integer; _theAttribute: String; _theAttributePosition: Integer io) protected;
// ---------------------------------------------------------------------------
// Created:     02 September 2004 by cnwrs2
//
// Purpose:   
// 04 May 2016 	cnwma1 PAR #37836 TFS#1945  MSL HAZD Symbol over Planned containers     
// 11/10/2022	navkc1	Bug 54935: MSL - Roro planning - Slow on big decks/large vessels
// ---------------------------------------------------------------------------
vars
	theDrawingAttribute : CM_DrawingAttribute;
	tmpX, tmpY: Real;
	theColour : Integer;
	theCharacter : Character;
	theFrame: CMUI_Frame;
	hazClass : CM_HazardClass;
	specialStow : CM_SpecialStow;
begin
	theFrame := _frame;

	theDrawingAttribute := self.allDrawingAttributes[_theAttribute];

	//#####  // PAR 37527
	if _theAttribute = PicTIHazard then							
		hazClass := self.getHazardClass(_ti, _req);
		if hazClass &lt;&gt; null then								
			theDrawingAttribute := hazClass.myDrawingAttribute;	
		endif;
		if theDrawingAttribute = null then													// 04/05/2016 cnwma1 PAR #37836  TFS #1945 
			theDrawingAttribute := self.allDrawingAttributes[_theAttribute];
		endif;
		
			
	elseif _theAttribute = PicSpecialStow then						
		specialStow := self.getSpecialStow(_ti, _req);						
		if specialStow &lt;&gt; null then									
			theDrawingAttribute := specialStow.myDrawingAttribute;	
		endif;
		if theDrawingAttribute = null then
			theDrawingAttribute := self.allDrawingAttributes[_theAttribute];  // 11/10/2022	navkc1	#54935
		endif;
	endif;
	// ####;
	
	
	if theDrawingAttribute = null then
		return;
	endif;

	theFrame.drawFontName := theDrawingAttribute.fontName;
	
	// #######################
	// DRAW THE CHARACTER
	
	theFrame.drawTextAlign := Frame.DrawTextAlign_Left;
	theCharacter := theDrawingAttribute.fontCharacter.Character;
	
	if _theAttColour &lt; 0 then
		theColour := theDrawingAttribute.colour;
	else	
		theColour := _theAttColour;
	endif;

	theFrame.drawTextAt(theCharacter,_x1+ tmpX,_y1 + tmpY, theColour);
	
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_req" type="CM_RORORequest"/>
        <Parameter name="_frame" type="CMUI_Frame" usage="input"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_theAttColour" type="Integer"/>
        <Parameter name="_theAttribute" type="String"/>
        <Parameter name="_theAttributePosition" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="drawContainersForSequenceSheet" id="152423a9-04fa-4ce7-b05b-f6e41496d421">
        <source>drawContainersForSequenceSheet(	_deckItemLayout : CM_DeckItemLayout; 
							_rect : PointArray;
							_tis : ObjectArray ;
							_job : CM_VoyageDeckJob) protected;
/*

Date		Who		Reason
25/07/2013	cnwer1	Initial creation CCMS 2265 par 32142
11/11/2019	jlgdap1	TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
*/
constants
	NarrowFont = "Simplified Arabic";
	SampleText =  "01 ABCD1234567 JPABA 25.5 E";
	MinFontSize = 5.5;
vars
	x1, y1, x2, y2   : Integer;
	aTI : CM_TrackedItem;
	aColour : Integer;
	obj : Object;
	text : String;
	myDrawingFrame : CMUI_PointDrawingFrame;
	isVertical, onlySeqNum, onlyIDs : Boolean;
	seqNum : String;
	yOffset,
	textX, textY,polyWidth, polyHeight,	pixelTIHeight : Real;
	wle : CM_WorkListEntry;
	txtLength  : Integer;
	oldFont		: String;
	tmpIcons	: StringArray;
	theAtt		: Integer;
	firstX : Real;	//18 Nov 2020	NDL	TFS 50311
begin

	if _tis = null then
		return;
	endif;
	
	if _tis.size = 0 then
		return;
	endif;
	myDrawingFrame := self.myPointDrawingFrame;
	
	if _deckItemLayout.myDeckItem.isKindOf(CM_ROROGCDefnVoyage) then
		return;
	endif;
	
	
	x1 := 9999999;
	y1 := 9999999;
	_rect.getExtremePoints(x1, y1, x2, y2);
	polyWidth := ((x2-x1) * self.scaleFactor) - 2 ;
	polyHeight :=  ((y2-y1)* self.scaleFactor) - 1 ;
	isVertical:= polyHeight &gt; polyWidth;
	
	textX :=(x1 * self.scaleFactor).Integer + 1 ; 
	textY :=(y1* self.scaleFactor);	 
	//8 is for the location id 
	if not isVertical then	
		polyHeight:=polyHeight - 9;
		
		pixelTIHeight:=polyHeight/_tis.size;
	else
		polyWidth:=polyWidth - 9;
		textX :=textX + 8;
		pixelTIHeight:=polyWidth/_tis.size;
	endif;
	if pixelTIHeight &gt; 10 then
		pixelTIHeight:=10;
	endif;
	myDrawingFrame.drawFontSize:=pixelTIHeight.max(3) -2;
	yOffset:=pixelTIHeight;
	

	myDrawingFrame.drawTextRotation := 0;
	myDrawingFrame.drawTextCharRotation := 0;
	oldFont:=myDrawingFrame.drawFontName;
	myDrawingFrame.drawFontName := NarrowFont;

	onlySeqNum := false;
	txtLength:=myDrawingFrame.drawTextWidth(SampleText).Integer;
		
	if myDrawingFrame.drawFontSize &lt; MinFontSize then
		onlySeqNum := true;
	endif;
	// VERTICAL
	if isVertical then
		myDrawingFrame.drawTextRotation := 270;
		myDrawingFrame.drawTextCharRotation := 270;
		if not onlySeqNum and txtLength &gt; polyHeight then
			myDrawingFrame.getTextDrawFontSizeForWidth(SampleText,polyHeight);
			if myDrawingFrame.drawFontSize &lt; MinFontSize then
				//myDrawingFrame.getTextDrawFontSizeForWidth('01 ABCD1234567',polyHeight);
				myDrawingFrame.getTextDrawFontSizeForWidthHgt( '01 ABCD1234567', polyHeight, (polyWidth / _tis.size) );	//18 Nov 2020	NDL	TFS 50311
				
				if myDrawingFrame.drawFontSize &gt;= MinFontSize then
					onlyIDs:=true;
				else
					onlySeqNum:=true;
				endif;
			endif;
		endif;		
	else
		if not onlySeqNum and txtLength &gt; polyWidth then
			myDrawingFrame.getTextDrawFontSizeForWidth(SampleText,polyWidth);
			if myDrawingFrame.drawFontSize &lt; MinFontSize then
			//	myDrawingFrame.getTextDrawFontSizeForWidth('01 ABCD1234567',polyWidth);
				myDrawingFrame.getTextDrawFontSizeForWidthHgt( '01 ABCD1234567', polyWidth, (polyHeight / _tis.size) );	//18 Nov 2020	NDL	TFS 50311
				
				if myDrawingFrame.drawFontSize &gt;= MinFontSize then
					onlyIDs:=true;
					textY:=textY + 8;
				else
					onlySeqNum:=true;
				endif;
			endif;
		endif;		
	endif;
	
	yOffset:=myDrawingFrame.drawFontSize + 2;
	if onlySeqNum then
		myDrawingFrame.drawFontSize:=7;	
		yOffset := myDrawingFrame.drawFontSize + 2; //18 Nov 2020	NDL	TFS 50311
		//epr par 33065 29/11/13
		if isVertical then
			textY:= textY  + 5;
			textX:= textX  + 4.2;
		else
			textX:= textX  + 2;
			firstX := textX;	//18 Nov 2020	NDL	TFS 50311
			textY := textY + yOffset; //18 Nov 2020	NDL	TFS 50311	//was textY:=textY + 4.2;	
		endif;
	else
		if isVertical then
			textY:=textY +1;
			textX :=textX + (pixelTIHeight/2);
		else
			textY :=(y2 * self.scaleFactor) - (yOffset) - (myDrawingFrame.drawFontSize-2); 
			textX:=textX + 1;
		endif;
	endif;

	create tmpIcons transient;
	
	foreach obj in _tis   do 
		tmpIcons.clear;
		aTI:=obj.CM_TrackedItem;
		seqNum:=null;
		wle:=_job.getWLEForTI(aTI);
		if wle &lt;&gt; null and wle.isKindOf(CM_VoyageWLE) then
			seqNum:=wle.CM_VoyageWLE.getSeqNum.asStringJMT;
		endif;
		
		if onlySeqNum then
			if seqNum = null then
				text := "X";
			else
				text:=seqNum;
			endif;
		
		else
			if seqNum = null then
				text := " ";
			else
				text:=seqNum;
			endif;
			
			//epr par 33151 10/12/13
			if  aTI.isTBAorIsRRP then
				text:=text &amp; "                 " ;
			else
				text:=text &amp; " " &amp; aTI.id;
			endif;
			
			if not onlyIDs then
				//aTI.getAllDrawingIconsByPriority(tmpIcons, 1);		// 8/12/17 MAP TFS7493	// TFS 46405
				aTI.getAllDrawingIconsByPriority(tmpIcons, 1, false);							// TFS 46405
				text:=text &amp; " "  &amp; aTI.dischargePort &amp; " " &amp; (aTI.totalWeight/1000).Decimal.truncatedTo(1).asStringJMT;
			endif;
		endif;
		
		if seqNum = null then
			aColour:=Gray;//its ROB cargo;
		else
			if wle &lt;&gt; null and wle.status =  WLE_COMPLETED then
				aColour:=Gray; //wle complete
			else
				aColour := Black;
			endif;
		endif;
		
		// VERTICAL
		if isVertical then
			myDrawingFrame.drawTextAt(text,textX, textY, aColour);	
			//only draw the first cargo attr
			if tmpIcons.first &lt;&gt; null then
				self.drawAttribute(null,null,myDrawingFrame,textX - 5 ,textY + myDrawingFrame.drawTextWidth(text) + 1, aColour,  tmpIcons.first, theAtt); // PAR 37527 added null for _REQ
				myDrawingFrame.drawFontName := NarrowFont;
			endif;
			
			if onlySeqNum then
				textY := textY +  myDrawingFrame.drawTextWidth(text&amp; " ").Integer;	
			else
				textX := textX + yOffset.Integer;
			endif;
		// HORIZONTAL
		else
			
			//18 Nov 2020	NDL	TFS 50311
			if onlySeqNum then
				if (( textX - firstX ) + myDrawingFrame.drawTextWidth(text &amp; " ") + 2 ) &gt; polyWidth then
					//too long to fit, shuffle down a line and reset to start of line.
					textY := textY + yOffset; //down a line
					textX := firstX; // start of line
				endif;
			endif;
			
			myDrawingFrame.drawTextAt(text,textX, textY, aColour);// aColour.getInverseColour());
			if tmpIcons.first &lt;&gt; null then
				self.drawAttribute(null,null,myDrawingFrame,textX + myDrawingFrame.drawTextWidth(text) + 1 ,textY+5, aColour,  tmpIcons.first, theAtt); // PAR 37527 added null for _REQ
				myDrawingFrame.drawFontName := NarrowFont;
			endif;
			
			if onlySeqNum then
				textX := textX + myDrawingFrame.drawTextWidth(text &amp; " ").Integer;
			else
				textY := textY - yOffset.Integer;	
			endif;
		endif;

	endforeach;
	
epilog
	myDrawingFrame.drawTextRotation := 0;
	myDrawingFrame.drawTextCharRotation := 0;
	myDrawingFrame.drawFontName := oldFont;
	delete tmpIcons;
end;</source>
        <access>protected</access>
        <Parameter name="_deckItemLayout" type="CM_DeckItemLayout"/>
        <Parameter name="_rect" type="PointArray"/>
        <Parameter name="_tis" type="ObjectArray"/>
        <Parameter name="_job" type="CM_VoyageDeckJob"/>
    </JadeMethod>
    <JadeMethod name="drawGCForSequenceSheet" id="800cc129-46f7-4c97-888b-19c542a6ce36">
        <source>drawGCForSequenceSheet(_deckItemLayout : CM_DeckItemLayout; 				
						_job : CM_VoyageDeckJob;
						_request : CM_ROROGCRequest) protected;
/*

Date		Who		Reason
30 July 2013	cnwer1	Initial creation CCMS 2265

*/
constants
	LineHeight = 13;
vars
	xx1, yy1, xx2, yy2,
	aColour, iconColour,
	completed, total: Integer;
	wle : CM_WorkListEntry;
	areaText : String;
begin

	if _request = null then
		return;
	endif;
	
	_deckItemLayout.myPolygonPixels.getExtremesForText(xx1,yy1,xx2,yy2);
	
	
	
	//cnwmc5 - PAR 31375 - added in scale factor
	xx1 := (xx1 * self.scaleFactor).Integer;
	yy1 := (yy1 * self.scaleFactor).Integer;
	xx2 := (xx2 * self.scaleFactor).Integer;
	yy2 := (yy2 * self.scaleFactor).Integer;
	
	aColour := _request.getAllocationColour();
	iconColour := aColour.getInverseColour();
	self.myPointDrawingFrame.drawFillColor := aColour;
	self.myPointDrawingFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
	self.myPointDrawingFrame.drawFontSize := 8.5; // PAR 29923
	self.myPointDrawingFrame.drawTextRotation := 0;
	self.myPointDrawingFrame.drawTextCharRotation := 0;

	
	self.myPointDrawingFrame.drawTextAt(_deckItemLayout.code,xx1, yy1,iconColour); //epr par 33151 10/12/13
	self.myPointDrawingFrame.drawTextAt(_request.getAllocationName(),xx1, yy1+ LineHeight,iconColour);
	  
	foreach wle in _request.allWorkListEntries discreteLock do
		if wle.status = WLE_COMPLETED  then
			 completed:=completed + 1;
		endif;
		total:=total + 1;
	endforeach;	
	 
	self.myPointDrawingFrame.drawTextAt(completed.asStringJMT &amp; "/" &amp; total.asStringJMT &amp; " Complete",xx1, yy1+(LineHeight*2),iconColour);
	 
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_deckItemLayout" type="CM_DeckItemLayout"/>
        <Parameter name="_job" type="CM_VoyageDeckJob"/>
        <Parameter name="_request" type="CM_ROROGCRequest"/>
    </JadeMethod>
    <JadeMethod name="drawIcons" id="40137059-b778-4346-b2d2-d6474791ec69">
        <source>drawIcons(	_ti : CM_TrackedItem; 
			_req : CM_RORORequest;
			_frame : CMUI_Frame input;
			_x1,_y1 : Real; 
			_inverseColor : Integer; _horizontal : Boolean) protected;
/*
Purpose:			
Date				Who			Reason
JUNE 2011			CNWAB1		Initial creation
09/01/2012			cnwmh5		PAR #30990 - remove code for rehandle icon	
11/03/2015			cnwmh5		Transient leaks
11/11/2019			jlgdap1		TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
11/10/2022	navkc1	Bug 54935: MSL - Roro planning - Slow on big decks/large vessels
*/
vars
	tmpIcons	: StringArray;
	theAtt		: Integer;
	tmpStr		: String;
	idx : Integer;
	tmpX, tmpY : Real;
	is40 : Boolean;
	maxIcons : Integer;
begin
	create tmpIcons transient;
	maxIcons := 1; // 11/10/2022	navkc1	#54935
	if _ti &lt;&gt; null and not _ti.isTBAorIsRRP then  //cnwrd1 par 30807 ccms 1310 added not istba
		//_ti.getAllDrawingIcons(tmpIcons);
		//_ti.getAllDrawingIconsByPriority(tmpIcons, 2);		// 8/12/17 MAP TFS7493	// TFS 46405
		is40 := (_ti.isForty() or _ti.isThirty or _ti.is45 or _ti.is53);  // 11/10/2022	navkc1	#54935
		if is40 then
			maxIcons := 2;  // 11/10/2022	navkc1	#54935
		endif;
		//_ti.getAllDrawingIconsByPriority(tmpIcons, 2, false);							// TFS 46405
		_ti.getAllDrawingIconsByPriority(tmpIcons, maxIcons, false);
	elseif _req &lt;&gt; null then //cnwrd1
		is40 := _req.getAttrIsNOT20();  // 11/10/2022	navkc1	#54935
		if is40 then
			maxIcons := 2;  // 11/10/2022	navkc1	#54935
		endif;
		//_req.getAllDrawingIconsByPriority(tmpIcons, 2);	// 12/12/17 MAP TFS7493
		_req.getAllDrawingIconsByPriority(tmpIcons, maxIcons);  // 11/10/2022	navkc1	#54935
	endif;

	tmpX := _x1;
	tmpY := _y1;
	
	if tmpIcons.size &gt; 0 then
		_frame.drawFontSize := 8;
		theAtt := 0;
		foreach tmpStr in tmpIcons do
			//if tmpStr = PicTIIsRehandle then								// 09/01/2013 cnwmh5 #30990 - removed
			//	continue;
			//endif;
			
			self.drawAttribute(_ti, _req, _frame,tmpX,tmpY, _inverseColor, tmpStr, theAtt); // PAR 37527 added _REQ
			if _horizontal then
				tmpX := tmpX + 7;
			else
				tmpY := tmpY + 8;
			endif;
				
			idx := idx + 1;
			//epr par 29647 31/5/12
			//if idx &gt;= 2 or self.scaleFactor &lt; 0.8 then // PAR 28887
			if idx &gt;= maxIcons or self.scaleFactor &lt; 0.8 then  // 11/10/2022	navkc1	#54935
				break;
			endif;

		endforeach;

//		self.allDrawingIcons.clear();
		// reset back to the default font
		self.myPointDrawingFrame.setDefaultFont(_frame);
	endif;
epilog
	delete tmpIcons;
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_req" type="CM_RORORequest"/>
        <Parameter name="_frame" type="CMUI_Frame" usage="input"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_inverseColor" type="Integer"/>
        <Parameter name="_horizontal" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawLayoutItemActual" id="20bc056d-f4ad-4c41-967d-015acfdbab2b">
        <updating/>
        <source>drawLayoutItemActual(frame : CMUI_PointDrawingFrame input;graphicIndex : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 June 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars
	theColour : Integer;
	objTI : Object;
	theText : String;
	doFloodFill, has40s, is40 : Boolean;
	deckItemLayout : CM_DeckItemLayout;
	aftLocn : CM_ROROLocnDefn;
	scale : Decimal[12,2];
	aTI, ti40 : CM_TrackedItem;
	allTIs : CM_TIArray;
	numTier : Integer;
	tmpPoints : PointArray;
	roroReq : CM_ROROSlotRequest;
begin
	self.myPointDrawingFrame:=frame;
	self.myPointDrawingFrame.autoRedraw := true;
	self.myPointDrawingFrame.drawWidth :=  1;
	
	scale := self.scaleFactor;
	if scale &lt;= 0 then
		scale := 1;
	endif;
	if self.myPointDrawingFrame.allPointGraphics.size &lt; graphicIndex then
		return;
	endif;
	deckItemLayout:=self.myPointDrawingFrame.allPointGraphics[graphicIndex].CM_DeckItemLayout;
	if deckItemLayout.pointsPolygon.size = 0 then
		return;
	endif;
	
	if not deckItemLayout.isPillar() and deckItemLayout.getObjectIRepresent() = null then
		return;
	endif;
	
	
	
	create allTIs transient;
	create tmpPoints transient;
	
	has40s := false;		
	ti40 := null;
	aTI := null;
	if self.modeView = ShpDisplayMode_Defn then
	else
		if deckItemLayout.isKindOf(CM_RORORequestLayout) then
			if deckItemLayout.CM_RORORequestLayout.myRequest.isBackEndRequest() then
				return; // ignore back end
			endif;
			
			roroReq := deckItemLayout.CM_RORORequestLayout.myRequest.CM_ROROSlotRequest;
//			is40 := (roroReq.getAttrIs40() or roroReq.getAttrIs30() or roroReq.getAttrIs45() or roroReq.getAttrIs53()); // PAR 30022 
			is40 := roroReq.getAttrIsNOT20(); // PAR 30253
			if is40 then // PAR 30022 

			// if deckItemLayout.CM_RORORequestLayout.myRequest.getAttrIs40() then
				if roroReq.mySlotRequestAft &lt;&gt; null then
					aftLocn := roroReq.mySlotRequestAft.myROROController.getDefn().CM_ROROLocnDefn;
					has40s := true;
				endif;
			endif;
		elseif deckItemLayout.myDeckItem&lt;&gt; null then
			deckItemLayout.myDeckItem.getAllTIs(REAL_MODE,allTIs, true);	
			if not allTIs.isEmpty() then
				foreach objTI in allTIs do
					if objTI.CM_TrackedItem.isContainer() and  not objTI.CM_TrackedItem.isTwenty() then
						has40s := true;
						ti40 := objTI.CM_TrackedItem;
						break;
					endif;
				endforeach;
				if has40s then
					if deckItemLayout.myDeckItem.isKindOf(CM_ROROLocnDefnVoyage) and not deckItemLayout.myDeckItem.CM_ROROLocnDefnVoyage.allROROSlotDefnByOrdinal.includes(ti40.myPrimaryActualLocation.CM_ROROSlotController.mySlotDefn) then
						return;
					endif;
					if deckItemLayout.myDeckItem.isKindOf(CM_ROROLocnDefnVoyage) then
						aftLocn := deckItemLayout.myDeckItem.CM_ROROLocnDefnVoyage.getAftLocnDefn();
					endif;
				endif;
			endif;
			
		endif;
	endif;
	
	// ########################################
	// ########################################
	// #### SET UP COLOURS AND LINE STYLES ETC
	// ########################################
	// ########################################
	
/*	// DO NOT Draw the Locns under our General Cargo poly
	// Only Defined Container Positions get covered. They only get covered by GC polys
	if self.modeView = ShpDisplayMode_Actual then
		// if covered by an actual GC Location
		if deckItemLayout.isCovered(DeckItemLayoutType_GCDischarge,true)   // PAR 27749
		or deckItemLayout.isCoveredByDefnWithCCCompleted(DeckItemLayoutType_GCLoad) then
			if not deckItemLayout.isPillar() then
				continue;
			endif;
		endif;
		
		// PAR 28990
		if  deckItemLayout.isCovered(DeckItemLayoutType_Locn,true)  then // hide any cargo positions that are under the OOTL cargo
			if deckItemLayout.isCoveredByOOTL(DeckItemLayoutType_Locn) then
				continue;
			endif;
		endif;
		// PAR 29178
		if  deckItemLayout.isCovered(DeckItemLayoutType_Graphic,true)  then // hide any cargo positions that are under the Equipment or General AREA
			continue;
		endif;

	endif;*/
	
	doFloodFill := self.myPointDrawingFrame.allFloodFill[graphicIndex];
	
	theColour:=White;
	
	self.myPointDrawingFrame.setupDrawing(graphicIndex,theColour,theText);
	 //epr par 29608 26/6/12
	if self.allSelectedObjects.includes(deckItemLayout) then
		self.myPointDrawingFrame.drawFillColor:=Grey;
	elseif self.allSelectedAltObjects.includes(deckItemLayout) then
		self.myPointDrawingFrame.drawFillColor := DarkGray;
	else
		if self.modeView = ShpDisplayMode_Defn then
			self.myPointDrawingFrame.drawFillColor := self.myPlanningForm.frmDeck.backColor;
		endif;
	endif;
	
	if self.modeView = ShpDisplayMode_Defn then

		self.myPointDrawingFrame.drawFillStyle:=Frame.DrawFillStyle_Solid;//Transparent;

	endif;
	
	
	// ########################################
	// ########################################
	// #### IF WE HAVE A 40 THEN ADJUST XYs
	// ########################################
	// ########################################
	tmpPoints.clear();
	deckItemLayout.pointsPolygon.copy(tmpPoints);

	//if aTI &lt;&gt; null and aTI.isForty() then
	if has40s and aftLocn &lt;&gt; null then
		if aftLocn.isVerticalOrientation() then
	//	app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1. ROTATED');
			tmpPoints[1] := aftLocn.myLayout.pointsPolygon[1];
			tmpPoints[5] := aftLocn.myLayout.pointsPolygon[5];
			tmpPoints[2] := aftLocn.myLayout.pointsPolygon[2];
		else
			tmpPoints[1] := aftLocn.myLayout.pointsPolygon[1];
			tmpPoints[5] := aftLocn.myLayout.pointsPolygon[5];
			tmpPoints[4] := aftLocn.myLayout.pointsPolygon[4];
		endif;
	endif;
	self.myPointDrawingFrame.drawAPolygon(tmpPoints,doFloodFill,theColour, self.myPointDrawingFrame.drawWidth, self.myPointDrawingFrame.drawFillColor, scale, theText);

	numTier := deckItemLayout.myDeckLayer.getNumTiers();
	self.drawAPolygonAfter(deckItemLayout,allTIs, numTier, tmpPoints, has40s);
epilog
	delete allTIs;
	delete tmpPoints;
end;</source>
        <Parameter name="frame" type="CMUI_PointDrawingFrame" usage="input"/>
        <Parameter name="graphicIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawLayoutItemActualForCC" id="812e7d94-0b44-4b48-9157-70b36e431aa4">
        <updating/>
        <source>drawLayoutItemActualForCC(frame : CMUI_PointDrawingFrame input;graphicIndex : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 June 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars
	theColour : Integer;
	theObject: Object;
	theText : String;
	doFloodFill, has40s : Boolean;
	deckItemLayout : CM_DeckItemLayout;
	aftLocn, theLocn : CM_ROROLocnDefn;
	scale : Decimal[12,2];
	aTI, ti40 : CM_TrackedItem;
	allTIs : CM_TIArray;
	numTier : Integer;
	tmpPoints : PointArray;
begin
	self.myPointDrawingFrame:=frame;
	self.myPointDrawingFrame.autoRedraw := true;
	self.myPointDrawingFrame.drawWidth :=  1;
	
	scale := self.scaleFactor;
	if scale &lt;= 0 then
		scale := 1;
	endif;
	if self.myPointDrawingFrame.allPointGraphics.size &lt; graphicIndex then
		return;
	endif;
	deckItemLayout:=self.myPointDrawingFrame.allPointGraphics[graphicIndex].CM_DeckItemLayout;
	if deckItemLayout.pointsPolygon.size = 0 then
		return;
	endif;
	
	if deckItemLayout.myDeckItem = null then
		return;
	endif;
	
	create allTIs transient;
	create tmpPoints transient;
	
// DO NOT Draw the Locns under our General Cargo poly
	// Only Defined Container Positions get covered. They only get covered by GC polys
	if self.modeView = ShpDisplayMode_ColCodeLoad then
		if deckItemLayout.isCovered(DeckItemLayoutType_CCLoad,true) then // PAR 27749
			return;
		endif;
	elseif self.modeView = ShpDisplayMode_ColCodeDisch then
		if deckItemLayout.isCovered(DeckItemLayoutType_CCDischarge,true) then // PAR 27749
			return;
		endif;
	endif;
	
	
	deckItemLayout.myDeckItem.getAllTIs(REAL_MODE,allTIs, true);
	doFloodFill := true;
	theColour:=White;

	self.myPointDrawingFrame.setupDrawing(graphicIndex,theColour,theText);
	 //epr par 29608 26/6/12
	if self.allSelectedObjects.includes(deckItemLayout) then
		self.myPointDrawingFrame.drawFillColor:=Grey;
	elseif self.allSelectedAltObjects.includes(deckItemLayout) then
		self.myPointDrawingFrame.drawFillColor := DarkGray;
	endif;
	
	
	tmpPoints.clear();
	deckItemLayout.pointsPolygon.copy(tmpPoints);
	
	if deckItemLayout.myDeckItem &lt;&gt; null and deckItemLayout.myDeckItem.isKindOf(CM_ROROLocnDefn) then
		theLocn := deckItemLayout.myDeckItem.CM_ROROLocnDefn; // PAR 28990

		has40s := false;
		if not allTIs.isEmpty() then
			foreach theObject in allTIs do
				// PAR 29050
				aTI := theObject.CM_TrackedItem;
				
				// PAR 29050 - in Load CC mode ignore any TIs that have been CCd for discharge
				if self.modeView = ShpDisplayMode_ColCodeLoad
				and ( (aTI.isToBeDischargedHere() and aTI.getVoyageWLEUnactioned(false) &lt;&gt; null)  // is colour coded
					  or (aTI.isRehandle or aTI.isSOB) ) then  // PAR 29477 (29771)
					continue;
				endif;
				if not aTI.isTwenty() then
					has40s := true;
					ti40 := aTI;
					break;
				endif;
			endforeach;
		else
			aTI := null;
		endif;
		if has40s and ti40 &lt;&gt; null then
			// ignore back end
			if not theLocn.allROROSlotDefnByOrdinal.includes(ti40.myPrimaryActualLocation.CM_ROROSlotController.mySlotDefn) then
				return;
			endif;
			aftLocn := theLocn.getAftLocnDefn();
			if aftLocn &lt;&gt; null then
				if aftLocn.isVerticalOrientation() then
					tmpPoints[1] := aftLocn.myLayout.pointsPolygon[1];
					tmpPoints[5] := aftLocn.myLayout.pointsPolygon[5];
					tmpPoints[2] := aftLocn.myLayout.pointsPolygon[2];
				else
					tmpPoints[1] := aftLocn.myLayout.pointsPolygon[1];
					tmpPoints[5] := aftLocn.myLayout.pointsPolygon[5];
					tmpPoints[4] := aftLocn.myLayout.pointsPolygon[4];
				endif;
			endif;
		endif;
	endif;
	
	numTier := deckItemLayout.myDeckLayer.getNumTiers();
	
	self.myPointDrawingFrame.drawAPolygon(tmpPoints,doFloodFill,theColour, self.myPointDrawingFrame.drawWidth, self.myPointDrawingFrame.drawFillColor, scale, theText);
	if self.modeView = ShpDisplayMode_ColCodeDisch or self.modeView = ShpDisplayMode_ColCodeLoad then	// PAR 29050
		self.drawAPolygonAfter(deckItemLayout,allTIs, numTier, tmpPoints, has40s);
	endif;
epilog
	delete allTIs;
	delete tmpPoints;
end;</source>
        <Parameter name="frame" type="CMUI_PointDrawingFrame" usage="input"/>
        <Parameter name="graphicIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawLayoutItemColourCoding" id="799dd1bc-71fe-440a-9523-f0fedcfbdf02">
        <updating/>
        <source>drawLayoutItemColourCoding(frame : CMUI_PointDrawingFrame input;graphicIndex : Integer; _isLoad : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 June 2012	cnwer1	Initial creation PAR 29608
//18 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
*/

vars
	scale : Decimal[12,2];
	theText : String;
	numTier : Integer;
	tmpPoints : PointArray;
	aReq : CM_RORORequest;
	has40s : Boolean;
	aftLocn, theLocn : CM_ROROLocnDefn;
	theDeckItem : CM_DeckItem;
	theReq : CM_RORORequest;
	aTI : CM_TrackedItem;
	allTIs : CM_TIArray;
	deckItemLayout : CM_DeckItemLayout;
	theColour : Integer;
	is40 : Boolean;
begin
	create allTIs transient;
	self.myPointDrawingFrame:=frame;
	self.myPointDrawingFrame.autoRedraw := true;
	self.myPointDrawingFrame.drawWidth :=  1;
	scale := self.scaleFactor;
	if scale &lt;= 0 then
		scale := 1;
	endif;
	if self.myPointDrawingFrame.allPointGraphics.size &lt; graphicIndex then
		return;
	endif;
	deckItemLayout:=self.myPointDrawingFrame.allPointGraphics[graphicIndex].CM_DeckItemLayout;
	if deckItemLayout.pointsPolygon.size = 0 then
		return;
	endif;
	if deckItemLayout.isPillar() then
		return;
	endif;
	// DO NOT Draw the Locns under our General Cargo poly
	// Only Defined Container Positions get covered. They only get covered by GC polys
	if self.modeView = ShpDisplayMode_ColCodeLoad then
		if deckItemLayout.isCovered(DeckItemLayoutType_CCLoad,true) then // PAR 27749
			return;
		endif;
	elseif self.modeView = ShpDisplayMode_ColCodeDisch then
		if deckItemLayout.isCovered(DeckItemLayoutType_CCDischarge,true) then // PAR 27749
			return;
		endif;
	endif;

	// ### FORTY FOOTER
	create tmpPoints transient;
	deckItemLayout.pointsPolygon.copy(tmpPoints);
	if deckItemLayout.isKindOf(CM_RORORequestLayout) then
		aReq := deckItemLayout.CM_RORORequestLayout.myRequest;
		has40s := false;
		if aReq &lt;&gt; null and aReq.myROROController.isKindOf(CM_ROROSlotController) then
			theLocn := aReq.myROROController.CM_ROROSlotController.mySlotDefn.myROROLocnDen;
		
//			is40 := (aReq.getAttrIs40() or aReq.getAttrIs30() or aReq.getAttrIs45() or aReq.getAttrIs53()); // PAR 30022 
			is40 := aReq.getAttrIsNOT20(); // PAR 30253
			if is40 then // PAR 30022 
			//if aReq.getAttrIs40() then
		
				has40s := true;
				if  aReq.getAttrIsBackend() then
					return;
				endif;
						
				aftLocn := theLocn.getAftLocnDefn();
				
			else // 20' Request
				// PAR 29050 - 40' RoB 
				if aReq.myROROController.hasROB(false) then
					aTI := aReq.myROROController.allTrackedItems.first();
					// if aTI.isForty() then
					if  (aTI.isForty() or aTI.is30 or aTI.is45 or aTI.is53) then // PAR 30022
						has40s := true;
						if not aReq.myROROController = aTI.myPrimaryActualLocation then // 20 foot request in a back end of a 40
	//						return;
							tmpPoints.clear();
							aftLocn := theLocn;
							aftLocn.myAdjacentSlotFwd.myLayout.pointsPolygon.copy(tmpPoints);
						else
							aftLocn := theLocn.getAftLocnDefn();
						endif;
					endif;
				elseif theLocn.hasROB(false) then // if our 20' req is on a LC that has discharge CC there are no RoB, so check if the stack has any RoB
					create allTIs transient;
					theLocn.getAllTIsRoB(allTIs, true, false);	//15 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
					foreach aTI in allTIs discreteLock do : loop40
					//	if aTI.isForty() then
						if  (aTI.isForty() or aTI.is30 or aTI.is45 or aTI.is53) then // PAR 30022
							has40s := true;
							if not aTI.myPrimaryActualLocation.CM_ROROSlotController.mySlotDefn.myROROLocnDen = theLocn then// our 20' req in in the backend of RoB 40s
								tmpPoints.clear();
								aftLocn := theLocn; // I am the Aft location
								aftLocn.myAdjacentSlotFwd.myLayout.pointsPolygon.copy(tmpPoints); // Get the fwd locn's points.
							else
								aftLocn := theLocn.getAftLocnDefn();
							endif;
							break loop40;
						endif;
					endforeach;
				endif;
			
			endif;
		endif;
	else	
		deckItemLayout.myDeckItem.getAllTIs(REAL_MODE, allTIs, true);

		// PAR 29050 - in Load CC mode ignore any TIs that have been CCd for discharge
		has40s := false;
		if not allTIs.isEmpty() then
			foreach aTI in allTIs do
				if self.modeView = ShpDisplayMode_ColCodeLoad
				and (aTI.isToBeDischargedHere() 
									or (aTI.isRehandle or aTI.isSOB))  // PAR 29770 
				and aTI.getVoyageWLEUnactioned(false) &lt;&gt; null then // is colour coded
					continue;
				endif;
				if  (aTI.isForty() or aTI.is30 or aTI.is45 or aTI.is53) then // PAR 30022
//				if not aTI.isTwenty() then
					has40s := true;
					break;
				endif;
			endforeach;
		endif;	
		if has40s  then
			aftLocn := deckItemLayout.myDeckItem.getAftLCFor40(REAL_MODE);
		endif;
	endif;
	
	if aftLocn &lt;&gt; null then
		if aftLocn.isVerticalOrientation() then
	//	app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1. ROTATED');
			tmpPoints[1] := aftLocn.myLayout.pointsPolygon[1];
			tmpPoints[5] := aftLocn.myLayout.pointsPolygon[5];
			tmpPoints[2] := aftLocn.myLayout.pointsPolygon[2];
		else
			tmpPoints[1] := aftLocn.myLayout.pointsPolygon[1];
			tmpPoints[5] := aftLocn.myLayout.pointsPolygon[5];
			tmpPoints[4] := aftLocn.myLayout.pointsPolygon[4];
		endif;
	endif;

	
	// ### SETUP DRAWING FRAME

	theColour:=White;
	self.myPointDrawingFrame.setupDrawing(graphicIndex,theColour,theText);
	 //epr par 29608 26/6/12
	if self.allSelectedObjects.includes(deckItemLayout) then
		self.myPointDrawingFrame.drawFillColor:=Grey;
	elseif self.allSelectedAltObjects.includes(deckItemLayout) then
		self.myPointDrawingFrame.drawFillColor := DarkGray;
	endif;
	
	// PAR 28746 
	numTier := deckItemLayout.myDeckLayer.getNumTiers();
	
	if aReq &lt;&gt; null  then
		theDeckItem := aReq.myROROController.getDefn();
		if theDeckItem.isLocnGC() then
			if theDeckItem.isAllReqsInJob(_isLoad) then
				self.myPointDrawingFrame.drawWidth :=  3;
			endif;
		endif;
	endif;
//self.myPointDrawingFrame.drawFillColor
	self.myPointDrawingFrame.drawAPolygon(tmpPoints,true,theColour, self.myPointDrawingFrame.drawWidth,self.myPointDrawingFrame.drawFillColor , scale, theText);
	
	if deckItemLayout.isKindOf(CM_RORORequestLayout) then
		self.drawReqInRectangle(theDeckItem, numTier, _isLoad, has40s, tmpPoints);
		self.drawReqInPolygon(deckItemLayout.CM_RORORequestLayout, numTier, _isLoad);
	else
		self.drawAPolygonAfter(deckItemLayout,allTIs, numTier, tmpPoints, has40s);
	endif;


	// PAR 28544 ### Draw a thick line around the location IF all of the requests are in a job.
	if theDeckItem &lt;&gt; null  then
		if theDeckItem.isLocnContainer() 
		or theDeckItem.isLocnLanePosition() then
			if theDeckItem.isAllReqsInJob(_isLoad) then
				self.drawRectangleFromPolygon(self.myPointDrawingFrame, tmpPoints);
			endif;
		endif;
	endif;
epilog
	delete  allTIs;
	delete tmpPoints;
end;</source>
        <Parameter name="frame" type="CMUI_PointDrawingFrame" usage="input"/>
        <Parameter name="graphicIndex" type="Integer"/>
        <Parameter name="_isLoad" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawLayoutItemProposed" id="9f328d26-66ca-4f58-b59d-064f439294df">
        <updating/>
        <source>drawLayoutItemProposed(frame : CMUI_PointDrawingFrame input;graphicIndex : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 June 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars
	theColour : Integer;
	objTI : Object;
	theText : String;
	doFloodFill, has40s : Boolean;
	deckItemLayout : CM_DeckItemLayout;
	aftLocn : CM_ROROLocnDefn;
	scale : Decimal[12,2];
	aTI, ti40 : CM_TrackedItem;
	allTIs : CM_TIArray;
	numTier : Integer;
	tmpPoints : PointArray;
begin
	self.myPointDrawingFrame:=frame;
	self.myPointDrawingFrame.autoRedraw := true;
	self.myPointDrawingFrame.drawWidth :=  1;
	
	scale := self.scaleFactor;
	if scale &lt;= 0 then
		scale := 1;
	endif;
	if self.myPointDrawingFrame.allPointGraphics.size &lt; graphicIndex then
		return;
	endif;
	deckItemLayout:=self.myPointDrawingFrame.allPointGraphics[graphicIndex].CM_DeckItemLayout;
	if deckItemLayout.pointsPolygon.size = 0 then
		return;
	endif;

	if not deckItemLayout.isPillar() and deckItemLayout.getObjectIRepresent() = null then
		return;
	endif;
		
	create allTIs transient;
	create tmpPoints transient;
	// ########################################
	// ########################################
	// #### HAVE WE GOT A 40 FOOTER ?
	// ########################################
	// ########################################
	has40s := false;		
	ti40 := null;
	aTI := null;
	aftLocn:=null;
	if deckItemLayout.myDeckItem&lt;&gt; null then

		deckItemLayout.myDeckItem.getProposedTIs(allTIs, true);

		if deckItemLayout.myDeckItem.isLocnContainer() then
			if not allTIs.isEmpty() then
				foreach objTI in allTIs do
					if objTI.CM_TrackedItem.isContainer() and  not objTI.CM_TrackedItem.isTwenty() then
						has40s := true;
						ti40 := objTI.CM_TrackedItem;
						break;
					endif;
				endforeach;
				if has40s then
					if ti40.myPrimaryActualLocation.isKindOf(CM_ROROSlotController) then
						if deckItemLayout.myDeckItem.isKindOf(CM_ROROLocnDefnVoyage) and not deckItemLayout.myDeckItem.CM_ROROLocnDefnVoyage.allROROSlotDefnByOrdinal.includes(ti40.myPrimaryActualLocation.CM_ROROSlotController.mySlotDefn) then
							return;
						endif;
					elseif ti40.myPrimaryPlannedLocation.isKindOf(CM_ROROSlotController) then
						if deckItemLayout.myDeckItem.isKindOf(CM_ROROLocnDefnVoyage) and not deckItemLayout.myDeckItem.CM_ROROLocnDefnVoyage.allROROSlotDefnByOrdinal.includes(ti40.myPrimaryPlannedLocation.CM_ROROSlotController.mySlotDefn) then
							return;
						endif;
					endif;
					if deckItemLayout.myDeckItem.isKindOf(CM_ROROLocnDefnVoyage) then
						aftLocn := deckItemLayout.myDeckItem.CM_ROROLocnDefnVoyage.getAftLocnDefn();
					endif;
				endif;
			endif;
		endif;
	endif;
	
	// ########################################
	// ########################################
	// #### SET UP COLOURS AND LINE STYLES ETC
	// ########################################
	// ########################################

/*	// DO NOT Draw the Locns under our General Cargo poly
	// Only Defined Container Positions get covered. They only get covered by GC polys
		// if covered by an actual GC Location
	if deckItemLayout.isCovered(DeckItemLayoutType_GCDischarge,true) then // hide any cargo positions that are under the GC cargo
		if not deckItemLayout.isPillar() then
			continue;
		endif;
	endif;
	// PAR 29178
	if  deckItemLayout.isCovered(DeckItemLayoutType_Graphic,true)  then // hide any cargo positions that are under the Equipment or General AREA
		continue;
	endif;
	*/
	doFloodFill := self.myPointDrawingFrame.allFloodFill[graphicIndex];
	theColour:=White;
	self.myPointDrawingFrame.setupDrawing(graphicIndex,theColour,theText);
	 //epr par 29608 26/6/12
	if self.allSelectedObjects.includes(deckItemLayout) then
		self.myPointDrawingFrame.drawFillColor:=Grey;
	elseif self.allSelectedAltObjects.includes(deckItemLayout) then
		self.myPointDrawingFrame.drawFillColor := DarkGray;
	else
		if deckItemLayout.isGCDefnLayout then
			self.myPointDrawingFrame.drawFillColor := self.myPointDrawingFrame.allFillColours[graphicIndex  ];//deckItemLayout.drawFillColour;
		else
			if allTIs.size &gt; 0 then
				self.myPointDrawingFrame.drawFillColor := self.myPlanningForm.frmDeck.backColor;
			endif;
		endif;
	endif;

	self.myPointDrawingFrame.drawFillStyle:=Frame.DrawFillStyle_Solid;//Transparent;
		
	// ########################################
	// ########################################
	// #### IF WE HAVE A 40 THEN ADJUST XYs
	// ########################################
	// ########################################
	tmpPoints.clear();
	deckItemLayout.pointsPolygon.copy(tmpPoints);
	
	if has40s and aftLocn &lt;&gt; null then
		if aftLocn.isVerticalOrientation() then
			tmpPoints[1] := aftLocn.myLayout.pointsPolygon[1];
			tmpPoints[5] := aftLocn.myLayout.pointsPolygon[5];
			tmpPoints[2] := aftLocn.myLayout.pointsPolygon[2];
		else
			tmpPoints[1] := aftLocn.myLayout.pointsPolygon[1];
			tmpPoints[5] := aftLocn.myLayout.pointsPolygon[5];
			tmpPoints[4] := aftLocn.myLayout.pointsPolygon[4];
		endif;
	endif;
	
	self.myPointDrawingFrame.drawAPolygon(tmpPoints,doFloodFill,theColour, self.myPointDrawingFrame.drawWidth, self.myPointDrawingFrame.drawFillColor, scale, theText);
	
	numTier := deckItemLayout.myDeckLayer.getNumTiers();
	if not allTIs.isEmpty() then
		self.drawAPolygonAfter(deckItemLayout,allTIs, numTier, tmpPoints, has40s);
	endif;
epilog
	delete  allTIs;
	delete tmpPoints;
end;</source>
        <Parameter name="frame" type="CMUI_PointDrawingFrame" usage="input"/>
        <Parameter name="graphicIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawMTLocation" id="a927e2b6-dd8f-4a49-a513-065966c91863">
        <updating/>
        <source>drawMTLocation(_deckItemLayout : CM_DeckItemLayout; _tis : ObjectArray; _numTier : Integer; _tmpPoints : PointArray; _has40s : Boolean) updating;
/*
Purpose:		CCMS 1009 28479	
Date		Who		Reason
10 June 2011	cnwab1	Initial creation
*/

vars
	x1, y1, x2, y2, numTier : Integer;
	xs1, ys1, xs2, ys2 : Real; // to scale
	xd1, yd1 : Real; // for drawing
	len, hite : Real;
	aTI : CM_TrackedItem;
	aColour, tiLen : Integer;
	obj : Object;
	myDrawingFrame : CMUI_PointDrawingFrame;
begin
	myDrawingFrame := self.myPointDrawingFrame;
	myDrawingFrame.drawTextRotation := 0;
	myDrawingFrame.drawTextCharRotation := 0;

	if _tis = null then
		return;
	endif;
	
	x1 := 9999999;
	y1 := 9999999;

	x1 := _tmpPoints[1].x;
	y1 := _tmpPoints[1].y;
	x2 := _tmpPoints[3].x;
	y2 := _tmpPoints[3].y;
	
	xs1 := x1 * self.scaleFactor;
	ys1 := y1 * self.scaleFactor;
	xs2 := x2 * self.scaleFactor;
	ys2 := y2 * self.scaleFactor;

	// Is the rotation master, draw a red dot.
	if not _deckItemLayout.myDeckItem.CM_ROROLocnDefn.allPlannedRotatedLocnDefns.isEmpty() then
		myDrawingFrame.drawFillColor := Red;
		myDrawingFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
		myDrawingFrame.drawEllipse(xs1+2, ys2-2, xs1+10, ys2-10,Red);
	endif;
	

	
epilog

end;</source>
        <Parameter name="_deckItemLayout" type="CM_DeckItemLayout"/>
        <Parameter name="_tis" type="ObjectArray"/>
        <Parameter name="_numTier" type="Integer"/>
        <Parameter name="_tmpPoints" type="PointArray"/>
        <Parameter name="_has40s" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawNoteACTUAL" id="56696b85-68dc-47f4-b734-7d31c223b1da">
        <updating/>
        <source>drawNoteACTUAL(_roroDefn : CM_DeckItem;_frame : CMUI_PointDrawingFrame input; _mode : Integer) updating;
/*
Purpose:			
Date		Who		Reason
26 September 2011	cnwab1	Initial creation
*/

vars
	scale : Decimal[12,2];
	theText : String;
	numTier, theColour, drawFillColour : Integer;
	tmpPoints : PointArray;
	theLayout : CM_DeckItemLayout;
	has40s, isMTLocn : Boolean;
	aftLocn : CM_ROROLocnDefn;
	allTIs : CM_TIArray;
	objTI, ti40 : CM_TrackedItem;
	gcLayer : CM_DeckLayerLayout;
	req : CM_RORORequest;
begin
	//cnwmc5 - 24 Feb 2014 - PAR 33109 - Removed block becuase it is causing removed CC to get drawn incorrectly.
	/*if self.modeView = ShpDisplayMode_ColCodeLoad // PAR 32246 - Stop notes from colour coding
	or self.modeView = ShpDisplayMode_ColCodeDisch then // PAR 32246
		return; // PAR 32246
	endif;*/

	// PAR 33246 - SOB GC areas redraw whole layer. This will make the source 'disappear'
	if _roroDefn.isLocnGC then
		req := _roroDefn.hasColourCoding(DISCHARGE_MOVETYPE);
		if req&lt;&gt; null and req.isSOB() and req.isComplete then
			gcLayer := _roroDefn.myLayout.myDeckLayer.myDeckLayout.getGCLayer();
			self.myPlanningForm.doDrawLayerForLayer(gcLayer);
			return;
		endif;
	endif;
	
	self.myPointDrawingFrame := _frame;
	create allTIs transient;
	_frame.autoRedraw := true;
	_frame.allPointGraphics.removeInvalidObjects();
	scale := self.scaleFactor;
	if scale &lt;= 0 then
		scale := 1;
	endif;
	
	numTier := _roroDefn.myDeck.numTier;
	if numTier = 0 then
		numTier := 3;
	endif;
	theLayout := _roroDefn.myLayout;
	
	// ### FORTY FOOTER
	create tmpPoints transient;
	theLayout.pointsPolygon.copy(tmpPoints);
	has40s := false;
	
	if _mode = PLANNING_MODE then
		_roroDefn.getProposedTIs(allTIs,true);
	else
		_roroDefn.getAllTIs(_mode,allTIs,true);
	endif;
	theColour := Black;
	drawFillColour := White;
	if not allTIs.isEmpty() then
		foreach objTI in allTIs do
			if self.modeViewSub = ShpDisplayModeSub_Text  
			or _roroDefn.isLocnLanePosition()
			or (self.modeViewSub = ShpDisplayModeSub_Colour and _roroDefn.isLocnGC() ) then // PAR 31077
				drawFillColour := objTI.getDrawingColour(TI_ColourMode_DischargePort);
			endif;
			if objTI.CM_TrackedItem.isContainer() then
				if  not objTI.CM_TrackedItem.isTwenty() then
					has40s := true;
					ti40 := objTI.CM_TrackedItem;
					break;
				endif;
			else // PAR 31077
				break; // PAR 31077 GC just use the first
			endif;
		endforeach;
		if has40s then
//			if _roroDefn.isKindOf(CM_ROROLocnDefnVoyage) and not _roroDefn.CM_ROROLocnDefnVoyage.allROROSlotDefnByOrdinal.includes(ti40.myPrimaryActualLocation.CM_ROROSlotController.mySlotDefn) then
//			return;
//			endif;

			// ### PAR 30944
			if _mode = PLANNING_MODE then
				if _roroDefn.isKindOf(CM_ROROLocnDefnVoyage) then
					if ti40.myPrimaryPlannedLocation.isKindOf(CM_ROROSlotController) then
						if not _roroDefn.CM_ROROLocnDefnVoyage.allROROSlotDefnByOrdinal.includes(ti40.myPrimaryPlannedLocation.CM_ROROSlotController.mySlotDefn) then
							return;
						endif;
					else
						return;
					endif;
				endif;
			elseif _mode = REAL_MODE then
				if _roroDefn.isKindOf(CM_ROROLocnDefnVoyage) then
					if ti40.myPrimaryActualLocation.isKindOf(CM_ROROSlotController) then
						if not _roroDefn.CM_ROROLocnDefnVoyage.allROROSlotDefnByOrdinal.includes(ti40.myPrimaryActualLocation.CM_ROROSlotController.mySlotDefn) then
							return;
						endif;
					else
						return;
					endif;
				endif;
			endif;
			
			
			if _roroDefn.isKindOf(CM_ROROLocnDefnVoyage) then
				aftLocn := _roroDefn.CM_ROROLocnDefnVoyage.getAftLocnDefn();
			endif;
			if aftLocn &lt;&gt; null then
				if aftLocn.isVerticalOrientation() then
					tmpPoints[1] := aftLocn.myLayout.pointsPolygon[1];
					tmpPoints[5] := aftLocn.myLayout.pointsPolygon[5];
					tmpPoints[2] := aftLocn.myLayout.pointsPolygon[2];
				else
					tmpPoints[1] := aftLocn.myLayout.pointsPolygon[1];
					tmpPoints[5] := aftLocn.myLayout.pointsPolygon[5];
					tmpPoints[4] := aftLocn.myLayout.pointsPolygon[4];
				endif;
			endif;
		endif;
	endif;	
	
	// ### SETUP DRAWING FRAME
	_frame.drawStyle := theLayout.drawLineStyle;
	if self.modeView = ShpDisplayMode_ColCodeLoad then
		// PAR 28513 frame.drawFillStyle := Frame.DrawFillStyle_DiagonalCross;
		_frame.drawFillStyle := Frame.DrawFillStyle_Solid; // PAR 28513
	elseif self.modeView = ShpDisplayMode_Actual then
		if self.modeViewSub = ShpDisplayModeSub_Colour then
			_frame.drawFillStyle := Frame.DrawFillStyle_Solid; 
		else
			_frame.drawFillStyle := Frame.DrawFillStyle_Solid; 
		endif;
	else
		_frame.drawFillStyle := Frame.DrawFillStyle_Solid; 
	endif;
	_frame.drawFillColor := drawFillColour;
	_frame.drawWidth := theLayout.drawWidth;
	
	
	_frame.drawAPolygon(tmpPoints,true,theColour, _frame.drawWidth, drawFillColour, scale, theText);
	self.drawAPolygonAfter(theLayout,allTIs, numTier, tmpPoints, has40s);

epilog
	delete tmpPoints;
	delete allTIs;
end;</source>
        <Parameter name="_roroDefn" type="CM_DeckItem"/>
        <Parameter name="_frame" type="CMUI_PointDrawingFrame" usage="input"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawNoteCOLOURCODING" id="298a01cf-c2ec-43ac-9b9b-c39d2ffe7237">
        <updating/>
        <source>drawNoteCOLOURCODING(_deckItemLayout : CM_RORORequestLayout;_frame : CMUI_PointDrawingFrame input; _isLoad : Boolean) updating;
/*
Purpose:			
Date		Who		Reason
26 September 2011	cnwab1	Initial creation
*/
//18 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
vars
	scale : Decimal[12,2];
	theText : String;
	numTier : Integer;
	tmpPoints : PointArray;
	aReq : CM_RORORequest;
	has40s, is40 : Boolean;
	aftLocn, theLocn : CM_ROROLocnDefn;
	theDeckItem : CM_DeckItem;
	theReq : CM_RORORequest;
	aTI : CM_TrackedItem;
	allTIs : CM_TIArray;
begin
	if self.modeView &lt;&gt; ShpDisplayMode_ColCodeLoad // PAR 32246 - Stop notes from actual moves
	and self.modeView &lt;&gt; ShpDisplayMode_ColCodeDisch then // PAR 32246
		return; // PAR 32246
	endif;

	self.myPointDrawingFrame := _frame;

	_frame.autoRedraw := true;
	scale := self.scaleFactor;
	if scale &lt;= 0 then
		scale := 1;
	endif;
	if _deckItemLayout.myDeckLayer &lt;&gt; null then
		numTier := _deckItemLayout.myDeckLayer.getNumTiers();
	endif;
	if numTier = 0 then
		numTier := 3;
	endif;
	
	if not  _frame.allPointGraphics.includes(_deckItemLayout) then
		_frame.doPointArrayAdd(_deckItemLayout.drawLineColour,true, Frame.DrawFillStyle_Solid, 1, _deckItemLayout.drawFillColour, _deckItemLayout);
		self.myPlanningForm.beginNotification(_deckItemLayout, EVENT_RORO_ITEM_UPDATE, Response_Continuous, null);
		self.myPlanningForm.beginNotification(_deckItemLayout, EVENT_RORO_ITEM_DELETE, Response_Continuous, null);
	endif;
	
	// ### FORTY FOOTER
	create tmpPoints transient;
	_deckItemLayout.pointsPolygon.copy(tmpPoints);
	aReq := _deckItemLayout.myRequest;
	has40s := false;
	if aReq &lt;&gt; null and aReq.myROROController.isKindOf(CM_ROROSlotController) then
		theLocn := aReq.myROROController.CM_ROROSlotController.mySlotDefn.myROROLocnDen;
	
//		is40 := (aReq.getAttrIs40() or aReq.getAttrIs30() or aReq.getAttrIs45() or aReq.getAttrIs53()); // PAR 30022 
		is40 := aReq.getAttrIsNOT20(); // PAR 30253
		if is40 then // PAR 30022 
		// if aReq.getAttrIs40() then
	
			has40s := true;
			if  aReq.getAttrIsBackend() then
				return;
			endif;
					
			aftLocn := theLocn.getAftLocnDefn();
			
		else // 20' Request
			// PAR 29050 - 40' RoB 
			if aReq.myROROController.hasROB(false) then
				aTI := aReq.myROROController.allTrackedItems.first();
				// if aTI.isForty() then
				if  (aTI.isForty() or aTI.is30 or aTI.is45 or aTI.is53) then // PAR 30022
					has40s := true;
					if not aReq.myROROController = aTI.myPrimaryActualLocation then // 20 foot request in a back end of a 40
//						return;
						tmpPoints.clear();
						aftLocn := theLocn;
						aftLocn.myAdjacentSlotFwd.myLayout.pointsPolygon.copy(tmpPoints);
					else
						aftLocn := theLocn.getAftLocnDefn();
					endif;
				endif;
			elseif theLocn.hasROB(false) then // if our 20' req is on a LC that has discharge CC there are no RoB, so check if the stack has any RoB
				create allTIs transient;
				theLocn.getAllTIsRoB(allTIs, true, false);	//15 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
				foreach aTI in allTIs discreteLock do : loop40
					// if aTI.isForty() then
					if  (aTI.isForty() or aTI.is30 or aTI.is45 or aTI.is53) then // PAR 30022
						has40s := true;
						if not aTI.myPrimaryActualLocation.CM_ROROSlotController.mySlotDefn.myROROLocnDen = theLocn then// our 20' req in in the backend of RoB 40s
							tmpPoints.clear();
							aftLocn := theLocn; // I am the Aft location
							aftLocn.myAdjacentSlotFwd.myLayout.pointsPolygon.copy(tmpPoints); // Get the fwd locn's points.
						else
							aftLocn := theLocn.getAftLocnDefn();
						endif;
						break loop40;
					endif;
				endforeach;
			endif;
		
		endif;
		if aftLocn &lt;&gt; null then
			if aftLocn.isVerticalOrientation() then
		//	app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1. ROTATED');
				tmpPoints[1] := aftLocn.myLayout.pointsPolygon[1];
				tmpPoints[5] := aftLocn.myLayout.pointsPolygon[5];
				tmpPoints[2] := aftLocn.myLayout.pointsPolygon[2];
			else
				tmpPoints[1] := aftLocn.myLayout.pointsPolygon[1];
				tmpPoints[5] := aftLocn.myLayout.pointsPolygon[5];
				tmpPoints[4] := aftLocn.myLayout.pointsPolygon[4];
			endif;
		endif;
	endif;	
	
	
	
	// ### SETUP DRAWING FRAME
	_frame.drawStyle := _deckItemLayout.drawLineStyle;
	_frame.drawFillStyle := _deckItemLayout.drawFillStyle;
	_frame.drawFillColor := _deckItemLayout.drawFillColour;
	_frame.drawWidth := _deckItemLayout.drawWidth;
	
	theReq := _deckItemLayout.myRequest;
	if theReq &lt;&gt; null  then
		theDeckItem := theReq.myROROController.getDefn();
		if theDeckItem.isLocnGC() then
			if theDeckItem.isAllReqsInJob(_isLoad) then
				_frame.drawWidth :=  3;
			endif;
		endif;
	endif;


	_frame.drawAPolygon(tmpPoints,true,_deckItemLayout.drawLineColour, _frame.drawWidth, _frame.drawFillColor, scale, theText);
	
	self.drawReqInRectangle(_deckItemLayout.myRequest.myROROController.getDefn(), numTier, _isLoad, has40s, tmpPoints);
	self.drawReqInPolygon(_deckItemLayout, numTier, _isLoad);


	// PAR 28544 ### Draw a thick line around the location IF all of the requests are in a job.
	theReq := _deckItemLayout.myRequest;
	if theReq &lt;&gt; null  then
		theDeckItem := theReq.myROROController.getDefn();
		if theDeckItem.isLocnContainer() 
		or theDeckItem.isLocnLanePosition() then
			if theDeckItem.isAllReqsInJob(_isLoad) then
				self.drawRectangleFromPolygon(_frame, tmpPoints);
			endif;
		endif;
	endif;
epilog
	delete tmpPoints;
	delete allTIs;
end;</source>
        <Parameter name="_deckItemLayout" type="CM_RORORequestLayout"/>
        <Parameter name="_frame" type="CMUI_PointDrawingFrame" usage="input"/>
        <Parameter name="_isLoad" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawPolygonsSequenceSheet" id="7c5e7c9e-5c60-4ac1-8499-6021d6fd234a">
        <source>drawPolygonsSequenceSheet(	deckItemLayout: CM_DeckItemLayout;
							job : CM_VoyageDeckJob;
							allRequests: ObjectArray);
/*

Date		Who		Reason
25 July 2013	cnwer1	Initial creation CCMS 2265

*/

vars
	idx : Integer;
	 ti40 : CM_TrackedItem;
	allTIs ,  all20,all40,
	all40fwd,
	all20aft: CM_TIArray;
	has40s : Boolean;
	theColour : Integer;
	theText : String;
	fwdLocn,
	aftLocn : CM_ROROLocnDefn;
	tmpPoints : PointArray;
	allControllers 	: CM_VoyageROROControllerArray;
	controller		: CM_VoyageROROController;
	wle : CM_WorkListEntry;
	ti : CM_TrackedItem;
	request :	CM_RORORequest;
	gcReq : CM_ROROGCRequest;
	startFontSize : Real;
begin
	if deckItemLayout = null then
		return;
	endif;
		
	if deckItemLayout.myDeckItem = null then
		return;
	endif;
	
	create tmpPoints transient;
	idx :=self.myPointDrawingFrame.allPointGraphics.indexOf(deckItemLayout);
	
	self.myPointDrawingFrame.autoRedraw := true;
	
	has40s := false;	
	ti40 := null;
	gcReq:=null;
	if allRequests.first.isKindOf(CM_ROROGCRequest) then
		gcReq := allRequests.first.CM_ROROGCRequest;
	endif;
	
	//epr par 33775 5/11/14
	if deckItemLayout.is40BackendForJob(job) then
		return;
	endif;
	
	create allControllers transient;
	create all20 transient;
	create all40 transient;
	create all20aft transient;
	create all40fwd transient;
	create allTIs transient;
	if gcReq = null then
		deckItemLayout.myDeckItem.getAllVoyageControllers(allControllers);	
		foreach controller in allControllers do
			request:=null;
			if job.isDischarge then
				request:=controller.myRORORequestDischarge ;
			else
				request:=controller.myRORORequestLoad ;			
			endif;
			
			if request&lt;&gt; null and allRequests.includes(request) then
				foreach wle in  request.allWorkListEntries do
					if wle.myTrackedItem &lt;&gt; null then
						if not wle.myTrackedItem.is20 and wle.myTrackedItem.isKindOf(CM_Container) then
							has40s:=true;
							all40.add(wle.myTrackedItem);
						else
							all20.add(wle.myTrackedItem);
						endif;
					else
						//epr par 32658 14/10/13
						if request.getAttrIs40 or request.getAttrIs45 or request.getAttrIs53 then
							has40s:=true;		
						endif;
					endif;
				endforeach;
				continue;
			endif;
			
			foreach ti in controller.allTrackedItems do
				//epr par 31151 13/2/13 only remain on board show if not CC for discharge &amp; IMEX ROB or IMPORT
				if controller.myRORORequestDischarge &lt;&gt;  null then
					continue;
				endif;
			
				if ti.getImExStatus() &lt;&gt; TI_IMEX_STATUS_REMAINONBOARD and
					ti.getImExStatus() &lt;&gt; TI_IMEX_STATUS_IMPORT then
					continue;
				endif;
				if ti.is20  then
					all20.add(ti);
				else
					all40.add(ti);
					has40s:=true;
				endif;
			endforeach;
		endforeach;
	endif;
	
	
	
	//if has40s then
	allControllers.clear;
	if deckItemLayout.myDeckItem.isKindOf(CM_ROROLocnDefnVoyage) then				
		if  has40s and  deckItemLayout.myDeckItem.CM_ROROLocnDefn.myAdjacentSlotAft  &lt;&gt; null then
			aftLocn := deckItemLayout.myDeckItem.CM_ROROLocnDefnVoyage.getAftLocnDefn();
			deckItemLayout.myDeckItem.CM_ROROLocnDefn.myAdjacentSlotAft.getAllVoyageControllers(allControllers);
		elseif deckItemLayout.myDeckItem.CM_ROROLocnDefn.myAdjacentSlotFwd &lt;&gt; null then
			fwdLocn := deckItemLayout.myDeckItem.CM_ROROLocnDefnVoyage.getFwdLocnDefn();
			deckItemLayout.myDeckItem.CM_ROROLocnDefn.myAdjacentSlotFwd.getAllVoyageControllers(allControllers);
		endif;
		foreach controller in allControllers do
			request:=null;
			if job.isDischarge then
				request:=controller.myRORORequestDischarge ;
			else
				request:=controller.myRORORequestLoad ;			
			endif;
			
			if request&lt;&gt; null  then //and allRequests.includes(request)
				foreach wle in  request.allWorkListEntries do
					if wle.myTrackedItem &lt;&gt; null then
						// if aft locn check fwd loc doesn't have 40s
						if fwdLocn &lt;&gt; null then
							if  not wle.myTrackedItem.is20 then
								all40fwd.add(wle.myTrackedItem);
							endif;
						else
							if  wle.myTrackedItem.is20 then
								all20aft.add(wle.myTrackedItem);
							endif;
						endif;
					endif;
				endforeach;
				continue;
			endif;
	
			foreach ti in controller.allTrackedItems do
				//epr par 31151 13/2/13 only remain on board show if not CC for discharge &amp; IMEX ROB or IMPORT
				if controller.myRORORequestDischarge &lt;&gt;  null then
					continue;
				endif;
			
				if ti.getImExStatus() &lt;&gt; TI_IMEX_STATUS_REMAINONBOARD and
					ti.getImExStatus() &lt;&gt; TI_IMEX_STATUS_IMPORT then
					continue;
				endif;
				if fwdLocn &lt;&gt; null then
					// if aft locn check fwd loc doesn't have 40s
					if  not ti.is20 then
						all40fwd.add(ti);
					endif;
				else
					if ti.is20  then
						all20aft.add(ti);
					endif;
				endif;
			endforeach;
		endforeach;		
		
	endif;

	all20.copy(allTIs);
	all40.copy(allTIs);
	
	theText := null;
	theColour := allRequests.first.CM_VoyageRequest.getAllocationColour;
	self.myPointDrawingFrame.drawFillStyle := self.myPointDrawingFrame.allFillStyles[idx];
	self.myPointDrawingFrame.drawWidth := self.myPointDrawingFrame.allDrawWidths[idx];

	if self.myPointDrawingFrame.showText  then
		theText := self.myPointDrawingFrame.allTexts[idx];	
	endif;
	
	if gcReq &lt;&gt; null then
		theText:=null;
		self.myPointDrawingFrame.drawFillColor :=theColour;
		theColour:=Black;//theColour.getInverseColour;
		myPointDrawingFrame.drawStyle:=Window.DrawStyle_Solid;
	else
		self.myPointDrawingFrame.drawFillColor := self.myPointDrawingFrame.allFillColours[idx];
		myPointDrawingFrame.drawStyle:=Window.DrawStyle_Dash;
	endif;
		
	tmpPoints.clear();
	deckItemLayout.pointsPolygon.copy(tmpPoints);
	
	if has40s then
		if aftLocn &lt;&gt; null then
			if aftLocn.isVerticalOrientation() then
				tmpPoints[1] := aftLocn.myLayout.pointsPolygon[1];
				tmpPoints[5] := aftLocn.myLayout.pointsPolygon[5];
				tmpPoints[2] := aftLocn.myLayout.pointsPolygon[2];
			else
				tmpPoints[1] := aftLocn.myLayout.pointsPolygon[1];
				tmpPoints[5] := aftLocn.myLayout.pointsPolygon[5];
				tmpPoints[4] := aftLocn.myLayout.pointsPolygon[4];
			endif;
		endif;
	else
		if  all40fwd.size &gt; 1 then
			return;
		endif;
	endif;
	
	//write theText &amp; " " &amp; has40s.String &amp; " " &amp; all20aft.size.String &amp; " " &amp; allTIs.size.String;
	myPointDrawingFrame.drawAPolygon(tmpPoints,true,theColour, 2,self.myPointDrawingFrame.drawFillColor , self.scaleFactor, theText);
	startFontSize:=myPointDrawingFrame.drawFontSize;
	if  gcReq &lt;&gt; null then
		//epr par 32929 7/11/13
		self.drawGCForSequenceSheet(gcReq.myLayout,job,gcReq);
	else
		if not all20aft.isEmpty then
			
			self.drawContainersForSequenceSheet(deckItemLayout,aftLocn.myLayout.pointsPolygon, all20aft,job);
			//epr par 33065 29/11/13 reset the font size to what it was after the layout id was drawn
			myPointDrawingFrame.drawFontSize:=startFontSize;
			if not allTIs.isEmpty() then
				self.drawContainersForSequenceSheet(deckItemLayout,deckItemLayout.pointsPolygon, allTIs,job);
			endif;
		else
			if not allTIs.isEmpty() then
				self.drawContainersForSequenceSheet(deckItemLayout,tmpPoints, allTIs,job);
			endif;
		endif;
	endif;

	// 31569 Is the rotation master, draw a red dot.
	if deckItemLayout.getDeckItem() &lt;&gt; null then
		deckItemLayout.getDeckItem().drawRotationMasterMark(myPointDrawingFrame, self.scaleFactor);
	endif;
	
epilog
	delete tmpPoints;
	delete allControllers;
	delete all20 ;
	delete all40 ;
	delete all20aft ;
	delete allTIs;
end;</source>
        <Parameter name="deckItemLayout" type="CM_DeckItemLayout"/>
        <Parameter name="job" type="CM_VoyageDeckJob"/>
        <Parameter name="allRequests" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="drawRectangleFromPolygon" id="8e5382d8-1093-49fc-a37e-87807cc870f7">
        <source>drawRectangleFromPolygon(_theFrame : Frame input; _tmpPoints : PointArray);
/*
Purpose:			
Date		Who		Reason
05 December 2011	cnwab1	Initial creation
*/

vars
	x1,y1,x2,y2 : Real;
begin

	// ### Rectangles only
	if _tmpPoints.size &lt; 4 or _tmpPoints.size &gt; 5 then
		return;
	endif;
	
	if _theFrame = null then
		return;
	endif;
	
	x1 := (_tmpPoints[1].x + 2) * self.scaleFactor;
	y1 := (_tmpPoints[1].y + 2) * self.scaleFactor;
	x2 := (_tmpPoints[3].x - 1) * self.scaleFactor;
	y2 := (_tmpPoints[3].y - 1) * self.scaleFactor;
	
	_theFrame.drawWidth := 2;
	_theFrame.drawRectangle(x1,y1,x2,y2,Black);
	
	
	
epilog

end;</source>
        <Parameter name="_theFrame" type="Frame" usage="input"/>
        <Parameter name="_tmpPoints" type="PointArray"/>
    </JadeMethod>
    <JadeMethod name="drawReqInPolygon" id="2adb2969-30a0-4a24-96d0-a8bd8cfb29eb">
        <updating/>
        <source>drawReqInPolygon(_reqLayout : CM_RORORequestLayout;  _numTier : Integer; _isLoad : Boolean) updating;
/*
Purpose:			
Date		Who		Reason
10 June 2011	cnwab1	Initial creation
*/

vars
	//cnwmc5
	xx1, yy1, xx2, yy2 : Integer;
	
	x1, y1, x2, y2, dlrOffset : Integer;
	xs1, ys1, xs2, ys2 : Real; // to scale
	xd1 : Real; // for drawing
	  qty : Real;
	aPoint : Point;
	aColour, iconColour : Integer;
	locnDefn : CM_DeckItem;
	gcDefn : CM_ROROGCDefnVoyage;
	deckItemLayout : CM_DeckItemLayout;
	req : CM_RORORequest;
	myDrawingFrame : CMUI_PointDrawingFrame;
	jobStr : String;
	scale : Decimal[12,2];
begin
	myDrawingFrame := self.myPointDrawingFrame;
	myDrawingFrame.drawTextRotation := 0;
	myDrawingFrame.drawTextCharRotation := 0;
	
	if _reqLayout = null then
		return;
	endif;
	locnDefn := _reqLayout.myRequest.myROROController.getDefn(); //deckItem.CM_ROROGCDefnVoyage;

	if not locnDefn.isLocnGC() then
		if locnDefn.isLocnLane() then
			self.drawReqInPolygonLane(_reqLayout, 0, _isLoad);
		endif;
		return;
	endif;
	gcDefn := locnDefn.CM_ROROGCDefnVoyage;
	deckItemLayout := _reqLayout;
	if deckItemLayout.myPolygonPixels.isEmpty() then
		return;
	endif;

	// PAR 30092
	scale := self.scaleFactor;
	if scale &lt;= 0 then
		scale := 1;
	endif;
	
	
	// Draw the TI Rectangles in side the polygon in the top left corner
	// Work out the top Y and draw to the lowest of the first 2 Ys
	
	aPoint := deckItemLayout.getExtremePoint(CM_Graphic.Position_Left);
	x1 := aPoint.x;
	aPoint := deckItemLayout.getExtremePoint(CM_Graphic.Position_Top);
	y1 := aPoint.y;
	
	// PAR 30092
	xs1 := x1 * scale;
	ys1 := y1 * scale;
	xs2 := x2 * scale;
	ys2 := y2 * scale;

	xd1 := xs1 + 2;
	
	if _isLoad then
		req := gcDefn.myGCController.myRORORequestLoad;
	else
		req := gcDefn.myGCController.myRORORequestDischarge;
	endif;
	
	if req = null then
		return;
	endif;
	
	if req.isSoB or req.isRehandle then // PAR 28330
		if req.isRehandle then
			aColour := self.COLOUR_DLR;
		elseif req.isSoB then
			aColour := self.COLOUR_SOB;
		endif;
		myDrawingFrame.drawFillColor := aColour;
		dlrOffset := 20;
		myDrawingFrame.drawFilledRectangle(xs1 + 3, ys1 + 3, xs1 + dlrOffset, ys1 + dlrOffset, White); // PAR 30092 - use xs1 and ys1
	endif;
	
	//cnwmc5
	deckItemLayout.myPolygonPixels.getExtremesForText(xx1,yy1,xx2,yy2);
	
	//cnwmc5 - PAR 31375 - added in scale factor
	xx1 := (xx1 * scale).Integer;
	yy1 := (yy1 * scale).Integer;
	xx2 := (xx2 * scale).Integer;
	yy2 := (yy2 * scale).Integer;
	
	aColour := req.getAllocationColour();
	iconColour := aColour.getInverseColour();
	myDrawingFrame.drawFillColor := aColour;
	myDrawingFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
	myDrawingFrame.drawFontSize := 8.5; // PAR 29923
		
	//cnwmc5
	myDrawingFrame.drawTextAt(req.getAllocationName(),xx1, yy1,iconColour);
	
	ys1 := ys1 + 15;
	
	//cnwmc5
	myDrawingFrame.drawTextAt(req.myLayout.getAreaInSquareMetresDisplay(),xx1, yy1+13,iconColour);
	
	ys1 := ys1 + 15;
	qty := req.quantity.max(1); // do not show zero
						
	//cnwmc5
	myDrawingFrame.drawTextAt(app.getErrorString(CM_Quantity) &amp; " " &amp; qty.asStringJMTWithPrecision(0,true) &amp; " (" &amp; 
						"P " &amp; req.getNumTIsOfMode(PLANNING_MODE, true).String &amp; ")  (" &amp; 
						"A " &amp; gcDefn.myGCController.getTotalQuantityActual().asStringJMT  &amp; ")"  //epr par 36305 19/6/15
						,xx1, yy1+26,iconColour);
						
	ys1 := ys1 + 15;
	
	if req.myJob &lt;&gt; null then
		jobStr :=  req.myJob.CM_VoyageJob.jobNum &amp; "/" &amp; req.numSeqAft.String; // PAR 28349
		if req.myJob.isJobComplete() then
			jobStr := jobStr &amp; " (C)";
		endif;
		if req.myJob.myJobSheet &lt;&gt; null then
			jobStr := jobStr &amp; " (" &amp; req.myJob.myJobSheet.myWorkPoint.code &amp; ")";
		endif;
		//cnwmc5
		myDrawingFrame.drawTextAt(app.getErrorString(Job) &amp; " " &amp; jobStr ,xx1, yy1+39,iconColour);
		ys1 := ys1 + 15;
	
	endif;

	if req &lt;&gt; null then
		self.drawIcons(null, req, myDrawingFrame, xd1, ys1 + 8, iconColour, true);
		
		// DRAW BLACK MARK FOR COMPLETE REQUEST
		if req.isComplete then
			myDrawingFrame.drawFillColor := Black;
			myDrawingFrame.drawFilledRectangle(xd1 + 1, ys1 +5, xd1+4, ys1+8, Black);
		endif;
		
		// DRAW GREEN MARK FOR LINKED REQUEST
		if (self.modeView = ShpDisplayMode_ColCodeLoad) then
			if req.myRequestLinkedDischarge &lt;&gt; null  then
				myDrawingFrame.drawFillColor := LightGreen;
				myDrawingFrame.drawFilledRectangle(xd1 + 6, ys1 +5, xd1+9, ys1+8, LightGreen);
			endif;
		endif;
		if (self.modeView = ShpDisplayMode_ColCodeDisch) then
			if req.myRequestLinkedLoad &lt;&gt; null  then
				myDrawingFrame.drawFillColor := LightGreen;
				myDrawingFrame.drawFilledRectangle(xd1 + 6, ys1 +5, xd1+9, ys1+8, LightGreen);
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_reqLayout" type="CM_RORORequestLayout"/>
        <Parameter name="_numTier" type="Integer"/>
        <Parameter name="_isLoad" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawReqInPolygonLane" id="0e3e89a3-1f43-42ed-8aed-c7cc8790f184">
        <updating/>
        <source>drawReqInPolygonLane(_reqLayout : CM_RORORequestLayout;  _numTier : Integer; _isLoad : Boolean) updating;
/*
Purpose:			
Date		Who		Reason
10 June 2011	cnwab1	Initial creation
*/

vars
	x1, y1, x2, y2, dlrOffset : Integer;
	xs1, ys1, xs2, ys2 : Real; // to scale
	xd1, yd1 : Real; // for drawing
	len, hite, qty : Real;
	aPoint : Point;
	aColour, iconColour : Integer;
	locnDefn : CM_DeckItem;
//	laneDefn : CM_ROROLanePositionDefn;	//17 Jul 2018	NDL	TFS 39254 - never used ???
	deckItemLayout : CM_DeckItemLayout;
	req : CM_RORORequest;
	aWLE : CM_WorkListEntry;
	myDrawingFrame : CMUI_PointDrawingFrame;
	jobStr, lineStr : String;
begin
	myDrawingFrame := self.myPointDrawingFrame;
	myDrawingFrame.drawTextRotation := 0;
	myDrawingFrame.drawTextCharRotation := 0;
	
	if _reqLayout = null then
		return;
	endif;
	locnDefn := _reqLayout.myRequest.myROROController.getDefn(); //deckItem.CM_ROROlaneDefnVoyage;

	if not locnDefn.isLocnLane() then
		return;
	endif;
	
//	laneDefn := locnDefn.CM_ROROLanePositionDefn; //17 Jul 2018	NDL	TFS 39254 - incorrect cast, and never used ???
	deckItemLayout := _reqLayout;
	if deckItemLayout.myPolygonPixels.isEmpty() then
		return;
	endif;
	
	// Draw the TI Rectangles in side the polygon in the top left corner
	// Work out the top Y and draw to the lowest of the first 2 Ys
	aPoint := deckItemLayout.myPolygonPixels[1];
	x1 := aPoint.x;
	y1 := aPoint.y;
	aPoint := deckItemLayout.myPolygonPixels[2];
	x2 := aPoint.x;
	y2 := aPoint.y;
	
	if y2 &gt; y1 then
		y1 := y2;
	endif;
	aPoint := deckItemLayout.myPolygonPixels[deckItemLayout.myPolygonPixels.size - 1];
	x2 := aPoint.x;
	y2 := aPoint.y;
	if x2 &gt; x1 then
		x1 := x2;
	endif;
	
	xs1 := x1 * self.scaleFactor;
	ys1 := y1 * self.scaleFactor;
	xs2 := x2 * self.scaleFactor;
	ys2 := y2 * self.scaleFactor;
	

	len := 20;
	
	xd1 := xs1 + 5;
	req := _reqLayout.myRequest;
/*	
	if _isLoad then
		req := laneDefn.myLaneController.myRORORequestLoad;
	else
		req := laneDefn.myLaneController.myRORORequestDischarge;
	endif;
	*/
	if req = null then
		return;
	endif;
	
	if req.isSoB or req.isRehandle then // PAR 28330
		if req.isRehandle then
			aColour := self.COLOUR_DLR;
		elseif req.isSoB then
			aColour := self.COLOUR_SOB;
		endif;
		myDrawingFrame.drawFillColor := aColour;
		dlrOffset := 20;
		myDrawingFrame.drawFilledRectangle(x1 + 3, y1 + 3, x1 + dlrOffset, y1 + dlrOffset, White);
	endif;
	
	
	
	aColour := req.getAllocationColour();
	iconColour := aColour.getInverseColour();
	myDrawingFrame.drawFillColor := aColour;
	myDrawingFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
	
	lineStr := req.getAllocationName();
	myDrawingFrame.drawTextAt(lineStr,xd1 + dlrOffset, ys1 + 2,iconColour);
	
	
	ys1 := ys1 + 12;
	qty := req.quantity.max(1); // do not show zero
	if req.myJob &lt;&gt; null then
		jobStr :=  req.myJob.CM_VoyageJob.jobNum &amp; "/" &amp; req.numSeqAft.String; // PAR 28349
		if req.myJob.isJobComplete() then
			jobStr := jobStr &amp; " (C)";
		endif;
		if req.myJob.myJobSheet &lt;&gt; null then
			jobStr := jobStr &amp; " (" &amp; req.myJob.myJobSheet.myWorkPoint.code &amp; ")";
		endif;
		jobStr := app.getErrorString(Job) &amp; " " &amp; jobStr;
	endif;
	
	lineStr := app.getErrorString(Length_Title) &amp; " " &amp; req.myLayout.getLengthInMetres().asStringJMTWithPrecision(0,true) &amp; "m " &amp; 
		app.getErrorString(Qty) &amp; " " &amp; qty.asStringJMTWithPrecision(0,true) &amp; " (" &amp; 
						"P " &amp; req.getNumTIsOfMode(PLANNING_MODE, true).String &amp; ")  (" &amp; 
						"A " &amp; req.getNumTIsOfMode(REAL_MODE, true).String &amp; ") " &amp; 
						jobStr;
	myDrawingFrame.drawTextAt(lineStr,xd1, ys1 + 5,iconColour);
	
	
	ys1 := ys1 + 12;
	
	if req &lt;&gt; null then
//		self.drawIcons(null, req, myDrawingFrame, xd1, ys1 + 8, iconColour, true);
		
		// DRAW BLACK MARK FOR COMPLETE REQUEST
		if req.isComplete then
			myDrawingFrame.drawFillColor := Black;
			myDrawingFrame.drawFilledRectangle(xd1 + 1, ys1 +5, xd1+4, ys1+8, Black);
		endif;
		
		// DRAW GREEN MARK FOR LINKED REQUEST
		if (self.modeView = ShpDisplayMode_ColCodeLoad) then
			if req.myRequestLinkedDischarge &lt;&gt; null  then
				myDrawingFrame.drawFillColor := LightGreen;
				myDrawingFrame.drawFilledRectangle(xd1 + 6, ys1 +5, xd1+9, ys1+8, LightGreen);
			endif;
		endif;
		if (self.modeView = ShpDisplayMode_ColCodeDisch) then
			if req.myRequestLinkedLoad &lt;&gt; null  then
				myDrawingFrame.drawFillColor := LightGreen;
				myDrawingFrame.drawFilledRectangle(xd1 + 6, ys1 +5, xd1+9, ys1+8, LightGreen);
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_reqLayout" type="CM_RORORequestLayout"/>
        <Parameter name="_numTier" type="Integer"/>
        <Parameter name="_isLoad" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawReqInRectangle" id="5971da3e-e3ca-4f62-86e1-d4e8d6f067e7">
        <updating/>
        <source>drawReqInRectangle(_deckItem : CM_DeckItem;  _numTier : Integer; _isLoad : Boolean; _has40s : Boolean; _tmpPoints : PointArray) updating;
/*
Purpose:			
Date		Who		Reason
10 June 2011	cnwab1	Initial creation
*/
//18 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
//26 Feb 2014  epr par 33066 for printing the scale is calculated to fit page, drawing Req was not considering the scale
// 11/10/2022	navkc1	Bug 54935: MSL - Roro planning - Slow on big decks/large vessels
vars
	x1, y1, x2, y2, numTier : Integer;
	xs1, ys1, xs2, ys2 : Real; // to scale
	xd1, yd1 : Real; // for drawing
	len, hite,tiLen : Real;
	aTI : CM_TrackedItem;
	iconColour, aColour : Integer;
	obj : Object;
	locnDefn : CM_ROROLocnDefnVoyage;
	deckItemLayout : CM_DeckItemLayout;
	slotDefn : CM_ROROSlotDefnVoyage;
	req, otherReq : CM_RORORequest;
	myDrawingFrame : CMUI_PointDrawingFrame;
	slotsInOrder : ObjectArray;
	isHorizontal, is40 : Boolean;
	scale : Real;
	mySlotController	: CM_ROROSlotController;
	hasROB	: Boolean;
begin
	if _numTier = 0 then
		return;
	endif;
	
	scale:=self.scaleFactor;
	//26/2/2014 33066 its too small to really see the boxes drawn add 20%
	if scale &lt; 0.5 then
		scale:=scale*1.6;
	endif;
	
	myDrawingFrame := self.myPointDrawingFrame;
	myDrawingFrame.drawTextRotation := 0;
	myDrawingFrame.drawTextCharRotation := 0;
	myDrawingFrame.drawWidth := 1; // PAR 28787
	if _deckItem = null then
		return;
	endif;

	if not _deckItem.isLocnContainer() then
		return;
	endif;

	create slotsInOrder transient;
	
	numTier := _numTier;
	locnDefn := _deckItem.CM_ROROLocnDefnVoyage;
	deckItemLayout := locnDefn.myLayout;

	x1 := 9999999;
	y1 := 9999999;

	if locnDefn.isVerticalOrientation() then
		x1 := _tmpPoints[1].x;
		y1 := _tmpPoints[1].y;
		x2 := _tmpPoints[2].x;
		y2 := _tmpPoints[3].y;
	else
		x1 := _tmpPoints[1].x;
		y1 := _tmpPoints[1].y;
		x2 := _tmpPoints[2].x;
		y2 := _tmpPoints[3].y;
	endif;

	
	xs1 := x1 * self.scaleFactor;
	ys1 := y1 * self.scaleFactor;
	xs2 := x2 * self.scaleFactor;
	ys2 := y2 * self.scaleFactor;

	len := xs2-xs1;
	hite := ys2-ys1;
	if _has40s then
		numTier := numTier * 2;
	endif;

	self.drawSortReqs(slotsInOrder, locnDefn, _has40s, _isLoad, not locnDefn.isVerticalOrientation()); // PAR 28883

	// PAR 28849 - set the icon colour based on the current drawing fill. We have just drawn the rectangle for the request so this should be the colour of that request
	aColour := myDrawingFrame.drawFillColor;
	iconColour := aColour.getInverseColour();
	
	// PAR 29897 - in 812 we now have 1 set of code for the drawing
	isHorizontal		:= (len &gt; hite);
	
	// HORIZONTAL
	if isHorizontal then

		len := (len / numTier);
		len := len - (2 * scale); // PAR 29164
		
		xd1 := xs1 + (4 * scale);
	else
		hite := (hite / numTier);
		hite := hite - (2 * scale); // PAR 29164
		
		// PAR 28900 yd1 := ys1 + 2;
		yd1 := ys2 - (2* scale);
		xd1 := xs1 + (2*scale);			
	endif;

	// PAR 28900 foreach slotDefn in slotsToDraw discreteLock do // PAR 28746 locnDefn.allROROSlotDefnByOrdinal discreteLock do
	foreach obj in slotsInOrder  discreteLock do
		slotDefn := obj.CM_ROROSlotDefnVoyage;
		
		mySlotController := slotDefn.mySlotController;  // 11/10/2022	navkc1	#54935
		
		if _isLoad then
			req := mySlotController.myRORORequestLoad;
		else
			req := mySlotController.myRORORequestDischarge;
		
			// PAR 32021 When a rotated load becomes the actual, we create 'empty' discharge CC layouts for the unused slots in the discharge view.
			// These should draw as empty white rectangles.
			if locnDefn.isPlannedRotated
			and req &lt;&gt; null and self.modeViewSubSub = ShpDisplayModeSub_ExportsHide then // PAR 32021
				if req.isDischarge
				and req.allAllocations.isEmpty() then
					return;
				endif;
			endif;
		endif;
		
				
		if self.modeViewSubSub = ShpDisplayModeSub_ExportsShow and not _isLoad then // PAR 31162
			otherReq := mySlotController.myRORORequestLoad;
			if otherReq  &lt;&gt; null then
				if otherReq.isComplete // Completed FWD
				or (otherReq.getAttrIsBackend() and otherReq.CM_ROROSlotRequest.mySlotRequestForward.isComplete) then // PAR 31162 AFT not completed so check fwd
					req := null;
				endif;
			endif;
		endif;
		
		tiLen := (len);
		if req &lt;&gt; null then
			if req.allAllocations.isEmpty() then // PAR 28883
				 // PAR 29807 return; // PAR 28883
				continue; // PAR 29807
			endif;
			if req.isBackEndRequest() then // PAR 28746
				continue;
			endif;
			
//			is40 := (req.getAttrIs40() or req.getAttrIs30() or req.getAttrIs45() or req.getAttrIs53()); // PAR 30022 
			is40 := req.getAttrIsNOT20(); // PAR 30253
			if is40 then // PAR 30022 
		//	if req.getAttrIs40() then
				if isHorizontal then
					tiLen := (len * 2);
				else
					tiLen := (hite * 2);
				endif;
			else // PAR 30092
				if isHorizontal then
					tiLen := len;
				else
					tiLen := hite;
				endif;
			
			endif;
			aColour := req.getAllocationColour();
			if req.isRehandle then
				aColour := self.COLOUR_DLR;
			elseif req.isSoB then
				aColour := self.COLOUR_SOB;
			endif;
		else
			hasROB := mySlotController.hasROB(false); // 11/10/2022	navkc1	#54935
			// PAR 29050
			if hasROB  // 11/10/2022	navkc1	#54935 
			// PAR 29897 - Always show actual Exports over discharge CC
			or (not _isLoad 
				and (mySlotController.myRORORequestLoad &lt;&gt; null and mySlotController.myRORORequestLoad.isComplete)) then
			
			
				aTI := mySlotController.allTrackedItems.first();
				if aTI &lt;&gt; null // PAR 30342
				and aTI.myPrimaryActualLocation = mySlotController then
					aColour := aTI.getDrawingColour(TI_ColourMode_DischargePort);
					myDrawingFrame.drawFillColor := aColour;
					myDrawingFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
					
					if not aTI.isTwenty() then
						if isHorizontal then
							tiLen := (len * 2);
						else
							tiLen := (hite * 2);
						endif;
					else // PAR 30092
						if isHorizontal then
							tiLen := len;
						else
							tiLen := hite;
						endif;
					endif;
					
					if isHorizontal then
						//if slotDefn.mySlotController.hasROB(false)  then
						if hasROB  then  // 14/10/2022	navkc1	#54935
							myDrawingFrame.drawFilledRectangle(xd1, ys1 + (6*scale), xd1 + tiLen + (2*scale), ys1 + (15*scale),aColour);
						// PAR 29897 - Always show actual Exports over discharge CC
						else
							myDrawingFrame.drawFilledRectangle(xd1, ys1 + (2*scale), xd1 + tiLen + (2*scale), ys2 -(2*scale),aColour);
						endif;
						xd1 := xd1 + tiLen + (4*scale);
					else
						//if slotDefn.mySlotController.hasROB(false)  then
						if hasROB  then  // 14/10/2022	navkc1	#54935
							myDrawingFrame.drawFilledRectangle(xd1 + (6*scale), yd1, xd1+(15*scale),yd1 - tiLen,aColour); 
						else
							myDrawingFrame.drawFilledRectangle(xd1 + (2*scale), yd1, xs2-(3*scale),yd1 - tiLen,aColour); 
						endif;
						yd1 := yd1 - tiLen - (2*scale); 
					
					endif;
				endif;
			endif;

			continue; // PAR 28900
		endif;
		myDrawingFrame.drawFillColor := aColour;
		myDrawingFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
		//global.cnwer1Write(tiLen.String);
		if isHorizontal then
			myDrawingFrame.drawFilledRectangle(xd1 , ys1 + (4* scale), xd1 + tiLen, ys1 + (9* scale),iconColour);// PAR 28990 added 2 pixels to put a gap if there is a job line
		else
			myDrawingFrame.drawFilledRectangle(xd1 + (2* scale), yd1, xd1+(7* scale),yd1 - tiLen,iconColour); // PAR 28748
		endif;
		
		if req &lt;&gt; null then
			aTI := req.getTrackedItem();
			// PAR 31073 noticed that if a DLR was planned load, it also showed as planned in discharge mode, so a null 'aTI' makes it use the request details
			if aTI &lt;&gt; null and (aTI.isRehandle or aTI.isSOB) then
				aTI := null;
			endif;
			
			if self.scaleFactor &gt; 0.5 then
				if isHorizontal then
					self.drawIcons(aTI, req, myDrawingFrame, xd1, ys1 + (8*scale), iconColour, true);
				else
					self.drawIcons(aTI, req, myDrawingFrame, xd1 + (8*scale), yd1 - tiLen, iconColour, false); //epr par 29647 31/5/12
				endif;
			endif;
			
			if (self.modeView = ShpDisplayMode_ColCodeLoad or self.modeView = ShpDisplayMode_ColCodeDisch) then 
				// DRAW BLACK MARK FOR COMPLETED WLE
				if req.isComplete  then
					myDrawingFrame.drawFillColor := Black;
					if isHorizontal then
						myDrawingFrame.drawFilledRectangle(xd1 + (2*scale), ys2 - (6*scale), xd1+(5*scale), ys2-(3*scale), Black);
					else
						myDrawingFrame.drawFilledRectangle(xs2-(4*scale), yd1 - (6*scale), xs2-(7*scale), yd1 - (9*scale), Black); // PAR 29050
					
					endif;
				endif;
			endif;
			// DRAW GREEN MARK FOR LINKED REQUEST
			if (self.modeView = ShpDisplayMode_ColCodeLoad) then
				if req.myRequestLinkedDischarge &lt;&gt; null  then
					myDrawingFrame.drawFillColor := LightGreen;
					if isHorizontal then
						myDrawingFrame.drawFilledRectangle(xd1 + (7*scale), ys2 - (6*scale), xd1+(10*scale), ys2-(3*scale), LightGreen);
					else
						myDrawingFrame.drawFilledRectangle(xs2-(4*scale), yd1 -(1*scale), xs2-(7*scale), yd1 - (4*scale), LightGreen); // PAR 29050
					endif;
				endif;
			endif;
			if (self.modeView = ShpDisplayMode_ColCodeDisch) then
				if req.myRequestLinkedLoad &lt;&gt; null  then
					myDrawingFrame.drawFillColor := LightGreen;
					if isHorizontal then
						myDrawingFrame.drawFilledRectangle(xd1 + (7*scale), ys2 - (6*scale), xd1+(10*scale), ys2-(3*scale), LightGreen);
					else
						myDrawingFrame.drawFilledRectangle(xs2-(4*scale), yd1 - (1*scale), xs2-(7*scale), yd1 - (4*scale), LightGreen); // PAR 29050
					endif;
				endif;
			endif;
		endif;
		if isHorizontal then
			xd1 := xd1 + tiLen + (2*scale); // PAR 29133
		else
			yd1 := yd1 - tiLen - (2* scale);  // PAR 29133
		endif;
	endforeach;

	// PAR 28886
	if locnDefn.isOOTL  and not locnDefn.allPlannedRotatedLocnDefns.isEmpty() then
	//  PAR 29990 - only the master. and locnDefn.isPlannedRotated then
		myDrawingFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
		myDrawingFrame.drawFillColor := Red;
		myDrawingFrame.drawEllipse(xs2 - (7*scale), ys2 - (7*scale), xs2 - (2*scale), ys2 - (2*scale),Red); 
	
	endif;
epilog
//	delete slotsToDraw;
	delete slotsInOrder;
end;</source>
        <Parameter name="_deckItem" type="CM_DeckItem"/>
        <Parameter name="_numTier" type="Integer"/>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_has40s" type="Boolean"/>
        <Parameter name="_tmpPoints" type="PointArray"/>
    </JadeMethod>
    <JadeMethod name="drawReqInRectangleOLD" id="42ebee0a-606b-42e6-a939-01401ddd2184">
        <updating/>
        <source>drawReqInRectangleOLD(_deckItem : CM_DeckItem;  _numTier : Integer; _isLoad : Boolean; _has40s : Boolean; _tmpPoints : PointArray) updating;

// NOT USED DELETE

//18 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed






























/*
Purpose:			
Date		Who		Reason
10 June 2011	cnwab1	Initial creation
