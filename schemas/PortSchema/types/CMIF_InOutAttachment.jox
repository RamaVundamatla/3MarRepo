        <updating/>
        <source>setLog(_terminal : CM_Terminal; _cargoType : Integer; _id : String; _sedMax, _sedMin : Decimal; _condition :String) updating;
//--------------------------------------------------------------
//Created: 01 February 2002 By: cnwgd1
