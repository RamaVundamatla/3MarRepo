    <DbClassMap file="basemap"/>
    <JadeMethod name="create" id="6c0ececc-775e-4167-be1e-3c5038bb44ff">
        <lockReceiver/>
        <updating/>
        <source>create() lockReceiver, updating;
// --------------------------------------------------------------------------------
// Created:		31 March 2001 by cnwdad1
//
// Purpose:		Add all key codes that are used by BaseSchema custom controls.
//				Use this array with the Window.registerFormKeys method for thin
//				clients to register the key codes that your application is trapping
//				at run-time.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Add BaseSchema key code constants.
	
	self.add(CNEC_KEY_ARROWDOWN);
	self.add(CNEC_KEY_ARROWLEFT);
	self.add(CNEC_KEY_ARROWRIGHT);
	self.add(CNEC_KEY_ARROWUP);
	self.add(CNEC_KEY_END);
	self.add(CNEC_KEY_F12);
	self.add(CNEC_KEY_HOME);
	self.add(CNEC_KEY_PAD0);
	self.add(CNEC_KEY_PAD1);
	self.add(CNEC_KEY_PAD2);
	self.add(CNEC_KEY_PAD3);
	self.add(CNEC_KEY_PAD4);
	self.add(CNEC_KEY_PAD5);
	self.add(CNEC_KEY_PAD6);
	self.add(CNEC_KEY_PAD7);
	self.add(CNEC_KEY_PAD8);
	self.add(CNEC_KEY_PAD9);
	self.add(CNEC_KEY_PAGEDOWN);
	self.add(CNEC_KEY_PAGEUP);
	
	// Now add JADE key code constants that are used by BaseSchema controls.
	
	self.add(J_key_0);
	self.add(J_key_1);
	self.add(J_key_2);
	self.add(J_key_3);
	self.add(J_key_4);
	self.add(J_key_5);
	self.add(J_key_6);
	self.add(J_key_7);
	self.add(J_key_8);
	self.add(J_key_9);
	self.add(J_key_Back);
	self.add(J_key_Space);
	self.add(J_key_Stop);
	
	self.cnEcSort(false);
end;</source>
    </JadeMethod>
</CollClass>
