    <JadeMethod name="getStringForTable" id="c95e7f23-f956-4af8-8082-67bc02695d5e">
        <source>getStringForTable() : String;
// ---------------------------------------------------------------------------
// Created:		23 May 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// PAR 22125 changed CM_Decimal1LeadingZero to CM_Decimal2LeadingZero
// 23/5/16 cnwmp6 TFS 488 - Multi timezone support


vars
	colStr : String;
begin
	colStr := self.systemToLocalTime(self.shiftStartTS).shortCurrentLocaleFormat() &amp; Tab &amp; 
				self.systemToLocalTime(self.shiftEndTS).shortCurrentLocaleFormat() &amp; Tab &amp; 
				self.shiftDescription &amp; Tab &amp; 
				"" &amp; Tab &amp; // GAP 1
				self.movesTI.String &amp; Tab &amp; 
				self.movesTEU.asStringJMTWithPrecision(1,false) &amp; Tab &amp; 
				self.movesLid.String &amp; Tab &amp; 
				"" &amp; Tab &amp; // GAP 2
				self.hoursGross.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).String &amp; Tab &amp; 
				self.hoursDown.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).String &amp; Tab &amp; //04 Apr 2012	NDL	Par 29369
				self.hoursDelay.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).String &amp; Tab &amp; 
				//self.hoursNet.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).String &amp; Tab &amp; 
				self.getHoursNetLessDownTime.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).String &amp; Tab &amp; //04 Apr 2012	NDL	Par 29369
				"" &amp; Tab &amp; // GAP 3
				self.tiGrossRate.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).String &amp; Tab &amp; Tab &amp;
				self.tiNetRate.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).String &amp; Tab &amp; Tab &amp;
				"" &amp; Tab &amp; // GAP 4
				self.liftMinPerHour.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).String  &amp; Tab &amp; Tab &amp;
				self.liftMaxPerHour.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).String;
	return colStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTotalMoves" id="daa55da3-3de3-4266-ad83-72d33cc5e864">
        <source>getTotalMoves():Integer;
/*
Date		Who		Reason
31 Jul 2008	concms1	Initial creation
27/03/2013	cnwcs5	Re-work to get around not having a crane reference
*/

vars
	result		:Integer;
	jobSheet	:CM_VoyageJobSheet;
begin
	
	result := result + self.getTotalContainers +
					self.getDLRAllItems + 
					self.getSOBAllItems +
					self.movesLid.Integer;

	// only for first KPI for this crane and the first crane for this voyage
	// cos lashings and bin nums are stored on the voyage not the crane job sheet
	jobSheet	:= self.myJobSheet;
		
	if jobSheet &lt;&gt; null then
		if self.myVoyage.allJobSheetsInOrder.first = jobSheet then
			// first crane for the voyage - now we need to make sure we only count lashing bin moves for
			// the first KPI for the job sheet
			if jobSheet.allVoyageKPICraneShifts.indexOf(self) = 1 then
				result := result + self.getNumLashingBinMoves;
			endif;
		endif;
	endif;
	
	return result;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
