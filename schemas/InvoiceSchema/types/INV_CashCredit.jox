    <JadeMethod name="tblCharges_dblClick" id="aa26f3f0-1c5e-44a5-a575-729554c7413b">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCharges_dblClick(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 December 2012	cnwer1	Initial creation HAT 2189
23 Jul 2019	jlgsl4	TFS 44274 - Cash Credit
*/

vars
	obj		: Object;
begin
	// 32974 access to cargo enquiry for extra free storage days (and anything else like this)
	if table.column = 1 then
		
		obj := table.accessCell(table.row, table.column).itemObject;
		if obj &lt;&gt; null then 
			if obj.isKindOf(CM_TrackedItem)  then
				self.myAssistant.myTerminal := self.myTerminal;			//  needs setting for cash receipt enquiry
				self.myAssistant.showCargoEnquiryForm(obj.CM_TrackedItem, self.myMasterMenuAction, false, false);	
				return;
			endif;
		endif;
	endif;
	// inspect the cash agent
	if table.column = 6 then
		obj := table.accessRow(table.row).itemObject;
		if obj &lt;&gt; null and app.isAllowedToInspect then
			obj.inspect;
		endif;
	endif;
	
	// add/edit extras
	//if table.column = 8 then // --&gt; TFS 44274
	//	self.doUpdateExtras();
	//endif; // &lt;-- TFS 44274
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
