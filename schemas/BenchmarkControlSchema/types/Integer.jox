<PrimType name="Integer">
    <JadeMethod name="asCreatorName" id="f7e554fd-5aee-404c-ba23-232b949eacf5">
        <source>asCreatorName():String;

begin
	if self = 0 then
		return "CreatorCreator";
	else
		return "Creator"&amp;self.padLeadingWith("0",2);
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="inc" id="c917b3ac-03d7-41a2-bab2-bc371d03f47a">
        <updating/>
        <source>inc() updating;

begin
	self := self + 1;
end;</source>
    </JadeMethod>
    <JadeMethod name="integerFormat" id="6ba355bf-78d3-4da2-9b92-aa162cdb27b1">
        <source>integerFormat():String;

begin
	return self.userNumberFormat($NoDecimals);
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</PrimType>
