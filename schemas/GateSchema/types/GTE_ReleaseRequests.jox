    <JadeMethod name="doNext" id="d1f35b56-6008-463e-929c-7c4b58038f09">
        <updating/>
        <source>doNext() updating;
/*
----------   ----------  --------------------------------------------------
Created:	30 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support	
----------   ----------  --------------------------------------------------
*/
vars
	pxyReserveSelection			: CM_ReserveSelection;
	releaseByType				: Boolean;
	tmpClone					: CM_BulkRelease;
begin
	//th2 PAR 14815 - next release request regardless of what is selected
	//if self.myMasterProxyObject = self.mySelectedObject then
		//save the bulk release and add a new one with all the same user entry
		
		if (not self.doSave) then
			return;
		endif;
		
		//clear everything except the entry table
		releaseByType := self.myMasterProxyObject.CM_BulkRelease.releaseByType;
		self.myMasterObject := null;
		self.mySelectedObject := null;
		
		//create new proxy release and set it from the entry table
		tmpClone := self.myMasterProxyObject.cloneSelf(true).CM_BulkRelease;
		tmpClone.CM_BulkRelease.setCode(null);
		tmpClone.CM_BulkRelease.setRequestDate(app.actualTimeServer);		// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
		self.myMasterProxyObject.CM_BulkRelease.cloneReferences(tmpClone, true);
		//replace
		delete self.myMasterProxyObject;
		self.myMasterProxyObject := tmpClone;
		
		//reload list and select the new release
		self.mode := self.Mode_Add;
		self.loadTree();
		self.selectObject(self.myMasterProxyObject);
		self.zSetTblEntryFocus();
	/*	
	elseif CM_ReserveSelection.hasInstance(self.mySelectedObject) then
		self.saveUserEntryReserveSelection();
		create pxyReserveSelection transient;
		pxyReserveSelection.setMyHeader(self.myMasterProxyObject.CM_BulkRelease);
		pxyReserveSelection.setPxyDefaults();
		self.mySelectedObject := pxyReserveSelection;
		self.saveUserEntryReserveSelection();
		
		self.loadTree();
		self.selectObject(pxyReserveSelection);
		self.zSetTblEntryFocus();
		
	endif;
	*/
epilog
	endLoad;
end;


</source>
    </JadeMethod>
    <JadeMethod name="doPinNumberCheck" id="c79ce3b3-c566-4ec6-b2cb-83f439939ceb">
        <source>doPinNumberCheck( _pxyBulkRelease : CM_BulkRelease): Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 December 2010	cnwrd1	Initial creation
*/
//15 May 2013	cnwrs1	par31549 stop removal of unused options
vars
	theProxyRelease,
	theRealRelease		: CM_BulkRelease;
	expectedEdition		: Integer;
	tiSet 				: CM_TISet;
	ti					: CM_TrackedItem;
	pinForm 			: GTE_OperatorPinCheck;
	oldMouseState		: Integer;
	strWithObject,
	pinNoString			: CM_String;
	pinNoList			: CM_StringDict;
begin

	oldMouseState := app.mousePointer;
	app.mousePointer	:=	Idle;

	pinNoList := self.allPinNumbers;
	theProxyRelease := _pxyBulkRelease;
	

	if self.mode = self.Mode_Update then
		theProxyRelease.pxyGetRealObjectAndEdition(theRealRelease, expectedEdition);
		
		if theRealRelease = null then
			//issues...
			app.raiseCMException1(ProxyMgrCannotLocateReal, CM_BulkRelease.name, null, null);
			return IDCANCEL;
		endif;
	endif;	
	
	
	if theProxyRelease = null then
		// garbage
		return IDOK;
	endif;
	
	if theProxyRelease.releaseByType then
		return IDOK;// no real cargo here to check pins against
	endif;
	
	if theProxyRelease.type &lt;&gt; BR_TYPE_RAIL then
		//currently only for rail releases
		return IDOK;
	endif;
	
//15 May 2013	cnwrs1	par31549 stop removal of unused options
//	if not self.myTerminal.getConfig(EDIOperatorStopRelPin).Boolean then
//		// only if we have the terminal config set
//		return IDOK;
//	endif;
	/*
	if not theProxyRelease.myOperator.getRequiresImpOperatorPIN() then
		// only if the operator requires it - check the ti's instead
		return IDOK;	
	endif;
	*/

// popup form and tget pin no's for all NEW tracked items.

	//need to delete removed cargo
	self.deletePinInfoForRemoved(theProxyRelease);
	
	foreach ti in theProxyRelease.allTrackedItemsAssigned do
		
		if ti.getImExStatus &lt;&gt; TI_IMEX_STATUS_IMPORT  then			//cnwas3 par 27739
			pinNoString := self.getPinRecordForCargo(ti);
			if pinNoString &lt;&gt; null then
				pinNoList.remove(pinNoString);				
			endif;	
			continue;
		endif;
		
		if not ti.myOperator.getRequiresImpOperatorPIN then
			continue;
		endif;
		
		if self.mode = self.Mode_Add or
		 (self.mode = self.Mode_Update and
			not theRealRelease.allTrackedItemsAssigned.includes(ti)) then
				if not self.hasPinRecordForCargo(ti) then
					create strWithObject transient;
					strWithObject.string := '';
					strWithObject.setMyObject(ti);
					pinNoList.add(strWithObject);	
				endif;
		endif;
	endforeach;
	

	if pinNoList.isEmpty then
		return IDOK;
	endif;
	
	pinForm := app.loadForm(GTE_OperatorPinCheck, GTE_Assistant, false, false, true, self.myTerminal,  self.myMasterMenuAction).GTE_OperatorPinCheck;	
	pinForm.init(pinNoList);
	pinForm.showModal();
	
	return pinForm.modalResult;
	
	
	
epilog
	delete tiSet;
	delete pinForm;	
	app.mousePointer	:=	oldMouseState;
end;</source>
        <Parameter name="_pxyBulkRelease" type="CM_BulkRelease"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doRemoveTrackedItem" id="866d04ed-f5ff-43eb-b6a0-6ece7007ec32">
        <source>doRemoveTrackedItem(_ti : CM_TrackedItem input) : Boolean  protected;
/*
----------   ----------  --------------------------------------------------
Created:	29 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	
	reserveDetail		: CM_ReserveDetail;
	release				: CM_BulkRelease;
	idx					: Integer;
begin

	//07 Dec 2012	NDL	Par 30815
	if _ti.isOffSite then
		app.raiseCMException1( Cargo_already_been_release, _ti.id, null, null );
		return false;
	endif;
	
	idx := self.lstTree.listIndex;
	
	release := self.myMasterProxyObject.CM_BulkRelease;
	release.removeTIAssigned(_ti);
	release.removeTIReleased(_ti);
	self.lstTree.removeItem(idx);
	return true;
	
	
end;


</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="7038bd58-bb6e-4f86-ac26-2c5c222bde11">
        <updating/>
        <source>doSave(): Boolean updating;
/*
----------   ----------  --------------------------------------------------
Created:	28 May 2007 By cnwth2

Purpose:	

Changed On  Changed By	Reason
23/09/2009	consw1		SFW1035 - get info from ReserveDetail rather than Yard Request	
----------  ----------	--------------------------------------------------
*/
vars
	newBR, pxyRelease	: CM_BulkRelease;
	result				: Integer;
	msg : String; //28 Feb 2019	NDL	TFS 42955
begin
	pxyRelease := self.myMasterProxyObject.CM_BulkRelease;
	
	//navra1 - MTN-35875- 5th Sep 2025-3 - start
	if pxyRelease &lt;&gt; null and pxyRelease.CM_BulkRelease &lt;&gt; null and pxyRelease.remarksAdditional1.startsWith("YARA") = true and not app.myCurrentUserCan(self.myTerminal, PmAdmEditAGGatewayRRMaint) then
		app.msgBox(app.getErrorString(Cannot_edit_AG_Gateway_RR), app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	//navra1 - MTN-35875- 5th Sep 2025-3 - end
	
	//28 Feb 2019	NDL	TFS 42955
	if self.myTerminal.getConfig(RelReqForceUserEst).Boolean then
		//User is required to enter a valid date, not just use the calculated one.
		if not pxyRelease.dateEstimatedRequired.date.isValid then
			msg := app.getErrorString(Must_enter_valid_estim_requi_d);
			app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			if self.tblEntry.getRowByName( ETRow_EstimatedRequiredDate ) &gt; 0 then
				self.tblEntry.row := self.tblEntry.getRowByName( ETRow_EstimatedRequiredDate );
				self.tblEntry.column := 2;
				self.tblEntry.setFocus();
			endif;
			return false;
		endif;
	endif;
	
	if pxyRelease.allReserveDetails.isEmpty and pxyRelease.allReservePackingChildren.isEmpty then
		if pxyRelease.releaseByType then
			app.msgBox(app.getErrorString(At_Least_One_RequestLine), app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
			return false;
		else
			app.msgBox(app.getErrorString(At_Least_One_CargoItem), app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
			return false;
		endif;
	endif;
	
	
	if self.doPinNumberCheck(pxyRelease) &lt;&gt; IDOK then //cnwrd1 par 25594 10.12.2010
		return false;
	endif;
	
	self.doSaveByTypeWeightRequested(pxyRelease); // ### TFS BUG 62755 05MAR2024 NAVAB1
	
	pxyRelease.requests.purge();

	while true do			
		if self.mode = self.Mode_Add then
			app.myTrxCA.trxCreateBulkRelease(pxyRelease, self.myMasterObject.CM_BulkRelease, self.allPinNumbers, app.myPassport);
		elseif self.mode = Mode_Update then
			app.myTrxUA.trxUpdateBulkRelease(pxyRelease, self.allPinNumbers, app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Release Request update', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		return false;
	endwhile;
	
	// CCMS 1606 AER 13/11/2007
	newBR := self.myMasterObject.CM_BulkRelease;
	if self.mode = Mode_Add then
		// set self.myCurrentObject so this is selected in table
		self.mySelectedObject := newBR;
		if newBR &lt;&gt; null then
			if newBR.type = BR_TYPE_ROAD then
				if not self.myTerminal.getConfig(NoPINs).Boolean then			//+cnwml2 PAR23532
					if newBR.myPinNo &lt;&gt; null then 
						app.msgBox('Release request added with PIN (' &amp; newBR.myPinNo.pinNo &amp; ')', 'Release Request Added', MsgBox_OK_Only + MsgBox_Information_Icon);
					else 
						app.writeStatement( "newBR.myPinNo is NULL");
					endif;
				endif;
			else
				app.msgBox('Release request added successfully', 'Release  Added', MsgBox_OK_Only + MsgBox_Information_Icon	);
			endif;				
		endif;
		
	else
		if newBR &lt;&gt; null then
		   	if pxyRelease.myCargoType &lt;&gt; self.myMasterObject.CM_BulkRelease.myCargoType then
		   		self.mySelectedObject := newBR;
		   		// switch the mode as the old obj has been deleted and
		   		// a new one created
		   		self.mode := Mode_Add;
		   	endif;   	
		endif;
	endif;
	
	return true;
epilog 

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveByTypeWeightRequested" id="7d0659ae-cb3a-4c86-bc44-4b8ffff8b277">
        <source>doSaveByTypeWeightRequested(_pxyRelReq : CM_BulkRelease);
/*
Purpose:			

Date		Who		Reason
05 March 2024	navab1	// ### TFS BUG 62755 05MAR2024 NAVAB1
*/

vars
	resDetl: CM_ReserveDetail;
	cargoType : CM_CargoType;
	reserveSelection : CM_ReserveSelection;
begin
	if not _pxyRelReq.context = RelReqContext_CargoGroupReview then
		return;
	endif;
	
	foreach resDetl in _pxyRelReq.allReserveDetails discreteLock do
		if not resDetl.isReserveSelection then
			continue;
		endif;
		
		reserveSelection := resDetl.CM_ReserveSelection;
		cargoType := reserveSelection.getMyCargoType();
		if cargoType &lt;&gt; null and cargoType.isBulkByWeight then
		elseif cargoType &lt;&gt; null and cargoType.isBulkByVolume then
		else
			if not reserveSelection.byTypeByWeight then 
				reserveSelection.setWeightRequested(0); 
			endif;	
		endif;
	
	endforeach;

	
epilog

end;</source>
        <Parameter name="_pxyRelReq" type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="doSearch" id="102bf5f8-005b-45cd-b934-c5618fff5d29">
        <updating/>
        <source>doSearch() updating;
/*
----------   ----------  --------------------------------------------------
Created:	05 June 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	releaseNo			: String;
	release				: CM_BulkRelease;
begin
	releaseNo := self.txtReleaseNo.text.trimBlanks.toUpper();
	if releaseNo = null then
		app.msgBox(app.getErrorString(Must_enter_release_number), app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
		self.txtReleaseNo.setFocus();
		return;
	endif;
	release := self.myTerminal.getBulkReleaseFromCode(releaseNo);
	if release = null then
		app.msgBox(app.getErrorString1(No_release_found, releaseNo), app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
		self.txtReleaseNo.setFocus();
		return;
	endif;
	
	self.myMasterObject := release;
	self.showHideSearcher();
	self.loadTree();
	self.selectObject(release);
end;


</source>
    </JadeMethod>
    <JadeMethod name="doSelectYardSource" id="078e2f2d-995a-48d1-a8a6-d3e47606c977">
        <updating/>
        <source>doSelectYardSource()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 July 2015	cnwma1	PAR #36555 CCMS 2509 TFS - Multi-location selection for MTs for vessel release

*/



vars
	sourceForm	: CMUI_SelectISOSourceMulti;
	desc : String;
	row 		: Integer;
begin
	row := self.tblEntry.getRowByName(ETRow_TerminalArea);
	

	sourceForm := app.loadForm(CMUI_SelectISOSourceMulti, CMUI_Assistant, false, false, true, self.myTerminal, self.myMasterMenuAction).CMUI_SelectISOSourceMulti;
	sourceForm.centreWindow;
	sourceForm.setMyTerminal(self.myTerminal);

	sourceForm.setDescription( self.getYardSourceDesc() ); 
	sourceForm.setSelectedValues( self.allSelectedTAs,self.allSelectedTAGridObjs, false, false  ) ; //grid objects
	
	sourceForm.grpAreaSchOrder.visible :=false;
	sourceForm.hideBestPick := true;
		
	sourceForm.showModal;
	
	if sourceForm.modalResult &lt;&gt; IDOK then
		return;
	endif;
	
	//update  entity
	self.allSelectedTAs.clear();
		
	sourceForm.getAreasWithGridObjs(self.allSelectedTAs, self.allSelectedTAGridObjs);
	
	self.tblEntry.accessCell(row,2).text :=  self.truncateDisplayString(getYardSourceText(), 30);
epilog
	delete sourceForm;
end;</source>
    </JadeMethod>
    <JadeMethod name="doTblEntryCellInputReady" id="2415e6d8-97c0-480e-a977-185a817572ca">
        <updating/>
        <source>doTblEntryCellInputReady(table: CM_EntryTable input; inputControl: Control input; cleft: Real io; ctop: Real io; cwidth: Real io; cheight: Real io) updating;
/*
----------   ----------  --------------------------------------------------
Created:	08 May 2007 By cnwth2

Purpose:	

Changed On  Changed By  Reason
----------  ----------  --------------------------------------------------
23/08/2013	cnwdap1		PAR #32331 Added Colour Picker
05/05/2014	cnwdap1		PAR #34058 Added total weight and total volume measurement tables
*/
vars
	tmpTable	: CM_EntryTable;
begin
	tmpTable := table;
	if inputControl.name = self.lstMTGrade.name or inputControl.name = self.lstPackLocn.name then
		self.myAssistant.listTableCellInputReady(tmpTable, cheight, saveRowHeight);
		self.doResize;
	endif;
	
	if inputControl = self.lstColour then																// PAR #32331
		self.myAssistant.listTableCellInputReady(tmpTable.CM_EntryTable, cheight, self.saveRowHeight);	// PAR #32331
		tmpTable.adjustHeight(1000);																	// PAR #32331
	endif;																								// PAR #32331
	
	if CMUI_MeasurementTable.hasInstance(inputControl) and not inputControl = self.tblMeasurement then	// PAR #34058
		app.doMeasureTableCellInputReady(tmpTable, inputControl);										// PAR #34058
	endif;																								// PAR #34058
end;


</source>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
        <Parameter name="inputControl" type="Control" usage="input"/>
        <Parameter name="cleft" type="Real" usage="io"/>
        <Parameter name="ctop" type="Real" usage="io"/>
        <Parameter name="cwidth" type="Real" usage="io"/>
        <Parameter name="cheight" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doTblEntryChange" id="5e0ae020-bfeb-4790-82fe-e5a819f9c56d">
        <updating/>
        <source>doTblEntryChange(_tbl : CM_EntryTable input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	08 May 2007 By cnwth2

Purpose:	

/* Changes

Date		Name	TFS#	Description
============================================================================
31/01/2019	jlgka1	41708	Call two method that will populate Bill Of Lading 
							and Bill Of Lading Items. Call a validation method.
08/03/2019	jlgka1	41708	Add setting of expiryTimeStampManual fields. 
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
21/12/2023	navcs2	ChangeRequest 57537: EUP | Release Request By Type - with Weight
25/06/2025  navbk1  Bug 34976: MTN - Cargo Review - Setting up a Release by Id and changing it to by type raises a 1312
============================================================================*/
vars
	releaseByType		: Boolean;
	bulkRelease			: CM_BulkRelease;
	reserveDetail		: CM_ReserveDetail;
	reserveTI			: CM_ReserveTI;
	reserveSelection	: CM_ReserveSelection;
	ti					: CM_TrackedItem;	
	expiryTime			: TimeStamp;
	expiryDate			: TimeStamp;
	expiryTimeStamp		: TimeStamp;
	obj					: Object;
begin
	if self.mySelectedObject &lt;&gt; self.myMasterProxyObject then
		if self.myTerminal.getConfig(UseTotReqAllowedFld).Boolean then
			if self.mySelectedObject.isKindOf(CM_CargoType) then
				self.setReserveTICustomsFieldValue(self.mySelectedObject.CM_CargoType, false, null);
			elseif self.mySelectedObject.isKindOf(CM_Product) then
				self.setReserveTICustomsFieldValue(self.mySelectedObject.CM_Product.myCargoType, true, self.mySelectedObject.CM_Product);
			endif;
			self.validateReserveTI(self.mySelectedObject);		
			self.setGroupLabel();
		endif;
		if _tbl.row &gt; _tbl.fixedRows and self.mySelectedObject.isKindOf(CM_ReserveDetail) then						// 21/12/2023	navcs2	ChangeRequest 57537
			obj := _tbl.accessRow(_tbl.row).itemObject;																// 21/12/2023	navcs2	ChangeRequest 57537
			if obj.isKindOf(EntTableRowTransient) and obj.EntTableRowTransient.name = ETRow_ByTypeByWeight then		// 21/12/2023	navcs2	ChangeRequest 57537
				self.showWeightOrRequested();																		// 21/12/2023	navcs2	ChangeRequest 57537
			endif;																									// 21/12/2023	navcs2	ChangeRequest 57537
		endif;																										// 21/12/2023	navcs2	ChangeRequest 57537															
		return;																											
	endif;
	
	if (_tbl.row &lt;&gt; _tbl.getRowByName(ETRow_ReleaseByType) or //they havn't selected a release type
	   self.cmbBRType.listIndex &lt; 1) and 
	   _tbl.row &lt;&gt; _tbl.getRowByName(ETRow_ExpiryTime) then
		return;
	endif;
	
	bulkRelease 		:= self.myMasterProxyObject.CM_BulkRelease;
	releaseByType		:= _tbl.getValueByName(ETRow_ReleaseByType).Boolean;
	expiryTime			:= _tbl.getValueByName(ETRow_ExpiryTime).TimeStamp;
	expiryDate			:= _tbl.getValueByName(ETRow_ExpiryDate).TimeStamp;
	
	expiryTimeStamp.setDate(expiryDate.Date);
	expiryTimeStamp.setTime(expiryTime.Time);
	
	if bulkRelease.expiryTimeStamp &lt;&gt; expiryTimeStamp then
		if not bulkRelease.expiryTimeStampManual then
			bulkRelease.setExpiryTimeStampManual(true);
		endif;
	endif;
	
	if (not releaseByType) and bulkRelease.releaseByType then
		reserveDetail := bulkRelease.allReserveDetails.first;
		
		//if CM_ReserveSelection.hasInstance(reserveDetail) and (not reserveDetail.allTrackedItems.isEmpty) then
		if CM_ReserveSelection.hasInstance(reserveDetail) and (reserveDetail.hasTi()) then //23/06/2023	navkc1	CR 58406 Task 58408
			//give warning when changing from release by type to not release by id if items attached
			//as this will remove any existing reserve selections they have entered
			if app.msgBox(app.getErrorString(Changing_ReleaseByID),app.getErrorString(Are_You_Sure), MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
				_tbl.setValueByName(ETRow_ReleaseByType, true);
				return;
			endif;
			//delete reserve details and create reserveTIs for each ti assigned
		
			if reserveDetail.allTrackedItemsReleased.isNotEmpty then
				foreach ti in bulkRelease.allTrackedItemsReleased do
					create reserveTI transient;
					reserveTI.setMyHeader(bulkRelease);
					reserveTI.addTIReleased(ti);
				endforeach;
			endif;

		endif;
		foreach reserveDetail in bulkRelease.allReserveDetails do
			if CM_ReserveSelection.hasInstance(reserveDetail) then
				delete reserveDetail;
			endif;
		endforeach;
	
		self.saveUserEntry();
		self.loadTree();
		self.selectObject(bulkRelease);
		self.tblEntry.goToRowByName(ETRow_ReleaseByType);
		
	elseif releaseByType and (not self.myMasterProxyObject.CM_BulkRelease.releaseByType) then
	
		//create a new reserve selection and assign any existing assigned items to it
		create reserveSelection transient;
		reserveSelection.setMyHeader(bulkRelease);
		reserveSelection.setPxyDefaults();
		
		//cnwsh3 - copy over the previously released items as well PAR15207 
		//Reason for this is to factor in the number of TIs already released if we are changing from a reserveTI to a releaseByType
		self.myMasterProxyObject.CM_BulkRelease.allTrackedItemsReleased.copy(reserveSelection.allTrackedItemsReleased);
		reserveSelection.setTotalRequested(bulkRelease.getTotalQtyRequested());											//25.06.25 navbk1 #34976
		foreach reserveDetail in bulkRelease.allReserveDetails do
			if not CM_ReserveTI.hasInstance(reserveDetail) then
				continue;
			endif;
			
			ti := reserveDetail.allTrackedItems.first;
			if ti &lt;&gt; null then
				// START 25.06.25 navbk1 #34976
				if ti.myCargoType.id = TI_CargoType_Container then
					reserveSelection.setMyISOType(ti.getISOType());
					reserveSelection.setMyISOGroup(ti.isoTypeGroup);
				else 																										//16.07.25 navbk1 #34976
					reserveSelection.setMyCargoType(ti.myCargoType);														//16.07.25 navbk1 #34976
					reserveSelection.setMyProduct(ti.myProduct);															//25.06.25 navbk1 #34976
				endif;
				// END 25.06.25 navbk1 #34976
				reserveSelection.addTI(ti);
			endif;
			delete reserveDetail;
		endforeach;
		
		self.saveUserEntry();
		self.loadTree();
		self.selectObject(bulkRelease);
		self.tblEntry.goToRowByName(ETRow_ReleaseByType);

	endif;
	
	self.setViewForReleaseType(bulkRelease.type, bulkRelease.releaseByType);
	self.populateHeaderBillOfLading(bulkRelease.type);
	self.populateBOLDetails();
	
	if not app.isSubTerminalsOn(self.myTerminal) then //cnwrd1 par 23219 30.3.2010 - remove sub terminal fields on view change
		self.tblEntry.hideRowByName(ETRow_MySubTerminal,false);		
		self.tblEntry.hideRowByName(ETRow_MySubTerminalTarget,false);	 
	endif;
end;
</source>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblEntryClick" id="b30cec9f-5244-4a03-aeb1-5d9a029bf8ec">
        <updating/>
        <source>doTblEntryClick() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 December 2023	navcs2	Initial creation

*/

vars
	tbl	: CM_EntryTable;
begin
	
	tbl := self.tblEntry;
	
	if tbl.row = tbl.getRow(ETRow_LocnByOldestTransArrival) then //19/02/2023	navkc1 CR 60078 Task 62450
		self.hasChangedLocnByOldest := true;
	endif;
	
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doTblEntryDblClick" id="6c0f2976-0563-410f-a154-2ef037917c04">
        <updating/>
        <source>doTblEntryDblClick(_table: CM_EntryTable input) updating;
//----------------------------------------------------------------
//	Created:	01 March 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 24/11/2011	cnwcs5	CCMS POL 2122 / par 28696 - View EDI Messages
// 01/07/2015	cnwma1	PAR #36555 CCMS 2509 TFS - Multi-location selection for MTs for vessel release
vars
	row, maskRow		: Integer;
	pCaption, pHint 	: String;
begin 
	row		:= _table.row;
	maskRow := _table.CM_EntryTable.getRow(ETRow_IdMask);

	if row = maskRow and maskRow &gt; 0 then
	    pHint 		:= 'Enter the cargo IDs to mask with. Can be full or partial cargo or series ids (eg SUDU 20). To enter a negative (NOT), add a "!" before the mask, i.e. !SUDU20. Each id should be on a separate line.';
	    pCaption 	:= 'Cargo ID Masking';
		
		self.myAssistant.showIdMaskWindow(self.tblEntry, maskRow, pCaption, pHint);
	endif;
	
	if row = _table.getRowByName(ETRow_EmailOptions) then
		self.doEmailOptionsDblClick(_table);
	endif;
	
	if row = _table.getRowByName(ETRow_AddAttachment) then
		self.showTISearcher();
	endif;
	
	if row = _table.getRowByName (ETRow_ViewEDIMessages) then	// par 28696
		self.doViewEDIMessages ();
	endif;
	
	if row = _table.getRowByName(ETRow_SetCriteria) then	//11 Jun 2015	NDL	Par 36338
		self.doMaintainCriteria();
	endif;
	
	if row = _table.getRowByName(ETRow_SetStops) then	//13 Sep 2016	NDL	TFS 2664 / 2001
		self.doMaintainStops();
	endif;
	
	if row = _table.getRowByName(ETRow_SetTasks) then	//13 Sep 2016	NDL	TFS 2664 / 2001
		self.doMaintainTasks();
	endif;
	
	if row = _table.getRowByName(ETRow_TerminalArea) then	
		self.doSelectYardSource();
	endif;
	
end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblEntryQryRowColChange" id="eac47751-f126-4a48-8e52-71a3924bff6e">
        <updating/>
        <source>doTblEntryQryRowColChange(_tbl : CM_EntryTable input; newRow: Integer; newCol: Integer) : Boolean updating;
/*
----------   ----------  --------------------------------------------------
Created:	31 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
28 Jul 2025  navma1 	 MTN-35577  MTN - Error 1081 While doing Road Receive Transaction with CM_BulkReleaseByCodeDict
17 Nov 2025  navbk1      MTN-36601  STWO - Post upgrade to 22.0.24.19 ? Duplicate release number validated only on "Save"
----------   ----------  --------------------------------------------------
*/
vars
	releaseNo : String;
	doCheck   : Boolean;
begin
	if _tbl.row = _tbl.getRow(ETRow_ReleaseNo) then 
		/*
		28.07.2025 navma1 #MTN-35577
		No Need to Check when release request number not changed when opening the form
		*/
		releaseNo := _tbl.getValueByName(ETRow_ReleaseNo).String;			
		if releaseNo &lt;&gt; null then
			if self.mode = self.Mode_Add then																//17.11.2025 navbk1 #36601
				doCheck := true;																			//17.11.2025 navbk1 #36601
			elseif self.mode = self.Mode_Update then
				if self.myMasterObject &lt;&gt; null and self.myMasterObject.isKindOf(CM_BulkRelease) then
					if self.myMasterObject.CM_BulkRelease.code &lt;&gt; releaseNo then
						doCheck := true;
					endif;
				endif;
			endif;
		endif;
		if doCheck then
			self.showDuplicateBRs(releaseNo);	
		endif;
	endif;
	return inheritMethod(_tbl, newRow, newCol);
	
end;</source>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="newRow" type="Integer"/>
        <Parameter name="newCol" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTreeClick" id="6996db53-b61a-4dd5-bb91-203a9bebd20d">
        <updating/>
        <source>doTreeClick() updating;
/*
----------   ----------  --------------------------------------------------
Created:	30 April 2007 By cnwth2

Purpose:	

/****Changes

Date		Name		TFS#		Description
============================================================================
23/08/2013	cnwdap1		PAR #32331 	Added Colour Picker
03/09/2013	cnwdap1		PAR #32404 	Hide Colour Picker if Terminal Config says so
10/12/2013	cnwdap1		PAR #33169 	Correct handling of measurement type fields
05/05/2014	cnwdap1		PAR #34058 	Cater for total weight and total volume for Bulk cargo
16/07/2014	cnwdap1		PAR #34329 	Hide lstColour properly
14/03/2016	cnwdap1		PAR #37606 	Reload iso type combo only if we have an iso group
									otherwise myAssistant.comboBoxISOTypeByGroup loads ALL iso types 
									regardless if isNotAvailableForEntry
22/12/2016	cnwdap1		TFS 3039 	SNO Empty Container Pool Management
24/01/2019	jlgka1		TFS 41708	Add the use of config to make the following fields visible
									or invisible Bill Of Lading (Request Header), 
									BOL Details and Total Requested Allowed (Attached Item Tree).
20/02/2019  jlger1		TFS 42398   Fixed issues with Bulk cargo 
09/09/2020	jlgdap1		TFS 49884	PEN Release Request Prior Date Issue
									When dragging and dropping cargo to a release request on a slow connection,
									the gotFocus event that fired if a combo had focus when the drag-drop happened
									would fire AFTER the table had been rebuilt from any proxy. So the release number
									was being overwritten by whatever content the combo box had when it got focus back
31/08/2023	jlizm1		TFS 59568 	Add instructions to release lines
6/12/2023	navcs2		ChangeRequest 57537: EUP | Release Request By Type - with Weight
14/05/2024	navnk30		ChangeRequest 63607: FR | 53127 - Additional Operational Instructions on the Order - Remedial
13 Jan 2025	navhl20 	CR MTN-33695: TPT | Release Request Delivery Party Info for Unique IDs
27 Feb 2025	navbs1		Bug MTN-34082: Invalid Required By Date exception when allocating the road job to gang
28 Jul 2025 navrv30		MTN 35529 MTN - Cargo Review Screen not calculating/displaying values correctly.
23/10/2025	jlizm1		MTN 36255	Rotabox Assign Release To Vessel
============================================================================*/
vars
	ti				: CM_TrackedItem;
	reserveObj		: CM_ReserveSelection;
	isoGroup 		: CM_ISOTypeGroup;			// 23/04/2010 cnwmh5 #23416
	isoType			: CM_ISOType;				// 23/04/2010 cnwmh5 #23416
	tmpVoyage		: CM_Voyage;
	tmpBOLIn		: CM_BOLIn;
	invalid			: Boolean;
	idx				: Integer;					// PAR #32404
	entRow			: EntTableRowTransient;		// PAR #32404
	cmifGrouping	: CMIF_ReserveTIGrouping; // jlgka1 TFS 41708	
	row				: Integer;
begin
	if self.mySelectedObject &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception,self.mySelectedObject,invalid);
		self.mySelectedObject.creationTime;
		self.btnInstruction.enabled :=
			self.mySelectedObject.isKindOf(CM_BulkRelease) or
			self.mySelectedObject.isKindOf(CM_ReserveDetail);	//14.05.2024 navnk30 #63607
	else
		self.btnInstruction.enabled := false;
		if self.myTerminal.getConfig(UseTotReqAllowedFld).Boolean then						
			if self.myMasterProxyObject &lt;&gt; null then
				if self.myMasterProxyObject.isKindOf(CM_BulkRelease) then
					if not self.myMasterProxyObject.CM_BulkRelease.releaseByType then
						self.tblEntry.clear();			
						row := 1;
						while self.tblEntry.rows &lt;&gt; 0 do
							self.tblEntry.deleteRow(row);					
						endwhile;
					endif;
				endif;
			elseif self.myMasterObject &lt;&gt; null then
				if self.myMasterObject.isKindOf(CM_BulkRelease) then
					if not self.myMasterObject.CM_BulkRelease.releaseByType then
						self.tblEntry.clear();			
						row := 1;
						while self.tblEntry.rows &lt;&gt; 0 do
							self.tblEntry.deleteRow(row);					
						endwhile;
					endif;
				endif;
			endif;
		endif;
		return;
	endif;
	
	if invalid then
		return;
	endif;
	

	self.tblEntry.foreColor := Black;
	if CM_BulkRelease.hasInstance(self.mySelectedObject) then
		self.btnDelete.enabled 			:= false;
		self.btnAddChild.enabled 		:= (self.mode &lt;&gt; self.Mode_View ); //epr par 35154 will now open TI searcher if release by id
		self.btnNext.enabled 			:= (self.mode &lt;&gt; self.Mode_View);
		self.btnNext.caption 			:= app.getErrorString(Next_Release_Request);
		self.btnNext.bubbleHelp 		:= app.getErrorString(Next_Release_Request).removeString('&amp;') &amp; ' (Alt-N)';
		//self.btnInstruction.enabled		:= false;			//14.05.2024 navnk30 #63607
		
		// store tblEntry row so we can restore it later								// TFS 49884
		if self.tblEntry.row &gt; self.tblEntry.fixedRows then								// TFS 49884
			row := self.tblEntry.row;													// TFS 49884
		endif;
		self.initEntryTable(ETDef_RequestHeaderInfo, self.tblEntry);
		self.setViewForReleaseType(self.mySelectedObject.CM_BulkRelease.type, self.mySelectedObject.CM_BulkRelease.releaseByType);
		self.populateHeaderBillOfLading(self.mySelectedObject.CM_BulkRelease.type);		
		self.populateBOLDetails();
		self.tblEntry.disableRowByName(ETRow_VoyageArrival);
		self.tblEntry.disableRowByName(ETRow_PoolParty);					// TFS 3039
		self.tblEntry.disableRowByName(ETRow_Booking);		
		//navra1 - BUG 63499 - 30th April 2024 - start
		if self.mySelectedObject.isKindOf(CM_BulkRelease) then
			if self.mySelectedObject.CM_BulkRelease.allReserveDetails &lt;&gt; null and self.mySelectedObject.CM_BulkRelease.allReserveDetails.size() &gt; 0 then
				if self.mySelectedObject.CM_BulkRelease.allReserveDetails.first().isKindOf(CM_ReserveSelection) then
					if self.mySelectedObject.CM_BulkRelease.allReserveDetails.first().CM_ReserveSelection.myReleaseCriteria &lt;&gt; null then
						if self.mySelectedObject.CM_BulkRelease.allReserveDetails.first().CM_ReserveSelection.myReleaseCriteria.includesCriteriaFor(YACriteriaType_BookingRef) then
							self.tblEntry.disableRowByName(ETRow_MyBookingRefStock);
						endif;
					endif;
				endif;
			endif;
		endif;
		//navra1 - BUG 63499 - 30th April 2024 - end
		self.tblEntry.setTableFromCM_Object(self.mySelectedObject, GTE_ReleaseRequests::setEntTblFromRelease.name);
		// restore tblEntry row in case it was overwritten in setTableFromCM_Object		// TFS 49884
		if row &gt; 0 and row &lt;= self.tblEntry.rows then																	// TFS 49884
			self.tblEntry.row := row;													// TFS 49884
		endif;																			// TFS 49884
		self.setTotReqFldFieldsVisibility(self.mySelectedObject.CM_BulkRelease.releaseByType);
	elseif CM_ReserveSelection.hasInstance(self.mySelectedObject) then
		reserveObj						:=	self.mySelectedObject.CM_ReserveSelection;
		self.btnDelete.enabled 			:= (self.mode &lt;&gt; self.Mode_View);
		self.btnNext.enabled 			:= (self.mode &lt;&gt; self.Mode_View);
		self.btnNext.caption 			:= app.getErrorString(Next_Request_Line);
		self.btnNext.bubbleHelp 		:= app.getErrorString(Next_Request_Line).removeString('&amp;') &amp; ' (Alt-N)';
		//self.btnInstruction.enabled	:= self.mode = self.Mode_Update;		//14.05.2024 navnk30 #63607
		
		self.initEntryTable(ETDef_RequestLine, self.tblEntry);
		
		if reserveObj.myCargoType &lt;&gt; null then
			//self.setViewForReleaseLineType(reserveObj.myCargoType.id);															//27.02.2025 navbs1 #34082		
			//epr TFS 41398 20/2/19
			self.cmbTiType.setObject(reserveObj.myCargoType);
			self.cmbTiType_click(self.cmbTiType);																					//27.02.2025 navbs1 #34082
			//self.cmbProduct.setOperator(reserveObj.getOperator);  //why myObject?  listObject is null at this point				//27.02.2025 navbs1 #34082
			//self.cmbProduct.setObject(reserveObj.myProduct);																		//27.02.2025 navbs1 #34082
			//self.setupMeasurementFields();																						//27.02.2025 navbs1 #34082	
		elseif reserveObj.myCargoType = null and reserveObj.myBOLIn &lt;&gt; null then	//24 Feb 2014	NDL	Par 33524		
			self.tblEntry.hideRowByName(ETRow_PackingType,false);
		endif;
		//epr TFS 5831 25/8/17 only bother if visible
		if self.tblEntry.isRowVisible(ETRow_IsoType) then
			// 23/04/2010 cnwmh5 #23416
			isoType := reserveObj.myISOType;
			isoGroup := reserveObj.myISOGroup;
			
			//epr TFS 5831 25/8/17
			self.myAssistant.comboBoxISOTypeByGroup(self.cmbISOType,isoGroup,isoType);			
		
			self.tblEntry.hideRowByName(ETRow_CargoTypeCodeForCntnt, false);
			self.tblEntry.hideRowByName(ETRow_CargoSubTypeCodeForCntnt, false);
			
			if isoType &lt;&gt; null then
				isoGroup:=isoType.myISOTypeGroup;
				self.myAssistant.comboBoxISOTypeGroupFilter(cmbISOGroup, isoGroup);
				
				if isoType.isRotatable then
					self.tblEntry.showRowByName(ETRow_CargoTypeCodeForCntnt, false);
					self.tblEntry.showRowByName(ETRow_CargoSubTypeCodeForCntnt, false);
				endif;
			else
				self.myAssistant.comboBoxISOTypeGroup(cmbISOGroup, isoGroup);										//+cnwml2 PAR25310
			endif;
		endif;
		//#24351	04/06/2010
		if reserveObj.myReserveHeader &lt;&gt; null then	
			tmpVoyage:= reserveObj.myReserveHeader.CM_BulkRelease.myVoyage;  //cnwjo3 par 24825.  myMasterProxyObject deleted in CMUI_TreeViewForm::zDoCancel
			tmpBOLIn := reserveObj.myBOLIn;			
			if tmpBOLIn &lt;&gt; null then
				//28 Jul 2025 navrv30		MTN 35529 
				if tmpBOLIn.myVoyage &lt;&gt; null and tmpVoyage = null then
					tmpVoyage := tmpBOLIn.myVoyage;					
				elseif tmpVoyage = null or (not tmpVoyage.allBOLInByTypeStatusNumDT.includes(tmpBOLIn)) then
					tmpBOLIn := null;	// we need to do this, because cmbVoyage.lostFocus() doesn't occur, when click on a reserveSelection straightaway
					reserveObj.setMyBOLIn(null);
				endif;
			endif;
			self.myAssistant.comboBoxBOLInsForVoyage(self.cmbBOL, tmpVoyage, tmpBOLIn);			
		endif;
		
		// PAR #32404 don't show colour list if terminal config turned off
		if not self.myTerminal.getConfig(ValidateColour).Boolean then	
			idx := self.tblEntry.getRowByName(ETRow_Colour);
			if idx &lt;&gt; null then
				entRow := self.tblEntry.accessRow(idx).itemObject.EntTableRowTransient;
				if entRow &lt;&gt; null then
					self.tblEntry.accessCell(idx, self.tblEntry.columns).cellControl := null;
					entRow.setControlName(null);
				endif;
			endif;
		endif;
		
		self.tblEntry.setTableFromCM_Object(self.mySelectedObject, GTE_ReleaseRequests::setEntTblFromReserveSelection.name);
		
		if reserveObj.myReserveHeader &lt;&gt; null then
			if reserveObj.myReserveHeader.myBookingRefStock &lt;&gt; null then
				self.doLoadBookRefItems(reserveObj.myReserveHeader.myBookingRefStock, reserveObj.myBookingRefItem);
			endif;
		endif;
		
		self.myAssistant.setColourDetails(reserveObj.colour, self.lstColour, null);			// PAR #32331
		
		//jlgka1 TFS 41708 --&gt;
		if reserveObj.myReserveHeader &lt;&gt; null then
			self.setTotReqFldFieldsVisibility(reserveObj.myReserveHeader.releaseByType);
		endif;
		//jlgka1 TFS 41708 &lt;--
		//jlier1 TFS 53678 27/6/22
		idx := self.tblEntry.getRowByName(ETRow_DeliveryInstructions);
		if idx &gt; 0 then
			self.tblEntry.accessCell(idx,self.tblEntry.columns).wordWrap:=true;
			self.tblEntry.accessRow(idx).height:=60;
			self.tblEntry.accessCell(idx,self.tblEntry.columns).maxLength:=400;
		endif;
		self.showWeightOrRequested();		// 6/12/2023 navcs2 ChangeRequest 57537
	elseif CM_TrackedItem.hasInstance(self.mySelectedObject) then
		self.btnDelete.enabled 			:= (self.mode &lt;&gt; self.Mode_View);
		//self.btnInstruction.enabled		:= false;		//14.05.2024 navnk30 #63607
		
		self.initEntryTable(ETDef_TIReleaseHeader, self.tblEntry); //cnwrd1 ccms 2274
		self.tblEntry.hideRowByName(ETRow_StopsToApply, false);	//16 Sep 2016	NDL	TFS 2646 / 2001
		self.tblEntry.hideRowByName(ETRow_TaskToApply, false);	//16 Sep 2016	NDL	TFS 2646 / 2001
		//Start 13.01.2025 navhl20 #33695
		self.tblEntry.hideRowByName(ETRow_DeliveryAddress, false);
		self.tblEntry.hideRowByName(ETRow_DeliveryParty, false);
		self.tblEntry.hideRowByName(ETRow_DeliveryInstructions, false);
		self.tblEntry.hideRowByName(ETRow_DeliveryFromDate, false);
		self.tblEntry.hideRowByName(ETRow_DeliveryFromTime, false);
		self.tblEntry.hideRowByName(ETRow_DeliveryToDate, false);
		self.tblEntry.hideRowByName(ETRow_DeliveryToTime, false);
		//End 13.01.2025 navhl20 #33695

		self.tblEntry.setTableFromCM_Object(self.mySelectedObject, GTE_ReleaseRequests::setEntTblFromTI.name);
		self.doTreeClickBreakBulk(self.mySelectedObject.CM_TrackedItem);
		//jlgka1 TFS 41708 --&gt;
		self.setTotReqFldFieldsVisibility(self.myMasterProxyObject.CM_BulkRelease.releaseByType);
		//jlgka1 TFS 41708 &lt;--
	elseif CM_ReserveTI.hasInstance(self.mySelectedObject) then
		self.btnDelete.enabled 			:= (self.mode &lt;&gt; self.Mode_View);
		self.btnNext.enabled 			:= false;
		//self.btnInstruction.enabled	:= self.mode = self.Mode_View;		//14.05.2024 navnk30 #63607
		self.initEntryTable(ETDef_TIReleaseHeader, self.tblEntry); //cnwrd1 ccms 2274
		//epr par 32330 29/8/13
		ti := self.mySelectedObject.CM_ReserveTI.getTI();
		self.tblEntry.setTableFromCM_Object(self.mySelectedObject, GTE_ReleaseRequests::setEntTblFromTI.name);
		self.doTreeClickBreakBulk(ti);
		//jlgka1 TFS 41708 --&gt;
		self.setTotReqFldFieldsVisibility(self.mySelectedObject.CM_ReserveTI.myReserveHeader.releaseByType);
		//jlgka1 TFS 41708 &lt;--
		self.cmbDeliveryParty.setIndexFromObject(self.mySelectedObject.CM_ReserveTI.myDeliveryParty);		//13.01.2025 navhl20 #33695
		self.cmbDeliveryParty.lostFocus(self.cmbDeliveryParty);												//13.01.2025 navhl20 #33695
	elseif (CM_CargoType.hasInstance(self.mySelectedObject) or CM_Product.hasInstance(self.mySelectedObject))  	//jlgka1 TFS 41708 --&gt;
			and self.myTerminal.getConfig(UseTotReqAllowedFld).Boolean then
			
			//self.btnInstruction.enabled		:= false;			//14.05.2024 navnk30 #63607
			
			if self.myMasterProxyObject &lt;&gt; null then
				if self.myMasterProxyObject.isKindOf(CM_BulkRelease) then
					if not self.myMasterProxyObject.CM_BulkRelease.releaseByType then 			
						self.btnDelete.enabled 			:= (self.mode &lt;&gt; self.Mode_View);
						self.btnNext.enabled 			:= false;
						self.initEntryTable(ETDef_TIReleaseGrouping, self.tblEntry); 
					
						create cmifGrouping transient;	
					
						self.myCMIFGrouping := cmifGrouping;
						cmifGrouping.setCMIFFromBulkRelease(self.myMasterProxyObject.CM_BulkRelease, cmifGrouping);
						self.tblEntry.setTableFromCM_Object(self.mySelectedObject, GTE_ReleaseRequests::setEntTblFromRuntimeValue.name);
					
						self.setGroupLabel();
					endif;
				endif;
			elseif self.myMasterObject &lt;&gt; null then
				if self.myMasterObject.isKindOf(CM_BulkRelease) then
					if not self.myMasterObject.CM_BulkRelease.releaseByType then 			
						self.btnDelete.enabled 			:= (self.mode &lt;&gt; self.Mode_View);
						self.btnNext.enabled 			:= false;
						self.initEntryTable(ETDef_TIReleaseGrouping, self.tblEntry); 
					
						create cmifGrouping transient;	
					
						self.myCMIFGrouping := cmifGrouping;
						cmifGrouping.setCMIFFromBulkRelease(self.myMasterObject.CM_BulkRelease, cmifGrouping);
						self.tblEntry.setTableFromCM_Object(self.mySelectedObject, GTE_ReleaseRequests::setEntTblFromRuntimeValue.name);
					
						self.setGroupLabel();
					endif;
				endif;
			endif;
	endif;//jlgka1 TFS 41708 &lt;--
	
	//19/06/2009 cnwdz2  par20027 hide sub-terminal field of the data entry table if the sub-terminal module is not enabled for the terminal 
	if not app.isSubTerminalsOn(self.myTerminal) then
		self.tblEntry.hideRowByName(ETRow_MySubTerminal,false);		
		self.tblEntry.hideRowByName(ETRow_MySubTerminalTarget,false);	 //cnwrd1 par 23219 30.3.2010
	endif;
	
	//if self.tblEntry.getRowByName(ETRow_Colour) &lt;&gt; null then		// PAR #34058									// PAR #34329
	if self.tblEntry.getRowByName(ETRow_Colour) &lt;&gt; null and self.myTerminal.getConfig(ValidateColour).Boolean then	// PAR #34329
		self.lstColour.visible := true;								// PAR #34058
	else															// PAR #34058
		self.lstColour.visible := false;							// PAR #34058
	endif;															// PAR #34058
		
	self.populateBOLDetails();
	self.doResize();
	
epilog
	self.myCMIFGrouping := null;
	delete cmifGrouping;
end;</source>
    </JadeMethod>
    <JadeMethod name="doTreeClickBreakBulk" id="5eeb354b-9841-404b-b948-5de06aece6d3">
        <source>doTreeClickBreakBulk(_aTI : CM_TrackedItem);
/*
Purpose:			

Parameters:			

Return Value:		

/****Changes

Date		Name	TFS#			Description
============================================================================
15/05/2013	cnwrd1					Initial creation
05/05/2014	cnwdap1	PAR #34085 		Cater for Bulk
26/6/14		cnwer1	par 34406 		Changes for bulk
24/01/2019	jlgka1	TFS 41708		Add the BOL Details and Total Requested Allowed.
27 Jan 2025	navhl20 CR MTN-33695   TPT | Release Request Delivery Party Info for Unique IDs
============================================================================*/

vars
	
begin

	if self.myMasterProxyObject &lt;&gt; null then								//27.01.2025 navhl20 #33695
		self.tblEntry.userInputEnabled 	:= not self.myMasterProxyObject.CM_BulkRelease.releaseByType;
	else
		self.tblEntry.userInputEnabled 	:= not self.myMasterObject.CM_BulkRelease.releaseByType;
	endif;
	if _aTI.myCargoType.isBulkMulti or _aTI.myCargoType.isBreakBulkMulti then //epr par 34623 24/7/14
		//epr par 34623 24/7/14
		/*if self.myMasterProxyObject &lt;&gt; null then							//27.01.2025 navhl20 #33695	
			self.tblEntry.userInputEnabled 	:= not self.myMasterProxyObject.CM_BulkRelease.releaseByType;//ccms 2274 break bulk needs quantity now
		else
			self.tblEntry.userInputEnabled 	:= not self.myMasterObject.CM_BulkRelease.releaseByType;
		endif;*/
		
		self.tblEntry.disableRowByName(ETRow_TopID);
		self.tblEntry.disableRowByName(ETRow_CargoTypeEntry);
		self.tblEntry.disableRowByName(ETRow_Info);
		//epr par 34406 24/6/14
		if _aTI.isBulkByQuantity then
			self.tblEntry.showRowByName(ETRow_TotalQuantity, false);
			self.tblEntry.hideRowByName(ETRow_TotalWeight, false);													// PAR #34058
			self.tblEntry.hideRowByName(ETRow_TotalVolume, false);	
			self.tblEntry.showRowByName(ETRow_TotalRequestedAllowed, false);	//jlgka1 TFS 41708
			self.tblEntry.showRowByName(ETRow_BolItems, false); 				//jlgka1 TFS 41708
		elseif _aTI.isBulkByVolume then
			self.tblEntry.hideRowByName(ETRow_TotalQuantity, false);
			self.tblEntry.hideRowByName(ETRow_TotalWeight, false);													// PAR #34058
			self.tblEntry.showRowByName(ETRow_TotalVolume, false);	
			self.tblEntry.hideRowByName(ETRow_TotalRequestedAllowed, false);	//jlgka1 TFS 41708
			self.tblEntry.hideRowByName(ETRow_BolItems, false); 				//jlgka1 TFS 41708
		elseif _aTI.isBulkByWeight then
			self.tblEntry.hideRowByName(ETRow_TotalQuantity, false);
			self.tblEntry.showRowByName(ETRow_TotalWeight, false);													// PAR #34058
			self.tblEntry.hideRowByName(ETRow_TotalVolume, false);	
			self.tblEntry.hideRowByName(ETRow_TotalRequestedAllowed, false);	//jlgka1 TFS 41708
			self.tblEntry.hideRowByName(ETRow_BolItems, false); 				//jlgka1 TFS 41708
		endif;
		self.tblEntry.foreColor := Black;
		//epr par 32330 29/8/13 can't change quantity once cargo is offsite
		if _aTI.isOffSite then
			self.tblEntry.userInputEnabled 	:= false;
			self.tblEntry.foreColor 		:= Grey; 
		endif;
	else
		//self.tblEntry.userInputEnabled 	:= false;//ccms 2274 break bulk needs quantity now
		if not self.tblEntry.userInputEnabled then								//27.01.2025 navhl20 #33695
			self.tblEntry.foreColor 		:= Grey; 
		endif;
		self.tblEntry.hideRowByName(ETRow_TotalQuantity, false);
		self.tblEntry.hideRowByName(ETRow_TotalWeight, false);				// PAR #34058
		self.tblEntry.hideRowByName(ETRow_TotalVolume, false);				// PAR #34058
		//jlgka1 TFS 41708 --&gt;
		self.tblEntry.hideRowByName(ETRow_TotalRequestedAllowed, false);			
		self.tblEntry.hideRowByName(ETRow_BolItems, false); 				
		//jlgka1 TFS 41708 &lt;--
	endif;
	//epr par  32418 13/9/13
	if _aTI.myProduct = null then
		self.tblEntry.hideRowByName(ETRow_MyProduct,false);
	else
		self.tblEntry.showRowByName(ETRow_MyProduct,false);
	endif;
	self.tblEntry.disableRowByName(ETRow_MyProduct);

epilog

end;</source>
        <Parameter name="_aTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doViewEDIMessages" id="98358a98-9e76-4cb1-b7cc-c5e6b74b22cc">
        <source>doViewEDIMessages() protected;
/*
Date		Who		Reason
24 Nov 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
07/11/2011	cnwrs1	CCMS POL 2122 / PAR 28696 - new property allEDIFiles
*/
vars
	release	:CM_BulkRelease;
	form	:CMUI_EDIMessagesForm;
begin
	release := self.myMasterObject.CM_BulkRelease;
	
	if release = null or release.allEDIFiles.isEmpty then
		return;
	endif;
	
	create form;
	
	// use method so any deleted files don't get copied
	release.getAllEDIFiles(form.allEDIFiles);
	
	form.textToHightlight	:= release.code;

	form.show;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="dropTIOnRelease" id="d2c7d233-4281-482f-bd15-98874d3efa3a">
        <updating/>
        <source>dropTIOnRelease(_ti : CM_TrackedItem input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	24 May 2007 By cnwth2

Purpose:	

/****Changes

Date		Name	TFS#		Description
============================================================================
06/12/2016	cnwdap1	TFS 3039 	SNO Empty Container Pool Management
03/08/2017	cnwma1	TFS #5209	PEN - Release Request Stop
24/01/2019	jlgka1	TFS 41708	STWO - CCRO Management. Set BOLIn and BOLItems.
12/04/2019	jlgka1	44369		STWO - Bug from Functional Review of 7058 Warning Quantities Incorrect
04/07/2022  navsj20 TFS 53862   EUP - WMS - Damage Recording Extra Details
22/08/2023	navkc1	CR 59610 Task 59611: Jade - Stop Prevention
============================================================================*/
vars
	release				: CM_BulkRelease;
	otherReserve		: CM_ReserveDetail;
	reserveTI			: CM_ReserveTI;
	poolParty 			: CM_MTPoolingParty;					// TFS 3039
begin
	if _ti = null then
		return;
	endif;

	// START 04 Jul 2022 navsj20 TFS 53862
	if _ti.hasStopsToBePrevented(StopPreventRelReqDamRefused) then
		app.msgBox(app.getErrorString(Damage_refuse_stop_cannot_add), app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
		return;	
	endif;
	// END 04 Jul 2022 navsj20 TFS 53862
	
	 // ### JIRA 34756 27MAY2025 NAVAB1
	if app.myPassport.myUser.canDo(self.myTerminal, Sub_CustomDocuments) then
		//22/08/2023	navkc1	CR 59610 Task 59611 --&gt;
		if _ti.hasStopsToBePrevented(StopPreventRelReqAssign) then
			app.msgBox(app.getErrorString1(Cargo_stop_preve_from_relea_re, _ti.id), app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
			return;	
		endif;
		//22/08/2023	navkc1	CR 59610 Task 59611 &lt;--
	endif;
	
	release := self.myMasterProxyObject.CM_BulkRelease;

	if release.releaseByType then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Cannot drop cargo items directly onto a release request by type. Must by dropped on a request line');
		return;
	endif;
	poolParty := release.myPoolingParty;														// TFS 3039
	if poolParty &lt;&gt; null and _ti.myPoolingParty &lt;&gt; poolParty then								// TFS 3039
		app.raiseCMException2(Cont_Not_In_Pooling_Party, _ti.id, poolParty.code, null, null);	// TFS 3039
	endif;																						// TFS 3039
	
	// 2.8.2017 cnwma1 TFS #5209
	if _ti.myConsignee &lt;&gt; null then
		if _ti.myConsignee.isRestricted then 
			app.raiseCMException1(ERR_TI_CONSIGNEE_RESTRICTED,_ti.id ,null ,null);
			return;
		endif;
	endif;
	//remove if already assigned to another reserve
	foreach otherReserve in release.allReserveDetails do
		if otherReserve.allTrackedItemsReleased.includes(_ti) then//make sure they really want to take it out of the released items and move it back to the assigned items
			if app.msgBox(app.getErrorString(Release_cargoitem_backAssigned), app.getErrorString(Are_You_Sure), MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
				return;
			endif;
		endif;
		if otherReserve.allTrackedItems.includes(_ti) then
			delete otherReserve;
		endif;
	endforeach;
	
	create reserveTI transient;
	reserveTI.setMyHeader(release);
	reserveTI.addTI(_ti);
	
	//epr par 3515 18/11/14 set default request value this will make it not complete
	if _ti.myCargoType.isBulkByWeight or _ti.myCargoType.isBulkByVolume then
		reserveTI.setWeightRequested(_ti.totalWeight);
		// jlgka1 TFS 44369 --&gt;
		if self.myTerminal.getConfig(UseTotReqAllowedFld).Boolean then	
			self.setTotReqAllowedDefault(reserveTI, self.myMasterProxyObject.CM_BulkRelease, _ti.totalWeight.Integer);
		endif;
		// jlgka1 TFS 44369 &lt;--
	else
		reserveTI.setTotalRequested(_ti.totalQuantity);
		if self.myTerminal.getConfig(UseTotReqAllowedFld).Boolean then			
			self.setTotReqAllowedDefault(reserveTI, self.myMasterProxyObject.CM_BulkRelease, _ti.totalQuantity);						
		endif;
	endif;
	
	reserveTI.setMyBOLIn(release.myBOLIn);	// jlgka1 TFS 41708
	reserveTI.setMyBOLDtl(self.getBOLItems(reserveTI.getCargoType(), reserveTI));			// jlgka1 TFS 41708
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="dropTIOnReserveSelection" id="8b8e96d3-57d8-4b23-9ded-390708d49554">
        <source>dropTIOnReserveSelection(_reserveSelection : CM_ReserveSelection input; _ti : CM_TrackedItem input);
/*
----------   ----------  --------------------------------------------------
Created:	24 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
04/07/2022  navsj20 ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
22/08/2023	navkc1	CR 59610 Task 59611: Jade - Stop Prevention
----------   ----------  --------------------------------------------------
*/
vars
	release			: CM_BulkRelease;
	otherReserve	: CM_ReserveDetail;
begin
	if _ti = null or _reserveSelection = null then
		return;
	endif;
	
	// START 04/07/2022  navsj20 TFS 53862 
	if _ti.hasStopsToBePrevented(StopPreventRelReqDamRefused) then
		app.msgBox(app.getErrorString(Damage_refuse_stop_cannot_add), app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	// END 04/07/2022  navsj20 TFS 53862
	
	 // ### JIRA 34756 27MAY2025 NAVAB1
	if app.myPassport.myUser.canDo(self.myTerminal, Sub_CustomDocuments) then
		//22/08/2023	navkc1	CR 59610 Task 59611 --&gt;
		if _ti.hasStopsToBePrevented(StopPreventRelReqAssign) then
			app.msgBox(app.getErrorString1(Cargo_stop_preve_from_relea_re, _ti.id), app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
			return;	
		endif;
		//22/08/2023	navkc1	CR 59610 Task 59611 &lt;--
	endif;
	
	if _reserveSelection.allTrackedItems.includes(_ti) then
		return;
	endif;
	
	release := self.myMasterProxyObject.CM_BulkRelease;
	//remove if already assigned to another reserve, and validate it's not a cargo item from the 
	//release's allTrackedItemsReleased collection 
	foreach otherReserve in release.allReserveDetails do
		if otherReserve.allTrackedItemsReleased.includes(_ti) then//make sure they really want to take it out of the released items and move it back to the assigned items
			app.msgBox(app.getErrorString(Release_cargoitem_backAssigned), app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		
		if otherReserve.allTrackedItems.includes(_ti) then
			otherReserve.allTrackedItems.remove(_ti);
			//13 Dec 2017	NDL	TFS 8091
			if not otherReserve.isTransient then
				self.updateObjectEdition( otherReserve );
			endif;
		endif;
	endforeach;
	//remove if item was previously associated with a packing child line
	foreach otherReserve in release.allReservePackingChildren do
		if otherReserve.allTrackedItemsReleased.includes(_ti) then//make sure they really want to take it out of the released items and move it back to the assigned items
			app.msgBox(app.getErrorString(Release_cargoitem_backAssigned), app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		
		if otherReserve.allTrackedItems.includes(_ti) then
			otherReserve.allTrackedItems.remove(_ti);
			//13 Dec 2017	NDL	TFS 8091
			if not otherReserve.isTransient then
				self.updateObjectEdition( otherReserve );
			endif;
		endif;
	endforeach;
	
	_reserveSelection.addTI(_ti);

end;


</source>
        <Parameter name="_reserveSelection" type="CM_ReserveSelection" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="dropTIValidate" id="4fee3ed6-a668-4abc-a3b7-afb51a4ecb4f">
        <source>dropTIValidate(reserveSelection  : CM_ReserveSelection; 				
			   trackedItem		 : CM_TrackedItem);
/*
----------   ----------  --------------------------------------------------
Created:	24 May 2007 By cnwth2

Purpose:	

Changed On  Changed By  Reason
----------  ----------  --------------------------------------------------
01/04/2010	cnwdap1		PAR #23347 Add check for availability grade
18/01/2016  cnwma1		PAR #37411 Release Request Error message
14/12/2016	cnwdap1		TFS 3039 SNO Empty Container Pool Management
*/
vars
	release			: CM_BulkRelease;
	isoType			: CM_ISOType;
	stCode			: String;
	releaseCode		: String;
	reason 			: String;
	poolParty 		: CM_MTPoolingParty;				// TFS 3039
begin
			
	if trackedItem = null then
		return;
	endif;
	release := self.myMasterProxyObject.CM_BulkRelease;
	//compare isEmpty
	if (not release.fullRelease) and (not trackedItem.isEmpty) then
		app.raiseCMWarning2(Warn_Request_Line_Match, 'Empty status', trackedItem.id, null, trackedItem, trackedItem);
	endif;
	
	//compare cargo types
	if release.myVoyage &lt;&gt; null and release.myVoyage &lt;&gt; trackedItem.myVoyage then
		app.raiseCMWarning2(Warn_Request_Line_Match, app.getErrorString(Voyage), trackedItem.id, null, trackedItem, trackedItem);
	endif;
	//compare operator
	if release.myOperator &lt;&gt; null and release.myOperator &lt;&gt; trackedItem.myOperator then
		app.raiseCMWarning2(Warn_Request_Line_Match, app.getErrorString(Operator), trackedItem.id, null, trackedItem, trackedItem);
	endif;
	// Compare MT pool party																		// TFS 3039
	poolParty := release.myPoolingParty;															// TFS 3039
	if poolParty &lt;&gt; null and trackedItem.myPoolingParty &lt;&gt; poolParty then									// TFS 3039
		app.raiseCMException2(Cont_Not_In_Pooling_Party, trackedItem.id, poolParty.code, null, null);		// TFS 3039
	endif;																							// TFS 3039
	
// cnwdad1 13/08/2009 - PAR #20455.
	if app.isSubTerminalsOn(release.myTerminal) then
		if release.mySubTerminal &lt;&gt; trackedItem.mySubTerminal then
			if trackedItem.mySubTerminal = null then
				stCode	:=	app.getString(Null);
			else
				stCode	:=	trackedItem.mySubTerminal.code;
			endif;
			
			//+cnwml2 PAR24892
			if release.mySubTerminal = null then
				releaseCode	:=	app.getString(Null);
			else
				releaseCode	:=	release.mySubTerminal.code;
			endif;
			
			app.raiseCMException3(SubTerminal_TI_BR_Mismatch, trackedItem.id, stCode, releaseCode, null, null);
		endif;
	endif;
		
	if reserveSelection &lt;&gt; null then
		//compare cargo type
		if reserveSelection.myCargoType &lt;&gt; null and reserveSelection.myCargoType &lt;&gt; trackedItem.myCargoType then
			app.raiseCMWarning2(Warn_Request_Line_Match, app.getErrorString(CargoType), trackedItem.id, null, trackedItem, trackedItem);
		endif;
		
		if trackedItem.isContainer then
			//compare ISO type (or ISO type group)
			isoType := app.myRoot.allISOTypes[trackedItem.getISOType()];
			
			if isoType &lt;&gt; null and reserveSelection.myISOType &lt;&gt; null then
				if (reserveSelection.myISOType &lt;&gt; isoType)	or (reserveSelection.myISOType.myISOTypeGroup &lt;&gt; isoType.myISOTypeGroup) then
					app.raiseCMWarning2(Warn_Request_Line_Match, app.getErrorString(ISO_Type), trackedItem.id, null, trackedItem, trackedItem);
				endif;
			endif;
			
			// PAR #23347 compare availability grade
			if not reserveSelection.allAvailabilityGrades.isEmpty and not reserveSelection.allAvailabilityGrades.includes(trackedItem.CM_Container.availabilityGrade) then
				app.raiseCMWarning2(Warn_Request_Line_Match, app.getErrorString(AvailabilityGrade), trackedItem.id, null, trackedItem, trackedItem);
			endif;
			
		else
			//compare products
			if trackedItem.myProduct &lt;&gt; null
			and reserveSelection.myProduct &lt;&gt; null
			and trackedItem.myProduct &lt;&gt; reserveSelection.myProduct
			then
				app.raiseCMWarning2(Warn_Request_Line_Match, app.getErrorString(Product), trackedItem.id, null, trackedItem, trackedItem);
			endif;
		endif;
	endif;
	
	//todo tasks
	if trackedItem.hasToDoTasks then
		app.raiseCMWarning1(Cargo_item_todo_tasks_pendin, trackedItem.id, null, trackedItem, trackedItem);
	endif;
	
	//todo stops
	if trackedItem.hasStops then
		//app.raiseCMWarning1(Full_Replacement_Message, 'Cargo item ' &amp; _ti.id &amp; ' has stops yet to be cleared.', null, _ti, _ti); //- cnwmd1, Par 20524
		app.raiseCMWarning1(Cargo_item_stops_cleared, trackedItem.id, null, trackedItem, trackedItem);
	endif;
	
	if reserveSelection &lt;&gt; null then				// 18/01/2016 cnwma1 PAR #37411
		//11 Dec 2015	NDL	Par 37288
		if not trackedItem.testAgainstReserveSelection( reserveSelection, reason, false, null ) then
			app.raiseCMWarning2(Warn_Request_Line_Match, reason, trackedItem.id, null, trackedItem, trackedItem);
		endif;
	endif;
end;</source>
        <Parameter name="reserveSelection" type="CM_ReserveSelection"/>
        <Parameter name="trackedItem" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getAmountForTI" id="baf0b119-1866-40d7-9c11-e24936112907">
        <source>getAmountForTI(_ti : CM_TrackedItem; _showUnit : Boolean) : String protected;
/*

Date		Who		Reason
20 Jun 2014	cnwer1	Initial creation PAR 34406
28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
*/

vars
	req 			: CM_DeliveryRequest;
	aReserveTI		: CM_ReserveDetail;
	theReserveTI	: CM_ReserveDetail;	
	bulkRelease 	: CM_BulkRelease;
	cargoType       : CM_CargoType;
begin
	if _ti = null then
		return null;
	endif;
	
	cargoType := _ti.myCargoType;										//28.05.2024 navma1 #64224
	
	if not (cargoType.isBreakBulkMulti or cargoType.isBulkMulti) then	//28.05.2024 navma1 #64224
		return null;
	endif;
	
	//epr TFS 41398 20/2/19
	if self.mode = CMUI_TreeViewForm.Mode_View then
		bulkRelease:=self.myMasterObject.CM_BulkRelease;
	else
		bulkRelease:=self.myMasterProxyObject.CM_BulkRelease;
	endif;	
	
	if  bulkRelease &lt;&gt; null then
		foreach aReserveTI in bulkRelease.allReserveDetails do			
			if aReserveTI.allTrackedItems.includes(_ti)  then
				theReserveTI := aReserveTI;		
				req:=theReserveTI.getDeliveryRequestForTI(_ti);
				break;
			endif;
			
			if aReserveTI.allTrackedItemsReleased.includes(_ti) then
				theReserveTI := aReserveTI;
				break;
			endif;
		endforeach;
	endif;

	if cargoType.isBreakBulkMulti then											//28.05.2024 navma1 #64224
		if req &lt;&gt; null then
			return req.getQuantityForRequest.asStringJMT;
		else
			if theReserveTI &lt;&gt; null and theReserveTI.isKindOf(CM_ReserveTI) and theReserveTI.getTotalRequested &lt;&gt; null then
				return theReserveTI.getTotalRequested.asStringJMT ;
			else
				return _ti.totalQuantity.asStringJMT;
			endif;	
		endif;
	endif;
	
	if cargoType.isBulkMulti then												//28.05.2024 navma1 #64224
		if theReserveTI &lt;&gt; null  and theReserveTI.isKindOf(CM_ReserveTI)  then
			return cargoType.getBulkTrackByDisplayForWeight(theReserveTI.weightRequested,_ti.getDensity,_showUnit);
		else
			if req &lt;&gt; null then
				return cargoType.getBulkTrackByDisplayForWeight(req.weightRequested,_ti.getDensity,_showUnit);
			else		
				return cargoType.getBulkTrackByDisplayForWeight(_ti.totalWeight,_ti.getDensity,_showUnit);		
			endif;
		endif;
		
	endif;
		
	return null;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_showUnit" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBOLItems" id="e34a0a86-0a17-4f10-becc-b88c1baa8dca">
        <source>getBOLItems(cargoType : CM_CargoType; currentReserveTI : CM_ReserveTI) : CM_BOLDtl;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 27 February 2019
TFS#		: 41708
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	reserveDet		: CM_ReserveDetail;
	bulkRelease		: CM_BulkRelease;
	bolItems		: CM_BOLDtl;	
begin
	if self.myMasterProxyObject.isKindOf(CM_BulkRelease) then
		bulkRelease := self.myMasterProxyObject.CM_BulkRelease;
		foreach reserveDet in bulkRelease.allReserveDetails do
			if reserveDet.isKindOf(CM_ReserveTI) and reserveDet.getCargoType() = cargoType then
				if reserveDet.CM_ReserveTI &lt;&gt; currentReserveTI then
					bolItems := reserveDet.CM_ReserveTI.myBOLDtl;
					break;
				endif;
			endif;
		endforeach;
	endif;	
	return bolItems;
end;</source>
        <Parameter name="cargoType" type="CM_CargoType"/>
        <Parameter name="currentReserveTI" type="CM_ReserveTI"/>
        <ReturnType type="CM_BOLDtl"/>
    </JadeMethod>
    <JadeMethod name="getEntryTableForRow" id="95358a5d-aa85-45fc-9288-7f4a1136b74c">
        <source>getEntryTableForRow(_rowName: String): CM_EntryTable;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 05/05/2014	cnwdap1		Initial creation PAR #34058
//
vars

begin
	return self.tblEntry;

epilog

end;</source>
        <Parameter name="_rowName" type="String"/>
        <ReturnType type="CM_EntryTable"/>
    </JadeMethod>
    <JadeMethod name="getItemPictureForObj" id="aab6b6bb-bc64-45bd-b6ad-4e88ef28d041">
        <source>getItemPictureForObj(_obj : CM_Object) : Binary;
/*
----------   ----------  --------------------------------------------------
Created:	30 April 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	ti			: CM_TrackedItem;
begin
	if CM_BulkRelease.hasInstance(_obj) then
		if _obj.CM_BulkRelease.type = BR_TYPE_ROAD then
			return self.picRelRoad.picture;
		elseif _obj.CM_BulkRelease.type = BR_TYPE_RAIL then
			return self.picRelRail.picture;
		elseif _obj.CM_BulkRelease.type = BR_TYPE_SHIP then
			return self.picRelShip.picture;
		elseif _obj.CM_BulkRelease.type = BR_TYPE_PACKING then
			return self.picRelPacking.picture;
		endif;
	elseif CM_ReserveSelection.hasInstance(_obj) then
		return self.picRequestLine.picture;
	elseif CM_ReserveTI.hasInstance(_obj) then
		ti := _obj.CM_ReserveTI.getTI(); //epr par 32330 29/8/13
		if ti = null then
			return null;
		elseif ti.isContainer then
			return self.picContainer.picture;
		else
			return self.picGeneralCargo.picture;
		endif;
	elseif CM_TrackedItem.hasInstance(_obj) then
		
		if _obj.CM_TrackedItem.isContainer then
			return self.picContainer.picture;
		else
			return self.picGeneralCargo.picture;
		endif;
	endif;
	
	return null;
end;


</source>
        <Parameter name="_obj" type="CM_Object"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="getPinRecordForCargo" id="dc1e99f5-93e0-4cc7-af80-28250c07870c">
        <source>getPinRecordForCargo(_ti : CM_TrackedItem) : CM_String;
/*
Date		    Who			Reason
19 July 2011	cnwas3	  Initial creation: par 27739
*/

vars
	stringThing : CM_String;
	theTi			: CM_TrackedItem;
begin
	
	foreach stringThing in self.allPinNumbers do
		theTi := stringThing.myObject.CM_TrackedItem;
		
		if theTi = _ti then			
			return stringThing;
		endif;
	endforeach;

	return null;
epilog
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_String"/>
    </JadeMethod>
    <JadeMethod name="getProductForMeasurementTypes" id="dc9e5efa-7a8f-457f-bc86-374c444f4cb7">
        <source>getProductForMeasurementTypes(): CM_Product;
/*

Date		Who		Reason
17 October 2013	cnwer1	Initial creation PAR

*/

vars
	cargoType : CM_CargoType;
	product : CM_Product;
begin
	cargoType := self.cmbTiType.listObject.CM_CargoType;
	if cargoType = null then
		return null;
	endif;
	
	if self.tblEntry.isRowVisible(ETRow_MyProduct) then
		product:= self.cmbProduct.listObject.CM_Product;
	endif;
	
	if product &lt;&gt; null then
		return product;
	endif;
	
	return cargoType.mySystemProductType;
	
epilog

end;</source>
        <ReturnType type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="getRelValueForDebug" id="fd1d5a06-cf21-4acb-a842-30b0d8ba66ef">
        <source>getRelValueForDebug():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 May 2020	jlgndl1	Initial creation	TFS 48783  Debug stuff, we only have a max of 75 chars displayed in teh dump.

*/

vars

	dataIndicator : String;

begin

	/*
	1 = pre setTblFromRelease value 
	2 = post setTblFromRelease value 
	3 = pre saveUserEntryBulkRelease value
	4 = post saveUserEntryBulkRelease value
	5 = pre doTblEntryQryRowColChange when row = ReleaseNo  - inheritmethod in here calls saveUserEntryBulkRelease
	6 = pre first dropTIOnRelease in doLstTreeDragDropEvent
	7 = post first dropTIOnRelease in doLstTreeDragDropEvent
	8 = post last dropTIOnRelease in doLstTreeDragDropEvent
	9 = is immediately before the 'Dump' in 'doSave'
	
	'nX' means it had a value, 'n ' means it didn't.
	
	*/

	if self.tblEntry.getValueByName(ETRow_ReleaseNo).String.trimBlanks = null then
		dataIndicator := " ";
	else
		dataIndicator := "X";
	endif;
	
	return dataIndicator &amp; ",";
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getReserveTis" id="ed047cbc-824a-4f05-a0fe-f5743c326a6a">
        <source>getReserveTis( _objs : CM_ReserveDetailSet input) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 September 2016	cnwndl1	Initial creation	TFS 2646 / 2001

*/

vars

	count : Integer;
	baseIndex : Integer;
	baseLevelIndex : Integer;
	
	startIndex : Integer;
	listCount : Integer;
	
	index : Integer;
	obj : Object;

begin

	if _objs &lt;&gt; null then
		_objs.clear();
	endif;

	baseIndex := self.lstTree.listIndex;
	if baseIndex &gt; 1 then
		baseLevelIndex := self.lstTree.itemLevel[baseIndex];
		listCount := self.lstTree.listCount;
		if listCount &gt; baseIndex then
			startIndex := baseIndex + 1;
			foreach index in startIndex to listCount do
				if self.lstTree.itemLevel[index] &lt;= baseLevelIndex then
					break;
				endif;
				obj := self.lstTree.itemObject[index];
				if obj &lt;&gt; null then
					if CM_ReserveTI.hasInstance(obj) then
						count := count + 1;
						if _objs &lt;&gt; null then
							_objs.add( obj.CM_ReserveTI );
						endif;
					endif;
				endif;
			endforeach;
		endif;
	endif;

	return count;

epilog

end;</source>
        <Parameter name="_objs" type="CM_ReserveDetailSet" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTreeCaptionForObj" id="1f27f3fc-8229-4a2e-8620-700accc48a12">
        <source>getTreeCaptionForObj(_obj : CM_Object) : String;
/*
----------   ----------  --------------------------------------------------
Created:	02 May 2007 By cnwth2

Purpose:	

/* Changes

Date		Name	TFS#		Description
============================================================================
11/03/2019	jlgka1	41708		Add Cargo Type / Product Desc Change in 
								label when there is BOL Id assigned.
28/07/2022	navsrk20	ChangeRequest 53974: EUP - OUT - Additional Fields on Release Line Level
============================================================================*/
vars
	str			: String;
	ti 			: CM_TrackedItem;
	reserveTI	: CM_ReserveTI;
	bulkRelease	: CM_BulkRelease;
	reserveDet	: CM_ReserveDetail;
	prod : CM_Product;
begin
	if CM_BulkRelease.hasInstance(_obj) then
		if _obj.CM_BulkRelease.code = null then
			str := '&lt;' &amp; app.getErrorString(Adding_New_Request) &amp; '&gt;';
		else
			str := _obj.CM_BulkRelease.code;// &amp; ' (' &amp; _obj.CM_BulkRelease.getReleaseByTypeDescr() &amp; ')';
			
		endif;
	elseif CM_ReserveSelection.hasInstance(_obj) then
		//str := _obj.CM_ReserveSelection.getDescription();			//28/07/2022 navsrk20 TFS 53974	
		str := _obj.CM_ReserveSelection.lineNumber.String &amp; Space &amp; Hyphen &amp; Space &amp; _obj.CM_ReserveSelection.getDescription();		//28/07/2022 navsrk20 TFS 53974	
	elseif CM_ReserveTI.hasInstance(_obj) then
		//epr par 32330 29/8/13
		ti			:= _obj.CM_ReserveTI.getTI;
		reserveTI 	:= _obj.CM_ReserveTI; //jlgka1 TFS 41708
		if ti = null then
			return null;
		endif;
		//epr par 34406 24/6/14
		//epr par 34623 25/7/14
		str:=_obj.CM_ReserveTI.getTotalRequestedDisplay();
		if str = 0.String then
			str:=null;
		endif;
		if str &lt;&gt; null then
			str:=str &amp; " x " ;
		endif;
		str :=str &amp;  ti.id;
		
		//06 Sep 2018	NDL	TFS 39950
		if ti.myCargoType.allowDuplicates then
			if ti.isOnSite and ti.myPrimaryActualLocation &lt;&gt; null then
				str := str &amp; " " &amp; ti.myPrimaryActualLocation.getFullId;
			endif;
		endif;
		
	elseif CM_TrackedItem.hasInstance(_obj) then
		//epr par 34406 24/6/14
		ti := _obj.CM_TrackedItem;
		str:=self.getAmountForTI(ti,true);
		if str &lt;&gt; null then
			str:=str &amp; " x " ;
		endif;
		//epr par 34623 25/7/14
		str :=str &amp;  ti.id;
		
		//06 Sep 2018	NDL	TFS 39950
		if ti.myCargoType.allowDuplicates then
			if ti.isOnSite and ti.myPrimaryActualLocation &lt;&gt; null then
				str := str &amp; " " &amp; ti.myPrimaryActualLocation.getFullId;
			endif;
		endif;
	elseif CM_CargoType.hasInstance(_obj) then
		//jlgka1 TFS 41708 --&gt;
		str := _obj.CM_CargoType.description;
		if self.myMasterProxyObject.isKindOf(CM_BulkRelease) then
			bulkRelease := self.myMasterProxyObject.CM_BulkRelease;			
			foreach reserveDet in bulkRelease.allReserveDetails do
				if reserveDet.isKindOf(CM_ReserveTI) then
					if reserveDet.CM_ReserveTI.getCargoType() = _obj.CM_CargoType then						
						if reserveDet.CM_ReserveTI.myBOLDtl &lt;&gt; null then
							str := str &amp; " ( BOL Amount " &amp; reserveDet.CM_ReserveTI.myBOLDtl.quantity.String &amp; " )";
						endif;
						break;
					endif;
				endif;
			endforeach;
		endif;
		//jlgka1 TFS 41708 &lt;--
	elseif CM_Product.hasInstance(_obj) then
		//jlgka1 TFS 41708 --&gt;
	//	str := _obj.CM_Product.description;
		//18 May 2021	NDL	TFS 51183
		prod := _obj.CM_Product;
		if prod.myCargoType &lt;&gt; null then
			str := prod.myCargoType.description &amp; ", " &amp; prod.description;
		else
			str := prod.description;
		endif;
		
		if self.myMasterProxyObject.isKindOf(CM_BulkRelease) then
			bulkRelease := self.myMasterProxyObject.CM_BulkRelease;			
			foreach reserveDet in bulkRelease.allReserveDetails do
				if reserveDet.isKindOf(CM_ReserveTI) then
					if reserveDet.CM_ReserveTI.getMyProduct() &lt;&gt; null then
					//	if reserveDet.CM_ReserveTI.getMyProduct().description = _obj.CM_Product.description then
						if reserveDet.CM_ReserveTI.getMyProduct() = _obj.CM_Product then	//18 May 2021	NDL	TFS 51183
							if reserveDet.CM_ReserveTI.myBOLDtl &lt;&gt; null then
								str := str &amp; " ( BOL Amount " &amp; reserveDet.CM_ReserveTI.myBOLDtl.quantity.String &amp; " )";
							endif;
							break;
						endif;
					endif;
				endif;
			endforeach;
		endif;
		//jlgka1 TFS 41708 &lt;--	
	endif;
	
	
	return str;

end;


</source>
        <Parameter name="_obj" type="CM_Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getYardSourceDesc" id="8cdbac54-2ff6-462b-a43b-78ea22c8e2f6">
        <source>getYardSourceDesc(): String ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 July 2015	cnwma1	PAR #36555 CCMS 2509 TFS - Multi-location selection for MTs for vessel release

*/
vars
	msgStr 		: String;
	isISOType	: Boolean;
	isEmpty		: Boolean;
	imex		: CM_IMEXStatus;
	obj		 	: Object;
	sep 		: String;
	row 		: Integer;
begin

	row := self.tblEntry.getRowByName(ETRow_TotalRequested);
	obj := self.cmbOperator.myObject;
	if obj &lt;&gt; null then
		msgStr := msgStr &amp; sep &amp; 'Oper: ' &amp; obj.CM_Operator.code;
		sep := ', ';
	endif;
	
	if self.tblEntry.accessCell(row,2).text.asIntegerJMT &gt; 0 then
		msgStr := msgStr &amp; sep &amp;' Total requested: ' &amp; self.tblEntry.accessCell(row,2).text.String;
		sep := ', ';
	endif;
	
	if self.cmbISOGroup.getCurrentItemObject.CM_ISOTypeGroup &lt;&gt; null then	
		msgStr := msgStr &amp; sep &amp;'ISO Group: ' &amp; cmbISOGroup.getCurrentItemObject.CM_ISOTypeGroup.code;
		sep := ', ';
	endif;
	
	
	if self.cmbISOType.getCurrentItemObject().CM_ISOType &lt;&gt; null then	
		msgStr := msgStr &amp; sep &amp;'ISO Type: ' &amp; self.cmbISOType.getCurrentItemObject().CM_ISOType.code;
		sep := ', ';
	endif;

	return msgStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getYardSourceText" id="49036416-d2f2-48ed-b41c-56678ecb5ad7">
        <source>getYardSourceText():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 July 2015	cnwma1	PAR # 36555 CCMS 2509 TFS - Multi-location selection for MTs for vessel release

*/

vars
	ta 		: CM_TerminalArea;
	sep 	: String;
	result 	: String;
begin	

	foreach ta in self.allSelectedTAs do
		result := result &amp; sep &amp; ta.id;
		sep := ', ';
	endforeach;
	
	return result;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleSysNotify" id="f2cebd3e-4b44-4795-9f38-80570f803ca0">
        <updating/>
        <source>handleSysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	07 June 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.mode = self.Mode_Add then
		return;//we can't possibly be interested
	endif;
	if theObject &lt;&gt; self.myMasterObject then
		return;
	endif;
	
	if self.mode = self.Mode_View then
		if eventType = Object_Create_Event or eventType = Object_Update_Event then
			self.loadTree();
			self.selectObject(self.mySelectedObject);
		elseif eventType = Object_Delete_Event then
			app.msgBox(app.getErrorString(User_deleted_release_request), app.getErrorString(Information), MsgBox_Exclamation_Mark_Icon);
			self.loadTree();//this will clear everything
		endif;
	else//updating
		if eventType = Object_Delete_Event then
			app.msgBox(app.getErrorString(User_deleted_release_edit), app.getErrorString(Information), MsgBox_Exclamation_Mark_Icon);
			self.btnCancelBase.click(self.btnCancelBase);
			self.myMasterObject := null;
			self.loadTree();//this will clear everything
		endif;
	endif;

end;


</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hasPinRecordForCargo" id="d359db4d-f432-4b58-a04a-28bdb29c8db4">
        <source>hasPinRecordForCargo( _ti : CM_TrackedItem) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 December 2010	cnwrd1	Initial creation

*/

vars
	stringThing : CM_String;
	theTi			: CM_TrackedItem;
begin
	
	foreach stringThing in self.allPinNumbers do
		theTi := stringThing.myObject.CM_TrackedItem;
		
		if theTi = _ti then
			return true;
		endif;
	endforeach;

	return false;
epilog
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="ce13fb7d-4b41-4fd4-94ff-fe07ac2f9605">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
/*
----------   ----------  --------------------------------------------------
Created:	29 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	userWindow		: CM_UserWindow;
	theXML, theXMLValue : String;
begin
	inheritMethod(_userWindow);
	
	if _userWindow = null then
		return;
	endif;
	theXML := _userWindow.xmlInfo;
	theXMLValue := theXML.cnEcGetTagValueOfName(XML_IMEX);
	if theXMLValue &lt;&gt; null then
 		self.defaultImexStatus := theXMLValue.Integer;
 	endif;
	self.chkCloseOnSave.value := self.closeOnSave;
end;


</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="loadCommodityCombo" id="d7479f59-31b8-4210-8626-032b343f190b">
        <updating/>
        <source>loadCommodityCombo(_cargoType : CM_CargoType; _cmbCommodity : CMUI_ComboBox input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24/04/2025	navrv30	MTN 34319 EUP | Creating a Release Request from Cargo Review - Validation

*/

vars
	commodity 	: CM_Commodity;
begin
	commodity := _cmbCommodity.listObject.CM_Commodity;
	if _cargoType &lt;&gt; null then		
		if _cmbCommodity &lt;&gt; null then 
			
			if _cargoType.isCommodityRequired and not _cargoType.allCommodities.isEmpty then
				_cmbCommodity.listCollection(_cargoType.allCommodities, true, ComboBox.DisplayCollection_Forward);
				
				if commodity = null then
					commodity := _cargoType.allCommodities[_cargoType.defaultCommodityCode];					
					_cmbCommodity.click(_cmbCommodity);
				endif;
			else
				commodity := _cmbCommodity.listObject.CM_Commodity;
				_cmbCommodity.listCollection(app.myRoot.allCommodities, true, 0);
			endif;
			
		endif;
	else
		if _cmbCommodity &lt;&gt; null then 
			_cmbCommodity.listCollection(app.myRoot.allCommodities, true, 0);
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_cmbCommodity" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="loadTree" id="5a5d1a59-2916-4164-b7c3-c314bdb94a62">
        <updating/>
        <source>loadTree() updating;
/*
----------   ----------  --------------------------------------------------
Created:	30 April 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	releaseRequest			: CM_BulkRelease;
	
begin
	
	self.lstTree.clear();
	
	if self.mode = self.Mode_Add then
		releaseRequest := self.myMasterProxyObject.CM_BulkRelease;
	elseif self.mode = self.Mode_Update then
		releaseRequest := self.myMasterProxyObject.CM_BulkRelease;	
	else
		releaseRequest := self.myMasterObject.CM_BulkRelease;
	endif;
	
	self.treeAdd_ReleaseRequest(releaseRequest);
	
end;


</source>
    </JadeMethod>
    <JadeMethod name="lstColour_displayRow" id="1b153f8f-7ef9-4689-b9e6-9090e0227ff8">
        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstColour_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;
//
// Purpose:			
//
