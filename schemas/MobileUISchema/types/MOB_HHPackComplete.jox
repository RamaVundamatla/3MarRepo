    <JadeMethod name="handleBtnTwo" id="d17bb317-414f-4c63-935f-a5bdcd84f03b">
        <updating/>
        <source>handleBtnTwo() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

begin

	//20 Apr 2015	NDL	Par 36095
	// 7/9/2015 36688 don't need this - it caused the next pack action to use this in error
	///self.myHandHeldCheckerAgent.setMyNextTiToAction(self.myPackContainer);
	
	if self.btnTwo.caption = app.getErrorString(Seals) then	//08 Mar 2017	NDL	TFS 3635
		self.gotoForm(MOB_SealTaskForm, false);
	
	//08 Mar 2017	NDL	TFS 3635
	elseif self.btnTwo.caption = app.getErrorString(Checks) then	
		self.myMobileGenericAgent.setMyNextTiToAction(self.myPackContainer);
		self.myMobileGenericAgent.setChecksState(CONT_CHECK_CONTEXT_PACK);
		self.myMobileGenericAgent.setDisplayIdOnCheckForm(true);
		self.gotoForm( MOB_HHGateCheckCargo, false );	
		
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateCombos" id="d6868e46-299c-4966-8c25-2a7ff8c7d3c2">
        <source>populateCombos();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 July 2011	cnwndl1	Initial creation
06 Sep 2018	jlgrh7 TFS40370 POL - [Fwd: ##RE-7735## : FW: ANL on IZM811N]
*/

vars

	tmpPassport : CM_Passport;
	failedDAC  :CM_DataAccessController;
	operator : CM_Operator;
	startOperator : CM_Operator;
	term : CM_Terminal;
	subTerm : CM_SubTerminal;
	startSubTerminal : CM_SubTerminal;
	packContainerVoyage : CM_Voyage;			//+TFS40370 
	packContainer : CM_TrackedItem;				//+TFS40370 
begin

	packContainer := self.myPackContainer;		//+TFS40370 
	if packContainer &lt;&gt; null then
		packContainerVoyage := self.myPackContainer.myVoyage;
	endif;
	
	tmpPassport := app.myPassport;	
	startOperator := self.cmbOperator.listObject.CM_Operator;
	self.cmbOperator.clear();

	//+TFS40370  -- only use voyage's available operators rather than all operators
	if packContainerVoyage &lt;&gt; null
	and not packContainerVoyage.isNullVoyage	//27 Feb 2019	NDL	TFS 43544
	then 
		foreach operator in packContainerVoyage.allOperators do 
			if operator.isNotAvailableForEntry then
				continue;
			endif;
			if tmpPassport &lt;&gt; null and (not operator.canUserAccessSelf(null, failedDAC, tmpPassport)) then
				continue;
			endif;
			self.cmbOperator.itemObject[self.cmbOperator.addItem(operator.code &amp; Tab &amp; operator.description)] := operator;
		endforeach;
	else
		//26 Feb 2019	NDL	TFS 43544
		foreach operator in app.myRoot.allOperators do
			if operator.isNotAvailableForEntry then
				continue;
			endif;
			if tmpPassport &lt;&gt; null and (not operator.canUserAccessSelf(null, failedDAC, tmpPassport)) then
				continue;
			endif;
			self.cmbOperator.itemObject[self.cmbOperator.addItem(operator.code &amp; Tab &amp; operator.description)] := operator;
		endforeach;
	endif;
	
	if startOperator &lt;&gt; null then
		self.cmbOperator.listIndex := self.cmbOperator.findObject(startOperator);
	endif; 
	
	if self.cmbOperator.listIndex = -1 and self.myPackContainer.myOperator &lt;&gt; null then
		self.cmbOperator.listIndex := self.cmbOperator.findObject( self.myPackContainer.myOperator );
	endif;
	
	

	if app.isSubTerminalsOn(self.myTerminal) then
	
		startSubTerminal := self.cmbSubTerminal.listObject.CM_SubTerminal;
		self.cmbSubTerminal.clear;
	
		self.cmbSubTerminal.visible := true;
		foreach subTerm in self.myTerminal.allSubTerminals do
			self.cmbSubTerminal.itemObject[self.cmbSubTerminal.addItem(subTerm.code)] := subTerm;
		endforeach;
		
		if startSubTerminal &lt;&gt; null then
			self.cmbSubTerminal.listIndex := self.cmbSubTerminal.findObject(startSubTerminal);
		endif; 
		
		if self.cmbSubTerminal.listIndex = -1 and self.myPackContainer.mySubTerminal &lt;&gt; null then
			self.cmbSubTerminal.listIndex := self.cmbSubTerminal.findObject( self.myPackContainer.mySubTerminal );
		endif;
		
	else
		self.cmbSubTerminal.clear;
		self.cmbSubTerminal.visible := false;
		self.cmbSubTerminal.listIndex := -1;
		
	endif;
	
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupControls" id="990313f3-5e64-4a04-b415-75e1557e21e5">
        <updating/>
        <source>setupControls() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 July 2011	cnwndl1	Initial creation

*/

vars

begin
								
	self.doResizeControls(true);
								
	self.populateCombos();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="0271fc8a-137b-408a-904c-cd58733f58b7">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

	checks : Boolean;
	nullTi : CM_TrackedItem;

begin
	
	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	self.myPackContainer := self.myMobileGenericAgent.myPackTi;

	inheritMethod();
	
	//08 Mar 2017	NDL	TFS 3635
	checks := false;
	if not self.myTerminal.hasNoCargoCheckItemsFor(CONT_CHECK_CONTEXT_PACK) then
		checks := self.myMobileGenericAgent.isWaitingOnRequiredChecks(CONT_CHECK_CONTEXT_PACK, self.myPackContainer, nullTi) &lt;&gt; null;
	endif;
	
	if checks then	//08 Mar 2017	NDL	TFS 3635
		self.setupCmdButtons( 3, app.getErrorString(Complete), app.getErrorString(Checks), app.getErrorString(Back), null, null );
	else
		self.setupCmdButtons( 3, app.getErrorString(Complete), app.getErrorString(Seals), app.getErrorString(Back), null, null );
	endif;
	
	self.setupControls();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="ed805900-c6a5-4aa8-a2b9-63f89dcbbafe">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0016611, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
