Date		Who		Reason
16 Apr 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars
	xlation	:CM_Xlation;
begin
	// we expect _coll to be the collection of xlations for the  receiver
	foreach xlation in _coll do
