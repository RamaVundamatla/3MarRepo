    <JadeMethod name="getParentForMachine" id="4ae9bbf2-bb0f-4df3-a0ce-86ba5f688cb1">
        <source>getParentForMachine(_machine: CM_Machine): CM_Object;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 February 2010	cnwer1	Initial creation

*/

vars

begin
	if	not ( _machine.machineType = MACHINETYPE_RTG or _machine.machineType = MACHINETYPE_RMG) then
		return  self.myTerminalArea;
	endif;

	return inheritMethod(_machine);

epilog

end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
