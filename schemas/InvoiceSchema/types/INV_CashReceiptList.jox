    <JadeMethod name="applyAgentToCargo" id="b652d3c9-3d59-4239-b650-7c8f848d3f56">
        <updating/>
        <source>applyAgentToCargo() updating, protected;

/*

Purpose:		Apply the entered customs agent/consignee etc, if any, to the selected cargo.
				Resync the relevent transactions before showing the current and proforma charges.

Parameters:			

Return Value:		


Date				Who		Reason
13 September 2013	cnwjre1	Initial creation
29 August 2017		jlgma1	TFS #5725 QNS - System Performance issues
18 Oct 2024			navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	allTIs 			: CM_TISet;
	tiChildren		: CM_TISet;
	allChildren		: CM_TIArray;
	pxyTISet		: CM_TISet;
	row  			: Integer;
	ti 				: CM_TrackedItem;
	child			: CM_TrackedItem;
	pxyTI			: CM_TrackedItem;
	pxyChild		: CM_TrackedItem;
	trans			: CM_TITransaction;
	consignee		: CM_ConsigneeConsignor;
	customsAgent	: CM_CustomsAgent;
	obj 			: Object;
	controller	    : CMIF_TiTransactionResync;
	logMessage		: String;
	rtnValue		: Boolean;
	result			: Integer;
	theReturn		: Integer;
	operator 		: CM_Operator;
	includeTI : Boolean;
	canLogExtra		: Boolean;			//26.02.2025 navah1	#34141
	agentCode : String;
begin

	create allTIs transient;
	create allChildren transient;
	canLogExtra	:= app.canLogExtraDetail();				//26.02.2025 navah1	#34141
	row := 2;
	while row &lt;= self.tblCharges.rows do
	
		obj := self.tblCharges.accessRow(row).itemObject;
		
		if obj &lt;&gt; null then
			if obj.isKindOf( CM_TrackedItem ) then
				ti := obj.CM_TrackedItem;
				
				/* TFS 47864  WAS
				if self.tblCharges.accessCell(row, 1).text = self.selectedString 
					or self.myQueryCashReceipt &lt;&gt; null then		// 34227 edit
						allTIs.add(ti);
				endif;
				NOW */

				// TFS 47864 need to include ti if doing find or clicking calculate again
				includeTI := (self.tblCharges.helpKeyword = "CHARGES") 
					or self.tblCharges.accessCell(row, 1).text = self.selectedString 
					or self.myQueryCashReceipt &lt;&gt; null;
					
				if includeTI then
					allTIs.add(ti);
				endif;				
			endif;
		endif;
		
		row := row + 1;
		
	endwhile;

	if self.cmbAgent.listObject	&lt;&gt; null then		// only apply the agent if selected
		// set the debtor directly from the agent
		if self.cashDebtorType.code = "SDT2" then
			consignee := self.cmbAgent.listObject.CM_ConsigneeConsignor;
			agentCode := consignee.code;  // ### JIRA 35502 18JUL2025 NAVAB1
			self.setMyDebtor(consignee.debtor);
		elseif self.cashDebtorType.code = "SDT3" then
			consignee := self.cmbAgent.listObject.CM_ConsigneeConsignor;
			agentCode := consignee.code;  // ### JIRA 35502 18JUL2025 NAVAB1
			self.setMyDebtor(consignee.debtor);
		elseif self.cashDebtorType.code = "SDT4" then // TFS 37454
			operator := self.cmbAgent.listObject.CM_Operator; // TFS 37454
			agentCode := operator.code;  // ### JIRA 35502 18JUL2025 NAVAB1
			self.setMyDebtor(operator.debtor); // TFS 37454
		elseif self.cashDebtorType.code = "SDT6" then
			customsAgent := self.cmbAgent.listObject.CM_CustomsAgent;
			agentCode := customsAgent.code;  // ### JIRA 35502 18JUL2025 NAVAB1
			self.setMyDebtor(customsAgent.myDebtor);
		elseif self.cashDebtorType.code = "SDT7" then
			consignee := self.cmbAgent.listObject.CM_ConsigneeConsignor;
			agentCode := consignee.code;  // ### JIRA 35502 18JUL2025 NAVAB1
			self.setMyDebtor(consignee.debtor);
		// ### TFS CR 65810 TASK 65811 27AUG2024 NAVAB1
		elseif self.cashDebtorType.code = "SDT1" then
			operator := self.cmbAgent.listObject.CM_Operator;
			agentCode := operator.code;  // ### JIRA 35502 18JUL2025 NAVAB1
			self.setMyDebtor(operator.debtor);
		endif;
		// 34800 handle children
		create tiChildren transient;
		foreach ti in allTIs do
			tiChildren.clear();
			ti.getAllNestedChildren(tiChildren);
			foreach child in tiChildren do
				allChildren.add(child);
			endforeach;
		endforeach;

		create pxyTISet transient;
		foreach ti in allTIs do
			// TFS 45953 Performance
			if not self.shouldApplyAgent(ti,self.cmbAgent.listObject.CM_Object) then
				continue;
			endif;
		
			//  creating a proxy for a parent also does it for the children
			if allChildren.includes(ti) then
				continue;
			endif;
			if pxyTISet &lt;&gt; null then // PAR 36319 
				pxyTISet.purge(); // PAR 36319 
			endif; // PAR 36319 
			pxyTI := app.createUpdateProxy(ti).CM_TrackedItem;
			pxyTISet.add(pxyTI);
			if self.cashDebtorType.code = "SDT2" then
				pxyTI.zSetPxyConsignee(consignee.code);
				logMessage := "Consignee " &amp; pxyTI.consignee;
			elseif self.cashDebtorType.code = "SDT3" then
				pxyTI.zSetPxyConsignor(consignee.code);
				logMessage := "Consignor " &amp; pxyTI.consignor;
			// ### TFS CR 65835 TASK 65891 27AUG2024 NAVAB1
			elseif self.cashDebtorType.code = "SDT1" then
				pxyTI.zSetPxyOperator(operator);
				logMessage := "Cargo Operator " &amp; pxyTI.operatorCode; 
			elseif self.cashDebtorType.code = "SDT4" then // TFS 37454
				pxyTI.zSetPxyOperator(operator); // TFS 37454
				logMessage := "Operator " &amp; pxyTI.operatorCode; // TFS 37454
			elseif self.cashDebtorType.code = "SDT6" then
				pxyTI.zSetPxyCustomsAgent(customsAgent);
				logMessage := "Customs agent " &amp; pxyTI.myCustomsAgent.code;
			elseif self.cashDebtorType.code = "SDT7" then
				pxyTI.zSetPxyFreightFowarderCode(consignee.code);
				logMessage := "Freight forwarder " &amp; pxyTI.freightForwarderCode;
			endif;
			//  set the child agent as well
			foreach pxyChild in pxyTI.allChildren do
				if self.cashDebtorType.code = "SDT2" then
					pxyChild.zSetPxyConsignee(consignee.code);
				elseif self.cashDebtorType.code = "SDT3" then
					pxyChild.zSetPxyConsignor(consignee.code);
				elseif self.cashDebtorType.code = "SDT6" then
					pxyChild.zSetPxyCustomsAgent(customsAgent);
				elseif self.cashDebtorType.code = "SDT7" then
					pxyChild.zSetPxyFreightFowarderCode(consignee.code);
				// ### TFS CR 65835 TASK 65891 27AUG2024 NAVAB1
				elseif self.cashDebtorType.code = "SDT1" then
					pxyChild.zSetPxyOperator(operator);
				endif;
			endforeach;
			
			
			// ### PAR 36319 - break bulk in multiple locations. As 1 is updated the others are auto update (damage, haz and stops) 
			//							this changes the edition and so gives an error if all are updated in 1 transaction. 
			//							So moved the trxUpdateTrackedItems into the loop and update 1 at a time.
			
			while true do
				// bulk-update the customs agent etc
				app.myTrxUA.trxUpdateTrackedItems(pxyTISet, TI_UPDMODE_NORMAL, null, app.myPassport);
		
				if app.myPassport.trxCompletedOK then
					rtnValue := true;
					break;
				else
					// from testing Apr 2016 no point in showing the warnings
					//result := app.showErrorWarningDialog('Cash Receipt', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
					result := IDOK;
					if app.myPassport.noErrors and
					result = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
	
					self.setAllErrorWarnings(app.myPassport);
				endif;
			
				rtnValue := false;
				break;
			endwhile;
			
		endforeach;
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("** " &amp; logMessage &amp; " applied to selected cargo **", LogTRACE.String);
		endif;
	endif;
	
	// resync regardless, as the agent may have been applied to the cargo before using this screen
	foreach ti in allTIs do
		create controller transient;
		controller.myTrackedItem := ti;
		controller.force := true;
		if self.cashDebtorType.code = "SDT2" then
			controller.updateConsignee := true;
		elseif self.cashDebtorType.code = "SDT3" then
			controller.updateConsignor := true;
		elseif self.cashDebtorType.code = "SDT6" then
			controller.updateCustomsAgent := true;
		elseif self.cashDebtorType.code = "SDT7" then
			controller.updateFreightForwarder := true;
		// ### TFS CR 65835 TASK 65891 27AUG2024 NAVAB1
		elseif self.cashDebtorType.code = "SDT1" then
			controller.updateOperator := true;
		endif;
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("Re-evaluate transactions for " &amp; ti.id, LogTRACE.String);
			app.invLog(" ", LogDEBUG.String);
		endif;
		// resync all transactions even those with posted invoices
		foreach trans in ti.allTransactions do		
		
		// 37707 resync now handles posted invoice lines - do need to do them for any other non-posted lines
			
			//29.08.2017 cnwma1 TFS #5725
			if self.isTransNeedReSync(trans, agentCode, self.cashDebtorType) then  // ### JIRA 35502 25JUL2025 NAVAB1
				controller.allTransactions.add(trans);
			 endif;
		endforeach;

		while true do
			app.myTrxUA.trxUpdateRsyncTrans(controller, app.myPassport);
			if app.myPassport.trxCompletedOK then
				self.clearErrorWarnings();
				break;
			else
				theReturn := app.showErrorWarningDialog("Transaction Resync", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);
			endif;
			break;
		endwhile;
		delete controller;
	endforeach;
	
epilog
	delete allTIs;
	delete allChildren;
	if pxyTISet &lt;&gt; null then
		pxyTISet.purge();
	endif;
	delete pxyTISet;
	delete controller;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="applyEvenWeight" id="0a07c459-dec5-46ad-abfa-e4ecd4f59519">
        <updating/>
        <source>applyEvenWeight() updating, protected;

/*

Purpose:		Apply the total weight of the BOL evenly to each container in the BOL,
				then apply the total cargo weight of each container evenly to the child cargo.
				The weight of the containers and children is changed regardless of whether they are selected or not.
				Resync the transactions before showing the current and proforma charges.
				If a Calculate has been done, do another one to show the new weights and charges.

Parameters:			

Return Value:		


Date		Who		Reason
09/03/2015	cnwjre1	Initial creation GPHA 2368
18 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	allTIs 				: CM_TISet;
	allChildren			: CM_TIArray;
	pxyTISet			: CM_TISet;
	childCount			: Integer;
	ti 					: CM_TrackedItem;
	pxyTI				: CM_TrackedItem;
	pxyChild			: CM_TrackedItem;
	trans				: CM_TITransaction;
	controller  		: CMIF_TiTransactionResync;
	logMessage			: String;
	containerWeight,
	childWeight			: Decimal[14, 4];
	rtnValue			: Boolean;
	result				: Integer;
	theReturn			: Integer;
	canLogExtra			: Boolean;	//26.02.2025 navah1	#34141
begin
	if self.myBOL = null then
		return;
	endif;
	
	containerWeight := self.myBOL.getBOLWeightForContainer();
	if containerWeight = null then
		return;
	endif;
	
	create allTIs transient;
	create allChildren transient;
	
	foreach ti in self.myBOL.allTrackedItems discreteLock where ti.isContainer do
		allTIs.add(ti);
	endforeach;
	
	if allTIs.isEmpty  then
		return;
	endif;
	
	canLogExtra	:= app.canLogExtraDetail();				//26.02.2025 navah1	#34141
	
	if canLogExtra then	//26.02.2025 navah1	#34141
		app.invLog(logMessage &amp; "BOL container weight of " &amp; containerWeight.String &amp; " applied to " &amp; allTIs.size.String &amp; " containers and contents", LogTRACE.String);
	endif;
	
	create pxyTISet transient;
	
	foreach ti in allTIs do
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog(logMessage &amp; "Container " &amp; ti.id &amp; " weight changed from " &amp; ti.totalWeight.String &amp; " to " &amp; containerWeight.String, LogTRACE.String);
		endif;
		// this creates proxies for each child as well
		pxyTI := app.createUpdateProxy(ti).CM_TrackedItem;
		pxyTI.zSetPxyWeight(containerWeight);
		pxyTISet.add(pxyTI);
			
		childCount := ti.allChildren.size;
		if childCount &gt; 0 then
			childWeight := containerWeight / childCount;
			
			foreach pxyChild in pxyTI.allChildren do
				if canLogExtra then	//26.02.2025 navah1	#34141
					app.invLog(logMessage &amp; "Contents " &amp; pxyChild.id &amp; " weight changed from " &amp; pxyChild.totalWeight.String &amp; " to " &amp; childWeight.String, LogTRACE.String);
				endif;
				// set the weight
				pxyChild.zSetPxyWeight(childWeight);
			endforeach;
		endif;
	endforeach;

	while true do
		// bulk-update the new weights to the containers and children
		app.myTrxUA.trxUpdateTrackedItems(pxyTISet, TI_UPDMODE_NORMAL, null, app.myPassport);

		if app.myPassport.trxCompletedOK then
			rtnValue := true;
			break;
		else
			result := app.showErrorWarningDialog('Cash Receipt', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
		endif;
		
		rtnValue := false;
		break;
	endwhile;
	// delete the proxies
	if pxyTISet &lt;&gt; null then
		pxyTISet.purge();
		delete pxyTISet;
	endif;
	// don't continue if error
	if not rtnValue then
		return;
	endif;
	
	foreach ti in allTIs do
		create controller transient;
		controller.myTrackedItem := ti;
		controller.updateWeight := true;
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("Re-evaluate transactions for " &amp; ti.id, LogTRACE.String);
			app.invLog(" ", LogDEBUG.String);		
		endif;
		// resync all transactions EVEN those with posted invoices
		foreach trans in ti.allTransactions do
		// 37707 resync now handles posted invoice lines - do need to do them for any other non-posted lines
			controller.allTransactions.add(trans);
		endforeach;

		while true do
			app.myTrxUA.trxUpdateRsyncTrans(controller, app.myPassport);
			if app.myPassport.trxCompletedOK then
				self.clearErrorWarnings();
				break;
			else
				theReturn := app.showErrorWarningDialog("Transaction Resync", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);
			endif;
			break;
		endwhile;
		delete controller;
	endforeach;

	doCalculate();
epilog
	delete allTIs;
	delete allChildren;
	if pxyTISet &lt;&gt; null then
		pxyTISet.purge();
	endif;
	delete pxyTISet;
	delete controller;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnCalculate_click" id="c41684b2-ae87-4531-9daa-c46f07ae0da7">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCalculate_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 July 2012	cnwndl1	Initial creation

*/

vars

begin

	self.doCalculate();

	

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnCheck_click" id="1bab4cfa-7e35-42a4-abf8-ed819d4982ca">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCheck_click(btn: Button input) updating;
/*

Date		Who		Reason
01 December 2014	cnwer1	Initial creation PAR 35304 CCMS GHA 2369 &amp; 2373 - eGate Integration

*/

vars
	ca : CM_CustomsAgent;
begin
	
	ca:=app.myRoot.allCustomsAgents[self.txtCustomsAg.text];
	if ca &lt;&gt; null then
		if self.cmbAgent.findObject(ca) &lt; 1 then
			ca:=null;
		endif;
		
	endif;
	
	if ca = null then
		self.lblCheckAgent.caption:="Invalid";
		self.lblCheckAgent.visible :=true;
		self.txtCustomsAg.text:=null;
		self.lblCheckAgent.foreColor:=Red;
		self.cmbAgent.listObject:=null;
	else

		self.lblCheckAgent.caption:="Valid";
		self.lblCheckAgent.visible :=true;
		self.lblCheckAgent.foreColor:=Green;
		self.cmbAgent.listObject:=ca;
		self.doAgentChange();
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnClose_click" id="30bc2e2f-9911-4113-94e0-43db2c19975f">
