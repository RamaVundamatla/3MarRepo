<Class name="Property">
    <JadeMethod name="cnEcDescription" id="ee01b190-7e65-426e-aca9-903ab134442e">
        <source>cnEcDescription(pOwnerObj:Object; pIncludeValue:Boolean):String;
// --------------------------------------------------------------------------------
// Created:		12 December 2005 by cnwdad1
//
// Purpose:		Returns a description of the receiver.
//
// Parameters:	pOwnerObj - A reference to the object on which the receiver is implemented.
//				pIncludeValue - If true, the receiver's primitivew value will be
//					included in the description.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	displayValue	: String;
	typeObj			: Type;
	propertyLength	: Integer;
	
begin
	typeObj			:=	self.getType();
	displayValue	:=	self.getName() &amp; ", " &amp; typeObj.name;
	propertyLength	:=	self.getLength();
	
	if typeObj.cnEcIsPrimitive() then
		if self.getType().getName() = "String" then				
			if propertyLength = -1 then
				displayValue	:=	displayValue &amp; ", Length=Maximum";
			else
				displayValue	:=	displayValue &amp; ", Length=" &amp; (propertyLength - 1).cnEcNumberFormat();
			endif;
		else
			displayValue	:=	displayValue &amp; ", Length=" &amp; propertyLength.cnEcNumberFormat();
		endif;
		
		if pIncludeValue and pOwnerObj &lt;&gt; null then
			displayValue	:=	displayValue &amp; ", Value=" &amp; pOwnerObj.getPropertyValue(self.getName()).String;
		endif;
	endif;
	
	return displayValue;
end;</source>
        <Parameter name="pOwnerObj" type="Object"/>
        <Parameter name="pIncludeValue" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcDocumentSelf" id="b06b9029-2f64-4a22-9c79-776602c423f9">
        <source>cnEcDocumentSelf(	pParameterObj:CnEcDocParameter;
					pAlias:String;
					pHtmlFile:File io;
					pIsIncludeRootSchemaClasses:Boolean;
					pSchemaColl:SchemaColl; pPathToIndex:String);
// --------------------------------------------------------------------------------
// Created:		12 October 2000 by cnwdad1
//
// Purpose:		Generates an HTML file to document the receiving property.
//
// Parameters:	pParameterObj - A reference to the class documentation parameter object.
//				pAlias - The alias name of the receiver. This may be null, in which
//					case, the actual name of the receiver will be used.
//				pHtmlFile (File) - The target documentation file.
//				pIsIncludeRootSchemaClasses (Boolean) - If true, RootSchema classes
//					will also be documented (useful for showing hyperlinks from
//					Class property references).
//				pSchemaColl (SchemaColl) - The collection (Array) of schemas that
//					are a valid list of schemas to be documented (used when including
//					hyperlinks from Class property references to the documentation
//					for for the reference type's Class).
//				pPathToIndex (String) - The file path if the documentation index file.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 21/10/2000	cnwdad1		Move the code to resolve a hyperlink to the requested
//							class into a (protected) method on SchemaEntity called
//							"cnEcDocumentGetClassHyperlink" so it can be reused.
// 23/01/2003	cnwdad1		Added support for an alias of the receiver's name.
// 19/02/2003	cnwdad1		Added the pTheParameter parameter so that hyperlinks
//							will not be generated to classes that are not included
//							in the documentation.
// 21/02/2003	cnwdad1		Changed to not print property text if the option on the
//							doc. parameter object to include class text is not set.
// --------------------------------------------------------------------------------
vars
	nameOfProperty		: String;
	accessType			: Character;
	propertyAccess		: String;
	propertyLength		: Integer;
	propertyText		: String;
	classHyperlink		: String;

begin
	if self.getName() &lt;&gt; "_persistentImpRefs"
	and self.getName() &lt;&gt; "_transientImpRefs"
	and (not self.isSystemObject())
	then
		// If the property if a reference to another class, then we want to include a
		// hyperlink to that class's documentation file from the "Type" name.

		if self.isKindOf(Reference) and pSchemaColl &lt;&gt; null then
			classHyperlink	:=	self.cnEcDocumentGetClassHyperlink(	pParameterObj,
																	self.getType.name,
																	pIsIncludeRootSchemaClasses,
																	pSchemaColl,
																	pPathToIndex);
		endif;

		// First, add a row to the table for the property features.

		accessType	:=	self.access;

		if accessType = 0.Character then
			propertyAccess	:=	"Public";
		elseif accessType = 1.Character then
			propertyAccess	:=	"Read only";
		elseif accessType = 2.Character then
			propertyAccess	:=	"Protected" ;
		endif;
		
		if pAlias = null then
			nameOfProperty	:=	self.getName();
		else
			nameOfProperty	:=	pAlias;
		endif;
		
		pHtmlFile.writeLine("&lt;TR&gt;");
		pHtmlFile.writeLine("&lt;TD&gt;" &amp; nameOfProperty &amp; "&lt;/TD&gt;");
		
		if classHyperlink = null then
			// Write the property type without a hyperlink.
			pHtmlFile.writeLine("&lt;TD&gt;" &amp; self.getType().getName() &amp; "&lt;/TD&gt;");
		else
			// Write the property type with a hyperlink to the Type class documentation file.
			pHtmlFile.writeLine("&lt;TD&gt;" &amp; classHyperlink &amp; "&lt;/TD&gt;");
		endif;
		
		propertyLength	:=	self.getLength();

		if self.getType().getName() = "String" then				
			if propertyLength = -1 then
				pHtmlFile.writeLine("&lt;TD&gt;Maximum&lt;/TD&gt;");
			else
				pHtmlFile.writeLine("&lt;TD&gt;" &amp; (propertyLength - 1).String &amp; "&lt;/TD&gt;");
			endif;
		else
			pHtmlFile.writeLine("&lt;TD&gt;" &amp; propertyLength.String &amp; "&lt;/TD&gt;");
		endif;

		pHtmlFile.writeLine("&lt;TD&gt;" &amp; propertyAccess &amp; "&lt;/TD&gt;");
		pHtmlFile.writeLine("&lt;/TR&gt;");

		// Now add a row for the Property Text (if there is any).

		propertyText	:=	self.text;

		if pParameterObj.isIncludeClassText and propertyText &lt;&gt; null then
			pHtmlFile.writeLine("&lt;TR&gt;");
			pHtmlFile.writeLine("&lt;TD COLSPAN=4&gt;&lt;TT&gt;" &amp; propertyText &amp; "&lt;/TT&gt;&lt;/TD&gt;");
			pHtmlFile.writeLine("&lt;/TR&gt;");
		endif;
	endif;
end;</source>
        <Parameter name="pParameterObj" type="CnEcDocParameter"/>
        <Parameter name="pAlias" type="String"/>
        <Parameter name="pHtmlFile" type="File" usage="io"/>
        <Parameter name="pIsIncludeRootSchemaClasses" type="Boolean"/>
        <Parameter name="pSchemaColl" type="SchemaColl"/>
        <Parameter name="pPathToIndex" type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetDetails" id="75e54526-0011-4ac3-bd04-dc1e5ddd40a7">
        <source>cnEcGetDetails(pOwnerObj:Object; pAllDetails:CnEcArray input);
// --------------------------------------------------------------------------------
// Created:		17 December 2005 by cnwdad1
//
// Purpose:		Returns a description of the receiver.
//
// Parameters:	pOwnerObj - A reference to the object on which the receiver is implemented.
//				pAllDetails - A reference to a multi-dimensional array to be populated
//					with the receiver's details.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	typeObj			: Type;
	propertyLength	: Integer;
	
begin
	typeObj			:=	self.getType();
	pAllDetails.addString(self.getName() &amp; Tab &amp; typeObj.name);
	propertyLength	:=	self.getLength();
	
	if typeObj.cnEcIsPrimitive() then
		if self.getType().getName() = "String" then				
			if propertyLength = -1 then
				pAllDetails.addString("Length" &amp; Tab &amp; "Maximum");
			else
				pAllDetails.addString("Length" &amp; Tab &amp; (propertyLength - 1).cnEcNumberFormat());
			endif;
		else
			pAllDetails.addString("Length" &amp; Tab &amp; propertyLength.cnEcNumberFormat());
		endif;
		
		pAllDetails.addString("Value" &amp; Tab &amp; pOwnerObj.getPropertyValue(self.getName()).String);
	else
		pAllDetails.addString("Type" &amp; Tab &amp; typeObj.class.cnEcGetSystemType().name);
		pAllDetails.addString("Schema" &amp; Tab &amp; self.getSchema().name);
		pAllDetails.addString("Length" &amp; Tab &amp; propertyLength.cnEcNumberFormat());
	endif;
end;</source>
        <Parameter name="pOwnerObj" type="Object"/>
        <Parameter name="pAllDetails" type="CnEcArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsAttribute" id="48e0c2ba-e3aa-4e7e-8ae4-766ea02f6745">
        <source>cnEcIsAttribute():Boolean;
// --------------------------------------------------------------------------------
// Created:		01 November 2001 by cnwdad1
//
// Purpose:		Returns a flag to indicate whether the receiver is an Attribute.
//
// Parameters:	None
//
// Returns:		True if the receiver is an Attribute, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsCollection" id="8f964057-d15d-4574-a3f2-86a8c934b38a">
        <source>cnEcIsCollection():Boolean;
// --------------------------------------------------------------------------------
// Created:		01 November 2001 by cnwdad1
//
// Purpose:		Returns a flag to indicate whether the receiver is a Collection Type.
//
// Parameters:	None
//
// Returns:		True if the receiver is a Collection Type, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.type.cnEcIsCollection();
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
