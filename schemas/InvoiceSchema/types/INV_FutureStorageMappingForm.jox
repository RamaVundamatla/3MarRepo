        <updating/>
        <source>cmbGroup_click(combobox: ComboBox input) updating;
/*
Purpose:			
Date		Who		Reason
20 May 2015	cnwab1	Initial creation
20/06/2023	navkc1	Defect 58743: Showing Multiple Label name
*/

vars

begin


	self.myStorageGroup := combobox.listObject.CM_TerminalAreaStorageGroup; // PAR 36275
	self.myStorageMapping := null;
	self.myQuantityRangeMap := null;
	self.btnAddSub.enabled := false; //20/06/2023	navkc1	Defect 58743 - Force the user to select a Quantity Map range 
	self.loadStorageTable(); // PAR 36275
epilog

end;</source>
