    <JadeMethod name="getVolumeString" id="1dd65eb6-fdc4-480f-bdd5-0ff26c1f161a">
        <source>getVolumeString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2021	navndl1	Initial creation	TFS 50906 

*/

vars
	
	cargoType : CM_CargoType;
	measureType : CM_MeasurementType;
	type : String;

begin

	cargoType := self.getCargoType;

	if self.volume = 0 then
		return null;
		
	elseif cargoType &lt;&gt; null and cargoType.isTrackByVolume then
		measureType := cargoType.getDefaultMeasurementForType(Type_Volume);
		type := measureType.shortName;
		return app.convertMeasurementForDisplay(type, self.volume ) &amp; " " &amp; type;
			
	endif;

	return self.volume.asStringJMT;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyage" id="5ea2fd8a-3667-45bc-b123-fba5e11bb2a5">
        <source>getVoyage(): CM_Voyage;
/*
Purpose:		LOCATION EVENT INVOICING	


#### CM_Transaction has 'getMyVoyage' CM_Event uses 'getVoyage'



ASPA say to charge the voyage not the barge

Date		Who		Reason
14JUN2021	NAVAB1	TFS 51219
*/

vars

begin
	//NAVAB1 Dmast/Wmast differences for 20.0.21.000
	return self.getMyVoyage();
	

epilog

end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="getVoyageCodes" id="b00efc37-31ce-4620-aa12-381db57eddd7">
        <source>getVoyageCodes():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	str : String;

begin
/* WAS NAVAB1 Dmast/Wmast differences for 20.0.21.000
	if self.mySourceVoyage &lt;&gt; null then
		str := self.mySourceVoyage.code; 
	endif;
	
	if self.myTargetVoyage &lt;&gt; null then
		if str &lt;&gt; null then
			str := str &amp; "," &amp; self.myTargetVoyage.code;
		else
			str := self.myTargetVoyage.code;
		endif;
	endif;
	NOW */
	
	if self.mySourceVoyage &lt;&gt; null then
		if self.mySourceVoyage.isBarge then
			if self.myTargetVoyage &lt;&gt; null then
				if not self.myTargetVoyage.isBarge then
					str := self.myTargetVoyage.code; 
				endif;
			endif;

		else
			str := self.mySourceVoyage.code; 
		endif;
	endif;
	
	if self.myTargetVoyage &lt;&gt; null then
		if str &lt;&gt; null then
			str := str &amp; "," &amp; self.myTargetVoyage.code;
		else
			str := self.myTargetVoyage.code;
		endif;
	endif;
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyageGroupCode" id="585626f3-0649-4dfc-ab9a-4c8b94f7608c">
        <source>getVoyageGroupCode(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 June 2021	navndl1	Initial creation	TFS 51245

*/

vars

begin

	if self.mySourceVoyage &lt;&gt; null then
		if self.mySourceVoyage.voyageGroupCode &lt;&gt; null then
			return self.mySourceVoyage.voyageGroupCode;
		endif;
	endif;
	
	if self.myTargetVoyage &lt;&gt; null then
		if self.myTargetVoyage.voyageGroupCode &lt;&gt; null then
			return self.myTargetVoyage.voyageGroupCode;
		endif;
	endif;
	
	return null;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVvrVisitNumbers" id="9ba25971-8f71-4551-92db-1fb9854be9aa">
        <source>getVvrVisitNumbers():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2021	navndl1	Initial creation	TFS	TFS 50906

*/

vars

	str : String;

begin

	if self.mySourceVVR &lt;&gt; null then
		str := self.mySourceVVR.visitNumber; 
	endif;
	
	if self.myTargetVVR &lt;&gt; null then
		if str &lt;&gt; null then
			str := str &amp; "," &amp; self.myTargetVVR.visitNumber;
		else
			str := self.myTargetVVR.visitNumber;
		endif;
	endif;
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWeightString" id="832c5aa2-f5f0-497d-97aa-6866f180c413">
        <source>getWeightString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2021	navndl1	Initial creation	TFS 50906 

*/

vars

	cargoType : CM_CargoType;
	measureType : CM_MeasurementType;
	type : String;

begin

	cargoType := self.getCargoType;

	if self.weight = 0 then
		return null;
		
	elseif cargoType &lt;&gt; null and cargoType.isTrackByWeight then
		measureType := cargoType.getDefaultMeasurementForType(Type_Weight);
		type := measureType.shortName;	
		return app.convertMeasurementForDisplay(type, self.weight ) &amp; " " &amp; type;

	endif;
	
	return self.weight.asStringJMT;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getYardLocationIds" id="7c788a17-a4ef-454f-b9a8-f550ef1ac2e1">
        <source>getYardLocationIds():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	str : String;
	invalid : Boolean;

begin

	on Exception do app.handleDeletedObject( exception, self.mySourceLocation, invalid );

	if self.mySourceLocation &lt;&gt; null and self.mySourceLocation.isActivityTrackingLocation then
		str := self.mySourceLocation.getFullId; 
	endif;
	
	on Exception do app.handleDeletedObject( exception, self.myTargetLocation, invalid );

	if self.myTargetLocation &lt;&gt; null and self.myTargetLocation.isActivityTrackingLocation then
		if str &lt;&gt; null then
			str := str &amp; "," &amp; self.myTargetLocation.getFullId;
		else
			str := self.myTargetLocation.getFullId;
		endif;
	endif;
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasAudits" id="84a1af95-a104-4e61-bea5-138ea7488bcb">
        <source>hasAudits(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2021	navndl1	Initial creation	TFS 

*/

vars

	hasAudits : Boolean;
	allAuditObjects : CM_AuditObjectDictByTimestamp;
	stateData : Any;

begin

	//when new audits is in production this re-implementation of 'hasAudits'  method can be deleted.

	process.isNDLAudits;
	
	stateData := self.getExtraData("allAuditObjects");
	if stateData &lt;&gt; null then
		allAuditObjects := stateData.CM_AuditObjectDictByTimestamp;
		hasAudits := not allAuditObjects.isEmpty;
	endif;
	
	return hasAudits;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="inventoryRowData" id="b1e3d3e5-1b9a-4c00-8490-aad3eefb69af">
        <source>inventoryRowData( _ta : CM_TerminalArea; _lc : CM_LocationsController; _weightMeasurementType : CM_MeasurementType  ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	locationStr : String;
	cargoTypeAbbrev : String;
	inAmount : String;
	outAmount : String;
	taIdString : String;
	charged : Boolean; // ### TFS 51219 03JUN2021 NAVAB1
begin

	if _lc &lt;&gt; null then
		if _lc = mySourceLocation and _lc = myTargetLocation then
			locationStr := "Source and Target Location";
			inAmount := self.getAmountString(false, _weightMeasurementType); // ### TFS 51515 13JUL2021 NAVAB1
			outAmount := self.getAmountString(false, _weightMeasurementType); // ### TFS 51515 13JUL2021 NAVAB1
		elseif _lc = mySourceLocation then
			locationStr := "Source Location";
			outAmount := self.getAmountString(false, _weightMeasurementType); // ### TFS 51515 13JUL2021 NAVAB1
		elseif _lc = myTargetLocation then
			locationStr := "Target Location";
			inAmount := self.getAmountString(false, _weightMeasurementType); // ### TFS 51515 13JUL2021 NAVAB1
		endif;
		
		if _ta &lt;&gt; null then // ### TFS 51515 13JUL2021 NAVAB1
			taIdString :=  _ta.id; // ### TFS 51515 13JUL2021 NAVAB1
		endif;
	elseif _ta &lt;&gt; null then
		taIdString :=  _ta.id;
		if _ta = mySourceTA and _ta = myTargetTA then
			locationStr := "Source and Target Location";
			inAmount := self.getAmountString(false, _weightMeasurementType); // ### TFS 51515 13JUL2021 NAVAB1
			outAmount := self.getAmountString(false, _weightMeasurementType); // ### TFS 51515 13JUL2021 NAVAB1
		elseif _ta = mySourceTA then
			locationStr := "Source Location";
			outAmount := self.getAmountString(false, _weightMeasurementType); // ### TFS 51515 13JUL2021 NAVAB1
		elseif _ta = myTargetTA then
			locationStr := "Target Location";
			inAmount :=  self.getAmountString(false, _weightMeasurementType); // ### TFS 51515 13JUL2021 NAVAB1
		endif;
	elseif _ta = null and _lc = null then
		if self.mySourceTA &lt;&gt; null and self.myTargetTA &lt;&gt; null then
			if self.mySourceTA = self.myTargetTA then
				taIdString := self.mySourceTA.id;
			else
				taIdString := self.mySourceTA.id &amp; "/" &amp; self.myTargetTA.id;
			endif;
			locationStr := "Source and Target Location";
		elseif  self.mySourceTA &lt;&gt; null then
			taIdString := self.mySourceTA.id;
			locationStr := "Source Location";
		elseif self.myTargetTA &lt;&gt; null then
			taIdString := self.myTargetTA.id;
			locationStr := "Target Location";
		else
			taIdString := "Unknown";
			locationStr := "Unknown";
		endif;
	endif;
	
	if self.isLocationBalance then
		inAmount := null;
		outAmount := null;
	endif;
	
	if self.myCargoType &lt;&gt; null then
		cargoTypeAbbrev := self.myCargoType.abbreviation;
	endif;
	
	charged := not self.allInvoiceLines.isEmpty(); // ### TFS 51219 03JUN2021 NAVAB1
	
	return self.needsRecalculation.getYesNo
	&amp; Tab &amp; taIdString
 // ### TFS 51515 13JUL2021 NAVAB1	&amp; Tab &amp; locationStr
	&amp; Tab &amp; cargoTypeAbbrev
	&amp; Tab &amp; self.operatorCode
	&amp; Tab &amp; self.getDisplayString
	&amp; Tab &amp; self.dateTime.asStringJMT
	&amp; Tab &amp; inAmount
	&amp; Tab &amp; outAmount
	&amp; Tab &amp; self.getNetAmountString( _ta, _lc, false, _weightMeasurementType)
	&amp; Tab &amp; self.remarks
	&amp; Tab &amp; charged.getYes(); // ### TFS 51219 03JUN2021 NAVAB1
				
epilog

end;</source>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_weightMeasurementType" type="CM_MeasurementType"/>
        <ReturnType type="String"/>
    </JadeMethod>
