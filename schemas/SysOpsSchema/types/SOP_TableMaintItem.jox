    <JadeMethod name="doSave" id="1f4793be-70a1-466b-ad0b-5669882e2516">
        <updating/>
        <source>doSave() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     18 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
