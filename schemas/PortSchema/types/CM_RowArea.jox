    <JadeMethod name="createRowAreaRowGap" id="bcb1c57a-7441-437b-a884-f543f0eb0934">
        <source>createRowAreaRowGap(_width : Real; _pos : Integer) protected;
// 
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------
// 10/06/2020	jlgdap1		TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
vars

	row : CM_RowAreaRow;

begin
	if self.skipGapCreation() then	// TFS 49453
		return;						// TFS 49453
	endif;							// TFS 49453
	// Create a new gap.
	create row persistent;
	row.setAttributes(_width);
	self.allRows.insert(_pos, row);

end;</source>
        <access>protected</access>
        <Parameter name="_width" type="Real"/>
        <Parameter name="_pos" type="Integer"/>
    </JadeMethod>
