    <JadeMethod name="setComboValues" id="ec6ec75e-ab42-47d4-a81d-c561924ca2f8">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 July 2021	navndl1	Initial creation	TFS 51528

*/
	
vars
	
	strArray : StringArray;
	str : String;
	
begin

	_combo.clear;
	
	create strArray transient;
	
	CMEVT_LocationActivity@allMovementTypes( strArray );
	
	foreach str in strArray do
		_combo.addItem(str);
	endforeach;
	
epilog

	delete strArray;
	
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="169e3fe9-b07f-4cbc-881e-9f90feb0395d">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 July 2021	navndl1	Initial creation	TFS 51528

*/

vars
	
	selectionValue	: Boolean;
	strArray : StringArray;
	str : String;
	
begin

	_tbl.rows := _tbl.fixedRows;
	
	create strArray transient;
	
	CMEVT_LocationActivity@allMovementTypes( strArray );
	
	foreach str in strArray do
		selectionValue := false;
		_tbl.accessRow(_tbl.addItem(selectionValue.cnEcGetTableCheckBoxValue &amp; Tab &amp; str ) );
	endforeach;
	
epilog

	delete strArray;
	
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="2e71e1e8-17e8-4e08-9cb3-647a68bd6c05">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 July 2021	navndl1	Initial creation	TFS 51528

*/

vars

	str : String;
	strArray : StringArray;
	numRows : Integer;
	idx : Integer;
	

begin

	create strArray transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			strArray.add(str);
		endif;
	endforeach;
	
	_op.setSearchValue(strArray);

epilog

	delete strArray;
	
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
