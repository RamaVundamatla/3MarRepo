    <JadeMethod name="create" id="4dec4701-94ca-455b-b46b-2e93c310ce3a">
        <updating/>
        <source>create() updating;
/*
----------   ----------  --------------------------------------------------
Created:	07 April 2009 By cnwdz2

Purpose:	CCMS1735: 

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin

	self.name := SOP_TableMaintForm.Table_SubTerminals;
	self.permissionView	 := PmAdmSubTerminalView;
	self.permissionMaint := PmAdmSubTerminalMaint;
	self.myDataClass := CM_SubTerminal;

end;</source>
