    <JadeMethod name="doDeleteTrain" id="94990575-5aa7-4dd4-abb8-3b429b6521bb">
        <updating/>
        <source>doDeleteTrain() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	07 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	train			: CM_Train;
	result			: Integer;
begin
	if self.mode &lt;&gt; self.Mode_View then
		return;
	endif;
	
	train  := self.mySelectedTrain;
	if train = null then
		//app.msgBox('You must select a train to delete first','Nothing selected', MsgBox_Exclamation_Mark_Icon); //- cnwmd1, CCMS 1067, Par 19710
		app.msgBox(app.getErrorString(Must_select_train_delete_first),app.getErrorString(Nothing_Selected), MsgBox_Exclamation_Mark_Icon); //+ cnwmd1, CCMS 1067, Par 19710
		return;
	endif;
	
	//if app.msgBox('Are you sure you want to delete train "' &amp; train.code &amp; '"?','Are you sure?', MsgBox_OK_Cancel) &lt;&gt; MsgBox_Return_OK then //- cnwmd1, CCMS 1067, Par 19710
	if app.msgBox(app.getErrorString1(Sure_that_want_delete_train, train.code),app.getErrorString(Are_You_Sure), MsgBox_OK_Cancel) &lt;&gt; MsgBox_Return_OK then //+ cnwmd1, CCMS 1067, Par 19710
		return;
	endif;
	
	while true do
		app.myTrxDA.trxDeleteTrain(self.mySelectedTrain, false, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			self.mySelectedTrain := null;
			self.setControlsForView();
			return;
		else
			//result := app.showErrorWarningDialog('Train Delete', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings); //- cnwmd1, CCMS 1067, Par 19710
			result := app.showErrorWarningDialog(app.getErrorString(Train_delete), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings); //+ cnwmd1, CCMS 1067, Par 19710
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		
		return;
	endwhile;
	
end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDeleteWagon" id="a09dd96f-2dfd-4b69-957c-48accc50d90a">
        <updating/>
        <source>doDeleteWagon() protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	20 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	allWagons			: CM_WagonSet;
	objArray			: ObjectArray;
	obj					: Object;
	str					: String;
	theReturn : Integer;
begin
	objArray := self.tblWagons.allSelectedObjects;
	if self.tblWagons.allSelectedObjects.isEmpty then
		//app.msgBox('Please select a wagon or wagons to delete first.', 'No wagons selected', MsgBox_OK_Only + MsgBox_Information_Icon); //+ cnwmd1, CCMS 1067, Par 19710
		app.msgBox(app.getErrorString(Pleas_selec_wagon_wagon_delet_), app.getErrorString(No_wagons_selected), MsgBox_OK_Only + MsgBox_Information_Icon);
		
		return;
	endif;
	create allWagons transient; // PAR 20607
	foreach obj in objArray do
		if str = null then
			str := obj.CM_Wagon.id;
		else
			str := str &amp; ", " &amp; obj.CM_Wagon.id;
		endif;
		allWagons.add(obj.CM_Wagon);// PAR 20607
	endforeach;
	
	//if app.msgBox('Are you sure you want to delete wagon(s) : ' &amp; str,'Are you sure?', MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then //- cnwmd1, CCMS 1067, Par 19710
	if app.msgBox(app.getErrorString1(Sure_you_want_delete_wagons, str), app.getErrorString(Are_You_Sure), MsgBox_Question_Mark_Icon + MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then //+ cnwmd1, CCMS 1067, Par 19710
		return;
	endif;
/*// PAR 20607	
	foreach obj in objArray do
		app.myTrxDA.trxDeleteWagon(obj.CM_Wagon, app.myPassport);
		
		if (not app.myPassport.trxCompletedOK) then
			//app.showErrorWarningDialog('Delete wagon', app.myPassport, ErrWarnMode_AddUpdate); //- cnwmd1, CCMS 1067, Par 19710
			app.showErrorWarningDialog(app.getErrorString(Delete_wagon), app.myPassport, ErrWarnMode_AddUpdate); //+ cnwmd1, CCMS 1067, Par 19710
		else
			self.clearErrorWarnings();
		endif;
	endforeach;
	// PAR 20607 now */

	while true do
		app.myTrxDA.trxDeleteWagons(allWagons, false, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Delete), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;

	self.doRefresh;	//18 Oct 2017	NDL	TFS 7459
	
epilog
	delete allWagons;
end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doEditViewWagon" id="d71d1eb6-bc13-442f-baa8-30b4b2f48cf9">
        <source>doEditViewWagon(_mode : Integer io)protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 June 2009	cnwmd1	Initial creation

*/

vars
	wagonForm : YRD_TrainWagonForm;
	wagon : CM_Wagon;
begin
	wagon := self.tblWagons.allSelectedObjects.first.CM_Wagon;
	if wagon = null then
		app.msgBox(app.getErrorString(Please_select_wagon), app.getErrorString(No_Wagon_selected), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	//cnwjo3 par 21920
	/*if wagon.confirmed then
		if _mode = YRD_TrainWagonForm.Mode_Update then
			if app.msgBox(app.getErrorString(This_wagon_been_confi_conno_ed), app.getErrorString(Wagon_confirmed), MsgBox_Exclamation_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
				_mode :=  YRD_TrainWagonForm.Mode_View;
			else
				return;
			endif;
		endif;
	endif;*/
	
	app.mousePointer := MousePointer_HourGlass;
	
	wagonForm := app.loadForm(YRD_TrainWagonForm, YRD_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).YRD_TrainWagonForm;
	
	if wagonForm = null then
		return;
	endif;
	
	self.setNavigatorHeading(app.getErrorString(Wagon_maintenance)); 
	wagonForm.setParentForm(self);
	wagonForm.setMyTerminal(self.myTerminal);
	wagonForm.setMyTrainForWagonCombo(self.mySelectedTrain);
	wagonForm.initialiseForm(self.mySelectedTrain, wagon, _mode);
	wagonForm.show;
		
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
        <Parameter name="_mode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doEnableForConfirm" id="419bdd9e-b8e8-4e20-be0e-ab37e2db1377">
        <source>doEnableForConfirm(_enable : Boolean);
// ---------------------------------------------------------------------------
// Created:     13 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.frmToolbar.enabled := _enable;
