    <JadeMethod name="getQueueTasks" id="88da7309-935c-456e-93c8-0e30beddf1bd">
        <source>getQueueTasks( arbiter : CM_RTQueueArbiter io; _isSource : Boolean);
//Each locations controller supplies the tasks required to do its stuff.
vars
	task	: CM_RTQueueTask;	
begin
	//epr par 33099 3/12/13 was 1090 because was queuing to CM_GeneralCargoController that didn't reimplement this method
	//now provide default task creation
	create task;
	if _isSource then
		
		task.setDetails(self,
						arbiter.targetLocation,
						TASK_UNACTIONED,
						TASK_PICKUP,
						arbiter.ti);	
	else
		//target
		task.setDetails(arbiter.sourceLocation,
						self,
						TASK_UNACTIONED,
						TASK_SETDOWN,
						arbiter.ti);
		
	endif;
	arbiter.entry.addTask(task);
end;</source>
        <Parameter name="arbiter" type="CM_RTQueueArbiter" usage="io"/>
        <Parameter name="_isSource" type="Boolean"/>
    </JadeMethod>
