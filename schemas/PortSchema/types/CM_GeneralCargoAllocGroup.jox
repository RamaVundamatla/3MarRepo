    <JadeMethod name="pxyCreateUpdateProxy" id="cada5130-154d-4c22-8d4c-17dce8727b63">
        <source>pxyCreateUpdateProxy(): SelfType;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 09/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars
	proxy : SelfType;
	lc : CM_LocationsController;
	col, pxyCol : CM_GeneralCargoAllocController;
	completedOK : Boolean;

begin
	proxy := inheritMethod();
	
	foreach lc in self.allLocations discreteLock do
		col := lc.CM_GeneralCargoAllocController;
		pxyCol := col.pxyCreateUpdateProxy();
		pxyCol.setDetails(col.id, proxy);
	endforeach;
	
	completedOK := true;
	return proxy;

epilog
	if not completedOK then
		delete proxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setDetails" id="c2eb67a7-6b39-4c00-8025-57fcdb7e4865">
        <updating/>
        <source>setDetails(_id : String; _ta : CM_GeneralCargoAllocRowArea) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars

begin
	self.locationId := _id;
	self.id := _id;
	self.ident := _id;
	self.myTerminalArea := _ta;
epilog

end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_ta" type="CM_GeneralCargoAllocRowArea"/>
    </JadeMethod>
    <JadeMethod name="testAreYouNextToMe" id="c957ccfb-83f4-4298-9b61-8e528cccb13c">
        <source>testAreYouNextToMe(pController: CM_LocationsController): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 18/05/2021	navdap1		Initial creation TFS 49899 MTN Labour on Block for New GC Areas
//
vars
	area : CM_GeneralCargoAllocRowArea;
	belowMe, aboveMe : CM_LocationsController;

begin
	area := self.myTerminalArea.CM_GeneralCargoAllocRowArea;
	belowMe := area.allRowControllersById.getAtKeyLss(self.id);
	aboveMe := area.allRowControllersById.getAtKeyGtr(self.id);
	
	if belowMe &lt;&gt; null and belowMe = pController then
		return true;
	elseif aboveMe &lt;&gt; null and aboveMe = pController then
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="pController" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateCargoProdMinMax" id="7f3fc19f-199a-442c-a57b-ef7dc4a62019">
        <source>updateCargoProdMinMax( _cargoType : CM_CargoType; _prod : CM_Product; _capacity : Real);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 March 2021	navndl1	Initial creation	TFS 49912

*/

vars

	realProdMinMax : CM_TerminalAreaProductMinMax;
	pxyProdMinMax : CM_TerminalAreaProductMinMax;
	maxQuantity : Integer;
	maxVolume : Decimal[16,4];
	maxWeight : Integer;

begin
	
	if _cargoType = null then
		return;
	endif;

	realProdMinMax := self.getProductMinMaxObject( _cargoType, _prod );
	
	if _capacity &lt;= 0 then
		if realProdMinMax &lt;&gt; null then
			//we don't need this one anymore.
			delete realProdMinMax;
		endif;
		return;
		
	else
	
		if _cargoType.isBulkMulti then
			if _cargoType.isTrackByWeight then
				maxWeight := _capacity.Integer;
			elseif  _cargoType.isTrackByVolume then
				maxVolume := _capacity;
			endif;
		else
			maxQuantity := _capacity.Integer;
		endif;
	
		if realProdMinMax = null then
			create pxyProdMinMax transient;
			create realProdMinMax persistent;
		else
			pxyProdMinMax := realProdMinMax.pxyCreateUpdateProxy();
		endif;
		
		pxyProdMinMax.setupProxy(null, _cargoType, _prod, null, 0, 0, maxVolume, maxWeight, maxQuantity );
		
		realProdMinMax.setFromPxyLocationMinMax( self, pxyProdMinMax );
		
	endif;

epilog

	delete pxyProdMinMax;

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_prod" type="CM_Product"/>
        <Parameter name="_capacity" type="Real"/>
    </JadeMethod>
    <JadeMethod name="updateRangeLabel" id="5e223afd-1df0-40fc-b54f-1ab3ea5c8fe8">
        <updating/>
