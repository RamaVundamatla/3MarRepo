    <JadeMethod name="cmbDischargePort_change" id="5f1918a7-89ed-48df-a953-102e7f7ed8d5">
        <controlMethod name="ComboBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbDischargePort_change(combobox: ComboBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2009	cnwas3	Initial creation

*/

vars
	tmpVoyage	: CM_Voyage;
	voyageCode	: String;

	port	: CM_Port;
begin

	voyageCode := self.cmbVoyageCode.text;
	
	tmpVoyage := self.myAssistant.getVoyageFromCombo(voyageCode);

	port := self.cmbDischargePort.listObject.CM_Port;

	self.cmbTranshipPort.setObjectAndVoyageDischPort(port,tmpVoyage);
	
	self.checkIMEXvalue();	//02 Aug 2013	NDL	Par 32154
	
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbDischargePort_click" id="22e0e79f-e802-4fd7-8794-4216219651c1">
        <controlMethod name="CMUI_ComboBoxObject::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbDischargePort_click(combobox: ComboBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2009	cnwas3	Initial creation

*/
vars
	tmpVoyage	: CM_Voyage;
	voyageCode	: String;

	port	: CM_Port;
begin
	if combobox.visible then
		
		voyageCode := self.cmbVoyageCode.text;
	
		tmpVoyage := self.myAssistant.getVoyageFromCombo(voyageCode);

		port := self.cmbDischargePort.listObject.CM_Port;

		self.cmbTranshipPort.setObjectAndVoyageDischPort(port,tmpVoyage);
		
		self.checkIMEXvalue();	//02 Aug 2013	NDL	Par 32154
		
	endif;
	
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
