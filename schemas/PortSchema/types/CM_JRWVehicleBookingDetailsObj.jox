    <JadeMethod name="populateMe" id="610a2872-39ad-4aaa-b35a-c79c8d547730">
        <updating/>
        <source>populateMe( _vbTs : CM_VehicleBookingTimeSlot ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 August 2014	cnwndl1	Initial creation	Penn CCMS 2399

*/

vars

	invalidObject : Boolean;
	edition : Integer;

	tiArray : CM_TIArray;
	ti : CM_TrackedItem;
	
	cargoRec : CM_JRWVBCargoReceive;
	cargoRel : CM_JRWVBCargoRelease;
	
	splitRollEvt : CMEVT_SplitRollBooking;
	bookingRef : CM_BookingRef;
	skipOver : Boolean;
	bookingRefItem : CM_BookingRefItem;
	reserveDetail : CM_ReserveDetail;
	
	cargoRecByType : CM_JRWVBCargoReceiveByType;
	
	bulkRelease : CM_BulkRelease;
	
	cargoRelByType : CM_JRWVBCargoReleaseByType;

begin

	self.myVehicleBookingTimeSlot := _vbTs;
	
	if _vbTs = null then
		return;
	endif;
	
	on Exception do app.handleDeletedObject( exception, _vbTs, invalidObject );
	
	edition := _vbTs.edition;
	if invalidObject then
		return;
	endif;
	
	// find the cargo items to be picked up
	create tiArray transient;
	_vbTs.getPickUpTis( tiArray );
	
	foreach ti in tiArray do
		cargoRel := self.createVBCargoRelease( ti );
	endforeach;
	
	// find the cargo items to be delivered
	tiArray.clear();
	_vbTs.getDeliveryTis( tiArray );
	
	foreach ti in tiArray do
		cargoRec := self.createVBCargoReceive( ti );
	endforeach;
	
	if _vbTs.myVehicleVisitRecord = null then
	
		//This one has not been used yet, so check the bookings and releases
		// If it had been used, we would have got teh detail in teh previous calls.
	
		//find booking items - (deliveries)
		//Add the pre-notes as CM_JRWVBCargoReceive items
		//Add the 'by type' BookingItems as CM_JRWVBCargoReceiveByType items
		foreach bookingRef in _vbTs.allBookingRefs do
			skipOver := false;
			foreach splitRollEvt in bookingRef.allSplitRollEventsAsOld do
				if splitRollEvt.isKindOf(CMEVT_RollBooking) then
					skipOver := true;
					break;
				endif;
			endforeach;
			if skipOver then
				continue;
			endif;
			foreach bookingRefItem in bookingRef.allBookingRefItems discreteLock do
				if bookingRefItem.quantity &lt; 1 and bookingRefItem.weight = 0 then
					continue;
				endif;
				if bookingRefItem.myReserveDetail &lt;&gt; null then
					reserveDetail := bookingRefItem.myReserveDetail;
					if reserveDetail.hasOutstanding and reserveDetail.myReserveHeader.type = BR_TYPE_ROAD then
						if reserveDetail.isKindOf(CM_ReserveSelection) then
							cargoRecByType := self.createVBCargoReceiveByType( reserveDetail.CM_ReserveSelection );
						elseif reserveDetail.isKindOf(CM_ReserveTI) then
							ti := reserveDetail.CM_ReserveTI.getTI;
							cargoRec := self.createVBCargoReceive( ti );
						endif;
					endif;
				endif;
				if bookingRefItem.allTIs.size() &gt; 0 then	
					foreach ti in bookingRefItem.allTIs do	
						if ti.isPreNote() and not ti.isChild then		
							cargoRec := self.createVBCargoReceive( ti );
						endif;									
					endforeach;									
				endif;
			endforeach;
		endforeach;

		//find all release requests
		//add the ti of the CM_ReserveTI as CM_JRWVBCargoRelease items
		//Add the 'by type' CM_ReserveSelection as CM_JRWVBCargoReleaseByType items
		foreach bulkRelease in _vbTs.allBulkReleases do
			if bulkRelease.releaseByType then
				foreach reserveDetail in bulkRelease.allReserveDetails discreteLock do
					if reserveDetail.isKindOf(CM_ReserveSelection) then
							cargoRelByType := self.createVBCargoReleaseByType( reserveDetail.CM_ReserveSelection );
						elseif reserveDetail.isKindOf(CM_ReserveTI) then
							ti := reserveDetail.CM_ReserveTI.getTI;
							cargoRel := self.createVBCargoRelease( ti );
						endif;
				endforeach;
			else
				foreach reserveDetail in bulkRelease.allReserveDetails discreteLock do
					if reserveDetail.hasOutstanding() then
						ti := reserveDetail.CM_ReserveTI.getTI;
						cargoRel := self.createVBCargoRelease( ti );
					endif;
				endforeach;
			endif;	
		endforeach;
	
	endif;
	
	

epilog

end;</source>
        <Parameter name="_vbTs" type="CM_VehicleBookingTimeSlot"/>
    </JadeMethod>
</Class>
