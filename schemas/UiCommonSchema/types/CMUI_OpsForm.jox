    <JadeMethod name="updateAddWle" id="9f8e29f7-7bf8-4fc7-aa9d-3a68ce05894a">
        <updating/>
        <source>updateAddWle(_wle : CM_WorkListEntry; _mode : Integer)updating, protected;
//--------------------------------------------------------------
//Created: 13 January 2004 By: cnwgd1
//--------------------------------------------------------------
vars
	str			: String;
	rtCol,
	rowIdx		: Integer;
begin

	if _wle = null then
		return;
	endif;
	
	if _mode &lt; Mode_Add or _mode &gt; Mode_Update then
		return;
	endif;

	rtCol := self.tblWorkEntries.getColumnByRowName(ETRow_RadioTelemetry);	
	
	if _mode = self.Mode_Update then
		str := self.displayRowForDataTable(_wle, self.tblWorkEntries);
		if self.tblWorkEntries.findObjectInRow(_wle, rowIdx) then
			self.doNotableRemove(_wle.myTrackedItem);
			self.tblWorkEntries.accessCell(rowIdx, 1).text := str;
			self.tblWLESetRowColour(_wle, rowIdx, rtCol);
		else
			rowIdx := self.tblWorkEntries.addItem(str);
			self.tblWorkEntries.accessRow(rowIdx).itemObject := _wle;	
			self.tblWLESetRowColour(_wle, rowIdx, rtCol);		
		endif;
	elseif _mode = self.Mode_Add then
		str := self.displayRowForDataTable(_wle, self.tblWorkEntries);
		rowIdx := self.tblWorkEntries.addItem(str);
		self.tblWorkEntries.accessRow(rowIdx).itemObject := _wle;	
		self.tblWLESetRowColour(_wle, rowIdx, rtCol);
	endif;

	self.tblWLESetSelected();
	self.doNotableAdd(_wle.myTrackedItem);
		
end;</source>
        <access>protected</access>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
