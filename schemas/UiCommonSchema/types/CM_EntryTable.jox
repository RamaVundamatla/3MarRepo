    <JadeMethod name="disableRow" id="39469daf-9631-4e0c-9d5d-9766842db0db">
        <updating/>
        <source>disableRow(pRow : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     17 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	entRowTrans			: EntTableRowTransient;
	jRow				: JadeTableRow;
begin
	entRowTrans := self.accessRow(pRow).itemObject.EntTableRowTransient;
	
	if entRowTrans = null then
		return;
	endif;
	
	entRowTrans.inputEnabled := false;
	
	// PAR 16919
	if not self.allowCellEnabled(entRowTrans) then
		self.accessCell(pRow, self.ColumnValue).foreColor := self.foreColor;		// JADE PAR 66229 jlgdap1 04 Sep 2018
		self.accessCell(pRow, self.ColumnValue).enabled := false;
	endif;
	
end;</source>
        <Parameter name="pRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="disableRowByName" id="faf906c9-e5d7-46b2-a904-1eae84bcc2ea">
        <updating/>
        <source>disableRowByName(pName : String) updating;
// ---------------------------------------------------------------------------
// Created:     10 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theRow	: Integer;
	
begin
	theRow := self.getRow(pName);
	
	if theRow &lt;&gt; 0 then
		self.disableRow(theRow);
	else
		if self.warningMethod &lt;&gt; null then
			self.form.sendMsgWithParams(self.warningMethod, self.name, method.name, 'Cannot disable row (' &amp; pName &amp; ') - not found in table');
		endif;
	endif;

end;</source>
        <Parameter name="pName" type="String"/>
    </JadeMethod>
    <JadeMethod name="doChangedComparismForControl" id="d857a2b0-58ea-455e-8766-22a47a205eba">
        <updating/>
        <source>doChangedComparismForControl(_controlName : String) updating;
// ---------------------------------------------------------------------------
// Created:     28 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	theRow				: Integer;
begin
	if self.changeMode = self.ChangeMode_None or
	   (self.changeMode = self.ChangeMode_FirstOnly and self.hasChanged) then
		return;
	endif;
	
	theRow := self.getRowByControlName(_controlName);
	if theRow &lt;= 0 then
		return;
	endif;
	
	self.doChangedComparison(theRow);

end;</source>
        <Parameter name="_controlName" type="String"/>
    </JadeMethod>
    <JadeMethod name="doChangedComparison" id="dbae6e61-56ae-46ee-b301-e4d248f407f6">
        <updating/>
        <source>doChangedComparison(theRow : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     28 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	origValue,
	newValue			: String;
	theCell				: JadeTableCell;
	entRowTrans			: EntTableRowTransient;
begin
	if self.changeMode = self.ChangeMode_None or
	   (self.changeMode = self.ChangeMode_FirstOnly and self.hasChanged) then
		return;
	endif;
	
	if theRow &lt; 1
	or theRow &gt; self.rows then
		return;
	endif;

	theCell := self.accessCell(theRow, ColumnValue);
	
	entRowTrans := self.accessRow(theRow).itemObject.EntTableRowTransient;
	if entRowTrans = null then //raise exception, or just return?
		return;	//need to blow the form away because this is called on the got focus - which happens when the exception dialog is closed
		//app.raiseUnexpectedProgramError(class.name, method.name, 'Entry Table Row Transient Object' &amp; CrLf &amp;
		//								'behind cell #' &amp; theCell.String &amp; ' was null');
	endif;									

	if entRowTrans.hasChanged then
		// already flagged as a change so can return
		return;
	endif;
	
	newValue := theCell.text;
	origValue := entRowTrans.originalValue;
	
	//if ((origValue = 'false') and (newValue = '0')) or				//-cnwml2 PAR24389
	//  ((origValue = 'true') and (newValue = '1')) then				//-cnwml2 PAR24389
	if entRowTrans.inputType = Table.InputType_CheckBox then
		//if ((origValue = 'No' or origValue = 'false') and (newValue = '0')) or		//+cnwml2 PAR24389
		if ((origValue = 'No' or origValue = 'false' or origValue = null) and (newValue = '0')) or	//04 Nov 2013	NDL	Par 32096
		   ((origValue = 'Yes' or origValue = 'true') and (newValue = '1')) then	//+cnwml2 PAR24389
			return;
		endif;
	endif;
	
	//cnwdz2 par 27147 start
	/*
	if origValue.isReal and 		//cnwas3 par 24728
	   newValue.isReal and 	 
	   origValue.asRealJMT() = newValue.asRealJMT() then
		return;
	endif;
	*/
	if entRowTrans.inputType = Table.InputType_TextNumeric or 
	   entRowTrans.inputType = Table.InputType_SignedNumeric then
		if 	origValue.asDecimalJMT() = newValue.asDecimalJMT() then 
			return;
		endif;
	endif;
	//cnwdz2 par 27147 end
	
	//never set hasChanged to false - if its changed BACK to its original value,
	//that still counts as a change
	if origValue &lt;&gt; newValue then
		entRowTrans.hasChanged := true;	
		self.hasChanged := true;
	
		if self.changeMode = ChangeMode_All then
			theCell.backColor := self.hasChangedColor;
		endif;
	endif;
	
end;</source>
        <Parameter name="theRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doChangedComparisonOLD" id="5ce9121d-01f7-4182-baa8-bfcb6fa7fb02">
        <updating/>
        <source>doChangedComparisonOLD() updating;
// ---------------------------------------------------------------------------
// Created:     28 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	origValue,
	newValue			: String;
	prevCell			: JadeTableCell;
	tmpCntrl			: Control;
	i					: Integer;
	entRowTrans			: EntTableRowTransient;
begin
	if self.changeMode = self.ChangeMode_None or
	   (self.changeMode = self.ChangeMode_FirstOnly and self.hasChanged) then
		return;
	endif;

	if self.previousRow &lt;= self.fixedRows or self.previousRow &gt; self.rows then
		return;
	endif;
	
	prevCell := self.accessCell(self.previousRow, ColumnValue);
	tmpCntrl := prevCell.cellControl;
	
	if tmpCntrl &lt;&gt; null and tmpCntrl.name[1] &lt;&gt; '_' then
		if ComboBox.hasInstance(tmpCntrl) then
			tmpCntrl.ComboBox.lostFocus(tmpCntrl.ComboBox);
		elseif TextBox.hasInstance(tmpCntrl) then
			tmpCntrl.TextBox.lostFocus(tmpCntrl.TextBox);
		elseif ListBox.hasInstance(tmpCntrl) then
			tmpCntrl.ListBox.lostFocus(tmpCntrl.ListBox);
		endif;
	endif;
	entRowTrans := self.accessRow(self.previousRow).itemObject.EntTableRowTransient;
	if entRowTrans = null then //raise exception, or just return?
		return;	//need to blow the form away because this is called on the got focus - which happens when the exception dialog is closed
		//app.raiseUnexpectedProgramError(class.name, method.name, 'Entry Table Row Transient Object' &amp; CrLf &amp;
		//								'behind cell #' &amp; self.previousRow.String &amp; ' was null');
	endif;									
	
	newValue := self.accessCell(self.previousRow, ColumnValue).text;
	origValue := entRowTrans.originalValue;

	if ((origValue = 'false') and (newValue = '0')) or
	   ((origValue = 'true') and (newValue = '1')) then
		return;
	endif;
	//never set hasChanged to false - if its changed BACK to its original value,
	//that still counts as a change
	if origValue &lt;&gt; newValue then
		entRowTrans.hasChanged := true;	
		self.hasChanged := true;
		
//app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '  setting hasChanged to true  ' &amp;
//					self.row.String &amp; '  &gt;&gt;' &amp; origValue &amp; '&lt;&lt;&gt;&gt;' &amp; newValue &amp; '&lt;&lt;');

		if self.changeMode = ChangeMode_All then
			self.accessCell(self.previousRow, ColumnValue).backColor := self.hasChangedColor;
		endif;
	endif;
	
epilog
	if self.userInputEnabled then
		self.previousRow := self.row;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="enableRow" id="8cac8d32-80a0-4823-a44a-9bde2978cfde">
        <updating/>
        <source>enableRow(pRow : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     17 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	entRowTrans			: EntTableRowTransient;
begin
	entRowTrans := self.accessRow(pRow).itemObject.EntTableRowTransient;
	if entRowTrans = null then
		return;
	endif;

	entRowTrans.inputEnabled := true;

	// PAR 16919
	self.accessCell(pRow, self.ColumnValue).enabled := true;

end;</source>
        <Parameter name="pRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="enableRowByName" id="ea8c7cb2-b2a7-42f3-98d9-8f1b900bfbf2">
        <updating/>
        <source>enableRowByName(pName : String) updating;
// ---------------------------------------------------------------------------
// Created:     10 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theRow	: Integer;
	
begin

	theRow := self.getRow(pName);
	
	if theRow &lt;&gt; 0 then
		self.enableRow(theRow);
	else
		if self.warningMethod &lt;&gt; null then
			self.form.sendMsgWithParams(self.warningMethod, self.name, method.name, 'Cannot enable row (' &amp; pName &amp; ') - not found in table');
		endif;
	endif;

end;</source>
        <Parameter name="pName" type="String"/>
    </JadeMethod>
    <JadeMethod name="getAttrName" id="4c22cdb2-abe9-4990-87ce-59976bf71815">
        <updating/>
        <source>getAttrName(pRow : Integer) : String updating;
// ---------------------------------------------------------------------------
// Created:     20 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.isValidRow(pRow) then
		//return self.accessCell(pRow, ColumnAttrName).text;
		return self.accessRow(pRow).itemObject.EntTableRowTransient.name;
	else
		if self.warningMethod &lt;&gt; null then
			self.form.sendMsgWithParams(self.warningMethod, self.name, method.name, 'Row (' &amp; pRow.String &amp; ') is invalid');
		endif;
	endif;
	
	return null;
	
end;</source>
        <Parameter name="pRow" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEntTableRowByControlName" id="154223a3-e197-48b1-93a8-14f9c156e9b8">
        <source>getEntTableRowByControlName(_controlName : String) : EntTableRowTransient;
// ---------------------------------------------------------------------------
// Created:     11 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

	obj				: Object;	
begin
	if self.myEntTableDef = null then
		return null;
	endif;
	
	foreach obj in self.allEntRowTransients do
		if obj.EntTableRowTransient.controlName = _controlName then
			return obj.EntTableRowTransient;
			break;
		endif;
	endforeach;
	
end;</source>
        <Parameter name="_controlName" type="String"/>
        <ReturnType type="EntTableRowTransient"/>
    </JadeMethod>
    <JadeMethod name="getFirstVisibleRow" id="af8c8350-0e17-4758-b0d1-3e61507cf705">
        <updating/>
        <source>getFirstVisibleRow() : Integer updating;
/*
----------   ----------  --------------------------------------------------
Created:	10 October 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	storeRow,
	rowCount,
	idx			: Integer;
begin
	storeRow := self.row;
	rowCount := self.rows;
	foreach idx in 1 to rowCount do
		if self.accessRow(idx).visible then
			return idx;
		endif;
	endforeach;

epilog
	
	if storeRow &gt; 0 and storeRow &lt; rowCount then
		self.row := storeRow;
	endif;
	
end;


</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getHeadingByName" id="d7d78da9-f679-493f-b00f-1aa8e3024375">
        <updating/>
        <source>getHeadingByName(pName : String) : String updating;
// ---------------------------------------------------------------------------
// Created:     09 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theRow				: Integer;
	entRowTrans			: EntTableRowTransient;
begin

	theRow := self.getRow(pName);
	
	if theRow &lt;&gt; 0 then
		entRowTrans := self.accessRow(theRow).itemObject.EntTableRowTransient;
		return entRowTrans.getHeading(self.myTerminologyCargoBOLType, self.myTerminologyTerminal, app.myCurrentLocale);
		//return entRowTrans.getHeading(self.myTerminologyCargoBOLType, self.myTerminologyTerminal, null);
	else
		if self.warningMethod &lt;&gt; null then
			self.form.sendMsgWithParams(self.warningMethod, self.name, method.name, 'Cannot get value for row (' &amp; pName.String &amp; ') - not found on table');
		endif;
	endif;
	
	return null;

end;</source>
        <Parameter name="pName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLastEntryRowControl" id="9ccaf4e5-dcbf-415a-9b71-3cb93180d3e9">
        <updating/>
        <source>getLastEntryRowControl() : Control updating;
// ---------------------------------------------------------------------------
// Created:     09 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpControl	: Control;
	
begin

	if self.bottomEntryRow = 0 then
		return null;
	endif;
	
	tmpControl := self.accessCell(self.bottomEntryRow, ColumnValue).cellControl;
	
	if tmpControl &lt;&gt; null and tmpControl.name[1] = '_' then
		// this is the Jade generated control and not ours.
		tmpControl := null;
	endif;
	
	return tmpControl;
	
end;</source>
        <ReturnType type="Control"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementTableForRowName" id="97bacdea-b8b9-49aa-ad6a-d0df8d22ee04">
        <updating/>
        <source>getMeasurementTableForRowName(_attrName : String) : CMUI_MeasurementTable updating;
/*

Date		Who		Reason
01 April 2014	cnwer1	Initial creation PAR

*/

vars
	numRows				: Integer;
	idx					: Integer;
	control				: Control;
	measureTable		: CMUI_MeasurementTable;
begin
	numRows := self.rows;
	
	foreach idx in self.topNonHeadingRow to numRows do
		control := self.accessCell(idx, self.ColumnValue).cellControl;
		
		if CMUI_MeasurementTable.hasInstance(control) then
			measureTable := control.CMUI_MeasurementTable;
			if measureTable.rowName = _attrName then
				return measureTable;
			endif;
		endif;
	endforeach;

	return null;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <ReturnType type="CMUI_MeasurementTable"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementValueByName" id="e5d5b624-4ece-4ca8-a0c7-40fc82680e7a">
        <updating/>
        <source>getMeasurementValueByName(_attrName : String) : Any updating;
/*
Purpose:			Returns the value (converted to storage default) from the measurement row
					indicated by the _atrrName parameter

Parameters:			_attrName - the ent table row name to look for

Return Value:		Value from measurement table converted from entry measurement type to storage measurement type

Date		Who		Reason
12/04/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars
	saveRow, saveCol	: Integer;
	numRows				: Integer;
	idx					: Integer;
	control				: Control;
	measureTable		: CMUI_MeasurementTable;
	value 				: Decimal [23,10];
	
begin
	saveRow := self.row;
	saveCol := self.column;
	
	numRows := self.rows;
	
	foreach idx in self.topNonHeadingRow to numRows do
		control := self.accessCell(idx, self.ColumnValue).cellControl;
		
		if CMUI_MeasurementTable.hasInstance(control) then
			measureTable := control.CMUI_MeasurementTable;
			if measureTable.rowName = _attrName then
				value := measureTable.getConvertedValue();
			endif;
		endif;
	endforeach;
	
	self.row 	:= saveRow;
	self.column := saveCol;
	
	return value;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getOrigValue" id="0c744c51-4b5a-4d6f-a51c-d9665f233c4d">
        <updating/>
        <source>getOrigValue(pRow : Integer) : Any updating;
// ---------------------------------------------------------------------------
// Created:     31 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	cell				: JadeTableCell;
	inType,
	tblInType			: Integer;
	entRowTrans			: EntTableRowTransient;
begin

	if self.isValidRow(pRow) then
		entRowTrans := self.accessRow(pRow).itemObject.EntTableRowTransient;
		cell := self.accessCell(pRow, self.ColumnValue);
	
		if entRowTrans.inputType = InputType_CheckBox then
			return cell.text.Boolean;

		elseif entRowTrans.inputType = InputType_Date then
			return cell.text.asDateJMT();

		elseif entRowTrans.inputType = InputType_Time then
// cnwdad1 17/06/2009 - PAR #19942.
			//return cell.text.Time;
			return cell.text.asTimeJMT();

		elseif entRowTrans.inputType = InputType_ColourSelection then
			if cell.backColor = self.backColor then
				// set to the default
				return White;
			else
				return cell.backColor;
			endif;
		else
			return cell.text;
		endif;
	else
		if self.warningMethod &lt;&gt; null then
			self.form.sendMsgWithParams(self.warningMethod, self.name, method.name, 'Cannot get value for row (' &amp; pRow.String &amp; ') - row is invalid');
		endif;
	endif;

end;</source>
        <Parameter name="pRow" type="Integer"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getOrigValueByName" id="eb1f48e6-173c-4cfe-adb1-aabaa6bdbccb">
        <updating/>
        <source>getOrigValueByName(_attrName : String) : Any updating;
// ---------------------------------------------------------------------------
// Created:     31 March 2003		cnwth2	
//
// Purpose:     Return the ent row transient originalValue, to save and restore	for TFS 2417	 
// ----------   ----------  --------------------------------------------------
vars
	theRow	: Integer;
	entRowTrans	: EntTableRowTransient;
begin

	theRow := self.getRow(_attrName);
	if theRow &lt;&gt; 0 then
		entRowTrans := self.accessRow(theRow).itemObject.EntTableRowTransient;
		return entRowTrans.originalValue;
	endif;
	
	return null;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getPictureByName" id="f317d9ff-e595-4993-976d-6ec9fcfeb700">
        <updating/>
        <source>getPictureByName(pName : String) : Binary updating;
// ---------------------------------------------------------------------------
// Created:     09 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	saveRow,
	saveCol,
	theRow	: Integer;
	thePic	: Binary;

begin

	theRow := self.getRow(pName);
	
	if theRow &lt;&gt; 0 then
	
		saveRow := self.row;
		saveCol := self.column;
		
		self.row := theRow;
		self.column := ColumnValue;
		thePic := self.accessCell(theRow, ColumnValue).picture;
		
		self.row := saveRow;
		self.column := saveCol;
		return thePic;

	else
		if self.warningMethod &lt;&gt; null then
			self.form.sendMsgWithParams(self.warningMethod, self.name, method.name, 'Cannot get picture for row (' &amp; pName.String &amp; ') - not found on table');
		endif;
	endif;

	return null;

end;</source>
        <Parameter name="pName" type="String"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="getRow" id="b67dc7bb-c7db-495e-8563-8f5c1953015b">
        <updating/>
        <source>getRow(pAttrName : String) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     03 November 2000 by cnwrs2
//
// Purpose:     Searches through the table to find the row which has the
//				attribute name (column 3 in the table).
//
// Parameters:  Atrribute name
//
// Returns:     The row number in the table with the attribute name.
//				If not found then returns 0.
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx					: Integer;
	numRows				: Integer;
	saveRow,
	saveCol				: Integer;
	rowFound			: Integer;
	entRowTrans			: EntTableRowTransient;
	obj					: Object;
	tmpAttrName			: String;
begin
	tmpAttrName := pAttrName[1:35].trimBlanks;
	if tmpAttrName = null then
		return null;
	endif;
	
	saveRow := self.row;
	saveCol	:= self.column;
	
	numRows := self.rows;
	
	foreach idx in topNonHeadingRow to numRows do

		obj := self.accessRow(idx).itemObject;
		
		/*
		if (obj = null) or (not EntTableRowTransient.hasInstance(obj)) then
			continue;
		endif;
		*/
		
		/*
		if idx = numRows then
			write '****(' &amp; obj.EntTableRowTransient.name &amp; ')(' &amp; tmpAttrName &amp; ')';
		endif;
		*/
		
 		if EntTableRowTransient.hasInstance(obj) and
 		   //obj.EntTableRowTransient.name = tmpAttrName then
		   obj.EntTableRowTransient.name.toUpper = tmpAttrName.toUpper then //+ cnwmd1
			rowFound := idx;
			break;
		endif;
	endforeach;


	self.row 	:= saveRow;
	self.column	:= saveCol;

	return rowFound;
	
end;</source>
        <Parameter name="pAttrName" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRowByControlName" id="042b5ea9-fc9a-4db7-9d39-4820905b11bc">
        <updating/>
        <source>getRowByControlName(pControlName : String) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     03 November 2000 by cnwrs2
//
// Purpose:     Searches through the table to find the row which has the
//				control name (JadeTableCell.cellControl).
//
// Parameters:  Atrribute name
//
// Returns:     The row number in the table with the control name.
//				If not found then returns 0.
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx		: Integer;
	maxRows		: Integer;
	obj			: Object;
begin

	maxRows := self.allEntRowTransients.size;
	foreach idx in 1 to maxRows do
		obj := self.allEntRowTransients[idx];
		if EntTableRowTransient.hasInstance(obj) and obj.EntTableRowTransient.controlName = pControlName then
			return idx;
		endif;
	endforeach;
	
	return 0;
			
/*
	if self.myEntTableDef = null then
		if self.warningMethod &lt;&gt; null then
			self.form.sendMsgWithParams(self.warningMethod, self.name, method.name, 'Cannot get value by controlName (' &amp; pControlName &amp; ') - myEntTableDef is null');
		endif;
		return 0;
	endif;

	return self.myEntTableDef.getRowByControlName(pControlName);
	*/
end;</source>
        <Parameter name="pControlName" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRowByName" id="4aaacf70-de66-4dc8-98e4-5dae25d0318a">
        <updating/>
        <source>getRowByName(_attrName : String) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     05 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	idx		: Integer;
	maxRows	: Integer;
	rowTrans	: EntTableRowTransient;
	obj 	: Object;
begin
	
	if self.allEntRowTransients.size = null then
		if self.myEntTableDef &lt;&gt; null then
			return self.myEntTableDef.getRowByName(_attrName);
		endif;
	endif;
	
	maxRows := self.rows;
	foreach idx in self.fixedRows + 1 to maxRows do
		obj:=self.accessRow(idx).itemObject;
		//epr TFS 47132 16/12/19
		if obj = null or not obj.isKindOf(EntTableRowTransient) then
			continue;
		endif;
		rowTrans := self.accessRow(idx).itemObject.EntTableRowTransient;
		if rowTrans = null then
			continue;
		endif;
		if rowTrans.name = _attrName then
			return idx;
		endif;
	endforeach;
	
	return 0;
			
end;</source>
        <Parameter name="_attrName" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRowByNameWithStartPos" id="fdb3de7b-6bbd-4242-881f-8a0b5f2481ec">
        <updating/>
        <source>getRowByNameWithStartPos(_attrName : String; _startPos: Integer) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     13 December 2004		cnwjc2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	idx			: Integer;
	maxRows		: Integer;
	rowTrans	: EntTableRowTransient;
	startRow	: Integer;
begin
	
	if self.myEntTableDef &lt;&gt; null then
		return self.myEntTableDef.getRowByNameWithStartPos(_attrName, _startPos);
	endif;
	
	startRow := self.fixedRows + 1;
	if _startPos &gt; startRow then
		startRow := _startPos;
	endif;
	
	maxRows := self.rows;
	foreach idx in startRow to maxRows do
		rowTrans := self.accessRow(idx).itemObject.EntTableRowTransient;
		if rowTrans = null then
			continue;
		endif;
		if rowTrans.name = _attrName then
			return idx;
		endif;
	endforeach;
	
	return 0;
			
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_startPos" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getValue" id="a4ab6386-dcd7-4bca-8787-6de8edc47d5f">
        <updating/>
        <source>getValue(pRow : Integer) : Any updating;
// ---------------------------------------------------------------------------
// Created:     09 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11/04/2006	cnwdad1		Added a check (and raise an exception) in the case
//							where the transient row object is not found.
// 30/10/2024   navsp1      MTN-33240 NSW - OnePort - Unable to update Last Successful Date/Time
// ---------------------------------------------------------------------------
vars
	cellObj			: JadeTableCell;
	entRowTrans		: EntTableRowTransient;
	rowInputType	: Integer;
	
begin
	if self.isValidRow(pRow) then
		entRowTrans	:=	self.accessRow(pRow).itemObject.EntTableRowTransient;
		
// cnwdad1 11/04/2006 - To protect against the case where the row object is not found!
		if entRowTrans = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'entRowTrans is null, CM_EntryTable has not been initialised correctly');
			return null;
		endif;
		
		cellObj			:=	self.accessCell(pRow, ColumnValue);
		rowInputType	:=	entRowTrans.inputType;

		if rowInputType = InputType_CheckBox then
			if cellObj.text.length &gt; 0 and cellObj.text[1] = '1' then
				return true;
			else
				return false;
			endif;
			
		elseif rowInputType = InputType_Date then
			return cellObj.text.asDateJMT();

		elseif rowInputType = InputType_Time then
			if cellObj.text.asTimeJMT().isValid() then
				return cellObj.text.asTimeJMT();
			else
				return null;
			endif;

		elseif rowInputType = InputType_Picture then
			return cellObj.picture;
	/*
	// too dangerous?
		elseif rowInputType = InputType_TextNumeric then //cnwrd1 3.8.09 par 20346 start
		// check for number of decimal places
			if entRowTrans.myEntTableCellControl &lt;&gt; null then
				if entRowTrans.myEntTableCellControl.EntTableTextNumeric.decimals &gt; 0 then
					//treat as decimal
					return cellObj.text.asDecimalJMT();
				else
					// treat as integer
					return cellObj.text.asIntegerJMT();
				endif;
			else
				// no cellcontroll treat as integer
				return cellObj.text.asIntegerJMT();
			endif;
		elseif rowInputType = InputType_SignedNumeric then 
		// check for number of decimal places
			if entRowTrans.myEntTableCellControl &lt;&gt; null then				
				if entRowTrans.myEntTableCellControl.EntTableSignedNumeric.decimals &gt; 0 then
					//treat as decimal
					return cellObj.text.asDecimalJMT();
				else
					// treat as integer
					return cellObj.text.asIntegerJMT();
				endif;
			else
				// no cellcontroll treat as integer
				return cellObj.text.asIntegerJMT();
			endif;			
		//cnwrd1 3.8.09 par 20346 end
		*/
		
		elseif cellObj.inputType = InputType_ComboBox
		and rowInputType = InputType_ColourSelection
		then
			if cellObj.backColor = self.backColor then
				// set to the default
				return White;
			else
				return cellObj.backColor;
			endif;
		elseif rowInputType = InputType_TimeStamp then			//MTN-33240
			return cellObj.text.trimBlanks.asTimeStampJMT();	//MTN-33240
		else
			// added trimBlanks so can trap for users only entering spaces	
			return cellObj.text.trimBlanks;
		endif;
	else
		if self.warningMethod &lt;&gt; null then
			self.form.sendMsgWithParams(self.warningMethod, self.name, method.name, 'Cannot get value for row (' &amp; pRow.String &amp; ') - row is invalid');
		endif;
	endif;
end;</source>
        <Parameter name="pRow" type="Integer"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getValueAsDate" id="aa581eaa-4f4d-4f87-bb3b-a539f778f018">
        <updating/>
        <source>getValueAsDate(pName : String) : Date updating;

vars
	s		: String;
	theRow	: Integer;
	a		: Any;
begin

	theRow := self.getRow(pName);
	
	if theRow &lt;&gt; 0 then
		a := self.getValue(theRow);
		
		if a.isKindOf(Date) then
			return a.Date;
		endif;
		return a.String.asDateJMT();
	else
		if self.warningMethod &lt;&gt; null then
			self.form.sendMsgWithParams(self.warningMethod, self.name, method.name, 'Cannot get value for row (' &amp; pName.String &amp; ') - not found on table');
		endif;
	endif;
	
	return null;

end;</source>
        <Parameter name="pName" type="String"/>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getValueByName" id="bd1d62b3-6848-4832-8d05-8a1975dfdcee">
        <updating/>
        <source>getValueByName(pName : String) : Any updating;
// ---------------------------------------------------------------------------
// Created:     09 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theRow	: Integer;

begin

	theRow := self.getRow(pName);
		
	if theRow &lt;&gt; 0 then
		return self.getValue(theRow);
	else
		if self.warningMethod &lt;&gt; null then
			self.form.sendMsgWithParams(self.warningMethod, self.name, method.name, 'Cannot get value for row (' &amp; pName.String &amp; ') - not found on table');
		endif;
	endif;
	
	return null;

end;</source>
        <Parameter name="pName" type="String"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getValueByNameIfVisible" id="22ee5606-7d1a-40ff-9f32-1ac0f620a45f">
        <updating/>
        <source>getValueByNameIfVisible(pName : String) : Any updating;
// ---------------------------------------------------------------------------
// Created:     09 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theRow	: Integer;

begin

	theRow := self.getRow(pName);
	
	if theRow &lt;&gt; 0 then
		if self.accessRow(theRow).visible then
			return self.getValue(theRow);
		endif;
	else
		if self.warningMethod &lt;&gt; null then
			self.form.sendMsgWithParams(self.warningMethod, self.name, method.name, 'Cannot get value for row (' &amp; pName.String &amp; ') - not found on table');
		endif;
	endif;
	
	return null;

end;</source>
        <Parameter name="pName" type="String"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="goToRowByName" id="9984c171-96c1-4fd7-ba16-7fb25fa9d4c5">
        <updating/>
        <source>goToRowByName(pName : String) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     21 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theRow	: Integer;
	
begin

	theRow := self.getRow(pName);
	
	if theRow &gt; 0 then
		self.row 	:= theRow;
		self.column := ColumnValue;
		if self.positionTop() = -1 then
			self.topRow := self.row;
		endif;
		return true;
	else
		self.column := ColumnValue;
		if self.topEntryRow &gt; 0 then
			self.row := self.topEntryRow;
		else
			if self.rows &gt; 0 then
				self.row := 1;
			endif;
		endif;
		return false;
	endif;
	
end;</source>
        <Parameter name="pName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="gotFocus" id="ea76a8d3-3bc6-4906-9078-24e5817e3bfd">
        <updating/>
        <source>gotFocus(table: Table input) updating;

vars

begin
	self.tabKey := J_key_Tab;
	
	// Added 28May01 RJS to handle problems where bottom row of table 1 and top row of table 2
	// both have custom controls =&gt; tab between the 2 tables get confused.  I believe that
	// the next release of Jade will address this problem - retest then.
	if table.row &gt; self.bottomEntryRow and 
	   self.topEntryRow &gt; 0 and
	   self.topEntryRow &lt;= table.rows then
//		table.row := self.topEntryRow;
	endif;

	inheritMethod(table);
	self.handleCellGotFocus();
	
	
	

	//self.doChangedComparison(self.row);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="handleCalenderDateChange" id="1297cedb-0bbc-4dfb-b440-5442c95203ed">
        <updating/>
        <source>handleCalenderDateChange(_cell: JadeTableCell input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 December 2019	jlger1	Initial creation TFS 47132

*/

vars
	obj : Object;	
	criteriaLine : CM_SelectorCriteriaLine;
	controlType : Integer;
	value : String;
begin
	obj:=self.accessRow(_cell.row).itemObject;
	if obj = null then
		return;
	endif;
	
	value:=_cell.text;
	
	if obj.isKindOf(CM_SelectorCriteriaLine) then
		criteriaLine:=obj.CM_SelectorCriteriaLine;
		controlType := criteriaLine.getControlType();
		if   controlType = QueryControl_Date  then
			obj.CM_SelectorCriteriaLine.myQueryOperator.setSearchValue(value );
		elseif controlType = QueryControl_DateRange then
			if self.accessCell(_cell.row,ColumnHeading).text.pos(Space &amp; app.getErrorString(From),1) &gt; 0 then
				obj.CM_SelectorCriteriaLine.myQueryOperator.CM_QDateRange.setFromDate(value .asDateJMT);
			else	
				obj.CM_SelectorCriteriaLine.myQueryOperator.CM_QDateRange.setToDate(value .asDateJMT);
			endif;
		endif;	
	endif;
	inheritMethod(_cell);


epilog

end;</source>
        <Parameter name="_cell" type="JadeTableCell" usage="input"/>
    </JadeMethod>
    <JadeMethod name="handleCellGotFocus" id="104f4f41-a433-4845-bf3f-4c2e32a9b827">
        <updating/>
        <source>handleCellGotFocus() updating, protected;
// ---------------------------------------------------------------------------
// Created:     10 June 2001 by cnwrs2
//
// Purpose:     Handles a pseudo - cell got focus event.  A custom method on the form
//				with the following signature can be called if in the entTableRow
//					xxx(table : CM_EntryTable; row : Integer; rowName : String; pValue : Any) updating;
// 08.01.2020 cnwma1 Bug 48173: PRP - Customs date.
// ---------------------------------------------------------------------------
vars
	obj					: Object;
	theCell				: JadeTableCell;
	theRow				: Integer;
	entTableControl		: EntTableCellControl;
	ctrl				: Control;
	entRowTrans			: EntTableRowTransient;
	tmpEditMask			: JadeEditMask;
begin
	theRow := self.row;

	if not self.isValidRow(theRow) then // &lt;= 0 or theRow &gt; self.rows then
		return;
	endif;

	self.amMovingToCellWithControl := false;	// 28/05/2010 cnwar2 #17918 - reset to false (see handleCellLostFocus)
	
	obj := self.accessRow(theRow).itemObject;
	theCell := self.accessCell(theRow, ColumnValue);
	//epr TFS 47132 16/12/19 
	if (obj = null) or (not EntTableRowTransient.hasInstance(obj)) then
	
		return;
	endif;
	
	entRowTrans := obj.EntTableRowTransient;
	entTableControl := entRowTrans.myEntTableCellControl;

	if entTableControl &lt;&gt; null and global.isValidObject(entTableControl) then
		// Initialise the cell attributes
		entTableControl.initialiseCellControl(theCell);
	else
		self.setSelectionStyle(theRow, false);
	endif;

	if self.changeMode &lt;&gt; self.ChangeMode_None and
	   (not entRowTrans.hasChanged) then
		// Do not update original value for checkbox since clicking on checkbox will 
		// update to new value before this point
		if (theCell.inputType &lt;&gt; Table.InputType_CheckBox and theCell.inputType &lt;&gt; Table.InputType_EditMask ) then	// 25/01/2011 cnwar2 #26807 //08.01.2020 cnwma1 #48173
			entRowTrans.originalValue := theCell.text;		
			entRowTrans.isOriginalValueSet := true;
		endif;
	endif;

	// Call the method on the form to do custom gotFocus if required.
	if entRowTrans.gotFocusMethodName &lt;&gt; null then
		form.sendMsgWithParams(entRowTrans.gotFocusMethodName, self, theRow, entRowTrans.name, self.getValue(theRow));
	endif;

	ctrl := theCell.cellControl;
	if ctrl &lt;&gt; null then
		if Table.hasInstance(ctrl) then
			ctrl.Table.userInputEnabled := entRowTrans.inputEnabled;
		else
			ctrl.enabled := entRowTrans.inputEnabled;
			if JadeEditMask.hasInstance(ctrl) then
			   	tmpEditMask := ctrl.JadeEditMask;
			   	tmpEditMask.selectionStyle := JadeEditMask.SelectionStyle_Select;
			endif;
		endif;

	elseif theCell.inputType = Table.InputType_CheckBox and
	   	   (not entRowTrans.inputEnabled) then
		if (not self.useSavedUserInputEnabled) then
			self.saveUserInputEnabled := self.userInputEnabled;
			self.useSavedUserInputEnabled := true;
			
		endif;
		theCell.enabled := entRowTrans.inputEnabled;//11570
		self.userInputEnabled := false;	// entRowTrans.inputEnabled;
		
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleCellLostFocus" id="b00f319f-4763-4b7f-b5c0-85b2855ab924">
        <updating/>
        <source>handleCellLostFocus() updating, protected;
// ---------------------------------------------------------------------------
// Created:     10 June 2001 by cnwrs2
//
// Purpose:     Handles a pseudo - cell lost focus event.  A custom method on the form
//				with the following signature can be called if in the entTableRow
//				xxx(table : CM_EntryTable; row : Integer; rowName : String; pValue : Any) updating;
// ---------------------------------------------------------------------------
vars
	entTableRow		: EntTableRowTransient;
	obj				: Object;
	theCell			: JadeTableCell;
	theRow			: Integer;
	tmpCntrl		: Control;
	tmpDate			: Date;
		
begin

	theRow := self.row;

	if theRow = 0 then
		return;
	endif;

	theCell := self.accessCell(theRow, ColumnValue);
	
	if self.useSavedUserInputEnabled then
		self.userInputEnabled := self.saveUserInputEnabled;
		self.useSavedUserInputEnabled := false;
		
	endif;

	obj := self.accessRow(theRow).itemObject;
	//epr TFS 47132 16/12/19 
	if obj &lt;&gt; null and EntTableRowTransient.hasInstance(obj) then
		entTableRow := obj.EntTableRowTransient;
		if entTableRow.inputType = self.InputType_Date then
			tmpDate := theCell.text.asDateJMT();
			if tmpDate.isValid() then
				theCell.text := tmpDate.shortFormatJMT();
				if self.amMovingToCellWithControl then		// 27/05/2010 cnwar2 #17918
					self.setFocus();						// required for selectionStyle issue when next cell is also an edit mask
				endif;										// amMovingToCellWithControl is true if user is tabbing to another cell
				self.amMovingToCellWithControl := false;
			endif;
		endif;
		if entTableRow.lostFocusMethodName &lt;&gt; null then
			form.sendMsgWithParams(entTableRow.lostFocusMethodName, self, theRow, entTableRow.name, self.getValue(theRow));
		endif;
	endif;

	tmpCntrl := theCell.cellControl;
	if tmpCntrl &lt;&gt; null and 
	   tmpCntrl.name[1] &lt;&gt; '_' and 
	   (not tmpCntrl.automaticCellControl) then
		
		// par 18271 cnwrd1 2.4.09 for checkboxes as cellcotnrolls we need to manualy call lostfocus as there is no auto cell controll.
		if tmpCntrl.isKindOf(CheckBox) then
			tmpCntrl.CheckBox.lostFocus(tmpCntrl.CheckBox);
		endif;
	else
		// check to see if a change has occured
		self.doChangedComparison(self.row);
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleColourSelectChange" id="490f0441-3a7e-4bfd-9972-549789c0496e">
        <source>handleColourSelectChange(pTable: Table input; pRow : Integer) protected;
// ---------------------------------------------------------------------------
// Created:     19 February 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpCell	: JadeTableCell;
	tmpText	: String;
	cmdColor	: CMDColor;

begin

	tmpCell := pTable.accessCell(pRow, ColumnValue).cloneSelf(true);
	tmpText := tmpCell.text;
	if tmpText = ColourCurrentText then
		// do nothing

	elseif tmpText = ColourSelectText then
		create cmdColor transient;
		cmdColor.preventFullOpen := false;
		cmdColor.color := tmpCell.backColor;
		if cmdColor.open = 0 then
			tmpCell.backColor := cmdColor.color;
			tmpCell.foreColor := tmpCell.backColor.getInverseColour();
		endif;
		
	elseif tmpText = ColourNoneText then
		tmpCell.backColor := self.backColor;
	endif;
	tmpCell.text := null;

epilog
	if cmdColor &lt;&gt; null then
		delete cmdColor;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pTable" type="Table" usage="input"/>
        <Parameter name="pRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleFormTab" id="bc6f053c-9307-4a90-ad76-53cef74e882c">
        <updating/>
        <source>handleFormTab(keyCode: Integer io; shift: Integer; pPrev, pNext : Control) updating;
// ---------------------------------------------------------------------------
// Created:     06 November 2000 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	entTable	: CM_EntryTable;
	lastRowControl,
	prevControl,
	nextControl,
	theActiveControl,
	tmpControl	: Control;
	
begin

	if keyCode &lt;&gt; J_key_Tab then
		// Tab has not been pressed so no need to handle
		return;
	endif;

	theActiveControl := app.activeControl;
	if CM_EntryTable.hasInstance(theActiveControl.parent) then
		theActiveControl := theActiveControl.parent.Control;
	endif;
	
	prevControl := pPrev;
	nextControl := pNext;

	if shift = 0 and theActiveControl = prevControl then
		// moving forward into table
		if CM_EntryTable.hasInstance(prevControl) then
			entTable := prevControl.CM_EntryTable;
			if entTable.row = entTable.bottomEntryRow then
				// on last row of previous table so move to first row of this table
				self.moveFirst();
			endif;
		else
			self.moveFirst();
		endif;
		
	elseif shift = 1 and theActiveControl = nextControl then
		// moving back into table
		
		if CM_EntryTable.hasInstance(nextControl) then
			entTable := nextControl.CM_EntryTable;
			if entTable.row = entTable.topEntryRow then
				// on top row of next table so move to last row of this table
				self.moveLast();
			endif;
		else
			self.moveLast();
		endif;
	endif;

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="pPrev" type="Control"/>
        <Parameter name="pNext" type="Control"/>
    </JadeMethod>
    <JadeMethod name="handleTableTab" id="c4b787fc-4216-416d-9518-f7d66f5f378a">
        <updating/>
        <source>handleTableTab(shift : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     07 June 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpCntrl	: Control;
	tmpRow		: Integer;

begin

	// entry table is the current active control so determine if
	// we move in/out of this.
	tmpRow := self.row;
	
	if tmpRow = self.bottomEntryRow and 
	   self.column = ColumnValue and shift = 0 then
		tmpCntrl := self.accessCell(tmpRow, ColumnValue).cellControl;
		if tmpCntrl &lt;&gt; null and tmpCntrl.automaticCellControl then
			// as the tbl lostFocus event is not fired in this case
			self.lostFocus(self);
		endif;
		self.tabKey := 0;
		self.form.tabNext();
		self.selected := false;
	elseif tmpRow = self.topEntryRow and 
	   self.column = ColumnValue and shift = 1 then
		tmpCntrl := self.accessCell(tmpRow, ColumnValue).cellControl;
		if tmpCntrl &lt;&gt; null and tmpCntrl.automaticCellControl then
			// as the tbl lostFocus event is not fired in this case
			self.lostFocus(self);
		endif;
		self.tabKey := 0;
		self.form.tabPrior();
		self.selected := false;
	endif;

end;</source>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hasHeading" id="c25c784b-678b-47a4-b41a-93e853800a9f">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>hasHeading(set: Boolean; _value: Boolean io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:     09 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set then
		hasHeading := _value;
		if hasHeading then
			if self.rows = 0 then
				self.rows := 1;
				self.fixedRows := 1;
			endif;
			topNonHeadingRow := 2;
		else
			// not sure if following is required?
			if self.fixedRows &lt;&gt; 0 then
				self.fixedRows := 0;
			endif;
			topNonHeadingRow := 1;
		endif;
	else
		_value := hasHeading;
	endif;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="hasRowChanged" id="b4b23c43-4e5d-467e-b839-f71379f8b548">
        <updating/>
        <source>hasRowChanged(pRow : Integer) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     09 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	entRowTrans				: EntTableRowTransient;
begin

	if self.isValidRow(pRow) then
		entRowTrans := self.accessRow(pRow).itemObject.EntTableRowTransient;
		return entRowTrans.hasChanged;
	else
		if self.warningMethod &lt;&gt; null then
			self.form.sendMsgWithParams(self.warningMethod, self.name, method.name, 'Invalid row ' &amp; pRow.String &amp; ') - invalid row');
		endif;
	endif;
	
	return true;

end;</source>
        <Parameter name="pRow" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasRowChangedByName" id="e4669a75-d0ad-48da-9693-c8f1cc508349">
        <updating/>
        <source>hasRowChangedByName(pName : String; pGiveWarning : Boolean) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     09 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpRow	: Integer;
	
begin

	tmpRow := self.getRow(pName);
	
	if tmpRow &gt; 0 then
		return self.hasRowChanged(tmpRow);
	else
		if pGiveWarning and self.warningMethod &lt;&gt; null then
			self.form.sendMsgWithParams(self.warningMethod, self.name, method.name, 'Cannot hide row (' &amp; pName &amp; ') - not found on table');
		endif;
	endif;

	return true;
	
end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pGiveWarning" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="headingColumnWidth" id="d25584f8-c3aa-4e76-9ccf-b7edce6b3659">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>headingColumnWidth(set: Boolean; _value: Integer io) mapping, updating;

vars

begin

	if set then
		if self.columns &gt;= ColumnHeading then
			self.accessColumn(ColumnHeading).width := _value;
			self.setValueColumnWidth();
		endif;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="hideRow" id="ab1a0a04-f42d-4532-ac92-64432ed7922d">
        <updating/>
        <source>hideRow(pRow : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     09 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpRow	: JadeTableRow;
	
begin

	if self.isValidRow(pRow) then
		tmpRow := self.accessRow(pRow);
		if (not tmpRow.visible) then
			// row is already hidden
			return;
		endif;
		
		tmpRow.visible := false;
		if pRow = topEntryRow then
			resetTopEntryRow();
		endif;
		if pRow = bottomEntryRow then
			resetBottomEntryRow();
		endif;
	else
		if self.warningMethod &lt;&gt; null then
			self.form.sendMsgWithParams(self.warningMethod, self.name, method.name, 'Cannot hide row (' &amp; pRow.String &amp; ') - invalid row');
		endif;
	endif;

end;</source>
        <Parameter name="pRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hideRowByName" id="ac01ab5d-f997-4a6f-aacd-7e54ac935cda">
        <updating/>
        <source>hideRowByName(pName : String; pGiveWarning : Boolean) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     09 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 18/03/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// ---------------------------------------------------------------------------
vars
	tmpRow	: Integer;
	obj		: Object;								// PAR #31155
	entRow	: EntTableRowTransient;					// PAR #31155
	row		: String;								// PAR #31155
	type	: String;								// PAR #31155
	entTableRow : EntTableRow;
begin

	tmpRow := getRow(pName);
	
	if tmpRow &gt; 0 then
		hideRow(tmpRow);
		// PAR #31155 is the row we just hid a measurement type			// PAR #31155
		// If so, hide any other rows associated with this one			// PAR #31155
		foreach obj in self.allEntRowTransients do						// PAR #31155
			entRow := obj.EntTableRowTransient;							// PAR #31155
			if not entRow.name.isMeasurementType then					// PAR #31155
				continue;												// PAR #31155
			endif;														// PAR #31155
			entRow.name.getRowNameMeasureType(row, type);				// PAR #31155
			if row = pName then											// PAR #31155
				tmpRow := getRow(entRow.name);							// PAR #31155
				if tmpRow &gt; 0 then										// PAR #31155
					self.hideRow(tmpRow);								// PAR #31155
				endif;													// PAR #31155
			endif;														// PAR #31155
		endforeach;														// PAR #31155
	else
		if pGiveWarning and self.warningMethod &lt;&gt; null then
			self.form.sendMsgWithParams(self.warningMethod, self.name, method.name, 'Cannot hide row (' &amp; pName &amp; ') - not found on table');
		endif;
	endif;

	return tmpRow;
	
end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pGiveWarning" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="isMeasurementRowVisible" id="4633ac96-af68-454d-a7a3-9627a07d7146">
        <updating/>
        <source>isMeasurementRowVisible(_attrName : String) : Boolean updating;
/*

Date		Who		Reason
08 December 2016	cnwer1	Initial creation TFS 2996

*/

vars
	numRows				: Integer;
	idx					: Integer;
	control				: Control;
	measureTable		: CMUI_MeasurementTable;
begin
	numRows := self.rows;
	
	foreach idx in self.topNonHeadingRow to numRows do
		control := self.accessCell(idx, self.ColumnValue).cellControl;
		
		if CMUI_MeasurementTable.hasInstance(control) then
			measureTable := control.CMUI_MeasurementTable;
			if measureTable.rowName = _attrName then
				return self.accessRow(idx).visible ;
			endif;
		endif;
	endforeach;

	return false;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOnBottomEntryRow" id="2fe6498e-fa96-4448-a67b-c3148fee2fa6">
        <source>isOnBottomEntryRow():Boolean;
/*
	Created on 28 March 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
tmpRow	: Integer;
begin
	tmpRow := self.row;
	if tmpRow &lt;= 0 then
		return false;
	endif;
	return (tmpRow = self.bottomEntryRow) ;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOnTopEntryRow" id="d5d4b776-01f1-4e25-9699-645fa0573455">
        <source>isOnTopEntryRow():Boolean;
/*
	Created on 28 March 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
tmpRow	: Integer;
begin
	tmpRow := self.row;
	if tmpRow &lt;= 0 then
		return false;
	endif;
	return (tmpRow = self.topEntryRow);
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOnTopOrBottomRow" id="f7b4f5e0-0b08-4504-ae01-9535b6cbcf6e">
        <source>isOnTopOrBottomRow() : Boolean;
// ---------------------------------------------------------------------------
// Created:     12 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpRow	: Integer;
begin
	tmpRow := self.row;
	if tmpRow &lt;= 0 then
		return false;
	endif;
	return (tmpRow = self.bottomEntryRow) or (tmpRow = self.topEntryRow);
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isRowVisible" id="caa59242-7742-49ad-b785-851f0e67f3ea">
        <updating/>
        <source>isRowVisible(pName : String) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     23 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpRow	: Integer;
	
begin

	tmpRow := getRow(pName);

	if tmpRow &gt; 0 then
		return self.accessRow(tmpRow).visible;
	else
		return false;
	endif;
		
end;</source>
        <Parameter name="pName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidRow" id="065a8a6f-263b-4b1c-a560-b14c05fae180">
        <source>isValidRow(pRow : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:     09 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if pRow &gt;= self.topNonHeadingRow and pRow &lt;= self.rows then
		return true;
	endif;
	
	return false;

end;</source>
        <Parameter name="pRow" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="35bb64fb-4b04-41a0-851f-427cd7a462a8">
        <controlMethod name="CM_BaseTable::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>keyDown(table: Table input; keyCode: Integer io; shift: Integer) updating, clientExecution;

/*
Date			Who		Reason
28 May 2010	cnwar2	Initial creation

*/
vars

begin
	inheritMethod(table, keyCode, shift);

	if keyCode = J_key_Tab then
		self.amMovingToCellWithControl := true;		// 27/05/2010 cnwar2 #17918 - user tabbing to new cell
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadEntRowTransients" id="da9b2540-4a6e-4e6e-a95b-6fdf41bdac24">
        <updating/>
        <source>loadEntRowTransients(_defName : String; 
					_allEntRows : EntTableRowArray;
					pGetControlMethod, 
					pWarningMethod : String) updating;
// ---------------------------------------------------------------------------
// Created:     11 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  pDef				- the definition to setup
//				pGetControlMethod	- a method on the form to return the correct control.  This is not
//									generally required but can be used if the controls are cloned so
//									that there are several controls with the same name.
//									Signature of the method is "xxxxx(pControlName : String) : Control"
//				pWarningMethod		- a method on the form to display any warning messages.  If null then
//									no warnings are given.
//									Signature of the method is "xxxxx(pTableName, pDefName, pControlName, pMsg : String)"
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12 Jan 2026  navlc30     JIRA 36954 Story MTN | Highlight Mandatory fields
// ---------------------------------------------------------------------------
vars
	entTableRow		: EntTableRow;
	entTableControl	: EntTableCellControl;
	idx,
	theRow			: Integer;
	cntrl			: Control;
	found			: Boolean;
	msg				: String;
	tmpNum			: Integer;
	entRowTrans		: EntTableRowTransient;
	usingLocalDict,
	ls				: Boolean;
	tmpControlsDict	: CMUI_ControlsByNameDict;
	numControls		: Integer;
	tmpLocale		: CM_Locale;
	
begin

	tmpLocale := app.myCurrentLocale;

	if pGetControlMethod = null then
		if self.form.isKindOf(CM_BaseForm) then
			tmpControlsDict := self.form.CM_BaseForm.getAllControlsByNameDict();
		else
			usingLocalDict := true;
			create tmpControlsDict transient;
			numControls := self.form.controlCount;
			foreach idx in 1 to numControls do
				cntrl := form.controls(idx);
				tmpControlsDict.add(cntrl);
			endforeach;
		endif;
	endif;
	
	foreach entTableRow in _allEntRows do
		entTableControl := entTableRow.myEntTableCellControl;
		tmpNum := 0;
		if entTableControl &lt;&gt; null then
			if EntTableSignedNumeric.hasInstance(entTableControl) then
				tmpNum := entTableControl.EntTableSignedNumeric.decimals;
			elseif EntTableTextNumeric.hasInstance(entTableControl) then
				tmpNum := entTableControl.EntTableTextNumeric.decimals;
			elseif EntTableTextBox.hasInstance(entTableControl) then
				tmpNum := entTableControl.EntTableTextBox.maxLength;
			endif;
		endif;
		theRow := self.addAttribute(entTableRow.myEntTableRowHeader.name, entTableRow.getHeading(self.myTerminologyCargoBOLType, self.myTerminologyTerminal, tmpLocale), entTableRow.inputType, tmpNum, entTableRow.visible);
		//the entRowTrans will have the above params set on it - now set the rest from the entRow persistent object
		entRowTrans := self.accessRow(theRow).itemObject.EntTableRowTransient;
		entRowTrans.setEntTableCellControl(entTableRow.myEntTableCellControl);
		entRowTrans.setMandatoryField(entTableRow.isMandatoryField);				//12.01.2026 navlc30 #36954
		entRowTrans.setSelf(entTableRow);
		
		//+cnwml2 PAR24389
		if self.form.isKindOf(CM_ContainerEnqForm) then
			if self.form.CM_ContainerEnqForm.myProxyObject &lt;&gt; null then
				entRowTrans.originalValue := self.form.CM_ContainerEnqForm.myProxyObject.getDisplayStringForAttribute(entTableRow.name, true);
				entRowTrans.isOriginalValueSet := true;
			endif;
		endif;
		
		if entTableRow.controlName &lt;&gt; null then
			// a user created control has been specified
			found := false;
			if pGetControlMethod &lt;&gt; null then
				cntrl := form.sendMsgWithParams(pGetControlMethod, entTableRow.controlName).Control;			
				if cntrl &lt;&gt; null then
					found := true;
				endif;
			else
				// find the control on the form with this name
				cntrl := tmpControlsDict[entTableRow.controlName].Control;
				if cntrl &lt;&gt; null then
					found := true;
				endif;
			endif;
			if found then
				self.setControl(theRow, cntrl);
				//if cntrl.height.Integer &gt; maxControlHeight then
				//	maxControlHeight := cntrl.height.Integer;
				//endif;
			else
				if pWarningMethod &lt;&gt; null then
					if pGetControlMethod &lt;&gt; null then
						msg := 'Control (' &amp; entTableRow.controlName &amp; ') not found on form - Form::' &amp; pGetControlMethod &amp; ' method needs modifying';
					else
						msg := 'Control (' &amp; entTableRow.controlName &amp; ') not found on form';
					endif;
					form.sendMsgWithParams(pWarningMethod, self.name, _defName, entTableRow.controlName, msg);
				endif;
			endif;
		endif;

	endforeach;

	/*	makes no sense to size the rows to the height of the largest row		JC 17/03/2005
	if maxControlHeight &gt; 0 then
		self.defaultRowHeight := self.rowHeight[1].max(maxControlHeight);
	endif;
	*/
	self.defaultRowHeight := self.EntryTableViewRowHeight;
	
	self.optimiseHeadingColumn();
	
epilog
	if usingLocalDict then
		delete tmpControlsDict;
	endif;

end;</source>
        <Parameter name="_defName" type="String"/>
        <Parameter name="_allEntRows" type="EntTableRowArray"/>
        <Parameter name="pGetControlMethod" type="String"/>
        <Parameter name="pWarningMethod" type="String"/>
    </JadeMethod>
    <JadeMethod name="lostFocus" id="d30e72bd-b35e-43d3-9390-d74b990fd859">
        <updating/>
        <source>lostFocus(table: Table input) updating;

vars

begin

	inheritMethod(table);

	self.handleCellLostFocus();
	
	if table.rows &gt; 0 then
		table.selected := false;
	endif;

	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mouseDown" id="56a37108-c50a-4e5f-baef-44f63c0aca2d">
        <controlMethod name="CM_BaseTable::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		26 Janurary 2010 by cnwjo3
//
// Purpose:		Make doubly sure that on a mouse down the text font colour is visible/viewable for colourSelectiosn
//				
//
vars
	theRow : Integer;
	entRowTrans		: EntTableRowTransient;
	tmpCell : JadeTableCell;
begin
	inheritMethod(table,button,shift,x,y);
	
	theRow := table.row;
	
	if theRow &lt; 1 then
		return;
	endif;
	//epr TFS 47132 16/12/19 
	if table.accessRow(theRow).itemObject.isKindOf(EntTableRowTransient) then
		entRowTrans := table.accessRow(theRow).itemObject.EntTableRowTransient;	
		
		//cnwjo3 par 22190
		if entRowTrans &lt;&gt; null then
			if entRowTrans.inputType = InputType_ColourSelection then
				tmpCell := table.accessCell(theRow, ColumnValue).cloneSelf(true);
				tmpCell.backColor.getInverseColour();
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="moveFirst" id="42666788-3f0f-4792-94fe-9aab0e911989">
        <updating/>
        <source>moveFirst() updating;

vars
	ctrl 	: Control;
begin
	self.resetTopEntryRow();

	if self.topEntryRow &gt; 0 then
		self.row := self.topEntryRow;
	else
		self.row := self.rows;
	endif;
	
	self.column := ColumnValue;
	
	if self.row &gt; 0 then
		self.topRow := self.row;
		self.setSelectionStyle(self.row, true);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="moveLast" id="a429a101-d9bf-4f4a-b94e-a48bc94f4821">
        <updating/>
        <source>moveLast() updating;

vars

begin

	if self.bottomEntryRow &gt; 0 and self.bottomEntryRow &lt;= self.rows then
		self.row := self.bottomEntryRow;
	else
		resetBottomEntryRow();
		if self.bottomEntryRow &lt;&gt; 0 then
			self.row := self.bottomEntryRow;
		else
			self.row := self.rows;
		endif;
	endif;
	self.column := ColumnValue;

	if self.row &gt; 0 then
		// set this row to the topRow to ensure it is visible
		self.topRow := self.row;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="optimiseHeadingColumn" id="26fea241-e564-4014-98c2-53c2a7f8e38d">
        <updating/>
        <source>optimiseHeadingColumn() updating;
// ---------------------------------------------------------------------------
// Created:     09 November 2000 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	idx			: Integer;
	xWidth		: Integer;
	numRows,
	maxWidth	: Integer;

begin

	if self.columns &lt; ColumnHeading then
		return;
	endif;
	
	//self.column := ColumnHeading; - removed 10 August 2005

	numRows := self.rows;

	// First do fixed header rows
	foreach idx in 1 to numRows do

		// self.row := idx;  // Why set current row to this?
		
		xWidth := self.getTextExtent(self.getCellText(idx, ColumnHeading));
		if fontItalic then
			xWidth := xWidth + 4;
		endif;
		if fontBold then
			xWidth := (xWidth * 1.2).rounded;
		endif;
		if self.fixed3D then
			xWidth := xWidth + 1;
		endif;
		maxWidth := maxWidth.max(xWidth);

	endforeach;
	//epr TFS 47132 19/11/19 
	self.headingColumnWidth := maxWidth + 8;
end;</source>
    </JadeMethod>
    <JadeMethod name="optimiseTableHeight" id="a5a6b259-7f7b-4d78-a8fe-c20e0ba6f97a">
        <updating/>
        <source>optimiseTableHeight() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 September 2009	cnwer1	Initial creation

*/

vars
	numRows, idx, totHeight : Integer;
begin
	numRows := self.rows;

	foreach idx in 1 to numRows do
		if not self.accessRow(idx).visible then
			continue;
		endif;
		totHeight := totHeight + self.accessRow(idx).height;
	endforeach;
	self.height := totHeight+2;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="optimiseValueRowHeights" id="a5ca90eb-55bb-480f-98ae-2ef6a9a9e26c">
        <updating/>
        <source>optimiseValueRowHeights() updating;
// ---------------------------------------------------------------------------
// Created:     11 February 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	numRows,
	numColumns,
	r	 		: Integer;
	inputText, 
	outputText 	: String;
	cellInputType,
	newRowHeight, 
	cellWidth, 
	cellHeight 	: Integer;
	idx			: Integer;
	colWidthArray	: IntegerArray;

begin

	if self.columns &lt; ColumnHeading then
		return;
	endif;

	numRows := self.rows;

	cellWidth := self.clientWidth - self.columnWidth[ColumnHeading];
	
	foreach r in 1 to numRows do
		newRowHeight := 0;				// self.rowHeight[r];

		cellInputType := self.accessCell(r, ColumnValue).inputType;
		if cellInputType &lt;&gt; InputType_None and
		   cellInputType &lt;&gt; InputType_TextBox then
			continue;
		endif;
				
		inputText := self.getCellText(r, ColumnValue);
		if inputText &lt;&gt; null then
			self.fitTextToCell(inputText, outputText, cellWidth, cellHeight);
			if outputText &lt;&gt; inputText then
				self.setCellText(r, ColumnValue, outputText);
			endif;
			newRowHeight := newRowHeight.max(cellHeight);
		endif;

 		if newRowHeight &lt;&gt; self.rowHeight[r] then
 			self.rowHeight[r] := newRowHeight;
 		endif;
 	endforeach;
 	

end;</source>
    </JadeMethod>
    <JadeMethod name="outputRowDetails" id="a30a318e-3e2d-4a98-b218-700abea4698a">
        <source>outputRowDetails();
// ---------------------------------------------------------------------------
// Created:     10 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	app.writeStatement( 'TopEntryRow = ' &amp; topEntryRow.String &amp; '  bottomEntryRow = ' &amp; bottomEntryRow.String &amp;
		'  topRow = ' &amp; topRow.String);
end;</source>
    </JadeMethod>
    <JadeMethod name="queryRowColChg" id="243f0b37-9d69-4ebe-83ac-2445d8ce4363">
        <updating/>
        <source>queryRowColChg(table: Table input; newSheet: Integer; newRow: Integer; newCol: Integer): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     07 June 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	rtnCode			: Boolean;
	
begin

	rtnCode := inheritMethod(table, newSheet, newRow, newCol);
	if (not rtnCode) then
		// user could not move to new row
		return false;
	endif;
	
	if table.row &lt;&gt; newRow then
		// Do After row processing here
		self.handleCellLostFocus();
	endif;

	return true;
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="newSheet" type="Integer"/>
        <Parameter name="newRow" type="Integer"/>
        <Parameter name="newCol" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="resetBottomEntryRow" id="97abcf09-40d2-4934-8448-a166940b8a3b">
        <updating/>
        <source>resetBottomEntryRow() updating, protected;
// ---------------------------------------------------------------------------
// Created:     10 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx		: Integer;
	max		: Integer;
	endRow	: Integer;
	
begin

	max := self.rows;
	if hasHeading then 
		endRow := 2;
	else
		endRow := 1;
	endif;
	
	bottomEntryRow := 0;
	
	foreach idx in max to endRow step -1 do
		if self.accessRow(idx).visible then
			bottomEntryRow := idx;
			break;
		endif;
	endforeach;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resetCellControls" id="6b06f572-0eeb-4315-9bd2-ee23c1610521">
        <updating/>
        <source>resetCellControls() updating;
// ---------------------------------------------------------------------------
// Created:     07 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	numRows,
	idx			: Integer;
	ert			: EntTableRowTransient;
	tmpCntrl	: Control;
	tmpCell		: JadeTableCell;

begin

	numRows := self.rows;
	foreach idx in 1 to numRows do

		ert := self.accessRow(idx).itemObject.EntTableRowTransient;
		if ert = null then
			continue;
		endif;
		
		if ert.controlName = null then
			continue;
		endif;
		
		
		tmpCell := self.accessCell(idx, ColumnValue);
		tmpCntrl := tmpCell.cellControl;

		if ert.controlName = 'cmbLoadPort' then
			app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '  ' &amp; tmpCntrl.String);
		endif;
		
		if tmpCntrl &lt;&gt; null and tmpCntrl.name[1] &lt;&gt; '_' then
			tmpCell.cellControl := tmpCntrl;
		endif;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="resetHeight" id="05980fe5-4e18-4315-9f05-b5170decd38b">
        <updating/>
        <source>resetHeight() updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	idx, numRows,totHeight : Integer;
begin
	numRows := self.rows;
	foreach idx in 1 to numRows do
		totHeight := totHeight + self.accessRow(idx).height;
	endforeach;
	self.height := totHeight + 4;
end;</source>
    </JadeMethod>
    <JadeMethod name="resetMeasurementTables" id="6f31510f-fab0-4f50-89c0-ddbe2a80c5e6">
        <updating/>
        <source>resetMeasurementTables() updating;
/*

Date		Who		Reason
17 October 2013	cnwer1	Initial creation PAR 32262 refactored out of CM_BaseForm resetMeasurementRows

*/

vars
	row			: Integer;
	ctrl		: Control;
	entTrans	: EntTableRowTransient;
	defaultEntRow :String;
begin	
	foreach row in self.rows to self.fixedRows + 1 step -1 do
		ctrl := self.accessCell(row, self.ColumnValue).cellControl;
		if CMUI_MeasurementTable.hasInstance(ctrl) then
			delete ctrl;
			entTrans := self.accessRow(row).itemObject.EntTableRowTransient;
			self.allEntRowTransients.remove(entTrans);
			self.showRowByName(entTrans.name,false);
			
			delete entTrans;
			self.removeItem(row);
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="resetSize" id="c5796238-845d-4a6c-a672-1e2d2b25ed4d">
        <updating/>
        <source>resetSize() updating;
// ---------------------------------------------------------------------------
// Created:     15 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	maxHeight	: Real;
	tmpParent	: Window;
   	parentHeight	: Real;
	
begin

	self.setValueColumnWidth();

	tmpParent := self.parent;
	
	if CMUI_SplitContainer.hasInstance(tmpParent) then
		return;
	endif;

	if Form.hasInstance(tmpParent) then
		parentHeight := tmpParent.Form.clientHeight;
	elseif Control.hasInstance(tmpParent) then
		parentHeight := tmpParent.Control.clientHeight;
	else
		parentHeight := tmpParent.height;
	endif;

	if self.stretchHeight = true then
		maxHeight := parentHeight - self.top - self.distanceFromBottom;
	else
		maxHeight := parentHeight - self.parentTopMargin - self.parentBottomMargin;
	endif;

	if maxHeight &lt; 0 then
		maxHeight := 0;
	endif;

	self.adjustHeight(maxHeight);
end;</source>
    </JadeMethod>
    <JadeMethod name="resetTopEntryRow" id="c358a387-abc3-42d5-a3cb-19568794bded">
        <updating/>
        <source>resetTopEntryRow() updating, protected;
// ---------------------------------------------------------------------------
// Created:     10 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx			: Integer;
	max			: Integer;
	
begin

	max := self.rows;
	
	topEntryRow := 0;
	
	foreach idx in topNonHeadingRow to max do
		if self.accessRow(idx).visible and (idx &gt; self.fixedRows)  then // ### AKB added fixedRows
			topEntryRow := idx;
			break;
		endif;
	endforeach;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resizeColumn" id="e51f21ed-f0c3-4c63-93dd-8e82c9788ca4">
        <updating/>
        <source>resizeColumn(table: Table input; column: Integer input; previousWidth: Integer input) updating;
// ---------------------------------------------------------------------------
// Created:     09 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	inheritMethod(table, column, previousWidth);
	
	table.CM_EntryTable.setValueColumnWidth();

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="column" type="Integer" usage="input"/>
        <Parameter name="previousWidth" type="Integer" usage="input"/>
    </JadeMethod>
    <JadeMethod name="rowColumnChg" id="a6aebf3b-aaf7-40ee-a343-cd2bb52a2528">
        <updating/>
        <source>rowColumnChg(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:     10 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
