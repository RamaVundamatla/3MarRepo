    <JadeMethod name="getSelectedDLRSOBSlots" id="dc97392a-ad85-4194-8f3c-a58c778faa71">
        <source>getSelectedDLRSOBSlots(_theSlots: CM_LCArray input; _theSlotsAlt: CM_LCArray input; _editions: CM_ObjectByOidEditionDict input; _isLoad : Boolean); // PAR 31144
/*
Purpose:			
Date		Who		Reason
09 September 2011	cnwab1	Initial creation
*/

vars
	tmpObject : Object;
begin

	foreach tmpObject in self.myBayDrawingController.allSelectedObjects do
		if tmpObject.isKindOf(CM_SlotController) then			
				_theSlots.add(tmpObject.CM_SlotController);				
		endif;
	endforeach;
	
	foreach tmpObject in self.myBayDrawingController.allSelectedObjectsAlt do
		if tmpObject.isKindOf(CM_SlotController) then
			_theSlotsAlt.add(tmpObject.CM_SlotController);
		endif;
	endforeach;
	
	self.myBayDrawingController.updateEditionForSelectedObjs(self.myBayDrawingController.allObjectEditions);  //cnwrd1 par 31052 29.1.13
	self.myBayDrawingController.allObjectEditions.copy(_editions);	// PAR 28968
		
epilog

end;</source>
        <Parameter name="_theSlots" type="CM_LCArray" usage="input"/>
        <Parameter name="_theSlotsAlt" type="CM_LCArray" usage="input"/>
        <Parameter name="_editions" type="CM_ObjectByOidEditionDict" usage="input"/>
        <Parameter name="_isLoad" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getSeqObjForRequest" id="cbcb0389-b6e0-4aba-ac75-78244839240d">
        <source>getSeqObjForRequest(_request : CM_SlotRequest) : CMIF_CustomSequenceObject protected;
// ---------------------------------------------------------------------------
// Created:     25 March 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpSeqObj	: CMIF_CustomSequenceObject;

begin
	if _request = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_request', null, null);
		return tmpSeqObj;
	endif;

	tmpSeqObj := self.allCustomSeqObjsByReq[_request];

	if tmpSeqObj = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'custSeq transient not found');
	endif;
	
	return tmpSeqObj;

end;</source>
        <access>protected</access>
        <Parameter name="_request" type="CM_SlotRequest"/>
        <ReturnType type="CMIF_CustomSequenceObject"/>
    </JadeMethod>
    <JadeMethod name="getSeqObjForSlot" id="d5566c8a-73ce-468f-a216-fccae6ff00b2">
        <source>getSeqObjForSlot(_slot : CM_SlotController) : CMIF_CustomSequenceObject protected;
// ---------------------------------------------------------------------------
// Created:     25 March 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpSeqObj	: CMIF_CustomSequenceObject;
	tmpSlotRequest	: CM_SlotRequest;

begin
	if _slot = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_slot', null, null);
		return tmpSeqObj;
	endif;

	if self.displayMode = ShpDisplayMode_ColCodeDisch then
		tmpSlotRequest := _slot.CM_SlotController.mySlotRequestDischarge;
	else
		tmpSlotRequest := _slot.CM_SlotController.mySlotRequestLoad;
	endif;

	if tmpSlotRequest = null then
		// not sure if we need an error here or not ???
		app.raiseUnexpectedProgramError(class.name, method.name, 'no slot request found for selected slot');
		return tmpSeqObj;
	endif;
	
	return self.getSeqObjForRequest(tmpSlotRequest);
	
end;</source>
        <access>protected</access>
        <Parameter name="_slot" type="CM_SlotController"/>
        <ReturnType type="CMIF_CustomSequenceObject"/>
    </JadeMethod>
    <JadeMethod name="getShipVoyFormDispAndWorkModes" id="3bf1744c-27a5-4597-a9d7-9ffa5d01081d">
        <source>getShipVoyFormDispAndWorkModes(_displayMode: Integer output; _workingMode: Integer output): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 August 2011	cnwndl1	Initial creation	Par 28035

*/

vars

begin

	_displayMode := self.displayMode;
	_workingMode := self.workingMode;

	return true;

	return inheritMethod(_displayMode, _workingMode);	// here to keep the reference....

epilog

end;</source>
        <Parameter name="_displayMode" type="Integer" usage="output"/>
        <Parameter name="_workingMode" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getTheSelectedJob" id="dacbf499-cc53-4019-88e7-37a1f2b85fc1">
        <source>getTheSelectedJob() : CM_VoyageJob protected;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		the job id may not be in the combo cos it has not been allocated to the crane so go to the point to get the job id
// ---------------------------------------------------------------------------
vars
	theJob 		: CM_VoyageJob;
	theSlot		: CM_SlotController;
	theRequest	: CM_Request;
	theObj		: Object;
	
begin

	theObj := self.myBayDrawingController.allSelectedObjects.first;
	if theObj = null then
		return null;
	endif;

	if theObj.isKindOf(CM_SlotController) then	
		theSlot := theObj.CM_SlotController;
		if self.displayMode = ShpDisplayMode_ColCodeDisch then
			theRequest := theSlot.mySlotRequestDischarge;
		else
			theRequest := theSlot.mySlotRequestLoad;
		endif;
		if theRequest &lt;&gt; null then
			theJob := theRequest.myJob.CM_VoyageJob;
		endif;
	endif;

	return theJob;

end;</source>
        <access>protected</access>
        <ReturnType type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="62037160-e7f0-4cd8-aebd-c7b7824d3efa">
        <updating/>
        <source>getXMLSettingsForSetup() updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		Get the user preferences from the user details for this form
// ---------------------------------------------------------------------------
vars
	userWindow		: CM_UserWindow;
	theXML, theXMLValue : String;
	flipH, flipV, bigFont,hideL,hideT,hideM : Boolean;
	zoomScale : Real;
begin

	inheritMethod();
//	if self.frmGridArea.myGridArea &lt;&gt; null then
//		self.frmGridArea.myGridArea.setFlips(self.xmlFlipH, self.xmlFlipV);
//	endif;
	self.myBayDrawingController.drawInReverse := self.xmlFlipH;

	self.mnuGridBigFont.checked := self.myBayDrawingController.myConfig.shipMacroUseBigFont;

	userWindow := app.getUserWindow(self.name, false);
	
	if userWindow = null then
		return;
	endif;
	theXML := userWindow.xmlInfo;

end;</source>
    </JadeMethod>
    <JadeMethod name="giveCustSeqNeedSaveWarning" id="2fc99dfc-cfae-48f0-947f-010c54e9fde7">
        <updating/>
        <source>giveCustSeqNeedSaveWarning(_frame: SHP_BayDrawingFrame input;
			_slot : CM_SlotController;
			button: Integer; shift: Integer; x: Real; y: Real) : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     17 August 2004 by cnwrs2
//
// Purpose:     returns TRUE if can carry on with action that triggered this call
// ---------------------------------------------------------------------------

vars
	rtnCode			: Integer;
	theCurrentJob	: CM_VoyageJob;
	tmpStr			: String;
	invalidJob 		: Boolean;
begin
	//14/02/2011 cnwdz2 par26989
	on Exception do app.handleDeletedObject(exception, theCurrentJob, invalidJob);

	if self.workingMode &lt;&gt; self.WorkMode_CustomSeq or 
	   (not self.hasChanged) then
		return true;
	endif;

	theCurrentJob := self.myCurrentJob; 

	if theCurrentJob = null then
		return true;
	endif;

	tmpStr := "You have updated the sequence for job " &amp; theCurrentJob.jobNum &amp; ", but have not" &amp; CrLf &amp;
			  "yet saved these changes." &amp; CrLf &amp; CrLf &amp;
			  "Select:" &amp; CrLf &amp;
			  "  Yes to save these changes now." &amp; CrLf &amp; CrLf &amp;
			  "  No to NOT save these changes." &amp; CrLf &amp; CrLf &amp;
			  "  Cancel to NOT save these changes and continue sequencing this job.";
	
	//14/02/2011 cnwdz2 par26989 start
	if invalidJob then
		return true;
	endif;
	//14/02/2011 cnwdz2 par26989 end
	
	rtnCode := app.msgBox(tmpStr, "Sequencing Error", MsgBox_Yes_No_Cancel);

	if rtnCode = MsgBox_Return_Yes then
		app.mousePointer := MousePointer_HourGlass;
		self.doSaveSequence();
		app.mousePointer := MousePointer_Default;
		
		return true;

	elseif rtnCode = MsgBox_Return_No then
		self.hasChanged := false;
		// the user wants to throw away any changes to the
		// existing job.
		self.doPicSeqUndoClick();
		self.currentSeqNumber := 0;
		theCurrentJob := null;

		if _frame &lt;&gt; null then
			// need to call the handleMoueseUp as the display of
			// the message box here prevents this from firing
			_frame.handleMouseUp(_slot, button, shift, x, y);
		endif;

		return true;
	else
		// rtnCode = MsgBox_Return_Cancel
		return false;
	endif;

epilog
	app.mousePointer := MousePointer_Default;

end;</source>
        <access>protected</access>
        <Parameter name="_frame" type="SHP_BayDrawingFrame" usage="input"/>
        <Parameter name="_slot" type="CM_SlotController"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleBayMouseDownEvent" id="914a9ac9-d4a1-4aa9-a822-7572a7d16096">
        <updating/>
        <source>handleBayMouseDownEvent(frame: SHP_BayDrawingFrame input;button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     22 January 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpObj	: Object;
	tmpSlot	: CM_SlotController;
begin
	frame.enableEvent("mouseMove", true);

	if button = Window.MouseButton_Left and shift = 0 or shift.isAltKeyPressed() then
		self.origXPos := x;
		self.origYPos := y;
		self.aMyOriginalWindow	:=	frame;

		tmpObj := frame.getObjectForPosition(x.Integer, y.Integer);
		
		if (tmpObj = null and (not self.hasChanged))
		or not tmpObj.isKindOf(CM_SlotController)	// ### AKB2005JUNE. maybe a hatchlid in cust seq mode
		then
			return;
		endif;
		
		self.tblGridAreaInfo.rows := 0;
		self.tblPopupInfo.rows := 0;
		
		if global.isValidObject(app.myMoveController) then // AKB2007JULY - DCT EXCEPTION
			app.myMoveController.mySlotRequest := null;
		endif;	
		
		app.myDraggedTrackedItem := null;
		
		// changed to prevent message box coming up continually - PAR8665
		if self.displayMode = ShpDisplayMode_ColCodeLoad
		and self.workingMode &lt;&gt; WorkMode_CustomSeq
		then
			self.handleBayMouseDownEventCCLoad(frame, button, shift, x, y);
		endif;

		if self.workingMode = WorkMode_CustomSeq then
			self.handleBayMouseDownEventSeq(frame, self.myBayDrawingController, tmpObj.CM_SlotController,
											button, shift, x, y);
	
		elseif self.workingMode = WorkMode_Plan then
			self.handleBayMouseDownEventPlan(self.myBayDrawingController, tmpObj.CM_SlotController,shift);
		endif;			
		
	elseif button = Window.MouseButton_Left 
	and (shift.isControlKeyPressed() and not shift.isAltKeyPressed() and not shift.isShiftKeyPressed())
	then
	// ### CTRL and LEFT MOUSE
		if self.workingMode = WorkMode_Plan 
		and self.displayMode = ShpDisplayMode_ColCodeLoad
		then
			self.origXPos := x;
			self.origYPos := y;
			self.aMyOriginalWindow	:=	frame;

			tmpObj := frame.getObjectForPosition(x.Integer, y.Integer);
			
			if (tmpObj = null and (not self.hasChanged))
			or not tmpObj.isKindOf(CM_SlotController)	// ### AKB2005JUNE. maybe a hatchlid in cust seq mode
			then
				return;
			endif;
			
			self.handleBayMouseDownEventPlan(self.myBayDrawingController, tmpObj.CM_SlotController,shift);
		endif;
	endif;
end;</source>
        <Parameter name="frame" type="SHP_BayDrawingFrame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="handleBayMouseDownEventCCLoad" id="932f5325-ac4e-4bb6-a6a3-7dc819c6e6e3">
        <updating/>
        <source>handleBayMouseDownEventCCLoad(frame: SHP_BayDrawingFrame input;button: Integer; shift: Integer; x: Real; y: Real) updating, protected;
// ---------------------------------------------------------------------------
// Created:     02 April 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpStr	: String;
	rtnCode	: Integer;

begin

	if self.displayMode &lt;&gt; ShpDisplayMode_ColCodeLoad then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid display mode (' &amp; self.displayMode.String &amp; ') for method');
		return;
	endif;
	
	if self.hasChanged and
	   self.myBayDrawingController.allSelectedObjects.size &gt; 0 and
	   button = Button.MouseButton_Left and
	   (not shift.isShiftKeyPressed) and  
	   (not shift.isControlKeyPressed) and 
	   (not shift.isAltKeyPressed) then // NO SHIFT, ALT or CONTROL
		// user is de-selecting the already selected slots so give a 
		// warning if there are pending updates they have not saved
		
		if self.workingMode = self.WorkMode_CustomSeq then
			tmpStr := "You have updated the sequence for the selected slots but have not" &amp; CrLf &amp;
					  "yet saved these changes.";
		else
			tmpStr := "You have changed the discharge port, commodity or cargo type for the" &amp; CrLf &amp;
					  "currently selected cargo but have not yet saved these changes.";
		endif;
	
		tmpStr := tmpStr &amp; CrLf &amp; CrLf &amp;
				"Select:" &amp; CrLf &amp;
				"  Yes to save these changes now." &amp; CrLf &amp; CrLf &amp;
				"  No to NOT save these changes and deselect the currently selected cargo." &amp; CrLf &amp; CrLf &amp;
				"  Cancel to NOT save these changes but leave the currently selected cargo selected.";
		
		rtnCode := app.msgBox(tmpStr, $Warning, MsgBox_Yes_No_Cancel + MsgBox_Question_Mark_Icon);
		if rtnCode = MsgBox_Return_Yes then
			app.mousePointer := MousePointer_HourGlass;
			if self.workingMode = self.WorkMode_CustomSeq then
				self.doSaveSequence();
			else
				self.doSaveColorCodeLoad(false);
			endif;
			app.mousePointer := MousePointer_Default;

		elseif rtnCode = MsgBox_Return_No then
			self.hasChanged := false;
			self.doGridAreaMouseUpEvent(frame, button, shift, x, y);
		else
			// rtnCode = MsgBox_Return_Cancel
			return;
		endif;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="frame" type="SHP_BayDrawingFrame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="handleBayMouseDownEventPlan" id="8766a599-c744-40f6-9783-e82432f4f58c">
        <updating/>
        <source>handleBayMouseDownEventPlan(_drawController : SHP_BayDrawingController; _slot : CM_SlotController; shift: Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 06/12/2011	cnwdap1		PAR #28615 Reinstate move controller's "ignore weight validation" setting
vars
	theTI : CM_TrackedItem;
	theSlotRequest : CM_SlotRequest;
	thePlanMove : CM_FutureMove;
	theLCs : CM_LCArray;
	anObj : Object;
begin
	if _slot = null then
		return;
	endif;
	
	if self.workingMode = WorkMode_Plan then
		self.moveModeForm := _drawController.moveMode;
		if self.displayMode = ShpDisplayMode_ColCodeDisch then

			// #### DISCHARGE
			theTI := _slot.allTrackedItems.first;
			theSlotRequest := _slot.mySlotRequestDischarge;
			if theSlotRequest &lt;&gt; null and theTI &lt;&gt; null and (not theSlotRequest.isSOB) then
				// only if we are not already planned
	
				thePlanMove := theTI.getFutureMoveOfType(PLANNING_MODE, TI_FutureMoveDLRDischarge);
				if thePlanMove = null then
					thePlanMove := theTI.getFutureMoveOfType(PLANNING_MODE, TI_FutureMovePlanned);
				endif;
				if thePlanMove = null then
					app.myDraggedTrackedItem := theTI;
					self.setMoveControllerSource(theTI);
					app.myMoveController.mySlotRequest := theSlotRequest;
				endif;					
			endif;
		else
			// ##### LOAD
			theSlotRequest := _slot.mySlotRequestLoad;
			if theSlotRequest &lt;&gt; null and theSlotRequest.myJob &lt;&gt; null and theSlotRequest.myJob.isJobComplete then
				theSlotRequest := null;
			endif;
			// if the load is complete check for a rework SlotRequest and switch to that
			if theSlotRequest = null then
				theSlotRequest := _slot.mySlotRequestDischarge;
				if theSlotRequest &lt;&gt; null then
					if not (theSlotRequest.isSOB or theSlotRequest.isRehandle) then
						theSlotRequest := null;
					endif;
					if theSlotRequest &lt;&gt; null then
						if theSlotRequest.myJob &lt;&gt; null and theSlotRequest.myJob.isJobComplete then
							theSlotRequest := null;
						endif;
					endif;							
				endif;
				if theSlotRequest &lt;&gt; null then
					theTI := theSlotRequest.getTrackedItem();
					// only if we are not already planned
					if theTI &lt;&gt; null
					and theTI.getPrimaryLocation(PLANNING_MODE) = null then
						app.myDraggedTrackedItem := theTI;
						self.setMoveControllerSource(theTI);
						app.myMoveController.mySlotRequest := theSlotRequest;
						
					endif;					
				endif;
			endif;

			// may have been erased so will be null move type
			if theSlotRequest &lt;&gt; null and (theSlotRequest.moveType = LOAD_MOVETYPE or theSlotRequest.isRehandle or theSlotRequest.isSOB) then
				self.setMoveControllerTarget(_slot);
				//jared: set mySlotRequest for other forms
				app.myMoveController.mySlotRequest := theSlotRequest;
				// PAR #28615 self.setMoveControllerTarget method just deleted the app.myMoveController that knew whether 
				// we were ignoring weight validation checks or not - need to reinstate this flag on the new move controller
				app.myMoveController.ignoreWeightValidation := self.chkIgnoreWeightV.value;
				
				app.myMoveController.autoSeqLoadPlan := false;
				if shift.isAltKeyPressed() 
				and not (theSlotRequest.isRehandle or theSlotRequest.isSOB) then
				
					app.myMoveController.autoSeqLoadPlan := true;
				endif;
				
				if theTI &lt;&gt; null then
					app.myMoveController.setMyTrackedItem(theTI);
				endif;
			endif;
		endif;
	endif;

	if app.myMoveController &lt;&gt; null then
		app.myMoveController.myOriginatingForm := self;
	endif;
epilog
	delete theLCs;
end;</source>
        <access>protected</access>
        <Parameter name="_drawController" type="SHP_BayDrawingController"/>
        <Parameter name="_slot" type="CM_SlotController"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleBayMouseDownEventSeq" id="e98f6402-7033-4ce4-982a-159199c89205">
        <updating/>
        <source>handleBayMouseDownEventSeq(_frame: SHP_BayDrawingFrame input; 
			_drawController : SHP_BayDrawingController; 
			_slot : CM_SlotController;
			button: Integer; shift: Integer; x: Real; y: Real) updating, protected;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theReturn : Integer;
	aftSlotRequest,
	theSlotRequest	: CM_SlotRequest;
	theCurrentJob,
	theSlotJob		: CM_VoyageJob;
	aftCusSeq,
	tmpCustSeq		: CMIF_CustomSequenceObject;
	isAltPressed,
	firstTimeForJob	: Boolean;
	nextCraneLane	: Integer;
	aftFrame		: SHP_BayDrawingFrame;
	shipSLiftIfDiffHeights, shipSLiftIfTLWgtExced, isBoldLine		: Boolean;
	aCrane : CM_Crane;
	maxLiftWeightTL : Integer;
	maxTwinLiftDiff : Integer;
	maxTwinLiftDiffSource : String;
	invalidJob 		: Boolean;
begin
	//14/02/2011 cnwdz2 par26990
	on Exception do app.handleDeletedObject(exception, theCurrentJob, invalidJob);
	
	isBoldLine	:=	true;
	shipSLiftIfTLWgtExced := self.myTerminal.getConfig(ShipSLiftIfTLWgtExced).Boolean; // 'Make S/Lift if crane twin lift weight exceeded'
	shipSLiftIfDiffHeights := self.myTerminal.getConfig(ShipSLiftIfDiffHeights).Boolean;

	if self.workingMode &lt;&gt; WorkMode_CustomSeq then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid workMode for method (' &amp; self.workingMode.String &amp; ')');
		return;
	endif;

	if _slot = null and (not self.hasChanged) then
		self.setCurrentJob(null);
		self.currentSeqNumber := 0;
		return;
	endif;
	
	//shift.isShiftKeyPressed then // SHIFT
	isAltPressed := shift.isAltKeyPressed; // ALT
	//shift.isControlKeyPressed then // CONTROL


	if _slot &lt;&gt; null then
		if self.displayMode = ShpDisplayMode_ColCodeDisch then
			theSlotRequest := _slot.mySlotRequestDischarge;
		elseif self.displayMode = ShpDisplayMode_ColCodeLoad then
			theSlotRequest := _slot.mySlotRequestLoad;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid displayMode (' &amp; self.displayMode.String &amp; ')');
			return;
		endif;

		if theSlotRequest = null and (not self.hasChanged) then
			// it is valid to click on a slot outside the job/area being sequenced
			// no error/warning required
			return;
		endif;
		
		if theSlotRequest &lt;&gt; null then
			theSlotJob := theSlotRequest.myJob.CM_VoyageJob;
		endif;
	endif;

	theCurrentJob := self.myCurrentJob; 

	if theCurrentJob &lt;&gt; null then
		if self.hasChanged and
		   (theCurrentJob &lt;&gt; theSlotJob or theSlotJob = null) then
			theReturn := app.msgBox("You are sequencing job " &amp; theCurrentJob.jobNum &amp; "," &amp; Cr
						&amp; "yet you clicked on a slot outside of that job." &amp; Cr &amp; Cr
						&amp; "Do you want to undo the sequencing?", "Sequencing Error",MsgBox_Yes_No);

			//14/02/2011 cnwdz2 par26990 start
			if not invalidJob then
				if theReturn = MsgBox_Return_Yes then
					// the user wants to throw away any changes to the
					// existing job.
					self.doPicSeqUndoClick();
					self.currentSeqNumber := 0;
					theCurrentJob := null;
					// need to call the handleMoueseUp as the display of
					// the message box here prevents this from firing
					_frame.handleMouseUp(_slot, button, shift, x, y);
				else
					// do not need to call handleMouseUp here as we
					// do not want it called
					return;
				endif;
			endif;
			//14/02/2011 cnwdz2 par26990 end
		endif;
	endif;
	
	if theSlotJob = null then
		return;
	elseif theCurrentJob &lt;&gt; theSlotJob then
		self.setCurrentJob(theSlotJob);
		firstTimeForJob := true;
	endif;
	
	tmpCustSeq	:= self.allCustomSeqObjsByReq[theSlotRequest];
	if tmpCustSeq &lt;&gt; null then
		if self.seqAppliesToMode = self.SeqAppliesTo_IndividualSlots then
			if self.btnTwinLiftCrane.value then
				nextCraneLane := self.lastCraneLaneUsed;
				self.hasChanged := true;
				
				nextCraneLane := self.myCurrentJob.getNextCraneLaneForTwin(self.allocateCraneLane, nextCraneLane);
				tmpCustSeq.isTwinLiftProperty := false;
				self.currentSeqNumber := self.txtSeqNum.text.Integer;
				tmpCustSeq.seqNumTwin := self.currentSeqNumber;
				tmpCustSeq.nextCraneLane := nextCraneLane;
				self.txtSeqNum.text := self.currentSeqNumber.asStringJMT;
				if isAltPressed then
					aftSlotRequest := theSlotRequest.getAftSlotRequest();
					if aftSlotRequest &lt;&gt; null and aftSlotRequest.myJob = theSlotRequest.myJob then
						aftCusSeq	:= self.allCustomSeqObjsByReq[aftSlotRequest];
						if aftCusSeq &lt;&gt; null then
							if aftSlotRequest.myJob.isKindOf(CM_VoyageJob) then
							/*	aCrane := aftSlotRequest.myJob.CM_VoyageJob.getJobCrane();
								if aCrane &lt;&gt; null then
									maxLiftWeightTL := aCrane.maxLiftWeightTL;
									//14 June 2010 NDL	Par 24108
									if aCrane.weightDifference &gt; 0 then
										maxTwinLiftDiff := aCrane.weightDifference.Integer;
									endif;
								endif; */
								aftSlotRequest.myJob.CM_VoyageJob.getWeightValidationValues( maxTwinLiftDiffSource, aCrane, maxLiftWeightTL, maxTwinLiftDiff);
							endif;
							
							if not tmpCustSeq.isTwinLift(aftCusSeq, shipSLiftIfTLWgtExced, maxLiftWeightTL, shipSLiftIfDiffHeights, maxTwinLiftDiff) then
								app.raiseCMException(Curren_item_cannot_twin_lifted, null, null);
								return;
							endif;
							if self.isSameTwinSeqReq then
								//self.currentSeqNumber := self.myLastCustomSequence.seqNumTwin;
								aftCusSeq.seqNumTwin := self.currentSeqNumber;
							else
								//self.currentSeqNumber := self.txtSeqNum.text.Integer;
								self.currentSeqNumber := self.currentSeqNumber + 1;
								aftCusSeq.seqNumTwin := self.currentSeqNumber;
							endif;
							//nextCraneLane := self.myCurrentJob.getNextCraneLaneForTwin(self.allocateCraneLane, nextCraneLane);
							// Par 14067
							aftCusSeq.nextCraneLane := nextCraneLane;
							self.currentSeqNumber := self.currentSeqNumber + 1;
							self.txtSeqNum.text := self.currentSeqNumber.asStringJMT;
							tmpCustSeq.isTwinLiftProperty := true;
							aftCusSeq.isTwinLiftProperty := true;
							aftFrame := self.myBayDrawingController.getFrameForBay(aftCusSeq.mySlotController.myBayVoyage);
							if aftFrame &lt;&gt; null then
								aftFrame.drawObject(aftCusSeq.mySlotController, self.myBayDrawingController);
							endif;
						else
							self.currentSeqNumber := self.currentSeqNumber + 1;
							self.txtSeqNum.text := self.currentSeqNumber.asStringJMT;
						endif;
					else
						self.currentSeqNumber := self.currentSeqNumber + 1;
						self.txtSeqNum.text := self.currentSeqNumber.asStringJMT;
					endif;
				else
					self.currentSeqNumber := self.currentSeqNumber + 1;
					self.txtSeqNum.text := self.currentSeqNumber.asStringJMT;
				endif;
				
				_frame.drawObject(tmpCustSeq.mySlotController, self.myBayDrawingController);
				self.lastCraneLaneUsed := nextCraneLane;
			else
				self.hasChanged := true;
				self.currentSeqNumber := self.txtSeqNum.text.Integer;
				tmpCustSeq.seqNum := self.currentSeqNumber;
				self.currentSeqNumber := self.currentSeqNumber + 1;
				self.txtSeqNum.text := self.currentSeqNumber.asStringJMT;
				_frame.drawObject(tmpCustSeq.mySlotController, self.myBayDrawingController);
			endif;
		else
			if self.btnTwinLiftCrane.value then
				self.currentSeqNumber := tmpCustSeq.seqNumTwin;
				self.txtSeqNum.text := self.currentSeqNumber.asStringJMT;
			else
				self.currentSeqNumber := tmpCustSeq.seqNum;
				self.txtSeqNum.text := self.currentSeqNumber.asStringJMT;
			endif;
		endif;
/*
		if firstTimeForJob then
			self.currentSeqNumber := tmpCustSeq.seqNum;
		else
			self.currentSeqNumber := self.currentSeqNumber + 1;
			tmpCustSeq.seqNum := self.currentSeqNumber;
			_frame.drawObject(tmpCustSeq.mySlotController, self.myBayDrawingController);
		endif;
*/		self.myLastCustomSequence := tmpCustSeq;
	else	
		app.raiseUnexpectedProgramError(class.name, method.name, 'custSeq transient not found');
	endif;
	
	/*if tmpCustSeq.isTwinLift(self.myLastCustomSequence) then
					self.myLastCustomSequence.isTwinLiftProperty := true;
					tmpCustSeq.isTwinLiftProperty := true;
					if self.isSameTwinSeqReq then
						self.currentSeqNumber := self.myLastCustomSequence.seqNumTwin;
						tmpCustSeq.seqNumTwin := self.currentSeqNumber;
					else
						self.currentSeqNumber := self.txtSeqNum.text.Integer;
						tmpCustSeq.seqNumTwin := self.currentSeqNumber;
						self.currentSeqNumber := self.currentSeqNumber + 1;
						self.txtSeqNum.text := self.currentSeqNumber.asStringJMT;
					endif;
					tmpCustSeq.nextCraneLane := nextCraneLane;
				else
					nextCraneLane := self.myCurrentJob.getNextCraneLaneForTwin(self.allocateCraneLane, nextCraneLane);
					tmpCustSeq.isTwinLiftProperty := false;
					self.currentSeqNumber := self.txtSeqNum.text.Integer;
					tmpCustSeq.seqNumTwin := self.currentSeqNumber;
					tmpCustSeq.nextCraneLane := nextCraneLane;
					self.currentSeqNumber := self.currentSeqNumber + 1;
					self.txtSeqNum.text := self.currentSeqNumber.asStringJMT;
				endif;*/

end;</source>
        <access>protected</access>
