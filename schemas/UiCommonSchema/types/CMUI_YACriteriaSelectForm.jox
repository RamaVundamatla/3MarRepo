    <JadeMethod name="setupForm" id="24b30fd6-e736-4e40-adb5-ff88fe1d0351">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
25 August 2008	consw1	Initial creation
21 Dec 2022     navsa20 ChangeRequest 55106: EUP - Filtered Drop-downs and Lists FIND LISTS
27/07/2023	navkc1	Bug 57701: FR | 54538 - EUP - Filtered Drop-downs and Lists - Find lists filter
*/

vars

begin
	inheritMethod();

	self.modalResult := IDCANCEL;

	self.setCaption( self.myCriteriaType.description );
	self.centreWindow();
	//self.centreOverParent(50);  //This can NOT be used when the calling form is Modal NDL Par 36234
	self.chkByDescription.visible := false;
	self.btnSaveBase.visible := false;
	self.btnCancelBase.visible := false;
	
	self.txtFind.text := criteriaValue;				//+cnwml2 PAR19072
	self.populateTable();
	self.doFind();									//+cnwml2 PAR19072

	if self.canOnlySelectOne then
		self.chkSelect.visible:=false;
	endif;
	
	self.checkSelected();
	/* 27/07/2023	navkc1	Bug 57701 keep the button enabled
	//self.btnClear.enabled := false;                 //21.12.2022 navsa20 TFS 55106		//05.06.2023 navtnr20 TFS 58331
	if self.txtFind.text &lt;&gt; null then				//05.06.2023 navtnr20 TFS 58331
		self.btnClear.enabled := true;
	else
		self.btnClear.enabled := false;
	endif;
	*/
epilog

end;</source>
