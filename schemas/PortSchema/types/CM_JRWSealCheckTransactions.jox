    <JadeMethod name="noOutputReturned" id="989cd892-4810-4b06-aca9-de72076a2471">
        <source>noOutputReturned(): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 October 2010	cnwndl1	Initial creation	Par 25608

*/

vars

begin

	if self.allJRWSealCheckDetailLines.isEmpty() then
		return true;
	endif;
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
