    <JadeMethod name="getCashReceipt" id="26429529-0301-4b0c-94ac-c4fb0bd36e9f">
        <source>getCashReceipt(_obj : Object):CM_CashReceipt;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
// 20/09/2019   cnwma1		Bug 46656: Receipt number not displaying on Charges tab for tax payments

*/

vars
	cashRec : CM_CashReceipt;
begin
	if _obj.isKindOf(CM_CashPayment) then
		cashRec := _obj.CM_CashPayment.myCashReceipt;
	endif;
	
	return cashRec;
epilog

end;</source>
