    <JadeMethod name="createSQLColumnPxyFromRow" id="457eec1f-095f-40ea-8566-f57e1a966b00">
        <updating/>
        <source>createSQLColumnPxyFromRow(_feature : CM_DataDumpFeature io;
						  _validate : Boolean;
						  _rowPointer : Integer; 
						  _columnPosArray : IntegerArray io;
						  _sqlColNamearray : HugeStringArray io; //25/06/2010 cnwdz2 24504
                          _extractClass : CM_DataDumpExtractClass; //21 June 2013 cnwgb1 30540 
                          _oidColName : String;  //21 June 2013 cnwgb1 30540 
						  _proxySQLColumn : CM_DataDumpSQLColumn output) : Boolean protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 May 2010	#cnwdz2	 24641
21 Feb 2024	navlw1	Bug 62446: MTN - Added validation for Oid, delete action, last operation, exported timestamp and features position columns 

*/

vars
	length, 
	columnPosistionInt,
	scaleFactor 			: Integer;
	maxLength   			: Boolean;
	jadeName,
	jadeType,
	columnPosistion,
	sqlColName, 
	sqlDataType,
	sqlDataTypeLength, 
	sqlDecimalDigits 		: String;
	extractClass 			: CM_DataDumpExtractClass;
begin
	_feature.getFeatureType(self.myDelegate.getOIDFormat(), length, scaleFactor,maxLength);
	extractClass := self.myProxyObject.CM_DataDumpExtractClass;	
	jadeName := self.tblExtFeatures.getCellText(_rowPointer, self.TableColumn_JadeName);
	jadeType := self.tblExtFeatures.getCellText(_rowPointer, self.TableColumn_JadeType);
	columnPosistion := self.tblExtFeatures.getCellText(_rowPointer, self.TableColumn_SQLColumnPosition);
	sqlColName := self.tblExtFeatures.getCellText(_rowPointer, self.TableColumn_SQLName);
	sqlDataType := self.tblExtFeatures.getCellText(_rowPointer, self.TableColumn_SQLType);
		
	sqlDataTypeLength := self.tblExtFeatures.getCellText(_rowPointer, self.TableColumn_SQLTypeLength);
	sqlDecimalDigits := self.tblExtFeatures.getCellText(_rowPointer, self.TableColumn_SQLDecimalDigits);
	
	
	if _validate then
        if _extractClass &lt;&gt; null then  //21 June 2013 cnwgb1 30540
            if  _extractClass.deleteActionColumnName &lt;&gt; null and 
                _extractClass.deleteActionColumnName = sqlColName then
                // Error Message
                app.msgBox(app.getErrorString2(ERR_Bad_Feature_SQL_Name, jadeName,self.lblDeleteColName.caption), 
                    app.getErrorString(ERR_ErrorBoxTitle), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
                return false;
            endif;
            if  _extractClass.lastOperationColumnName &lt;&gt; null and 
                _extractClass.lastOperationColumnName = sqlColName then
                // Error Message
                app.msgBox(app.getErrorString2(ERR_Bad_Feature_SQL_Name, jadeName,self.lblOptnColName.caption), 
                    app.getErrorString(ERR_ErrorBoxTitle), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
                return false;
            endif;
            if  _extractClass.exportedTimestampColumnName &lt;&gt; null and
                _extractClass.exportedTimestampColumnName = sqlColName then
                // Error Message
                app.msgBox(app.getErrorString2(ERR_Bad_Feature_SQL_Name, jadeName,self.lblExpDateTimie.caption), 
                    app.getErrorString(ERR_ErrorBoxTitle), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
                return false;
            endif;
            if  _oidColName &lt;&gt; null and
                _oidColName = sqlColName then
                // Error Message
                app.msgBox(app.getErrorString2(ERR_Bad_Feature_SQL_Name, jadeName,self.lblOIDClumnName.caption), 
                    app.getErrorString(ERR_ErrorBoxTitle), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
                return false;
            endif;
            // #62446 navlw1 check the position of the oid, delete action, last operation, exported timestamp columns
			if _extractClass.oidColumnPos = 0 or _extractClass.oidColumnPos = null then
				app.msgBox(app.getErrorString1(ERR_BulkLoadNullColumnPos, self.txtOIDColNValue.text), 
				app.getErrorString(ERR_ErrorBoxTitle), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
				return false;
			endif;
			if _extractClass.deleteActionColumnName &lt;&gt; null and _extractClass.deleteActionColumnPos = 0 then
				app.msgBox(app.getErrorString1(ERR_BulkLoadNullColumnPos, self.lblDeleteColName.caption), 
				app.getErrorString(ERR_ErrorBoxTitle), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
				return false;
			endif;
			if _extractClass.lastOperationColumnName &lt;&gt; null and _extractClass.lastOperationColumnPos = 0 then
				app.msgBox(app.getErrorString1(ERR_BulkLoadNullColumnPos, self.lblOptnColName.caption), 
				app.getErrorString(ERR_ErrorBoxTitle), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
				return false;
			endif;
			if _extractClass.exportedTimestampColumnName &lt;&gt; null and _extractClass.exportedTimestampColumnPos = 0 then
				app.msgBox(app.getErrorString1(ERR_BulkLoadNullColumnPos, self.lblExpDateTimie.caption), 
				app.getErrorString(ERR_ErrorBoxTitle), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
				return false;
			endif;
			// end #62446
        endif;
            
		if not _feature.getSQLTypeLength(jadeType,sqlDataType,sqlDataTypeLength,sqlDecimalDigits,length,scaleFactor,maxLength) then
			app.msgBox(app.getErrorString2(ERR_InvalidSQLTypeLength, jadeName,jadeType), 
					   app.getErrorString(ERR_ErrorBoxTitle), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return false;			
		endif;
		
		columnPosistionInt := columnPosistion.asIntegerJMT();
		// #62446 navlw1
		if columnPosistionInt = 0 then
			app.msgBox(app.getErrorString1(ERR_BulkLoadNullColumnPos, sqlColName), 
			app.getErrorString(ERR_ErrorBoxTitle), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return false;
		endif;
		
		if columnPosistionInt &lt;&gt; 0 and _columnPosArray.includes(columnPosistionInt)then
			app.msgBox(app.getErrorString2(ERR_DuplicateColumnPos, jadeName,jadeType), 
					   app.getErrorString(ERR_ErrorBoxTitle), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return false;	
		else
			_columnPosArray.add(columnPosistionInt);
		endif;
			
		if sqlColName = null or _sqlColNamearray.includes(sqlColName) then
			app.msgBox(app.getErrorString2(ERR_InvalidSQLColumnName, jadeName,jadeType), 
					   app.getErrorString(ERR_ErrorBoxTitle), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return false;
			
		else
			_sqlColNamearray.add(sqlColName);
		endif;
	endif;
		
	if not maxLength then
		maxLength := self.tblExtFeatures.getCellText(_rowPointer, self.TableColumn_SQLIsMaxtLength) = '1';
	endif;
	create _proxySQLColumn transient;
	_proxySQLColumn.setProxy(maxLength, length, scaleFactor, sqlColName, extractClass, _feature, app.myRoot.allDataDumpSQLDataTypes[sqlDataType.toUpper()], columnPosistionInt);
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_feature" type="CM_DataDumpFeature" usage="io"/>
        <Parameter name="_validate" type="Boolean"/>
        <Parameter name="_rowPointer" type="Integer"/>
        <Parameter name="_columnPosArray" type="IntegerArray" usage="io"/>
        <Parameter name="_sqlColNamearray" type="HugeStringArray" usage="io"/>
        <Parameter name="_extractClass" type="CM_DataDumpExtractClass"/>
        <Parameter name="_oidColName" type="String"/>
        <Parameter name="_proxySQLColumn" type="CM_DataDumpSQLColumn" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDeleteActionChange" id="b37f6dde-de46-498e-808c-8212391899a4">
        <source>doDeleteActionChange();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 May 2010	#cnwdz2	 24641

*/

vars

begin
	if self.cmbDeleteAction.text = self.DeleteOpt_UpdateFlag then
		self.lblDeleteColName.visible := true;
		self.txtDeleteColName.visible := true;
		self.txtDeleteColPos.visible := true;
	else
		self.lblDeleteColName.visible := false;
		self.txtDeleteColName.visible := false;
		self.txtDeleteColPos.visible := false;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doJadeClassChange" id="fada3592-5546-483a-b3cf-f5f9ec77993a">
        <updating/>
        <source>doJadeClassChange() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 April 2010	#cnwdz2	 24641

*/

vars
	jadeClass : CM_DataDumpClass;
	c : Class;
begin
	if self.mode = self.Mode_Add then
		delete self.myProxyObject;
		self.initProxy(null);	
	endif;
	
	self.txtSQLTblName.text := null;
	self.initTblExtFeatures();
	
	jadeClass := self.cmbJadeClass.listObject.CM_DataDumpClass;
	if jadeClass = null then
		return;
	endif;
	
	self.txtSQLTblName.text := jadeClass.classAlias;
	c := rootSchema.getSchema("PortSchema").getClass(jadeClass.className);
	self.txtJadeClassDesc.text := self.getItemDescription(c.text);
	self.txtFeatureDesc.text := null;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="cacd6f71-a575-47e4-a6a5-5f42828385d1">
        <updating/>
        <source>doOK() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 April 2010	#cnwdz2	 24641

*/

vars
	index : Integer;
	jadeClass : CM_DataDumpClass;
	lastOperation : Character;
	
	sqlTableName,
	deleteActionColumnName,
	lastOperationColumnName,
	exportedTimestampColumnName : String;
	deleteActionColumnPos       : Integer;
	lastOperationColumnPos      : Integer;
	exportedTimestampColumnPos  : Integer;
	oidColumnPos                : Integer;
	deleteAction : Integer;
	proxyExtractClass : CM_DataDumpExtractClass;
begin
	app.mousePointer	:=	Busy;
	
	proxyExtractClass := self.myProxyObject.CM_DataDumpExtractClass;
	if self.mode = self.Mode_Add then
		jadeClass := self.cmbJadeClass.listObject.CM_DataDumpClass;
	elseif self.mode = self.Mode_Edit then
		jadeClass := proxyExtractClass.myDataDumpClass;
	endif;
	
	if jadeClass = null then
		return;
	endif;
		
	sqlTableName            := self.txtSQLTblName.text;
	oidColumnPos            := self.txtOIDColPos.text.Integer;
	
	deleteAction            := self.getDeleteAction();
	if deleteAction = CM_DataDumpExtractClass.DeleteOpt_UpdateFlag then
		deleteActionColumnName  := self.txtDeleteColName.text;
		deleteActionColumnPos   := self.txtDeleteColPos.text.Integer;
	endif;
	
	lastOperationColumnName := self.txtOptnColName.text;
	lastOperationColumnPos  := self.txtLastOpColPos.text.Integer;
	lastOperation           := null;
	
	exportedTimestampColumnName := self.txtExpDateTime.text;
	exportedTimestampColumnPos  := self.txtExpDTColPos.text.Integer;
	
	proxyExtractClass.setProxy( jadeClass,null,sqlTableName,
							    deleteAction,  deleteActionColumnName,  deleteActionColumnPos,
							    lastOperation, lastOperationColumnName, lastOperationColumnPos,
							    exportedTimestampColumnName, exportedTimestampColumnPos,
							    oidColumnPos, proxyExtractClass.extractedUpToDateTime);

	if self.doSaveFeaturesForExtractClass(proxyExtractClass) then
		if self.myDelegate.doSaveJadeSQLMapping( proxyExtractClass, self.mode=self.Mode_Add) then
			inheritMethod();
		endif;
	endif;
	
epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveFeaturesForExtractClass" id="4a8b25b6-1401-40a1-9582-0a3a60726255">
        <updating/>
        <source>doSaveFeaturesForExtractClass(_extractClass:CM_DataDumpExtractClass input):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 April 2010	#cnwdz2	 24641
//19 June 2012	cnwrs1		Par 29827 - data Extract limit for number of features
*/
constants
	FeatureCountLimit = 127;	//19 June 2012	cnwrs1		Par 29827 
vars
	rowPointer	: Integer;
	startRow	: Integer;
	maxRow		: Integer;
	itemObj     : CM_DataDumpFeature;
	
	proxySQLColumn,
	realSQLColumn: CM_DataDumpSQLColumn;
	
	columnPosArray  : IntegerArray;
	sqlColNamearray : HugeStringArray; //25/06/2010 cnwdz2 24504
	colPos          : Integer;
    oidColName      : String;
//	maxFeatureCountLimit : Integer;
	
	selectedCount : Integer;	//22 Dec 2015	NDL Par 36888
begin
	
	startRow	:=	self.tblExtFeatures.fixedRows + 1;
	maxRow		:=	self.tblExtFeatures.rows;
	
	selectedCount := 1; //This equates to the "Jade Object Oid Column Name"	22 Dec 2015	NDL Par 36888
	selectedCount := selectedCount + (self.tblExtFeatures.rows - self.tblExtFeatures.fixedRows);	//22 Dec 2015	NDL Par 36888

	//cnwrd1 par 32871 we need to take into account these fields too. otherwise we can have too many selected and go boom later.
//	maxFeatureCountLimit := FeatureCountLimit;
	
	if _extractClass.exportedTimestampColumnName &lt;&gt; null then
	//	maxFeatureCountLimit := maxFeatureCountLimit -1;
		selectedCount := selectedCount + 1; //This equates to the "Export Date/Time Column Name" 22 Dec 2015	NDL Par 36888
	endif;
	
	if _extractClass.lastOperationColumnName &lt;&gt; null then
	//	maxFeatureCountLimit := maxFeatureCountLimit -1;
		selectedCount := selectedCount + 1; //This equates to the "Last SQL Operation Column Name" 22 Dec 2015	NDL Par 36888
	endif;
	
	if _extractClass.deleteActionColumnName &lt;&gt; null then
	//	maxFeatureCountLimit := maxFeatureCountLimit -1;
		selectedCount := selectedCount + 1; //This equates to the "Delete Flag Column Name" 22 Dec 2015	NDL Par 36888
	endif;
	
	
	if selectedCount &gt; FeatureCountLimit then	//19 June 2012	cnwrs1		Par 29827 - data Extract limit for number of features
		app.msgBox(app.getErrorString2(ERR_TooManyFeatures, selectedCount.String, FeatureCountLimit.String), 
			   app.getErrorString(ERR_ErrorBoxTitle), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		self.txtLastOpColPos.setFocus();
		self.txtLastOpColPos.selectAll();
		return false;
	endif;
	
	create columnPosArray transient;
	create sqlColNamearray transient;
	
	colPos := _extractClass.oidColumnPos;
	if colPos &gt; 0 then
		columnPosArray.add(colPos);
	endif;
	
	colPos := _extractClass.lastOperationColumnPos;
	if colPos &gt; 0 then
		if columnPosArray.includes(colPos) then
			app.msgBox(app.getErrorString2(ERR_DupColPosForOpField, colPos.String, self.lblOptnColName.caption), 
				   app.getErrorString(ERR_ErrorBoxTitle), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			self.txtLastOpColPos.setFocus();
			self.txtLastOpColPos.selectAll();
			return false;
		else
			columnPosArray.add(colPos);
		endif;
	endif;
	
	colPos := _extractClass.exportedTimestampColumnPos;
	if colPos &gt; 0 then
		if columnPosArray.includes(colPos) then
			app.msgBox(app.getErrorString2(ERR_DupColPosForOpField, colPos.String, self.lblExpDateTimie.caption), 
				   app.getErrorString(ERR_ErrorBoxTitle), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			self.txtExpDTColPos.setFocus();
			self.txtExpDTColPos.selectAll();
			return false;
		else
			columnPosArray.add(colPos);
		endif;
	endif;
	
	if _extractClass.deleteAction = CM_DataDumpExtractClass.DeleteOpt_UpdateFlag then
		colPos := _extractClass.deleteActionColumnPos;
		if colPos &gt; 0 then
			if columnPosArray.includes(colPos) then
				app.msgBox(app.getErrorString2(ERR_DupColPosForOpField, colPos.String, self.lblDeleteColName.caption), 
				   app.getErrorString(ERR_ErrorBoxTitle), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
				self.txtDeleteColPos.setFocus();
				self.txtDeleteColPos.selectAll();
				return false;
			else
				columnPosArray.add(colPos);
			endif;
		endif;
	endif;

	oidColName := self.txtOIDColNValue.text;
	self.resetExtractClassCollations(_extractClass);
	foreach rowPointer in startRow to maxRow do
		itemObj	:=	self.tblExtFeatures.accessRow(rowPointer).itemObject.CM_DataDumpFeature;
		if not self.createSQLColumnPxyFromRow(itemObj,true,rowPointer,columnPosArray,sqlColNamearray,_extractClass, oidColName, proxySQLColumn) then
			return false;
		endif;
		_extractClass.allDataDumpFeatures.add(itemObj);
		_extractClass.allDataDumpSQLColumns.add(proxySQLColumn);
	endforeach;

	return true;
epilog
	delete columnPosArray;
	delete sqlColNamearray;
end;</source>
        <Parameter name="_extractClass" type="CM_DataDumpExtractClass" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblSelectedFeatureClick" id="cea53519-f75f-429f-bfa5-37a5923416e6">
        <updating/>
        <source>doTblSelectedFeatureClick(_tbl : CM_DataTable input) protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 April 2010	#cnwdz2	 24641

*/

vars
	cell : JadeTableCell;
	jadeType,
	sqlTypes : String;
	dataDumpFeature : CM_DataDumpFeature;
	sqlLengthTxtBox : TextBox;
	defaultValue : String;
begin
	if _tbl = null or
	   _tbl.row &lt;= _tbl.fixedRows then
		return;
	endif;
	
	if _tbl.column &lt;&gt; self.TableColumn_SQLName and _tbl.column &lt;&gt; self.TableColumn_SQLType and 
	   _tbl.column &lt;&gt; self.TableColumn_SQLTypeLength and _tbl.column &lt;&gt; self.TableColumn_SQLDecimalDigits and
	   _tbl.column &lt;&gt; self.TableColumn_SQLColumnPosition then
		return;
	endif;

	dataDumpFeature := self.tblExtFeatures.accessRow(_tbl.row).itemObject.CM_DataDumpFeature;
	
	if _tbl.column = self.TableColumn_SQLName then
		cell := _tbl.accessCell(_tbl.row, self.TableColumn_SQLName);		
		cell.inputType := Table.InputType_TextBox;
		cell.maxLength := CM_DataDumpExtractDef.SQLColumnMaxStringLength;
	endif;
	
	if _tbl.column = self.TableColumn_SQLType then
		cell := _tbl.accessCell(_tbl.row, self.TableColumn_SQLType);
		//dataDumpFeature	:=	self.tblExtFeatures.accessRow(_tbl.row).itemObject.CM_DataDumpFeature;	
		sqlTypes := dataDumpFeature.getSQLTypes(self.myDelegate.getOIDFormat(), self.sqlVersion, defaultValue);
		if sqlTypes.containsOneOf(Tab) then
			cell.inputType := Table.InputType_ComboBox;
			cell.comboList := sqlTypes;
		endif;
	endif;

	if _tbl.column = self.TableColumn_SQLTypeLength then
		//dataDumpFeature	:=	self.tblExtFeatures.accessRow(_tbl.row).itemObject.CM_DataDumpFeature;	
		if dataDumpFeature.canChangeLength(_tbl.getCellText(_tbl.row, self.TableColumn_SQLType)) then
			cell := _tbl.accessCell(_tbl.row, self.TableColumn_SQLTypeLength);		
			cell.inputType := Table.InputType_TextNumeric;
			cell.maxLength := CM_DataDumpExtractDef.SQLColumnMaxLength;
		endif;
	endif;
	
	if _tbl.column = self.TableColumn_SQLDecimalDigits then
		//dataDumpFeature	:=	self.tblExtFeatures.accessRow(_tbl.row).itemObject.CM_DataDumpFeature;	
		if dataDumpFeature.canChangeDecimalDigists(_tbl.getCellText(_tbl.row, self.TableColumn_SQLType)) then
			cell := _tbl.accessCell(_tbl.row, self.TableColumn_SQLDecimalDigits);		
			cell.inputType := Table.InputType_TextNumeric;
			cell.maxLength := CM_DataDumpExtractDef.SQLColumnMaxLength;
		endif;
	endif;
	
	if _tbl.column = self.TableColumn_SQLColumnPosition then
		cell := _tbl.accessCell(_tbl.row, self.TableColumn_SQLColumnPosition);		
		cell.inputType := Table.InputType_TextNumeric;
		cell.maxLength := CM_DataDumpExtractDef.SQLColumnMaxLength;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDeleteAction" id="19789620-79a8-4a93-b11d-585da185cbef">
        <source>getDeleteAction():Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 April 2010	#cnwdz2	 24641

*/

vars
	deleteActionStr : String;
begin
	deleteActionStr := self.cmbDeleteAction.itemText[self.cmbDeleteAction.listIndex];
	if deleteActionStr = self.DeleteOpt_SendAll then
		return CM_DataDumpExtractClass.DeleteOpt_SendAll;
	endif;
	
	if deleteActionStr = self.DeleteOpt_SendNo then
		return CM_DataDumpExtractClass.DeleteOpt_SendNo;
	endif;
	
	if deleteActionStr = self.DeleteOpt_UpdateFlag then
		return CM_DataDumpExtractClass.DeleteOpt_UpdateFlag;
	endif;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getItemDescription" id="c68bd7b7-a962-4bed-8267-3ecfb8b3ac7e">
        <source>getItemDescription(_text:String):String protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 June 2010	#cnwdz2	 24641

*/

vars
	documentation : String;
begin
	documentation := _text.cnEcGetTagValueOfName(Doc_Documentation);
	return documentation.cnEcGetTagValueOfName(Doc_Description);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_text" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initCmbDeleteOption" id="d275df2a-b330-4cf8-a805-c4e24feda8ff">
        <source>initCmbDeleteOption();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 April 2010	#cnwdz2	 24641

*/

vars
	delAction : Integer;
begin
	
	self.cmbDeleteAction.clear;
	self.cmbDeleteAction.sorted := false;
	
	self.cmbDeleteAction.addItem(self.DeleteOpt_SendAll);		
	self.cmbDeleteAction.addItem(self.DeleteOpt_SendNo);
	self.cmbDeleteAction.addItem(self.DeleteOpt_UpdateFlag);
	self.cmbDeleteAction.listIndex := 1;
	
	if self.mode = self.Mode_Edit then
		delAction := self.myProxyObject.CM_DataDumpExtractClass.deleteAction;
		if delAction &gt; 0 then
			self.cmbDeleteAction.listIndex := delAction;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initCmbJadeClass" id="6df759fd-ee92-4f79-864d-fae2b19ec5d9">
        <source>initCmbJadeClass();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 April 2010	#cnwdz2	 24641

*/

vars
	masterClass	: CM_DataDumpClass;
	masterDict	: CM_DataDumpClassDict;
	index 		: Integer;
	className   : String;
	c           : Class;
begin
	if self.mode = self.Mode_Add then
		self.lblJadeClassName.visible := false;
		self.cmbJadeClass.visible := true;
		self.cmbJadeClass.clear;
		self.cmbJadeClass.sorted := true;
	
		masterDict := app.myRoot.allDataDumpClasses;
		foreach masterClass in masterDict do
			index := self.cmbJadeClass.addItem(masterClass.className);		
			self.cmbJadeClass.itemObject[index] := masterClass;
		endforeach;
	elseif self.mode = self.Mode_Edit then
		self.cmbJadeClass.visible := false;
		className := self.myProxyObject.CM_DataDumpExtractClass.className;
		self.lblJadeClassName.caption := className;
		self.lblJadeClassName.visible := true;
		c := rootSchema.getSchema("PortSchema").getClass(className);
		self.txtJadeClassDesc.text := self.getItemDescription(c.text);
		self.txtFeatureDesc.text := null;
	endif;
epilog

end;</source>
    </JadeMethod>
