    <JadeMethod name="adjustTotalCargoTareWeights" id="061c3c1e-391b-4d31-a63f-0c5f0aed4904">
        <source>adjustTotalCargoTareWeights( _originalTi : CM_TrackedItem;
							_fromControl : Control;	// the one that just lost focus
							_totalWeightKgs : Decimal; // the current value in the table representing total weight . May actually be populated with volume
							_cargoWeightKgs : Decimal; // the current value in the table for cargo weight
							_tareWeightKgs : Decimal;// the current value in the table for tare weight
							_tblTotalWeight : CMUI_MeasurementTable input; // Might actually be total volume
							_tblCargoWeight : CMUI_MeasurementTable input;
							_tblTareWeight : CMUI_MeasurementTable input;
							_isSplitForm : Boolean
							):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2018	jlgndl1	Initial creation	TFS 36697

*/

vars

	newTotalWeight : Decimal[14,4];
	newCargoWeight : Decimal[14,4];
	newTareWeight : Decimal[14,4];
	
	typeWeight : String;
	measureType : CM_MeasurementType;
	ct : CM_CargoType;
	typeVolume : String;
	volMeasureType : CM_MeasurementType;
	
	ratio : Real;
	
	didUpdate : Boolean;

begin

	didUpdate := false;
	
	if not _originalTi.myCargoType.useTareCargoWeight then
		return didUpdate;
	endif;
	
	measureType := _originalTi.getDefaultMeasurementForType(Type_Weight);
	if measureType = null then
		return didUpdate;
	endif;
	
	typeWeight:= measureType.shortName;
	
	newTotalWeight := _totalWeightKgs;
	newCargoWeight := _cargoWeightKgs;
	newTareWeight := _tareWeightKgs;
		
	if _fromControl = _tblCargoWeight then
		if _originalTi.usesAutoWeightCalculate() and _isSplitForm then
			//Cargo Weight may have changed
			//User can only change Cargo Weight in this mode. The system calculates Total Weight and Tare Weight
			//based on ratio of the existing values against the new split Total Weight.
			if _originalTi.totalWeight &gt; 0 and _originalTi.weightTare &gt; 0 then
				ratio := _originalTi.totalWeight / _originalTi.weightCargo;
			elseif _originalTi.weightCargo &gt; 0 then
				ratio := 1;
			elseif _originalTi.weightTare &gt; 0 then
				ratio := 0;
			endif;
			newTotalWeight := _cargoWeightKgs * ratio;
			newTareWeight := newTotalWeight - _cargoWeightKgs;
				
		else
			//Cargo Weight may have changed, reset Total weight based on Cargo + Tare, don't alter tare.
			newTotalWeight := _cargoWeightKgs + _tareWeightKgs;
			
		endif;	
		
	elseif _fromControl = _tblTareWeight then
		//This can only happen when the cargo type / product does not use 'auto weight calculate'
		//Tare Weight may have changed, potentially update Total weight, don't touch Cargo weight..
		if _originalTi.usesAutoWeightCalculate() and _isSplitForm then
			// NOT allowed, do nothing
			
		else
			newTotalWeight := _cargoWeightKgs + _tareWeightKgs;
			
		endif;
			
	elseif _fromControl = _tblTotalWeight then
		if _originalTi.usesAutoWeightCalculate() and _isSplitForm then
			//User can only change Total in this mode. The system calculates Cargo Weight and Tare Weight
			//based on ratio of the existing values against the new split Total Weight.
			if _originalTi.weightCargo &gt; 0 and _originalTi.weightTare &gt; 0 then
				ratio := _originalTi.weightCargo / _originalTi.totalWeight;
			elseif _originalTi.weightCargo &gt; 0 then
				ratio := 1;
			elseif _originalTi.weightTare &gt; 0 then
				ratio := 0;
			endif;
			newCargoWeight := _totalWeightKgs * ratio;
			newTareWeight := _totalWeightKgs - newCargoWeight;
		
		else
			//Total Weight may have changed, potentially update Cargo weight, don't touch Tare weight..
			newCargoWeight := _totalWeightKgs - _tareWeightKgs;
			
			//28 Mar 2018	NDL	TFS 37621
			if newCargoWeight &lt; 0 then
				// Can't obey the rules, as have removed more than cargo weight that we can adjust....
				newCargoWeight := 0;
				newTareWeight := newTotalWeight; 
			endif;
			
			
		endif;
			
	endif;
	
	//Now do the updating if there is anything to do.
	
	if newTareWeight &lt;&gt; _tareWeightKgs then
		_tblTareWeight.setValues(app.convertMeasurementForDisplay(typeWeight, newTareWeight) &amp; Space &amp; typeWeight);
		didUpdate := true;
	endif;
	
	if newCargoWeight &lt;&gt; _cargoWeightKgs then
		_tblCargoWeight.setValues(app.convertMeasurementForDisplay(typeWeight, newCargoWeight) &amp; Space &amp; typeWeight);
		didUpdate := true;
	endif;
	
	if newTotalWeight &lt;&gt; _totalWeightKgs then
		ct := _originalTi.myCargoType;
		if ct.isBreakBulkMulti then
			_tblTotalWeight.setValues(app.convertMeasurementForDisplay(typeWeight, newTotalWeight) &amp; Space &amp; typeWeight);
			didUpdate := true;
				
		elseif ct.isBulkMulti then	
			if ct.isTrackByWeight then
				_tblTotalWeight.setValues(app.convertMeasurementForDisplay(typeWeight, newTotalWeight) &amp; Space &amp; typeWeight);
				didUpdate := true;
			elseif ct.isTrackByVolume then
				measureType := _originalTi.getDefaultMeasurementForType(Type_Volume);
				typeVolume := measureType.shortName;
				_tblTotalWeight.setValues(app.convertMeasurementForDisplay(typeVolume, newTotalWeight / _originalTi.getDensity ) &amp; Space &amp; typeVolume);
				didUpdate := true;
			endif;
			
		endif;

	endif;
		
	return didUpdate;

epilog

end;</source>
        <Parameter name="_originalTi" type="CM_TrackedItem"/>
        <Parameter name="_fromControl" type="Control"/>
        <Parameter name="_totalWeightKgs" type="Decimal"/>
        <Parameter name="_cargoWeightKgs" type="Decimal"/>
        <Parameter name="_tareWeightKgs" type="Decimal"/>
        <Parameter name="_tblTotalWeight" type="CMUI_MeasurementTable" usage="input"/>
        <Parameter name="_tblCargoWeight" type="CMUI_MeasurementTable" usage="input"/>
        <Parameter name="_tblTareWeight" type="CMUI_MeasurementTable" usage="input"/>
        <Parameter name="_isSplitForm" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
