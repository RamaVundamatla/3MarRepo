    <JadeMethod name="doLoadAvailabilityGrades" id="54a99790-3162-4125-95b5-a130a1a4b3c0">
        <source>doLoadAvailabilityGrades() protected;
// ---------------------------------------------------------------------------
// Created:     12 March 2004	cnwth2
//
// ----------   ----------  --------------------------------------------------
vars
	userWindow	: CM_UserWindow;
	availGrade	: CM_MTGrade;
	mtGrade		: Integer;
	combo		: CMUI_ComboFilterMTGrade;
begin
	userWindow := self.myUserWindow;
	
	if userWindow &lt;&gt; null then
