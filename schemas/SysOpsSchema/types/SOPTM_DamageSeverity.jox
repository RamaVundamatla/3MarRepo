epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="5443bf10-8261-42b9-890a-fc051aa68396">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2022	navhl20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars
	theForm	: SOP_TableMaintForm;
begin
	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_DamageSeverity);
	
	theForm.shtTblInput1.caption := app.getErrorString(Details);
	theForm.initTblInput(theForm.tblInput1, ETDef_DamageSeverity);
	theForm.shtTblInput1.visible := true;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="05a27e30-6981-4e52-a9b6-8d0fa46befa5">
        <updating/>
        <source>showThumbnail(_damageSeverity : CM_DamageSeverity) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2022	navhl20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars
	theForm : SOP_TableMaintForm;
begin
	theForm := self.myForm;
	theForm.tblInput1.clearValues();
	
	theForm.tblInput1.setValueByName(ETRow_Code, _damageSeverity.code);
	theForm.tblInput1.setValueByName(ETRow_Description, _damageSeverity.description);
	theForm.tblInput1.setValueByName(ETRow_DamageSeverity, _damageSeverity.level);
	theForm.tblInput1.setValueByName(ETRow_IsNotAvailableForEntry, _damageSeverity.isNotAvalableForEntry);
	

epilog

end;</source>
        <Parameter name="_damageSeverity" type="CM_DamageSeverity"/>
    </JadeMethod>
</Class>
