    <JadeMethod name="getValueForRow" id="81aa8e8d-9bc8-4419-8c66-f603600e641d">
        <source>getValueForRow(_rowName: String; _obj: Object output): Any;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 November 2009	cnwas3	Initial creation

*/

vars

begin
	if _rowName = ETRow_BgpCreateInvoiceCharges then
		return self.chkCreateInvoiceCharges;
	elseif _rowName = ETRow_BgpAutoSelectorQuery then
		return self.mySelectorQuery.heading;
	elseif _rowName = ETRow_ServerFilePath then
		return self.networkPath;
	elseif _rowName = ETRow_BgpSnapShotDefinition then
		if self.mySSDefinition &lt;&gt; null then
			return self.mySSDefinition.name;
		endif;
	endif;
	return inheritMethod(_rowName, _obj);
end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_obj" type="Object" usage="output"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="0561bc0a-5129-4798-8022-32e10f42b8e3">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Date		Who		Reason
30 November 2009	cnwas3	Initial creation
20/04/2011			cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
							trying to create the proxy
*/

vars

	task : CM_AutoTaskSummarySnapShot;
	completedOK		: Boolean;
	
begin
	
	task := inheritMethod();
	task.mySelectorQuery := self.mySelectorQuery;
	task.chkCreateInvoiceCharges:= self.chkCreateInvoiceCharges;
	task.networkPath := self.networkPath;
	task.mySSDefinition := self.mySSDefinition;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return task;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete task;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="6236f941-e71f-4c05-beff-9161d2ec281d">
        <updating/>
        <source>setForCreate(_pxyAutoTask: CM_AutoTaskSummarySnapShot) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 November 2009	cnwas3	Initial creation

*/

vars

begin
	
	inheritMethod(_pxyAutoTask);
	self.requestClassName 	:= BGP_SummarySnapShot.name;
	self.chkCreateInvoiceCharges	:= _pxyAutoTask.chkCreateInvoiceCharges;
	self.mySelectorQuery	:= _pxyAutoTask.mySelectorQuery;
	self.networkPath := _pxyAutoTask.networkPath;
	self.mySSDefinition := _pxyAutoTask.mySSDefinition;
	//self.emailRecipient 	:= _pxyAutoTask.emailRecipient;
	//self.checkToDate	:= _pxyAutoTask.checkToDate;
	//self.networkPath	:= _pxyAutoTask.networkPath;
	//self.myHarbour:=_pxyAutoTask.myHarbour;

epilog

end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskSummarySnapShot"/>
    </JadeMethod>
