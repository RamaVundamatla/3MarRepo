    <JadeMethod name="trxDeleteTransactionType" id="62d053e7-ab3c-46e2-bd4a-7f3bde04a0fa">
        <updating/>
        <source>trxDeleteTransactionType(pTransactionTypeObj:CM_TransactionType io; _passport:CM_Passport input) updating;
