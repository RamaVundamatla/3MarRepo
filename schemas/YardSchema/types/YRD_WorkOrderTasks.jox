<GUIClass name="YRD_WorkOrderTasks" id="39a58bf0-c1f0-431b-884c-2ce49879a0f3">
    <superclass name="CMUI_Modal"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
