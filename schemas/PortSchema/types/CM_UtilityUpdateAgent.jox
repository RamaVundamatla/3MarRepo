/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 December 2009	cnwndl1	Initial creation	CCMS 1023

*/

vars

begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions( true );
	
	app.myValCA.valOutputFormatSS( _proxyFormat, _realFormat );
	
	if _realFormat = null then	
		app.raiseCMException2( MethodWithNullParam, method.name, '_realFormat', null, null );
		return;
	endif;
	
	if not self.checkValidationWithPassport( _passport ) then
		return;
	endif;
	
	app.setContinueCMExceptions( false );
	
	self.exclusiveLock( _realFormat );
	
	if _passport.noErrors and _realFormat.edition &lt;&gt; _expectedEdition then
		app.raiseCMException1( ObjectUpdatedByAnotherUserSave, 'SS Output Format', null, null );
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric( _realFormat, true );
	endif;
	
	if _passport.noErrors then
		_realFormat.setForUpdate( _proxyFormat );
	endif;
	
epilog
	
end;</source>
