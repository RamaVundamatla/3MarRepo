    <JadeMethod name="toolbarShowCaptions" id="6d9a0696-4e9c-4b5a-b7bc-496832ef945e">
        <updating/>
        <source>toolbarShowCaptions(_showCaptions: Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Sep 2023	navhl20	ChangeRequest 60432: MTN - Add time filter to Audit Enquiry screen.

*/

vars
	currentHeight : Real;
	newHeight : Real;
	heightDiff : Real;
begin
	currentHeight := self.frmToolbar.height;
	inheritMethod(_showCaptions);
	newHeight := self.frmToolbar.height;
	heightDiff := newHeight - currentHeight;
	if _showCaptions then
		self.frmSearch.height := self.frmSearch.height + heightDiff + 10;
		self.tblData.height := self.tblData.height - heightDiff + 20;
		self.tblData.top := self.tblData.top + heightDiff + 10;
		self.tblSearch.height := self.tblSearch.height + heightDiff + 20;
	endif;
	self.doResize();
epilog

end;</source>
        <Parameter name="_showCaptions" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="7ac34689-8301-4a19-9be8-7e1c88d07dc9">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 January 2023 08:48:35.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008307, locale);
	btnAuditConfig.translateBubbleHelp(Xlat_0024330, locale);
	btnAuditConfig.translateCaption(Xlat_0024331, locale);
end;</source>
    </JadeMethod>
</GUIClass>
