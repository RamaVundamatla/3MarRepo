    <JadeMethod name="doTranslations" id="e88cd663-1a7a-49b2-b5b6-3961d029105d">
        <updating/>
        <source>doTranslations(_xlationOperator: CM_Operator) updating;
//25 Jun 2015	cnwrs1	Par 33901/36027 - Default booking commodity
//16 Nov 2015   cnwgb1  Par 37172 Modify Action on Prenotes
//10 Jun 2016	cnwrs1	TFS 2150 - If you process an operatorCode and there is not xlation operator then start using that operator
// 17 Aug 2016	cnwrs1	TFS 2562 String too long with commodity 
// 18 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	foundMatch : Boolean;
	shippingLine : CM_ShippingLine;
	operatorShippingLine : CM_OperatorShippingLine;
	voyage : CM_Voyage;
	tiOperator : CM_Operator;
	port : CM_Port;
	lISOType : CM_ISOType;
	lISOTypeDesc : String;
	consignor,conisgnee : CM_ConsigneeConsignor;
	consignorStr,consigneeStr : String;
begin
	inheritMethod(_xlationOperator);

	if self.dischargePort = '****' then
		shippingLine := app.myRoot.allShippingLines[self.shippingLineCode];
		
		if shippingLine = null then
			voyage := self.getMyTerminal.lookupVoyage(self.getVoyageCode(), null, false);
			
			if voyage &lt;&gt; null then
				shippingLine 			:= voyage.myShippingLine;
				self.shippingLineCode 	:= shippingLine.code;
			endif;
		endif;
		
		tiOperator := app.myRoot.allOperators[self.operatorCode];
		
		if shippingLine &lt;&gt; null and tiOperator &lt;&gt; null then
			operatorShippingLine := app.myRoot.allOperatorShippingLines[tiOperator, shippingLine];
			
			if operatorShippingLine &lt;&gt; null then
				port := operatorShippingLine.getDischargePort(self.destinationPort);
				
				if port &lt;&gt; null then
					self.dischargePort := port.code;
				endif;
			endif;
		endif;
	endif;

	// check ISOType xlation
	if _xlationOperator &lt;&gt; null then
		if self.isoType &lt;&gt; null then
			lISOType := app.myRoot.allISOTypes[self.isoType];
		endif;
		if lISOType = null then
			global.getExtraData(self.allExtraData, ETRow_IsoTypeDesc, lISOTypeDesc);
			if lISOTypeDesc &lt;&gt; null then
				self.isoType := _xlationOperator.getXlationSystemCode(lISOTypeDesc, XLATION_TYPE_ISOTYPE_BYOP, foundMatch)[1:4];
			else
				self.isoType := _xlationOperator.getXlationSystemCode(self.isoType, XLATION_TYPE_ISOTYPE_BYOP, foundMatch)[1:4];
			endif;
		endif;
	endif;
epilog
	
end;</source>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="findCMIFCargo" id="fade48fa-e529-4004-b167-2d5af4f8c5bf">
        <source>findCMIFCargo(_cmifList : CMIF_PrenoteSet; _cargoTypeCode : Integer; _prenoteID : String) : CMIF_PreNote;
// ---------------------------------------------------------------------------
// Created:	18 June 2010 By Graeme Black cnwgb1
// Status: 	
// Purpose:	PAR 23419 Allow Prenotes/Cargo EDI to create child cargo
// ---------------------------------------------------------------------------
// 13 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
vars
	obj : CMIF_TIObject;
	cmifPrenote : CMIF_PreNote;
begin
	if _prenoteID = null or _cargoTypeCode = 0 then
		return null;
	endif;
	foreach obj in _cmifList do
		cmifPrenote := obj.CMIF_PreNote;
		if cmifPrenote &lt;&gt; null then 
			if cmifPrenote.id.trimBlanks() = _prenoteID.trimBlanks() then
				if cmifPrenote.cargoType = _cargoTypeCode then
					return cmifPrenote;
				endif;
			endif;
		endif;
	endforeach;
	return null;
epilog
end;</source>
        <Parameter name="_cmifList" type="CMIF_PrenoteSet"/>
        <Parameter name="_cargoTypeCode" type="Integer"/>
        <Parameter name="_prenoteID" type="String"/>
        <ReturnType type="CMIF_PreNote"/>
    </JadeMethod>
    <JadeMethod name="getCarbonDioxide" id="18844b24-0678-4d3f-8da8-4b3ae6350740">
        <source>getCarbonDioxide():Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 April 2020	jlgndl1	Initial creation	TFS 47958

*/

vars

begin

	//All Carbon Dioxide display fields are limited to Decimal 6,2  so don't returm bigger than that
	if self.carbonDioxide &gt; 999.99 then
		return 999.99;
	endif;

	return self.carbonDioxide;

epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
