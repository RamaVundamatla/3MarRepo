    <JadeMethod name="initTableGateLanes" id="a66df807-51b2-459f-b47d-226c491fdd0e">
        <updating/>
        <source>initTableGateLanes(_table : CM_DataTable input; _taType : Integer) updating; // cnwjk3 ccms 1018 18/11/09
/*

Purpose:			This is really just a quick mock up


Return Value:		


Date		Who		Reason
01 August 2006	cnwer1	Initial creation - PAR#xxxx
21/09/2009		cnwcs5	par 20582 - Table not being initialised properly (took out VTA specific code)
27 Mar 2013		cnwer1	PAR 31244 &amp; 31205
*/
vars

begin
	_table.optimiseRowHeight	:= true;
	_table.fixedColumns			:= 0;
	
	if _taType = TA_TYPE_RORO_LANE_AREA then
		_table.myDataClass			:= CM_RoRoController;	
		_table.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_RoRoLaneMaint));
	elseif _taType =  TA_TYPE_YARD_INTERCHANGE or _taType = TA_TYPE_WORKPOINT_INTERCHANGE then //epr TFS 1918 29/4/16
		_table.myDataClass			:= CM_YardICAreaLaneController;
		_table.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_VTAInterchangeMaint));

	elseif _taType = TA_TYPE_IRREGULAR_BLOCK_AREA then // ### TFS CR 58499 TASK 61459 04JAN2024 NAVAB1
		_table.myDataClass := CM_IrregularBlockController;
		_table.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_TATransAreas));
	elseif _taType = TA_TYPE_CRANE_TRANS then
		_table.myDataClass := CM_CraneLaneController;
		_table.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_CraneTALanes));
	endif;

	
	_table.top			 		:= 5;
	_table.left					:= 5;
	_table.parentTopMargin		:= _table.top;
	_table.parentLeftMargin		:= _table.left;
	_table.parentRightMargin	:= 15;
	_table.parentBottomMargin 	:= 10;

	_table.lockBottom 			:= false;
	_table.lockRight			:= false;
	_table.stretchHeight 		:= true;
	_table.stretchWidth 		:= true;

	_table.cnEcResizeContents();	
epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_taType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="insertRowColumn" id="dddafb27-28e3-473a-a1cb-41564e141d48">
        <updating/>
        <source>insertRowColumn() updating;
// ---------------------------------------------------------------------------
// Created:		02 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	gridRow	 		: SOP_GridRow;
	gridColumn		: SOP_GridColumn;
	isToDraw		: Boolean;
	idx				: Integer;
begin
	self.areaChanged := true;
	beginLoad;
	idx := self.myCurrentSOPGridArea.selectedRow;
	if idx &lt;&gt; 0 then
		gridRow := self.myCurrentSOPGridArea.allGridRows[idx].SOP_GridRow;
		
		if gridRow = null then
			return;
		endif;
		
		// 11/7/06 epr par 12048 if this was a newly inserted row then this will be null and cause 1090
		if gridRow.myGridRow &lt;&gt; null then
			if gridRow.myGridRow.isInUseForInsert() then
				app.msgBox("Cannot insert, row " &amp; gridRow.label &amp; " is in use.","Insert Problem",MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
				return;
			endif;
		endif;
		create gridRow transient;
		self.myCurrentSOPGridArea.insertGridRow(gridRow, idx);
		tblMain.setValueByName(ETRow_Rows,self.myCurrentSOPGridArea.allGridRows.size);
		isToDraw := true;
		return;
	endif;
	idx := self.myCurrentSOPGridArea.selectedColumn;
	if idx &lt;&gt; 0 then
		gridColumn := self.myCurrentSOPGridArea.allGridColumns[idx].SOP_GridColumn;
		
		if gridColumn = null then
			return;
		endif;
		
		if gridColumn.myGridCol &lt;&gt; null then
			if gridColumn.myGridCol.isInUseForInsert() then
				app.msgBox("Cannot insert, column " &amp; gridColumn.label &amp; " has 40 footer conflict.","Insert Problem",MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
				return;
			endif;
		endif;
		
		create gridColumn transient;
		self.myCurrentSOPGridArea.insertGridColumn(gridColumn, idx);
		tblMain.setValueByName(ETRow_Cols,self.myCurrentSOPGridArea.allGridColumns.size);
		isToDraw := true;
		return;
	endif;

	
epilog
	endLoad;
	if isToDraw then
		self.frmMain.drawSelf();
	endif;
	self.myCurrentSOPGridArea.setSelected(0,0);
end;</source>
    </JadeMethod>
    <JadeMethod name="isValidType" id="85330bf1-8bfd-4fba-b186-a3f7eb15d22f">
        <source>isValidType(pType : Integer; _isInterTermMulti : Boolean) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25/02/2010 	cnwcs5 		remove VTA references
// ---------------------------------------------------------------------------
vars

	terminal	: CM_Terminal;
	user 		: CM_User;

begin
	if pType = TA_TYPE_SWAP or 
		pType = TA_TYPE_SUBBLOCK_STACK or
//		pType = TA_TYPE_ROAD_TRANS or	25/02/2010 cnwcs5 remove VTA references // leave till we delete the constant after 7.7.3
		pType = TA_TYPE_GATE_ROAD or
		(pType = TA_TYPE_INTERTERM_TRANS_AREA and not _isInterTermMulti) or
		pType = TA_TYPE_RTG_INTERCHANGE or
		pType = TA_TYPE_RMG_INTERCHANGE then
//	or pType = TA_TYPE_RAIL_TRANS then
		return false;
	elseif pType = TA_TYPE_BULK then
		user := app.getMyUser();
		
		//terminal := app.getMyTerminal(); //- cnwmd1, Par 20643
		terminal := self.myTerminal; //+ cnwmd1, Par 20643
		if user = null or terminal = null or not user.canDo(terminal, Mod_BulkCargo) then
			return false;
		endif;
	elseif pType = TA_TYPE_RMG or pType = TA_TYPE_RMG_LANE then
		//epr par 32613 2/10/13 don't show if not licensed
	/*	if not app.myRoot.canDo(PmRMGFunctions) then
			return false;
		endif; */	//07 Oct 2019	NDL	TFS 46169
	elseif pType = TA_TYPE_RTG or pType = TA_TYPE_RTG_LANE then
		//epr par 32613 2/10/13 don't show if not licensed
	/*	if not app.myRoot.canDo(PmRTGFunctions) then
			return false;
		endif; */	//07 Oct 2019	NDL	TFS 46169
	endif;
	
	return true;
	
end;</source>
        <access>protected</access>
        <Parameter name="pType" type="Integer"/>
        <Parameter name="_isInterTermMulti" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="bbd34809-3990-4408-bd12-c049623e66ba">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 July 2020	jlgndl1	Initial creation	TFS 49775

*/

vars

begin

	if shift.isControlKeyPressed then
		if keyCode = J_key_N then
			self.labelContents := 0;
			self.showThumbnailData( self.myCurrentObject );
			return;
		elseif keyCode = J_key_C then
			self.labelContents := 1;
			self.showThumbnailData( self.myCurrentObject );
			return;
		elseif keyCode = J_key_W then
			self.labelContents := 2;
			self.showThumbnailData( self.myCurrentObject );
			return;
		elseif keyCode = J_key_Y then
			self.labelContents := 3;
			self.showThumbnailData( self.myCurrentObject );
			return;
		endif;
	endif;
	
	inheritMethod(keyCode, shift);

epilog

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="listsMachinesDisplayEntry" id="8655e6b1-27ad-4273-98bf-c8ec4c33f3df">
