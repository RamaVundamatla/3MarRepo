    <JadeMethod name="doActionTask" id="c9a76a68-71d7-4157-8dc9-04f373531752">
        <updating/>
        <source>doActionTask(_woActionIF   : CMIF_WorkOrderAction;
			 _realJob	   : CM_Job io;
			 _passport     : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Apr 2023 navma1  ChangeRequest 57569:[57570] EUP - [Framework] Refactor Actioning Work Order Tasks
12 Apr 2023 navhl20 ChangeRequest 55443:[54991] EUP - Receive Cargo Work Order - Enhancements
12 Apr 2023 navma1  ChangeRequest 57569:[57570] EUP - [Framework] Refactor Actioning Work Order Tasks
19 Apr 2023 navhl20 Defect 57648: MTN - Issues when actioning the multiple Receive Cargo Work Order tasks
17 Jul 2023	navma1	Bug 59158: MTN - Actioning ToDo work orders doesn't create Update Transaction
17 Jul 2023	navma1	Bug 59158: MTN - Actioning ToDo work orders doesn't create Update Transaction
*/

vars
	todoParams   	: CMIF_WorkOrderJobParams;
	wodToDo		 	: CM_WodToDo;
	tiSet			: CM_TISet;
begin
	inheritMethod(_woActionIF,_realJob,_passport);
	
	//Cargo Already been selected
	if _woActionIF.numberFromKnownCargo &gt; 0 then
		
		self.doActionTaskKnown(_woActionIF,_realJob,_passport);
		
		/*
			if there is any ToDo Tasks Attached to the work orders
		*/
		if _woActionIF.useYardJobs then
			if self.allToDoRequests.isNotEmpty() then
				wodToDo := self.allToDoRequests.first;									//19.4.2023 navhl20	#57648
				wodToDo.doActionTask(_woActionIF,_realJob,_passport);					//19.4.2023 navhl20	#57648
			endif;
		endif;
	else
		self.doActionTaskUnKnown(_woActionIF,_realJob,_passport);
	endif;
	
epilog
	delete todoParams;
	delete tiSet;
end;</source>
        <Parameter name="_woActionIF" type="CMIF_WorkOrderAction"/>
        <Parameter name="_realJob" type="CM_Job" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doActionTaskKnown" id="e5c3db0b-c83c-40ba-bc18-c5b4766c3d6d">
        <updating/>
        <source>doActionTaskKnown(_woActionIF  : CMIF_WorkOrderAction;
				  _realJob	   : CM_Job io;
				  _passport    : CM_Passport input)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Apr 2023 navma1  ChangeRequest 57569:[57570] EUP - [Framework] Refactor Actioning Work Order Tasks
17 Jul 2023	navma1	Bug 59158: MTN - Actioning ToDo work orders doesn't create Update Transaction

*/

vars
	tiSet 		: CM_TISet;
	ti	  		: CM_TrackedItem;
	jobParams 	: CMIF_WorkOrderJobParams;
begin

	create tiSet transient;
	self.allAvailableTIs.copy(tiSet);
	
	// Move to actioned 0
	foreach ti in tiSet do 
		self.allAvailableTIs.tryRemoveIfNotNull( ti);					
		self.allActionedTIs.addNoDuplicates(ti,false);	
	endforeach;
	
	self.totalActioned 	  := self.allActionedTIs.size;								
	self.totalUnactioned  := self.allSelectedTIs.size - self.allActionedTIs.size;
	
	create jobParams transient;
	
	tiSet.copy(jobParams.allTIs);
	
	if _woActionIF.useYardJobs then
		self.createWOJobs(_woActionIF,jobParams,_realJob,_passport);					//12.04.2023 navma1 #57569:[57570]
	endif;	

epilog
	delete tiSet;
	delete jobParams;
end;</source>
        <Parameter name="_woActionIF" type="CMIF_WorkOrderAction"/>
        <Parameter name="_realJob" type="CM_Job" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
