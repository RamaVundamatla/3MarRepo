    <JadeMethod name="displayExtraInfoForObj" id="3cf29e36-1652-4658-a1d4-2c69c36b62a3">
        <source>displayExtraInfoForObj(_obj : CM_Object) protected;

vars
	dataContainer : CM_DataContainer;
begin

	
	self.tblInfo.rows := 0;
	
	create dataContainer transient;
	dataContainer.headerColour := self.colorHeadingColumn;
	dataContainer.valueColour := self.colorValueColumn;

	if _obj &lt;&gt; null and _obj.isKindOf(CM_Object) then
		_obj.CM_Object.getExtraInfo(dataContainer);
		self.showExtraInformation(dataContainer, self.tblInfo, true, false, 4, 1, 1, 1, 1);
		self.doResizeColumnWidths(self.tblInfo, true);
	endif;

epilog
	delete dataContainer;
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="doAutoPlan" id="617f54e6-af1b-41e3-8a37-eaafcc654300">
        <updating/>
        <source>doAutoPlan() protected, updating;

// Created by cnwdvb1 on 03 May 2006

vars

	cmifMonitor	: CMIF_Monitor;
begin

	cmifMonitor := app.myPassport.myCMIFMonitor;
	if cmifMonitor = null then
		create cmifMonitor transient;
		app.myPassport.setMyCMIFMonitor(cmifMonitor);
		cmifMonitor.myParent := self;
	endif;
	self.modalDialogShow(null, null, null, null, 'Auto Planning For Voyage '&amp; self.myVoyage.code, cmifMonitor.message);

   	self.pbProgressBar.visible := true;   	
	app.doWindowEvents(0);

	app.autoPlanForDischargeYA(self.myTerminal, self.myVoyage, self.myWleSetOut);
	
epilog

	self.frmModalDialog.visible := false;
	delete cmifMonitor;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doAutoplanning" id="40ae386f-b885-4314-a047-f54e802bd67b">
        <updating/>
        <source>doAutoplanning(_autoPlan : Boolean) protected, updating;

// Created by cnwdvb1 on 02 May 2006

vars
	aWLE : CM_WorkListEntry;
	wles,
	wlesWithWarnings	: CM_WLEArray;
	result				: Integer;
	wle					: CM_WorkListEntry;

begin

	if _autoPlan then
		if app.msgBox('Do you wish to auto plan all discharge jobs for voyage ' &amp; self.myVoyage.code, 'Auto Discharge', MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_Yes then
			return;
		endif;
		self.doAutoPlan();
	else
		if app.msgBox('Do you wish to unplan the discharge jobs for voyage ' &amp; self.myVoyage.code &amp; ' that have been auto planned by this process', 'Auto Discharge', MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_Yes then
			return;
		endif;
		create wles transient;
		create wlesWithWarnings transient;
		
//		self.myWleSetOut.copy(wles); // PAR 12634
		// only unplan those that are planned
		foreach aWLE in self.myWleSetOut do
			if aWLE.myTrackedItem &lt;&gt; null
			and not aWLE.myTrackedItem.allPlannedFutureMoves.isEmpty then
				wles.add(aWLE);
			endif;
		endforeach;
		
		while true do
			app.myTrxUA.trxUpdateWLEsUnplan(wles, wlesWithWarnings, NO_MODE, app.myPassport);
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				foreach wle in wles do
					if self.myWleSetOut.includes(wle) then
						self.myWleSetOut.remove(wle);
					endif;
				endforeach;
				break;
			else
				result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnSkipErr);
				if result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					
					// only reprocess the wles that had warnings.
					wles.clear;
					wlesWithWarnings.copy(wles);
					wlesWithWarnings.clear;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			endif;
			break;
		endwhile;
	endif;
	
	self.loadTblData();
epilog
	delete wles;
	delete wlesWithWarnings;

end;</source>
        <access>protected</access>
        <Parameter name="_autoPlan" type="Boolean"/>
    </JadeMethod>
