    <JadeMethod name="isAvowel" id="073f2d41-acbd-4175-b0ed-62cdb83a7c98">
        <source>isAvowel(pChar : Character):Boolean protected;

vars

begin
	if pChar = "A" 
	or pChar = "E" 
	or pChar = "I" 
	or pChar = "O" 
	or pChar = "U" then
		return true;
	else
		return false;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pChar" type="Character"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="removeDuplicateChars" id="52b9041c-375d-4265-b2f5-c00cf47f41f6">
        <source>removeDuplicateChars(pWorkString : String io) protected;

vars
	retValue	: String;
	char		: Character;
	lastChar	: Character;
	size		: Integer;
	pos			: Integer;
	
begin
	if pWorkString.length() &gt; 1 then
		size := pWorkString.length();
		retValue := "";
		
		foreach pos in 1 to size do
			char := pWorkString[pos:1].Character;
			if char &lt;&gt; lastChar then
				retValue := retValue &amp; char.String;
				lastChar := char;
			else
				continue;
			endif;
		endforeach;
		
		pWorkString := retValue;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pWorkString" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="removeNonAlpha" id="a8aa55d1-0fad-4223-93d1-901b2776b52e">
        <source>removeNonAlpha(pWorkString : String io) protected;

vars
	retValue	: String;
	char		: Character;
	size		: Integer;
	pos			: Integer;
	
begin
	pWorkString.trimBlanks();
	size		:=	pWorkString.length();
	retValue	:=	"";
	
	foreach pos in 1 to size do
		char := pWorkString[pos:1].Character;
		
		if char.isAlpha() then
			retValue := retValue &amp; char.String;
		else
			continue;
		endif;
	endforeach;
	
	pWorkString := retValue;
end;</source>
        <access>protected</access>
        <Parameter name="pWorkString" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="returnFirstChars" id="583e3c29-e80d-4645-a9bb-7b2d683e9c2f">
        <source>returnFirstChars(pWorkString : String io; pMaxLength : Integer) protected;

begin
	if pMaxLength = 0 then
		
	else
		if pWorkString.length() &gt; pMaxLength then
			pWorkString := pWorkString[1:pMaxLength];
		endif;
	endif;		
end;</source>
        <access>protected</access>
        <Parameter name="pWorkString" type="String" usage="io"/>
        <Parameter name="pMaxLength" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="fd4f9fb3-17c3-4ded-b324-9a45545ca4be">
        <updating/>
        <source>updateMe(pInputString : String) updating;

vars

begin
	if self.inputString &lt;&gt; pInputString then
		self.inputString := pInputString;
	endif;		
end;</source>
        <Parameter name="pInputString" type="String"/>
    </JadeMethod>
</Class>
