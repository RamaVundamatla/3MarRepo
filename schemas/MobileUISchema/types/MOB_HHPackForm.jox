        <source>handleBtnOne() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 June 2011	cnwndl1	Initial creation	Par 26476

*/

vars

begin

	if not self.validateSelections() then
		return;
	endif;
	
	self.myMobileGenericAgent.setPackContainerDetails(	self.myCargoStockBookingRef,	//_stockBookingRef : CM_BookingRef;
															self.myCargoStockBookingItem,	//_stockBookingRefItem : CM_BookingRefItem;
															self.myContBookingRef,	//_exportBookingRef : CM_BookingRef;
															self.myContBookingItem,	//_exportBookingRefItem : CM_BookingRefItem;
															self.myTrackedItem	//_trackedItem : CM_TrackedItem
															);	
	self.gotoForm( MOB_HHPackContainerUpdForm, false );

epilog

end;</source>
