    <JadeMethod name="validateMe" id="6cb505a7-d7e4-4701-986d-447c1decc64e">
        <source>validateMe();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2018	jlgndl1	Initial creation	TFS 38914

*/

vars

	realForCheck : CM_InvTypeVesselMinCharge;
	existing : CM_InvTypeVesselMinCharge;

begin

	if self.minimumChargeAmount &gt; CM_InvoiceTypeSurchargeExempt.HighValue_15_2 then	//rework again 24 Jul 2019	NDL TFS 45509	
		app.raiseCMException2(ERR_LOWER_GT_UPPER, app.getErrorString(Minimum_charge), CM_InvoiceTypeSurchargeExempt.HighValue_15_2.asStringJMT, null, null); 
	endif;
	
	if self.mySurchargesAndExemptions = null then
		app.raiseCMException(Current_surcharge_exemptions, null,null);
		return;
	endif;
	
	if self.getMinimumChargeInvLineType = null then
		app.raiseCMException(Minim_charg_line_type_must_sel, null,null);
		return;
	endif;
	
	if self.myVessel = null then
		app.raiseCMException(Input_required_field_vessel, null,null);
		return;
	endif;
	
	if self.isTransient then
		realForCheck := self.pxyGetRealObject();
	else
		realForCheck := self;
	endif;
	
	existing := self.mySurchargesAndExemptions.allInvTypeVesselMinCharges.getAtKey( self.myVessel );
	if existing = null or existing = realForCheck then
		//we can carry on.
	else
		//This key is already used.
		app.raiseCMException(Minim_charg_alrea_exist_this_v, null,null);
		return;
	endif;

epilog

end;

</source>
    </JadeMethod>
