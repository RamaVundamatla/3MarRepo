    <JadeMethod name="scriptKeyExpired" id="2e1fb247-466a-4675-85ff-2e64a457d289">
        <source>scriptKeyExpired(_key: String; factor: Integer): Boolean;
//----------------------------------------------------------------
//	Created:	13 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	year	: Integer;
	day		: Integer;
begin
	year := ('2' &amp; _key[1:3]).Integer;
	day := (_key[4:end]).Integer + factor;
	
	if day &gt; 365 then
		year := year + 1;
		day := day - 365;
	endif;

	if day &gt; app.getUTCTime.date.dayOfYear 
	and year &gt;= app.getUTCTime.date.year() then
		return false;
	endif;

	return true;
	
end;</source>
        <Parameter name="_key" type="String"/>
        <Parameter name="factor" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sealCheckTypeEnumToString" id="dc29738d-e2e4-4270-a408-7d56ff5dc4d9">
