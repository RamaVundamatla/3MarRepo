    <JadeMethod name="isStorageDetailMatch" id="1f312cdb-e1b4-4ece-a802-9206d022de42">
        <source>isStorageDetailMatch(_criteria: CM_YACriteria; _ti: CM_TrackedItem; _tiTrx : CM_TITransaction): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24/07/2017	cnwma1	TFS #5513:STWO - Direct Delivery Invoicing Set-up

*/

vars

begin
	//epr TFS 37176 21/2/18
//	return _criteria.myYAData.CM_YADataBoolean.doesValueMatch( _ti.directDelivery);
	
	if _tiTrx &lt;&gt; null and _tiTrx.myTrackedItem &lt;&gt; null then	//13 Nov 2019	NDL	TFS 47344
		return _criteria.myYAData.CM_YADataBoolean.doesValueMatch( _tiTrx.myTrackedItem.directDelivery );// directDelivery not kept on the generic transaction
	else
		return _criteria.myYAData.CM_YADataBoolean.doesValueMatch( _ti.directDelivery );
	endif;

epilog

end;</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
