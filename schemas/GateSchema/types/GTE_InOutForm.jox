    <JadeMethod name="btnDeleteCurrent_click" id="b2d9e785-5ece-4915-a59d-f0251fb3de1c">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDeleteCurrent_click(btn: Button input) updating;
//--------------------------------------------------
// Created:	15 September 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	if fldInOut.sheets &gt; 2 then 
		self.causeEvent(InOut_DeleteSheet, true, self.topSheet);
		self.notifyGotFocus();
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Attempt to delete system sheets');
	endif;
end;</source>
