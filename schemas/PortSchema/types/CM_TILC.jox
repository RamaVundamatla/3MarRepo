    <JadeMethod name="setMyType" id="9b4e66f6-9a16-4aa5-9b7f-94183f42803b">
        <updating/>
        <source>setMyType(_type : CM_TILCType) updating;
// -------------------------------------------
// Created 12 December 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	if _type &lt;&gt; self.myTILCType then
		self.myTILCType := _type;
	endif;
	
	//15/10/2025	navkc1 JIRA 36057
	if _type &lt;&gt; null and _type.allowUpdateTotalWeight then
		self.updateTILCTotalWeightConfig(true);
	endif;
	

end;</source>
