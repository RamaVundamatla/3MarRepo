    <JadeMethod name="checkLCFromXYNoTI" id="799c901e-c693-4244-9d1c-7a74a8403916">
        <source>checkLCFromXYNoTI(layerFrame :CMUI_PointDrawingFrame input;x,y : Real  ): CM_LocationsController protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 February 2012	cnwer1	Initial creation CCMS MES 1033

*/

vars
	itemLayout : CM_DeckItemLayout;
	objectIndex : Integer;
	theLC : CM_LocationsController;
	theDefn : CM_DeckItem;
	theReq : CM_RORORequest;
begin
	
		
	if layerFrame.detectIfInPolygon(x.Integer,y.Integer, objectIndex) then // this set 'TheGraphic' reference
		if layerFrame.theGraphic.isKindOf(CM_DeckItemLayout) then
			itemLayout := layerFrame.theGraphic.CM_DeckItemLayout;
			if not itemLayout.isVisible or not itemLayout.myDeckLayer.isVisible then
				return null;
			endif;
			layerFrame.theGraphic := null;
			
			if itemLayout.myDeckItem &lt;&gt; null then
				theLC := itemLayout.myDeckItem.getLCNoTI(self.myPlanningForm.moveModeForm);
				if theLC &lt;&gt; null then
					return theLC;
				endif;
			elseif itemLayout.isKindOf(CM_RORORequestLayout) and  itemLayout.CM_RORORequestLayout.myRequest &lt;&gt; null then
				theDefn := itemLayout.CM_RORORequestLayout.myRequest.myROROController.getDefn();
				
				// PAR 28942
				theReq := theDefn.getFirstUnplannedRequest(true);
				if theReq &lt;&gt; null then
					return theReq.myROROController;
				endif;
				theLC := itemLayout.CM_RORORequestLayout.myRequest.myROROController;
				if theLC &lt;&gt; null then
					return theLC;
				endif;
			endif;
			
		endif;
		layerFrame.theGraphic := null;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="layerFrame" type="CMUI_PointDrawingFrame" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
