    <JadeMethod name="validateMe" id="c8ad452a-ce6a-474d-b1d1-17d795039ff8">
        <source>validateMe();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 April 2018	jlgndl1	Initial creation	FS 37821

*/

vars

	existing : CM_InvoiceTypeExternalTax;
	realForCheck : CM_InvoiceTypeExternalTax;
	iter : Iterator;

begin

	if self.mySurchargesAndExemptions = null then
		app.raiseCMException(Current_surcharge_exemptions, null, null);
		return;
	endif;
	
	if self.rangeStart &lt; 0 then
		app.raiseCMException(XXX_less_than_zero, null, null);
		return;
	endif;
	
	if self.rangeEnd &lt;= 0 then
		app.raiseCMException(Range_not_zero, null, null);
	elseif self.rangeEnd &gt; CM_InvoiceTypeSurchargeExempt.HighValue_15_2 then	//24 Apr 2018	NDL	TFS 37819 rework, and again 24 Jul 2019	NDL TFS 45509
		app.raiseCMException2(ERR_LOWER_GT_UPPER, app.getErrorString(RangeEnd), CM_InvoiceTypeSurchargeExempt.HighValue_15_2.asStringJMT, null, null); 
	endif;
	
	if self.rangeEnd &lt; self.rangeStart then	
		app.raiseCMException(Range_not_less_than_range_star, null, null);
	endif;
	
	if self.externalTaxCode.trimBlanks = null then
		app.raiseCMException(Externa_code_not_empty, null, null);
		return;
	endif;
	
	if self.myDebtor = null then
		app.raiseCMException(INV_Please_Select_A_Debtor, null, null);
		return;
	endif;
	
	if self.isTransient then
		realForCheck := self.pxyGetRealObject();
	else
		realForCheck := self;
	endif;
	
	existing := self.mySurchargesAndExemptions.allInvTypeExternalTax.getAtKey( self.myDebtor, self.rangeStart );
	if existing = null or existing = realForCheck then
		//we can carry on.
	else
		//This key is already used.
		app.raiseCMException(Surch_rate_alrea_exist_this_de, null, null);
		return;
	endif;
	
	iter := self.mySurchargesAndExemptions.allInvTypeExternalTax.createIterator;
	while iter.next( existing ) do
		if existing.myDebtor &lt;&gt; self.myDebtor then
			continue;
		endif;
		if existing = realForCheck then
			continue;
		endif;
		if existing = self then
			continue;
		endif;
		if existing.isValueWithinRange( self.rangeStart) then
 		// write "rangeStart of self is within range of existing ";
			app.raiseCMException(YAM_Msg_OverlapingRanges, null, null);
		endif;
		if existing.isValueWithinRange( self.rangeEnd) then
		//	write "rangeEnd of self is within range of existing ";
			app.raiseCMException(YAM_Msg_OverlapingRanges, null, null);
		endif;
		if self.isValueWithinRange( existing.rangeStart) then
		//	write "rangeStart of existing is within range of self ";
			app.raiseCMException(YAM_Msg_OverlapingRanges, null, null);
		endif;
		if self.isValueWithinRange( existing.rangeEnd) then
		//	write "rangeEnd of existing is within range of self ";
			app.raiseCMException(YAM_Msg_OverlapingRanges, null, null);
		endif;
	endwhile; 

epilog

	delete iter;

end;</source>
    </JadeMethod>
