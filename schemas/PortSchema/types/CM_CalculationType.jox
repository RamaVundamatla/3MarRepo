    <JadeMethod name="isQuantityBased" id="f51a86dd-9af3-4fae-9e3f-7f726168a439">
        <source>isQuantityBased() : Boolean;
/*
Purpose:			

Date		Who		Reason
27JAN2023	NAVAB1	CR 55624 TASK 55700 
*/
vars
	result	: Boolean;
begin
	if self.calculationType = INV_CALC_TYPE_QUANTITY or
	   self.calculationType = INV_CALC_TYPE_WO_CARGOQUANTITY or
	   self.calculationType = INV_CALC_TYPE_INVENT_QUANTITY 
		 // ### JIRA 35638 06AUG2025 NAVAB1 added in other quantity  based calc types. For cash, only the cargo ones matter but as a general method it has all invoicing types
		or self.calculationType = INV_CALC_TYPE_RESOURCE_QTY
		or self.calculationType = INV_CALC_TYPE_TRANSQUANTITY
		or self.calculationType = INV_CALC_TYPE_WO_RES_QTYQTY
		or self.calculationType = INV_CALC_TYPE_QUANTITY_ONBOARD then //jlier1 TFS 63956 20/5/24
		result := true;
	endif;

	return result;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStandardBOL" id="2840ab65-e47f-4208-b790-40e8e8ad15e7">
        <source>isStandardBOL():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 October 2019	jlgndl1	Initial creation	TFS 47100

*/

constants
	PREFIX = "BOL";
vars
	
begin
	
	if self.isBolCalcType then
	
		if self.code = (PREFIX &amp; INV_CALC_TYPE_BOL_NUMITEMS.String)
		or  self.code = (PREFIX &amp; INV_CALC_TYPE_BOL_VALUEOF1.String)
		or  self.code = (PREFIX &amp; INV_CALC_TYPE_BOL_VOLUME.String)
		or  self.code = (PREFIX &amp; INV_CALC_TYPE_BOL_WEIGHT.String) then
			return true;
		endif;
	endif;
	
	return false;

end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStandardCargo" id="c2b75558-1c34-461e-94ab-0db3fdfac211">
        <source>isStandardCargo() : Boolean;
// return true if a cargo type and code starting with 'CCT'
vars
	
begin
	if self.isCargoCalcType // TFS 39198
	and self.code.length &gt; 3 
	and self.code[1:3] = "CCT" then
		return true;
	else
		return false;
	endif;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStandardEvent" id="ce9a90c3-ad14-405d-b36e-f0f89994b075">
        <source>isStandardEvent() : Boolean;
// return true if a event type and code starting with 'ECT'
// 23/08/2022	jlika1		TFS 54897 MTN - Days being charged is incorrect
constants
	PREFIX = "ECT";
vars
	
begin
	if self.isEventCalcType then // TFS 39198
	
		if self.code = (PREFIX &amp; INV_CALC_TYPE_EVENT_GRT.String)
		or  self.code = (PREFIX &amp; INV_CALC_TYPE_EVENT_LENGTH.String)
		or  self.code = (PREFIX &amp; INV_CALC_TYPE_EVENT_TIME_DAYS.String)
		or  self.code = (PREFIX &amp; INV_CALC_TYPE_EVENT_TIME_HOURS.String)
		or  self.code = (PREFIX &amp; INV_CALC_TYPE_EVENT_TIME_MINUT.String)
		or  self.code = (PREFIX &amp; INV_CALC_TYPE_EVENT_UNIT.String)
		or  self.code = (PREFIX &amp; INV_CALC_TYPE_EVENT_DAYS_FULL.String) then
			return true;
		endif;
	endif;
	
	return false;

end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
