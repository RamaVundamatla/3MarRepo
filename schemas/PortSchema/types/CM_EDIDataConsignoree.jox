    <JadeMethod name="verifyEDIDataTIs" id="f7684fb7-91dd-450d-9851-443ed53b7a2a">
        <updating/>
        <source>verifyEDIDataTIs( _passport : CM_Passport input ) : Integer updating;

/*
Purpose:	To verify the EDI Data loaded.

Changes

Date		Name	TFS#		Description
============================================================================
19 Feb 2010	cnwrl1	Initial creation as part of PAR 21735 = CCMS 1068 (CR005) - EDI file load of Consignor/Consignee
13 May 2016	cnwns1	TFS 488 	Multi Timezone Support
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
============================================================================*/
vars
	partsDone			: Integer;
	partsInJob			: Integer;
	progressStr			: String;
	progressTS			: TimeStamp;
	ediTI 				: CM_EDITrackedItem;
	passport			: CM_Passport;
	terminal			: CM_Terminal;
	allAddConsignorees	: CM_ConsignArray;
	allUpdConsignorees	: CM_ConsignArray;
	allDelConsignorees	: CM_ConsignArray;
	pxyConsignObj		: CM_ConsigneeConsignor;
	realConsignObj		: CM_ConsigneeConsignor;
	ediConsignTI		: CM_EDIConsignoreeTI;
	
begin
	// Arm our base exception handlers.9
	on Exception do validationExceptionHandler(exception, _passport);
	app.setContinueCMExceptions(true);	// get as many error messages in 1 go as possible
	
	passport	:= _passport;
	partsInJob	:= self.allEDITrackedItems.size();
	partsDone	:= null;
	terminal	:= self.getMyTerminal();
	
	if terminal = null then
		// should never happen but just in case!
		app.raiseCMException1(Err_InvalidTerminal, null, null, null);
		return passport.allErrorWarnings.size();
	endif;
	
	progressStr	:= app.getString(Verifying_Loaded_Details, partsInJob.display());
	progressTS	:= app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	self.updateProgress(progressTS, progressStr, partsDone, partsDone, true, passport);
	
	create allAddConsignorees transient;
	create allUpdConsignorees transient;
	create allDelConsignorees transient;
	
	foreach ediTI in self.allEDITrackedItems do
		partsDone			:= partsDone + 1;
		self.updateProgress(progressTS, progressStr, partsDone, partsDone, false, passport);
		
		// Now validate each ediTrackedItem.
		//self.zValidateEdiData(ediTI.CM_EDIConsignoreeTI, passport);
		
		ediConsignTI	:=	ediTI.CM_EDIConsignoreeTI;
		realConsignObj	:=	app.myRoot.allConsigneeConsignors[ediConsignTI.code];
		
		if realConsignObj = null then
			if ediTI.messageMode = CM_EDITrackedItem.EDI_ACTION_DELETE then
				continue;
			endif;
			
			create pxyConsignObj transient;
			ediConsignTI.setProxyFromEDI(pxyConsignObj);
			allAddConsignorees.add(pxyConsignObj);
		else
			if ediTI.messageMode = CM_EDITrackedItem.EDI_ACTION_DELETE then
				allDelConsignorees.add(realConsignObj);
			else
				pxyConsignObj	:=	app.createUpdateProxy(realConsignObj).CM_ConsigneeConsignor;
				allUpdConsignorees.add(pxyConsignObj);
			endif;
		endif;
	endforeach;
	
	if not passport.hasErrors then
		self.validateConsigns(allAddConsignorees, allUpdConsignorees, allDelConsignorees);
	endif;
	
	self.updateProgress(progressTS, progressStr, partsDone, partsDone, true, passport);
	
	return passport.allErrorWarnings.size();
epilog
	allAddConsignorees.purge();
	allUpdConsignorees.purge();
	
	delete allAddConsignorees;
	delete allUpdConsignorees;
	delete allDelConsignorees;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="zLoadDB" id="6e3f84a1-e226-47b4-9007-3362ebea2fb5">
        <source>zLoadDB(_ediConsignoreeTI:CM_EDIConsignoreeTI input;
		_passport:CM_Passport input) protected;

//	******* THIS METHOD IS NO LONGER USED ("Z" METHODS SHOULDN'T BE IMPLEMENTED ANYWAY!!).

/*
Date				Who		Reason
22 February 2010	cnwrl1	Initial creation as part of PAR 21735 = CCMS 1068 (CR005) - EDI file load of Consignor/Consignee
*/
	
vars
	ediConsignoreeTI		: CM_EDIConsignoreeTI;
	realConsigneeConsignor	: CM_ConsigneeConsignor;
	proxyConsigneeConsignor	: CM_ConsigneeConsignor;
	newConsigneeConsignor	: CM_ConsigneeConsignor;
	
begin
	ediConsignoreeTI	:= _ediConsignoreeTI;		// to reduce dereferencing set a local variable
	
	// establish if the details already exist.
	realConsigneeConsignor	:= app.myRoot.allConsigneeConsignors[ediConsignoreeTI.code];
	
	if realConsigneeConsignor = null then
		create proxyConsigneeConsignor transient;
		ediConsignoreeTI.setProxyFromEDI(proxyConsigneeConsignor);
		app.myTrxCA.trxCreateConsigneeConsignor(proxyConsigneeConsignor, newConsigneeConsignor, _passport);
	else
		proxyConsigneeConsignor	:= app.createUpdateProxy(realConsigneeConsignor).CM_ConsigneeConsignor;
		ediConsignoreeTI.setProxyFromEDI(proxyConsigneeConsignor);
		app.myTrxUA.trxUpdateConsigneeConsignor(proxyConsigneeConsignor, _passport);
	endif;
epilog
	delete proxyConsigneeConsignor;
end;</source>
        <access>protected</access>
        <Parameter name="_ediConsignoreeTI" type="CM_EDIConsignoreeTI" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
