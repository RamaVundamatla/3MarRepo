    <JadeMethod name="getInvoiceLines" id="c9cb1d5a-009a-4ae2-aa7f-ba7d2d749cf9">
        <source>getInvoiceLines(_theInvLines : CM_InvoiceLineBySeqNumDict input) ;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	anObject : Object;
begin
	// ### TFS 55751 06DEC2022 NAVAB1 - this screen shows cash payments as well as invoice lines
	foreach anObject in self.tblData.allSelectedObjects do
		if CM_InvoiceLine.hasInstance(anObject) then
			_theInvLines.add(anObject.CM_InvoiceLine);
		endif;
	endforeach;

 // ### TFS 55751 06DEC2022 NAVAB1	self.tblData.allSelectedObjects.copy(_theInvLines);

end;</source>
        <Parameter name="_theInvLines" type="CM_InvoiceLineBySeqNumDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getMyTrackedItem" id="71915bd7-62ba-49a8-a3c5-b2192a42cf0a">
        <source>getMyTrackedItem(	_id: String;
					_cargoType: CM_CargoType;
					_operator: CM_Operator;	//12 Dec 2019	NDL	TFS 47954
					_location: CM_LocationsController	//12 Dec 2019	NDL	TFS 47954
					): CM_TrackedItem protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
24 September 2019	jlgzm1	Initial creation TFS 46054 STWO Adding Extra Details to Manual Invoice Lines

*/

vars
	ti, tmpTi		: CM_TrackedItem;
	tiSet 			: CM_TISet;
	cargotTypeId 	: Integer;
	iter : Iterator;
begin
	// searches onhship, onsite, offsite collections
	ti := inheritMethod(_id, _cargoType, _operator, _location);
	
	// if nothing found search notified
	if ti = null then
	/*	create tiSet transient;
		if _cargoType &lt;&gt; null then
			cargotTypeId := _cargoType.id;
		endif;
		self.myTerminal.lookupAllNotifiedOnsiteTIs(cargotTypeId, _id, tiSet, false, null);
		
		// tiSet can get matches for partial id, only want an exact match
		foreach tmpTi in tiSet do
			if tmpTi.id = _id then
				return tmpTi;
			endif;
		endforeach; */
		if _location = null then
			iter := self.myTerminal.allNotifiedTIsByIdCargoType.createIterator;
			while iter.next( tmpTi ) do
				if tmpTi.id &lt;&gt; _id then
					break;
				endif;
				if _cargoType &lt;&gt; null and tmpTi.myCargoType &lt;&gt; _cargoType then
					break;
				endif;
				if _operator &lt;&gt; null and tmpTi.myOperator &lt;&gt; _operator then
					continue;
				endif;	
				return tmpTi;
			endwhile;
		endif;
	endif;
	
	return ti;

epilog
	delete tiSet;
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_location" type="CM_LocationsController"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getStatusGood" id="1e978b0c-e51d-4982-8bbc-1acfd9a06e3c">
        <source>getStatusGood() : Boolean;
// ---------------------------------------------------------------------------
// Created:		05 July 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	inv : CM_Invoice;

begin
	if self.myCurrentInvoiceLine &lt;&gt; null then
		inv := self.myCurrentInvoiceLine.invoice;
	elseif self.myCurrentCashPayment &lt;&gt; null then
		inv := self.myCurrentCashPayment.myInvoice;
	endif;
	
	if inv = null then
		inv := self.myCurrentInvoice;
	endif;
	
	if inv = null then
		return false;
	endif;
	
//	if inv.status = CM_Invoice.INVOICE_POSTED
	if inv.isPostedOrReversal	//04 Sep 2017	NDL	TFS 6759
	or inv.isVoided
	then
		return false;
	endif;
	
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="47d75394-1dc2-47d2-86b2-b8fdb419e818">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Sep 2023 navhl20 ChangeRequest 59376: CPL - Invoice Generation Clocking (avg 25 secs)

*/

vars
	theXML : String;
begin
	theXML := inheritMethod();
	theXML := theXML &amp; global.formatAsXML(self.btnIncludeArchive.name, self.btnIncludeArchive.value.String);
	return theXML;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="7e7e6058-8eba-41e9-bf68-ca0a246790b4">
        <source>getXMLSettingsForSetup();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Sep 2023 navhl20 ChangeRequest 59376: CPL - Invoice Generation Clocking (avg 25 secs)

*/

vars
	userWindow		: CM_UserWindow;
	theXML, 
	theXMLValue 	: String;
begin
	userWindow := app.getUserWindow(self.name, false);
	
	if userWindow = null then
		return;
	endif;
	theXML := userWindow.xmlInfo;

	theXMLValue := theXML.cnEcGetTagValueOfName(self.btnIncludeArchive.name);
	self.btnIncludeArchive.value := theXMLValue &lt;&gt; null and theXMLValue.Boolean;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="includeLine" id="834df7cc-b88d-4203-a686-d0b4928a92c7">
        <source>includeLine(_invLine : CM_InvoiceLine) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 April 2023  navmv20 TFS 55304 Task 55544: Jade - Invoice Line Copy Audits
*/

vars
	debtor : CM_Debtor;
	invLineType : CM_InvoiceLineDesc;
	bol : CM_BOL;
begin
	if _invLine = null then
		return false;
	endif;

	debtor := self.cmbDebtor.listObject.CM_Debtor;
	if debtor &lt;&gt; null 
	and _invLine.debtor &lt;&gt; debtor then
		return false;
	endif;
	
	invLineType := self.cmbInvLineTypeQu.listObject.CM_InvoiceLineDesc;
	if invLineType &lt;&gt; null
	and _invLine.invoiceLineDesc &lt;&gt; invLineType then
		return false;
	endif;
	
	bol := self.cmbBOL.listObject.CM_BOL;
	if bol &lt;&gt; null
	and _invLine.myTransactionBOL &lt;&gt; null
	and _invLine.myTransactionBOL.myBOL &lt;&gt; null
	and _invLine.myTransactionBOL.myBOL &lt;&gt; bol then
		return false;
	endif;
	
	if self.myCurrentInvoice &lt;&gt; null then
		if _invLine.invoice &lt;&gt; self.myCurrentInvoice then
			return false;
		endif;
	endif;
	
	
	return true;
epilog

end;</source>
        <Parameter name="_invLine" type="CM_InvoiceLine"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initInvPropTable" id="3ca5fadf-a5f1-45ad-961c-79c0ae4fabd0">
        <source>initInvPropTable(_enTableDef : String);
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 25 Jan 2021 cnwma1 Bug 50665: ASPA - Separation of a list of cargo items by terminal
// ---------------------------------------------------------------------------

vars
	cargoTypeCol   : CM_CargoTypeSet;
begin
	//epr par 36958 28/9/15
	inheritMethod(_enTableDef);
	if self.cmbCargoTypeInvP.listCount &lt;= 1 then
		//self.cmbCargoTypeInvP.listCollection( app.myRoot.allCargoTypesById, false, 0);  //25.01.2021 cnwma1 #50665	
		create cargoTypeCol transient;                                                    //25.01.2021 cnwma1 #50665
		self.myTerminal.getAllCargoTypes(cargoTypeCol,true);
		self.cmbCargoTypeInvP.listCollection( cargoTypeCol, false, 0); 
	endif;
	
	self.populateCargoOperLocns();		//13 Dec 2019	NDL	TFS 47954
	
	// ### TFS BUG 64249 23MAY2024 NAVAB1
	if app.doNotFIlterCombos then
		self.cmbCargoVoyage_.style := ComboBox.Style_DropDownList; 
	endif;
epilog
	delete cargoTypeCol;
end;</source>
        <Parameter name="_enTableDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="initQueryFrame" id="aac12bd9-14cf-48e0-a6b5-11bfbe9dab22">
        <updating/>
        <source>initQueryFrame() updating, protected;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 29 Mar 2023	navmv20 Bug 57023: EUP - inconsistent search behaviour with external number

vars
	sht			: CMUI_Sheet;
begin
	inheritMethod();
	
	sht := self.shtQuery1;
	sht.caption := app.getErrorString(INV_Invoice_List);
	
	self.setQueryControl(self.lblCargoID_);
	self.setQueryControl(self.cmbInvLineTypeQu); // PAR 34469
	self.setQueryControl(self.lblInvLineTypeQu); // PAR 34469
	self.setQueryControl(self.cmbCargoID_);
	self.setQueryControl(self.lblCargoSite_);
	self.setQueryControl(self.lblCargoType_);
	self.setQueryControl(self.cmbCargoSite_);
	self.setQueryControl(self.cmbCargoType_);
	self.setQueryControl(self.cmbCargoVoyage_);
	self.setQueryControl(self.lblCargoVoyage_);
	
	//self.optExternal.visible := false;	//15 Apr 2016	NDL	TFS 1849 //29/03/2023 navmv20 Bug 57023

	sht.visible := true;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initTableData" id="12cbf8b1-725e-48f5-9de5-c20a4f0e49ee">
        <updating/>
        <source>initTableData(_theEntDef: String) updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.tblData.setForm(self); // ### TFS BUG 64017 07MAY2024 NAVAB1;

	inheritMethod(_theEntDef);

//	self.tblData.readOnly := true; // this was stopping the arrow keys from working!!!


	self.tblData.multiSelect := CM_BaseTable.MultiSelect_Simple;
	self.tblData.fixedColumns := 1;
	self.tblData.accessColumn(1).backColor := self.colorHeadingColumn;

end;</source>
        <Parameter name="_theEntDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="initTableDataWithView" id="6d34ad09-b123-484a-ac01-9ba4fb690049">
        <source>initTableDataWithView(_view : String);
/*
Purpose:			

Date		Who		Reason
22 April 2024	navab1	CR 63369 TASK 63371 
10 Sep 2025		navbs1 	Bug 35962: MTN | Invoice Lines Form displaying empty rows when rows are added from Selector form
*/

vars
	entTableView	: EntTableView;
	entTableDef		: EntTableDef;
	theTable		: CM_DataTable;
	emptyPlaceHolder : CM_TIArray;
begin
	theTable := self.tblData;
	
	theTable.userInputEnabled := false;
	theTable.selectMode := CM_EntryTable.SelectMode_FixedRow;
	theTable.selectionType := CM_EntryTable.SelectionType_Row;
	theTable.rows := theTable.fixedRows;
	theTable.cnEcResizeContents();
	
	entTableDef := app.myController.getEntTableDef(ETDef_InvListDataTableLines);
	if entTableDef &lt;&gt; null then
		self.tblData.setForm(self); // ### TFS BUG 64017 07MAY2024 NAVAB1;
		self.tblData.setTblDataEntRowsFromView(entTableDef,_view);
	endif;
	
	theTable.readOnly := false;	
	theTable.fixedColumns := 0;
	theTable.show3D := Table.Show3D_Not3D;

	self.tblData.multiSelect := CM_BaseTable.MultiSelect_Simple;
	self.tblData.fixedColumns := 1;
	self.tblData.accessColumn(1).backColor := self.colorHeadingColumn;
	
	// doing this to make tblData enabled for pagination by opening form
	if app.myRoot.isPaginated then		 												//10.09.2025 navbs1 #35962
		create emptyPlaceHolder transient;
		self.tblData.getDataAndDisplayRowsPaginat(Table.DisplayCollection_Forward, null, emptyPlaceHolder, true);
	endif;

epilog
	delete emptyPlaceHolder;			//10.09.2025 navbs1 #35962
end;</source>
        <Parameter name="_view" type="String"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="42420b57-bdf0-487c-8472-cd5f78b374fd">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
//29 Mar 2023	navmv20 Bug 57023: EUP - inconsistent search behaviour with external number
//12 April 2023  navmv20 TFS 55304 Task 55544: Jade - Invoice Line Copy Audits
//11 Sep 2023 	navhl20 ChangeRequest 59376: CPL - Invoice Generation Clocking (avg 25 secs)
vars
	bank : CM_Bank;
	mode	: Integer; //15/05/2025	navkc1 JIRA EPIC-34131 STORY-34820
begin
	if self.myCurrentInvoice &lt;&gt; null 
	or self.myCurrentInvoiceLine &lt;&gt; null
	or self.myCurrentCashPayment &lt;&gt; null then	
		self.frmQuery.visible := false;
	endif;
	// 35872 
	if self.myCurrentInvoice &lt;&gt; null then
		bank := self.myCurrentInvoice.bank;	//12/04/2023 navmv20 TFS 55304 Task 55544
	elseif self.myCurrentInvoiceLine &lt;&gt; null then
		bank := self.myCurrentInvoiceLine.bank;	//12/04/2023 navmv20 TFS 55304 Task 55544
	elseif self.myCurrentCashPayment &lt;&gt; null then
		bank := self.myCurrentCashPayment.getBank();	//12/04/2023 navmv20 TFS 55304 Task 55544
	endif;
	if bank = null then
		bank := self.myTerminal.getDefaultCompanyBank();	//12/04/2023 navmv20 TFS 55304 Task 55544
	endif;
	
	self.setBank(bank);		//12/04/2023 navmv20 TFS 55304 Task 55544
	
	self.useTableSorting := true;
	self.setNavigatorHeading(self.caption);
	
	self.setCaption(app.getErrorString(INV_Invoice_Lines_List) &amp; " " &amp; self.myCurrentBank.code); // 	TFS 2682  // ### TFS BUG 57729 28APR2023 NAVAB1 'Invoice Lines List' was 'Invoice List'

	// ### TFS CR 62992 TASK 62994 21MAR2024 NAVAB1self.initTableData(ETDef_InvListDataTableLines);
	
	// ### TFS CR 62992 TASK 62994 21MAR2024 NAVAB1 - EUP have their own columns that include static (not derived) values for amounts and tax details
	if app.isSpecial then
		//if app.msgBox("Do you want to run with Euroports Columns?", "Question",MsgBox_Yes_No) = MsgBox_Return_Yes then
		mode := app.msgBoxCustom("Which Columns mode do you want to run with?", "Question", MsgBoxCustom_Icon_Question_Mark  + MsgBoxCustom_Default_Third, "EUP", "GHANA", "MTN Default");
		if mode = MsgBoxCustom_Return_One then
			self.initTableDataWithView(ETView_InvListInvLineEUP);
		elseif mode = MsgBoxCustom_Return_Two then
			self.initTableDataWithView(ETView_LinesGPHA); //15/05/2025	navkc1 JIRA EPIC-34131 STORY-34820
		else
			self.initTableDataWithView(ETView_InvListInvLineDefault);
		endif;
		
	else
		if app.myRoot.isClientEuroPorts() then
			self.initTableDataWithView(ETView_InvListInvLineEUP);
		elseif app.myRoot.isClientGhana() then //15/05/2025	navkc1 JIRA EPIC-34131 STORY-34820
			self.initTableDataWithView(ETView_LinesGPHA);
		else
			self.initTableDataWithView(ETView_InvListInvLineDefault);
		endif;
	endif;

	self.initInvPropTable(ETDef_InvListInvLineProperties);
	
	self.initRateTable(); // PAR 10224
	
	self.cmbCargoID_.style:=ComboBox.Style_DropDownComboList;
	self.btnQueryDebtor.myToolbarButton.drawButtonDown();
	//self.chkArchive.value := false;							//11.9.2023 navhl20 #59376
	self.doCmbInvoiceStatusBuild();
	self.doCmbCargoSiteBuild();
	self.doCmbInvoiceTypeBuild(self.cmbInvTypeInv, false);
	self.doCmbInvoiceTypeBuild(self.cmbInvoiceType, true);
	self.doCmbTermsTradeBuild();
	self.doCmbConsigneeBuild();		// 30931
	self.doCmbBankBuild(self.cmbBank);
	self.doCmbInvoiceLineTypeBuild();
	self.doCmbSearchFor(self.cmbSearchFor); //29/03/2023 navmv20 Bug 57023
	
	self.doCmbDebtorBuild(self.cmbDebtor);
	self.doCmbDebtorBuild(self.cmbDebtorInvProp);
	self.myAssistant.comboBoxInvoiceStatusReason(self.cmbReasonCode); //epr par  36958 29/9/15
	
	self.btnQueryDebtor.value:=true;
	self.setQuery();
	
	self.btnPrint.bubbleHelp := app.getErrorString(INV_Print_Detail);

	
	self.myAssistant.comboBoxCargoTypes(self.cmbCargoType_, app.myPassport.getDefaultCargoType());

	if self.allInvoiceLines.size &gt; 0 then		// par 21800 show invoice lines from snapshot summary
		self.populateInvoiceTable(false);
	elseif self.myCurrentInvoice &lt;&gt; null then	
		self.frmQuery.visible := false;
		// set the controls to get query for this one invoice
		self.textSearch.text := self.myCurrentInvoice.sequenceNum.String;
		//29/03/2023 navmv20 Bug 57023 - START
		//self.optSearchInvoice.value := true;
		self.cmbSearchFor.listIndex := self.cmbSearchFor.findStringExact(1,app.getErrorString(Invoice_invoice_number));
		self.textSearch.dataType := TextBox.DataType_Numeric;
		self.textSearch.maxLength := 9;
		//29/03/2023 navmv20 Bug 57023 - END
		self.btnQueryInvoice.value := true;
		self.doQuery();  // resets frmQuery.visible value
		if (self.tblData.rows = self.tblData.fixedRows) then // PAR 10141 - if no invoice lines found for the invoice 
			self.frmQuery.visible := false; 				// that the screen was opened from then dont show searcher
		endif;
	elseif self.myCurrentInvoiceLine &lt;&gt; null then	
		self.frmQuery.visible := false;
		self.textSearch.text := self.myCurrentInvoiceLine.sequenceNum.String;
		 //29/03/2023 navmv20 Bug 57023 - START
		//self.optSearchLine.value := true;
		self.cmbSearchFor.listIndex := self.cmbSearchFor.findStringExact(1,app.getErrorString(Invoice_line_number));
		self.textSearch.dataType := TextBox.DataType_Numeric;
		self.textSearch.maxLength := 9;
		 //29/03/2023 navmv20 Bug 57023 - END
		self.btnQueryInvoice.value := true;		// 37247 to make sure it does an invoice line search
		self.doQuery();
	elseif self.myCurrentCashPayment &lt;&gt; null then		// 33437 show cash payments from cargo transaction Charges
		self.frmQuery.visible := false;
		self.allCashPayments.add(self.myCurrentCashPayment);
		self.populateInvoiceTable(false);
	elseif self.myCurrentDebtor &lt;&gt; null then
		self.frmQuery.visible := false;
		self.cmbDebtor.listObject := self.myCurrentDebtor;
		self.doQuery();
	endif;
	self.mnuContextTable.visible := true;
	self.mnuContextTable.caption := app.getErrorString(INV_Invoice_Lines_List);
	self.mnuInvPending.caption := app.getErrorString(INV_Change_Status_Normal); // ### JIRA 35468 31JUL2025 NAVAB1
	self.mnuInvLines.caption := app.getErrorString(INV_Invoice);
	self.mnuOOWShowBay.translateCaption(Xlat_0013523, app.myCurrentLocale);
	self.setContextMenus();
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateInvLinesCollection" id="bcf6f0dc-c515-4b15-993c-5de01ce61a39">
        <source>populateInvLinesCollection(_invoiceLines : CM_InvoiceLineBySeqNumDict);
/*

Purpose:			No references but this is used in 
						UiCommonSchema::CMUI_OwnershipChangeEnquiry::doBtnInvoiceIssueClick
						UiCommonSchema::CMUI_OwnershipChangeMaint::doBtnInvoiceIssueClick

Parameters:			

Return Value:		

Date		Who		Reason
08/12/2023	navkc1 ChangeRequest 58261 Task 58260: Jade - COO Invoice Issues Send Email

*/

vars

begin
	_invoiceLines.copy(self.allInvoiceLines);
epilog

end;</source>
        <Parameter name="_invoiceLines" type="CM_InvoiceLineBySeqNumDict"/>
    </JadeMethod>
    <JadeMethod name="populateInvoiceTable" id="8355a449-6971-4d1e-a15e-91a213c62fd1">
        <updating/>
        <source>populateInvoiceTable(_showProgressForm : Boolean) updating;
// Oct 2010 moved out of doQuery for par 21800 to allow calling this form with
//	self.allInvoiceLines pre-populated with invoice lines for a given snapshot summary data.
//
// Changed On	By			Reason
// ----------	--------	----------------------------------------------------------
// 04/04/2016	cnwdap1		PAR #35843 Make progress monitoring properly time-based
//02 Feb 2025	navrv30 JIRA 33828 MTN - When using multi-threading form showing two progress bars
//29 Jul 2025	navbs1	Story MTN-35314: MTN | Pagination - Invoice Line List
//09 Sep 2025	navbs1 	Bug 35962: MTN | Invoice Lines Form displaying empty rows when rows are added from Selector form
constants
	Max_Rows = 5000;
	DefaultHeight = 145;
	DefaultWidth = 345;
vars
	invName : String;
	invLine:       CM_InvoiceLine;
	payment		: CM_CashPayment;
	selectedRow, idx :             Integer;
	theTable:           Table;
	pd:               CMS_Progress;
	progressTime,
	newTime		: Integer;
	itemsToShow	: Integer;
	form : CM_BaseForm;
	isFirstActivatedComplete : Boolean;
	objArray 				 : ObjectArray;
begin

	on CM_ProgressException do haltProgress(exception);
	
	self.mousePointer := Window.MousePointer_HourGlass;

	self.myCurrentInvoiceLine := null;
	self.tblInfo.rows := 0;			// clear the info table of details from prior selections
	
	theTable := self.tblData;
	//self.doQueryRemoveItem();																		//04.08.2025 navbs1 #35314
	theTable.CM_DataTable.clearAllData();
	
	//theTable.rows := theTable.fixedRows;															//29.07.2025 navbs1 #35314
	
	//theTable.clearAllSelected();
	//theTable.allSelectedRows.clear;																//31.07.2025 navbs1 #35314
	
	selectedRow := 0;
	//theTable.rows := 1;																			//29.07.2025 navbs1 #35314
	create objArray transient;																		//31.07.2025 navbs1 #35314
	objArray.addAll(self.allInvoiceLines);															//31.07.2025 navbs1 #35314
	objArray.addAll(self.allCashPayments);															//31.07.2025 navbs1 #35314
	
	itemsToShow := self.allInvoiceLines.size + self.allCashPayments.size;
	//epr TFS 2067 12/7/16
	if not self.tblData.isPaginated and  not self.doMaxTableSizeCheck(itemsToShow, null) then		//04.08.2025 navbs1 #35314		//09.09.2025 navbs1 #35962
		return;
	endif;
	//JIRA 33828
	/*if _showProgressForm then
		create pd;
		pd.setBackground(self.backColor);
		pd.show;
		pd.setAction("Loading Invoices...");
		pd.progress.partsInJob := itemsToShow.min(JadeTableRowLimit);
		invName := caption &amp; ", " &amp; pd.progress.partsInJob.String &amp; " items.";
		pd.setAction(invName);
	endif;*/
	
	progressTime := app.clock;

	//navra1 - TFS 63751/Task 63752 - 13th May 2024	- start
	
	
	form := self;	
	//02 Feb 2025	navrv30 JIRA 33828
	isFirstActivatedComplete := self.isFirstActivateComplete;
	self.isFirstActivateComplete := true;		
	//self.tblData.getDataAndDisplayRowsMultith(self.allInvoiceLines, true, form, true);										//29.07.2025 navbs1 #35314
	self.tblData.getDataAndDisplayRowsPaginat(Table.DisplayCollection_Forward, null, objArray, true);							//29.07.2025 navbs1 #35314
	
	/*	
	foreach invLine in self.allInvoiceLines do		
		idx := idx + 1;		
		// change to use app.clock to speed up (PAR 20778)
		//if idx mod 50 = 0 then															// PAR #35843
			newTime := app.clock;
			//if newTime - progressTime &gt; 1000 then	// update every second					// PAR #35843
			if newTime - progressTime &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then		// PAR #35843
				progressTime := newTime;
				if _showProgressForm then
					pd.progress.partsDone := idx;
// ### TFS BUG 62926 13MAR2024 NAVAB1					pd.doWindowEvents(0);
					pd.txtDetails.text := "Invoice Line : " &amp; invLine.sequenceNum.String;
				endif;
			endif;
		//endif;																			// PAR #35843
		
		self.doQueryAddLine(invLine);	
		
		if self.tblData.rows = JadeTableRowLimit then
			break;
		endif;
	endforeach;	
	*/
	
	/*if self.tblData.rows &lt;&gt; JadeTableRowLimit then
		foreach payment in self.allCashPayments do
			self.doQueryAddPayment(payment);
			if self.tblData.rows = JadeTableRowLimit then
				break;
			endif;
		
		endforeach;
	endif;*/	
	
	/*if self.tblData.rows &lt;&gt; JadeTableRowLimit then																			//31.07.2025 navbs1 #35314
		self.tblData.getDataAndDisplayRowsMultith(self.allCashPayments, true, form, true);	
	endif;	*/
	
	self.clientHeight := clientHeight;
	self.clientWidth := clientWidth;
	//navra1 - TFS 63751/Task 63752 - 13th May 2024 - end

	self.frmQuery.visible := (self.tblData.rows = self.tblData.fixedRows);

	// set up the info table from the new entries
	if self.tblData.rows &gt; self.tblData.fixedRows then
		self.tblData.selectRow(2,false);
		self.tblData.row := 2;
		self.doTblDataRowColChange(self.tblData);
	endif;

epilog
	// 23340 reset status line selected count after query - done in epilog, and setMyCaption moved here, to keep both correct after cancel of query
	self.showSelectedCount(self.tblData.allSelectedObjects.size, self.tblData.rows-self.tblData.fixedRows);
	self.setMyCaption();
	self.isFirstActivateComplete := isFirstActivatedComplete;  //02 Feb 2025	navrv30 JIRA 33828
	//delete pd;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="_showProgressForm" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateSnapshotCollection" id="c0e1e59d-e0bc-45b5-856e-70c055534132">
        <source>populateSnapshotCollection(_coll :Collection input) protected;
// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1
vars
	obj	:Object;
begin
	foreach obj in self.myCurrentInvoiceLine.mySnapShotData.mySnapshotData.allSnapshotData do
		_coll.add(obj);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_coll" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="positionQueryFrame" id="1014325e-ca3c-434f-a127-1a5248df43da">
        <source>positionQueryFrame() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
// 24 Feb 2023	navmv20 TFS 56403 Task 56404: UI - Invoice List add Category
*/

vars

begin
	inheritMethod();
	self.frmQuery.height	:=	395;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="rowPostprocess" id="45665000-2951-4512-a48c-0f1fa1189e03">
        <updating/>
        <source>rowPostprocess(_dataTable: CM_DataTable io; _idx: Integer; _obj: Object) : Boolean updating;
/*

Purpose:			

Parameters:			
	
Return Value:		

Date		Who		Reason
13 May 2024	navra1	Initial creation - //navra1 - TFS 63751/Task 63752 - 13th May 2024
*/

vars
	invoiceLine : CM_InvoiceLine;
	colNumber	: Integer;
	cashPayment : CM_CashPayment;
	
begin
	
	if _dataTable.name = "tblData" then
		if _obj.isKindOf(CM_InvoiceLine) then
			invoiceLine := _obj.CM_InvoiceLine;		

			// setup note for this item
			self.doNotableAdd(invoiceLine);
			self.doNotableAdd(invoiceLine.invoice);
			
		elseif _obj.isKindOf(CM_CashPayment) then			
			cashPayment := _obj.CM_CashPayment;				
			self.doNotableAdd(cashPayment);			
		endif;
	endif;
	
	return true;
	
epilog

end;</source>
        <Parameter name="_dataTable" type="CM_DataTable" usage="io"/>
        <Parameter name="_idx" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="saveSelectedTrackedItems" id="22f9302d-8f92-4f9d-b0e4-d20197aa0304">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_CMUI_TrackedItems::saveSelectedTrackedItems"/>
        </interfaceImplements>
        <updating/>
        <source>saveSelectedTrackedItems(_allTIs : CM_TIArray) : Boolean updating;
/*

Purpose:			Called from INV_CargoSearchForm

Parameters:			

Return Value:		

Date				Who		Reason
24 September 2019	jlgzm1	Initial creation STWO Adding Extra Details to Manual Invoice Lines

*/

vars
	ti : CM_TrackedItem;
	currentTA : CM_TerminalArea;
begin

	if _allTIs = null then
		return true;
	endif;
	
	ti := _allTIs.first;
	
	if ti &lt;&gt; null then
		// Update "New Invoice Line" table with selected TI id and cargo type
		self.myCurrentTI := ti;
		self.myCurrentCargoType := ti.myCargoType;
		self.tblInvProperties.setValueByName( ETRow_CargoId, ti.id );
		self.cmbCargoTypeInvP.listObject := ti.myCargoType;
		self.tblInvProperties.setValueByName( ETRow_CargoType, ti.myCargoType.description );
		
		//13 Dec 2019	NDL	TFS 47954
		self.myCurrentTIOperator := ti.myOperator;	//13 Dec 2019	NDL	TFS 47954
		self.cmbCargoOper.listIndex := self.cmbCargoOper.findObject( self.myCurrentTIOperator );
		self.cmbCargoOper.lostFocus( self.cmbCargoOper );
		self.myCurrentTILocation := ti.myPrimaryActualLocation;
		
		//18 Dec 2019	NDL	TFS 47954
		if self.myCurrentTILocation = null then
			currentTA := null;
		elseif self.myCurrentTILocation.isMachineController then
			currentTA := self.myCurrentTILocation.CM_MachineController.getMyLastKnownTerminalArea;
		else
			currentTA := self.myCurrentTILocation.getMyTerminalArea;
		endif;
		
		if currentTA = null then
			self.cmbCargoTA.listIndex := -1;
		else
			self.cmbCargoTA.listIndex := self.cmbCargoTA.findObject( currentTA );
		endif;
		
		self.cmbCargoTA.lostFocus( self.cmbCargoTA );
		if self.cmbCargoTA.listIndex &gt;= 1 then
			self.cmbCargoLoc.listIndex := self.cmbCargoLoc.findObject( self.myCurrentTILocation );
			self.cmbCargoLoc.lostFocus( self.cmbCargoLoc );
		endif;
		
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_allTIs" type="CM_TIArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setBank" id="e79ddd4a-2022-45d7-a15e-c254d3ca731d">
        <updating/>
        <source>setBank(_bank : CM_Bank) updating;
/*
Purpose:			

Date		Who		Reason
//12 April 2023  navmv20 TFS 55304 Task 55544: Jade - Invoice Line Copy Audits
*/

vars

begin
	if self.myCurrentBank &lt;&gt; null then
		self.endNotificationForSubscriber(self.myCurrentBank);
	endif;
	
	self.myCurrentBank := _bank;
	
	if self.myCurrentBank &lt;&gt; null then
		self.beginNotification(self.myCurrentBank, self.myTerminal.getTerminalEvent(Event_InvoiceLineCreate), Response_Continuous, null); 
	endif;
epilog

end;</source>
        <Parameter name="_bank" type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="setContextMenus" id="386ed8b3-57ec-4685-aa0e-5f8cb8efea2d">
        <source>setContextMenus();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
					Created March 2004 By Andrew Bishop cnwab1
19 Nov 2019 cnwma1 Bug 47532: JMT - Invoice List Screen Fix for 47455 Has Created Inconsistencies on the Invoice Lines Screen

*/
vars
	
begin
	
	self.mnuContextSep01.visible 		:= true;
	self.mnuContextColourLegend.visible := false;
	self.mnuSendReportMain.visible 		:= true;
	self.mnuSendReportAll.visible 		:= true;
	self.mnuSendReportSelected.visible  := true;
	self.mnuSendReportSeparator.visible := true;
	self.mnuSendReportSelected.visible  := true;
	self.mnuOverrideExtRef.visible 		:= self.displayOverrideExtRef(); //08/12/2025	navkc1 JIRA 36262
	
	self.mnuInvAudits.visible           := false;
	/* TFS BUG 58789 26JUNE2023 NAVAB1	
	self.mnuInvAudits.caption  			:= "Audit Enquiry...";
	if self.myCurrentInvoiceLine &lt;&gt; null then
		self.mnuInvAudits.visible := self.myCurrentInvoiceLine.hasAudits;	//14 Jan 2021	NDL	TFS 50152
	elseif self.myCurrentCashPayment &lt;&gt; null then  
		self.mnuInvAudits.visible := self.myCurrentCashPayment.hasAudits;	//14 Jan 2021	NDL	TFS 50152
	endif;
	*/
	
	self.mnuAuditsForObject.visible := true; // TFS BUG 58789 26JUNE2023 NAVAB1		
	
	if self.myCurrentInvoiceLine &lt;&gt; null then
		if not self.myCurrentInvoiceLine.unqualifiedAudits.isEmpty or 
			   not self.myCurrentInvoiceLine.qualifiedAudits.isEmpty   then 
				self.mnuInvAudits.visible := true;
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setEnableObjects" id="b08089cc-ed5e-40e5-bce3-959bd1f5ff84">
        <source>setEnableObjects();
/*
 ---------------------------------------------------------------------------
Created:		November 2004 By Andrew Bishop cnwab1

Purpose:		
22/09/2015 	cnwma1  PAR #36506 Convert Invoice items Description  with Posted invoice
08/11/2015	cnwdap1 PAR #37149 Enable New button and menu even if no invoice line displayed
17/03/2017 	cnwma1 	TFS #3661:ADP - Invoice Management Permissions
19 Sep 2018	cnwma1	ChangeRequest 39698: PEL1 - SAP Enable SAP interfaces
12 Nov 2018	cnwma1	ChangeRequest 41945: PEL1 - SAP - Invoice changes restriction
12/07/2019 	JLGNS1	Bug 45557: GUQ - Voiding on Escalating Cash Receipts (Part2)
05 Aug 2019	jlgdi1	TFS 45301 Used CM_CashPayments.Status_Void instead of CM_InvoiceLine.STATUS_VOIDED
13 October 2022	navmv20  ChangeRequest 55005: EUP - Invoicing - Invoice Line TAX Maintenance
15 April 2023  navmv20 TFS 55304 Task 55545: UI - Invoice Line List Changes
08 Sep 2025 navbs1 Bug 35859:14051 exception when trying to search an invoice line using Voyage query
*/

vars
	canMaint ,			
	canNew ,					
	invoiceSelected ,	
	invoiceLineSelected ,
	cashPaymentSelected ,
	canReevaluate ,
	canVoid ,
	canNormal,
	canOverride ,
	canViewTrans ,
	canUpdateInv,
	canCopySameInvDiffCargo,			//15/04/2023 navmv20 TFS 55304 TASK 55545
	canCopyDiffInvDiffCargo,			//15/04/2023 navmv20 TFS 55304 TASK 55545
	canCopyDiffInvSameCargo  : Boolean;	//15/04/2023 navmv20 TFS 55304 TASK 55545
	currentInvLine           : CM_InvoiceLine;	//15/04/2023 navmv20 TFS 55304 TASK 55545
	obj : Object;
	inv : CM_Invoice;
	row : Integer;
begin
	
	invoiceLineSelected	:= self.myCurrentInvoiceLine &lt;&gt; null;
	invoiceSelected		:= self.myCurrentInvoice &lt;&gt; null;
	cashPaymentSelected := self.myCurrentCashPayment &lt;&gt; null;
	
	if invoiceSelected then //12.11.2018 cnwma1 TFS #41945									//Bug 45557
		canUpdateInv := self.myCurrentInvoice.canUpdate;									//Bug 45557
	elseif cashPaymentSelected then															//Bug 45557
		if self.myCurrentCashPayment.myInvoice &lt;&gt; null then //03 Jul 2019	NDL	TFS 45432	//Bug 45557
			canUpdateInv := self.myCurrentCashPayment.myInvoice.canUpdate;					//Bug 45557
		else																				//Bug 45557
			canUpdateInv :=  true;															//Bug 45557
		endif;																				//Bug 45557
	elseif invoiceLineSelected then															//Bug 45557
		if 	self.myCurrentInvoiceLine.invoice &lt;&gt; null then	//03 Jul 2019	NDL	TFS 45432	//Bug 45557
			canUpdateInv := self.myCurrentInvoiceLine.invoice.canUpdate;					//Bug 45557
		else																				//Bug 45557
			canUpdateInv :=  true;															//Bug 45557
		endif;																				//Bug 45557
	endif;																					//Bug 45557
	
	canMaint 		:= app.getMyUser().canDo(self.myTerminal,PmAdmInvoicelistMaint) and invoiceLineSelected ;
	canNew 			:= app.getMyUser().canDo(self.myTerminal,PmAdmInvoicelistMaint);							// PAR #37149
	canReevaluate   := app.getMyUser().canDo(self.myTerminal,PmAdmInvLineReEvaluate);   						// 17/03/2016 cnwma1 TFS #3661s
	canOverride 	:= app.getMyUser().canDo(self.myTerminal,PmAdmInvLineOverrideRate);   					    // 17/03/2016 cnwma1 TFS #3661s
	canVoid         := app.getMyUser().canDo(self.myTerminal,PmAdmInvoiceLineStatusVoid);                       //12.11.2018 cnwma1 TFS #41945
	canNormal       := app.getMyUser().canDo(self.myTerminal,PmAdmInvoiceLineStatusNormal);                     //12.11.2018 cnwma1 TFS #41945
	canViewTrans    := app.getMyUser().canDo(self.myTerminal, PmTiTransactionView);                             //12.11.2018 cnwma1 TFS #41945
	canCopyDiffInvDiffCargo		:= app.getMyUser().canDo(self.myTerminal, PmAdmDiffInvDiffCargoMaint); //15/04/2023 navmv20 TFS 55304 TASK 55545
	canCopyDiffInvSameCargo     := app.getMyUser().canDo(self.myTerminal, PmAdmDiffInvSameCargoMaint); //15/04/2023 navmv20 TFS 55304 TASK 55545
	canCopySameInvDiffCargo 	:= app.getMyUser().canDo(self.myTerminal, PmAdmSameInvDiffCargoMaint); //15/04/2023 navmv20 TFS 55304 TASK 55545
	
	//15/04/2023 navmv20 TFS 55304 TASK 55545 - START
	row := self.tblData.accessedRow.row;								//08.09.2025 navbs1  #35859  
	if row &gt; 1 and row &lt;= self.tblData.rows then 						//08.09.2025 navbs1  #35859
		obj := self.tblData.accessRow(row).itemObject;					//08.09.2025 navbs1  #35859
	endif;
	if obj.isKindOf(CM_InvoiceLine) then
		currentInvLine := obj.CM_InvoiceLine;
	endif;
	if self.tblData.allSelectedObjects.size() &gt; 0 then 
		self.mnuSameInvDiffCargo.enabled := true; 
		self.mnuNewInvDiffCargo.enabled := true;
		self.mnuNewInvSameCargo.enabled := true;
		self.mnuSameInvSameCargo.enabled := true;
	else
		self.mnuSameInvDiffCargo.enabled := false; 
		self.mnuNewInvDiffCargo.enabled := false;
		self.mnuNewInvSameCargo.enabled := false;
		self.mnuSameInvSameCargo.enabled := false;
	endif;
	
	if currentInvLine &lt;&gt; null and (currentInvLine.invoice.status = CM_Invoice.INVOICE_OPEN or  currentInvLine.invoice.status = CM_Invoice.INVOICE_PENDING) then
		if canCopySameInvDiffCargo and currentInvLine &lt;&gt; null then
			self.mnuSameInvDiffCargo.visible := true; 
		else
			self.mnuSameInvDiffCargo.visible := false;
		endif;
		
	endif;
	
	if canCopyDiffInvSameCargo and currentInvLine &lt;&gt; null then
		self.mnuNewInvSameCargo.visible := true;
	else
		self.mnuNewInvSameCargo.visible := false;
	endif;
		
	if canCopyDiffInvDiffCargo and currentInvLine &lt;&gt; null then
		self.mnuNewInvDiffCargo.visible := true;
	else
		self.mnuNewInvDiffCargo.visible := false;
	endif;
	
	if currentInvLine &lt;&gt; null then
		self.mnuSameInvSameCargo.visible := true;
	else
		self.mnuSameInvSameCargo.visible := false;
	endif;
		
	//15/04/2023 navmv20 TFS 55304 TASK 55545 - END
	
	/*OverRide*/ 
	//self.btnOverRide.enabled  := canOverride and invoiceSelected and self.myCurrentInvoice.canOverrideRates;       		     // 17/03/2016 cnwma1 TFS #3661 //12.11.2018 cnwma1 TFS #41945
	self.btnOverRide.enabled    := canOverride and invoiceSelected and self.myCurrentInvoice.canOverrideRates and canUpdateInv ; // 17/03/2016 cnwma1 TFS #3661 //12.11.2018 cnwma1 TFS #41945
	self.mnuInvOverride.visible := self.btnOverRide.enabled;
	
	self.mnuInvOvrTaxCode.visible := self.btnOverRide.enabled; //13/10/2022 navmv20 TFS 55005
	/*New*/
	//self.btnNew.enabled  := canNew;									// PAR #37149 //12.11.2018 cnwma1 TFS #41945
	self.btnNew.enabled    := canNew and canUpdateInv;  				// PAR #37149 //12.11.2018 cnwma1 TFS #41945
	self.mnuInvNew.visible := self.btnNew.enabled;	   				    // PAR #37149
	
	/*Update*/
	//self.btnUpdate.enabled := canMaint;                               //12.11.2018 cnwma1 TFS #41945             
	self.btnUpdate.enabled   := canMaint and canUpdateInv;              //12.11.2018 cnwma1 TFS #41945
	self.mnuInvUpdate.visible:= self.btnUpdate.enabled;
	
	/*Reevaluate*/
	//self.btnReeval.enabled  := canReevaluate and invoiceSelected and self.myCurrentInvoice.canBeReevaluated;						 // 17/03/2016 cnwma1 TFS #3661 //12.11.2018 cnwma1 TFS #41945
	self.btnReeval.enabled    := canReevaluate and invoiceSelected and self.myCurrentInvoice.canBeReevaluated and canUpdateInv;		 // 17/03/2016 cnwma1 TFS #3661 //12.11.2018 cnwma1 TFS #41945
	self.mnuInvReeval.visible := self.btnReeval.enabled ;
	self.mnuInvRecalc.visible     := self.btnReeval.enabled; // ### TFS CR 63369 TASK 63502 11APR2024 NAVAB1
	
	/*Void*/
	//self.btnStatusVoid.enabled :=  canVoid;                    //12.11.2018 cnwma1 TFS #41945
	self.btnStatusVoid.enabled   :=  canVoid and canUpdateInv;  //12.11.2018 cnwma1 TFS #41945
	if self.btnStatusVoid.enabled then
		if self.myCurrentInvoiceLine &lt;&gt; null then
			self.btnStatusVoid.enabled:=self.myCurrentInvoiceLine.status &lt;&gt; CM_InvoiceLine.STATUS_VOIDED;
		elseif self.myCurrentCashPayment &lt;&gt; null then
			self.btnStatusVoid.enabled:= self.myCurrentCashPayment.status &lt;&gt; CM_CashPayment.Status_Void; // TFS 45301
		else
			self.btnStatusVoid.enabled:=false;
		endif;
	endif;
	self.mnuInvVoid.visible := self.btnStatusVoid.enabled;
	
	/*Normal*/
	//self.btnNormal.enabled :=  canNormal; 					//12.11.2018 cnwma1 TFS #41945
	self.btnNormal.enabled   :=  canNormal and canUpdateInv;    //12.11.2018 cnwma1 TFS #41945
	if self.btnNormal.enabled then
		if self.myCurrentInvoiceLine &lt;&gt; null then
			self.btnNormal.enabled:=self.myCurrentInvoiceLine.status = CM_InvoiceLine.STATUS_VOIDED;
		elseif self.myCurrentCashPayment &lt;&gt; null then
			self.btnNormal.enabled:= self.myCurrentCashPayment.status = CM_CashPayment.Status_Void;	// TFS 45301
		else
			self.btnNormal.enabled:=false;
		endif;
	endif;
	self.mnuInvPending.visible :=self.btnNormal.enabled;  // ### JIRA 35468 31JUL2025 NAVAB1
	
	/*Show Bay*/
	self.mnuOOWShowBay.visible := canMaint and  self.myCurrentInvoiceLine.mySnapShotData &lt;&gt; null;
	
	/*View Transactions*/
	self.mnuContextViewTxns.visible:= invoiceLineSelected and canViewTrans ; //12.11.2018 cnwma1 TFS #41945
	
	/*Print*/
	self.btnPrint.enabled 		   := invoiceSelected;
	self.mnuInvPrintDetail.visible := invoiceSelected;
	
	/*Show Audits*/
	self.btnAudits.enabled	  := (self.myCurrentInvoiceLine &lt;&gt; null and self.myCurrentInvoiceLine.hasFinancialAudits) or 
								 (self.myCurrentCashPayment &lt;&gt; null and self.myCurrentCashPayment.hasFinancialAudits);
	self.mnuInvAudits.visible := self.btnAudits.enabled;
	
	/*Convert*/
	//self.btnConvert.enabled := canMaint  and self.canBeConverted();  					//12.11.2018 cnwma1 TFS #41945
	self.btnConvert.enabled   := canMaint  and self.canBeConverted() and canUpdateInv;  //12.11.2018 cnwma1 TFS #41945
	self.mnuInvConvert.visible:= self.btnConvert.enabled;
	
	 // ### JIRA 35691 14AUG2025 NAVAB1
	inv := self.myCurrentInvoice;
	if inv = null
	and self.myCurrentInvoiceLine &lt;&gt; null then
		inv := self.myCurrentInvoiceLine.invoice;
	endif;
	if inv &lt;&gt; null then
		self.btnOpenSchedule.enabled    := canMaint and (inv.isPosted or inv.isPostedDraft);    // ### JIRA 35469 31JUL2025 NAVAB1
	endif;
	
	self.mnuSendReportMain.visible := true;
	self.mnuSendReportAll.visible := true;
	self.mnuSendReportSelected.visible := true;
	self.mnuSendReportSeparator.visible := true;
	self.mnuSendReportSelected.visible := true;
	self.mnuInvUpdPaymentStatus.visible := false;                                        //24.9.2018 cnwma1 TFS #39698
	
	//15/04/2023 navmv20 TFS 55304 TASK 55545 - START
	self.mnuCopySelectedLines.visible := true;
	self.mnuNewInvDiffCargo.visible := true;
	self.mnuNewInvSameCargo.visible := true;
	self.mnuSameInvDiffCargo.visible := true;
	self.mnuSameInvSameCargo.visible := true;
	//15/04/2023 navmv20 TFS 55304 TASK 55545 - END
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setMyCaption" id="32180006-f39e-4558-bf64-63e6a4eb245d">
        <updating/>
        <source>setMyCaption() updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theCaption: String;
	numItems : Integer;
begin
	numItems := self.tblData.rows - self.tblData.fixedRows;
	theCaption := app.getErrorString(INV_Invoice_Lines_List);
	if self.cmbDebtor.listIndex &gt; 0 then
		theCaption := theCaption &amp; " - " &amp; self.cmbDebtor.text ;
	elseif self.cmbCargoID_.listIndex &gt; 0 then
		theCaption := theCaption &amp; " - " &amp; self.cmbCargoID_.text;
	elseif self.textSearch.text &lt;&gt; null then
		theCaption := theCaption &amp; " - " &amp; self.textSearch.text;
	endif;
	theCaption := theCaption &amp; " (" &amp; numItems.String &amp; " " &amp; app.getErrorString(INV_Items) &amp; ")";
	self.caption := theCaption;

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyCurrentTI" id="0216a70a-3f83-4c30-85bc-aed473b2383c">
        <updating/>
        <source>setMyCurrentTI() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 Nov 2020         cnwma1  Bug 50278: STWO - Creating a manual invoice line against split cargo through searcher selects wrong cargo.

*/
vars
	cargoTypeId,
	tiId		  : String;
	ti			  : CM_TrackedItem;
	cargoType	  : CM_CargoType;
	cargoOperator : CM_Operator;
	cargoLocation : CM_LocationsController;
	
begin

	
	tiId		  := self.tblInvProperties.getValueByName(ETRow_CargoId).String;
	cargoTypeId	  := self.tblInvProperties.getValueByName(ETRow_CargoType).String;
	cargoType	  := self.cmbCargoTypeInvP.listObject.CM_CargoType;	
	cargoOperator := self.cmbCargoOper.listObject.CM_Operator;				//12 Dec 2019	NDL	TFS 47954
	cargoLocation := self.cmbCargoLoc.listObject.CM_LocationsController;	//12 Dec 2019	NDL	TFS 47954
	
	if tiId = null then
	//or cargoTypeId = null then // TFS 46054 jlgzm1 16/10/2019, 
	//don't have to enter a cargo ID, we'll just grab the first ID match
		self.myCurrentTI		 := null;
		self.myCurrentCargoType  := null;
		self.myCurrentTIOperator := null;	//13 Dec 2019	NDL	TFS 47954
		self.myCurrentTILocation := null;	//13 Dec 2019	NDL	TFS 47954
		return;
	endif;

	// so, there is tiId &lt;&gt; null and cargoTypeId &lt;&gt; null
	if self.myCurrentTI &lt;&gt; null 
	and self.myCurrentCargoType &lt;&gt; null
	and self.myCurrentTI.id = tiId 
	and self.myCurrentCargoType.description = cargoTypeId	  //17 Dec 2019	NDL	TFS FS 47954
	and self.myCurrentTIOperator = cargoOperator			  //12 Dec 2019	NDL	TFS 47954
	//and self.myCurrentTILocation = cargoLocation			  //12 Dec 2019	NDL	TFS 47954    //23.11.2020 cnwma1 #50278
	then
		if self.myCurrentTI.isOnSite then                     //23.11.2020 cnwma1 #50278
			if self.myCurrentTILocation = cargoLocation then
				return;	// nothing changed, just return
			endif;
		else
			return;
		endif;
	endif;
	
	self.myCurrentTI		 := null;
	self.myCurrentCargoType	 := null;
	self.myCurrentTIOperator := null;
	self.myCurrentTILocation := null;
	
	ti := self.getMyTrackedItem( tiId, cargoType, cargoOperator, cargoLocation );
	if ti &lt;&gt; null then
		self.myCurrentTI		 := ti;
		self.myCurrentCargoType	 := cargoType;
		self.myCurrentTIOperator := cargoOperator;
		self.myCurrentTILocation := cargoLocation;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setQuery" id="ef6ca1d0-7ccb-41c2-bb4b-636a3655767c">
        <updating/>
        <source>setQuery() updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 24 Feb 2023	navmv20 TFS 56403 Task 56404: UI - Invoice List add Category
// 24 Feb 2023	navmv20 TFS 56403 Task 56460: Jade - Selector Category collection
// 29 Mar 2023	navmv20 Bug 57023: EUP - inconsistent search behaviour with external number
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod();
	self.lblDateRange.visible:=false;
	self.mskDateFrom.visible:=false;
	self.mskDateTo.visible:=false;
	self.cmbInvoiceStatus.visible := false;
	self.cmbInvoiceType.visible := false;
	
	self.cmbInvLineTypeQu.visible := self.btnQueryDebtor.value; // PAR 34469
	self.lblInvLineTypeQu.visible := self.btnQueryDebtor.value; // PAR 34469

	self.lblStatus.visible := false;
	self.lblType.visible := false;
	
	//10 Aug 2021	NDL	TFS 51702
	self.lblPDateRange.visible:=false;
	self.mskPDateFrom.visible:=false;
	self.mskPDateTo.visible:=false;
	
	self.cmbInvCategory.visible := false; //24/02/2023	navmv20 TFS 56403 Task 56404
	self.lblInvCategory.visible := false;//24/02/2023	navmv20 TFS 56403 Task 56404
	//29/03/2023 navmv20 Bug 57023 - START
	//self.txtExternalNumber.visible := false; //24/02/2023	navmv20 TFS 56403 Task 56460
	//self.lblExternalNumber.visible := false; //24/02/2023	navmv20 TFS 56403 Task 56460
	
	self.lblSearchFor.visible := btnQueryInvoice.value;
	self.cmbSearchFor.visible := btnQueryInvoice.value;
	self.textSearch.visible   := btnQueryInvoice.value;
	//29/03/2023 navmv20 Bug 57023 - END
	return;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="8ae532b4-9aca-41cd-8435-71ab13ea3b88">
