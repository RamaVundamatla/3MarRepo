    <JadeMethod name="getToDoTask" id="14a8e0eb-72cb-4111-93df-5dd670b453d3">
        <source>getToDoTask(_wle: CM_WOToDoWLE) : CM_ToDoTask;
/*
Purpose - 	
Who - NAVAB1
Date - 27SEP2023
ADO - CR 60699 TASK 60700 
*/

vars
	task : CM_ToDoTask;
	toDoTask : CM_ToDoTask;
	toDoTaskDesc : CM_ToDoTaskDesc;
	
begin
	toDoTask := _wle.myToDoTask;

	if toDoTask = null then
		if _wle.job = null then
			return null;
		endif;
		toDoTaskDesc := _wle.job.CM_WOToDoTaskJob.myToDoTaskDesc;
		if toDoTaskDesc = null then
			return null;
		endif;
		foreach task in _wle.myTrackedItem.allToDoTasksToDo where task.toDoTaskDesc = toDoTaskDesc do
			toDoTask := task;
			break;
		endforeach;
	endif;
	
	return toDoTask;

epilog

end;</source>
        <Parameter name="_wle" type="CM_WOToDoWLE"/>
        <ReturnType type="CM_ToDoTask"/>
    </JadeMethod>
    <JadeMethod name="getType" id="f2328bf9-e124-4679-98a4-1ae58523b7ad">
        <source>getType(_job: CM_Job):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Jun 2023	navhl20	ChangeRequest 57747:[57748] EUP - Delivery Dispatch – Allocate Jobs to Gangs

*/

vars

begin
	if _job.isKindOf(CM_RoadJob) then
		return WORK_POINT_TYPE_ROAD;
	elseif _job.isKindOf(CM_RailJob) then
		return WORK_POINT_TYPE_RAIL;
	elseif _job.isKindOf(CM_ToDoJob) or _job.isKindOf(CM_WOToDoTaskJob) then
		return WORK_POINT_TYPE_TODO;
	elseif _job.isKindOf(CM_YardJob) then
		return WORK_POINT_TYPE_YARD;
	elseif _job.isKindOf(CM_PackJob) or _job.isKindOf(CM_UnpackJob) then
		return WORK_POINT_TYPE_PACKUNPACK;
	elseif _job.isKindOf(CM_WOReceiveCargoJob)  then
		if _job.myWODtl.CM_WodReceive.transport = TI_TRANSMODE_ROAD then
			return WORK_POINT_TYPE_ROAD;
		elseif _job.myWODtl.CM_WodReceive.transport = TI_TRANSMODE_SHIP then
			return WORK_POINT_TYPE_SHIP;
		endif;
		
	elseif _job.isKindOf(CM_WOReleaseCargoJob)  then
		if _job.myWODtl.CM_WodRelease.transport = TI_TRANSMODE_ROAD then
			return WORK_POINT_TYPE_ROAD;
		elseif _job.myWODtl.CM_WodRelease.transport = TI_TRANSMODE_SHIP then
			return WORK_POINT_TYPE_SHIP;
		endif;
	endif;
	return null;
epilog

end;</source>
        <Parameter name="_job" type="CM_Job"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getWLEsforJob" id="5a70204f-d77f-4d15-aeb7-003dfc8c6913">
        <source>getWLEsforJob(_obj : CM_Job;_wleArr,_tempWleArr	: CM_WLEArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Mar 2025	navhl20 CR MTN-34425: MTN - Removing unnecessary codes from Work Order Operation screen methods.

*/

vars
	wle			: CM_WorkListEntry;
	wod			: CM_WodPack;
	job,
	jobPack		: CM_Job;
	ti  		: CM_TrackedItem;	
	numTIs		: Integer;
	tempWle		: CM_WOToDoWLE;	
begin
	job := _obj;
	if job.isKindOf(CM_WOPackJob) then
		wod := job.CM_WOPackJob.myWODtl.CM_WodPack;
		if wod &lt;&gt; null then
			foreach jobPack in wod.allJobs do
				if job.id = jobPack.id then	
					jobPack.workListEntries.copy(_wleArr);
				endif;
			endforeach;
		else
			_obj.CM_Job.workListEntries.copy(_wleArr);
		endif;
	elseif wle &lt;&gt; null and wle.isForToDoWOTransaction() then
		numTIs := job.CM_WOToDoTaskJob.allTrackedItems.size();
		if numTIs &gt; 0 then 
			foreach ti in job.CM_WOToDoTaskJob.allTrackedItems do
				create tempWle transient;
				beginTransientTransaction;
				tempWle := wle.cloneSelf(true).CM_WOToDoWLE;
				tempWle.setJob(wle.job);
				tempWle.setMyTrackedItem(ti);
				commitTransientTransaction;
				_tempWleArr.add(tempWle);
			endforeach;
			_tempWleArr.copy(_wleArr);
		else
			job.workListEntries.copy(_wleArr);
		endif;	
	else
		job.CM_Job.workListEntries.copy(_wleArr);
	endif;
epilog

end;</source>
        <Parameter name="_obj" type="CM_Job"/>
        <Parameter name="_wleArr" type="CM_WLEArray" usage="input"/>
        <Parameter name="_tempWleArr" type="CM_WLEArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getWOForReport" id="0715fe25-e0d9-4d62-b37e-c754a9feb895">
        <source>getWOForReport(_objArray : ObjectArray input; _selectedOnly : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Aug 2023 navhl20 ChangeRequest 58568: EUP - Delivery Dispatch – Reporting

*/

vars
	job			: CM_Job;
	objArray	: CM_ObjectArray;
	tbl			: CM_DataTable;
	wo			: CM_WorkOrder;
begin
	tbl := self.mnuReport.userObject.CM_DataTable;
	if _selectedOnly then
		foreach job in tbl.allSelectedObjects as CM_Job do
			wo := job.getWorkOrder();
			if wo &lt;&gt; null then
				_objArray.tryAdd(wo);
			endif;
		endforeach;
	else
		create objArray transient;
		tbl.getAllRowObjects(objArray);
		foreach job in objArray as CM_Job do
			wo := job.getWorkOrder();
			if wo &lt;&gt; null then
				_objArray.tryAdd(wo);
			endif;
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_objArray" type="ObjectArray" usage="input"/>
        <Parameter name="_selectedOnly" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="9545e1cf-0197-458e-ba4f-fbbd27bab4f8">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 May 2023 navhl20	ChangeRequest 57766:[57767] EUP - Delivery Dispatch – Define Job Sheet
07 Jun 2023 navhl20 ChangeRequest 58543: EUP - Delivery Dispatch – Allocation List - VAS
17 Jul 2023	navma1	ChangeRequest 59151: EUP | Delivery Dispatch - Hide Job Details
29 Aug 2023 navhl20 ChangeRequest 59216: EUP | Delivery Dispatch - Adding Splitter to resize tables
04 Oct 2023 navhl20 ChangeRequest 60033: EUP | Ship Operations in DD - [54176.010] - [Receive] Ship Job List 
12 Feb 2024 navnk30 ChangeRequest 62420: EUP | Retrospective Operations - [54177.020] - Allocate Road Jobs
05 Apr 2024 navhl20 ChangeRequest 63302: EUP - Bulk Moves in Retrospective Screen
25 Mar 2025	navhl20 CR MTN-34425: MTN - Removing unnecessary codes from Work Order Operation screen methods.
*/

vars
	rtnString		:	String;
begin
	rtnString := inheritMethod();
	self.saveXMLStrForTblColumns(self.tblJobsAllocated);
	self.saveXMLStrForTblColumns(self.tblJobSheet);
	self.saveXMLStrForTblColumns(self.tblJobsUnallocated);
	self.saveXMLStrForTblColumns(self.tblWlesAllocated);
	self.saveXMLStrForTblColumns(self.tblWlesUnallocated);
	
	if self.defJobSheet &lt;&gt; null then
		rtnString := rtnString &amp; self.defJobSheet;
	endif;
	
	if self.defJobAllocatted &lt;&gt; null then
		rtnString := rtnString &amp; global.formatAsXML(self.operationMode.String &amp; self.tblJobsAllocated.name, self.defJobAllocatted);			//25.03.2025 navhl20 #34425
	endif;
	
	if self.defJobUnAllocatted &lt;&gt; null then
		rtnString := rtnString &amp; global.formatAsXML(self.operationMode.String &amp; self.tblJobsUnallocated.name, self.defJobUnAllocatted);		//25.03.2025 navhl20 #34425
	endif;
	
	if self.defWleUnallocated &lt;&gt; null then
		rtnString := rtnString &amp; global.formatAsXML(self.operationMode.String &amp; self.tblWlesUnallocated.name, self.defWleUnallocated);		//25.03.2025 navhl20 #34425
	endif;
	
	if self.defWleAllocated &lt;&gt; null then
		rtnString := rtnString &amp; global.formatAsXML(self.operationMode.String &amp; self.tblWlesAllocated.name, self.defWleAllocated);			//25.03.2025 navhl20 #34425
	endif;
	
	rtnString := rtnString &amp; global.formatAsXML(self.cmbMode.name, self.operationMode.String);												//07.6.2023 navhl20 #58543	//25.03.2025 navhl20 #34425
	
	rtnString := rtnString &amp; global.formatAsXML(self.chkJobDetail.name, self.chkJobDetail.value.String);	//17.07.2023 navma1 #59151
	rtnString := rtnString &amp; global.formatAsXML(self.chkFilterCriteria.name, self.chkFilterCriteria.value.String);		//29.8.2023 navhl20 #59216
	rtnString := rtnString &amp; global.formatAsXML(self.chkJobSheet.name, self.chkJobSheet.value.String);		//04.10.2023 navhl20 #60033
	rtnString := rtnString &amp; global.formatAsXML(self.chkCurrentVoyage.name, self.chkCurrentVoyage.value.String);		//04.10.2023 navhl20 #60033

	return  rtnString;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleExceptionJob" id="aab07529-5a89-43c3-86e0-72371e6f20b8">
        <source>handleExceptionJob(_exObj : Exception; _job : CM_Job io) : Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2025	navrv30	MTN 34504 MTN - Work Order Operations - Waiting Time Column not displaying as expected

*/

constants
	ObjectNotFound	: Integer = 4;
	ObjectDeleted	: Integer = 1072;
begin

	if _exObj.errorCode = ObjectNotFound 
	or _exObj.errorCode = ObjectDeleted then
		_job := null;
		return Ex_Resume_Next;
	endif;

	return Ex_Pass_Back;

end;</source>
        <access>protected</access>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_job" type="CM_Job" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleNotifications" id="284cb1fd-f559-471e-8baf-7eefc5bae670">
        <updating/>
        <source>handleNotifications(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2023 navhl20	ChangeRequest 57766:[57767] EUP - Delivery Dispatch – Define Job Sheet
29 May 2023 navhl20 ChangeRequest 57747:[57748] EUP - Delivery Dispatch – Allocate Jobs to Gangs
16 Jun 2023 navhl20 ChangeRequest 57762: EUP - Delivery Dispatch – Un Allocated Pack/UnPack
16 Jun 2023 navhl20 Defect 58640: MTN - Vehicle Booking Id doesn't get populated on the delivery dispatch screen
21 Jun 2023 navhl20 Defect 58684: MTN - Unallocated list is not refreshing correctly
26 Jul 2023	navma1	ChangeRequest 56738: EUP | Stop Including Work Order Jobs in Work order operation screen
15 Sep 2023 navlc30 ChangeRequest 60211: EUP | Delivery Dispatch Colour Legend
22 Sep 2023 navhl20 Bug 60655: EUP | 53729 - Delivery Dispatch Screen - initial feedback
02 Nov 2023 navhl20 ChangeRequest 60091: EUP | Ship Operations in DD - [54176.040] - [Receive] Allocation List
21 Nov 2023 navmd1	TFS 61353 Fix notifications ignoring filter criteria
05 Dec 2023 navhl20 ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes
18 Jan 2024 navhl20 ChangeRequest 62066: EUP | Ship Operations in DD - FR - 01
29 Jan 2023 navhl20 Bug 62229: EUP - 14051 exception on the thinclient when completing the unpack job using the Cargo Scanning app
13 Feb 2023 navhl20 ChangeRequest 62093: EUP | Retrospective Operations - [54177.030] - Road Receive
13 Mar 2024 navhl20 ChangeRequest 62734: EUP | Ship Operations in DD - [54176.060] - [Release] Retrospective Operations
20 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
29 Mar 2024 navhl20 ChangeRequest 63251: FR | 53729 - Delivery Dispatch screen - Further issues and Remedial work
17 May 2024 navhl20 Bug 64191: EUP - Lock and Freeze issue
29 May 2024 navhl20 Bug 64345: EUP - Retrospective Partial Discharge not wokring.
30 May 2024 navhl20 Bug 64101: EUP - For the Pack Job the parent and child details are empty on the Complete Job form 
31 May 2024 navhl20 Bug 64261: EUP | VAS - Not able to complete TODO jobs
06 Jun 2024 navhl20 Bug 64511: EUP - Work order operations screen refresh issue
24 Jun 2024 ChangeRequest 64770: EUP | 54014 - Cargo Work Orders Enhancements - Remedial - 1
03 Jul 2024 navhl20	ChangeRequest 64969: EUP | 53856 - New Scanning App - Unpack mode issue
09 Jul 2024	navbs1	ChangeRequest 64778: EUP | Delivery Dispatch Multi Select Search
12 Aug 2024 navhl20	Bug 65586: Pack Work order - Issues
22 Aug 2024 navhl20	Bug 65424: EUP | 53729 - WO Jobs - Split Pack or Unpack job issues
14 Oct 2024	navnk30	JIRA 12385: MTN - Work Order Operation Screen notifications restricts user
12 Mar 2025	jlier1	MTN-34200 - changed wle and job notifications - fixed a few issues with coloring job rows and when mode = ALL
25 Mar 2025	navhl20 CR MTN-34425: MTN - Removing unnecessary codes from Work Order Operation screen methods.
*/

vars
	termEvent,idx	: Integer;
	invalidObject	: Boolean;
	theDataLine  	: String;
	tbl				: CM_DataTable;
	jobSheet		: CM_WorkPointJobSheet;
begin
	
	if theObject.isKindOf(CM_Job) or theObject.isKindOf(CM_WorkListEntry) then
		if self.notificationLevel = self.NoteLevelDoNotes then
			self.beginTimerForNotifications(theObject, eventType, eventTag, userInfo);
		endif;
		
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception, theObject, invalidObject);

	if eventType = Voyage_WO_Bulk_Move_Started and theObject &lt;&gt; null and theObject.isKindOf(CM_VoyageWorkPointJob) then		//14.10.2024 navnk30 JIRA #12385
		self.bulkMoveVoyageJob := theObject.CM_VoyageWorkPointJob;
		return;
	elseif eventType = Voyage_WO_Bulk_Move_Completed then
		self.handleVoyageJobBulkMoveNote(eventType, theObject, eventTag, userInfo);
		return;
	elseif self.isShipMoveNote(eventType, theObject, userInfo) then
		return;
	endif;
	
	if self.myTerminal &lt;&gt; null then
		termEvent := self.myTerminal.getEventFromTerminalEvent(eventType);
	endif;
	
	if theObject.isKindOf(CM_WorkPointJobSheet) then
		tbl := self.tblJobSheet;
		if tbl.visible then
			// Are we valid ?
			theObject.edition;
			
			// Check for deletes first
			if termEvent = Event_JobSheet_WP_Delete or invalidObject then
				tbl.removeItemObject(theObject.CM_WorkPointJobSheet);
			elseif termEvent = Event_JobSheet_WP_Create then
				jobSheet := theObject.CM_WorkPointJobSheet;
				if self.includeObject(null, jobSheet) then
					theDataLine := jobSheet.getAttributeStringForDefArray(tbl.allTblDataEntRows);
					tbl.addItemObject(theObject, theDataLine);
					self.loadtblWorkPointTypes();																			//09.07.2024 navbs1 #64778
				endif;
			elseif termEvent = Event_JobSheet_WP_Update then
				if tbl.findObjectInRow(theObject.CM_WorkPointJobSheet, idx) then
					tbl.setCellText(idx, 1, theObject.CM_WorkPointJobSheet.getAttributeStringForDefArray(tbl.allTblDataEntRows));
				endif;
			endif;
		endif;
	endif; //18/03/2025	navkc1 JIRA Story MTN-34154
	/* //18/03/2025	navkc1 JIRA Story MTN-34154 - Moved to beginTimerForNotifications method
	elseif theObject.isKindOf(CM_Job) then																					//29.5.2023 navhl20 #57747[57748]
	
		job := theObject.CM_Job;		
		tbl := self.tblJobsUnallocated;
		
		if job.myJobSheetForWorkPoint &lt;&gt; null then
			isAllocatted := true;
			tbl := self.tblJobsAllocated;
		endif;
		
		if eventType = Object_Update_Event or 
			eventType = self.myTerminal.getTerminalEvent(Object_Update_Event) or
			eventType = self.myTerminal.getTerminalEvent(WorkOrderJob_Update_Event) 		then		//02.07.2024 navhl20 #64969
			if selMode = YRD_WorkOrderOperation.Mode_ALL or (selMode &lt;&gt; YRD_WorkOrderOperation.Mode_SHIP and job.isJobMatchingMode(selMode)) then							//02.11.2023 navhl20 #60091 //17.05.2024 navhl20 #64191
				// Why are we clearing the last selected item in the table ? It might not even be whats currently on screen
				//tbl.clearAllSelected();																					//06.06.2024 navhl20 #64511
				
				// If we've switched from allocated or deallocated to the other, then remove from the old table
				if isAllocatted and self.tblJobsUnallocated.findObjectInRow(job,idx) then									//12.08.2024 navhl20 #65586
					self.tblJobsUnallocated.removeItemObject(job);
					self.tblWlesUnallocated.resetColumns(true);																//29.03.2024 navhl20 #63251
				elseif not isAllocatted and self.tblJobsAllocated.findObjectInRow(job,idx) then								//12.08.2024 navhl20 #65586
					self.tblJobsAllocated.removeItemObject(job);
					self.tblWlesAllocated.resetColumns(true);																//29.03.2024 navhl20 #63251
				endif;
				
				// Are we really an add ?
				if not tbl.findObjectInRow(job, idx) then
					if self.includeObject(job, null) then
						theDataLine := job.getAttributeStringForDefArray(tbl.allTblDataEntRows);
						tbl.addItemObject(job, theDataLine);
					endif;
				else
					// If we can no longer show this job, then remove it
					if not job.canBeIncludedOnWOO() and tbl.findObjectInRow(job,idx) then									//12.08.2024 navhl20 #65586
						tbl.removeItemObject(job);
						self.tblWlesAllocated.resetColumns(true);															//31.05.2024 navhl20 #64261
						self.tblWlesUnallocated.resetColumns(true);															//31.05.2024 navhl20 #64261
					else
						tbl.setCellText(idx, 1, job.getAttributeStringForDefArray(tbl.allTblDataEntRows));
					endif;
				endif;
				
				idx:=0;
				if tbl.findObjectInRow(job, idx) then																		//24.06.2024 navhl20 #64770
					if job.myJobSheetForWorkOrder = null then
						tbl.removeItemObject(job);
					else
						self.setRowColourForWorkPoint(tbl, job, idx);
					endif;
				endif;
						
			elseif job.isJobMatchingMode(selMode) then // selMode = YRD_WorkOrderOperation.Mode_SHIP 						//17.05.2024 navhl20 #64191
				if isAllocatted then
					tbl := self.tblJobsAllocated;
					if job.isKindOf(CM_VoyageWorkPointJob) then																//05.12.2023 navhl20 #58400[61617]
						if job.CM_VoyageWorkPointJob.myWorkOrderReceiveJob &lt;&gt; null then
							jobWo := job.CM_VoyageWorkPointJob.myWorkOrderReceiveJob;
						else
							jobWo := job.CM_VoyageWorkPointJob.myWorkOrderReleaseJob;
						endif;
					endif;
					if tbl.findObjectInRow(job, idx) then
						// Update text and colour
						tbl.setCellText(idx, 1, job.getAttributeStringForDefArray(tbl.allTblDataEntRows));
						self.setRowColourForWorkPoint(tbl , job, idx);
						//tbl.selectRow(idx,false);																			//13.02.2023 navhl20 #62093	//30.05.2024 navhl20 #64101
					endif;
					//If ship job connected with voyage job should notify ship job also with voyage job.
					if jobWo &lt;&gt; null then																					//05.12.2023 navhl20 #58400[61617]
						tbl := self.tblJobsUnallocated;
						if tbl.findObjectInRow(jobWo, idx) then
							// Update text and colour
							tbl.setCellText(idx, 1, jobWo.getAttributeStringForDefArray(tbl.allTblDataEntRows));
							self.setRowColourForWorkPoint(tbl , jobWo, idx);
						endif;
						if not jobWo.canBeIncludedOnWOO() and tbl.findObjectInRow(job,idx) then								//18.01.2024 navhl20 #62066	//12.08.2024 navhl20 #65586
							tbl.removeItemObject(jobWo);
							self.tblWlesAllocated.resetColumns(true);														//31.05.2024 navhl20 #64261
							self.tblWlesUnallocated.resetColumns(true);														//31.05.2024 navhl20 #64261
						endif;
					else
						tbl := self.tblJobsUnallocated;
						if tbl.findObjectInRow(job, idx) then
							// Update text and colour
							tbl.setCellText(idx, 1, job.getAttributeStringForDefArray(tbl.allTblDataEntRows));
							self.setRowColourForWorkPoint(tbl , job, idx);
						endif;
						if not job.canBeIncludedOnWOO() and tbl.findObjectInRow(job,idx) then								//18.01.2024 navhl20 #62066	//12.08.2024 navhl20 #65586
							tbl.removeItemObject(job);
							self.tblWlesAllocated.resetColumns(true);														//31.05.2024 navhl20 #64261
							self.tblWlesUnallocated.resetColumns(true);														//31.05.2024 navhl20 #64261
						endif;
					endif;
				endif;
				
				tbl := self.tblJobsUnallocated;
				if tbl.findObjectInRow(job, idx) then
					// Update text and colour
					tbl.setCellText(idx, 1, job.getAttributeStringForDefArray(tbl.allTblDataEntRows));
					self.setRowColourForWorkPoint(tbl , job, idx);
					//tbl.selectRow(idx,false);																				//13.02.2023 navhl20 #62093	//30.05.2024 navhl20 #64101
				endif;
			endif;
			
		elseif eventType = Object_Create_Event  then
			isAddable := false;
			tbl.clearAllSelected();
			
			// Only add if our Mode is the same or we don't care
			if job.isJobMatchingMode(selMode) or selMode = YRD_WorkOrderOperation.Mode_ALL then
				// Are we allowed to actually add this job
				if self.includeObject(job, null) then
					theDataLine := job.getAttributeStringForDefArray(tbl.allTblDataEntRows);
					idx := tbl.addItemObject(job, theDataLine);
					
					self.setRowColourForWorkPoint(tbl , job, idx);															//15.9.2023 navlc30 #60211
				endif;
				
				if job.isKindOf(CM_WOPackJob) then																			//22.08.2024 navhl20 #65424
					foreach jobChild in job.myWODtl.allJobs do
						if not jobChild.CM_WOPackJob.isPackParentJob and jobChild.id &lt;&gt; job.id then
							if tbl.findObjectInRow(jobChild, idx) then
								tbl.setCellText(idx, 1, jobChild.getAttributeStringForDefArray(tbl.allTblDataEntRows));
								break;
							endif;
						endif;
					endforeach;
				endif;
			endif;
			
		elseif eventType = Object_Delete_Event or
			eventType = self.myTerminal.getTerminalEvent(WorkOrderJob_Delete_Event)  then
			job.edition;
			if invalidObject then
				// Remove from either table if we have it
				if self.tblJobsUnallocated.findObjectInRow(job,idx) then													//12.08.2024 navhl20 #65586
					self.tblJobsUnallocated.removeItemObject(job);
					self.tblWlesUnallocated.resetColumns(true);
				elseif self.tblJobsAllocated.findObjectInRow(job,idx) then
					self.tblJobsAllocated.removeItemObject(job);
					self.tblWlesAllocated.resetColumns(true);
				endif;
			endif;
		endif;
		
		self.setShtCaption(self.tblJobsUnallocated);
		self.setShtCaption(self.tblJobsAllocated);
		
	elseif theObject.isKindOf(CM_WorkListEntry) 																			//30.5.2023 navhl20 #57747[57748]
	and self.chkJobDetail.value then																						//06.06.2024 navhl20 #64511
		tbl := self.tblJobsUnallocated;
		tblWle	:= self.tblWlesUnallocated;
		wle := theObject.CM_WorkListEntry;
		job := wle.job;
		
		if job &lt;&gt; null and (selMode = YRD_WorkOrderOperation.Mode_ALL or job.isJobMatchingMode(selMode)) then
			if job &lt;&gt; null and job.myJobSheetForWorkPoint &lt;&gt; null then
				tbl := self.tblJobsAllocated;
				tblWle	:= self.tblWlesAllocated;
			endif;
			
			if selMode = YRD_WorkOrderOperation.Mode_SHIP then																//29.05.2024 navhl20 #64345
				if (tbl = self.tblJobsAllocated and job.isKindOf(CM_WorkOrderJob)) or
				(tbl = self.tblJobsUnallocated and job.isKindOf(CM_VoyageWorkPointJob)) then
					return;
				endif;
			endif;
			
			if job.isKindOf(CM_WOPackJob) and job.CM_WOPackJob.isPackParentJob then											//12.08.2024 navhl20 #65586
				wod := job.myWODtl;
				if wod &lt;&gt; null then
					foreach jobWo in wod.allJobs where not jobWo.CM_WOPackJob.isPackParentJob do
						if job.id = jobWo.id then
							job 	:= jobWo;
							tbl 	:= self.tblJobsAllocated;
							tblWle	:= self.tblWlesAllocated;
						endif;
					endforeach;
				endif;
			endif;
			
			if tbl.allSelectedObjects.first = job then																		//17.05.2024 navhl20 #64191
				if tbl.findObjectInRow(job, idx) then																		//20.03.2024 navhl20 #62863
					// Update text and colour
					tbl.setCellText(idx, 1, job.getAttributeStringForDefArray(tbl.allTblDataEntRows));
					self.setRowColourForWorkPoint(tbl , job, idx);
					//tbl.selectRow(idx,false);																				//06.06.2024 navhl20 #64511
					idx := 0;																								//29.05.2024 navhl20 #64345
				endif;
				
				if tblWle.rows &gt; 1 then																						//31.05.2024 navhl20 #64101
					if tblWle.findObjectInRow(wle,idx) and 
					(eventType = self.myTerminal.getTerminalEvent(WLE_Update_Event) or eventType = Object_Update_Event) then		//29.05.2024 navhl20 #64345
						tblWle.setCellText(idx, 1, wle.getAttributeStringForDefArray(tblWle.allTblDataEntRows));
						idx := 0;															//29.05.2024 navhl20 #64345
					elseif not tblWle.findObjectInRow(wle,idx) and 
					(eventType = self.myTerminal.getTerminalEvent(WLE_Create_Event) or eventType = Object_Create_Event) then		//29.05.2024 navhl20 #64345
						theDataLine := wle.getAttributeStringForDefArray(tblWle.allTblDataEntRows);
						idx := tblWle.addItemObject(wle, theDataLine);
					endif;
					if wle.status = WLE_COMPLETED then
						tblWle.accessedRow.foreColor := White;
						tblWle.accessedRow.backColor := Grey;
					endif;
				endif;
			endif;
		endif;
	endif;
	*/ //18/03/2025	navkc1 JIRA Story MTN-34154 End
epilog
	endLoad;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="handleVoyageJobBulkMoveNote" id="4f0e954e-4b42-4154-a037-c380f059afe6">
        <updating/>
        <source>handleVoyageJobBulkMoveNote(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Oct 2024	navnk30	JIRA 12385: MTN - Work Order Operation Screen notifications restricts user

*/

vars
	obj				: Object;
	wle 			: CM_WorkListEntry;
	wleOidStr		: String;
	wleOidsStrArr	: StringArray;
	tblJobs,
	tblWles			: CM_DataTable;
	rowId			: Integer;
begin
	if eventType &lt;&gt; Voyage_WO_Bulk_Move_Completed or
			theObject &lt;&gt; self.bulkMoveVoyageJob or
			self.fldJobs.topSheet &lt;&gt; self.shtAllocated then
		return;
	endif;

	tblJobs := self.tblJobsAllocated;
	if tblJobs.findObjectInRow(self.bulkMoveVoyageJob, rowId) then
		tblJobs.setCellText(rowId, 1, self.bulkMoveVoyageJob.getAttributeStringForDefArray(tblJobs.allTblDataEntRows));
		self.setRowColourForWorkPoint(tblJobs, self.bulkMoveVoyageJob, rowId);
	endif;
	
	if not self.chkJobDetail.value then
		return;
	endif;
	tblWles := self.tblWlesAllocated;
	wleOidsStrArr := userInfo.String.getTokens();
	foreach wleOidStr in wleOidsStrArr do
		obj := wleOidStr.asOid();
		if obj = null or not obj.isKindOf(CM_WorkListEntry) then
			continue;
		endif;
		
		wle := obj.CM_WorkListEntry;		
		if not tblWles.findObjectInRow(wle, rowId) then
			rowId := tblWles.addItemObject(wle, wle.getAttributeStringForDefArray(tblWles.allTblDataEntRows));
		endif;			
		tblWles.accessRow(rowId).foreColor := White;
		tblWles.accessRow(rowId).backColor := Grey;
	endforeach;
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="includeObject" id="bc1bd10a-7e5e-48e8-9936-06f6db470a4a">
        <source>includeObject(_job : CM_Job; _jobsheet : CM_WorkPointJobSheet):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2023	navhl20	ChangeRequest 57714:[57764] EUP - Delivery Dispatch – Gate
05 Jun 2023 navhl20 ChangeRequest 57760: EUP - Delivery Dispatch – Un Allocated VAS
07 Jun 2023 navhl20 ChangeRequest 57747:[57748] EUP - Delivery Dispatch – Allocate Jobs to Gangs
08 Jun 2023 navhl20 ChangeRequest 58543: EUP - Delivery Dispatch – Allocation List - VAS
04 Jul 2023 navhl20 Defect 58906: MTN - The Allocated and Unallocated list is not refreshing correctly using the filter criteria
26 Jul 2023	navma1	ChangeRequest 56738: EUP | Stop Including Work Order Jobs in Work order operation screen
04 Oct 2023 navhl20 ChangeRequest 60033: EUP | Ship Operations in DD - [54176.010] - [Receive] Ship Job List 
16 Oct 2023 navhl20 Bug 60863: EUP - Delivery Dispatch Remedial [1]
19 Oct 2023 navhl20 Bug 60931: EUP - Delivery Dispatch Remedial [2]
09 Nov 2023 navhl20 Bug 61169: MTN - Unable to filter ship jobs by Commodity
21 Nov 2023 navmd1	TFS 61353 Move additional criteria from notification to includeObject and just call that instead
28 Nov 2023 navhl20 Bug 61545: EUP - Ship Operations in DD - Gang ID is not available in the filter criteria on WO Operations form
28 Nov 2023 navhl20 ChangeRequest 61508: EUP | Ship Operations in DD - [54176.010] - [Release] Ship Job List 
25 Jan 2023 navhl20 ChangeRequest 62166: EUP | 53729 - Delivery Dispatch Screen - outstanding issues
22 Feb 2024 navhl20 ChangeRequest 62525: EUP | Retrospective Operations - [54177.060] - Cargo &amp; Truck Checks
11 Mar 2024 navhl20 ChangeRequest 60097: EUP | Ship Operations in DD - [54176.060] - [Receive] Retrospective Operations
05 Apr 2024 navhl20 ChangeRequest 63302: EUP - Bulk Moves in Retrospective Screen
10 Apr 2024 navhl20 ChangeRequest 63251: FR | 53729 - Delivery Dispatch screen - Further issues and Remedial work - 1
29 Apr 2024 navma1	Bug 63868: MTN - 1081 from performance test QA-PerformanceTest-Dumps_20240424
17 Jun 2024 navhl20 ChangeRequest 64684: EUP - Add new filter criteria in Work Order Operations.
09 Jul 2024	navbs1	ChangeRequest 64778: EUP | Delivery Dispatch Multi Select Search
24 Sep 2024 navhl20	Bug 66244: EUP - Filter Jobs based on From/To Date
25 Feb 2025 navma1  MTN-34075 MTN | Dead Lock (1081) on CM_JobsByPriorityRequiredDT
02 Apr 2024 navma1	MTN-34517 MTN - Unable to filter the jobs using the Vessel filter criteria on the WO Operations form
*/

vars
	selectedImex		: CM_IMEXStatus;
	jobType				: Integer;
	jobStatus,
	selectedTruckStatus : String;
	ti 					: CM_TrackedItem;
	ref					: String;
	wPTs				: ObjectArray;
	fromDate,
	toDate,
	gateEntry,
	wagonEntry			: TimeStamp;
	dwellTime			: Integer;
	fromShift,
	toShift				: CM_Shift;
	firstWH				: CM_TerminalArea;
	selectedCommodity	: CM_Commodity;
	selectedVoyage		: CM_Voyage;
	selectedVessel		: CM_Vessel;
	wpJobSheet			: CM_WorkPointJobSheet;
	jobSheets			: ObjectArray;
	wodDtl				: CM_WorkOrderDtl;
	voyageOfJob			: CM_Voyage;
	lc					: CM_YardController;
	vehicle     		: CM_Vehicle;
	wagon				: CM_Wagon;
	selectedTrain,
	jobTrain			: CM_Train;
	obj					: Object;
	shiftStartDateTime	: TimeStamp;	// ### JIRA: MTN-33528 12Dec2024 NAVPW1
	terminal			: CM_Terminal;
begin
	
	
	selectedVessel 		:= null;
	selectedVoyage 		:= null;
	selectedCommodity	:= null;
	selectedTruckStatus := null;
	selectedImex		:= null;
	
	
	terminal	:= self.myTerminal;
	jobSheets 	:= self.tblWPJobSheet.allSelectedObjects;						//09.07.2024 navbs1 #64778
	wPTs		:= self.tblWorkPointTypes.allSelectedObjects;					//09.07.2024 navbs1 #64778
	jobStatus 	:= self.cmbJobStatus.text;
	ref			:= self.txtReference.text;
	dwellTime 	:= self.txtDwellTime.text.Integer;								//05.6.2023 navhl20 #57760
	
	if self.cmbImex.text &lt;&gt; null then											//19.10.2023 navhl20 #60931
		selectedImex 		:= self.cmbImex.listObject.CM_IMEXStatus;
	endif;
	
	if self.cmbShiftFrom.text &lt;&gt; Space then										//25.09.2024 navhl20 #66244
		fromShift 	:= self.cmbShiftFrom.listObject.CM_Shift;
	else
		fromShift 	:= null;
	endif;
	
	if self.cmbShiftTo.text &lt;&gt; Space then										//25.09.2024 navhl20 #66244
		toShift 	:= self.cmbShiftTo.listObject.CM_Shift;
	else
		toShift 	:= null;
	endif;
	
	firstWH		:= self.cmbFirstWarehouse.listObject.CM_TerminalArea;			//08.6.2023 navhl20 #58543
	
	
	if self.cmbVessel.visible then												//17.06.2024 navhl20 #64684
		selectedVessel 		:= self.cmbVessel.listObject.CM_Vessel;				//04.10.2023 navhl20 #60033
		selectedVoyage 		:= self.cmbTransport.listObject.CM_Voyage;			//04.10.2023 navhl20 #60033
	endif;
	
	if self.cmbCommodity.visible then											//17.06.2024 navhl20 #64684
		selectedCommodity 	:= self.cmbCommodity.listObject.CM_Commodity;		//04.10.2023 navhl20 #60033
	endif;
	
	if self.cmbTruckStatus.visible then											//31.01.2023 navhl20 #62166
		selectedTruckStatus := self.cmbTruckStatus.text;
	endif;
	
	if self.cmbTransport.visible then											//17.06.2024 navhl20 #64684
		obj := self.cmbTransport.listObject;
		if obj &lt;&gt; null and obj.isKindOf(CM_Train) then
			selectedTrain := obj.CM_Train;
		endif;
	endif;
	
	fromDate.setDate(self.txtFromDate.getDate());
	if self.txtFromTime.text = "  :  " then
		fromDate.setTime('00:01'.Time);
	else
		fromDate.setTime(self.txtFromTime.getTime);
	endif;
	toDate.setDate(self.txtToDate.getDate);
	if self.txtFromTime.text = "  :  " then
		toDate.setTime('00:01'.Time);
	else
		toDate.setTime(self.txtToTime.getTime);
	endif;
	
	if self.cmbJobType.text &lt;&gt; null then										//05.7.2023 navhl20 #58906
		jobType 	:= self.cmbJobType.itemData[self.cmbJobType.listIndex];
	endif;
	

	if _jobsheet &lt;&gt; null then
		if jobSheets.size &gt; 0  and not jobSheets.includes( _jobsheet) then							//28.11.2023 navhl20 #61545 //09.07.2024 navbs1 #64778
			return false;
		endif;
		
		if wPTs.size &gt; 0 and _jobsheet.myWorkPoint = null then										//09.07.2024 navbs1 #64778
			return false;
		endif;
		
		if wPTs.size &gt; 0 and not wPTs.includes(_jobsheet.myWorkPoint.myWorkPointType) then			//09.07.2024 navbs1 #64778
			return false;
		endif;
		
		if fromShift &lt;&gt; null and fromDate.isValid and _jobsheet.myShift &lt;&gt; null and fromDate &gt; _jobsheet.myShift.startDateTime then		//16.10.2023 navhl20 #60863
			return false;
		endif;
		
		if toShift &lt;&gt; null and toDate.isValid and _jobsheet.myShift &lt;&gt; null and toDate &lt; _jobsheet.myShift.endDateTime then				//16.10.2023 navhl20 #60863
			return false;
		endif;
		
		return true;
	endif;
	
	if _job &lt;&gt; null then
		
	
		wpJobSheet := _job.myJobSheetForWorkPoint;
		
		if wpJobSheet &lt;&gt; null then
			if  jobSheets.isNotEmpty and not  jobSheets.includes(wpJobSheet) then						//28.11.2023 navhl20 #61545	//09.07.2024 navbs1 #64778
				return false;
			endif;
			
			if wPTs.size &gt; 0 and wpJobSheet.myWorkPoint = null then										//09.07.2024 navbs1 #64778
				return false;
			endif;
			
			if wPTs.size &gt; 0 and not  wPTs.includes(wpJobSheet.myWorkPoint.myWorkPointType) then		//09.07.2024 navbs1 #64778
				return false;
			endif;
			
			// ### JIRA: MTN-33528 12Dec2024 NAVPW1
			if wpJobSheet.myShift &lt;&gt; null then
				shiftStartDateTime := wpJobSheet.myShift.startDateTime;
			endif;
			// ### JIRA: MTN-33528 12Dec2024 NAVPW1
			
			if fromShift &lt;&gt; null and fromDate.isValid and fromDate &gt; shiftStartDateTime then	// ### JIRA: MTN-33528 12Dec2024 NAVPW1
				return false;
			endif;
			
			if toShift &lt;&gt; null and toDate.isValid and toDate &lt; shiftStartDateTime then			// ### JIRA: MTN-33528 12Dec2024 NAVPW1
				return false;
			endif;
		endif;
		
		//Start 24.09.2024 navhl20 #66244
		// No work point ? Just check job required by date
		if fromShift = null and toShift = null then
			if _job.isRoadJob then
				gateEntry := _job.CM_RoadJob.getGateEntryTimeStamp();
				
				if not gateEntry.isValid then
					return false;
				endif;
				
				if fromDate.isValid and gateEntry.isValid and fromDate &gt; gateEntry then
					return false;
				endif;
				
				if toDate.isValid and gateEntry.isValid and toDate &lt; gateEntry then
					return false;
				endif;
			elseif _job.isRail then
				wagonEntry := _job.CM_RailJob.getWagonEntryTimeStamp();
				
				if not wagonEntry.isValid then
					return false;
				endif;
				
				if fromDate.isValid and wagonEntry.isValid and fromDate &gt; wagonEntry then
					return false;
				endif;
				
				if toDate.isValid and wagonEntry.isValid and toDate &lt; wagonEntry then
					return false;
				endif;
			else
				if fromDate.isValid and fromDate &gt; _job.requiredByDT then
					return false;
				endif;
				
				if toDate.isValid and toDate &lt; _job.requiredByDT then
					return false;
				endif;
			endif;
		endif;
		//End 24.09.2024 navhl20 #66244
		
		if _job.getMyTerminal() &lt;&gt; terminal then
			return false;
		endif;
		
		if not _job.canBeIncludedOnWOO then																	//26.07.2023 navma1 #56738
			return false;
		endif;
		
		if jobType &lt;&gt; null and not _job.isJobTypeMatching(jobType) then										//05.7.2023 navhl20 #58906
			return false;
		endif;
		
		if selectedImex &lt;&gt; null then
			ti := _job.getFirstTrackedItem();
			if ti &lt;&gt; null and selectedImex &lt;&gt; ti.getImExStatusObject() then
				return false;
			endif;
		endif;
		
		if jobStatus &lt;&gt; null and jobStatus &lt;&gt; _job.statusString then
			return false;
		endif;
		
		if ref &lt;&gt; null then
			if _job &lt;&gt; null then																			//25.01.2023 navhl20 #62166
				wodDtl	:= _job.getMyWorkOrderDtl();
				if wodDtl &lt;&gt; null and wodDtl.isKindOf(CM_WodToDo) and wodDtl.CM_WodToDo.myWorkOrderDetail &lt;&gt; null then
					wodDtl := wodDtl.CM_WodToDo.myWorkOrderDetail;
				endif;
			endif;
			
			if wodDtl = null then
				return false;
			endif;
			
			if wodDtl &lt;&gt; null and  ref &lt;&gt; wodDtl.getReference() then
				return false;
			endif;
		endif;
		
		if dwellTime &lt;&gt; null and _job.dwellTime &lt; dwellTime then
			return false;
		endif;
		
		if firstWH &lt;&gt; null and _job.plannedLocation &lt;&gt; firstWH.id then //26/08/2024	navkc1 CR 63588 Task 63589
			return false;
		endif;
		
		if selectedCommodity &lt;&gt; null and not _job.isMatchingCommodity(selectedCommodity.code) then			//06.11.2023 navhl20 #61169
			return false;
		endif;
		
		
		if selectedVoyage &lt;&gt; null  or selectedVessel &lt;&gt; null then											//02.04.2024 navma1 #MTN-34517
			voyageOfJob := _job.getMyVoyage();
			if selectedVoyage &lt;&gt; null and  selectedVoyage &lt;&gt; voyageOfJob then								//04.10.2023 navhl20 #60033
				return false;
			endif;
		endif;
		
		if voyageOfJob &lt;&gt; null then
			if selectedVessel &lt;&gt; null  and selectedVessel &lt;&gt; voyageOfJob.myVessel then						//04.10.2023 navhl20 #60033
				return false;
			endif;
		else
			if selectedVessel &lt;&gt; null  then																	//28.11.2023 navhl20 #61508
				return false;
			endif;
		endif;
		
		if selectedTrain &lt;&gt; null then																		//17.06.2024 navhl20 #64684
			jobTrain := _job.getMyTrain();
			if jobTrain = null then
				return false;
			elseif jobTrain &lt;&gt; null and jobTrain &lt;&gt; selectedTrain then
				return false;
			endif;
		endif;
		
		
		if _job.requiredByDT = null and _job.getWorkOrder() = null  then
			return false;
		endif;
		
		if selectedTruckStatus &lt;&gt; null then																	//31.01.2023 navhl20 #62166
			if _job.isRoadJob then
				if _job.status = JOB_COMPLETE then
					return false;
				endif;
				
				vehicle := _job.CM_RoadJob.myVehicle;														//02.04.2024 navma1 #63302
				
				if vehicle = null then
					return false;
				endif;
				
				lc  := vehicle.myPrimaryActualLocation;														//02.04.2024 navma1 #63302
				
				if lc = null then
					return false;
				endif;
				
				if vehicle &lt;&gt; null and lc &lt;&gt; null then											
					if selectedTruckStatus = self.Truck_InYard  and not lc.isInsideYard then						//02.04.2024 navma1 #63302
						return false;
					endif;
					if selectedTruckStatus = self.Truck_Pending_Entry and lc.isInsideYard then						//02.04.2024 navma1 #63302
						return false;
					endif;
				endif;
			else
				return false;
			endif;
		endif;
		
		return true;
	endif;
	return false;
epilog

end;</source>
        <Parameter name="_job" type="CM_Job"/>
        <Parameter name="_jobsheet" type="CM_WorkPointJobSheet"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="71c81362-2552-4bac-847c-293a4f4d9268">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Jun 2023	navhl20	ChangeRequest 58543: EUP - Delivery Dispatch – Allocation List - VAS
17 Jul 2023	navma1	ChangeRequest 59151: EUP | Delivery Dispatch - Hide Job Details
29 Aug 2023 navhl20 ChangeRequest 59216: EUP | Delivery Dispatch - Adding Splitter to resize tables
04 Oct 2023 navhl20 ChangeRequest 60033: EUP | Ship Operations in DD - [54176.010] - [Receive] Ship Job List 
12 Feb 2024 navnk30 ChangeRequest 62420: EUP | Retrospective Operations - [54177.020] - Allocate Road Jobs
05 Apr 2024 navhl20 ChangeRequest 63302: EUP - Bulk Moves in Retrospective Screen
31 Mar 2025	navhl20 CR MTN-34425: MTN - Removing unnecessary codes from Work Order Operation screen methods.
*/

vars
	hideJobDetails,
	hideCriteria,
	hideVoyage,
	hideJobSheet		: String;
begin
	
	inheritMethod(_userWindow);
	
	if _userWindow = null then
		return;
	endif;
	
	self.operationMode 	    := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.cmbMode.name );
	self.defJobAllocatted   := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.operationMode &amp; self.tblJobsAllocated.name);		//31.03.2025 navhl20 #34425
	self.defJobUnAllocatted := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.operationMode &amp; self.tblJobsUnallocated.name);	//31.03.2025 navhl20 #34425
	self.defWleUnallocated  := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.operationMode &amp; self.tblWlesUnallocated.name);	//31.03.2025 navhl20 #34425
	self.defWleAllocated 	:= _userWindow.xmlInfo.cnEcGetTagValueOfName(self.operationMode &amp; self.tblWlesAllocated.name);		//31.03.2025 navhl20 #34425
	
	hideJobDetails := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.chkJobDetail.name);	//17.07.2023 navma1 #59151
	if hideJobDetails &lt;&gt; null then
		self.chkJobDetail.value := hideJobDetails.Boolean;
	endif;
	
	hideCriteria := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.chkFilterCriteria.name);		//29.8.2023 navhl20 #59216
	if hideCriteria &lt;&gt; null then
		self.chkFilterCriteria.value := hideCriteria.Boolean;
	endif;
	
	hideJobSheet := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.chkJobSheet.name);			//04.10.2023 navhl20 #60033
	if hideJobSheet &lt;&gt; null then
		self.chkJobSheet.value := hideJobSheet.Boolean;
	endif;
	
	hideVoyage := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.chkCurrentVoyage.name);		//04.10.2023 navhl20 #60033
	if hideVoyage &lt;&gt; null then
		self.chkCurrentVoyage.value := hideVoyage.Boolean;
	endif;
epilog

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="initMnuPriority" id="1041214a-1e8f-4606-8c15-73777be8ae7f">
        <updating/>
        <source>initMnuPriority() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
02 Jun 2023 	navlw1 	CHangeRequest 58294: EUP | Delivery Dispatch Screen - Setting Priority

*/

vars
	idx 		: Integer;
	mnuChild 	: MenuItem;
begin

	self.mnuSetPrioritySub.visible := false;
	foreach idx in 1 to 3 do
		mnuChild := self.mnuSetPriority.loadSubMenu(idx);
		mnuChild.caption := idx.String;
		mnuChild.visible := true;
		mnuChild.enabled := true;
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="isShipMoveNote" id="32af1222-1341-49b6-9c2b-2ab3818de317">
        <source>isShipMoveNote(eventType: Integer; theObject : Object; userInfo : Any) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Oct 2024	navnk30	JIRA 12385: MTN - Work Order Operation Screen notifications restricts user

*/

vars
	noteObj	: Object;
begin
	if eventType = Voyage_WO_Bulk_Move_Started or eventType = Voyage_WO_Bulk_Move_Completed then
		return true;
	endif;
	
	if userInfo &lt;&gt; null and userInfo.isKindOf(Object) then
		noteObj := userInfo.Object;
	else
		noteObj := theObject;
	endif;
	
	if noteObj = null or self.bulkMoveVoyageJob = null then
		return false;
	elseif CM_VoyageWLE.hasInstance(noteObj) then
		return noteObj.CM_VoyageWLE.job = self.bulkMoveVoyageJob;
	elseif CM_WOWLE.hasInstance(noteObj) then
		return noteObj.CM_WOWLE.job = self.bulkMoveVoyageJob.myWorkOrderReceiveJob or
				noteObj.CM_WOWLE.job = self.bulkMoveVoyageJob.myWorkOrderReleaseJob;
	elseif CM_VoyageWorkPointJob.hasInstance(noteObj) then
		return noteObj = self.bulkMoveVoyageJob;
	elseif CM_WOReceiveCargoJob.hasInstance(noteObj) or CM_WOReleaseCargoJob.hasInstance(noteObj) then
		return self.bulkMoveVoyageJob.myWorkOrderReceiveJob = noteObj or
			self.bulkMoveVoyageJob.myWorkOrderReleaseJob = noteObj;
	else
		return false;
	endif;
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="userInfo" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadCmbShiftFrom" id="0b2cbed4-f4a8-48f7-a9d5-b83db8a29c22">
        <source>loadCmbShiftFrom();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2023 navma1  ChangeRequest 57878: EUP - Delivery Dispatch – Screen Design
29 Mar 2024 navhl20 ChangeRequest 63251: FR | 53729 - Delivery Dispatch screen - Further issues and Remedial work
03 Apr 2024 navhl20 ChangeRequest 63302: EUP - Bulk Moves in Retrospective Screen
*/

vars
	startDT,
	now,
	endDT	  : TimeStamp;
	tmpTime   : Time;
	shift,
	mtShift   : CM_Shift;
begin
	
	now := app.actualTimeServer();
	
	startDT.setDate(now.date().addDays(-7));				//29.03.2024 navhl20 #63251
	tmpTime.setTime(0,0,0,0);
	startDT.setTime(tmpTime);
	
	
	endDT.setDate(now.date());								//29.03.2024 navhl20 #63251
	tmpTime.setTime(23,59,59,0);
	endDT.setTime(tmpTime);
	
	self.allShiftsFromDays.purge;
	self.myTerminal.getShiftsFromRange(self.allShiftsFromDays, startDT, endDT);
	create mtShift transient;								//03.04.2024 navhl20 #63302
	self.allShiftsFromDays.add(mtShift);					//03.04.2024 navhl20 #63302
	
	self.cmbShiftFrom.clear;
	self.cmbShiftFrom.sorted := false;
	self.cmbShiftFrom.listCollection(self.allShiftsFromDays, false, ComboBox.DisplayCollection_Forward);
	
	foreach shift in self.allShiftsFromDays do				//29.03.2024 navhl20 #63251
		if shift.startDateTime &lt;= now and shift.endDateTime &gt;= now then
			self.cmbShiftFrom.setIndexFromObject(shift);
			self.txtFromDate.setDate(shift.startDateTime.date);
			self.txtFromTime.setTime(shift.startDateTime.time);
			break;
		endif;
	endforeach;
epilog
	delete mtShift;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadCmbShiftTo" id="3c904bae-ee15-44df-8a94-a022f789bdf9">
        <source>loadCmbShiftTo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2023 navma1  ChangeRequest 57878: EUP - Delivery Dispatch – Screen Design
29 Mar 2024 navhl20 ChangeRequest 63251: FR | 53729 - Delivery Dispatch screen - Further issues and Remedial work
03 Apr 2024 navhl20 ChangeRequest 63302: EUP - Bulk Moves in Retrospective Screen
*/

vars
	startDT,
	now,
	endDT	  : TimeStamp;
	tmpTime   : Time;
	shift	  : CM_Shift;
	mtShift	  : CM_Shift;
begin
	
	now := app.actualTimeServer();
	
	startDT.setDate(now.date().addDays(-7));				//29.03.2024 navhl20 #63251
	tmpTime.setTime(0,0,0,0);
	startDT.setTime(tmpTime);
	
	
	endDT.setDate(now.date());								//29.03.2024 navhl20 #63251
	tmpTime.setTime(23,59,59,0);
	endDT.setTime(tmpTime);
	
	self.allShiftsToDays.purge;
	self.myTerminal.getShiftsFromRange(self.allShiftsToDays, startDT, endDT);
	
	create mtShift transient;								//03.04.2024 navhl20 #63302
	self.allShiftsToDays.add(mtShift);						//03.04.2024 navhl20 #63302
	
	self.cmbShiftTo.clear;
	self.cmbShiftTo.sorted := false;
	self.cmbShiftTo.listCollection(self.allShiftsToDays, false, ComboBox.DisplayCollection_Forward);
	
	foreach shift in self.allShiftsToDays do				//29.03.2024 navhl20 #63251
		if shift.startDateTime &lt;= now and shift.endDateTime &gt;= now then
			self.cmbShiftTo.setIndexFromObject(shift);
			self.txtToDate.setDate(shift.endDateTime.date);
			self.txtToTime.setTime(shift.endDateTime.time);
			break;
		endif;
	endforeach;
epilog
	delete mtShift;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadFliterCriteria" id="ba78b61f-880b-4f0b-a224-82bfd5aacce6">
        <source>loadFliterCriteria();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2023 navma1  ChangeRequest 57878: EUP - Delivery Dispatch – Screen Design
08 Jun 2023 navhl20 ChangeRequest 58543: EUP - Delivery Dispatch – Allocation List - VAS
04 Oct 2023 navhl20 ChangeRequest 60033: EUP | Ship Operations in DD - [54176.010] - [Receive] Ship Job List 
*/

vars

begin
	self.buildCmbJobStatus();
