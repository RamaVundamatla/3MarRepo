    <JadeMethod name="doCreateBOL" id="29243c55-48a8-4fc7-858a-87a3d719cf6e">
        <source>doCreateBOL() : String;

// Created by cnwdvb1 on 03 August 2007
/* Basically we are going to produce one docket per dtl. We create a new interface common each time.
This means Owens can mix and match docket common details without having to worry about batching them. */	

vars
	intFaceArray		: CMIF_TIObjectArray;
	intFaceCommon		: CMIF_InOutCommon;
	intFaceItem			: CMIF_BOLIn;
	terminal			: CM_Terminal;
	passport			: CM_Passport;
	err					: CM_Error;
	pos					: Integer;
	area				: CM_TerminalArea;
	location			: CM_LocationsController;
	operator			: CM_Operator;
	areaId,
	lcnId,
	rtnStr				: String;
	tmpQuantity,
	error				: Integer;
	errorStr			: String;
	ticketStr			: String;
	foundLC				: CM_LocationsController;
	foundHeight			: Integer;
	
begin
	app.writeLog(method.name &amp; ' start processing BOL', LogINFO);
	
	passport := app.myPassport;
	terminal := passport.myTerminal;
	
	create intFaceCommon transient;
	
	intFaceCommon.myTerminal					:= terminal;
	intFaceCommon.autoComplete					:= false;
	intFaceCommon.roadTransAreaId				:= terminal.getConfig(DefRoadOpsArea).String.trimRight();
	intFaceCommon.batNumber						:= null;
	intFaceCommon.carrierCode					:= self.carrierCode.toUpper();
	intFaceCommon.driverId						:= self.driverId.toUpper();
	intFaceCommon.regNumber						:= self.vehicle.toUpper();
	intFaceCommon.isReceiptRequired				:= false;
	intFaceCommon.isAttemptMatch				:= self.autoMatch;
	
	create intFaceArray transient;
	create intFaceItem transient;
	
	intFaceItem.setMyInOutCommon(intFaceCommon);
	intFaceItem.transportMode					:= TI_TRANSMODE_ROAD;
	intFaceItem.myTerminal						:= terminal;
	intFaceItem.bolType							:= BOLType_Log;
	intFaceItem.activity						:= self.activity;
	intFaceItem.backload						:= self.backLoad;
	intFaceItem.chhSupplier						:= self.chhSupplier;	
	intFaceItem.consignorCode					:= self.consignorExporter.toUpper();
	intFaceItem.consigneeCode					:= null;
	intFaceItem.sourceLocation					:= self.forest.toUpper();
	intFaceItem.sourceSubLocation				:= self.compartment.toUpper();
	intFaceItem.compartment						:= self.compartment.toUpper();
	intFaceItem.sourceSubSubLocation			:= self.stand.toUpper();
	intFaceItem.isFSC							:= self.isFSC;		// CCMS JML 1105, PAR 21535 Nov 2009
	intFaceItem.operatorCode					:= self.operator.toUpper();
	operator									:= app.myRoot.allOperators[intFaceItem.operatorCode];
	
	if operator = null then
		error := ERR_INVALID_OPERATOR;
		errorStr := app.getErrorString1(ERR_INVALID_OPERATOR, intFaceItem.operatorCode);
		return errorStr;
	endif;
	
	intFaceItem.myOperator						:= operator;
	intFaceItem.customer						:= self.customer;
	intFaceItem.fellDate						:= self.fellDate;
	intFaceItem.gangNumber						:= self.gang;
	intFaceItem.logGradeCode					:= self.grade.toUpper();
	intFaceItem.weightGrossTonnes				:= self.grossWeight;
	intFaceItem.weightNetTonnes					:= self.netWeight;
	intFaceItem.weightTareTonnes				:= self.tareWeight;
	intFaceItem.nightshift						:= self.isNightShift;
	intFaceItem.jasScaled						:= self.jasScaled;
	intFaceItem.lengthRandom					:= self.length.toUpper();
	intFaceItem.loaderNumber					:= self.loaderNumber;
	intFaceItem.handlingContractor2				:= self.loadingContractor;
	intFaceItem.logTypeCode						:= self.logType.toUpper();
	intFaceItem.handlingContractor1				:= self.loggingContractor;
	intFaceItem.loggingOperation				:= self.loggingOperation.toUpper();
	intFaceItem.loggingOrganisation				:= self.loggingOrg.toUpper();
	intFaceItem.numItems						:= self.numItems;
	intFaceItem.bolNumber						:= self.number.toUpper();
	intFaceItem.numberOfLifts					:= self.numberOfLifts;
	intFaceItem.percentScaled					:= self.percentScaled;
	intFaceItem.pickupPoint						:= self.pickupPoint;
	intFaceItem.remarks							:= self.remarks;
	intFaceItem.scalerCode						:= self.scalerCode.toUpper();
	intFaceItem.logSpeciesCode					:= self.species;
	intFaceItem.ticketedAll						:= self.ticketedAll;
	intFaceItem.trailerNumber					:= self.trailerNumber;
	intFaceItem.logTreatmentCode				:= self.treatment.toUpper();
	intFaceItem.truckNumber						:= self.truckNumber;
	intFaceItem.weighbridge						:= self.weighBridge;
	intFaceItem.logLocation						:= self.yardLocation.toUpper();
	intFaceItem.unloadPoint						:= self.unloadPoint;
	intFaceItem.opid							:= self.opid;
	
	terminal.findLocationFromString(self.yardLocation, true, foundLC, foundHeight);
	intFaceItem.myPlannedLocation				:=	foundLC;
	
	if self.yardLocation &lt;&gt; null and foundLC = null then
		pos		:=	1;
		areaId	:=	self.yardLocation.scanUntil(',', pos);
		lcnId	:=	self.yardLocation[pos + 1: end];
		area	:=	terminal.allTerminalAreas[areaId];
		
		if area &lt;&gt; null then
			location := area.getLocationsControllerFromId(lcnId);
		endif;
		
		intFaceItem.myPlannedLocation	:=	location;
	endif;
	
	tmpQuantity := self.numItems;
	foreach ticketStr in self.allTicketSequences do
		self.processTicketSequences(intFaceItem, ticketStr, tmpQuantity);
	endforeach;
	
// cnwdad1 09/10/2009 - PAR #21226.
	if intFaceItem.mySubTerminal = null then
		intFaceItem.setSubTerminalDefault();
	endif;
	
	intFaceArray.add(intFaceItem);
	
	app.writeLog('Before trxCreateInOut', LogINFO);
	//app.myTrxCA.trxCreateInOutVehicle(intFaceCommon, passport);		//cnwmc5 - 22 Jan 2015 - PAR 35518
	app.myTrxCA.trxCreateInOut(intFaceCommon, intFaceArray, passport, null);	//TFS 53107, AjitM, navam1
	
	if passport.trxCompletedOK() then
		app.writeLog('After trxCreateInOut successful', LogINFO); 
		return null;
	else
		app.writeLog('After trxCreateInOut unsuccessful', LogINFO); 
		foreach err in passport.allErrors do
			if rtnStr = null then
				rtnStr	:=	rtnStr &amp; "BOL " &amp; self.number.toUpper() &amp; ", " &amp; err.text;
			else
				rtnStr	:=	rtnStr &amp; ", BOL " &amp; self.number.toUpper() &amp; ", " &amp; err.text;
			endif;
		endforeach;
		if rtnStr.length &gt; 1 then
			app.writeLog(rtnStr, LogINFO);
			return rtnStr;
		endif;
	endif;
	
	return rtnStr;
epilog
	delete intFaceArray;
	delete intFaceCommon;
	delete intFaceItem;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processTicketSequences" id="3821c971-38a5-4bcc-b5dd-c947510a736f">
        <source>processTicketSequences(_intFaceItem : CMIF_BOLIn input; _ticket : String; _remaining : Integer io) protected;

// Created by cnwdvb1 on 08 August 2007

vars

	ticketSeq 	: CM_TicketSequence;
	numFrom,
	numTo,	
	pos,
	qty		: Integer;
	strFrom,
	strTo : String;	
	rtValue : Boolean;
		
begin

	pos := 1;
	strFrom	:= _ticket.scanUntil(',', pos);
	strTo	:= _ticket[pos + 1: end];
	
	if strFrom = null or strTo = null then
		return;
	endif;
	
	numFrom := strFrom.getTrailingInteger();
	numTo := strTo.getTrailingInteger();
	
	if numFrom &gt; numTo then
		//app.raiseCMException(ERR_BASE_NOT_GT_CURRENT, ETRow_FromId, null);
	endif;
	
	qty := (numTo.Integer - numFrom.Integer) + 1;
	
	create ticketSeq transient;

	ticketSeq.setProxy(strFrom, strTo, qty, self.jasScaled);
							//tblItem.getValueByName(ETRow_Scale).Boolean);							 
	
	//self.checkForDuplicateId(ticketSeq);
	_intFaceItem.myTerminal.validateTicketSequence(_intFaceItem.allTicketSequences, ticketSeq);

	_intFaceItem.allTicketSequences.add(ticketSeq);

end;</source>
        <access>protected</access>
        <Parameter name="_intFaceItem" type="CMIF_BOLIn" usage="input"/>
        <Parameter name="_ticket" type="String"/>
        <Parameter name="_remaining" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="770a9df3-d8d7-44e8-b9e4-d426f0122f81">
        <updating/>
        <source>setForCreate(_proxy: CM_RemoteBOLEntryDtl; _realRemoteHdr: CM_RemoteDataHdr) updating;

// Created by cnwdvb1 on 03 August 2007

vars

begin
	inheritMethod(_proxy, _realRemoteHdr);
	
	self.activity				:= _proxy.activity;
	self.autoMatch				:= _proxy.autoMatch;
	self.backLoad				:= _proxy.backLoad;
	self.carrierCode			:= _proxy.carrierCode;
	self.chhSupplier			:= _proxy.chhSupplier;
	self.compartment			:= _proxy.compartment;
	self.consignorExporter		:= _proxy.consignorExporter;
	self.customer				:= _proxy.customer;
	self.driverId				:= _proxy.driverId;
	self.fellDate				:= _proxy.fellDate;
	self.forest					:= _proxy.forest;
	self.gang					:= _proxy.gang;
	self.grade					:= _proxy.grade;
	self.grossWeight			:= _proxy.grossWeight;		
	self.isNightShift			:= _proxy.isNightShift;		
	self.jasScaled				:= _proxy.jasScaled;
	self.length					:= _proxy.length;
	self.loaderNumber			:= _proxy.loaderNumber;
	self.loadingContractor		:= _proxy.loadingContractor;
	self.logType				:= _proxy.logType;
	self.loggingContractor		:= _proxy.loggingContractor;
	self.loggingOperation		:= _proxy.loggingOperation;
	self.loggingOrg				:= _proxy.loggingOrg;
	self.netWeight				:= _proxy.netWeight;
	self.numItems				:= _proxy.numItems;
	self.number					:= _proxy.number;
	self.numberOfLifts			:= _proxy.numberOfLifts;
	self.operator				:= _proxy.operator;
	self.opid					:= _proxy.opid;
	self.percentScaled			:= _proxy.percentScaled;
	self.pickupPoint			:= _proxy.pickupPoint;
	self.remarks				:= _proxy.remarks;
	self.scalerCode				:= _proxy.scalerCode;
	self.species				:= _proxy.species;
	self.stand					:= _proxy.stand;
	self.tareWeight				:= _proxy.tareWeight;
	self.ticketedAll			:= _proxy.ticketedAll;
	self.trailerNumber			:= _proxy.trailerNumber;
	self.treatment				:= _proxy.treatment;
	self.truckNumber			:= _proxy.truckNumber;
	self.unloadPoint			:= _proxy.unloadPoint;
	self.vehicle				:= _proxy.vehicle;
	self.weighBridge			:= _proxy.weighBridge;
	self.yardLocation			:= _proxy.yardLocation;
	
	_proxy.allTicketSequences.copy(self.allTicketSequences);

end;</source>
        <Parameter name="_proxy" type="CM_RemoteBOLEntryDtl"/>
        <Parameter name="_realRemoteHdr" type="CM_RemoteDataHdr"/>
    </JadeMethod>
    <JadeMethod name="setProxyForBOLEntry" id="78b4a6a2-afee-4571-831b-106091c5431a">
        <updating/>
        <source>setProxyForBOLEntry(	_activity, 			
						_autoMatch,			
						_backLoad,			
						_carrierCode,		
						_chhSupplier,		
						_compartment,		
						_consignorExport,	
						_customer,			
						_driverId,			
						_fellDate,			
						_forest,			
						_gang,				
						_grade,				
						_grossWeight,		
						_isNightShift,		
						_jasScaled,
						_length,
						_loaderNumber,
						_loadingContractor,
						_logType,
						_loggingContractor,
						_loggingOperation,
						_loggingOrg,
						_netWeight,
						_numItems,
						_number,
						_numberOfLifts,
						_operator,
						_opid,
						_percentScaled,
						_pickupPoint,
						_remarks,
						_scalerCode,
						_species,
						_stand,
						_fsc,			// CCSM XML 1105, PAR 21535 Nov 2009
						_tareWeight,
						_ticketedAll,
						_trailerNumber,
						_treatment,
						_truckNumber,
						_unloadPoint,
						_vehicle,
						_weighBridge,
						_yardLocation		: String;
						_ticketSequences	: StringArray input;
						_remoteHeader 		: CM_RemoteDataHdr) updating;

// Created by cnwdvb1 on 03 August 2007

vars

begin

	self.activity				:= _activity;
	self.autoMatch				:= _autoMatch.Boolean;
	self.backLoad				:= _backLoad;
	self.carrierCode			:= _carrierCode;
	self.chhSupplier			:= _chhSupplier;
	self.compartment			:= _compartment;
	self.consignorExporter		:= _consignorExport;
	self.customer				:= _customer;
	self.driverId				:= _driverId;
	self.fellDate				:= self.convertDate(_fellDate);
	self.forest					:= _forest;
	self.gang					:= _gang;
	self.grade					:= _grade;
	self.grossWeight			:= _grossWeight.Real;		
	self.isNightShift			:= _isNightShift.Boolean;		
	self.jasScaled				:= _jasScaled.Boolean;
	self.length					:= _length;
	self.loaderNumber			:= _loaderNumber;
	self.loadingContractor		:= _loadingContractor;
	self.logType				:= _logType;
	self.loggingContractor		:= _loggingContractor;
	self.loggingOperation		:= _loggingOperation;
	self.loggingOrg				:= _loggingOrg;
	self.netWeight				:= _netWeight.Real;
	self.numItems				:= _numItems.Integer;
	self.number					:= _number;
	self.numberOfLifts			:= _numberOfLifts.Integer;
	self.operator				:= _operator;
	self.opid					:= _opid;
	self.percentScaled			:= _percentScaled.Integer;
	self.pickupPoint			:= _pickupPoint;
	self.remarks				:= _remarks;
	self.scalerCode				:= _scalerCode;
	self.species				:= _species;
	self.stand					:= _stand;
	self.isFSC					:= _fsc.Boolean;		// CCMS JML 1105, PAR 21535 Nov 2009
	self.tareWeight				:= _tareWeight.Real;
	self.ticketedAll			:= _ticketedAll.Boolean;
	self.trailerNumber			:= _trailerNumber;
	self.treatment				:= _treatment;
	self.truckNumber			:= _truckNumber;
	self.unloadPoint			:= _unloadPoint;
	self.vehicle				:= _vehicle;
	self.weighBridge			:= _weighBridge;
	self.yardLocation			:= _yardLocation;
	
	if _ticketSequences &lt;&gt; null then
		_ticketSequences.copy(self.allTicketSequences);
	endif;
	
	self.setProxy(_remoteHeader);
	

end;</source>
