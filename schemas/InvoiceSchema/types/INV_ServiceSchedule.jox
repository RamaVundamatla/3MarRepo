    <JadeMethod name="doQuery" id="40e49134-c011-4986-afcd-e6472a0bb0e3">
        <updating/>
        <source>doQuery() updating, protected;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin

	// ### TFS 51912 14Sep2021 NAVPW1
	if(txtFilterBox.text &lt;&gt; "") then
		self.loadServiceSchedule(true);
	else
		self.loadServiceSchedule(false);
	endif;
	// ### TFS 51912 14Sep2021 NAVPW1
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="a27af287-0311-4ed2-8696-339c48bd5618">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 08 May 2025 navrv30	MTN 34672: MTN | Multigroup Selection Filter Phase 3
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod();
	
	self.lstPropFour.move(0,0,self.lstPropFour.parent.width,self.lstPropFour.parent.height + 20);	
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="ee2ddfb9-5a12-46bf-8c3b-f9d0667a119f">
        <updating/>
        <source>doSave() updating, protected;
// save code for save and save/next
vars
	ls : Boolean;
	theReturn : Integer;
	realService, pxyService : CM_ServiceObject;
begin
	if self.updateMode = self.UpdateMode_New then
		if self.modePropertyNew = self.MODEPROPERTY_SERVICE then
			create pxyService as CM_Service transient;
		else
			create pxyService as CM_ServiceGroup transient;
		endif;			
	else
		app.cmsBeginLoad(ls);
		pxyService := app.createUpdateProxy(self.myCurrentServiceObject).CM_ServiceObject;
		app.cmsEndLoad(ls);
	endif;
	
	self.doSetProxyFromTable(pxyService);
	
	while true do
		if self.updateMode = self.UpdateMode_New then
			app.myTrxCA.trxCreateServiceObject(pxyService,realService,app.myPassport);
		else
			app.myTrxUA.trxUpdateServiceObject(pxyService,app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Service Schedule", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
	self.frmProperties.visible := false;
	self.frmToolbar.enabled := true;
	self.lstData.enabled := true;
epilog
	app.cmsEndLoad(ls);
	delete pxyService;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSetProxyFromTable" id="967b534a-a3a1-404f-b4c5-b36b8b0c9f7f">
        <updating/>
        <source>doSetProxyFromTable(_pxy : CM_ServiceObject input) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 29/3/22  jlier1	TFS 53286
// 23/8/22	navkc1 	ChangeRequest #54569 - Add Service Types
vars
	notAvailable	: Boolean;

	rateType : Integer;
	rootSG, tmpSG : CM_ServiceGroup;
begin
	rootSG := self.myCurrentBank.getRootServiceGroup();
	if self.myCurrentServiceGroup = null then
		self.myCurrentServiceGroup := rootSG;
	endif;
	
	if self.myCurrentServiceObject = null then // PAR 31657
		self.myCurrentServiceObject := rootSG;
	endif;

	if self.myCurrentServiceObject.isKindOf(CM_Service) 
	or self.modePropertyNew = self.MODEPROPERTY_SERVICE then
		rateType := self.cmbRateTypes.itemData[self.cmbRateTypes.listIndex];
	else
		if self.myCurrentServiceObject.CM_ServiceGroup = rootSG then
			self.myCurrentServiceGroup := rootSG;
		endif;
	endif;
	tmpSG := self.myCurrentServiceGroup;
	notAvailable := false;
	if myCurrentServiceObject.class.name = CM_Service.name then		// just CM_Service itself, not service groups or CM_VoidService
		notAvailable := self.tblProperties.getValueByName(ETRow_IsNotAvailableForEntryCk).Boolean;
	endif;
	
	if self.updateMode = self.UpdateMode_Update 
	and self.modePropertyUpdate = self.MODEPROPERTY_GROUP then
		tmpSG := null;
	endif;
	
	_pxy.setProxy(self.tblProperties.getValueByName(ETRow_Name60).String,
					self.myCurrentBank,
					self.tblProperties.getValueByName(ETRow_Remarks).String,
					self.cmbGL.listObject.CM_GLCode,
					tmpSG,
					rateType,
					self.cmbCalcTypes.listObject.CM_CalculationType,
					self.cmbTaxCode.listObject.CM_TaxCode,
					notAvailable,self.tblProperties.getValueByName(ETRow_ExternalReference1).String,self.tblProperties.getValueByName(ETRow_ExternalReference2).String,
					null); // 23/08/22	navkc1	#54569
	
end;</source>
        <Parameter name="_pxy" type="CM_ServiceObject" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblExtraDClick" id="97eff3e3-32d8-4bd1-ab35-bc24babe12c7">
        <updating/>
        <source>doTblExtraDClick(_table: CM_DataTable input) updating;
// 24024 show calculation type or quantity hook code
vars
	obj	: Object;
begin
	obj := _table.accessCell(_table.row, _table.column).itemObject;
	if obj &lt;&gt; null then
		if obj.isKindOf(CM_CalculationType) then
			self.myAssistant.showTableViewForm(obj.CM_Object, PmAdmInvCalcTypesView, self.myMasterMenuAction, true, false);
		elseif obj.isKindOf(CM_HookCode) then
			self.showHookCodeMaintForm();
		endif;
	endif;
	
end;
</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doUpdate" id="bbc3310d-7b70-4662-ae31-36612e3f75e1">
        <updating/>
        <source>doUpdate() updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 29/3/22  jlier1	TFS 53286
// 16/06/2022	jlizm1	52495 Disable editing of void service and invoice lines
// 22/08/2022	navkc1	ChangeRequest 54569: Use the same new form for Edit mode
vars
	invoiceForm		: INV_NewService;
begin
	if not  global.isValidObject(self.myCurrentServiceObject) then
		global.beep;
		return;
	endif;
	
	if self.myCurrentServiceObject.isKindOf(CM_VoidService) then
		// should not be able to edit void service
		return;
	endif;
	
	self.setUpdateMode(self.UpdateMode_Update);
	self.modePropertyNew := null;

	if self.myCurrentServiceObject.isKindOf(CM_Service) then
		self.modePropertyUpdate := self.MODEPROPERTY_SERVICE;
		//self.showPropertyFrame(null, null,null);	// 22/08/2022	navkc1	#54569
		
		// 22/08/2022	navkc1	#54569 --&gt; 
		invoiceForm := app.loadForm(INV_NewService, INV_Assistant, false, false, false, self.myTerminal, null).INV_NewService;

		if invoiceForm = null then
			return;
		endif;
		
		invoiceForm.createMyAssistant(INV_Assistant);
		invoiceForm.mode 					:= self.UpdateMode_Update;
		invoiceForm.myCurrentServiceObject 	:= self.myCurrentListObject.CM_Service;
		invoiceForm.myCurrentBank			:= self.myCurrentListObject.CM_Service.bank;
		invoiceForm.myCurrentServiceGroup 	:= self.myCurrentListObject.CM_Service.group;
		invoiceForm.btnNext.visible			:= false;
		invoiceForm.btnNext.enabled 		:= false;
		invoiceForm.grpInvoiceLine.visible 	:= false;
		invoiceForm.grpInvoiceLine.enabled 	:= false;
		
		invoiceForm.showModal();
		// 22/08/2022	navkc1	#54569 &lt;--
	else
		self.modePropertyUpdate := self.MODEPROPERTY_GROUP;
		self.showPropertyFrame(null, null,null);
	endif;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="doUpdateFromDrag" id="967a795f-06ef-4f92-a29c-c2c6f815d4ab">
        <updating/>
        <source>doUpdateFromDrag(_source : CM_ServiceObject; _target : CM_ServiceGroup) updating;
// ---------------------------------------------------------------------------
// Created:		23 July 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 29/3/22  jlier1	TFS 53286
// 23/8/22	navkc1 	ChangeRequest #54569 - Add Service Types
vars
	ls : Boolean;
	theReturn : Integer;
	pxyService : CM_ServiceObject;
begin
	self.updateMode := self.UpdateMode_Update;
	
	app.cmsBeginLoad(ls);
	pxyService := app.createUpdateProxy(_source).CM_ServiceObject;
	app.cmsEndLoad(ls);
	
	pxyService.setProxy(_source.name,
					_source.bank,
					_source.remarks,
					_source.genLCode,
					_target,
					_source.CM_Service.defaultRateTable,
					_source.CM_Service.myCalculationType,
					_source.myTaxCode,
					_source.isNotAvailableForEntry,null,null,
					null); // 23/08/22	navkc1	#54569
	
	while true do
		app.myTrxUA.trxUpdateServiceObject(pxyService,app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Service Schedule", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
	self.frmProperties.visible := false;
	self.frmToolbar.enabled := true;
	self.lstData.enabled := true;
	self.doQuery();
epilog
	app.cmsEndLoad(ls);		// 08/04/2011 cnwmh5 #27347
	delete pxyService;

end;</source>
        <Parameter name="_source" type="CM_ServiceObject"/>
        <Parameter name="_target" type="CM_ServiceGroup"/>
    </JadeMethod>
    <JadeMethod name="doUserNote" id="6b3e69f2-2593-44be-9fbc-68fd9fc338d5">
        <updating/>
        <source>doUserNote(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	event : Integer;
	theServiceObject : CM_ServiceObject;
	idx,idy,level, itemLevel, idxSt, idxEnd, newIdx : Integer;
	name	: String;
begin
	inheritMethod(eventType, theObject, eventTag, userInfo);

	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	theServiceObject := userInfo.CM_ServiceObject;
	
	if event = EVENT_SERVICE_DELETE then
		idx := self.lstData.findObject(theServiceObject);
		if idx &gt; 0 then
			self.lstData.removeItem(idx);
		endif;
		return;
	endif;
	

	if event = EVENT_SERVICE_CREATE then
		// ## insert the new ServiceObject by finding the group then insert under that.
		idx := self.lstData.findObject(theServiceObject.group);
		if idx &gt; 0 then
			level := self.lstData.itemLevel[idx] + 1;
			newIdx := 0;
			// ## insert alphabetically under parent.
			idxSt := idx + 1;
			idxEnd := self.lstData.listCount();
			foreach idy in idxSt to idxEnd do
				itemLevel := self.lstData.itemLevel[idy];
				if itemLevel = level then
					if self.lstData.itemText[idy] &gt; theServiceObject.name  then
						newIdx := idy;
						break;
					endif;
				elseif itemLevel &lt; level then
					newIdx := idy;
					break;
				endif;

			endforeach;
			if newIdx = 0 then
				newIdx := idxEnd + 1;
			endif;
//			theServiceObject.loadListSubAt(self.lstData,level,newIdx);
			self.loadListBoxObjectAt(theServiceObject,level,newIdx);
		endif;
	elseif event = EVENT_SERVICE_UPDATE then
		idx := self.lstData.findObject(theServiceObject);
		if idx &gt; 0 then
			name := theServiceObject.name;
			if theServiceObject.isKindOf(CM_Service) then
				if theServiceObject.CM_Service.myCalculationType &lt;&gt; null and
				   theServiceObject.CM_Service.myCalculationType.myHookCodeRate &lt;&gt; null then
					name := name &amp; " (" &amp; app.getErrorString(Rate_hook_code) &amp; ")";
				endif;
			endif;
			self.lstData.itemText[idx] := name ;
		endif;
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="loadGLCodes" id="5260b565-b862-44e8-a9b9-65337ffdf169">
        <source>loadGLCodes();
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	idx		: Integer;	
	aGL : CM_GLCode;
begin
	self.lstPropFour.rows := 0;
	self.lstPropFour.allSelectedObjects.clear;
	
	foreach aGL in self.myCurrentBank.glCodes where not aGL.isNotAvailableForEntry do
		idx := self.lstPropFour.addItemObject(aGL.code &amp; " - " &amp; aGL.remarks,aGL);
	endforeach;
	self.lstPropFour.accessColumn(2).width := self.lstPropFour.clientWidth - self.lstPropFour.accessColumn(1).width;


end;</source>
    </JadeMethod>
    <JadeMethod name="loadListBoxObject" id="45db98de-c4d0-411b-9213-59368baebd3f">
        <source>loadListBoxObject(_service: CM_ServiceObject; _level: Integer; _expanded: Boolean); // ### TFS 51912 14Sep2021 NAVPW1 Added Boolean
// ---------------------------------------------------------------------------
// Created:		July 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	filterText		: String; // ### TFS 51912 14Sep2021 NAVPW1
	name			: String;
	theListBox		: ListBox;
	servMem 		: CM_ServiceObject;
	
begin

	theListBox := self.lstData;
	filterText := self.txtFilterBox.text.toUpper(); // ### TFS 51912 16Sep2021 NAVPW1
	
	//Using level so we do not filter root service group
	// ### TFS 51912 14Sep2021 NAVPW1
	if (_level &gt; 1 and filterText &lt;&gt; "") then
		if ( _service.isKindOf(CM_ServiceGroup)) then //If this is a service group we need to check if we need to display it
			if (checkServiceGroupNeeded(_service, filterText) = false) then //Lookahead to see if we need the service group. If not then don't add it
				return;
			endif;
		elseif (_service.name.toUpper().pos(filterText, 1) &lt; 1) then //Check if service does not match filter then do not display it
			return;
		endif;
	endif;
	// ### TFS 51912 14Sep2021 NAVPW1
	
	name := _service.name;
	if _service.isKindOf(CM_Service) then
		if _service.CM_Service.myCalculationType &lt;&gt; null and
		   _service.CM_Service.myCalculationType.myHookCodeRate &lt;&gt; null then
			name := name &amp; " (" &amp; app.getErrorString(Rate_hook_code) &amp; ")";
		endif;
	endif;
	theListBox.addItem(name);
	theListBox.itemObject[theListBox.newIndex] := _service;
	theListBox.itemLevel[theListBox.newIndex] := _level;
	theListBox.itemExpanded[theListBox.newIndex] := _expanded; // ### TFS 51912 14Sep2021 NAVPW1
	
	if _service.isKindOf(CM_ServiceGroup) then
		theListBox.itemPicture[theListBox.newIndex] := self.picServiceGroup.picture;
		
		foreach servMem in _service.CM_ServiceGroup.groupMembers do
			if servMem = _service then
				continue;
			endif;
			self.loadListBoxObject(servMem, _level+1, _expanded); // ### TFS 51912 14Sep2021 NAVPW1
		endforeach;
	else

		if _service.CM_Service.myCalculationType = null then
			theListBox.itemPicture[theListBox.newIndex] := self.picService.picture;
		elseif _service.CM_Service.myCalculationType.isCargoCalcType then
			theListBox.itemPicture[theListBox.newIndex] := self.picService.picture;
		elseif _service.CM_Service.myCalculationType.isVoyageCalcType then
			theListBox.itemPicture[theListBox.newIndex] := self.picServiceVTMIS.picture;
		elseif _service.CM_Service.myCalculationType.isWorkOrderType then // TFS 39198
			theListBox.itemPicture[theListBox.newIndex] := self.picServiceVTMIS.picture; // TFS 39198
		elseif _service.CM_Service.myCalculationType.isEventCalcType then
			theListBox.itemPicture[theListBox.newIndex] := self.picServiceEvent.picture;
		elseif _service.CM_Service.myCalculationType.isInventoryType then // ### TFS 51219 28MAY2021 NAVAB1
			theListBox.itemPicture[theListBox.newIndex] := self.picServiceInventory.picture; // ### TFS 51219 28MAY2021 NAVAB1
		elseif _service.CM_Service.myCalculationType.isBolCalcType then	// 31 Oct 2019	NDL	TFS 47100
			theListBox.itemPicture[theListBox.newIndex] := self.picServiceBol.picture;	// 31 Oct 2019	NDL	TFS 47100
		endif;	
	
	endif;
end;</source>
        <Parameter name="_service" type="CM_ServiceObject"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_expanded" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadListBoxObjectAt" id="082df2c5-c334-4079-b429-b3d4792aa2ee">
        <source>loadListBoxObjectAt(_service: CM_ServiceObject; _level: Integer; _at : Integer);
// ---------------------------------------------------------------------------
// Created:		July 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	name: String;
	aServ : CM_Service;
	theListBox: ListBox;
begin

	theListBox := self.lstData;
	name := _service.name;
	if _service.isKindOf(CM_Service) then
		if _service.CM_Service.myCalculationType &lt;&gt; null and
		   _service.CM_Service.myCalculationType.myHookCodeRate &lt;&gt; null then
			name := name &amp; " (" &amp; app.getErrorString(Rate_hook_code) &amp; ")";
		endif;
	endif;
	
	if _at &gt; 0 then
		theListBox.addItemAt(name,_at);
	else
		theListBox.addItem(name);
	endif;
	theListBox.itemObject[theListBox.newIndex] := _service;

	if _service.isKindOf(CM_Service) then
		aServ := _service.CM_Service;
		if aServ.myCalculationType = null then
			theListBox.itemPicture[theListBox.newIndex] := theListBox.form.INV_ServiceSchedule.picService.picture;
		elseif aServ.myCalculationType.isInventoryType then // ### TFS 51219 28MAY2021 NAVAB1
			theListBox.itemPicture[theListBox.newIndex] := theListBox.form.INV_ServiceSchedule.picServiceInventory.picture; // ### TFS 51219 28MAY2021 NAVAB1
		elseif aServ.myCalculationType.isCargoCalcType then
			theListBox.itemPicture[theListBox.newIndex] := theListBox.form.INV_ServiceSchedule.picService.picture;
		elseif aServ.myCalculationType.isVoyageCalcType then
			theListBox.itemPicture[theListBox.newIndex] := theListBox.form.INV_ServiceSchedule.picServiceVTMIS.picture;
		elseif aServ.myCalculationType.isWorkOrderType then // TFS 39198
			theListBox.itemPicture[theListBox.newIndex] := theListBox.form.INV_ServiceSchedule.picServiceVTMIS.picture; // TFS 39198
		elseif aServ.myCalculationType.isBolCalcType then // 31 Oct 2019	NDL	TFS 47100
			theListBox.itemPicture[theListBox.newIndex] := theListBox.form.INV_ServiceSchedule.picServiceBol.picture; // 31 Oct 2019	NDL	TFS 47100
		else
			theListBox.itemPicture[theListBox.newIndex] := theListBox.form.INV_ServiceSchedule.picServiceEvent.picture;
		endif;	
	else
		theListBox.itemPicture[theListBox.newIndex] := theListBox.form.INV_ServiceSchedule.picServiceGroup.picture;
	endif;

	theListBox.itemLevel[theListBox.newIndex] := _level;

end;</source>
        <Parameter name="_service" type="CM_ServiceObject"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_at" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadServiceSchedule" id="8ad0583e-57d9-4969-b05b-06ec3aa4c3be">
        <updating/>
        <source>loadServiceSchedule(_expanded: Boolean) updating; // ### TFS 51912 14Sep2021 NAVPW1 Added Boolean
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	rootSG : CM_ServiceGroup;
begin
	rootSG := self.myCurrentBank.getRootServiceGroup();

	self.lstData.clear;
	self.loadListBoxObject(rootSG, 1, _expanded); // ### TFS 51912 14Sep2021 NAVPW1
	
	self.lstData.itemExpanded[1] := true;

end;</source>
        <Parameter name="_expanded" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="lstDataMouseMoveEvent" id="804a0785-6682-41c4-a05f-44015b9eac05">
        <updating/>
        <source>lstDataMouseMoveEvent(button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     26 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	
	if self.myCurrentServiceObject = null then
		app.msgBox('Select a Service, to move.','Make Selection', MsgBox_Information_Icon + MsgBox_OK_Only);
		return;
	endif;

	self.lstData.dragCursor := self.picCursorDrag.picture;

	self.dragMode := DragMode_Drag;	
	self.dragCursor := self.lstData.dragCursor;

end;</source>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
