    <JadeMethod name="setRemarks" id="d465a1d4-294b-40e6-9848-ddd768a54960">
        <updating/>
        <source>setRemarks(_theRemarks : String) updating;
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

	theAutoRemarks,
	theRemarks : String;

begin

	theAutoRemarks := self.getAutoRemarks();
	if theAutoRemarks = null and _theRemarks = null then
		self.remarks := null;
	elseif theAutoRemarks = null then
		self.remarks := _theRemarks;
	elseif _theRemarks = null then
		self.remarks := theAutoRemarks;
	else
		if _theRemarks.pos(theAutoRemarks, 1) &gt; 0 then
			//already includes auto remarks
			self.remarks := _theRemarks;
		else
			self.remarks := theAutoRemarks &amp; '; ' &amp; _theRemarks;
		endif;
	endif;

end;</source>
        <Parameter name="_theRemarks" type="String"/>
    </JadeMethod>
    <JadeMethod name="setRequestSeqNumberSingle" id="07b635c4-da87-4b00-9336-57109182b50b">
        <source>setRequestSeqNumberSingle(_portDict, _starboardDict : Dictionary) protected;
// -------------------------------------------
// Created 29 August 2005 by cnwdvb1
// -------------------------------------------
vars

	obj				: Object;
	number			: Integer;
	last,
	cmif			: CMIF_CustomSequenceObject;
	isTwinLift,
	isSameSeqReq	: Boolean;
	over40,
	under40,
	under,
	over			: Integer;

begin
	
	// Get configuration once.
	over := ((self.myTerminal.getConfig(StartSeqNum20_OverDeck).Integer) - 1).max(0);
	under := ((self.myTerminal.getConfig(StartSeqNum20_UnderDeck).Integer) - 1).max(0);
	over40 := ((self.myTerminal.getConfig(StartSeqNum40_OverDeck).Integer) - 1).max(0);
	under40 := ((self.myTerminal.getConfig(StartSeqNum40_UnderDeck).Integer) - 1).max(0);
	
	// Port dictionary. Just send in the number and the config in the right order.
	foreach obj in _portDict do
		cmif := obj.CMIF_CustomSequenceObject;
		number := number + 1;
		cmif.myRequest.setSeqNumDefSingle(number, over, under, over40, under40, false);
	endforeach;
	
	// Reset
	number := 0;
	last := null;
	
	// Starboard dictionary. Just send in the number and the config in the right order.
	foreach obj in _starboardDict do
		cmif := obj.CMIF_CustomSequenceObject;
		number := number + 1;
		cmif.myRequest.setSeqNumDefSingle(number, over, under, over40, under40, true);
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_portDict" type="Dictionary"/>
        <Parameter name="_starboardDict" type="Dictionary"/>
    </JadeMethod>
    <JadeMethod name="setRequestSeqNumberSingleFirst" id="5a6a8912-79eb-4e58-9055-6ce6ec49ced2">
        <source>setRequestSeqNumberSingleFirst(_portDict, _starboardDict : ObjectArray) protected;
// ---------------------------------------------------------------------------
// Created:     July 2008 ANDREW BISHOP
//
// Purpose:     Take the slots in a predefined order and renumber them
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 21JUL2008		CNWAB1			Created for PAR 17412
// ---------------------------------------------------------------------------

vars
	obj						: Object;
	over					: Integer;
	under					: Integer;
	under40					: Integer;
	over40					: Integer;
	seqNumber				: Integer;
	lastCSO					: CMIF_CustomSequenceObject;
	currentCSO				: CMIF_CustomSequenceObject;
	isTwinLift				: Boolean;
	isAllocateCraneLane		: Boolean;
	isSameSeqReq			: Boolean;
	nextCraneId, maxLiftWeightTL				: Integer;
	terminal				: CM_Terminal;
	shipSLiftIfDiffHeights, shipSLiftIfTLWgtExced, boldLine				: Boolean;
	slotRequestObj			: CM_SlotRequest;
	aCrane : CM_Crane;
	
begin
	terminal := app.getMyTerminalDO_NOT_USE();
	// Get configuration once.
	over := ((terminal.getConfig(StartSeqNum20_OverDeck).Integer) - 1).max(0);
	under := ((terminal.getConfig(StartSeqNum20_UnderDeck).Integer) - 1).max(0);
	over40 := ((terminal.getConfig(StartSeqNum40_OverDeck).Integer) - 1).max(0);
	under40 := ((terminal.getConfig(StartSeqNum40_UnderDeck).Integer) - 1).max(0);
	
	foreach obj in _portDict do
		currentCSO	:=	obj.CMIF_CustomSequenceObject;
		
		// Set request.
		slotRequestObj	:=	currentCSO.myRequest;
		seqNumber := seqNumber + 1;
		slotRequestObj.setSeqNumDefSingle(seqNumber, over, under, over40, under40, false);
	endforeach;
	
	// Reset.
	seqNumber	:=	0;
	
	// Starboard sorting see above for detail.
	foreach obj in _starboardDict do
		currentCSO	:=	obj.CMIF_CustomSequenceObject;
		// Set request.
		slotRequestObj	:=	currentCSO.myRequest;
		seqNumber := seqNumber + 1;
		slotRequestObj.setSeqNumDefSingle(seqNumber, over, under, over40, under40, true);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_portDict" type="ObjectArray"/>
        <Parameter name="_starboardDict" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="setRequestSeqNumberTwin" id="7bf5ac07-e6e8-4d21-b83d-b253c1562591">
        <source>setRequestSeqNumberTwin(_portDict, _starboardDict : ObjectArray) protected;//Dictionary);
// -------------------------------------------
// Created 29 August 2005 by cnwdvb1
// -------------------------------------------
vars
	obj						: Object;
	over					: Integer;
	under					: Integer;
	under40					: Integer;
	over40					: Integer;
	seqNumber				: Integer;
	lastCSO					: CMIF_CustomSequenceObject;
	currentCSO				: CMIF_CustomSequenceObject;
	isTwinLift				: Boolean;
	isAllocateCraneLane		: Boolean;
	isSameSeqReq			: Boolean;
	nextCraneId, maxLiftWeightTL				: Integer;
	shipSLiftIfDiffHeights, shipSLiftIfTLWgtExced, boldLine				: Boolean;
	slotRequestObj			: CM_SlotRequest;
	aCrane : CM_Crane;
	maxTwinLiftDiff : Integer;
	maxTwinLiftDiffSource : String;
	
begin
	
	
	// Get configuration values.
	isSameSeqReq := self.myTerminal.getConfig(SameSeqNumberTwinLift).Boolean;
	isAllocateCraneLane := self.myTerminal.getConfig(AllocateCraneLane).Boolean;
	over := ((self.myTerminal.getConfig(StartSeqNum20_OverDeck).Integer) - 1).max(0);
	under := ((self.myTerminal.getConfig(StartSeqNum20_UnderDeck).Integer) - 1).max(0);
	over40 := ((self.myTerminal.getConfig(StartSeqNum40_OverDeck).Integer) - 1).max(0);
	under40 := ((self.myTerminal.getConfig(StartSeqNum40_UnderDeck).Integer) - 1).max(0);
	shipSLiftIfTLWgtExced := self.myTerminal.getConfig(ShipSLiftIfTLWgtExced).Boolean; // 'Make S/Lift if crane twin lift weight exceeded'
	shipSLiftIfDiffHeights := self.myTerminal.getConfig(ShipSLiftIfDiffHeights).Boolean;
	
//	aCrane := self.getJobCrane();
//	if aCrane &lt;&gt; null then
//		maxLiftWeightTL := aCrane.maxLiftWeightTL;
//	endif;
	
	self.getWeightValidationValues( maxTwinLiftDiffSource, aCrane, maxLiftWeightTL, maxTwinLiftDiff);	//15 June 2010	NDL	Par 24108
		

	// Port sort.
	boldLine := true;
	
	foreach obj in _portDict do
		currentCSO	:=	obj.CMIF_CustomSequenceObject;
		// Is the last object match up for a twin lift with the current.
		isTwinLift	:=	currentCSO.isTwinLift(lastCSO, shipSLiftIfTLWgtExced, maxLiftWeightTL, shipSLiftIfDiffHeights, maxTwinLiftDiff);
		
		if isTwinLift then
			// Retro fit twin lift to last object.
			lastCSO.myRequest.setTwinLift(true, false);
			// Do we want a new sequence number.
			if not isSameSeqReq then
				seqNumber	:=	seqNumber + 1;
			endif;
			
		else
			boldLine := not boldLine;
			// Not a twin lift so we want a crane cage if system is configured for one.
			nextCraneId := self.getNextCraneLaneForTwin(isAllocateCraneLane, nextCraneId);
			// Next sequence number.
			seqNumber	:=	seqNumber + 1;
			
		endif;
		
		// Set request.
		slotRequestObj	:=	currentCSO.myRequest;
//		currentCSO.myRequest.setSeqNumDefTwin(seqNumber, over, under, over40, under40, false, isTwinLift, boldLine, nextCraneId);
		slotRequestObj.setSeqNumDefTwin(seqNumber, over, under, over40, under40, false, isTwinLift, boldLine, nextCraneId);
		
		lastCSO	:=	currentCSO;
		
	endforeach;
	
	// Reset.
	seqNumber	:=	0;
	lastCSO		:=	null;
	nextCraneId	:=	0;
	
	// Starboard sorting see above for detail.
	foreach obj in _starboardDict do
		currentCSO	:=	obj.CMIF_CustomSequenceObject;
		isTwinLift	:=	currentCSO.isTwinLift(lastCSO, shipSLiftIfTLWgtExced, maxLiftWeightTL, shipSLiftIfDiffHeights, maxTwinLiftDiff);
		
		if isTwinLift then
			lastCSO.myRequest.setTwinLift(true, true);
			if not isSameSeqReq then
				seqNumber	:=	seqNumber + 1;
			endif;
		else	
			nextCraneId :=  self.getNextCraneLaneForTwin(isAllocateCraneLane, nextCraneId);
			seqNumber	:=	seqNumber + 1;
		endif;
		
		slotRequestObj	:=	currentCSO.myRequest;
//		cmif.myRequest.setSeqNumDefTwin(seqNumber, over, under, over40, under40, true, isTwinLift, false, nextCraneId);
		slotRequestObj.setSeqNumDefTwin(seqNumber, over, under, over40, under40, true, isTwinLift, false, nextCraneId);
		lastCSO	:=	currentCSO;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_portDict" type="ObjectArray"/>
        <Parameter name="_starboardDict" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="setRequestSeqNumbers" id="53899a28-3551-4a12-9665-72a8a77d1d6b">
        <updating/>
        <source>setRequestSeqNumbers(_theJobParams:CMIF_VoyageJobParams) updating; //PAR 18414 added 'updating'

// ##########################
// PAR 19416/18416 _theJobParams can be NULL
// ##########################



/* This method sets up the twin and single lift sequencing using dynamic dictionaries. */
vars
	isDischarge					: Boolean;
	requestObj					: CM_Request;
	dynaStarboardSingle			: DynaDictionary;
	dynaPortSingle				: DynaDictionary;
	dynaStarboardTwin			: DynaDictionary;
	dynaPortTwin				: DynaDictionary;
	sortObj						: CMIF_CustomSequenceObject;
	seqPortDischarge			: String;
	seqStarboardDischarge		: String;
	seqPortLoad					: String;
	seqStarboardLoad			: String;
	ordinalBay					: String;
	fortyFooter					: String;
	ordinalDeck					: String;
	useSeperateLength			: Boolean;
	allPortLiftsObj				: CMIF_CustomSequenceObjectArray;
	allStarboardLiftsObj		: CMIF_CustomSequenceObjectArray;
	allSlotsByBayDeckTierCell	: CM_SlotReqByBayDeckTierCell;
	isSeqForJob : Boolean;
begin
	exclusiveLock(self);

	// Work out what type of job we are dealing with.
	if self.jobType = JOB_TYPE_DISCHARGE or self.jobType = JOB_TYPE_SOB then
		isDischarge	:=	true;
	elseif self.jobType = JOB_TYPE_LOAD then
		isDischarge	:=	false;
	else
		return;
	endif;
	
	// Do we want to split the 20s and 40s out?
	useSeperateLength := self.myTerminal.getConfig(SeperateLengthSequencing).Boolean;
	
	// Grab the attribute names that will be used in the sort.
	seqPortDischarge		:= CMIF_CustomSequenceObject::tmpPortDischargeSeq.name;
	ordinalBay				:= CMIF_CustomSequenceObject::mySlotController.name &amp; '.' &amp; CM_SlotController::myBayVoyage.name &amp; '.' &amp; CM_BayVoyage::ordinalBay.name;
	seqStarboardDischarge	:= CMIF_CustomSequenceObject::tmpStarDischargeSeq.name;
	seqPortLoad				:= CMIF_CustomSequenceObject::tmpPortLoadSeq.name;
	seqStarboardLoad		:= CMIF_CustomSequenceObject::tmpStarLoadSeq.name;
	fortyFooter				:= CMIF_CustomSequenceObject::is40.name;
	
	ordinalDeck				:= CMIF_CustomSequenceObject::mySlotController.name &amp; '.' &amp; CM_SlotController::ordinalDeck.name; 
	
	create dynaPortTwin transient;
	create dynaStarboardTwin transient;
	create dynaPortSingle transient;
	create dynaStarboardSingle transient;
	
	// Set the membership of all dyna dicts.
	dynaPortTwin.setMembership(CMIF_CustomSequenceObject);
	dynaStarboardTwin.setMembership(CMIF_CustomSequenceObject);
	dynaPortSingle.setMembership(CMIF_CustomSequenceObject);
	dynaStarboardSingle.setMembership(CMIF_CustomSequenceObject);
	
	// Add keys in appropriate order for each senario.
	if isDischarge then	
		dynaPortTwin.addMemberKey(ordinalDeck, true, false);
		if useSeperateLength then
			dynaPortTwin.addMemberKey(fortyFooter, true, false);
		endif;
		dynaPortTwin.addMemberKey(seqPortDischarge, false, false);
		dynaPortTwin.addMemberKey(ordinalBay, false, false);
		dynaPortTwin.endKeys(false);	
	
		dynaStarboardTwin.addMemberKey(ordinalDeck, true, false);
		if useSeperateLength then
			dynaStarboardTwin.addMemberKey(fortyFooter, true, false);
		endif;
		dynaStarboardTwin.addMemberKey(seqStarboardDischarge, false, false);
		dynaStarboardTwin.addMemberKey(ordinalBay, false, false);
		dynaStarboardTwin.endKeys(false);	
		
		
		dynaPortSingle.addMemberKey(ordinalDeck, true, false);
		dynaPortSingle.addMemberKey(ordinalBay, false, false);
		if useSeperateLength then
			dynaPortSingle.addMemberKey(fortyFooter, true, false);
		endif;
		dynaPortSingle.addMemberKey(seqPortDischarge, false, false);
		dynaPortSingle.endKeys(false);	

		dynaStarboardSingle.addMemberKey(ordinalDeck, true, false);
		dynaStarboardSingle.addMemberKey(ordinalBay, false, false); 
		if useSeperateLength then
			dynaStarboardSingle.addMemberKey(fortyFooter, true, false);
		endif;
		dynaStarboardSingle.addMemberKey(seqStarboardDischarge, false, false);
		dynaStarboardSingle.endKeys(false);	
	else
		dynaPortTwin.addMemberKey(ordinalDeck, false, false);
		if useSeperateLength then
			dynaPortTwin.addMemberKey(fortyFooter, false, false);
		endif;
		dynaPortTwin.addMemberKey(seqPortLoad, false, false);
		dynaPortTwin.addMemberKey(ordinalBay, false, false);
		dynaPortTwin.endKeys(false);	
	
		dynaStarboardTwin.addMemberKey(ordinalDeck, false, false);
		if useSeperateLength then
			dynaStarboardTwin.addMemberKey(fortyFooter, false, false);
		endif;
		dynaStarboardTwin.addMemberKey(seqStarboardLoad, false, false);
		dynaStarboardTwin.addMemberKey(ordinalBay, false, false);
		dynaStarboardTwin.endKeys(false);
		
		dynaPortSingle.addMemberKey(ordinalDeck, false, false);
//		dynaPortSingle.addMemberKey(ordinalBay, false, false);// PAR 17412
		if useSeperateLength then
			dynaPortSingle.addMemberKey(fortyFooter, false, false);
		endif;
		dynaPortSingle.addMemberKey(ordinalBay, false, false);// PAR 17412
		dynaPortSingle.addMemberKey(seqPortLoad, false, false);
		dynaPortSingle.endKeys(false);	
	
		dynaStarboardSingle.addMemberKey(ordinalDeck, false, false);
//		dynaStarboardSingle.addMemberKey(ordinalBay, false, false);// PAR 17412
		if useSeperateLength then
			dynaStarboardSingle.addMemberKey(fortyFooter, false, false);
		endif;
		dynaStarboardSingle.addMemberKey(ordinalBay, false, false);// PAR 17412
		dynaStarboardSingle.addMemberKey(seqStarboardLoad, false, false);
		dynaStarboardSingle.endKeys(false);
	endif;
	
	// Create cmifs set them up and then sort the little monkeys.
	foreach requestObj in self.allRequests do
		// ignore the load SOBs there is a problem if the load is linked and is in the same position as a discharge in the same job.
		if requestObj.isSOB and requestObj.getAttrIsLoad  then // PAR 15425
			continue; // PAR 15425
		endif;  // PAR 15425 

		
		create sortObj transient;
		sortObj.isUsingDifferentLengths := useSeperateLength;
		sortObj.setFromRequest(requestObj.CM_SlotRequest, false);
		sortObj.isTwinLiftProperty := false;
		dynaPortTwin.add(sortObj);
		dynaStarboardTwin.add(sortObj);
		dynaPortSingle.add(sortObj);
		dynaStarboardSingle.add(sortObj);
	endforeach;

	// The cmifs are in the correct order so it's time to apply the sequencing to
	// the requests.
	self.setRequestSeqNumberSingle(dynaPortSingle, dynaStarboardSingle);
	
	create allPortLiftsObj transient;
	create allStarboardLiftsObj transient;
	dynaPortTwin.copy(allPortLiftsObj);
	dynaStarboardTwin.copy(allStarboardLiftsObj);
	
	// DVB This needs to be called here and then maybe again later if
	// resequencing for single before twin.
	// Par 14515
	self.setRequestSeqNumberTwin(allPortLiftsObj, allStarboardLiftsObj);
	
	if _theJobParams &lt;&gt; null then // PAR 19416/18613
		isSeqForJob := _theJobParams.isSeqForJob;// PAR 19416/18613
	endif;
	
	if self.myTerminal.getConfig(SeqGroupSingleLifts).Boolean
	and (isSeqForJob or self.myTerminal.getConfig(AutoCustomSeqSingleFirst).Boolean) // CCMS 1519
	and not isDischarge
	then
		// Par 14515
		self.groupSinglesForTLJob(allPortLiftsObj, dynaPortTwin, false);
		self.groupSinglesForTLJob(allStarboardLiftsObj, dynaStarboardTwin, true);
		self.setRequestSeqNumberTwin(allPortLiftsObj, allStarboardLiftsObj);

		self.isTwinLift := self.canBeTwinLiftVoyageJob();//PAR 18414

		 // PAR 17412 Added AKB2008JUL - Only do this if we are a single lift job, if this is a twin lift job the single lift sequence has already been done correctly.
		 //												We are only re doing this because of the config flags to make sure that singles in a mixed 20/40 job are first.
		if not self.isTwinLift then
			self.groupSinglesForSLJob(allPortLiftsObj, dynaPortTwin, false);// PAR 17412 Added AKB2008JUL
			self.groupSinglesForSLJob(allStarboardLiftsObj, dynaStarboardTwin, true);// PAR 17412 Added AKB2008JUL
			self.setRequestSeqNumberSingleFirst(allPortLiftsObj, allStarboardLiftsObj); // PAR 17412 Added AKB2008JUL
		endif;
	else
		self.isTwinLift := self.canBeTwinLiftVoyageJob(); //epr par 36734 12/8/15
	endif;

	//epr par 28431 better place to call the setSeqWorkOrderNum than the load to ops
	if not self.isTwinLift then				// 27/10/2011 cnwmh5 #28577
		self.setSeqWorkOrderNum();
	endif;
	
	
	
epilog
	// Only purge one as looking at same cmif objects.
	if allPortLiftsObj &lt;&gt; null then
		allPortLiftsObj.purge();
	endif;
	
	delete dynaPortSingle;
	delete dynaStarboardSingle;
	delete dynaPortTwin;
	delete dynaStarboardTwin;
	delete allPortLiftsObj;
	delete allStarboardLiftsObj;
	delete allSlotsByBayDeckTierCell;
//	delete params;
end;</source>
        <Parameter name="_theJobParams" type="CMIF_VoyageJobParams"/>
    </JadeMethod>
    <JadeMethod name="setRequestSeqNumbersSet" id="5acd11ae-3fc0-4bcf-ab3e-b0b5fea72d42">
        <source>setRequestSeqNumbersSet(_params : CMIF_SeqParams input;_request : CM_Request input);
//AA 16/11/00: This initially sets the slot sequence numbers to default settings.
//Only applies to this job: ie it does not bugger up any other sequences currently in place.
//Without this and following custom sequencing mods, all seq numbers were 0 by default
//which didn't seem quite right.
vars

begin
	if not _request.isKindOf(CM_SlotRequest) then 
		app.raiseUnexpectedProgramError(class.name, method.name, 'Encountered a non-slot request');
		return;
	endif;
	exclusiveLock(_request);

	// PAR 21746 _params.isForty := (_request.CM_SlotRequest.getAttrIs40() or _request.CM_SlotRequest.fortyBack);
	_params.isForty := (_request.getAttrIs40() or _request.getAttrIsBackend()); // PAR 21746 
	_params.isStarBoard := false;
	_params.displayAllBaysInHold := true;

	_request.CM_SlotRequest.setSlotSeqNums(_params);
end;</source>
        <Parameter name="_params" type="CMIF_SeqParams" usage="input"/>
        <Parameter name="_request" type="CM_Request" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setSecondID" id="af2b72b3-37cc-4fd9-b7fa-f313351b8283">
        <updating/>
        <source>setSecondID() updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.myJobSheet = null then // PAR 26945
		return;
	endif;
	
	self.craneId := self.myJobSheet.CM_VoyageJobSheet.crane;
end;</source>
    </JadeMethod>
    <JadeMethod name="setSeqWorkOrderNum" id="b938d60f-7986-4d88-9b28-d736e5a6f454">
        <source>setSeqWorkOrderNum() ;

/*

Purpose:		Set the work order number	

Parameters:			

Return Value:		


Date			Who		Reason
19 July 2011	cnwmh5	Initial creation

*/

vars

	request				: CM_Request;
	wle 				: CM_WorkListEntry;
	idx					: Integer;
	
begin

	foreach request in self.allRequests do
		idx := 0;
		foreach wle in request.allWorkListEntries do
			idx := idx + 1;
			wle.CM_VoyageWLE.setSeqNumWorkOrder(idx);
		endforeach;
	endforeach; 

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setShipOpsLoad" id="be4ec046-42ad-4cc1-abb7-c385f4f0cff2">
        <updating/>
        <source>setShipOpsLoad() updating;
//   Description : Method to load a job to the operational side of vessel activity
// 18/07/2011	cnwmh5	#27479 - Uncomment setting of sequence numbers
vars

begin

	exclusiveLock(self);

	if (self.jobType &lt;&gt; JOB_TYPE_LOAD) 
	and (self.jobType &lt;&gt; JOB_TYPE_DISCHARGE)
	and (self.jobType &lt;&gt; JOB_TYPE_SOB) then
		return;
	endif;
	//-------------------------------------------------------------
	// Test if the job is in a valid state to perform this action
	//-------------------------------------------------------------
	if self.isLoadedToOperations then
		return;
	endif;

	self.setIsLoaded(true); //epr 28/11/2013 CCMS 2323
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setShipOpsUnload" id="e263d582-e78c-4229-b63c-79bef395b6f6">
        <updating/>
        <source>setShipOpsUnload() updating;

vars
	
begin
	exclusiveLock(self);

	if (jobType &lt;&gt; JOB_TYPE_LOAD ) and ( jobType &lt;&gt; JOB_TYPE_DISCHARGE ) and ( jobType &lt;&gt; JOB_TYPE_SOB  ) then
		return;
	endif;

	if  self.status = JOB_COMPLETE then
		return;
	endif;

	self.setIsLoaded( false); //epr 28/11/2013 CCMS 2323
end;</source>
    </JadeMethod>
    <JadeMethod name="setSidesAndNumHatches" id="84fa7f9f-315c-4076-8e85-765a73be5a45">
        <updating/>
        <source>setSidesAndNumHatches() updating, protected;
// ---------------------------------------------------------------------------
// Created:     18 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpHatchLids	: CM_HatchLidArray;
	
begin

	create tmpHatchLids transient;
	self.getHatchLidsForRequests(tmpHatchLids);
	self.setSidesFromHatchLids(tmpHatchLids);

epilog
	delete tmpHatchLids;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setSidesFromHatchLids" id="c68343e9-1443-4afd-92fd-c540b071c29a">
        <updating/>
        <source>setSidesFromHatchLids(_hatches : CM_HatchLidArray) updating, protected;
/*
------------------------------------------------------------------------
Created:			03 March 2003 by cnwdwq1
Purpose:			Determines whether the job is a port/centre/starboard type
Parameters:		
Returns:			
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars
	hatch : CM_HatchLid;
	tmpSide : Integer;
begin
	//----------------------
	//Default the values
	//----------------------
	self.isCentre := false;
	self.isPort := false;
	self.isStarboard := false;

	if _hatches.isEmpty then
		return;
	endif;

	foreach hatch in _hatches do
		if hatch.sideAbbreviation = "P" then
			self.isPort := true;
		elseif hatch.sideAbbreviation = "C" then
			self.isCentre := true;
		elseif hatch.sideAbbreviation = "S" then
			self.isStarboard := true;
		endif;
	endforeach;
	
end;</source>
        <access>protected</access>
        <Parameter name="_hatches" type="CM_HatchLidArray"/>
    </JadeMethod>
