Return Value:		


Date		Who		Reason
21 May 2025 navrv30	MTN 34504 MTN - Work Order Operations - Waiting Time Column not displaying as expected

*/

vars

begin
	if eventTag = Timer_Refresh then
		self.timerRefreshActive := false;
		self.timerUpdateDwellTime(self.tblJobsUnallocated);
		self.timerUpdateDwellTime(self.tblJobsAllocated);
	else
		inheritMethod(eventTag); //27/05/2025	navkc1 JIRA MTN 34904
	endif;
	self.beginTimerForRefresh();
epilog

end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="timerUpdateDwellTime" id="9e0e07bf-98b9-4013-a0cb-38bca9846f60">
        <source>timerUpdateDwellTime(_table : CM_DataTable);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 May 2025 navrv30	MTN 34504 MTN - Work Order Operations - Waiting Time Column not displaying as expected 

*/

vars
	row,
	cnt,
	pos,
	col : Integer;
	job : CM_Job;
	str	: String;
	table : CM_DataTable;
begin	
	
	table := _table;
	col := table.getColumnByRowName(ETRow_WaitingTime);	
	if col &lt; 1 then
		// Dwell TIme column is not visible
		return;
	endif;
	
	on Exception do self.handleExceptionJob(exception, job);		
	
	cnt := table.rows;
	pos := table.fixedRows+1;
	
	foreach row in pos to cnt do
		job := table.accessRow(row).itemObject.CM_Job;
		if job = null then
			continue;
		endif;
		job.fetchLatest();
		if job = null then
			continue;
		endif;		
		str := job.getDisplayStringForAttribute(ETRow_WaitingTime, false);
		table.accessCell(row, col).text := str;
	endforeach;
	
end;</source>
        <Parameter name="_table" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="599cbcc0-6f5e-4f42-ad38-ccbe8fc17572">
