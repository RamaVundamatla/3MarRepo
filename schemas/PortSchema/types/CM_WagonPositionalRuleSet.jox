<CollClass name="CM_WagonPositionalRuleSet" id="320a3573-0d6b-41a0-a509-b10167969588">
    <loadFactor>98</loadFactor>
    <memberType name="CM_WagonPositionalRule"/>
    <superclass name="CM_ObjectSet"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="wagonPosition"/>
    <JadeMethod name="loadMeetsWagonPositionalRule" id="5bcf3cac-9c84-4e61-ae9e-59b0afc9af12">
        <source>loadMeetsWagonPositionalRule( 	_moveController : CMIF_MoveController;
								_wagon : CM_Wagon;
								_positionError : Integer output;
								_rulesMet : CM_WagonPositionalRuleSet io
								):Boolean;

/*

Purpose:			

Parameters:			
	_addPosition is the '20 foot' position, not the traditional 10 ft location.
Return Value:		


Date		Who		Reason
27 July 2009	cnwndl1	Initial creation

*/

vars

	ti : CM_TrackedItem;
	
	localDict : CM_WagonPositionalRuleSet;	
	
	tiLocationId : String;
	tiPosition : Integer; // 20 foot position.
	tiLength : Integer;
	tiWeight : Decimal [12,2];
	tiHeight : Decimal [12,2];
	
	posiRule : CM_WagonPositionalRule;
	posi : CM_WagonPosition;
	
	primary : CM_WagonController;
	wagon : CM_Wagon;
	
	iter : Iterator;
	wagPosiDataDict : CMIF_WagonPositionDataDict;
	wagPosiData : CMIF_WagonPositionData;
	
begin

	if _rulesMet &lt;&gt; null then
		_rulesMet.clear();
	endif;

	

	if _moveController &lt;&gt; null then
		// we are moving cargo onto a wagon.
		primary := _moveController.myToPrimaryLocation.CM_WagonController;
		ti := _moveController.myTrackedItem;	// the cargo we are moving 
		wagon := primary.myWagon;	// the wagon we are moving the cargo onto
		tiPosition := ( ( wagon.allLocationsControllersArray.indexOf(primary) + 1) / 2 ) .Integer; // the position on the wagon
	
	elseif _wagon &lt;&gt; null then
	// we are just doing a check on a wagon - no current moves
		wagon := _wagon;
		
	else
	// No Wagon or Controller passed in	
		return false;
	endif;
	
	if wagon &lt;&gt; null and wagon.isWellcarVisit then
		// well cars don't have soft positional rules, they are implied and embedded.
		return self.loadMeetsWellcarPosiRules( _moveController, _wagon, _positionError, _rulesMet );
	endif;
	
	if self.isEmpty then
		// no rules to check against
		return true;
	endif;
	
	
	create localDict transient;
	self.copy(localDict);
	
	//get all existing ti/s on the wagon that are staying on for the outward journey
	// and all ti's planned onto the wagon.
	create wagPosiDataDict transient;
	wagon.getTIDataForPosiRuleCheck( wagPosiDataDict );
				
	// this is the ti on the passed in controller being moved onto the wagon
	if ti &lt;&gt; null then
	
		wagPosiData := wagPosiDataDict.getAtKey(tiPosition);
		if wagPosiData &lt;&gt; null then
			// we already have something in this position or planned in this position for the outward trip
			// so get that data
			tiLength := wagPosiData.length;
			tiWeight := wagPosiData.getWeight;
			tiHeight := wagPosiData.getHeight;
			if not wagPosiData.allTrackedItems.includes(ti) then
				// this one isn't already planned so add these values in too.
				tiWeight := tiWeight + ti.totalWeight;
				tiHeight := tiHeight + ti.getActualHeightRaw();
			endif;
		else
			// nothing currently in this position that is staying there, so only need the details of this ti..
			tiLength := ti.getActualLength().Integer;
			tiWeight := ti.totalWeight; 
			tiHeight := ti.getActualHeightRaw(); 
		endif;
			
//write "Adding TI @ [" &amp; tiPosition.String &amp; "] " &amp; tiLength.String &amp;  " / " &amp; tiWeight.String &amp;  " / " &amp; tiHeight.String;
		foreach posiRule in localDict do
			posi := posiRule.allWagonPositions.getAtKey(tiPosition);
			if posi = null then
				// this rule doesn't have this position declared.
				localDict.remove(posiRule);
			else
				if posi.cargoLength &lt;&gt; tiLength then
					// the position in this rule that we want to use is not valid for this length container
					localDict.remove(posiRule);
				elseif posi.getMaxCargoHeight &gt; 0 and posi.getMaxCargoHeight &lt; tiHeight then
					// the container will stand taller than the max cargo height permitted in this position on this rule
					localDict.remove(posiRule);
				//elseif posi.maxWeight &gt; 0 and posi.maxWeight &lt; tiWeight then
				elseif posi.maxWeight &lt; tiWeight then	// 09 Mar 2010	NDL	Par 23037
					// the total weight will be greater than the max cargo weight permitted in this position on this rule
					localDict.remove(posiRule);
				endif;
			endif;
		endforeach;
		
	endif;
	
	if localDict.isEmpty then
		_positionError := tiPosition;
		return false;
	endif;
	
	iter := wagPosiDataDict.createIterator;
	while iter.next( wagPosiData ) do

		tiPosition := wagPosiData.position;
		tiLength := wagPosiData.length;
		tiWeight := wagPosiData.getWeight;
		tiHeight := wagPosiData.getHeight;
		
//write "Existing actual or planned  at [" &amp; tiPosition.String &amp; "] " &amp; tiLength.String &amp;  " / " &amp; tiWeight.String &amp;  " / " &amp; tiHeight.String;

		foreach posiRule in localDict do
			posi := posiRule.allWagonPositions.getAtKey(tiPosition);
			if posi = null then
				localDict.remove(posiRule);
			else
//write posi.cargoLength.String &amp; " / " &amp; posi.maxWeight.String &amp; " / " &amp; posi.getMaxCargoHeight.String;
				if posi.cargoLength &lt;&gt; tiLength then
					localDict.remove(posiRule);
				elseif posi.getMaxCargoHeight &gt; 0 and posi.getMaxCargoHeight &lt; tiHeight then
					localDict.remove(posiRule);
				//elseif posi.maxWeight &gt; 0 and posi.maxWeight &lt; tiWeight then
				elseif posi.maxWeight &lt; tiWeight then	// 09 Mar 2010	NDL	Par 23037
					localDict.remove(posiRule);
				endif;
			endif;
		endforeach;
		
		if localDict.isEmpty then
			_positionError := tiPosition;
			return false;
		endif;
		
	endwhile;
	
	if localDict.isEmpty then
		return false;
	else
		if _rulesMet &lt;&gt; null then
			localDict.copy(_rulesMet);
		endif;
		return true;
	endif;
	

epilog

	delete iter;
	delete localDict;
	delete wagPosiDataDict;
	
end;</source>
        <Parameter name="_moveController" type="CMIF_MoveController"/>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="_positionError" type="Integer" usage="output"/>
        <Parameter name="_rulesMet" type="CM_WagonPositionalRuleSet" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadMeetsWellcarPosiRules" id="150636b1-1e53-4864-850f-aa7145c7ba06">
        <source>loadMeetsWellcarPosiRules(	_moveController : CMIF_MoveController;
							_wagon : CM_Wagon;
							_positionError : Integer output;
							_rulesMet : CM_WagonPositionalRuleSet io
							):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 December 2014	cnwndl1	Initial creation	Par 35346

*/

vars

	ti : CM_TrackedItem;
	primary : CM_WellcarWagonController;
	well : CM_WellcarWellVisit;
	tiPosition : Integer; // 20 foot position.
	wagPosiDataDict : CMIF_WagonPositionDataDict;
	wagPosiData : CMIF_WagonPositionData;
	tiWeight : Decimal [12,2];
	tiHeight : Decimal [12,2];
	otherTi : CM_TrackedItem;
	processedTis : CM_TISet;
	wagon : CM_WellcarVisit;
	wellMaxCargoWeight : Decimal [12,2];
	posiMaxCargoHeight : Decimal [12,2];

begin

	if _moveController &lt;&gt; null then
		// we are moving cargo onto a wagon.
		primary := _moveController.myToPrimaryLocation.CM_WellcarWagonController;
		ti := _moveController.myTrackedItem;	// the cargo we are moving 
		well := primary.myWellcarWellVisit;	// the wagon well we are moving the cargo onto
		if well &lt;&gt; null then
			wagon := well.myWellcarVisit;
		endif;
		tiPosition := ( ( well.allLocationsControllersArray.indexOf(primary) + 1) / 2 ) .Integer; // the position on the wagon
	
	elseif _wagon &lt;&gt; null and _wagon.isWellcarVisit then
	// we are just doing a check on a wagon - no current moves
		wagon := _wagon.CM_WellcarVisit;
		
	else
		return true;
		
	endif;
	
	
	
	create processedTis transient;		
	// this is the ti on the passed in controller being moved onto the wagon / well
	if ti &lt;&gt; null and well &lt;&gt; null then
		//get all existing ti/s on the well that are staying on for the outward journey
		// and all ti's planned onto the well.
		create wagPosiDataDict transient;
		well.getTIDataForPosiRuleCheck( wagPosiDataDict );
	
		wagPosiData := wagPosiDataDict.getAtKey(tiPosition);
		if wagPosiData &lt;&gt; null then
			// we already have something in this position or planned in this position for the outward trip
			// so get that data
			tiHeight := wagPosiData.getHeight;
			if not wagPosiData.allTrackedItems.includes(ti) then
				// this one isn't already planned so add these values in too.
				tiHeight := tiHeight + ti.getActualHeightRaw();
			endif;
		else
			// nothing currently in this position that is staying there, so only need the details of this ti..
			tiHeight := ti.getActualHeightRaw(); 
		endif;
		
		posiMaxCargoHeight := primary.getMaxCargoHeight;
		if posiMaxCargoHeight &gt; 0 and posiMaxCargoHeight &lt; tiHeight then
			_positionError := tiPosition;
			return false;
		endif;
		
		// get the weight of all of the well positions.
		tiWeight := ti.totalWeight;
		processedTis.add(ti);
		foreach wagPosiData in wagPosiDataDict do
			foreach otherTi in wagPosiData.allTrackedItems do
				if not processedTis.includes( otherTi ) then
					tiWeight := tiWeight + otherTi.totalWeight;
					processedTis.add(otherTi);
				endif;
			endforeach;
		endforeach;
		
		wellMaxCargoWeight := primary.getMaxWellCargoWeight;
		if wellMaxCargoWeight &gt; 0 and wellMaxCargoWeight &lt; tiWeight then	// 09 Mar 2010	NDL	Par 23037
			// the total weight will be greater than the max cargo weight permitted in this well
			_positionError := tiPosition;
			return false;
		endif;
		
	elseif wagon &lt;&gt; null then
		foreach well in wagon.allWagonWellsArray do
			
			//get all existing ti/s on the well that are staying on for the outward journey
			// and all ti's planned onto the well.
			create wagPosiDataDict transient;
			well.getTIDataForPosiRuleCheck( wagPosiDataDict );
			
			primary := well.allLocationsControllersArray.first;
			if primary = null then
				continue;
			endif;
			wellMaxCargoWeight := primary.getMaxWellCargoWeight;
			posiMaxCargoHeight := primary.getMaxCargoHeight;
			
			if wellMaxCargoWeight &gt; 0 then 
				foreach wagPosiData in wagPosiDataDict do
					foreach otherTi in wagPosiData.allTrackedItems do
						if not processedTis.includes( otherTi ) then
							tiWeight := tiWeight + otherTi.totalWeight;
							processedTis.add(otherTi);
						endif;
					endforeach;
				endforeach;
				if wellMaxCargoWeight &lt; tiWeight then
					_positionError := 1;
					return false;
				endif;
			endif;
			
			if posiMaxCargoHeight &gt; 0 then
				foreach wagPosiData in wagPosiDataDict do
					primary := well.allLocationsControllersArray[(( wagPosiData.position * 2 ) - 1 )].CM_WellcarWagonController;
					tiHeight := wagPosiData.getHeight;
					if posiMaxCargoHeight &lt; tiHeight then
						_positionError := (( wagon.allLocationsControllersArray.indexOf(primary) + 1 ) / 2 ).Integer;
						return false;
					endif;
				endforeach;
			endif;
			
			delete wagPosiDataDict;
		endforeach;
			
	endif;
	
	return true;

epilog

	delete processedTis;
	delete wagPosiDataDict;
	

end;</source>
        <Parameter name="_moveController" type="CMIF_MoveController"/>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="_positionError" type="Integer" usage="output"/>
        <Parameter name="_rulesMet" type="CM_WagonPositionalRuleSet" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
