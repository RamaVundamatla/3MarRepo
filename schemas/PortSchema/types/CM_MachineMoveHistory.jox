    <JadeMethod name="getLastSetDown" id="757ba7f5-98d0-4e94-918a-d0eda3cab81b">
        <source>getLastSetDown() : CM_MachineMoveHistory;
/*
Purpose: Find and return the last setdown

Parameters:			

Return Value:		

Date		Who		Reason
30 April 2012	cnwdw1	Initial creation
*/
vars
	last: CM_MachineHistory;
begin
	last := self;
	while last &lt;&gt; null do
		if last.myNextHistory = null then
			break;
		endif;
		last := last.myPriorHistory;
	endwhile;
	
	while last &lt;&gt; null and last.type &lt;&gt; Type_SetDown do
		last := last.myPriorHistory;
	endwhile;
	
	return last.CM_MachineMoveHistory;
epilog

end;</source>
        <ReturnType type="CM_MachineMoveHistory"/>
    </JadeMethod>
    <JadeMethod name="getMoveAmount" id="313d2baa-acce-43d4-b3f0-2d08f70647f0">
        <source>getMoveAmount() : String;
/*

Date		Who		Reason
20 March 2014	cnwer1	Initial creation PAR

*/

vars
	ct : CM_CargoType;
	measure		: CM_MeasurementType;
	density  	: Decimal[14,4];
	ti		: CM_TrackedItem;
begin
	
	ct:= app.myRoot.allCargoTypesById[self.cargoType];
	if ct = null then
		return self.quantity.asStringJMT;
	endif;
	
	if ct.isBreakBulkMulti then
		return self.quantity.asStringJMT;
	endif;
	
	if ct.isBulkMulti then
		ti:= self.getTrackedItem;
		if ti &lt;&gt; null then
			density:=ti.getDensity;
		else
			if ct.mySystemProductType &lt;&gt; null then
				density:=ct.mySystemProductType.getDefaultValueStringForType(Type_Density).Decimal;
			endif;
		endif;
		
		return ct.getBulkTrackByDisplayForWeight( self.weight,density,true);	
		
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMoveDuration" id="dc1a648b-690e-4b73-ad2c-9d1278289618">
        <source>getMoveDuration():Integer;
// ---------------------------------------------------------------------------
// Created:     02 November 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Move duration in minutes
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	startTS, endTS	:TimeStamp;
	result			:Integer;
begin
	// move duration is time between pickup and setdown
	startTS := self.getStartOfMoveTS;
	endTS	:= self.getEndOfMoveTS;
	
	if startTS &lt;&gt; null and endTS &lt;&gt; null then
		result := 	startTS.getDifferenceInSeconds (endTS).rounded;
	endif;
	
	return result;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMoveSlackTime" id="982992ea-575e-4504-ba32-52337a4b58b8">
        <source>getMoveSlackTime():Integer;
// ---------------------------------------------------------------------------
// Created:     02 November 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ts1, ts2	:TimeStamp;
begin
	ts1	:= self.getAcceptMoveTS;
	ts2	:= self.getStartOfMoveTS;
	
	if ts1 &lt;&gt; null and ts2 &lt;&gt; null and ts2 &gt;= ts1 then
		return ts2.getDifferenceInSeconds (ts1).rounded;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
