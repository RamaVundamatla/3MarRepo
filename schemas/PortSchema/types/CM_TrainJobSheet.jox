<Class name="CM_TrainJobSheet" id="9fe8f4a1-8596-4e67-a123-555c085933e1">
    <superclass name="CM_JobSheet"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>


Train job sheet is only used for release jobs, to allow them to be planned to wagons. No Queuing or actual moving allowed.</text>
    <DbClassMap file="operatn"/>
    <ExplicitInverseRef name="myTrain" id="6ee2c295-2f0e-4922-8445-86fc2c410efd">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <embedded/>
        <type name="CM_Train"/>
