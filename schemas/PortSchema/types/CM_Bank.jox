	//invProc := CM_InvoiceProcessDefault.firstInstance;					//05.06.2025 navma1 #MTN-34114
	invProc	  := app.myRoot.allInvoiceProcesses[InvoiceProcessDefault];		//05.06.2025 navma1 #MTN-34114
	
