    <JadeMethod name="tranMapLoadCFT" id="882b1261-9cc4-4fbf-9a06-db4c6f8f7c00">
        <source>tranMapLoadCFT(_testType : Integer);
// load transaction map for cargo freight tonnage test
// _testType parameter is: 1 = lowest, 2 = lowest + default, 3 = highest, 4 = highest + default, anything else is All

vars
	fileContent : String;
	fileName	: String;
	mapName		: String;
	grouping1,
	grouping2,
	grouping3	: String;
	bank		: CM_Bank;
	cargoMap	: CM_TranMap;

begin
	fileName := "CargoCFT";
	mapName := "UT_CFT";
	if _testType = 1 then
		grouping1 := "Lowest";
		grouping2 := "Lowest";
		grouping3 := "Lowest";
	elseif _testType = 2 then
		grouping1 := "Lowest";
		grouping2 := "Lowest Default";
		grouping3 := "Lowest";
	elseif _testType = 3 then
		grouping1 := "Highest 1";
		grouping2 := "Highest 1";
		grouping3 := "Highest 1";
	elseif _testType = 4 then
		grouping1 := "Highest 1";
		grouping2 := "Highest 1 Default";
		grouping3 := "Highest 1";
	else
		grouping1 := "All";
		grouping2 := "All";
		grouping3 := "All";
	endif;

	fileContent := 	'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,RORO?,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?' &amp; CrLf &amp;
		'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),All,VOID' &amp; CrLf &amp;
		'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),(Default),Stop Set,,(Default),(Default) ›,(Default),All,VOID' &amp; CrLf &amp;
		'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),(Default),Stop Set,,(Default),(Default) ›,(Default),' &amp; grouping1 &amp; ',UT_CFTInvLineType1' &amp; CrLf &amp;
		'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),(Default),Stop Set,,(Default),(Default) ›,(Default),' &amp; grouping2 &amp; ',UT_CFTInvLineType2' &amp; CrLf &amp;
		'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),(Default),Stop Set,,(Default),(Default) ›,(Default),' &amp; grouping3 &amp; ',UT_CFTInvLineType3' &amp; CrLf;

	
	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();
	
	bank := app.myPassport.myTerminal.getDefaultCompanyBank();
	cargoMap := bank.myCurrentTranMapCargo[mapName];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");

	app.myTrxUA.trxUpdateBankTMActive(cargoMap, app.myPassport);

epilog

end;
</source>
        <Parameter name="_testType" type="Integer"/>
    </JadeMethod>
