	date.setDate(31, 3, 2022);
	time.setTime(0, 0, 0, 0);
	requiredTimeStamp.setDate(date);
	requiredTimeStamp.setTime(time);
	
	self.logMessage("Running Comparison for '" &amp; _fileAndDirectory &amp; "'", LogDEBUG);
	
	//Load the selected schema file
	appLogTmpDir := app.getAppServerLogDir() &amp; '\tmpFiles';
	
	targetDir := app.copyFileToAppServer(_fileAndDirectory);
	
	self.logMessage("File copied from '" &amp; _fileAndDirectory &amp; "' to '" &amp; targetDir &amp; "'", LogDEBUG);
	
	self.createSections();
	
	self.logMessage("Loading Schema File: '" &amp; _schemaFileName &amp; "'", LogDEBUG);
	self.doLoadSchemaFile(targetDir, _schemaFileName);
	self.logMessage("Finished Loading Schema", LogDEBUG);
	
	loadedSchemaFile := self.mySchemaFile.mySchema;
	
	/*
	**	Run class and method comparison between the 2
	*/
	
	//Get Loaded Schema Data
	//Not sure why this exists??????
	//Find the use of typeSources
	if(loadedSchemaFile.allSections.getAtKey("typeSources") &lt;&gt; null) then
		loadedSchemaClassesSection := loadedSchemaFile.allSections.getAtKey("typeSources").DEV_SchemaClassesSection;
	else
		//throw exception
	endif;
	
	//Get Loaded Schema Constant Data
	if(loadedSchemaFile.allSections.getAtKey("constantDefinitions") &lt;&gt; null) then
		loadedSchemaConstantsSection := loadedSchemaFile.allSections.getAtKey("constantDefinitions").DEV_SchemaConstantsSection;
	endif;
	
	if(loadedSchemaFile.allSections.getAtKey("typeDefinitions") &lt;&gt; null) then
		loadedSchemaMethodSection := loadedSchemaFile.allSections.getAtKey("typeDefinitions").DEV_SchemaClassesSection;
	else
		//throw exception
	endif;
	
	//Process each class in schema and check if current schema has the same class
	
	self.logMessage("Checking Schema '" &amp; loadedSchemaFile.name &amp; "'", LogDEBUG);
	
	currentSchemaData := rootSchema.getSchema(loadedSchemaFile.name);
	
	if currentSchemaData = null then
		self.logMessage("Schema not found | " &amp; loadedSchemaFile.name, LogFATAL);
		self.errorsOccurred := true;
		return;
	endif;
	
	/*
	* Global Constant Categories?
	* Global Constants
	*/
	if loadedSchemaConstantsSection &lt;&gt; null then
		foreach loadedConstantCategory in loadedSchemaConstantsSection.allConstantCategories do
			currentConstantCategory := currentSchemaData.getCategory(loadedConstantCategory.name);
			if currentConstantCategory &lt;&gt; null then
				if currentConstantCategory.text &lt;&gt; loadedConstantCategory.documentationTextData 
					and loadedConstantCategory.modifiedTimeStamp &lt; requiredTimeStamp 
				then
					self.reportAgent.createReport(loadedSchemaFile, _reportType);
					self.reportAgent.addGcCategory(loadedSchemaFile.name, loadedConstantCategory, self.reportAgent.Object_Different);
				endif;
				
				foreach loadedGlobalConstant in loadedConstantCategory.allConstants do
					if not loadedGlobalConstant.modifiedTimeStamp &lt; requiredTimeStamp then 		//Check if the last modified timestamp is greater than 7 days ago
						continue; 																//If not continue looping
					else
						currentConstant := currentSchemaData.getConstant(loadedGlobalConstant.name);
						if currentConstant &lt;&gt; null then 
							if currentConstant.text &lt;&gt; loadedGlobalConstant.documentationTextData 
								or currentConstant.getSource() &lt;&gt; loadedGlobalConstant.value
								//currentConstant.type.name &lt;&gt; loadedGlobalConstant.type - Needs implementing
							then
								self.reportAgent.createReport(loadedSchemaFile, _reportType);
								self.reportAgent.addGcCategory(loadedSchemaFile.name, loadedConstantCategory, reportAgent.Object_Link);
								self.reportAgent.addGlobalConstant(loadedSchemaFile.name, loadedGlobalConstant, reportAgent.Object_Different);
								
								self.errorsOccurred := true;
							endif;
			
						else
							self.reportAgent.createReport(loadedSchemaFile, _reportType);
							self.reportAgent.addGcCategory(loadedSchemaFile.name, loadedConstantCategory, reportAgent.Object_Link);
							self.reportAgent.addGlobalConstant(loadedSchemaFile.name, loadedGlobalConstant, reportAgent.Object_Missing);
							
							self.errorsOccurred := true;
						endif;
					endif;
				endforeach;
			else
				self.reportAgent.createReport(loadedSchemaFile, _reportType);
				self.reportAgent.addGcCategory(loadedSchemaFile.name, loadedConstantCategory, reportAgent.Object_Missing);
				
				self.errorsOccurred := true;
			endif;
			
		endforeach;
	endif;
	
	
	/*
	* Classes and Methods/Attributes/Constants check
	*/
	if loadedSchemaMethodSection &lt;&gt; null then
		foreach loadedClass in loadedSchemaMethodSection.allClasses do
			currentClass := currentSchemaData.getClass(loadedClass.name);
			
			if self.classIsIgnored(currentSchemaData, loadedClass.name) then
				continue;
			endif;
			
			if currentClass &lt;&gt; null then 											//If we can find the class then compare it
				if currentClass.text &lt;&gt; loadedClass.documentationTextData then 		//If the documentation text on the class doesn't match then add to differing classes array
					self.reportAgent.createReport(loadedSchemaFile, _reportType);
					self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Different);
					
					self.errorsOccurred := true;
				endif;
				
				/*
				* Attributes
				*/
				foreach loadedAttribute in loadedClass.allAttributes do 					//Loop through attributes
					if not loadedAttribute.modifiedTimeStamp &lt; requiredTimeStamp then 		//Check if the last modified timestamp is greater than 7 days ago
						continue; 															//If not continue looping
					else
						currentAttribute := currentClass.getProperty(loadedAttribute.name); //Get the current attribute from the environment
						if(currentAttribute &lt;&gt; null) then 									//If we can find the attribute then compare it
							if currentAttribute.type.name &lt;&gt; loadedAttribute.type
								or currentAttribute.text &lt;&gt; loadedAttribute.documentationTextData
							then 															//If the documentation text and type on the attribute doesn't match then 
																							//add to differing attributes array
								self.reportAgent.createReport(loadedSchemaFile, _reportType);
								self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Link);
								self.reportAgent.addAttribute(loadedSchemaFile.name, loadedAttribute, self.reportAgent.Object_Different);
								
								self.errorsOccurred := true;
							endif;
						else 																//Add it to the missing attributes array as it does not exist
							self.reportAgent.createReport(loadedSchemaFile, _reportType);
							self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Link);
							self.reportAgent.addAttribute(loadedSchemaFile.name, loadedAttribute, self.reportAgent.Object_Missing);
							self.errorsOccurred := true;
						endif;
					endif;
				endforeach;
				
				/*
				* Constants
				*/
				foreach loadedConstant in loadedClass.allConstants do 						//Loop through constants
					if not loadedConstant.modifiedTimeStamp &lt; requiredTimeStamp then 		//Check if the last modified timestamp is greater than 7 days ago
						continue; 															//If not continue looping
					else
						currentConstant := currentClass.getConstant(loadedConstant.name); 	//Get the current constant from the environment
						if currentConstant &lt;&gt; null then 									//If we can find the constant then compare it
							if currentConstant.type.name &lt;&gt; loadedConstant.type 
								or currentConstant.text &lt;&gt; loadedConstant.documentationTextData 
								or currentConstant.getSource() &lt;&gt; loadedConstant.value
							then 															//If the documentation text, value and type on the constant doesn't match then 
																							//add to differing constants array
								self.reportAgent.createReport(loadedSchemaFile, _reportType);
								self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Link);
								self.reportAgent.addConstant(loadedSchemaFile.name, loadedConstant, self.reportAgent.Object_Different);
								
								self.errorsOccurred := true;
							endif;
						else 																//Add it to the missing constants array as it does not exist
							self.reportAgent.createReport(loadedSchemaFile, _reportType);
							self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Link);
							self.reportAgent.addConstant(loadedSchemaFile.name, loadedConstant, self.reportAgent.Object_Missing);
							self.errorsOccurred := true;
						endif;
					endif;
				endforeach;
				
				/*
				* References
				*/
				foreach loadedReference in loadedClass.allReferences do
					//Loop through references
					if not loadedReference.modifiedTimeStamp &lt; requiredTimeStamp then
						continue;
					endif;
					
					currentReference := currentClass.getProperty(loadedReference.name).Reference; //Get the current constant from the environment
					if currentReference &lt;&gt; null then 									//If we can find the constant then compare it
						if currentReference.type.name &lt;&gt; loadedReference.type 
							or currentReference.text &lt;&gt; loadedReference.documentationTextData 
							//or currentReference.getSource() &lt;&gt; loadedReference.value
						then 															//If the documentation text, value and type on the constant doesn't match then 
																						//add to differing constants array
							self.reportAgent.createReport(loadedSchemaFile, _reportType);
							self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Link);
							self.reportAgent.addReference(loadedSchemaFile.name, loadedReference, self.reportAgent.Object_Different);
							
							self.errorsOccurred := true;
						endif;
					else 																//Add it to the missing constants array as it does not exist
						self.reportAgent.createReport(loadedSchemaFile, _reportType);
						self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Link);
						self.reportAgent.addReference(loadedSchemaFile.name, loadedReference, self.reportAgent.Object_Missing);
						
						self.errorsOccurred := true;
					endif;
				endforeach;
				
				/*
				* Methods
				* Process method comparison for class
				*/
				foreach loadedMethod in loadedClass.allMethods do
					if loadedMethod.name = "translateForm" then
						continue;
					endif;
					
					if not loadedMethod.modifiedTimeStamp &lt; requiredTimeStamp then
						continue;
					else
						currentMethod := currentClass.getMethod(loadedMethod.name);
						if currentMethod &lt;&gt; null then
							//Method Exists in both classes
							if currentMethod.getSource() &lt;&gt; loadedMethod.desc
								or currentMethod.text &lt;&gt; loadedMethod.documentationTextData
							then
								self.reportAgent.createReport(loadedSchemaFile, _reportType);
								self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Link);
								self.reportAgent.addMethod(loadedSchemaFile.name, loadedMethod, self.reportAgent.Object_Different);
								
								self.errorsOccurred := true;
							endif;
						else
							self.reportAgent.createReport(loadedSchemaFile, _reportType);
							self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Link);
							self.reportAgent.addMethod(loadedSchemaFile.name, loadedMethod, self.reportAgent.Object_Missing);
							
							self.errorsOccurred := true;
						endif;
					endif;
				endforeach;
			endif;
		endforeach;
	endif;
	
end;</source>
        <Parameter name="_fileAndDirectory" type="String"/>
        <Parameter name="_schemaFileName" type="String"/>
        <Parameter name="_writeMethodsToFile" type="Boolean"/>
        <Parameter name="_reportType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doGetRecentlyModified" id="8f841152-4e68-45c0-a532-bc29de437b7a">
        <updating/>
        <source>doGetRecentlyModified(_fileAndDirectory,
					_schemaFileName 	: String; 
					_writeMethodsToFile : Boolean;
					_reportType			: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 December 2021	navpw1	Initial creation TFS: 52202

*/

vars
	devSchemaSection				: DEV_SchemaGenericSection;
	targetDir, 
	appLogTmpDir,
	currentSource					: String;
	currentSchemaData				: Schema;
	currentConstantCategory 		: ConstantCategory;
	currentConstant					: Constant;
	currentClass 					: Class;
	currentAttribute				: Property;
	currentReference				: Reference;
	currentPrimitive				: PrimType;
	currentInterface				: JadeInterface;
	currentMethod 					: Method;
	loadedSchemaFile 				: DEV_Schema;
	loadedSchemaClassesSection 		: DEV_SchemaClassesSection;
	loadedSchemaMethodSection		: DEV_SchemaClassesSection;
	loadedSchemaConstantsSection 	: DEV_SchemaConstantsSection;
	loadedClass						: DEV_Class;
	loadedAttribute					: DEV_Attribute;
	loadedMethod					: DEV_Method;
	loadedConstantCategory			: DEV_GlobalConstantCategory;
	loadedGlobalConstant			: DEV_GlobalConstant;
	loadedConstant					: DEV_ClassConstant;
	loadedReference					: DEV_Reference;
	property						: Property;
	outputFile 						: File;
	requiredTimeStamp 				: TimeStamp;
	
begin
	if _schemaFileName.cnContains("JMMobileClientBaseSchema") or _schemaFileName.cnContains("TestingDataLoadSchema") then
		return;
	endif;
	
	requiredTimeStamp := requiredTimeStamp.subtractHoursAndMinutes(self.DaysForComparison * 24);
	
	self.logMessage("Running Comparison for '" &amp; _fileAndDirectory &amp; "'", LogDEBUG);
	
	//Load the selected schema file
	appLogTmpDir := app.getAppServerLogDir() &amp; '\tmpFiles';
	
	targetDir := app.copyFileToAppServer(_fileAndDirectory);
	
	self.logMessage("File copied from '" &amp; _fileAndDirectory &amp; "' to '" &amp; targetDir &amp; "'", LogDEBUG);
	
	self.createSections();
	
	self.logMessage("Loading Schema File: '" &amp; _schemaFileName &amp; "'", LogDEBUG);
	self.doLoadSchemaFile(targetDir, _schemaFileName);
	self.logMessage("Finished Loading Schema", LogDEBUG);
	
	loadedSchemaFile := self.mySchemaFile.mySchema;
	
	/*
	**	Run class and method comparison between the 2
	*/
	
	//Get Loaded Schema Data
	//Not sure why this exists??????
	//Find the use of typeSources
	if(loadedSchemaFile.allSections.getAtKey("typeSources") &lt;&gt; null) then
		loadedSchemaClassesSection := loadedSchemaFile.allSections.getAtKey("typeSources").DEV_SchemaClassesSection;
	else
		//throw exception
	endif;
	
	//Get Loaded Schema Constant Data
	if(loadedSchemaFile.allSections.getAtKey("constantDefinitions") &lt;&gt; null) then
		loadedSchemaConstantsSection := loadedSchemaFile.allSections.getAtKey("constantDefinitions").DEV_SchemaConstantsSection;
	endif;
	
	if(loadedSchemaFile.allSections.getAtKey("typeDefinitions") &lt;&gt; null) then
		loadedSchemaMethodSection := loadedSchemaFile.allSections.getAtKey("typeDefinitions").DEV_SchemaClassesSection;
	else
		//throw exception
	endif;
	
	//Process each class in schema and check if current schema has the same class
	
	self.logMessage("Checking Schema '" &amp; loadedSchemaFile.name &amp; "'", LogDEBUG);
	
	currentSchemaData := rootSchema.getSchema(loadedSchemaFile.name);
	
	if currentSchemaData = null then
		self.logMessage("Schema not found | " &amp; loadedSchemaFile.name, LogFATAL);
		self.errorsOccurred := true;
		return;
	endif;
	
	/*
	* Global Constant Categories?
	* Global Constants
	*/
	if loadedSchemaConstantsSection &lt;&gt; null then
		foreach loadedConstantCategory in loadedSchemaConstantsSection.allConstantCategories do
			currentConstantCategory := currentSchemaData.getCategory(loadedConstantCategory.name);
			if currentConstantCategory &lt;&gt; null then
				if currentConstantCategory.text &lt;&gt; loadedConstantCategory.documentationTextData 
					and loadedConstantCategory.modifiedTimeStamp &gt; requiredTimeStamp 
				then
					self.reportAgent.createReport(loadedSchemaFile, _reportType);
					self.reportAgent.addGcCategory(loadedSchemaFile.name, loadedConstantCategory, self.reportAgent.Object_Different);
				endif;
				
				foreach loadedGlobalConstant in loadedConstantCategory.allConstants do
					if not loadedGlobalConstant.modifiedTimeStamp &gt; requiredTimeStamp then 		//Check if the last modified timestamp is greater than 7 days ago
						continue; 																//If not continue looping
					else
						currentConstant := currentSchemaData.getConstant(loadedGlobalConstant.name);
						if currentConstant &lt;&gt; null then 
							if currentConstant.text &lt;&gt; loadedGlobalConstant.documentationTextData 
								or currentConstant.getSource() &lt;&gt; loadedGlobalConstant.value
								//currentConstant.type.name &lt;&gt; loadedGlobalConstant.type - Needs implementing
							then
								self.reportAgent.createReport(loadedSchemaFile, _reportType);
								self.reportAgent.addGcCategory(loadedSchemaFile.name, loadedConstantCategory, reportAgent.Object_Link);
								self.reportAgent.addGlobalConstant(loadedSchemaFile.name, loadedGlobalConstant, reportAgent.Object_Different);
								
								self.errorsOccurred := true;
							endif;
			
						else
							self.reportAgent.createReport(loadedSchemaFile, _reportType);
							self.reportAgent.addGcCategory(loadedSchemaFile.name, loadedConstantCategory, reportAgent.Object_Link);
							self.reportAgent.addGlobalConstant(loadedSchemaFile.name, loadedGlobalConstant, reportAgent.Object_Missing);
							
							self.errorsOccurred := true;
						endif;
					endif;
				endforeach;
			else
				self.reportAgent.createReport(loadedSchemaFile, _reportType);
				self.reportAgent.addGcCategory(loadedSchemaFile.name, loadedConstantCategory, reportAgent.Object_Missing);
				
				self.errorsOccurred := true;
			endif;
			
		endforeach;
	endif;
	
	
	/*
	* Classes and Methods/Attributes/Constants check
	*/
	if loadedSchemaMethodSection &lt;&gt; null then
		foreach loadedClass in loadedSchemaMethodSection.allClasses do
			currentClass := currentSchemaData.getClass(loadedClass.name);
			
			if self.classIsIgnored(currentSchemaData, loadedClass.name) then
				continue;
			endif;
			
			if currentClass &lt;&gt; null then 											//If we can find the class then compare it
				if currentClass.text &lt;&gt; loadedClass.documentationTextData then 		//If the documentation text on the class doesn't match then add to differing classes array
					self.reportAgent.createReport(loadedSchemaFile, _reportType);
					self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Different);
					
					self.errorsOccurred := true;
				endif;
				
				/*
				* Attributes
				*/
				foreach loadedAttribute in loadedClass.allAttributes do 					//Loop through attributes
					if not loadedAttribute.modifiedTimeStamp &gt; requiredTimeStamp then 		//Check if the last modified timestamp is greater than 7 days ago
						continue; 															//If not continue looping
					else
						currentAttribute := currentClass.getProperty(loadedAttribute.name); //Get the current attribute from the environment
						if(currentAttribute &lt;&gt; null) then 									//If we can find the attribute then compare it
							if currentAttribute.type.name &lt;&gt; loadedAttribute.type
								or (currentAttribute.type.name = DEV_Attribute.AttrType_String and
									loadedAttribute.type = DEV_Attribute.AttrType_String and
									currentAttribute.Attribute.length &lt;&gt; loadedAttribute.length)	//Check that string lengths are the same
								or currentAttribute.text &lt;&gt; loadedAttribute.documentationTextData	//ToDo - Add a check for Decimal length and precision plus other types
							then 															//If the documentation text and type on the attribute doesn't match then 
																							//add to differing attributes array
								self.reportAgent.createReport(loadedSchemaFile, _reportType);
								self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Link);
								self.reportAgent.addAttribute(loadedSchemaFile.name, loadedAttribute, self.reportAgent.Object_Different);
								
								self.errorsOccurred := true;
							endif;
						else 																//Add it to the missing attributes array as it does not exist
							self.reportAgent.createReport(loadedSchemaFile, _reportType);
							self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Link);
							self.reportAgent.addAttribute(loadedSchemaFile.name, loadedAttribute, self.reportAgent.Object_Missing);
							self.errorsOccurred := true;
						endif;
					endif;
				endforeach;
				
				/*
				* Constants
				*/
				foreach loadedConstant in loadedClass.allConstants do 						//Loop through constants
					if not loadedConstant.modifiedTimeStamp &gt; requiredTimeStamp then 		//Check if the last modified timestamp is greater than 7 days ago
						continue; 															//If not continue looping
					else
						currentConstant := currentClass.getConstant(loadedConstant.name); 	//Get the current constant from the environment
						if currentConstant &lt;&gt; null then 									//If we can find the constant then compare it
							if currentConstant.type.name &lt;&gt; loadedConstant.type 
								or currentConstant.text &lt;&gt; loadedConstant.documentationTextData 
								or currentConstant.getSource() &lt;&gt; loadedConstant.value
							then 															//If the documentation text, value and type on the constant doesn't match then 
																							//add to differing constants array
								self.reportAgent.createReport(loadedSchemaFile, _reportType);
								self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Link);
								self.reportAgent.addConstant(loadedSchemaFile.name, loadedConstant, self.reportAgent.Object_Different);
								
								self.errorsOccurred := true;
							endif;
						else 																//Add it to the missing constants array as it does not exist
							self.reportAgent.createReport(loadedSchemaFile, _reportType);
							self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Link);
							self.reportAgent.addConstant(loadedSchemaFile.name, loadedConstant, self.reportAgent.Object_Missing);
							self.errorsOccurred := true;
						endif;
					endif;
				endforeach;
				
				/*
				* References
				*/
				foreach loadedReference in loadedClass.allReferences do
					currentReference := null;
					//Loop through references
					if not loadedReference.modifiedTimeStamp &gt; requiredTimeStamp then
						continue;
					endif;
					
					property := currentClass.getProperty(loadedReference.name);	//Protect against invalid class type errors in case DMAST has a class and WMAST has the property as attribute
					if property.isKindOf(Reference) then
						currentReference := property.Reference; //Get the current constant from the environment
					endif;
					
					if currentReference &lt;&gt; null then 									//If we can find the constant then compare it
						if currentReference.type.name &lt;&gt; loadedReference.type 
							or currentReference.text &lt;&gt; loadedReference.documentationTextData 
							//or currentReference.getSource() &lt;&gt; loadedReference.value
						then 															//If the documentation text, value and type on the constant doesn't match then 
																						//add to differing constants array
							self.reportAgent.createReport(loadedSchemaFile, _reportType);
							self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Link);
							self.reportAgent.addReference(loadedSchemaFile.name, loadedReference, self.reportAgent.Object_Different);
							
							self.errorsOccurred := true;
						endif;
					else 																//Add it to the missing constants array as it does not exist
						self.reportAgent.createReport(loadedSchemaFile, _reportType);
						self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Link);
						self.reportAgent.addReference(loadedSchemaFile.name, loadedReference, self.reportAgent.Object_Missing);
						
						self.errorsOccurred := true;
					endif;
				endforeach;
				
				/*
				* Methods
				* Process method comparison for class
				*/
				foreach loadedMethod in loadedClass.allMethods do
					if loadedMethod.name = "translateForm" then
						continue;
					endif;
					
					if not loadedMethod.modifiedTimeStamp &gt; requiredTimeStamp then
						continue;
					else
						currentMethod := currentClass.getMethod(loadedMethod.name);
						if currentMethod &lt;&gt; null then
							//Method Exists in both classes
							currentSource := currentMethod.getSource();
							if (currentSource &lt;&gt; loadedMethod.desc and currentSource[1:currentSource.length-CrLf.length] &lt;&gt; loadedMethod.desc)	// If the only difference is a CrLf at the end, then we don't care
								or currentMethod.text &lt;&gt; loadedMethod.documentationTextData
							then
								self.reportAgent.createReport(loadedSchemaFile, _reportType);
								self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Link);
								self.reportAgent.addMethod(loadedSchemaFile.name, loadedMethod, self.reportAgent.Object_Different);
								
								self.errorsOccurred := true;
							endif;
						else
							self.reportAgent.createReport(loadedSchemaFile, _reportType);
							self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Link);
							self.reportAgent.addMethod(loadedSchemaFile.name, loadedMethod, self.reportAgent.Object_Missing);
							
							self.errorsOccurred := true;
						endif;
					endif;
				endforeach;
			endif;
		endforeach;
	endif;
	
end;</source>
        <Parameter name="_fileAndDirectory" type="String"/>
        <Parameter name="_schemaFileName" type="String"/>
        <Parameter name="_writeMethodsToFile" type="Boolean"/>
        <Parameter name="_reportType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doLoadJadeMethod" id="b3e62a64-8afa-4027-b890-b2a9a37b79b8">
        <source>doLoadJadeMethod(_file : File io; _schemaFileName : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 November 2022	navpw1	Initial creation

*/

constants
	JadeVersionRegex = "jadeVersionNumber\s(?'jadeVersion'[0-9." &amp; '"' &amp; "]*);";
	JadeCommandRegex = "JADE COMMAND FILE NAME";
	REGEXIGNORECASE : Boolean = true;
	REGEXEXPLICITCAPTURE : Boolean = true;
	LeadingTabs 			= "^[\t]*";
	
	//Schema Stuff
	FirstSchemaLine 	= "(?'schema'[A-Za-z0-9]*)\ssubschemaOf\s(?'subSchema'[A-Za-z]*)\s(?'otherData'[A-za-z0-9\s,=;]*)";
	ModifiedTimeStamp 	= "\t\tsetModifiedTimeStamp\s(?'modifiedTimestamp'[A-Za-z0-9&lt;&gt;" &amp; '"' &amp; "\s.:;]*)";
	
	//Type Definitions
	PartialDefinitionRegex = "^[\s\t]*(?'className'[a-zA-z0-9:]*)[\s\t]*partialDefinition$";
	JadeMethodDefWholeRegex 	= "^[\s]*(?'name'[A-Za-z0-9_-]*)[^\)]+?\)[^;]*;[\r\n]*";

	//Type Sources
	MethodStartRegex 		= "^{$";
	ClassRegex 				= "^\t(?'className'[A-Za-z0-9_]*)";
	SignatureEnd 			= "^.*end[\s]*;.*$";
	CommentStartRegex 		= "^[\s\t]*\/\*.[^\*\/]*$";
	CommentEndRegex 		= "^.*\*\/.*$";
	CompleteCommentRegex 	= "^.*\/\*.*\*\/.*$";
	MethodEndRegex 			= "^}$";
	StartComment 			= "\/\*";
	EndComment 				= "\*\/";
	ReplaceOneEndCrLf 		= "[\r\n]{1}$";
	
vars
	line			: String;
	lineNumber 		: Integer;
	matches			: JadeRegexMatch;
	schema,
	classNameDef,
	methodNameDef,
	methodDef,
	documentationTextStr,
	classNameSource,
	methodSourceName,
	methodDescSource,
	previousLine : String;
	modifiedTimeStamp 			: LSModifiedTimeStamp;
	
	processingMethod,
	processingMethodData,				//Whether we are processing method data. Gets set after we read '{' as thats the method start
	processingComment		: Boolean;	//used to determine if we are reading a comment as method keywords could be in a comment and we want to ignore it
	currentMethodCount,
	currentMethodDataCount: Integer;
	
begin
	lineNumber := 0; //Initialise Line Number
	
	line := _file.readLine(); //Read the next line
	lineNumber += 1; //Grab next line number
	
	//Read until schema definitions
	while not JadeRegex@contains(line, "schemaDefinition", REGEXIGNORECASE) do
		line := _file.readLine(); //Read the next line
		lineNumber += 1; //Grab next line number
	endwhile;
	
	line := _file.readLine(); //Read the next line
	lineNumber += 1; //Grab next line number
	
	//Should be Schema Def Line
	if (JadeRegex@match(line, FirstSchemaLine, REGEXIGNORECASE, REGEXEXPLICITCAPTURE, matches)) then //Read Jade Version from file
		schema := matches.getCaptureByName("schema").value;
		write "Schema: " &amp; schema;
	endif;
	
	//Read until type definitions
	while not JadeRegex@contains(line, "typeDefinitions", REGEXIGNORECASE) do
		line := _file.readLine(); //Read the next line
		lineNumber += 1; //Grab next line number
	endwhile;
	
	line := _file.readLine(); //Read the next line
	lineNumber += 1; //Grab next line number
	
	//Grab class name from type definitions
	if JadeRegex@match(line, PartialDefinitionRegex, REGEXIGNORECASE, REGEXEXPLICITCAPTURE, matches) then
		classNameDef := matches.getCaptureByName("className").value;
		write "Class Name Def: " &amp; classNameDef;
	endif;
	
	line := _file.readLine(); //Read the next line
	lineNumber += 1; //Grab next line number
	
	//Skip over "	(" line
	line := _file.readLine(); //Read the next line
	lineNumber += 1; //Grab next line number
	
	//Skip over "jadeMethodDefinitions" line
	line := _file.readLine(); //Read the next line
	lineNumber += 1; //Grab next line number
	
	//Grab method name from type definitions
	
	if JadeRegex@match(line, JadeMethodDefWholeRegex, true, true, matches) then
		methodDef := JadeRegex@replaceAll(matches.value, "", LeadingTabs, true);
		
		methodNameDef := matches.getCaptureByName("name").value;
		JadeRegex@replaceAll(methodDef, "", "\r\n$", true);
		
		write "Method Name Def: " &amp; methodNameDef;
		write "Method Definition: " &amp; methodDef;
		
		line := _file.readLine(); //Read the next line
		lineNumber += 1; //Grab next line number
	else
		//In case we are a multi line method descriptor (Can happen)
		while not JadeRegex@isMatch(line, SetModifiedTimeStampRegex, true) do
		
		endwhile;
	endif;
	
	create modifiedTimeStamp transient;
	
	//Grab method last modified by from type definitions
	if self.checkModifiedTimestamp(line, modifiedTimeStamp) then
		write "Modified TimeStamp: " &amp; modifiedTimeStamp.modifiedTimeStamp.String;
		write "Modified By: " &amp; modifiedTimeStamp.modifiedBy;
		line := _file.readLine(); //Read the next line
		lineNumber += 1; //Grab next line number
	endif;
	
	//Grab method documentation text from type definitions
	if JadeRegex@isMatch(line, "^\s*documentationText", true) then
		//documentationText Loop to get text data
		documentationTextStr := null;
		documentationTextStr := self.getDocumentationText(line, lineNumber, _file);
		documentationTextStr := null;
		line := _file.readLine(); //Read the next line
		lineNumber += 1; //Grab next line number
	endif;
	
	//Read until type sources
	while not JadeRegex@contains(line, "typeSources", REGEXIGNORECASE) do
		line := _file.readLine(); //Read the next line
		lineNumber += 1; //Grab next line number
	endwhile;
	
	line := _file.readLine(); //Read the next line
	lineNumber += 1; //Grab next line number
	
	//Grab class name from type sources
	if JadeRegex@match(line, ClassRegex, REGEXIGNORECASE, REGEXEXPLICITCAPTURE, matches) then
		classNameSource := matches.getCaptureByName("className").value;
		write "Class Name Source: " &amp; classNameSource;
		line := _file.readLine(); //Read the next line
		lineNumber += 1; //Grab next line number
	endif;
	
	//Skip over "	(" line
	line := _file.readLine(); //Read the next line
	lineNumber += 1; //Grab next line number
	
	//Skip over "jadeMethodSources" line
	line := _file.readLine(); //Read the next line
	lineNumber += 1; //Grab next line number
	
	//Grab method name from type sources
	methodSourceName := line.removeTabCrLfs().trimWhiteSpace();
	//line := _file.readLine(); //Read the next line
	//lineNumber += 1; //Grab next line number
	
	//Skip over "{" line - Maybe don't skip it for now
	//line := _file.readLine(); //Read the next line
	//lineNumber += 1; //Grab next line number
	
	//Grab method desc/code from type sources
	processingComment := false;
	processingMethod := false;
	processingMethodData := false;
	currentMethodCount := 0;
	
	while true do
		line := _file.readLine();
		lineNumber := lineNumber + 1;
	
		if(line = null and _file.endOfFile()) then
			break;
		endif;
		
		if (not processingComment and not processingMethodData and JadeRegex@isMatch(line, MethodStartRegex, true)) then
				currentMethodCount := currentMethodCount + 1; //Not needed?
				methodSourceName := previousLine;
				processingMethod := true;
		elseif (not processingComment and line = "begin") then
			if (processingMethodData) then
				methodDescSource := methodDescSource &amp; line &amp; CrLf;
				currentMethodDataCount := currentMethodDataCount + 1;
			else
				processingMethodData := true;
				methodDescSource := methodDescSource &amp; line &amp; CrLf;
				currentMethodDataCount := 1;
			endif;

		elseif (not processingComment and JadeRegex@isMatch(line, SignatureEnd, true)) then
		
			if (currentMethodDataCount = 1) then
				processingMethodData := false;
				methodDescSource := methodDescSource &amp; line &amp; CrLf;
			else
				currentMethodDataCount := currentMethodDataCount - 1;
				methodDescSource := methodDescSource &amp; line &amp; CrLf;
			endif;
			
		
		elseif (JadeRegex@contains(line, StartComment, true) and (JadeRegex@isMatch(line, CommentStartRegex, true) or line = "/*")) then //Do not process commented code inside method as method endings
			processingComment := true;
			methodDescSource := methodDescSource &amp; line &amp; CrLf;
		
		elseif (JadeRegex@contains(line, EndComment, true) and JadeRegex@isMatch(line, CommentEndRegex, true)) then 
			processingComment := false;
			methodDescSource := methodDescSource &amp; line &amp; CrLf;
		
		elseif (JadeRegex@isMatch(line, CompleteCommentRegex, true)) then
			methodDescSource := methodDescSource &amp; line &amp; CrLf;
				
		elseif (not processingComment and not processingMethodData and JadeRegex@isMatch(line, MethodEndRegex, true)) then //end of method so read data
			if (currentMethodCount = 1) then
				methodDescSource := JadeRegex@replaceAll(methodDescSource, "", ReplaceOneEndCrLf, true);
				processingMethod := false;
			else
				currentMethodCount := currentMethodCount - 1;
				methodDescSource := methodDescSource &amp; line &amp; CrLf;
			endif;
		elseif processingMethod then
			methodDescSource := methodDescSource &amp; line &amp; CrLf;
			previousLine := line; //Used for MethodName as it appears before the { in the file
		else
			previousLine := line; //Used for MethodName as it appears before the { in the file
		endif;
		
	endwhile;
	
	write "Method Source Name: " &amp; methodSourceName;
	
	write "Method Source Desc:";
	write methodDescSource;
	
	//Finish and update method for the class/schema
	
	//Check class and method names match from different sections
	
	//Lookup schema, class and method
	
	//Update method
	
epilog
	delete modifiedTimeStamp;
	
end;</source>
        <Parameter name="_file" type="File" usage="io"/>
        <Parameter name="_schemaFileName" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadSchemaFile" id="639727c6-b0c1-406d-aa8e-81d075ecfd7c">
        <updating/>
        <source>doLoadSchemaFile(_fileAndDirectory, _schemaFileName : String) updating;
/*

Purpose:			Loads the schema file into transients

Parameters:			_fileAndDirectory:	File &amp; directory to load
					_schemaFileName:	Filename of the schema to load

Return Value:		

Date		Who		Reason
19 October 2021	navpw1	Initial creation TFS: 52202

*/
	
begin
	self.createSections();
	self.loadSchemaFile(_fileAndDirectory, _schemaFileName);
	self.cleanUpFiles(app.getAppServerLogDir() &amp; '\tmpFiles', _schemaFileName, _fileAndDirectory, true, false, false);
	
end;</source>
        <Parameter name="_fileAndDirectory" type="String"/>
        <Parameter name="_schemaFileName" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadTypeDefinitionsSection" id="fed1a151-dbd4-4ebc-a777-871ee11b8ff2">
        <updating/>
        <source>doLoadTypeDefinitionsSection(_fileAndDirectory, _schemaFileName : String) updating;
/*

Purpose:			Temp Method

Parameters:			

Return Value:		

Date		Who		Reason
30 November 2021	navpw1	Initial creation TFS:52202

*/

constants
	JadeVersionRegex = "jadeVersionNumber\s(?'jadeVersion'[0-9." &amp; '"' &amp; "]*);";
	JadeCommandRegex = "JADE COMMAND FILE NAME";
	
vars
	line			: String;
	inputFile 		: File;
	lineNumber 		: Integer;
	matches			: JadeRegexMatch;
	
begin
	self.createSections();
	
	if self.mySchemaFile &lt;&gt; null then
		delete self.mySchemaFile;
	endif;
	self.trxCreateSchemaFile(_schemaFileName);
	
	//Create Transients
	create inputFile transient;
					
	inputFile.maxRecordSize := self.MaxRecordSize;
	inputFile.usePresentationFileSystem := false;
	inputFile.openInput(_fileAndDirectory);
	
	lineNumber := 0; //Initialise Line Number
	
	line := inputFile.readLine(); //Read the next line
	lineNumber += 1; //Grab next line number
	
	if (JadeRegex@match(line, JadeVersionRegex, true, true, matches)) then //Read Jade Version from file
		self.trxUpdateSchemaFile(matches.getCaptureByName("jadeVersion").value, self.mySchemaFile.commandFileData); //Update our file with the jade version number
	endif;

	line := inputFile.readLine(); //Read the next line
	lineNumber += 1; //Grab next line number
	
	if (JadeRegex@contains(line, JadeCommandRegex, true)) then //Jade command file name is optional in schema files
		self.trxUpdateSchemaFile(self.mySchemaFile.jadeVersion, line); //Update our file with the Jade command file name
	endif;
	
	while true do
		delete matches; //Transients are created everytime JadeRegex@match is called
		
		//Process File
		if (line = "schemaDefinition") then
			self.loadSchemaSection(line, line, lineNumber, inputFile);
		elseif(line = "typeDefinitions") then //Is this line a section header
			self.loadTypeDefinitionsSection(line, line, lineNumber, inputFile);
		else
			line := inputFile.readLine(); //Read the next line
			
			//EOF check
			if(line = null and inputFile.endOfFile()) then
				break;
			endif;

			lineNumber += 1;
			
		endif;
	endwhile;
	
epilog
	delete inputFile;
	delete matches;

end;</source>
        <Parameter name="_fileAndDirectory" type="String"/>
        <Parameter name="_schemaFileName" type="String"/>
    </JadeMethod>
    <JadeMethod name="doProcessMthFile" id="1aa6afba-8281-4431-8f94-f1d7175449a8">
        <source>doProcessMthFile(_fileAndDirectory : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
01 February 2024	navpw1	Initial creation

*/

constants
	JadeVersionRegex = "jadeVersionNumber\s(?'jadeVersion'[0-9." &amp; '"' &amp; "]*);";
	JadeCommandRegex = "JADE COMMAND FILE NAME";
	FirstSchemaLine 	= "(?'schema'[A-Za-z0-9]*)\ssubschemaOf\s(?'subSchema'[A-Za-z]*)\s(?'otherData'[A-za-z0-9\s,=;]*)";
	ClassDefinitionRegex = "^[\s\t]*(?'className'[a-zA-z0-9:]*)$";
	JadeMethodRegex 	= "^[\s]*(?'name'[A-Za-z0-9_-]*)[^\)]+?\)[^;]*;[\r\n]*";
	EndOfClass 				= "^[\s]?\)$";
	ClassSourceRegex 				= "^\t(?'className'[A-Za-z0-9_]*)\s*\(";
	
	LeadingTabs 			= "^[\t]*";
	DocumentationText 	= "documentationText";
	
vars
	line			: String;
	inputFile,
	outputFile		: File;
	lineNumber 		: Integer;
	matches			: JadeRegexMatch;
	fileReadingCompleted : Boolean;
	modifiedTimeStamp		: LSModifiedTimeStamp;
	jadeMethodDesc,
	methodDefName,
	methodName,
	methodSource	: String;
	schema,
	subSchema,
	otherData,
	classDefName,
	className : String;
	
begin
	//Create Transients
	create modifiedTimeStamp;
    create inputFile transient;
	create outputFile transient;
	
	inputFile.maxRecordSize := self.MaxRecordSize;
    inputFile.usePresentationFileSystem := false;
    inputFile.mode := inputFile.Mode_Input;
    inputFile.unicodeBOM := true;
    inputFile.kind := inputFile.Kind_Unicode; //Most extracted files are from Jade 2022
    inputFile.openInput(_fileAndDirectory);
	
	// Re save the file as ANSI until Wmast is on 2022
    outputFile.usePresentationFileSystem := false;
    outputFile.mode := File.Mode_Output;
    outputFile.kind := File.Kind_ANSI;
    outputFile.fileName := inputFile.fileName &amp; "_ansi";
    outputFile.writeString(inputFile.readString(inputFile.fileLength));
    outputFile.close();
    
	inputFile.close();
    inputFile.fileName := outputFile.fileName;
    inputFile.unicodeBOM := false;
    inputFile.kind := File.Kind_ANSI;
    inputFile.open();
	
	lineNumber := 0; //Initialise Line Number
	
	line := inputFile.readLine(); //Read the next line
	lineNumber += 1; //Grab next line number
	
	if (JadeRegex@match(line, JadeVersionRegex, true, true, matches)) then //Read Jade Version from file
		//self.trxUpdateSchemaFile(matches.getCaptureByName("jadeVersion").value, self.mySchemaFile.commandFileData); //Update our file with the jade version number
	endif;
	
	line := inputFile.readLine(); //Read the next line
	lineNumber += 1; //Grab next line number
	
	if (JadeRegex@contains(line, JadeCommandRegex, true)) then //Jade command file name is optional in schema files
		line := inputFile.readLine(); //Read the next line
		lineNumber += 1; //Grab next line number
	endif;
	
	if (JadeRegex@contains(line, "schemaDefinition", true)) then
		//write "schemaDefinition Section found";
		line := inputFile.readLine(); //Read the next line
		lineNumber += 1; //Grab next line number
		
		if(JadeRegex@match(line, FirstSchemaLine, true, true, matches)) then //Do we match the first schema file line
			//write "Schema Definition Line found";
			schema := matches.getCaptureByName("schema").value;
			subSchema := matches.getCaptureByName("subSchema").value;
			otherData := matches.getCaptureByName("otherData").value;
			
		else
			return;
		endif;
		
		line := inputFile.readLine(); //Read the next line
		lineNumber += 1; //Grab next line number
		
		if (JadeRegex@contains(line, DocumentationText, true)) then
			
			line := inputFile.readLine(); //Read the next line
			lineNumber += 1; //Grab next line number
			
		endif;
		
		if self.checkModifiedTimestamp(line, modifiedTimeStamp) then
			
			line := inputFile.readLine(); //Read the next line
			lineNumber += 1; //Grab next line number
			
		endif;
		
		if (JadeRegex@contains(line, "typeDefinitions", true)) then
			line := inputFile.readLine(); //Read the next line
			lineNumber += 1; //Grab next line number
			
			if JadeRegex@match(line, ClassDefinitionRegex, true, true, matches) then
				classDefName := matches.getCaptureByName("className").value;
				
				line := inputFile.readLine(); //Read the next line
				lineNumber += 1; //Grab next line number
				
			else
				return;
			endif;
			
			if line = "	(" then
				line := inputFile.readLine(); //Read the next line
				lineNumber += 1; //Grab next line number
				
			endif;
			
			if (JadeRegex@contains(line, "jadeMethodDefinitions", true)) then
				line := inputFile.readLine(); //Read the next line
				lineNumber += 1; //Grab next line number
				
				if JadeRegex@match(line, JadeMethodRegex, true, true, matches) then
					jadeMethodDesc := JadeRegex@replaceAll(matches.value, "", LeadingTabs, true);
					methodDefName := matches.getCaptureByName("name").value;
					JadeRegex@replaceAll(jadeMethodDesc, "", "\r\n$", true);
					
					line := inputFile.readLine(); //Read the next line
					lineNumber += 1; //Grab next line number
					
					if (JadeRegex@contains(line, DocumentationText, true)) then
						line := inputFile.readLine(); //Read the next line
						lineNumber += 1; //Grab next line number
						
					endif;
					
					if self.checkModifiedTimestamp(line, modifiedTimeStamp) then
						line := inputFile.readLine(); //Read the next line
						lineNumber += 1; //Grab next line number
						
					endif;
					
				endif;
			endif;
			
			while true do
				line := inputFile.readLine(); //Read the next line
				lineNumber += 1; //Grab next line number
				
				if JadeRegex@isMatch(line, EndOfClass, true) then
					break;
				endif;
			endwhile;
			
		endif;
	endif;
	
	line := inputFile.readLine(); //Read the next line
	lineNumber += 1; //Grab next line number
	
	if (JadeRegex@contains(line, "typeSources", true)) then
		line := inputFile.readLine(); //Read the next line
		lineNumber += 1; //Grab next line number
		
		if JadeRegex@isMatch(line, ClassSourceRegex, true) then
			JadeRegex@match(line, ClassSourceRegex, true, true, matches);
			className := matches.getCaptureByName("className").value;
			
			line := inputFile.readLine(); //Read the next line
			lineNumber += 1; //Grab next line number
		else
			return;
			
		endif;
		
		if (JadeRegex@contains(line, "jadeMethodSources", true)) then
			line := inputFile.readLine(); //Read the next line
			lineNumber += 1; //Grab next line number
			
			methodName := line;
			
			line := inputFile.readLine(); //Read the next line
			lineNumber += 1; //Grab next line number
			
			//line := inputFile.readLine(); //Read the next line
			//lineNumber += 1; //Grab next line number
			
			while not inputFile.endOfFile() do
				methodSource &amp;= line &amp; CrLf;
				line := inputFile.readLine(); //Read the next line
				lineNumber += 1; //Grab next line number
				
			endwhile;
			methodSource := methodSource.stripTrailingChar(Cr).stripTrailingChar(Lf).stripTrailingChar(Cr).stripTrailingChar(Lf);
			
		endif;
		
		
	endif;
	
	write "Schema Info:";
	write"-------------";
	write "Schema: " &amp; schema;
	write "Subschema: " &amp; subSchema;
	write "Other Data: " &amp; otherData;
	write CrLf;
	write "Class Info:";
	write"-------------";
	write "Class Name Def: " &amp; classDefName;
	write "Method Name: " &amp; methodDefName;
	write "Method Desc: " &amp; jadeMethodDesc;
	write CrLf;
	
	write "Method Info:";
	write"-------------";
	write "Class Name: " &amp; className;
	write "Method Name: " &amp; methodName;
	write "Method Source: " &amp; CrLf &amp; methodSource;
	
	fileReadingCompleted := true;
	
	//Create an output window of what was found in the file using a transient object
	//Get user to approve loading of the data into the source compare report
	//Logic for loading into the report:
	//Loop through the source compare report
	//Find Method from schema, class and method name
	//Strip '{' &amp; '}' and update method source
	//Save the changes to the report
	
epilog
	delete inputFile;
	delete outputFile;
	delete matches;
	if not fileReadingCompleted then
		write "Reading File failed: " &amp; CrLf &amp; "Line Number: " &amp; lineNumber.String &amp; CrLf &amp; "Line: " &amp; line;
	endif;
	delete modifiedTimeStamp;
	
end;</source>
        <Parameter name="_fileAndDirectory" type="String"/>
    </JadeMethod>
    <JadeMethod name="doSchemaComparison" id="5ec05886-afa3-4da2-89e9-b8b8d7d481f0">
        <updating/>
        <source>doSchemaComparison(_fileAndDirectory,
					_schemaFileName 	: String; 
					_writeMethodsToFile : Boolean;
					_reportType			: Integer) updating;
/*

Purpose:			Do the schema comparison

Parameters:			_fileAndDirectory:		String		File and directory of the schema to load
					_schemaFileName:		String		The schema filename to load
					_writeMethodsToFile:	Boolean		Should we write methods to file

Return Value:		

Date				Who		Reason
03 November 2021	navpw1	Initial creation TFS: 52202
12 December 2023	navmd1	Ignore differences in HotfixesCommonSchema

*/

vars
	targetDir, 
	appLogTmpDir,
	currentSource					: String;
	currentSchemaData				: Schema;
	currentConstantCategory 		: ConstantCategory;
	currentConstant					: Constant;
	currentClass 					: Class;
	currentAttribute				: Property;
	currentReference				: Reference;
	currentMethod 					: Method;
	loadedSchemaFile 				: DEV_Schema;
	loadedSchemaClassesSection 		: DEV_SchemaClassesSection;
	loadedSchemaConstantsSection 	: DEV_SchemaConstantsSection;
	loadedClass						: DEV_Class;
	loadedAttribute					: DEV_Attribute;
	loadedConstant					: DEV_ClassConstant;
	loadedReference					: DEV_Reference;
	loadedMethod					: DEV_Method;
	loadedConstantCategory			: DEV_GlobalConstantCategory;
	loadedGlobalConstant			: DEV_GlobalConstant;
	property						: Property;
	
	//Temp
	outputFile 						: File;
	
begin
	if	_schemaFileName.cnContains("JMMobileClientBaseSchema") or
		_schemaFileName.cnContains("TestingDataLoadSchema") or
		_schemaFileName.cnContains("HotFixesCommonSchema")
	then
		return;
	endif;
	
	self.logMessage("Running Comparison for '" &amp; _fileAndDirectory &amp; "'", LogDEBUG);
	
	//Load the selected schema file
	appLogTmpDir := app.getAppServerLogDir() &amp; '\tmpFiles';
	
	targetDir := app.copyFileToAppServer(_fileAndDirectory);
	
	self.logMessage("File copied from '" &amp; _fileAndDirectory &amp; "' to '" &amp; targetDir &amp; "'", LogDEBUG);
	
	self.createSections();
	
	self.logMessage("Loading Schema File: '" &amp; _schemaFileName &amp; "'", LogDEBUG);
	self.doLoadSchemaFile(targetDir, _schemaFileName);
	self.logMessage("Finished Loading Schema", LogDEBUG);
	
	loadedSchemaFile := self.mySchemaFile.mySchema;
	
	/*
	**	Run class and method comparison between the 2
	*/
	
	//Get Loaded Schema Data
	if(loadedSchemaFile.allSections.getAtKey("typeDefinitions") &lt;&gt; null) then
		loadedSchemaClassesSection := loadedSchemaFile.allSections.getAtKey("typeDefinitions").DEV_SchemaClassesSection;
	else
		//throw exception
	endif;
	
	//Get Loaded Schema Constant Data
	if(loadedSchemaFile.allSections.getAtKey("constantDefinitions") &lt;&gt; null) then
		loadedSchemaConstantsSection := loadedSchemaFile.allSections.getAtKey("constantDefinitions").DEV_SchemaConstantsSection;
	endif;
	
	//Process each class in schema and check if current schema has the same class
	
	self.logMessage("Checking Schema '" &amp; loadedSchemaFile.name &amp; "'", LogDEBUG);
	
	currentSchemaData := rootSchema.getSchema(loadedSchemaFile.name);
	
	if currentSchemaData = null then
		self.logMessage("Schema not found | " &amp; loadedSchemaFile.name, LogFATAL);
		self.errorsOccurred := true;
		return;
	endif;
	
	
	/*
	**	Process Global Constant Comparison
	*/
	if loadedSchemaConstantsSection &lt;&gt; null then
		foreach loadedConstantCategory in loadedSchemaConstantsSection.allConstantCategories do
			currentConstantCategory := currentSchemaData.getCategory(loadedConstantCategory.name);
			if currentConstantCategory &lt;&gt; null then
				if currentConstantCategory.text &lt;&gt; loadedConstantCategory.documentationTextData then
					self.reportAgent.createReport(loadedSchemaFile, _reportType);
					self.reportAgent.addGcCategory(loadedSchemaFile.name, loadedConstantCategory, self.reportAgent.Object_Different);
				endif;
				
				foreach loadedGlobalConstant in loadedConstantCategory.allConstants do
					currentConstant := currentSchemaData.getConstant(loadedGlobalConstant.name);
					if currentConstant &lt;&gt; null then
						if currentConstant.text &lt;&gt; loadedGlobalConstant.documentationTextData 
							or currentConstant.getSource() &lt;&gt; loadedGlobalConstant.value
							// or currentConstant.type.name &lt;&gt; loadedGlobalConstant.type - Needs implementing
						then
							self.reportAgent.createReport(loadedSchemaFile, _reportType);
							self.reportAgent.addGcCategory(loadedSchemaFile.name, loadedConstantCategory, self.reportAgent.Object_Link);
							self.reportAgent.addGlobalConstant(loadedSchemaFile.name, loadedGlobalConstant, self.reportAgent.Object_Different);
							
							self.errorsOccurred := true;
						endif;
					else
						self.reportAgent.createReport(loadedSchemaFile, _reportType);
						self.reportAgent.addGcCategory(loadedSchemaFile.name, loadedConstantCategory, self.reportAgent.Object_Link);
						self.reportAgent.addGlobalConstant(loadedSchemaFile.name, loadedGlobalConstant, self.reportAgent.Object_Missing);
						
						self.errorsOccurred := true;
					endif;
				endforeach;
			else
				self.reportAgent.createReport(loadedSchemaFile, _reportType);
				self.reportAgent.addGcCategory(loadedSchemaFile.name, loadedConstantCategory, self.reportAgent.Object_Missing);
			
				self.errorsOccurred := true;
			endif;
			
		endforeach;
	endif;
		
	/*
	**	Process Class/Attribute/Method Comparison
	*/
	if loadedSchemaClassesSection &lt;&gt; null then
		foreach loadedClass in loadedSchemaClassesSection.allClasses do
			//Load the currentClass into a variable
			currentClass := currentSchemaData.getClass(loadedClass.name);
			
			if self.classIsIgnored(currentSchemaData, loadedClass.name) then
				continue;
			endif;
			
			if currentClass &lt;&gt; null then											//If we can find the class then compare it
				if currentClass.text &lt;&gt; loadedClass.documentationTextData then 		//If the documentation text on the class doesn't match then add to differing classes array
					self.reportAgent.createReport(loadedSchemaFile, _reportType);
					self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Different);
					
					self.errorsOccurred := true;
				endif;
				
				/*
				* Attributes
				*/
				foreach loadedAttribute in loadedClass.allAttributes do 					//Loop through attributes
					currentAttribute := currentClass.getProperty(loadedAttribute.name); //Get the current attribute from the environment
					if(currentAttribute &lt;&gt; null) then 									//If we can find the attribute then compare it
						if currentAttribute.type.name &lt;&gt; loadedAttribute.type
							or (currentAttribute.type.name = DEV_Attribute.AttrType_String and
								loadedAttribute.type = DEV_Attribute.AttrType_String and
								currentAttribute.Attribute.length &lt;&gt; loadedAttribute.length)	//Check that string lengths are the same
							or currentAttribute.text &lt;&gt; loadedAttribute.documentationTextData	//ToDo - Add a check for Decimal length and precision plus other types
						then 															//If the documentation text and type on the attribute doesn't match then 
																						//add to differing attributes array
							self.reportAgent.createReport(loadedSchemaFile, _reportType);
							self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Link);
							self.reportAgent.addAttribute(loadedSchemaFile.name, loadedAttribute, self.reportAgent.Object_Different);
							
							self.errorsOccurred := true;
						endif;
					else 																//Add it to the missing attributes array as it does not exist
						self.reportAgent.createReport(loadedSchemaFile, _reportType);
						self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Link);
						self.reportAgent.addAttribute(loadedSchemaFile.name, loadedAttribute, self.reportAgent.Object_Missing);
						
						self.errorsOccurred := true;
					endif;
				endforeach;
				
				/*
				* Constants
				*/
				foreach loadedConstant in loadedClass.allConstants do 					//Loop through constants
					currentConstant := currentClass.getConstant(loadedConstant.name); 	//Get the current constant from the environment
					if currentConstant &lt;&gt; null then 									//If we can find the constant then compare it
						if currentConstant.type.name &lt;&gt; loadedConstant.type 
							or currentConstant.text &lt;&gt; loadedConstant.documentationTextData 
							or currentConstant.getSource() &lt;&gt; loadedConstant.value
						then 															//If the documentation text, value and type on the constant doesn't match then 
																						//add to differing constants array
							self.reportAgent.createReport(loadedSchemaFile, _reportType);
							self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Link);
							self.reportAgent.addConstant(loadedSchemaFile.name, loadedConstant, self.reportAgent.Object_Different);
							
							self.errorsOccurred := true;
						endif;
					else 																//Add it to the missing constants array as it does not exist
						self.reportAgent.createReport(loadedSchemaFile, _reportType);
						self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Link);
						self.reportAgent.addConstant(loadedSchemaFile.name, loadedConstant, self.reportAgent.Object_Missing);
						
						self.errorsOccurred := true;
					endif;
				endforeach;
				
				/*
				* References
				*/
				foreach loadedReference in loadedClass.allReferences do 						//Loop through constants
					currentReference := null;
					property := currentClass.getProperty(loadedReference.name);	//Protect against invalid class type errors in case DMAST has a class and WMAST has the property as attribute
					if property.isKindOf(Reference) then
						currentReference := property.Reference; //Get the current constant from the environment
					endif;
					
					if currentReference &lt;&gt; null then 									//If we can find the constant then compare it
						if currentReference.type.name &lt;&gt; loadedReference.type 
							or currentReference.text &lt;&gt; loadedReference.documentationTextData 
							//or currentReference.getSource() &lt;&gt; loadedReference.value
						then 															//If the documentation text, value and type on the constant doesn't match then 
																						//add to differing constants array
							self.reportAgent.createReport(loadedSchemaFile, _reportType);
							self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Link);
							self.reportAgent.addReference(loadedSchemaFile.name, loadedReference, self.reportAgent.Object_Different);
							
							self.errorsOccurred := true;
						endif;
					else 																//Add it to the missing constants array as it does not exist
						self.reportAgent.createReport(loadedSchemaFile, _reportType);
						self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Link);
						self.reportAgent.addReference(loadedSchemaFile.name, loadedReference, self.reportAgent.Object_Missing);
						
						self.errorsOccurred := true;
					endif;
				endforeach;
				
				/*
				* Methods
				* Process method comparison for class
				*/
				foreach loadedMethod in loadedClass.allMethods do
					//Load the currentMethod into a variable
					if loadedMethod.name = "translateForm" then
						continue;
					endif;
					
					currentMethod := currentClass.getMethod(loadedMethod.name);
					if currentMethod &lt;&gt; null then
						//Method Exists in both classes
						
						//Run Hash to check if different
						
						//if currentMethod.getSource().trimBlankCharacters() &lt;&gt; loadedMethod.desc.trimBlankCharacters()
						currentSource := currentMethod.getSource();
						if (currentSource &lt;&gt; loadedMethod.desc and currentSource[1:currentSource.length-CrLf.length] &lt;&gt; loadedMethod.desc)	// If the only difference is a CrLf at the end, then we don't care
							or currentMethod.text &lt;&gt; loadedMethod.documentationTextData
						then
							if(_writeMethodsToFile) then
								create outputFile transient;
								outputFile.usePresentationFileSystem := false;
								outputFile.openOutput(appLogTmpDir &amp; "\" &amp; "Loaded-" &amp; loadedClass.name &amp; "--" &amp; loadedMethod.name &amp; ".jadeMethod");
								outputFile.writeString(loadedMethod.desc);
								delete outputFile;
								
								create outputFile transient;
								outputFile.usePresentationFileSystem := false;
								outputFile.openOutput(appLogTmpDir &amp; "\" &amp; "Current-" &amp; currentClass.name &amp; "--" &amp; currentMethod.name &amp; ".jadeMethod");
								outputFile.writeString(currentMethod.getSource());
								delete outputFile;
							endif;
							
							self.reportAgent.createReport(loadedSchemaFile, _reportType);
							self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Link);
							self.reportAgent.addMethod(loadedSchemaFile.name, loadedMethod, self.reportAgent.Object_Different);
							
							self.errorsOccurred := true;
						endif;
					else
						self.reportAgent.createReport(loadedSchemaFile, _reportType);
						self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Link);
						self.reportAgent.addMethod(loadedSchemaFile.name, loadedMethod, self.reportAgent.Object_Missing);
					
						//Add Method to listbox as it is different/not in the other schema
						self.errorsOccurred := true;
					endif;
				endforeach;

			else
				self.reportAgent.createReport(loadedSchemaFile, _reportType);
				self.reportAgent.addClass(loadedSchemaFile.name, loadedClass, self.reportAgent.Object_Missing);
				//Add Class to listbox as it is different/not in the other schema
				self.errorsOccurred := true;
			endif;
		endforeach;
	endif;
	
epilog
	
end;</source>
        <Parameter name="_fileAndDirectory" type="String"/>
        <Parameter name="_schemaFileName" type="String"/>
        <Parameter name="_writeMethodsToFile" type="Boolean"/>
        <Parameter name="_reportType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDocumentationText" id="33a9b4aa-f476-459e-a5e9-3804e946aadf">
        <source>getDocumentationText(_line : String io; _lineNumber : Integer io; _inputFile : File io) : String protected;
/*

Purpose:			For getting documentation text within schema files		

Parameters:			_line: 			String		Is an input output parameter used to hold the current lines text
					_lineNumber:	Integer		Is an input output parameter used to hold the current line number
					_inputFile: 	File		Is an input output parameter used to hold the current file we are working on.
												As this is used in loops

Return Value:		String: Representing the documentation text

Date		Who		Reason
10 November 2021	navpw1	Initial creation TFS: 52202

*/

constants
	GraveAccent = "`";

vars
	documentationTextStr : String;
	graveAccentRegex : JadeRegexPattern;
	pos : Integer;
begin
	//graveAccentRegex := self.regexPatterns["GraveAccentRegex"].myRegexPattern;
	pos := 1; //Needs to be Initialized
	//documentationText Loop to get text data
	_line := _inputFile.readLine();
	_lineNumber := _lineNumber + 1;
	documentationTextStr := null;
	if (JadeRegex@contains(_line, GraveAccent, false)) then
		documentationTextStr := documentationTextStr &amp; _line &amp; CrLf;
		if(_line.countOccurrences(GraveAccent) &lt; 2) then
			while true do
				_line := _inputFile.readLine();
				_lineNumber := _lineNumber + 1;
				documentationTextStr := documentationTextStr &amp; _line &amp; CrLf;
				if(JadeRegex@contains(_line, GraveAccent, false) and _line.countOccurrences(GraveAccent) = 1 and _line.pos(GraveAccent, 1) = _line.length()) then
					break;
				endif;
			endwhile;
		endif;
	endif;
	documentationTextStr := JadeRegex@replaceAll(documentationTextStr, "", ReplaceOneEndCrLf, true);
	documentationTextStr.scanUntil(GraveAccent, pos);	//Get index of GraveAccent
	documentationTextStr := documentationTextStr[pos:end]; //Substring from GraveAccent to end of string
	documentationTextStr := JadeRegex@replaceAll(documentationTextStr, "", "^`{1}|`{1}$", true); //Replace the first and last GraveAccents with nothing
	documentationTextStr := JadeRegex@replaceAll(documentationTextStr, GraveAccent, GraveAccent&amp;GraveAccent, false); // finally replace any escaped GraveAccents with just a single GraveAccent

	return documentationTextStr;

end;</source>
        <access>protected</access>
        <Parameter name="_line" type="String" usage="io"/>
        <Parameter name="_lineNumber" type="Integer" usage="io"/>
        <Parameter name="_inputFile" type="File" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
