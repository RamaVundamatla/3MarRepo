    <JadeMethod name="getMachineRuleTerminalArea" id="830615e7-0a4e-4581-b3b1-e2dfd63a29c2">
        <source>getMachineRuleTerminalArea(): CM_TerminalArea;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2022	jlier1	Initial creation 54701

*/

vars
	lc : CM_LocationsController;
begin
	if self.myTILC &lt;&gt; null then
		lc:= self.myTILC.myPrimaryActualLocation;
	endif;
	
	if lc &lt;&gt; null then
		if lc.isKindOf(CM_TILCController) then
			return lc.myTerminalArea;
		else
			return lc.getMachineRuleTerminalArea;
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_TerminalArea"/>
    </JadeMethod>
