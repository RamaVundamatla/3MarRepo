    <JadeMethod name="doShowOptions" id="0f4fc377-f5d7-4ac5-a759-9faa0f536bd5">
        <updating/>
        <source>doShowOptions() updating;
// ---------------------------------------------------------------------------
// Created:		24 October 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	canGate, canRail, canShip : Boolean;
	canDO : Integer;
	frm : Form;
begin
	if app.myHandHeldLogonGuiAgent.myHandHeldAgent.HandHeldLogonAgent.canDoHandHeldShip() then
		canShip := true;
		canDO := canDO + 2;
	endif;
	if app.myHandHeldLogonGuiAgent.myHandHeldAgent.HandHeldLogonAgent.canDoHandHeldGate() then
		canGate := true;
		canDO := canDO + 1;
	endif;
	if app.myHandHeldLogonGuiAgent.myHandHeldAgent.HandHeldLogonAgent.canDoHandHeldRail() then
		canRail := true;
		canDO := canDO + 1;
	endif;
	self.frmMain.zOrder(0);
	self.frmMain.visible := false;
		
	if canDO = 1 then
		self.frmOptions.zOrder(0);
		self.frmOptions.visible := false;

		if canGate then
			self.doShowGate();
		elseif canRail then
			self.doShowRail();
		elseif canShip then
			self.doShowShip();
//			self.doShowCar();

		endif;
	elseif canDO &gt; 1 then
		
		self.frmOptions.zOrder(1);
		self.frmOptions.visible := true;
		self.btnAppGate.visible := canGate;
		self.btnAppRailConf.visible := canRail;
		self.btnAppShipLander.visible := canShip;
		self.btnAppCar.visible := canShip;
		self.btnAppCarYard.visible := canShip;
		
		
		
	else
		self.frmMain.zOrder(1);
		self.frmMain.visible := true;
		app.msgBox("You do not have permission to use" &amp; Cr &amp; 
							"any hand held applications in JMT." &amp; Cr &amp; 
							"Please see you system administrator.", "Hand Held Permission Problem", MsgBox_Exclamation_Mark_Icon);
		self.frmOptions.zOrder(0);
		self.frmOptions.visible := false;
		return;
	endif;
	
end;</source>
    </JadeMethod>
