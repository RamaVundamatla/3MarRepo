    <JadeMethod name="doInstanceProcessing" id="7f07e36b-47d9-4ce5-a41c-62b7bfe31a5d">
        <updating/>
        <source>doInstanceProcessing(_isInitialize : Boolean) protected, updating;
//
// cnwdvb1 14 January 2003 
// 19 Mar 2012	cnwrs1	Par 29288 - the recusion is causing EDI to get into a processing loop that fills the kernael stack
//06 Nov 2012	cnwrs1		Par 28355 - Fixup error messages
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
// 28 Sep 2016	cnwrs1	TFS 2756 PAR38267 allow Cams to run per terminal
//
vars
	reqDict		: BGP_RequestsByCreatedDTDict;
	reqDelDict : BGP_RequestSet;
	request : BGP_Request;
	object		: Object;
	tmpClass	: Class;
	ls	: Boolean;
//	isRecursive	: Boolean;
	className	: String;
begin
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;" start "&amp;self.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	create reqDict transient;
	create reqDelDict transient;
	foreach className in self.allRequestClassesToProcess do
		tmpClass := self.getClass(className);
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;" tmpClass="&amp;tmpClass.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		if tmpClass = null then
			// Class has not been correctly setup.
			app.remoteErrorWarningToAlert('INFO &gt;&gt; Error initializing app ' &amp; self.name &amp; 
				' could not locate ' &amp; className, null, null, null, true, true);
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;" ERROR tmpClass="&amp;tmpClass.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
			continue;
		endif;
		
		if _isInitialize then
			// Begin class notification here.
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;" beginClassNotification "&amp;BGP_Object.BGP_ActionRequest.String&amp;" for "&amp;tmpClass.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
			self.beginClassNotification(tmpClass, false, BGP_Object.BGP_ActionRequest, Response_Continuous, null);
			if app.isSDSSecondaryDB then
				app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;" beginClassNotification "&amp;Object_Create_Event.String&amp;" for "&amp;tmpClass.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
				self.beginClassNotification(tmpClass, false, Object_Create_Event, Response_Continuous, 0);
				self.beginClassNotification(BGP_GenericController, false, Object_Update_Event, Response_Continuous, 0);
				if self.myCurrentRequest &lt;&gt; null and
				   self.myCurrentRequest.isKindOf(BGP_BackupDB) then
					app.writeLog(class.name&amp;'::'&amp;method.name&amp;' there is a request waiting so try and process it '&amp;self.myCurrentRequest.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
					app.writeLog(class.name&amp;'::'&amp;method.name&amp;' beginclassnotification for '&amp;self.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
					self.myCurrentRequest.beginClassNotification(CM_Backup, false, Object_Update_Event, Response_Continuous, 0); 
				   	self.myCurrentRequest.BGP_BackupDB.runBackup();
					return;
				endif;
			else
				if tmpClass = BGP_BackupDB then	// CCMS1150 cnwrs1 04 July 2011 during start up make sure the status is idle.
					app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;" initailize cleanup of CM_Backup status and BGP_BackupDB", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
					app.myTrxUA.trxUpdateBGPBackupReset(app.myRoot.myBackup, self);
				endif;
			endif;
			foreach object in tmpClass.instances do
				request := object.BGP_Request;
				if self.tryLock(request, Share_Lock, Session_Duration, LockTimeout_Immediate) then
					if request.isProcessed then
						reqDelDict.add(request);
					endif;
					self.unlock(request);
				endif;
			endforeach;
			foreach request in reqDelDict do
				app.myTrxDA.trxDeleteBGPRequest(null, request, true, app.myPassport);
			endforeach;	
		endif;
		
		foreach object in tmpClass.instances do
			if self.tryLock(object, Share_Lock, Session_Duration, LockTimeout_Immediate) then
				if not object.BGP_Request.isProcessed then
					//27 Oct 2018 jlger1 tfs 41625 -  have tasks for each terminal
					if self.getMyTerminal &lt;&gt; null and object.BGP_Request.myTerminal  &lt;&gt; null then
						if getMyTerminal &lt;&gt; object.BGP_Request.myTerminal then
							self.unlock(object);
							continue;
						endif;
					endif;
					app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;" reqDict.add "&amp;object.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
					reqDict.add(object.BGP_Request);
				endif;
				self.unlock(object);
			endif;
		endforeach;
	endforeach;
	
	// Only stop when there is nothing to process.
//	isRecursive := reqDict.size &gt; 0;
	foreach object in reqDict do
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;" processRequest for "&amp;object.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		self.processRequest(object.BGP_Request);
	endforeach;

	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;" end", LogTRACE);	//25 Nov 2019	NDL	TFS 47053
epilog	
	
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;" epilog", LogTRACE);	//25 Nov 2019	NDL	TFS 47053
	delete reqDict;
	delete reqDelDict;
end;</source>
        <access>protected</access>
        <Parameter name="_isInitialize" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doShowLogName" id="b30cb920-e76f-4d8c-b928-1a0c7737a533">
        <source>doShowLogName(_process : Process) protected;
//----------------------------------------------------------------
//	Created:	11 February 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	alert		: CM_SystemAlert;
	extraDetail,
	detail		: String;
begin
	
	create alert;
	detail := "Log information for BGPController " &amp; self.logFileName(); //cnwrs1 par 17287 June 2008
	alert.details := detail;
	
	alert.setSeverity(SEVERE_INFO);

	extraDetail := self.machineName &amp; " " &amp; app.getLogFilename();

	alert.addLogEntry(extraDetail);
	
	alert.add;
	app.commitAlert();
	self.sendCallBackMsg(_process, detail &amp; CrLf &amp; extraDetail);
//	self.causeEvent(BGP_Object.BGP_CallBackMsg, true, detail &amp; ',' &amp; _process.getOidString);
	
end;</source>
        <access>protected</access>
        <Parameter name="_process" type="Process"/>
    </JadeMethod>
    <JadeMethod name="finish" id="fee76586-b336-4039-a1f3-fdbc1166de18">
        <updating/>
        <source>finish() updating;

/*

Date		Who		Reason
29 Nov 2011	cnwkpd1	PAR #28753 - BGP form issues
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
*/

vars

begin
	
	app.writeLog(class.name&amp;'::'&amp;method.name, LogTRACE);	//25 Nov 2019	NDL	TFS 47053
	
	app.exitLogFile();
	if not app.isBGPAppAbort then
		if not app.isSDSSecondaryDB then	// CCMS1150 cnwrs1 16 June 2011		// PAR #28753
			app.myTrxUA.trxUpdateBGPControllerProcess(self, null, null, true, app.myPassport);
		endif;
	endif;
	inheritMethod();
	
end;</source>
    </JadeMethod>
