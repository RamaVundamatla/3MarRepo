    </JadeMethod>
    <JadeMethod name="verifyEDIDataTIs" id="81ca55d9-599f-4da8-a454-1ae1fa8aa98e">
        <updating/>
        <source>verifyEDIDataTIs(_passport: CM_Passport input): Integer updating;
/*

Purpose:			Validate the EDi transaction data against the specific rules that apply to EDI load

Parameters:			Passport

Return Value:		Number of errors found

Changes

Date		Name	TFS#		Description
============================================================================
19 Sep 2012	cnwrs1	CCMS SFW 1290 Transaction file
18 Oct 2012	cnwrs1	CCMS SFW 1290 Transaction file
18 Oct 2012	cnwkpd	PAR #30400 CCMS SFW 1290 - Add in code to exclude specific transaction types that 
								can not be loaded
08 Oct 2015	cnwrs1	Par 36863 	make EDI consistant times when refreshing progress bar
13 May 2016	cnwns1	TFS 488  	Multi Timezone Support
04 Jul 2018 jlgrh7 	TFS #39128 	ADP - FW: DL for Rotation 1801002901 in production
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
11 Jan 2023	navkc1	TFS CR 55625 TASK 55660 Task 55660: Jade - Contract Id EDI TRX
============================================================================*/
vars
	terminal 		: CM_Terminal;
	errorLimit 		: Integer;
	totalTIs 		: Integer;
	ediTI 			: CM_EDITrackedItem;
	ediTransaction 	: CM_EDITransactionTI;
	tiCount 		: Integer;
	errCount 		: Integer;
	imexStatus 		: CM_IMEXStatus;
	cargoType 		: CM_CargoType;
	cargoTypeCode 	: Integer;
	ti 				: CM_TrackedItem;
	tiTrans	 		: CM_TITransaction;
	progressTS 		: TimeStamp;
	consign : CM_ConsigneeConsignor;
begin
	// Arm our base exception handlers
	on Exception do validationExceptionHandler(exception, app.myPassport);
	
	progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	terminal := self.getMyTerminal();
	if terminal = null then
		app.raiseCMException1(Err_InvalidTerminal, null, null, null);
	endif;
	
	errorLimit := terminal.getConfig(EDIVerificationErrorLimit).Integer;
	_passport.clearErrorsWarnings();
	app.setContinueCMExceptions(true);
	
	totalTIs := self.allEDITrackedItems.size();
	tiCount := null;
	self.updateProgress(progressTS, "Verifying cargo details", totalTIs, tiCount, true, _passport);

	foreach ediTI in self.allEDITrackedItems do
		ediTransaction := ediTI.CM_EDITransactionTI;
		tiCount := tiCount + 1;
		self.updateProgress(progressTS, "Verifying cargo details", totalTIs, tiCount, false, _passport);
		
		if ediTransaction.cargoTypeDescr &lt;&gt; null then
			if app.myRoot.allCargoTypesById[ediTransaction.cargoTypeDescr.Integer] = null and
			   app.myRoot.getCargoTypeIDFromDescription(ediTransaction.cargoTypeDescr) = null and
			   app.myRoot.getCargoTypeIDFromAbbrev(ediTransaction.cargoTypeDescr) = null then
				app.raiseCMException1(ERR_INVALID_TI_TYPE, ediTransaction.cargoTypeDescr, ETRow_CargoTypeDescr, ediTI);
				errCount := errCount + 1;
				if errCount &gt; errorLimit then
					break;
				endif;
			endif;
		endif;
		if ediTransaction.id &lt;&gt; null then
			cargoType := app.myRoot.allCargoTypesById[ediTransaction.cargoTypeDescr.Integer];
			if cargoType = null then
				cargoTypeCode := app.myRoot.getCargoTypeIDFromDescription(ediTransaction.cargoTypeDescr);
				if cargoTypeCode = null then
					cargoTypeCode := app.myRoot.getCargoTypeIDFromAbbrev(ediTransaction.cargoTypeDescr);
				endif;
			else
				cargoTypeCode := cargoType.id;
			endif;
			ti := terminal.lookupTrackedItem(ediTransaction.id, cargoTypeCode, TI_STATE_UNDEFINED, null, false);
			if ti = null then
				app.raiseCMException3(Specfied_Cargo_DoesNotExist, ediTransaction.id, ediTransaction.cargoTypeDescr, terminal.code, ETRow_Id, ediTI);
				errCount := errCount + 1;
				if errCount &gt; errorLimit then
					break;
				endif;
			endif;
		endif;
		if ediTransaction.commodity &lt;&gt; null and
		   app.myRoot.allCommodities[ediTransaction.commodity.toUpper()] = null then															//+TFS39128
			app.raiseCMException1(ERR_INVALID_COMMODITY, ediTransaction.commodity, ETRow_Commodity, ediTI);
			errCount := errCount + 1;
			if errCount &gt; errorLimit then
				break;
			endif;
		endif;
		if ediTransaction.companyCode &lt;&gt; null and
		   terminal.companies[ediTransaction.companyCode] = null then
			app.raiseCMException2(ERR_FIELD_COMPANY, ediTransaction.companyCode, app.getErrorString(CM_CompanyBank), ETRow_CompanyCode, ediTI);
			errCount := errCount + 1;
			if errCount &gt; errorLimit then
				break;
			endif;
		endif;
		if ediTransaction.consignee &lt;&gt; null then
			consign := app.myRoot.allConsigneeConsignors[ediTransaction.consignee];
			if consign = null then
				app.raiseCMException1(ERR_INVALID_CONSIGN, ediTransaction.consignee, ETRow_Consignee, ediTI);
				errCount := errCount + 1;
				if errCount &gt; errorLimit then
					break;
				endif;
			else	//07 Sep 2021	NDL	TFS 51928
				ediTransaction.verifyObjectAvailableForEntry( consign );
			endif;
		endif;
		if ediTransaction.consignor &lt;&gt; null then
			consign := app.myRoot.allConsigneeConsignors[ediTransaction.consignor];
			if consign = null then
				app.raiseCMException1(ERR_INVALID_CONSIGN, ediTransaction.consignor, ETRow_Consignor, ediTI);
				errCount := errCount + 1;
				if errCount &gt; errorLimit then
					break;
				endif;
			else	//07 Sep 2021	NDL	TFS 51928
				ediTransaction.verifyObjectAvailableForEntry( consign );
			endif;
		endif;
		if ediTransaction.contentsStatus &lt;&gt; null and
		   app.myRoot.allContentsStatuses[ediTransaction.contentsStatus] = null then
			app.raiseCMException1(ERR_INVALID_CONTENTS_STATUS, ediTransaction.contentsStatus.String, ETRow_ContentsStatus, ediTI);
			errCount := errCount + 1;
			if errCount &gt; errorLimit then
				break;
			endif;
		endif;
		if ediTransaction.customsAgent &lt;&gt; null and
		   app.myRoot.allCustomsAgents[ediTransaction.customsAgent] = null then
			app.raiseCMException1(InvalidCustomsAgent, ediTransaction.customsAgent, ETRow_CustomsAgent, ediTI);
			errCount := errCount + 1;
			if errCount &gt; errorLimit then
				break;
			endif;
		endif;
		if ediTransaction.dischargePort &lt;&gt; null and
		   app.myRoot.allPorts[ediTransaction.dischargePort] = null then
			app.raiseCMException1(ERR_INVALID_DIS_PORT, ediTransaction.dischargePort, ETRow_DischargePort, ediTI);
			errCount := errCount + 1;
			if errCount &gt; errorLimit then
				break;
			endif;
		endif;
		if ediTransaction.imexStatus &lt;&gt; null and
		   ediTransaction.getImExStatusObj() = null then
			app.raiseCMException1(ERR_INVALID_IMEX_STATUS, ediTransaction.imexStatus, ETRow_ImExStatus, ediTI);
			errCount := errCount + 1;
			if errCount &gt; errorLimit then
				break;
			endif;
		endif;
		if ediTransaction.operatorCode &lt;&gt; null and
		   app.myRoot.allOperators[ediTransaction.operatorCode] = null then
			app.raiseCMException1(ERR_INVALID_OPERATOR, ediTransaction.operatorCode, ETRow_OperatorCode, ediTI);
			errCount := errCount + 1;
			if errCount &gt; errorLimit then
				break;
			endif;
		endif;
		if ediTransaction.otherCargoTypeDescr &lt;&gt; null then
			if app.myRoot.allCargoTypesById[ediTransaction.otherCargoTypeDescr.Integer] = null and
			   app.myRoot.getCargoTypeIDFromDescription(ediTransaction.otherCargoTypeDescr) = null and
			   app.myRoot.getCargoTypeIDFromAbbrev(ediTransaction.otherCargoTypeDescr) = null then
				app.raiseCMException1(ERR_INVALID_TI_TYPE, ediTransaction.otherCargoTypeDescr, ETRow_OtherCargoTypeDescr, ediTI);
				errCount := errCount + 1;
				if errCount &gt; errorLimit then
					break;
				endif;
			endif;
		endif;
		if ediTransaction.otherCargoId &lt;&gt; null then
			cargoType := app.myRoot.allCargoTypesById[ediTransaction.otherCargoTypeDescr.Integer];
			if cargoType = null then
				cargoTypeCode := app.myRoot.getCargoTypeIDFromDescription(ediTransaction.otherCargoTypeDescr);
				if cargoTypeCode = null then
					cargoTypeCode := app.myRoot.getCargoTypeIDFromAbbrev(ediTransaction.otherCargoTypeDescr);
				endif;
			else
				cargoTypeCode := cargoType.id;
			endif;
			if terminal.lookupTrackedItem(ediTransaction.otherCargoId, cargoTypeCode, TI_STATE_UNDEFINED, null, false) = null then
				app.raiseCMException3(Specfied_Cargo_DoesNotExist, ediTransaction.otherCargoId, ediTransaction.otherCargoTypeDescr, terminal.code, ETRow_OtherCargoId, ediTI);
				errCount := errCount + 1;
				if errCount &gt; errorLimit then
					break;
				endif;
			endif;
		endif;
		if ediTransaction.taskDescr &lt;&gt; null and
		   ediTransaction.getToDoTaskObj() = null then
			app.raiseCMException1(ERR_INVALID_TODOTASKDESCR, ediTransaction.taskDescr, ETRow_TaskDescr, ediTI);
			errCount := errCount + 1;
			if errCount &gt; errorLimit then
				break;
			endif;
		endif;
		if ediTransaction.transactionTime &lt;&gt; null and
		   not ediTransaction.transactionTime.isValid then
			app.raiseCMException1(ERR_DATETIME_FORMAT, ediTransaction.transactionTime.String, ETRow_TransactionTime, ediTI);
			errCount := errCount + 1;
			if errCount &gt; errorLimit then
				break;
			endif;
		endif;
		if ediTransaction.transactionType &lt;&gt; null then
			if app.myRoot.allTransactionTypes[ediTransaction.transactionType] = null then
				app.raiseCMException1(ERR_INVALID_TRANSTYPE, ediTransaction.transactionType.String, ETRow_TransactionType, ediTI);
				errCount := errCount + 1;
				if errCount &gt; errorLimit then
					break;
				endif;
			else
				// Add here a specific list of transaction types that are not supported in the load, either due to required
				// data that is not included in the file layout, or transaction types that are not appropriate 
				// for migrated data
				if ediTransaction.transactionType = TRANS_TYPE_REL_REQ_ASSIGN or
				   ediTransaction.transactionType = TRANS_TYPE_REL_REQ_UNASSIGN then
					app.raiseCMException1(ERR_INVALID_TRANSTYPE, ediTransaction.transactionType.String, ETRow_TransactionType, ediTI);
					errCount := errCount + 1;
					if errCount &gt; errorLimit then
						break;
					endif;
				endif;
			endif;
		endif;
		if ediTransaction.voyageCode &lt;&gt; null and
		   terminal.lookupVoyage(ediTransaction.voyageCode, null, true) = null then
			app.raiseCMException1(ERR_INVALID_VOYAGE, ediTransaction.voyageCode, ETRow_VoyageCode, ediTI);
			errCount := errCount + 1;
			if errCount &gt; errorLimit then
				break;
			endif;
		endif;
		
		//jlier1 TFS 54846 11/10/22
		if ediTransaction.countryOfOriginCode &lt;&gt; null then
			if app.myRoot.allCountries[ediTransaction.countryOfOriginCode] = null then
				app.raiseCMException1(Invalid_Country_Origin, ediTransaction.countryOfOriginCode, "countryOfOriginCode", null);
				errCount := errCount + 1;
				if errCount &gt; errorLimit then
					break;
				endif;	
			endif;
		endif;
		if ti &lt;&gt; null then
			if ediTransaction.messageMode = CM_EDITrackedItem.EDI_ACTION_ADD then
				tiTrans := self.getTransaction(ediTransaction, ti);
				if tiTrans &lt;&gt; null then 
					app.raiseCMException3(Specified_Trans_Already_Exists, ediTransaction.id, ediTransaction.transactionTime.asStringJMT, ediTransaction.transactionType.String, ETRow_Id, ediTransaction);
					errCount := errCount + 1;
					if errCount &gt; errorLimit then
						break;
					endif;
				endif;
			elseif ediTransaction.messageMode = CM_EDITrackedItem.EDI_ACTION_UPDATE or
			   ediTransaction.messageMode = CM_EDITrackedItem.EDI_ACTION_DELETE then
				tiTrans := self.getTransaction(ediTransaction, ti);
				if tiTrans = null then 
					app.raiseCMException3(Speci_trans_dated_type_invalid, ediTransaction.id, ediTransaction.transactionTime.asStringJMT, ediTransaction.transactionType.String, ETRow_Id, ediTransaction);
					errCount := errCount + 1;
					if errCount &gt; errorLimit then
						break;
					endif;
				endif;
			endif;
		endif;
		
		// 11/01/2023	navkc1	TFS CR 55625 TASK 55660
		if ediTransaction.contractIdForTIstring &lt;&gt; null then
			ediTransaction.verifyContractId();
		endif;
	endforeach;
	self.updateProgress(progressTS, "Verifying cargo details", totalTIs, tiCount, true, _passport);
	
	//if _passport.noErrors() then // 11/01/2023	navkc1	TFS CR 55625 TASK 55660
	if _passport.allErrorWarnings.isEmpty() then
		app.myTrxUA.trxProcessEDITransactions(self, true, _passport);
	endif;
	return _passport.allErrorWarnings.size();
end;
</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
