28 April 2016	cnwndl1	Initial creation

*/

vars

begin

	if self.myTrackedItem &lt;&gt; null then
		return self.myTrackedItem.id;
	endif;
	
	return "Unknown";

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isAssignTrn" id="3a205565-9817-4487-a402-992421954695">
        <source>isAssignTrn():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2016	cnwndl1	Initial creation	TFS 1903

*/

vars

begin

	return self.toBolNumber.trimBlanks &lt;&gt; null and self.myToTfrTransaction = null;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
