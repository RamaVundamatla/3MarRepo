    <JadeMethod name="dragDrop" id="eaa35385-278b-489b-ab6d-c557a2931d32">
        <controlMethod name="Frame::dragDrop"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>dragDrop(frame: Frame input; win: Window input; x: Real; y: Real) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		15 September 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	cdc : YRD_ContainerDrawingController;
begin
	cdc := self.myContainerDrawingFrame.getDrawingController();
	
	if cdc = null then																			// cnwjk3 ccms 1018 01/02/10
		if not self.isControllKey and not self.isShiftKey then									// cnwjk3 ccms 1018 01/02/10
			self.myContainerDrawingFrame.dragDrop(self.myContainerDrawingFrame, win, x, y);		// cnwjk3 ccms 1018 01/02/10
		endif;																					// cnwjk3 ccms 1018 01/02/10
	else																						// cnwjk3 ccms 1018 01/02/10
		if not cdc.isForOverview then
			if not self.isControllKey and not self.isShiftKey then
				self.myContainerDrawingFrame.dragDrop(self.myContainerDrawingFrame, win, x, y);
			endif;
		elseif global.isValidObject(app.myMoveController) then // drag drop moving from a different frame
			if not self.isControllKey and not self.isShiftKey then
				self.myContainerDrawingFrame.dragDrop(self.myContainerDrawingFrame, win, x, y);
			endif;
		endif;
	endif;
	self.clearGraphics;
	
	inheritMethod(frame, win, x, y);
epilog
	if not self.isControllKey and not self.isShiftKey then	// 24442, don't clear move controller from drag-select
		app.myMoveController := null;
	endif;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="dragOver" id="728e444a-798b-4609-a373-b483a4190eee">
        <controlMethod name="CMUI_GridAreaDrawingFrame::dragOver"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>dragOver(frame: Frame input; win: Window input; x: Real; y: Real; state: Integer) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		15 September 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	cdc : YRD_ContainerDrawingController;
begin
// process.weiwrite(self.height);
//process.weidebug;

	cdc := self.myContainerDrawingFrame.getDrawingController();
	//if cdc.isForOverview and not global.isValidObject(app.myMoveController) then
	if cdc &lt;&gt; null and cdc.isForOverview and not global.isValidObject(app.myMoveController) then	// cnwjk3 ccms 1018 01/02/10
		self.drawDragFrame(x,y);
	else
		if self.isControllKey  or self.isShiftKey then
			self.drawDragFrame(x,y);
		else
			self.myContainerDrawingFrame.dragOver(self.myContainerDrawingFrame, win, x, y, state);
		endif;
	endif;
	
	inheritMethod(frame, win, x, y, state);

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawBand" id="a180c647-104a-4d0e-9c86-ac6c144f1425">
        <updating/>
        <source>drawBand() updating;
// ---------------------------------------------------------------------------
// Created:		02 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	Duration = 100;
vars

begin

	if doFlash then
		while doFlash do
			self.drawStyle := Frame.DrawStyle_Dash;
			self.drawWidth := 1;
		
			self.drawFillStyle := Frame.DrawFillStyle_Transparent;
			self.drawFillColor := Black;
		
			process.sleep(Duration);
			self.drawFilledRectangle(10,10,200,100, Black);
			self.refreshNow();
			process.sleep(Duration);
			self.drawFilledRectangle(10,10,200,100, White);
			self.refreshNow();
			if not doFlash then
				break;
			endif;
		endwhile;	
		app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. BREAK doFlash");
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="drawDragFrame" id="cfd166ce-6574-4ed4-9433-b2eb51ce5203">
        <updating/>
        <source>drawDragFrame( x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

constants
	WIDTH	= 1;
vars
	tmpPoint : Point;
	x1,x2,y1,y2,idx : Integer;
	yalColour : Integer;
begin

// process.weiwrite(x); 
	self.clearGraphics;

	self.drawStyle := Frame.DrawFillStyle_Transparent;
	self.drawWidth := 1;

	self.drawFillStyle := Frame.DrawFillStyle_Transparent;
	self.drawFillColor := Black;

	self.drawFilledRectangle(self.origXPos.Integer, self.origYPos.Integer,x,y, Black);


end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseDown" id="12746ded-0cfc-4fb5-9d20-85bfe0ddc0fd">
        <controlMethod name="CMUI_GridAreaDrawingFrame::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>mouseDown(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		15 September 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin

	self.isControllKey := shift.isControlKeyPressed;
	self.isShiftKey := shift.isShiftKeyPressed;
	self.isAltKey := shift.isAltKeyPressed;
	
	doFlash := not doFlash;

	self.myContainerDrawingFrame.mouseDown(self.myContainerDrawingFrame, button, shift, x, y);

	self.origXPos := x;
	self.origYPos := y;
	inheritMethod(frame, button, shift, x, y);

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseMove" id="2f3b384d-d4b4-430c-ab4d-638729a6fa4e">
        <controlMethod name="Frame::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>mouseMove(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		September 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	yrdForm : YRD_GridAreaEnquiryForm;	
	cdc : YRD_ContainerDrawingController;
begin
	cdc := self.myContainerDrawingFrame.getDrawingController();
	
	if button = Window.MouseButton_Left 
	and frame.dragMode &lt;&gt; DragMode_Drag
	and app.dragDetected(x, y, self.origXPos, self.origYPos) then
		//if cdc.isForOverview then
		if cdc &lt;&gt; null and cdc.isForOverview then	// cnwjk3 ccms 1018 01/02/10
			if self.isControllKey then
				
				self.isDrawDeskTopRectangle := true;
				self.dragMode := DragMode_Drag;
				self.dragCursor := self.form.CM_BaseForm.picYAAreaCur.picture;
			else
				
				self.isDrawShiftSelectRectangle := true;
				self.dragMode := DragMode_Drag;
				self.dragCursor := self.form.CM_BaseForm.picYAAreaCur.picture;
			endif;
		else
			if self.isControllKey then
				
				self.isDrawDeskTopRectangle := true;
				self.dragMode := DragMode_Drag;
				self.dragCursor := self.form.CM_BaseForm.picYAAreaCur.picture;
			else
				app.isDragging := true;
				self.myContainerDrawingFrame.mouseMove(self.myContainerDrawingFrame, button, shift, x, y);
			endif;
		endif;
	elseif	self.isControllKey then
		self.myContainerDrawingFrame.mouseMove(self.myContainerDrawingFrame, button, shift, x, y);
	endif;
	
	inheritMethod(frame, button, shift, x, y);

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseUp" id="aae331cd-ec92-48bf-99bd-a46155d876fc">
        <controlMethod name="CMUI_GridAreaDrawingFrame::mouseUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>mouseUp(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		September 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	cdc : YRD_ContainerDrawingController;
	yrdForm : Form;
	gridAreaForm : YRD_GridAreasForm;
	objs : ObjectArray;
	rows : ObjectSet;
	obj : Object;
	drillToBays : Boolean;
	statusLocns : CM_LCArray;
	statMess : String;
	parentString : String;

begin

	cdc := self.myContainerDrawingFrame.getDrawingController();
	drillToBays := true; // make configurable later?
	
	if not self.isDrawDeskTopRectangle 
	and not self.isDrawShiftSelectRectangle then
		self.myContainerDrawingFrame.mouseUp(self.myContainerDrawingFrame, button, shift, x, y);
	endif;
	self.isControllKey := false;
	self.isShiftKey := false;
	self.isAltKey := false;
	
	self.lastMouseX := x.Integer;
	self.lastMouseY := y.Integer;
	self.clearGraphics;
	self.dragMode := DragMode_None;


	if self.isDrawDeskTopRectangle then
		//if cdc.isForOverview then
		if cdc &lt;&gt; null then	//24 Aug 2011	NDL	Par 28035
			yrdForm := cdc.getForm;
			if yrdForm &lt;&gt; null and yrdForm.isKindOf(YRD_GridAreasForm) then
				gridAreaForm := yrdForm.YRD_GridAreasForm;
			endif;
		endif;
		if gridAreaForm &lt;&gt; null and gridAreaForm.mnuMultiMove.checked  then	//24 Aug 2011	NDL	Par 28035
			self.myContainerDrawingFrame.selectBlockOfObjectsFromXYs(self, CM_LocationsController, CM_YALocationCell, self.origXPos.Integer,self.origYPos.Integer,self.lastMouseX, self.lastMouseY);
			create statusLocns transient;
			gridAreaForm.getSelectedMultiMoveLocations( statusLocns );
			statMess := " " &amp; app.getErrorString(SHP_Selected) &amp; " " &amp; statusLocns.size.String;
			gridAreaForm.frmStatusLine.myFrameCaption.caption := statMess;
		
		elseif cdc &lt;&gt; null and cdc.isForOverview then		// cnwjk3 ccms 1018 01/02/10
			self.myContainerDrawingFrame.selectBlockOfObjectsFromXYs(self, CM_LocationsController, null, self.origXPos.Integer,self.origYPos.Integer,self.lastMouseX, self.lastMouseY);
			cdc.doDFStatusLine();
		elseif cdc &lt;&gt; null and cdc.isForGCRack then		
			self.myContainerDrawingFrame.selectBlockOfObjectsFromXYs(self, CM_IrregularBlockController, null, self.origXPos.Integer,self.origYPos.Integer,self.lastMouseX, self.lastMouseY);
			cdc.drawSelf(false);
			cdc.doDFStatusLine();
		else
			self.myContainerDrawingFrame.selectBlockOfObjectsFromXYs(self, CM_TrackedItem, null, self.origXPos.Integer,self.origYPos.Integer,self.lastMouseX, self.lastMouseY);
			cdc.doDFStatusLine();
		endif;
	
		//cdc.doDFStatusLine();
		
	elseif self.isDrawShiftSelectRectangle then
		if cdc &lt;&gt; null and cdc.isForOverview then		// cnwjk3 ccms 1018 01/02/10
			if cdc.isForSatelliteView then
					self.myContainerDrawingFrame.showYardGridAreasForm(self.origXPos.Integer, self.origYPos.Integer, self.lastMouseX, self.lastMouseY);
			elseif drillToBays then
				
			else
				self.myContainerDrawingFrame.selectBlockOfObjectsFromXYs(self, CM_LocationsController, CM_GridRow, self.origXPos.Integer,self.origYPos.Integer,self.lastMouseX, self.lastMouseY);
				create rows transient;
				foreach obj in cdc.allSelectedObjects do
					if obj.isKindOf(CM_GridRow) then
						rows.add(obj);
					endif;
				endforeach;
				cdc.clearAllSelectedObjects();
				cdc.myGridOverviewForm.myAssistant.showYardRowEnquiryForm(rows, cdc.myGridOverviewForm.myMasterMenuAction,  null, true, VIEW_DISPORT, 1, null); // PAR 19913
			endif;
			return;
		else
			return;
		endif;
	
		cdc.doDFStatusLine();
	endif;


	inheritMethod(frame, button, shift, x, y);
epilog
	self.isDrawDeskTopRectangle := false;
	self.isDrawAltSelectRectangle := false;
	self.isDrawShiftSelectRectangle := false;
	delete objs;
	delete rows;
	delete statusLocns;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="reorderSelectedObjects" id="75da9b44-d0e8-4b94-818f-3f6b6a1fa769">
        <source>reorderSelectedObjects(_x1, _y1,_x2,_y2 : Integer;_objs: ObjectArray input; _type: Integer);
// ---------------------------------------------------------------------------
// Created:		01 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		CALLED from the container drawing frame via super class
//
// ---------------------------------------------------------------------------

vars
	sortOrder : Integer;
begin

	
	if _type = 1 then
		if _x1 &gt; _x2 then
			if _y1 &gt; _y2 then
				sortOrder := self.SelectOrder_BRTL;
			else
				sortOrder := self.SelectOrder_TRBL;
			endif;
		else
			if _y1 &gt; _y2 then
				sortOrder := self.SelectOrder_BLTR;
			else
				sortOrder := self.SelectOrder_TLBR;
			endif;
		
		endif;
	
		self.sortObjects(_objs, sortOrder);
	endif;
end;</source>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
        <Parameter name="_objs" type="ObjectArray" usage="input"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="7b6de4d9-a843-432a-91a9-dcca3fede6fb">
        <updating/>
        <source>setForCreate() updating;
// ---------------------------------------------------------------------------
// Created:		15 September 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.name := "Overlay DRAG Frame";

	self.bevelInner := Frame.Bevel_None;
	self.bevelOuter := Frame.Bevel_None;
	self.borderStyle := Frame.BorderStyle_None;
	self.boundaryWidth := 0;
	self.caption := null;
	self.transparent := true;
	self.visible := false;
	self.lockBottom := true;
	self.lockRight := true;
	self.stretchHeight := true;
	self.stretchWidth := true;


end;</source>
    </JadeMethod>
    <JadeMethod name="sortObjects" id="bf6eff2f-7e6f-4a50-98ea-2a10494045e0">
        <source>sortObjects(_objs : ObjectArray input; _order : Integer);
// ---------------------------------------------------------------------------
// Created:		01 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
//Date		    Who		Reason
//15 Feb 2024	navbs1	Bug 62465: CPL - Error#1086 While Bulk Planning
// ---------------------------------------------------------------------------

vars
	tmpSortDict		: DynaDictionary;
	row, col,pos,mode, dup : Integer;
	anLC : CM_LocationsController;
	aGC : CM_GridController;
	aTI : CM_TrackedItem;
	anObj : Object;
	cdc : YRD_ContainerDrawingController;
begin

	cdc := self.myContainerDrawingFrame.getDrawingController();
	mode := cdc.displayMode;
	create tmpSortDict transient;
	
	tmpSortDict.setMembership(CM_TrackedItem);
	if _order = self.SelectOrder_BRTL then
	
		tmpSortDict.addExternalKey(Integer,9,true,true); // desending ROW
		tmpSortDict.addExternalKey(Integer,9,true,true); // desending COLUMN
		tmpSortDict.addExternalKey(Integer,9,true,true); // desending STACK POSITION

	elseif _order = self.SelectOrder_TRBL then
		tmpSortDict.addExternalKey(Integer,9,false,true); // ascsending ROW
		tmpSortDict.addExternalKey(Integer,9,true,true); // desending COLUMN
		tmpSortDict.addExternalKey(Integer,9,true,true); // reverse STACK POSITION
	elseif _order = self.SelectOrder_BLTR then
		tmpSortDict.addExternalKey(Integer,9,true,true); // desending ROW
		tmpSortDict.addExternalKey(Integer,9,false,true); // ascending COLUMN
		tmpSortDict.addExternalKey(Integer,9,true,true); // reverse STACK POSITION
	elseif _order = self.SelectOrder_TLBR then
		tmpSortDict.addExternalKey(Integer,9,false,true); // ascending ROW
		tmpSortDict.addExternalKey(Integer,9,false,true); // ascending COLUMN
		tmpSortDict.addExternalKey(Integer,9,true,true); // reverse STACK POSITION
	endif;

	tmpSortDict.endKeys(true);
	
	dup := 999;
	foreach anObj in _objs where anObj.isKindOf(CM_TrackedItem) do		//15.02.2024 navbs1 #62465
		aTI := anObj.CM_TrackedItem;
		
		if mode = DISPLAY_MODE_ACTUAL then
			anLC := aTI.myPrimaryActualLocation;
		elseif mode = DISPLAY_MODE_QUEUE then
			anLC := aTI.myPrimaryQueuedLocation;
		else
			anLC := aTI.myPrimaryPlannedLocation;
		endif;		
		if anLC.isKindOf(CM_GridController) then
			aGC := anLC.CM_GridController;
			
			row := aGC.row;
			col := aGC.column;
			pos := aGC.allTrackedItems.indexOf(aTI);
			tmpSortDict.putAtKey(row,col,pos,aTI);
		else // should never hit this
			dup := dup + 1;
			tmpSortDict.putAtKey(999,dup,9,aTI);
		endif;
	endforeach;
	_objs.clear;
	tmpSortDict.copy(_objs);

epilog
	delete tmpSortDict;
end;</source>
        <Parameter name="_objs" type="ObjectArray" usage="input"/>
        <Parameter name="_order" type="Integer"/>
    </JadeMethod>
    <DevControlTypes name="YRD_ContainerDragSelectFrame">
        <bitmap></bitmap>
        <windowClass>AlFrame</windowClass>
        <DevControlProperties name="alignChildren">
            <cntrlType>list</cntrlType>
            <optionsList>
                <value>0 - None</value>
                <value>1 - Align Width</value>
                <value>2 - All</value>
            </optionsList>
        </DevControlProperties>
        <DevControlProperties name="alignContainer">
            <cntrlType>list</cntrlType>
            <optionsList>
                <value>0 - None</value>
                <value>1 - Align Top</value>
                <value>2 - Align Bottom</value>
                <value>3 - Align Width</value>
                <value>4 - Stretch to next control below</value>
                <value>5 - Align Container</value>
            </optionsList>
        </DevControlProperties>
        <DevControlProperties name="alignment">
            <cntrlType>list</cntrlType>
            <optionsList>
                <value>0 - Left  justify - TOP</value>
                <value>1 - Left  justify - MIDDLE</value>
                <value>2 - Left  justify - BOTTOM</value>
                <value>3 - Right justify - TOP</value>
                <value>4 - Right justify - MIDDLE</value>
                <value>5 - Right justify - BOTTOM</value>
                <value>6 - Center - TOP</value>
                <value>7 - Center - MIDDLE</value>
                <value>8 - Center - BOTTOM</value>
            </optionsList>
        </DevControlProperties>
        <DevControlProperties name="allowDocking">
            <cntrlType>integer</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="backBrush">
            <cntrlType>picture</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="backBrushStyle">
            <cntrlType>list</cntrlType>
            <optionsList>
                <value>0 - tile</value>
                <value>1 - stretch</value>
                <value>2 - center</value>
                <value>3 - stretch proportional</value>
            </optionsList>
        </DevControlProperties>
        <DevControlProperties name="backColor">
            <cntrlType>color</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="bevelColor">
            <cntrlType>color</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="bevelInner">
            <cntrlType>list</cntrlType>
            <optionsList>
                <value>0 - None</value>
                <value>1 - Inset</value>
