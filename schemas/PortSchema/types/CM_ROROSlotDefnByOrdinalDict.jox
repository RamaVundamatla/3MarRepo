    <JadeMethod name="getMemberByOrdinal" id="6cba6eb3-9c8f-4e84-9598-692a8f7af6ae">
        <source>getMemberByOrdinal(idx : Integer) : CM_ROROSlotDefn;
/*
Date		    Who			Reason
04 May 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars
	slot : CM_ROROSlotDefn;
begin
	foreach slot in self where slot.ordinal = idx do
		return slot;
	endforeach;
epilog

end;</source>
        <Parameter name="idx" type="Integer"/>
        <ReturnType type="CM_ROROSlotDefn"/>
    </JadeMethod>
