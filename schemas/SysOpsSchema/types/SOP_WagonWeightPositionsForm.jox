    <JadeMethod name="clearPosition" id="50eb9d5c-6281-4ab4-aecb-c4a98f047539">
        <source>clearPosition( _grpPosition : CMUI_GroupBox; _enabled : Boolean ) protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30/06/2009	cnwndl1	Initial creation
12/03/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
11 Sep 2013	NDL	Par 32172
*/
vars

begin
	
	if _grpPosition = grpPosition1 then
		cmbLength1.listIndex := -1;
		tblMaxWeight1.text := null;
		self.tblDeckHeight1.setValues(app.convertMeasurementForDisplay(self.heightType.shortName, defaultDeckHeight) &amp; Space &amp; self.heightType.shortName);
		grpPosition1.enabled := _enabled;
		
	elseif _grpPosition = grpPosition2 then
		cmbLength2.listIndex := -1;
		tblMaxWeight2.text := null;
		self.tblDeckHeight2.setValues(app.convertMeasurementForDisplay(self.heightType.shortName, defaultDeckHeight) &amp; Space &amp; self.heightType.shortName);
		grpPosition2.enabled := _enabled;
		
	elseif _grpPosition = grpPosition3 then
		cmbLength3.listIndex := -1;
		tblMaxWeight3.text := null;
		self.tblDeckHeight3.setValues(app.convertMeasurementForDisplay(self.heightType.shortName, defaultDeckHeight) &amp; Space &amp; self.heightType.shortName);
		grpPosition3.enabled := _enabled;
		
	elseif _grpPosition = grpPosition4 then
		cmbLength4.listIndex := -1;
		tblMaxWeight4.text := null;
		self.tblDeckHeight4.setValues(app.convertMeasurementForDisplay(self.heightType.shortName, defaultDeckHeight) &amp; Space &amp; self.heightType.shortName);
		grpPosition4.enabled := _enabled;
		
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_grpPosition" type="CMUI_GroupBox"/>
        <Parameter name="_enabled" type="Boolean"/>
    </JadeMethod>
