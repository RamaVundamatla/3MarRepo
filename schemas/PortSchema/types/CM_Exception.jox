<ExceptionClass name="CM_Exception" id="9af03f33-bac2-4f9e-8a53-87a203b2e57d">
    <superclass name="NormalException"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <PrimAttribute name="isWarning" id="3d915ef2-9ffc-4525-9514-060756943a32">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <ImplicitInverseRef name="mySubject" id="e8e287b3-b62d-424f-9ecc-45cff0cd65a1">
        <embedded/>
        <type name="CM_Object"/>
        <access>readonly</access>
    </ImplicitInverseRef>
