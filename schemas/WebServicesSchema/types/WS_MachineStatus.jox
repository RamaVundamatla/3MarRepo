    <JadeMethod name="getCanSwap" id="eb0d0dbc-fa6c-4aa7-b797-05d1be94f719">
        <source>getCanSwap():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 November 2019		jlgns1	Initial creation TFS47394

*/

vars
		
	realTask1, 
	realTask2 	: CM_RTQueueTask;
	realMachine : CM_Machine;
	config 		: CM_RTVehicleConfig;

begin
	if self.allCurrentTasks.size &lt;&gt; 2 then
		return false;
	endif;

	//jlier1	TFS 52595 20/21/21
	if currentSession = null then
		realMachine:=app.myPassport.myMachine;
	else
		realMachine:=currentSession.myCurrentMachine;
	endif;
	if realMachine = null then
		return 	false;
	endif;
		
	config:=realMachine.myTerminal.getRTVehicleConfigForObject(realMachine);
	if config &lt;&gt; null and not config.allowChangeSetdown then
		return false;
	endif;
	
	if not realMachine.isTandemLift then
		return true;
	endif;
		
	realTask1 := realMachine.allCurrentQueueTasks[1];
	realTask2 := realMachine.allCurrentQueueTasks[2];
	
	if realTask1.targetLocation = realTask2.targetLocation then
		return true;
	endif;
	
	if realTask1.myEntry.myJob.isRoadJob and realTask2.myEntry.myJob.isRoadJob then	
		if realTask1.ti &lt;&gt; null and realTask2.ti &lt;&gt; null then
			app.myPassport.errorsToIgnore.add(ERR_TI_ALREADY_ALLOCATED);
			app.myPassport.errorsToIgnore.add(TI_TestReqOnOtherRelease);
			
			app.myTrxUA.trxCheckTiAgaintRequest(realTask1.ti,realTask2.getTaskRequest,app.myPassport);
			if not app.myPassport.noErrorsIgnored then
				return false;
			endif;
			
			app.myTrxUA.trxCheckTiAgaintRequest(realTask2.ti,realTask1.getTaskRequest,app.myPassport);			
			if not app.myPassport.noErrorsIgnored then
				return false;
			endif;	
		else
			return false;
		endif;
	endif;

	
	return true;
epilog
	app.myPassport.clearErrorsWarnings();
	app.myPassport.clearErrorsToIgnore(); 
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="4a676d84-9ca8-45b7-81e0-ad6963f9f428">
        <updating/>
        <source>setProxyFromObject(_object: CM_Machine) updating;
/*

Date		Who		Reason
23 May 2017	cnwer1	Initial creation TFS
3/12/2019	jlgns1	TFS47394 PNL - Tandem Move Enhancements
*/

vars
	task : Object;
	wsTask : WS_QueueTask;
	allTasks : ObjectArray;
	
begin
	inheritMethod(_object);
	self.machineId  :=_object.id;
	self.status     :=_object.statusStr;
	self.queueId    :=_object.queueId;
	if _object.myPrimaryQueue &lt;&gt; null then
		self.canDoDischarge := _object.myPrimaryQueue.canMachineDischarge();
	endif;
	create allTasks transient;
	_object.allCurrentQueueTasks.copy(allTasks);
	foreach task in allTasks discreteLock do
		create wsTask transient;
		wsTask.setProxyFromObject(task.CM_RTQueueTask);
		self.allCurrentTasks.add(wsTask);
	endforeach;
	
	self.canSwap := self.getCanSwap;										//TFS47394
	
	
epilog
	delete allTasks;
end;</source>
        <Parameter name="_object" type="CM_Machine"/>
    </JadeMethod>
</Class>
