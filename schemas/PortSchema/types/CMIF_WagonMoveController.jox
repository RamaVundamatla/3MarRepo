    <JadeMethod name="autoSetEffectiveTimeStamp" id="1af0ff1c-e5a2-4a89-96a8-4b1362626161">
        <updating/>
        <source>autoSetEffectiveTimeStamp() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 February 2021	navndl1	Initial creation	TFS 50837

*/

constants
	RailOpsFormName : String = "YRD_RailOperationsForm";
vars

	activeForm : Form;
	railOpsForm : Form;
	ts : TimeStamp;
	
begin

	if self.effectiveTimeStamp.isValid then
		//don't clobber what has already been set.
		return;
	endif;

	if app.applicationType = app.ApplicationType_GUI then
		activeForm := app.activeForm();
		if activeForm &lt;&gt; null then
			if activeForm.name = RailOpsFormName then
				railOpsForm := activeForm;
			else
				railOpsForm := activeForm.getMyParentNamed( RailOpsFormName );
			endif;
		endif;
	endif;
	
	if railOpsForm &lt;&gt; null then
		railOpsForm.sendMsgWithIOParams("getRetrospectiveTS",ts);
		self.setEffectiveTimeStampOverride( ts );
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="executeMove" id="e675baf9-229b-4a8f-bd27-56919839bc2c">
        <updating/>
        <source>executeMove(_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 May 2009	consw1	Initial creation
12 Aug 2009	consw1	PAR 19913 - SFW1067 Rail Simplifications
25 Aug 2022 navhl20 ChangeRequest 54281: EUP - Wagon Track Planning
01/05/2023	navkc1	Bug 57742: Wagon Track Planning - Capacity for Same Train
31/07/2023 navmv20  Defect 59308: MTN - No validation when planning the wagon which is confirmed inwards
*/

vars
	fromPosition : Integer;
	obj : Object;
	oldRailLine,
	myRailLine : CM_RailLine;	//25.8.2022 navhl20 TFS 54281
	myTrain 	: CM_Train;		//25.8.2022 navhl20 TFS 54281
	pos : Integer;
	railLines : CM_ObjectSet;
	wagon : CM_Wagon;
	wagTerm : CM_Terminal;
	myRail : CM_Rail;	//25.8.2022 navhl20 TFS 54281
	
begin
	//Start 25.8.2022 navhl20 TFS 54281
	if self.moveMode = UNPLAN_MODE then
		self.isUndoMove := true;
	elseif self.moveMode = self.MOVE_TO_PLAN then
		self.isMoveToPlanned := true;
	endif;
	//End 25.8.2022 navhl20 TFS 54281
	
	if self.myTargetRailLine &lt;&gt; null then
		//self.validateMove(); // PAR 21182  -&gt; PAR 22031 requires this to be commented out
		if self.moveMode = PLANNING_MODE then // 01/05/2023	navkc1	Bug 57742
			//31/07/2023 navmv20  Defect 59308 - START
			foreach wagon in self.allWagons do
				if wagon.confirmed then
					app.raiseCMException(Wagon_already_confirmed_invard,null,null);
				endif;
			endforeach;
			//31/07/2023 navmv20  Defect 59308 - END
			self.validatePlannedRailLineSpace();
		else
			self.validateRailLineSpace();
		endif;
		create railLines transient;
		railLines.add(self.myTargetRailLine);
	endif;

	//30 Apr 2015	NDL	Par 36133
	foreach wagon in self.allWagons do
		if not self.isUndoMove // ### TFS BUG 58951 19JUL2023 NAVAB1 - allow departed wagons to be unplanned
		and wagon.isDeparted then
			app.raiseCMException(Unable_move_departe_wagon, null, null);
		endif;
	endforeach;
	if self.myTargetTrain &lt;&gt; null then
		if self.myTargetTrain.isDeparted then
			app.raiseCMException1(Train_departe_cannot_updated, self.myTargetTrain.code, null, null);
		endif;
	endif;
		
	//  Find position of first wagon that is already on the target train

	foreach wagon in self.allWagons do
		wagTerm := wagon.getTerminal();
		
		//Start 25.8.2022 navhl20 TFS 54281
		if wagon.myPrimaryPlannedLocation &lt;&gt; null then
			myTrain := wagon.myPrimaryPlannedLocation.myTrain;
			if myTrain &lt;&gt; null then
				if myTrain.myTerminal &lt;&gt; wagTerm then
					app.raiseCMException1(Unable_move_departe_wagon, app.getErrorString(Null), null, null);
				endif;
			endif;
		endif;
		
		if self.moveMode = PLANNING_MODE and self.myTargetRailLine = null then
			app.raiseCMException(Wagon_should_planned_railare,app.getErrorString(Error),null);
		endif;		
		//End 25.8.2022	navhl20	TFS 54281
		
		//02Mar2023 navsp1 TFS 56764
		//Raise an exception if the wagon is already confirmed inward
		//31/07/2023 navmv20  Defect 59308 - START
		/*if self.moveMode = PLANNING_MODE and  wagon.confirmed then
			app.raiseCMException(Wagon_already_confirmed_invard,null,null);
		endif;*/
		//31/07/2023 navmv20  Defect 59308 - END
		
		if self.myTargetTrain &lt;&gt; null then
			if self.myTargetTrain.myTerminal &lt;&gt; wagTerm then
				app.raiseCMException1(Unable_move_departe_wagon, app.getErrorString(Null), null, null);
			endif;
			if self.isInwardTarget then
				if wagon.myTrainInwards = self.myTargetTrain then
					fromPosition := wagon.getMyPositionTrainInwards();
					break;
				endif;
			else
				if wagon.myTrainOutwards = self.myTargetTrain then
					fromPosition := wagon.getMyPositionTrainOutwards();
					break;
				endif;
			endif;
		elseif self.myTargetRailLine &lt;&gt; null then
			if self.myTargetRailLine.myRailArea.myTerminal &lt;&gt; wagTerm then
				app.raiseCMException1(Err_InvalidTerminal, app.getErrorString(Null), null, null);
			endif;
			break;
		endif;
	endforeach;
	
	//Start 25.8.2022 navhl20 TFS 54281
	if self.isUndoMove then
		self.executeUndoMove();
	elseif isMoveToPlanned then
		pos := self.targetPosition;
		if fromPosition &gt; self.targetPosition or fromPosition = 0 then
			foreach wagon in self.allWagons do
				if wagon.myPrimaryPlannedLocation &lt;&gt; null then
					myRailLine := wagon.myPrimaryPlannedLocation.myRailLine;
					myTrain := wagon.myPrimaryPlannedLocation.myTrain;
					if myTrain &lt;&gt; null then
						pos := myTrain.addWagon( self, wagon.confirmed, wagon, pos );
					elseif myRailLine &lt;&gt; null then
						oldRailLine := wagon.myRailLine;
						pos := wagon.myPrimaryPlannedLocation.plannedIndex;
						if oldRailLine &lt;&gt; null and not railLines.includes(oldRailLine) then
							railLines.add(oldRailLine);
						endif;
						myRailLine.addWagon( self, wagon, pos, true );
						pos := wagon.getMyPosition();
					endif;
					pos := pos + 1;
				endif;
			endforeach;
		else
			foreach wagon in self.allWagons reversed do
				if wagon.myPrimaryPlannedLocation &lt;&gt; null then
					myTrain := wagon.myPrimaryPlannedLocation.myTrain;
					if myTrain &lt;&gt; null then
						pos := myTrain.addWagon( self, self.isInwardTarget, wagon, pos );
					endif;
				endif;
			endforeach;
		endif;

		if myRailLine &lt;&gt; null then
			// get rid of null references on the end the wagon array
			foreach obj in railLines do
				obj.CM_RailLine.tidyWagons();
			endforeach;
		endif;
		foreach wagon in self.allWagons do
			if wagon.allPlannedFutureMoves.isNotEmpty then
				wagon.allPlannedFutureMoves.purge();
			endif;
		endforeach;
	elseif self.moveMode = PLANNING_MODE then
		self.executePlan();
	else
	//End 25.8.2022 navhl20 TFS 54281
		//  Do the move.
		//  The individual moves are done in reverse order when we have a wagon that is already on
		//  the target train, and it comes after the target position.  This is an attempt to
		//  keep the source/target values in the audit transactions reasonable.
		//  No longer doing this reversal for moves on the rail line as space for the move is being
		//  created by shunting wagons forward and filling/removing gaps as we go.
		
		pos := self.targetPosition;
		
		if fromPosition &gt; self.targetPosition or fromPosition = 0 or self.myTargetRailLine &lt;&gt; null then
			foreach wagon in self.allWagons do
				if self.myTargetTrain &lt;&gt; null then
					pos := self.myTargetTrain.addWagon( self, self.isInwardTarget, wagon, pos );
				elseif self.myTargetRailLine &lt;&gt; null then
					oldRailLine := wagon.myRailLine;
					if oldRailLine &lt;&gt; null and not railLines.includes(oldRailLine) then
						railLines.add(oldRailLine);
					endif;
					self.myTargetRailLine.addWagon( self, wagon, pos, true );
					pos := wagon.getMyPosition();
				endif;
				pos := pos + 1;
			endforeach;
		else
			foreach wagon in self.allWagons reversed do
				if self.myTargetTrain &lt;&gt; null then
					pos := self.myTargetTrain.addWagon( self, self.isInwardTarget, wagon, pos );
				endif;
			endforeach;
		endif;

		if self.myTargetRailLine &lt;&gt; null then
			// get rid of null references on the end the wagon array
			foreach obj in railLines do
				obj.CM_RailLine.tidyWagons();
			endforeach;
		endif;
		//Start 25.8.2022 navhl20 TFS 54281
		foreach wagon in self.allWagons do
			if wagon.allPlannedFutureMoves.isNotEmpty and not self.isFromTrain then
				wagon.allPlannedFutureMoves.purge();
			endif;
		endforeach;
		//End 25.8.2022 navhl20 TFS 54281
	endif;	//25.8.2022 navhl20 TFS 54281
	
	//  Notify wagon changes
	
	foreach wagon in self.allWagons do
		app.myEventManager.createSingleObjInfoNoteEvt(wagon, _passport.myTerminal.getTerminalEvent(Wagon_Update_Event), wagon);
		wagon.updateObjectEdition(wagon);	//19.09.2022 navhl20 TFS 54281	
	endforeach;

epilog
	delete railLines;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="executePlan" id="cd941238-6b07-462a-8d30-2bb27f623d4f">
        <updating/>
        <source>executePlan() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 August 2022	navhl20	ChangeRequest 54281: EUP - Wagon Track Planning
01/05/2023		navkc1	Bug 57742: Wagon Track Planning - Capacity for Same Train
*/

vars
	wagon 			: CM_Wagon;
	wagonPlanned,
	wagonPlannedPxy,
	wagonPlannedNew : CM_FutureMoveWagonPlanned;
	effectiveDate: TimeStamp;
	targetStr : String;
begin
	foreach wagon in self.allWagons do
		if wagon.allPlannedFutureMoves.isEmpty then
			create wagonPlannedPxy transient;
			create wagonPlannedNew persistent;
			wagonPlannedPxy.setProxy(wagon,
								  self.myTargetTrain,
								  self.myTargetRailLine,
								  self.targetPosition,
								  wagon.myTerminal,
								  TI_FutureMovePlanned,
								  self.isInwardTarget // 01/05/2023	navkc1	Bug 57742
								  );
			wagonPlannedNew.setCreate(wagonPlannedPxy);
		else
			wagonPlanned := wagon.myPrimaryPlannedLocation;
			beginLoad;
				wagonPlannedPxy := wagonPlanned.pxyCreateUpdateProxy();
			endLoad;
			wagonPlannedPxy.setRailLine(self.myTargetRailLine);
			wagonPlanned.setUpdate(wagonPlannedPxy);
		endif;
		
		self.autoSetEffectiveTimeStamp();
		effectiveDate := self.effectiveTimeStamp;
		wagon.createTransaction( effectiveDate, EVT_WagonPlanned,self.myTargetRailLine, null, null, true, null, null, null); // ### TFS BUG 58951 19JUL2023 NAVAB1 - myTargetRailLine
		delete wagonPlannedPxy;
	endforeach;
epilog
	delete wagonPlannedPxy;
end;</source>
    </JadeMethod>
    <JadeMethod name="executeReturnToTerminalMove" id="bc1bffe5-df20-4a6e-8e77-aa5e537a5baa">
        <updating/>
        <source>executeReturnToTerminalMove(_passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 November 2009	cnwndl1	Initial creation
01/05/2023	navkc1	Bug 57742: Wagon Track Planning - Capacity for Same Train
*/

vars

	wagon : CM_Wagon;
	train : CM_Train;
	terminal : CM_Terminal;
	ti : CM_TrackedItem;
	
	
begin

	if not self.returnWagon then
		app.raiseCMException1(Contact_developer, "Return wagon boolean not set", null, null);
		return;
	endif;

	wagon := self.allWagons.first;
	if wagon = null then
		app.raiseCMException(Wagon_null, null, null);
		return;
	endif;
	
	self.validateMove(); 
	
	if self.moveMode = PLANNING_MODE then  // 01/05/2023	navkc1	Bug 57742
		self.validatePlannedRailLineSpace();
	else
		self.validateRailLineSpace();
	endif;
	
	train := wagon.myTrainOutwards;
	if train = null then
		app.raiseCMException(Null_train, null, null);
		return;
	endif;
	
	terminal := train.myTerminalDeparted;
	if terminal = null then
		terminal := train.myTerminal;
	endif;
	if terminal = null then
		app.raiseCMException(ERROR_NULL_Terminal, null, null);
		return;
	endif;

	//Train
	//clear any TIs on the wagon from Trains allTIsReleased collection
	foreach ti in wagon.allTIsReleased do
		if train.allTIsReleased.includes(ti) then
			train.allTIsReleased.remove(ti);
		endif;
	endforeach;

	//Train
	// set myTerminal and reset myTerminalDeparted
	train.resetTerminalOnWagonReturn(terminal);
	
	//wagon
	// set myRailLine
	self.myTargetRailLine.addWagon( self, wagon, targetPosition, true );
	
	//wagon
	// set myTerminal and reset myTerminalDeparted, clear allTIsReleased, 
	// reset confirmed outwards, and add return transaction.
	wagon.returnWagon( self, terminal, targetPosition, _passport);
	
	
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="executeUndoMove" id="58dd00ac-9daa-4fc7-9799-07b1865d4b43">
        <updating/>
        <source>executeUndoMove() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2022	navhl20	ChangeRequest 54281: EUP - Wagon Track Planning
24 Aug 2022 navsj20	ChangeRequest 54281: EUP - Wagon Track Planning

*/

vars
	wagon :CM_Wagon;
	effectiveDate: TimeStamp;
	railline : CM_RailLine;
	fm : CM_FutureMoveWagonPlanned;
begin
	 // ### TFS BUG 58951 19JUL2023 NAVAB1 - rewritten
	if not self.isUndoMove then
		return;
	endif;
	
	foreach wagon in self.allWagons do
		fm := wagon.allPlannedFutureMoves.first.CM_FutureMoveWagonPlanned; 
		if fm &lt;&gt; null then
			railline :=fm.myRailLine;
			wagon.allPlannedFutureMoves.purge();
			self.autoSetEffectiveTimeStamp();
			effectiveDate := self.effectiveTimeStamp;
			wagon.createTransaction( effectiveDate, EVT_WagonUnplanned,railline, null, null, true, null, null, null); 
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setEffectiveTimeStampOverride" id="c3075295-f8ed-4f3c-800b-bef789cdf457">
        <updating/>
        <source>setEffectiveTimeStampOverride(newTS : TimeStamp) updating;
/*

Purpose:			

Parameters:			

Return Value:		

