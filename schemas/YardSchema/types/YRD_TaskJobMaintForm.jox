    <JadeMethod name="refreshFromChildSourceForm" id="0dd5a4d9-34fd-497a-941a-36aa5b99871a">
        <updating/>
        <source>refreshFromChildSourceForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
23 December 2009	cnwrd1	Initial creation
08/04/2011			cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
*/

vars
	loadStateSet : Boolean;
	workOrder : CM_WorkOrder;
	pxyWOSource : CM_WorkOrderTISource;
begin

	workOrder := myCurrentProxyWorkOrder;

	//Note: No cancel functionality for Add is allowed for. This is done on purpose.
	//Having to allow for the cancel would require a copy of the proxy to be made
	//if frm.modalResult = IDOK and self.mode = self.Mode_Add then //Persistent wodtls have NOT been updated
	if self.mode = self.Mode_Add then //Persistent wodtls have NOT been updated
		self.doWorkOrderDisplay();
	elseif self.mode = self.Mode_Update then 
		//Either cancel has been presssed or an update on the persistent source has occurred.  
		//Refresh from persistent source in both cases.  
		//This is so that:
		//1. In the event of updating a persistent object the latest edition of the real object is retreived 
		//2. In the event of a cancel, any changes to the proxies has been backed out of
		
		app.cmsBeginLoad(loadStateSet);
		
		pxyWOSource := workOrder.CM_WorkOrderTI.mySource;
		delete pxyWOSource;
		
		pxyWOSource := self.setProxyWorkOrderSource();
		self.getSourceDisplay(workOrder);
		
		app.cmsEndLoad(loadStateSet);
	endif;
	
	self.lblTotalRequest.caption := app.getErrorString(Total_Requested) &amp; ' : ' &amp; workOrder.CM_WorkOrderTI.mySource.getTotalCargoCount().String;
		
	self.setControlsForMode(true);
epilog
	app.cmsEndLoad(loadStateSet);		// 08/04/2011 cnwmh5 #27347
end;</source>
    </JadeMethod>
    <JadeMethod name="refreshFromChildTaskForm" id="320bf677-885e-41ad-b363-09e2b7940f49">
        <updating/>
        <source>refreshFromChildTaskForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
23 December 2009	cnwrd1	Initial creation
08/04/2011			cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
*/

vars
	loadStateSet : Boolean;
	workOrder : CM_WorkOrder;
	task : CM_WorkOrderDtl;
begin
	
	workOrder := self.myCurrentProxyWorkOrder;
	
	
	//Note: No cancel functionality for Add is allowed for. This is done on purpose.
	//Having to allow for the cancel would require a copy of the proxy to be made
	if self.mode = self.Mode_Add then //Persistent wodtls have NOT been updated
		self.doWorkOrderDisplay();
	elseif self.mode = self.Mode_Update then 
		//Either cancel has been presssed or an update on the persistent wodtls has occurred.  
		//Refresh from persistent wodtls in both cases.  
		//This is so that:
		//1. In the event of updating a persistent object the latest edition of the real object is retreived 
		//2. In the event of a cancel, any changes in to the proxies in YRD_TaskJobTasks has been backed out of
		app.cmsBeginLoad(loadStateSet);
		
		workOrder.allWoDtls.purge();
		self.myCurrentWorkOrder.pxyCreateUpdateProxyWODtls(workOrder);
		self.doTaskDisplay(workOrder);
		app.cmsEndLoad(loadStateSet);
	endif;
	
	self.setControlsForMode(true);
epilog
	app.cmsEndLoad(loadStateSet);		// 08/04/2011 cnwmh5 #27347
end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForMode" id="97f6c932-2376-4866-8284-21863467e3a4">
        <source>setControlsForMode(_setFocus : Boolean)protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29/07/2009	cnwmd1	Initial creation
18/05/2018	jlgdap1	TFS 38560 PEL1 Voyage Work Orders
15 Feb 2023 navma1  ChangeRequest 56561: FR 53944 | EUP - Simplified Voyage Work Order
*/

vars
	mo : Integer;
	allowSourceEdit : Boolean;
	cmbTaskId : Integer;
begin
	mo := self.mode;
	
	//12 Mar 2019	NDL	TFS 43405
	if self.cmbTask.visible and self.cmbTask.listIndex &gt; 0 then
		cmbTaskId := self.cmbTask.itemData[ self.cmbTask.listIndex ];
	endif;
	if cmbTaskId = WO_TASK_RELEASEEXTENSION then
		self.grpSource.enabled := false; // nothing to go in here for release extensions.
	else
		self.grpSource.enabled := true;
	endif;
	
	//visibility
	//self.cmbTask.visible := mo = self.Mode_Add and not self.hasTaskFormBeenShown;													// TFS 38560
	self.cmbTask.visible := mo = self.Mode_Add and (not self.hasTaskFormBeenShown or self.tbTasks.rows = self.tbTasks.fixedRows);	// TFS 38560
	
	self.lProgress.visible := mo = self.Mode_Update or mo = self.Mode_View;
	//self.tbTasks.visible := mo = self.Mode_Update or mo = self.Mode_View or hasTaskFormBeenShown;													// TFS 38560
	self.tbTasks.visible := mo = self.Mode_Update or mo = self.Mode_View or (hasTaskFormBeenShown and self.tbTasks.rows &gt; self.tbTasks.fixedRows);	// TFS 38560
	
	self.btnSourceEdit.enabled := true;
	self.btnTaskEdit.enabled := true;
	
	self.lJobID.visible := true;
	self.txtJobID.visible := true;
	
	self.txtJobID.enabled := mo = self.Mode_Add ;
	
	self.btnEmail.enabled := mo = self.Mode_Add or mo = self.Mode_Update;
	self.chkSendEmail.enabled := mo = self.Mode_Add or mo = self.Mode_Update;
	
	self.cmbCargoType.enabled := mo = self.Mode_Add or mo = self.Mode_Update;
	self.cmbJobStatus.enabled := mo = self.Mode_Add or mo = self.Mode_Update;
	
	self.cmbJobEnteredBy.enabled := mo = self.Mode_Add or mo = self.Mode_Update;
	self.cmbOrganisation.enabled := mo = self.Mode_Add or mo = self.Mode_Update;
	self.cmbTask.enabled := self.myCurrentProxyWorkOrder.allWoDtls.size = 0;
	
	self.tmApproved.enabled := mo = self.Mode_Add or mo = self.Mode_Update;
	
	self.txtEmail.enabled := false;
	
	if not self.myCurrentProxyWorkOrder.isVoyageWorkOrder then						// TFS 38560
		if self.myCurrentProxyWorkOrder.CM_WorkOrderTI.mySource = null then
			allowSourceEdit := true;
		else
			allowSourceEdit := not self.myCurrentProxyWorkOrder.CM_WorkOrderTI.mySource.hasNonIDSource();
		endif;
	endif;																			// TFS 38560
	
	self.txtSourceList.visible := allowSourceEdit;
	self.cmbCargoType.enabled := allowSourceEdit;
	
	
	
	//self.tbCargo.visible := not allowSourceEdit;												// TFS 38560
	//self.cmbCargoType.visible := allowSourceEdit;												// TFS 38560
	//self.lblCargoType.visible := allowSourceEdit;												// TFS 38560
	self.tbCargo.visible := not allowSourceEdit and self.workOrderMode = WorkOrderMode_Cargo;	// TFS 38560
	self.cmbCargoType.visible := allowSourceEdit and self.workOrderMode = WorkOrderMode_Cargo;	// TFS 38560
	self.lblCargoType.visible := allowSourceEdit and self.workOrderMode = WorkOrderMode_Cargo;	// TFS 38560
	
	
	
	self.txtReference.enabled := mo = self.Mode_Add or mo = self.Mode_Update;
	self.txtTotalRequired.enabled := mo = self.Mode_Add or mo = self.Mode_Update;
	self.txtRemarks.enabled := mo = self.Mode_Add or mo = self.Mode_Update;
	
	self.dtJobRequiredBy.enabled := mo = self.Mode_Add or mo = self.Mode_Update;
	self.tmJobRequiredBy.enabled := mo = self.Mode_Add or mo = self.Mode_Update;
	self.dtEnterd.enabled := mo = self.Mode_Add or mo = self.Mode_Update;
	self.tmEntered.enabled := mo = self.Mode_Add or mo = self.Mode_Update;
	self.dtApproved.enabled := mo = self.Mode_Add or mo = self.Mode_Update;
	
	self.dtJobStartDate.enabled := mo = self.Mode_Add or mo = self.Mode_Update;
	self.tmJobstartTime.enabled := mo = self.Mode_Add or mo = self.Mode_Update;
	self.dtJobCompleted.enabled := mo = self.Mode_Add or mo = self.Mode_Update;
	self.tmJobCompleted.enabled := mo = self.Mode_Add or mo = self.Mode_Update;
	self.dtApprovalExpiry.enabled := mo = self.Mode_Add or mo = self.Mode_Update;	//11 Jun 2018	NDL	TFS 38795
	self.tmApprovalExpiry.enabled := mo = self.Mode_Add or mo = self.Mode_Update;	//11 Jun 2018	NDL	TFS 38795
	
	self.btnSchedule.enabled := self.myCurrentProxyWorkOrder.hasBeenApproved();
	
	self.txtApprovedBy.readOnly := true;
	
	if self.myCurrentProxyWorkOrder.taskStatus &lt; WO_STATUS_APPROVED and  app.workOrderStatusStringToEnum( self.cmbJobStatus.text ) = WO_STATUS_APPROVED then		//15.02.2023 navma1 #56561
		self.txtApprovedBy.readOnly := false;
	endif;
	
	if self.myCurrentWorkOrder &lt;&gt; null then	
		if self.myCurrentWorkOrder.taskStatus = WO_STATUS_COMPLETE or self.myCurrentWorkOrder.taskStatus = WO_STATUS_CANCELLED then
			self.chkSetArchived.visible := true;
		else
			self.chkSetArchived.visible := false;
		endif;
	endif;
	
	self.lEmail.visible := self.chkSendEmail.value;
	self.txtEmail.visible := self.chkSendEmail.value;
	self.btnEmail.visible := self.chkSendEmail.value;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_setFocus" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDefaults" id="7b6af679-6c1e-4206-93d3-556ca3527d16">
        <source>setDefaults()protected;
/*
Purpose:			Set default values for new Work Order

Parameters:			

Return Value:		

Date		Who		Reason
29/07/2009	cnwmd1	Initial creation
04/12/2013	cnwdap1	PAR #32719 Don't reset the cargo type combo if we've already set it in displaySelectorResults
18 Jul 2016	cnwns1 	TFS2333 Multi-timezone issues
08/05/2018	jlgdap1	TFS 38501 PEL1 Work Order Changes
15 Feb 2023 navma1 ChangeRequest 56561: FR 53944 | EUP - Simplified Voyage Work Order
*/
vars
	cargoBOLType : CM_CargoBOLType;
	nowLocal	 : TimeStamp;
begin
	nowLocal := self.systemToLocalTime(app.actualTimeServer);	//18 July 2016	cnwns1 	TFS2333
	self.cmbJobStatus.listIndex := self.cmbJobStatus.findString(1, app.workOrderStatusEnumToString(WO_STATUS_USERENTRY) );		//15.02.2023 navma1 #56561
	self.cmbJobEnteredBy.setObject(app.myPassport.myUser);
	
	if self.mode &lt;&gt; self.Mode_Add or self.txtSourceList.text = null then	// PAR #32719
		cargoBOLType := app.myPassport.getDefaultCargoBOLType();
		if cargoBOLType &lt;&gt; null then
			self.cmbCargoType.setObject(cargoBOLType);
		endif;
	endif;																	// PAR #32719
	
	self.cmbOrganisation.setObject(app.myPassport.myUser.myOrganisation);
	
	self.dtEnterd.setDate(nowLocal.Date );					//18 July 2016	cnwns1 	TFS2333
	self.tmEntered.setTime(nowLocal.Time );					//18 July 2016	cnwns1 	TFS2333
	
	
	self.lblPin.visible   := false;			// TFS 38501
	self.lblPinNo.visible := false;			// TFS 38501
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setFormObject" id="25565ddd-7b37-4807-b094-ec6360947f4e">
        <updating/>
        <source>setFormObject(_obj: Object) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14/01/2010	cnwrd1	Initial creation
17/05/2018	jlgdap1	TFS 38560 PEL1 Voyage Work Orders
*/

vars
	woMode : Integer;			// TFS 38560

begin
	if _obj.CM_WorkOrder.isVoyageWorkOrder then								// TFS 38560
		woMode := WorkOrderMode_Voyage;										// TFS 38560
	else																	// TFS 38560
		woMode := WorkOrderMode_Cargo;										// TFS 38560
	endif;																	// TFS 38560
	//self.initialiseForm ( _obj.CM_WorkOrder, self.Mode_Update);			// TFS 38560
	self.initialiseForm ( _obj.CM_WorkOrder, self.Mode_Update, woMode,null);		// TFS 38560

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setProxyWorkOrder" id="00c95ef7-aeef-4bf0-b3d6-cb13539c693b">
        <updating/>
        <source>setProxyWorkOrder(_pxyWorkOrder : CM_WorkOrder input) : Boolean protected, updating;

/*

Purpose:			

Parameters:			Sets the base

Return Value:		


Date		Who		Reason
28/07/2009	cnwmd1	Initial creation
29/04/2016	cnwns1	TFS 488 - Multi Timezone Support
23/05/2018	jlgdap1	TFS 38560 PEL1 Voyage Work Orders
24 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
*/

vars
	workOrder 		: CM_WorkOrder;
	enteredByUser 	: CM_User;
	org 			: CM_Organisation;
	sendEmail 		: Boolean;
	totalReq		: Integer;
	taskStatus 		: Integer;
	reqByDTLocal	: TimeStamp;
	reqByDTSystem	: TimeStamp;
	enteredDTLocal	: TimeStamp;
	enteredDTSystem	: TimeStamp;
	startDTLocal	: TimeStamp;
	startDTSystem	: TimeStamp;
	approvedBy 		: String;
	refStr 			: String;
	remarksStr 		: String;
	appExpLocal		: TimeStamp;
	appExpSystem	: TimeStamp;
begin
	
	if workOrder &lt;&gt; null then //Existing work order.  New work order will be set later on to avoid duplicates
		_pxyWorkOrder.setID(workOrder.id);
	else
		_pxyWorkOrder.setID( self.txtJobID.text);  //if we have a user entered jobiD.
	endif;
	
	totalReq := self.txtTotalRequired.text.Integer;
	
	sendEmail := self.chkSendEmail.value;
	
	reqByDTLocal.setDate(self.dtJobRequiredBy.text.asDateJMT());
	reqByDTLocal.setTime(self.tmJobRequiredBy.text.asTimeJMT());
	reqByDTSystem := self.localToSystemTime(reqByDTLocal);//29 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	enteredDTLocal.setDate(self.dtEnterd.text.asDateJMT());
	enteredDTLocal.setTime(self.tmEntered.text.asTimeJMT());
	enteredDTSystem := self.localToSystemTime(enteredDTLocal);//29 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support

	//approvedDT.setDate(self.dtApproved.text.asDateJMT());
	//approvedDT.setTime(self.tmApproved.text.asTimeJMT());
	startDTLocal.setDate(self.dtJobStartDate.text.asDateJMT());
	startDTLocal.setTime(self.tmJobstartTime.text.asTimeJMT());
	startDTSystem := self.localToSystemTime(startDTLocal);//29 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
	//complDT.setDate(self.dtJobCompleted.text.asDateJMT());
	//complDT.setTime(self.tmJobCompleted.text.asTimeJMT());
	
	appExpLocal.setDate( self.dtApprovalExpiry.text.asDateJMT );	//11 Jun 2018	NDL	TFS 38795
	appExpLocal.setTime( self.tmApprovalExpiry.text.asTimeJMT );	//11 Jun 2018	NDL	TFS 38795
	appExpSystem := self.localToSystemTime(appExpLocal);			//11 Jun 2018	NDL	TFS 38795
	
	refStr := self.txtReference.text;
	
	enteredByUser := self.cmbJobEnteredBy.listObject.CM_User;
	approvedBy 	  := self.txtApprovedBy.text;
	remarksStr 	  := self.txtRemarks.text;
	taskStatus	  := app.workOrderStatusStringToEnum( self.cmbJobStatus.text );		//15.02.2023 navma1 #56561
	
	org := self.cmbOrganisation.listObject.CM_Organisation;
	
	_pxyWorkOrder.setProxy(self.myEmailController.allToAddresses,
		refStr,
		sendEmail,
		enteredDTSystem,
		enteredByUser,
		approvedBy,
		org,
		self.myTerminal,
		remarksStr,
		reqByDTSystem,
		startDTSystem,
		taskStatus
		);	
		
	_pxyWorkOrder.setArchived( self.chkSetArchived.value);
	_pxyWorkOrder.setApprovalExpiry( appExpSystem );	//11 Jun 2018	NDL	TFS 38795
	
	if self.workOrderMode = WorkOrderMode_Cargo then										// TFS 38560
		_pxyWorkOrder.CM_WorkOrderTI.setTotalRequired(totalReq);							//24.01.2023 navma1 #56141 Task#56147
	elseif self.workOrderMode = WorkOrderMode_Voyage then									// TFS 38560
		_pxyWorkOrder.CM_WorkOrderVoyage.setMyVoyage(self.cmbVoyage.listObject.CM_Voyage);	// TFS 38560
	endif;																					// TFS 38560
	return true;
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_pxyWorkOrder" type="CM_WorkOrder" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxyWorkOrderSource" id="15b13d62-5a1e-4c29-814b-e6c8850e4352">
        <source>setProxyWorkOrderSource() : CM_WorkOrderTISource protected;

/*

Purpose:			
	method is only called for new work 
Parameters:

Return Value:		Will return CM_WorkOrderTISource for new proxy that has a persistant real object (update mode).  This is because the clone takes place


Date		Who		Reason
30 July 2009	cnwmd1	Initial creation
*/

vars
	realWOSource : CM_WorkOrderTISource;
begin
	if self.myCurrentWorkOrder &lt;&gt; null then
		realWOSource := self.myCurrentWorkOrder.CM_WorkOrderTI.mySource;
	endif;

	return self.myCurrentProxyWorkOrder.setProxyWorkOrderSource(
					realWOSource, 
					self.myCurrentProxyWorkOrder.CM_WorkOrderTI, 
					self.cmbCargoType.listObject.CM_CargoType, 
					self.txtSourceList.text, 
					self.hasSourceFormBeenShown);
	
epilog
	
end;</source>
        <access>protected</access>
        <ReturnType type="CM_WorkOrderTISource"/>
    </JadeMethod>
    <JadeMethod name="setProxyWorkOrderTasks" id="e81692b8-657c-436d-a230-a7a66aa37936">
        <source>setProxyWorkOrderTasks(_pxyWorkOrder : CM_WorkOrder input) protected;

/*

Purpose:			Creates each CM_WorkOrderDtl and adds to the pxyWorkOrder.

Parameters:			

Return Value:		


Date		Who		Reason
31 Jul 2009	cnwmd1	Initial creation
29 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
18/05/2018	jlgdap1	TFS 38560 PEL1 Voyage Work Orders
24 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
*/

vars
	reqByDT, 
	startDT  : TimeStamp;
	taskType : Integer;
begin
	if self.mode &lt;&gt; self.Mode_Add then
		app.raiseUnexpectedProgramError(self.class.name, method.name, "Should only be creating a WorkOrderDtl on work order creation");
	endif;
	
	reqByDT.setDate(self.dtJobRequiredBy.text.asDateJMT());
	reqByDT.setTime(self.tmJobRequiredBy.text.asTimeJMT());
	reqByDT := self.localToSystemTime(reqByDT);//29 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
	startDT.setDate(self.dtJobStartDate.text.asDateJMT());
	startDT.setTime(self.tmJobstartTime.text.asTimeJMT());
	startDT := self.localToSystemTime(startDT);//29 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
	if self.cmbTask.listIndex &gt; 0 then
		//epr TFS 41310 15/10/18
		if self.cmbTask.listObject &lt;&gt; null then
			taskType := WO_TASK_TODO;
		else
			taskType:= self.cmbTask.listData;
		endif;
			
		_pxyWorkOrder.createProxyWorkOrderTasks(taskType,reqByDT, startDT,  self.cmbTask.listObject.CM_ToDoTaskDesc);	//24.01.2023 navma1 #56141 Task#56147
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_pxyWorkOrder" type="CM_WorkOrder" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setRejectReason" id="3ae5f197-8ac0-43a8-ae33-ae8fc9b5f9d2">
        <source>setRejectReason() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		True if reject reason value was set

Date				Who		Reason
12 October 2021		jlizm1	Initial creation TFS 51963 SAL Voyage Request Changes

*/

vars

	frm : YRD_WorkOrderRejectForm;
	remark : CM_PredefinedRemark;
	
begin

	frm := app.loadForm(YRD_WorkOrderRejectForm, YRD_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).YRD_WorkOrderRejectForm;
	
	if frm = null then
		return false;
	endif;

	frm.myParentForm := self;	
	frm.showModal();
	
	if frm.modalResult = IDOK then
		if frm.selectedRemark &lt;&gt; null then
			self.txtRemarks.text := frm.selectedRemark.description;
			return true;
		endif;
	endif;
	
	return false;
	
epilog

	delete frm;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="832df875-0375-4624-b9d5-6359f7291460">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28/07/2009	cnwmd1	Initial creation
24/05/2018	jlgdap1	TFS 38560 PEL1 Voyage Work Orders
10/09/2021  navma1  ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
*/

vars
	voyage : CM_Voyage;
	term   : CM_Terminal;
begin
	
	term 				:= self.myTerminal;					//10.09.2021 navma1 #51002
	self.useYardJobs	:= term.isUseYardJobsForCargoWo;    //10.09.2021 navma1 #51002
	
	self.centreOverParent(100);
	
	self.width := self.minimumWidth;
	if self.workOrderMode = WorkOrderMode_Voyage then
		self.minimumHeight := self.minimumHeight - 55;
	endif;
	self.height 	:= self.minimumHeight;
	self.hasChanged := false;
	self.createProxy();
	
	self.buildCombos();
	
	self.tbTasks.selectionType := self.tbTasks.SelectionType_Row;
	self.tbCargo.selectionType := self.tbCargo.SelectionType_Row;
	
	// TFS 38560
	if self.workOrderMode = WorkOrderMode_Voyage then
		self.grpSource.caption := app.getErrorString(Voyage) &amp; Colon;
		self.lblVoyage.move(self.lblTotalRequired.left, self.lblTotalRequired.top, self.lblTotalRequired.width, self.lblTotalRequired.height);
		self.cmbVoyage.move(self.txtTotalRequired.left, self.txtTotalRequired.top, self.cmbJobStatus.width, self.cmbJobStatus.height);
		self.lblExternalVoyCode.move(self.lblTotalRequired.left, self.lblVoyage.top + self.lblVoyage.height + 5, self.lblTotalRequired.width, self.lblTotalRequired.height);
		self.txtExternalVoyCode.move(self.txtTotalRequired.left, self.lblVoyage.top + self.lblVoyage.height + 5, self.cmbJobStatus.width,self.txtTotalRequired.height);
		
		self.lblVoyage.visible 			 := true;
		self.cmbVoyage.visible 			 := true;
		self.lblExternalVoyCode.visible  := true;
		self.txtExternalVoyCode.visible	 := true;
		self.txtExternalVoyCode.enabled  := false;
		self.grpSource.height			 := self.grpSource.height - 49;
		self.grpJobDetails.top			 := self.grpJobDetails.top - 49;
		self.grpJobDetails.height 		 := 240;
		self.lblTotalRequired.visible 	 := false;
		self.txtTotalRequired.visible 	 := false;
		self.lblTotalRequest.visible 	 := false;
		self.tbCargo.visible 			 := false;
		self.cmbCargoType.visible 		 := false;
		self.lblCargoType.visible 		 := false;
		self.btnSourceEdit.visible 		 := false;
	endif;
	// TFS 38560
	
	create self.myEmailController transient;
	
	if self.mode = self.Mode_View then //default
		self.doWorkOrderDisplay();
	elseif self.mode = self.Mode_Update then
		self.doWorkOrderEdit();
	elseif self.mode = self.Mode_Add then
		self.doWorkOrderNew();
	endif;
	
	if not self.useYardJobs then							// TFS 38560    //10.09.2021 navma1 #51002
		self.btnSchedule.visible    := false;			    // TFS 38560
		self.lJobStartAt.visible    := false;				// TFS 38560
		self.dtJobStartDate.visible := false;				// TFS 38560
		self.tmJobstartTime.visible := false;				// TFS 38560
	endif;													// TFS 38560
	self.mnuShowSources.visible := false;					// TFS 38560
		
	self.caption := self.getFormCaption();
	
	if self.myInitVoyage &lt;&gt; null then
		voyage:=self.myInitVoyage;
	else
		voyage := app.getMyCurrentVoyageForTerminal(self.myTerminal);		// TFS 38560
	endif;
	if voyage &lt;&gt; null and voyage.myTerminal = self.myTerminal and self.cmbVoyage.listIndex = -1 then	// TFS 38560
		self.cmbVoyage.listIndex := self.cmbVoyage.findObject(voyage);		// TFS 38560
	endif;																	// TFS 38560
	
	self.beginClassNotification(CM_WorkOrder, false, Any_System_Event, Response_Continuous, null); //cnwrd1 
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="cef8a6b3-a6e8-4b3d-ac60-aef138c74b65">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 January 2010	cnwrd1	Initial creation
29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
*/

vars


	expectedEdition : Integer;
	invalidObj : Boolean;
	edition  : Integer;
begin

	on Exception  do app.handleDeletedObject(exception,theObject,invalidObj);
	edition := theObject.edition;
	
	
	if eventType = Object_Update_Event and theObject = self.myCurrentWorkOrder and not invalidObj then
		app.msgBox('Another user has updated the Work Order you currently have selected.' &amp; CrLf &amp;
				'The Work Order must now be re-loaded.', 'Work Order updated', MsgBox_Exclamation_Mark_Icon);
		
		delete self.myCurrentProxyWorkOrder;
		self.createProxy();
		self.doWorkOrderDisplay();

	elseif (invalidObj or  eventType = Object_Delete_Event) and theObject = self.myCurrentWorkOrder then
		app.msgBox('Another user has deleted the Work Order you are currently editing. The editing must now be cancelled','Work Order deleted by another user.',MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		self.unloadForm();
	endif;
	
	
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
