    <JadeMethod name="addSearchToolbarControls" id="4439db91-a3bd-483b-830b-294927c7f442">
        <source>addSearchToolbarControls();
/*

Purpose:			


Return Value:		


Date		Who		Reason
19 December 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	toolbar : CMUI_Toolbar;
begin
	
	toolbar := self.frmSearchToolbar;
	toolbar.addButton(self.btnQuery, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnResetSearch, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnHideSearcher, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;
	
	toolbar.alignContainer := Frame.AlignContainer_Top; 


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="584e3c20-4f30-492b-aee7-64c5cf06a92e">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
18 December 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	toolbar : CMUI_Toolbar;
	showCaptions : Boolean;
begin
	inheritMethod();
	toolbar := self.frmToolbar;
	showCaptions := toolbar.showCaptions;
	
	toolbar.addButton(self.btnShowSearch, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnPrint,CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnRefresh,CMUI_Toolbar.Control_Alignment_Left);

	
	toolbar.addButton(self.btnFlipVert,CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnHideCompleted,CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	

	toolbar.addButton(self.btnShipDelays,CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnDelaysEnquiry,CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnVoyageDef,CMUI_Toolbar.Control_Alignment_Left);

	
	toolbar.addButton(self.btnOOW,CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnOOWCreation,CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
