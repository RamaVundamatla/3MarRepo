    <JadeMethod name="doSave" id="410763e8-78d4-4bc0-8bfe-c9e27fe599c4">
        <updating/>
        <source>doSave()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

	
	proxy : CM_VehicleBookingDayTemplate;
	name : String;
	priority : Integer;
	calendar : CM_Calendar;
	newDayTemp : CM_VehicleBookingDayTemplate;
	theReturn : Integer;
	loadState : Boolean;

begin

	if not self.doValidate() then
		return;
	endif;
	
	name := self.txtName.text;
	priority := self.txtPriority.text.Integer;
	calendar := self.cmbCalendar.listObject.CM_Calendar;
	
	if self.myDayTemplate = null then
		create proxy transient;
	else
		app.cmsBeginLoad(loadState);
		proxy := self.myDayTemplate.pxyCreateUpdateProxy().CM_VehicleBookingDayTemplate;
		app.cmsEndLoad(loadState);
	endif;
	
	
	proxy.setProxy(	name,	//	_name : String;
					priority,	//	_priority : Integer;
					calendar,	//_myCalendar : CM_Calendar;
					self.myVehicleBookingTerminal	//_myVehicleBookingTerm : CM_VehicleBookingTerminal
					);
					
	while true do
		if self.myDayTemplate = null then
			app.myTrxCA.trxCreateVehicleDayTemp(proxy, newDayTemp, app.myPassport);
		else
			app.myTrxUA.trxUpdateVehicleDayTemp(proxy, app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			if self.myDayTemplate = null then
				self.myDayTemplate := newDayTemp;
			endif;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Vehicle_schedule_day_template), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;
	
	self.setTimeButtons();
	
epilog

	delete proxy;
	app.cmsEndLoad(loadState);

end;</source>
    </JadeMethod>
    <JadeMethod name="doValidate" id="a9af73b0-ff27-4090-ae09-93466b9894e5">
        <source>doValidate():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

begin

	if self.myVehicleBookingTerminal = null then
		app.msgBox( app.getErrorString(Terminal_reference_set), app.getErrorString(Error), MsgBox_OK_Only);
		return false;
	endif;
	
	if self.txtName.text.trimBlanks = null then
		app.msgBox( app.getErrorString(Name_required_field), app.getErrorString(Error), MsgBox_OK_Only);
		self.txtName.setFocus();
		return false;
	endif;

	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initTblTimes" id="29166632-fe6e-4367-a1d8-e685ec04d7ad">
        <source>initTblTimes();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

	entTableDef : EntTableDef;
	iter : Iterator;
	timeTemp : CM_VehicleBookingTimeTemplate;

begin

	self.tblTimes.clear();
	
	entTableDef := app.myController.getEntTableDef(ETDef_TimeSlotTemplate);
	self.tblTimes.setTblDataEntRowsFromDef(entTableDef);
	
	self.tblTimes.selectMode := Table.SelectMode_WholeRows;
	
	if self.myDayTemplate = null then
		return;
	endif;
	
	iter := self.myDayTemplate.allTimeTemplates.createIterator;
	
	while iter.next( timeTemp ) do
		self.addObjToTblTimes( timeTemp );
	endwhile;

epilog

	self.setTimeButtons();
	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="populateCmbCalendar" id="c8e27468-1bd7-42c6-97af-2785c95b6e42">
        <source>populateCmbCalendar();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 April 2013	cnwndl1	Initial creation

*/

vars

	iter : Iterator;
	calendar : CM_Calendar;
	index : Integer;

begin

	self.cmbCalendar.clear();
	iter := self.myTerminal.allCalendars.createIterator;
	while iter.next( calendar ) do
		index := self.cmbCalendar.addItem( calendar.description );
		self.cmbCalendar.itemObject[index] := calendar;
	endwhile;

epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyTemplates" id="bb854cd6-2183-4580-b0ce-edb902f4342a">
        <updating/>
        <source>setMyTemplates( dayTemp : CM_VehicleBookingDayTemplate; vssTerm : CM_VehicleBookingTerminal ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

begin

	
	self.myDayTemplate := dayTemp;
	if dayTemp &lt;&gt; null then
		self.myVehicleBookingTerminal := dayTemp.myVehicleBookingTerminal;
	else
		self.myVehicleBookingTerminal := vssTerm;
		if self.myVehicleBookingTerminal.hasDefaultDayTemplate() then
			self.chkIsDefault.enabled := false;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="dayTemp" type="CM_VehicleBookingDayTemplate"/>
        <Parameter name="vssTerm" type="CM_VehicleBookingTerminal"/>
    </JadeMethod>
    <JadeMethod name="setTimeButtons" id="2ec86698-1f51-4c84-b7f8-82ebe8f62063">
        <source>setTimeButtons();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

	timeTemp : CM_VehicleBookingTimeTemplate;
	
begin

	if self.myDayTemplate &lt;&gt; null then
	
		if self.tblTimes.row &gt; self.tblTimes.fixedRows and self.tblTimes.row &lt;= self.tblTimes.rows then
			timeTemp := self.tblTimes.accessRow( self.tblTimes.row ).itemObject.CM_VehicleBookingTimeTemplate;
		endif;
	
		self.btnAddTime.enabled := true;
		self.btnDelTime.enabled := timeTemp &lt;&gt; null;
		self.btnUpdTime.enabled := timeTemp &lt;&gt; null;
		
	else
		self.btnAddTime.enabled := false;
		self.btnDelTime.enabled := false;
		self.btnUpdTime.enabled := false;
		
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="7ec51213-13a4-4644-9892-e2625fd0f3ec">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

begin

	self.populateCmbCalendar();
	
	inheritMethod();
	
	self.centreOverParent(0);
	
	if self.myDayTemplate &lt;&gt; null then
		self.chkIsDefault.value :=  self.myDayTemplate.isDefaultTemplate;
	else
		self.chkIsDefault.value :=  false;	
	endif;
	self.doClickDefault;
	
	self.txtTerminal.text := self.myVehicleBookingTerminal.myTerminal.name;
	
	self.initTblTimes();

epilog

end;</source>
    </JadeMethod>
