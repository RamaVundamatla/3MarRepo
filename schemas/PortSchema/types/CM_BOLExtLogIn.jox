    <JadeMethod name="setPxyFromCMIF_BOL" id="b3aeb14e-9deb-4623-9d6a-e0fa9e52ec19">
        <updating/>
        <source>setPxyFromCMIF_BOL(_bol: CMIF_BOLIn) updating;
// ---------------------------------------------------------------------------
// Created:     25 June 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	pxyTicketSeq, 
	intTicketSeq		: CM_TicketSequence;

begin
	inheritMethod(_bol);

	self.activity			:= _bol.activity;
	self.backload			:= _bol.backload;
	self.chhSupplier		:= _bol.chhSupplier;
	self.customer			:= _bol.customer;
	self.fellDate 			:= _bol.fellDate;
	self.gangNumber			:= _bol.gangNumber;
	self.jasScaled			:= _bol.jasScaled;
	self.lengthCode 		:= _bol.lengthRandom;	
	self.loaderNumber		:= _bol.loaderNumber;
	self.logGradeCode 		:= _bol.logGradeCode;
	self.logSpeciesCode 	:= _bol.logSpeciesCode;
	self.logTreatmentCode	:= _bol.logTreatmentCode;
	self.logTypeCode 		:= _bol.logTypeCode;
	self.nightshift			:= _bol.nightshift;
	self.numberOfLifts		:= _bol.numberOfLifts;
	self.percentScaled		:= _bol.percentScaled;
	self.pickupPoint		:= _bol.pickupPoint;
	self.scalerCode			:= _bol.scalerCode;
	
	if self.allScalerCodes.size &lt;= 1 then
		self.scalerCode		:= _bol.scalerCode;
	endif;
	self.ticketedAll		:= _bol.ticketedAll;
	self.weighbridge		:= _bol.weighbridge;
	self.isFSC				:= _bol.isFSC;	//CCMS JML 1105, PAR 21535 Nov 2009
	
	self.setActualPieceCountError( _bol.driversPieceCount);	//#23894 21/10/2010


	foreach intTicketSeq in _bol.allTicketSequences do
		pxyTicketSeq := intTicketSeq.cloneSelf(true);
		self.allTicketSequences.add(pxyTicketSeq);
	endforeach;

/*	
	foreach pxySeq in self.allTicketSequences do
		if (not _bol.allTicketSequences.includes(pxySeq)) then
			pxySeq.erase(NORMAL_ERASE);
		endif;
	endforeach;

	foreach pxySeq in _bol.allTicketSequences do
		if (not self.allTicketSequences.includes(pxySeq)) then
			self.allTicketSequences.add(pxySeq);
		endif;
	endforeach;
*/
end;</source>
        <Parameter name="_bol" type="CMIF_BOLIn"/>
    </JadeMethod>
