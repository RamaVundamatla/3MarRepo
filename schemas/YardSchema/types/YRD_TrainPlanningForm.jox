    <JadeMethod name="showRakeRailArea" id="ca937e49-2f99-4f8c-ab36-74ca6fca13d4">
        <updating/>
        <source>showRakeRailArea(_railArea : CM_Rail; _sdf : CMUI_ScrollableDrawingFrame input) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:     
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	lRailLine	: CM_RailLine;
begin
	if _railArea = null then
		return;
	endif;
	
	foreach lRailLine in _railArea.allRailLines do
		showRakeRailLine(lRailLine, _sdf);
	endforeach;
		
epilog

end;</source>
        <Parameter name="_railArea" type="CM_Rail"/>
        <Parameter name="_sdf" type="CMUI_ScrollableDrawingFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showRakeRailLine" id="1039cd57-c378-4265-a542-44e8ae7a1ed1">
        <updating/>
        <source>showRakeRailLine(pRailLine : CM_RailLine; _sdf : CMUI_ScrollableDrawingFrame input) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:     
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	lWagon	: CM_Wagon;
	maxWagons,
	numWagons,
	lineIdx,
	maxStackHeight,
	idx		: Integer;
begin

	if pRailLine = null then
		return;
	endif;
	
	lineIdx := pRailLine.myRailArea.allRailLines.indexOf(pRailLine);
	numWagons := pRailLine.allWagons.size;	
	pRailLine.getMaxStackHeight(maxStackHeight);
	maxWagons := pRailLine.maximumWagons;
	
	foreach idx in 1 to maxWagons do
		if idx &lt;= numWagons then
			lWagon := pRailLine.allWagons[idx];
		else
			lWagon := null;
		endif;
		self.showRakeWagon(lineIdx, idx, lWagon, null, pRailLine, maxStackHeight, maxWagons, _sdf);
	endforeach;

end;</source>
        <Parameter name="pRailLine" type="CM_RailLine"/>
        <Parameter name="_sdf" type="CMUI_ScrollableDrawingFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showRakeWagon" id="4bb2e810-a62a-4b52-9deb-8c68e7ebcbb2">
        <updating/>
        <source>showRakeWagon(pRow, pCol : Integer; pWagon : CM_Wagon; pTrain : CM_Train; pRailLine : CM_RailLine; 
				_maxStackHeight : Integer; _maxWagons : Integer; _sdf : CMUI_ScrollableDrawingFrame input) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:     
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------

vars
	aWagonArea	: YRD_WagonArea;
	wagonFrame	: CMUI_GridAreaFrame;
	col			: Integer;
	showUnconfirmed : Boolean;
	colourCoding : Integer;
begin

	if pWagon &lt;&gt; null and not self.allWagons.includes(pWagon) then
		self.allWagons.add(pWagon);
	endif;

	create aWagonArea transient;

	if self.flipHorizontal then
		aWagonArea.setFlips( true, false );
		col := _maxWagons + 1 - pCol;
	else
		col := pCol;
	endif;

	showUnconfirmed := (pRailLine = null);
	
	aWagonArea.setForCreate(pWagon, self.outwardsTrain, pTrain, pRailLine, self.myFilterTrain, pRow, col,
							self.clrWagon.backColor,
							_sdf.myHLabels.backColor,
							self.clrLocation.backColor,
							_maxStackHeight, showUnconfirmed, false,
							_sdf.myDrawingAttrController);
	
	self.maxWagonFrames := maxWagonFrames + 1;
	wagonFrame := frmGridArea.loadControl(maxWagonFrames).CMUI_GridAreaFrame;
	wagonFrame.parent := _sdf;
	wagonFrame.ignoreSkin := true;
	wagonFrame.visible := true;

	_sdf.addGridAreaAndFrame(aWagonArea, wagonFrame);
	wagonFrame.doAutoScrolling := false;
	aWagonArea.updatePictures();
	
end;</source>
        <Parameter name="pRow" type="Integer"/>
        <Parameter name="pCol" type="Integer"/>
        <Parameter name="pWagon" type="CM_Wagon"/>
        <Parameter name="pTrain" type="CM_Train"/>
        <Parameter name="pRailLine" type="CM_RailLine"/>
        <Parameter name="_maxStackHeight" type="Integer"/>
        <Parameter name="_maxWagons" type="Integer"/>
        <Parameter name="_sdf" type="CMUI_ScrollableDrawingFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showTrain" id="c6375086-2c31-4a93-af6e-af9a307b0638">
        <updating/>
        <source>showTrain( _train : CM_Train; _maxWagons : Integer; _sdf : CMUI_ScrollableDrawingFrame input) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:     Show wagons for give train
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	lWagon	: CM_Wagon;
	lineIdx,
	maxStackHeight,
	idx		: Integer;
begin

	if _train = null then
		return;
	endif;
	
	lineIdx := self.allTrains.indexOf(_train);

	if lineIdx = 0 then
		return;
	endif;
	
	if outwardsTrain then
		//  Outwards train
		foreach lWagon in _train.allWagonsByOrderOutward do
			maxStackHeight := maxStackHeight.max(lWagon.myWagonClass.maxNumInStack);
		endforeach;
		foreach lWagon in _train.allWagonsByOrderOutward do
			idx := idx + 1;
			self.showRakeWagon(lineIdx, idx, lWagon, _train, null, maxStackHeight, _maxWagons, _sdf);
		endforeach;
	else
		//  Inwards train
		foreach lWagon in _train.allWagonsByOrderInward do
			maxStackHeight := maxStackHeight.max(lWagon.myWagonClass.maxNumInStack);
		endforeach;
		foreach lWagon in _train.allWagonsByOrderInward do
			idx := idx + 1;
			self.showRakeWagon(lineIdx, idx, lWagon, _train, null, maxStackHeight, _maxWagons, _sdf);
		endforeach;
	endif;
	
	while idx &lt; _maxWagons do
		idx := idx + 1;
		self.showRakeWagon(lineIdx, idx, null, _train, null, maxStackHeight, _maxWagons, _sdf);
	endwhile;

end;</source>
        <Parameter name="_train" type="CM_Train"/>
        <Parameter name="_maxWagons" type="Integer"/>
        <Parameter name="_sdf" type="CMUI_ScrollableDrawingFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showTrainQueryContext" id="2da65546-83d7-47c6-b9fa-43aa9844a0f1">
        <updating/>
        <source>showTrainQueryContext(cntrl : Table input; conwin : Window input; mouse : Boolean; x : Integer; y : Integer) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     03 June 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	xLeft 	: Real;
	yTop	: Real;
	
begin
	xLeft := x;
	yTop := y;
	
	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);
	
	self.popupMenu(self.mnuTrainQuery, xLeft.Integer, yTop.Integer);
	
	return false;

epilog

end;</source>
