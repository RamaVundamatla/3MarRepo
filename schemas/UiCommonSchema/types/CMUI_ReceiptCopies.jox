    <JadeMethod name="btnCancel_click" id="abf723b9-2788-4079-b156-e14d3cf9a236">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;

vars

begin
	copies := 0;

	unloadForm;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnPrint_click" id="02c66d2e-68c9-4bd8-b547-4f4c8a4e3264">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnPrint_click(btn: Button input) updating;

vars

begin
	self.modalResult := MsgBox_Return_OK;
	self.printPreview := chkPrintPreview.value;
	unloadForm;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbCopies_change" id="db0614a3-bacb-45e4-b004-671da5c63a69">
        <controlMethod name="ComboBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCopies_change(combobox: ComboBox input) updating;

vars

begin
	self.copies := combobox.text.Integer;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbCopies_lostFocus" id="063c0d68-6fd5-4cf4-b09d-84cc954e3f99">
        <controlMethod name="CMUI_ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
