    </JadeMethod>
    <JadeMethod name="disableAllYA" id="6ae574c9-56ee-4609-9eba-98947f16c928">
        <source>disableAllYA(_disable: Boolean);
// Date: 20 November 2008	
// Author: cnwdw1	
// Description: Disable all YA in the current terminal
vars
	ya: CM_YardAllocation;
begin

	// Quick and nasty disabling of all YA
	///if not process.isInTransactionState then
		beginTransaction;
	///endif;
	foreach ya in self.getTerminal.allYardAllocations do
		ya.setPropertyValue(CM_YardAllocation::isDisabled.name, _disable);
