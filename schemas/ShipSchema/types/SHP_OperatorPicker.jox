<GUIClass name="SHP_OperatorPicker" id="275b0a1d-848e-4b28-b4fa-22c7207c15bc">
    <superclass name="CMUI_Modal"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="allOperators" id="38eb4def-33fb-4951-bc0a-c61058c011b9">
        <memberTypeInverse/>
        <type name="CM_OperatorSet"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="cmbOperator" id="d8e73e5b-2bb4-479a-bc39-58dd1ed0a6b5">
        <embedded/>
        <type name="CMUI_ComboOperator"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblInstructions" id="cc747c0d-16ac-4c89-bd07-c161fa26c82b">
        <embedded/>
        <type name="CMUI_Label"/>
    </ImplicitInverseRef>
    <JadeMethod name="load" id="083def1e-84fa-4074-bcd7-f933e976504d">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

/*
Date		Who		Reason
27 May 2009	cnwar2	Initial creation

*/
vars

begin
	self.resize();
	self.setupForm();
	self.centreWindow();
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="20b15505-8501-47d6-b689-1a052ed156c2">
        <updating/>
        <source>setupForm() updating;

/*
Date		Who		Reason
23 Sep 2009	cnwar2	#20674
*/
vars

begin
	inheritMethod();
	
	self.cmbOperator.clear();
	self.cmbOperator.listCollection(self.allOperators, false, 0);
	self.cmbOperator.setInitialised(true);
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="6826eca2-97d3-4fb1-97a7-7a57b6ac3963">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 August 2018 15:38:15.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022914, locale);
	lblInstructions.translateCaption(Xlat_0011536, locale);
end;</source>
    </JadeMethod>
</GUIClass>
