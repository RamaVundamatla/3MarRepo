    <JadeMethod name="isLoadedToOps" id="c8e3ff3f-f70c-4af8-9236-21f370a7f061">
        <source>isLoadedToOps() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 September 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	job : CM_VoyageJob;
begin
	if self.mySlotRequestDischarge &lt;&gt; null then
		job :=  self.mySlotRequestDischarge.myJob.CM_VoyageJob;
	elseif self.mySlotRequestLoad &lt;&gt; null then
		job :=  self.mySlotRequestLoad.myJob.CM_VoyageJob;
	endif;
	
	if job &lt;&gt; null then
		return job.isLoadedToOperations;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
