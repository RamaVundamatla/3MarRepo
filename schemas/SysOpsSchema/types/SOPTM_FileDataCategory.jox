    <JadeMethod name="doSave" id="22ca14d0-ad38-498c-8fff-e70fcc2b02a0">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30/11/2022  navmv20 TFS CR 55299 Task 55519: UI - New File Category Maintenance UI
24/01/2023 navvt20 TFS CR 56204 Task 56206: UI - File Category Maintenance

*/


vars
	theForm 				: SOP_TableMaintForm;
	tbl						: CM_EntryTable;
	code,
	description			    : String;
	categoryContext			: Integer;
	pxyFileCategory,
	realFileCategory		: CM_FileDataCategory;
	terminal				: CM_Terminal;
	isExternal				: Boolean; // 24 Jan 2023 navvt20 TFS 56206
begin
	theForm := self.myForm;
	tbl := theForm.tblInput1;
	
	code := tbl.getValueByName(ETRow_Code).String;
	description := tbl.getValueByName(ETRow_Description).String;
	categoryContext := app.getContextTextStrToInt(tbl.getValueByName(ETRow_Context).String);
	terminal	    := self.myForm.myTerminal;
	isExternal		:= tbl.getValueByName(ETRow_External).Boolean; // 24 Jan 2023 navvt20 TFS 56206
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_FileDataCategory transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object null for update');
			return false;
		endif;
	endif;
	
	pxyFileCategory := theForm.myProxyObject.CM_FileDataCategory;
	//pxyFileCategory.setProxy(categoryContext,code,  description, app.myRoot); // ### TFS CR 55299 TASK 55985 28DEC2022 NAVAB1 pass in root // 24 Jan 2023 navvt20 TFS 56206
	pxyFileCategory.setProxy(categoryContext,code,  description, app.myRoot,isExternal); // ### TFS CR 55299 TASK 55985 28DEC2022 NAVAB1 pass in root // 24 Jan 2023 navvt20 TFS 56206
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateFileCategory(pxyFileCategory, realFileCategory, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateFileCategory(pxyFileCategory, app.myPassport);
	endif;
	
	return app.myPassport.trxCompletedOK();
epilog
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
