<Class name="CM_DataDumpTransSpecClass" id="cb22cb6e-f36d-4cf0-990d-9e63aae7cabf">
    <superclass name="CM_DataDumpTransient"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>An instance is created for each specific (real) sub-class of
CM_DataDumpClass in the given extract.</text>
    <DbClassMap file="cmtrans"/>
    <ExplicitInverseRef name="allTransSpecFeatures" id="92d77f04-70a3-4260-8176-b8e849c0d9aa">
        <kind>parent</kind>
        <updateMode>manual</updateMode>
        <type name="CM_DataDumpTransFeatureArray"/>
        <access>readonly</access>
        <Inverse name="CM_DataDumpTransSpecFeature::myTransSpecClass"/>
    </ExplicitInverseRef>
    <PrimAttribute name="isInitialisedWithFeatures" id="06a46fda-899c-479b-81a1-7d2ac94b592a">
        <embedded/>
        <type name="Boolean"/>
        <access>protected</access>
    </PrimAttribute>
    <ImplicitInverseRef name="myClass" id="57b8f6f0-3f19-4b42-acdb-e51babb86d8b">
        <embedded/>
        <type name="Class"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myExtractClass" id="4cf9fac9-06f6-4eb3-95e8-77dab3eab5ff">
        <embedded/>
        <type name="CM_DataDumpExtractClass"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ExplicitInverseRef name="myTransExtractClass" id="a0c074e1-f199-47ef-8ef6-ced0523a2e0c">
        <kind>child</kind>
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="CM_DataDumpTransExtractClass"/>
        <access>readonly</access>
        <Inverse name="CM_DataDumpTransExtractClass::allTransSpecClasses"/>
    </ExplicitInverseRef>
    <JadeMethod name="allTransSpecFeatures" id="1aa712f3-7c69-427e-a8a4-cabe94405030">
        <methodInvocation>mapping</methodInvocation>
        <source>allTransSpecFeatures(set: Boolean; _value: CM_DataDumpTransFeatureArray io) mapping;
// ---------------------------------------------------------------------------
// Created:     08 July 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	if not set then
		if not self.isInitialisedWithFeatures then
			app.raiseUnexpectedProgramError(self.getName, method.name,
					"Attempt to access allTransSpecFeature without calling " &amp;
					"initialiseWithFeatures() first");
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_DataDumpTransFeatureArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="createFeature" id="960790c6-ba4c-491a-8034-8a9e75d32842">
        <updating/>
        <source>createFeature(_dataDumpFeature: CM_DataDumpFeature; _realFeature: Feature;
		_subClassFeatureType: Type) : CM_DataDumpTransSpecFeature updating, protected;
// ---------------------------------------------------------------------------
// Created:     03 June 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	newFeature : CM_DataDumpTransSpecFeature;

begin
	create newFeature transient;
	newFeature.setForCreate(_dataDumpFeature, _realFeature, _subClassFeatureType);
	self.allTransSpecFeatures.add(newFeature);
	
	return newFeature;
end;</source>
        <access>protected</access>
        <Parameter name="_dataDumpFeature" type="CM_DataDumpFeature"/>
        <Parameter name="_realFeature" type="Feature"/>
        <Parameter name="_subClassFeatureType" type="Type"/>
        <ReturnType type="CM_DataDumpTransSpecFeature"/>
    </JadeMethod>
    <JadeMethod name="getClassAlias" id="c07fea1f-05cf-4593-8186-b3b19a9ca7f5">
        <source>getClassAlias() : String;
// ---------------------------------------------------------------------------
// Created:     04 June 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	return self.myTransExtractClass.myDataDumpClass.classAlias;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getClassId" id="e232df31-8274-46ff-9fa2-66023205c9ac">
        <source>getClassId() : String;
// ---------------------------------------------------------------------------
// Created:     24 July 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	return self.getClassAlias &amp; " (" &amp; self.myClass.name &amp; ")";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtractFromDateTime" id="ed5d15ec-98c5-4c66-b832-191d239439ce">
        <source>getExtractFromDateTime() : TimeStamp;
// ---------------------------------------------------------------------------
// Created:     22 July 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	return self.myExtractClass.extractedUpToDateTime;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getExtractSequence" id="d9d2b578-faee-4d98-9862-2088de592ca6">
        <source>getExtractSequence() : Integer;
// ---------------------------------------------------------------------------
// Created:     22 July 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	return self.myTransExtractClass.getExtractSequence;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initialiseWithFeatures" id="bd414edb-9704-4bc3-a730-07161a0abfa4">
        <updating/>
        <source>initialiseWithFeatures() updating;
// ---------------------------------------------------------------------------
// Created:     01 July 2003 by cnwsb1
//
// Purpose:		Sets the specific features for the given real class.  Call
//				this before first accessing the allTransFeatures.  The delayed
//				initialisation is done for performance reasons - as you
//				do not need to initialise the feature list for classes that
//				have no activity, or only have deletes.
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
22 May 2009	cnwkpd1	Change beginload/endLoad to app.cmsBeginLoad to prevent 1053
					exceptions

*/

vars
	dataDumpClass : CM_DataDumpClass;
	dataDumpFeature : CM_DataDumpFeature;
	realFeature : Feature;
	subClassFeatureType : Type;
	localLoadState : Boolean;

begin
	if self.isInitialisedWithFeatures then
		// There is no harm calling this method more than once, but
		// we do not want to initialise the features more than once
		// (for performance reasons).
		return;
	endif;
	
	self.isInitialisedWithFeatures := true;
	//
	//  Include a beginLoad just around this code - handles lots of meta data 
	//
	app.cmsBeginLoad(localLoadState);
	
	dataDumpClass := self.myExtractClass.myDataDumpClass;
	
	// in here get collection of methods and properties from each class
	// and pass through to method below
	// Class::getMethods()
	//
	if self.myExtractClass.myDataDumpExtractDef.isFormatSQLNative = false then
	
		foreach dataDumpFeature in self.myExtractClass.allDataDumpFeatures do
			realFeature := dataDumpClass.getFeatureForClass(self.myClass, dataDumpFeature.featureName);
			subClassFeatureType := dataDumpFeature.mySubClassFeatureType;
			self.createFeature(dataDumpFeature, realFeature, subClassFeatureType);
		endforeach;
	endif;
	
epilog
	app.cmsEndLoad(localLoadState);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="44b3f486-8b78-46ff-8bb4-346dd8032247">
        <updating/>
        <source>setForCreate(_extractClass: CM_DataDumpExtractClass; _realClass: Class;
		_initialiseOnCreate: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     03 June 2003 by cnwsb1
//
// Important:	You must call initialiseWithFeatures() before accessing
//				allTransFeatures.
// ---------------------------------------------------------------------------
begin
	self.myClass := _realClass;
	self.myExtractClass := _extractClass;
	
	if _initialiseOnCreate then
		// For performance reasons you may want to initialise all Features
		// in one go, or you may want to initialise them per class used.
		self.initialiseWithFeatures();
	endif;
end;</source>
        <Parameter name="_extractClass" type="CM_DataDumpExtractClass"/>
        <Parameter name="_realClass" type="Class"/>
        <Parameter name="_initialiseOnCreate" type="Boolean"/>
    </JadeMethod>
</Class>
