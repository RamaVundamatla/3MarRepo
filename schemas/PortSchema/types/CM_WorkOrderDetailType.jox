    <JadeMethod name="validateForCreate" id="394586c5-2b8d-4372-b2d2-c99e48b60417">
        <source>validateForCreate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Sep 2021 navma1 ChangeRequest 51925: SAL - Web Portal Cargo Work Orders

*/

vars

begin
	if app.myRoot.allWorkOrderTaskTypes[type,id] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.type.String, null, null);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="0375c4ff-883b-4086-a5b1-758d1969b93c">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Sep 2021 navma1 ChangeRequest 51925: SAL - Web Portal Cargo Work Orders

*/

vars
	woDetailtType 	: CM_WorkOrderDetailType;
	realDetailType	: CM_WorkOrderDetailType;	
begin
	
	if self.isTransient then
		realDetailType := self.pxyGetRealObject;
	else
		realDetailType := self;
	endif;
	
	if self.description = null then
		app.raiseCMException(Input_required_field_Desc, null, null);
	endif;
	
	foreach woDetailtType in app.myRoot.allWorkOrderTaskTypes do	
		if realDetailType &lt;&gt; woDetailtType then
			if woDetailtType.description.toUpper = self.description.toUpper then
				app.raiseCMException1(VB_DUPLICATED_ITEM, self.description, null, null);	
				return;		
			endif;
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
</Class>
