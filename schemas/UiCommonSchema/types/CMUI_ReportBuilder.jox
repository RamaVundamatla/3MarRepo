        <updating/>
        <source>lstTblUsers_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;
/*
----------   ----------  --------------------------------------------------
Created:	23 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	selected		: Boolean;
begin
	selected := table.CMUI_ListTable.allSelectedObjects.includes(obj);
	// re-using this for cranes as well 
	if obj.isKindOf(CM_User) then
		return self.myAssistant.displayEntryUsersList(obj.CM_User, selected);
	elseif obj.isKindOf(CM_Crane) then
		return self.myAssistant.displayEntryCranesList(obj.CM_Crane, selected);
	endif;
end;
