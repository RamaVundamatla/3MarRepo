<Class name="CM_VesselSectionVoyage" id="3483fc3b-7ad5-4d17-95a7-35de7daea7d1">
    <superclass name="CM_VesselSection"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="vesselStructures"/>
    <ExplicitInverseRef name="myVoyageStructuralElement" id="ef7fbf25-d98d-4556-be90-bf896bfafea5">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <embedded/>
        <type name="CM_VoyageStructuralElements"/>
        <access>readonly</access>
        <Inverse name="CM_VoyageStructuralElements::allSections"/>
        <Inverse name="CM_VoyageStructuralElements::allSectionsByPosition"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myVoyageStructure" id="e7dcc5ae-2cb1-435e-8d62-4884816a06b4">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
