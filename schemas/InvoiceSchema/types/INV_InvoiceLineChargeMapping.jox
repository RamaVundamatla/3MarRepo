	endforeach;
	
	
	mapTable.row := 1;
	mapTable.column := 1;

	self.setEnableObjects();
	mapTable.accessColumn(2).width := 100;
	
epilog
	app.cmsEndLoad(ls);
	delete pd;
end;</source>
