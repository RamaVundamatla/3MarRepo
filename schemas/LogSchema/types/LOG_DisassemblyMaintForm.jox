    <JadeMethod name="checkForUniqueId" id="2074a70f-b1bf-4eb0-9d3e-479b222d9b1c">
        <source>checkForUniqueId(_id : String; _isNew : Boolean) : Boolean protected;

vars

	newLog 	: CMIF_LogRegrade;
	count 	: Integer;

begin

	foreach newLog in self.allNewLogs do
		if newLog.id = _id then
			if _isNew then
				app.raiseCMException1(UniqueIdRequired, 'New ID', null, null);
				return false;
			else
				if newLog &lt;&gt; self.mySelectedNewLog then
					app.raiseCMException1(UniqueIdRequired, 'New ID', null, null);
					return false;
				endif;
			endif;
		endif;
	endforeach;
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
        <Parameter name="_isNew" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
