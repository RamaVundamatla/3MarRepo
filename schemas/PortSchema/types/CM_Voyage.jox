    <JadeMethod name="getStevedoreForOperator" id="df7f7e85-63c8-4c73-97fd-3b98c4272249">
        <source>getStevedoreForOperator(_myOperator : CM_Operator) : String;

// cnwdvb1 21 November 2002 

vars

	voyageOperator	: CM_VoyageOperator;
	iter			: Iterator;

begin
	
	if _myOperator = null then
		return null;
	endif;
	iter := self.allVoyageIOperators.createIterator;
	while iter.next(voyageOperator) do
		if voyageOperator.myOperator = _myOperator then
			return voyageOperator.stevedoreCode1;
		endif;
	endwhile;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_myOperator" type="CM_Operator"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStockOrderHeaderObject" id="a62b3630-db96-4265-b429-d47d3813681e">
        <source>getStockOrderHeaderObject(_operator : CM_Operator; _orderNo : String): CM_StockOrderHeader;
//--------------------------------------------------------------
//Created: 12 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	hdr	: CM_StockOrderHeader;

begin

	// for logs the orderNo is unknown so use GEQ and test afterwards
	// that the operator is correct
	hdr := self.allOrdersByOperatorOrderNo.getAtKeyGeq(_operator, _orderNo);
	if hdr &lt;&gt; null and hdr.myOperator &lt;&gt; _operator then
		hdr := null;
	endif;
	
	return hdr;
	

end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_orderNo" type="String"/>
        <ReturnType type="CM_StockOrderHeader"/>
    </JadeMethod>
    <JadeMethod name="getTITransactionForTIId" id="0d08a88c-f51e-4912-93b5-3732c3bb23aa">
        <source>getTITransactionForTIId(_type : Integer; _id : String) : CM_TITransaction;
/*

Date		Who		Reason
10 October 2013	cnwer1	Initial creation PAR 32776

*/

vars
	iter : Iterator;
	tiTransaction : CM_TITransaction;
begin

	iter:=self.allTITransactionsByTypeDT.createIterator;
	
	self.allTITransactionsByTypeDT.startKeyGeq(_type,null,iter);
	while iter.next(tiTransaction) do
		if tiTransaction.type &lt;&gt; _type then
			return null;
		endif;
		if tiTransaction.myTrackedItem = null then
			return null;
		endif;
		if tiTransaction.myTrackedItem.id = _id then
			return tiTransaction;
		endif;
			
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_id" type="String"/>
        <ReturnType type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="getTITxns" id="96374709-9675-416d-a8a2-52d315cb3696">
        <source>getTITxns(_type : Integer; 
			_startDate, _endDate : TimeStamp;
			_lookupByType : Boolean; //false = lookup by DT,Type; true by Type,DT
			_callBackMethod : String; 
			_callBackObject : Object;
			_col : Collection input);
// ---------------------------------------------------------------------------
// Created:     19 July 2004	cnwth2
//
// Purpose:     
//	 14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  		 
// ----------   ----------  --------------------------------------------------
vars
	iter			: Iterator;
	trans			: CM_TITransaction;
	keyTimeStamp	: TimeStamp;
	keyType			: Integer;
	breakOut		: Boolean;
	passport		: CM_Passport;
	dictByTypeDT	: CM_TITransactionByTypeDateDict;
	dictByDTType	: CM_TITransactionByDateTypeDict;
	filterRpt		: CMQF_FilterReports;
	
begin
	passport := app.myPassport;
	if _col = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Collection passed is null');
		return;
	endif;
	
	if _lookupByType then
		dictByTypeDT := self.allTITransactionsByTypeDT;
		iter := dictByTypeDT.createIterator();
		dictByTypeDT.startKeyGeq(_type, _startDate, iter);
	else
		dictByDTType := self.allTITransactionsByDTType;
		iter := dictByDTType.createIterator();
		dictByDTType.startKeyGeq(_startDate, _type, iter);
	endif;
	
	while iter.next(trans) do
		if _lookupByType then
			iter.getCurrentKeys(keyType,keyTimeStamp); //MTN-35226
		else
			iter.getCurrentKeys(keyTimeStamp,keyType); //MTN-35226
		endif;
			
		if _type &lt;&gt; null and keyType &lt;&gt; _type then
			break;
		endif;
		
		if keyTimeStamp &gt; _endDate then
			break;
		endif;
		
		if breakOut then  
			break;
		endif;
		
		if _callBackMethod &lt;&gt; null and _callBackObject &lt;&gt; null then
			if (not _callBackObject.sendMsgWithIOParamsJMT(_callBackMethod, trans, passport, breakOut).Boolean) then
				continue;
			endif;
		endif;
		
		if _callBackObject &lt;&gt; null and _callBackObject.isKindOf(CMQF_FilterReports) then
			filterRpt := _callBackObject.CMQF_FilterReports;
			filterRpt.checkStatusIncludesObject(null, passport, breakOut);
		endif;
		
		if (not _col.includes(trans)) then
			_col.add(trans);
		endif;
	endwhile;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_startDate" type="TimeStamp"/>
        <Parameter name="_endDate" type="TimeStamp"/>
        <Parameter name="_lookupByType" type="Boolean"/>
        <Parameter name="_callBackMethod" type="String"/>
        <Parameter name="_callBackObject" type="Object"/>
        <Parameter name="_col" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTITxnsByTypeFromTIs" id="e3ce2347-b1d4-4a6e-9d49-710c65d7e232">
        <source>getTITxnsByTypeFromTIs(	_type : Integer; 
						_searchOnShip,
						_searchOnsite,
						_searchNotified,
						_searchOffsite : Boolean;
						_startDate, 
						_endDate : TimeStamp; 
						_callBackMethod : String; 
						_callBackObject : Object; 
						_collection : Collection input);
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 26 November 2008
// Implemented version: CCMS1765 PAR18532
//	Get the transactions of a type from all tis that are included in the ti collections of the voyage.  Allows for reporting on ti transactions
//  by voyage, similar to methods on terminal. Note: Different to searching for transactions in the voyage transaction
//  collection as they only record ship related transactions from tis.
//----------------------------------------------------------------------
vars
	passport		: CM_Passport;
	ti 				: CM_TrackedItem;
	tiTxnCollection : ObjectSet;
begin
	passport := app.myPassport;
	if _collection = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Collection (_collection) item is null');
	endif;
	
	create tiTxnCollection transient;
	if _searchOnShip then
		foreach ti in self.allOnshipTIsByIdCargoType discreteLock where ti.allTransactions.isNotEmpty() do 
			ti.getTITxnsByTypeDate(_type, _startDate, _endDate, _callBackMethod, _callBackObject, tiTxnCollection);
		endforeach;
	endif;
	
	if _searchOnsite then
		foreach ti in self.allOnsiteTIsByIdCargoType discreteLock where ti.allTransactions.isNotEmpty() do
			ti.getTITxnsByTypeDate(_type, _startDate, _endDate, _callBackMethod, _callBackObject, tiTxnCollection);
		endforeach;
	endif;
	
	if _searchNotified then
		foreach ti in self.allNotifiedTIsByIdCargoType discreteLock where ti.allTransactions.isNotEmpty() do
			ti.getTITxnsByTypeDate(_type, _startDate, _endDate, _callBackMethod, _callBackObject, tiTxnCollection);
		endforeach;
	endif;
	
	if _searchOffsite then
		foreach ti in self.allOffsiteTIsByIdCargoType discreteLock where ti.allTransactions.isNotEmpty() do
			ti.getTITxnsByTypeDate(_type, _startDate, _endDate, _callBackMethod, _callBackObject, tiTxnCollection);
		endforeach;
	endif;

	tiTxnCollection.copy(_collection);
epilog
	delete tiTxnCollection;
end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_searchOnShip" type="Boolean"/>
        <Parameter name="_searchOnsite" type="Boolean"/>
        <Parameter name="_searchNotified" type="Boolean"/>
        <Parameter name="_searchOffsite" type="Boolean"/>
        <Parameter name="_startDate" type="TimeStamp"/>
        <Parameter name="_endDate" type="TimeStamp"/>
        <Parameter name="_callBackMethod" type="String"/>
        <Parameter name="_callBackObject" type="Object"/>
        <Parameter name="_collection" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTIsImportVoyageAllocation" id="e8c167b2-a2b9-450d-8d85-28f4a1b716e7">
        <source>getTIsImportVoyageAllocation(_ti : CM_TrackedItem; _voyageAllocations : CM_VoyAllocationByPriority) : CM_VoyageAllocation;
/*

Date		    Who			Reason
25 January 2011	cnwas3	  par 26773

*/

vars
	voyAlloc : CM_VoyageAllocation;
	cmifAutoPlan : CMIF_YAAutoPlan;
begin

	create cmifAutoPlan as CMIF_YAAutoPlanNormal transient;
	cmifAutoPlan.attachTI(_ti);

	foreach voyAlloc in _voyageAllocations discreteLock do
		if not voyAlloc.isImportAllocation() then 
			continue;
		endif;
		if voyAlloc.doesTIMatchMe(cmifAutoPlan,true) then
			return voyAlloc;
		endif;
	endforeach;
	
	return null;

epilog
	delete cmifAutoPlan;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_voyageAllocations" type="CM_VoyAllocationByPriority"/>
        <ReturnType type="CM_VoyageAllocation"/>
    </JadeMethod>
    <JadeMethod name="getTIsVoyageAllocation" id="40faae1e-9ec0-4eba-9f94-c5fb9a9a0780">
        <source>getTIsVoyageAllocation(_ti : CM_TrackedItem; _voyageAllocations : CM_VoyAllocationByPriority) : CM_VoyageAllocation;
// ---------------------------------------------------------------------------
// Created:     28 January 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 09 Jan 2013		cnwkpd1			PAR #30964 - Performance enhancements for Load Colour Coding -
//									add hard-coded filtering by Discharge Port
// ---------------------------------------------------------------------------

vars
	voyAlloc : CM_VoyageAllocation;
	cmifAutoPlan : CMIF_YAAutoPlan;
	tiDischargePort		: String;
	allocDischargePort	: CM_Port;	
	
begin

	create cmifAutoPlan as CMIF_YAAutoPlanNormal transient;
	cmifAutoPlan.attachTI(_ti);
	
	tiDischargePort := _ti.dischargePort;

	foreach voyAlloc in _voyageAllocations reversed, discreteLock  do // PAR 34184 add 'reversed'
		if voyAlloc.isImportAllocation() then // PAR 25833 - only interested in exports and tranships	
			continue;
		endif;
		
		// PAR #30964 - Hard-coded filter by Discharge Port, to exclude unnecessary criteria checks
		allocDischargePort := voyAlloc.getDischargePort();
		if allocDischargePort &lt;&gt; null and allocDischargePort.code &lt;&gt; tiDischargePort then
			continue;
		endif;
		
		if voyAlloc.doesTIMatchMe(cmifAutoPlan,true) then
			return voyAlloc;
		endif;
	endforeach;
	
	return null;

epilog
	delete cmifAutoPlan;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_voyageAllocations" type="CM_VoyAllocationByPriority"/>
        <ReturnType type="CM_VoyageAllocation"/>
    </JadeMethod>
    <JadeMethod name="getTimeAtAllBerths" id="10b4df0d-6a3b-4188-88d6-83eed4969388">
        <source>getTimeAtAllBerths() : Real;
/*
Purpose:			Use in Report Writer reports - do not delete

Parameters:			

Return Value:		

Date		Who		Reason
04/09/2012	cnwdap1	Initial creation PAR #30146
*/
vars
	movement 			: HMS_VoyageMovement;
	startBerthTime		: TimeStamp;
	finishBerthTime 	: TimeStamp;
	timeSpent 			: TimeStampInterval;

begin
	startBerthTime := null;
	finishBerthTime := null;
	
	foreach movement in self.myHMSVoyageData.allVoyageMovements do
		if movement.isMovementTypeShift and movement.myPreviousMovement.isMovementTypeArrival then
			startBerthTime := movement.occursOnDTNEW;
		elseif movement.isMovementTypeArrival and not movement.getMyBerth.myWharf.isLogicalWharf then
			startBerthTime := movement.occursOnDTNEW;
		elseif movement.isMovementTypeDeparture then
			finishBerthTime := movement.occursOnDTNEW;
		endif;
	endforeach;
	
	if startBerthTime &lt;&gt; null and finishBerthTime &lt;&gt; null then
		timeSpent := finishBerthTime - startBerthTime;
		return timeSpent.asMinutes;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getTimeAtAnchorage" id="b801ebc1-153e-4586-a1e8-894e5d0c5f08">
        <source>getTimeAtAnchorage() : Real;
/*
Purpose:			Used in Report Writer reports - do not delete

Parameters:			

Return Value:		Number of minutes spent at Anchorage

Date		Who		Reason
04/09/2012	cnwdap1	Initial creation PAR #30146
*/
vars
	movement 			: HMS_VoyageMovement;
	startAtAnchorage	: TimeStamp;
	finishAtAnchorage 	: TimeStamp;
	timeSpent 			: TimeStampInterval;

begin
	startAtAnchorage := null;
	finishAtAnchorage := null;
	
	foreach movement in self.myHMSVoyageData.allVoyageMovements do
		if movement.isMovementTypeArrival and movement.getMyBerthPrevious = null then
			startAtAnchorage := movement.occursOnDTNEW;
		elseif movement.isMovementTypeShift and movement.myPreviousMovement.isMovementTypeArrival then
			finishAtAnchorage := movement.occursOnDTNEW;
		endif;
	endforeach;
	
	if startAtAnchorage &lt;&gt; null and finishAtAnchorage &lt;&gt; null then
		timeSpent := finishAtAnchorage - startAtAnchorage;
		return timeSpent.asMinutes;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getTimePeriod" id="5ce8c978-f94b-48e8-a8c1-dc3ee61f3973">
        <source>getTimePeriod():String;

vars

begin
	return self.systemToLocalTime(self.arrivedDT).shortCurrentLocaleFormat() &amp; ' Departing ' &amp; self.systemToLocalTime(self.departedDT).shortCurrentLocaleFormat();	// 25/5/16	cnwmp6	TFS 488 - Multi timezone support
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTotalDelaysOnDate" id="03b2c642-0843-4b26-8944-e718cf0df0bb">
        <source>getTotalDelaysOnDate(_date : Date; _allVoyageDelays : CM_DelayByStartDTDict io) : Real;
/*

Purpose:			Find total delays for voyage on specific day.
					Doesn't allow for overlapping delays.
Parameters:			

Return Value:		

Date		Who		Reason
19 Aug 2019	jlgsl4	TFS 45615 - ASPA - Ship Load Summary
*/

constants
	MillisecInHour = 3600000;
vars
	delay : CM_Delay;
	totalDelayHours : Real;
begin
	foreach delay in self.allDelays where _date &gt;= delay.startDT.date and _date &lt;= delay.endDT.date do
		if _allVoyageDelays.indexOf(delay) = 0 then			
			_allVoyageDelays.add(delay); // only add delay to voyage's delays if we haven't encountered it before
		endif;
		if delay.startDT.date = delay.endDT.date then // if delay was on one day only,
			totalDelayHours := delay.endDT.differenceInHoursReal(delay.startDT) + totalDelayHours; // add delay's hours
		elseif _date = delay.startDT.date then // if checking hours on start date,
			totalDelayHours := -delay.startDT.time.Real / MillisecInHour + totalDelayHours + 24; // find delay hours until end of the day
		elseif _date = delay.endDT.date then // if checking hours on finish date,
			totalDelayHours := delay.endDT.time.Real / MillisecInHour + totalDelayHours; // find delay hours until end time
		else
			totalDelayHours := totalDelayHours + 24;
		endif;
	endforeach;
	return totalDelayHours;
epilog

end;</source>
        <Parameter name="_date" type="Date"/>
        <Parameter name="_allVoyageDelays" type="CM_DelayByStartDTDict" usage="io"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getTotalPlanned" id="a9178536-202f-499c-85c7-de46ee13b086">
        <source>getTotalPlanned(_getLoad : Boolean; _includeDLR : Boolean) : Integer;
/*
Purpose:			
Date		Who		Reason
13 January 2015	cnwab1	Initial creation
*/

vars
	amount : Integer;
	tis: CM_TIArray;
	ti : CM_TrackedItem;
begin

	if self.myShipBlockStack= null then
		return 0;
	endif;
	create tis transient;
	
	if _getLoad then
		// how many are planned to the ship location
		self.myShipBlockStack.getAllPlannedTrackedItems(tis,true,false);
		amount := amount + tis.size;
	else
		// how many of the items on ship are planned off
		foreach ti in self.myShipBlockStack.allTrackedItems discreteLock  where ti.isImport   do
			if ti.myPrimaryPlannedLocation &lt;&gt; null then
				amount := amount + ti.quantity;
			endif;
		endforeach;
	endif;
	
	return amount;
epilog
	delete tis;
end;</source>
        <Parameter name="_getLoad" type="Boolean"/>
        <Parameter name="_includeDLR" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalTIs" id="a019f6e1-e7c8-4f0b-8704-b3d4712e306a">
        <source>getTotalTIs() : Integer;
/*
----------   ----------  --------------------------------------------------
Created:	01 June 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	totalTIs : Integer;
	aJS : CM_JobSheet;
begin
	foreach aJS in self.allJobSheets discreteLock do
		totalTIs := totalTIs + aJS.CM_VoyageJobSheet.allShipReceivals.size;
		totalTIs := totalTIs + aJS.CM_VoyageJobSheet.allShipReleases.size;
	endforeach;
	return totalTIs;
end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTrackedItemsAnywhere" id="11ee78f0-f410-4f21-b4c8-e468fed08d60">
