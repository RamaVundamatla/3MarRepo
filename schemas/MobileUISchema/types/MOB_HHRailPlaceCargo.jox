    <JadeMethod name="handleSelectSearchItem" id="45b52fcc-a960-46c2-bc36-da5b100bc025">
        <updating/>
        <source>handleSelectSearchItem() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

	selectedTI : CM_TrackedItem;

begin
	
	selectedTI:=self.cmbSearchItem.listObject.CM_TrackedItem;
	
	if selectedTI = null then
		self.txtIsoType.text := null;
		self.lblCargoType.caption := null;
	else
		self.txtIsoType.text := selectedTI.getISOType;
		self.lblCargoType.caption := selectedTI.cargoTypeDescr;
	endif;

epilog

end;</source>
