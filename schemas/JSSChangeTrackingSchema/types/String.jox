<PrimType name="String">
    <JadeMethod name="padZeros" id="e7666fe3-f815-41a0-a95a-53c8668840a0">
        <source>padZeros(num : Integer) : String;
//
//27 Jul 2016	cnwrs1	Par 38030 C3 Data Extract loosing updates
//
vars
    str : String;
    i : Integer;
begin

    if num &gt; length then
        i := 0;
        while i &lt; num-length do
            str := str &amp; "0";
            i := i + 1;
        endwhile;
        str := str &amp; self;
    else
        str := self[1:num];
    endif;

    return str;

end;</source>
        <Parameter name="num" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
</PrimType>
