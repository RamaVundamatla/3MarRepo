    <JadeMethod name="doOK" id="5c202ee4-dc6d-4f0e-9e8c-d4e18e5e398f">
        <updating/>
        <source>doOK() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 May 2009	cnwrd1	Initial creation

*/

vars

begin
	//cnwjo3 par 22756
	if self.myCurrentBookingRef = null then
		return;
	endif;
	
	if self.doValidateBookingForCargo() then
		self.modalResult := ModalResultOK;
		self.unloadForm();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSelectBooking" id="94a4de02-4a16-4a27-95ca-8b8ef9135062">
        <updating/>
        <source>doSelectBooking() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 May 2009	cnwrd1	Initial creation

*/

vars
	bookingRef	: CM_BookingRef;
	theRow		: Integer;
begin
	//cnwjo3 par 22756
	//you've entered a valid booking but it has no
	//voyage.  Sorry, you can't use this voyage until it has proper data
	if self.tblBookings.row &lt; 1 then
		return;
	endif;


	bookingRef := self.tblBookings.accessRow(self.tblBookings.row).itemObject.CM_BookingRef;
	
	self.myCurrentBookingRef := bookingRef;
/*
	voyage
	discharge
	destination
	*/
	
	self.txtVoyage.text := self.myCurrentBookingRef.myVoyage.code;
	self.txtDischarge.text := self.myCurrentBookingRef.dischargePort;
	self.txtDestination.text := self.myCurrentBookingRef.destinationPort;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doValidateBookingForCargo" id="25ab5696-3651-45fd-95ed-45a5220b888d">
        <source>doValidateBookingForCargo(): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 May 2009	cnwrd1	Initial creation

*/

vars
	bookingItem : CM_BookingRefItem;
	result : Integer;
	reason : String; //05/04/2024	navkc1 Bug 63509
begin
	if self.myCurrentTrackedItem &lt;&gt; null then				//+cnwml2 PAR22785
		bookingItem := self.myCurrentBookingRef.getMatchingItemForTI( self.myCurrentTrackedItem, reason);
	
		if bookingItem = null then // havnt found a booking item show a warning.
			//result :=  app.msgBox(app.getErrorString2( Error_No_Booking_Ref_Item, self.myCurrentBookingRef.bookingReference, self.myCurrentTrackedItem.id), 'No Booking Item Found', MsgBox_OK_Cancel );
			result :=  app.msgBox(app.getErrorString3( Error_No_Booking_Ref_Item, self.myCurrentBookingRef.bookingReference, self.myCurrentTrackedItem.id, reason), 'No Booking Item Found', MsgBox_OK_Cancel ); //05/04/2024	navkc1 Bug 63509
			
			if result = MsgBox_Return_OK then
				return true;
			else
				return false;
			endif;
		else
			return true;
		endif;
		
		//app.raiseCMException1(Error_No_Booking_Ref_Item, self.id, null, null);
		return bookingItem &lt;&gt; null;
	else
		return true;
	endif;
	//return true;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupBookingRefTable" id="54b873a8-e2ac-4623-b007-19aab215c7e3">
        <updating/>
        <source>setupBookingRefTable() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 May 2009	cnwrd1	Initial creation
8 March 2010 cnwjo3 found a booking reference with no myVoyage!, par 22756
20 Aug 2010	cnwdap1	PAR #23925 CCMS MES 1076 include operator with voyage in brackets
*/

vars
	br : CM_BookingRef;
	str : String;
begin
	foreach br in self.allBookingRefs do
		//cnwjo3 par 22756.  new rule, if a booking does not have a defined
		//voyage code (ie: neither a voyage or *Null voyage* then cannot assign
		//to this ti at this time
		if br.myVoyage &lt;&gt; null then
			str := br.bookingReference  &amp; ' (' &amp; br.myVoyage.code &amp; ' ' &amp; br.myOperator.code &amp; ')';
			self.tblBookings.addItemObject(br, str);
		endif;
	endforeach;
	
	self.tblBookings.selectRow(1,false);
	self.doSelectBooking();
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="360ec550-2024-4e2c-8a97-e9df024e9823">
