/*
Purpose:			
Date		Who		Reason
10 December 2015	cnwab1	Initial creation
*/

vars

begin
	if app.msgBox("Only use this sort on EntTableDefs for column sorting!" &amp; CrLf &amp; CrLf &amp; "Continue?","Sort", MsgBox_Yes_No +  MsgBox_Exclamation_Mark_Icon) = MsgBox_Return_Yes then
	self.tblDef.sortColumn[1] := 2;
	self.tblDef.sortAsc[1] := true;
	self.tblDef.resort();
	endif;
epilog

end;</source>
