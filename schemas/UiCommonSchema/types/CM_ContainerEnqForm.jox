    </JadeMethod>
    <JadeMethod name="setGeneralCargoInfoRows" id="08266ba0-9102-45e8-9a58-b56a0335e513">
        <executionLocation>client</executionLocation>
        <source>setGeneralCargoInfoRows(_tbl : CM_EntryTable input; _obj : CM_Object; _rowName : String) : Boolean clientExecution;
/*
----------   ----------  --------------------------------------------------
Created:	07 December 2006 By cnwmo1

Purpose:	Return true if row is hidden

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	row	: Integer;
	cargoType	: CM_CargoType;
	product	: CM_Product;
begin
	
	if (not _obj.isKindOf(CM_TrackedItem)) then
		return false;
	endif;
	
	// 35199 handle cargo attributes of items with cargo type but no sub-type (product)
	if _obj.CM_TrackedItem.myProduct &lt;&gt; null then
		product := _obj.CM_TrackedItem.myProduct;
	else
		cargoType := _obj.CM_TrackedItem.myCargoType;
		if cargoType &lt;&gt; null then
			product := cargoType.mySystemProductType;
		endif;
	endif;
	if product = null then
		return false;
	endif;
				
	// 35846 always show total weight, not dependent on cargo/product type attributes
	///if (_rowName = ETRow_TotalWeight) and not product.isAttributeValidForCargoType(ETRow_MyWeight) then
	///		row := _tbl.hideRowByName(ETRow_TotalWeight, false);
	///		return (row &gt; 0);	
	if (_rowName = ETRow_Volume) and not product.isAttributeValidForCargoType(ETRow_MyVolume) then
			row := _tbl.hideRowByName(ETRow_Volume , false);
			return (row &gt; 0);	
	elseif (_rowName = ETRow_Quantity) and not product.isAttributeValidForCargoType(ETRow_MyQuantity) then
			row := _tbl.hideRowByName( ETRow_Quantity, false);
			return (row &gt; 0);
	elseif (_rowName = ETRow_Density) and not product.isAttributeValidForCargoType(ETRow_MyDensity) then
			row := _tbl.hideRowByName( ETRow_Density, false);
			return (row &gt; 0);
	elseif (_rowName = ETRow_Length) and not product.isAttributeValidForCargoType(ETRow_MyLength) then
			row := _tbl.hideRowByName( ETRow_Length, false);
			return (row &gt; 0);	
	elseif (_rowName = ETRow_Height) and not product.isAttributeValidForCargoType(ETRow_MyHeight) then
			row := _tbl.hideRowByName( ETRow_Height, false);
			return (row &gt; 0);	
	elseif (_rowName = ETRow_Width) and not product.isAttributeValidForCargoType(ETRow_MyWidth) then
			row := _tbl.hideRowByName( ETRow_Width, false);
			return (row &gt; 0);
	elseif (_rowName = ETRow_Pieces) and not product.isAttributeValidForCargoType(ETRow_MyQuantity) then
			row := _tbl.hideRowByName( ETRow_Pieces, false);
			return (row &gt; 0);	
	elseif (_rowName = ETRow_WidthString) and not product.isAttributeValidForCargoType(ETRow_WidthString) then
			row := _tbl.hideRowByName( ETRow_WidthString, false);
			return (row &gt; 0);	
	elseif (_rowName = ETRow_HeightString) and not product.isAttributeValidForCargoType(ETRow_HeightString) then
			row := _tbl.hideRowByName( ETRow_HeightString, false);
			return (row &gt; 0);	
	elseif (_rowName = ETRow_LengthString) and not product.isAttributeValidForCargoType(ETRow_LengthString) then
			row := _tbl.hideRowByName( ETRow_LengthString, false);
			return (row &gt; 0);	
	endif;
	return false;
end;</source>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_rowName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setIncludeAllVoyagesInFilter" id="f3424231-5dc8-49d7-b153-df2875b22ddd">
        <updating/>
        <source>setIncludeAllVoyagesInFilter(_value : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     07 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 21 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
vars
	crit : CM_SelectorCriteriaLine;
	foundRow : Integer;
	combo : ComboBox;
begin
   
	if self.includeArchivedVoyages = _value then
		return;
	endif;
	
	self.includeArchivedVoyages := _value;
	self.includeSailedVoyages := _value; // PAR 16939  cnwrs1 June 2008 keep archived and sailed voy gettings the same
	
	combo:=self.cmbFiltVoyage;
	foundRow :=self.tblSearch.getRowByName(ETRow_FilterVoyage);
	if self.useSelectorTable then
		crit :=self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::voyageCode.name);
		if crit &lt;&gt; null then
			self.tblSearch.findObjectInRow(crit,foundRow);
			if foundRow  &gt; 0 then
				combo:= self.getControlByName("cmbQ" &amp; crit.propName).ComboBox;	
			endif;
		endif;
	endif;
	
	if _value then
		self.btnFilterVoyages.caption := app.getErrorString(Active_Voyages);
		self.btnFilterVoyages.bubbleHelp := app.getErrorString(Active_Voyages);
		if foundRow &gt; 0 then
			self.tblSearch.accessCell(foundRow,1).text := app.getErrorString(All_Voyages);
		endif;
	else
		self.btnFilterVoyages.caption := app.getErrorString(All_Voyages);
		self.btnFilterVoyages.bubbleHelp := app.getErrorString(All_Voyages);
		if foundRow &gt; 0 then
			self.tblSearch.accessCell(foundRow,1).text := app.getErrorString(Active_Voyages);
		endif;
	endif;


	self.myAssistant.comboBoxVoyageCurrent(	combo,
											null,
											true,
											self.includeArchivedVoyages,
											self.includeSailedVoyages,
											true,
											true,
											true,
											true,
											false,
											false); //cnwrs1 par15258 nov 2007

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setIncludesDepartedVoyages" id="2320f9cd-6887-4ce6-b5ae-e58021515dd8">
        <updating/>
        <source>setIncludesDepartedVoyages(_value : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     08 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 29/06/2010	cnwdap1		Load Tranship Voyage combo
// 11/03/2019   cnwma1		Bug 43466: PNL - Slow opening windows Cargo Enquiry &amp; Bookings
// 3/11/2019	jlgns1	``  TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin

	locale := app.myCurrentLocale;
	
	self.includeSailedVoyages := _value;
	if _value then
		self.mnuToggleDepartedVoys.caption := app.getErrorString(Hide_departed_voyages);
	else
		self.mnuToggleDepartedVoys.translateCaption(Xlat_0008354, locale);
	endif;
	
	/*
	11.03.2019 cnwma1 #	43466
	self.myAssistant.comboBoxVoyageCurrent(	self.cmbVoyage, 
											self.cmbVoyage.listObject.CM_Voyage, 
											true, 
											self.includeArchivedVoyages, //cnwrs1 par15258 nov 2007
											self.includeSailedVoyages,   //cnwrs1 par15258 nov 2007
											true,
											true,
											true,
											true,
											false,
											false);
		
	// PAR #24516 Load tranship export voyage combo as well
	self.myAssistant.comboBoxVoyageCurrent(	self.cmbExpTshipVoy, 
											self.cmbExpTshipVoy.listObject.CM_Voyage, 
											true, 
											self.includeArchivedVoyages, //cnwrs1 par15258 nov 2007
											self.includeSailedVoyages,   //cnwrs1 par15258 nov 2007
											true,
											true,
											true,
											true,
											false,
											false);
	*/
end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setInitialisedTableValByEntRow" id="7b7a1965-2a62-4135-b0a5-6b85bcce99e6">
        <source>setInitialisedTableValByEntRow( _entRow : String ; _value : Any);

/*

Purpose:			
This will set every instance of the row provided to the value on each initialised table. 
Non - initialised tables will either be set from the proxy or the real on initialisation.

Parameters:			

Return Value:		


Date		Who		Reason
25 May 2009	cnwrd1	Initial creation



*/

vars
	tbl : CM_EntryTable;
	idx,
	row : Integer;
	entRowTrans		: EntTableRowTransient;

begin

	foreach idx in self.allInitializedSheets do
		//cnwrd1 for par 28962 16.1.2012
		if  self.isShowingAlphabetised  then
			tbl := self.tblAlpha;
		else
			tbl := self.getEditTableForIndex(idx);
		endif;
		
		row := tbl.getRowByName(_entRow);
		
		if row &gt; 0 then
			//+cnwml2 PAR24259
			entRowTrans := tbl.accessRow(row).itemObject.EntTableRowTransient;
			if entRowTrans &lt;&gt; null then
				entRowTrans.hasChanged := true;
			endif;
			tbl.setValueByName(_entRow, _value);
		endif;
		
	endforeach;

epilog

end;</source>
        <Parameter name="_entRow" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="setInitialisingInEditMode" id="cc81dc27-6c56-4ca8-b8da-f391d0aa03f0">
        <updating/>
        <source>setInitialisingInEditMode(_value: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 July 2016	cnwer1	Initial creation TFS 2336

*/

vars

begin
	self.amInitialisingInEditMode	:= _value;
	
	if not app.getMyUser.canDo(self.myTerminal, self.permissionMaint) then
		if self.myCurrentObject &lt;&gt; null
			and self.myCurrentObject.isKindOf(CM_TrackedItem) 
			and self.myCurrentObject.CM_TrackedItem.isPreNote then
				self.amInitialisingInEditMode:= app.getMyUser.canDo(self.myTerminal, PmGtePreNoteMaint);
		else
			self.amInitialisingInEditMode:=false;
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
