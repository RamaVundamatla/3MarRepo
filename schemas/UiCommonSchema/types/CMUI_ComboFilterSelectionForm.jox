    <JadeMethod name="btnFilter_click" id="4b9f6e22-0144-4a1f-85f6-8e80e8749bde">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnFilter_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 August 2015	cnwndl1	Initial creation	Par 36789

*/

vars

begin

	self.clickFilterBtn();

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="clickFilterBtn" id="120b7c2d-2f52-4ae2-8b57-34ff90aafe69">
        <source>clickFilterBtn();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 August 2015	cnwndl1	Initial creation	Par 36789

*/

vars

	sensitive : Boolean;
	filterText : String;
	index : Integer;
	itemText : String;

begin

	sensitive := self.chkSensitive.value;

	if sensitive then
		filterText := self.txtFilter.text;
	else
		filterText := self.txtFilter.text.toUpper;
	endif;
	
	self.rePopulate();
	
	if filterText = null or filterText.length &lt; 1 then
		return;
	endif;

	index := self.cmbSelect.listCount();
	while true do
		if index &lt; 1 then
			break;
		endif;
		if sensitive then
			itemText := self.cmbSelect.itemText[index];
		else
			itemText := self.cmbSelect.itemText[index].toUpper;
		endif;
		if itemText.pos(filterText,1) &lt; 1 then
			self.cmbSelect.removeItem(index);
		endif;
		index := index - 1;
	endwhile;
	
	self.cmbSelect.showDropDown();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="99e6061b-e517-4f28-ae64-6b7d16274807">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 August 2015	cnwndl1	Initial creation	Par 36789

*/

vars

begin

	if self.cmbSelect.listIndex &gt; 0 then
		if self.cmbSelect.listObject &lt;&gt; null then
			self.myRelatedCombo.listIndex := self.myRelatedCombo.findObject( self.cmbSelect.listObject );
		elseif self.myRelatedCombo.listCount = self.cmbSelect.listCount then
			self.myRelatedCombo.listIndex := self.cmbSelect.listIndex;
		endif;
	endif;

	inheritMethod();

epilog

end;</source>
    </JadeMethod>
