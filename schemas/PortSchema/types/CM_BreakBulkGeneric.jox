    <JadeMethod name="validateColour" id="2bbdc4ca-a4c6-4625-bc66-9c6c26e07c42">
        <updating/>
        <source>validateColour() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/09/2013	cnwdap1		Initial creation PAR #32215 CCMS DPH 2290 New Car Attributes
// 03/12/2013	cnwdap1		PAR #33019 CCMS DPH 2285 This can get called without being in transaction state
//							so can't update self here.
//
vars
	colours 		: StringArray;
	col				: String;
	sortedColours	: CM_VehicleColourByColour;
	sortedColour	: CM_VehicleColour;

begin
	if not self.myTerminal.getConfig(ValidateColour).Boolean then
		return;
	endif;
	
	create colours transient;
	create sortedColours transient;
	self.colour.getTokensForDelimiter(Space, colours);
	foreach col in colours do
		sortedColour := app.myDutyDocRoot.allVehicleColours[col];
		if sortedColour = null then
			app.raiseCMException1(ERR_INVALID_COLOURCODE, col, "colour", null);
		else
			sortedColours.addNoDuplicates(sortedColour, false);
		endif;
	endforeach;
	
	// now get colours in alphabetical order and build self.colour from them		// PAR #33019
	//col := null;																	// PAR #33019
	//foreach sortedColour in sortedColours do										// PAR #33019
	//	if col &lt;&gt; null then															// PAR #33019
	//		col := col &amp; Space;														// PAR #33019
	//	endif;																		// PAR #33019
	//	col := col &amp; sortedColour.colour;											// PAR #33019
	//endforeach;																	// PAR #33019
	//self.colour := col;															// PAR #33019
	
epilog
	delete colours;
	delete sortedColours;
end;</source>
        <access>protected</access>
    </JadeMethod>
