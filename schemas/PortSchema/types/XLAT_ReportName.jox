    <text>
This needs to be changed to get into from the CM_Report Global Consstant Category
and not the XLAT_ReportNames constant category.
 - refer to how XLAT_Menu class is populaated</text>
    <DbClassMap file="translation"/>
    <JadeMethod name="getUniqueNumber" id="4fea3788-7c9f-4cc1-8d0c-fe0626318396">
        <source>getUniqueNumber(_category : XLAT_Category; _constant: GlobalConstant): Integer protected;

// Other global constant categories have a unique range of Integers.
// Report Names Items are splt across CM_Report and MenuHdrReportConstants Global Constant categories.
vars
begin
	app.raiseUnexpectedProgramError(class.name, method.name, 'Method should not be called for this class');
	return null;
end;</source>
        <access>protected</access>
        <Parameter name="_category" type="XLAT_Category"/>
        <Parameter name="_constant" type="GlobalConstant"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
