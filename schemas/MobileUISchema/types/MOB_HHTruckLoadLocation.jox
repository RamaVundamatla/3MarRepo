    <JadeMethod name="doComplete" id="b38ea419-246c-470f-aebf-c8a06888d86b">
        <source>doComplete():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 September 2018	jlgndl1	Initial creation	TFS 39950 - Cut down version of the 'doComplete' method on 'HHTruckAllCargo' form

*/

vars

	errorMess : String;
	roadJob : CM_RoadJob;
	exitGate : CM_Gate;
	lane : CM_GateAreaLaneController;
	wle : CM_WorkListEntry;
	allReleaseByTypeWles : CM_WLEArray;
	wlesWithWarnings : CM_WLEArray;
	result : Integer;
	truck : CM_Vehicle;
	vvr 	: CM_VehicleVisitRecord;
	attemptRoadExit : Boolean;
	ti : CM_TrackedItem;
	errString : String;
	errMsg : String;
	truckLoaderRequireConfirm : Boolean;
	allIncompleteWLEs : CM_WLEArray;

begin

	truck := self.myMobileGenericAgent.myTruck;
	if truck = null then
		return false;
	endif;
	
	if app.myPassport.myTerminal.getConfig(HhTruckLoadConfComplete).Boolean then
		if self.msgBox(app.getErrorString(AreYouSureComplete),app.getErrorString(Complete)&amp;'?' , MsgBox_Yes_No, false) &lt;&gt; MsgBox_Return_Yes then
			return false;
		endif;
	endif;
	
	foreach ti in truck.locationsController.allTrackedItems do
		if ti.hasUnactionedDocumentActions(false,false,errString) then 
			if errorMess &lt;&gt; null then
				errorMess := errorMess &amp; CrLf;
			endif;
			errorMess := errorMess &amp; errString;
		endif;
	endforeach;
	if errorMess &lt;&gt; null then
		if self.msgBox(errorMess, app.getErrorString(SHP_Do_You_Want_To_Continue), MsgBox_Yes_No, false) &lt;&gt; MsgBox_Return_Yes then
			return false;
		endif;
	endif;

	roadJob := self.myMobileGenericAgent.myTruck.allRoadJobs.first.CM_RoadJob;
	if roadJob = null then
		self.msgBox(app.getErrorString(Err_Gate_VehicleNoJob) ,app.getErrorString(Error), MsgBox_OK_Only, true);
		return false;
	endif;
	
	create allReleaseByTypeWles transient;
	create wlesWithWarnings transient;
	create allIncompleteWLEs transient;								
	foreach wle in roadJob.workListEntries do
		if wle.myTrackedItem = null
		and not wle.status = WLE_COMPLETED
		then
			if wle.myRequest &lt;&gt; null then	
				if wle.myRequest.isKindOf(CM_ReceivalRequest) then
					continue;
				endif;
				if wle.myRequest.isKindOf(CM_DeliveryRequest) then
					if CM_DeliveryRequest.hasInstance(wle.myRequest) then
						if wle.myRequest.isAnyId then	//05 Aug 2014	NDL	Par 34675
							if wle.myTrackedItem = null then
								app.myTrxUA.trxCompleteAnyIdExtraTasks(wle.myRequest.CM_DeliveryRequest, app.myPassport);
								continue;
							endif;
						elseif wle.myRequest.CM_DeliveryRequest.totalRequested = 0 then
							// this is a template style of WLE, i.e. for an unknown number of items.
							app.myTrxUA.trxUpdateWLEStatusDirectWLE(wle.CM_YardWLE, WLE_COMPLETED, app.myPassport);
							continue;
						endif;
					endif;
				endif;
			endif;	
			allReleaseByTypeWles.add(wle);
			
		elseif wle.status &lt;&gt; WLE_COMPLETED and wle.myTrackedItem &lt;&gt; null then
			allIncompleteWLEs.add(wle);										
			
		endif;
	endforeach;
	
	if not allReleaseByTypeWles.isEmpty then

		while true do
			app.myTrxUA.trxUpdateWLEsDoMove(allReleaseByTypeWles, wlesWithWarnings, REAL_MODE, false, null,app.myPassport);

			if app.myPassport.trxCompletedOK then

				break;
			else
				if app.myPassport.allErrorWarnings.size = 1 and app.myPassport.returnCode = INFO_NO_AUTOPLAN then
					result := 1;				
				else
					result := app.showErrorWarningDialog( app.getErrorString( Operations_move ), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				endif;
				if result = IDOK then
					// there must have just been warnings that the user has acknowledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					// only reprocess the wles that had warnings.
					allReleaseByTypeWles.clear;
					wlesWithWarnings.copy(allReleaseByTypeWles);
					wlesWithWarnings.clear;	
					continue;
				endif;
				errorMess := app.myPassport.getAllErrorsWarningsAsString();
			endif;
			break;
		endwhile;	
	endif;

	if errorMess &lt;&gt; null then
		self.msgBox(errorMess ,app.getErrorString(Error), MsgBox_OK_Only, true);
		return false;
	endif;
	
	if allIncompleteWLEs.isEmpty then							
		vvr:=truck.getCurrentVisit;
		if vvr &lt;&gt; null then 
			self.myMobileGenericAgent.createTruckEvent(vvr,EVT_TruckLoadComplete);		
		endif;
	endif;														
	
	if self.myTerminal.getConfig(AllowMobileRoadExit).Boolean then
		attemptRoadExit := self.msgBox(app.getErrorString(Want_road_exit) ,app.getErrorString(Process_road_exit) &amp; "?", MsgBox_Yes_No, false) = MsgBox_Return_Yes;
		if attemptRoadExit then
			self.doCompleteOutward();
		endif;
	endif; 
	
	return true;

epilog

	delete allReleaseByTypeWles;
	delete wlesWithWarnings;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCompleteOutward" id="470c36cc-efed-4064-89a8-3c0d9fbbcb77">
        <source>doCompleteOutward();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 September 2018	jlgndl1	Initial creation	TFS 39950
16 Feb 2024	navnk30	ChangeRequest 62414: EUP | Retrospective Operations - [54177.050] - Road Exit

*/

vars

	truck : CM_Vehicle;
	theRoadJob : CM_RoadJob;
	invalidJob : Boolean;
	errorMess : String;
	userResponse : Integer;
	visit : CM_VehicleVisitRecord;
	
	controller : CM_LaneController;
	thePrinter : CM_PrinterDef;
	printers : StringArray;
	printReceipt : Boolean;
	
begin

	truck := self.myMobileGenericAgent.myTruck;
	on Exception do app.handleDeletedObject(exception, theRoadJob, invalidJob);
	theRoadJob := truck.allRoadJobs.first.CM_RoadJob;
	
	if theRoadJob &lt;&gt; null then
		visit := theRoadJob.CM_RoadJob.myVehicleVisit;
	endif;
	
	if invalidJob then
		return;
	endif;

	// Look thru all of its road jobs set and check if any of them still have any devices in their working devices IDs collection.
	if theRoadJob &lt;&gt; null and theRoadJob.status &lt;&gt; JOB_COMPLETE then
		if theRoadJob.allWorkingDeviceIDs.cnEcIsNotEmpty() then
			userResponse :=	self.msgBox( app.getErrorString (XLAT_RoadExit_Warning1), app.getString(Warning), MsgBox_Question_Mark_Icon + MsgBox_Yes_No, false);
			if userResponse &lt;&gt; MsgBox_Return_Yes then
				return;
			endif;
		endif;
		if theRoadJob.autoComplete then
			self.msgBox(app.getErrorString (XLAT_Road_Exit_Error1), app.getErrorString(Error), MsgBox_OK_Only, true);
			return;
		else
			self.msgBox(app.getErrorString (XLAT_Road_Exit_Error2), app.getErrorString(Error), MsgBox_OK_Only, true);
			return;	
		endif;
	endif;
	
	

	if theRoadJob &lt;&gt; null then
		// if the vehicle is going out a gate that has a p-check location then 
		if not self.doProcessRoadExit_CheckLocn (truck, true) then
			return;
		endif;
		
		if theRoadJob.isTurnAroundJob and truck &lt;&gt; null then
			// if turnaround defferred update of deleted TIs transactions crashes
			app.myTrxDA.trxVehicleRoadExit(truck, app.myPassport);
		else	
			//app.myTrxDA.trxRoadExit(theRoadJob, app.myPassport);		//16.02.2024 navnk30 #62414
			app.myTrxDA.trxRoadExit(theRoadJob, null, app.myPassport);	//16.02.2024 navnk30 #62414
		endif;
		
	elseif truck &lt;&gt; null then
		// if the vehicle is going out a gate that has a p-check location then 
		if not self.doProcessRoadExit_CheckLocn (truck, true) then
			return;
		endif;
		
		app.myTrxDA.trxVehicleRoadExit(truck, app.myPassport);
	
	endif;
	
	if (not app.myPassport.trxCompletedOK) then
		errorMess := app.myPassport.getAllErrorsWarningsAsString;
		self.msgBox(errorMess, app.getErrorString(Error), MsgBox_OK_Only, true);
		return;
	else
		
		printReceipt := self.myTerminal.getConfig(GateReceiptRequired).Boolean;	
		if visit &lt;&gt; null and printReceipt then
			controller := self.myMobileGenericAgent.myGateAreaLaneController;
			if controller &lt;&gt; null then
				thePrinter := controller.getPrinter();
			else	//04 Mar 2016	NDL	TFS 1593
				errorMess := app.getErrorString(Gate_recei_not_produ_gate_used);
				self.msgBox(errorMess, app.getErrorString(Printing_error), MsgBox_OK_Only, false);
				return;
			endif;
			
			if thePrinter = null then
				errorMess := app.getErrorString1(Need_Server_Printer, controller.getFullId);
				self.msgBox(errorMess, app.getErrorString(Printing_error), MsgBox_OK_Only, true);
			
			else
				create printers transient;
				self.getServerPrinters( printers );

				if not printers.includes( thePrinter.physicalPrinterName.trimBlanks ) then
					errorMess := app.getErrorString2(Unknown_Server_Printer, thePrinter.physicalPrinterName.trimBlanks, controller.getFullId);
					self.msgBox(errorMess, app.getErrorString(Printing_error), MsgBox_OK_Only, true);
						
				else
					visit.printRoadReceipt(	null, null, thePrinter.physicalPrinterName ); //epr TFS 2401 22/7/16 use physical name
					if (not app.myPassport.trxCompletedOK) then
						errorMess := app.myPassport.getAllErrorsWarningsAsString;
						self.msgBox(errorMess, app.getErrorString(Error), MsgBox_OK_Only, true);
					endif;
					
				endif;
			
			endif;
			
		endif;
		
		
	endif;
	
epilog

	delete printers;

end;</source>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="5075dfef-36a9-4775-91ba-b5f1ba390e56">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 September 2018	jlgndl1	Initial creation	TFS 39950

*/

vars

	cTop : Real;
	stdWidth : Real;
	stdHeight : Real;
	cLeft : Real;
	tabIndex : Integer;
	cHeight : Real;

begin

	self.setResizeableMarginAndFontSize();
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	
	cTop := self.resizedMargin;
	cLeft := self.resizedMargin;
	
	tabIndex := 4000;
	
	if _initialSetup then
		self.txtTruck.setAndIncrementTabIndex( tabIndex );
		self.txtTruck.visible := true;
	endif;
	self.txtTruck.move( 	cLeft,
							cTop,
							stdWidth,
							stdHeight );
							
	cTop := cTop + self.txtTruck.height + self.resizedMargin;
	cHeight := ( self.clientHeight - cTop - self.getCMDButtonsHeight() - ( self.resizedMargin * 2 ) );
	if _initialSetup then
		self.frmLocation.setAndIncrementTabIndex( tabIndex );
		self.frmLocation.visible := true;
	endif;
	self.frmLocation.move(	cLeft, 
							cTop, 
							stdWidth - 2, 
							cHeight - 2);
							
	self.lblNoLocation.move(	1, 
								1, 
								self.frmLocation.width - 2, 
								stdHeight);
	
	self.resizeScrollButtons();
	
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
