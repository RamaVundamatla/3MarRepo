    <JadeMethod name="tReleaseByType_Mark" id="d3871e4f-b181-480d-80bb-5dea7023872a">
        <source>tReleaseByType_Mark();
// cnwndl1
//27 Jan 2010	cnwdw1	
// Test that gate out of a "by type" release request for mark
constants
	RELEASE = "UTRRBYTYPE";
vars
	releaseRequest: CM_BulkRelease;
	ti: CM_TrackedItem;
	ya: CM_YardAllocation;
	locations : CM_LCArray;
	source: CM_LocationsController;
	yaName: String;
	cargoType: CM_CargoType;
begin
	self.setTerminalConfig(UseBestPickDirector, false);
	
	self.disableAllYA(true);
	self.setTerminalConfig(AutoPlanMTReleaseStrategy, AutoPlanMTRelStrategyYA);
	
	deleteReleaseRequest(RELEASE);
	
	ti := self.addCannonAtLocation("UCAN1", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), bs1);
	self.opts.addAssoc("Mark", "XXX");
	self.opts.addAssoc("TotalWeight", 25);
	self.updateTI(ti);
	assertEqual(ti.mark, "XXX");
	
	create locations transient;
	locations.add(bs1.allLocationsControllers.first.CM_YardController);
	yaName := self.getProfileSetting(UT_Profile.P_YA).asString;
	self.deleteYA(yaName);
	ya := self.addYA1(yaName, YACriteriaType_Mark, "XXX", locations);
	assertFalse(ya.isDisabled);
	
	// Create the Release
	self.opts.purge;
	self.opts.addAssoc("Mark", "XXX");
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	cargoType := self.getCargoType("CANNON");
	releaseRequest := addReleaseByTypeRequestOpts(RELEASE, BR_TYPE_ROAD, cargoType.id);
	assertNotNull(releaseRequest);
	
	// Make sure that the expected source is found by autoplan
	source := app.sourceTisForRequestYA(self.getTerminal(), releaseRequest.requests.first);
	assertNotNullMsg(source, getYAAutoPlanMessages);
	assertEqual(source.getName(), locations.first.getName());
	
epilog
	delete locations;
	self.disableAllYA(false);
end;</source>
    </JadeMethod>
    <JadeMethod name="tReleaseISOSubstitution" id="54aa182a-8d4b-440e-86d5-e8f9b6534a57">
        <source>tReleaseISOSubstitution();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/11/2014	cnwdap1		Initial creation PAR #35236
//
constants
	ForkStack		= "UTFORKDP";
	BlockStack		= "UTBLOCKDP";
	ICArea			= "UTICDP";
	ReceiveArea		= "UTRCDP";
	TheContainer1	= "UTDP1234567";
	TheContainer2	= "UTDP7654321";
	ReleaseRequest	= "UTRELREQDP";
	TheTruck		= "UTTRUCKDP";
	ForkLift		= "FLDP";
	TheQueue		= "DPGTOB";
	IsoType			= "U4D2";
	WantedIsoType	= "U4D1";
	IsoGroup		= "U4DP";
	SubIsoGroup		= "U4SB";
	
vars
	terminal		: CM_Terminal;
	root			: CM_Root;
	forkStack 		: CM_ForkLiftStack;
	blockStack		: CM_BlockStack;
	icArea			: CM_YardInterchangeArea;
	receiveArea		: CM_BlockStack;
	container1,
	container2, ti	: CM_Container;
	release			: CM_BulkRelease;
	operator		: CM_Operator;
	machineRule		: CM_RTQueueMultiRule;
	isoGroup		: CM_ISOTypeGroup;
	isoType			: CM_ISOType;
	forklift		: CM_Machine;
	queue			: CM_SubQueue;
	tas				: StringArray;
	task			: CM_RTQueueTask;
	wle				: CM_WorkListEntry;
	iter			: Iterator;
	operatorTerm	: CM_OperatorTerminal;
	count			: Integer;
	yardJob			: CM_YardInternalJob;
	setDown			: String;

begin
	// Create two containers on site (that are the only ones of that ISO type on site) - one in a block stack, the other in a transfer area
	// Queue one container in a multi-machine move from one terminal area to another, stopping in the transfer area in between
	// Move this container to the transfer area, leave it queued for the second half of the move.
	// Create a packing release request for a substitution ISO group that matches the containers' ISO type.
	// Ensure the containers are the only ones on site that match the release request
	// Create a Delivery request for the release using the transfer area as the source area
	// The delivery request should auto plan, it should find the second container
	// Move the second container to a block stack and requeue the delivery request, it should fail this time
	//
	// Then:
	// Complete the move for the container, then move it back to the transfer area.
	// Requeue the delivery request - it should now autoplan successfully
	
	// Set up stuff first
	self.deleteTerminalArea(ForkStack);	
	self.deleteTerminalArea(BlockStack);
	self.deleteTerminalArea(ICArea);
	self.deleteContainer(TheContainer1);
	self.deleteContainer(TheContainer2);
	self.deleteReleaseRequest(ReleaseRequest);
	self.deleteVehicle(TheTruck);
	self.deleteMachine(ForkLift);
	self.deleteQueue(TheQueue);
	
	terminal := self.getTerminal;
	self.setTerminalConfig(AutoPlanMTReleaseStrategy, 3);
	self.setTerminalConfig(UseBestPickDirector, true);
	root := terminal.myRoot;
	operator := root.allOperators["MSC"];
	create tas transient;
	
	// create the terminal areas - gridded block stack, block stack and interchange
	self.opts.purge;
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("HideOverview", true);
	icArea := self.addInterchangeArea(ICArea, null);
	self.opts.purge;
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("StockControlled", true);
	self.opts.addAssoc("DefaultYIC", icArea);
	forkStack := self.addForkLiftStack(ForkStack, 2, 2, 1);
	self.opts.purge;
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("StockControlled", true);
	self.opts.addAssoc("DefaultYIC", icArea);
	blockStack := self.addBlockStack(BlockStack, 20, null);
	self.opts.purge;
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("StockControlled", true);
	self.opts.addAssoc("DefaultYIC", icArea);
	receiveArea := self.addReceiveTransArea(ReceiveArea, 20, null);
	
	// Create the containers
	container1 := self.createContainer(TheContainer1, IsoType, "MT", operator, false).CM_Container;
	assertNotNullMsg(container1, "Container " &amp; TheContainer1 &amp; " not created");
	self.move(container1, blockStack);
	assertEqualMsg(container1.myPrimaryActualLocation, blockStack.myLocationsController, "Container " &amp; TheContainer1 &amp; " not in " &amp; BlockStack &amp; " but in " &amp; container1.myPrimaryActualLocation.getFullId);
	assertEqualMsg(container1.operatorCode, "MSC", "Container " &amp; TheContainer1 &amp; " has the wrong operator - should be MSC, is " &amp; container1.operatorCode);
	container2 := self.createContainer(TheContainer2, IsoType, "MT", operator, false).CM_Container;
	assertNotNullMsg(container2, "Container " &amp; TheContainer2 &amp; " not created");
	self.move(container2, receiveArea);
	assertEqualMsg(container2.myPrimaryActualLocation.myTerminalArea, receiveArea, "Container " &amp; TheContainer2 &amp; " not in " &amp; ReceiveArea &amp; " but in " &amp; container2.myPrimaryActualLocation.getFullId);
	assertEqualMsg(container2.operatorCode, "MSC", "Container " &amp; TheContainer2 &amp; " has the wrong operator - should be MSC, is " &amp; container2.operatorCode);
	
	// Make sure a substitution rule exists for the iso type of the containers
	isoGroup := root.allISOTypeGroups[SubIsoGroup];
	isoType := root.allISOTypes[WantedIsoType];
	assertTrueMsg(isoGroup &lt;&gt; null, "Substitute ISO Group " &amp; SubIsoGroup &amp; " not found");
	assertTrueMsg(isoType &lt;&gt; null, "ISO Type " &amp; WantedIsoType &amp; " not found");
	assertTrueMsg(isoType.myISOTypeGroup.allSubstitutingISOGroups.includes(isoGroup), "ISO Group " &amp; SubIsoGroup &amp; " not in substitution group for ISO type " &amp; WantedIsoType);
	
	// Queue the first container in a multi-machine move from the block stack to the gridded block stack, stopping in the transfer area in between
	// Set up machine rule first
	machineRule := terminal.allRTQueueMultiRuleTATypes[blockStack.myType, forkStack.myType];
	if machineRule &lt;&gt; null then
		beginTransaction;
		delete machineRule;
		commitTransaction;
	endif;
	self.addMachineRuleType(blockStack.myType, forkStack.myType, RTMoveMethod_25, FullMoveQueuing);
	// then queue the container
	self.moveQueued(container1, forkStack.allLocationsControllers.first);
	assertNotNullMsg(container1.getPrimaryLocation(QUEUE_MODE), TheContainer1 &amp; " queued location");
	assertEqualMsg(container1.getPrimaryLocation(QUEUE_MODE).myTerminalArea, forkStack, TheContainer1 &amp; " did not queue to " &amp; ForkStack);
	wle := container1.allWorklistEntries.last;
	assertNotNullMsg(wle, "WLE for container " &amp; container1.id &amp; " is null");
	assertEqualMsg(wle.allRTQueueEntries.size, 2, "WLE for container " &amp; container1.id &amp; " has " &amp; wle.allRTQueueEntries.size.String &amp; " entries, should have 2");
	// now move it to the interchange area
	queue := self.addQueue(TheQueue, blockStack, forkStack, true);
	tas.add(forkStack.id);
	tas.add(blockStack.id);
	tas.add(icArea.id);
	forklift := self.addForkLift(ForkLift, 98, tas, TheQueue);
	assertNotNullMsg(queue, "Queue " &amp; TheQueue &amp; " is null");
	assertNotNullMsg(forklift, "Forklift " &amp; ForkLift &amp; " is null");
	self.machineLogon(forklift);
	task := self.machineTaskRequest(forklift);
	self.assertEqualMsg(task.taskType, TASK_PICKUP, "Task type for " &amp; ForkLift &amp; " should be " &amp; TASK_PICKUP.String &amp; ", but is " &amp; task.taskType.String);
	self.assertEqualMsg(task.status, TASK_OFFERED, "Task status for " &amp; ForkLift &amp; "should be " &amp; TASK_OFFERED.String &amp; ", but is " &amp; task.status.String);
	self.machineAcceptTask(forklift, task);
	self.machinePickup(forklift);
	self.machineSetdown(forklift, container1, ICArea);
	self.assertTrueMsg(container1.myPrimaryActualLocation.myTerminalArea.id = ICArea, "Container " &amp; TheContainer1 &amp; " is not in " &amp; ICArea &amp; ", but in " &amp; container1.myPrimaryActualLocation.myTerminalArea.id);
	
	// container is now in the interchange area, check there are only two of this iso type in the terminal for the operator
	operatorTerm := operator.allOperatorTerminals[terminal];
	iter := operatorTerm.allOnsiteMTContsByISOType.createIterator;
	operatorTerm.allOnsiteMTContsByISOType.startKeyGeq(IsoType, iter);
	while iter.next(ti) do
		if ti.isoType &lt;&gt; IsoType then
			break;
		endif;
		count := count + 1;
	endwhile;
	self.assertTrueMsg(count = 2, "There is " &amp; count.String &amp; " containers with iso type " &amp; IsoType &amp; " in terminal " &amp; terminal.code);
	
	// Create a release request for an iso type that has our container's iso group as a substitute group
	self.opts.purge;
	self.opts.addAssoc("ISOGroup", IsoGroup);
	self.opts.addAssoc("CanbeHiLoCube", true);
	self.opts.addAssoc("Operator", operator);
	release := self.addReleaseByTypeRequestOpts(ReleaseRequest, BR_TYPE_PACKING, TI_CargoType_Container);
	// Now create a delivery request with the receive area as the source area
	yardJob := self.createInternalDeliveryMove(release, receiveArea, blockStack, queue, IsoType, IsoGroup);
	// yard job should have at least one RT entry
	self.assertTrueMsg(yardJob &lt;&gt; null and app.isValidObject(yardJob), "Yard Job is invalid");
	self.assertTrueMsg(not yardJob.allEntries.isEmpty, "Yard Job has no RTQ entries");
	
	// delete the job, and delete the second container in the recive area, leaving just the queued box on site
	beginTransaction;
	yardJob.erase(NORMAL_ERASE);
	commitTransaction;
	yardJob := null;
	self.deleteContainer(TheContainer2);
	
	// Recreate the delivery request - should fail as it won't find a valid box that isn't already queued
	yardJob := self.createInternalDeliveryMove(release, icArea, blockStack, queue, IsoType, IsoGroup);
	self.assertTrueMsg(yardJob = null or not app.isValidObject(yardJob), "Yard Job is valid");
	
	// Complete the multi-machine move
	task := self.machineTaskRequest(forklift);
	self.assertEqualMsg(task.taskType, TASK_PICKUP, "Second Task type for " &amp; ForkLift &amp; " should be " &amp; TASK_PICKUP.String &amp; ", but is " &amp; task.taskType.String);
	self.assertEqualMsg(task.status, TASK_OFFERED, "Second Task status for " &amp; ForkLift &amp; " should be " &amp; TASK_OFFERED.String &amp; ", but is " &amp; task.status.String);
	self.machineAcceptTask(forklift, task);
	self.machinePickup(forklift);
	setDown := forkStack.allLocationsControllers.first.getFullId;
	self.machineSetdown(forklift, container1, setDown);
	self.assertTrueMsg(container1.myPrimaryActualLocation.myTerminalArea.id = ForkStack, "Container " &amp; TheContainer1 &amp; " is not in " &amp; ForkStack &amp; ", but in " &amp; container1.myPrimaryActualLocation.myTerminalArea.id);
	
epilog
	
	// delete the machine move rule in case it messes up subsequent tests
	if machineRule &lt;&gt; null then
		self.deleteMachineRule(blockStack.myType, forkStack.myType);
	endif;
	
	delete tas;
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="tReleaseToDoTasks" id="a76cdc9b-9492-49d9-9ec0-9b75ee3ae819">
        <source>tReleaseToDoTasks();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 01/12/2014	cnwdap1		Initial creation PAR #35081 test releases and interaction between sub-terminals / inter-terminals and to do tasks
//
constants
	SubTerm1Code 	= "UT_DepotA";
	SubTerm2Code 	= "UT_DepotB";
	ToDoTaskCode 	= "UT_ToDoZ";
	TheContainer1	= "UTDP1234567";
	ReleaseRequest	= "UTRELREQDP";
	TheTruck		= "UTTRUCKDP";
	IsoType			= "U4D1";
	BlockStack1		= "UTBL1DP";
	BlockStack2		= "UTBL2DP";
	PackingRequest	= "UTPACKEL1";
	TheQueue		= "DPGTOB";
	
vars
	terminal				: CM_Terminal;
	operator				: CM_Operator;
	subTerm1, subTerm2		: CM_SubTerminal;
	resetSubTermAreaDefined	: Boolean;
	resetPackingSubTerm		: Boolean;
	container, ti			: CM_Container;
	iter 					: Iterator;
	count					: Integer;
	release, packRelease	: CM_BulkRelease;
	tiSet					: CM_TISet;
	subTerm					: CM_SubTerminal;
	toDoTask				: CM_ToDoTaskDesc;
	blockStack1				: CM_BlockStack;
	blockStack2				: CM_BlockStack;
	singleGate				: CM_Gate;
	truck					: CM_Vehicle;
	job 					: CM_RoadJob;
	wle 					: CM_WorkListEntry;
	delRequest				: CM_DeliveryRequest;
	alertType 				: CM_SystemAlertType;
	alert, theAlert			: CM_SystemAlert;
	isInSubTerm1			: Boolean;
	opTerm					: CM_OperatorTerminal;
	packTarget				: CM_SubTerminal;
	pxySubTermDef,
	realSubTermDef			: CM_SubTerminalAreaDef;
	selectedObjects			: ObjectSet;
	yardJob					: CM_YardInternalJob;
	queue					: CM_SubQueue;
	subTerminalsEnabled		: Boolean;
	
begin
	// Ensure terminal has sub-terminals turned on
	terminal := self.getTerminal();
	operator := self.getOperator("MSC");
	
	subTerminalsEnabled := self.getTerminalConfig(IsSubTerminalsOn).Boolean;
	self.setTerminalConfig(IsSubTerminalsOn, true);
	
	self.assertTrueMsg(app.isSubTerminalsLicensed, "Not licensed for sub terminals!");
	self.assertTrueMsg(app.isSubTerminalsOn(terminal), terminal.name &amp; " not set up for sub terminals!");
	
	// delete some stuff
	self.deleteContainer(TheContainer1);
	self.deleteReleaseRequest(ReleaseRequest);
	self.deleteVehicle(TheTruck);
	self.deleteSubTerminal(SubTerm1Code);
	self.deleteSubTerminal(SubTerm2Code);
	self.deleteTerminalArea(BlockStack1);
	self.deleteTerminalArea(BlockStack2);
	
	// set up some stuff - sub terminals, to do task, terminal areas
	subTerm1 := self.addSubTerminal(SubTerm1Code, SubTermType_Depot_Int);
	subTerm2 := self.addSubTerminal(SubTerm2Code, SubTermType_Depot_Int);
	if not terminal.getConfig(IsSubTerminalAreaDefined).Boolean then
		resetSubTermAreaDefined := true;
		self.setSubTerminalAreaDefined(true);	
	endif;
	toDoTask := app.myRoot.allToDoTaskDescsByShortDesc.getAtKey(ToDoTaskCode);
	if toDoTask &lt;&gt; null then
		self.deleteToDoTaskDescription(toDoTask);
	endif;
	toDoTask := self.createToDoTaskDesc(ToDoTaskCode);
	self.opts.purge;
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("StockControlled", true);
	blockStack1 := self.addBlockStack(BlockStack1, 20, null);
	self.opts.purge;
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("StockControlled", true);
	blockStack2 := self.addBlockStack(BlockStack2, 20, null);
	
	// add terminal areas to separate sub-terminals
	create pxySubTermDef transient;
	create selectedObjects transient;
	selectedObjects.add(blockStack1);
	pxySubTermDef.setProxy(subTerm1.code, subTerm2.description, false, selectedObjects, subTerm1, terminal);
	app.myTrxCA.trxCreateSubTerminalAreaDef(pxySubTermDef, realSubTermDef, app.myPassport);
	delete pxySubTermDef;
	delete selectedObjects;
	create pxySubTermDef transient;
	create selectedObjects transient;
	selectedObjects.add(blockStack2);
	pxySubTermDef.setProxy(subTerm2.code, subTerm2.description, false, selectedObjects, subTerm2, terminal);
	app.myTrxCA.trxCreateSubTerminalAreaDef(pxySubTermDef, realSubTermDef, app.myPassport);
	
	// 1. Create a Release Request for a specific ISO type and operator - make sure there's only 1 container on site that matches
	container := self.addContainer(TheContainer1, operator, IsoType, "MT", TI_IMEX_STATUS_STORAGE).CM_Container;
	assertNotNullMsg(container, "Container " &amp; TheContainer1 &amp; " not created");
	self.move(container, blockStack2);
	assertEqualMsg(container.myPrimaryActualLocation, blockStack2.myLocationsController, "Container " &amp; container.id &amp; " is not in " &amp; blockStack1.getName);
	opTerm := operator.allOperatorTerminals[terminal];
	iter := opTerm.allOnsiteMTContsByISOType.createIterator;
	opTerm.allOnsiteMTContsByISOType.startKeyGeq(IsoType, iter);
	while iter.next(ti) do
		if ti.isoType &lt;&gt; IsoType then
			break;
		endif;
		count := count + 1;
	endwhile;
	delete iter;
	assertEqualMsg(count, 1, "There is more than 1 " &amp; IsoType &amp; " container on site in " &amp; terminal.code);
	release := self.addReleaseByTypeRequest(ReleaseRequest, BR_TYPE_ROAD, TI_CargoType_Container, IsoType);
	assertNotNullMsg(release, "Release Request " &amp; ReleaseRequest &amp; " not created");
	
	// 2. Assign a to do task to the container
	create tiSet transient;
	tiSet.add(container);
	self.addToDoTask(toDoTask, tiSet);
	assertEqualMsg(container.allToDoTasksToDo.size, 1, "Container " &amp; container.id &amp; " has no to do tasks");
	
	// 3. Ensure all sub-terminals for the terminal are in the to do task's list of allowed sub-terminals
	foreach subTerm in terminal.allSubTerminals do
		assertTrueMsg(toDoTask.allAllowedEditSubTerms.includes(subTerm), "Sub-terminal " &amp; subTerm.code &amp; " is not allowed for To Do Task " &amp; toDoTask.description);
	endforeach;
	assertTrueMsg(terminal.allSubTerminals.size = toDoTask.allAllowedEditSubTerms.size, "Size mismatch between terminal.allSubTerminals and toDoTask.allAllowedEditSubTerms");
	// and check what sub-terminal the container is in
	isInSubTerm1 := container.mySubTerminal = subTerm1;
	
	// 4. Gate in a truck for the release request - should fail to auto-plan
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	assertNotNull(singleGate);
	self.opts.purge;
	self.opts.addAssoc("release", release);
	self.gateOutContainer(TheTruck, null, "UTDRIVER", null, true, singleGate , null);
	truck := self.getVehicle(TheTruck);
	self.assertTrueMsg(truck &lt;&gt; null, "Can't find the truck.");
	self.assertTrueMsg(truck.allRoadJobs.size = 1, "Wrong number of jobs on the truck.");
	job := truck.allRoadJobs.first.CM_RoadJob;
	self.assertTrueMsg(job &lt;&gt; null, "Can't find the job.");
	self.assertTrueMsg(job.workListEntries.size = 1, "Wrong number of wles on the job.");
	wle := truck.allRoadJobs.first.workListEntries.first;
	self.assertTrueMsg(wle &lt;&gt; null, "Can't find the wle.");
	delRequest := wle.myRequest.CM_DeliveryRequest;
	self.assertTrueMsg(delRequest &lt;&gt; null, "The delivery request wasn't found.");
	self.assertTrueMsg(delRequest.myReserveDetail &lt;&gt; null, "The delvery request did not have the Reserve Selection set.");
	alertType := app.myRoot.allSystemAlertTypes[EVENT_AT_FailedAutoPlanRequest];
	iter := alertType.allSystemAlerts.createIterator;
	while iter.next( alert ) do
		if alert.getLinkedTo &lt;&gt; delRequest then
			continue;
		endif;
		theAlert := alert;
		break;
	endwhile;
	self.assertTrueMsg( theAlert &lt;&gt; null, "The Alert for 'Failed Auto Plan Request' not created or not linked to the Delivery request.");
	beginTransaction;
	theAlert.erase(NORMAL_ERASE);
	commitTransaction;
	
	// 4. Create a Work Request for delivery of the ISO type to another terminal area that will change the container's sub-terminal
	setTerminalConfig(MySubTerminalForTargetBulk, subTerm1);
	self.assertTrueMsg(terminal.getConfig(MySubTerminalForTargetBulk).CM_SubTerminal = subTerm1, "Packing SubTerminal not set to " &amp; SubTerm1Code);
	packRelease := self.addReleaseByTypeRequest(PackingRequest, BR_TYPE_PACKING, TI_CargoType_Container, IsoType);
	self.assertTrueMsg(packRelease &lt;&gt; null, "Release not created");
	self.assertTrueMsg(packRelease.mySubTerminalTarget &lt;&gt; container.mySubTerminal, "Packing Release Sub-Terminal equals the container's Sub-Terminal");
	
	// 6. Queue the delivery request - should autoplan OK
	queue := self.addQueue(TheQueue, blockStack1, blockStack2, true);
	yardJob := self.createInternalDeliveryMove(packRelease, blockStack1, blockStack2, queue, IsoType, null);
	// yard job should have at least one RT entry
	self.assertTrueMsg(yardJob &lt;&gt; null and app.isValidObject(yardJob), "Yard Job is invalid");
	self.assertTrueMsg(not yardJob.allEntries.isEmpty, "Yard Job has no RTQ entries");
	
	// 7. Retry the Release Request - should still fail to autoplan
	self.deleteReleaseRequest(ReleaseRequest);
	self.deleteVehicle(TheTruck);
	release := self.addReleaseByTypeRequest(ReleaseRequest, BR_TYPE_ROAD, TI_CargoType_Container, IsoType);
	assertNotNullMsg(release, "Release Request " &amp; ReleaseRequest &amp; " not created");
	self.opts.purge;
	self.opts.addAssoc("release", release);
	self.gateOutContainer(TheTruck, null, "UTDRIVER", null, true, singleGate , null);
	truck := self.getVehicle(TheTruck);
	self.assertTrueMsg(truck &lt;&gt; null, "Can't find the truck.");
	self.assertTrueMsg(truck.allRoadJobs.size = 1, "Wrong number of jobs on the truck.");
	job := truck.allRoadJobs.first.CM_RoadJob;
	self.assertTrueMsg(job &lt;&gt; null, "Can't find the job.");
	self.assertTrueMsg(job.workListEntries.size = 1, "Wrong number of wles on the job.");
	wle := truck.allRoadJobs.first.workListEntries.first;
	self.assertTrueMsg(wle &lt;&gt; null, "Can't find the wle.");
	delRequest := wle.myRequest.CM_DeliveryRequest;
	self.assertTrueMsg(delRequest &lt;&gt; null, "The delivery request wasn't found.");
	self.assertTrueMsg(delRequest.myReserveDetail &lt;&gt; null, "The delvery request did not have the Reserve Selection set.");
	alertType := app.myRoot.allSystemAlertTypes[EVENT_AT_FailedAutoPlanRequest];
	delete iter;
	iter := alertType.allSystemAlerts.createIterator;
	while iter.next( alert ) do
		if alert.getLinkedTo &lt;&gt; delRequest then
			continue;
		endif;
		theAlert := alert;
		break;
	endwhile;
	self.assertTrueMsg( theAlert &lt;&gt; null, "The Alert for 'Failed Auto Plan Request' not created or not linked to the Delivery request.");
	beginTransaction;
	theAlert.erase(NORMAL_ERASE);
	commitTransaction;
	
	// inter-terminal checks are done in UT_InterTerminalTransfer::tToTermWithAvailGradeAndToDo
	
epilog
	self.setTerminalConfig(IsSubTerminalsOn, subTerminalsEnabled);
	if resetSubTermAreaDefined then
		self.setSubTerminalAreaDefined( false );
	endif;
	delete iter;
	delete tiSet;
	delete pxySubTermDef;
	delete selectedObjects;
	
	// delete the new tracked item
	self.deleteContainer(TheContainer1);
	
	// delete the new todo task
	self.deleteToDoTaskDescription(toDoTask);
	
	//delete the sub terminals
	self.deleteSubTerminal(SubTerm1Code);
	self.deleteSubTerminal(SubTerm2Code);
end;</source>
    </JadeMethod>
    <JadeMethod name="tSelectISOSource1" id="f0e1f5b9-e1b1-4a18-a9a0-0013d55b6823">
        <source>tSelectISOSource1();
// cnwns1
/* cnwjre1
	select a block stack as the source, no yard allocations involved
*/

vars
	taSource: CM_ForkLiftStack;
	ti, nextTI, osTI,
	otherTI : CM_TrackedItem;
	releaseRequest: CM_BulkRelease;
	truck: CM_Vehicle;
	vvr: CM_VehicleVisitRecord;
	singleGate: CM_Gate;
	wle : CM_WorkListEntry;
	qe : CM_RTQueueEntry;
begin
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	deleteTerminalArea("UTFORK");
	taSource:= self.addForkLiftStack("UTFORK", 6, 5, 2);
	assertNotNullMsg(taSource, "UTFORK");
	
	self.deleteContainer("TEST0000011");
	self.deleteContainer("TEST0000002");
	self.deleteContainer("TEST0000003");
	self.deleteContainer("TEST0000004");
	self.deleteVehicle("UTTRUCK");


	self.opts.addAssoc("Width", "200");
	self.opts.addAssoc(UTTI_IMEX, TI_IMEX_STATUS_STORAGE);
	ti := self.addContainerOpts("TEST0000011", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(ti, "TEST0000011");
	self.move(ti ,taSource.allGridControllersByRowColumn[1, 1]);
	self.assertEqualMsg(ti.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[1, 1], "Did not move TEST0000011 to correct location");
	
	osTI:= self.addContainerOpts("TEST0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(osTI, "TEST0000002");
	self.move(osTI ,taSource.allGridControllersByRowColumn[2, 2]);
	self.assertEqualMsg(osTI.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[2, 2], "Did not move TEST0000002 to correct location");
	
	nextTI:= self.addContainerOpts("TEST0000003", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(nextTI, "TEST0000003");
	self.move(nextTI ,taSource.allGridControllersByRowColumn[3, 3]);
	self.assertEqualMsg(nextTI.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[3, 3], "Did not move TEST0000003 to correct location");
	
	otherTI:= self.addContainerOpts("TEST0000004", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(otherTI, "TEST0000004");
	self.move(otherTI ,bs1.myLocationsController);
	self.assertEqualMsg(otherTI.myPrimaryActualLocation, bs1.myLocationsController, "Did not move TEST0000004 to correct location");

	// Create the Release
	self.opts.purge();
	self.opts.addAssoc("ISOType", "2200");
	self.opts.addAssoc("FullRelease", true);
	releaseRequest := addReleaseByTypeRequestOpts("UTRRRoad", BR_TYPE_ROAD, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	
	// Gate Out
	self.opts.purge();
	self.opts.addAssoc("release", releaseRequest);
	vvr := self.gateOutContainer("UTTRUCK", "", "UTDRIVER", null, true, singleGate ,null);
	
	truck := self.getVehicle("UTTRUCK");
	assertEqual(truck.allRoadJobs.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.size, 1);

	// actual test
	wle := releaseRequest.allRequestsBeingActioned.first.allWorkListEntries.first;
	self.unqueueWLE(wle);
	self.setISOSource(wle, bs1);
	
	// should be a single queue entry from setISOSource, with source location of bs1
	qe := wle.allRTQueueEntries.first;
	assertEqual(qe.allTasks.first.sourceLocation.ident, bs1.id);

epilog
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="tSelectISOSource2" id="76226c20-2b0e-4803-a892-0ff59408e913">
        <source>tSelectISOSource2();
// cnwns1
/* cnwjre1
	select a gridded area as the source, using yard allocations
*/

vars
	containers : String;
	taSource : CM_ForkLiftStack;
	taSource2 : CM_StraddleStack;
	ti, nextTI, osTI,
	otherTI : CM_TrackedItem;
	releaseRequest: CM_BulkRelease;
	truck: CM_Vehicle;
	vvr: CM_VehicleVisitRecord;
	singleGate: CM_Gate;
	wle : CM_WorkListEntry;
	qe : CM_RTQueueEntry;
	ya : CM_YardAllocation;
	lc : CM_LocationsController;
	locations : CM_LCArray;
	source: CM_LocationsController;
	yaName: String;
begin
	self.disableAllYA(true);
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	deleteTerminalArea("UTFORK");
	deleteTerminalArea("UTFORK2");
	taSource := self.addForkLiftStack("UTFORK", 6, 5, 2);
	assertNotNullMsg(taSource, "UTFORK");

	deleteTerminalArea("UTSTRD");
	taSource2 := addStraddleStack("UTSTRD", 3, 8, 2);
	assertNotNullMsg(taSource2, "UTSTRD");
	
	self.deleteContainer("TEST0000011");
	self.deleteContainer("TEST0000002");
	self.deleteContainer("TEST0000003");
	self.deleteContainer("TEST0000004");
	self.deleteVehicle("UTTRUCK");


	self.opts.addAssoc("Width", "200");
	self.opts.addAssoc(UTTI_IMEX, TI_IMEX_STATUS_STORAGE);
	ti := self.addContainerOpts("TEST0000011", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(ti, "TEST0000011");
	self.move(ti ,taSource.allGridControllersByRowColumn[1, 1]);
	self.assertEqualMsg(ti.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[1, 1], "Did not move TEST0000011 to correct location");
	
	osTI:= self.addContainerOpts("TEST0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(osTI, "TEST0000002");
	self.move(osTI ,taSource.allGridControllersByRowColumn[2, 2]);
	self.assertEqualMsg(osTI.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[2, 2], "Did not move TEST0000002 to correct location");
	
	nextTI:= self.addContainerOpts("TEST0000003", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(nextTI, "TEST0000003");
	self.move(nextTI ,taSource.allGridControllersByRowColumn[3, 3]);
	self.assertEqualMsg(nextTI.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[3, 3], "Did not move TEST0000003 to correct location");
	
	// into the second area
	otherTI:= self.addContainerOpts("TEST0000004", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(otherTI, "TEST0000004");
	self.move(otherTI ,taSource2.allGridControllersByRowColumn[1, 1]); // was 2, 5
	self.assertEqualMsg(otherTI.myPrimaryActualLocation, taSource2.allGridControllersByRowColumn[1, 1], "Did not move TEST0000004 to correct location");

	// Create the Release
	self.opts.purge();
	self.opts.addAssoc("ISOType", "2200");
	self.opts.addAssoc("FullRelease", true);
	releaseRequest := addReleaseByTypeRequestOpts("UTRRRoad", BR_TYPE_ROAD, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	
	// Gate Out
	self.opts.purge();
	self.opts.addAssoc("release", releaseRequest);
	vvr := self.gateOutContainer("UTTRUCK", "", "UTDRIVER", null, true, singleGate ,null);
	
	truck := self.getVehicle("UTTRUCK");
	assertEqual(truck.allRoadJobs.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.size, 1);

	// actual test
	// create yard allocations to be used in set setISOSource
	//locations are Top Left &amp; bottom Right
	create locations transient;
	locations.add(taSource2.allGridControllersByRowColumn[1, 4]);
	locations.add(taSource2.allGridControllersByRowColumn[3, 6]);
	
	self.deleteYA("UT");
	containers := "20";
	ya := self.addYA1("UT", YACriteriaType_ContainerLength, containers, locations);
	assertNotNullMsg(ya, "UT Yard Allocation");

	wle := releaseRequest.allRequestsBeingActioned.first.allWorkListEntries.first;
	// Apr 2010 the failure now raises an error message
	self.expectTrxError(Must_unque_befor_sourc_loc);  // 86030. This job must be unqueued before a new source location can be selected.
	self.expectTrxError(Request_failed_auto_plan);  // 84880. Request failed to auto plan
	self.setISOSource(wle, taSource2);

	// should be a single queue entry from setISOSource, with source location of UTSTRD
	// currently the auto-plan fails and nothing is queued
	//qe := wle.allRTQueueEntries.first;
	//assertEqual(qe.allTasks.first.sourceLocation.ident, taSource2.id);
	self.assertNoTrxErrorsOrWarnings();

epilog
	delete locations;
	self.disableAllYA(false);
end;
</source>
    </JadeMethod>
    <JadeMethod name="tSelectISOSource3" id="55a23ebf-ad11-4cdc-9be2-dfb00f76c4a4">
        <source>tSelectISOSource3();
// cnwns1
/* cnwjre1
	select a gridded area as the source, auto-plan fails, best-fit finds the area
*/

vars
	containers : String;
	taSource : CM_ForkLiftStack;
	taSource2 : CM_StraddleStack;
	ti, nextTI, osTI,
	otherTI : CM_TrackedItem;
	releaseRequest: CM_BulkRelease;
	truck: CM_Vehicle;
	vvr: CM_VehicleVisitRecord;
	singleGate: CM_Gate;
	wle : CM_WorkListEntry;
	qe : CM_RTQueueEntry;
	ya : CM_YardAllocation;
	lc : CM_LocationsController;
	locations : CM_LCArray;
	source: CM_LocationsController;
	yaName: String;
begin
	self.disableAllYA(true);
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	deleteTerminalArea("UTFORK");
	deleteTerminalArea("UTFORK2");
	taSource := self.addForkLiftStack("UTFORK", 6, 5, 2);
	assertNotNullMsg(taSource, "UTFORK");

	deleteTerminalArea("UTSTRD");
	taSource2 := addStraddleStack("UTSTRD", 3, 8, 2);
	assertNotNullMsg(taSource2, "UTSTRD");
	
	self.deleteContainer("TEST0000011");
	self.deleteContainer("TEST0000002");
	self.deleteContainer("TEST0000003");
	self.deleteContainer("TEST0000004");
	self.deleteVehicle("UTTRUCK");


	self.opts.addAssoc("Width", "200");
	self.opts.addAssoc(UTTI_IMEX, TI_IMEX_STATUS_STORAGE);
	ti := self.addContainerOpts("TEST0000011", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(ti, "TEST0000011");
	self.move(ti ,taSource.allGridControllersByRowColumn[1, 1]);
	self.assertEqualMsg(ti.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[1, 1], "Did not move TEST0000011 to correct location");
	
	osTI:= self.addContainerOpts("TEST0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(osTI, "TEST0000002");
	self.move(osTI ,taSource.allGridControllersByRowColumn[2, 2]);
	self.assertEqualMsg(osTI.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[2, 2], "Did not move TEST0000002 to correct location");
	
	nextTI:= self.addContainerOpts("TEST0000003", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(nextTI, "TEST0000003");
	self.move(nextTI ,taSource.allGridControllersByRowColumn[3, 3]);
	self.assertEqualMsg(nextTI.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[3, 3], "Did not move TEST0000003 to correct location");
	
	// into the second area
	otherTI:= self.addContainerOpts("TEST0000004", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(otherTI, "TEST0000004");
	self.move(otherTI ,taSource2.allGridControllersByRowColumn[1, 1]);
	self.assertEqualMsg(otherTI.myPrimaryActualLocation, taSource2.allGridControllersByRowColumn[1, 1], "Did not move TEST0000004 to correct location");

	// Create the Release
	self.opts.purge();
	self.opts.addAssoc("ISOType", "2200");
	self.opts.addAssoc("FullRelease", true);
	releaseRequest := addReleaseByTypeRequestOpts("UTRRRoad", BR_TYPE_ROAD, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	
	// Gate Out
	self.opts.purge();
	self.opts.addAssoc("release", releaseRequest);
	vvr := self.gateOutContainer("UTTRUCK", "", "UTDRIVER", null, true, singleGate ,null);
	
	truck := self.getVehicle("UTTRUCK");
	assertEqual(truck.allRoadJobs.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.size, 1);

	// actual test
	// create yard allocations to be used in set setISOSource
	//locations are Top Left &amp; bottom Right
	create locations transient;
	locations.add(taSource2.allGridControllersByRowColumn[1, 4]);
	locations.add(taSource2.allGridControllersByRowColumn[3, 6]);
	
	self.deleteYA("UT");
	containers := "20";
	ya := self.addYA1("UT", YACriteriaType_ContainerLength, containers, locations);
	assertNotNullMsg(ya, "UT Yard Allocation");

	wle := releaseRequest.allRequestsBeingActioned.first.allWorkListEntries.first;
	// Apr 2010 the failure now raises an error message
	self.expectTrxError(Must_unque_befor_sourc_loc);  // 86030. This job must be unqueued before a new source location can be selected.
	self.expectTrxError(Request_failed_auto_plan);  // 84880. Request failed to auto plan
	self.setISOSource(wle, taSource2);

	// should be a single queue entry from setISOSource, with source location of UTSTRD
	// currently the auto-plan fails and nothing is queued
	//qe := wle.allRTQueueEntries.first;
	//if qe &lt;&gt; null then
	//assertEqual(qe.allTasks.first.sourceLocation.ident, taSource2.id);
	//endif;
	self.assertNoTrxErrorsOrWarnings();

epilog
	delete locations;
	self.disableAllYA(false);
end;
</source>
    </JadeMethod>
    <JadeMethod name="tSelectISOSource4" id="035f4cfe-dd8b-421d-998b-92e36e5bccf5">
        <source>tSelectISOSource4();
// cnwns1
/* cnwjre1
	select a gridded area as the source, auto-plan fails, best-fit finds the area
	but not the given one
*/

vars
	containers : String;
	taSource : CM_ForkLiftStack;
	taSource2 : CM_StraddleStack;
	taSource3 : CM_StraddleStack;
	ti, nextTI, osTI,
	otherTI : CM_TrackedItem;
	releaseRequest: CM_BulkRelease;
	truck: CM_Vehicle;
	vvr: CM_VehicleVisitRecord;
	singleGate: CM_Gate;
	wle : CM_WorkListEntry;
	qe : CM_RTQueueEntry;
	ya : CM_YardAllocation;
	lc : CM_LocationsController;
	locations : CM_LCArray;
	source: CM_LocationsController;
	yaName: String;
begin
	self.disableAllYA(true);
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	deleteTerminalArea("UTFORK");
	taSource := self.addForkLiftStack("UTFORK", 6, 5, 2);
	assertNotNullMsg(taSource, "UTFORK");

	deleteTerminalArea("UTSTRD");
	taSource2 := addStraddleStack("UTSTRD", 3, 8, 2);
	assertNotNullMsg(taSource2, "UTSTRD");
	
	deleteTerminalArea("UTSTRD2");
	taSource3 := addStraddleStack("UTSTRD2", 3, 8, 2);
	assertNotNullMsg(taSource3, "UTSTRD2");

	self.deleteContainer("TEST0000011");
	self.deleteContainer("TEST0000002");
	self.deleteContainer("TEST0000003");
	self.deleteContainer("TEST0000004");
	self.deleteVehicle("UTTRUCK");

	// add containers for different ISO types than required
	// add as STORAGE so the best pick will find them
	self.opts.addAssoc("IMEX", TI_IMEX_STATUS_STORAGE);
	self.opts.addAssoc("Width", "200");
	ti := self.addContainerOpts("TEST0000011", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(ti, "TEST0000011");
	self.move(ti ,taSource.allGridControllersByRowColumn[1, 1]);
	self.assertEqualMsg(ti.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[1, 1], "Did not move TEST0000011 to correct location");
	
	osTI:= self.addContainerOpts("TEST0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(osTI, "TEST0000002");
	self.move(osTI ,taSource.allGridControllersByRowColumn[2, 2]);
	self.assertEqualMsg(osTI.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[2, 2], "Did not move TEST0000002 to correct location");
	
	nextTI:= self.addContainerOpts("TEST0000003", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(nextTI, "TEST0000003");
	self.move(nextTI ,taSource.allGridControllersByRowColumn[3, 3]);
	self.assertEqualMsg(nextTI.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[3, 3], "Did not move TEST0000003 to correct location");
	
	// into the second area - this is the container matching the criteria
	otherTI:= self.addContainerOpts("TEST0000004", "2210", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(otherTI, "TEST0000004");
	self.move(otherTI ,taSource2.allGridControllersByRowColumn[1, 1]);
	self.assertEqualMsg(otherTI.myPrimaryActualLocation, taSource2.allGridControllersByRowColumn[1, 1], "Did not move TEST0000004 to correct location");

	// Create the Release
	self.opts.purge();
	self.opts.addAssoc("ISOType", "2210");
	self.opts.addAssoc("FullRelease", true);
	releaseRequest := addReleaseByTypeRequestOpts("UTRRRoad", BR_TYPE_ROAD, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	
	// Gate Out
	
	self.opts.purge();
	self.opts.addAssoc("release", releaseRequest);
	vvr := self.gateOutContainer("UTTRUCK", "", "UTDRIVER", null, true, singleGate ,null);
	
	truck := self.getVehicle("UTTRUCK");
	assertEqual(truck.allRoadJobs.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.size, 1);

	// actual test
	// create yard allocations to be used in set setISOSource
	//locations are Top Left &amp; bottom Right
	create locations transient;
	locations.add(taSource2.allGridControllersByRowColumn[1, 1]);
	locations.add(taSource2.allGridControllersByRowColumn[3, 6]);
	
	self.deleteYA("UT");
	containers := "20";
	ya := self.addYA1("UT", YACriteriaType_ContainerLength, containers, locations);
	assertNotNullMsg(ya, "UT Yard Allocation");

	wle := releaseRequest.allRequestsBeingActioned.first.allWorkListEntries.first;
	// this should find the container in taSource2.  taSource3 is actually empty.
	// Apr 2010 the failure now raises an error message
	self.expectTrxError(Must_unque_befor_sourc_loc);  // 86030. This job must be unqueued before a new source location can be selected.
	self.expectTrxError(Request_failed_auto_plan);  // 84880. Request failed to auto plan
	self.setISOSource(wle, taSource3);

epilog
	delete locations;
	self.disableAllYA(false);
end;
</source>
    </JadeMethod>
    <JadeMethod name="tSelectISOSource5" id="c5727736-3fcf-44a4-a641-f0642e40036d">
        <source>tSelectISOSource5();
//cnwndl1
/*

Purpose:			

Parameters:		Select Term area for release by type with best pick ( but no matching cargo in area )
				should not create job at attempt to enqueueRequest from RTQueueArbiter

Return Value:		


Date		Who		Reason
24 May 2011	cnwndl1	Initial creation	Par 27524

*/

vars
	mtStrategy : Integer;
	resetStrategyTo : Integer;
	taSource, otherSource: CM_ForkLiftStack;
	ti, otherTI : CM_TrackedItem;
	releaseRequest: CM_BulkRelease;
	truck: CM_Vehicle;
	vvr: CM_VehicleVisitRecord;
	singleGate: CM_Gate;
	wle : CM_WorkListEntry;
	qe : CM_RTQueueEntry;
begin

	self.setTerminalConfig(AutoPlanMTReleaseStrategy, AutoPlanMTRelStrategyTerminal);
	
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	deleteTerminalArea("UTFORK2");
	taSource:= self.addForkLiftStack("UTFORK2", 6, 5, 2);
	assertNotNullMsg(taSource, "UTFORK2");
	
	deleteTerminalArea("UTFORK3");
	otherSource:= self.addForkLiftStack("UTFORK3", 6, 5, 2);
	assertNotNullMsg(otherSource, "UTFORK3");
	
	self.deleteContainer("TEST0000501");
	self.deleteContainer("TEST0000502");
	self.deleteVehicle("UTTRUCK");

	self.opts.addAssoc("Width", "200");
	self.opts.addAssoc(UTTI_IMEX, TI_IMEX_STATUS_STORAGE);
	ti := self.addContainerOpts("TEST0000501", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(ti, "TEST0000501");
	self.move(ti ,taSource.allGridControllersByRowColumn[1, 1]);
	self.assertEqualMsg(ti.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[1, 1], "Did not move TEST0000501 to correct location");
	
	otherTI := self.addContainerOpts("TEST0000502", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(otherTI, "TEST0000502");
	self.move(otherTI ,otherSource.allGridControllersByRowColumn[1, 1]);
	self.assertEqualMsg(otherTI.myPrimaryActualLocation, otherSource.allGridControllersByRowColumn[1, 1], "Did not move TEST0000502 to correct location");

	// Create the Release
	self.opts.purge();
	self.opts.addAssoc("ISOType", "2200");
	self.opts.addAssoc("TerminalArea", taSource);
	self.opts.addAssoc("BestPick", true);
	releaseRequest := addReleaseByTypeRequestOpts("UTRRRoad", BR_TYPE_ROAD, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	
	// Create the jobs to gate out
	self.opts.purge();
	self.opts.addAssoc("release", releaseRequest);
	vvr := self.gateOutContainer("UTTRUCK", "", "UTDRIVER", null, true, singleGate ,null);
	
	truck := self.getVehicle("UTTRUCK");
	assertEqual(truck.allRoadJobs.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.size, 1);

	// actual test
	wle := releaseRequest.allRequestsBeingActioned.first.allWorkListEntries.first;
	assertNotNull(wle);
	assertNull(wle.myTrackedItem);	

epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="tSelectISOSource6" id="40f19e8b-934f-4635-997d-d074859dda46">
        <source>tSelectISOSource6();
// cnwns1
// cnwjre1
/* cnwrd1
	select a block stack as the source, autoplan fails, change source location to gbs and succeed.
	to test that setISOSource overrides the release request reserve details terminal area.
*/

vars
	containers : String;
	taSource : CM_ForkLiftStack;
	taSource2 : CM_StraddleStack;
	ti, nextTI, osTI,
	otherTI : CM_TrackedItem;
	releaseRequest: CM_BulkRelease;
	truck: CM_Vehicle;
	vvr: CM_VehicleVisitRecord;
	singleGate: CM_Gate;
	wle : CM_WorkListEntry;
	qe : CM_RTQueueEntry;
	ya : CM_YardAllocation;
	lc : CM_LocationsController;
	locations : CM_LCArray;
	source: CM_LocationsController;
	yaName: String;
begin
	self.disableAllYA(true);
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	deleteTerminalArea("UTFORK");
	taSource := self.addForkLiftStack("UTFORK", 6, 5, 2);
	assertNotNullMsg(taSource, "UTFORK");
	
	self.deleteContainer("TEST0000011");
	self.deleteContainer("TEST0000002");
	self.deleteVehicle("UTTRUCK");


	self.opts.addAssoc("Width", "200");
	self.opts.addAssoc(UTTI_IMEX, TI_IMEX_STATUS_STORAGE);
	ti := self.addContainerOpts("TEST0000011", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(ti, "TEST0000011");
	self.move(ti ,taSource.allGridControllersByRowColumn[1, 1]);
	self.assertEqualMsg(ti.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[1, 1], "Did not move TEST0000011 to correct location");
	
	osTI:= self.addContainerOpts("TEST0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(osTI, "TEST0000002");
	self.move(osTI ,taSource.allGridControllersByRowColumn[2, 2]);
	self.assertEqualMsg(osTI.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[2, 2], "Did not move TEST0000002 to correct location");


	// Create the Release
	self.opts.purge();
	self.opts.addAssoc("ISOType", "2200");
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("TerminalArea", bs1); //add BS1 as the source location now
	releaseRequest := addReleaseByTypeRequestOpts("UTRRRoad", BR_TYPE_ROAD, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	
	// Gate Out
	self.opts.purge();
	self.opts.addAssoc("release", releaseRequest);
	self.expectTrxError(Request_failed_auto_plan);  // this should fail as BS1 should have no matching cargo or YA
	vvr := self.gateOutContainer("UTTRUCK", "", "UTDRIVER", null, true, singleGate ,null);
	
	truck := self.getVehicle("UTTRUCK");
	assertEqual(truck.allRoadJobs.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.size, 1);


	create locations transient;
	locations.add(taSource.allGridControllersByRowColumn[1, 1]);
	locations.add(taSource.allGridControllersByRowColumn[2, 2]);
	
	self.deleteYA("UT");
	containers := "20";
	ya := self.addYA1("UT", YACriteriaType_ContainerLength, containers, locations);
	assertNotNullMsg(ya, "UT Yard Allocation");

	wle := releaseRequest.allRequestsBeingActioned.first.allWorkListEntries.first;

	self.clearExpectedTrxErrors();
	// this should queue OK
	self.setISOSource(wle, taSource);
	self.assertNoTrxErrorsOrWarnings();

epilog
	delete locations;
	self.disableAllYA(false);
end;
</source>
    </JadeMethod>
    <JadeMethod name="tSelectISOSourceMulti1" id="86983d43-267e-4cc1-8121-f052e0b1b566">
        <source>tSelectISOSourceMulti1();
// cnwns1
// cnwjre1
/* cnwrd1
	select a block stack as the source, no yard allocations involved
*/

vars
	taSource: CM_ForkLiftStack;
	ti, nextTI, osTI,
	otherTI : CM_TrackedItem;
	releaseRequest: CM_BulkRelease;
	truck: CM_Vehicle;
	vvr: CM_VehicleVisitRecord;
	singleGate: CM_Gate;
	wle : CM_WorkListEntry;
	qe : CM_RTQueueEntry;	
	wles : CM_WLEArray;
	termAreas : CM_TerminalAreaArray;
	termAreaGridObjects : CM_GridObjectArray;
begin
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	deleteTerminalArea("UTFORK");
	taSource:= self.addForkLiftStack("UTFORK", 6, 5, 2);
	assertNotNullMsg(taSource, "UTFORK");
	
	self.deleteContainer("TEST0000001");
	self.deleteContainer("TEST0000002");
	self.deleteContainer("TEST0000003");
	self.deleteContainer("TEST0000004");
	self.deleteVehicle("UTTRUCK");


	self.opts.addAssoc("Width", "200");
	self.opts.addAssoc(UTTI_IMEX, TI_IMEX_STATUS_STORAGE);
	ti := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(ti, "TEST0000001");
	self.move(ti ,taSource.allGridControllersByRowColumn[1, 1]);
	self.assertEqualMsg(ti.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[1, 1], "Did not move TEST0000001 to correct location");
	
	osTI:= self.addContainerOpts("TEST0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(osTI, "TEST0000002");
	self.move(osTI ,taSource.allGridControllersByRowColumn[2, 2]);
	self.assertEqualMsg(osTI.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[2, 2], "Did not move TEST0000002 to correct location");
	
	nextTI:= self.addContainerOpts("TEST0000003", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(nextTI, "TEST0000003");
	self.move(nextTI ,taSource.allGridControllersByRowColumn[3, 3]);
	self.assertEqualMsg(nextTI.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[3, 3], "Did not move TEST0000003 to correct location");
	
	otherTI:= self.addContainerOpts("TEST0000004", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(otherTI, "TEST0000004");
	self.move(otherTI ,bs1.myLocationsController);
	self.assertEqualMsg(otherTI.myPrimaryActualLocation, bs1.myLocationsController, "Did not move TEST0000004 to correct location");

	// Create the Release
	self.opts.purge();
	self.opts.addAssoc("ISOType", "2200");
	self.opts.addAssoc("FullRelease", true);
	releaseRequest := addReleaseByTypeRequestOpts("UTRRRoad", BR_TYPE_ROAD, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	
	// Gate Out
	self.opts.purge();
	self.opts.addAssoc("release", releaseRequest);
	vvr := self.gateOutContainer("UTTRUCK", "", "UTDRIVER", null, true, singleGate ,null);
	
	truck := self.getVehicle("UTTRUCK");
	assertEqual(truck.allRoadJobs.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.size, 1);

	// actual test
	
	create wles transient;
	create termAreas transient;
	create termAreaGridObjects transient;
	
	// this should replan the wle's according to the ta list and availability
	releaseRequest.allRequestsBeingActioned.first.allWorkListEntries.copy( wles);	
	termAreas.add(bs1);
	termAreas.add(bs2);
	
	// wle array, term areas, bestpick, fifo
	self.setISOSourceMulti( wles, termAreas,termAreaGridObjects, false, false);
	
	// should be a single queue entry from setISOSource, with source location of bs1
	if not wles.isEmpty then
		wle := wles.first;
		qe := wle.allRTQueueEntries.first;
		assertEqual(qe.allTasks.first.sourceLocation.ident, bs1.id);
	else
		
	endif;

epilog
	delete wles;
	delete termAreas;
	delete termAreaGridObjects;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tTestAutoPlanRelReq" id="0139bb22-15a7-4d5f-a749-2966695cdfd6">
        <updating/>
        <source>tTestAutoPlanRelReq() updating;
/*

Purpose:			TFS 1779

Date		Who		Reason
08 April 2016	cnwmk3	Initial creation

*/
constants
	ReleaseId1			= "UT_REL01";
vars
	ya1, ya2			: CM_YardAllocation;
	ti1, ti2			: CM_TrackedItem;
	releaseRequest		: CM_BulkRelease;
	vvr					: CM_VehicleVisitRecord;
	tiArray				: CM_TIArray;
	source 				: CM_LocationsController;
	cmifYARequest 		: CMIF_YAAutoPlan;
	task				: CM_RTQueueTask;
	gcArea				: CM_IrregularBlockArea;
	ground				: CM_IrregularBlockController;
	mtReleaseStrategy	: Integer;
begin
	mtReleaseStrategy := self.setTerminalConfig(AutoPlanMTReleaseStrategy, AutoPlanMTRelStrategyBoth).Integer;
	self.disableAllYA(true);
	// block stack
	self.deleteTerminalArea("BS01");
	bs1 := self.addBlockStack("BS01", 5, null);
	
	// add yard allocation
	ya1 := self.addYA1("UT_YA", null, null, bs1.myLocationsController);
	self.assertNotNull(ya1);
	
	// add containers
	self.deleteContainer("CONTR00001");
	ti1 := self.addContainerAtLocation("CONTR00001", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), "2200", "MT", TI_IMEX_STATUS_IMPORT, bs1.myLocationsController);
	self.assertNotNull(ti1);
	
	// Create a ROAD release by type for empty containers.  Set the total requested to a big number say '100'.
	self.opts.addAssoc("Number", 100);
	self.opts.addAssoc("ISOType", "2200");
	self.opts.addAssoc("CreateDeliveryRequest", true);
	releaseRequest := self.addReleaseByTypeRequestOpts(ReleaseId1, BR_TYPE_ROAD, TI_CargoType_Container);
	
	// Make sure that the expected source is found by autoplan
	self.deleteStops(ti1);
	source := app.sourceTisForRequestYA(self.getTerminal(), releaseRequest.requests.first);
	assertNotNullMsg(source, getYAAutoPlanMessages);
	assertEqual(source.getName(), bs1.myLocationsController.getName());
	self.assertTrueMsg( app.myYAAgent &lt;&gt; null, "No YAAgent for 'request'" );
	cmifYARequest := app.myYAAgent.myCMIFYAAutoPlan;
	self.assertTrueMsg( cmifYARequest &lt;&gt; null, "No CMIF on the YA Agent for 'request'" );
	self.assertTrueMsg( cmifYARequest.allKeepTrackedTis.first.id = "CONTR00001", "First Ti found for 'request' should be " &amp; "CONTR00001" );
	
	// gate in truck for release ti1
	self.deleteVehicle("UT_TRK");
	self.opts.purge();
	self.opts.addAssoc("release", releaseRequest);
	
	create tiArray transient;
	tiArray.add(ti1);
	
	self.deleteStops(ti1);
	vvr := self.gateOutContainer("UT_TRK", "", "", tiArray[1].CM_Container, true, 
		self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString), null);
	self.assertNotNull(vvr);
	
	// The director task created should become RT queued
	task := ti1.getDirectorOrPickupTask();
	self.assertNotNull(task);
	beginTransaction;
	task.setStatusUnactioned();
	commitTransaction;
	self.assertEqual(task.status, TASK_PICKUP);
	
	self.deleteStops(tiArray[1].CM_TrackedItem);
	
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	
	self.disableAllYA(true);
	// add general cargo area
	gcArea := self.addGeneralCargoArea("UT_GC", "", 5, 5, 10, null, null);
	self.assertNotNull(gcArea);
	
	self.opts.purge();
	self.opts.addAssoc( "LocationType",  GC_GroundLocation );
	ground := self.addGCRackOrGround(gcArea,3,4,3,4,"GC01");
	
	// add yard allocation for general cargo area
	ya2 := self.addYA1("UT_GC", null, null, ground);
	self.assertNotNull(ya2);
	
	self.deleteContainer("CONTR00002");
	ti2 := self.addContainerAtLocation("CONTR00002", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), "2200", "MT", TI_IMEX_STATUS_IMPORT, ground);
	self.assertNotNull(ti2);
	
	// Make sure that the expected source is found by autoplan
	self.deleteStops(ti2);
	source := app.sourceTisForRequestYA(self.getTerminal(), releaseRequest.requests.first);
	assertNotNullMsg(source, getYAAutoPlanMessages);
	assertEqual(source.getName(), ground.getName());
	self.assertTrueMsg( app.myYAAgent &lt;&gt; null, "No YAAgent for 'request'" );
	cmifYARequest := app.myYAAgent.myCMIFYAAutoPlan;
	self.assertTrueMsg( cmifYARequest &lt;&gt; null, "No CMIF on the YA Agent for 'request'" );
	self.assertTrueMsg( cmifYARequest.allKeepTrackedTis.first.id = "CONTR00002", "First Ti found for 'request' should be " &amp; "CONTR00002" );
	
	// gate in truck for release ti2
	self.deleteVehicle("UT_TRK");
	self.opts.purge();
	self.opts.addAssoc("release", releaseRequest);
	
	tiArray.add(ti2);
	
	vvr := self.gateOutContainer("UT_TRK", "", "", tiArray[2].CM_Container, true, 
		self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString), null);
	self.assertNotNull(vvr);
	
	// The director task created should become RT queued
	task := ti2.getDirectorOrPickupTask();
	self.assertNotNull(task);
	beginTransaction;
	task.setStatusUnactioned();
	commitTransaction;
	self.assertEqual(task.status, TASK_PICKUP);
	
	self.deleteStops(tiArray[2].CM_TrackedItem);
	
	self.workVehicle(vvr);
	self.roadExit(vvr);
epilog
	self.setTerminalConfig(AutoPlanMTReleaseStrategy, mtReleaseStrategy);
	self.disableAllYA(false);
	delete tiArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="tYABestpick" id="036b2afb-cecc-45e3-b9c8-a95604d653c2">
        <source>tYABestpick();
// cnwndl1
//24 February 2010	cnwdw1	
//
vars
	locations : CM_LCArray;
	ti1, ti2, ti3: CM_TrackedItem;
	ya: CM_YardAllocation;
	ta1, ta2: CM_GridArea;
	yaName: String;
	request: CM_Request;
	source: CM_LocationsController;
	newOp	: CM_Operator;
	autoPlanMTReleaseStrategy : Integer;
begin
	self.disableAllYA(true);
	newOp := self.getOperator("TEST");
	
	self.deleteContainer("TEST0000001");
	ti1 := self.addContainer("TEST0000001", self.operator,"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.deleteContainer("TEST0000002");
	ti2 := self.addContainer("TEST0000002", self.operator,"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.deleteContainer("TEST0000003");
	ti3 := self.addContainer("TEST0000003", newOp,"2200", "MT", TI_IMEX_STATUS_STORAGE);
	// Remove all automatic stops
	self.deleteStops(ti1);
	self.deleteStops(ti2);
	self.deleteStops(ti3);

	deleteTerminalArea("UTSTRD");
	ta1:= addStraddleStack("UTSTRD", 6, 6, 2);
	deleteTerminalArea("UTSTRDX");
	ta2:= addStraddleStack("UTSTRDX", 6, 6, 2);
	
	create locations transient;
	locations.add(ta1.allGridControllersByRowColumn[1, 1]);
	locations.add(ta1.allGridControllersByRowColumn[2, 6]);
	
	yaName := self.getProfileSetting(UT_Profile.P_YA).asString;
	self.deleteYA(yaName);
	ya := self.addYA1WithFill(yaName, YACriteriaType_OperatorItem, self.operator.code, locations, YAFillOption_InOrder, YAFillOption_BestPick,false);

	self.move(ti1, ta1.allGridControllersByRowColumn[1, 1]);  // this is overstowed
	self.move(ti2, ta1.allGridControllersByRowColumn[1, 1]);	 // this is the best pick
	self.move(ti3, ta1.allGridControllersByRowColumn[2, 1]);	 // this is a different operator

	self.setTerminalConfig(AutoPlanMTReleaseStrategy, AutoPlanMTRelStrategyYA);

	request := self.createRequest(self.operator.code, null);
	source := app.sourceTisForRequestYA(self.getTerminal(), request);
	assertNotNullMsg(source, getYAAutoPlanMessages);
	assertEqual(app.myYAAgent.myCurrentCMIFYAAutoPlan.allFoundTis.size, 1);
	assertEqual(app.myYAAgent.myCurrentCMIFYAAutoPlan.allFoundTis.first, ti2);

	// Make sure can find cargo when we specify an area
	delete request;
	request := self.createRequest(self.operator.code, ta1);
	source := app.sourceTisForRequestYA(self.getTerminal(), request);
	assertNotNullMsg(source, getYAAutoPlanMessages);
	assertEqual(app.myYAAgent.myCurrentCMIFYAAutoPlan.allFoundTis.size, 1);
	assertEqual(app.myYAAgent.myCurrentCMIFYAAutoPlan.allFoundTis.first, ti2);
	
	// Make sure dont find cargo when we specify an mt area
	delete request;
	request := self.createRequest(self.operator.code, ta2);
	source := app.sourceTisForRequestYA(self.getTerminal(), request);
	assertNull(source);
	
epilog
	delete request;
	delete locations;
	self.disableAllYA(false);
end;
</source>
    </JadeMethod>
    <JadeMethod name="tYABestpick2" id="5d419be9-ce69-4cae-8a2d-75a4fdd9a76d">
        <source>tYABestpick2();
// cnwndl1
//24 February 2010	cnwdw1	
// all matching containers are overstowed, it should find the least-overstowed
vars
	locations : CM_LCArray;
	ti1, ti2, ti3, ti4: CM_TrackedItem;
	ya: CM_YardAllocation;
	ta: CM_GridArea;
	yaName: String;
	request: CM_Request;
	source: CM_LocationsController;
	newOp	: CM_Operator;
	autoPlanMTReleaseStrategy : Integer;
begin
	self.disableAllYA(true);
	newOp := self.getOperator("TEST");
	
	self.deleteContainer("TEST0000001");
	ti1 := self.addContainer("TEST0000001", self.operator,"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.deleteContainer("TEST0000002");
	ti2 := self.addContainer("TEST0000002", self.operator,"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.deleteContainer("TEST0000003");
	ti3 := self.addContainer("TEST0000003", newOp,"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.deleteContainer("TEST0000004");
	ti4 := self.addContainer("TEST0000004", newOp,"2200", "MT", TI_IMEX_STATUS_STORAGE);
	// Remove all automatic stops
	self.deleteStops(ti1);
	self.deleteStops(ti2);
	self.deleteStops(ti3);
	self.deleteStops(ti4);

	deleteTerminalArea("UTSTRD");
	ta:= addStraddleStack("UTSTRD", 6, 6, 4);

	
	create locations transient;
	locations.add(ta.allGridControllersByRowColumn[1, 1]);
	locations.add(ta.allGridControllersByRowColumn[2, 6]);
	
	yaName := self.getProfileSetting(UT_Profile.P_YA).asString;
	self.deleteYA(yaName);
	ya := self.addYA1WithFill(yaName, YACriteriaType_OperatorItem, self.operator.code, locations, YAFillOption_InOrder, YAFillOption_BestPick,false);

	self.move(ti1, ta.allGridControllersByRowColumn[1, 1]);  // this is overstowed
	self.move(ti2, ta.allGridControllersByRowColumn[1, 1]);	 // this is also overstowed but is still the best pick
	self.move(ti3, ta.allGridControllersByRowColumn[1, 1]);	//  this is a different operator
	self.move(ti4, ta.allGridControllersByRowColumn[1, 1]);	//  this is a different operator

	self.setTerminalConfig(AutoPlanMTReleaseStrategy, AutoPlanMTRelStrategyYA);

	request := self.createRequest(self.operator.code, null);
	source := app.sourceTisForRequestYA(self.getTerminal(), request);
	assertNotNullMsg(source, getYAAutoPlanMessages);
	assertEqual(app.myYAAgent.myCurrentCMIFYAAutoPlan.allFoundTis.size, 1);
	assertEqual(app.myYAAgent.myCurrentCMIFYAAutoPlan.allFoundTis.first, ti2);

epilog
	delete request;
	delete locations;
	self.disableAllYA(false);
end;
</source>
    </JadeMethod>
    <JadeMethod name="uGetOperatorMTDict" id="c7cdaa9e-9ca3-4a75-b33c-e3ae1ca4e8ff">
        <source>uGetOperatorMTDict();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 June 2012	cnwdw1	Initial creation
*/
vars
	operatorName: String;
	operator: CM_Operator;
	operatorTerminal: CM_OperatorTerminal;
begin
	
	operatorName := "Operator";
	read operatorName;
	
	operator := self.getOperator(operatorName);
	if operator &lt;&gt; null then
		operatorTerminal := operator.getOperatorTerminal(self.getTerminal, false);
		if operatorTerminal &lt;&gt; null then
			operatorTerminal.allOnsiteMTContsByISOType.inspectModal;
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="unitTestBeforeClass" id="fc4fe3eb-fd87-4ed7-8a7e-f37dfdb9a205">
        <updating/>
        <source>unitTestBeforeClass() updating, protected;
//18 December 2008	cnwdw1	
//
vars
		
begin
	inheritMethod;
	
	self.deleteTerminalArea(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString);
	bs1 := addBlockStack(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString, 100, null);
	self.deleteTerminalArea(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString&amp;"2");
	bs2 := addBlockStack(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString&amp;"2", 100, null);
	operator := getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
