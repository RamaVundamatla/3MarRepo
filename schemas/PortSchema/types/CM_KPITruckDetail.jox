    <JadeMethod name="updateFromVisitRecord" id="059621e9-4bc7-4c18-ab26-2d2c597402d4">
        <updating/>
        <source>updateFromVisitRecord(_visit : CM_VehicleVisitRecord) updating;
// ---------------------------------------------------------------------------
// Created:		14 February 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	
begin

	self.myVisitRecord :=_visit;
	self.dwellSeconds := _visit.dwellTimeMinutes;		// PAR 16390
	self.sortCarrier := _visit.vehicle.carrierCode;
	
end;</source>
        <Parameter name="_visit" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
