vars

begin
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="053fd66c-c07a-4f20-aaac-07309767f045">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     03 May 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.id = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Description) , null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Description) , null, null); // cnwdb2	PAR 35364
	endif;	
	if self.allYardControllers.isEmpty then 
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Loc), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Loc), null, null); // cnwdb2	PAR 35364
	endif;	
end;</source>
    </JadeMethod>
</Class>
