    <JadeMethod name="convertBaseToTarget" id="84f25557-d057-4555-9797-f414cb5bd1ac">
        <source>convertBaseToTarget(pMeasure: Real; pUnitTo: Integer): Real protected;
// --------------------------------------------------------------------------------
// Created:		27 May 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	convertedMeasure	: Real;
	
begin
	if pUnitTo = self.ACRES then
		convertedMeasure	:=	pMeasure / 4046.8564224;
		
	elseif pUnitTo = self.ARES then
		convertedMeasure	:=	pMeasure / 100;

	elseif pUnitTo = self.CIRCULAR_INCHES then
		convertedMeasure	:=	pMeasure / 0.000506707479;

	elseif pUnitTo = self.HECTARES then
		convertedMeasure	:=	pMeasure / 10000;

	elseif pUnitTo = self.HIDES then
		convertedMeasure	:=	pMeasure / 485000;

	elseif pUnitTo = self.ROODS then
		convertedMeasure	:=	pMeasure / 1011.7141056;

	elseif pUnitTo = self.SQUARES_TIMBER then
		convertedMeasure	:=	pMeasure / 9.290304;

	elseif pUnitTo = self.SQUARE_CENTIMETRES then
		convertedMeasure	:=	pMeasure / 0.0001;

	elseif pUnitTo = self.SQUARE_FEET then
		convertedMeasure	:=	pMeasure / 0.09290304;

	elseif pUnitTo = self.SQUARE_FEET_US_SURVEY then
		convertedMeasure	:=	pMeasure / 0.092903411613;

	elseif pUnitTo = self.SQUARE_INCHES then
		convertedMeasure	:=	pMeasure / 0.00064516;

	elseif pUnitTo = self.SQUARE_KILOMETRES then
		convertedMeasure	:=	pMeasure / 1000000;

	elseif pUnitTo = self.SQUARE_METRES then
		convertedMeasure	:=	pMeasure;

	elseif pUnitTo = self.SQUARE_MILES_INT then
		convertedMeasure	:=	pMeasure / 2589988.110336;

	elseif pUnitTo = self.SQUARE_MILLIMETRES then
		convertedMeasure	:=	pMeasure / 0.000001;

	elseif pUnitTo = self.SQUARE_RODS then
		convertedMeasure	:=	pMeasure / 25.29285264;

	elseif pUnitTo = self.SQUARE_YARDS then
		convertedMeasure	:=	pMeasure / 0.83612736;

	elseif pUnitTo = self.TOWNSHIPS then
		convertedMeasure	:=	pMeasure / 93239571.972;

	else
		CnEcBaseSchemaException.raise_(CNEC_X_12004, "[" &amp; pUnitTo.String &amp; "] is an unknown unit of area to convert to.");

	endif;
epilog
	return convertedMeasure;
end;</source>
        <access>protected</access>
        <Parameter name="pMeasure" type="Real"/>
        <Parameter name="pUnitTo" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="convertToBaseUnit" id="028c5c8f-89b1-420a-8955-e2146c66008e">
        <source>convertToBaseUnit(pUnitFrom: Integer): Real protected;
// --------------------------------------------------------------------------------
// Created:		27 May 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	convertedMeasure	: Real;
	
begin
	if pUnitFrom = self.ACRES then
		convertedMeasure	:=	self.measure * 4046.8564224;
		
	elseif pUnitFrom = self.ARES then
		convertedMeasure	:=	self.measure * 100;

	elseif pUnitFrom = self.CIRCULAR_INCHES then
		convertedMeasure	:=	self.measure * 0.000506707479;

	elseif pUnitFrom = self.HECTARES then
		convertedMeasure	:=	self.measure * 10000;

	elseif pUnitFrom = self.HIDES then
		convertedMeasure	:=	self.measure * 485000;

	elseif pUnitFrom = self.ROODS then
		convertedMeasure	:=	self.measure * 1011.7141056;

	elseif pUnitFrom = self.SQUARES_TIMBER then
		convertedMeasure	:=	self.measure * 9.290304;

	elseif pUnitFrom = self.SQUARE_CENTIMETRES then
		convertedMeasure	:=	self.measure * 0.0001;

	elseif pUnitFrom = self.SQUARE_FEET then
		convertedMeasure	:=	self.measure * 0.09290304;

	elseif pUnitFrom = self.SQUARE_FEET_US_SURVEY then
		convertedMeasure	:=	self.measure * 0.092903411613;

	elseif pUnitFrom = self.SQUARE_INCHES then
		convertedMeasure	:=	self.measure * 0.00064516;

	elseif pUnitFrom = self.SQUARE_KILOMETRES then
		convertedMeasure	:=	self.measure * 1000000;

	elseif pUnitFrom = self.SQUARE_METRES then
		convertedMeasure	:=	self.measure;

	elseif pUnitFrom = self.SQUARE_MILES_INT then
		convertedMeasure	:=	self.measure * 2589988.110336;

	elseif pUnitFrom = self.SQUARE_MILLIMETRES then
		convertedMeasure	:=	self.measure * 0.000001;

	elseif pUnitFrom = self.SQUARE_RODS then
		convertedMeasure	:=	self.measure * 25.29285264;

	elseif pUnitFrom = self.SQUARE_YARDS then
		convertedMeasure	:=	self.measure * 0.83612736;

	elseif pUnitFrom = self.TOWNSHIPS then
		convertedMeasure	:=	self.measure * 93239571.972;

	else
		CnEcBaseSchemaException.raise_(CNEC_X_12003, "[" &amp; pUnitFrom.String &amp; "] is an unknown unit of area to convert from.");

	endif;
epilog
	return convertedMeasure;
end;</source>
        <access>protected</access>
        <Parameter name="pUnitFrom" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getAllUnits" id="ea618ab2-6801-41c7-97ee-ba265291b3a3">
        <source>getAllUnits(pAllUnits: IntegerArray input);
// --------------------------------------------------------------------------------
// Created:		10 May 2008 by Darrell
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	pAllUnits.add(self.ACRES);
	pAllUnits.add(self.ARES);
	pAllUnits.add(self.CIRCULAR_INCHES);
	pAllUnits.add(self.HECTARES);
	pAllUnits.add(self.HIDES);
	pAllUnits.add(self.ROODS);
	pAllUnits.add(self.SQUARES_TIMBER);
	pAllUnits.add(self.SQUARE_CENTIMETRES);
	pAllUnits.add(self.SQUARE_FEET);
	pAllUnits.add(self.SQUARE_FEET_US_SURVEY);
	pAllUnits.add(self.SQUARE_INCHES);
	pAllUnits.add(self.SQUARE_KILOMETRES);
	pAllUnits.add(self.SQUARE_METRES);
	pAllUnits.add(self.SQUARE_MILES_INT);
	pAllUnits.add(self.SQUARE_MILLIMETRES);
	pAllUnits.add(self.SQUARE_RODS);
	pAllUnits.add(self.SQUARE_YARDS);
	pAllUnits.add(self.TOWNSHIPS);
end;</source>
        <Parameter name="pAllUnits" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getUnitName" id="ae21fc56-ee05-4a1c-a87d-13111a24fb29">
        <source>getUnitName(pUnit: Integer): String;
// --------------------------------------------------------------------------------
// Created:		09 May 2008 by Darrell
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pUnit = self.ACRES then
		return "Acres";
	elseif pUnit = self.ARES then
		return "Ares";
	elseif pUnit = self.CIRCULAR_INCHES then
		return "Circular Inches";
	elseif pUnit = self.HECTARES then
		return "Hectares";
	elseif pUnit = self.HIDES then
		return "Hides";
	elseif pUnit = self.ROODS then
		return "Roods";
	elseif pUnit = self.SQUARES_TIMBER then
		return "Squares (Timber)";
	elseif pUnit = self.SQUARE_CENTIMETRES then
		return "Square Centimetres";
	elseif pUnit = self.SQUARE_FEET then
		return "Square Feet";
	elseif pUnit = self.SQUARE_FEET_US_SURVEY then
		return "Square Feet (US Survey)";
	elseif pUnit = self.SQUARE_INCHES then
		return "Square Inches";
	elseif pUnit = self.SQUARE_KILOMETRES then
		return "Square Kilometres";
	elseif pUnit = self.SQUARE_METRES then
		return "Square Metres";
	elseif pUnit = self.SQUARE_MILES_INT then
		return "Square Miles (International)";
	elseif pUnit = self.SQUARE_MILLIMETRES then
		return "Square Millimetres";
	elseif pUnit = self.SQUARE_RODS then
		return "Square Rods";
	elseif pUnit = self.SQUARE_YARDS then
		return "Square Yards";
	elseif pUnit = self.TOWNSHIPS then
		return "Townships";
	else
		CnEcBaseSchemaException.raise_(CNEC_X_12003, "[" &amp; pUnit.String &amp; "] is an unknown unit of Area to convert from.");
		return null;
	endif;
end;</source>
        <Parameter name="pUnit" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
