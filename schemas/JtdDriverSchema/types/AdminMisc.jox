    <JadeMethod name="runTest" id="ee4f4901-8938-4c90-83a9-6d3d6a06b01d">
        <updating/>
        <source>runTest():Integer updating;

vars
	sa:StringArray;
	meth:String;
begin
	create sa transient;
	sa.add('am002_CN_lstTest_click');
	sa.add('am004_CN_lstTest_dblClick');
	sa.add('am006_SPAF_cmbArea_click');
	sa.add('am008_CN_lstTest_click');
	sa.add('am010_CN_lstTest_dblClick');
	sa.add('am012_CN_lstTest_click');
	sa.add('am014_CN_lstTest_dblClick');
	sa.add('am016_CN_lstTest_click');
	sa.add('am018_CN_lstTest_dblClick');
	sa.add('am020_CN_lstTest_click');
	sa.add('am022_CN_lstTest_dblClick');
	sa.add('am024_CN_lstTest_click');
	sa.add('am026_CN_lstTest_dblClick');
	sa.add('am028_GRRF_picture_click');
	sa.add('am999_tidyUp');

	foreach meth in sa do
		if meth[6:2] &lt;&gt; "v_" then
			app.doWindowEvents(longPause);
		endif;
		userPreTransaction(meth);
		retCode:=self.sendMsg(meth).Integer;
		userPostTransaction(meth);
		if app.atcgReplayFailure then
			app.atcgReplayFailure:=false;
			break;
		elseif retCode = 0 then
			app.logMessage("Test "&amp;self.class.name&amp;"::"&amp;meth&amp;" succeeded");
		else
			app.logMessage("Test "&amp;self.class.name&amp;"::"&amp;meth&amp;" failed with error code "&amp;retCode.String);
			break;
		endif;
	endforeach;
	app.atcgDetectMissedMsgBoxes;
	app.logMessage("Finished");
	return 0;
epilog
	delete sa;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
