    <JadeMethod name="buildFloorTypeCombo" id="e0aa29b0-6224-471d-aa08-9f83f7f748b7">
        <source>buildFloorTypeCombo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2025	navcs2	MTN-34843  Development - Fleet file Form implementation

*/

vars

begin
	self.cmbFloorType.addItemWithData(app.getErrorString(FloorType_UndefinedDesc), 0);
	self.cmbFloorType.addItemWithData(app.getErrorString(FloorType_FlooredDesc), 1);
	self.cmbFloorType.addItemWithData(app.getErrorString(FloorType_SkeletonDesc), 2);
	
	if self.myTiMaster &lt;&gt; null then
		self.cmbFloorType.setIndex(self.myTiMaster.floorType);
	endif;
epilog

end;</source>
    </JadeMethod>
