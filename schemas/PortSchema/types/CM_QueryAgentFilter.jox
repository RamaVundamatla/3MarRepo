    <JadeMethod name="qryRailRakeClear" id="e2b10f15-690d-4ef2-a6ef-d70d54cb590f">
        <updating/>
        <source>qryRailRakeClear(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;
//----------------------------------------------------------------
//	Created:	17 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

// cnwmd1, Method re-written for par 21850

vars
	numSelected 		: Integer;
