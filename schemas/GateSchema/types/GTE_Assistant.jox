    <JadeMethod name="showHideAttachmentFields" id="f1869891-5fa6-4e14-861b-96c23af5cfd8">
        <source>showHideAttachmentFields(pTable : CM_EntryTable io; pShow : Boolean);
// ---------------------------------------------------------------------------
// Created:     12 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx,
	addAttachRow	: Integer;
		
begin

	if pTable &lt;&gt; null then
		if pShow then
			addAttachRow := pTable.showRowByName(ETRow_AddAttachment, true);
		else
			addAttachRow := pTable.hideRowByName(ETRow_AddAttachment, true);
		endif;

		foreach idx in (addAttachRow + 1) to pTable.rows do
			if pTable.accessCell(idx, 1).text[1:6] = ATTACH_RowName then
				if pShow then
					pTable.showRow(idx);
				else
					pTable.hideRow(idx);
				endif;
			endif;
		endforeach;
	endif;
	
end;</source>
        <Parameter name="pTable" type="CM_EntryTable" usage="io"/>
        <Parameter name="pShow" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showHideCAFields" id="10de0a71-0ae5-4b05-807f-760ad2a9f6ec">
        <source>showHideCAFields( pTable : CM_EntryTable input; pShow : Boolean; pInitialise : Boolean );
// ---------------------------------------------------------------------------
// Created:     12 September 2007 by cnwvu1
//
// Date			Who			Reason
// 12/09/2008	Simon Ward	CCMS1654 - Controlled Atmosphere improvements
// ---------------------------------------------------------------------------
vars
	rowN : Integer;
	nullString : String;
begin

	if pTable &lt;&gt; null then
		rowN := pTable.getRow( ETRow_IsControlledAtmosphere );
		if rowN &gt; 0 then
			pTable.setValue( rowN, pShow );		
		endif;
		if pShow then
			pTable.showRowByName( ETRow_Oxygen, false );
			pTable.showRowByName( ETRow_CarbonDioxide, false );
			pTable.showRowByName( ETRow_CurtainsIn, false );
		else
			pTable.hideRowByName( ETRow_Oxygen, false );
			pTable.hideRowByName( ETRow_CarbonDioxide, false );
			pTable.hideRowByName( ETRow_CurtainsIn, false );
		endif;
		//  Oxygen and carbon dioxide are initialised to spaces so editing can check if value entered
		if pInitialise then
			rowN := pTable.getRow( ETRow_Oxygen );
			if rowN &gt; 0 then
				pTable.setValue( rowN, nullString );		
			endif;
			rowN := pTable.getRow( ETRow_CarbonDioxide );
			if rowN &gt; 0 then
				pTable.setValue( rowN, nullString );		
			endif;
			rowN := pTable.getRow( ETRow_CurtainsIn );
			if rowN &gt; 0 then
				pTable.setValue( rowN, false );		
			endif;
		endif;
	endif;

end;
</source>
        <Parameter name="pTable" type="CM_EntryTable" usage="input"/>
        <Parameter name="pShow" type="Boolean"/>
        <Parameter name="pInitialise" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showHideCEDOField" id="37d3721a-cba7-4c0a-8ded-9fc85ae2f14b">
        <source>showHideCEDOField(_tbl : CM_EntryTable input; _mode : Integer) ;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		CCMS 1294 AKB2005JAN - Show CEDO by permission
// ---------------------------------------------------------------------------

vars

begin
	// CCMS 1294 AKB2005JAN - Show CEDO by permission
	if _mode = GTE_PreNoteForm.Mode_Add then // ADD
		if app.myPassport.myUser.canDo(self.myTerminal,PmGteCEDOCreate) then
			_tbl.showRowByName(ETRow_CustomExportEntryNumber,false);
			_tbl.enableRowByName(ETRow_CustomExportEntryNumber);
		else
			_tbl.hideRowByName(ETRow_CustomExportEntryNumber,false);
		endif;
	elseif _mode = GTE_PreNoteForm.Mode_Update then // UPDATE
		if app.myPassport.myUser.canDo(self.myTerminal,PmGteCEDOUpdate) then
			_tbl.showRowByName(ETRow_CustomExportEntryNumber,false);
			_tbl.enableRowByName(ETRow_CustomExportEntryNumber);
		else
			_tbl.disableRowByName(ETRow_CustomExportEntryNumber);
		endif;
	endif;
	

end;</source>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showHideCOUFields" id="6544eadc-f267-4c62-95d1-6b7f44dc0846">
        <source>showHideCOUFields(pTable : CM_EntryTable input; pShow : Boolean);
// ---------------------------------------------------------------------------
// Created:     12 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	15/6/01			AA		Never set the cou check box to true, regardless of iso type
// ---------------------------------------------------------------------------
vars
	r	: Integer;
		
begin

	if pTable &lt;&gt; null then
		r := pTable.getRow(ETRow_HasCOU);
		if r &gt; 0 then
			pTable.setValue(r, pShow);		//AA 15/6/01
		endif;
		if pShow then
			pTable.showRowByName(ETRow_CouId, false);
			pTable.showRowByName(ETRow_CouISOType, false);
			pTable.showRowByName(ETRow_CouType, false);
			pTable.showRowByName('couTypeString', false);
		else
			pTable.hideRowByName(ETRow_CouId, false);
			pTable.hideRowByName(ETRow_CouISOType, false);
			pTable.hideRowByName(ETRow_CouType, false);
			pTable.showRowByName('couTypeString', false);
		endif;
	endif;
	
end;</source>
        <Parameter name="pTable" type="CM_EntryTable" usage="input"/>
        <Parameter name="pShow" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showHideCompanyField" id="b9fa2944-a244-4c4f-be97-6b2c141dcb3a">
        <source>showHideCompanyField(pTblMain, pTblExtra : CM_EntryTable input);
// ---------------------------------------------------------------------------
// Created:     19 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.myTerminal.getConfig(MultiCompany).Boolean then
		self.mainExtraShowRow(pTblMain, pTblExtra, ETRow_CompanyCode);
	else
		self.mainExtraHideRow(pTblMain, pTblExtra, ETRow_CompanyCode);
	endif;

end;</source>
        <Parameter name="pTblMain" type="CM_EntryTable" usage="input"/>
        <Parameter name="pTblExtra" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showHideDimensionFields" id="b8814d14-2d2a-4b67-940f-863d102b0262">
        <source>showHideDimensionFields(pTable : CM_EntryTable io; pShow : Boolean; _cargoType : CM_CargoType);
// ---------------------------------------------------------------------------
// Created:     12 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	action	: Integer;
	
begin

	if pTable &lt;&gt; null then
		if pShow then
			action := CM_EntryTable.ShowRowsOnly;
		else
			action := CM_EntryTable.HideRowsOnly;
		endif;
		
		if _cargoType.id = TI_CargoType_Container then
			pTable.showHideRowsByViewName('Dimensions', action, false);
		elseif _cargoType.id = TI_CargoType_Timber then
			pTable.showHideRowsByViewName('DimensionsTimber', action, false);
		endif;
	endif;

end;</source>
        <Parameter name="pTable" type="CM_EntryTable" usage="io"/>
        <Parameter name="pShow" type="Boolean"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="showHideDriversPieceCount" id="fca170dc-d229-4b05-84e3-378a620ac023">
        <source>showHideDriversPieceCount(pTable : CM_EntryTable input; pShow : Boolean);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 January 2010	cnwas3	Initial creation

*/

vars
	r	: Integer;	
begin
	
	if pTable &lt;&gt; null then
		r := pTable.getRow(ETRow_PieceCountError);
		if r &gt; 0 then
			pTable.setValue(r, pShow);		
		endif;
		if pShow then
			pTable.showRowByName(ETRow_DriversPieceCount, false);				
		else
			pTable.hideRowByName(ETRow_DriversPieceCount, false);			
		endif;
