                "total": 10
            },
            "position": 2,
            "remarks": "Test Remarks2",
            "retentionPeriod": "\/Date(1681256226290+0000)\/",
            "status": "Test Status",
            "typeId": "Test2"
        }
    ],
    "density": 0.00,
    "destinationPortId": "NZAKA",
    "dimensions": {
        "height": 0.00,
        "length": 0.00,
        "width": 0.00
    },
    "dischargePortId": "NZPOE",
    "hazards": [
        {
            "acidBase": "ACID",
            "flashpointTemperature": 2,
            "id": "2.2",
            "limitedQuantity": true,
            "marinePollutant": 1,
            "packingGroupId": "I",
            "undgNumber": "0326, 0333"
        }
    ],
    "id": "PHL01649",
    "imexStatus": "IMP",
    "isoTypeId": "2200",
    "loadPortId": "NZPOE",
    "locationId": "BS1",
    "operatorId": "ABC",
    "receivalDetails": {
        "carrierId": "ABC",
        "dateTime": "\/Date(1681251779000+0000)\/",
        "id": "UK67",
        "type": "Train"
    },
    "reeferProperties": null,
    "releaseDetails": null,
    "remarks": "Test Remarks",
    "vesselId": "",
    "volume": 0.00,
    "weights": {
        "gross": 2250.0000,
        "net": 250.0000,
        "tare": 2000.0000
    }
}';
vars
	prevPos,
	startPos,
	endPos,
	pos,
	msDateLength,
	epochPlusPos: Integer;
	epochNumStr,
	str : String;
	epochNum : Integer64;
	msDate : TimeStamp;
	result : String;
	
begin
	str := AdvancedJSON;
	
	startPos := 1;
	
	while true do
		prevPos := startPos;
		startPos := str.pos("\/Date", startPos);
		
		if startPos &gt; 0 then
			endPos := str.pos("\/", startPos);
			pos := startPos;
			pos += "\/Date(".length();
			//write pos;
			epochNumStr := str.scanUntil(")", pos);
			write epochNumStr;
			
			epochPlusPos := epochNumStr.pos("+", 1);
			//If we have a plus position
			if epochPlusPos &gt; 0 then
				epochPlusPos := 1; //Reset position to use below
				epochNumStr := epochNumStr.scanUntil("+", epochPlusPos); //only get the string up until the + pos
			endif;
			
			str.scanUntil("/", pos); //Get the ending into the pos var
			
			write epochNumStr;
			epochNum := epochNumStr.asInteger64JMT;
			epochNum := (epochNum/1000).Integer64;
			write epochNum;
			msDate.setFromUnixEpoch(epochNum);
			//write msDate;
			
			msDateLength := pos-startPos+2;
			
			write "Start: " &amp; startPos.asStringJMT &amp; " | End: " &amp; msDateLength.asStringJMT;
			
			if prevPos &gt; 1 then
				prevPos -= 1;
			endif;
			
			result &amp;= str[prevPos:startPos-prevPos]; //Get our data before the date
			
			result &amp;= msDate.localToUTCTime.asJSONFormat(); //Append our time to result
			
			startPos += pos-startPos+2;
		else
			if prevPos &gt; 1 then
				prevPos -= 1;
			endif;
			
			result &amp;= str[prevPos:end];
			break;
			
		endif;
		
	endwhile;
	
	write result;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="pwTestVoyageStuff" id="f53b4d25-ad22-4d20-8d12-5035f67d5d66">
