    <JadeMethod name="getKeyStringForProperty" id="35befbcc-1d65-460a-8df6-b7dfd8b0d6cb">
        <source>getKeyStringForProperty(_propName: String): String protected;
// ---------------------------------------------------------------------------
// Created:     20 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	keyStr	: String;
	
begin

	keyStr := _propName;
	keyStr[1] := keyStr[1].toUpper;
	
	return keyStr;

end;</source>
        <access>protected</access>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isObjectCorrectType" id="2f557737-d35f-4651-a704-31f2f8a2298c">
        <source>isObjectCorrectType(_obj: CM_Object): Boolean protected;
// ---------------------------------------------------------------------------
// Created:     20 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if _obj.isKindOf(CM_User) then
		return true;
	endif;
	
	app.raiseUnexpectedProgramError(class.name, method.name, 'Unknown class (' &amp; _obj.String &amp; ')');

end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="CM_Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFromPersistentData" id="2e7d4bfb-0412-48f2-97ad-c3d58df92bac">
        <updating/>
        <source>setFromPersistentData(_user : CM_User) updating;
// ---------------------------------------------------------------------------
// Created:     06 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12 Jan 2026 navhl20 Bug MTN-36897: PEN - Transient File Growth in PEN Production Environment
// ---------------------------------------------------------------------------
vars
	propCol	: PropertyColl;
	prop	: Property;
	keyStr	: String;
	
begin

	inheritMethod(_user);



	if self.allProperties = null then
		self.allProperties := self.class.allPropertiesUpTo(CMIF_Config);
	endif;

	propCol := self.allProperties;
	//propCol := self.class.allPropertiesUpTo(CMIF_Config);
	
	foreach prop in propCol do
		if self.isPropertyToIgnore(prop) then
			continue;
		endif;
		keyStr := self.getKeyStringForProperty(prop.name);
		if keyStr &lt;&gt; null then
			self.setPropertyFromStringValue(prop, _user.getStateData(ConfigGrp_System, keyStr));
		else
			// need to handle as a special
			
		endif;
	endforeach;
epilog
	delete propCol;				//12.01.2026 navhl20 #36897
end;</source>
        <Parameter name="_user" type="CM_User"/>
    </JadeMethod>
    <JadeMethod name="setXMLTagForType" id="44c7b320-c401-4246-9aea-79a0eb941fcb">
        <updating/>
        <source>setXMLTagForType() updating, protected;
// ---------------------------------------------------------------------------
// Created:     20 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.xmlTagForType := XMLTag_LvlUserVoyagePlanning;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updatePersistentObject" id="035376a7-f650-4297-9519-9c9e9df03184">
        <source>updatePersistentObject(_user : CM_User input; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     08 August 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 12 Jan 2026 navhl20 Bug MTN-36897: PEN - Transient File Growth in PEN Production Environment
vars
	propCol	: PropertyColl;
	prop	: Property;
	keyStr	: String;
	
begin

	inheritMethod(_user, _passport);

//	if self.allProperties.isEmpty then
//		self.allProperties := self.class.allPropertiesUpTo(CMIF_Config);
//	endif;

	propCol := self.allProperties;
	//propCol := self.class.allPropertiesUpTo(CMIF_Config);

	foreach prop in propCol do
		if self.isPropertyToIgnore(prop) then
			continue;
		endif;
		keyStr := self.getKeyStringForProperty(prop.name);
	
		if keyStr &lt;&gt; null then
			_user.setStateData(ConfigGrp_System, keyStr, self.getPropertyValue(prop.name));
		else
			// need to handle as a special
			app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '&gt;&gt;&gt;&gt; special ' &amp; prop.name);
		endif;
	endforeach;
epilog
	delete propCol;				//12.01.2026 navhl20 #36897
end;</source>
        <Parameter name="_user" type="CM_User" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
