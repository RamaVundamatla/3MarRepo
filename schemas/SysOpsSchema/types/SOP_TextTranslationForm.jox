    </JadeMethod>
    <JadeMethod name="doReplace" id="66bedc6c-6144-40a6-954a-ec2ce7f383f8">
        <updating/>
        <source>doReplace() updating, protected;

vars
	idx : Integer;
	table : CM_TextTranslationTable;
	partsDone : Integer;
	replaceText : String;

begin
	// clear each table
	foreach table in self.allDataTables do
		table.rows := table.fixedRows;
		table.refreshNow;
	endforeach;		

	// set up filters from user settings

	// locales
	self.myLocale := cmbLocale.listObject.CM_Locale;
	if self.myLocale = null then	// 26733 Jan 2011 add option for all locales
		app.msgBox("Please select an actual locale", self.caption, MsgBox_Stop_Icon);
		self.cmbLocale.setFocus();
		return;
	endif;

	// search phrase and words
	self.searchPhrase := txtSearch.text.trimBlanks();
	self.searchWords.clear();
	self.searchPhrase.getWords(self.searchWords);
	
	replaceText := txtReplace.text.trimBlanks;

	// refine existing search, or new global search?
	self.refineExisting := chkSearchTables.value;
	
	// selected, or all categories?
	self.allCategories.clear();
	if chkTextMessages.value then
		self.allCategories.add(self.myRoot.allXLAT_Categories[XLAT_Exceptions]);
	endif;
	if chkFormCaptions.value then
		self.allCategories.add(self.myRoot.allXLAT_Categories[XLAT_FormCaptions]);
	endif;
	if chkMenuEntities.value then
		self.allCategories.add(self.myRoot.allXLAT_Categories[XLAT_Menus]);
	endif;
	if chkPermissions.value then
		self.allCategories.add(self.myRoot.allXLAT_Categories[XLAT_Permissions]);
	endif;
	if chkReportNames.value then
		self.allCategories.add(self.myRoot.allXLAT_Categories[XLAT_ReportNames]);
	endif;
	if chkTableEntities.value then
		self.allCategories.add(self.myRoot.allXLAT_Categories[EntTableRows]);
	endif;

	if self.allCategories.isEmpty() then
		app.msgBox("At least one category must be selected", caption, MsgBox_Stop_Icon);
		return;
	endif;
	
	// Users not permitted to change tect for locale "0000".
	if not app.isDevelopmentSystem and self.myLocale = app.myRoot.getLocale(StandardTextLocaleStr, true) then
		app.msgBox('You cannot change the text for locale "0000".' &amp; CrLf &amp; "Select a different locale.", caption, MsgBox_Stop_Icon);
		return;
	endif;

	statusLine.caption := "";
	on Exception do searchExceptionHandler(exception);

	// do the search
	if self.searchWords.size() = 0 then
		return;
	endif;
	
	self.myAgent.doReplaceText(	self.allCategories,
								self.myLocale,
								self.refineExisting,
								self.searchWords,
								self.searchPhrase,
								replaceText,
								self,
								SOP_TextTranslationForm::zInitialiseProgressMonitor.name,
								SOP_TextTranslationForm::zUpdateProgressMonitor.name);

	// show final amount
	if self.myProgress = null then
		return;
	endif;
	
	self.myProgress.updateProgress(null, self.myProgress.partsInJob, self.myProgress.partsDone);
	self.zFinaliseProgressMonitor();
	statusLine.caption := self.myAgent.progressCount.String &amp; " rows changed.";
	self.zInitialiseProgressMonitor(0, self.myAgent.progressCount, "Loading translatable text into tables");

	// populate each table
	foreach table in self.allDataTables do
		self.displayTranslatableText(table, partsDone);
	endforeach;		
	
	// hide the search frame
	if self.tblMessages.rows &gt; self.tblMessages.fixedRows then
		self.frmSearch.visible := false;
	endif;
	
	self.mode := self.Mode_View;
epilog	
	if self.myProgress &lt;&gt; null then
		self.zFinaliseProgressMonitor();
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
