    <JadeMethod name="doResize" id="4b4fd6f4-88c5-463a-b932-1d504f9b8e89">
        <updating/>
        <source>doResize() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 Jun 2010	cnwer1	Initial creation
08 Nov 2012 cnwer1	PAR 30700 -problem resizing
*/
constants
	WIDTH = 240;
		Margin = 5;
vars
	screenWidth,
	screenHeight,lblHeight : Integer;
	theLeft, theTop, theWidth, theHeight :Integer;
begin
	if app.myVMAgent &lt;&gt; null then
		self.getVehicleMountedScreenSize(screenWidth,screenHeight);
		
		if screenWidth &gt; 400 then
			self.width:=(screenWidth*(2/3)).Integer.max(400);
		else
			self.width:=screenWidth;
		endif;

		if screenHeight &gt; 500 then
			self.height := (screenHeight *(2/3)).Integer.max(400);
		else
			self.height:=screenHeight;
		endif;
	else
		self.width:=WIDTH;	
	endif;
	
	//epr par 33025 20/11/13
	self.btnOne.height:= self.btnOne.getTextHeight(self.btnOne.caption)+ (Margin *2);
	self.btnTwo.height:= self.btnOne.clientHeight;
	self.btnOne.top := self.clientHeight - self.btnOne.clientHeight - Margin;
	self.btnTwo.top := self.btnOne.top;
	
	self.lblHeader.parentAspect:=Control.ParentAspect_StretchRight;
	
	lblHeight:=self.lblHeader.getTextHeightForWidth(self.lblHeader.caption,self.width.Integer);
	self.lblHeader.move( self.MARGIN, 
	                      self.MARGIN, 
						  self.clientWidth - 2*self.MARGIN, 
						  lblHeight);
	
	self.tblErrors.move( self.MARGIN, 
	                       self.lblHeader.clientHeight + self.lblHeader.top, 
						  self.clientWidth - 2*self.MARGIN, 
						  self.clientHeight - self.btnOne.height -(Margin *2) -  (self.lblHeader.clientHeight + self.lblHeader.top)); //- self.getCMDHeight()/
	self.tblErrors.accessColumn(1).width := self.width.Integer - 2*self.MARGIN-2;
	self.tblErrors.accessColumn(1).wordWrap := true;
	self.tblErrors.autoSize := Table.AutoSize_Row;
	
	//epr par 30774 centreWindow for some reason doesn't quite work on windows mobile 6.5 - work it out myself from getMonitorWorkArea
	self.getMonitorWorkArea(theLeft, theTop, theWidth, theHeight);
	self.left:=(theWidth - self.clientWidth)/2;
	self.top:=(theHeight - self.clientHeight)/2;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
