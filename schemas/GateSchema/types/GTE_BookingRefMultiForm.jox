    <JadeMethod name="doMnuCargoLabelPrint" id="dad8e3e5-a392-4f14-9ec2-0de1e3aea851">
        <source>doMnuCargoLabelPrint();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 January 2010	cnwndl1	Initial creation	CCMS MES 1004

*/

vars
	bookingArray : CM_ObjectArrayActual;
	obj : Object;
	booking : CM_BookingRef;
begin
	
	if self.tblData.allSelectedObjects.isEmpty then
		return;
	endif;
	
	create bookingArray transient;

	foreach obj in self.tblData.allSelectedObjects do
		if obj.isKindOf(CM_BookingRef) then
			bookingArray.addExclusive( obj );
		elseif obj.isKindOf(CM_BookingRefItem) then
			booking := obj.CM_BookingRefItem.myBookingReference;
			if booking &lt;&gt; null then
				bookingArray.addExclusive( booking );
			endif;
		endif;
	endforeach;
	
	if bookingArray.isEmpty then
		return;
	endif;
	
	self.myAssistant.showCargoIdLabelPrintForm(bookingArray);
	
	
epilog

	delete bookingArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuColumnOrganiserClick" id="6931efb1-8fb6-485a-8394-2a68c89f87a6">
        <source>doMnuColumnOrganiserClick(_menuItem: MenuItem);
/*
	Created on 20 February 2008
	
	by Debby Hutchison
	
	Purpose:
	
Changed On	By			Reason
----------	--------	-------------------------------------------------------
19/03/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars
	
begin
	if self.mnuColumnOrganiser.userObject = self.tblBRItems then
		self.tblBRItems.showColumnOrganiserFrm(self.myTerminal);
	elseif self.mnuColumnOrganiser.userObject = self.tblData then
		//epr par 33900 4/4/14 measurement columns now handled on column orgainser form
		self.tblData.showColumnOrganiserFrm(self.myTerminal, null);								// PAR #31155
	else
		inheritMethod(_menuItem);
	endif;
epilog
	
end;</source>
        <Parameter name="_menuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doMnuFormContextMenu" id="ee26e416-478a-4017-9214-1a362ff9dfde">
        <updating/>
        <source>doMnuFormContextMenu( conwin : Window input; mouse : Boolean; x : Integer; y : Integer ) : Boolean updating;
/*
	Created on 20 February 2008
	
	by Debby Hutchison
	
	Purpose:
	
Changed On	By			Reason
----------	--------	-------------------------------------------
19/03/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Get rid of column organiser menu item on booking item table 
							- it doesn't do anything anyway
*/
vars
	tmpMenu		: MenuItem;
	
begin
	if conwin = self.tblBRItems then
		self.mnuColumnOrganiser.visible := false;					// PAR #31155
	else
		self.mnuColumnOrganiser.caption := 'Column Organiser';
		self.mnuColumnOrganiser.visible := true;					// PAR #31155
	endif;
		
	return inheritMethod( conwin, mouse, x, y );

end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMnuReceived" id="8f036617-6980-419f-9f5e-b767dc56dc4d">
        <source>doMnuReceived(_coll : ObjectArray input);
/*
Date		Who		Reason
08 Jul 2009	cnwml2	Initial creation
12 Jun 2013	cnwcs5	par 31670 - check if prenoted, simplified code
*/

vars
	isBooking	:Boolean;
	obj 		:Object;									
begin
	isBooking := not self.btnShowBookItms.value; 

	foreach obj in self.tblData.allSelectedObjects do
		if isBooking then 
			obj.CM_BookingRef.getReceivedTrackedItems (_coll);
		else
			obj.CM_BookingRefItem.getReceivedTrackedItems (_coll);
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_coll" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuReleased" id="59b95adc-c14f-4f74-b4e1-9e3bb57b8bb6">
        <source>doMnuReleased(_tiArray : ObjectArray input);
/*
Date		Who		Reason
08 July 2009	cnwml2	Initial creation

*/

vars
	resDtl : CM_ReserveDetail;
	ti 		: CM_TrackedItem;
	obj		: Object;							//+cnwml2 PAR19782 CCMS SFW 1079
	booking : CM_BookingRef;
	bookingRefItem : CM_BookingRefItem;
begin
	if self.btnShowBookItms.value then
		if self.tblData.allSelectedObjects.size &gt; 0 then
			foreach obj in tblData.allSelectedObjects do 
				bookingRefItem := obj.CM_BookingRefItem;
				resDtl := bookingRefItem.myReserveDetail;
				if resDtl &lt;&gt; null then
					if resDtl.allTrackedItemsReleased.size &gt; 0 then
						foreach ti in resDtl.allTrackedItemsReleased do
							_tiArray.add(ti);
						endforeach;
					endif;
				endif;
			endforeach;
		endif;
	else
		if self.tblData.allSelectedObjects.size &gt; 0 then
			foreach obj in tblData.allSelectedObjects do
				booking := obj.CM_BookingRef;
				foreach bookingRefItem in booking.allBookingRefItems do									
				resDtl := bookingRefItem.myReserveDetail;
					if resDtl &lt;&gt; null then
						if resDtl.allTrackedItemsReleased.size &gt; 0 then
							foreach ti in resDtl.allTrackedItemsReleased do
								_tiArray.add(ti);
							endforeach;
						endif;
					endif;
				endforeach;
			endforeach;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_tiArray" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuReserved" id="a3a589df-b65e-470c-92ea-505cdd9983c5">
        <source>doMnuReserved(_tiArray : ObjectArray io);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 July 2009	cnwml2	Initial creation
23/06/2023		navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

vars

	realObj,pxyBookItem : CM_BookingRefItem;
	resDtl : CM_ReserveDetail;
	ti 		: CM_TrackedItem;
	obj		: Object;							//+cnwml2 PAR19782 CCMS SFW 1079
	booking : CM_BookingRef;
	bookingRefItem : CM_BookingRefItem;
begin
	
	if self.btnShowBookItms.value then
		if self.tblData.allSelectedObjects.size &gt; 0 then
			foreach obj in tblData.allSelectedObjects do
				bookingRefItem := obj.CM_BookingRefItem;
				resDtl := bookingRefItem.myReserveDetail;
				if resDtl &lt;&gt; null then
					/* //23/06/2023	navkc1	CR 58406 Task 58408
					if resDtl.allTrackedItems.size &gt; 0 then
						foreach ti in resDtl.allTrackedItems do
							_tiArray.add(ti);
						endforeach;
					endif;
					*/
					
					//23/06/2023	navkc1	CR 58406 Task 58408
					resDtl.getAllTrackedItems(_tiArray, false);
				endif;
			endforeach;
		endif;
	else
		if self.tblData.allSelectedObjects.size &gt; 0 then
			foreach obj in tblData.allSelectedObjects do
				booking := obj.CM_BookingRef;
				foreach bookingRefItem in booking.allBookingRefItems do									
				resDtl := bookingRefItem.myReserveDetail;
					if resDtl &lt;&gt; null then
						/* //23/06/2023	navkc1	CR 58406 Task 58408
						if resDtl.allTrackedItems.size &gt; 0 then
							foreach ti in resDtl.allTrackedItems do
								_tiArray.add(ti);
							endforeach;
						endif;
						*/
						//23/06/2023	navkc1	CR 58406 Task 58408
						resDtl.getAllTrackedItems(_tiArray, false);
					endif;
				endforeach;
			endforeach;
		endif;
	endif;
epilog
	
end;</source>
        <Parameter name="_tiArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doMnuShowPrenoted" id="a4a3892c-5a80-405d-a4c5-81c0fe49ae45">
