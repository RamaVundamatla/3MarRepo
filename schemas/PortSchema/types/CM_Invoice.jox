    <JadeMethod name="getEndDate" id="170146b5-b537-4df6-bf57-5c396a2865ed">
        <source>getEndDate():Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 October 2017	jlgma1	TFS #7139  JMT - Adding Invoice End Date to Selector Query

