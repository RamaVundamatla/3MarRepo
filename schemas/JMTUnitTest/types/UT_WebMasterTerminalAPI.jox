18 Jun 2024	navdap1	TFS 63107 CUX | GET /releaseRequest API to return release request line items
25 Jul 2024	navmd1	TFS 64945 Added piecesRequested to ByType line items
30 Jul 2024 navsp1  TFS 65419: CUX | GET /releaseRequest - Add bookingId and state to Release Detail
*/
constants
	ReleaseReqOne = "R1257";
