        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDebtorNames" id="8c79baa0-b545-403d-8e52-75317cee323e">
        <source>getDebtorNames() : String;
/*
Purpose:			
28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
Date		Who		Reason
 // ### TFS CR 56814 TASK 56813 07JUL2023 NAVAB1*/

vars
	woDtl      : CM_WorkOrderDtl;
	debtorName, returnStr : String;
begin
	foreach woDtl in self.allWoDtls discreteLock do	//28.05.2024 navma1 #64224
		debtorName := woDtl.getDebtorName();
		if debtorName &lt;&gt; null then
			/*
			if returnStr.pos(debtorName,1) = 0 then
				if returnStr = null then
					returnStr := debtorName;
				else
					returnStr := returnStr &amp; ", " &amp; debtorName;
				endif;
			endif;
			*/
			
			returnStr.addStringToList(debtorName, ", "); //04/04/2025	navkc1 JIRA Story MTN-33940
		endif;
	endforeach;
	
	return returnStr;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDestinationLocation" id="7cbc34e2-02d8-46fc-8a86-3dc32d8598b2">
