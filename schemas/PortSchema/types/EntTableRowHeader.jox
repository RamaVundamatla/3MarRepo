<Class name="EntTableRowHeader" id="f9d7572a-4d99-46fd-b868-325f4e0632e7">
    <superclass name="EntTableEntity"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="entTable"/>
    <ExplicitInverseRef name="allEntTableRows" id="c472b906-4aee-4089-8678-c9f9231ef710">
        <kind>parent</kind>
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <type name="EntTableRowSet"/>
        <access>readonly</access>
        <Inverse name="EntTableRow::myEntTableRowHeader"/>
    </ExplicitInverseRef>
    <PrimAttribute name="constantName" id="4bc0aa61-2c62-41b6-bb7e-bb261bc7d6af">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myEntTableDataRoot" id="db026720-4396-44cd-96d5-6dcd15a8b710">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="EntTableDataRoot"/>
        <access>readonly</access>
        <Inverse name="EntTableDataRoot::allEntTableRowHeadersByName"/>
    </ExplicitInverseRef>
    <PrimAttribute name="name" id="12121acd-da4c-4ffe-86b8-3ff9ab3ad30c">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getName" id="49ac4903-33f2-4cdd-84c9-4323baef183f">
        <source>getName(): String;
// ---------------------------------------------------------------------------
// Created:     09 November 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return self.String &amp; ' (' &amp; self.name &amp; ')';

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputAsXML" id="92687025-d051-46e2-9dfd-5647681d886a">
        <source>outputAsXML() : String;
// ---------------------------------------------------------------------------
// Created:     27 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	xmlStr	: String;
	etRow	: EntTableRow;
	
begin

	xmlStr := self.formatAsXMLPrefix(XMLTag_EntTableRow) &amp;
			  self.formatAsXML(XMLTag_RowName, self.name.xmlReplaceReservedChars(true)) &amp;
			  self.formatAsXML(XMLTag_ConstantName, self.constantName.xmlReplaceReservedChars(true));

	foreach etRow in self.allEntTableRows do
		xmlStr := xmlStr &amp; etRow.outputAsXML();
	endforeach;

	xmlStr := xmlStr &amp; self.formatAsXMLSuffix(XMLTag_EntTableRow);

	return xmlStr;
				  
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="set" id="ca1ae0a3-a60f-4fd5-88ba-c18f36232549">
        <updating/>
        <source>set(_constName, pName : String; pRoot : EntTableDataRoot) updating;
// ---------------------------------------------------------------------------
// Created:     08 November 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.name	:= pName;
	self.myEntTableDataRoot	:= pRoot;
	
	if _constName = null then
		self.setConstantName();
	else
		self.constantName := _constName;
	endif;
	
end;</source>
        <Parameter name="_constName" type="String"/>
        <Parameter name="pName" type="String"/>
        <Parameter name="pRoot" type="EntTableDataRoot"/>
    </JadeMethod>
    <JadeMethod name="setConstantName" id="e8154f28-e80f-439e-8347-646263ab65f5">
        <updating/>
        <source>setConstantName() updating;
// ---------------------------------------------------------------------------
// Created:     28 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpName	: String;

begin

	tmpName := self.myEntTableDataRoot.translateConstantName(RowType, self.name);
	
	tmpName := RowPrefix &amp; tmpName[1].toUpper &amp; tmpName[2:end];
	while tmpName.length &gt; 30 do
		app.msgBox('Generated constant name ' &amp; tmpName &amp; ' is too long.  Please enter manually', 'Error', MsgBox_OK_Only);
		read tmpName;
	endwhile;
	
	self.constantName := tmpName;

end;</source>
    </JadeMethod>
</Class>
