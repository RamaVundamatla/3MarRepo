    <JadeMethod name="changedValueDetails" id="5e8ba48b-7f63-48ba-918f-485ce6ee94e0">
        <source>changedValueDetails(_key : String; _terminal : CM_Terminal; _isRestore : Boolean);

/*

Purpose:		output the changed value details

				TESTING ONLY

Date			Who		Reason
11/12/2014		cnwmh5	Initial creation

*/

vars

	str 						: String;

begin

	str := method.qualifiedName() &amp; Tab;

	// check to see if in temp collection already
	if not _isRestore and not self.allStateDataChangedNames.includes(_key) then
		self.allStateDataChangedNames.add(_key);
		str := str &amp; "Before: " &amp;_key &amp; Tab;
		if _terminal &lt;&gt; null then
			str := str &amp; self.allTerminalStateData.first.getStateData(_key).String;
		else
			str := str &amp; self.allSystemStateData.first.getStateData(_key).String;
		endif;
		/////write str;
	endif;
	
	str := method.qualifiedName() &amp; Tab;
	
	// get the current value
	if _isRestore then
		str := str &amp; "Restored: " &amp; _key &amp; Tab;
	else
		str := str &amp; "Changed: " &amp; _key &amp; Tab;
	endif;
	
	if _terminal &lt;&gt; null then
		str := str &amp; _terminal.getAllStateData().first.getStateData(_key).String;
	else
		str := str &amp; app.myRoot.getAllStateData().first.getStateData(_key).String;
	endif;	
	/////write str;

epilog

end;</source>
        <Parameter name="_key" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_isRestore" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="2af8460f-1cde-4d3c-aacf-d0a939fe7336">
        <updating/>
        <source>create() updating;

/*

Purpose:		

Date			Who		Reason
11 December 2014	cnwmh5	Initial creation

*/

vars

begin

	create self.allChangedStateDataDict transient;
	allChangedStateDataDict.setMembership(Object);
	allChangedStateDataDict.addExternalKey(String, 32, false, false);		// class name
	allChangedStateDataDict.addExternalKey(String, 32, false, false);		// method name
	allChangedStateDataDict.addExternalKey(String, 32, false, false);		// test name
	allChangedStateDataDict.addExternalKey(String, 32, false, false);		// State Data Key
	allChangedStateDataDict.addExternalKey(String, 32, false, false);		// Terminal / System data
	allChangedStateDataDict.endKeys(false);

epilog

end;</source>
    </JadeMethod>
