        <source>fileOpen(pFileName:String):File;
// --------------------------------------------------------------------------------
// Created:		14 February 1999 by cnwdad1
//
// Purpose:		Opens a disk file.
//
// Parameters:	pFileName (String) - The name of the file to open.
// Returns:		File - The file object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	file	: File;

begin
	create file;
	file.kind	:=	File.Kind_Binary;
	file.mode	:=	File.Mode_Input;
//	file.openInput(pFileName);
epilog
	return file;
end;</source>
        <Parameter name="pFileName" type="String"/>
