    <JadeMethod name="assignCargoToTrain" id="72a39b45-4cdb-4db6-916d-5f0a4029cd09">
        <source>assignCargoToTrain( _wagon : CM_Wagon; _ti : CM_TrackedItem io; _pos : Integer ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 February 2013	cnwndl1	Initial creation	Par 31102

*/

vars

	train : CM_Train;
	moveController : CMIF_MoveController;
	targetLc : CM_LocationsController;

begin

	train := _wagon.myTrainInwards;
	
	beginTransaction;
	_ti.setIntendedReleaseModeFromStr(TI_TRANSMODE_RAIL_STR);
	_ti.setMyTrainAssigned(train,null);
	commitTransaction;
	
	targetLc := _wagon.allLocationsControllersArray[_pos];
	
	// Clear all the stops
	self.deleteStops(_ti);

	app.setContinueCMExceptions(true);
	app.myPassport.clearErrorsWarnings();

	create moveController transient;
	moveController.setMyTrackedItem( _ti);
	moveController.setMyToPrimaryLocation(targetLc);
	moveController.setMoveMode(PLANNING_MODE);
	moveController.isSystemMove := true;
	
	while true do
		app.myTrxUA.trxMoveTrackedItemNewRailJob(moveController, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			if app.myPassport.noErrors then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
	
	self.assertTrueMsg(app.myPassport.trxCompletedOK,"Assign of cargo failed.[" &amp; _ti.id &amp; "] " &amp; app.myPassport.getErrorsAndWarningsAsString);
	
	
epilog

	delete moveController;

end;</source>
        <access>protected</access>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
        <Parameter name="_pos" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="assignSlotToTrain" id="506f25ba-ef26-4a34-a223-4eebad7f7f63">
        <source>assignSlotToTrain(_slotsFrom : CM_SlotControllerArray; _wagon : CM_Wagon; _ti : CM_TrackedItem io; _pos : Integer ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
08 February 2013	cnwndl1	Initial creation	Par 31102
06 June 2019		jlgzm1	TFS 42840 MSL - Direct Delivery Between LOLO RORO Voyages and Rail

*/

vars

	train : CM_Train;
	moveController : CMIF_MoveController;
	targetLc : CM_LocationsController;
	slot : CM_SlotController;

begin

	train := _wagon.myTrainInwards;
	
	beginTransaction;
	_ti.setIntendedReleaseModeFromStr(TI_TRANSMODE_RAIL_STR);
	_ti.setMyTrainAssigned(train,null);
	commitTransaction;
	
	targetLc := _wagon.allLocationsControllersArray[_pos];
	
	// Clear all the stops
	self.deleteStops(_ti);

	app.setContinueCMExceptions(true);
	app.myPassport.clearErrorsWarnings();

	create moveController transient;
	moveController.setMyTrackedItem( _ti);
	moveController.setMyToPrimaryLocation(targetLc);
	moveController.setMoveMode(PLANNING_MODE);
	moveController.isSystemMove := true;

	foreach slot in _slotsFrom do
		if slot.allTrackedItemsById.includesKey(_ti.id, _ti.cargoType) then
			moveController.mySlotRequest := slot.mySlotRequestDischarge;
			break;
		endif;
	endforeach;

	while true do
		app.myTrxUA.trxMoveTrackedItemNewRailJob(moveController, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			if app.myPassport.noErrors then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
	
	self.assertTrueMsg(app.myPassport.trxCompletedOK,"Assign of cargo failed.[" &amp; _ti.id &amp; "] " &amp; app.myPassport.getErrorsAndWarningsAsString);
	
	
epilog

	delete moveController;

end;</source>
        <access>protected</access>
        <Parameter name="_slotsFrom" type="CM_SlotControllerArray"/>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
        <Parameter name="_pos" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="assignWLEToRoadDR" id="289fc1aa-3d6d-45d2-93e2-12da41ce9ed8">
        <source>assignWLEToRoadDR(_wle : CM_WorkListEntry; _quantity : Integer; _weight : Decimal; _theLC : CM_LocationsController);
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
30 August 2019			jlgzm1	Initial creation TFS 42878 Direct Release Between Road and Voyage

*/

vars
	moveController : CMIF_MoveController;
begin
	
	app.setContinueCMExceptions(true);
	app.myPassport.clearErrorsWarnings();
	
	create moveController transient;
	moveController.setMyWorkListEntry(_wle);
	moveController.setQuantity(_quantity);
	moveController.setWeight(_weight);
	moveController.setMyTrackedItem(_wle.myTrackedItem);
	moveController.isDirectReleaseMove := true;
	moveController.setMyToPrimaryLocation(_theLC);
	moveController.setMoveMode(PLANNING_MODE);
	
	while true do
		app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			if app.myPassport.noErrors then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
	
	self.assertTrueMsg(app.myPassport.trxCompletedOK,"Assign of cargo failed.[" &amp; _wle.myTrackedItem.id &amp; "] " &amp; app.myPassport.getErrorsAndWarningsAsString);
	
epilog
	delete moveController;
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_theLC" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="assignWLEToTrainDR" id="fec5e3e7-04db-4696-a685-b427aea9d409">
        <source>assignWLEToTrainDR(_wle : CM_WorkListEntry; _quantity : Integer; _weight : Decimal; _wagon : CM_Wagon; _pos : Integer );
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
21 August 2019		jlgzm1	Initial creation TFS 42872 Direct Release Between HOLD Voyages and Rail

*/

vars
	moveController : CMIF_MoveController;
	targetLC : CM_LocationsController;
begin

	app.setContinueCMExceptions(true);
	app.myPassport.clearErrorsWarnings();
	
	targetLC := _wagon.allLocationsControllersArray[_pos];
	
	if targetLC = null then
		app.writeLog("Assigning wle to null targetLC", LogINFO);
	else
		app.writeLog("Assigning wle to: " &amp; targetLC.getFullId, LogINFO);
	endif;

	create moveController transient;
	moveController.setMyWorkListEntry(_wle);
	moveController.setQuantity(_quantity);
	moveController.setWeight(_weight);
	moveController.setMyTrackedItem(_wle.myTrackedItem);
	moveController.isDirectReleaseMove := true;
	moveController.setMyToPrimaryLocation(targetLC);
	moveController.setMoveMode(PLANNING_MODE);
	
	while true do
		app.myTrxUA.trxMoveTrackedItemNewRailJob(moveController, app.myPassport);
		if app.myPassport.trxCompletedOK then
			app.writeLog(method.qualifiedName &amp; " trxCompletedOK", LogINFO);
			break;
		else
			if app.myPassport.noErrors then
				app.writeLog(method.qualifiedName &amp; " not trxCompletedOK, no errors, had warnings: " &amp; app.myPassport.getErrorsAndWarningsAsString, LogINFO);
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			app.writeLog(method.qualifiedName &amp; " not trxCompletedOK, had errors: " &amp; app.myPassport.getErrorsAndWarningsAsString, LogINFO);
		endif;
		app.writeLog(method.qualifiedName &amp; " not trxCompletedOK", LogINFO);
		break;
	endwhile;
	
	self.assertTrueMsg(app.myPassport.trxCompletedOK,"Assign of cargo failed.[" &amp; _wle.myTrackedItem.id &amp; "] " &amp; app.myPassport.getErrorsAndWarningsAsString);
	
epilog
	delete moveController;
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="_pos" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="createDDCargoOnShip" id="253b9cee-e6e3-4fe3-84b1-0891ce0c53e9">
        <source>createDDCargoOnShip( itemNumber : Integer ):CM_TrackedItem protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2013	cnwndl1	Initial creation	Par 31102

*/

vars

	theSlot : CM_LocationsController;
	cargo : CM_TrackedItem;
	contId : String;
	strs : StringArray;
	idx : Integer;
	aPort : CM_Port;

begin

	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	create strs transient;
	
	if itemNumber = 1 then
		strs.add("010182");
		contId := "JMTZ0022001";
	elseif itemNumber = 2 then
		strs.add("010184");
		contId := "JMTZ0022002";
	elseif itemNumber = 3 then
		strs.add("010186");
		contId := "JMTZ0022003";
	elseif itemNumber = 4 then
		strs.add("010188");
		contId := "JMTZ0022004";
	elseif itemNumber = 5 then
		strs.add("010282");
		contId := "JMTZ0022005";
	elseif itemNumber = 6 then
		strs.add("010284");
		contId := "JMTZ0022006";
	elseif itemNumber = 7 then
		strs.add("010286");
		contId := "JMTZ0022007";
	elseif itemNumber = 8 then
		strs.add("010288");
		contId := "JMTZ0022008";
	elseif itemNumber = 11 then
		strs.add("010482");
		contId := "JMTZ0022011";
	elseif itemNumber = 12 then
		strs.add("010484");
		contId := "JMTZ0022012";
	else
		return null;
	endif;
	
	voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch(contId, "U20G", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, aPort, voyage);
	
	// make it direct delivery
	beginTransaction;
	cargo.setPropertyValue("directDelivery",true);
	commitTransaction;
	
	// Clear all the stops
	self.deleteStops(cargo);
	
	return cargo;
	

epilog

	delete strs;
	
end;</source>
        <access>protected</access>
        <Parameter name="itemNumber" type="Integer"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="createDischargeJob" id="23bb0395-c62a-4964-92b7-1bd108231e81">
        <source>createDischargeJob( _itemNumber : Integer):CM_VoyageJob protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 February 2013	cnwndl1	Initial creation

*/

vars

	tier : Integer;
	cell : Integer;
	slots : CM_SlotControllerArray;
	voyageJob : CM_VoyageJob;
	
begin

	if _itemNumber &lt;= 4 then
		tier := _itemNumber;
		cell := 4;
	elseif _itemNumber &lt;= 8 then
		tier := _itemNumber - 4;
		cell := 3;
	elseif _itemNumber &lt;= 12 then
		tier := _itemNumber - 10;
		cell := 2;
	endif;
	
	create slots transient;
	self.getJobSlotControllers(voyage.code,"01",DeckOnDeck,cell,tier,1,slots);
	voyageJob:=self.addVoyageJob(voyage,"CRN1",slots, true);
	assertTrue(voyageJob &lt;&gt; null);
	
	return voyageJob;
	
epilog

	delete slots;

end;</source>
        <access>protected</access>
        <Parameter name="_itemNumber" type="Integer"/>
        <ReturnType type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="createOutwardVoyage" id="d525ef4c-84fd-4a54-bc4a-b4e9fa7d6268">
        <source>createOutwardVoyage( voyCode : String ) : CM_Voyage protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 February 2013	cnwndl1	Initial creation

*/

vars

begin

	self.deleteVoyage(voyCode);
	return addVoyageWithContainerStructur(voyCode, vessel.code, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="voyCode" type="String"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="createRailTrainAndWagon" id="0cd2d830-4806-40b6-af2c-c59be4c2be91">
        <source>createRailTrainAndWagon( _wagonCode : String; _trainCode : String; _railAreaId : String; _preNote1, _preNote2 : CM_TrackedItem ):CM_Wagon protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 February 2013	cnwndl1	Initial creation
// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
*/

vars

	train : CM_Train;
	now : TimeStamp;
	pxyTrain : CM_Train;
	railArea : CM_Rail;
	railLine : CM_RailLine;
	wagon : CM_Wagon;
	
	moveController	: CMIF_MoveController;
	preNote : CM_TrackedItem;

begin

	now := app.actualTimeServer;// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support

	train := self.addTrain(_trainCode, null);
	self.assertTrueMsg(train &lt;&gt; null,"Train not created. ");
	
	railArea :=	self.addRailArea(_railAreaId, 4, 5);
	self.assertTrueMsg(railArea &lt;&gt; null,"Rail Area not created. ");
	
	railLine :=	railArea.allRailLinesByIndex[1];
	self.assertTrueMsg(railLine &lt;&gt; null,"Rail line not found. ");
	
	wagon := self.addWagonInRailArea(_wagonCode, _wagonCode[1:2], railArea, train);
	self.assertTrueMsg(wagon &lt;&gt; null,"Wagon not created. ");
	
	if _preNote1 &lt;&gt; null then
	
		preNote := _preNote1;
		beginTransaction;
		preNote.setReceiptTransportMode( TI_TRANSMODE_RAIL );
		commitTransaction;
		
		create moveController transient;
		moveController.setMyTrackedItem(preNote);
		moveController.setMyToPrimaryLocation(wagon.allLocationsControllersArray[1]);
		moveController.setMoveMode(REAL_MODE);
		moveController.isForcedMove := true;
	
		app.myTrxUA.trxMoveTrackedItemNewRailJob(moveController, app.myPassport);
		self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
		delete moveController;
		
	endif;
	
	if _preNote2 &lt;&gt; null then
	
		preNote := _preNote2;
		beginTransaction;
		preNote.setReceiptTransportMode( TI_TRANSMODE_RAIL );
		commitTransaction;
		
		create moveController transient;
		moveController.setMyTrackedItem(preNote);
		moveController.setMyToPrimaryLocation(wagon.allLocationsControllersArray[3]);
		moveController.setMoveMode(REAL_MODE);
		moveController.isForcedMove := true;
	
		app.myTrxUA.trxMoveTrackedItemNewRailJob(moveController, app.myPassport);
		self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
		delete moveController;
		
	endif;
	
	pxyTrain := app.createUpdateProxy(train).CM_Train;
	pxyTrain.setProxyDetails(now);
	
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateTrain(pxyTrain, false, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK,"Arrive Train failed. " &amp; app.myPassport.getErrorsAndWarningsAsString);
	
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateWagonPosition(railLine, wagon, 1, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK,"Set Wagon position failed. " &amp; app.myPassport.getErrorsAndWarningsAsString);
	
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, train, true, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK,"Wagon confirm in failed. " &amp; app.myPassport.getErrorsAndWarningsAsString);
	
	return wagon;

epilog

	delete pxyTrain;

end;</source>
        <access>protected</access>
        <Parameter name="_wagonCode" type="String"/>
        <Parameter name="_trainCode" type="String"/>
        <Parameter name="_railAreaId" type="String"/>
        <Parameter name="_preNote1" type="CM_TrackedItem"/>
        <Parameter name="_preNote2" type="CM_TrackedItem"/>
        <ReturnType type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="departTrainAndClearRake" id="b1deddca-65ae-4a7b-9441-cb3ff24ae076">
        <source>departTrainAndClearRake( _train : CM_Train) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 February 2013	cnwndl1	Initial creation	Par 31102

*/

vars

	train : CM_Train;
	cmifToDepartTrain : CMIF_RakeRegion;

begin

	train := _train;
	self.ignoreTrxWarnings(true);
	
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, false, train, false, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), "Failed to confirm train. " &amp; app.myPassport.getAllErrorsWarningsAsString());

	// clear the entire train.
	create cmifToDepartTrain transient;	
	cmifToDepartTrain.myTrain := train;
	
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateRailClearRake(cmifToDepartTrain, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), "Failed to clear rake. " &amp; app.myPassport.getAllErrorsWarningsAsString());
	

epilog

	delete cmifToDepartTrain;

end;</source>
        <access>protected</access>
        <Parameter name="_train" type="CM_Train"/>
    </JadeMethod>
    <JadeMethod name="handHeldDirectDischargeTrx" id="1833f8d5-eea3-4993-a85d-4ee86e8aef1f">
        <source>handHeldDirectDischargeTrx(_ti : CM_TrackedItem; _targetLc : CM_LocationsController; _wle : CM_WorkListEntry) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 February 2013	cnwndl1	Initial creation

*/

vars

	moveController	: CMIF_MoveController;
	result	: Integer;
	foundHeight : Integer;
	rtQueEntry : CM_RTQueueEntry;
	futureMove : CM_FutureMove;

begin

	// Clear all the stops
	self.deleteStops(_ti);

	app.setContinueCMExceptions(true);
	app.myPassport.clearErrorsWarnings();

	create moveController transient;
	moveController.setMyTrackedItem( _ti);
	moveController.setMyToPrimaryLocation(_targetLc);
	moveController.setMoveMode(REAL_MODE);
	
	
	moveController.setMyWorkListEntry(_wle);
	moveController.setQuantity(_wle.quantity); 	// tfs42872 jlgzm1 21/08/2019
	moveController.setWeight(_wle.weight);		// tfs42872
	if not _wle.allRTQueueEntries.isEmpty then
		rtQueEntry := _wle.allRTQueueEntries.last;
	endif;
	if rtQueEntry &lt;&gt; null then
		moveController.isRTMultiMove := true;
		moveController.myRTQueueEntry := rtQueEntry;
		moveController.isRTPickupTask := false;
		moveController.setJobForMove(_wle.job);
		moveController.isRadioTelemetryMove := true;
		futureMove := _wle.myFutureMove;
	endif;
	
	while true do
		//Do the move
		app.myTrxUA.trxMoveTrackedItemAndUnQueue(moveController, futureMove, null, app.myPassport);
		if app.myPassport.trxCompletedOK then
			app.myPassport.clearErrorsWarnings();
			return;
		else
			if app.myPassport.noErrors then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return;
		
	endwhile;
		
epilog

	delete moveController;
	
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_targetLc" type="CM_LocationsController"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="listAllTransactions" id="72b00783-eb83-47dd-b07e-b843fd58edad">
        <source>listAllTransactions(_ti : CM_TrackedItem) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
17 March 2025		jlizm1	Initial creation

*/

vars
	trx 		: CM_TITransaction;
	returnStr 	: String;
	s1,
	s2,
	s3,
	s4			: String;
	
begin
	if _ti = null then
		return returnStr;
	endif;
	
	foreach trx in _ti.allTransactions where not trx.deleted do
		s1 := "Date: " &amp; trx.dateTime.String;
		s2 := "Type: " &amp; trx.typeString.padTrimTo(13);
		s3 := "Details: " &amp; trx.getDetails.padTrimTo(38);
		s4 := "IsDRMove: " &amp; trx.isDirectReleaseMove.String;
		returnStr := returnStr &amp; s1 &amp; Tab &amp; s2 &amp; Tab &amp; s3 &amp; Tab &amp; s4 &amp; CrLf;
	endforeach;
	
	return returnStr;
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="moveTruckToInterchangeArea" id="30945701-4831-4b76-bf3a-1077139dabd5">
        <source>moveTruckToInterchangeArea( truck : CM_Vehicle input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 February 2013	cnwndl1	Initial creation

*/

vars

	lc : CM_YardController;

begin

	lc := self.dualGate.getNextLocation_IN(truck);
	
	app.myTrxUA.trxMoveVehicle( truck, lc, app.myPassport );

epilog

end;</source>
        <access>protected</access>
        <Parameter name="truck" type="CM_Vehicle" usage="input"/>
    </JadeMethod>
    <JadeMethod name="planLoadItemDR" id="37d82c5a-f05b-4dee-aa8e-6591ad1bf8a0">
        <source>planLoadItemDR( _voyage : CM_Voyage; _ti : CM_TrackedItem; _wle : CM_WorkListEntry; _col : Integer; _tier : Integer ):CM_VoyageJob protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
04 February 2013	cnwndl1	Initial creation
06 June 2019		jlgzm1	TFS 42840 MSL - Direct Delivery Between LOLO RORO Voyages and Rail

*/

vars

	jobSheet : CM_VoyageJobSheet;
	slots : CM_SlotControllerArray;
	theTIs: CM_TIArray;
	ti : CM_TrackedItem;
	lcs : CM_LCArray;
	moveController : CMIF_MoveController;
	tmpLoadCC	: CMIF_LoadColorCode;
	voyageJob : CM_VoyageJob;

begin

	jobSheet := voyage.allJobSheets["CRN1"];
	
	create theTIs transient;
	theTIs.add(_ti);

	app.myTrxUA.trxUpdateTIsReadyToShip(theTIs,true,app.myPassport);
	
	create slots transient;
	self.getJobSlotControllers(_voyage.code,"01",DeckOnDeck,_col,_tier,1,slots);
	
	create tmpLoadCC transient;
	tmpLoadCC.overrideMoveType :=true;
	tmpLoadCC.myDischargePort:=app.myRoot.allPorts["NZAKL"];
	
	tmpLoadCC.myCommodityGroup := null;
	self.markSlotsAsLoadJob(slots,tmpLoadCC);
	
	voyageJob := self.addVoyageJob(_voyage,"CRN1",slots, false);
	
	create lcs transient;
	slots.copy(lcs);
	create moveController transient;

	moveController.isRehandleMove := false;
	moveController.mySlotRequest := slots.first.mySlotRequestLoad;
	moveController.setMoveMode(PLANNING_MODE);
	moveController.isSystemMove := true;
	moveController.isForcedMove := true;
	moveController.doingAutoLoadPlanning := true;
	
	moveController.setMyWorkListEntry(_wle);
	moveController.setMyTrackedItem(_ti);
	
	app.myPassport.setWarningsIgnored(true);
	moveController.moveTrackedItemTarget(self.getTerminal(), slots.first, null, null);
	
	foreach ti in theTIs discreteLock do
		self.assertTrueMsg((ti.myPrimaryPlannedLocation &lt;&gt; null),ti.id &amp; " Prenote did not plan load.");
	endforeach;	

	self.deleteStops(_ti);
	return voyageJob;
	
epilog

	delete lcs;
	delete theTIs;
	delete slots;
	delete moveController;
	delete tmpLoadCC;
	
end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_col" type="Integer"/>
        <Parameter name="_tier" type="Integer"/>
        <ReturnType type="CM_VoyageJob"/>
