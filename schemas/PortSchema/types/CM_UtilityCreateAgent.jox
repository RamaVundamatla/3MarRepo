    <JadeMethod name="utlCreateWorkOrder" id="95162e49-b454-4555-9444-173d96100ceb">
        <source>utlCreateWorkOrder(_proxyWorkOrder : CM_WorkOrder; _workOrder:CM_WorkOrder output;	_passport : CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31/07/2009	cnwmd1	Initial creation
23/05/2018	jlgdap1	TFS 38560 PEL1 Voyage Work Orders
24/03/2023	navhl20	ChangeRequest 57301:[57303] EUP - [Framework] - Improve Audits on Work orders
13/11/2023	navdap1	TFS 59458 EUP | EDI Specific Performance
*/

vars
	voyageProformaTrxAction  : CMIF_TrxActionWOProforma;
	voyageProcess : CM_VoyageProcess;			// TFS 59458
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valWorkOrder(_proxyWorkOrder);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	//create _workOrder as CM_WorkOrderTI persistent;			// TFS 38560
	create _workOrder as _proxyWorkOrder.class persistent;		// TFS 38560
	_workOrder.setForCreate(_proxyWorkOrder);

	if _passport.noErrors then
		if not app.isInProformaMode then
			voyageProcess := _passport.myTerminal.getDefaultVoyageProcess();			// TFS 59458
			if voyageProcess = null or not voyageProcess.isEUPDefaultProcess then		// TFS 59458
				//epr 20/6/18 TFS 39166
				create voyageProformaTrxAction transient;
				voyageProformaTrxAction.setMyWorkOrder(_workOrder,CM_TrxControlAgent.Trx_Create);
				_passport.addTrxPostAction(voyageProformaTrxAction);
				
				//self.myCreateAuditAgent.audCreateGeneric(_workOrder);
			endif;																		// TFS 59458
		endif;
		
		
	endif;
	
	if _passport.noErrors then										//24.3.2023 navhl20	#57301[57303]
		self.myCreateAuditAgent.audCreateGeneric(_workOrder);
	endif;
	
epilog

end;</source>
        <Parameter name="_proxyWorkOrder" type="CM_WorkOrder"/>
        <Parameter name="_workOrder" type="CM_WorkOrder" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateWorkOrderAction" id="45da067d-6949-4c53-86ca-2a234d0e2952">
        <updating/>
        <source>utlCreateWorkOrderAction(_woActionIF : CMIF_WorkOrderAction;
						 _passport	 : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29/07/2009	cnwrd1	Initial creation
28/05/2018	jlgdap1	TFS 38560 PEL1 Voyage Work Orders
08 Feb 2023 navma1  ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
28 Mar 2023 navhl20 ChangeRequest 57301:[57303] EUP - [Framework] - Improve Audits on Work orders
*/

vars
	workOrderDtl 	: CM_WorkOrderDtl;
	trxAA 	   		: CM_UpdateTransactionAuditAgent;
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valWorkOrderAction(_woActionIF,	_passport);

	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	workOrderDtl := _woActionIF.myWorkOrderDtl.CM_WorkOrderDtl;	
	
	create trxAA transient;													//28.3.2023 navhl20	#57301[57303]
	trxAA.audUpdateGeneric(workOrderDtl.myParent, true);					//28.3.2023 navhl20	#57301[57303]
	
	if workOrderDtl &lt;&gt; null then	
		workOrderDtl.actionItems( 	_woActionIF,	_passport);
	endif;
	
	if _passport.noErrors then												//28.3.2023 navhl20	#57301[57303]
		trxAA.audUpdateGeneric(workOrderDtl.myParent, false);
	endif;
epilog
	delete trxAA;
end;</source>
        <Parameter name="_woActionIF" type="CMIF_WorkOrderAction"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
