    <JadeMethod name="btnDetails_click" id="690fca2e-f52d-4d52-a84c-bd22ab6484dd">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDetails_click(btn: Button input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/05/2021	navdap1		Initial creation TFS 50878 ASPA Bulk Barge Cargo Creation
//
vars

begin
	self.doShowCargoDetailsForm();
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="changeIDsIfRequired" id="72a9d520-00e6-4e59-9629-f4a3713ce5c8">
        <source>changeIDsIfRequired(_prefix : String; _number : Integer);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/06/2021	navdap1		Initial creation TFS 51381 ASPA Bulk Barge Create - Cargo ID
//
vars
	idx : Integer;
	ti : CM_TrackedItem;
	vessel : CM_Vessel;
	cargoId : String;

begin
	idx := 1;
	while idx &lt;= self.allTrackedItems.size do
		ti := self.allTrackedItems[idx];
		vessel := self.allVessels[idx].CM_Vessel;
		
		cargoId := self.myAssistant.generateCargoIdForBargeCargo(_prefix, _number, vessel);
		if cargoId &lt;&gt; ti.id then
			ti.zSetPxyId(cargoId);
		endif;
		idx := idx + 1;
	endwhile;
epilog

end;</source>
        <Parameter name="_prefix" type="String"/>
        <Parameter name="_number" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="changeVessel" id="dd18605c-2988-4b26-a0bc-e81596e65112">
        <updating/>
        <source>changeVessel()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2020	jlgndl1	Initial creation	TFS 49417

*/

vars

	oper : CM_Operator;
	shipLine : CM_ShippingLine;
	bu : CM_Bank;

begin

	self.myCurrentVessel := self.cmbVessel.listObject.CM_Vessel;
//	oper := self.cmbOperator.listObject.CM_Operator;
//	shipLine := self.cmbShipLine.listObject.CM_ShippingLine;
//	bu := self.cmbBusUnits.listObject.CM_Bank;
	
	if self.myCurrentVessel = null then
		self.cmbOperator.listIndex := -1;
		self.cmbShipLine.listIndex := -1;
		self.txtExtRef.text := null;
		return;
	endif;
	
	//set defaults if not set
	if oper = null then
		oper := self.myCurrentVessel.myOperator;
	endif;
	if oper &lt;&gt; null then
		self.cmbOperator.listIndex := self.cmbOperator.findObject( oper );
	endif;
	
	if shipLine = null and self.myCurrentVessel.myHMSVesselData &lt;&gt; null then
		shipLine := self.myCurrentVessel.myHMSVesselData.myDefaultShippingLine;
	endif;
	if shipLine &lt;&gt; null then
		self.cmbShipLine.listIndex := self.cmbShipLine.findObject( shipLine );
	endif;
	
	if bu = null then
		bu := self.myTerminal.getDefaultCompanyBank();
	endif;
	if bu &lt;&gt; null then
		self.cmbBusUnits.listIndex := self.cmbBusUnits.findObject( bu );
	endif;
	
	
	
	
	

epilog

end;</source>
    </JadeMethod>
