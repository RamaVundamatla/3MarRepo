    <JadeMethod name="tblReleasedTrackedItems_click" id="45b81f5d-e495-471e-a8b3-a15837bab8f1">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblReleasedTrackedItems_click(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 September 2025	navcs2	Initial creation

*/

vars
	tbl			: CM_DataTable;
	ti			: CM_TrackedItem;
	location	: CM_LocationsController;
	trans		: CM_TITransaction;
	move		: CM_Move;
	ta			: CM_TerminalArea;
begin
	tbl :=  self.tblReleasedTrackedItems;
	if tbl.myInitialSelectObject &lt;&gt; null then
		ti := tbl.myInitialSelectObject.CMIF_MoveQuantityTI.myTI;
	endif;
	
	if ti &lt;&gt; null then
		foreach trans in ti.getAllTransactionsOfType(TRANS_TYPE_MOVE) do
			move := trans.CM_Move;
			if trans.CM_Move.getSourceLocationsController &lt;&gt; null and trans.CM_Move.getSourceLocationsController.isYardLocation then
				location := trans.CM_Move.getSourceLocationsController();
				ta  := location.getMyTerminalArea();
				break;
			endif;
		endforeach;
		
		if ta &lt;&gt; null then
			self.cmbTerminalArea.setIndexFromObject(ta);
		endif;
		
		if location &lt;&gt; null then
			self.buildCmbSubTerminalAreas(ta);
			self.cmbTerminalSubArea.setIndexFromObject(location);
		endif;
	endif;
	
	
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
