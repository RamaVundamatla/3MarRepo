<CollClass name="DateArray">
    <JadeMethod name="jssDoSort" id="ab5ba05d-f485-48aa-9ad5-6f32bb789000">
        <lockReceiver/>
        <updating/>
        <source>jssDoSort(pTheSorter : JSSSorter) lockReceiver, updating, protected;
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Purpose:		Refer to method implementation on the Array class.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	arrayPointer	: Integer;
	dateValue		: Date;
	theSortKey		: Object;
	anyValue		: Any;

begin
	foreach dateValue in self do
		pTheSorter.addValue(dateValue);
	endforeach;
	
	self.purge();
	
	foreach theSortKey in pTheSorter.mySortColl do
		self.add(theSortKey.JSSSortKey.getValue().Date);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pTheSorter" type="JSSSorter"/>
    </JadeMethod>
</CollClass>
