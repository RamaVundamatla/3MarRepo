    <JadeMethod name="handleNotification" id="b7b7681b-1696-404a-ab58-4bb2c399e997">
        <source>handleNotification(eventType: Integer; theObject: Object);
//----------------------------------------------------------------
//	Created:	27 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	termEvent : Integer;
begin

	if eventType = Object_Update_Event then
		//update the object already in the table
		self.doTblUpdateObject(theObject.CM_EDITrackedItem);
	else
		termEvent := self.myTerminal.getEventFromTerminalEvent(eventType);
		if termEvent = Event_CusResEDITI_Create then
			//add object if suitable
			self.doTblAddCreated(theObject.CM_EDIFile);
		elseif termEvent = Event_EDITI_Delete then
			//remove lines
			self.doTblRemoveDeleted(theObject.CM_EDIData);
		endif;
	endif;
	

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="includeObject" id="f93375b1-cc26-4092-8af3-d21af7dbb02d">
        <source>includeObject(_ediTI: CM_EDITrackedItem): Boolean protected;
//----------------------------------------------------------------
//	Created:	20 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	csTI	: CM_EDICustomStopTI;
	voyage	: CM_Voyage;						// cnwrl1 13/05/2010 PAR 24221
	fromLocal,
	toLocal,
	fromSystem,
	toSystem: TimeStamp;
	
begin
// cnwdad1 23/07/2010 - PAR #25135.
//	csTI := _ediTI.CM_EDICustomStopTI;		&lt;&lt;--- Removed this, and added test for CM_EDICustomStopTI kind below.
	if _ediTI.isKindOf(CM_EDICustomStopTI) then
		csTI := _ediTI.CM_EDICustomStopTI;
	else
		return false;
	endif;
	
	//date range ok?
	if csTI.fileDateTime.isValid() then		// 16/6/16 cnwmp6 TFS 488 - Multi timezone support
//	and (not csTI.fileDateTime.date.cnEcIsBetween(self.txtStartDate.getDate(), self.txtEndDate.getDate())) then
		if self.txtStartDate.text.Date.isValid() then
			fromLocal.setDate(self.txtStartDate.text.Date);
			fromLocal.setTime("0:00:00".Time);
			fromSystem := self.localToSystemTime(fromLocal);
			if csTI.fileDateTime &lt; fromSystem then
				return false;	
			endif;
		endif;

		if self.txtEndDate.text.Date.isValid() then
			toLocal.setDate(self.txtEndDate.text.Date + 1);
			toLocal.setTime("0:00:00".Time);
			toSystem := self.localToSystemTime(toLocal);
			if csTI.fileDateTime &gt;= toSystem then
				return false;	
			endif;
		endif;
	endif;
	
	//voyage ok?
	if self.filterVoyageCode = self.VoyageNotSet then
//		if csTI.myVoyage &lt;&gt; null then		// cnwrl1 13/05/2010 PAR 24221 - what it was
		if csTI.getMyVoyage() &lt;&gt; null then
			return false;
		endif;
	elseif self.filterVoyageCode &lt;&gt; null then
		/* cnwrl1 13/05/2010 PAR 24221 - what it was
		if csTI.myVoyage = null
		or not global.isValidObject(csTI.myVoyage) // PAR 11177
		or csTI.myVoyage.code &lt;&gt; self.filterVoyageCode then
		cnwrl1 13/05/2010 PAR 24221 - end of what it was */
		voyage	:= csTI.getMyVoyage();
		if voyage = null
		or voyage.code &lt;&gt; self.filterVoyageCode then
			return false;
		endif;
	endif;
	
	//text search
	if self.bookingRefFilterText &lt;&gt; null
	and csTI.billOfLading.toUpper.pos(self.bookingRefFilterText.toUpper, 1) = 0 then
		return false;
	endif;
	
	if self.cedoFilterText &lt;&gt; null
	and csTI.entryNumber.toUpper.pos(self.cedoFilterText.toUpper, 1) = 0 then
		return false;
	endif;
	
	if self.consignorFilterText &lt;&gt; null
	and csTI.consignor.toUpper.pos(self.consignorFilterText.toUpper, 1) = 0 then
		return false;
	endif;
	
	if self.vesselFilterText &lt;&gt; null
	and csTI.vesselName.toUpper.pos(self.vesselFilterText.toUpper, 1) = 0 then
		return false;
	endif;
	
	if self.anyFilterText &lt;&gt; null
	and csTI.getAttributeStringForDefArray(self.tblData.allTblDataEntRows).toUpper.pos(self.anyFilterText.toUpper, 1) = 0 then
		return false;
	endif;
	
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_ediTI" type="CM_EDITrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initQueryFrame" id="bce20fb3-bc42-43ad-badb-dacdfd9f63c9">
        <updating/>
        <source>initQueryFrame() updating, protected;
//----------------------------------------------------------------
//	Created:	05 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	sht		: CMUI_Sheet;

begin
	/*
	sht := self.shtQuery1;
	sht.visible := true;
	sht.caption := "Filter Criteria";
	

	sht := self.shtQuery2;
	sht.visible := true;
	sht.caption := "Text Search";
	*/
	self.setControlsForQuery();
	
//	Adjust any controls on the query frame
//	only need to do once - not for every resize
//	self.tblTextSearch.move(0, 50, self.tblTextSearch.parent.width, self.tblTextSearch.parent.height);
	self.tblSearchText.move(0, 50, self.tblSearchText.parent.width, self.tblSearchText.parent.height);
	self.cmbVoyage.width	:= 215;
//	self.txtStartDate.width	:= 215;
//	self.txtEndDate.width	:= 215;
	self.lblTextSearch.width := 215;
	self.txtComment.width := 215;
	self.lblTextSearch.caption := app.getErrorString(TextSearchInfo); 
	self.lblComment.top := self.lblFromDate.top;
	self.txtComment.top := self.lblFromDate.top;

	
	self.myAssistant.comboBoxVoyageCurrent(	self.cmbVoyage,
											app.getMyCurrentVoyage(),  //cnwjo3 par 23105 //app.myCurrentVoyage,
											true,
											false,
											false,
											true,
											true,
											false,
											true,
											false,
											false);
	self.cmbVoyage.addItemAt(self.VoyageNotSet, 1);
	self.cmbVoyage.addItemAt(Tab, 1);
	
	self.setTextTable();
	self.setFilterDefaults();
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initTable" id="cc13e56f-bde5-4914-9b04-ded4bc142414">
        <updating/>
