    <JadeMethod name="getXlationForeignCode" id="e1c936b6-6d17-4599-ba09-5e4e3f1e082d">
        <source>getXlationForeignCode(_systemCode:String; _type:Integer; _foundMatch :Boolean output):String;
/*
Date		Who		Reason
18 Oct 2010	cnwkpd1	PAR #25810 - EDI performance changes
14 Dec 2010 cnwrs1  ccms 1976 make it work for inland voyages
07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
03 Nov 2023	jlika1	TFS 61087 - EUP - Cargo Type EDI Translations not working
*/

vars
 	operatorTerminal: CM_OperatorTerminal;
	foreignCode
	, systemCode 	: String;
	xlationTable 	: CM_XlationTable;
	terminalArray 	: ObjectArray;	//ccms 1976 cnwrs1 16 dec 2010 7.9.1 only
	thisTerminal
	, terminal 		: CM_Terminal;
	obj 			: Object;		
	cargoSubXlation : CM_XlationTable;
begin
	systemCode := _systemCode.trimBlanks;
    if systemCode &lt;&gt; null then
		if   CM_XlationTable@isOperatorTerminalXlation(_type) then //jlier1 TFS 54846 5/10/22
			thisTerminal := app.myPassport.myTerminal;	//cnwrs1 ccms 1976 15 Dec 2010	
			create terminalArray transient;
			terminalArray.add(thisTerminal);
			if _type = XLATION_TYPE_VOYAGETERMINAL then
				foreach terminal in thisTerminal.allTerminalsForVoyageInland do
					terminalArray.add(terminal);
				endforeach;
			endif;
			
			foreach obj in terminalArray do
				terminal := obj.CM_Terminal;
				
				operatorTerminal := self.allOperatorTerminals[terminal];
				
				if operatorTerminal &lt;&gt; null then	//cnwrs1 19 oct 2010 get unit test working
					xlationTable := operatorTerminal.allXlationTables[_type, null];
				endif;
				
				if xlationTable &lt;&gt; null then
					foreignCode := xlationTable.matchOnSystemCode(systemCode, _foundMatch);
				endif;
				
				if _foundMatch then
					break;
				endif;
			endforeach;
			
			if foreignCode = null then
				foreignCode := systemCode;
			endif;
		else			
			xlationTable := self.allXlationTables[_type, null];		// PAR #25810
			
			if xlationTable = null and _type = XLATION_TYPE_CARGOSUBTYPE_BYOP then
				foreach cargoSubXlation in self.allXlationTables do
					if cargoSubXlation.type = _type then
						xlationTable := cargoSubXlation;
						break;
					endif;					
				endforeach;
			endif;
			
			if xlationTable &lt;&gt; null then
				foreignCode := xlationTable.matchOnSystemCode(systemCode, _foundMatch);
			endif;
			
			if not _foundMatch then
				foreignCode := systemCode;
			endif;
		endif;
	endif;
	
	return foreignCode;
epilog
	delete terminalArray;
end;</source>
        <Parameter name="_systemCode" type="String"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_foundMatch" type="Boolean" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXlationSystemCode" id="3ca0e318-01c9-4036-808b-89dfbd380f6e">
        <source>getXlationSystemCode(_foreignCode:String; _type:Integer; _foundMatch :Boolean output):String;
/*
Date		Who		Reason
18 Oct 2010	cnwkpd1	PAR #25810 - EDI performance changes
14 Dec 2010 cnwrs1  ccms 1976 make it work for inland voyages
07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
											  - remove voyage specific code - it can be done in getXlationSystemCode_voyage
*/
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation

vars
    systemCode, foreignCode	: String;
	xlationTable 			: CM_XlationTable;
	temp : String; // TFS 43566
begin
	// force developer to use special method for MT grade etc
	if _type = XLATION_TYPE_MTGRADE_BYOP or
		_type = XLATION_TYPE_COMMODITY_BYOP or
		_type = XLATION_TYPE_VOYAGETERMINAL or
		_type = XLATION_TYPE_CARGOSUBTYPE_BYOP then 
		app.raiseUnexpectedProgramError (self.class.name, method.name, "Method called for invalid translation type");
	endif;
	
	foreignCode	:= _foreignCode.trimBlanks;

	if foreignCode &lt;&gt; null then
		xlationTable := self.allXlationTables[_type, null];		// PAR #25810
		
		if xlationTable &lt;&gt; null then
			systemCode := xlationTable.matchOnForeignCode(foreignCode, _foundMatch);	// par 31259 March 2013
		endif;
		
		if not _foundMatch then
			systemCode := foreignCode;
		endif;
	endif;
	
	return systemCode;
epilog

end;
</source>
        <Parameter name="_foreignCode" type="String"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_foundMatch" type="Boolean" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXlationSystemCode_CargoSubT" id="4b96cab4-aed5-467c-a54e-2d67bad7d70c">
        <source>getXlationSystemCode_CargoSubT( _foreignCode : String; _cargoType : CM_CargoBOLType;  _foundMatch :Boolean output) : String;
//
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
//
vars
    systemCode	: String;
	xlationTable : CM_XlationTable;
begin
	if _foreignCode &lt;&gt; null then
		xlationTable := self.allXlationTables[XLATION_TYPE_CARGOSUBTYPE_BYOP, _cargoType];
		
		if xlationTable &lt;&gt; null then
			systemCode := xlationTable.matchOnForeignCode(_foreignCode, _foundMatch);
		endif;
		
		if not _foundMatch then
			systemCode := _foreignCode;
		endif;
	endif;
	
	return systemCode;

end;
</source>
        <Parameter name="_foreignCode" type="String"/>
        <Parameter name="_cargoType" type="CM_CargoBOLType"/>
        <Parameter name="_foundMatch" type="Boolean" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXlationSystemCode_Commodity" id="6dee95f7-6d9b-4e2c-87eb-0d10b5257703">
        <source>getXlationSystemCode_Commodity(_foreignCode :String; _foundMatch :Boolean output; _temperature :Real):String;
/*
Date		Who		Reason
07 Mar 2013	cnwcs5	Initial creation - CCMS POL 2097 / par 31259
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
*/
vars
    systemCode, foreignCode	: String;
	xlationTable 			: CM_XlationTable;
begin
	foreignCode	:= _foreignCode.trimBlanks;
	
	if foreignCode &lt;&gt; null then
		xlationTable := self.allXlationTables[XLATION_TYPE_COMMODITY_BYOP, null];
		
		if xlationTable &lt;&gt; null then
			systemCode := xlationTable.matchOnForeignCode(foreignCode, _foundMatch, _temperature);	
		endif;
		
		if systemCode = null then
			systemCode := foreignCode;
		endif;
	endif;
	
	return systemCode;
epilog
	
end;
</source>
        <Parameter name="_foreignCode" type="String"/>
        <Parameter name="_foundMatch" type="Boolean" usage="output"/>
        <Parameter name="_temperature" type="Real"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXlationSystemCode_Country" id="10dba760-d3a1-49b8-97c6-f47742911a1c">
        <source>getXlationSystemCode_Country(_foreignCode:String;  _foundMatch :Boolean output):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 October 2022	jlier1	Initial creation 54846

*/

vars
	terminal : CM_Terminal;
	xlation				: CM_Xlation;
	operatorTerminal	: CM_OperatorTerminal;
    systemCode			: String; 
	    xlationTable		: CM_XlationTable;
begin
	terminal := app.myPassport.myTerminal;
				
	operatorTerminal := self.allOperatorTerminals[terminal];
	
	if operatorTerminal &lt;&gt; null then	//cnwrs1 19 oct 2010 get unit test working
		xlationTable := operatorTerminal.allXlationTables[XLATION_TYPE_COUNTRYTERMINAL, null];
	endif;
	
	if xlationTable &lt;&gt; null then
		systemCode := xlationTable.matchOnForeignCode(_foreignCode, _foundMatch);
	endif;
	
	if _foundMatch then
		return systemCode;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_foreignCode" type="String"/>
        <Parameter name="_foundMatch" type="Boolean" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXlationSystemCode_Instruct" id="331cb94f-1239-4d1a-a438-fd1bf28a3ec9">
        <source>getXlationSystemCode_Instruct(_foreignCode : String; _foundMatch : Boolean output) : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/07/2023	navdap1		Initial creation TFS 58923 EUP CallOff EDI Load / EDI Data
//
vars
	terminal : CM_Terminal;
	xlation : CM_Xlation;
	operatorTerminal : CM_OperatorTerminal;
    systemCode : String; 
	xlationTable : CM_XlationTable;

begin
	terminal := app.myPassport.myTerminal;
	operatorTerminal := self.allOperatorTerminals[terminal];
	
	if operatorTerminal &lt;&gt; null then
		xlationTable := operatorTerminal.allXlationTables[XLATION_TYPE_INSTRUCTTERMINAL, null];
	endif;
	
	if xlationTable &lt;&gt; null then
		systemCode := xlationTable.matchOnForeignCode(_foreignCode, _foundMatch);
	endif;
	
	if _foundMatch then
		return systemCode;
	endif;
	
	return _foreignCode;

epilog

end;</source>
        <Parameter name="_foreignCode" type="String"/>
        <Parameter name="_foundMatch" type="Boolean" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXlationSystemCode_MTGrade" id="71d94746-5c11-4ddc-985c-895929e7ab19">
        <source>getXlationSystemCode_MTGrade(_foreignCode :String; _foundMatch :Boolean output; _temperature :Real; _text :String):String;
/*
Date		Who		Reason
07 Mar 2013	cnwcs5	Initial creation - CCMS POL 2097 / par 31259
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
*/
vars
    systemCode, foreignCode	: String;
	xlationTable 			: CM_XlationTable;
begin
	foreignCode	:= _foreignCode.trimBlanks;
	
	if foreignCode &lt;&gt; null then
		xlationTable := self.allXlationTables[XLATION_TYPE_MTGRADE_BYOP, null];
		
		if xlationTable &lt;&gt; null then
			systemCode := xlationTable.matchOnForeignCode(foreignCode, _foundMatch, _temperature, _text);	
		endif;
		
		if systemCode = null then
			systemCode := foreignCode;
		endif;
	endif;
	
	return systemCode;
epilog
	
end;
</source>
        <Parameter name="_foreignCode" type="String"/>
