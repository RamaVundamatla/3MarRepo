    <JadeMethod name="getDisplayStringForAttribute" id="7e4f18d3-25a0-4fe1-a53d-29352a14031d">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2020 cnwma1 ChangeRequest 49906: MTN - Ops View External Webservice


*/

vars
	controller : BGP_Controller;
begin
	
	if _attrName = ETRow_WebServiceType then
		return ExternalWebServiceOPSVIEW;
	endif;

	if _attrName = ETRow_StatusBGP then // ### TFS 50669 02AUG2021 NAVAB1
		if app.isAppropriateBGPRunning(BGP_OpsViewWSRequest.name) then
			controller := app.getBGPControllerForRequest(BGP_OpsViewWSRequest.name, true);
			if controller.getStatus() &lt;&gt; "" then
				return controller.getStatus(); // IDLE, START, RUNNING, STOPPED
			else
				return EWS_STATUS_STOPPED;
			endif;
		else
			if app.isAppropriateBGPConfigured(BGP_OpsViewWSRequest.name, null) &lt; 1 then // BGP FOR OPSVIEW NOT CONFIGURED
				return "NOT CONFIGURED";
			else
				return EWS_STATUS_STOPPED;
			endif;
		endif;
	elseif _attrName = ETRow_ForceSnapshot then // ### TFS 50669 17AUG2021 NAVAB1
		return self.mandatorySnapshot.getYes();
//	elseif _attrName = ETRow_SnapshotDownTimeSend then // ### TFS 50669 17AUG2021 NAVAB1
//		return self.hoursDownBeforeSnapshot.asStringJMT();

	elseif _attrName = ETRow_StatusProducer then // ### TFS 50669 02AUG2021 NAVAB1
		if self.status &lt;&gt; null then
			return self.status;
		else
			return EWS_STATUS_STOPPED;
		endif;
	endif;
	
	return inheritMethod(_attrName, _short);
	
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isForTerminal" id="f6e475e5-9911-4c69-ac1b-4abd5d645867">
        <source>isForTerminal(_terminal: CM_Terminal): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/12/2022	navdap1		Initial creation TFS 55159 MTN - Export CAMS to JSON API Endpoint
//
vars

begin
	return _terminal = null or self.allTerminals.includes(_terminal);

epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
