    <JadeMethod name="updateSubTermForCargo" id="c0a5594d-80c6-4ac7-8779-0cb4bde24569">
        <source>updateSubTermForCargo( _preUpdateTiSet : CM_TISet; _passport : CM_Passport input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 May 2015	cnwndl1	Initial creation	Par 36181

*/

vars

	preUpdateTis : CM_TISet;
	postUpdateTis : CM_TISet;
	ti : CM_TrackedItem;
	invalidObj : Boolean;
	iter : Iterator;
	edition : Integer;
	subTerm : CM_SubTerminal;
	bank : CM_Bank;
	defaultBank : CM_Bank;

begin
	
	if not self.myTerminal.getConfig(IsSubTerminalAreaDefined).Boolean then
		return;
	endif;
	
	subTerm := self.mySubTerminal;
	bank := subTerm.getMyBank;
	defaultBank := self.myTerminal.getDefaultCompanyBank;
	
	// The cargo that was related to this Sub Terminal Area Definition prior to the update.
	create preUpdateTis transient;
	if _preUpdateTiSet &lt;&gt; null and not _preUpdateTiSet.isEmpty then
		_preUpdateTiSet.copy(preUpdateTis);
	endif;
	
	// The cargo that IS related to this Sub Terminal Area Definition NOW.
	create postUpdateTis transient;
	self.getAllTisInArea( postUpdateTis );
	
	on Exception do app.handleDeletedObject( exception, ti, invalidObj );
	
	// all the Ti's that are still here need to be set and removed from the 
	// pre update list ( they may be in both )
	iter := postUpdateTis.createIterator;
	while iter.next( ti ) do
		invalidObj := false;
		edition := ti.edition;
		if not invalidObj then
			preUpdateTis.removeIfPresent(ti);
			ti.resyncSubTerminalAndBusUnit(_passport);
		endif;
	endwhile;
	delete iter;
	
	//we should be left with only the cargo that is no longer related to this sub terminal
	// defined area, so null out the subterminal ref, and set the bank to the default
	iter := preUpdateTis.createIterator;
	while iter.next( ti ) do
		invalidObj := false;
		edition := ti.edition;
		if not invalidObj then
			ti.resyncSubTerminalAndBusUnit(_passport);
		endif;
	endwhile;
	delete iter;
	
epilog

	delete iter;
	delete preUpdateTis;
	delete postUpdateTis;

end;</source>
        <Parameter name="_preUpdateTiSet" type="CM_TISet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
