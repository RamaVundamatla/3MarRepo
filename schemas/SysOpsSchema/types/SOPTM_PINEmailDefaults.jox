    <JadeMethod name="clearThumbnailData" id="8a972904-b337-4a7c-b839-0b12df8750c8">
        <updating/>
        <source>clearThumbnailData() updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theForm : SOP_TableMaintForm;

begin
  
    theForm := self.myForm;
	theForm.tblInput1.clearValues();
	theForm.mulSelect1.setSelected(null);

end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="2c5bb4f8-e8e9-4065-8d9f-d2dafb57beba">
        <updating/>
        <source>create() updating;
//----------------------------------------------------------------
//	Created:	21 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	self.name := SOP_TableMaintForm.Table_PINEmailDefaults;
	self.permissionView	 := PmAdmPINEmailDefView;
	self.permissionMaint := PmAdmPINEmailDefMaint;
	self.myDataClass := CM_PINObjectDefaultEmail;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="686cd4ff-33b2-4ec1-b1d1-055d7546078f">
        <updating/>
        <source>doDelete(pObj: CM_Object io) updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  " disable delete button");
	app.raiseUnexpectedProgramError(class.name, method.name, 'Delete not permitted for this item type');
	
end;</source>
        <Parameter name="pObj" type="CM_Object" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="39483f90-8e0e-4f9b-86ca-b67adac3ac55">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
//	errObj				: CM_Error;
//	idx					: Integer;
//	ignoreWarnings,
//	rtnValue			: Boolean;
	proxyPINEmail		: CM_PINObjectDefaultEmail;
//	lType,
//	lName,
//	lObjectType,
	lSubjectLine,
	lMessage			: String;
//	lIsPrenote,
	lAttachCartersNote	: Boolean;
	lTerminal			: CM_Terminal;
	lEmailFields		: StringArray;
	theForm				: SOP_TableMaintForm;
	lEnabled			: Boolean;
	lCopyTo				: String;
	lSendToCarrier		: Boolean;
	lSendToConsignee	: Boolean;
	
begin
    theForm := self.myForm; 

//	lType				:= theForm.tblInput1.getValueByName(ETRow_Type).String;
//	lName				:= theForm.tblInput1.getValueByName(ETRow_Name).String;
//	lObjectType			:= theForm.tblInput1.getValueByName(ETRow_ObjectType).String;
	lSubjectLine		:= theForm.tblInput1.getValueByName(ETRow_SubjectLine).String;
	lMessage			:= theForm.tblInput1.getValueByName(ETRow_Message).String;
//	lIsPrenote			:= theForm.tblInput1.getValueByName(ETRow_IsPrenote).Boolean;
	lAttachCartersNote	:= theForm.tblInput1.getValueByName(ETRow_AttachCartersNote).Boolean;
	lEnabled			:= theForm.tblInput1.getValueByName(ETRow_Enabled).Boolean;
	// cnwrl1 29/07/2009 PAR 20349 - start of coding
	lCopyTo				:= theForm.tblInput1.getValueByName( ETRow_CopyTo ).String;
	lSendToCarrier		:= theForm.tblInput1.getValueByName( ETRow_SendToCarrier ).Boolean;
	lSendToConsignee	:= theForm.tblInput1.getValueByName( ETRow_SendToConsignee ).Boolean;
	// cnwrl1 29/07/2009 PAR 20349 - end of coding
	
	lTerminal := theForm.myTerminal;
	create lEmailFields transient;
	theForm.mulSelect1.getSelectedDisplayEntries(lEmailFields);
	if theForm.myProxyObject = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
		return false;
	endif;

	proxyPINEmail := theForm.myProxyObject.CM_PINObjectDefaultEmail;
//	proxyPINEmail.setProxyPINEmail(lSubjectLine,lMessage, lEmailFields, lAttachCartersNote, lEnabled);	// cnwrl1 29/07/2009 PAR 20349 - what it was
	proxyPINEmail.setProxyPINEmail(	lSubjectLine,
									lMessage,
									lEmailFields,
									lAttachCartersNote,
									lEnabled,
									lCopyTo,
									lSendToCarrier,
									lSendToConsignee );
	
	if theForm.mode = theForm.Mode_Add then
		app.raiseUnexpectedProgramError(class.name, method.name, 'invalid mode for this table');
		return false;
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdatePINEmail(proxyPINEmail, app.myPassport);
	endif;

	return app.myPassport.trxCompletedOK();
epilog
  	if lEmailFields &lt;&gt; null then
  		delete lEmailFields;
  	endif;
	
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
