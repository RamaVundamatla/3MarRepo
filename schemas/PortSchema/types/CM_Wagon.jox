    <JadeMethod name="setRailAllocation" id="c85ca1f9-9106-4630-b17a-babc0487439a">
        <source>setRailAllocation(_railAllocTemplate : CM_RailAllocation; _passport : CM_Passport input);
/*
----------   ----------  --------------------------------------------------
Created:	14 November 2006 By cnwth2

Purpose:	N.B. Currently the way this works is that ALL wagon controllers on a particular
			wagon have the same rail allocation. So colour coding is per wagon, not
			per wagon controller - even though rail allocation is associated with the wagon controllers.
			This is so it may by changed to 'per controller' colour coding in the future.
			
			This method is responsible for 'consolodating' rail allocations per rail area. i.e. it will
			first look to see if there are any existing allocation with exactly the same criteria and if there are
			then it will simply add this wagon's controller to that allocation. Old allocation with no wagon
			controllers left in them are cleaned up in the wagonController.setMyRailAllocation method
			
			Note also that the rail allocations have no terminal reference. They are
			only inversed to wagon controllers and rail area. This is to save having to generate some unique ID and then
			hide them from the user in the GUI. - as per design discussion with RS2 09/11/06
			
Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	yardAllocation		: CM_YardAllocation;
	realAlloc			: CM_RailAllocation;
	wagonController		: CM_WagonController;
	yaDict				: CM_YAByPriorityDict;
begin

	//wagonController := self.allLocationsControllers.first;
	wagonController := self.allLocationsControllersArray[1];	//04 Dec 2014	NDL	Par 35345
	if wagonController = null then
		return;//not confirmed - we displayed a warning that this would be skipped in the validation section of the trx
	endif;
	
	//13 Nov 2014	NDL	Par 35164
	if _railAllocTemplate = null then
		//foreach wagonController in self.allLocationsControllers do
		foreach wagonController in self.allLocationsControllersArray do	//04 Dec 2014	NDL	Par 35345
			wagonController.setRailAllocation(realAlloc);
		endforeach;
		return;
	endif;
	
	//check to see whether there is an existing rail allocation in this wagon's area that is exactly the same criteria
	//if there is one, we'll just add this wagon's controllers to it
	if wagonController.myTerminalArea &lt;&gt; null then
		yaDict := wagonController.myTerminalArea.allYardAllocations;
		foreach yardAllocation in yaDict where yardAllocation.isRailAllocation do
			if yardAllocation.CM_RailAllocation.isSameCriteria(_railAllocTemplate) then
				realAlloc := yardAllocation.CM_RailAllocation;
				break;
			endif;
		endforeach;
	endif;
	
	if realAlloc = null then
		create realAlloc persistent;
		realAlloc.setForCreateFromTemplate(_railAllocTemplate, null);
	elseif realAlloc.color &lt;&gt; _railAllocTemplate.color then //+ cnwmd1, CCMS 1067, Par 20136 - color has changed but no criteria has.
		realAlloc.setColor(_railAllocTemplate.color);
	endif;
	
	//add this wagon's controllers to it
	//foreach wagonController in self.allLocationsControllers do
	foreach wagonController in self.allLocationsControllersArray do	//04 Dec 2014	NDL	Par 35345
		wagonController.setRailAllocation(realAlloc);
	endforeach;
	
	app.myEventManager.createSingleObjInfoNoteEvt(self, self.getTerminal().getTerminalEvent(Wagon_Update_Event), self);  // PAR 21182
	
	
end;


</source>
        <Parameter name="_railAllocTemplate" type="CM_RailAllocation"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
