    </JadeMethod>
    <JadeMethod name="validateMe" id="2cb90133-c651-4c69-9ec2-2c6005d240a2">
        <source>validateMe() protected;
// ---------------------------------------------------------------------------
// Created:     02 July 2003 by cnwrs1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 13/03/2013	cnwcs5		CCMS POL 2097 / par 31259 - transaltion criteria
// ---------------------------------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
01 Jun 2013	cnwrs1	JMT821 cut, upgrade failing in Xlation conversion
15 Jul 2014	Par 34567	CCMS 2346 add EDI Xlation for Cargo Type and Cargo Sub Type
19 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
21 Mar 2017	cnwdap1	TFS 3734 AAT Vehicle Make translation type
07 Jun 2023	jlika1	TFS 58320 58319 | Jade work for Translations
08 Jun 2023	navpw1	TFS: 57813 (58438) - Added sorting method to if statement
08 Nov 2023	jlika1	TFS 61129 61013 CUX | Cargo Priority - EDI Translation
============================================================================*/

vars
	type	:Integer;
begin
	type := self.type;
	
	if type = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'XlationTable Type', null, null);
		app.raiseCMException(Input_required_field_xlatTable, null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.type = XLATION_TYPE_CARGOSUBTYPE_BYOP or 
	   self.type = XLATION_TYPE_CARGOTYPE_BYOP or 
	   self.type = XLATION_TYPE_CARRIER_BYOP or 
	   self.type = XLATION_TYPE_COMMODITY_BYOP or 
	   self.type = XLATION_TYPE_CONSIGNEE_BYOP or 
	   self.type = XLATION_TYPE_ISOTYPE_BYOP or 
	   self.type = XLATION_TYPE_MTGRADE_BYOP or	 
	   self.type = XLATION_TYPE_OPERATOR_BYOP or
	   self.type = XLATION_TYPE_PORT_BYOP or
	   self.type = XLATION_TYPE_TERMINAL_BYOP or
	   self.type = XLATION_TYPE_VESSEL_BYOP or
	   self.type = XLATION_TYPE_SHIPINGAGENT_BYOP or 
	   self.type = XLATION_TYPE_SHIPPINGLINE_BYOP or
	   self.type = XLATION_TYPE_SORTINGMETHD_BYOP or	// ### TFS 57813 (58438) 07Jun2023 NAVPW1
	   self.type = XLATION_TYPE_CUSTPRIORITY_BYOP
	   then 
		// need operator
		if self.myOperator = null then
			app.raiseUnexpectedProgramError(self.class.name, method.name, 'XlationTable parent (operator) is null');
		endif;
		if self.type = XLATION_TYPE_CARGOSUBTYPE_BYOP then 
			// need operator
			if self.myCargoType = null then
				app.raiseUnexpectedProgramError(self.class.name, method.name, 'XlationTable parent (CargoType) is null');
			endif;
		endif;
	elseif self.isSystemXlationTable then	//jlier1 TFS 54846 30/9/22
		// no operator or operator terminal required
		// no need to check root as there is only one
	elseif CM_XlationTable@isOperatorTerminalXlation(self.type) then //jlier1 TFS 54846 30/9/22		
		// need operator terminal
		if self.myOperatorTerminal = null then
			if not app.isConverting then
				app.raiseUnexpectedProgramError(self.class.name, method.name, 'XlationTable parent (operator/terminal) is null');
			endif;
		endif;
	elseif self.type = XLATION_TYPE_WORKPOINT then
		if self.myTerminal = null then		
			app.raiseUnexpectedProgramError(self.class.name, method.name, 'XlationTable parent (terminal) is null');
		endif;
		
	else
		// invalid translation type - we expect the form to take care of this 
		app.raiseUnexpectedProgramError(self.class.name, method.name, 'Invalid XlationTable Type');
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verify" id="f49eeb05-6d50-414f-9188-575ee2a0fa07">
        <source>verify(_allWarnings : HugeStringArray input);
//
// Par 17380 cnwrs1 feb 2009
// check the default settings 
//
// 15/04/203	cnwcs5	CCMS pol 2097 / par 31259
vars
	xlation, lastXlation 	: CM_Xlation;
	duplicateCode, haveOne 	: Boolean; 
	prefix, msg				: String;
	operator				: CM_Operator;
begin
	operator 	:= self.getMyOperator; 

	foreach xlation in self.allOutwardTranslations do
		prefix		:= 'Operator ' &amp; self.getTypeString (true) &amp; ' system code ' &amp; xlation.systemCode &amp; ' foreign code ' &amp; xlation.foreignCode;
		
		if operator &lt;&gt; null then
			prefix := operator.code &amp; ' ' &amp; prefix;
		endif;
		
		if xlation.getMySystemObject = null then
			// does not have a valid system object
			msg := prefix &amp; ' - null system object on outward translation';
			
			app.writeLog (msg, 0);
			
			_allWarnings.add(msg);
			
		elseif xlation.systemCode = null then
			// no system code - should not happen
			msg :=  prefix &amp; ' - null system code on outward translation';
			
			app.writeLog(msg, 0);
			_allWarnings.add(msg);
		endif;
		
		if xlation.foreignCode = null then
			// no foriegn code - agains should not happen now
			msg := prefix &amp;  ' - null foreign code on outward translation';
			
			app.writeLog(msg, 0);
			_allWarnings.add(msg);
		endif;
		
		if   CM_XlationTable@isOperatorTerminalXlation(self.type) then //jlier1 TFS 54846 5/10/22
			continue;
		endif;
		
		if lastXlation &lt;&gt; null then
			// we are looking for duplicate outward translations now
			if xlation.systemCode = lastXlation.systemCode then
				// we have at least one duplicate
				msg		:= prefix &amp; ', duplicate outward translation will never be used.';
					
				app.writeLog(msg, 0);
				_allWarnings.add(msg);
			endif;
		endif;
		
		lastXlation := xlation;		
	endforeach;

//	inward translations
	lastXlation 	:= null;
	
	foreach xlation in self.allInwardTranslations do
		prefix		:= 'Operator ' &amp; self.getTypeString (true) &amp; ' foreign code ' &amp; xlation.foreignCode &amp; ' system code ' &amp; xlation.systemCode;
		
		if operator &lt;&gt; null then
			prefix := operator.code &amp; ' ' &amp; prefix;
		endif;

		if xlation.getMySystemObject = null then
			// does not have a valid system object
			msg := prefix &amp; ' - null system object on inward translation';
			
			app.writeLog (msg, 0);
			
			_allWarnings.add(msg);
			
		elseif xlation.systemCode = null then
			// no system code - should not happen
			msg :=  prefix &amp; ' - null system code on inward translation';
			
			app.writeLog(msg, 0);
			_allWarnings.add(msg);
		endif;
		
		if xlation.foreignCode = null then
			// no foriegn code - agains should not happen now
			msg := prefix &amp;  ' - null foreign code on inward translation';
			
			app.writeLog(msg, 0);
			_allWarnings.add(msg);
		endif;
		
		if   CM_XlationTable@isOperatorTerminalXlation(self.type) then //jlier1 TFS 54846 5/10/22
			// duplicates OK for voyage
			continue;
		endif;
		
		if xlation.CM_Xlation_In.myXlationCriteria &lt;&gt; null then
			// duplicates OK with criteria
			continue;
		endif;
		
		if lastXlation &lt;&gt; null then
			if xlation.foreignCode = lastXlation.foreignCode then
				// we have a duplicate inward transaction - OK if we have criteria but not otherwise
				msg := prefix &amp; ',  duplicate inward translation will never be used';
				
				app.writeLog(msg, 0);
				_allWarnings.add(msg);
			endif;
		endif;
		
		lastXlation := xlation;
	endforeach;
end;</source>
        <Parameter name="_allWarnings" type="HugeStringArray" usage="input"/>
    </JadeMethod>
</Class>
