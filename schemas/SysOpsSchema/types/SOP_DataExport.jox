	self.cmbOIDFormat.itemData[row] := CM_DataDumpExtractDef.OIDFormatHex;
	
	row := self.cmbOIDFormat.addItem(global.getOIDFormatDescr(CM_DataDumpExtractDef.OIDFormatString));
	self.cmbOIDFormat.itemData[row] := CM_DataDumpExtractDef.OIDFormatString;

	self.cmbOIDFormat.listIndex := 1;

	self.comboOIDFormatSelect();
end;</source>
        <access>protected</access>
    </JadeMethod>
