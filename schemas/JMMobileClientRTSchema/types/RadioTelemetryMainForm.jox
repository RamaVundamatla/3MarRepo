    <JadeMethod name="aState" id="4de874e6-ec6b-4f7e-9a07-d4386a0f6873">
        <methodInvocation>mapping</methodInvocation>
        <source>aState(set: Boolean; _value: Integer io) mapping;
// -------------------------------------------
// Created 18 January 2006 by cnwdvb1
// -------------------------------------------
begin
	if set and _value = RadioTelemetryGuiAgent.Error then
		_value := self.aState;
		return;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="adjustColorsAfterLogon" id="89a59e84-5868-4347-8b76-497d18fa46c3">
        <updating/>
        <source>adjustColorsAfterLogon(	_sysColorBackGeneral,
						_sysColorForeGeneral,
						_sysColorBackTable,
						_sysColorForeTable,
						_userColorBackGeneral,
						_userColorForeGeneral,
						_userColorBackTable,
						_userColorForeTable : Integer) protected, updating;
// -------------------------------------------
// Created 25 January 2006 by cnwdvb1
// -------------------------------------------
vars
//	iniColorBackground,
//	iniColorForeground	: Integer;
	
begin
	app.writeSystemColorsToIni(_sysColorBackGeneral, _sysColorForeGeneral, _sysColorBackTable, _sysColorForeTable);
	
	if _userColorBackGeneral &lt;&gt; -1 and _userColorForeGeneral &lt;&gt; -1
	and _userColorBackTable &lt;&gt; -1 and _userColorForeTable &lt;&gt; -1
	then
		app.setApplicationColors(_userColorBackGeneral, _userColorForeGeneral, _userColorBackTable, _userColorForeTable);
	else
		app.setApplicationColors(_sysColorBackGeneral, _sysColorForeGeneral, _sysColorBackTable, _sysColorForeTable);
	endif;
	
	self.doApplyScreenColors();
end;</source>
        <access>protected</access>
        <Parameter name="_sysColorBackGeneral" type="Integer"/>
        <Parameter name="_sysColorForeGeneral" type="Integer"/>
        <Parameter name="_sysColorBackTable" type="Integer"/>
        <Parameter name="_sysColorForeTable" type="Integer"/>
        <Parameter name="_userColorBackGeneral" type="Integer"/>
        <Parameter name="_userColorForeGeneral" type="Integer"/>
        <Parameter name="_userColorBackTable" type="Integer"/>
        <Parameter name="_userColorForeTable" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="automaticGetNextTask" id="2ebc43b8-4434-46ea-97c0-783b0b100e20">
        <source>automaticGetNextTask() : Boolean protected;

vars

begin
	return app.myRTGuiAgent.RadioTelemetryGuiAgentThin.myRTThinClientAgent.automaticGetNextTask();
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
