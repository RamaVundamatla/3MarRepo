    <JadeMethod name="lstTblStop_displayRow" id="e9fc5c3f-1f3b-4f4e-9de1-0e01967efb4c">
        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstTblStop_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;
// ---------------------------------------------------------------------------
// Created:     12 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 17 Mar 2021  cnwma1      Bug 50912: SNO -- Missing STOP list while creating a new report type = Cargo Report
vars
	selected	: Boolean;
	stopTable   : CM_StopsTable;
begin

	if obj = null then                  //17.03.2021 cnwma1 #50912
		return null;
	endif;
	
	selected	 := table.CMUI_ListTable.allSelectedObjects.includes(obj);
	stopTable	 := obj.CM_StopsTable;  //17.03.2021 cnwma1 #50912
	
	//return self.myAssistant.displayEntryStopsTableList(obj.CM_StopsTable, selected, true);  //17.03.2021 cnwma1 #50912
	
	//17.03.2021 cnwma1 #50912
	if selected then
		return TableCheckBox_Selected &amp; Tab &amp; stopTable.code &amp; " - " &amp; stopTable.heading;
	else
		if app.myRoot.allAvailableStopsTables.includes(stopTable)  then
			return TableCheckBox_NotSelected &amp; Tab &amp; stopTable.code &amp; " - " &amp; stopTable.heading;
		else
			return null;
		endif;
	endif;
	
end;</source>
