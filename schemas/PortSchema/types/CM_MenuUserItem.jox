    <JadeMethod name="getMyMenuRoot" id="c1899744-5335-40ae-92ed-6ecc82159969">
        <source>getMyMenuRoot() : CM_MenuRoot;
// ---------------------------------------------------------------------------
// Created:     28 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	parent : CM_MenuEntity;
begin
	
	parent := self.myParent;
	
	if self.myMenuRoot &lt;&gt; null then
		return self.myMenuRoot;
	elseif parent &lt;&gt; null then
		if parent = self then //par17772 cnwrs1 Aug 2008 can end up in an endless loop
			return self.myMenuRoot;
		elseif parent.myParent &lt;&gt; null then
			if parent.myParent = self then //par17772 cnwrs1 Aug 2008 can end up in an endless loop
				return self.myMenuRoot;
			endif;
		endif;
		return parent.getMyMenuRoot();
	endif;	
	return null;

end;</source>
        <ReturnType type="CM_MenuRoot"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="65094cb5-1259-4ff9-9365-f645785aab25">
        <source>getMyTerminal(): CM_Terminal;
// ---------------------------------------------------------------------------
// Created:     19 August 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if self.myTerminal &lt;&gt; null then
		return app.myRoot.getTerminalForScenario(self.myTerminal);
		//return self.myTerminal;
	endif;
	
	if self.myMenuRoot &lt;&gt; null then
		return self.myMenuRoot.getMyTerminal();
	elseif self.myParent &lt;&gt; null then
		return self.myParent.getMyTerminal();
	endif;
	
end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
