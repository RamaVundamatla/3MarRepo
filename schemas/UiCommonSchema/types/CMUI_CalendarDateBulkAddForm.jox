    <JadeMethod name="delete" id="cac326ce-0380-4783-b5ca-349699fe0cec">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>delete() updating, clientExecution;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 October 2010	cnwndl1	Initial creation

*/

vars

begin

	if not self.allTransCalendarDates.isEmpty then
		self.allTransCalendarDates.purge;
	endif;
	
	if not self.allTemplateDatesByMonth.isEmpty then
		self.allTemplateDatesByMonth.purge;
	endif;
	
	if not self.allTemplateDatesByDay.isEmpty then
		self.allTemplateDatesByDay.purge;
	endif;
	
	
epilog

end;</source>
