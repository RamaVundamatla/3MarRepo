    </JadeMethod>
    <JadeMethod name="setupForCreate" id="fb8df79f-2455-42e8-ac3a-6bc9bfe2c9c6">
        <updating/>
        <source>setupForCreate(_proxyLocationStatistics : CM_LocationStatistics) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2008	conkc1	Initial creation

*/

vars

begin
	if _proxyLocationStatistics.myParent = null then
		return;
	endif;
	clearSystemCounts;
	self.c20Projected  := 0;
	self.c30Projected  := 0;
	self.c40Projected  := 0;
	self.c45Projected  := 0;
	self.c53Projected  := 0;
	self.myParent      := _proxyLocationStatistics.myParent;
epilog

end;</source>
        <Parameter name="_proxyLocationStatistics" type="CM_LocationStatistics"/>
    </JadeMethod>
    <JadeMethod name="update" id="f904d715-6661-4e6f-9fec-2f619049823c">
        <updating/>
        <source>update(_proxy : CM_LocationStatistics) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2008	conkc1	Initial creation

*/

vars

begin
	self.c20Used      := _proxy.c20Used;
	self.c30Used      := _proxy.c30Used;
	self.c40Used      := _proxy.c40Used;
	self.c45Used      := _proxy.c45Used;
	self.c53Used      := _proxy.c53Used;

	self.c20PlannedOut := _proxy.c20PlannedOut;
	self.c30PlannedOut := _proxy.c30PlannedOut;
	self.c40PlannedOut := _proxy.c40PlannedOut;
	self.c45PlannedOut := _proxy.c45PlannedOut;
	self.c53PlannedOut := _proxy.c53PlannedOut;

	self.c20QueuedOut  := _proxy.c20QueuedOut;
	self.c30QueuedOut  := _proxy.c30QueuedOut;
	self.c40QueuedOut  := _proxy.c40QueuedOut;
	self.c45QueuedOut  := _proxy.c45QueuedOut;
	self.c53QueuedOut  := _proxy.c53QueuedOut;

	self.c20PlannedIn  := _proxy.c20PlannedIn;
	self.c30PlannedIn  := _proxy.c30PlannedIn;
	self.c40PlannedIn  := _proxy.c40PlannedIn;
	self.c45PlannedIn  := _proxy.c45PlannedIn;
	self.c53PlannedIn  := _proxy.c53PlannedIn;

	self.c20QueuedIn   := _proxy.c20QueuedIn;
	self.c30QueuedIn   := _proxy.c30QueuedIn;
	self.c40QueuedIn   := _proxy.c40QueuedIn;
	self.c45QueuedIn   := _proxy.c45QueuedIn;
	self.c53QueuedIn   := _proxy.c53QueuedIn;

	self.c20Projected  := _proxy.c20Projected;
	self.c30Projected  := _proxy.c30Projected;
	self.c40Projected  := _proxy.c40Projected;
	self.c45Projected  := _proxy.c45Projected;
	self.c53Projected  := _proxy.c53Projected;

	self.c20Free      := _proxy.c20Free;
	self.c30Free      := _proxy.c30Free;
	self.c40Free      := _proxy.c40Free;
	self.c45Free      := _proxy.c45Free;
	self.c53Free      := _proxy.c53Free;

	self.c20Total     := _proxy.c20Total;
	self.c30Total     := _proxy.c30Total;
	self.c40Total     := _proxy.c40Total;
	self.c45Total     := _proxy.c45Total;
	self.c53Total     := _proxy.c53Total;

epilog

end;</source>
        <Parameter name="_proxy" type="CM_LocationStatistics"/>
    </JadeMethod>
</Class>
