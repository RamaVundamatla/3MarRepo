    <JadeMethod name="trxUpdateVehicleVisitFlexi" id="e67be5b3-b7a8-4f9c-92cf-7d863a2b4bf1">
        <updating/>
        <source>trxUpdateVehicleVisitFlexi(_pxyObject : CM_VehicleVisitRecord; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     September 2008 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
//19 May 2025	jlier1	MTN-34221 refactoring validation so is before trx 

vars

begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(true);
	
	_pxyObject.validateForUpdate(_passport);
	
	endLoad;		// to clear any locks that may have been held as part of validation
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	beginTransaction;

	app.myUtilityUA.utlUpdateVehicleVisitFlexi(_pxyObject,false,  _passport);

epilog
	self.finaliseActivityWithPassportEW(_passport, true);
end;</source>
        <Parameter name="_pxyObject" type="CM_VehicleVisitRecord"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateVehicleVisitFlexis" id="d7dbe767-f246-49ba-8e24-9e9516e548a7">
        <updating/>
        <source>trxUpdateVehicleVisitFlexis(_vvrSet : CM_VehicleVisitRecordSet; 
						  _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 March 2023	navsp1	Initial creation TFS Bug 57269: FR | 53667 - EUP - Inspection App checks - Bulk Edit
19 May 2025	jlier1	MTN-34221 refactoring validation so is before trx 
*/

vars
	vvr		: CM_VehicleVisitRecord;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	
	app.setContinueCMExceptions(true);
	foreach vvr in _vvrSet discreteLock do
		vvr.validateForUpdate(_passport);
	endforeach;
	
	endLoad;		// to clear any locks that may have been held as part of validation
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
		
	app.setContinueCMExceptions(false);
	
	_passport.useTITransactionDeferUpdate := true;
	_passport.useTIDictDeferUpdate := true;
	
	beginTransaction;
	
	foreach vvr in _vvrSet do
		app.myUtilityUA.utlUpdateVehicleVisitFlexi(vvr,false,  _passport);
		if (not _passport.noErrors) then
			break;
		endif;
	endforeach;

	if _passport.noErrors then
		_passport.doDeferredUpdates();
	endif;
epilog
	self.finaliseActivityWithPassportEW(_passport, true);
end;</source>
        <Parameter name="_vvrSet" type="CM_VehicleVisitRecordSet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
