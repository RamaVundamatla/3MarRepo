    <JadeMethod name="testSendEmail" id="abb2bbef-79a8-4403-9f77-313963998c5f">
        <source>testSendEmail();
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	strArray:StringArray;
begin
	app.initialize;
	beginTransientTransaction;
	create strArray sharedTransient;
	strArray.add("rsargent@jadeworld.com");
	strArray.add("Hello");
	strArray.add("The Message.");
	commitTransientTransaction;
	app.startApplicationWithParameter("PortSchema","SendEmail",strArray);
end;</source>
    </JadeMethod>
