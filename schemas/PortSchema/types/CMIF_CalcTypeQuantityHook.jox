    <JadeMethod name="amendQuantity" id="7edded97-0aca-4290-a37f-d10a8ca7b323">
        <source>amendQuantity(_cmif : CMIF_CalcTypeQuantityHook) : Real;
/*

Purpose:			

Parameters:			This is the example code for Pelindo1 to be used in the 'Quantity Hook Code'
					of the Calculation Type of 'PEL1 Base To Base Tug' using 'HMS - Time Block (Hours)'
					and processing HMS_VTMISTransactions.

Return Value:		

Date		Who		Reason
13 November 2018	jlgndl1	Initial creation	TFS 41964
23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/
vars

	origQty : Real;
	berth : HMS_Berth;
	minutes : Integer;
	extraMins : Integer;
	hours : Integer;
	remainder : Real;
	retValue : Real;
	canLogExtra	: Boolean;	//28.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//28.02.2025 navah1	#34141
	
	origQty := _cmif.origQty; // Hours and parts of
	if canLogExtra then	//28.02.2025 navah1	#34141
		app.invLog( "Original time in hours = " &amp; origQty.asStringJMT, LogINFO.String);
	endif;
	
	minutes := ( origQty * 60 ).Integer;
	if canLogExtra then	//28.02.2025 navah1	#34141
		app.invLog( "Original time in minutes = " &amp; minutes.asStringJMT, LogINFO.String);
	endif;
	
	berth := _cmif.getBerthFromTrxMovement(); //this method attempts to derive the Berth from the transaction
												// and does its own logging.
	if berth &lt;&gt; null then
		extraMins := berth.baseToBaseTugDuration;
		if canLogExtra then	//28.02.2025 navah1	#34141
			app.invLog( "Berth base to base in minutes = " &amp; extraMins.asStringJMT, LogINFO.String);
		endif;
		if extraMins &lt;&gt; 0 then
			minutes := minutes + extraMins;
			if canLogExtra then	//28.02.2025 navah1	#34141
				app.invLog( "Combined time in minutes = " &amp; minutes.asStringJMT, LogINFO.String);
			endif;
		endif;
	endif;
	
	if minutes = 0 then
		//nothing more to do, bail.
		if canLogExtra then	//28.02.2025 navah1	#34141
			app.invLog( "Combined time in minutes = zero", LogINFO.String);
		endif;
		return retValue;
	endif;
	
	hours := minutes div 60; 		//Whole hours
	remainder := minutes mod 60;	//Whole minutes
	if canLogExtra then	//28.02.2025 navah1	#34141
		app.invLog( "Converted to " &amp; hours.asStringJMT &amp; " hours and " &amp; remainder.asStringJMT &amp; " minutes", LogINFO.String);
	endif;
	//Now round up to the neares 1/2 hour.
	if remainder = 0 then
		// exactly on teh hour, no rounding
		retValue := hours;
		if canLogExtra then	//28.02.2025 navah1	#34141
			app.invLog( "No rounding required " &amp; retValue.asStringJMT &amp; " hours", LogTRACE.String);
		endif;
	else
		if remainder &lt;= 30 then
			//less than or exactly 1/2 hour, call it 30 minutes
			retValue := hours + .5;
		else
			//more than 1/2 hour, call it an hour
			retValue := hours + 1;	
		endif;
		if canLogExtra then	//28.02.2025 navah1	#34141
			app.invLog( "Rounded to " &amp; retValue.asStringJMT &amp; " hours", LogTRACE.String);
		endif;
	endif;
	
	return retValue;
	
end;</source>
        <Parameter name="_cmif" type="CMIF_CalcTypeQuantityHook"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="amendShiftFenders" id="f972720f-30f1-4f53-a18b-235c5937e656">
        <source>amendShiftFenders();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 April 2019	jlger1	Initial creation

*/

vars
	voyage : CM_Voyage;
	movement : HMS_VoyageMovement;
	iter : Iterator;
	resUsed : HMS_ResourceUsed;
	calcType : CM_CalculationType;
	currentResourceUsed : HMS_ResourceUsed;
	invLine : CM_InvoiceLine;
	charge : CM_Charge;
begin

	if self.myTransaction &lt;&gt; null and self.myTransaction.isKindOf( HMS_VTMISTransaction ) then
		movement := self.myTransaction.HMS_VTMISTransaction.myMovement.HMS_VoyageMovement;
		currentResourceUsed:=self.myTransaction.HMS_VTMISTransaction.myResourceUsed;
		if currentResourceUsed = null then
			return;
		endif;
		if movement = null then
			return;
		endif;
		if movement.isMovementTypeDeparture then
			if movement.myPreviousMovement.isMovementTypeShift then
				iter:= movement.myPreviousMovement.HMS_VoyageMovement.allResourceUsed.createIterator;
				while iter.next(resUsed) do
					if currentResourceUsed.myResourceType = resUsed.myResourceType then
						calcType:=resUsed.myVTMISTransaction.getCalcTypeForTransaction;
						if calcType = null then
							continue;
						endif;
						if calcType.calculationType = INV_CALC_TYPE_RESOURCE_DAYS then
							//this is for shift and there is already one for the departure then 
							//return null;
							foreach invLine in resUsed.myVTMISTransaction.allInvoiceLines discreteLock do
								foreach charge in invLine.charges discreteLock do
									charge.void;
								endforeach;
							
							
							endforeach;
						endif;
					endif;
					
				endwhile;	
			endif;	
			
			
		endif;
		
	endif;
	
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="getBerthFromTrxMovement" id="1d776dc9-b135-48d8-a8a2-36c353c96562">
        <source>getBerthFromTrxMovement():HMS_Berth;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 November 2018	jlgndl1	Initial creation	TFS 41964
23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars

	voyage : CM_Voyage;
	movement : HMS_VoyageMovement;
	berth : HMS_Berth;
	wharf : HMS_Wharf;
	canLogExtra	: Boolean;	//28.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//28.02.2025 navah1	#34141

	if self.myTransaction &lt;&gt; null and self.myTransaction.isKindOf( HMS_VTMISTransaction ) then
		movement := self.myTransaction.HMS_VTMISTransaction.myMovement.HMS_VoyageMovement;
		if movement &lt;&gt; null then
			if canLogExtra then	//28.02.2025 navah1	#34141
				app.invLog("Movement established directly from transaction.", LogTRACE.String);
			endif;
		else
			voyage := self.myTransaction.HMS_VTMISTransaction.myVoyage;
			if voyage &lt;&gt; null then
				movement := voyage.getMovementForDateTime( self.myTransaction.createdTime );
				if movement &lt;&gt; null then
					if canLogExtra then	//28.02.2025 navah1	#34141
						app.invLog("Movement established from Voyage via transaction created time.", LogTRACE.String);
					endif;
				endif;
			endif;
		endif;
	endif;
	
	if movement = null then
		if canLogExtra then	//28.02.2025 navah1	#34141
			app.invLog("No Movement found via transaction.", LogTRACE.String);
		endif;
	else
		if movement.moveType = HMSMovementTypeArrival then
			berth := movement.getMyBerth;
		elseif movement.moveType = HMSMovementTypeShift then
			wharf := movement.getMyWharf;
			if wharf &lt;&gt; null and not wharf.isLogicalWharf then
				berth := movement.getMyBerth;
			else
				berth := movement.getMyBerthPrevious;
			endif;
		elseif movement.moveType = HMSMovementTypeDeparture then
			berth := movement.getMyBerthPrevious;
		endif;
		if canLogExtra then	//28.02.2025 navah1	#34141
			if berth = null then
				app.invLog("No Berth found on Movement.", LogTRACE.String);
			else
				app.invLog("Berth = " &amp; berth.getDisplayString, LogTRACE.String );
			endif;
		endif;
	endif;
	
	return berth;

epilog

end;</source>
        <ReturnType type="HMS_Berth"/>
    </JadeMethod>
</Class>
