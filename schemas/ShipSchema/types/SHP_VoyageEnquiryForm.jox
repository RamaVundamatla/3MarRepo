	if self.myCurrentVoyage &lt;&gt; null then
		wodVoyageCargoRequest := self.myCurrentVoyage.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_CARGOINITIAL).CM_WodVoyageCargoRequest;
