    <JadeMethod name="btnUseShipExch_click" id="614f675c-bf31-4ee3-b863-5fe76f3c76f6">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnUseShipExch_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2009	cnwndl1	Initial creation CCMS 1031 / Par 20474

*/

vars
	
begin

	if self.myVoyage &lt;&gt; null then
		txtExchDate.setDate(self.myVoyage.shipExchangeDate.date);
		txtExchTime.setValue(self.myVoyage.shipExchangeDate.time);
	endif;
	
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
