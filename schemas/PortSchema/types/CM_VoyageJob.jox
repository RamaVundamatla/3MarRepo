    <JadeMethod name="groupSinglesForSLJob" id="d42ea79e-8880-4486-bb85-84e2c81a2d3d">
        <source>groupSinglesForSLJob(_array : CMIF_CustomSequenceObjectArray input; _dynaTwin : DynaDictionary input;_isStarBoard : Boolean);
// ---------------------------------------------------------------------------
// Created:     July 2008 ANDREW BISHOP
//
// Purpose:     Take the slots in a predefined order and renumber them
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 21JUL2008		CNWAB1			Created for PAR 17412
// ---------------------------------------------------------------------------

vars

	obj,
	obj2,
	objSorter	: Object;		
	sorter,
	otherSorterAbove,
	otherSorterBelow,
	tmpSorter	: CMIF_CustomSequenceObject;
	slot,
	slotAbove	: CM_SlotController;
	arraySecond,
	arrayFirst,
	array40: ObjectArray;
	sorterDict	: CMIF_CustomSequencesBySlot;
	isTwinLift	: Boolean;
	tmpStr : String;
	tmpSorted : CMIF_CustomSequenceObjectArray;
	bay1, bay2 : CM_Bay;
begin

	// Nothing to do.
	if _array.isEmpty() then
		return;
	endif;
	
	tmpSorted := _array;
	
	// Create transient arrays
	create sorterDict transient;
	create arraySecond transient;
	create arrayFirst transient;
	create array40 transient;
	
	self.getBays(bay1, bay2);
	
	// Set up dict which is keyed by slot controller.
	_array.copy(sorterDict);
	
	
	// Go through array in the order that is passed in.
	foreach obj in tmpSorted  discreteLock do
		sorter := obj.CMIF_CustomSequenceObject;
		tmpStr := sorter.mySlotController.getFullId();
		
		
		// ### get all the 40s
//		if sorter.myRequest.is40() 
		if not sorter.myRequest.is20() then // PAR 21917
			array40.add(sorter);
			continue;
		endif;
		
		// ### single lift for the othe rbay so add them the that group
		if sorter.mySlotController.myBayVoyage &lt;&gt; bay1 then
			arraySecond.add(sorter);
			continue;
		endif;

		// ### must be a single lift for the first bay
		arrayFirst.add(sorter);
		
	endforeach;
	
	_array.clear();
	
	_dynaTwin.clear();
	arrayFirst.copy(_dynaTwin);
	_dynaTwin.copy(_array);

	_dynaTwin.clear();
	arraySecond.copy(_dynaTwin);
	_dynaTwin.copy(_array);
	
	_dynaTwin.clear();
	array40.copy(_dynaTwin);
	_dynaTwin.copy(_array);
epilog
	delete sorterDict;
	delete arraySecond;
	delete arrayFirst;
	delete array40;
end;</source>
        <Parameter name="_array" type="CMIF_CustomSequenceObjectArray" usage="input"/>
        <Parameter name="_dynaTwin" type="DynaDictionary" usage="input"/>
        <Parameter name="_isStarBoard" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="groupSinglesForTLJob" id="cc2e0a15-60ea-4883-9745-e75b7f442d61">
        <source>groupSinglesForTLJob(_array : CMIF_CustomSequenceObjectArray input; _dynaTwin : DynaDictionary input;_isStarBoard : Boolean);
// 
/*

PAR 37111 rewrote this method with defined rules DEC2015



Purpose:		Try to group the single lifts into 1 or 2 groups- before or after or both.	
Date				Who			Reason
DEC 2015		CNWAB1		Initial creation


By the time the process gets here all the slots are either twin lift, 20 single lift or 40 single lift.

Simple Rules:

1. Group all TLs together
2. Group all 40s together
3. Any SL with a TL/40 anywhere above it in the same cell must be before the TL/40s and so are added to the before group.
4. Any SL with a TL/40 anywhere below it in the same cell must be after the TL/40s and so are added to the after group.

5. After that any SLs that have not been grouped:
5.1 Compare the SL with the SLs in the before and after groups and if it is in the same tier as one of them add the ungrouped SL to the same before or after group.

6. After that any SLs that have not been grouped:
6.1 Check that there are only SL above and return the last SL that is above.
6.2 Compare that SL to the before and after grouped SLs and if it is in one of the groups add the ungrouped SL to the same group.
6.3 if the SL is still not grouped:
6.4 Compare the SL with the TLs and 40 groups and if it is in the &lt;= tier as one of the TL/40s add them to the before group

7. Default:
Add to the after group.

*/

vars
	groupAll20s, addToSLLast : Boolean;
	obj,
	obj2,
	objSorter	: Object;		
	sorter, sorter20,
	otherSorterBelow,
	tmpSorter	: CMIF_CustomSequenceObject;
	slot,
	slotAbove	: CM_SlotController;
	slBay1After,slBay1Before,
	slBay2After,slBay2Before,
	arrayTwin,allSingleSLs, allSingleSL2s,
	array40: ObjectArray;
	sorterDict	: CMIF_CustomSequencesBySlot;
	isTwinLift, added	: Boolean;
	tmpStr : String;
	tmpSorted : CMIF_CustomSequenceObjectArray;
	bay1, bay2 : CM_Bay;
	tmpSR : CM_SlotRequest;
	tmpSR2 : CM_SlotRequest;	//17 Jun 2019	NDL	TFS 45192
begin

	// Nothing to do.
	if _array.isEmpty() then
		return;
	endif;
	
	tmpSorted := _array;
	
	create sorterDict transient;
	create allSingleSLs transient;
	create allSingleSL2s transient;
	create slBay1After transient;
	create slBay1Before transient;
	create slBay2After transient;
	create slBay2Before transient;
	create arrayTwin transient;
	create array40 transient;
	
	self.getBays(bay1, bay2);
	
	// Set up dict which is keyed by slot controller.
	_array.copy(sorterDict);
	
	foreach obj in tmpSorted  discreteLock do
		sorter := obj.CMIF_CustomSequenceObject;
		tmpStr := sorter.mySlotController.getFullId();
		
		// #####################
		// ### 1. Group all TLs together
		// #####################
		if sorter.myRequest.isTwinLift(_isStarBoard) then
			arrayTwin.add(sorter);
			continue;
		endif;
		
		// #####################
		// ### 2. Group all 40s together
		// #####################
		if not sorter.myRequest.is20() then 
			array40.add(sorter);
			continue;
		endif;
		
		// #####################
		// ### 3. Any SL with a TL/40 anywhere above
		// #####################
		tmpSR := sorter.myRequest.hasCCTL40InSameJobAboveBelow(true);

		if tmpSR &lt;&gt; null then // there is a TL Above
		
			//17 Jun 2019	NDL	TFS 45192
			tmpSR2 := sorter.myRequest.hasCCTL40InSameJobAboveBelow(false);
			if tmpSR2 &lt;&gt; null then
				//we have below tLs or 40's Above and below, but we are a single
				//Add us to the tl's so we are sorted into the right tier.
				arrayTwin.add(sorter);
				continue;
			endif;
			
			if sorter.mySlotController.myBayVoyage = bay1 then
				slBay1Before.add(sorter);
			else
				slBay2Before.add(sorter);
			endif;
			continue;
		else 
			
			// #####################
			// ### 4. Any SL with a TL/40 anywhere below
			// #####################
			tmpSR := sorter.myRequest.hasCCTL40InSameJobAboveBelow(false);
			if tmpSR &lt;&gt; null then // there is a TL Above
	//			tmpSorter := tmpSorted.getSeqObjFromSlotReq(tmpSR); // PAR 17814
	
				if sorter.mySlotController.myBayVoyage = bay1 then
					slBay1After.add(sorter);
				else
					slBay2After.add(sorter);
				endif;
				continue;
			endif;
		
		endif;

		// For SLs that have no TL above or below add to an array to do a tier check afterwards.
		allSingleSLs.add(sorter);
		
	endforeach;
	
	// #####################
	// ### 5. After that any SLs that have not been grouped
	// #####################
	foreach obj2 in allSingleSLs  discreteLock do : outerloop
		sorter := obj2.CMIF_CustomSequenceObject;

		// #####################
		// ### 5.1 Compare the SL with the SLs in the before and after groups and if it is in the same tier as one of them add the ungrouped SL to the same before or after group.
		// #####################

		if sorter.mySlotController.myBayVoyage = bay1 then
			foreach obj in slBay1Before do
				tmpSorter := obj.CMIF_CustomSequenceObject;
				
				if tmpSorter.mySlotController.ordinalTier = sorter.mySlotController.ordinalTier then
					slBay1Before.add(sorter);
					continue outerloop;
				endif;
			endforeach;
			foreach obj in slBay1After do
				tmpSorter := obj.CMIF_CustomSequenceObject;
				
				if tmpSorter.mySlotController.ordinalTier = sorter.mySlotController.ordinalTier then
					slBay1After.add(sorter);
					continue outerloop;
				endif;
			endforeach;
		endif;
		
		if sorter.mySlotController.myBayVoyage = bay2 then
			foreach obj in slBay2Before do
				tmpSorter := obj.CMIF_CustomSequenceObject;
				
				if tmpSorter.mySlotController.ordinalTier = sorter.mySlotController.ordinalTier then
					slBay2Before.add(sorter);
					continue outerloop;
				endif;
			endforeach;
			foreach obj in slBay2After do
				tmpSorter := obj.CMIF_CustomSequenceObject;
				
				if tmpSorter.mySlotController.ordinalTier = sorter.mySlotController.ordinalTier then
					slBay2After.add(sorter);
					continue outerloop;
				endif;
			endforeach;
		endif;
		

		
		allSingleSL2s.add(sorter);

	endforeach;

	// #####################
	// ### 6. After that any SLs that have not been grouped
	// #####################
	foreach obj2 in allSingleSL2s  discreteLock do : outerloop
		sorter := obj2.CMIF_CustomSequenceObject;
		
		// ### 6.1  Check that there are only SL above and return the last SL that is above.
		tmpSR := sorter.myRequest.hasCCTL20InSameJobAboveBelow(true);

		if tmpSR &lt;&gt; null then // there is only SL Above
			// ### 6.2 Compare that SL to the before and after grouped SLs and if it is in one of the groups add the ungrouped SL to the same group.
			tmpSorter := tmpSorted.getSeqObjFromSlotReq(tmpSR); // PAR 17814
			
			if slBay1Before.includes(tmpSorter) then
				slBay1Before.add(sorter);
				continue outerloop;
			endif;
			
			if slBay1After.includes(tmpSorter) then
				slBay1After.add(sorter);
				continue outerloop;
			endif;
			
			if slBay2Before.includes(tmpSorter) then
				slBay2Before.add(sorter);
				continue outerloop;
			endif;
			
			if slBay2After.includes(tmpSorter) then
				slBay2After.add(sorter);
				continue outerloop;
			endif;
		endif;
		
		// ### 6.3 if the SL is still not grouped:
		// ### 6.4 Compare the SL with the TLs and 40 groups and if it is in the &lt;= tier as one of the TL/40s add them to the before group
		foreach obj in arrayTwin do
			tmpSorter := obj.CMIF_CustomSequenceObject;
			
			if tmpSorter.mySlotController.ordinalTier &gt;= sorter.mySlotController.ordinalTier  then
				if sorter.mySlotController.myBayVoyage = bay1 then
					slBay1Before.add(sorter);
				else
					slBay2Before.add(sorter);
				endif;
				continue outerloop;
			endif;
		endforeach;		
		
		foreach obj in array40 do
			tmpSorter := obj.CMIF_CustomSequenceObject;
			
			if tmpSorter.mySlotController.ordinalTier &gt;= sorter.mySlotController.ordinalTier  then
				if sorter.mySlotController.myBayVoyage = bay1 then
					slBay1Before.add(sorter);
				else
					slBay2Before.add(sorter);
				endif;
				continue outerloop;
			endif;
		endforeach;		
		
		// #################
		//### 7. DEFAULT
		// #################
		if sorter.mySlotController.myBayVoyage = bay1 then
			slBay1After.add(sorter);
		else
			slBay2After.add(sorter);
		endif;

	endforeach;

	_array.clear();
	
	_dynaTwin.clear();
	slBay1Before.copy(_dynaTwin);
	_dynaTwin.copy(_array);
	
	_dynaTwin.clear();
	slBay2Before.copy(_dynaTwin);
	_dynaTwin.copy(_array);

	
	_dynaTwin.clear();
	arrayTwin.copy(_dynaTwin);
	_dynaTwin.copy(_array);
	
	_dynaTwin.clear();
	array40.copy(_dynaTwin);
	_dynaTwin.copy(_array);
	
	_dynaTwin.clear();
	slBay1After.copy(_dynaTwin);
	_dynaTwin.copy(_array);
	
	_dynaTwin.clear();
	slBay2After.copy(_dynaTwin);
	_dynaTwin.copy(_array);

epilog

	delete sorterDict;
	delete allSingleSLs;
	delete allSingleSL2s;
	delete slBay1After;
	delete slBay1Before;
	delete slBay2After;
	delete slBay2Before;
	delete arrayTwin;
	delete array40;
end;</source>
        <Parameter name="_array" type="CMIF_CustomSequenceObjectArray" usage="input"/>
        <Parameter name="_dynaTwin" type="DynaDictionary" usage="input"/>
        <Parameter name="_isStarBoard" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="groupSinglesForTwinJob" id="5f5c62b1-3ec3-4ee9-9ac6-a892b565fe5e">
        <source>groupSinglesForTwinJob(_allLiftsObj:ObjectArray input; _allSlotsByBayDeckTierCell:CM_SlotReqByBayDeckTierCell);
// --------------------------------------------------------------------------------
// Created:		12 January 2006 by cnwdad1
//
// Purpose:		For twin lift jobs, we need to move all single lifts either to the
//				top of the order, or leave them till the very end (a twin lift includes
//				forty-foot containers).
//
//				Note that this only applies for the loading of a ship.
//
// Parameters:	_allLiftsObj - A reference to the array of lifts in the job.
//				_allSlotsByBayDeckTierCell - A reference to a collection of the Job's
//					slot requests, in order of the Bay, Deck, Tier and Cell.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 04/04/2006	cnwdad1		Added a check of the seperate length sequencing flag,
//							i.e. to seperate the sequencing of 20s and 40s (the 40s
//							will be done last if this option is set).
// --------------------------------------------------------------------------------
vars
	elementObj					: Object;
	sequenceObj					: CMIF_CustomSequenceObject;
	adjacentSequenceObj			: CMIF_CustomSequenceObject;
	slotRequestObj				: CM_SlotRequest;
	adjacentSlotObj				: CM_SlotRequest;
	allLiftsToDoFirstObj		: ObjectArray;
	allLiftsToDoLastObj			: ObjectArray;
	isSeperateLengthSeq			: Boolean;
	
begin
	isSeperateLengthSeq	:=	app.getMyTerminalDO_NOT_USE().getConfig(SeperateLengthSequencing).Boolean;

	create allLiftsToDoFirstObj transient;
	create allLiftsToDoLastObj transient;
	
	// Separate out the single-lifts at the start and the end of the job.
	
	foreach elementObj in _allLiftsObj do
		sequenceObj		:=	elementObj.CMIF_CustomSequenceObject;
		
		if sequenceObj.isTwinLiftProperty or sequenceObj.is40 then
			// Ignore twin-lifts and 40s.
			if isSeperateLengthSeq and sequenceObj.is40 then
				allLiftsToDoLastObj.add(sequenceObj);
			endif;
			continue;
		endif;
		
		slotRequestObj	:=	sequenceObj.myRequest;
		
		// If there are no containers beneath this lift, then it can be done first.
		
		adjacentSlotObj	:=	_allSlotsByBayDeckTierCell.getSlotBeneath(slotRequestObj);

		if adjacentSlotObj = null then
			// Nothing below so can do first.
			allLiftsToDoFirstObj.add(sequenceObj);
			continue;
		else
			adjacentSequenceObj	:=	self.findSequenceObjForRequest(_allLiftsObj, adjacentSlotObj);
			
			if adjacentSequenceObj &lt;&gt; null
			and allLiftsToDoFirstObj.includes(adjacentSequenceObj)
			then
				// Something below that is already being done first so can move.
				allLiftsToDoFirstObj.add(sequenceObj);
				continue;
			endif;
		endif;
		
		// If there are no containers above this lift, then it can be done last.
		
		adjacentSlotObj	:=	_allSlotsByBayDeckTierCell.getSlotAbove(slotRequestObj);
		
		if adjacentSlotObj = null then
			// Nothing above so can do last.
			allLiftsToDoLastObj.add(sequenceObj);
			continue;
		else
			adjacentSequenceObj	:=	self.findSequenceObjForRequest(_allLiftsObj, adjacentSlotObj);
			
			if adjacentSequenceObj &lt;&gt; null
			and allLiftsToDoLastObj.includes(adjacentSequenceObj)
			then
				// Something above that is already being done last so can move.
				allLiftsToDoLastObj.add(sequenceObj);
				continue;
			endif;
		endif;
	endforeach;
	
	// Now move the lifts to the appropriate place in the job.
	
	foreach elementObj in allLiftsToDoFirstObj reversed do
		sequenceObj	:=	elementObj.CMIF_CustomSequenceObject;
		_allLiftsObj.remove(sequenceObj);
		_allLiftsObj.insert(1, sequenceObj);
	endforeach;
	
	foreach elementObj in allLiftsToDoLastObj do
		sequenceObj	:=	elementObj.CMIF_CustomSequenceObject;
		_allLiftsObj.remove(sequenceObj);
		_allLiftsObj.add(sequenceObj);
	endforeach;
epilog
	delete allLiftsToDoFirstObj;
	delete allLiftsToDoLastObj;
end;
/*
	Example:

	+---+---+---+---+---+	+---+---+---+---+---+
	|3 t|5 4|10s|   |   |	|3 t| X |   |   |   |
	| A | B | J |   |   |	| G | X |   |   |   |
	+---+---+---+---+---+	+---+---+---+---+---+
	    |4 t|6 4|9 t|		    |4 t| X |9 t|
	    | C | D | E |		    | H | X | I |
	    +---+---+---+		    +---+---+---+
	    |   |   |8 t|		    |   |2 s|8 t|
	    |   |   | L |		    |   | F | Z |
	    +---+---+---+		    +---+---+---+
	    |   |   |7 t|		    |   |1 s|7 t|
	    |   |   | M |		    |   | K | N |
	    +---+---+---+		    +---+---+---+
	
	Therefore, the lift sequence would be:
	
		AG
		B
		CH
		J
		D
		F
		K
		EI
		LZ
		MN
	
	But, by moving the single-lifts to the top and bottom, we then have:
		
		 1 K
		 2 F
		 3 AG
		 4 CH
		 5 B
		 6 D
		 7 MN
		 8 LZ
		 9 EI
		10 J
	
*/</source>
        <Parameter name="_allLiftsObj" type="ObjectArray" usage="input"/>
        <Parameter name="_allSlotsByBayDeckTierCell" type="CM_SlotReqByBayDeckTierCell"/>
    </JadeMethod>
    <JadeMethod name="hasBulkRelease" id="bf7860aa-b7b5-4885-9d24-e68ff802b5ac">
        <source>hasBulkRelease() : Boolean;
// Return true if this load job has any slots marked as a bulk release. 
vars
	slotRequest : CM_Request;
begin
	if self.jobType = JOB_TYPE_LOAD then
		foreach slotRequest in self.allRequests do
			if 	slotRequest.isBulkRelease then
				return true;
			endif;
		endforeach;
	endif;
	return false;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasBulkReleaseItem" id="089a1692-0e5f-4aee-ba3f-93d4530cfcad">
        <source>hasBulkReleaseItem() : Boolean;
// Does this job have at least one bulk release slot
vars
	request : CM_Request;
begin
	foreach request in self.allRequests do
		if request.isBulkRelease then
			return true;
		endif;
	endforeach;
	return false;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
