    <JadeMethod name="doOpenCloseDimensionsSection" id="495b396e-a1b9-418f-b458-b0e38f202985">
        <updating/>
        <source>doOpenCloseDimensionsSection() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 August 2009	cnwjk3	Initial creation

*/

vars
	opening : Boolean;
begin
	if self.lblDimensions.visible then
		self.doOpenCloseSection(self.lblDimensions, self.lblCargoDetails, self.btnDimensions, opening);
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doOpenCloseSection" id="1bae4478-979b-44f9-af6e-7b72fc5f1462">
        <updating/>
        <source>doOpenCloseSection(_sectionFrame: CMUI_FieldFrame; _nextSectionFrame: CMUI_FieldFrame; _button : CMUI_Button input; _opening : Boolean io) updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 July 2009	cnwdap1	Initial creation
*/
vars

begin
	// are we opening or closing
	if _sectionFrame = self.lblAddDetails then
		_opening := self.closedAdditional;
		self.closedAdditional := not _opening;
	elseif _sectionFrame = self.lblCargoDetails then
		_opening := self.closedCargo;
		self.closedCargo := not _opening;
	elseif _sectionFrame = self.lblDimensions then
		_opening := self.closedDimensions;
		self.closedDimensions := not _opening;
	elseif _sectionFrame = self.lblReeferDetails then
		_opening := self.closedReefer;
		self.closedReefer := not _opening;
	elseif _sectionFrame = self.lblVoyageDetails then
		_opening := self.closedVoyage;
		self.closedVoyage := not _opening;
	endif;

	inheritMethod(_sectionFrame, _nextSectionFrame, _button, _opening);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_sectionFrame" type="CMUI_FieldFrame"/>
        <Parameter name="_nextSectionFrame" type="CMUI_FieldFrame"/>
        <Parameter name="_button" type="CMUI_Button" usage="input"/>
        <Parameter name="_opening" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="94264a55-1695-4ad4-9044-3f2c864c5212">
        <updating/>
        <source>doSave() : Boolean protected, updating;
// ---------------------------------------------------------------------------
// Created:     07 August 2008 by cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//	10/01/2010		cnwjre1			CCMS 1071
//	16/03/2010		cnwdap1			PAR #22604 Prevent duplicate IDs on attachments form
//	24/03/2010		cnwdap1			PAR #23320 Correct duplicate ID checking
//  10/07/2024		navma1			Bug 64544: EUP - DeadLocks When Creating Prenotes
// ---------------------------------------------------------------------------

vars
	isOk : Boolean;
	string : String;
	dupId : String;
begin

	if self.isAttachmentForm and not self.myTerminal.getConfig(AllowDuplicatePreNotes).Boolean then	//30 Nov 2016	NDL	TFS 2999
		dupId := self.findAnyDuplicateId();
		if dupId &lt;&gt; null then
			string := app.getErrorString1( Cargo_already_used, dupId );
			app.msgBox(string, app.getErrorString(Error), MsgBox_OK_Only);
			return false;
		endif;
	endif;
	
	if self.isFlexiGateForm then
		isOk := self.doSaveFlexiGateForm(true);
	elseif self.isPreNoteForm or
	    self.isOnshipForm //epr par 34945 20/10/14
		or self.isOnsiteForm then // TFS 2318
		// ### JIRA 12384 21OCT2024 NAVAB1isOk := self.doSavePreNoteForm;
		isOk := self.doSavePreNoteFormDLRT;// ### JIRA 12384 21OCT2024 NAVAB1
	elseif self.isRailPreNoteForm then
		isOk := self.doSaveRailPreNoteForm;
	elseif self.isMakeLCLForm then
		isOk := self.doSaveMakeLCLForm;
	endif;
	if isOk then 
		self.unloadForm;
		self.bringMainFormToFront();
	endif;

	return isOk;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveAdditionalDetails" id="9accd027-9f97-4509-a01f-7229a20c52f1">
        <updating/>
        <source>doSaveAdditionalDetails() updating, protected;
/*
Purpose:			Additional Details is really just teh current form reconfigured
					So saving is not necessary, we just restore the old Ent Table Def
					and the form appears as it did previously - the additional details fields
					are all still there and populated, and will get picked up on the overall save.

Parameters:			

Return Value:		

Date		Who		Reason
20 August 2009	cnwdap1	Initial creation
*/
vars

begin
	self.initFieldsForEntDefName(self.oldEntTableDef, true);
	self.oldEntTableDef := null;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSaveFlexiGateController" id="94ae259c-519b-40c3-8172-3d50561ae1a1">
        <source>doSaveFlexiGateController(controller 		: CMIF_FlexiGateController io) protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/05/2013	cnwer1	Initial creation CCMS DPH 2274 - Refactored code block from doSaveFlexiGateForm
12/08/2013	cnwdap1	PAR #32123 Colour changes
12/09/2013	cnwdap1	PAR #32215 New Car attributes
05/03/2014	cnwdap1	PAR #33193 CCMS DHP 2285 Added Purchase Order and Service Order fields
29/04/2015	cnwdap1	PAR #36094 CCMS SFW 1413 TFS 313 Cold Store Enhancements
10/08/2015	cnwdap1	PAR #36421 Hazardous Materials Handling
25/11/2015	cnwma1  PAR #36943 Shipping Reference error during extract
4/10/2016   cnwns1  TFS 2755:Time saved incorrectly - multi-timezone issue
09/11/2016	cnwdap1	TFS 2842 Hazardous Details Enhancements
31/08/17	jlgns1	6735 POL - [Fwd: ##5431## : 8.5.1.090 Not saving VGM authorised details]
3/05/2018 	JLGNS1	Bug 38457: DQM - Dry Bulk - ( Gate in and Merge )
02/10/2020  cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
19/05/2022	jlika1	TFS 53316 - EUP - GEN - Additional Dimensions For Cargo - PortSchema
20 may 2022	navgm20 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
16 August 2022	navak20	TFS ChangeRequest 54441: EUP - Additional Field - Country of Origin
19/12/2022	jlier1	TFS 55584  		HS Code Combobox Usage
21 Feb 2023 navtnr20	TFS CR 55648 Task 55663: UI - Contract Id
06/04/2023	navkc1	CR# 56431 Task 56438: UI - Cargo Enquiry
24/07/2023	jlizm1	TFS 57333 Empty Full containers causing issues when editing receivals
18/08/2023  navma1	Bug 59902: FR | EUP - 53308 - Cargo Group creation - Road Gate screen
14/11/2023	jlika1	TFS 61131 61013 CUX | Cargo Priority - Prenotes and Add Cargo Forms
02/10/2025	navdap1	MTN-36141 AAT | RotaBox Creation (EDI/API/Manual)
*/

vars
	obj 			: Object;
	operator	 	: CM_Operator;
	carriageTempC,
	carriageTempF,
	packTempC,
	packTempF		: Real;
	cargoType		: CM_CargoType;
	control : Control;
	sealValue : String;
	sealTypeName : String;
	sealType : CM_SealType;
	hazard : Object;
	invalidHazard : Boolean;
	packed : TimeStamp;						// PAR #31018
	transit : TimeStamp;					// PAR #31018
	totalMinutes : Integer;					// PAR #31018
	hours : Integer;						// PAR #31018
	minutes : Decimal [12,2];				// PAR #31018
	haz, newHaz : CM_TIHazard;			// PAR #36421
	packTSLocal 		: TimeStamp;	//TFS 2755
	packTSSystem 		: TimeStamp;	//TFS 2755
	transitOnTSLocal  	: TimeStamp;	//TFS 2755
	transitOnTSSystem 	: TimeStamp;	//TFS 2755
	expiryDateLocal		: TimeStamp;	//TFS 2755
	weight		   : Decimal [16,8];
	product        : CM_Product;
begin
	if controller = null then
		return;
	endif;
	
	cargoType := self.cmbType.getObject().CM_CargoType;
	if cargoType &lt;&gt; null then
		controller.cargoType := cargoType.id;
	endif;
	
	controller.myTerminal := self.myTerminal;
	controller.myVehicleVisitRecord := self.myCurrentVehicleVisit;
	
	//if self.isFull then
	if self.isFullContainer() then
		controller.jobType := CMGTE_Entity.JobType_FullIN;
	elseif self.isEmptyContainer() then
		controller.jobType := CMGTE_Entity.JobType_EmptyIN;
	elseif self.myPxyGTEEntity.isKindOf(CMGTE_ReceivalByType) then
		controller.jobType := CMGTE_Entity.JobType_ReceivalByType;
	else
		controller.jobType := CMGTE_Entity.JobType_GeneralIN;	
	endif;

	// Main Details
	controller.bookingNumber 		:= self.txtBookingRef.getString();
	controller.myBookingRefItem 	:= self.cmbBRItem.getObject().CM_BookingRefItem;
	
	//29 Sep 2011	NDL	Par 28285
	if self.isFlexiGateForm and self.cargoIDs.size &gt; 1 and self.updateMode = self.Mode_Add then
		controller.id				:= self.cargoIDs[1];
	else
		controller.id 				:= self.txtCargoID.getString();
	endif;
	
	controller.myProduct 			:= self.cmbSubCargo.getObject().CM_Product;

	//epr 2/5/13 CCMS 2274
	//controller.numItems 			:= self.txtNumItems.getInteger();	
	//controller.numItems.max(1);
	self.setObjectFromNumItemsValue( controller );	//04 Mar 2014	NDL	Par 33596
	
	controller.volumeTotal			:= self.tblTotalVolume.getConvertedValue;					// PAR #31155
	controller.yardLocationTxt		:= self.txtLocation.getString();
	
	obj := self.cmbSubTerminal.getObject;
	if obj &lt;&gt; null then
		controller.subTerminalCode 	:= obj.CM_SubTerminal.code;
	endif;

	obj := self.cmbISOType.getObject;
	if obj &lt;&gt; null then
		controller.isoTypeCode 		:= obj.CM_ISOType.code;
	endif;

	if self.cmbCommodity.visible then
		obj := self.cmbCommodity.getObject;
		if obj &lt;&gt; null then
			controller.commodity 		:= obj.CM_Commodity.code;
			
			if obj.CM_Commodity.isEmpty and self.isFullContainer() then	// TFS 57333
				controller.jobType := CMGTE_Entity.JobType_EmptyIN;
			endif;
		endif;
	endif;
	
	// 03/02/2012 cnwar2 #28799
	obj := self.cmbCarrier.getObject;
	if obj &lt;&gt; null then
		controller.myCarrier 		:= obj.CM_Carrier;
	endif;
	if self.tblTotalWeight.getConvertedValue &lt;&gt; null then										// PAR #31155
		//controller.weightTotal 		:= self.tblTotalWeight.getConvertedValue;					// PAR #31155 //24.1.2018 cnwma1 BUG #36720
		//24.1.2018 cnwma1 BUG #36720
		if cargoType &lt;&gt; null and cargoType.isBulkByVolume then
			if not self.cmbSubCargo.isHidden then
				product := self.cmbSubCargo.getObject.CM_Product;
			else
				product := cargoType.mySystemProductType;
			endif;
			if product &lt;&gt; null and product.myDensityDec.value &lt;&gt; null then							// ### TFS 52193 22Nov2021 NAVPW1
					weight := self.tblTotalVolume.getConvertedValue * product.myDensityDec.value;	// ### TFS 52193 22Nov2021 NAVPW1
			endif;
			controller.weightTotal 		:= weight;
		else
			controller.weightTotal			:= self.tblTotalWeight.getConvertedValue; 
		endif;
	endif;
	
	//epr tfs 2011 8/6/16
	if self.chkIsWeightCertified.visible then
		controller.isWeightCertified := self.chkIsWeightCertified.getBoolean();
	//	controller.weightCertifiedName:=self.txtWeightAuthorised.getString();
	//	controller.weightCertifiedReference:=self.txtWeightCertifiedBy.getString();
		
		//23 Aug 2017	NDL	TFS 5803
		//TFS 6735 jlgns1 31/08/2017 
		//obj := self.cmbWeightPerson.getObject;
		//if obj &lt;&gt; null then
		//	controller.weightCertifiedName := obj.CM_WeighAuthority.certifiedName;  // company
		//	controller.weightCertifiedReference := obj.CM_WeighAuthority.authorisedName;	// person
		//endif;
		controller.weightCertifiedName 		:= self.txtWeightAuthorised.getString();  	// company	//TFS 6735 jlgns1 31/08/2017 
		controller.weightCertifiedReference := self.txtWeightCertifiedBy.getString();	// person	//TFS 6735 jlgns1 31/08/2017 
		
	else
		//19 Mar 2014	NDL	Par 33268
		if self.chkWeightCert.visible then
			controller.isWeightCertified := self.chkWeightCert.value;
		endif;
	endif;
		
	if self.tblNettWeight.visible then																	//Bug 38457
		if self.tblNettWeight.getConvertedValue &lt;&gt; null then							// PAR #31155	//Bug 38457
			controller.weightCargo 		:= self.tblNettWeight.getConvertedValue;		// PAR #31155	//Bug 38457
		endif;																							//Bug 38457
	endif;																								//Bug 38457
	if self.tblTareWeight.visible then																	//Bug 38457
		if self.tblTareWeight.getConvertedValue &lt;&gt; null then							// PAR #31155	//Bug 38457
			controller.weightTare 		:= self.tblTareWeight.getConvertedValue;		// PAR #31155	//Bug 38457
		endif;																							//Bug 38457
	endif;																								//Bug 38457
	
	if self.isAttachmentForm and not self.isGeneralCargo then
		controller.weightTotal 		:= self.tblTotalWeight.getConvertedValue;					// PAR #31155
	endif;
	
	if self.myPxyGTEEntity.isKindOf(CMGTE_TILC) then
		controller.myChassisType 	:= self.cmbTrailerType.getObject.CM_TILCType;
	elseif self.myPxyGTEEntity.isKindOf(CMGTE_Generator) then
		controller.myGeneratorType	:= self.cmbGeneratorType.getObject.CM_GeneratorType;
	endif;

	// Voyage Details
	obj := self.cmbImexStatus.getObject;
	if obj &lt;&gt; null then
		controller.imexStatus 		:= obj.CM_IMEXStatus.code;
	endif;
	obj := self.cmbVoyageCode.listObject;
	if obj &lt;&gt; null then
		controller.voyageCode 		:= obj.CM_Voyage.code;
	endif;
	obj := self.cmbOperatorCode.listObject;
	if obj &lt;&gt; null then
		controller.operatorCode 	:= obj.CM_Operator.code;
	endif;
	obj := self.cmbDestPort.listObject;
	if obj &lt;&gt; null then
		controller.destinationPort 	:= obj.CM_Port.code;
	endif;
	obj := self.cmbDischargePort.listObject;
	if obj &lt;&gt; null then
		controller.dischargePort 	:= obj.CM_Port.code;
	endif;
	
	obj := self.cmbTranshipPort.listObject;
	if obj &lt;&gt; null then
		controller.myTranshipToPort	:=	obj.CM_Port;
	endif;
	
	controller.allDischargePorts.clear;
	foreach obj in self.lstOptionalPorts.allSelectedObjects do
		controller.allDischargePorts.add(obj.CM_Port.code);
	endforeach;
	
	obj := self.cmbConsignor.getObject;
	if obj &lt;&gt; null then
		controller.consignorCode 	:= obj.CM_ConsigneeConsignor.code;
	endif;
	obj := self.cmbConsignee.getObject;
	if obj &lt;&gt; null then
		controller.consigneeCode 	:= obj.CM_ConsigneeConsignor.code;
	endif;
		

	controller.length 						:= self.tblLength.getConvertedValue;					// PAR #31155
	controller.width 						:= self.tblWidth.getConvertedValue;						// PAR #31155
	controller.height 						:= self.tblHeight.getConvertedValue;					// PAR #31155
	controller.lengthString 				:= self.txtLengthText.getString();
	controller.widthString	 				:= self.txtWidthText.getString();	
	controller.heightString 				:= self.txtHeightText.getString();
//	controller.quantity						:= self.txtQuantity.getInteger();
	self.setObjectFromQuantityValue( controller );	//04 Mar 2014	NDL	Par 33596
	controller.weight 						:= self.tblWeight.getConvertedValue;					// PAR #31155
	controller.density 						:= self.tblDensity.getConvertedValue;					// PAR #31155 // ### TFS 52193 22Nov2021 NAVPW1
	// jlika1 TFS 53316 --&gt;
	controller.diameter						:= self.tblDiameter.getConvertedValue();
	controller.grade						:= self.txtGrade.getString();
	controller.grammage						:= self.txtGrammage.getString().Decimal;
	controller.rollingLength				:= self.tblRollingLength.getConvertedValue();
	// jlika1 TFS 53316 &lt;--
	// PAR #23190 start
	if not self.cmbDimType.isHidden then
		controller.type 					:= self.cmbDimType.getString();
	else
		controller.type 					:= self.txtDimType.getString();
	endif;

	if self.tblVolume.isHidden then																	// PAR #31155
		controller.volume					:= self.tblTotalVolume.getConvertedValue;				// PAR #31155
	else
		controller.volume					:= self.tblVolume.getConvertedValue;					// PAR #31155
	endif;
	// PAR #23442 end
	
	// Cargo Details
	controller.description 					:= self.txtDescription.getString();
	controller.alternativeId				:= self.txtAlternativeId.getString();
	controller.mark							:= self.txtMark.getString();
	//controller.colour						:= self.lstColour.getString();												// PAR #32123
	controller.colour						:= self.myAssistant.getColourString(self.lstColourList, self.txtColourList);// PAR #32123
	controller.markNumber					:= self.txtMarkNumber.getString();
		
	// 20 Sep 2010	NDL Par 25608
	controller.allSeals.clear();
	if cargoType = null then
		if self.myPxyGTEEntity &lt;&gt; null and self.myPxyGTEEntity.isKindOf(CMGTE_Container) then
			cargoType := app.myRoot.allCargoTypesById[TI_CargoType_Container];
			controller.cargoType := cargoType.id;
		endif;
	endif;
	if cargoType &lt;&gt; null then
		foreach obj in self.allClonedControls do
			control := obj.Control;
			if control.isKindOf(CMUI_FieldTextBox) then
				sealValue := control.CMUI_FieldTextBox.getString;
				sealTypeName := control.name;
				sealType := app.myRoot.getSealType( sealTypeName );
				if sealType &lt;&gt; null then
					if not sealType.notAvailableForEntry then
						if sealType.allCargoTypes.includes( cargoType ) then
						controller.setSealNumberValueDirect( sealType,  sealValue, null );
						endif;
					endif;
				endif;
			endif;
		endforeach;
	endif;	

	controller.operatorExportReleaseNumber 	:= self.txtOpExRelNbr.getString();
	controller.customEntryNumber 			:= self.txtCustomsExDel.getString();
	
	controller.clientRef					:= self.txtClientRef.getString();  //cnwrd1 par 23337 20.5.2010
	
	controller.purchaseOrder				:= self.txtPurchaseOrder.getString();		// PAR #33193 
	controller.serviceOrder					:= self.txtServiceOrder.getString();		// PAR #33193 
	controller.shippingReference		:= self.txtShippingRef.getString();  //25/11/2015 cnwma1 PAR #36943
	controller.directDelivery 				:= self.chkDirDel.getBoolean;	//28 Jan 2013	NDL	CCMS 1299		Par 31102
	
	obj := self.cmbMTGrade.getObject;
	if obj &lt;&gt; null then
		controller.availabilityGrade 		:= obj.CM_MTGrade.code;
	endif;
	controller.offsitePreTrip 				:= self.chkPreTrip.getBoolean;
	controller.offsiteCleaned 				:= self.chkCleaned.getBoolean;
	controller.remarks 						:= self.txtRemarks.getString();		//cnwmc5 - 19 May 2014 - PAR 34173
	
	controller.hasRadio						:= self.chkRadio.getBoolean;
	controller.selfPropelled				:= self.chkSelfPropelled.getBoolean;
	
	// PAR #23442 Set Timber details
	controller.preSlung						:= self.chkPreSlung.getBoolean;
	controller.wet							:= self.chkWet.getBoolean;
	
	controller.isOverDimensions				:= self.chkIsOverDim.value;
	controller.dimLenFront					:= self.txtDimLenFront.text.asDecimalJMT;
	controller.dimLenRear					:= self.txtDimLenRear.text.asDecimalJMT;
	controller.dimWidthRight				:= self.txtDimWidthRight.text.asDecimalJMT;
	controller.dimWidthLeft					:= self.txtDimWidthLeft.text.asDecimalJMT;

	if not self.isGeneralCargo() then
		controller.height					:= self.txtDimOverHeight.text.asDecimalJMT;
	endif;
	
	controller.allTIHazards.clear;
	//self.lstHazardList.allSelectedObjects.copy(controller.allTIHazards);
	//16/02/2011 cnwdz2 par27021 start
	on Exception do app.handleDeletedObject(exception, hazard, invalidHazard);
	foreach hazard in self.lstHazardList.allSelectedObjects do
		invalidHazard := false;
		hazard.edition();
		if invalidHazard then
			continue;
		endif;
		if hazard.cnEcIsPersistent then										// PAR #36421
			haz := hazard.CM_TIHazard;										// PAR #36421
			create newHaz transient;										// PAR #36421
			//newHaz.setProxy(haz.code, haz.description, haz.allUNDGCodes.asCSV(false), null, haz.limitedQuantity, haz.packingGroup);	// TFS 2842
			newHaz.setProxy(	haz.code, 							// TFS 2842
								haz.description, 					// TFS 2842
								haz.allUNDGCodes.asCSV(false), 		// TFS 2842
								null, 								// TFS 2842
								haz.limitedQuantity, 				// TFS 2842
								haz.packingGroup,					// TFS 2842
								haz.flashpointTemperature,			// TFS 2842
								haz.isMarinePollutant,				// TFS 2842
								haz.acidsBases	);					// TFS 2842
		else																// PAR #36421
			newHaz := hazard.CM_TIHazard;									// PAR #36421
		endif;																// PAR #36421
		//controller.allTIHazards.add(hazard.CM_Hazard);					// PAR #36421
		controller.allTIHazards.addNoDuplicates(newHaz, false);				// PAR #36421
	endforeach;
	//16/02/2011 cnwdz2 par27021 end
	
	obj := self.cmbSpecialStow.getObject();
	if obj &lt;&gt; null then
		controller.specialStow 				:= obj.CM_SpecialStow.code;
	endif;
	// Start 20 may 2022	navgm20	TFS 53204
	obj := self.cmbShippingLine.getObject();
	if obj &lt;&gt; null then
		controller.shippingLineCode :=	obj.CM_ShippingLine.code;
	endif;
	// End 20 may 2022	navgm20	TFS 53204

	//Start 16.08.2022 navak20 TFS 54441
	obj := self.cmbCtryOfOrigin.getObject();
	if obj &lt;&gt; null then
		controller.countryOfOriginCode := obj.CM_Country.code;
	endif;
	//End 16.08.2022 navak20 TFS 54441
	//Start //21.02.2023 navtnr20 TFS CR 55648 Task 55663
	obj := self.cmbInvContractID.getObject();
	if obj &lt;&gt; null then
		controller.setInvoiceContractId(obj.CM_InvoiceContract.contractId); 
	endif;
	//End //21.02.2023 navtnr20 TFS CR 55648 Task 55663
	controller.allSpecialLifts.clear;
	self.lstSpecialLift.allSelectedObjects.copy(controller.allSpecialLifts);
	
	// Reefer Details
	if self.txtTimeOffPower.getString = null then 			// cnwas3, Par 26199 begin
		controller.allowableTimeOffPower 		:= NULL_ALLOWABLE_TIME_OFF_POWER;
	else
		controller.allowableTimeOffPower 		:= self.txtTimeOffPower.getString.Decimal;
	endif;														// cnwas3, Par 26199 end
	
	operator := self.cmbOperatorCode.listObject.CM_Operator;
	
	self.doDeriveTemperatures(operator, carriageTempC, carriageTempF, packTempC, packTempF);
	controller.carriageTempF 				:= carriageTempF;
	controller.carriageTempC 				:= carriageTempC;
	controller.packTempF 					:= packTempF;
	controller.packTempC 					:= packTempC;
	
	if self.txtCO2Percent.getString.Decimal = 0 then
		controller.setCarbonDioxide( NULL_CARBON_DIOXIDE );
	else
		controller.setCarbonDioxide( self.txtCO2Percent.getString.asDecimalJMT );
	endif;
	if self.txtOxygenPercent.getString.Decimal = 0 then
		controller.setOxygen( NULL_OXYGEN );
	else
		controller.setOxygen( self.txtOxygenPercent.getString.asDecimalJMT );
	endif;
	controller.curtainsIn 					:= self.chkCurtainsIn.getBoolean;
	if self.txtHumidity.getString.Decimal = 0 then
		controller.setHumidity( NULL_HUMIDITY );
	else
		controller.setHumidity( self.txtHumidity.getString.asDecimalJMT );
	endif;
								// PAR #31155
	if self.tblVentilation.getConvertedValue = 0 then												// PAR #31155
		controller.ventilation				:= NULL_VENTILATION;
	else
		controller.ventilation 				:= self.tblVentilation.getConvertedValue;				// PAR #31155
	endif;
	//4/10/2016   cnwns1  TFS 2755:Time saved incorrectly - multi-timezone issue
	packTSLocal.cnEcSetDateAndTime(self.txtPackDate.getDate,self.txtPackTime.getTime);	//TFS 2755
	packTSSystem := self.localToSystemTime(packTSLocal);								//TFS 2755
	controller.packDate	:= packTSSystem.date();											//TFS 2755
	controller.packTime := packTSSystem.time();											//TFS 2755

	if self.cmbCoolingType.getString &lt;&gt; null then
		controller.coolingType 				:= app.coolingTypeStringToENum(self.cmbCoolingType.getString);
	endif;
	if self.cmbVoltageType.getString &lt;&gt; null then
		controller.voltageType 				:= app.voltageTypeStringToENum(self.cmbVoltageType.getString);
	endif;
	
	// water cooled - derived from cmbCoolingType = ContainerWaterCooled
	
	// Additional Details
	//stops
	foreach obj in lstAllStops.allSelectedObjects do
		controller.allStops.add(obj.CM_StopsTable.id);
	endforeach;
	
	//todo tasks
	foreach obj in lstToDoTasks.allSelectedObjects do
		controller.allToDoTasks.add(obj.CM_ToDoTaskDesc);
	endforeach;
	
	obj := self.cmbFreightFwdr.getObject;
	if obj &lt;&gt; null then
		controller.freightForwarderCode := obj.CM_ConsigneeConsignor.code;
	endif;
	obj := self.cmbCustomsAgent.getObject;
	if obj &lt;&gt; null then
		controller.customsAgentCode 	:= obj.CM_CustomsAgent.code;
	endif;
	controller.billOfLading				:= self.txtHouseBOL.getString();
	controller.consignorVoyageCode 		:= self.txtConsignVoy.getString();
	controller.eirNumber 				:= self.txtEquipXchg.getString();
	obj := self.cmbBusUnit.getObject;
	if obj &lt;&gt; null then
		controller.companyCode 			:= obj.CM_Bank.code;
	endif;
	controller.purchaseOrder			:= self.txtPurchaseOrder.getString();
	
	// PAR #31018 CCMS POL 2223 Set new transit on power attributes
	controller.onPowerDuringTransit		:= self.chkTransitPower.getBoolean();			// PAR #31018
	//4/10/2016   cnwns1  TFS 2755:Time saved incorrectly - multi-timezone issue
	transitOnTSLocal.cnEcSetDateAndTime(self.txtTransitOnDate.getDate(),self.txtTransitOnTime.getTime());//TFS 2755
	transitOnTSSystem := self.localToSystemTime(transitOnTSLocal);										 //TFS 2755
	controller.transitOnPowerDate := transitOnTSSystem.date();											 //TFS 2755
	controller.transitOnPowerTime := transitOnTSSystem.time();											 //TFS 2755	
	controller.transitOnPowerRemarks	:= self.txtTransitRemark.getString();			// PAR #31018
	controller.remainingTimeOffPower	:= NULL_ALLOWABLE_TIME_OFF_POWER;				// PAR #31018
	// calculate remaining time off power												// PAR #31018
	// if I was on power during transit, remaining time off power is 					// PAR #31018
	// 		transit on power date/time - pack date/time									// PAR #31018
	// If I wasn't on power during transit, remaining time off power is					// PAR #31018
	// 		now date/time - pack date/time												// PAR #31018
	if controller.packDate &lt;&gt; null then													// PAR #31018
		packed.setDate(controller.packDate);											// PAR #31018
		packed.setTime(controller.packTime);											// PAR #31018
		if packed &gt; app.actualTimeServer then											// PAR #31411
			controller.remainingTimeOffPower := controller.allowableTimeOffPower;		// PAR #31411
		else																			// PAR #31411
			if controller.onPowerDuringTransit then										// PAR #31018
				transit.setDate(controller.transitOnPowerDate);							// PAR #31018
				transit.setTime(controller.transitOnPowerTime);							// PAR #31018
				totalMinutes := packed.minutesDiff(transit).Integer;					// PAR #31018
			else																		// PAR #31018
				totalMinutes := packed.minutesDiff(app.actualTimeServer).Integer;		// PAR #31018
			endif;																		// PAR #31018
			totalMinutes := ((controller.allowableTimeOffPower * 60) - totalMinutes).Integer;// PAR #31018
			hours := (totalMinutes / 60).Integer;										// PAR #31018
			minutes := (totalMinutes mod 60) / 100;										// PAR #31018
			if (hours + minutes) &gt; 0 then												// PAR #31018
				controller.remainingTimeOffPower := hours + minutes;					// PAR #31018
			else																		// PAR #31018
				controller.remainingTimeOffPower := null;								// PAR #31018
			endif;																		// PAR #31018
		endif;																			// PAR #31411
	endif;																				// PAR #31018
	
	if self.hasPreNote() then
		// store the edition of the prenote so that we can check for change 
		// during validation and handle appropriately
		//controller.tiEdition := self.myTI.edition;
		controller.tiEdition := self.tiPrenoteEdition;
	endif;
	
	// PAR #32215 New Car attributes													// PAR #32215
	if self.cmbVehicleMake.getObject &lt;&gt; null then										// PAR #32215
		controller.make			:= self.cmbVehicleMake.getObject.CM_VehicleMake.make;	// PAR #32215
	endif;																				// PAR #32215
	if self.cmbVehicleModel.getObject &lt;&gt; null then										// PAR #32215
		controller.model		:= self.cmbVehicleModel.getObject.CM_VehicleModel.model;// PAR #32215
	endif;																				// PAR #32215
	if self.cmbVehicleType.getObject &lt;&gt; null then										// PAR #32215
		controller.carType 		:= self.cmbVehicleType.getObject.CM_VehicleType.type;	// PAR #32215
	endif;																				// PAR #32215
	controller.year 			:= self.txtYear.getInteger;								// PAR #32215
	controller.trackingNumber1 	:= self.txtTracking1.getString;							// PAR #32215
	controller.trackingNumber2 	:= self.txtTracking2.getString;							// PAR #32215
	controller.docsReceived.setDate(self.txtDocsReceived.getDate);						// PAR #32215
	controller.docsSent.setDate(self.txtDocsSent.getDate);								// PAR #32215
	controller.docsCleared.setDate(self.txtDocsCleared.getDate);						// PAR #32215
	controller.docsReturned.setDate(self.txtDocsReturned.getDate);						// PAR #32215
	controller.nbrDoors 		:= self.txtDoors.getInteger;							// PAR #32215
	controller.isNew			:= self.chkNew.getBoolean;	// PAR #32215
	
	expiryDateLocal.cnEcSetDateAndTime(self.txtExpiryDate.getDate(),TimeEndOfDay);				 //TFS 2755
	controller.expiryDate := self.localToSystemTime(expiryDateLocal).date();					 //TFS 2755
	
	//epr TFS 3581 15/3/17
	if self.chkExternallyMonitor.visible then
		controller.isExternallyMonitored := self.chkExternallyMonitor.getBoolean();
	endif;
	
	//02.10.2020 cnwma1 TFS #50112
	obj := self.cmbStevedore.getObject;
	if obj &lt;&gt; null then
		controller.stevedoreCode 	:= obj.CM_Stevedore.code;
	endif;
	
	//jlier1 TFS 53515 25/5/22
	if self.txtCargoGroupID.getString &lt;&gt; null then
		if self.txtCargoGroupID.userObject &lt;&gt; null and self.txtCargoGroupID.userObject.isKindOf(CM_CargoGroup) then
			if self.txtCargoGroupID.userObject.CM_CargoGroup.id = self.txtCargoGroupID.getString() then 		//18.08.2023 navma1 #59902 
				controller.myCargoGroup := self.txtCargoGroupID.userObject.CM_CargoGroup;
			else
				controller.cargoGroupId := self.txtCargoGroupID.getString;
			endif;
		else
			controller.cargoGroupId := self.txtCargoGroupID.getString;
			
		endif;
	endif;
	
	if self.cmbHSCode.getObject &lt;&gt; null then
		controller.hsCode		:= self.cmbHSCode.getObject.CM_HarmonizedSystem.id; //jlier1 TFS 55584 20/12/22
	endif;
	
	controller.attributeisOverlanded := self.chkOverlanded.getBoolean(); //06/04/2023	navkc1	CR# 56431 Task 56438
	
	// ### TFS 57812 (58439) 15Jun2023 NAVPW1
	controller.itemised := self.chkItemised.getBoolean();
	controller.secondaryBarcodeId := self.txtSecondaryBarcodeId.getString;
	controller.mySortingMethod := self.cmbSortingMethod.getObject.CM_SortingMethod;
	// ### TFS 57812 (58439) 15Jun2023 NAVPW1
	
	controller.myCustomerPriority := self.cmbCustPriority.getObject().CM_CustomerPriority;
	
	// MTN-36141
	if not self.cmbContentsCargoType.isHidden and self.cmbContentsCargoType.getObject &lt;&gt; null then
		cargoType := self.cmbContentsCargoType.getObject.CM_CargoType;
		controller.cargoTypeContents := cargoType.id;
		controller.myProduct := self.cmbProdType.getObject.CM_Product;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="controller" type="CMIF_FlexiGateController" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doSaveFlexiGateForm" id="992028e3-9102-41e6-b37c-00a016429d63">
        <updating/>
        <source>doSaveFlexiGateForm(_doSave : Boolean) : Boolean updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

/* Changes

Date		Name	TFS#			Description
============================================================================
29/07/2009	cnwdap1					Initial creation
15/03/2010	cnwdap1	PAR #23190 		Dimensions Type can be from combo or text box
30/03/2010	cnwdap1	PAR #23470 		Set total weight correctly on attachment form
06/04/2010	cnwdap1	PAR #23442 		Set volume from total volume if volume field is hidden
16/01/2013	cnwdap1	PAR #31018 
					CCMS POL 2223 	Set new transit on power attributes
27/03/2013	cnwdap1	PAR #31155 	
					CCMS SFW 1321 	Inperial Measurements
11/04/2013	cnwdap1	PAR #31411 		Correct calculation of remaining time off power if packed date is in the future
27/02/2018	cnwma1  ChangeRequest 
					36813: 			PEN - Gen Sets, Chassis &amp; Reefers
09/04/2019	jlgka1	TFS 44159		SNO - Issue during seal check.
11/01/2022	navdap1	TFS 52268		AAT 1-Stop VBS Integration
============================================================================*/
vars
	controller 			 : CMIF_FlexiGateController;
	saveAttachment		 : CMGTE_Entity;
	saveParent			 : CMGTE_Entity;
	saveVisit			 : CM_VehicleVisitRecord;
	validateOnly		 : Boolean;
	cargoType			 : CM_CargoType;
	multiPxyGTEArray 	 : CMGTE_EntityArray;
	multiPxyGTEArrayCopy : CMGTE_EntityArray;
	extraGTEEntity 		 : CMGTE_Entity;
	indx 				 : Integer;
	warningsToIgnore 	 : IntegerArray;
	error 				 : CM_Error;
	damageInstance 		 : CM_DamageInstance;
	obj					 : Object;
	cargoCheckForm 		 : CMUI_CargoChecksForm;
	realGTEEntity		 : CMGTE_Entity;
	msg 				 : String;
	remainingGateScanData: CM_GenericScanRecDataArray;
begin
	// are we doing an actual receipt update, or creating a transient attachment:
	if self.isAttachmentForm then
		validateOnly := true;
	else
		validateOnly := false;
	endif;
	
	create controller transient;
	
	if validateOnly and self.myPxyGTEEntity &lt;&gt; null then
		// save off original attachment proxy
		saveAttachment := self.myPxyGTEEntity;
		saveParent := self.myPxyGTEEntity.myParent;
		saveVisit := self.myPxyGTEEntity.myVehicleVisitRecord;
		// force a new attachment proxy to be created
		self.myPxyGTEEntity.setMyVehicleVisit(null);
		self.myPxyGTEEntity.setParentObject(null);
		self.myPxyGTEEntity := null;
	endif;
	
	// Get the cargo type here so that we can decide which type of CMGTE_Entity to create.
	cargoType := self.cmbType.getObject().CM_CargoType;

	if self.myPxyGTEEntity = null then
		if self.isGeneralCargo() then
			if self.txtCargoID.getString() = null then	
				if self.myTerminal.roadProcessIsASPA then	//20 Oct 2020	NDL	TFS 49189
					msg := app.getErrorString(Relea_type_witho_recei_type_no);
					app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
					self.txtCargoID.setFocus();
					return false;
				endif;
				create self.myPxyGTEEntity as CMGTE_ReceivalByType transient;	
			//if cargoType &lt;&gt; null then											
			elseif cargoType &lt;&gt; null then
				if cargoType.id  = TI_CargoType_Generator then
					create self.myPxyGTEEntity as CMGTE_Generator transient;			
				elseif cargoType.isTrailer() then			
					create self.myPxyGTEEntity as CMGTE_TILC transient;	
				elseif cargoType.productType = ProductType_Vehicle then
					create self.myPxyGTEEntity as CMGTE_Car transient;
				// PAR #23442 Timber
				elseif cargoType.id = TI_CargoType_Timber then
					create self.myPxyGTEEntity as CMGTE_Cargo transient;
				elseif cargoType.id = TI_CargoType_COU then
					create self.myPxyGTEEntity as CMGTE_Machinery transient; //epr par 34376 11/9/14
				else
					create self.myPxyGTEEntity as CMGTE_Receival transient;
				endif;
			else
				// default to receival if we don't have a cargo type yet
				create self.myPxyGTEEntity as CMGTE_Receival transient;
			endif;
		else
			create self.myPxyGTEEntity as CMGTE_Container transient;
		endif;
	endif;
		
	//epr 2/5/13 -attempt make this method shorter
	self.doSaveFlexiGateController(controller);

	if self.myBookingRefItem &lt;&gt; null then 
		// Set the proxy from the booking ref first, so that we allow overwrites from the GUI
		self.myPxyGTEEntity.setPXYFromBooking(self.myBookingRefItem);
	endif;
	
	self.myPxyGTEEntity.setPXYFromController(controller); 
	
	//epr par 31845 29/10/13
	foreach damageInstance in self.allDamageInstancesByPos do
		damageInstance.setMySubject(self.myPxyGTEEntity);
	endforeach;
	//epr par 31845 29/10/13
	foreach obj in self.allPhotos do
		obj.CM_Attachment.setMyGTEEntity(self.myPxyGTEEntity);
	endforeach;
	
	if validateOnly then
		self.myPxyGTEEntity.setParentObject(self.myParentForm.CMUI_ReceiveCargoForm.myPxyGTEEntity);
	
	else
		//27.02.2018 cnwma1 ChangeRequest #36813
		if self.myPxyGTEEntity &lt;&gt; null  then
			if self.myPxyGTEEntity.isKindOf(CMGTE_Receival) then
				self.createGeneratorFromTiMaster();
			endif;
		endif;
		//27.02.2018 cnwma1 ChangeRequest #36813
	endif;
	
	//04 Oct 2016	NDL	TFS 2781
	if self.myPxyGTEEntity.isKindOf(CMGTE_Receival) then
		if not self.validateAustCAN() then
			self.txtCustomsExDel.setFocus();
			return false;
		endif;
	endif;
	
	if not self.do1StopVBSCheck(self.myPxyGTEEntity) then	// TFS 52268
		return false;										// TFS 52268
	endif;													// TFS 52268
	
	if self.cargoIDs.size &gt; 1 and self.updateMode = self.Mode_Add then
		if self.isAttachmentForm then
			//29 Oct 2013	NDL	Par 31829 - add these suckers to the parent as children
			create multiPxyGTEArray transient;
			foreach indx in 2 to self.cargoIDs.size do
				controller.id := self.cargoIDs[indx];
				create extraGTEEntity as self.myPxyGTEEntity.class transient;
				if self.myBookingRefItem &lt;&gt; null then 
					extraGTEEntity.setPXYFromBooking(self.myBookingRefItem);
				endif;
				extraGTEEntity.setPXYFromController(controller);
				extraGTEEntity.setParentObject(self.myParentForm.CMUI_ReceiveCargoForm.myPxyGTEEntity);
				multiPxyGTEArray.add(extraGTEEntity);
			endforeach;
				
		else
			//29 Sep 2011	NDL	Par 28285
			if self.isFlexiGateForm then
				create multiPxyGTEArray transient;
				foreach indx in 2 to self.cargoIDs.size do
					controller.id := self.cargoIDs[indx];
					create extraGTEEntity as self.myPxyGTEEntity.class transient;
					if self.myBookingRefItem &lt;&gt; null then 
						extraGTEEntity.setPXYFromBooking(self.myBookingRefItem);
					endif;
					extraGTEEntity.setPXYFromController(controller);
					//extraGTEEntity.setJobQueueNum( 1000 + indx );														//cnwmc5 - 3 Jan 2014 - PAR 31916
					extraGTEEntity.setJobQueueNum( 1000 +  indx + self.myCurrentVehicleVisit.allGateEntities.size );	//cnwmc5 - 3 Jan 2014 - PAR 31916
					multiPxyGTEArray.add(extraGTEEntity);
				endforeach;
			endif;
		
		endif;
	endif;
	
	if self.isFlexiGateForm and _doSave
	and self.myAssistant.saveFlexiGateEntity(self.myMainForm, (self.updateMode = self.Mode_Update and not validateOnly), self.myPxyGTEEntity, validateOnly, null) then
		//epr changes for CCMS 1386 ROB gate cargo	
		if validateOnly then
			// replace original attachment proxy with new one that has been successfully validated
			self.myParentForm.CMUI_ReceiveCargoForm.removeAttachment(saveAttachment);
			self.myParentForm.CMUI_ReceiveCargoForm.updateAttachments(self.myPxyGTEEntity);
			delete saveAttachment;
		endif;
		//29 Sep 2011	NDL	Par 28285
		if multiPxyGTEArray &lt;&gt; null then		
			create warningsToIgnore transient;	//18 Nov 2011	NDL	Par 28527
			
			foreach extraGTEEntity in multiPxyGTEArray do
				
				//18 Nov 2011	NDL	Par 28527
				if not app.myPassport.allErrorWarnings.isEmpty then
					foreach error in app.myPassport.allErrorWarnings do
						if error.warningOnly then
							// this is a warning that has already been OK'd by the user on one of the sister pxyGTE's 
							if not warningsToIgnore.includes( error.errorCode ) then
								warningsToIgnore.add( error.errorCode );
							endif;
						endif;
					endforeach;
				endif;

				//self.myAssistant.saveFlexiGateEntity(self.myMainForm, false, extraGTEEntity, false, warningsToIgnore);
				//29 Oct 2013	NDL	Par 31829
				self.myAssistant.saveFlexiGateEntity(self.myMainForm, false, extraGTEEntity, self.isAttachmentForm, warningsToIgnore);
				
				
			endforeach;
			
			if self.isAttachmentForm and app.myPassport.noErrors then
				foreach extraGTEEntity in multiPxyGTEArray do
					self.myParentForm.CMUI_ReceiveCargoForm.updateAttachments(extraGTEEntity);
				endforeach;
			endif;
				
		endif;
		
		//07 May 2014	NDL	Par 34076 - Cargo Checks for the gate when receiving cargo with an id.
		if self.myTerminal.hasNoCargoCheckItemsFor(CARGO_CHECK_CONTEXT_ROAD_REC) then
			//nothing to do here.
		elseif  self.myCurrentVehicleVisit &lt;&gt; null and not self.isAttachmentForm then
			if self.myPxyGTEEntity.isKindOf(CMGTE_Receival) then
				realGTEEntity := self.myCurrentVehicleVisit.getGateRecievalMatchingThis(self.myPxyGTEEntity.CMGTE_Receival);
			else
				realGTEEntity := null;
			endif;
			
			
			if app.myPassport.noErrors
			and realGTEEntity &lt;&gt; null
			then

				delete self.myPxyGTEEntity;
				self.myPxyGTEEntity := null;
				
				create cargoCheckForm transient;
				cargoCheckForm.myTerminal := self.myTerminal;
				cargoCheckForm.setBaseDetails(realGTEEntity.CMGTE_Receival.myTrackedItem,realGTEEntity.CMGTE_Receival,CARGO_CHECK_CONTEXT_ROAD_REC);			//cnwmc5 - 26 Nov 2015 - PAR 37138
				cargoCheckForm.setParentForm(self);
				cargoCheckForm.showModal;				
				delete cargoCheckForm;
				// 20 Nov 2019	NDL	TFS 47568 moved this updating code to CM_TrxControlCretaeAgent::trxCreateSealsCheckTransaction where it belongs
			/*	if realGTEEntity.CMGTE_Receival.myTrackedItem &lt;&gt; null then
					//jlgka1 TFS 44159 --&gt;
					beginTransaction;				
					realGTEEntity.CMGTE_Receival.setUpdatedSeals(realGTEEntity.CMGTE_Receival.myTrackedItem.allSeals);
					commitTransaction;
					//jlgka1 TFS 44159 &lt;--
				endif; */
			endif;
				
			if app.myPassport.noErrors and multiPxyGTEArray &lt;&gt; null and not multiPxyGTEArray.isEmpty then
				create multiPxyGTEArrayCopy transient;
				multiPxyGTEArray.copy(multiPxyGTEArrayCopy);
				
				foreach extraGTEEntity in multiPxyGTEArrayCopy do
					if not app.myPassport.noErrors then
						break;
					endif;
					if extraGTEEntity.isKindOf(CMGTE_Receival) then
						realGTEEntity :=  self.myCurrentVehicleVisit.getGateRecievalMatchingThis(extraGTEEntity.CMGTE_Receival);
					else
						continue;
					endif;
					if realGTEEntity = null then
						continue;
					endif;
					
					multiPxyGTEArray.remove( extraGTEEntity );
					delete extraGTEEntity;
					
					create cargoCheckForm transient;
					cargoCheckForm.myTerminal := self.myTerminal;
					cargoCheckForm.setBaseDetails(realGTEEntity.CMGTE_Receival.myTrackedItem,realGTEEntity.CMGTE_Receival,CARGO_CHECK_CONTEXT_ROAD_REC);		//cnwmc5 - 26 Nov 2015 - PAR 37138
					cargoCheckForm.setParentForm(self);
					cargoCheckForm.showModal;
					delete cargoCheckForm;
				
				endforeach;
			endif;
			
		endif;
	
		// TFS 52777 navmd1 Generic Gate Scan API
		if self.isFlexiGateForm and app.myPassport.noErrors then
			remainingGateScanData := self.myMainForm.myAssistant.allRemainingGSRCargo;
			if remainingGateScanData.size &gt; 0 then
				remainingGateScanData.remove(remainingGateScanData.first);
			endif;
		endif;
	
		return true;
	endif;
	
	return false;
	
epilog
	if saveAttachment &lt;&gt; null then
		// save of new attachment proxy was not successful, restore original proxy 
		delete self.myPxyGTEEntity;
		self.myPxyGTEEntity := saveAttachment;
		self.myPxyGTEEntity.setParentObject(saveParent);
		self.myPxyGTEEntity.setMyVehicleVisit(saveVisit);
	endif;
	delete controller;
	//29 Sep 2011	NDL	Par 28285
	if multiPxyGTEArray &lt;&gt; null and not multiPxyGTEArray.isEmpty then
		if not self.isAttachmentForm then	//30 Oct 2013	NDL	Par 31829
			multiPxyGTEArray.purge;
		endif;
	endif;
	delete multiPxyGTEArray;
	delete multiPxyGTEArrayCopy;
	delete warningsToIgnore;
end;</source>
        <access>protected</access>
        <Parameter name="_doSave" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveMakeLCLForm" id="de7fd1dd-8571-4f73-8d42-862a1d466210">
        <updating/>
        <source>doSaveMakeLCLForm():Boolean updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/12/2013	cnwndl1	Initial creation	Par 32854
01/09/2014	cnwdap1	PAR #34771 Mark this LCL as a child object of we have a parent container
08 March 2018	jlgsl4	TFS 37348 - Stop 'Booking is unknown or invalid' for child added to booked ctr
13/04/2024	navnk30 Bug 63247: EUP Testing | Container Weights not updated when Making New LCL
*/

vars

	intFaceArray : CMIF_TIObjectArray;
	indx : Integer;
	preNote : CMIF_PreNote;
	result : Integer;
	errObj : CM_Error;
	newTI : CM_TrackedItem;
	location : CM_LocationsController;
	parentContainer : CM_TrackedItem;
	newTIs			: CM_TISet;

begin

	if self.myPackUnpackObject &lt;&gt; null then
		if self.myPackUnpackObject.isKindOf(CM_LocationsController) then
			location := self.myPackUnpackObject.CM_LocationsController;
		elseif self.myPackUnpackObject.isKindOf(CM_TrackedItem) then
			parentContainer := self.myPackUnpackObject.CM_TrackedItem;
		endif;
	endif;
	
	create intFaceArray transient;
	self.setPreNote();
	
	if parentContainer &lt;&gt; null then						// PAR #34771
		self.myIntFacePreNote.isChild := true;			// PAR #34771
		self.myIntFacePreNote.setMyPackParent(parentContainer); // TFS 37348
	endif;												// PAR #34771
	
	intFaceArray.add(self.myIntFacePreNote);
	
	if self.cargoIDs.size &gt; 1 then
		self.myIntFacePreNote.id := self.cargoIDs[1];
		foreach indx in 2 to self.cargoIDs.size do
			preNote := self.myIntFacePreNote.cloneAllNonInverseProperties();
			preNote.id := self.cargoIDs[indx];
			preNote.setMyProxyTrackedItem(null);
			intFaceArray.add(preNote);
		endforeach;
	endif;
	
	while true do
		if self.updateMode = Mode_Add then
			app.myTrxCA.trxCreateTrackedItemsLCL(intFaceArray, location, parentContainer, app.myPassport);
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid mode (' &amp; self.updateMode.asStringJMT &amp; ')');
			return false;
		endif;
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Prenotes), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			errObj := app.myPassport.getFirstErrorWarning();			
			
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window

			if errObj &lt;&gt; null then
				self.goToErrorItem(errObj);
			endif;
		endif;
		
		return false;

	endwhile;
		
	//13.04.2024 navnk30 #63247 START
	create newTIs transient;
	newTIs.add(self.myIntFacePreNote.getMyTI());
	self.causeEvent(CMUI_AttachBreakBulkModal.LCLCargosCreated, true, newTIs);
	//13.04.2024 navnk30 #63247 END
	
	delete self.myIntFacePreNote;
	
	//epr par 34711 26/8/14 already does this on form as this is modal 

	return true;
	
epilog

	if intFaceArray &lt;&gt; null then
		delete intFaceArray;
	endif;
	
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveOnshipCargo" id="2dc5c37e-c58f-483c-b54d-dc690924381d">
        <updating/>
        <source>doSaveOnshipCargo(    intFaceArray : CMIF_TIObjectArray input) : Boolean updating, protected;
/*

Date		Who		Reason
17 October 2014	cnwer1	Initial creation PAR 34945 refactored
// 17/04/2018    jlgrh7 TFS 38055 MSL - coparn deletes stop fields
// 15/10/2018		jlgrh7 TFS 40673 JMT - Error 90909
*/

vars
	voyage : CM_Voyage;
	preNote : CMIF_PreNote ;
	theY,
	theX : Decimal[14,4]; 
	theDeck : CM_DeckVoyage; 
	msg : String;
	strArray : StringArray; 
	lc : CM_LocationsController;
	height : Integer;
	cargoType : CM_CargoBOLType;
	isLane : Boolean;
	laneDefn : CM_ROROLaneDefn;
	laneLC : CM_ROROLaneController;
	laneLen : Decimal [9,0];
	isROROLC : Boolean;
	spaceidx : Integer;
begin
    voyage := self.cmbVoyageCode.listObject.CM_Voyage;
	preNote := self.myIntFacePreNote;		

	// TFS 40417 the location on ship must include the voyage code
	//						The RORO stuff creates GC RORO areas on deck if the LC does not exist
	//						Use the terminal to find the LC as this uses the voyage code
	self.myTerminal.findLocationFromString(preNote.stowageLocation, false, lc, height);// TFS 40417 use terminal to find
	
	// TFS 40417 DEFAULT
	if voyage &lt;&gt; null  then
		isROROLC := voyage.myROROStructure &lt;&gt; null;
	endif;
	
	if lc &lt;&gt; null then // TFS 40417
		isLane := lc.isROROVoyageLane(); // TFS 40417
	endif;

	// TFS 40417 if LC does not exist and this has RORO decks then try to create the new location.
	if (isLane or lc = null) and isROROLC then
	
		// JLGAB1 TESTING TFS 42863
		theX := preNote.CMIF_OnshipCargo.roroX;
		theY := preNote.CMIF_OnshipCargo.roroY;
	
		// TFS 39254 moved 'findLocation' up here from below
// TFS 40417		create strArray transient;
// TFS 40417	strArray.add(preNote.stowageLocation);
// TFS 40417		voyage.findLocation(strArray, false, lc, height);

		// TFS 40417
		if voyage &lt;&gt; null then
			if preNote.stowageLocation.pos(voyage.code,1) &gt; 0 then
				spaceidx := preNote.stowageLocation.pos(" ",1) + 1;
				preNote.stowageLocation := preNote.stowageLocation[spaceidx:end];
			endif;
		endif;

	
		// TFS 39254 if LC does not exist then it will be treated as a GC area and needs a default X and Y
		if lc = null then
			if self.chkOOTL.getBoolean then																											//+TFS40673
				if not preNote.hasCoordinates(theX, theY) then // OOTL or GC with polygon
					app.raiseCMException(Gener_cargo_ootl_conta_requi_d, null, null);
					return false;
				endif;
			endif;
		else // TFS 39254
			isLane := lc.isROROVoyageLane();
			
			if isLane then
				laneLC := lc.CM_ROROLaneController;
				laneDefn:= laneLC.myLaneDefn;
			endif;
		endif;
		if lc = null then
			theDeck := voyage.myROROStructure.getDeckFromLocationString(preNote.stowageLocation).CM_DeckVoyage;
			// PAR 28400 - Take 2
			if theDeck = null then
				app.raiseCMException1(Err_LocationNotFound, "'" &amp; preNote.stowageLocation &amp; "'. Must contain the deck ID.", null, null);
				return false;
			endif;
			
			//26 June 2012	NDL	Par 29775
			if theDeck.areCoordinatesWild(theX, theY, msg) then
				if app.msgBox( msg,app.getErrorString(Continue),MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon) = MsgBox_Return_No then
					return false;
				endif;
			endif;
		
		endif;
		
		
		// TFS 2250 replace code below with code that works
		//if self.myProxyTrackedItem = null then
		//	self.onCargoTypeChange(); // Creates Proxy 		
		//endif;
		cargoType := cmbType.getObject.CM_CargoType;
		if self.myProxyTrackedItem = null and cargoType &lt;&gt; null then
			create self.myProxyTrackedItem as cargoType.CM_CargoType.myClassToCreate transient;
		endif;	// end 2250
		if self.myProxyTrackedItem = null then // PAR 28400 2
			return false;
		endif;
		self.myIntFacePreNote.setTrackedItemData(null,self.myProxyTrackedItem,app.myPassport);				//+TFS38055 
		
		// TFS 2255 added for a demo on 29/6/16
		cargoType := cmbType.getObject.CM_CargoBOLType;
		if cargoType &lt;&gt; null then
			self.myProxyTrackedItem.setCargoType(cargoType.id);
		endif;
		
		if self.myProxyTrackedItem &lt;&gt; null then					
			//26 June 2012	NDL	Par 29775
//			create strArray transient;
//			strArray.add(preNote.stowageLocation);
//			voyage.findLocation(strArray, false, lc, height);
			if lc &lt;&gt; null and lc.isROROVoyageSlot then
				if not self.myProxyTrackedItem.isKindOf(CM_Container) then
					app.raiseCMException1(Only_containers_roro_slot, preNote.stowageLocation, null, null);
					return false;
				endif;
			endif;
			
			// TFS 39254 get lane length
			if isLane then
				if self.myProxyTrackedItem.length = 0 then
					if laneDefn = null then
						laneLen := 10000; // centimetres
					else
						// lane defn length is in metres, cargo is in centimetres
						laneLen := laneDefn.CM_ROROLaneDefnVoyage.myLaneController.spareLength * 100;
					endif;
					self.myProxyTrackedItem.setLength(laneLen);
				
				endif;
			endif;
			
			delete strArray;
			if isLane then // TFS 39254
				app.myTrxCA.trxCreateROROLaneCargo(false,  laneDefn, null, self.myProxyTrackedItem,app.myPassport);		// TFS 39254
			elseif self.myProxyTrackedItem.isKindOf(CM_Container) then
				app.myTrxCA.trxCreateROROOOTLCargo(null, preNote.stowageLocation, self.myProxyTrackedItem, true, theX, theY, theDeck, app.myPassport);
			else
				app.myTrxCA.trxCreateROROGCCargo(false, null,preNote.stowageLocation,self.myProxyTrackedItem,theX, theY,theDeck,app.myPassport);
			endif;
			self.myProxyTrackedItem := null; 
			self.myIntFacePreNote.setMyProxyTrackedItem(null);				
		endif;

	else
		app.myTrxCA.trxCreatePreNotes(intFaceArray, false, app.myPassport);
	endif;
	
	return true;
epilog
	delete strArray;
end;</source>
        <access>protected</access>
        <Parameter name="intFaceArray" type="CMIF_TIObjectArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveOnsiteCargo" id="e0dd5781-83b8-4c90-8926-0be115b31c3f">
        <updating/>
        <source>doSaveOnsiteCargo(    intFaceArray : CMIF_TIObjectArray input) : Boolean updating, protected;
/*
Purpose:			
Date				Who			Reason
FEB 2107		CNWAB1		Initial creation
*/


vars
	voyage : CM_Voyage;
	preNote : CMIF_PreNote ;
	theY,
	theX : Decimal[14,4]; 
	theDeck : CM_DeckVoyage; 
	msg : String;
	strArray : StringArray; 
	lc : CM_LocationsController;
	height : Integer;
	cargoType : CM_CargoBOLType;
begin
    voyage := self.cmbVoyageCode.listObject.CM_Voyage;
	preNote := self.myIntFacePreNote;		

	app.myTrxCA.trxCreatePreNotes(intFaceArray, false, app.myPassport);
	
	return true;
epilog
	delete strArray;
end;</source>
        <access>protected</access>
        <Parameter name="intFaceArray" type="CMIF_TIObjectArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSavePreNoteForm" id="ae126b1f-46e6-4919-94ee-4474e0092ef7">
        <updating/>
        <source>doSavePreNoteForm(): Boolean updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/07/2009	cnwdap1	Initial creation
15/12/2009	cnwdap1	PAR #21826 Don't set original proxy TI on prenote if we're in the attachment form - this will be handled by the parent TI later
							Original proxy was being deleted in parent processing, then causing an error 4 when the child was updated
Jan-Feb 2010 cnwjre1 CCMS1071 add code for general cargo on-ship
24/02/2010	cnwdap1	PAR #22466 Error 4 when saving PreNote - myIntFacePreNote erase method was deleting the myProxyTrackedItem object on the CMIF_PreNote,
								but this was the same object as self.myProxyTrackedItem. When this form did its own tidy-up, this object was no longer there.
18/12/2015  cnwma1	PAR #37281	Container quantity = 63	
11/01/2022	navdap1	TFS 52268	AAT 1-Stop VBS Integration
01/03/2022	navdap1	TFS 52974	MTN 1-Stop VBS Integration - Error while creating a prenote
JIRA 12384 21OCT2024 NAVAB1 : EUP - DeadLocks When Creating Prenotes
05 Jan 2026 navhl20 Bug MTN-36905: MTN - Transient leaks in receive cargo forms.
*/
vars
	tmpAttach			: CMIF_InOutAttachment;
	errObj				: CM_Error;
	result				: Integer;
	intFaceArray		: CMIF_TIObjectArray;
	origCargoType		: Integer;
	origTransMode		: Integer;
	newTI				: CM_TrackedItem;
	termEmailDefaults	: CM_PINObjectDefaultEmail;
	carrier				: CM_Carrier;
	defaultEmailType	: Integer;
	validateOnly		: Boolean;
	preNote				: CMIF_PreNote;
	indx				: Integer;
	consignee			: CM_ConsigneeConsignor;
	cargotype			: CM_CargoType;
begin
	// are we doing an actual prenote update, or creating a transient attachment?
	if self.isAttachmentForm() then
		if self.myTI &lt;&gt; null and not self.myTI.isTransient then
			validateOnly := false;
		else
			validateOnly := true;
		endif;
	else
		validateOnly := false;
	endif;
	
	if self.updateMode = Mode_Update then
		if self.myProxyTrackedItem = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'ProxyObject is null for update');
			return false;
		endif;
		if self.myTI &lt;&gt; null then
			origCargoType := self.myTI.CM_TrackedItem.cargoType;
			origTransMode := self.myTI.CM_TrackedItem.receiptTransportMode;
		endif;
		
		// PAR 21827 If allAttachments has tracked items in it, we are editing an existing tracked item
		// Remove the tracked items and replace with CMIF_PreNotes so that normal processing works
		self.doConvertTIAttachments();
	endif;
	
	if self.isOnshipForm 											//18/12/2015  cnwma1 PAR #37281 ,To clear those details when using Save Next
	or self.isOnsiteForm then // TFS 2318
		cargotype :=self.cmbType.getObject.CM_CargoType;
		if cargotype &lt;&gt; null then
			if cargotype.id = TI_CargoType_Container then
				tblVolume.setValueDefault(null);
				tblTotalVolume.setValueDefault(null);
				tblDensity.setValueDefault(null);
				tblWidth.setValueDefault(null);
				tblLength.setValueDefault(null);
				tblHeight.setValueDefault(null);
				txtNumItems.setValue(null);
				txtQuantity.setValue(null);
			endif;
		endif;
	endif;
	
	create intFaceArray transient;
	self.setPreNote();

	//if self.myProxyTrackedItem &lt;&gt; null and not self.isAttachmentForm then		// PAR 21826 Don't set original proxy on attachment form
	if self.myProxyTrackedItem &lt;&gt; null and self.myProxyTrackedItem.pxyIsProxy then		// PAR 21826 Don't set original proxy on attachment form
		self.myIntFacePreNote.CMIF_PreNote.setMyOriginalProxyTI(self.myProxyTrackedItem.CM_TrackedItem);
	endif;
	
	// TFS 52974 This is checking for a booking slot for TODAY for a prenote - a little bit OTT
	// TFS 52974 if self.isPreNoteForm and not self.do1StopVBSCheck(self.myIntFacePreNote) then	// TFS 52268
	// TFS 52974 	return false;																// TFS 52268
	// TFS 52974 endif;																			// TFS 52268
	
	if self.myEmailDefaults = null
	and self.updateMode = Mode_Add
	and self.myIntFacePreNote.CMIF_PreNote.transportMode.trimBlanks = TI_TRANSMODE_ROAD_STR then //par15417 cnwrs1 nov 2007
		//create a clone of the terminal default to add to the IntFacePreNote
		//there may already be one if the terminal defaults have been changed by the user in this mode 
		if self.myIntFacePreNote.hasCSIStop then
			defaultEmailType	:= PINEmail_PrenoteCustomsInspect;
		else
			defaultEmailType	:= PINEmail_Prenote;
		endif;
		termEmailDefaults	:= self.myTerminal.getEmailDefaultsSettings( defaultEmailType );
		self.myEmailDefaults := termEmailDefaults.cloneSelf(true).CM_PINObjectDefaultEmail;
		carrier := self.cmbCarrier.getObject.CM_Carrier;
		consignee := self.cmbConsignee.getObject.CM_ConsigneeConsignor; //+ cnwmd1 Par 24232
		//if carrier &lt;&gt; null then //- cnwmd1 Par 24232
		//self.myEmailDefaults.setAddresses( self.myTerminal, carrier, null, defaultEmailType ); //- cnwmd1, Par 24232
		self.myEmailDefaults.setAddresses( self.myTerminal, carrier, consignee, defaultEmailType ); //+ cnwmd1 Par 24232
		//endif;
	endif;

	if self.myEmailDefaults &lt;&gt; null then
		self.myIntFacePreNote.setEmailDefaultObject(self.myEmailDefaults);
	endif;
	
	intFaceArray.add(self.myIntFacePreNote);
	// multiple items CCMS 1071 - copy the incoming CMIF_PreNote and allocate the cargo ids - all else stays the same
	if self.cargoIDs.size &gt; 1 then
		self.myIntFacePreNote.id := self.cargoIDs[1];
		foreach indx in 2 to self.cargoIDs.size do
			preNote := self.myIntFacePreNote.cloneAllNonInverseProperties();
			preNote.id := self.cargoIDs[indx];
			preNote.setMyProxyTrackedItem(null);
			intFaceArray.add(preNote);
		endforeach;
	endif;

	while true do
		if validateOnly then
			app.myValCA.valTrackedItemAttachment(self.myIntFacePreNote, app.myPassport);
		elseif self.updateMode = Mode_Add then
			//epr par 34945 20/10/14
			preNote := self.myIntFacePreNote;
			if preNote &lt;&gt; null and preNote.isKindOf(CMIF_OnshipCargo) then 		
				if not self.doSaveOnshipCargo( intFaceArray) then
					return false;
				endif;
			elseif preNote &lt;&gt; null and preNote.isKindOf(CMIF_OnsiteCargo) then 		
				if not self.doSaveOnsiteCargo( intFaceArray) then
					return false;
				endif;
			else
				app.myTrxCA.trxCreatePreNotes(intFaceArray, false, app.myPassport);
				// ### JIRA 12384 21OCT2024 NAVAB1
				if app.myPassport.hadDeadlock = true then	
					return false;
				endif;
			endif;
		elseif self.updateMode = Mode_Update then
			app.myTrxUA.trxUpdatePreNotes(intFaceArray, false, app.myPassport);
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid mode (' &amp; self.updateMode.asStringJMT &amp; ')');
			return false;
		endif;
		
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Prenotes), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;

	endwhile;

	// The update was successful
	
	if not validateOnly then
		newTI := self.myIntFacePreNote.myPersistentTrackedItem;
		if newTI = null and 
			preNote.myProxyTrackedItem &lt;&gt; null then
			newTI := app.myProxyManager.getRealObject(preNote.myProxyTrackedItem).CM_TrackedItem;
		endif;
	endif;

	if self.updateMode = Mode_Add then
		// set self.myCurrentObject so this is selected in table
		self.myCurrentTrackedItem := newTI;
		if newTI &lt;&gt; null then
			if self.isPreNoteForm then
				self.myAssistant.addPreNoteFromCargoReceiptForm(self.myMainForm, newTI);
				if not self.myTerminal.getConfig(NoPINs).Boolean then
					if self.myIntFacePreNote.CMIF_PreNote.transportMode.trimBlanks = TI_TRANSMODE_ROAD_STR 
						and self.myIntFacePreNote.pinNo &lt;&gt; null	//It can be null, when no PIN generation for hazardous or over dimension cargo. ccms 1676 Feb 2009.
					then
						app.msgBox('Pre-Note added with PIN (' &amp; self.myIntFacePreNote.pinNo &amp; ')', 'Pre-Note Added', MsgBox_OK_Only + MsgBox_Information_Icon);
					//cnwmc5 - 24 Feb 2014 - PAR 35743
					//else
					//	app.msgBox('Pre-Note added successfully', 'Pre-Note Added', MsgBox_OK_Only + MsgBox_Information_Icon	);
					endif;		
				endif;
			endif;
		endif;
		
	else
		// self.mode = Mode_Update
		if newTI &lt;&gt; null then
		   	if newTI.cargoType &lt;&gt; origCargoType then
		   		self.myCurrentTrackedItem := newTI;
		   		
		   		// switch the mode as the old obj has been deleted and
		   		// a new one created
		   		self.updateMode := Mode_Add;
		   	endif;
		   	
		endif;
	endif;
	
	// if we're doing an attachment, save it back to the parent form
	//if validateOnly then	// PAR #21827
	if self.isAttachmentForm then
		// PAR #21827 If we're updating, the object we have will be the newTI, not the intFacePreNote
		if self.updateMode = Mode_Update and newTI &lt;&gt; null then
			self.myParentForm.CMUI_ReceiveCargoForm.updateAttachments(newTI);
		else
			self.myParentForm.CMUI_ReceiveCargoForm.updateAttachments(self.myIntFacePreNote);
			
			//08 July 2014	NDL	Par 34526
			if intFaceArray &lt;&gt; null and intFaceArray.size &gt; 1 then
				foreach indx in 2 to intFaceArray.size do
					preNote := intFaceArray[indx].CMIF_PreNote;
					self.myParentForm.CMUI_ReceiveCargoForm.updateAttachments(preNote);
				endforeach;
			endif;
			
		endif;
		return true;
	endif;

	//self.allAttachments.purge;
	self.purgeTransientAttachments();	//10 Oct 2012	NDL	Par 30503
	
	// don't delete the transient if we're an attachments form, this transient has been attached to the 
	// parent form as one of its attachments
	if not validateOnly then
		// PAR #22466 myIntFacePreNote has a link to self.myProxyTrackedItem which gets deleted when
		// myIntFacePreNote is deleted, so clear the self.myProxyTrackedItem reference
		//self.myProxyTrackedItem := null;  //  cnwrd1 par 22549 11.3.2010 if from prenote form deleting cmig_prenote doesnt delete the proxy
		delete self.myIntFacePreNote;
	endif;
	return true;
	
epilog
	if intFaceArray &lt;&gt; null then
		intFaceArray.purge();					//05.01.2026 navhl20 #36905
		delete intFaceArray;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSavePreNoteFormDLRT" id="530836ef-27bc-49b4-9a4c-034892675d3a">
        <updating/>
        <source>doSavePreNoteFormDLRT():Boolean protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
JIRA 12384 21OCT2024 NAVAB1: EUP - DeadLocks When Creating Prenotes
7/3/25 navsaa30 14818 MTN | Silent Deadlock Retry Technical Debt
03/11/2025 jlier1 	MTN-34531 - Deadlock retry for everyone
*/

vars
	localCaption : String;
	result, hadDeadlock : Boolean;
begin
	localCaption := self.caption;
	
	//set up the silent deadlock handler to attempt to retry
	app.myPassport.setupForDeadlockReplay(250, 3000);
	app.myPassport.silentDeadlockLimit := 10;	
	
	self.mousePointer := Window.MousePointer_HourGlass;
	
	while true do
	
		//call the code that was originally in this method
		if not self.doSavePreNoteForm() then	// original code 
			if not  hadDeadlock then	
				return false;
			endif;
		endif;
		
		//if we did NOT have a dead lock, just bail out.
		if app.myPassport.noTrxReplayAllowed() then	
			if app.myPassport.hadDeadlock then //had a deadlock and reached the limit show the deadlock error
				app.showErrorWarningDialog(app.getErrorString(Gate), app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			endif;
			return not hadDeadlock;
		endif;
		
		self.updateCaptionDeadlockRetry(localCaption);	
	endwhile;

	
epilog

	//set the silent deadlock handler back to the default values i.e. OFF
	
	app.myPassport.resetSilentDeadlockHandler;	//7/3/25 navsaa30 #14818
	self.caption := localCaption;
	self.mousePointer := Window.MousePointer_Default;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveRailPreNoteForm" id="f43e4814-53f6-48ca-8e2c-2dbe3d09778d">
        <updating/>
        <source>doSaveRailPreNoteForm(): Boolean updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05/08/2009	cnwdap1	Initial creation
12/10/2009	cnwdap1	PAR #20814 Allow for Temperature in Rail screen - new Ent Table Def
08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
27/03/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
10/04/2014	cnwdap1	PAR #33606 CCMS SFW 1366 Bulk
24.1.2018 	cnwma1  Bug 36720: LNX - FW: Ticket 8126 Ticket Number 6223214 - GLG - JMT - fault. THIS IS A PRIORATY A
20 may 2022 navtnr20 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
16 August 2022	navak20	TFS ChangeRequest 54441: EUP - Additional Field - Country of Origin
21 Feb 2023 navtnr20	TFS CR 55648 Task 55663: UI - Contract Id
*/
vars
	proxyTI,
	ti,
	cloneTi			: CM_TrackedItem;
	cargoType 		: CM_CargoBOLType;
	tiId,
	proxyTIID		: String;
	loadState		: Boolean;
	class			: Class;
	containerID,
	commodity		: String;
	operator		: CM_Operator;
	weight		   : Decimal [16,8];
	product        : CM_Product;
	tiMaster :     CM_TIMaster;
	genMaster      : CM_TIMaster;
	pxyGen         : CM_Generator;
	ship		: CM_ShippingLine;
begin

		cargoType 	:= self.cmbType.getObject.CM_CargoBOLType;
		tiId 		:= self.txtCargoID.getString.trimBlanks.toUpper;
		
		if cargoType = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Cargo Type', null, null);
			app.raiseCMException(Input_required_field_cargoType, null, null); // cnwdb2	PAR 35364
			return false;
		endif;
			
		if tiId = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Cargo ID', null, null);
			app.raiseCMException(Input_required_field_cargoId, null, null); // cnwdb2	PAR 35364
			return false;
		endif;	

		app.cmsBeginLoad(loadState);	// remove loadstate

		if app.isInterTerminalTransferEnabled() then
			ti := self.myTerminal.lookupTrackedItem(tiId.toUpper.trimBlanks, cargoType.id, TI_STATE_TRANSFER, null, true);
		endif;
		
		if ti &lt;&gt; null then
			cloneTi := ti.getCloneForInterTerminalMove2(self.myTerminal, true);
		else
			ti := self.myTerminal.allNotifiedTIsByCargoTypeId[cargoType.id, tiId.toUpper.trimBlanks];
			//12 Sep 2013	NDL	Par 32479 - multi pre-note break bulk on train
			if ( cargoType.isAllowDuplicates ) and self.updateMode = self.Mode_Add then
				ti := null;
			endif;
		endif;
		
		// cnwrd1 1/11/2010 par 25075 CCMS POL 1973
	/* •	UiCommonSchema CMUI_ReceiveCargoForm doSaveRailPreNoteForm – remove current validation checks for on-site cargo items (at line 53). 
			Replace with expanded checks based on edit mode of the screen/ and checking prenoted and on-site cargo. 
				If adding and on-site match found, raise a warning. 
				If adding and a prenoted match found, raise an error. 
				If editing and on-site match found, raise a warning.*/	
				
		if self.updateMode = self.Mode_Update then
			// we are updating
			if self.myTerminal.allOnsiteTIsByCargoTypeId[cargoType.id, tiId.trimBlanks] &lt;&gt; null then
				app.raiseCMWarning1(ERR_TI_ONSITE,tiId.trimBlanks, null,null,null);
				return false;
			endif;
			
		elseif self.updateMode = self.Mode_Add then
			//we are adding
			
			if ( not cargoType.isAllowDuplicates ) then //12 Sep 2013	NDL	Par 32479 - multi pre-note break bulk on train
				//if there is an onsite real raise a warning
				if self.myTerminal.allOnsiteTIsByCargoTypeId[cargoType.id, tiId.trimBlanks] &lt;&gt; null then
					app.raiseCMWarning1(ERR_TI_ONSITE,tiId.trimBlanks, null,null,null);
					return false;
				endif;		
				// if there is a prenote already raise an error
					
					if self.myTerminal.allNotifiedTIsByCargoTypeId[cargoType.id, tiId.trimBlanks] &lt;&gt; null then				
						app.raiseCMException2(ERR_PRENOTE_ID_EXISTS, tiId, null,"", null); 
					return false;
					
				endif;
			endif;
			
		endif;
		
		if cargoType.isKindOf(CM_CargoType) then
			class := cargoType.CM_CargoType.myClassToCreate;
		else
			class := cargoType.class;
		endif;
		
		if ti = null then
			if self.myTI &lt;&gt; null and myTI.isTransient then
				proxyTI := self.myTI;
			else
				endLoad;	//19 May 2011	NDL	Par 27459 - must be unconditional here, we will be in load state, and must end it
			//12 Sep 2013	NDL	Par 32479 - No point in asking the question, thats exactly what they are trying to do from this form.....
			//	if app.msgBox(app.getErrorString(YRDWagonCreateItem), "Add New Cargo Item", MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
					beginLoad;	//19 May 2011	NDL	Par 27459 - must be unconditional here, must restart it.
					create proxyTI as class transient;
					proxyTI.setPxyFromDefaultTI(self.myTerminal,cargoType.id, tiId, null, null);
					
					//27.02.2018 cnwma1 ChangeRequest #36813
					/*
					tiMaster := app.myRoot.findTIMasterByCargoType(cargoType.id,tiId);
					if tiMaster  &lt;&gt; null and tiMaster.allTIMasterAttachees.isNotEmpty then
						genMaster :=tiMaster.allTIMasterAttachees.first.CM_TIMaster;
						if genMaster &lt;&gt; null then
						
						create pxyGen transient;
						pxyGen.setPxyFromDefaultTI(proxyTI.myTerminal,genMaster.cargoType,genMaster.id,null,genMaster.myOperatorNew);
						pxyGen.setPxyFromTIMaster(genMaster.CM_TIMasterGenerator,proxyTI);					
						proxyTI.attachGenerator(pxyGen,app.myPassport);
						endif;
					endif;
					*/
					//27.02.2018 cnwma1 ChangeRequest #36813
			//	else
			//		beginLoad;	//19 May 2011	NDL	Par 27459 - must be unconditional here, must restart it.
			//		return false;
			//	endif;
			endif;
		elseif cloneTi &lt;&gt; null then
			proxyTI := cloneTi;
		elseif ti &lt;&gt; null then
			if ti.site = TI_SITE_ONSITE then
				app.raiseCMException1(ERR_TI_ONSITE, tiId.trimBlanks, null, null);
				app.raiseCMException1(ERR_ADDING_TI, tiId.trimBlanks, null, null);
				return false;
			endif;
			
			proxyTI := ti.pxyGetProxyObject;
				
			if proxyTI &lt;&gt; null then
				if (not self.myCurrentTrackedItem = ti) then
					endLoad;	//19 May 2011	NDL	Par 27459 - must be unconditional here, we will be in load state, and must end it
					app.msgBox(app.getErrorString(YRDWagonCargoItemAdd), "Add Cargo Item", MsgBox_Stop_Icon + MsgBox_OK_Only);
					beginLoad;	//19 May 2011	NDL	Par 27459 - must be unconditional here, must restart it.
					return false;
				endif;
			else
				proxyTI := ti.pxyCreateUpdateProxy();
			endif;
		endif;
		
		// we have the default proxy - now set the relevant values from the form
		if txtCargoID.getString &lt;&gt; null then
		//	containerID := txtCargoID.getString;
		endif;
		if cmbOperatorCode.listObject &lt;&gt; null then
			operator := cmbOperatorCode.listObject.CM_Operator;
		endif;
		if cmbCommodity.getObject &lt;&gt; null then
			commodity := cmbCommodity.getObject.CM_Commodity.code;
		endif;
		
		proxyTI.setPxyFromDefaultTI(	self.myTerminal,
										cargoType.id,
										containerID,
										commodity,
										operator	);
										
		if txtBookingRef.getString &lt;&gt; null then
			proxyTI.setBookingReference(txtBookingRef.getString);
		endif;
		if cmbISOType.getObject &lt;&gt; null then
			//+cnwml2 PAR25323
			if proxyTI.isKindOf(CM_Container) then
				proxyTI.CM_Container.setISOType(cmbISOType.getObject.CM_ISOType.code);
			elseif proxyTI.isKindOf(CM_Generator) then
				proxyTI.CM_Generator.setISOType(cmbISOType.getObject.CM_ISOType.code);
			endif;
		endif;
		if cmbSubCargo.getObject &lt;&gt; null then
			proxyTI.setMyProduct(cmbSubCargo.getObject.CM_Product);
		endif;
		if cmbVoyageCode.listObject &lt;&gt; null then
			proxyTI.setVoyageCode(cmbVoyageCode.listObject.CM_Voyage.code, app.myPassport);
		endif;
		if cmbDestPort.listObject &lt;&gt; null then
			proxyTI.setDestinationPort(cmbDestPort.listObject.CM_Port.code);
		endif;
		if cmbDischargePort.listObject &lt;&gt; null then
			proxyTI.setDischargePort(cmbDischargePort.listObject.CM_Port.code);
		endif;
		if cmbTranshipPort.listObject &lt;&gt; null then
			proxyTI.setTranshipToPort(cmbTranshipPort.listObject.CM_Port);
		endif;
		// START 20 may 2022 navtnr20 TFS 53204
		if cmbShippingLine.getObject &lt;&gt;  null then
			proxyTI.setMyShippingLine(cmbShippingLine.getObject.CM_ShippingLine);
		endif;
		// END	20 may 2022 navtnr20 TFS 53204
		
		//Start 16.08.2022 navak20 TFS 54441
		if cmbCtryOfOrigin.getObject &lt;&gt;  null then
			proxyTI.setMyCountryOfOrigin(cmbCtryOfOrigin.getObject.CM_Country);
		endif;
		//End 16.08.2022 navak20 TFS 54441
		if cmbInvContractID.getObject &lt;&gt; null then	//21.02.2023 navtnr20 TFS CR 55648 Task 55663
			proxyTI.setContractId(cmbInvContractID.getObject.CM_InvoiceContract.contractId);
		endif;
		//if txtTotalWeight.getInteger &lt;&gt; null then 												// PAR #31155
		//	proxyTI.setTotalWeight(txtTotalWeight.getInteger, null, app.myPassport);				// PAR #31155
		if tblTotalWeight.getConvertedValue &lt;&gt; null then 											// PAR #31155
			
			//proxyTI.setTotalWeight(tblTotalWeight.getConvertedValue, null, app.myPassport);		// PAR #31155 //24.1.2018 cnwma1 BUG #36720
			//24.1.2018 cnwma1 BUG #36720
			if cargoType &lt;&gt; null and cargoType.CM_CargoType.isBulkByVolume then
				if not self.cmbSubCargo.isHidden then
					product := self.cmbSubCargo.getObject.CM_Product;
				else
					product := cargoType.CM_CargoType.mySystemProductType;
				endif;
				if product &lt;&gt; null and product.myDensityDec.value &lt;&gt; null then							// ### TFS 52193 22Nov2021 NAVPW1
						weight := self.tblTotalVolume.getConvertedValue * product.myDensityDec.value;	// ### TFS 52193 22Nov2021 NAVPW1
				endif;
				proxyTI.setTotalWeight(weight, null, app.myPassport);
			else
				proxyTI.setTotalWeight(tblTotalWeight.getConvertedValue, null, app.myPassport);
			endif;

		endif;
		if self.tblTotalVolume.getConvertedValue &lt;&gt; null then												// PAR #33606
			proxyTI.setTotalVolumeWithTrans(self.tblTotalVolume.getConvertedValue, null, app.myPassport);	// PAR #33606
		endif;																								// PAR #33606
		if cmbTrailerType.getObject &lt;&gt; null and proxyTI.isKindOf(CM_TILC) then
			proxyTI.CM_TILC.setMyType(cmbTrailerType.getObject.CM_TILCType);
		endif;
		if cmbGeneratorType.getObject &lt;&gt; null and proxyTI.isKindOf(CM_Generator) then
			proxyTI.CM_Generator.setMyGeneratorType(cmbGeneratorType.getObject.CM_GeneratorType);
		endif;
		
		if txtCarriageTemp.getDecimal &lt;&gt; null and proxyTI.isKindOf(CM_Container) then	// PAR #20814
			proxyTI.CM_Container.zSetPxyTemperatureCelsius(txtCarriageTemp.getDecimal);	// PAR #20814
		endif;																			// PAR #20814
		
		proxyTI.setReceiptTransportMode(TI_TRANSMODE_RAIL);		// 19/11/2012 cnwar2 #30463
		
		//19 Aug 2013	NDL	Par 32169
		//if proxyTI.myCargoType &lt;&gt; null and proxyTI.myCargoType.allowDuplicates then
		//	proxyTI.setTotalQuantity( self.txtNumItems.getInteger );
		//endif;
		self.setObjectFromNumItemsValue( proxyTI );	//04 Mar 2014	NDL	Par 33596
		
		//12 Sep 2013	NDL	Par 32452
		proxyTI.setMark(self.txtMark.getString);
		if proxyTI.isKindOf( CM_BreakBulkGeneric) then
			proxyTI.CM_BreakBulkGeneric.setColour( self.myAssistant.getColourString(self.lstColourList, self.txtColourList) );
		endif;
		
		//jlier1 TFS 53515 - 26/5/22	
		if app.isCargoGroupEnabled then
			proxyTI.setCargoGroup(null,self.txtCargoGroupID.getString,app.myPassport);
		endif;
		
		//the proxy is now passed to teh assistant that performs teh call on teh correct form to process the proxy....
		self.myAssistant.addPreNoteFromCargoReceiptForm(self.myParentForm, proxyTI);
	return true;

epilog
	app.cmsEndLoad(loadState);		// 08/04/2011 cnwmh5 #27347
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSelectVoyage" id="7d6a2bb7-9630-48ee-b7d5-bcb599c5fe61">
        <updating/>
        <source>doSelectVoyage() updating, protected;
// from cmbVoyageCode_click and ship voyage selection, to set associated operator etc

vars
	tmpVoyage	: CM_Voyage;
	voyageCode	: String;
	pos			: Integer;
	operator    : CM_Operator;
	port	: CM_Port;
	portString  : String;
begin
	self.lstOptionalPorts.clearSelected();
	self.myAssistant.listTableDischarge(self.lstOptionalPorts, self.cmbVoyageCode.listObject.CM_Voyage, null);
	
	// Filter the operator based on voyage
	
	pos := 1;
	voyageCode := self.cmbVoyageCode.text;
	if voyageCode &lt;&gt; null then
		// strip off the description
		voyageCode := voyageCode.scanUntil(Tab, pos).trimRight;
	endif;	
	
	tmpVoyage := self.myAssistant.getVoyageFromCombo(voyageCode);
	self.cmbOperatorCode.resetCollectionForVoyage(tmpVoyage);
	
	// discharge ports
	port := self.cmbDischargePort.listObject.CM_Port;
	self.cmbDischargePort.setObjectAndVoyage(port, tmpVoyage); 
	
	if port = null and self.isOnshipForm then
		//02 Aug 2013	NDL	Par 32154 - Set default discharge port to here...
		portString 	:= self.myTerminal.getConfig(PortDestCode).String;
		if portString &lt;&gt; null then
			port := app.myRoot.allPorts[portString];
		endif;
		if port &lt;&gt; null then
			self.cmbDischargePort.setObjectFromCode(portString);
		endif;
	endif;
	
	//tranship ports
	self.cmbTranshipPort.setObjectAndVoyageDischPort(port,tmpVoyage);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSetCaption" id="e4421cdd-4421-46e1-8e7f-854bf62f475d">
        <updating/>
        <source>doSetCaption() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
16 July 2009	cnwjk3	Initial creation
20 Jan 2010		cnwjre1	Add Onship code, CCSM 1071
*/
vars
	cap		: String;
	
begin
	if self.isOnshipForm or self.isOnsiteForm then //TFS 2318
		if self.updateMode = self.Mode_Add then
			cap := app.getErrorString(Cargo_ADD);
		else
			cap := app.getErrorString(Cargo_Edit);
		endif;
		self.setCaption(cap);
		return;
	endif;
	
	if self.isMakeLCLForm then
		if self.myPackUnpackObject.isKindOf(CM_LocationsController) then
			cap := app.getErrorString(Cargo_ADD);
		elseif self.myPackUnpackObject.isKindOf(CM_TrackedItem) then
			cap := app.getErrorString1(Make_LCL_In, self.myPackUnpackObject.CM_TrackedItem.id);
		endif;
		self.setCaption(cap);
		return;
	endif;
	
	if self.currentEntTableDef = ETDef_ContainerFull then
		if self.isPreNoteForm then
			cap := app.getErrorString(Prenote_caption) &amp; " " &amp; app.getErrorString(Full) &amp; " " &amp; app.getErrorString(Container);
		else
			cap := app.getErrorString(Receive) &amp; " " &amp; app.getErrorString(Full) &amp; " " &amp; app.getErrorString(Container);
		endif;	
		
	elseif self.currentEntTableDef = ETDef_ContainerFullReefer then
		if self.isPreNoteForm then
			cap := app.getErrorString(Prenote_caption) &amp; " " &amp; app.getErrorString(Full) &amp; " " &amp; app.getErrorString(Reefer);
		else
			cap := app.getErrorString(Receive) &amp; " " &amp; app.getErrorString(Full) &amp; " " &amp; app.getErrorString(Reefer);
		endif;
	elseif self.currentEntTableDef = ETDef_ContainerEmpty then
		if self.isPreNoteForm then
			cap := app.getErrorString(Prenote_caption) &amp; " " &amp; app.getErrorString(Empty) &amp; " " &amp; app.getErrorString(Container);
		else
			cap := app.getErrorString(Receive) &amp; " " &amp; app.getErrorString(Empty) &amp; " " &amp; app.getErrorString(Container);
		endif;
	elseif self.currentEntTableDef = ETDef_NewItem then
		cap := app.getErrorString(Prenote_caption) &amp; " " &amp; app.getErrorString(New) &amp; " " &amp; app.getErrorString(Item);
	elseif self.currentEntTableDef.isOneOf(ETDef_RailPreNote, ETDef_RailPreNoteCargo,ETDef_CreateNewCargo) then
		cap := app.getErrorString(Create) &amp; " " &amp; app.getErrorString(New) &amp; " " &amp; app.getErrorString(Cargo);
	elseif self.currentEntTableDef = ETDef_AttachmentDetails then
		cap := app.getErrorString(Attachment) &amp; " " &amp; app.getErrorString(Details) &amp; " " &amp; app.getErrorString(Container);
	elseif self.currentEntTableDef = ETDef_AttachmentGeneral then
		cap := app.getErrorString(Attachment) &amp; " " &amp; app.getErrorString(Details) &amp; " " &amp; app.getErrorString(CMQF_GeneralCargo);
	else
		if self.isPreNoteForm then
			cap := app.getErrorString(Prenote_caption) &amp; " " &amp;  app.getErrorString(CMQF_GeneralCargo);
		else
			cap := app.getErrorString(Receive) &amp; " " &amp;  app.getErrorString(CMQF_GeneralCargo);
		endif;
	endif;
	self.setCaption(cap);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSetSubTerminal" id="5ede96e6-57b2-4959-99f6-76a272fabb65">
        <source>doSetSubTerminal() protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 August 2009	cnwdap1	Initial creation
11/03/2010	cnwmh5	PAR 22546 - only do if myTI/MyRealGTEEntity are null so
					doesn't set sub terminal to default if editing one of these items
*/
vars
	imexStatusObj	: CM_IMEXStatus;
	imexStatus		: Integer;
	commodityObj	: CM_Commodity;
	commodCode		: String;
	terminalObj		: CM_Terminal;
	subTerminalObj	: CM_SubTerminal;
	cargoTypeObj	: CM_CargoBOLType;
	subTerminaType	: Integer;
	isContainer		: Boolean;
	releaseType		: Integer;
	
begin
	if cmbSubTerminal.isHidden then
		return;
	endif;
	
	// 11/03/2010 cnwmh5 #22546 - Start
	if myTI &lt;&gt; null or self.myRealGTEEntity &lt;&gt; null then
		return;
	endif;
	// 11/03/2010 cnwmh5 #22546 - End
	
	terminalObj		:=	self.myTerminal;
	cargoTypeObj	:=	cmbType.getObject.CM_CargoBOLType;
	imexStatusObj	:=	cmbImexStatus.getObject.CM_IMEXStatus;
	commodityObj	:=	cmbCommodity.getObject.CM_Commodity;
	isContainer		:=	false;
	releaseType		:=	0;
	
	if cargoTypeObj &lt;&gt; null then
		if cargoTypeObj.isCargoType() then
			subTerminaType := CM_SubTerminal.Type_TrackedItem;			//+cnwml2 PAR24393
			if cargoTypeObj.id = TI_CargoType_Container then
				isContainer		:=	true;
			else
				isContainer		:= false;
			endif;
		else
			subTerminaType		:=	CM_SubTerminal.Type_BOL;
		endif;
	endif;
	
	if imexStatusObj &lt;&gt; null then
		imexStatus	:=	imexStatusObj.code;
	endif;
	
	if commodityObj &lt;&gt; null then
		commodCode	:=	commodityObj.code;
	endif;
	
	subTerminalObj	:=	terminalObj.getDefaultSubTerminal(	subTerminaType,
															releaseType,	// cnwdad1 27/01/2010 - PAR #22205.
															imexStatus,
															commodCode,
															isContainer);
	if subTerminalObj &lt;&gt; null then
		cmbSubTerminal.setForObject(subTerminalObj);
	endif;	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSetTemperatureLabels" id="d658b4a9-10b3-4e30-abef-c5cbc63b9582">
        <source>doSetTemperatureLabels() protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30/07/2009	cnwjk3	Initial creation
05/05/2015	cnwdap1	PAR #36094 CCMS 1413 TFS 313 Cold Store Enhancements
*/
vars
	ctrl			: Control;
	obj				: Object;
	strPackTemp,
	strCarriageTemp	: String;
	
begin
	obj :=  self.cmbOperatorCode.listObject;
	if obj &lt;&gt; null then
		//strCarriageTemp := "Carriage Temp ";															// PAR #36094
		//strPackTemp := "Pack Temp ";																	// PAR #36094
		if obj.CM_Operator.displayTempFahrenheit  then
			//strCarriageTemp := strCarriageTemp &amp; "(deg F)";											// PAR #36094
			//strPackTemp := strPackTemp &amp; "(deg F)";													// PAR #36094
			strCarriageTemp := app.getEntTableRowTranslation(ETRow_CarriageTempF, ETGrp_CargoDetails);	// PAR #36094
			if strCarriageTemp = null then																// PAR #36094
				strCarriageTemp := "Carriage Temp (deg F)";												// PAR #36094
			endif;																						// PAR #36094
			strPackTemp := app.getEntTableRowTranslation(ETRow_PackTempF, ETGrp_CargoDetails);			// PAR #36094
			if strPackTemp = null then																	// PAR #36094
				strPackTemp := "Pack Temp (deg F)";														// PAR #36094
			endif;																						// PAR #36094
		else
			//strCarriageTemp := strCarriageTemp &amp; "(deg C)";											// PAR #36094
			//strPackTemp := strPackTemp &amp; "(deg C)";													// PAR #36094
			strCarriageTemp := app.getEntTableRowTranslation(ETRow_CarriageTempC, ETGrp_CargoDetails);	// PAR #36094
			if strCarriageTemp = null then																// PAR #36094
				strCarriageTemp := "Carriage Temp (deg C)";												// PAR #36094
			endif;																						// PAR #36094
			strPackTemp := app.getEntTableRowTranslation(ETRow_PackTempC, ETGrp_CargoDetails);			// PAR #36094
			if strPackTemp = null then																	// PAR #36094
				strPackTemp := "Pack Temp (deg C)";														// PAR #36094
			endif;																						// PAR #36094
		endif;						
		self.getControlForEntDefRow(self.txtCarriageTemp.name, ctrl);
		if ctrl &lt;&gt; null then
			ctrl.CMUI_FieldTextBox.setMyCaption(strCarriageTemp);
		endif;
		self.getControlForEntDefRow(self.txtPackTemp.name, ctrl);
		if ctrl &lt;&gt; null then
			ctrl.CMUI_FieldTextBox.setMyCaption(strPackTemp);
		endif;
		

		
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doShowAdditionalDetails" id="1557718c-51dd-4e03-b4c0-012871d07db7">
        <updating/>
        <source>doShowAdditionalDetails() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 August 2009	cnwdap1	Initial creation
25 November2015	cnwma1  PAR #36943 Shipping Reference error during extract
20 may 2022	navgm20 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
16 August 2022	navak20	TFS ChangeRequest 54441: EUP - Additional Field - Country of Origin
23 Feb 2023 navtnr20	TFS CR 55648 Task 55663: UI - Contract Id
13 Apr 2023 navmk20		Bug 56980: MTN - Additional details form not displayed
17 November 2023 navmv20 Bug 61153: FR | 54089 EUP - Invoice Contracts - Invoice Contact ID field on cargo creation.
05/02/2023		navkc1 	Bug 62302: CUX | Can't mark onboard or child cargo as 'overlanded'
*/
vars
	detailsForm	: CMUI_AdditionalDetailsForm;

	custAgent	: CM_CustomsAgent;
	booking		: CM_BookingRef;
	bank        : CM_Bank; //17/11/2023 navmv20 Bug 61153
	voyage      : CM_Voyage; //17/11/2023 navmv20 Bug 61153
begin
	/* Start - 13/4/2023 navmk20 TFS 56980
	if self.cargoIDs.size &gt; 1 then
		//14 Nov 2013	NDL	Par 32955
		return;
	endif;
	End - 13/4/2023 navmk20 TFS 56980 */
	
	detailsForm := app.loadForm(	CMUI_AdditionalDetailsForm,
							self.myAssistant.class,
							false,
							false,
							true,
							self.myTerminal, null).CMUI_AdditionalDetailsForm;
							
	detailsForm.setColumnsAndControlWidth(2, 200);
	
	//+cnwml2 PAR26255
	if self.cmbCustomsAgent.getObject &lt;&gt; null then
		custAgent := self.cmbCustomsAgent.getObject.CM_CustomsAgent;
	else
		if self.txtBookingRef.getString &lt;&gt; null then
			booking := self.myTerminal.allBookingRefsByRef[self.txtBookingRef.getString];
			if booking &lt;&gt; null then
				//custAgent := app.myRoot.allCustomsAgents[booking.customsAgent];
				custAgent := booking.getCustomsAgentObject();	// PAR 26922 - change to use new method
			endif;
		endif;
	endif;
	detailsForm.myOperator := self.cmbOperatorCode.listObject.CM_Operator;//21.02.2023 navtnr20 TFS CR 55648 Task 55663
	 //17/11/2023 navmv20 Bug 61153 - start
	voyage := self.cmbVoyageCode.getCurrentItemObject().CM_Voyage;
	if self.cmbBusUnit.listCount() = 1 then
		bank := self.cmbBusUnit.getEmbeddedControl.ComboBox.itemObject[1].CM_Bank;
	endif;
	if bank = null and voyage &lt;&gt; null then
		bank := voyage.myDischargeCompany;
	endif;
	if bank = null then
		bank := cmbBusUnit.getObject.CM_Bank;
	endif;
	////17/11/2023 navmv20 Bug 61153- end
	
	detailsForm.setDetailsFromParentForm(	txtDescription.getString,
											lstAllStops.allSelectedObjects,
											lstToDoTasks.allSelectedObjects,
											cmbSpecialStow.getObject.CM_SpecialStow,
											lstSpecialLift.allSelectedObjects,
											cmbFreightFwdr.getObject.CM_ConsigneeConsignor,
											//cmbCustomsAgent.getObject.CM_CustomsAgent,
											custAgent,
											txtHouseBOL.getString,
											txtConsignVoy.getString,
											txtEquipXchg.getString,
											txtPurchaseOrder.getString,
											txtShippingRef.getString,   //25/11/2015 cnwma1 PAR #36943
											cmbTransportMode.getString,
											txtWagon.getString,
											txtWagonTrain.getString,	//04 Nov 2009	NDL Par 21519
											cmbWagonClass.getObject.CM_WagonClass,	//12 May 2014	NDL	Par 33615
											cmbSubTerminal.getObject.CM_SubTerminal,
											//cmbBusUnit.getObject.CM_Bank, //17/11/2023 navmv20 Bug 61153
											bank, //17/11/2023 navmv20 Bug 61153
											chkCurtainsIn.getBoolean,
											cmbCoolingType.getText,
											cmbVoltageType.getText,
											txtCargoID.getString,
											self.myProxyTrackedItem,
											cmbShippingLine.getObject.CM_ShippingLine,			//20 may 2022 navgm20  TFS 53204
											cmbCtryOfOrigin.getObject.CM_Country,			// 16.08.2022 navak20 TFS 54441	
											self.isPreNoteForm,
											cmbType.getObject.CM_CargoType,					// 17.4.2023 navmk20 TFS 56980
											cmbInvContractID.getObject.CM_InvoiceContract,//23.02.2023 navtnr20 TFS CR 55648 Task 55663
											chkOverlanded.getBoolean()	//05/02/2023	navkc1 Bug 62302
											);
	detailsForm.setIsFromFlexiGate(self.isFlexiGateForm);
	detailsForm.setIsEmptyContainer(self.isEmptyContainer);
	detailsForm.setParentForm(self);
	detailsForm.showModal;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doShowAttachmentsForm" id="07ff2e81-aff8-4b3a-8719-3bf8583521a7">
        <updating/>
        <source>doShowAttachmentsForm() updating, protected;
/*
Date		Who		Reason
30/07/2009	cnwdap1	Initial creation
30/06/2014	cnwdap1	PAR #34483 CCMS DPH 2384 Allow attachments from on ship cargo creation form
28/03/2023	navkc1	CR#57036 Task 57221: Jade - Move New Cargo to Trailer Not Pack
19/12/2024	jlizm1	MTN 33241 Cannot edit attachments when creating cargo from voyage ops live
*/
vars
	obj			: Object;
	prenote		: CMIF_PreNote;
	receival	: CMGTE_Receival;
	ti			: CM_TrackedItem;
	
begin
	obj := self.cmbAttachments.listObject;
	
	if obj &lt;&gt; null then
		if obj.isKindOf(CMIF_PreNote) then
			prenote := obj.CMIF_PreNote;
		elseif obj.isKindOf(CMGTE_Receival) then	
			receival := obj.CMGTE_Receival;
		elseif obj.isKindOf(CM_TrackedItem) then
			ti := obj.CM_TrackedItem;
		endif;
	endif;
	
	if self.isPreNoteForm then
		self.myAssistant.showCargoReceiptFromPreNote(self, true, self.numberOfColumns - 1, self.defaultControlWidth, ti, prenote, true, self.transportMode);
	elseif self.isFlexiGateForm then
		self.doSaveFlexiGateForm(false);
		self.myAssistant.showCargoReceiptFromFlexiGate(self, true, self.flexiCargoType, self.numberOfColumns - 1, self.defaultControlWidth, null, false, receival, null, null, ti, null, null, self.myCurrentVehicleVisit, null);
	elseif self.isOnshipForm then	
		// PAR #34483 // epr par 34945 21/10/14
		self.myAssistant.showCargoAddFromOnship(self, true, self.numberOfColumns - 1, self.defaultControlWidth, self.cmbBOLItem.getObject().CM_BOLDtl, null, ti, prenote, self.myVoyage, true, null);	 // TFS 2318 CNWAB1
	elseif self.isOnsiteForm then
		//28/03/2023	navkc1	#57221
		self.myAssistant.showCargoAddFromOnsite(self, true, self.numberOfColumns - 1, self.defaultControlWidth, null, null, ti, prenote, self.myVoyage, true, null);
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doShowHSCodeSearcherForm" id="a6a2cdf6-f122-4dd8-93b8-f01e691691d3">
        <source>doShowHSCodeSearcherForm();
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 20 December 2022
TFS#		: 55584
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	hsCode : CM_HarmonizedSystem;
begin

	hsCode := self.myAssistant.showHSCodeSearchForm(self, true);

	if hsCode &lt;&gt; null then		
		if self.cmbHSCode.getEmbeddedControl.ComboBox.findObject(hsCode) &lt; 0 then
			self.cmbHSCode.addItemObject(hsCode.getDisplayString(), hsCode);
		endif;
		self.cmbHSCode.setForObject(hsCode);		
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doShowHazardsForm" id="783dc759-8748-4307-8b21-02b87781f187">
        <updating/>
        <source>doShowHazardsForm() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 09/06/2015	cnwdap1		Initial creation PAR #36421 Hazardous Materials Handling
//
vars
	booking : CM_BookingRef;

begin
	if self.isFlexiGateForm then
		self.doSaveFlexiGateForm(false);
