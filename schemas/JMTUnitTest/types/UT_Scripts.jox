    <JadeMethod name="uEdiControllerTest" id="03c083cc-d4fd-48c4-aa82-8a2efc902409">
        <source>uEdiControllerTest();
/*

Purpose:			

Parameters:			Bring up two Unit Test runner sessions.
					Run UT_Scripts::uEdiControllerTestLock in the first session, once it tells you to run this script.
					do so in the second session, and when it completes, click OK in tehfirst session to release the locks.
					If the details tab output of the second session includes "Retry previously locked ediData Cargo Group"
					then it worked.

Return Value:		

Date		Who		Reason
06 March 2019	jlgndl1	Initial creation	TFS 41914

*/

vars

	ediCont : CM_EDIControllerAgent;
	term : CM_Terminal;
	intArray : IntegerArray;
	oldLevel : Integer;

begin

	oldLevel := app.logLevel;
	app.changeLogLevel(LogDEBUG);

	term := self.getTerminal();

	create ediCont transient;
	create intArray transient;
	intArray.add( EDIDataType_CargoGroupNotified );
	
	ediCont.setTerminal( term );	
	ediCont.actionForAutoTerminal( true, false, false, intArray ) ;

epilog

	app.changeLogLevel(oldLevel);

	delete ediCont;
	delete intArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="uEdiControllerTestLock" id="8a8eb8a0-49f7-4236-9728-5b403ff7c4ea">
        <source>uEdiControllerTestLock();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 March 2019	jlgndl1	Initial creation	TFS 41914

*/

vars

	ediDataCustomStop : CM_EDIDataCargoGroupNotified;
	ediDataSet : CM_EDIDataSet;
	ediData : CM_EDIData;

begin

	create ediDataSet transient;

	foreach ediDataCustomStop in CM_EDIDataCargoGroupNotified.instances discreteLock do
		if ediDataCustomStop.ediDataType = EDIDataType_CargoGroupNotified then
			ediDataSet.add( ediDataCustomStop );
		endif;
	endforeach;
	
	foreach ediData in ediDataSet do
		ediData.lock( ediData, Share_Lock, Session_Duration, 0 );
	endforeach;
	
	app.msgBox("All 'EDIDataType_OneStopCust' EDI data locked in UT, run 'UT_Scripts::uEdiControllerTest' from another unit test session","Locked",MsgBox_OK_Only);

epilog

	foreach ediData in ediDataSet do
		ediData.unlock(ediData);
	endforeach;

	delete ediDataSet;

end;</source>
    </JadeMethod>
