    <JadeMethod name="doSave" id="01bc7f97-7947-46d7-b90b-0c313e63839b">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 July 2011	cnwer1	Initial creation CCMS MES 1116
02 OCt  2018    cnwma1  ChangeRequest 41234: SAP Integration - Mapping fields
26 Apr 2023 	navhl20	ChangeRequest 57712:[54552] EUP - Delivery Dispatch – Adding Work Point Types
*/

vars
	theForm 				: SOP_TableMaintForm;	
	pxyWorkPoint		: CM_WorkPoint;
	code,
	description,
	externalRef			: String;
	jobSeed,
	colour,
	targetRatePHWeight 	: Integer;
	targetRatePHLM		: Integer;
	workPointType		: CM_WorkPointType;
	tbl				    : CM_EntryTable;
begin
	theForm := self.myForm; 
	tbl	    := theForm.tblInput1;
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_WorkPoint transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	pxyWorkPoint 		:= theForm.myProxyObject.CM_WorkPoint;
	code				:= tbl.getValueByName(ETRow_Code).String;
	description 		:= tbl.getValueByName(ETRow_Description).String;
	jobSeed				:= tbl.getValueByName(ETRow_JobSeed).Integer;
	colour 				:= tbl.getValueByName(ETRow_Colour).Integer;
	targetRatePHWeight	:= tbl.getValueByName(ETRow_TargetRatePHWeight).Integer;
	targetRatePHLM		:= tbl.getValueByName(ETRow_TargetRatePHLM).Integer;
	externalRef   		:= tbl.getValueByName(ETRow_ExternalRef).String;     //02.10.2018 cnwma1 TFS #41234
	workPointType 		:= theForm.cmbWPTData.listObject.CM_WorkPointType;																			//26.4.2023 navhl20 #57712[54552]
	
	//pxyWorkPoint.setProxy(code,description,colour,jobSeed,targetRatePHLM,targetRatePHWeight,theForm.myTerminal,externalRef);						//26.4.2023 navhl20 #57712[54552]
	pxyWorkPoint.setProxy(code,description,colour,jobSeed,targetRatePHLM,targetRatePHWeight,theForm.myTerminal,workPointType,externalRef);			//26.4.2023 navhl20 #57712[54552]
	
	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateWorkPoint(pxyWorkPoint, theForm.myCurrentObject, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateWorkPoint(pxyWorkPoint, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK();
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doShowRateDefinitionForm" id="4acda09a-c2eb-4c7c-a5ff-cd605612fbf2">
        <source>doShowRateDefinitionForm( _workPoint : CM_WorkPoint );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 March 2018	jlgndl1	Initial creation	TFS 37437

*/

vars

	form : SOP_WorkPointRatesMaint;
	str : String;

begin
	
	create form;
	form.setMyTerminal(self.myForm.myTerminal);
	form.setMyWorkPoint( _workPoint );
	
	form.showModal();
	
	//refresh the lines in case we changed the number of rates...
	str := self.myForm.tblDataDisplayRow(self.myForm.tblData, _workPoint);
	self.myForm.tblData.setCellText( self.myForm.tblData.row, 1, str );
	str := _workPoint.getDisplayStringForAttribute(ETRow_NumWorkPointRates, false); 
	self.myForm.tblInput1.setValueByName(ETRow_NumWorkPointRates,str);	

epilog

end;</source>
        <Parameter name="_workPoint" type="CM_WorkPoint"/>
    </JadeMethod>
