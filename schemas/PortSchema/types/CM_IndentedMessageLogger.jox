<Class name="CM_IndentedMessageLogger" id="f46151da-e712-4d15-b09b-8163ac5c194a">
    <superclass name="CM_MessageLogger"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <PrimAttribute name="indent" id="37d50bb7-2029-4150-a106-158611d480f9">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="indentLevel" id="3eaa9f5a-e484-455d-9599-9204122e007c">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="addLog" id="5f29c9da-bc85-455a-8ba2-bc675cb54ad9">
        <source>addLog(_message: String;_msgSeverity : Integer; _errorCode : Integer);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 September 2009	cnwer1	Initial creation

*/

vars
	theMessage : String;
	indentString : String;
	i : Integer;
begin	

	while i &lt; self.indentLevel do
		indentString:=indentString &amp; self.indent;
		i:=i+1;
	endwhile;

	theMessage:= indentString &amp; _message;
	self.allMessages.add(theMessage);
	
	//13 Sep 2012	NDL	Par 30633
	if _errorCode &gt; 0 then
		if not self.allErrorCodesUsed.includes( _errorCode ) then
			self.allErrorCodesUsed.add( _errorCode );
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_message" type="String"/>
        <Parameter name="_msgSeverity" type="Integer"/>
        <Parameter name="_errorCode" type="Integer"/>
    </JadeMethod>
</Class>
