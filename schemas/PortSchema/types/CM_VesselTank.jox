    <JadeMethod name="getDefinitionXML" id="ab42e473-8061-4e37-9639-273e7cd0464f">
        <source>getDefinitionXML() : String;
/*
Purpose:			
Date				Who			Reason
MAY 2011		CNWAB1		Initial creation
*/

vars

	hml : String;
begin
	hml := "&lt;TANK&gt;" ;
	hml := hml &amp; "&lt;TCODE&gt;" &amp; self.code &amp; "&lt;/TCODE&gt;";
	hml := hml &amp; "&lt;TDESC&gt;" &amp; self.description &amp; "&lt;/TDESC&gt;";
	hml := hml &amp; "&lt;TVOL&gt;" &amp; self.volume.String &amp; "&lt;/TVOL&gt;";
	hml := hml &amp; "&lt;TREMARKS&gt;" &amp; self.remarks &amp; "&lt;/TREMARKS&gt;";
	
	if self.myVesselTankType &lt;&gt; null then
		hml := hml &amp; "&lt;TTYPE&gt;" &amp; self.myVesselTankType.code &amp; "&lt;/TTYPE&gt;";
	endif;
	hml := hml &amp; "&lt;/TANK&gt;";

	return hml;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="4100b528-cd19-4655-a2e2-47742e450ab5">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin

	if _attrName = ETRow_Code then
		return self.code.asStringJMT;
	elseif _attrName = ETRow_Description then
		return self.description.asStringJMT;
	elseif _attrName = ETRow_Remarks then
		return self.remarks.asStringJMT;
	elseif _attrName = ETRow_Volume then
		return self.volume.asStringJMT;
	elseif _attrName = ETRow_ContentsType then
		if self.myVesselTankType &lt;&gt; null then
			return self.myVesselTankType.code.asStringJMT;
		endif;
		return null;
	else
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
