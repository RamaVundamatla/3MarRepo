    <JadeMethod name="handleException" id="15f281f3-be90-40ad-ab6f-9f5f0d9d58eb">
        <updating/>
        <source>handleException(pException: Exception): Integer updating;
/*
Date		Who		Reason
03 Feb 2011	cnwrs1	PAR #25828 - using up too many licences
*/
vars
	ts: TimeStamp;
	lMessage: String;
	notifierTA: JSSCTNotificationObjectTA;
	dumpCallStack: Boolean;
	processOidString: String;
	notificationObject : JSSCTNotificationObject;	//par 25828 cnwrs1 3 Feb 20111
begin
//	on Exception do null;
	self.dumpCallStack(self.class.getName());
	self.monitor(self.class.name&amp;'::'&amp;method.name&amp;' ', MONITOR_DEBUG);
	//	check for an error 4 - Object not found, when the system is shut down and the sharedTransient object disappears
	if pException.errorCode = 4 then
		if self.myNotificationObject &lt;&gt; null and	//par 25828 cnwrs1 3 Feb 2011
		   self.myNotificationObject.mySharedTransientInstance &lt;&gt; null and 
		   global.isValidObject(self.myNotificationObject.mySharedTransientInstance) then
		else
			self.currentErrorCode := pException.errorCode;
			return(Ex_Abort_Action);
		endif;
	endif;
	processOidString := process.getOidString;
	if pException.reportingMethodDesc &lt;&gt; null then
		lMessage := app.name &amp; "." &amp; self.class.getName() &amp; "::handleException " &amp; pException.errorCode.String &amp; " - " &amp;
																				   pException.text &amp; " reported by " &amp;
																				   pException.reportingMethodDesc.method.name &amp; ' at position ' &amp;
																				   pException.reportingMethodDesc.position.String;
		notificationObject := JSSCTNotificationObject.firstInstance;	//par 25828 cnsrs1 3 Feb 2011
		if notificationObject &lt;&gt; null then 
			JSSCTNotificationObject.firstInstance.causeEvent(JSSCT_Monitor_Note, true,
																ts.date.format("ddMMMyy ") &amp;
																ts.Time.String &amp; "." &amp; (ts.Time.milliSecond + 1000).String[2:3] &amp; " " &amp;
	//															process.number.String &amp; " | " &amp; 
																processOidString[processOidString.pos(".",1)+1:end] &amp; " | " &amp;
																lMessage);
		endif;
		self.logMessage(lMessage);
	endif;
	if pException.currentMethodDesc = null then
		lMessage := app.name &amp; "." &amp; self.class.getName() &amp; "::handleException " &amp; pException.errorCode.String &amp; " - " &amp; pException.text &amp; " occurred.";
	else
		lMessage := app.name &amp; "." &amp; self.class.getName() &amp; "::handleException " &amp; pException.errorCode.String &amp; " - " &amp;
																				   pException.text &amp; " occurred in " &amp;
																				   pException.currentMethodDesc.method.name &amp; ' at position ' &amp;
																				   pException.currentMethodDesc.position.String;
	endif;
	self.logMessage(lMessage);
	dumpCallStack := app.getProfileStringAppServer(app.getIniFileNameAppServer(), "JSSChangeTracker", "DumpCallStack", 'false').toLower = 'true';
	if pException.errorCode = 1266 or dumpCallStack then
		self.dumpCallStack(self.class.getName());
	endif;
	if self.myNotificationObject = null then	//par 25828 cnwrs1 3 Feb 2011
		return(Ex_Abort_Action);	//Ex_Pass_Back);
	endif;
	JSSCTNotificationObject.firstInstance.causeEvent(JSSCT_Nibbler_Note, true, self.myNotificationObject.buildNibbler_RaiseAlert("Unhandled Exception " &amp; pException.errorCode.String, lMessage));

	JSSCTNotificationObject.firstInstance.causeEvent(JSSCT_Monitor_Note, true,
														ts.date.format("ddMMMyy ") &amp;
														ts.Time.String &amp; "." &amp; (ts.Time.milliSecond + 1000).String[2:3] &amp; " " &amp;
//														process.number.String &amp; " | " &amp;
														processOidString[processOidString.pos(".",1)+1:end] &amp; " | " &amp;
														lMessage);
	if self.isStartedApplication then
		//	decrement the usage count
		create notifierTA transient;
		notifierTA.myNotificationObject := self.myNotificationObject.mySharedTransientInstance;
		notifierTA.usageCount := -1;
		notifierTA.sharedTransient := true;
		notifierTA.updateEntitySharedTransient();
		delete notifierTA;
		//	send message to monitor that we are terminating
		self.monitor("Change Tracking Checker - Decremented Usage counter...", MONITOR_ALWAYS);
		//	begin the timer to check for an interupt
		self.beginTimer(10000, Timer_Continuous, TIMER_INTERRUPT);
	endif;
	return(Ex_Abort_Action);	//Ex_Pass_Back);
end;</source>
        <Parameter name="pException" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleLockException" id="209aa020-b1db-4cf7-b3be-973831d017a0">
        <updating/>
        <source>handleLockException(pLockException: LockException): Integer updating;
// Go into a loop trying for the object, and keep trying until you get the lock.
vars
	retryCnt: Integer;
begin
	self.monitor(self.class.name&amp;'::'&amp;method.name&amp;' ', MONITOR_DEBUG);
	while not tryLock(pLockException.lockTarget, pLockException.lockType, pLockException.lockDuration,
							pLockException.lockTimeout) do

		retryCnt := retryCnt + 1;

		// just keep chugging away
		if retryCnt &gt;  500 then
			process.sleep(5000);
			retryCnt := 0;
		endif;
	endwhile;

	return Ex_Continue;
end;</source>
        <Parameter name="pLockException" type="LockException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="inheritsFromWindow" id="78da922b-9ba0-482d-b9c8-e74d0ccbb114">
        <source>inheritsFromWindow(pClass: Class): Boolean;
/*
		Method to see if the class is a subclass of Window, Form or Control
*/
vars
	class: Class;
	className: String;
begin
	self.monitor(self.class.name&amp;'::'&amp;method.name&amp;' ', MONITOR_DEBUG);
	class := pClass;

	while class &lt;&gt; Object do
		className := class.name;
		if className = 'Form' or className = 'Control' or className = 'Window' then
			return (true);
		endif;
		class := class.getSuperclass();
	endwhile;

	return (false);
end;</source>
        <Parameter name="pClass" type="Class"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initialize" id="969e5437-9375-4616-9192-45a1629fef6b">
        <updating/>
        <source>initialize(pMyPublicInterface: JSSCTChangeTrackingInterface; pMyPersistentInstance: JSSCTNibblerManager) updating;
/*
*/
vars
	notifier: JSSCTNotificationObject;
	notifierTA: JSSCTNotificationObjectTA;
begin
	on Exception do handleException(exception);
	on LockException do handleLockException(exception); // JETkgd 20/1/2004

	self.debug := app.getProfileStringAppServer(app.getIniFileNameAppServer(), "JSSChangeTracker", "Debug", "false").Boolean;
	self.myPublicInterface := pMyPublicInterface;
	self.myPersistentInstance := pMyPersistentInstance;
	self.beginNotification(self.myPersistentInstance, Object_Update_Event, Response_Continuous, 47);
	if self.myPublicInterface.myJadeLog &lt;&gt; null then
		self.myJadeLog := self.myPublicInterface.myJadeLog;
	endif;

	//	register for notifications of the audit log swapping
	create self.myDBAdminObject transient;
	self.beginNotification(system, JadeDatabaseAdmin.LogTransferEvent, Response_Continuous, LOG_TRANSFER_TAG);

	//	get the persistent notification object for notifying, or create if not there yet
	//		create a transient copy to do the notification building,
	//			attach a pointer to the persistent instance,
	//				create a shared transient instance for communicating with the changer application, and point to it
	notifier := JSSCTNotificationObject.firstInstance;
	if notifier = null then
		beginTransaction;
		create notifier;
		commitTransaction;
	endif;
	self.myNotificationObject := notifier.cloneSelf(true);
	self.myNotificationObject.setMyPersistentInstance(notifier);
	create notifierTA transient;
	notifierTA.applicationSchema := currentSchema;
	notifierTA.usageCount := 1;
	notifierTA.myPersistentInstance := notifier;
	notifierTA.sharedTransient := true;
	notifierTA.createEntitySharedTransient();
	self.myNotificationObject.setMySharedTransientInstance(notifierTA.myNotificationObject);

	//	set the user and admin info on the process object for the Jade Monitor
	notifierTA.trxUpdateProcessDisplay("JSS Change Tracker V[" &amp; JSSCT_VERSION &amp; "]", "");

	delete notifierTA;

	create self.myTA transient;
	self.myTA.myNibblerManager := self.myPersistentInstance;
	//	start the notifications on the persistent &amp; shared transient notification objects required for communicating
	self.beginNotification(self.myNotificationObject.myPersistentInstance, JSSCT_Nibbler_Note, Response_Continuous, 1);
	self.beginNotification(self.myNotificationObject.mySharedTransientInstance, JSSCT_Nibbler_Note, Response_Continuous, 2);

	self.myTitle := Nibbler_Title;
	//	send message to monitor that we have started
	self.monitor(Nibbler_Title &amp; " Started.", MONITOR_ONLY);

	//	save a pointer to the ChangeTracking root,
	self.myChangeTrackingRoot := JSSCTChangeTrackingRoot.firstInstance;

	self.state := "Initializing";
	//	send a Notification that I have started
	self.myNotificationObject.myPersistentInstance.causeEvent(JSSCT_Nibbler_Note, true, self.myNotificationObject.buildNibbler_Started(self));

	self.setState("Checking in .ini file for classes to initialize");
	//	check for classes in the ini file that we have to initialize
//	self.checkForIniFileClasses();

	self.setState("Checking for missed journals");
	//	start checking for any audit logs swapped that we missed
	self.checkForMissedAuditLogs();

	self.setState("Sleeping at " &amp; app.actualTimeServer.String);

	//	begin the timer to go off every 30 seconds
	self.beginTimer(300 * 1000, Timer_Continuous, TIMER_SLEEPING);
	//	begin the timer to go off every 30 mins
	self.beginTimer(30 * 60 * 1000, Timer_Continuous, TIMER_NEXT_DAY);
end;</source>
        <Parameter name="pMyPublicInterface" type="JSSCTChangeTrackingInterface"/>
        <Parameter name="pMyPersistentInstance" type="JSSCTNibblerManager"/>
    </JadeMethod>
    <JadeMethod name="initializeClassChangeTracking" id="88d478b3-e80b-4529-bc0c-9a1e53ded543">
        <updating/>
        <source>initializeClassChangeTracking(pClass: Class) updating;
/*
Date		Who		Reason
03 Feb 2011	cnwrs1	PAR #25828 - using up too many licences
24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
//11 Nov 2013	cnwrs1	Par #31540 - use current time rather than trx transation time from journal
*/
constants
	TELL_NUMBER: Integer = 999;
vars
	changedObjectChecker: JSSCTChangedObjectChecker;
	className: String;
	changeClass: JSSCTChangeTrackingClass;
	startObject: Object;
	startObjectID: String;
	startObjectInstance: Integer;
	startingDate: Date;
	findStartingObject: Boolean;
	iter: Iterator;
	changeObject: Object;
	changeObjectID: String;

	processObject: Boolean;
	lTimeStamp: TimeStamp;
	lAction: String;
	saveState: String;
	count: Integer;
	countAndTell: Integer;

	iniFile: String;
	initialDays: Integer;
begin
	self.monitor(self.class.name&amp;'::'&amp;method.name&amp;' ', MONITOR_DEBUG);
	self.monitor(self.myTitle &amp; " - Initializing Class " &amp; pClass.name &amp; "...", MONITOR_ALWAYS);
	saveState := self.state;

	create changedObjectChecker transient;
	changedObjectChecker.initialize(self.myNotificationObject.mySharedTransientInstance.applicationSchema);

	self.tryShareLockingObject(self.myChangeTrackingRoot);
	self.tryShareLockingObject(self.myChangeTrackingRoot.allChangeClasses);
	changeClass := self.myChangeTrackingRoot.allChangeClasses[pClass.name,false];
	self.unlock(self.myChangeTrackingRoot.allChangeClasses);
	self.unlock(self.myChangeTrackingRoot);
	if changeClass = null then
		self.monitor("Change Tracking collection for Class " &amp; pClass.name &amp; " not found in ClassInitializer.", MONITOR_ONLY);
		return;
	endif;
	//	establish starting date for when instances are to be kept
//	startingDate := app.actualTimeServer().date - self.myChangeTrackingRoot.daysToKeepTrackingChanges;	//par25828 cnwrs1 3 Feb 2011

	//	check for ini file parameter to override the period that we will go back to, to start looking from
	iniFile := app.getIniFileNameAppServer();
	initialDays := app.getProfileStringAppServer(iniFile, "JSSChangeTracker", "InitializationDays", '-1').Integer;

	if initialDays &gt; 0 then
		//	recalculate the starting date based on the ini file number
		startingDate := app.actualTimeServer().date - initialDays;
	elseif initialDays = 0 then
		//	pretend that we have finished initializing the class
		self.myChangeTrackingClassTA.initializing := false;
		self.myChangeTrackingClassTA.myChangeTrackingClass := changeClass;
		self.myChangeTrackingClassTA.updateEntity();

		self.monitor(self.myTitle &amp; " - Class " &amp; pClass.name &amp; " Initialized for 0 days.", MONITOR_ALWAYS);
		return;
	endif;
	self.setState(saveState &amp; " - find starting instance...");
	//	establish a starting object in the instances collection
	startObject := self.findStartingObject(pClass, startingDate);
	if startObject = null then
		if self.interruptProcessing then
			return;
		endif;
		findStartingObject := false;
	else
		startObjectID := startObject.getOidString();
		startObjectInstance := startObjectID[startObjectID.pos(".",1)+1:end].Integer;
		findStartingObject := true;
	endif;
	className := pClass.name;
	self.myChangeObjectTA.myChangeClass := changeClass;
	self.myChangeObjectTA.myChangeClass := null;

	//	step quickly through the instances for this class until we get to the starting object,
	//		then begin processing the instances of the class
	self.setState(saveState &amp; " - initialize instances...");
	iter := pClass.instances.createIterator();
	self.setState(saveState &amp; " - read instances...");
	while iter.next(changeObject) &lt;&gt; null do

		process.sleep(0);
		app.doWindowEvents(0);
		//	check if we have been asked to stop
		if self.interruptProcessing then
			break;
		endif;
		if findStartingObject then
			changeObjectID := self.getOidStringForObject(changeObject);
			if changeObjectID[changeObjectID.pos(".",1)+1:end].Integer &lt; startObjectInstance then
				process.sleep(0);
				continue;
			endif;
			findStartingObject := false;
			self.lastAuditFileTimeStamp := app.actualTimeServer;
		endif;
		//	we have an instance that we need to process to see if it is one that we want

		//	first, check if we already have this object being tracked
		changeObjectID := changeObject.getOidString();

		if changeClass.allChangesByOid[changeObjectID] &lt;&gt; null then
			continue;
		endif;
		//	then check if it is within the date and time range
		processObject := false;
		lTimeStamp := changedObjectChecker.checkObjectUpdated(changeObject).TimeStamp;
		if lTimeStamp.date = null then
			lTimeStamp := changeObject.creationTime;
			if lTimeStamp.date &gt;= startingDate then
				processObject := true;
				self.myChangeObjectTA.changeAction := JSSCTChangeTrackingObject.ACTION_CREATE;
			endif;
		elseif lTimeStamp.date &gt;= startingDate then
			processObject := true;
			self.myChangeObjectTA.changeAction := JSSCTChangeTrackingObject.ACTION_UPDATE;
		endif;
		//	add the object if it qualifies
		if processObject then
			self.myChangeObjectTA.changeTimestamp := lTimeStamp;
			self.myChangeObjectTA.changeObject := changeObject;
			self.myChangeObjectTA.changeObjectID := changeObjectID;
			self.myChangeObjectTA.className := className;
			self.myChangeObjectTA.changeSequence := 0;
			self.myChangeObjectTA.changeTransactionID := 0;
			self.myChangeObjectTA.trxTimestamp := lTimeStamp;
	
			if changeClass.allChangesByOid[changeObjectID] &lt;&gt; null then
				continue;
			endif;
			self.myChangeObjectTA.createEntity();

			self.lastAuditFileTimeStamp := app.actualTimeServer;

			count := count + 1;
			countAndTell := countAndTell + 1;

			if countAndTell &gt; TELL_NUMBER then
				self.setState(saveState &amp; " - read instances...(" &amp; count.String &amp; ")");
				countAndTell := 0;
			endif;
		endif;
	endwhile;
	self.setState(saveState &amp; " - read instances. (" &amp; count.String &amp; ")");

	//	check if we were asked to stop
	if self.interruptProcessing then
		self.monitor(self.myTitle &amp; " - Class " &amp; pClass.name &amp; " initialization interrupted.", MONITOR_ALWAYS);
	else
		self.myChangeTrackingClassTA.initializing := false;
		self.myChangeTrackingClassTA.myChangeTrackingClass := changeClass;
		self.myChangeTrackingClassTA.updateEntity();

		self.monitor(self.myTitle &amp; " - Class " &amp; pClass.name &amp; " Initialized. (" &amp; count.String &amp; ")", MONITOR_ALWAYS);
	endif;
epilog
	delete iter;
	delete changedObjectChecker;
end;</source>
        <Parameter name="pClass" type="Class"/>
    </JadeMethod>
    <JadeMethod name="logMessage" id="174b3fe2-0333-43ce-9d69-43899ec1a4af">
        <source>logMessage(pMessage: String);
/*
*/
begin
	if self.myJadeLog = null then
		if app = null then
			write(pMessage);
		else
			app.writeLog(pMessage,true);
		endif;
	else
		self.myJadeLog.logServer(pMessage);
	endif;
end;</source>
        <Parameter name="pMessage" type="String"/>
    </JadeMethod>
    <JadeMethod name="monitor" id="72ac26de-e3bb-4930-bd5a-c6ef27c23654">
        <source>monitor(pMessage: String; level: Integer);
/*
Date		Who		Reason
03 Feb 2011	cnwrs1	PAR #25828 - using up too many licences
//22 Aug 2014	cnwrs1	Par 34821 - Improve monitor activity
*/
vars
	ts: TimeStamp;
	notifier: JSSCTNotificationObject;
	processOidString: String;
begin 
//write pMessage&amp;' '&amp;level.String&amp;' '&amp;self.debug.String;
	if level = MONITOR_DEBUG and 
	   not self.debug then	//par 25828 cnwrs1 3 Feb 2011
		return;
	endif;
	if level &lt;&gt; MONITOR_DEBUG then
		if self.myNotificationObject &lt;&gt; null then
			notifier := self.myNotificationObject.myPersistentInstance;
		endif;
		if notifier = null then
			notifier := JSSCTNotificationObject.firstInstance;
		endif;
		if notifier = null then
			return;
		endif;
		processOidString := process.getOidString;
		notifier.causeEvent(JSSCT_Monitor_Note, true,
							ts.date.format("ddMMMyy ") &amp;
							ts.Time.String &amp; "." &amp; (ts.Time.milliSecond + 1000).String[2:3] &amp; " " &amp;
	//						process.number.String &amp; " | " &amp;
							processOidString[processOidString.pos(".",1)+1:end] &amp; " | " &amp;
							pMessage[1:2000]);
	endif;
	self.logMessage(pMessage);
end;</source>
        <Parameter name="pMessage" type="String"/>
        <Parameter name="level" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="processAuditCollection" id="a201d3ff-0f70-4d09-9bcc-9966a22dd176">
        <updating/>
        <source>processAuditCollection(_lOid  : String io; 
                       _lType : Integer io;
                       _class : Class io) : Boolean updating, protected;

/*

Purpose:			Separate Collection code

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2009	conkc1	Initial creation
21 May 2009	cnwkpd1	Rework to use JADE recommended mechanism (see JADE PAR #51153 for details)

*/

vars
//	posFrom          : Integer;
//	posTo            : Integer;
//	collectionNumber : Integer;
//	classNumber      : Integer;
//	instanceNumber   : Integer;
	collectionClass  : JSSCTCollectionClassEntry;
	readNext         : Boolean;

	collClass			: Class;
	collObject			: Object;
	ownerObject			: Object;
	
begin
	collObject := _lOid.asOid();
	if collObject = null then
		self.monitor("Collection Header Oid " &amp; _lOid &amp; " invalid format.", MONITOR_ONLY);
		readNext := true;
		return readNext;
	endif;

	collClass := self.getClassForObject(collObject);
	if collClass = null then
		monitor("***** Could not find Collection Class for Object Id " &amp; _lOid, MONITOR_ONLY);
		readNext := true;
		return readNext;
	endif;

	// Check if we are tracking this collection
	collectionClass := self.allCollectionClassEntries[collClass.name];
	if collectionClass = null then
		readNext := true;
		return readNext;
	endif;
	
	// Get owner object for this collection
	ownerObject := self.getOwnerForObject(collObject);
	if ownerObject = null then
		monitor("***** Could not find Owner Object for Object Id " &amp; _lOid, MONITOR_ONLY);
		readNext := true;
		return readNext;
	endif;

	// Get and check class for owner object
	_class := self.getClassForObject(ownerObject);
	if _class = null then
		monitor("***** Could not find Class for Owner Object (" &amp; self.getOidStringForObject(ownerObject) &amp; ") for Object Id " &amp; _lOid, MONITOR_ONLY);
		readNext := true;
		return readNext;
	endif;

	//	check if we are tracking the collection for this class
	if collectionClass.allClassesCollectionIn[_class.name] = null then
		readNext := true;
		return readNext;
	endif;

	//	we ARE tracking this collection for this class, so now fudge the lOid parameter to look like it is an update to the parent object
	_lOid := self.getOidStringForObject(ownerObject);
	_lType := JadeAuditAccess.Jaa_Type_Update;
	
	return false;

/*	KPD 21/05/2009 - old code replaced	
	
	//	get the collection and parent class numbers and instance number
	posFrom := 1;
	posTo   := _lOid.pos('.', posFrom);
	if posTo &lt;= posFrom then
		self.monitor("Collection Header Oid " &amp; _lOid &amp; " invalid format 1.", MONITOR_ONLY);
		readNext := true;
		return readNext;
	endif;

	collectionNumber := _lOid[posFrom : posTo - 1].Integer;
	_class := self.myNotificationObject.mySharedTransientInstance.applicationSchema.getClassByNumber(collectionNumber);
	if _class = null then
		monitor("***** Could not find Collection Class (" &amp; collectionNumber.String &amp; ") for Object Id " &amp; _lOid, MONITOR_ONLY);
		readNext := true;
		return readNext;
	endif;
	//	check if we are tracking this collection
	collectionClass := self.allCollectionClassEntries[_class.name];
	if collectionClass = null then
		readNext := true;
		return readNext;
	endif;

	posFrom := posTo + 1;
	posTo   := _lOid.pos('.', posFrom);
	if posTo &lt;= posFrom then
		self.monitor("Collection Header Oid " &amp; _lOid &amp; " invalid format 2.", MONITOR_ONLY);
		readNext := true;
		return readNext;
	endif;
	instanceNumber := _lOid[posFrom : posTo - 1].Integer;

	posFrom := posTo + 1;
	posTo   := _lOid.pos('.', posFrom);
	if posTo &lt;= posFrom then
		self.monitor("Collection Header Oid " &amp; _lOid &amp; " invalid format 3.", MONITOR_ONLY);
		readNext := true;
		return readNext;
	endif;

	classNumber := _lOid[posFrom : posTo - 1].Integer;
	_class       := self.myNotificationObject.mySharedTransientInstance.applicationSchema.getClassByNumber(classNumber);
	if _class = null then
		monitor("***** Could not find Class (" &amp; classNumber.String &amp; ") for Collection Class (" &amp; collectionNumber.String &amp; ") for Object Id " &amp; _lOid, MONITOR_ONLY);
		readNext := true;
		return readNext;
	endif;
*/
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_lOid" type="String" usage="io"/>
        <Parameter name="_lType" type="Integer" usage="io"/>
        <Parameter name="_class" type="Class" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processAuditLog" id="428368a5-0805-4a4b-bcde-3f1ca9415995">
        <updating/>
        <source>processAuditLog(pAuditLogNumber: Integer) updating;

/*

Date		Who		Reason
5/2/03		JMH		Don't get ini file ignores, done earlier now
15 Apr 2005	KC      Changed the create of auditLogInterface to getting the JSSCTAuditLogInterface.firstProcessTransientInstance
					Removed delete of auditLogInterface object from the epilog
21 Apr 2009	cnwkpd1	Change asObject to asOid for data from the journal - see JADE PAR #51153 for more info
03 Feb 2011	cnwrs1	PAR #25828 - using up too many licences
09 Jul 2013	cnwrs1	Par #31540 - use current time rather than trx transation time from journal
24 Sep 2013	cnwrs1	CCMS2238 C3 Change Tracker
11 Nov 2013	cnwrs1	Par #31540 - use current time rather than trx transation time from journal
27 Nov 2013	cnwrs1	Par 33085 skip journals with error 3097
14 Oct 2014	cnwkpd1	PAR #35072 - Prevent 1429 exceptions when using server execution option
//27 Jul 2016	cnwrs1	Par 38030 C3 Data Extract loosing updates
*/

vars
	result       : Integer;
	readNext     : Boolean;
//	startingDate : Date;		//par 25828 cnwrs1 3 feb 2011
	trxTimeStamp : TimeStamp;	//09 Jul 2013	cnwrs1	Par #31540 - use current time rather than trx transation time from journal
	lTimeStamp   : TimeStamp;
	lastTimeStamp: TimeStamp;
	lOid         : String;
	lSequence    : Decimal [20];
	lType        : Integer;
	lTranId      : Decimal [20];
	lAction      : Integer;

	obj			 : Object;
	classNumber  : Integer;
	class        : Class;
	schemaName   : String;

	serverExecuteLog : Boolean;
	snoozeFrequency  : Integer;
	snoozeCount      : Integer;
	onServer         : String;

	totalCount       : Integer;
	processedCount   : Integer;
	commitFrequency  : Integer;

	auditLogInterface: JSSCTAuditLogInterface;
	journalOptions   : Integer;
	userName : String;
	transactionUserName : String; //cnwrd1 par 34666
	userIndex : Integer;
	cUserName : String;
	cUserIndex : Integer;
//	jadeAuditAccess : JadeAuditAccess;		// PAR #35072
	firstTrxTimeStamp : TimeStamp;
	lastTrxTimeStamp : TimeStamp;

begin 
	self.monitor(self.class.name&amp;'::'&amp;method.name&amp;' '&amp;pAuditLogNumber.String, MONITOR_DEBUG);
	create self.myChangeObjectTA transient; 
	self.myChangeObjectTA.myChangeTrackingRoot := self.myChangeTrackingRoot;
	create self.myChangeTrackingClassTA transient;
	self.myChangeTrackingClassTA.myChangeTrackingRoot := self.myChangeTrackingRoot;
	create self.myClassInitializeRequestTA transient;
	

	//	establish starting date for when instances are to be kept
//	startingDate := app.actualTimeServer().date - self.myChangeTrackingRoot.daysToKeepTrackingChanges;

	//	process journal locally or on the server
	serverExecuteLog := app.getProfileStringAppServer(app.getIniFileNameAppServer(), "JSSChangeTracker", "ReadLogServerExecution", 'true').toLower = "true";
	if serverExecuteLog = true then
		onServer := ' on Server ';
	endif;

	auditLogInterface := JSSCTAuditLogInterface.firstProcessTransientInstance;
	if auditLogInterface = null then
		create auditLogInterface transient;
	endif;
	auditLogInterface.myPersistentInstance := JSSCTAuditLogInterface.firstInstance;
	auditLogInterface.myNibblerManager := self;
//	jadeAuditAccess := auditLogInterface.myJadeAuditAccess;	//24 Sept 2013	cnwrs1	CCMS2238 C3 Change Tracker	// PAR #35072

	//	set the journal options before calling the entry point

	//	- flag if we want to include or exclude the class list
	if self.trackAllClassesByDefault then
		journalOptions := journalOptions + 2;		//	set bit 2 = exclude registered classes
	endif;
	//	- decide if we want to get the Collection Header entries
	if self.allCollectionClassEntries.size &gt; 0 then
		journalOptions := journalOptions + 1;		//	set bit 1 = collection headers to be tracked
	endif;
	//	now set the options in the dll
	if journalOptions &gt; 0 then
		auditLogInterface.setReadOptions(serverExecuteLog, journalOptions);
	endif;
	//	get any definitions for ignoring deletes of a class within a specified instance range
	self.checkForIniFileClasses(auditLogInterface);

	result := auditLogInterface.openJournal(serverExecuteLog, pAuditLogNumber);
	self.monitor(self.class.name&amp;'::'&amp;method.name&amp;' '&amp;pAuditLogNumber.String&amp;' result='&amp;result.String, MONITOR_DEBUG);

	if result = 3068 or result = 3097 then	//	Incompatible log format - assume last Jade5 journal file
		self.monitor(self.myTitle &amp; ' - Jade (prior version) Journal file ' &amp; pAuditLogNumber.String &amp; ' skipped. ', MONITOR_ONLY);
		return;
/*
		//	can only be assumed if this property is still = 0
		if self.myPersistentInstance.lastJade5Log = 0 then

			//	update the manager to show that we have skipped the ONE Jade5 journal file, and no more
			self.myTA.lastAuditFileNumber := pAuditLogNumber;
			self.myTA.lastAuditFileComplete := true;
			self.myTA.lastAuditFileTimeStamp := app.actualTimeServer;
			self.myTA.lastAuditFileSequence := 0;
			self.myTA.lastJade5Log := pAuditLogNumber;

			self.lastAuditFileNumber := pAuditLogNumber;
			self.lastAuditFileComplete := true;
			self.lastAuditFileTimeStamp := app.actualTimeServer;
			self.lastAuditFileSequence := 0;
			self.lastJade5Log := pAuditLogNumber;

			self.myTA.updateEntity();
			self.monitor(self.myTitle &amp; ' - Jade (prior version) Journal file ' &amp; pAuditLogNumber.String &amp; ' skipped.', MONITOR_ONLY);

			self.myTA.lastJade5Log := 0;
			//	reset to zero so we don't process it again
			self.lastJade5Log := 0;
			//	update the controller(s) if running
			self.setState(self.state);
			self.currentErrorCode := 0;

			return;

		endif;*/
	endif;
	if result = 0 then

		//	update the manager to show where we have started
		self.myTA.lastAuditFileNumber := pAuditLogNumber;
		self.myTA.lastAuditFileComplete := false;
		self.myTA.lastAuditFileTimeStamp := app.actualTimeServer; //rs may 2005
		self.myTA.lastAuditFileSequence := 0;

		self.lastAuditFileNumber := pAuditLogNumber;
		self.lastAuditFileComplete := false;
		self.lastAuditFileTimeStamp := app.actualTimeServer; //rs may 2005
		self.lastAuditFileSequence := 0;

		//	update the controller(s) if running
		self.setState(self.state);

		//	get the frequency at which we will do a sleep and doWindowEvents
		snoozeFrequency := app.getProfileStringAppServer(app.getIniFileNameAppServer(), "JSSChangeTracker", "SnoozeFrequency", '100').Integer;

		//	get the frequency at which we will do a commitTransaction
		commitFrequency := app.getProfileStringAppServer(app.getIniFileNameAppServer(), "JSSChangeTracker", "CommitFrequency", '10000').Integer;

		self.monitor(self.myTitle &amp; " - Processing Journal " &amp; pAuditLogNumber.String &amp; " ..." &amp; onServer, MONITOR_ONLY);

		//	we need to process the journal file within a transaction, otherwise we will create heaps of journal entries ourself
		beginTransaction;

		result := auditLogInterface.readJournal(serverExecuteLog, lType, lTranId, trxTimeStamp, lOid, lAction, lSequence);	//09 Jul 2013	cnwrs1	Par #31540 - use current time rather than trx transation time from journal
		if result = 0 then
			firstTrxTimeStamp := trxTimeStamp;
			lastTrxTimeStamp := trxTimeStamp;
		endif;
		while result = 0 do
			lTimeStamp := app.actualTimeServer;	//09 Jul 2013	cnwrs1	Par #31540 - use current time rather than trx transation time from journal
			lastTimeStamp := lTimeStamp;
			totalCount := totalCount + 1;

			snoozeCount := snoozeCount + 1;
			if snoozeCount &gt; snoozeFrequency then
				process.sleep(0);
//	taken the doWindowEvents out as it only allows notifications thru that sleep(0) doesn't, but may do more other stuff that we don't want
//				app.doWindowEvents(0);
				//	reset the snooze counter
				snoozeCount := 0;
			endif;
			//	check if we need to start a new transaction
			if totalCount mod commitFrequency = 0 then
				commitTransaction;
				self.monitor(self.myTitle &amp; " - Committing after " &amp; totalCount.String &amp; " entries processed...", MONITOR_ONLY);
				beginTransaction;
			endif;
			if lType = JadeAuditAccess.Jaa_Type_BeginTransaction then
//write "Jaa_Type_BeginTransaction";
				auditLogInterface.getUserData(serverExecuteLog, userName, userIndex);	// PAR #35072
				userName := self.getUserCode(userIndex);
				self.setTranIDForUser(lTranId,userIndex,userName); //cnwrd1 par 34666
//write("Begin user :" &amp; userIndex.String &amp; " " &amp; userName);
			elseif lType = JadeAuditAccess.Jaa_Type_AbortTransaction then
//write "Jaa_Type_AbortTransaction";
				auditLogInterface.getUserData(serverExecuteLog, userName, userIndex);	// PAR #35072
				userName := self.getUserCode(userIndex);
//write("Abort user :" &amp; userIndex.String &amp; " " &amp; userName);
				self.processAuditLogAbort(lTranId);
				self.lastAuditFileTimeStamp := app.actualTimeServer;
				self.clearTranIDForUser(userIndex); //cnwrd1 par 34666
				//	check if we have been asked to stop - only do this on abort and commit
				if self.interruptProcessing then
					break;
				endif;
			elseif lType = JadeAuditAccess.Jaa_Type_CommitTransaction then
//write "Jaa_Type_CommitTransaction";
				auditLogInterface.getUserData(serverExecuteLog, userName, userIndex);	// PAR #35072
				userName := self.getUserCode(userIndex);
//write("Committ user :" &amp; userIndex.String &amp; " " &amp; userName);
				self.processAuditLogCommit(lTranId, lTimeStamp);
				self.lastAuditFileTimeStamp := app.actualTimeServer;
				self.clearTranIDForUser(userIndex); //cnwrd1 par 34666

				//	check if we have been asked to stop - only do this on abort and commit
				if self.interruptProcessing then
					break;
				endif;
			elseif lType = JadeAuditAccess.Jaa_Type_UserSignOn then
//write "Jaa_Type_UserSignOn";
				auditLogInterface.getUserData(serverExecuteLog, userName, userIndex);	// PAR #35072
//write("Sign on user :" &amp; userIndex.String &amp; " " &amp; userName);
				self.monitor("Sign on user :" &amp; userIndex.String &amp; " " &amp; userName, MONITOR_ONLY);
				self.addUser(userIndex, userName);
			elseif lType = JadeAuditAccess.Jaa_Type_UserSignOff then
//write "Jaa_Type_UserSignOff";
				auditLogInterface.getUserData(serverExecuteLog, userName, userIndex);	// PAR #35072
//write("Sign off user :" &amp; userIndex.String &amp; " " &amp; userName);
				self.monitor("Sign off user :" &amp; userIndex.String &amp; " " &amp; userName, MONITOR_ONLY);
				self.removeUser(userIndex);
			elseif lType = JadeAuditAccess.Jaa_Type_ChangeUser then
//write "Jaa_Type_ChangeUser";
				auditLogInterface.getChangeUserData(serverExecuteLog, userName, userIndex, cUserName, cUserIndex);	// PAR #35072
//write("Change user :" &amp; userIndex.String &amp; " " &amp; userName);
				self.monitor("Change user :" &amp; userIndex.String &amp; " " &amp; userName, MONITOR_ONLY);
				self.changeUser(userIndex, userName);
			elseif lType = JadeAuditAccess.Jaa_Type_Create or 
				   lType = JadeAuditAccess.Jaa_Type_Update or 
				   lType = JadeAuditAccess.Jaa_Type_Delete then

				if lAction = JadeAuditAccess.Jaa_Object_Collection then
					readNext := processAuditCollection(lOid, lAction, class);
					if readNext = true then
						result := auditLogInterface.readJournal(serverExecuteLog, lType, lTranId, trxTimeStamp, lOid, lAction, lSequence);	//09 Jul 2013	cnwrs1	Par #31540 - use current time rather than trx transation time from journal
						if result = 0 then
							lastTrxTimeStamp := trxTimeStamp;
						else
							trxTimeStamp := lastTrxTimeStamp;
						endif;
						lTimeStamp := app.actualTimeServer;	//09 Jul 2013	cnwrs1	Par #31540 - use current time rather than trx transation time from journal
						continue;
					endif;
				elseif lAction = JadeAuditAccess.Jaa_Object_Object then

					// Identify the class we are dealing with from the object id
					// KPD 20/05/2009 - rework to use JADE recommended method					
					obj := lOid.asOid();
					class := self.getClassForObject(obj);
					
//					classNumber := lOid[1 : lOid.pos(".", 1) -1].Integer;
//					class := self.myNotificationObject.mySharedTransientInstance.applicationSchema.getClassByNumber(classNumber);
	
					if class = null then
						monitor("***** Could not find Class for Object Id " &amp; lOid, MONITOR_ONLY);
						result := auditLogInterface.readJournal(serverExecuteLog, lType, lTranId, trxTimeStamp, lOid, lAction, lSequence);	//09 Jul 2013	cnwrs1	Par #31540 - use current time rather than trx transation time from journal
						if result = 0 then
							lastTrxTimeStamp := trxTimeStamp;
						else
							trxTimeStamp := lastTrxTimeStamp;
						endif;
						lTimeStamp := app.actualTimeServer;	//09 Jul 2013	cnwrs1	Par #31540 - use current time rather than trx transation time from journal
						continue;
					endif;
				endif;
				//	check that it is not a system object and not one of this schema(or above)'s objects, or any JSS schema object
				schemaName := class.schema.name;
				if schemaName = "JSSChangeTrackingSchema" or
				   schemaName = "JSSCoreSchema" or
				   schemaName = "JSSInternetSchema" or
				   class.isSystemObject() then
					//	ignore system objects
					result := auditLogInterface.readJournal(serverExecuteLog, lType, lTranId, trxTimeStamp, lOid, lAction, lSequence);	//09 Jul 2013	cnwrs1	Par #31540 - use current time rather than trx transation time from journal
					if result = 0 then
						lastTrxTimeStamp := trxTimeStamp;
					else
						trxTimeStamp := lastTrxTimeStamp;
					endif;
					lTimeStamp := app.actualTimeServer;	//09 Jul 2013	cnwrs1	Par #31540 - use current time rather than trx transation time from journal
					continue;
				endif;
//				if lTimeStamp.date &lt; startingDate then
					//	ignore changes that are too old
//					result := auditLogInterface.readJournal(serverExecuteLog, lType, lTranId, trxTimeStamp, lOid, lAction, lSequence);	//09 Jul 2013	cnwrs1	Par #31540 - use current time rather than trx transation time from journal
//					lTimeStamp := app.actualTimeServer;	//09 Jul 2013	cnwrs1	Par #31540 - use current time rather than trx transation time from journal
//					continue;
//				endif;
				//	process this entry
				if lType = JadeAuditAccess.Jaa_Type_Delete then

					//self.processAuditLogDelete(class, lTimeStamp, lOid, lTranId, lSequence, trxTimeStamp);
					transactionUserName := self.getUserCodeFromTranID(lTranId ); //cnwrd1 par 34666
					self.monitor(self.class.name&amp;'::'&amp;method.name&amp;" processAuditLogDelete "&amp;lType.String&amp;' '&amp;class.name&amp;' '&amp;lTimeStamp.formatAsYYYYMMDDHHMMSSMMM&amp;' '&amp;lOid.String&amp;' '&amp;transactionUserName, MONITOR_DEBUG);
					self.processAuditLogDelete(class, lTimeStamp, lOid, lTranId, lSequence, trxTimeStamp, transactionUserName);	//07 Jan 2014	NDL	Par 33264
					processedCount := processedCount + 1;

				elseif lType = JadeAuditAccess.Jaa_Type_Create or lType = JadeAuditAccess.Jaa_Type_Update then

					//self.processAuditLogChange(class, lTimeStamp, lOid, lType, lTranId, lSequence, trxTimeStamp);
					transactionUserName := self.getUserCodeFromTranID(lTranId ); //cnwrd1 par 34666
					self.monitor(self.class.name&amp;'::'&amp;method.name&amp;" processAuditLogChange "&amp;lType.String&amp;' '&amp;class.name&amp;' '&amp;lTimeStamp.formatAsYYYYMMDDHHMMSSMMM&amp;' '&amp;lOid.String&amp;' '&amp;transactionUserName, MONITOR_DEBUG);
					self.processAuditLogChange(class, lTimeStamp, lOid, lType, lTranId, lSequence, trxTimeStamp, transactionUserName);//07 Jan 2014	NDL	Par 33264
					processedCount := processedCount + 1;

				endif;
			endif;
			//	read the next entry
			result := auditLogInterface.readJournal(serverExecuteLog, lType, lTranId, trxTimeStamp, lOid, lAction, lSequence);	//09 Jul 2013	cnwrs1	Par #31540 - use current time rather than trx transation time from journal
			if result = 0 then
				lastTrxTimeStamp := trxTimeStamp;
			else
				trxTimeStamp := lastTrxTimeStamp;
			endif;
			lTimeStamp := app.actualTimeServer;	//09 Jul 2013	cnwrs1	Par #31540 - use current time rather than trx transation time from journal
//			self.monitor(""&amp;trxTimeStamp.formatAsYYYYMMDDHHMMSSMMM, MONITOR_ALWAYS);
		endwhile;

		//	we have finished with this journal, so commit any changes
		commitTransaction;

		//	check if we were asked to stop
		if self.interruptProcessing then
			self.monitor(self.myTitle &amp; " - Journal " &amp; pAuditLogNumber.String &amp; " processing interrupted.", MONITOR_ONLY);
		else
			self.monitor(self.myTitle &amp; " - Journal " &amp; pAuditLogNumber.String &amp; " processed, " &amp; processedCount.String &amp; " entries selected out of " &amp; totalCount.String &amp; " read, from "&amp;firstTrxTimeStamp.formatAsYYYYMMDDHHMMSSMMM&amp;' to '&amp;lastTrxTimeStamp.formatAsYYYYMMDDHHMMSSMMM, MONITOR_ONLY);

			//	update the manager to show where we have ended
			self.myTA.lastAuditFileNumber := pAuditLogNumber;
			self.myTA.lastAuditFileComplete := true;
			self.myTA.lastAuditFileTimeStamp := lastTimeStamp;	//app.actualTimeServer;
			self.myTA.lastAuditFileSequence := lSequence;

			self.lastAuditFileNumber := pAuditLogNumber;
			self.lastAuditFileComplete := true;
			self.lastAuditFileTimeStamp := lastTimeStamp;	//app.actualTimeServer;
			self.lastAuditFileSequence := lSequence;

			//	once we have processed a Jade6 journal, we can't allow the skipping of an old Jade5 one
			if self.myPersistentInstance.lastJade5Log = 0 then
				self.myTA.lastJade5Log := 1;
			endif;
			self.myTA.updateEntity();
			//	reset to zero so we don't process it again
			self.myTA.lastJade5Log := 0;

			//	update the controller(s) if running
			self.setState(self.state);
		endif;
	else
		//	if we haven't started yet, it's ok for the file not to be there
		if self.myPersistentInstance.lastAuditFileNumber &gt; 0 then
			//	check if there is an ini file option to indicate that its OK to have a missing file // JETkgd 23/01/2004
			if app.getProfileStringAppServer(app.getIniFileNameAppServer(), "JSSChangeTracker", "IgnoreMissingFiles", "false") = "false" then
				/*
					We could not access this journal file, so we must throw up out hands and die, as we cannot afford to miss
					a file!
				*/
				self.monitor(self.myTitle &amp; " - Terminating due to Journal file (" &amp; pAuditLogNumber.String &amp; ") unavailability, return code " &amp; result.String &amp; ".", MONITOR_ONLY);
				self.currentErrorCode := result;
				self.myNotificationObject.myPersistentInstance.causeEvent(JSSCT_Nibbler_Note, true, self.myNotificationObject.buildNibbler_RaiseAlert("Change Tracker Journal file missing.", "Change Tracker could not find Jade Journal file number " &amp; pAuditLogNumber.String &amp; ". Return code " &amp; result.String));
				return;
			endif;
		endif;
	endif;
	if result &lt;&gt; 3036 then
		auditLogInterface.closeJournal(serverExecuteLog);
	endif;
	self.currentErrorCode := 0;

epilog
	delete self.myClassInitializeRequestTA;
	delete self.myChangeTrackingClassTA;
	delete self.myChangeObjectTA;
end;</source>
        <Parameter name="pAuditLogNumber" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="processAuditLogAbort" id="4a5c63fb-224d-46a9-84fd-46e7ba7b1317">
        <updating/>
        <source>processAuditLogAbort(pTranId : Decimal) updating, protected;
/*
//22 Aug 2014	cnwrs1	Par 34821 - usercode not always updated correctly*/
vars
	iter         : Iterator;
	changeObject : JSSCTChangeTrackingObject;
begin
	self.monitor(self.class.name&amp;'::'&amp;method.name&amp;' ', MONITOR_DEBUG);
	iter := self.myChangeTrackingRoot.allUpdatesByTransactionIdDict.createIterator;
	self.myChangeTrackingRoot.allUpdatesByTransactionIdDict.startKeyGeq(pTranId, null, iter);
	while iter.next(changeObject) do
		//	check that we are still processing this transaction id
		if changeObject.changeTransactionID &lt;&gt; pTranId then
			break;
		endif;
		//	check if we need to restore or throw away the aborted change
		self.myChangeObjectTA.myChangeObject := changeObject;
		if changeObject.previouslyTracked then

			//	restore the previously tracked change
			self.myChangeObjectTA.myChangeObject := changeObject;
			self.myChangeObjectTA.previouslyTracked := false;
			self.myChangeObjectTA.changeAction := changeObject.priorChangeAction;
			self.myChangeObjectTA.changeTimestamp := changeObject.priorChangeTimestamp;
			self.myChangeObjectTA.changeObject := changeObject.changeObject;
			self.myChangeObjectTA.changeSequence := changeObject.changeSequence;
			self.myChangeObjectTA.changeTransactionID := null;
			self.myChangeObjectTA.userCode := changeObject.userCode;

			self.myChangeObjectTA.myChangeClass := self.myChangeTrackingRoot.allChangeClasses[changeObject.className, false];
			if changeObject.changeAction = JSSCTChangeTrackingObject.ACTION_DELETE then
				self.myChangeObjectTA.myDeleteClass := self.myChangeTrackingRoot.allDeleteClasses[changeObject.className, true];
			else
				self.myChangeObjectTA.myDeleteClass := null;
			endif;
			self.myChangeObjectTA.updateEntityInTransState();

		else

			//	remove the aborted change
			if changeObject.changeAction = JSSCTChangeTrackingObject.ACTION_DELETE then
				self.myChangeObjectTA.myChangeClass := null;
				self.myChangeObjectTA.myDeleteClass := self.myChangeTrackingRoot.allDeleteClasses[changeObject.className, true];
			else
				self.myChangeObjectTA.myChangeClass := self.myChangeTrackingRoot.allChangeClasses[changeObject.className, false];
				self.myChangeObjectTA.myDeleteClass := null;
			endif;
			self.myChangeObjectTA.deleteEntityInTransState();

		endif;
	endwhile;
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="pTranId" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="processAuditLogChange" id="1876e4c6-f9c6-44c0-bd73-64af523ea55c">
        <updating/>
        <source>processAuditLogChange(pClass: Class; pTimeStamp: TimeStamp; pOid: String; pType: Integer; pTranId: Decimal; pSequence: Decimal; _trxTimeStamp : TimeStamp; _userCode : String) updating, protected;

/*

Date		Who		Reason
21 May 2009	cnwkpd1	Change asObject to asOid - see JADE PAR #51153 for more info
11 Nov 2013	cnwrs1	Par #31540 - use current time rather than trx transation time from journal
*/
vars
	className    : String;

	changeObject : JSSCTChangeTrackingObject;
	changeClass  : JSSCTChangeTrackingClass;
	deleteClass  : JSSCTChangeTrackingClass;
begin 
//	self.monitor(self.class.name&amp;'::'&amp;method.name&amp;" pOid="&amp;pOid&amp;' className='&amp;pClass.name, MONITOR_DEBUG);
	className := pClass.name;

	self.reserveLock(self.myChangeTrackingRoot.allChangeClasses);

	changeClass := self.myChangeTrackingRoot.allChangeClasses[className,false];
	if changeClass = null then
		if self.trackAllClassesByDefault then
			//	check if we have been asked to ignore this class
			if self.allClassIniFileEntries[className] &lt;&gt; null then
				self.unlock(self.myChangeTrackingRoot.allChangeClasses);
				return;
			endif;
		else
			//	check if we have NOT been asked to include this class
			if self.allClassIniFileEntries[className] = null then
				self.unlock(self.myChangeTrackingRoot.allChangeClasses);
				return;
			endif;
		endif;
		//	check that this is not a Window subclass
		if pClass.inheritsFrom(Window) then
			self.unlock(self.myChangeTrackingRoot.allChangeClasses);
			return;
		endif;
		changeClass := self.createChangeDictForClass(className, false, true);
	endif;
	self.myChangeObjectTA.myChangeClass := null;
	self.myChangeObjectTA.myDeleteClass := null;

	changeObject := changeClass.allChangesByOid[pOid];
	if changeObject = null then
		deleteClass := self.myChangeTrackingRoot.allDeleteClasses[className,true];
		if deleteClass &lt;&gt; null then
			changeObject := deleteClass.allChangesByOid[pOid];
			if changeObject &lt;&gt; null then
				self.myChangeObjectTA.myDeleteClass := deleteClass;
				self.myChangeObjectTA.isDelete := true;
			endif;
		endif;
	endif;
	self.myChangeObjectTA.myChangeObject := changeObject;
	self.myChangeObjectTA.changeTimestamp := pTimeStamp;
	self.myChangeObjectTA.changeObject   := pOid.asOid();
	self.myChangeObjectTA.changeObjectID := pOid;
	self.myChangeObjectTA.className := className;
	self.myChangeObjectTA.changeSequence := pSequence;
	self.myChangeObjectTA.changeTransactionID := pTranId;
	self.myChangeObjectTA.trxTimestamp := _trxTimeStamp;
	self.myChangeObjectTA.userCode := _userCode;	//07 Jan 2014	NDL	Par 33264

	self.myChangeObjectTA.myChangeClass := changeClass;
	if changeObject = null then
		if pType = JadeAuditAccess.Jaa_Type_Create then
			self.myChangeObjectTA.changeAction := JSSCTChangeTrackingObject.ACTION_CREATE;
		else
			self.myChangeObjectTA.changeAction := JSSCTChangeTrackingObject.ACTION_UPDATE;
		endif;
		self.myChangeObjectTA.createEntityInTransState();
	else
		/*
			Only update the change tracking if timestamp is after the current one,
			we could be initializing from the instances collection and be behind the
			process that is reading the journals
		*/
		if pTimeStamp &gt;= changeObject.changeTimestamp then
			self.myChangeObjectTA.changeAction := JSSCTChangeTrackingObject.ACTION_UPDATE;

			//	update the prior state of this object in case the transaction is aborted
			if not changeObject.previouslyTracked then
				self.myChangeObjectTA.previouslyTracked := true;
				self.myChangeObjectTA.priorChangeAction := changeObject.changeAction;
				self.myChangeObjectTA.priorChangeTimestamp := changeObject.changeTimestamp;
			endif;
			self.myChangeObjectTA.updateEntityInTransState();
		else
			self.unlock(self.myChangeTrackingRoot.allChangeClasses);
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pClass" type="Class"/>
        <Parameter name="pTimeStamp" type="TimeStamp"/>
        <Parameter name="pOid" type="String"/>
        <Parameter name="pType" type="Integer"/>
        <Parameter name="pTranId" type="Decimal"/>
        <Parameter name="pSequence" type="Decimal"/>
        <Parameter name="_trxTimeStamp" type="TimeStamp"/>
        <Parameter name="_userCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="processAuditLogCommit" id="eda1c442-dc72-41a2-8f9a-178b8a8950ff">
        <updating/>
        <source>processAuditLogCommit(pTranId: Decimal; pTimeStamp: TimeStamp) updating, protected;
/*
//22 Aug 2014	cnwrs1	Par 34821 - usercode not always updated correctly
//12 Jan2015	cnwrd1	par 35437 - set timestamp on transaction for cross journal trx
*/
vars
	iter         : Iterator;
	changeObject : JSSCTChangeTrackingObject;
begin
//	self.monitor(self.class.name&amp;'::'&amp;method.name&amp;' ', MONITOR_DEBUG);
	iter := self.myChangeTrackingRoot.allUpdatesByTransactionIdDict.createIterator;
	self.myChangeTrackingRoot.allUpdatesByTransactionIdDict.startKeyGeq(pTranId, null, iter);
	while iter.next(changeObject) do
		//	check that we are still processing this transaction id
		if changeObject.changeTransactionID &lt;&gt; pTranId then
			break;
		endif;
		//	apply the commited change
		self.myChangeObjectTA.myChangeObject := changeObject;
		self.myChangeObjectTA.changeAction := changeObject.changeAction;
		self.myChangeObjectTA.changeObject := changeObject.changeObject;
		self.myChangeObjectTA.changeSequence := changeObject.changeSequence;
		self.myChangeObjectTA.changeTimestamp := pTimeStamp;	//cnwrd1 par 35437
		self.myChangeObjectTA.changeTransactionID := null;
		self.myChangeObjectTA.previouslyTracked := false;

		self.myChangeObjectTA.myChangeClass := null;
		self.myChangeObjectTA.myDeleteClass := null;

		self.myChangeObjectTA.userCode := changeObject.userCode;
		self.myChangeObjectTA.updateEntityInTransState();
	endwhile;
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="pTranId" type="Decimal"/>
        <Parameter name="pTimeStamp" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="processAuditLogDelete" id="e2906db4-6c1b-4e46-9b47-1c4add4246ff">
        <updating/>
        <source>processAuditLogDelete(pClass: Class; pTimeStamp: TimeStamp; pOid: String; pTranId: Decimal; pSequence: Decimal; _trxTimeStamp : TimeStamp; _userCode : String) updating, protected;
//
//11 Nov 2013	cnwrs1	Par #31540 - use current time rather than trx transation time from journal
//
vars
	className    : String;

	changeClass  : JSSCTChangeTrackingClass;
	deleteObject : JSSCTChangeTrackingObject;
	deleteClass  : JSSCTChangeTrackingClass;

	instanceNumber: Integer;
	ignoreDeletes : JSSCTIgnoreDeletesEntry;
begin
//	self.monitor(self.class.name&amp;'::'&amp;method.name&amp;" pOid="&amp;pOid&amp;' className='&amp;pClass.name, MONITOR_DEBUG);
	className := pClass.name;

	self.reserveLock(self.myChangeTrackingRoot.allChangeClasses);

	//	look for the object in the create/update collection
	changeClass := self.myChangeTrackingRoot.allChangeClasses[className,false];
	if changeClass = null then
		if self.trackAllClassesByDefault then
			//	check if we have been asked to ignore this class
			if self.allClassIniFileEntries[className] &lt;&gt; null then
				self.unlock(self.myChangeTrackingRoot.allChangeClasses);
				return;
			endif;
		else
			//	check if we have NOT been asked to include this class
			if self.allClassIniFileEntries[className] = null then
				self.unlock(self.myChangeTrackingRoot.allChangeClasses);
				return;
			endif;
		endif;
		//	check that this is not a Window subclass
//		if self.inheritsFromWindow(pClass) then
		if pClass.inheritsFrom(Window) then
			self.unlock(self.myChangeTrackingRoot.allChangeClasses);
			return;
		endif;
		self.createChangeDictForClass(className, false, true);
	else
//		self.monitor(self.class.name&amp;'::'&amp;method.name&amp;" changeDict="&amp;changeDict.String&amp;' allChangesByOidDict='&amp;changeDict.allChangesByOidDict.String,true);
		deleteObject := changeClass.allChangesByOid[pOid];
	endif;
	self.reserveLock(self.myChangeTrackingRoot.allDeleteClasses);

	//	look for the object in the create/update collection
	deleteClass := self.myChangeTrackingRoot.allDeleteClasses[className,true];
	if deleteClass = null then
		deleteClass := self.createChangeDictForClass(className, true, true);
	else
		if deleteObject = null then
			deleteObject := deleteClass.allChangesByOid[pOid];
			if deleteObject &lt;&gt; null then
				changeClass := null;
			endif;
		endif;
	endif;
	self.myChangeObjectTA.myChangeClass := changeClass;
	self.myChangeObjectTA.myDeleteClass := deleteClass;
	self.myChangeObjectTA.myChangeObject := deleteObject;
	self.myChangeObjectTA.changeTimestamp := pTimeStamp;
	self.myChangeObjectTA.changeObject := null;
	self.myChangeObjectTA.changeObjectID := pOid;
	self.myChangeObjectTA.className := className;
	self.myChangeObjectTA.changeAction := JSSCTChangeTrackingObject.ACTION_DELETE;
	self.myChangeObjectTA.changeSequence := pSequence;
	self.myChangeObjectTA.changeTransactionID := pTranId;
	self.myChangeObjectTA.trxTimestamp := _trxTimeStamp;
	self.myChangeObjectTA.userCode := _userCode;	//07 Jan 2014	NDL	Par 33264
	
	//	check if we have an ignoreDeletes entry for this class
	ignoreDeletes := self.allClassIgnoreDeletesEntries[pClass.name];
	if ignoreDeletes &lt;&gt; null then
		//	get the instance and check if it is in the range to be ignored
		instanceNumber := pOid[pOid.pos(".",1)+1:end].Integer;
//		if not ignoreDeletes.ignoreThisDelete(instanceNumber) then
		if instanceNumber &lt; ignoreDeletes.instanceStart or instanceNumber &gt; ignoreDeletes.instanceEnd then
			ignoreDeletes := null;
		endif;
	endif;
	if deleteObject = null then
		//	see if we need to process this delete or not
		if ignoreDeletes = null then

			//	if we are creating the delete object entry, then we don't have a create/update entry
			self.myChangeObjectTA.myChangeClass := null;
			self.myChangeObjectTA.createEntityInTransState();

		endif;
	else
		//	see if we need to process this delete or not
		if ignoreDeletes = null then
			/*
				Only update the change tracking if timestamp is after the current one,
				we could be initializing from the instances collection and be behind the
				process that is reading the journals
			*/
			if pTimeStamp &gt;= deleteObject.changeTimestamp then

				//	update the prior state of this object in case the transaction is aborted
				if not deleteObject.previouslyTracked then
					self.myChangeObjectTA.previouslyTracked := true;
					self.myChangeObjectTA.priorChangeAction := deleteObject.changeAction;
					self.myChangeObjectTA.priorChangeTimestamp := deleteObject.changeTimestamp;
				endif;
				self.myChangeObjectTA.updateEntityInTransState();
			else
				self.unlock(self.myChangeTrackingRoot.allChangeClasses);
				self.unlock(self.myChangeTrackingRoot.allDeleteClasses);
			endif;
		else
			//	a create/update entry, or a delete entry exists, so we need to delete it
			//		as we are not tracking the delete of this instance
			if changeClass &lt;&gt; null then
				self.myChangeObjectTA.myDeleteClass := null;
			endif;
			self.myChangeObjectTA.deleteEntityInTransState();

		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pClass" type="Class"/>
        <Parameter name="pTimeStamp" type="TimeStamp"/>
        <Parameter name="pOid" type="String"/>
        <Parameter name="pTranId" type="Decimal"/>
        <Parameter name="pSequence" type="Decimal"/>
        <Parameter name="_trxTimeStamp" type="TimeStamp"/>
        <Parameter name="_userCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="removeJSSCTDict" id="ee7b10d6-c412-4d0f-ae0b-a3735ff3fd23">
        <source>removeJSSCTDict();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 August 2014	cnwrd1	Initial creation
for par 34666 uppgrade cleanup - called from PortSChema JadeScript rel822_par3488 and via portSchema upgrade.
*/

vars
	theDict : JSSCTUserbyTranID;
	iter : Iterator;
	dictUser : JSSCTUser;	
	tranNo : Decimal[12];
begin

	theDict := self.getJSSCTUserTranIDDict();
	
	if theDict = null then
		return;
	endif;
	
	iter := theDict.createIterator;
	
	beginTransaction;
	
	while iter.next(dictUser) do
		theDict.getIteratorKeys(tranNo,iter);
		dictUser.setTranID(tranNo);
	endwhile;

	delete dictUser;
	commitTransaction;
	
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="removeOutOfDateChanges" id="55b6b621-d276-4872-b903-28ca3010123c">
        <updating/>
        <executionLocation>server</executionLocation>
        <source>removeOutOfDateChanges() updating, serverExecution;
/*
Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks
03 Feb 2011	cnwrs1	PAR #25828 - using up too many licences
24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
*/
constants
	TELL_NUMBER: Integer = 99;
vars
	changeClass: JSSCTChangeTrackingClass;
	changeInstance: JSSCTChangeTrackingObject;
	deleteClass: JSSCTChangeTrackingClass;
	deleteInstance: JSSCTChangeTrackingObject;
	startingDate: Date;
	iterDict: Iterator;
	iterInstance: Iterator;
	lTimeStamp: TimeStamp;
	saveState: String;
	count: Integer;
	countAndTell: Integer;
	totalCount: Integer;
	processedCount: Integer;
	commitFrequency: Integer;
	startTime : TimeStamp;	//cnwrs1 par 25828 2 Feb 2011
	currTime : TimeStamp;	//cnwrs1 par 25828 2 Feb 2011
	stopTime : TimeStamp;	//cnwrs1 par 25828 2 Feb 2011
	timeInterval : TimeStampInterval;	//cnwrs1 par 25828 2 Feb 2011
	stopDeleteTime : Integer;	//cnwrs1 par 25828 3 Feb 2011	
	daysToKeepTrackingChanges : Integer; 	//cnwrs1 par 25828 3 Feb 2011
begin
	on Exception do handleException(exception);
	on LockException do handleLockException(exception); // JETkgd 20/1/2004
	self.monitor(self.class.name&amp;'::'&amp;method.name&amp;' ', MONITOR_DEBUG);
	startTime := app.actualTimeServer;	//cnwrs1 par 25828 2 Feb 2011
	saveState := self.state;

	create self.myChangeObjectTA transient;
	self.myChangeObjectTA.myChangeTrackingRoot := self.myChangeTrackingRoot;

	//	establish starting date for when instances are to be kept
	daysToKeepTrackingChanges := app.getProfileStringAppServer(app.getIniFileNameAppServer(), "JSSChangeTracker", "InitializationKeepTrackingDays", "5").Integer;
	startingDate := (app.actualTimeServer().date - daysToKeepTrackingChanges) - 1;
	self.monitor(self.myTitle &amp; " - Removing out of date Changes before "&amp;startingDate.String, MONITOR_ALWAYS);

	self.myChangeObjectTA.myDeleteClass := null;

	//	get the frequency at which we will do a commitTransaction
	commitFrequency := app.getProfileStringAppServer(app.getIniFileNameAppServer(), "JSSChangeTracker", "CommitFrequency", '10000').Integer;

	//	remove out of date instances from the change collections
	iterDict := self.myChangeTrackingRoot.allChangeClasses.createIterator();

	beginTransaction;

	while iterDict.next(changeClass) do
		self.tryLock(changeClass, Share_Lock, Session_Duration, 60000);
		self.myChangeObjectTA.myChangeClass := changeClass;
		delete iterInstance;			// PAR #26678
		iterInstance := changeClass.allChangesByTime.createIterator();	// par 25828 cnwrs1 4 Feb 2011
		while iterInstance.next(changeInstance) do
			self.tryShareLockingObject(changeInstance);
			if changeInstance.changeTimestamp.date &lt; startingDate then
				stopTime := changeInstance.changeTimestamp;	//par 15828 cnwrs1 3 feb 2011
				self.myChangeObjectTA.myChangeObject := changeInstance;
//				self.myChangeObjectTA.deleteEntity();
				self.myChangeObjectTA.deleteEntityInTransState();

				count := count + 1;
//				countAndTell := countAndTell + 1;

				//	check if we need to start a new transaction
				if count mod commitFrequency = 0 then
					commitTransaction;
					self.myTitle := "Change Tracking Checker [" &amp; (self.myDBAdminObject.getCurrentLogNumber() - 1).String &amp; "]";
					self.monitor(self.myTitle &amp; " - Committing after " &amp; count.String &amp; " instances deleted...", MONITOR_ONLY);
					currTime := app.actualTimeServer;	//cnwrs1 par25828 02 Feb 2011
					timeInterval := currTime - startTime;
					stopDeleteTime := app.getProfileStringAppServer(app.getIniFileNameAppServer(), "JSSChangeTracker", "MaxTimeForRemoveToRunInSecs", "600").Integer * 1000;
					self.debug := app.getProfileStringAppServer(app.getIniFileNameAppServer(), "JSSChangeTracker", "Debug", 'false').Boolean;	//cnwrs1 par25828 02 Feb 2011
					self.monitor(self.myTitle &amp; " - Stop remove after "&amp;(stopDeleteTime/1000).String&amp;" secs", MONITOR_DEBUG);	//cnwrs1 par25828 02 Feb 2011
					if stopDeleteTime &gt; 0 and 
					   timeInterval.getMilliseconds &gt; stopDeleteTime then
						self.monitor(self.myTitle &amp; " - Stopping to allow next journal to process, deleted changes up to " &amp; changeClass.className&amp;' '&amp;stopTime.String &amp; "...", MONITOR_ALWAYS);
						return;
					endif;
					beginTransaction;
				endif;
//				if countAndTell &gt; TELL_NUMBER then
//					self.setState(saveState &amp; " - deleted instances...(" &amp; count.String &amp; ")");
//					countAndTell := 0;
//				endif;
			else
				self.unlock(changeInstance);
				break;
			endif;
//			process.sleep(0);
//			app.doWindowEvents(0);
			//	check if we have been asked to stop
			if self.interruptProcessing then
				return;
			endif;
		endwhile;
		self.unlock(changeClass);
	endwhile;

	commitTransaction;
	self.monitor(self.myTitle &amp; " - Committing after " &amp; count.String &amp; " instances deleted...", MONITOR_ONLY);

	delete iterDict;
	delete iterInstance;
	iterInstance := null;
	self.monitor(self.myTitle &amp; " - removed " &amp; count.String &amp; " out of date creates/updates.", MONITOR_ALWAYS);

	self.myChangeObjectTA.myChangeClass := null;
	count := 0;
	//	remove out of date instances from the delete collections
	iterDict := self.myChangeTrackingRoot.allDeleteClasses.createIterator();

	beginTransaction;

	while iterDict.next(deleteClass) do
		self.tryLock(deleteClass, Share_Lock, Session_Duration, 60000); // JETkgd 22/01/2004
		self.myChangeObjectTA.myDeleteClass := deleteClass;
		self.myChangeObjectTA.isDelete := true;

		delete iterInstance;			// PAR #26678
		iterInstance := deleteClass.allChangesByTime.createIterator();	//par 25828 cnwrs1 4 Feb 2011
		while iterInstance.next(deleteInstance) do
//write deleteInstance.String;
			self.tryShareLockingObject(deleteInstance); // JETkgd 22/01/2004
			if deleteInstance.changeTimestamp.date &lt; startingDate then
				stopTime := deleteInstance.changeTimestamp;	//par 15828 cnwrs1 3 feb 2011
				self.myChangeObjectTA.myChangeObject := deleteInstance;
//				self.myChangeObjectTA.deleteEntity();
				self.myChangeObjectTA.deleteEntityInTransState();
				count := count + 1;
//				countAndTell := countAndTell + 1;

				//	check if we need to start a new transaction
				if count mod commitFrequency = 0 then
					commitTransaction;
					self.myTitle := "Change Tracking Checker [" &amp; (self.myDBAdminObject.getCurrentLogNumber() - 1).String &amp; "]";
					self.monitor(self.myTitle &amp; " - Committing after " &amp; count.String &amp; " instances deleted...", MONITOR_ONLY);
					currTime := app.actualTimeServer;	//cnwrs1 par25828 02 Feb 2011
					timeInterval := currTime - startTime;
					stopDeleteTime := app.getProfileStringAppServer(app.getIniFileNameAppServer(), "JSSChangeTracker", "MaxTimeForRemoveToRunInSecs", "600").Integer * 1000;
					self.debug := app.getProfileStringAppServer(app.getIniFileNameAppServer(), "JSSChangeTracker", "Debug", 'false').Boolean;	//cnwrs1 par25828 02 Feb 2011
					self.monitor(self.myTitle &amp; " - Stop remove after "&amp;(stopDeleteTime/1000).String&amp;" secs", MONITOR_DEBUG);	//cnwrs1 par25828 02 Feb 2011
					if stopDeleteTime &gt; 0 and 
					   timeInterval.getMilliseconds &gt; stopDeleteTime then
						self.monitor(self.myTitle &amp; " - Stopping to allow next journal to process, deleted deletes up to " &amp; deleteClass.className&amp;' '&amp;stopTime.String &amp; "...", MONITOR_ALWAYS);
						return;
					endif;
					beginTransaction;
				endif;
//				if countAndTell &gt; TELL_NUMBER then
//					self.setState(saveState &amp; " - deleted instances...(" &amp; count.String &amp; ")");
//					countAndTell := 0;
//				endif;
			else
				self.unlock(deleteInstance);  // JETkgd 22/01/2004
				break;
			endif;
//			process.sleep(0);
//			app.doWindowEvents(0);
			//	check if we have been asked to stop
			if self.interruptProcessing then
				return;
			endif;
		endwhile;
		self.unlock(deleteClass);  // JETkgd 22/01/2004
	endwhile;

	commitTransaction;
	self.monitor(self.myTitle &amp; " - Committing after " &amp; count.String &amp; " instances deleted...", MONITOR_ONLY);

	self.monitor(self.myTitle &amp; " - removed " &amp; count.String &amp; " out of date deletes.", MONITOR_ALWAYS);

epilog
	if self.interruptProcessing then
		self.monitor(self.myTitle &amp; " - Removing out of date Changes Interrupted.", MONITOR_ALWAYS);
	else
		self.monitor(self.myTitle &amp; " - Removing out of date Changes Complete.", MONITOR_ALWAYS);
	endif;
	delete iterDict;
	delete iterInstance;
	delete self.myChangeObjectTA;
end;</source>
    </JadeMethod>
    <JadeMethod name="removeUser" id="a8565f0b-c5e7-4779-8ea2-b357c7f7af2a">
        <updating/>
        <source>removeUser(_userIndex : Integer) updating;
//
//16 Sep 2013	cnwrs1	CCMS 2238 C3 Change Tracker User code
//
vars
	user : JSSCTUser;
begin
//	on Exception do exceptor(exception);
	user := self.myChangeTrackingRoot.allUsersByIndex[_userIndex];
	if user &lt;&gt; null then
//		users.removeKey(_userIndex);
		delete user;
	else
		//write "user: " &amp; userIndex.String &amp; " not found";
	endif;
end;
</source>
        <Parameter name="_userIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setDebug" id="4635b564-c96d-4fcc-9311-71c2387dc060">
        <updating/>
        <source>setDebug(_value:Boolean) updating;

vars

begin
	self.debug := _value;
end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setState" id="f9736bd4-037d-4006-86b4-77cdbee82b97">
        <updating/>
        <source>setState(value: String) updating;
/*
*/
begin
	if value = self.state then
		return;
	endif;
	self.monitor(self.class.name&amp;'::'&amp;method.name&amp;' '&amp;value, MONITOR_DEBUG);
	self.state := value;
	//	send a Notification to show the change in state
	self.myNotificationObject.myPersistentInstance.causeEvent(JSSCT_Nibbler_Note, true, self.myNotificationObject.buildNibbler_Respond(self));
end;</source>
        <Parameter name="value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setTranIDForUser" id="c1d109ad-5738-492c-a104-1ae6c3ab0f30">
        <updating/>
        <source>setTranIDForUser(_tranID : Decimal; _userIndex : Integer;_userName : String) updating;

/*

Purpose: par 34666	

Parameters:			

Return Value:		


Date		Who		Reason
05 August 2014	cnwrd1	Initial creation

*/

vars
	user : JSSCTUser;
begin

	user := self.myChangeTrackingRoot.allUsersByIndex[_userIndex];
	if user = null then
		user := self.addUser(_userIndex,_userName);		
	endif;
	
	user.setTranID(_tranID);

epilog

end;</source>
        <Parameter name="_tranID" type="Decimal"/>
        <Parameter name="_userIndex" type="Integer"/>
        <Parameter name="_userName" type="String"/>
    </JadeMethod>
    <JadeMethod name="startClassInitializerApp" id="2b3058da-ac00-4bc4-b378-d676aed60cbf">
        <source>startClassInitializerApp(pMyInitializeClassRequest: JSSCTInitializeClassRequest input);
/*
*/
vars
	proc: Process;  // JETkgd
	str: String;
begin
	self.monitor(self.class.name&amp;'::'&amp;method.name&amp;' ', MONITOR_DEBUG);
	if pMyInitializeClassRequest = null or
	   pMyInitializeClassRequest.applicationClass = null then
		return;
	endif;
	str := pMyInitializeClassRequest.applicationClass.String;
self.monitor(self.class.name&amp;'::'&amp;method.name&amp;' '&amp;pMyInitializeClassRequest.String, MONITOR_DEBUG);
self.monitor(self.class.name&amp;'::'&amp;method.name&amp;' '&amp;pMyInitializeClassRequest.applicationClass.String, MONITOR_DEBUG);
	//	only if we have NOT been asked to stop
	if not self.interruptProcessing then
//		app.startApplicationWithParameter("JSSChangeTrackingSchema", "JSSClassInitializer", pMyInitializeClassRequest);
		proc := app.startApplicationWithParameter("JSSChangeTrackingSchema", "JSSClassInitializer", pMyInitializeClassRequest); // JETkgd
		self.logMessage("JSSCTNibblerManager::startClassInitializerApp  Initializing " &amp; str);  // kgd
	endif;
// Enforce single threading of initializers and wait until it has finished
	while global.isValidObject(proc) = true do
		process.sleep(250);
	endwhile;
end;</source>
        <Parameter name="pMyInitializeClassRequest" type="JSSCTInitializeClassRequest" usage="input"/>
    </JadeMethod>
    <JadeMethod name="startedApplication" id="87668415-0288-43fd-9ea2-c896dfdae85a">
        <updating/>
        <source>startedApplication(pNotifyObject: JSSCTNotificationObject) updating;
/*
		This method is initiated by the JSSChangeTracker application

		It is passed a shared transient notification object to be used to communicate with the original nibbler app.
KC	15 April 2005 Added code before terminate to delete JSSCTAuditLogInterface.firstProcessTransientInstance;

Date		Who		Reason
03 Feb 2011	cnwrs1	PAR #25828 - using up too many licences
*/
vars
	currentAuditLogNumber: Integer;
	startingAuditLogNumber: Integer;
	iniFileAuditLogNumber: Integer;
	indx: Integer;
	result: Integer;
	notifierTA: JSSCTNotificationObjectTA;
	nibblerTA: JSSCTNibblerManagerTA;

	auditLogInterface: JSSCTAuditLogInterface;
begin
	on Exception do handleException(exception);
	on LockException do handleLockException(exception); // JETkgd 20/1/2004

	self.debug := app.getProfileStringAppServer(app.getIniFileNameAppServer(), "JSSChangeTracker", "Debug", 'false').Boolean;	//par 25828 cnwrs1 3 feb 2011

	self.monitor(self.class.name&amp;'::'&amp;method.name&amp;' ', MONITOR_DEBUG);
	if not self.tryLock(JSSCTSingleThreadingObject.lastInstance, Exclusive_Lock, Session_Duration, LockTimeout_Immediate) then	//par 25828 cnwrs1 3 Feb 2011
		self.monitor(self.class.name&amp;'::'&amp;method.name&amp;' terminate this process', MONITOR_DEBUG);
		terminate;
		return;
	endif;
	self.isStartedApplication := true;

	//	create a transient copy to do the notification building,
	//	attach a pointer to the shared transient instance,
	self.myNotificationObject := pNotifyObject.cloneSelf(true);
	self.myNotificationObject.setMySharedTransientInstance(pNotifyObject);
	self.myNotificationObject.setMyPersistentInstance(pNotifyObject.myPersistentInstance);

	create self.myJadeLog;
	self.myJadeLog.fileName := JSSChangeTrackerLog;

	//	save a pointer to the ChangeTracking root,
	self.myChangeTrackingRoot := JSSCTChangeTrackingRoot.firstInstance;

	//	save a pointer to my persistent instance
	self.myPersistentInstance := JSSCTNibblerManager.firstInstance;

	create self.myTA transient;
	self.myTA.myNibblerManager := self.myPersistentInstance;
	//	start the notifications on the persistent &amp; shared transient notification objects required for communicating
	self.beginNotification(self.myNotificationObject.myPersistentInstance, JSSCT_Nibbler_Note, Response_Continuous, 1);
	self.beginNotification(self.myNotificationObject.mySharedTransientInstance, JSSCT_Nibbler_Note, Response_Continuous, 2);

	//	increment the usage count
	create notifierTA transient;
	notifierTA.myNotificationObject := self.myNotificationObject.mySharedTransientInstance;
	notifierTA.usageCount := 1;
	notifierTA.sharedTransient := true;
	notifierTA.updateEntitySharedTransient();

	create nibblerTA transient;

	//	set the user and admin info on the process object for the Jade Monitor
	nibblerTA.trxUpdateProcessDisplay("JSS Change Tracker Checker V[" &amp; JSSCT_VERSION &amp; "]", PROCESS_ADMIN_INFO_CATCH_UP);

	self.myTitle := "Change Tracking Checker";
	self.state := "Initializing";
	//	send a Notification that I have started
	self.myNotificationObject.myPersistentInstance.causeEvent(JSSCT_Nibbler_Note, true, self.myNotificationObject.buildNibbler_Started(self));

	//	get any definitions for ignoring deletes of a class within a specified instance range
	self.checkForIniFileClasses(JSSCTAuditLogInterface.firstProcessTransientInstance); //rs may 2005

	//	check that we didn't crash part way through an audit log
	if not self.myPersistentInstance.lastAuditFileComplete then
		self.setState("Processing incomplete journal " &amp; self.myPersistentInstance.lastAuditFileNumber.String);
		self.currentErrorCode := 0;
		self.processAuditLog(self.myPersistentInstance.lastAuditFileNumber);
		if self.currentErrorCode &gt; 0 then
			self.setState("Terminating due to error.");
			//	decrement the usage count
			notifierTA.usageCount := -1;
			notifierTA.updateEntitySharedTransient();
			return;
		endif;
	endif;
	//	find the current audit log number
	create self.myDBAdminObject transient;
	currentAuditLogNumber := self.myDBAdminObject.getCurrentLogNumber() - 1;
	self.monitor(method.qualifiedName &amp; ' ' &amp; 'currentAuditLogNumber=' &amp; currentAuditLogNumber.String, MONITOR_DEBUG);
	self.monitor(method.qualifiedName &amp; ' ' &amp; 'lastAuditFileNumber=' &amp; self.myPersistentInstance.lastAuditFileNumber.String, MONITOR_DEBUG); //par 25828 cnwrs1 14 feb 2011
	self.myTitle := "Change Tracking Checker [" &amp; currentAuditLogNumber.String &amp; "]";
	//	check to see if there are any audit logs between the last one we
	//		successfully processed and the current one
	if currentAuditLogNumber &gt; self.myPersistentInstance.lastAuditFileNumber then
		startingAuditLogNumber := self.myPersistentInstance.lastAuditFileNumber + 1;
		self.monitor(method.qualifiedName &amp; ' ' &amp; 'startingAuditLogNumber=' &amp; startingAuditLogNumber.String, MONITOR_DEBUG);
		/*
			For existing systems, the current audit log number could be large,
			so let's start from the top and go backwards until we DON'T get a log,
			then go forward from there?
		*/
		if startingAuditLogNumber = 1 then
			self.monitor(method.qualifiedName &amp; ' ' &amp; ' startingAuditLogNumber must be 1', MONITOR_DEBUG);
			create auditLogInterface transient;
			auditLogInterface.myPersistentInstance := JSSCTAuditLogInterface.firstInstance;
			auditLogInterface.myNibblerManager := self;

			foreach startingAuditLogNumber in currentAuditLogNumber to 1 step -1 do
				result := auditLogInterface.openJournal(true, startingAuditLogNumber);
				if result = 0 then
					auditLogInterface.closeJournal(true);
				else
 //rs may 2005					auditLogInterface.closeJournal(true);
					//	check if there is an ini file option to override the starting journal number
					iniFileAuditLogNumber := app.getProfileStringAppServer(app.getIniFileNameAppServer(), "JSSChangeTracker", "StartingJournalNumber", '0').Integer;
					if iniFileAuditLogNumber &gt; 0 then
						//	if there is, make sure it is within the current range
						if iniFileAuditLogNumber &gt; startingAuditLogNumber and iniFileAuditLogNumber &lt;= currentAuditLogNumber then
							startingAuditLogNumber := iniFileAuditLogNumber;
						endif;
					endif;
					self.monitor("Starting initial journal processing at number " &amp; startingAuditLogNumber.String, MONITOR_ALWAYS);
					break;
				endif;
				process.sleep(0);
			endforeach;

			delete auditLogInterface;
		endif;
//		foreach indx in self.lastAuditFileNumber + 1 to currentAuditLogNumber do
		currentAuditLogNumber := self.myDBAdminObject.getCurrentLogNumber() - 1;
//		foreach indx in startingAuditLogNumber to currentAuditLogNumber do // kgd fix foreach behaviour
	    indx := startingAuditLogNumber; // kgd fix foreach behaviour
    	while indx &lt;= currentAuditLogNumber do // kgd fix foreach behaviour
			self.myTitle := "Change Tracking Checker [" &amp; currentAuditLogNumber.String &amp; "]";
			self.state := "Processing catch up journal";
			self.currentErrorCode := 0;
			self.processAuditLog(indx);
			if self.currentErrorCode &gt; 0 then
				self.setState("Terminating due to error.");
				//	decrement the usage count
				notifierTA.usageCount := -1;
				notifierTA.updateEntitySharedTransient();
				return;
			endif;
			process.sleep(0);
//			app.doWindowEvents(0);
			//	check if we have been asked to stop
			if self.interruptProcessing then
				break;
			endif;
			currentAuditLogNumber := self.myDBAdminObject.getCurrentLogNumber() - 1;
			indx := indx + 1; // kgd fix foreach behaviour
			if indx &gt;= currentAuditLogNumber then	//par 25828 cnwrs1 4 feb 2011
				nibblerTA.trxUpdateProcessDisplay("JSS Change Tracker Checker V[" &amp; JSSCT_VERSION &amp; "]", "Remove out of date Changes");
				//	remove any out of date changes
				self.setState("Removing out of date Changes");
				self.removeOutOfDateChanges();
				if self.interruptProcessing then
					break;
				endif;
				currentAuditLogNumber := self.myDBAdminObject.getCurrentLogNumber() - 1;
			endif;
    	endwhile; // kgd fix foreach behaviour
//		endforeach; // kgd fix foreach behaviour
	endif;
	//	set the user and admin info on the process object for the Jade Monitor
/*	//par 25828 cnwrs1 4 feb 2011
	nibblerTA.trxUpdateProcessDisplay("JSS Change Tracker Checker V[" &amp; JSSCT_VERSION &amp; "]", "Remove out of date Changes");

	//	remove any out of date changes
	self.setState("Removing out of date Changes");
	self.removeOutOfDateChanges();
*/	//par 25828 cnwrs1 4 feb 2011
	//	decrement the usage count
	notifierTA.usageCount := -1;
	notifierTA.updateEntitySharedTransient();

	self.setState("Completed");

epilog
	if self.isLockedByMe(JSSCTSingleThreadingObject.lastInstance) then	//par 25828 cnwrs1 3 Feb 2011
		self.unlock(JSSCTSingleThreadingObject.lastInstance); // JETkgd 20/1/2004
		if self.myNotificationObject &lt;&gt; null then	//par 25828 cnwrs1 3 Feb 2011
			//	send a Notification that I am terminating
			self.myNotificationObject.myPersistentInstance.causeEvent(JSSCT_Nibbler_Note, true, self.myNotificationObject.buildNibbler_Terminating(self));
		endif;
	endif;
	delete nibblerTA;
	delete self.myNotificationObject;
	delete self.myDBAdminObject;
	delete notifierTA;
	delete self.myTA;
	delete self.myJadeLog;
	delete JSSCTAuditLogInterface.firstProcessTransientInstance;
	terminate;
end;</source>
        <Parameter name="pNotifyObject" type="JSSCTNotificationObject"/>
    </JadeMethod>
    <JadeMethod name="startedClassInitializer" id="7c586fed-e926-473c-9a8b-855cf5354b04">
        <updating/>
        <source>startedClassInitializer(pInitializeClassRequest: JSSCTInitializeClassRequest) updating;
/*
		This method is initiated by the JSSClassInitalizer application

		It is passed a shared transient object containing the user application schema, the class to initialize
		and the shared transient notification object to be used to communicate with the original nibbler app.
KC	15 April 2005 Added code prior to terminate to delete JSSCTAuditLogInterface.firstProcessTransientInstance;
*/
vars
	class: Class;
	className: String;
	schemaName: String;
	notifierTA: JSSCTNotificationObjectTA;
begin
	on Exception do handleException(exception);
	on LockException do handleLockException(exception); // JETkgd 20/1/2004

	self.monitor(self.class.name&amp;'::'&amp;method.name&amp;' ', MONITOR_DEBUG);
	self.debug := app.getProfileStringAppServer(app.getIniFileNameAppServer(), "JSSChangeTracker", "Debug", 'false').Boolean;	//par 25828 cnwrs1 3 feb 2011

	self.isStartedApplication := true;

	self.lastAuditFileNumber := 0;
	self.lastAuditFileComplete := false;
	self.lastAuditFileTimeStamp := app.actualTimeServer;
	self.lastAuditFileSequence := 0;

	//	create a transient copy to do the notification building,
	//	attach a pointer to the shared transient instance,
	self.myNotificationObject := pInitializeClassRequest.myNotificationObject.cloneSelf(true);
	self.myNotificationObject.setMySharedTransientInstance(pInitializeClassRequest.myNotificationObject);
	self.myNotificationObject.setMyPersistentInstance(pInitializeClassRequest.myNotificationObject.myPersistentInstance);

	create self.myJadeLog;
	self.myJadeLog.fileName := JSSChangeTrackerLog;

	//	save a pointer to the ChangeTracking root,
	self.myChangeTrackingRoot := JSSCTChangeTrackingRoot.firstInstance;

	//	save a pointer to my persistent instance
	self.myPersistentInstance := JSSCTNibblerManager.firstInstance;

	create self.myChangeObjectTA transient;
	self.myChangeObjectTA.myChangeTrackingRoot := self.myChangeTrackingRoot;
	create self.myChangeTrackingClassTA transient;
	self.myChangeTrackingClassTA.myChangeTrackingRoot := self.myChangeTrackingRoot;
	create self.myClassInitializeRequestTA transient;

	//	first, get all the classes that we are to IGNORE (clean out any old ones first)
	self.checkForIniFileIgnores(null);

	create self.myTA transient;
	self.myTA.myNibblerManager := self.myPersistentInstance;
	//	start the notifications on the persistent &amp; shared transient notification objects required for communicating
	self.beginNotification(self.myNotificationObject.myPersistentInstance, JSSCT_Nibbler_Note, Response_Continuous, 1);
	self.beginNotification(self.myNotificationObject.mySharedTransientInstance, JSSCT_Nibbler_Note, Response_Continuous, 2);

	//	increment the usage count
	create notifierTA transient;
	notifierTA.myNotificationObject := self.myNotificationObject.mySharedTransientInstance;
	notifierTA.usageCount := 1;
	notifierTA.sharedTransient := true;
	notifierTA.updateEntitySharedTransient();

	schemaName := pInitializeClassRequest.applicationSchema.name;
	className := pInitializeClassRequest.applicationClass;

	//	set the user and admin info on the process object for the Jade Monitor
	self.myChangeObjectTA.trxUpdateProcessDisplay("JSS Class Initializer V[" &amp; JSSCT_VERSION &amp; "] " &amp; schemaName &amp; "." &amp; className, PROCESS_ADMIN_INFO_INITIALIZER);

	self.myTitle := "Change Tracking Initializer";
	self.state := "Initializing";
	//	send a Notification that I have started
	self.myNotificationObject.myPersistentInstance.causeEvent(JSSCT_Nibbler_Note, true, self.myNotificationObject.buildNibbler_Started(self));

	class := pInitializeClassRequest.applicationSchema.getClass(className);
	if class &lt;&gt; null then
		self.setState("Initializing class " &amp; pInitializeClassRequest.applicationClass);
		self.initializeClassChangeTracking(class);
	endif;
	self.myClassInitializeRequestTA.myInitializeClassRequest := pInitializeClassRequest;
	self.myClassInitializeRequestTA.deleteEntitySharedTransient();

	//	decrement the usage count
	notifierTA.usageCount := -1;
	notifierTA.updateEntitySharedTransient();

	self.setState("Completed");

epilog
	//	send a Notification that I am terminating
	self.myNotificationObject.myPersistentInstance.causeEvent(JSSCT_Nibbler_Note, true, self.myNotificationObject.buildNibbler_Terminating(self));

	delete self.myNotificationObject;
	delete self.myChangeObjectTA;
	delete self.myChangeTrackingClassTA;
	delete self.myClassInitializeRequestTA;
	delete notifierTA;
	delete self.myTA;
	delete self.myJadeLog;
	delete JSSCTAuditLogInterface.firstProcessTransientInstance;
	terminate;
end;</source>
        <Parameter name="pInitializeClassRequest" type="JSSCTInitializeClassRequest"/>
    </JadeMethod>
    <JadeMethod name="sysNotification" id="2a80f835-600e-40b7-bb6f-97bbfcba83aa">
        <updating/>
        <source>sysNotification(eventType: Integer; theObject: Object; eventTag: Integer) updating;
/*
*/
begin
//	self.monitor(self.class.name&amp;'::'&amp;method.name&amp;' ', MONITOR_DEBUG);
	if eventType = Object_Update_Event then
		if theObject = self.myPersistentInstance then
			self.lastAuditFileComplete := self.myPersistentInstance.lastAuditFileComplete;
			self.lastAuditFileNumber := self.myPersistentInstance.lastAuditFileNumber;
			self.lastAuditFileSequence := self.myPersistentInstance.lastAuditFileSequence;
			self.lastAuditFileTimeStamp := self.myPersistentInstance.lastAuditFileTimeStamp;
		endif;
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="34fdb270-aff0-4245-9f11-9bce357bc045">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
/*
KC	15 April 2005 Added code prior to terminate to delete JSSCTAuditLogInterface.firstProcessTransientInstance
*/

vars

begin
//	self.monitor(self.class.name&amp;'::'&amp;method.name&amp;' ', MONITOR_DEBUG);
	if eventTag = TIMER_INTERRUPT then

		//	check if we were asked to stop
		if self.interruptProcessing then
			delete JSSCTAuditLogInterface.firstProcessTransientInstance;
			terminate;
		endif;
	elseif eventTag = TIMER_SLEEPING then

		self.setState("Sleeping at " &amp; app.actualTimeServer.String);


	elseif eventTag = TIMER_NEXT_DAY then

		//	at the turn of each day we want to remove any out of date changes
		if app.actualTimeServer.date &gt; self.lastAuditFileTimeStamp.date then

			//	check if we have a "Catch Up" application already running
			if self.myStartedProcess &lt;&gt; null and global.isValidObject(self.myStartedProcess) then
				if self.myStartedProcess.node = process.node and 
				   self.myStartedProcess.adminInfo = self.PROCESS_ADMIN_INFO_CATCH_UP then
					//	"Catch Up" application already running which will do what we want when it finishes
					return;
				endif;
			endif;
			//	start application to process any outstanding journals, and clean up out of date changes
			self.checkForMissedAuditLogs();
		endif;
	endif;
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateEntity" id="d1793321-e429-4b23-9117-e27ebc7126e8">
        <updating/>
        <source>updateEntity(pNibblerManagerTA: JSSCTNibblerManagerTA) updating;
/*
*/
begin
	self.monitor(self.class.name&amp;'::'&amp;method.name&amp;' '&amp;pNibblerManagerTA.lastAuditFileNumber.String, MONITOR_DEBUG);
	self.lastAuditFileNumber := pNibblerManagerTA.lastAuditFileNumber;
	self.lastAuditFileSequence := pNibblerManagerTA.lastAuditFileSequence;
	self.lastAuditFileTimeStamp := pNibblerManagerTA.lastAuditFileTimeStamp;
	self.lastAuditFileComplete := pNibblerManagerTA.lastAuditFileComplete;
	if pNibblerManagerTA.lastJade5Log &gt; 0 then
		self.lastJade5Log := pNibblerManagerTA.lastJade5Log;
	endif;
end;</source>
        <Parameter name="pNibblerManagerTA" type="JSSCTNibblerManagerTA"/>
    </JadeMethod>
    <JadeMethod name="userNotification" id="17b3ca2e-2695-4133-aba9-5be2000a7628">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*
KC	15 April 2005 Added code prior to terminate to delete JSSCTAuditLogInterface.firstProcessTransientInstance;

Date		Who		Reason
03 Feb 2011	cnwrs1	PAR #25828 - using up too many licences

*/

vars
	userNote: Integer;
	initializeClassRequest: JSSCTInitializeClassRequest;
	waitCount: Integer;
	terminateWaitSeconds: Integer;
	processInfo: String;
	previousState: String;

	xmlDocument: JSSXmlDocument;
	rootElement: JSSXmlElement;
	processString: String;
begin
	self.debug := app.getProfileStringAppServer(app.getIniFileNameAppServer(), "JSSChangeTracker", "Debug", 'false').Boolean;	//par 25828 cnwrs1 3 feb 2011
	previousState := self.state;

	if eventTag = LOG_TRANSFER_TAG then

		//	wait a moment, so any backup processes get the journal file first
		process.sleep(2000);

		//	check if we have a "Catch Up" application already running
		if self.myStartedProcess &lt;&gt; null and global.isValidObject(self.myStartedProcess) then
			if self.myStartedProcess.node = process.node and
			   self.myStartedProcess.adminInfo = self.PROCESS_ADMIN_INFO_CATCH_UP then
				//	"Catch Up" application already running and will process this journal when it gets to it
				return;
			endif;
		endif;
		//	start application to process this journal
		self.checkForMissedAuditLogs();
	else

		//	unbust the userInfo string parameter
		self.myNotificationObject.decodeUserInfo(userInfo.String);
		userNote := self.myNotificationObject.eventType;

		if eventType = JSSCT_Nibbler_Note then

			//	process the notifications that can occur any time
			if userNote = JSSCT_Nibbler_Calling then

				//	send a respond notification that I am running
				self.myNotificationObject.myPersistentInstance.causeEvent(JSSCT_Nibbler_Note, true, self.myNotificationObject.buildNibbler_Respond(self));

			elseif userNote = JSSCT_Nibbler_Bounce then

				if not self.isStartedApplication then
					//	send a Notification to my shared transient instance to stop any started transaction
					self.myNotificationObject.mySharedTransientInstance.causeEvent(JSSCT_Nibbler_Note, true, self.myNotificationObject.buildNibbler_Terminate(null));

					process.sleep(2000);
					unlock(self.myPublicInterface.mySingleThreader);

					//	start an application the same as myself, then self terminate
					app.startApplication(currentSchema.name, app.name);
					delete JSSCTAuditLogInterface.firstProcessTransientInstance;
					terminate;
				endif;
			elseif userNote = JSSCT_Nibbler_RaiseAlert then

				/*
					We have had a serious problem, so we must throw up our hands and die
				*/
				if self.myPublicInterface &lt;&gt; null then
					self.myPublicInterface.raiseAlert(self.myNotificationObject.paramOne, self.myNotificationObject.paramTwo);
				endif;
				//	send a Notification to my shared transient instance to stop any started transactions and terminate
				self.myNotificationObject.mySharedTransientInstance.causeEvent(JSSCT_Nibbler_Note, true, self.myNotificationObject.buildNibbler_Terminate(null));

			elseif userNote = JSSCT_Nibbler_Terminate then

				if self.myNotificationObject.paramOne = null or self.myNotificationObject.paramOne = process.getOidString() then

					if not self.isStartedApplication then

						//	send a Notification to my shared transient instance to stop any started transaction
						self.myNotificationObject.mySharedTransientInstance.causeEvent(JSSCT_Nibbler_Note, true, self.myNotificationObject.buildNibbler_Terminate(null));

						processInfo := process.userInfo;
						//	if a general call to stop, make sure any started tasks have also stopped
						//	otherwise, if specifically told to stop, then stop immediately
						if self.myNotificationObject.paramOne = null then
							terminateWaitSeconds := app.getProfileStringAppServer(app.getIniFileNameAppServer(), "JSSChangeTracker", "TerminateWaitSeconds", "30").Integer;
							while self.myNotificationObject.mySharedTransientInstance.usageCount &gt; 1 do
								process.sleep(2000);
								self.sharedLock(self.myNotificationObject.mySharedTransientInstance);
								self.unlock(self.myNotificationObject.mySharedTransientInstance);
								waitCount := waitCount + 1;
								//	set the user and admin info on the process object for the Jade Monitor
								self.myTA.trxUpdateProcessDisplay(processInfo &amp; "...Terminating " &amp; self.myNotificationObject.mySharedTransientInstance.usageCount.String &amp; " (" &amp; (waitCount * 2).String &amp; ")", process.adminInfo);
								self.setState(process.userInfo);
								//	wait a maximum of one minutes - 30 * 2 second sleeps
								if waitCount &gt; terminateWaitSeconds then
									break;
								endif;
							endwhile;
						endif;
						//	send message to monitor that we are terminating
						self.monitor(Nibbler_Title &amp; " Terminating.", MONITOR_ONLY);
						self.setState(Nibbler_Title &amp; " Terminating.");

						//	send a respond notification that I am stopping
						self.myNotificationObject.myPersistentInstance.causeEvent(JSSCT_Nibbler_Note, true, self.myNotificationObject.buildNibbler_Terminating(self));
						delete JSSCTAuditLogInterface.firstProcessTransientInstance;
						terminate;

					elseif self.isStartedApplication then

						self.setState("Interrupted");
						//	send message to monitor that we are terminating
						self.monitor("Change Tracking Checker application Interrupted...", MONITOR_ALWAYS);
						//	set the user and admin info on the process object for the Jade Monitor
						self.myTA.trxUpdateProcessDisplay(process.userInfo &amp; "...Interrupted", process.adminInfo);

						self.interruptProcessing := true;

					endif;
				endif;
			endif;
		elseif userNote = JSSCT_Nibbler_Terminating then
			if not self.isStartedApplication then
				create xmlDocument transient;
				xmlDocument.parseDocument(self.myNotificationObject.paramOne);
				rootElement := xmlDocument.myRootElement;
				if rootElement &lt;&gt; null then
					processString := rootElement.allChildElementsByName["process"].tagValue;
					if self.myStartedProcessString = processString then
						self.myStartedProcess := null;
						self.myStartedProcessString := null;
					endif;
				endif;
				delete xmlDocument;
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</Class>
