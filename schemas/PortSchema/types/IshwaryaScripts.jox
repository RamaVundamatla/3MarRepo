    <JadeMethod name="initialInstall_ExportImport" id="b9031887-ec2a-466c-bbd5-aa3d54c4c9e5">
        <source>initialInstall_ExportImport();
// ============================================================================
// SCRIPT: initialInstall_ExportImport.jade
// ============================================================================
// PURPOSE: First-time setup of export/import registry
// WHEN TO RUN: During new system installation
// ============================================================================

vars
    maintAgent: CM_ExportImportMaintenanceAgent;
    startTime, endTime: TimeStamp;
begin
	app.initialize();
    write "+----------------------------------------------------------------+";
    write "? Export/Import Registry - Initial Installation                 ?";
    write "+----------------------------------------------------------------+";
    write "";
    write "System: " &amp; app.myRoot.client;
    
    startTime := app.actualTimeAppServer;
    write "Start Time: " &amp; startTime.String;
    write "";
    
    // Create maintenance agent
    create maintAgent transient;
	
	/*beginTransaction;
		app.myRoot.allExportImportClasses.purge();
	commitTransaction;*/
	// Populate registry
	maintAgent.maintainExportImportClasses();
	
	write "";
	write "? Registry initialization completed successfully";

epilog
	 delete maintAgent;
	
	endTime := app.actualTimeAppServer;
	write "";
	write "End Time: " &amp; endTime.String;
	write "Duration: " &amp; (endTime - startTime).String;
end;</source>
    </JadeMethod>
    <JadeMethod name="purgeClasses" id="4e2a2071-5dc9-4ede-83ee-4da6865f37c0">
        <source>purgeClasses();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 January 2026	naviv1	Initial creation

*/

vars

begin
	beginTransaction;
		app.myRoot.allExportImportClasses.purge();
		CM_ExportImportProperty.instances.purge();
	commitTransaction;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="releaseUpgrade_ExportImport" id="e1f0edf9-987d-4106-82dd-f2b0caffdacd">
        <source>releaseUpgrade_ExportImport();
// ============================================================================
// SCRIPT: releaseUpgrade_ExportImport.jade
// ============================================================================
// PURPOSE: Syncs registry with code changes (new release)
// WHEN TO RUN: After schema upgrade, before system restart
// ============================================================================

vars
    maintAgent: CM_ExportImportMaintenanceAgent;
    exportClass: CM_ExportImportClass;
    beforeCount, afterCount: Integer;
    startTime, endTime: TimeStamp;
    changesDetected: Boolean;
begin
	app.initialize();
    write "+----------------------------------------------------------------+";
    write "? Export/Import Registry - Release Upgrade                      ?";
    write "+----------------------------------------------------------------+";
    write "";
    write "System: " &amp; app.myRoot.client;
    write "Release: " &amp; app.myRoot.version.String;
    
    startTime := app.actualTime;
    write "Start Time: " &amp; startTime.String;
    write "";
    
    // Count classes before
    beforeCount := app.myRoot.allExportImportClasses.size;
    write "Classes Before Upgrade: " &amp; beforeCount.String;
    write "";
    
    // Create maintenance agent
    create maintAgent transient;

        // Sync registry (handles add/update/delete)
        maintAgent.maintainExportImportClasses();
        
        // Count classes after
        afterCount := app.myRoot.allExportImportClasses.size;
        
        write "";
        write "Classes After Upgrade: " &amp; afterCount.String;
        
        // Detect changes
        changesDetected := (afterCount &lt;&gt; beforeCount);
        
        if changesDetected then
            write "";
            write "? Registry upgraded successfully";
            write "  Net Change: " &amp; (afterCount - beforeCount).String &amp; " classes";
        else
            write "";
            write "? Registry verified - no changes needed";
        endif;
        
        write "";
        write "Current Exportable Classes:";
        write "--------------------------------------------------------------";
        
        // List all exportable classes
        foreach exportClass in app.myRoot.allExportImportClasses do
            if exportClass.isExportable then
                write "  ? " &amp; exportClass.displayName.padBlanks(40) &amp; 
                    " [" &amp; exportClass.category &amp; "]" &amp;
                    " (" &amp; exportClass.allProperties.size.String &amp; " props)";
            endif;
        endforeach;
        
  
epilog
	delete maintAgent;
			
	endTime := app.actualTime;
	write "";
	write "End Time: " &amp; endTime.String;
	write "Duration: " &amp; (endTime - startTime).String; 
end;</source>
    </JadeMethod>
</Class>
