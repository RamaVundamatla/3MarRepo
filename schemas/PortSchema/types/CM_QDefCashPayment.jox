    <JadeMethod name="createProperties" id="9b8dde55-e1a3-4da9-b822-866a16b2d6ea">
        <source>createProperties();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2014	cnwndl1	Initial creation	Par 34142
16/06/2014	cnwjre1	34364 rename some of the attributes and set needToUpperCase
*/

vars

	tmpProp		: CM_QueryProperty;
	
begin

	inheritMethod();
	
	//business unit
	create tmpProp as CM_QStrBusinessUnitMethod persistent;
	tmpProp.set('Business Unit', CM_CashPayment::getBankCode.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//debtor name
	create tmpProp as CM_QRefDebtorMethod persistent;
	tmpProp.set('Debtor', CM_CashPayment::getDebtor.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//vessel
	create tmpProp as CM_QStrVesselMethod persistent;
	tmpProp.set('Vessel', CM_CashPayment::getVesselName.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//voyage
	create tmpProp as CM_QStrVoyageMethod persistent;
	tmpProp.set('Voyage', CM_CashPayment::getVoyageCode.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
