    <JadeMethod name="createLanePosition" id="1abbea35-c9d7-4cea-ba8b-0e2fa32a9362">
        <source>createLanePosition(_mode : Integer; _locnCode : String; _lengthDecimetres : Integer) : CM_ROROLanePositionDefn;
/*
Purpose:			
Date		Who		Reason
06 December 2011	cnwab1	Initial creation
*/

vars
	lanePos : CM_ROROLanePositionDefn;
begin
	
	if self.isTransient then 
		create lanePos transient;
	else
		create lanePos persistent;
	endif;

	lanePos.setFromLaneController(self, _mode,_locnCode,_lengthDecimetres);
	
	return lanePos;
epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_locnCode" type="String"/>
        <Parameter name="_lengthDecimetres" type="Integer"/>
        <ReturnType type="CM_ROROLanePositionDefn"/>
    </JadeMethod>
    <JadeMethod name="createUpdateRORORequest" id="71cf7fd5-1c3f-4a03-a718-e9c03edd15e3">
        <updating/>
        <source>createUpdateRORORequest(_isLoad : Boolean; _voyAlloc : CM_VoyageAllocation; _numItems : Integer; _moveType : Integer; _fwdSlot : CM_VoyageROROController; _passport : CM_Passport input): CM_RORORequest updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 December 2009	cnwas3	Initial creation
21/11/11 - Added _fwdSlot - PAR 28585
*/

vars
	theLinkedRequest,
	pxyRequest,
	realRequest	: CM_RORORequest;
	tmpSlot,
	theLinkedSlot	: CM_VoyageROROController;
	theTI			: CM_TrackedItem;
	theMoveType		: Integer;
	tmpVoyage		: CM_Voyage;
	isCreate,
	needAftRequest	: Boolean;
	lanePos : CM_ROROLanePositionDefn;
	lanePosLC : CM_ROROLanePositionController;
begin

	tmpVoyage := self.myVoyage;

	// PAR 28479
	theMoveType := _moveType;
	
	if theMoveType = NULL_MOVETYPE then
		if _isLoad then
			theMoveType := LOAD_MOVETYPE;
		else
			theMoveType := DISCHARGE_MOVETYPE;
		endif;
	endif;
	
	   
	realRequest := null;
	isCreate := true;

	// ### Each colour coding request has its own DEFN and LC. We DO NOT use this LC
	lanePos := self.createLanePosition(ShpDisplayMode_ColCodeLoad, null, 0);
	lanePosLC := lanePos.myLanePositionController;
	
	// we need to create a request
	create pxyRequest as self.getRequestClass() transient;
	pxyRequest.setProxyForCreateVA(lanePosLC, theMoveType, _isLoad,_numItems,_voyAlloc);	// PAR 28479	- theMoveType
	
	if _passport.hasErrors then
		// something went wrong in the above set
		return null;
	endif;

	app.myUtilityCA.utlCreateSlotRequestRORO(pxyRequest, realRequest, _passport);
	
	
	return realRequest;

epilog
	delete pxyRequest;
end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_voyAlloc" type="CM_VoyageAllocation"/>
        <Parameter name="_numItems" type="Integer"/>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_fwdSlot" type="CM_VoyageROROController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_RORORequest"/>
    </JadeMethod>
