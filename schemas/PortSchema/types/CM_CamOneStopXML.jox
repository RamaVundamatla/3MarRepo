    <JadeMethod name="addMessage" id="1116d5ae-2cc0-4b32-8c05-45c391c538da">
        <source>addMessage( _anArray : HugeStringArray input; _aString : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 August 2016	cnwndl1	Initial creation	TFS 2277 / 2561

*/

vars
	msgLength :Integer;	
	theString : String;
begin
	theString := _aString;
	msgLength := theString.length;
	
	while msgLength &gt; 2047 do
		_anArray.add(theString[1:2047]);	
		theString := theString[2048:msgLength];
		msgLength := theString.length;
	endwhile;
	
	_anArray.add(theString);
end;</source>
        <Parameter name="_anArray" type="HugeStringArray" usage="input"/>
        <Parameter name="_aString" type="String"/>
    </JadeMethod>
    <JadeMethod name="addXMLLinesToGroup4" id="9402b7e3-8b87-434a-903f-5d7086ca1c5b">
        <source>addXMLLinesToGroup4( _anArray : HugeStringArray input; _aString : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 September 2016	cnwndl1	Initial creation	TFS 2276 / 2565

*/

vars

	str : String;
	pos : Integer;
	startStr : String;
	endStr : String;

begin

	str :=  _aString;
	
	while true do
		if str = null then
			break;
		endif;
		pos := str.pos(CrLf,1);
		if pos &gt; 1 then
			startStr := str[ 1 : pos - 1 ];
			if pos = str.length then
				endStr := null;
			else
				endStr := str[ pos + 2 : end ];
			endif;
		else
			if str.length &lt; 512 then
				startStr := str;
				endStr := null;
			else
				startStr := str[ 1 : 511 ];
				endStr := str[ 512 : end ];
			endif;
		endif;
		_anArray.add(startStr);
		str := endStr;
	endwhile;

epilog

end;</source>
        <Parameter name="_anArray" type="HugeStringArray" usage="input"/>
        <Parameter name="_aString" type="String"/>
    </JadeMethod>
    <JadeMethod name="availableCargoTypes" id="98c65181-c0a6-4cea-a04d-a87836654524">
        <source>availableCargoTypes(_classColl: ClassColl input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 August 2016	cnwndl1	Initial creation	TFS 2277 / 2561

*/

vars

begin
	inheritMethod(_classColl);
	
	_classColl.add(CM_TrackedItem);
	_classColl.add(CM_BreakBulk);
	_classColl.add(CM_BreakBulkGeneric);
	_classColl.add(CM_Bulk);
	_classColl.add(CM_Car);
	_classColl.add(CM_LCL);
	_classColl.add(CM_Timber);
	_classColl.add(CM_ClipOnUnit);
	_classColl.add(CM_Generator);
	_classColl.add(CM_TILC);

epilog

end;</source>
        <Parameter name="_classColl" type="ClassColl" usage="input"/>
    </JadeMethod>
    <JadeMethod name="availableEvents" id="36623f98-7dd4-4b81-8012-83dc89a0281e">
        <source>availableEvents(_eventList: IntegerArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 August 2016	cnwndl1	Initial creation

*/

vars
	eventType : CM_EventType;
	iter : Iterator;
begin
	
	iter:=app.myRoot.allEventTypesByCategory.createIterator;
	app.myRoot.allEventTypesByCategory.startKeyGeq(CM_EventType.VOYAGE_EVENT,null,iter);

	while iter.next(eventType) do
	
		if eventType.category = CM_EventType.SYSTEM_EVENT or
			eventType.category = CM_EventType.WARNING_EVENT then
			continue;
		endif;
		
		if eventType.category &lt;&gt; CM_EventType.VOYAGE_EVENT then
			break;
		endif;
		
		_eventList.add(eventType.type);
		
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_eventList" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="availableTransactions" id="511e68eb-cd0a-4a28-9359-031c14ea4b5c">
        <source>availableTransactions(_classColl: ClassColl input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 August 2016	cnwndl1	Initial creation

*/

vars

	schema : Schema;
	class : Class;
	subs : ClassColl;
	skip : Boolean;

begin

	schema := currentSchema;
	
	while schema.name &lt;&gt; "PortSchema" do
		schema := schema.superschema;
	endwhile;
	
	class := schema.getClass( CM_TITransaction.name );
	
	create subs transient;
	//class.getSubclasses( subs );
	class.allSubclasses( subs );
	
	on Exception do self.handle70084(exception,skip);
	
	foreach class in subs do
		skip := false;
		global.getTiTxnTypeForClass( class ); // some old trans hanging around with no proper type.
		if skip then
			continue;
		endif;
		_classColl.add(class);
	endforeach;

epilog

	delete subs;

end;
</source>
        <Parameter name="_classColl" type="ClassColl" usage="input"/>
    </JadeMethod>
    <JadeMethod name="buildEventFile" id="71cbd43f-8ba0-4ce3-b41e-246fd4ce32c0">
        <updating/>
        <source>buildEventFile(_camProtocol: CM_CamProtocol input; _camAgent: CM_CamControllerAgent input; _seqNumber: Integer; _unhSeqNumber: Integer io; _terminal: CM_Terminal) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Sep 2016	cnwndl1	Initial creation
09 Jan 2020	jlgdap1	TFS 48016 SNO Deletion CODECO - change of signature for app.myTrxUA.trxSetupCamTaskHistory
*/

vars
	allEventTrans	: CM_EventTransByDateTime;
	seqNo			: Integer;
	transaction		: CM_EventTransaction;
    camFile         : CM_CamFile;
	camTaskHistory	: CM_CamTaskHistory;
	startTS, endTS	: TimeStamp;
	iter			: Iterator;
	daysToLookBack	: Integer;
	trProcessDateTime	: TimeStamp;
	logExcludedTransaction	: Boolean;
	isFirstTime : Boolean;

begin
	seqNo			:= _seqNumber;
	iter 			:= _terminal.allEventTransactionsByCamsTS.createIterator;
	startTS					:= _camAgent.startDateTime;	
	endTS					:= _camAgent.endDateTime;	
	logExcludedTransaction	:= _camAgent.logExcludedTransactions;

	create allEventTrans transient;
	create camFile transient;	
	_terminal.allEventTransactionsByCamsTS.startKeyGeq(startTS, iter);

	while iter.next(transaction) do
		if transaction.camsTimeStamp &gt; endTS then
			break;
		endif;
		// makes sense to exclude transaction of the incorrect type 1st
		if not self.includeEvent(transaction, _camProtocol,  _camAgent) then
			continue;
		endif;
		if not transaction.isValidForCamsProcess(startTS, daysToLookBack, trProcessDateTime) then 	// par 15375
			if logExcludedTransaction then
				_camAgent.logReasonForExclusion (transaction, 'Event transaction was created prior to CAMS start date/time');
			endif;
			continue;
		endif;
		
		if not self.isEventTypeToBeProcessed(_camProtocol, transaction) then
			if logExcludedTransaction then
				_camAgent.logReasonForExclusion (transaction, 'Event transaction type does not match CAM proctocol event types');
			endif;
			continue;
		endif;
		
		// we want it
		allEventTrans.add(transaction);

	endwhile;

	if allEventTrans.size = 0 then	// Nothing found 
		app.writeLog(_camProtocol.code &amp; " no events found", LogWARN);
		return;
	endif;
	
	// Process the transactions
	// Create one file for EACH transaction
	isFirstTime := true;
	foreach transaction in allEventTrans do			// These are now in date seq
		
		self.processEvent(transaction, _camProtocol, _camAgent, camFile);

		if camFile.camVoyages.size &gt; 0 then
			if not isFirstTime then
				self.createNextCamTaskHistory(_camAgent, _camProtocol, seqNo);
			endif;
			isFirstTime	:= false;
		
			//app.myTrxUA.trxSetupCamTaskHistory(_camProtocol, _camAgent, camFile, _camAgent.runDateTime, camTaskHistory, _unhSeqNumber, seqNo, _terminal, null, null);		// TFS 48016
			app.myTrxUA.trxSetupCamTaskHistory(_camProtocol, _camAgent, camFile, _camAgent.runDateTime, camTaskHistory, _unhSeqNumber, seqNo, _terminal, null, null, null);	// TFS 48016
			camFile.clear();
			seqNo := seqNo + 1;
			
			if seqNo &gt; 9999 and ( seqNo mod 10000 = 0 ) then	//16 Feb 2017	NDL	TFS 3454
				//File name uses this number, and only allowed to be 4 digits for OneStop.  Dont want number "0000"
				seqNo := seqNo + 1;
			endif;
			_camAgent.setProcessSeqNumber(seqNo);
		endif;
	endforeach;

epilog

	delete allEventTrans;
    delete camFile;
	delete iter;
	
end;</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol" usage="input"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_unhSeqNumber" type="Integer" usage="io"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="buildFile" id="0b511af8-57f2-40dc-a4d9-d59995eed396">
        <updating/>
        <source>buildFile(_camProtocol: CM_CamProtocol input; _camAgent: CM_CamControllerAgent input; _seqNumber: Integer; _unhSeqNumber: Integer io; _terminal: CM_Terminal) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Aug 2016	cnwndl1	Initial creation
09 Jan 2020	jlgdap1	TFS 48016 SNO Deletion CODECO - change of signature for app.myTrxUA.trxSetupCamTaskHistory
12 Mar 2020	jlgdap1	TFS 48785 SNO COARRI Issue - new parameter for CM_CamProtocolDesc includeTransaction
*/

vars
	camFile 				: CM_CamFile;
	camGroup				: CM_CamGroup;
	transaction 			: CM_TITransaction;
	camTaskHistory 			: CM_CamTaskHistory;
	startTS, endTS			: TimeStamp;
//	coll					: CM_TITransactionByDateTypeDict;
	coll					: CM_TITransactionByDtOrdTiDict;	//13 Aug 2020	NDL	TFS 49876
	typeColl				: IntegerArray;
	iter 					: Iterator;
	logExcludedTransaction	: Boolean;		
	str						: String;
	type					: Integer;
	seqNo					: Integer;
	isFirstTime				: Boolean;
	
begin

	seqNo := _seqNumber;

    self.buildEventFile(_camProtocol, _camAgent, seqNo, _unhSeqNumber, _terminal);
	
	seqNo := _camAgent.processSeqNumber;
	if seqNo = _seqNumber then
		isFirstTime := 	true;
	endif;
   
	create camFile transient;
	create coll transient;
	
	camGroup				:= _camProtocol.camGroup;				
	startTS					:= _camAgent.startDateTime;				
	endTS					:= _camAgent.endDateTime;				
	logExcludedTransaction	:= _camAgent.logExcludedTransactions;	
	
	iter 	:= _terminal.allTITransactionsByCamsTS.createIterator();

	create typeColl transient;
	
	self.getTransactionTypesToProcess (_camProtocol, typeColl);
	
	// build up colection with all transactions os required type/dates in a collection
	foreach type in typeColl do
		// str in the transaction type (integer)
		iter.reset;
		
		_terminal.allTITransactionsByCamsTS.startKeyGeq(type, startTS, iter);
		
		while iter.next (transaction) do
			if transaction.type &lt;&gt; type or
				transaction.camsTimeStamp &gt; endTS then 
				break;
			endif;
			
			coll.add (transaction);
		endwhile;
	endforeach;
	
	if not typeColl.includes(TRANS_TYPE_MOVE) then
		//need to consider any moves that are actually logical deletes. 
		iter.reset;
		_terminal.allTITransactionsByCamsTS.startKeyGeq(TRANS_TYPE_MOVE, startTS, iter);
		while iter.next (transaction) do
		//	if transaction.type &lt;&gt; type or
			if transaction.type &lt;&gt; TRANS_TYPE_MOVE or	//04 May 2017	NDL	TFS 4320
				transaction.camsTimeStamp &gt; endTS then 
				break;
			endif;
			
			if not transaction.CM_Move.isToDeleteArea then
				continue;
			endif;
			
			coll.add (transaction);
		endwhile;
	endif;
	
	delete iter;
	
	iter := coll.createIterator;
	
	while iter.next(transaction) do		
		// makes sense to exclude transaction of the incorrect type 1st
		if self.includeTransaction (transaction, transaction.camsTimeStamp, startTS, endTS, 
									_camProtocol, camGroup, _camAgent, logExcludedTransaction, null) then	// TFS 48785
			
			if self.isTransactionToBeProcessed(_camProtocol, transaction, _camAgent) then 		
			
				if not isFirstTime then
					self.createNextCamTaskHistory(_camAgent, _camProtocol, seqNo);	
				endif;
				
				isFirstTime := false;
				
				if _camAgent.logIncludedTransactions then
					_camAgent.logReasonForInclusion(transaction, "Transaction is correct time period and in Transaction Type list [" &amp; transaction.String &amp; "]");
				endif;
				self.processTransaction(transaction, _camProtocol, _camAgent, camFile);				
			//	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' tr='&amp;transaction.String&amp;' ti='&amp;transaction.myTrackedItem.String&amp;' '&amp;transaction.myTrackedItem.id, LogDebug3);
				
				//app.myTrxUA.trxSetupCamTaskHistory(_camProtocol, _camAgent, camFile, _camAgent.runDateTime, camTaskHistory, _unhSeqNumber, seqNo, _terminal, null, null);		// TFS 48016
				app.myTrxUA.trxSetupCamTaskHistory(_camProtocol, _camAgent, camFile, _camAgent.runDateTime, camTaskHistory, _unhSeqNumber, seqNo, _terminal, null, null, null);	// TFS 48016
				camFile.clear();
				seqNo := seqNo + 1;
				
				if seqNo &gt; 9999 and ( seqNo mod 10000 = 0 ) then	//16 Feb 2017	NDL	TFS 3454
					//File name uses this number, and only allowed to be 4 digits for OneStop.  Dont want number "0000"
					seqNo := seqNo + 1;
				endif;
			
				_camAgent.setProcessSeqNumber(seqNo);					
			endif;
				
		endif;
		
	endwhile;
	
epilog

	delete camFile;
	delete iter;
	delete coll;
	delete typeColl;
	
end;</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol" usage="input"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_unhSeqNumber" type="Integer" usage="io"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="convertTStoUTC" id="e5231aaa-5913-4b4d-bf9a-e64b1d715847">
        <source>convertTStoUTC( _localTS : TimeStamp ) : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 August 2016	cnwndl1	Initial creation		TFS 2561 / 2277

*/

vars

	utc : TimeStamp;

begin
	utc := _localTS.systemToUTC;
	return utc;

epilog

end;</source>
        <Parameter name="_localTS" type="TimeStamp"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
