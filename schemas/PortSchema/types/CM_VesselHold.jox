    </JadeMethod>
    <JadeMethod name="setForUpdate" id="82102a0a-e85f-454f-b86c-efc7039a142c">
        <updating/>
        <source>setForUpdate(_proxy: SelfType) updating;
/*
 ------------------------------------------------------------------------
Created:			11 October 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars

begin
	inheritMethod(_proxy);
	self.myCellularVesselStructure := _proxy.myCellularVesselStructure;

end;</source>
        <Parameter name="_proxy" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="23cddb50-315f-4414-8f3c-0a7f02089019">
        <updating/>
        <source>setProxy(_myVessel : CM_CellularVesselStructure; _ordinalHold : Integer) updating;
/*
 ------------------------------------------------------------------------
Created:			11 October 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars

begin
	self.myCellularVesselStructure := _myVessel;
	self.ordinalHold := _ordinalHold;
end;</source>
        <Parameter name="_myVessel" type="CM_CellularVesselStructure"/>
        <Parameter name="_ordinalHold" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateOrdinalNoDups" id="c2bda5a3-8dd5-4d83-bdec-cb8f60054832">
        <updating/>
        <source>updateOrdinalNoDups(newHoldOrdinal : Integer) updating;
/*

Purpose:	updates ordinal - checks and updates duplicates before hand to 
			avoid duplicates

Parameters:			

Return Value:		

Date		Who		Reason
07 February 2013	cnwer1	Initial creation HAT 2189

*/

vars
	dupHold : CM_VesselHold;
begin
	dupHold:= self.myCellularVesselStructure.allHolds[newHoldOrdinal].CM_VesselHold;
	if dupHold &lt;&gt; null then
		dupHold.setOrdinalHold(dupHold.ordinalHold + CM_Bay.BayOrdinalOffset);
	endif;	
	self.setOrdinalHold(newHoldOrdinal);
epilog

end;</source>
        <Parameter name="newHoldOrdinal" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="66c65a87-c61e-403d-9b59-d11f27c556e0">
        <source>validateForUpdate();
/*
 ------------------------------------------------------------------------
Created:			11 October 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
// 09/12/2014 cnwdb2 PAR 35364

*/
vars

begin
	if self.myCellularVesselStructure.allHolds[self.ordinalHold] &lt;&gt; null then
	//	app.raiseCMException3(ERR_DUPLICATE_KEY,"Ordinal Hold",self.ordinalHold.String,null,null,null);
		app.raiseCMException1(Already_exists_ordinalHold,self.ordinalHold.String,null,null); // cnwdb2 PAR 35364
		return;
	endif;
	inheritMethod();

end;</source>
    </JadeMethod>
</Class>
