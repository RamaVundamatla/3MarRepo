    <JadeMethod name="verifyTransportMode" id="9665a8c3-3115-4e65-b982-5a9d443f775c">
        <source>verifyTransportMode() protected;
//
// 02 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
// 28 Nov 2024  navma1	MTN-19124 STWO - Uploading an EDI file 'freezes' MTN.
//
vars
	transportModeUpper : String;
begin
	
	transportModeUpper := self.transportMode.toUpper;				//28.11.2024 navma1 #MTN-19124
	
	if transportModeUpper = TI_TRANSMODE_NULL_STR.toUpper or
	   transportModeUpper = TI_TRANSMODE_ROAD_STR.toUpper or
	   transportModeUpper = TI_TRANSMODE_RAIL_STR.toUpper or
	   transportModeUpper = TI_TRANSMODE_SHIP_STR.toUpper or
	   transportModeUpper = TI_TRANSMODE_INTERNAL_STR.toUpper or
	   transportModeUpper = TI_TRANSMODE_PACKING_STR.toUpper  then
		return;
	endif;
	
	app.raiseCMWarning2(InvalidAttrForTransportMode, self.transportMode, null, ETRow_TransportMode, self, self);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
