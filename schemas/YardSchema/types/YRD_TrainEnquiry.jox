    <JadeMethod name="doSaveTrainArrive" id="659c8b48-e77a-404d-9435-a1dda7365c6f">
        <updating/>
        <source>doSaveTrainArrive() updating;
// ---------------------------------------------------------------------------
// Created:     31 July 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	pxyTrain : CM_Train;
	arrTS : TimeStamp;
	result : Integer;
begin

	arrTS.setDate(self.mskTrainArrDT.getDate());
	arrTS.setTime(self.mskTrainArrTM.getTime());
	
	pxyTrain := app.createUpdateProxy(self.myCurrentTrain).CM_Train;
	
	pxyTrain.setProxyDetails(arrTS);
	
	while true do
		app.myTrxUA.trxUpdateTrain(pxyTrain, false, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			return;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Train_update), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings); 
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		
		return;
	endwhile;
	
epilog
	delete pxyTrain;
end;</source>
    </JadeMethod>
    <JadeMethod name="doShowCargoReview" id="5bd79066-e4e8-4ff3-93be-fc4a909f4260">
        <source>doShowCargoReview();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/09/2023	navkc1	CR 60428 Task 60702: UI - Cargo Review Option in Transport UI

*/

vars
	cgReviewForm			: CMUI_CargoReview;
	criteriaLine			: CM_SelectorCriteriaLine;
	qdef					: CM_QueryDefinition;
	train					: CM_Train;
	sa						: StringArray;
	criteriaLines			: CM_SelectorCriteriaLineArray;
begin
	
	if self.tblData.allSelectedObjects.isEmpty() then
		return;
	endif;
	
	cgReviewForm := app.loadForm(CMUI_CargoReview, CMUI_Assistant, true, true, false, self.getMyTerminal(), null).CMUI_CargoReview;
	
	if cgReviewForm = null then
		return;
	endif;
	
	qdef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, CM_QueryDefinition.TrackedItem_Query_Mode];
	
	if qdef = null then
		return;
	endif;
	
	create criteriaLines transient;
	create sa transient;
	
	foreach train in self.tblData.allSelectedObjects as CM_Train do
		sa.add(train.getCodeDate());
	endforeach;
	
	criteriaLine := qdef.createCriteriaLine(CM_TrackedItem::getReceiveTrainCode.name, CM_QueryOperator.Operator_IsOneOf, sa);
	criteriaLines.add(criteriaLine);
	
	criteriaLine := qdef.createCriteriaLine(CM_TrackedItem::site.name, CM_QueryOperator.Operator_Equal, TI_SITE_ONSITE_str);
	criteriaLines.add(criteriaLine);
	
	cgReviewForm.createCriteriaLinesFromParent(criteriaLines);
	cgReviewForm.setParentForm(self);
	cgReviewForm.show();
	cgReviewForm.autoDoCustDocFromParent(); //23/02/2023	navkc1 CR 62580 Task 62581
epilog
	delete sa;
	delete criteriaLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSummarise" id="4f202080-66fe-426e-8b66-709edb652044">
        <source>doSummarise(_in : Boolean);
// ---------------------------------------------------------------------------
// Created:     28 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	train : CM_Train;
	wagon : CM_Wagon;
	obj : Object;
	objArray : CM_TIArray;
begin


	create objArray transient;
	
	foreach obj in self.tblData.allSelectedObjects discreteLock do
		train := obj.CM_Train;
		train.getAllTrackedItems(_in,objArray);
	endforeach;
	
	if objArray.isEmpty() then
		app.msgBox(app.getErrorString(No_Cargo_For_Train), app.getErrorString(Cargo_summary), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	self.myAssistant.showXTABSummaryDefinitionForm( objArray, false, false, false, true );
epilog
	delete objArray;
end;</source>
        <Parameter name="_in" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblDataClick" id="5963c1e6-28f6-46e3-a002-4cc36b6553b7">
        <updating/>
        <source>doTblDataClick(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:     29 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if table.row &lt;= table.CM_DataTable.fixedRows then
		return;
	endif;
	
	if table.CM_DataTable.allSelectedObjects.isEmpty then
		return;
	endif;
	
	self.myCurrentTrain := table.CM_DataTable.allSelectedObjects.first.CM_Train;
	
	self.doEnableForTrain(not self.myCurrentTrain.isNullTrain());
	if self.myCurrentTrain.isNullTrain() then
		self.btnNew.enabled := true;
	endif;
	
	// 26/01/2012 cnwar2 #28704
	self.mnuContextTrainPlan.enabled := not self.myCurrentTrain.isDeparted();
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnNew.enabled:= false;
		self.btnCopyTrain.enabled:= false;
		self.btnDelete.enabled:= false;
		self.btnAddRequest.enabled:= false;
		self.btnRemarks.enabled:= false;
	endif;
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblDataContextMenu" id="5d68defe-3f6d-4595-8b6d-d8dd119f74fc">
        <updating/>
        <source>doTblDataContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2009	cnwmd1	Initial creation

*/

vars
	rtnValue : Boolean;
begin

	rtnValue := self.doMnuContextBuild(cntrl, conwin, mouse,x,y);
	
	if rtnValue then
		return inheritMethod(cntrl, conwin, mouse,x,y);
	endif;
	
	return rtnValue;

epilog

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblDataDBClick" id="add90745-1aa0-4911-80bf-0fc369a90e0b">
        <updating/>
        <source>doTblDataDBClick(table: CM_DataTable input) updating;
// ---------------------------------------------------------------------------
// Created:     25 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	initObject		: CM_Train;
	row : Integer;
begin
	
	row := table.row;

	if table.row &lt;= table.fixedRows then
		inheritMethod(table);
		return;
	endif;
	
	initObject := self.tblData.accessRow(row).itemObject.CM_Train;
	if initObject = null then
		app.msgBox(app.getErrorString(Please_select_train_edit_first),app.getErrorString(No_Train_selected), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	
	self.myAssistant.showTrainMaintenance(initObject, self.myMasterMenuAction, YRD_TrainForm.Mode_View, self);
epilog
	app.mousePointer := MousePointer_Default;

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblDataDragDrop" id="97b1a0cc-7c18-4b1b-a42c-bf6f5c77d6f3">
        <updating/>
        <source>doTblDataDragDrop(table: Table input; win: Window input; x: Real; y: Real) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 Jun 2009	consw1	Initial creation

*/

vars
	theRow : Integer;
	train : CM_Train;
	
begin
	theRow := self.tblData.getRowFromY(y);
	if theRow &gt; self.tblData.fixedRows then
		train := self.tblData.accessRow(theRow).itemObject.CM_Train;
	endif;

	if app.myWagonMoveController &lt;&gt; null and self.wagonReceiveDrop(train) then
		return;
	endif;
	
	inheritMethod(table, win, x, y);

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doTrainConfirm" id="994fe6dc-9d3b-4915-aa67-017162b3c71b">
        <updating/>
        <source>doTrainConfirm(_inward : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     May 2009 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	autoPlan : Boolean;
	result	 : Integer;
	train : CM_Train;
	tmpStr : String;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	wagMoveController : CMIF_WagonMoveController;
	
begin
	train := self.tblData.allSelectedObjects.first.CM_Train;
	
	if train = null then	
		//app.msgBox('Please select a train to confirm first','No train selected', MsgBox_Exclamation_Mark_Icon);
		app.msgBox(app.getErrorString(Please_select_train_confirm),app.getErrorString(Train_confirmation), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	if _inward then
		tmpStr := app.getErrorString(Inward_Rail);
	else
		tmpStr := app.getErrorString(Outward_Rail);
	endif;
	
//	if app.msgBox('Are you sure that you want to confirm all wagons for train ' &amp;  &amp; ' onto the tracks?', "Train Confirmation", MsgBox_Question_Mark_Icon + MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
	if app.msgBox(app.getErrorString2(Confirm_Train_To_Tracks, self.myAssistant.displayEntryTrain(train), tmpStr),  tmpStr &amp; " " &amp; app.getErrorString(Train_confirmation), MsgBox_Question_Mark_Icon + MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
		return;
	endif;
	
	if _inward then
//	result := app.msgBox("Do you want the system to Autoplan the cargo?", "Auto Plan?", MsgBox_Question_Mark_Icon + MsgBox_Yes_No);
		result := app.msgBox(app.getErrorString(Want_system_autopla_cargo), app.getErrorString(AutoPlan), MsgBox_Question_Mark_Icon + MsgBox_Yes_No);
		if result = MsgBox_Return_Yes then
			autoPlan := true;
		endif;
	endif;
	
	//26 Feb 2021	NDL	TFS 50837
	create wagMoveController transient;
	wagMoveController.autoSetEffectiveTimeStamp();
	
	app.mousePointer := MousePointer_HourGlass;
	
	//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateWagonConfirmTrain(wagMoveController, _inward, train, autoPlan, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(app.getErrorString(Train_confirmation), app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
epilog
	delete wagMoveController;
	app.mousePointer := MousePointer_Default;				
end;</source>
        <Parameter name="_inward" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTrainDeparture" id="e9f1a9b9-6b74-4aad-beaf-7968b841d995">
        <updating/>
        <source>doTrainDeparture() updating;
// ---------------------------------------------------------------------------
// Created:     21 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	train : CM_Train;
	wagon : CM_Wagon;
	obj : Object;
	objSet : CM_TrainSet;
	theReturn : Integer;
	tmpStr : String;
begin

	app.mousePointer := Window.MousePointer_HourGlass;
	
	create objSet transient;
	
	foreach obj in self.tblData.allSelectedObjects discreteLock do
		train := obj.CM_Train;
		
		if train.myTerminalDeparted &lt;&gt; null then
			continue;
		endif;
		
		if tmpStr = null then
			tmpStr := train.code;
		else
			tmpStr := tmpStr &amp; ", " &amp; train.code;
		endif;
		objSet.add(train);
	endforeach;
	
	if objSet.isEmpty() then
		app.msgBox(app.getErrorString(Please_select_train), app.getErrorString(Departure_process), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
	else
		if app.msgBox(app.getErrorString1(Pleas_confi_that_want_proce_de, tmpStr), app.getErrorString(Departure_process), MsgBox_Question_Mark_Icon + MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
			return;
		endif;
		
		while true do
			app.myTrxUA.trxUpdateTrainsDeparture(objSet, app.myPassport);
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				global.beep;
				break;
			else
				theReturn := app.showErrorWarningDialog(app.getErrorString(Departure_process), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
				return;
			endif;
			break;
		endwhile;
	endif;

epilog
	delete objSet;
	app.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="getQueryCaption" id="2ac526e7-9c3b-4c09-8ac7-046b0b866f90">
        <source>getQueryCaption() : String;
// ---------------------------------------------------------------------------
// Created:     21 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 09 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------
constants
	Break = " | ";
vars
	tmpCaption, tmpCode, subCaption  : String;	
	arrTS, depTS : TimeStamp;
	tmpPort : CM_Port;
begin
	
	// ### CODE
	tmpCode := self.txtCode.text.trimBlanks();
	if tmpCode &lt;&gt; null then
		subCaption := app.getErrorString(Code) &amp; " '" &amp; tmpCode &amp; "'";
		if tmpCaption = null then
			tmpCaption := subCaption;
		else
			tmpCaption := tmpCaption &amp; Break &amp; subCaption;
		endif;
	endif;
	
	// ### ARRIVAL TIMESTAMP
	arrTS.setDate(self.mskArrivalDT.getDate());
	arrTS.setTime(self.mskArrivalTM.getTime());
	arrTS := self.localToSystemTime(arrTS);// 09 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	if arrTS.date.isValid() then
		subCaption := app.getErrorString(Arrival_date_time) &amp; " " &amp; arrTS.asStringJMT();
		if tmpCaption = null then
			tmpCaption := subCaption;
		else
			tmpCaption := tmpCaption &amp; Break &amp; subCaption;
		endif;
		
	endif;
	
	// ### DEPARTURE TIMESTAMP
	depTS.setDate(self.mskDepartureDT.getDate());
	depTS.setTime(self.mskDepartureTM.getTime());
	depTS := self.localToSystemTime(depTS);// 09 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	if depTS.date.isValid() then
		subCaption := app.getErrorString(Departure_date_time) &amp; " " &amp; depTS.asStringJMT();
		if tmpCaption = null then
			tmpCaption := subCaption;
		else
			tmpCaption := tmpCaption &amp; Break &amp; subCaption;
		endif;
		
	endif;
	
	// ### ORIGIN
	tmpPort := self.cmbOrigin.listObject.CM_Port;
	if tmpPort &lt;&gt; null then
		subCaption := app.getErrorString(Origin_port) &amp; " " &amp; tmpPort.code;
		if tmpCaption = null then
			tmpCaption := subCaption;
		else
			tmpCaption := tmpCaption &amp; Break &amp; subCaption;
		endif;
	endif;

	// ### DESTINATION
	tmpPort := self.cmbDestination.listObject.CM_Port;
	if tmpPort &lt;&gt; null then
		subCaption := app.getErrorString(Destination) &amp; " " &amp; tmpPort.code;
		if tmpCaption = null then
			tmpCaption := subCaption;
		else
			tmpCaption := tmpCaption &amp; Break &amp; subCaption;
		endif;
	endif;
	
	//Status
	//navsp1 17MAY2022 TFS#53619
	if self.cmbStatus.listIndex &gt; -1 then
		
		subCaption := app.getErrorString(Destination) &amp; " " &amp; self.cmbStatus.text;
		if tmpCaption = null then
			tmpCaption := subCaption;
		else
			tmpCaption := tmpCaption &amp; Break &amp; subCaption;
		endif;
	endif;
	
	//navsp1 17MAY2022 TFS#53619
	/*if self.chkIncludeOnSite.value then
		subCaption := app.getErrorString(YES_DEM_HERE_TRAINES);
		if tmpCaption = null then
			tmpCaption := subCaption;
		else
			tmpCaption := tmpCaption &amp; Break &amp; subCaption;
		endif;
	
	endif;
	*/
	//navsp1 24MAY2022 TFS#53619 - uncommented
	if self.chkDeparted.value then
		subCaption := app.getErrorString(YES_DEM_THERE_TRAINES);
		if tmpCaption = null then
			tmpCaption := subCaption;
		else
			tmpCaption := tmpCaption &amp; Break &amp; subCaption;
		endif;
	
	endif;
	
	return tmpCaption;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="8e85e8bd-977a-4325-8696-1650c8ecba99">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 November 2009	cnwas3	Initial creation

*/

