    <JadeMethod name="isLoggedIn" id="b01d5fd8-d6d7-4944-ac0e-b50b956c8bf4">
        <source>isLoggedIn(): Boolean;
// ---------------------------------------------------------------------------
// Created:		26 March 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
02 Apr 2008	cnwkpd1	PAR #16421 - Rework to remove extended share locking on JADE 
					system objects

*/

vars
//	theNodes 		: NodeDict;
//	aNode 			: Node;	
	aProcess 		: Process;
	invalidProcess	: Boolean;
	
begin
	on Exception do app.handleDeletedObject(exception, aProcess, invalidProcess);

	foreach aProcess in Process.instances do
		if aProcess.userCode.toUpper = self.code.toUpper then
			return true;	
		endif;
	endforeach;
	
	return false;
	
/*	PAR #16421 - old code replaced

	theNodes := system.nodes;

	foreach aNode in theNodes do
		foreach aProcess in aNode.processes do
			if aProcess.userCode.toUpper = self.code.toUpper then
				return true;	
			endif;
		endforeach;
	endforeach;

	return false;
*/
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isNewUser" id="56f46c2c-f01f-4e4c-bb75-0011da4ab8af">
        <source>isNewUser() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Dec 2025 navlc30 JIRA 36748 CUX - Enforce SSO Login

*/

vars

begin
	if self.status = NewUser or self.status  = PendingUser then
		return true;
	else
		return false;
	endif;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
