    <JadeMethod name="tCamCODECORoadRcvCancel" id="e048becc-2814-4fb5-a353-f5c14fac89c6">
        <source>tCamCODECORoadRcvCancel();
/*
Purpose: Test the following
		1. Info Edi Sent is generated for Road Receive Cancelled transaction when 
		   - Receive Road Cancel Transaction exist in Track Item and 
		   - Receive Road Transaction has been processed (Info EDI Sent)
		2. Modified entry and New entries (EDI Sent)
		   - (modified) BGM entry uses document type equal to 1 (cancellation) (not 34)
		   - (new entry) New RFF+ACW segment in the header section (before TDT)
		   - (new entry) New FTX+AA1+++&lt;Cacnellation Reason&gt; entry	
		
		Phase 1 - 
		   - create container
		   - create vehicle visit record
		   - run ADHoc Cam
		   Assert
		   
		Phase 2
		   - cancel the road job for the container
		   - run ADHoc Cam

		Case # 1 - Time Line
		|-- Gate In (1)--|-- CAMS EDI run (2)--|-- Road Job has been Deleted (3)--|-- CAMS EDI run (4)--|
		Expected
		- (1) Road Receive transaction created
		- (2) GATE-IN EDI Info sent created
		- (3) Road Receive transaction Deleted
			  Road Receive Cancelled transaction created
		- (4) GATE-IN Cancellation EDI created
		
		Case # 2 - Time Line (Current behaviour is not ideal becuase system still process Receive Road transaction eventhough it is deleted)
							 (Ideally, it should ignore logically deleted transaction)
		|-- Gate In (1)--|-- Road Job has been Deleted (2)--|-- CAMS EDI run (3)--|
		Ideal behaviour
		- (1) Road Receive transaction created		
		- (2) Road Receive transaction Deleted
			  Road Receive Cancelled transaction created
		- (3) no EDI messages to be sent out
		
Parameters:			

Return Value:		

Date		Who		TFS		Reason
05 Nov 2019	jlgdi1	46578	Initial creation
*/

constants
	Cam_Grp_UT = "UTGRP";
	Cam_Grp_UT_Desc = "UT RCV ROAD CANCEL";
	Recipient_UT = "UT RCPT";
	Sender_Terminal_UT = "UT_SNDR_TRMNL";
	Sender_Depot_UT = "UT_SNDR_DEPOT";
	Shipper_UT = "UT_SHPR";
	Facility_UT = "UT_FACILITY";
	Call_Sign_Not_Use = false;
	Voyage_Op_Not_Use = false;
	By_MMDD_Not_Use = false;
	Max_Seal_Length_5 = 5;
	Protocol_Codeco162 = "UT CODECO 162";
	Protocol_Codeco213 = "UT CODECO 213";
	ISO_CONTAINER = 1;	
	ContainerID1 = "ZZZZ1911051";
	ContainerID2 = "ZZZZ1911052";
	TruckID = "UTT123";
	DriverID = "UTD123";
	BGM_Identifier = "BGM";
	Msg_Func_Original : String = "9";
	Msg_Func_Cancellation : String = "1";
	Segment_FTXAAI : String = "FTX+AAI";
	Segment_RFFACW : String = "RFF+ACW";
	Voyage_UT = "UTVOY999";
	Vessel_UT = "UTVSL999";
	TruckID2 = "UTT124";
	
vars
	operatorDict : CM_OperatorByCodeDict;
	freightForwarders : CM_ConsigneeConsignorSet;
	operator : CM_Operator;
	camGroup : CM_CamGroup;
	camProtocol162 : CM_CamProtocol;
	camProtocol213 : CM_CamProtocol;
	rcvRoadCancelledTransNum : Integer;
	
	container1 : CM_TrackedItem;
	container2 : CM_TrackedItem;

	terminal : CM_Terminal;	
	gate : CM_Gate;
	vvr : CM_VehicleVisitRecord;
	vvr1 : CM_VehicleVisitRecord;
    gte : CMGTE_Entity;
	
	singleGate : CM_Gate;
	
	runDateTime : TimeStamp;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	
	camTaskHistory : CM_CamTaskHistory;
	
	yardWLE : CM_YardWLE;
	
	xmlDocA : JadeXMLDocument;
	infoEDISent : CM_InfoEDISent;
	tiTransaction : CM_TITransaction;
	theLines : HugeStringArray;
	actualXMLElements : JadeXMLElementArray;
	actual : String;
	xmlElement : JadeXMLElement;
	xmlNodeArray : JadeXMLNodeArray;
	xmlCDATA : JadeXMLCDATA;
	
	totalLines : Integer;
	arrayElement : JadeXMLElement;
	entryElement : JadeXMLElement;
	
	ediSentRcvRoad : CM_InfoEDISent;
	ediSentRcvRoadCancel : CM_InfoEDISent;
	
	tLinesRcvRoad : Integer;
	tLinesRcvRoadCancel : Integer;
	camVoyage : CM_CamVoyage;
	camMessage : CM_CamMessage;	
	infoLines : StringArray512;
	voyage : CM_Voyage;
	vessel : CM_Vessel;	
	passport : CM_Passport;
	
begin
	// Arrange
	passport := app.myPassport;	
	startDateTime := app.actualTimeServer;
	/* 1. Create CAM Group
	   2. Create CAM Protocol
	*/
	create operatorDict transient;
	create freightForwarders transient;
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	operatorDict.add(operator);
	
	self.deleteCamGroup(Cam_Grp_UT);
	camGroup := self.getCamGroup(Cam_Grp_UT);
	self.assertIsDeleted(camGroup);
	
	camGroup := self.addCamGroup(Cam_Grp_UT, 
								 Cam_Grp_UT_Desc, 
								 Recipient_UT, 
								 Sender_Terminal_UT, 
								 Sender_Depot_UT, 
								 Facility_UT, 
								 Call_Sign_Not_Use, 
								 By_MMDD_Not_Use, 
								 Voyage_Op_Not_Use, 
								 operatorDict, 
								 freightForwarders, 
								 Max_Seal_Length_5, 
								 Shipper_UT);
	self.assertNotNullMsg(camGroup, "Failed to create CAM Group");
	
	camProtocol162 := self.getCamProtocol(Protocol_Codeco162);
	self.assertIsDeleted(camProtocol162);
	camProtocol162 := self.createCamProtocolCodeco(Protocol_Codeco162,
												   camGroup,
												   "STANDARD CODECO SMDG162",
												   "NZCHC",
												   operator.code,
												   null,
												   true,
												   true);
	self.assertTrueMsg(camProtocol162.allRegisteredCargoTypes.includes(TI_CargoType_Container), "ISO Cargo Type Container is not registered");
	
	// Registered the transaction 'CM_ReceiveRoadCancelled' in the protocol
	rcvRoadCancelledTransNum := global.getTiTxnTypeForClass(CM_ReceiveRoadCancelled);
	if not (camProtocol162.registeredTransactions.includes(rcvRoadCancelledTransNum.asStringJMT)) then 
		beginTransaction;
		camProtocol162.registeredTransactions.add(rcvRoadCancelledTransNum.asStringJMT);
		commitTransaction;
	endif;
	self.assertTrueMsg(camProtocol162.registeredTransactions.includes(rcvRoadCancelledTransNum.asStringJMT), "CM_ReceiveRoadCancelled is not registered");
	
	camProtocol213 := self.getCamProtocol(Protocol_Codeco213);
	self.assertIsDeleted(camProtocol213);
	camProtocol213 := self.createCamProtocolCodeco(Protocol_Codeco213,
												   camGroup,
												   "STANDARD CODECO SMDG213",
												   "NZCHC",
												   operator.code,
												   null,
												   true,
												   true);
	self.assertTrueMsg(camProtocol213.allRegisteredCargoTypes.includes(TI_CargoType_Container), "ISO Cargo Type Container is not registered");
	
	// Registered the transaction 'CM_ReceiveRoadCancelled' in the protocol
	if not (camProtocol213.registeredTransactions.includes(rcvRoadCancelledTransNum.asStringJMT)) then 
		beginTransaction;
		camProtocol213.registeredTransactions.add(rcvRoadCancelledTransNum.asStringJMT);
		commitTransaction;
	endif;
	self.assertTrueMsg(camProtocol213.registeredTransactions.includes(rcvRoadCancelledTransNum.asStringJMT), "CM_ReceiveRoadCancelled is not registered");
	
	/*
	  Arrange Vessel/Voyage
	*/
	self.deleteVoyage(Voyage_UT);
	voyage := self.getVoyage(Voyage_UT);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(Vessel_UT);
	vessel := self.getVessel(Vessel_UT);
	self.assertIsDeleted(vessel);
	
	vessel := self.addVesselLOLOholdsRORO(Vessel_UT, operator);
	self.assertNotNullMsg(vessel, 'Failed to add vessel');

	voyage	:= self.addVoyageWithConRORO(Voyage_UT,
										 Vessel_UT,
										 operator.code,
										 self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString,
										 null,
										 10, false, true);
	self.assertNotNullMsg( voyage, 'Add voyage failed' );
	voyage := self.getVoyage(Voyage_UT);
	self.assertNotNullMsg(voyage, "Failed to add voyage");
	
	/*
	  1. Arrange Road Operation
	*/
	
	terminal := CM_Root.firstInstance.allTerminals[self.getProfileSetting(UT_Profile.P_TERMINAL).asString];
	gate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	
	self.deleteVehicle(TruckID);
	
	
	
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	
	vvr := self.gateInContainer(TruckID,
								ContainerID1, 
								"22G0", 
								operator.code,
								"MT", 
								singleGate);
								
	self.assertNotNull(vvr);
	container1 := self.getTrackedItem(ContainerID1);
	assertNotNull(container1);
	assertEqual(vvr.vehicle.allRoadJobs.size, 1);
	assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.size, 1);
	
	beginTransaction;
	container1.setMyVoyage(voyage, passport);
	commitTransaction;
	
	// Unit Test 1 - Run CAM Adhoc for Road Received
	// Let us run the Cam Adhoc
	endDateTime := app.actualTimeServer.addMinutes(1);
	app.setIsBackGroundApp (true);
	runDateTime := app.actualTimeServer;
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol162);
	camTaskHistory := camProtocol162.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
			
	foreach tiTransaction in container1.allTransactions reversed do
		if tiTransaction.isKindOf(CM_InfoEDISent) then
			infoEDISent := tiTransaction.CM_InfoEDISent;
			if infoEDISent.myOtherTransaction.isKindOf(CM_ReceiveRoad) then 
				ediSentRcvRoad := infoEDISent;
				break;
			endif;
		endif;
	endforeach;
	
	self.assertNotNullMsg(ediSentRcvRoad, "Failed to locate EDI Info Sent for Road Receive Transaction");
	
	create xmlDocA transient;
	xmlDocA.parseString(ediSentRcvRoad.xmlInfo);
	
	self.assertEqual(xmlDocA.childNodes.size(), 1);
	
	xmlElement := xmlDocA.childNodes.first().JadeXMLElement;
	tLinesRcvRoad := xmlElement.childNodes.size();
	
	create infoLines transient;
	ediSentRcvRoad.getInformationLines(infoLines);
	
	self.assertEqualMsg(zGetBGMDocumentType(infoLines, 
											BGM_Identifier, 
											ediSentRcvRoad.myCamProtocol),
						Msg_Func_Original, 
						"Incorrect Document Type declaration for Road Receive Transaction");
	
	
	// Unit Test 2 
	// - Delete YardWLE Current Entry
	// - Run CAM Adhoc for Road Received
	startDateTime := app.actualTimeServer;
	yardWLE := vvr.myRoadJob.getWLEForTI(container1).CM_YardWLE;
	beginTransaction;
	yardWLE.deleteCurrentEntry(false, "UT Delete Current Entry");
	commitTransaction;
	endDateTime := app.actualTimeServer.addMinutes(1);
	app.setIsBackGroundApp (true);
	runDateTime := app.actualTimeServer;
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol162);
	camTaskHistory := camProtocol162.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

	foreach tiTransaction in container1.allTransactions reversed do
		if tiTransaction.isKindOf(CM_InfoEDISent) then
			infoEDISent := tiTransaction.CM_InfoEDISent;
			if infoEDISent.myOtherTransaction.isKindOf(CM_ReceiveRoadCancelled) then 
				ediSentRcvRoadCancel := infoEDISent;
				break;
			endif;
		endif;
	endforeach;
	
	self.assertNotNullMsg(ediSentRcvRoadCancel, "Failed to locate EDI Info Sent for Road Receive Cancel transaction");

	xmlDocA.parseString(ediSentRcvRoadCancel.xmlInfo);	
	self.assertEqual(xmlDocA.childNodes.size(), 1);
	
	xmlElement := xmlDocA.childNodes.first().JadeXMLElement;
	tLinesRcvRoadCancel := xmlElement.childNodes.size();
	self.assertTrueMsg(tLinesRcvRoadCancel &gt; tLinesRcvRoad, "There are missing messages");
		
	/* Test for the following
	// 1. Test for the BGM line message function mode = '1'
	// 2. Test for existence of 'RFF_ACW' segement
	// 3. Test for existence of 'FTX+AA1' segment
	*/
	
	infoLines.clear();
	ediSentRcvRoadCancel.getInformationLines(infoLines);
	
	// Test for the BGM line message function mode = '1'
	self.assertEqualMsg(zGetBGMDocumentType(infoLines, 
											BGM_Identifier, 
											ediSentRcvRoadCancel.myCamProtocol),
						Msg_Func_Cancellation, 
						"Incorrect Document Type declaration for Road Receive Cancel Transaction");
	
	// Test for existence of 'RFF_ACW' segement
	self.assertTrueMsg(self.zGetXMLAttribute(infoLines, Segment_RFFACW) &lt;&gt; null, "Missing RFF+ACW segment for Road Receive Cancelled transaction");
	
	// Test for existence of 'FTX+AA1' segment
	self.assertTrueMsg(self.zGetXMLAttribute(infoLines, Segment_FTXAAI) &lt;&gt; null, "Missing FTX+AAI segment for Road Receive Cancelled transaction");
	
	//self.workVehicle(vvr);
	//self.roadExit(vvr);
	
	/* Case 2 
		|-- Gate In (1)--|-- Road Job has been Deleted (2)--|-- CAMS EDI run (3)--|	
	*/
	ediSentRcvRoadCancel := null; // reset to null
	startDateTime := app.actualTimeServer; // for running EDI Cam
	
	vvr1 := self.gateInContainer(TruckID2,
								ContainerID2, 
								"22G0", 
								operator.code,
								"MT", 
								singleGate);
	container2 := self.getTrackedItem(ContainerID2);
	assertNotNull(container2);
	assertEqual(vvr1.vehicle.allRoadJobs.size, 1);
	assertEqual(vvr1.vehicle.allRoadJobs.first.workListEntries.size, 1);
	
	beginTransaction;
	container2.setMyVoyage(voyage, passport);
	commitTransaction;
	
	yardWLE := vvr1.myRoadJob.getWLEForTI(container2).CM_YardWLE;
	beginTransaction;
	yardWLE.deleteCurrentEntry(false, "UT Delete Current Entry");
	commitTransaction;
	endDateTime := app.actualTimeServer.addMinutes(1);
	app.setIsBackGroundApp (true);
	runDateTime := app.actualTimeServer;
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol162);
	camTaskHistory := camProtocol162.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

	foreach tiTransaction in container2.allTransactions reversed do
		if tiTransaction.isKindOf(CM_InfoEDISent) then
			infoEDISent := tiTransaction.CM_InfoEDISent;
			if infoEDISent.myOtherTransaction.isKindOf(CM_ReceiveRoadCancelled) then 
				ediSentRcvRoadCancel := infoEDISent;
				break;
			endif;
		endif;
	endforeach;		
	
	self.assertNullMsg(ediSentRcvRoadCancel, "EDI Message for  Receive Road Cancel transaction must not exist");
epilog
	delete infoLines;
	delete camMessage;
	delete camVoyage;
	delete xmlDocA;
	delete actualXMLElements;
	
	self.deleteJobEntry(vvr.myRoadJob.workListEntries.first);
	self.deleteJobEntry(vvr1.myRoadJob.workListEntries.first);
	
	beginTransaction;
	delete vvr;
	delete vvr1;
	commitTransaction;
	
	container1 := self.getTrackedItem(ContainerID1);
	if container1 &lt;&gt; null then 
		self.deleteContainer(ContainerID1);
	endif;

	container2 := self.getTrackedItem(ContainerID2);
	if container2 &lt;&gt; null then 
		self.deleteContainer(ContainerID2);
	endif;
	
	self.deleteVoyage(Voyage_UT);	
	self.deleteVessel(Vessel_UT);
	
	self.deleteCamProtocol(Protocol_Codeco162);
	self.deleteCamProtocol(Protocol_Codeco213);
	self.deleteCamGroup(Cam_Grp_UT);
	
	delete operatorDict;
	delete freightForwarders;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCamCODECORoadRcvCancelB4Cam" id="5aeb1db8-b649-47a1-9bd9-d9fa888db4d4">
        <source>tCamCODECORoadRcvCancelB4Cam();
/*
Purpose: Test the following for Case # 2 |-- Gate In (1)--|-- Road Job has been Deleted (2)--|-- CAMS EDI run (3)--|
		1. Info Edi Sent is generated for Road Receive Cancelled transaction when 
		   - Receive Road Cancel Transaction exist in Track Item and 
		   - Receive Road Transaction has been processed (Info EDI Sent)
		2. Modified entry and New entries (EDI Sent)
		   - (modified) BGM entry uses document type equal to 1 (cancellation) (not 34)
		   - (new entry) New RFF+ACW segment in the header section (before TDT)
		   - (new entry) New FTX+AA1+++&lt;Cacnellation Reason&gt; entry	
		
	   - create container
	   - create vehicle visit record
	   - cancel the road job for the container
	   - run ADHoc Cam
		
		Case # 2 - Time Line (Current behaviour is not ideal becuase system still process Receive Road transaction eventhough it is deleted)
							 (Ideally, it should ignore logically deleted transaction)
		|-- Gate In (1)--|-- Road Job has been Deleted (2)--|-- CAMS EDI run (3)--|
		Ideal behaviour
		- (1) Road Receive transaction created		
		- (2) Road Receive transaction Deleted
			  Road Receive Cancelled transaction created
		- (3) no EDI messages to be sent out
		
Parameters:			

Return Value:		

Date		Who		TFS		Reason
25 Nov 2019	jlgdi1	46578	Initial creation
*/

constants
	Cam_Grp_UT = "UTGRP";
	Cam_Grp_UT_Desc = "UT RCV ROAD CANCEL";
	Recipient_UT = "UT RCPT";
	Sender_Terminal_UT = "UT_SNDR_TRMNL";
	Sender_Depot_UT = "UT_SNDR_DEPOT";
	Shipper_UT = "UT_SHPR";
	Facility_UT = "UT_FACILITY";
	Call_Sign_Not_Use = false;
	Voyage_Op_Not_Use = false;
	By_MMDD_Not_Use = false;
	Max_Seal_Length_5 = 5;
	Protocol_Codeco162 = "UT CODECO 162";
	Protocol_Codeco213 = "UT CODECO 213";
	ISO_CONTAINER = 1;	
	ContainerID1 = "ZZZZ1911051";
	ContainerID2 = "ZZZZ1911052";
	TruckID = "UTT123";
	DriverID = "UTD123";
	BGM_Identifier = "BGM";
	Msg_Func_Original : String = "9";
	Msg_Func_Cancellation : String = "1";
	Segment_FTXAAI : String = "FTX+AAI";
	Segment_RFFACW : String = "RFF+ACW";
	Voyage_UT = "UTVOY999";
	Vessel_UT = "UTVSL999";
	TruckID2 = "UTT124";
	
vars
	operatorDict : CM_OperatorByCodeDict;
	freightForwarders : CM_ConsigneeConsignorSet;
	operator : CM_Operator;
	camGroup : CM_CamGroup;
	camProtocol162 : CM_CamProtocol;
	camProtocol213 : CM_CamProtocol;
	rcvRoadCancelledTransNum : Integer;
	
	container1 : CM_TrackedItem;
	container2 : CM_TrackedItem;

	terminal : CM_Terminal;	
	gate : CM_Gate;
	vvr : CM_VehicleVisitRecord;
    gte : CMGTE_Entity;
	
	singleGate : CM_Gate;
	
	runDateTime : TimeStamp;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	
	camTaskHistory : CM_CamTaskHistory;
	
	yardWLE : CM_YardWLE;
	
	xmlDocA : JadeXMLDocument;
	infoEDISent : CM_InfoEDISent;
	tiTransaction : CM_TITransaction;
	theLines : HugeStringArray;
	actualXMLElements : JadeXMLElementArray;
	actual : String;
	xmlElement : JadeXMLElement;
	xmlNodeArray : JadeXMLNodeArray;
	xmlCDATA : JadeXMLCDATA;
	
	totalLines : Integer;
	arrayElement : JadeXMLElement;
	entryElement : JadeXMLElement;
	
	ediSentRcvRoad : CM_InfoEDISent;
	ediSentRcvRoadCancel : CM_InfoEDISent;
	
	tLinesRcvRoad : Integer;
	tLinesRcvRoadCancel : Integer;
	camVoyage : CM_CamVoyage;
	camMessage : CM_CamMessage;	
	infoLines : StringArray512;
	voyage : CM_Voyage;
	vessel : CM_Vessel;	
	passport : CM_Passport;
	
begin
	// Arrange
	passport := app.myPassport;	
	startDateTime := app.actualTimeServer;
	/* 1. Create CAM Group
	   2. Create CAM Protocol
	*/
	create operatorDict transient;
	create freightForwarders transient;
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	operatorDict.add(operator);
	
	self.deleteCamGroup(Cam_Grp_UT);
	camGroup := self.getCamGroup(Cam_Grp_UT);
	self.assertIsDeleted(camGroup);
	
	camGroup := self.addCamGroup(Cam_Grp_UT, 
								 Cam_Grp_UT_Desc, 
								 Recipient_UT, 
								 Sender_Terminal_UT, 
								 Sender_Depot_UT, 
								 Facility_UT, 
								 Call_Sign_Not_Use, 
								 By_MMDD_Not_Use, 
								 Voyage_Op_Not_Use, 
								 operatorDict, 
								 freightForwarders, 
								 Max_Seal_Length_5, 
								 Shipper_UT);
	self.assertNotNullMsg(camGroup, "Failed to create CAM Group");
	
	camProtocol162 := self.getCamProtocol(Protocol_Codeco162);
	self.assertIsDeleted(camProtocol162);
	camProtocol162 := self.createCamProtocolCodeco(Protocol_Codeco162,
												   camGroup,
												   "STANDARD CODECO SMDG162",
												   "NZCHC",
												   operator.code,
												   null,
												   true,
												   true);
	self.assertTrueMsg(camProtocol162.allRegisteredCargoTypes.includes(TI_CargoType_Container), "ISO Cargo Type Container is not registered");
	
	// Registered the transaction 'CM_ReceiveRoadCancelled' in the protocol
	rcvRoadCancelledTransNum := global.getTiTxnTypeForClass(CM_ReceiveRoadCancelled);
	if not (camProtocol162.registeredTransactions.includes(rcvRoadCancelledTransNum.asStringJMT)) then 
		beginTransaction;
		camProtocol162.registeredTransactions.add(rcvRoadCancelledTransNum.asStringJMT);
		commitTransaction;
	endif;
	self.assertTrueMsg(camProtocol162.registeredTransactions.includes(rcvRoadCancelledTransNum.asStringJMT), "CM_ReceiveRoadCancelled is not registered");
	
	camProtocol213 := self.getCamProtocol(Protocol_Codeco213);
	self.assertIsDeleted(camProtocol213);
	camProtocol213 := self.createCamProtocolCodeco(Protocol_Codeco213,
												   camGroup,
												   "STANDARD CODECO SMDG213",
												   "NZCHC",
												   operator.code,
												   null,
												   true,
												   true);
	self.assertTrueMsg(camProtocol213.allRegisteredCargoTypes.includes(TI_CargoType_Container), "ISO Cargo Type Container is not registered");
	
	// Registered the transaction 'CM_ReceiveRoadCancelled' in the protocol
	if not (camProtocol213.registeredTransactions.includes(rcvRoadCancelledTransNum.asStringJMT)) then 
		beginTransaction;
		camProtocol213.registeredTransactions.add(rcvRoadCancelledTransNum.asStringJMT);
		commitTransaction;
	endif;
	self.assertTrueMsg(camProtocol213.registeredTransactions.includes(rcvRoadCancelledTransNum.asStringJMT), "CM_ReceiveRoadCancelled is not registered");
	
	/*
	  Arrange Vessel/Voyage
	*/
	self.deleteVoyage(Voyage_UT);
	voyage := self.getVoyage(Voyage_UT);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(Vessel_UT);
	vessel := self.getVessel(Vessel_UT);
	self.assertIsDeleted(vessel);
	
	vessel := self.addVesselLOLOholdsRORO(Vessel_UT, operator);
	self.assertNotNullMsg(vessel, 'Failed to add vessel');

	voyage	:= self.addVoyageWithConRORO(Voyage_UT,
										 Vessel_UT,
										 operator.code,
										 self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString,
										 null,
										 10, false, true);
	self.assertNotNullMsg( voyage, 'Add voyage failed' );
	voyage := self.getVoyage(Voyage_UT);
	self.assertNotNullMsg(voyage, "Failed to add voyage");
	
	/*
	  1. Arrange Road Operation
	*/
	
	terminal := CM_Root.firstInstance.allTerminals[self.getProfileSetting(UT_Profile.P_TERMINAL).asString];
	gate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	
	self.deleteVehicle(TruckID);
	vvr := self.addVehicleVisitRecord(TruckID, "UT", DriverID , gate.name.asStringJMT);
	self.assertNotNull(vvr);
	
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	
	vvr := self.gateInContainer(TruckID,
								ContainerID1, 
								"22G0", 
								operator.code,
								"MT", 
								singleGate);
	container1 := self.getTrackedItem(ContainerID1);
	assertNotNull(container1);
	assertEqual(vvr.vehicle.allRoadJobs.size, 1);
	assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.size, 1);
	
	beginTransaction;
	container1.setMyVoyage(voyage, passport);
	commitTransaction;
			
	startDateTime := app.actualTimeServer;
	yardWLE := vvr.myRoadJob.getWLEForTI(container1).CM_YardWLE;
	beginTransaction;
	yardWLE.deleteCurrentEntry(false, "UT Delete Current Entry");
	commitTransaction;
	endDateTime := app.actualTimeServer.addMinutes(1);
	
	app.setIsBackGroundApp (true);
	runDateTime := app.actualTimeServer;
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol162);
	camTaskHistory := camProtocol162.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

	foreach tiTransaction in container1.allTransactions reversed do
		if tiTransaction.isKindOf(CM_InfoEDISent) then
			infoEDISent := tiTransaction.CM_InfoEDISent;
			if infoEDISent.myOtherTransaction.isKindOf(CM_ReceiveRoadCancelled) then 
				ediSentRcvRoadCancel := infoEDISent;
			endif;
			if infoEDISent.myOtherTransaction.isKindOf(CM_ReceiveRoad) then 
				ediSentRcvRoad := infoEDISent;
			endif;
		endif;
	endforeach;
	
	self.assertNullMsg(ediSentRcvRoad, "EDI Message for Receive Road transaction must not exist");
	self.assertNullMsg(ediSentRcvRoadCancel, "EDI Message for  Receive Road Cancel transaction must not exist");
	
epilog
	delete infoLines;
	delete camMessage;
	delete camVoyage;
	delete xmlDocA;
	delete actualXMLElements;
	
	container1 := self.getTrackedItem(ContainerID1);
	if container1 &lt;&gt; null then 
		self.deleteContainer(ContainerID1);
	endif;

	container2 := self.getTrackedItem(ContainerID2);
	if container2 &lt;&gt; null then 
		self.deleteContainer(ContainerID2);
	endif;
	
	self.deleteVoyage(Voyage_UT);	
	self.deleteVessel(Vessel_UT);
	
	self.deleteCamProtocol(Protocol_Codeco162);
	self.deleteCamProtocol(Protocol_Codeco213);
	self.deleteCamGroup(Cam_Grp_UT);
	
	delete operatorDict;
	delete freightForwarders;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCamCODECORoadRcvCancelRFFBN" id="3dcdd078-db08-45b3-adf2-6523de555887">
        <source>tCamCODECORoadRcvCancelRFFBN();
/*
Purpose: Test the following
		1. Info Edi Sent is generated for Road Receive Cancelled transaction when 
		   - Receive Road Cancel Transaction exist in Track Item and 
		   - Receive Road Transaction has been processed (Info EDI Sent)
		2. Modified entry and New entries (EDI Sent)
		   - (new entry) New RFF+BN segment in the header section		   
		
		Phase 1 - 
		   - create container
		   - create vehicle visit record
		   - run ADHoc Cam
		   Assert
		   
		Phase 2
		   - cancel the road job for the container
		   - run ADHoc Cam

		Case # 1 - Time Line
		|-- Gate In (1)--|-- CAMS EDI run (2)--|-- Road Job has been Deleted (3)--|-- CAMS EDI run (4)--|
		Expected
		- (1) Road Receive transaction created
		- (2) GATE-IN EDI Info sent created 
		- (3) Road Receive transaction Deleted
			  Road Receive Cancelled transaction created
		- (4) GATE-IN Cancellation EDI created
		
Parameters:			

Return Value:		

Date		Who		TFS		Reason
19 Feb 2020	jlgka1	48550	Initial creation
*/

constants
	Cam_Grp_UT 			= "CAMGRP";
	Cam_Grp_UT_Desc 	= "UT RCV ROAD CANCEL";
	Recipient_UT 		= "UT RCPT";
	Sender_Terminal_UT 	= "UT_SNDR_TRMNL";
	Sender_Depot_UT 	= "UT_SNDR_DEPOT";
	Shipper_UT 			= "UT_SHPR";
	Facility_UT 		= "UT_FACILITY";
	Call_Sign_Use 		= true;
	Voyage_Op_Not_Use 	= false;
	By_MMDD_Not_Use 	= false;
	Max_Seal_Length_5 	= 5;
	Protocol_Codeco162 	= "UT CODECO 162";
	ContainerID1 		= "ZZZ19022020";
	TruckID 			= "UTT022020";
	DriverID 			= "UTD022020";
	BGM_Identifier 		= "BGM";
	Voyage_UT 			= "UTVOY220";
	Vessel_UT 			= "UTVSL220";
	Segment_FTXAAI 		: String = "FTX+AAI";
	Segment_RFFACW 		: String = "RFF+ACW";
	Segment_RFFBN 		: String = "RFF+BN";	
	Msg_Func_Original 	: String = "9";
	Msg_Func_Cancellation : String = "1";
	
vars
	operatorDict 			 : CM_OperatorByCodeDict;	
	freightForwarders 		 : CM_ConsigneeConsignorSet;
	operator				 : CM_Operator;
	camGroup 				 : CM_CamGroup;
	camProtocol162 			 : CM_CamProtocol;	
	rcvRoadCancelledTransNum : Integer;
	
	container1 				 : CM_TrackedItem;

	terminal 				 : CM_Terminal;	
	gate 					 : CM_Gate;
	vehicleVisitRecord		 : CM_VehicleVisitRecord;
	pxyVehicleVisitRecord	 : CM_VehicleVisitRecord;
    	
	singleGate 				 : CM_Gate;
	
	runDateTime 			 : TimeStamp;
	startDateTime 			 : TimeStamp;
	endDateTime 			 : TimeStamp;
	
	camTaskHistory 			 : CM_CamTaskHistory;
	
	yardWLE 				 : CM_YardWLE;
	
	xmlDocA 				 : JadeXMLDocument;
	infoEDISent 			 : CM_InfoEDISent;
	tiTransaction 			 : CM_TITransaction;
	actualXMLElements 		 : JadeXMLElementArray;
	xmlElement 				 : JadeXMLElement;
	
	ediSentRcvRoad 			 : CM_InfoEDISent;
	ediSentRcvRoadCancel 	 : CM_InfoEDISent;
	
	tLinesRcvRoad 			 : Integer;
	tLinesRcvRoadCancel 	 : Integer;
	camVoyage 				 : CM_CamVoyage;
	camMessage 				 : CM_CamMessage;	
	infoLines 				 : StringArray512;
	voyage 				 	 : CM_Voyage;
	vessel 					 : CM_Vessel;	
	passport 				 : CM_Passport;	
begin
	// Arrange
	passport := app.myPassport;	
	startDateTime := app.actualTimeServer;
	/* 1. Create CAM Group
	   2. Create CAM Protocol
	*/
	create operatorDict transient;	
	create freightForwarders transient;
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	operatorDict.add(operator);
	
	self.deleteCamGroup(Cam_Grp_UT);
	camGroup := self.getCamGroup(Cam_Grp_UT);
	self.assertIsDeleted(camGroup);
	
	camGroup := self.addCamGroup(Cam_Grp_UT, 
								 Cam_Grp_UT_Desc, 
								 Recipient_UT, 
								 Sender_Terminal_UT, 
								 Sender_Depot_UT, 
								 Facility_UT, 
								 Call_Sign_Use, 
								 By_MMDD_Not_Use, 
								 Voyage_Op_Not_Use, 
								 operatorDict, 
								 freightForwarders, 
								 Max_Seal_Length_5, 
								 Shipper_UT);
	self.assertNotNullMsg(camGroup, "Failed to create CAM Group");
	
	camProtocol162 := self.getCamProtocol(Protocol_Codeco162);
	self.assertIsDeleted(camProtocol162);
	camProtocol162 := self.createCamProtocolCodeco(Protocol_Codeco162,
												   camGroup,
												   "STANDARD CODECO SMDG162",
												   "NZCHC",
												   operator.code,
												   null,
												   true,
												   true);
	self.assertTrueMsg(camProtocol162.allRegisteredCargoTypes.includes(TI_CargoType_Container), "ISO Cargo Type Container is not registered");
	
	// Registered the transaction type 'CM_ReceiveRoadCancelled' in the protocol
	rcvRoadCancelledTransNum := global.getTiTxnTypeForClass(CM_ReceiveRoadCancelled);
	if not (camProtocol162.registeredTransactions.includes(rcvRoadCancelledTransNum.asStringJMT)) then 
		beginTransaction;
		camProtocol162.registeredTransactions.add(rcvRoadCancelledTransNum.asStringJMT);
		commitTransaction;
	endif;
	self.assertTrueMsg(camProtocol162.registeredTransactions.includes(rcvRoadCancelledTransNum.asStringJMT), "Transaction Type Receive Road Cancelled is not registered");
	
	/*
	  Arrange Vessel/Voyage
	*/
	self.deleteVoyage(Voyage_UT);
	voyage := self.getVoyage(Voyage_UT);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(Vessel_UT);
	vessel := self.getVessel(Vessel_UT);
	self.assertIsDeleted(vessel);
	
	vessel := self.addVesselLOLOholdsRORO(Vessel_UT, operator);
	self.assertNotNullMsg(vessel, 'Failed to add vessel');

	voyage	:= self.addVoyageWithConRORO(Voyage_UT,
										 Vessel_UT,
										 operator.code,
										 self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString,
										 null,
										 10, false, true);
	self.assertNotNullMsg( voyage, 'Add voyage failed' );
	voyage := self.getVoyage(Voyage_UT);
	self.assertNotNullMsg(voyage, "Failed to add voyage");
	
	/*
	  1. Arrange Road Operation
	*/
	
	terminal := CM_Root.firstInstance.allTerminals[self.getProfileSetting(UT_Profile.P_TERMINAL).asString];
	gate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	
	self.deleteVehicle(terminal.vehicles[TruckID, "UT"]);
	
	//Create Vehicle Visit Record
	vehicleVisitRecord := self.addVehicleVisitRecord(TruckID, "UT", DriverID , gate.name.asStringJMT);
	self.assertNotNull(vehicleVisitRecord);
	
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	
	self.opts.addAssoc("BookingNumber", "84827034");
	self.opts.addAssoc("IMEX", TI_IMEX_STATUS_EXPORT);
	self.opts.addAssoc("Voyage", voyage.code);	
	self.opts.addAssoc("DischargePort", "NZAKL");
		
	// Create the Gate Entity for container
	self.createGateEntity(vehicleVisitRecord, "CONT", ContainerID1, "42G1", operator.code, "MT", 1);
	
	// Complete the Gate In - Road job is created
	pxyVehicleVisitRecord := app.createUpdateProxy(vehicleVisitRecord).CM_VehicleVisitRecord;
	self.ignoreTrxWarnings(true);
	app.myTrxCA.trxCreateInOutFlexiJob(pxyVehicleVisitRecord, vehicleVisitRecord,null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.checkTIsForTxnOfType(vehicleVisitRecord.allReceivedTrackedItems, TRANS_TYPE_REC_ROAD);	
	
	container1 := self.getTrackedItem(ContainerID1);
	assertNotNull(container1);
	assertEqual(vehicleVisitRecord.vehicle.allRoadJobs.size, 1);
	assertEqual(vehicleVisitRecord.vehicle.allRoadJobs.first.workListEntries.size, 1);
	
	beginTransaction;
	container1.setMyVoyage(voyage, passport);
	commitTransaction;
	
	// Unit Test 1 - Run CAM Adhoc for Road Received
	// Let us run the Cam Adhoc
	endDateTime := app.actualTimeServer.addMinutes(1);
	app.setIsBackGroundApp (true);
	runDateTime := app.actualTimeServer;
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol162);
	camTaskHistory := camProtocol162.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
			
	foreach tiTransaction in container1.allTransactions reversed do
		if tiTransaction.isKindOf(CM_InfoEDISent) then
			infoEDISent := tiTransaction.CM_InfoEDISent;
			if infoEDISent.myOtherTransaction.isKindOf(CM_ReceiveRoad) then 
				ediSentRcvRoad := infoEDISent;
				break;
			endif;
		endif;
	endforeach;
	
	self.assertNotNullMsg(ediSentRcvRoad, "Failed to locate EDI Info Sent for Receive Road Transaction");
	
	create xmlDocA transient;
	xmlDocA.parseString(ediSentRcvRoad.xmlInfo);
	
	self.assertEqual(xmlDocA.childNodes.size(), 1);
	
	xmlElement := xmlDocA.childNodes.first().JadeXMLElement;
	tLinesRcvRoad := xmlElement.childNodes.size();
	
	create infoLines transient;
	ediSentRcvRoad.getInformationLines(infoLines);
	
	self.assertEqualMsg(zGetBGMDocumentType(infoLines, 
											BGM_Identifier, 
											ediSentRcvRoad.myCamProtocol),
						Msg_Func_Original, 
						"Incorrect Document Type declaration for Receive Road Transaction");
	
	// Test for existence of 'RFF+BN' segement
	self.assertTrueMsg(self.zGetXMLAttribute(infoLines, Segment_RFFBN) &lt;&gt; null, "Missing RFF+BN segment for Receive Road transaction");
	
	// Unit Test 2 
	// - Delete YardWLE Current Entry
	// - Run CAM Adhoc for Receive Road Cancelled
	startDateTime := app.actualTimeServer;
	yardWLE := vehicleVisitRecord.myRoadJob.getWLEForTI(container1).CM_YardWLE;
	beginTransaction;
	yardWLE.deleteCurrentEntry(false, "UT Delete Current Entry");
	commitTransaction;
	endDateTime := app.actualTimeServer.addMinutes(1);
	app.setIsBackGroundApp (true);
	runDateTime := app.actualTimeServer;
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol162);
	camTaskHistory := camProtocol162.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

	foreach tiTransaction in container1.allTransactions reversed do
		if tiTransaction.isKindOf(CM_InfoEDISent) then
			infoEDISent := tiTransaction.CM_InfoEDISent;
			if infoEDISent.myOtherTransaction.isKindOf(CM_ReceiveRoadCancelled) then 
				ediSentRcvRoadCancel := infoEDISent;
				break;
			endif;
		endif;
	endforeach;
	
	self.assertNotNullMsg(ediSentRcvRoadCancel, "Failed to locate EDI Info Sent for Receive Road Cancelled transaction");

	xmlDocA.parseString(ediSentRcvRoadCancel.xmlInfo);	
	self.assertEqual(xmlDocA.childNodes.size(), 1);
	
	xmlElement := xmlDocA.childNodes.first().JadeXMLElement;
	tLinesRcvRoadCancel := xmlElement.childNodes.size();
	self.assertTrueMsg(tLinesRcvRoadCancel &gt; tLinesRcvRoad, "There are missing messages");
		
	/* Test for the following
	// 1. Test for the BGM line message function mode = '1'
	// 2. Test for existence of 'RFF_ACW' segement
	// 3. Test for existence of 'FTX+AA1' segment
	// 3. Test for existence of 'RFF+BN' segment
	*/
	
	infoLines.clear();
	ediSentRcvRoadCancel.getInformationLines(infoLines);
	
	// Test for the BGM line message function mode = '1'
	self.assertEqualMsg(zGetBGMDocumentType(infoLines, 
											BGM_Identifier, 
											ediSentRcvRoadCancel.myCamProtocol),
						Msg_Func_Cancellation, 
						"Incorrect Document Type declaration for Receive Road Cancelled Transaction");
	
	// Test for existence of 'RFF+BN' segement
	self.assertTrueMsg(self.zGetXMLAttribute(infoLines, Segment_RFFBN) &lt;&gt; null, "Missing RFF+BN segment for Receive Road Cancelled transaction");
	
	// Test for existence of 'RFF_ACW' segement
	self.assertTrueMsg(self.zGetXMLAttribute(infoLines, Segment_RFFACW) &lt;&gt; null, "Missing RFF+ACW segment for Receive Road Cancelled transaction");
	
	// Test for existence of 'FTX+AA1' segment
	self.assertTrueMsg(self.zGetXMLAttribute(infoLines, Segment_FTXAAI) &lt;&gt; null, "Missing FTX+AAI segment for Receive Road Cancelled transaction");
	
epilog
	delete infoLines;
	delete camMessage;
	delete camVoyage;
	delete xmlDocA;
	delete actualXMLElements;
	
	if vehicleVisitRecord &lt;&gt; null and vehicleVisitRecord.myRoadJob &lt;&gt; null then
		self.deleteJobEntry(vehicleVisitRecord.myRoadJob.workListEntries.first);
	endif;
	
	beginTransaction;
	delete pxyVehicleVisitRecord;
	delete vehicleVisitRecord;
	commitTransaction;
	
	container1 := self.getTrackedItem(ContainerID1);
	if container1 &lt;&gt; null then 
		self.deleteContainer(ContainerID1);
	endif;

	self.deleteVoyage(Voyage_UT);	
	self.deleteVessel(Vessel_UT);
	
	self.deleteCamProtocol(Protocol_Codeco162);
	self.deleteCamGroup(Cam_Grp_UT);
	
	delete operatorDict;	
	delete freightForwarders;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCamCODECORoadReceiveCancel" id="d10ff453-d259-4a05-8571-f75ec42eaecf">
        <source>tCamCODECORoadReceiveCancel();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 21/04/2020	jlgdap1		Initial creation TFS 48911 Deletion CODECO
// 15/05/2020	jlgdap1		TFS 49371 SNO BGM Sequence number corrections
//
/* Testing the following scenarios
		1. CODECO is generated for Road Receive Cancelled transaction when 
		   - Receive Road Cancel Transaction exist in Track Item and 
		   - Receive Road Transaction has been processed (Info EDI Sent)
		2. Road Received Cancellation CODECO has the following segments
		   - New RFF+BN segment in the header section contains the Booking from the original Road Received transaction
		   - New FTX+AAI segment in the EQD section contains the Receival Cancellation reason
		   - New RFF+ACW segment in the header contains the unique sequence number from teh original Road Receival BGM segment
		
		Phase 1 - 
		   - create containers
		   - create vehicle visit record
		   - run ADHoc Cams
		   Assert
		   
		Phase 2
		   - cancel the road job for one container
		   - run ADHoc Cam
		   Assert new segments are present and contain correct data

		Case # 1 - Time Line
		|-- Gate In (1)--|-- CAMS EDI run (2)--|-- Road Job Deleted (3)--|-- CAMS EDI run (4)--|
		Expected
		- (1) Road Receive transaction created
		- (2) GATE-IN EDI Info sent created
		- (3) Road Receive transaction Deleted
			  Road Receive Cancelled transaction created
		- (4) GATE-IN Cancellation EDI created
		
		Case # 2 - Time Line 
		|-- Gate In (1)--|-- Road Job Deleted (2)--|-- CAMS EDI run (3)--|
		Ideal behaviour
		- (1) Road Receive transaction created		
		- (2) Road Receive transaction Deleted
			  Road Receive Cancelled transaction created
		- (3) no EDI messages to be sent out
		
		Case # 3 - Time Line. This has Single Transaction per File turned OFF on the CAMS protocol
		|-- Gate In (1)--|-- CAMS EDI run (2)--|-- Road Job Deleted (3)--|-- CAMS EDI run (4)--|
		Expected
		- (1) Road Receive transaction created
		- (2) GATE-IN EDI Info sent created
		- (3) Road Receive transaction Deleted
			  Road Receive Cancelled transaction created
		- (4) GATE-IN Cancellation EDI created
		
*/
constants
	Cam_Grp_UT = "UTGRP";
	Cam_Grp_UT_Desc = "UT RCV ROAD CANCEL";
	Recipient_UT = "UT RCPT";
	Sender_Terminal_UT = "UT_SNDR_TRMNL";
	Sender_Depot_UT = "UT_SNDR_DEPOT";
	Shipper_UT = "UT_SHPR";
	Facility_UT = "UT_FACILITY";
	Call_Sign_Not_Use = false;
	Voyage_Op_Not_Use = false;
	By_MMDD_Not_Use = false;
	Max_Seal_Length_5 = 5;
	Protocol_Codeco162 = "UT CODECO 162";
	Protocol_Codeco213 = "UT CODECO 213";
	ISO_CONTAINER = 1;	
	ContainerID1_1 = "ZZZZ1911051";
	ContainerID1_2 = "ZZZZ1911052";
	ContainerID1_3 = "ZZZZ1911053";
	ContainerID2_1 = "ZZZZ2911051";
	ContainerID3_1 = "ZZZZ3911051";
	ContainerID3_2 = "ZZZZ3911052";
	ContainerID3_3 = "ZZZZ3911053";
	TruckID1 = "UTT123_1";
	TruckID2 = "UTT123_2";
	TruckID3 = "UTT123_3";
	TruckID4 = "UTT123_4";
	TruckID5 = "UTT123_5";
	TruckID6 = "UTT123_6";
	TruckID7 = "UTT123_7";
	BookingReference = "CAMSBOOKING";
	BookingReference2 = "CAMSBOOKING2";
	BGM_Identifier = "BGM";
	Msg_Func_Original : String = "9";
	Msg_Func_Cancellation : String = "1";
	Segment_FTXAAI : String = "FTX+AAI";
	Segment_RFFACW : String = "RFF+ACW";
	Segment_RFFBN = "RFF+BN";
	Voyage_UT = "UTVOY999";
	Vessel_UT = "UTVSL999";
	CancelReason = "UT Delete Current Entry";
	CancelReason2 = "UT Delete Current Entry 2";
	
vars
	passport : CM_Passport;
	startDateTime, endDateTime, runDateTime : TimeStamp;
	operatorDict : CM_OperatorByCodeDict;
	freightForwarders : CM_ConsigneeConsignorSet;
	operator : CM_Operator;
	camGroup : CM_CamGroup;
	camProtocol162 : CM_CamProtocol;
	voyage : CM_Voyage;
	vessel : CM_Vessel;
	terminal : CM_Terminal;
	singleGate : CM_Gate;
	vvr1, vvr2, vvr3, vvr4, vvr5, vvr6, vvr7 : CM_VehicleVisitRecord;
	container1_1, container1_2, container1_3, container2_1, container3_1, container3_2, container3_3 : CM_Container;
	camTaskHistory : CM_CamTaskHistory;
	infoEDISent, ediSentRcvRoad, ediSentRcvRoadCancel, ediSentRcvRoad2, ediSentRcvRoadCancel2 : CM_InfoEDISent;
	tiTransaction : CM_TITransaction;
	xmlDoc : JadeXMLDocument;
	actualXMLElements : JadeXMLElementArray;
	xmlElement : JadeXMLElement;
	rffBN, bgm, rffACW, ftxAAI : String;
	pos : Integer;
	bgmSequence, bgmSequence2 : String;
	infoLines : StringArray512;
	yardWLE : CM_YardWLE;
	rcvRoadTrans, rcvRoadTrans2 : CM_ReceiveRoad;

begin
	passport := app.myPassport;	
	startDateTime := app.actualTimeServer;
	
	// Create CAM Group and CAM Protocol
	create operatorDict transient;
	create freightForwarders transient;
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	operatorDict.add(operator);
	
	self.deleteCamGroup(Cam_Grp_UT);
	camGroup := self.getCamGroup(Cam_Grp_UT);
	self.assertIsDeleted(camGroup);
	
	camGroup := self.addCamGroup(Cam_Grp_UT, Cam_Grp_UT_Desc, Recipient_UT, Sender_Terminal_UT, Sender_Depot_UT, Facility_UT, Call_Sign_Not_Use, By_MMDD_Not_Use, Voyage_Op_Not_Use, operatorDict, freightForwarders, Max_Seal_Length_5, Shipper_UT);
	self.assertNotNullMsg(camGroup, "Failed to create CAM Group");
	
	self.deleteCamProtocol(Protocol_Codeco162);
	camProtocol162 := self.getCamProtocol(Protocol_Codeco162);
	self.assertIsDeleted(camProtocol162);
	camProtocol162 := self.createCamProtocolCodeco(Protocol_Codeco162, camGroup, "STANDARD CODECO SMDG162", "NZCHC", operator.code, null, true, true);
	self.assertTrueMsg(camProtocol162 &lt;&gt; null, "Failed to create CAM protocol CODECO 162");
	self.assertTrueMsg(camProtocol162.allRegisteredCargoTypes.includes(TI_CargoType_Container), "ISO Cargo Type Container is not registered");
	self.assertTrueMsg(camProtocol162.registeredTransactions.includes(TRANS_TYPE_REC_ROAD.String), "Cams protocol doesn't include Receive - Ship");
	
	// Register the transaction 'CM_ReceiveRoadCancelled' in the protocol, and make sure it's one transaction per file
	if not camProtocol162.registeredTransactions.includes(TRANS_TYPE_RCVROADCANCELLED.String) then 
		beginTransaction;
		camProtocol162.registeredTransactions.add(TRANS_TYPE_RCVROADCANCELLED.String);
		camProtocol162.setPropertyValue(CM_CamProtocol::singleTransactionPerFile.name, true);
		commitTransaction;
	endif;
	self.assertTrueMsg(camProtocol162.registeredTransactions.includes(TRANS_TYPE_RCVROADCANCELLED.String), "CM_ReceiveRoadCancelled is not registered");
		
	// create vessel / voyage
	self.deleteVoyage(Voyage_UT);
	voyage := self.getVoyage(Voyage_UT);
	self.assertIsDeleted(voyage);
	self.deleteVessel(Vessel_UT);
	vessel := self.getVessel(Vessel_UT);
	self.assertIsDeleted(vessel);
	
	vessel := self.addVesselLOLOholdsRORO(Vessel_UT, operator);
	self.assertNotNullMsg(vessel, 'Failed to add vessel');
	voyage	:= self.addVoyageWithConRORO(Voyage_UT, Vessel_UT, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, null, 10, false, true);
	self.assertNotNullMsg( voyage, 'Failed to add voyage' );
	
	// set up road ops
	self.deleteVehicle(TruckID1);
	self.deleteVehicle(TruckID2);
	self.deleteVehicle(TruckID3);
	self.deleteVehicle(TruckID4);
	self.deleteVehicle(TruckID5);
	self.deleteVehicle(TruckID6);
	self.deleteVehicle(TruckID7);
	terminal := CM_Root.firstInstance.allTerminals[self.getProfileSetting(UT_Profile.P_TERMINAL).asString];
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	
	// gate in the 3 containers
	vvr1 := self.gateInContainer(TruckID1, ContainerID1_1, "22G0", operator.code, "MT", singleGate);
	self.assertNotNull(vvr1);
	container1_1 := self.getTrackedItem(ContainerID1_1).CM_Container;
	assertNotNull(container1_1);
	assertEqual(vvr1.vehicle.allRoadJobs.size, 1);
	assertEqual(vvr1.vehicle.allRoadJobs.first.workListEntries.size, 1);
	
	vvr2 := self.gateInContainer(TruckID2, ContainerID1_2, "22G0", operator.code, "MT", singleGate);
	self.assertNotNull(vvr2);
	container1_2 := self.getTrackedItem(ContainerID1_2).CM_Container;
	assertNotNull(container1_2);
	assertEqual(vvr2.vehicle.allRoadJobs.size, 1);
	assertEqual(vvr2.vehicle.allRoadJobs.first.workListEntries.size, 1);
	
	vvr3 := self.gateInContainer(TruckID3, ContainerID1_3, "22G0", operator.code, "MT", singleGate);
	self.assertNotNull(vvr3);
	container1_3 := self.getTrackedItem(ContainerID1_3).CM_Container;
	assertNotNull(container1_3);
	assertEqual(vvr3.vehicle.allRoadJobs.size, 1);
	assertEqual(vvr3.vehicle.allRoadJobs.first.workListEntries.size, 1);
	
	// set the voyage on 2 of the containers, and add a booking to container 2
	// Leave container 3 on the null voyage - this affects the order in which 
	// CAMS files are processed, and hence the BGM sequence
	beginTransaction;
	container1_1.setMyVoyage(voyage, passport);
	container1_2.setMyVoyage(voyage, passport);
	
	container1_2.setPropertyValue(CM_TrackedItem::bookingReference.name, BookingReference);
	commitTransaction;
	
	////////////////////////////////////////////////////////////////////////
	// Case 1 Phase 1 - Run Cams for the three Road Received transactions
	// Check that container 2 has a booking ref in RFF+BN, and retain
	// its BGM sequence number
	///////////////////////////////////////////////////////////////////////
	endDateTime := app.actualTimeServer.addMinutes(1);
	app.setIsBackGroundApp(true);
	runDateTime := app.actualTimeServer;
	self.runCamsNow(startDateTime, camProtocol162);
	camTaskHistory := camProtocol162.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	
	// find the edi data for container 2 - this is the one we're going to cancel
	foreach tiTransaction in container1_2.allTransactions reversed do
		if tiTransaction.isKindOf(CM_InfoEDISent) then
			infoEDISent := tiTransaction.CM_InfoEDISent;
			if infoEDISent.myOtherTransaction.isKindOf(CM_ReceiveRoad) then 
				ediSentRcvRoad := infoEDISent;
				break;
			endif;
		endif;
	endforeach;
	self.assertNotNullMsg(infoEDISent, "Failed to find EDI sent data for container 2");
	
	// check the booking was recorded on the Receive Road transaction for container 2
	rcvRoadTrans := container1_2.getLastTransOfType(TRANS_TYPE_REC_ROAD).CM_ReceiveRoad;
	self.assertNotNullMsg(rcvRoadTrans, "Container 1_2 Road Receive Transaction case 1");
	self.assertTrueMsg(rcvRoadTrans.externalReferenceId.pos(BookingReference,1) &gt; 1, "Receive Road Transaction hasn't retained Booking Reference Case 1");
	
	// check the booking was recorded in the edi data, and also retain the sequence number on the BGM segment
	create xmlDoc transient;
	xmlDoc.parseString(ediSentRcvRoad.xmlInfo);
	xmlElement := xmlDoc.childNodes.first().JadeXMLElement;
	create infoLines transient;
	ediSentRcvRoad.getInformationLines(infoLines);
	rffBN := self.zGetXMLAttribute(infoLines, Segment_RFFBN);
	self.assertTrueMsg(rffBN &lt;&gt; null, "Missing RFF+BN segment for Receive Road transaction");
	self.assertTrueMsg(rffBN.pos(BookingReference, 1) &lt;&gt; null, "RFF+BN doesn't contain booking reference");
	bgm := self.zGetXMLAttribute(infoLines, BGM_Identifier);
	self.assertTrueMsg(bgm &lt;&gt; null, "Missing BGM segment for Receive Road transaction");
	pos := bgm.pos(camProtocol162.elementSeparator, 8);
	bgmSequence := bgm[8:pos-8];
	
	// check the BGM sequence was recorded on the Receive Road transaction for container 2
	self.assertTrueMsg(rcvRoadTrans.externalReferenceId[1:bgmSequence.length] = bgmSequence, "Receive Road Transaction hasn't retained BGM sequence Case 1");
	
	////////////////////////////////////////////////////////////////////////
	// Case 1 Phase 2 - cancel the Road Received transaction for container 2
	// Should produce cams data with the following
	// RFF+ACW segment with the BGM sequence number from TEST 1
	// FTX+AAI segment with the vvr cancellation reason
	// RFF+BN segment with container 2's booking reference
	////////////////////////////////////////////////////////////////////////
	startDateTime := app.actualTimeServer;
	yardWLE := vvr2.myRoadJob.getWLEForTI(container1_2).CM_YardWLE;
	beginTransaction;
	yardWLE.deleteCurrentEntry(false, CancelReason);
	commitTransaction;
	
	// Road visit cancelled - now run Cams to get the Road Received Cancelled message
	endDateTime := app.actualTimeServer.addMinutes(1);
	app.setIsBackGroundApp(true);
	runDateTime := app.actualTimeServer;
	self.runCamsNow(startDateTime, camProtocol162);
	camTaskHistory := camProtocol162.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	
	foreach tiTransaction in container1_2.allTransactions reversed do
		if tiTransaction.isKindOf(CM_InfoEDISent) then
			infoEDISent := tiTransaction.CM_InfoEDISent;
			if infoEDISent.myOtherTransaction.isKindOf(CM_ReceiveRoadCancelled) then 
				ediSentRcvRoadCancel := infoEDISent;
				break;
			endif;
		endif;
	endforeach;
	self.assertNotNullMsg(ediSentRcvRoadCancel, "Failed to locate EDI Info Sent for Road Receive Cancel transaction");
	
	xmlDoc.parseString(ediSentRcvRoadCancel.xmlInfo);
	self.assertEqual(xmlDoc.childNodes.size(), 1);
	xmlElement := xmlDoc.childNodes.first().JadeXMLElement;
	infoLines.clear();
	ediSentRcvRoadCancel.getInformationLines(infoLines);
	// check sequence number in RFF+ACW
	rffACW := self.zGetXMLAttribute(infoLines, Segment_RFFACW);
	self.assertTrueMsg(rffACW &lt;&gt; null, "Missing RFF+ACW segment for Road Receive Cancelled transaction");
	self.assertTrueMsg(rffACW.pos(bgmSequence, 1) &gt; 1, "BGM Sequence number not in RFF+ACW segment");
	// check cancellation reason is in FTX+AAI segment
	ftxAAI := self.zGetXMLAttribute(infoLines, Segment_FTXAAI);
	self.assertTrueMsg(ftxAAI &lt;&gt; null, "Missing FTX+AAI segment for Road Receive Cancelled transaction");
	self.assertTrueMsg(ftxAAI.pos(CancelReason.toUpper, 1) &gt; 1, "Cancellation Reason not in FTX+AAI segment");
	// check booking reference is in RFF+BN segment
	rffBN := self.zGetXMLAttribute(infoLines, Segment_RFFBN);
	self.assertTrueMsg(rffBN &lt;&gt; null, "Missing RFF+BN segment for Road Receive Cancelled transaction");
	self.assertTrueMsg(rffBN.pos(BookingReference.toUpper, 1) &gt; 1, "Booking Reference not in RFF+BN segment");
	
	///////////////////////////////////////////////////
	// Case 2 Phase 1 - gate in a container then cancel
	///////////////////////////////////////////////////
	ediSentRcvRoad := null; // reset to null
	ediSentRcvRoadCancel := null; // reset to null
	startDateTime := app.actualTimeServer; // for running EDI Cam
	
	vvr4 := self.gateInContainer(TruckID4, ContainerID2_1, "22G0", operator.code, "MT", singleGate);
	container2_1 := self.getTrackedItem(ContainerID2_1).CM_Container;
	assertNotNull(container2_1);
	assertEqual(vvr4.vehicle.allRoadJobs.size, 1);
	assertEqual(vvr4.vehicle.allRoadJobs.first.workListEntries.size, 1);
	
	beginTransaction;
	container2_1.setMyVoyage(voyage, passport);
	commitTransaction;
	
	yardWLE := vvr4.myRoadJob.getWLEForTI(container2_1).CM_YardWLE;
	beginTransaction;
	yardWLE.deleteCurrentEntry(false, CancelReason);
	commitTransaction;
	
	//////////////////////////////////////////////////////////////
	// Case 2 Phase 2 - run cams. There should be no cams messages
	//////////////////////////////////////////////////////////////
	endDateTime := app.actualTimeServer.addMinutes(1);
	app.setIsBackGroundApp (true);
	runDateTime := app.actualTimeServer;
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol162);
	camTaskHistory := camProtocol162.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

	foreach tiTransaction in container2_1.allTransactions reversed do
		if tiTransaction.isKindOf(CM_InfoEDISent) then
			infoEDISent := tiTransaction.CM_InfoEDISent;
			if infoEDISent.myOtherTransaction.isKindOf(CM_ReceiveRoadCancelled) then 
				ediSentRcvRoadCancel := infoEDISent;
			elseif infoEDISent.myOtherTransaction.isKindOf(CM_ReceiveRoad) then
				ediSentRcvRoad := infoEDISent;
			endif;
		endif;
	endforeach;		
	
	// there should be no cams for the "Received Road" transaction or the "Received Road - Cancelled" transaction
	self.assertNullMsg(ediSentRcvRoad, "EDI Message for Receive Road transaction must not exist");
	self.assertNullMsg(ediSentRcvRoadCancel, "EDI Message for Receive Road Cancel transaction must not exist");
	
	/////////////////////////////////////////////////////////////////////////////////////
	// Case 3 - do Case 1 again with the CAM protocol "Single Transaction per File" turned off
	/////////////////////////////////////////////////////////////////////////////////////
	beginTransaction;
	camProtocol162.setPropertyValue(CM_CamProtocol::singleTransactionPerFile.name, false);
	commitTransaction;
	self.assertTrueMsg(not camProtocol162.singleTransactionPerFile, "Single Transaction Per File is still set ON");
	
	startDateTime := app.actualTimeServer;
	
	// gate in some more containers
	vvr5 := self.gateInContainer(TruckID5, ContainerID3_1, "22G0", operator.code, "MT", singleGate);
	self.assertNotNull(vvr5);
	container3_1 := self.getTrackedItem(ContainerID3_1).CM_Container;
	assertNotNull(container3_1);
	assertEqual(vvr5.vehicle.allRoadJobs.size, 1);
	assertEqual(vvr5.vehicle.allRoadJobs.first.workListEntries.size, 1);
	vvr6 := self.gateInContainer(TruckID6, ContainerID3_2, "22G0", operator.code, "MT", singleGate);
	self.assertNotNull(vvr6);
	container3_2 := self.getTrackedItem(ContainerID3_2).CM_Container;
	assertNotNull(container3_2);
	assertEqual(vvr6.vehicle.allRoadJobs.size, 1);
	assertEqual(vvr6.vehicle.allRoadJobs.first.workListEntries.size, 1);
	vvr7 := self.gateInContainer(TruckID7, ContainerID3_3, "22G0", operator.code, "MT", singleGate);
	self.assertNotNull(vvr7);
	container3_3 := self.getTrackedItem(ContainerID3_3).CM_Container;
	assertNotNull(container3_3);
	assertEqual(vvr7.vehicle.allRoadJobs.size, 1);
	assertEqual(vvr7.vehicle.allRoadJobs.first.workListEntries.size, 1);
	
	// Set the voyage on 2 containers and booking on the second container
	// This changes the ordering of the cam voyage objects created and afffects the
	// BGM sequencing in the resulting file - double check that we're getting it right
	beginTransaction;
	container3_1.setMyVoyage(voyage, passport);
	container3_2.setMyVoyage(voyage, passport);
	container3_2.setPropertyValue(CM_TrackedItem::bookingReference.name, BookingReference2);
	commitTransaction;
	
	/////////////////////////////////////////////////////////////////////
	// Case 3 Phase 1 - Run Cams ad-hoc for the Road Received transactions
	// Check that second container has a booking ref in RFF+BN, and retains its
	// BGM sequence number
	/////////////////////////////////////////////////////////////////////
	endDateTime := app.actualTimeServer.addMinutes(1);
	app.setIsBackGroundApp(true);
	runDateTime := app.actualTimeServer;
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol162);
	camTaskHistory := camProtocol162.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	
	// find the edi data for the container
	foreach tiTransaction in container3_2.allTransactions reversed do
		if tiTransaction.isKindOf(CM_InfoEDISent) then
			infoEDISent := tiTransaction.CM_InfoEDISent;
			if infoEDISent.myOtherTransaction.isKindOf(CM_ReceiveRoad) then 
				ediSentRcvRoad2 := infoEDISent;
				break;
			endif;
		endif;
	endforeach;
	self.assertNotNullMsg(ediSentRcvRoad2, "Failed to find EDI sent data for container 3 Case 3");
	
	// check the booking was recorded in the edi data, and also retain the sequence number on the BGM segment
	delete xmlDoc;
	create xmlDoc transient;
	xmlDoc.parseString(ediSentRcvRoad2.xmlInfo);
	xmlElement := xmlDoc.childNodes.first().JadeXMLElement;
	infoLines.clear;
	ediSentRcvRoad2.getInformationLines(infoLines);
	rffBN := self.zGetXMLAttribute(infoLines, Segment_RFFBN);
	self.assertTrueMsg(rffBN &lt;&gt; null, "Missing RFF+BN segment for Receive Road transaction Case 3");
	self.assertTrueMsg(rffBN.pos(BookingReference2, 1) &lt;&gt; null, "RFF+BN doesn't contain booking reference Case 3");
	bgm := self.zGetXMLAttribute(infoLines, BGM_Identifier);
	self.assertTrueMsg(bgm &lt;&gt; null, "Missing BGM segment for Receive Road transaction Case 3");
	pos := bgm.pos(camProtocol162.elementSeparator, 8);
	bgmSequence2 := bgm[8:pos-8];
	
	// check the BGM sequence number and booking were recorded on the Receive Road transaction
	rcvRoadTrans2 := container3_2.getLastTransOfType(TRANS_TYPE_REC_ROAD).CM_ReceiveRoad;
	self.assertNotNullMsg(rcvRoadTrans2, "Container 3_1 Road Receive Transaction case 3");
	self.assertTrueMsg(rcvRoadTrans2.externalReferenceId[1:bgmSequence2.length] = bgmSequence2, "Receive Road Transaction hasn't retained BGM sequence Case 3 '" &amp; rcvRoadTrans2.externalReferenceId &amp; "' vs '" &amp; bgmSequence2 &amp; "'");
	self.assertTrueMsg(rcvRoadTrans2.externalReferenceId[bgmSequence2.length+3:end] = BookingReference2, "Receive Road Transaction hasn't retained Booking Reference 2 Case 3 '" &amp; rcvRoadTrans2.externalReferenceId[bgmSequence2.length+2:end] &amp; "' vs '" &amp; BookingReference2);
	
	//////////////////////////////////////////////////////////////////////////
	// Case 3 Phase 2 - cancel the Road Received transaction for container 2
	// Should produce cams data with the following
	// RFF+ACW segment with the BGM sequence number from Phase 1
	// FTX+AAI segment with the vvr cancellation reason
	// RFF+BN segment with container's booking reference
	//////////////////////////////////////////////////////////////////////////
	startDateTime := app.actualTimeServer;
	yardWLE := vvr6.myRoadJob.getWLEForTI(container3_2).CM_YardWLE;
	beginTransaction;
	yardWLE.deleteCurrentEntry(false, CancelReason2);
	commitTransaction;
	
	// Road visit cancelled - now run Cams to get the Road Received Cancelled message
	endDateTime := app.actualTimeServer.addMinutes(1);
	app.setIsBackGroundApp(true);
	runDateTime := app.actualTimeServer;
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol162);
	camTaskHistory := camProtocol162.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	
	foreach tiTransaction in container3_2.allTransactions reversed do
		if tiTransaction.isKindOf(CM_InfoEDISent) then
			infoEDISent := tiTransaction.CM_InfoEDISent;
			if infoEDISent.myOtherTransaction.isKindOf(CM_ReceiveRoadCancelled) then 
				ediSentRcvRoadCancel2 := infoEDISent;
				break;
			endif;
		endif;
	endforeach;
	self.assertNotNullMsg(ediSentRcvRoadCancel2, "Failed to locate EDI Info Sent for Road Receive Cancel transaction Case 3");
	
	xmlDoc.parseString(ediSentRcvRoadCancel2.xmlInfo);
	self.assertEqual(xmlDoc.childNodes.size(), 1);
	xmlElement := xmlDoc.childNodes.first().JadeXMLElement;
	infoLines.clear();
	ediSentRcvRoadCancel2.getInformationLines(infoLines);
	// check sequence number in RFF+ACW
	rffACW := self.zGetXMLAttribute(infoLines, Segment_RFFACW);
	self.assertTrueMsg(rffACW &lt;&gt; null, "Missing RFF+ACW segment for Road Receive Cancelled transaction Case 3");
	self.assertTrueMsg(rffACW.pos(bgmSequence2, 1) &gt; 1, "BGM Sequence number not in RFF+ACW segment Case 3 " &amp; rffACW &amp; Tab &amp; bgmSequence2);
	// check cancellation reason is in FTX+AAI segment
	ftxAAI := self.zGetXMLAttribute(infoLines, Segment_FTXAAI);
	self.assertTrueMsg(ftxAAI &lt;&gt; null, "Missing FTX+AAI segment for Road Receive Cancelled transaction Case 3");
	self.assertTrueMsg(ftxAAI.pos(CancelReason2.toUpper, 1) &gt; 1, "Cancellation Reason not in FTX+AAI segment Case 3");
	// check booking reference is in RFF+BN segment
	rffBN := self.zGetXMLAttribute(infoLines, Segment_RFFBN);
	self.assertTrueMsg(rffBN &lt;&gt; null, "Missing RFF+BN segment for Road Receive Cancelled transaction Case 3");
	self.assertTrueMsg(rffBN.pos(BookingReference2.toUpper, 1) &gt; 1, "Booking Reference not in RFF+BN segment Case 3");
	
	// Success!
	
epilog
	delete operatorDict;
	delete freightForwarders;
	delete infoLines;
	delete xmlDoc;
	delete actualXMLElements;
	
	self.deleteJobEntry(vvr1.myRoadJob.workListEntries.first);
	self.deleteJobEntry(vvr2.myRoadJob.workListEntries.first);
	self.deleteJobEntry(vvr3.myRoadJob.workListEntries.first);
	self.deleteJobEntry(vvr4.myRoadJob.workListEntries.first);
	self.deleteJobEntry(vvr5.myRoadJob.workListEntries.first);
	self.deleteJobEntry(vvr6.myRoadJob.workListEntries.first);
	self.deleteJobEntry(vvr7.myRoadJob.workListEntries.first);
	
	beginTransaction;
	delete vvr1;
	delete vvr2;
	delete vvr3;
	delete vvr4;
	delete vvr5;
	delete vvr6;
	delete vvr7;
	commitTransaction;
	
	self.deleteContainer(ContainerID1_1);
	self.deleteContainer(ContainerID1_2);
	self.deleteContainer(ContainerID1_3);
	self.deleteContainer(ContainerID2_1);
	self.deleteContainer(ContainerID3_1);
	self.deleteContainer(ContainerID3_2);
	self.deleteContainer(ContainerID3_3);
	
	self.deleteVoyage(Voyage_UT);
	self.deleteVessel(Vessel_UT);
	
	self.deleteCamProtocol(Protocol_Codeco162);
	self.deleteCamGroup(Cam_Grp_UT);
end;</source>
    </JadeMethod>
    <JadeMethod name="tCamCodecoDPH_FLS_GateIn_Out" id="324c5c3e-ef60-4581-a521-410cdcb5f27f">
        <source>tCamCodecoDPH_FLS_GateIn_Out();
// cnwrs1
// par 27653
// 09 Jul 2013	cnwrs1	Par 31968The FLS Codeco should use RFF+BM for Bill of Lading number
// 10 Jul 2010	cnwrs1	Par 31974 suppress RRF+BN for GIE (GATEINMT) and LEWIS, SEATRUCK GOE (GATEOUTMT)
// 08 Aug 2013 cnwgb1   Par 32247 Various translation issues
// 16 Oct 2013 cnwgb1   Par 32767 PEV Changes
//30 Jan 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
constants
	VoyageName1		= 'VYPAR27653_1';				// all upper case!
	VoyageName2		= 'VYPAR27653_2';				// all upper case!
	VoyageName3		= 'VYPAR27653_3';				// all upper case!
	VoyageName4		= 'VYPAR27653_4';				// all upper case!
	VoyageName5		= 'VYPAR27653_5';				// all upper case!
	InVoyName1		= 'VYIN27653_1';				// all upper case!
	InVoyName2		= 'VYIN27653_2';				// all upper case!
	InVoyName3		= 'VYIN27653_3';				// all upper case!
	InVoyName4		= 'VYIN27653_4';				// all upper case!
	InVoyName5		= 'VYIN27653_5';				// all upper case!
	VoyageName1Tr	= 'TVY27653_1';				    // all upper case!
	VoyageName2Tr	= 'TVY27653_2';				    // all upper case!
	VoyageName3Tr	= 'TVY27653_3';				    // all upper case!
	VoyInName3Tr	= 'TVYIN27653_3';				// all upper case!
	VoyageName4Tr	= 'TVY27653_4';				    // all upper case!
	VoyageName5Tr	= 'TVY27653_5';				    // all upper case!
	BoatCode		= 'VSPAR27653';
    BoatCodeTrans   = 'TVS27653';
    BoatName        = 'My Vessel';
	ContainerName1	= 'PARC1230001';
	ContainerName2	= 'PARC1230002';
	ContainerName3	= 'PARC1230003';
	ContainerName4	= 'PARC1230004';
	ContainerName5	= 'PARC1230005';
	TestOperator	= 'UTOP';
	CamGroup = "P27653";
	CamProtocol = "PAR27653";
    ReleaseNumber = "1234";
    CarrierCode = "UT_CA1";
    CarrierCodeTr = "CA1";
vars
	runDateTime : TimeStamp;
	lRegisteredCargoTypes : IntegerArray;
	tempStr	: String;
	idx : Integer;
	container1 : CM_Container;
	container2 : CM_Container;
	container3 : CM_Container;
	container4 : CM_Container;
	container5 : CM_Container;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage1 : CM_Voyage;
	voyage2 : CM_Voyage;
	voyage3 : CM_Voyage;
	voyage4 : CM_Voyage;
	voyage5 : CM_Voyage;
	passport : CM_Passport;
//	bs : CM_BlockStack;
	terminal : CM_Terminal;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	nextDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	emailEntity : CM_EmailEntity;
	camProtocolDesc : CM_CamProtocolDesc;
	registeredTransactions : StringArray;
	scheduleTimes : TimeArray;
	freightForwarders : CM_ConsigneeConsignorSet;
	allCoarriExportPorts : CM_PortByCodeDict;
	emailCopyAddresses : CM_EmailEntityByTypeNameDict;
	emailCarrierAddresses : CM_EmailEntityByTypeNameDict;
	packOperators : CM_OperatorByCodeDict;
	packExportConsignees : CM_ConsignByCodeDict;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	camTrainEventTypes : CM_EventTypeByNameDict;
	allPackAreas : CM_TAByIdDict;
	objArray : CM_ObjectArray;	//transaction are added to this array and this array is purged at the end to ensure the transactions dont affect other unit tests
	transObj : CM_TITransaction;
	transRelObj : CM_Release;
	strArray : StringArray;
	str : String;
    bolNumber : String;
    thisTerminal : String;
    carrier : CM_Carrier;
	theLines : HugeStringArray;
	portCode : String;
begin
	self.setTerminalConfig(GateInAutoBOLNumber, true);
	create theLines transient;
	startDateTime := app.actualTimeServer;
	nextDateTime := startDateTime.addMinutes(1);
	passport := app.myPassport;
	operator := self.getOperator(TestOperator);
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; TestOperator.display);
	portCode := self.getTerminal.getConfig(PortDestCode).String;
	self.setTerminalConfig(PortDestCode, "USJAX");
	
	create objArray transient;
	
    // Delete EDI Translations for required voyages and vessels
	self.deleteEDIInwardXlation(VoyageName1,XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIOutwardXlation(VoyageName1,XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIInwardXlation(VoyageName2,XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIOutwardXlation(VoyageName2,XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIInwardXlation(VoyageName3,XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIOutwardXlation(VoyageName3,XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIInwardXlation(VoyageName4,XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIOutwardXlation(VoyageName4,XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIInwardXlation(VoyageName5,XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIOutwardXlation(VoyageName5,XLATION_TYPE_VOYAGETERMINAL, operator, null);
    self.deleteEDIOutwardXlation(BoatCodeTrans, XLATION_TYPE_VESSEL_BYOP, operator, null);
    self.deleteEDIInwardXlation(BoatCode, XLATION_TYPE_VESSEL_BYOP, operator, null);
   
    // Delete required voyages and vessels
	self.deleteVoyage(VoyageName1);
	voyage1 := self.getVoyage(VoyageName1);
	self.assertIsDeleted(voyage1);
	self.deleteVoyage(VoyageName2);
	voyage2 := self.getVoyage(VoyageName2);
	self.assertIsDeleted(voyage2);
	self.deleteVoyage(VoyageName3);
	voyage3 := self.getVoyage(VoyageName3);
	self.assertIsDeleted(voyage3);
	self.deleteVoyage(VoyageName4);
	voyage4 := self.getVoyage(VoyageName4);
	self.assertIsDeleted(voyage4);
	self.deleteVoyage(VoyageName5);
	voyage5 := self.getVoyage(VoyageName5);
	self.assertIsDeleted(voyage5);
 
	self.deleteVessel(BoatCode);
	vessel := self.getVessel(BoatCode);
	self.assertIsDeleted(vessel);
    
    //Delete the Carrier and Translation
    self.deleteEDIOutwardXlation(CarrierCodeTr, XLATION_TYPE_CARRIER_BYOP, operator, null);
    self.deleteEDIInwardXlation(CarrierCode, XLATION_TYPE_CARRIER_BYOP, operator, null);
    self.deleteCarrier(CarrierCode);
    carrier := self.getCarrier(CarrierCode);
    self.assertIsDeleted(carrier);

	
	// Delete the cargo - this should have already been done if on the voyage, 
    // but just in case some other test is using the same IDs, delete anyway
	self.deleteContainer(ContainerName1);
	container1 := self.getTrackedItem(ContainerName1).CM_Container;
	self.assertIsDeleted(container1);
	self.deleteContainer(ContainerName2);
	container2 := self.getTrackedItem(ContainerName2).CM_Container;
	self.assertIsDeleted(container2);
	self.deleteContainer(ContainerName3);
	container3 := self.getTrackedItem(ContainerName3).CM_Container;
	self.assertIsDeleted(container3);
	self.deleteContainer(ContainerName4);
	container4 := self.getTrackedItem(ContainerName4).CM_Container;
	self.assertIsDeleted(container4);
	self.deleteContainer(ContainerName5);
	container5 := self.getTrackedItem(ContainerName5).CM_Container;
	self.assertIsDeleted(container5);
    
	// Now create the required voyages and vessels
	vessel := self.addVesselCellularWithCode(BoatCode, BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatCode.display &amp; ' failed');
	

	voyage1 := self.addVoyageWithInwardCode(        VoyageName1, 
                                                    InVoyName1,
													BoatCode,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage1, 'Add voyage ' &amp; VoyageName1 &amp; ' failed');
	voyage2 := self.addVoyageWithInwardCode(        VoyageName2,
                                                    InVoyName2,
													BoatCode,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage2, 'Add voyage ' &amp; VoyageName2 &amp; ' failed');
	voyage3 := self.addVoyageWithInwardCode(        VoyageName3,
                                                    InVoyName3,
													BoatCode,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage3, 'Add voyage ' &amp; VoyageName3 &amp; ' failed');
	voyage4 := self.addVoyageWithInwardCode(        VoyageName4,
                                                    InVoyName4,
													BoatCode,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage4, 'Add voyage ' &amp; VoyageName5 &amp; ' failed');
	voyage5 := self.addVoyageWithInwardCode(        VoyageName5,
                                                    InVoyName5,
													BoatCode,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage5, 'Add voyage ' &amp; VoyageName5 &amp; ' failed');

    // Now add the edi data translations for the vessels and voyages
    self.createEDIXlation(BoatCodeTrans, BoatCode,    XLATION_TYPE_VESSEL_BYOP,    true, operator, null );
	self.createEDIXlation(VoyageName1Tr, VoyageName1, XLATION_TYPE_VOYAGETERMINAL, true, operator, null );
	self.createEDIXlation(VoyageName2Tr, VoyageName2, XLATION_TYPE_VOYAGETERMINAL, true, operator, null );
	self.createEDIXlation(VoyageName3Tr, VoyageName3, XLATION_TYPE_VOYAGETERMINAL, true, operator, null );
	self.createEDIXlation(VoyInName3Tr,  InVoyName3,  XLATION_TYPE_VOYAGETERMINAL, true, operator, null );
	self.createEDIXlation(VoyageName4Tr, VoyageName4, XLATION_TYPE_VOYAGETERMINAL, true, operator, null );
	self.createEDIXlation(VoyageName5Tr, VoyageName5, XLATION_TYPE_VOYAGETERMINAL, true, operator, null );
    
    // Add the Carrier &amp; Translation
	create emailCarrierAddresses transient;
    carrier := self.addCarrier(CarrierCode, "A Unit Test Carrier", emailCarrierAddresses, false, false, true, null);
    self.assertNotNullMsg( carrier, 'Add carrier ' &amp; CarrierCode &amp; ' failed' );
    self.createEDIXlation(CarrierCodeTr, CarrierCode,    XLATION_TYPE_CARRIER_BYOP,    true, operator, null );

	// Add the container to the voyage
	container1 := self.addContainerForExport(ContainerName1,
										operator,
										"2200",					// ISOType is not needed
										"GENL",					// commodity is not needed
										TI_IMEX_STATUS_EXPORT,	// import not export
										"PAR27653",					// booking id
										voyage1.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerName1.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container1, tempStr);
	self.assertNotNull(voyage1.myShipBlockStack);
	self.move(container1, voyage1.myShipBlockStack);
//    transObj := self.createTransaction(container1, global.getTiTxnTypeForClass(CM_ReceiveRoad), startDateTime);
    // Add the container to the voyage
	container2 := self.addContainerForExport(ContainerName2,
										operator,
										"2200",					// ISOType is not needed
										"MT",					// commodity is not needed
										TI_IMEX_STATUS_EXPORT,	// import not export
										"PAR27653",					// booking id
										voyage2.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerName2.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container2, tempStr);
	self.assertNotNull(voyage2.myShipBlockStack);
	self.move(container2, voyage2.myShipBlockStack);
//    transObj := self.createTransaction(container2, global.getTiTxnTypeForClass(CM_ReceiveRoad), startDateTime);

	container3 := self.addContainerForExport(ContainerName3,
										operator,
										"2200",					// ISOType is not needed
										"GENL",					// commodity is not needed
										TI_IMEX_STATUS_EXPORT,	// import not export
										"PAR27653",					// booking id
										voyage3.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerName3.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
    bolNumber := container3.billOfLading;
	self.assertNotNullMsg(container3, tempStr);
	self.assertNotNull(voyage3.myShipBlockStack);
	self.move(container3, voyage3.myShipBlockStack);
//    transObj := self.createTransaction(container3, global.getTiTxnTypeForClass(CM_ReceiveRoad), nextDateTime);
    transObj := self.createTransaction(container3, global.getTiTxnTypeForClass(CM_ReleaseRoad), startDateTime);
    
	container4 := self.addContainerForExport(ContainerName4,
										operator,
										"2200",					// ISOType is not needed
										"MT",					// commodity is not needed
										TI_IMEX_STATUS_EXPORT,	// import not export
										"PAR27653",					// booking id
										voyage4.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerName4.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
    beginTransaction;
    container4.setDeliveryRelease(ReleaseNumber);
	container4.setClientRef("CR001");
    container4.setReleaseCarrier(CarrierCode);
    commitTransaction;
	self.assertNotNullMsg(container4, tempStr);
	self.assertNotNull(voyage4.myShipBlockStack);
	self.move(container4, voyage4.myShipBlockStack);
//    transObj := self.createTransaction(container4, global.getTiTxnTypeForClass(CM_ReceiveRoad), nextDateTime);
    transObj := self.createTransaction(container4, global.getTiTxnTypeForClass(CM_ReleaseRoad), startDateTime);
    
    // Add the container to the voyage
	container5 := self.addContainerForExport(ContainerName5,
										operator,
										"2200",					// ISOType is not needed
										"MT",					// commodity is not needed
										TI_IMEX_STATUS_IMPORT,	// import not export
										"BKPAR27653",					// booking id
										voyage5.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerName5.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container5, tempStr);
	self.assertNotNull(voyage5.myShipBlockStack);
	self.move(container5, voyage5.myShipBlockStack);
    transObj := self.createTransaction(container5, global.getTiTxnTypeForClass(CM_ReleaseRoad), startDateTime);

	objArray.add(transObj);
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, "REP", "UT", "NZCHC", "JAXT0", false, false, false, operatorDict, freightForwarders, 16, "SHIP");
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveRoad).asStringJMT);
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReleaseRoad).asStringJMT);
	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	camProtocolDesc := app.myRoot.allCamProtocolDescs["FLS Codeco"];
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	camProtocol := self.addCamProtocol(CamProtocol, CamProtocol, allCoarriExportPorts, camGroup, "JAXT0", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, false, false, false, false, false, false, false, false, false, false, true/*BGM per movement*/, false, 
									   false, false, false, false, false, false, false, false, false, false, false, false, 
									   0, 0, 0, 0, '', '', '', camEditTriggerFields, camTrainEventTypes, null, false, 0, self.getTerminal, true, true, false, false, false, false, false, false, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	tempStr	:= 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(camProtocol, tempStr);
	self.assertNotNull(camProtocol);

	endDateTime := startDateTime.addMinutes(1);
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	
	self.assertEqualMsg(theLines.size.String, "94", "Cams has not run correctly.");

	create strArray transient;
	strArray.add("UNB+UNOA:2+UT+REP+");//Partial Comparison

	strArray.add("UNH+1+CODECO:D:95B:UN:ITG14'");
	strArray.add("BGM+109+1+9'");
	strArray.add("TDT+1+" &amp; VoyageName1Tr &amp; "+++" &amp; BoatCodeTrans &amp; ":::172'");
	strArray.add("NAD+CA+SHIP:172'");
	strArray.add("GID+1'");
	strArray.add("EQD+CN+PARC1230001+2200:102:5+++5'");
	strArray.add("RFF+BN:PAR27653'");
	strArray.add("DTM+7:");//Partial Comparison
	strArray.add("LOC+165+USJAX:139:6+JAXT0:TER:ZZZ'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("MEA+AAE+T+KGM:2000'");
	strArray.add("FTX+AAI++");   // Partial Comparison
	strArray.add("CNT+16:1'");
	strArray.add("UNT+14+1'");

	strArray.add("UNH+2+CODECO:D:95B:UN:ITG14'");
	strArray.add("BGM+34+2+9'");
	strArray.add("TDT+1++++:::172'");
	strArray.add("NAD+CA+SHIP:172'");
	strArray.add("GID+1'");
	strArray.add("EQD+CN+PARC1230002+2200:102:5+++4'");
	strArray.add("DTM+7:");//Partial Comparison
	strArray.add("LOC+165+USJAX:139:6+JAXT0:TER:ZZZ'");
	strArray.add("MEA+AAE+T+KGM:2000'");
	strArray.add("FTX+AAI++");   // Partial Comparison
	strArray.add("CNT+16:1'");
	strArray.add("UNT+12+2'");

	strArray.add("UNH+3+CODECO:D:95B:UN:ITG14'");
	strArray.add("BGM+111+3+9'");
	strArray.add("TDT+1+" &amp; VoyInName3Tr &amp; "+++" &amp; BoatCodeTrans &amp; ":::172'");
	strArray.add("NAD+CA+SHIP:172'");
	strArray.add("GID+1'");
	strArray.add("EQD+CN+PARC1230003+2200:102:5+++5'");
	strArray.add("RFF+BM:"&amp;container3.billOfLading&amp;"'");
	strArray.add("DTM+7:");//Partial Comparison
	strArray.add("LOC+165+USJAX:139:6+JAXT0:TER:ZZZ'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("MEA+AAE+T+KGM:2000'");
	strArray.add("FTX+AAI++");   // Partial Comparison
	strArray.add("CNT+16:1'");
	strArray.add("UNT+14+3'");

	strArray.add("UNH+4+CODECO:D:95B:UN:ITG14'");
	strArray.add("BGM+109+4+9'");
	strArray.add("TDT+1+" &amp; VoyageName3Tr &amp; "+++" &amp; BoatCodeTrans &amp; ":::172'");
	strArray.add("NAD+CA+SHIP:172'");
	strArray.add("GID+1'");
	strArray.add("EQD+CN+PARC1230003+2200:102:5+++5'");
	strArray.add("RFF+BN:PAR27653'");
	strArray.add("DTM+7:");//Partial Comparison
	strArray.add("LOC+165+USJAX:139:6+JAXT0:TER:ZZZ'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("MEA+AAE+T+KGM:2000'");
	strArray.add("FTX+AAI++");   // Partial Comparison
	strArray.add("CNT+16:1'");
	strArray.add("UNT+14+4'");

	strArray.add("UNH+5+CODECO:D:95B:UN:ITG14'");
	strArray.add("BGM+50+5+9'");
	strArray.add("TDT+1++++:::172'");
	strArray.add("NAD+CA+SHIP:172'");
	strArray.add("GID+1'");
	strArray.add("EQD+CN+PARC1230004+2200:102:5+++4'");
	strArray.add("RFF+BN:'");
	strArray.add("DTM+7:");//Partial Comparison
	strArray.add("LOC+165+USJAX1:139:6+"&amp;CarrierCodeTr&amp;":TER:ZZZ'");
	strArray.add("MEA+AAE+T+KGM:2000'");
	strArray.add("FTX+AAI++");   // Partial Comparison
	strArray.add("CNT+16:1'");
	strArray.add("UNT+13+5'");

	strArray.add("UNH+6+CODECO:D:95B:UN:ITG14'");
	strArray.add("BGM+34+6+9'");
	strArray.add("TDT+1++++:::172'");
	strArray.add("NAD+CA+SHIP:172'");
	strArray.add("GID+1'");
	strArray.add("EQD+CN+PARC1230004+2200:102:5+++4'");
	strArray.add("DTM+7:");//Partial Comparison
	strArray.add("LOC+165+USJAX:139:6+JAXT0:TER:ZZZ'");
	strArray.add("MEA+AAE+T+KGM:2000'");
	strArray.add("FTX+AAI++");   // Partial Comparison
	strArray.add("CNT+16:1'");
	strArray.add("UNT+12+6'");

	strArray.add("UNH+7+CODECO:D:95B:UN:ITG14'");
	strArray.add("BGM+36+7+9'");
	strArray.add("TDT+1++++:::172'");
	strArray.add("NAD+CA+SHIP:172'");
	strArray.add("GID+1'");
	strArray.add("EQD+CN+PARC1230005+2200:102:5+++4'");
	strArray.add("RFF+BN:BKPAR27653'");
	strArray.add("DTM+7:");//Partial Comparison
	strArray.add("LOC+165+USJAX:139:6+JAXT0:TER:ZZZ'");
	strArray.add("MEA+AAE+T+KGM:2000'");
	strArray.add("FTX+AAI++");   // Partial Comparison
	strArray.add("CNT+16:1'");
	strArray.add("UNT+13+7'");

	strArray.add("UNZ+7+0'");
    
	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		idx := idx + 1;
		str := strArray[idx];
		self.assertEqual(tempStr[1:str.length], str);
	endforeach;  
    
	beginTransaction;
	objArray.purge;
	commitTransaction;
epilog
	self.setTerminalConfig(PortDestCode, portCode);
	delete operatorDict;
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete emailCarrierAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete registeredTransactions;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
	delete objArray;
	delete strArray;
	delete lRegisteredCargoTypes;
	delete theLines;
end;</source>
