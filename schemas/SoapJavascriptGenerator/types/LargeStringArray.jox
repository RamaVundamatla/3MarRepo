    <JadeMethod name="stringify" id="ece75dbf-f3f7-41f5-8bf7-73633b8bb6f6">
        <source>stringify():String;

vars
	s,t : String;
begin
	foreach t in self do
		s := s &amp; t &amp; CrLf;
	endforeach;
	return s;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
