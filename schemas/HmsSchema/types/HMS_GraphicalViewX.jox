    <JadeMethod name="snapBerthPointer" id="8761df16-7e17-48e3-a980-9b3df0e9bf89">
        <updating/>
        <source>snapBerthPointer()updating;

vars
	tmpBerth : HMS_Berth;
begin

	if self.myCurrentWorkingMovement &lt;&gt; null then
		tmpBerth := self.myCurrentWorkingMovement.myBerth;
	endif;	

	if self.lastSelectedBerth &lt;&gt; tmpBerth then
		// update the map view
		if self.myAerialMapForm &lt;&gt; null then
			self.myAerialMapForm.snapAerialView(tmpBerth);
		endif;
	endif;

	self.scrollToSelectedBerth(tmpBerth);
	
end;</source>
    </JadeMethod>
