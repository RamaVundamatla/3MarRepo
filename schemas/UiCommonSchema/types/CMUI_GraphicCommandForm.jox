    <JadeMethod name="translateForm" id="a4881c06-ca18-47fa-9452-9448dcfced09">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007444, locale);
	btnClear.translateBubbleHelp(Xlat_0000439, locale);
	btnClear.translateCaption(Xlat_0000441, locale);
	btnLoadFromCSV.translateCaption(Xlat_0014122, locale);
	btnTBAdd.translateBubbleHelp(Xlat_0000440, locale);
	btnTBAdd.translateCaption(Xlat_0000442, locale);
	btnTBDelete.translateBubbleHelp(Xlat_0000443, locale);
	btnTBDelete.translateCaption(Xlat_0000446, locale);
	btnTBExport.translateBubbleHelp(Xlat_0000444, locale);
	btnTBExport.translateCaption(Xlat_0000447, locale);
	btnTBFlip.translateBubbleHelp(Xlat_0000436, locale);
	btnTBFlip.translateCaption(Xlat_0000437, locale);
	btnTBImport.translateBubbleHelp(Xlat_0000445, locale);
	btnTBImport.translateCaption(Xlat_0000448, locale);
	btnTBPrint.translateBubbleHelp(Xlat_0000433, locale);
	btnTBPrint.translateCaption(Xlat_0000434, locale);
	btnTBRefresh.translateBubbleHelp(Xlat_0000431, locale);
	btnTBRefresh.translateCaption(Xlat_0000432, locale);
	frmPolygon.translateCaption(Xlat_0000435, locale);
	lblColour.translateCaption(Xlat_0000438, locale);
	lblColourFill.translateCaption(Xlat_0000430, locale);
	mnuContext.translateCaption(Xlat_0007445, locale);
	mnuContextNoFills.translateCaption(Xlat_0007446, locale);
	mnuContextZ1.translateCaption(Xlat_0007447, locale);
