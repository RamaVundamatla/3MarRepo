    <JadeMethod name="extrapolateBayDirection" id="87798ed6-94c7-4000-818a-8a4174ed2e6d">
        <source>extrapolateBayDirection(_wle : CM_VoyageWLE; _twinLiftCageDescription : Integer) : String;

// Created by cnwdvb1 on 09 August 2006
vars
	isStarboardBirthed	: Boolean;
	voyage				: CM_Voyage;
	isAftBay,
	isForedBay			: Boolean;
begin

	if _wle = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'WLE reference is null', null, null);
		return null;
	endif;
	
	if not _wle.isTwinLift then
		return null;
	endif;
	
	voyage := _wle.getVoyage();
	
	if voyage = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Voyage reference is null', null, null);
		return null;
	endif;
	
	isAftBay := _wle.isAftBay();
	
	isForedBay := not isAftBay;
		
	isStarboardBirthed := voyage.starboardBerthed;
	
	if _twinLiftCageDescription = TwinLiftCageDirections_NthSth then
		if (isStarboardBirthed and isAftBay) or
		(not isStarboardBirthed and isForedBay) then
			return app.getErrorString(North);
		else
			return app.getErrorString(South);
		endif;
	elseif _twinLiftCageDescription = TwinLiftCageDirections_SthNth then
		if (isStarboardBirthed and isAftBay) or
		(not isStarboardBirthed and isForedBay) then
			return app.getErrorString(South);
		else
			return app.getErrorString(North);
		endif;
	elseif _twinLiftCageDescription = TwinLiftCageDirections_WstEst then
		if (isStarboardBirthed and isAftBay) or
		(not isStarboardBirthed and isForedBay) then
			return app.getErrorString(West);
		else
			return app.getErrorString(East);
		endif;
	elseif _twinLiftCageDescription = TwinLiftCageDirections_EstWst then
		if (isStarboardBirthed and isAftBay) or
		(not isStarboardBirthed and isForedBay) then
			return app.getErrorString(East);
		else
			return app.getErrorString(West);
		endif;
	elseif _twinLiftCageDescription = TwinLiftCageDirections_LftRgt then
		if (isStarboardBirthed and isAftBay) or
		(not isStarboardBirthed and isForedBay) then
			return app.getErrorString(Left);
		else
			return app.getErrorString(Right);
		endif;
	elseif _twinLiftCageDescription = TwinLiftCageDirections_RgtLft then
		if (isStarboardBirthed and isAftBay) or
		(not isStarboardBirthed and isForedBay) then
			return app.getErrorString(Right);
		else
			return app.getErrorString(Left);
		endif;
	else
		return null;
	endif;
		
end;</source>
        <Parameter name="_wle" type="CM_VoyageWLE"/>
        <Parameter name="_twinLiftCageDescription" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="fileCategoryStringToEnum" id="fba6ecfd-2162-4412-95f4-afa179794170">
