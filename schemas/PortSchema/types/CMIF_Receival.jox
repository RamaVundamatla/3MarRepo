    <JadeMethod name="setFromTI" id="732651c5-9338-44b2-9b51-a2581a123991">
        <updating/>
        <source>setFromTI( _ti : CM_TrackedItem; _terminal : CM_Terminal ) updating;

/*
Purpose:			
Return Value:		

Date		Who		Reason
20/11/2007	cnwer1	Initial creation - PAR#xxxx
02/11/2009	cnwdap1	CCMS MES 1017 Add new over dimension fields
24/02/2010	cnwdap1	PAR #21827 Add Break-Bulk fields
24/03/2010	cnwdap1	PAR #23320 Add setting of myProduct reference
03 Oct 2017	jlgrs1	TFS 7245 - POL hazard details being cleared during EDI update
19 Oct 2017	NDL	TFS 7426 - POL onPowerDuringTransit being cleared during EDI update
05 Jun 2018	jlgrs1	TFS 39018 SNO Cargo Operator in COPRAR
12/05/2022	jlika1	TFS 53316 - EUP - GEN - Additional Dimensions For Cargo - PortSchema
*/

vars
	theTI : CM_TrackedItem;
	container:CM_Container;
	haz : CM_Hazard;
	stop : CM_Stops;
	tmpReal : Real;
	allStops	: CM_StopsByIdDict;
	bbg : CM_BreakBulkGeneric;
	
begin
	inheritMethod(_ti, _terminal);

	theTI := _ti;
	
	self.cargoGroupId := _ti.getMyCargoGroupId;	//15 Feb 2016	NDL	Par 37544
	self.commodity := _ti.commodity;
	self.companyCode	:= _ti.companyCode;
	self.consignorCode	:= _ti.consignor;
	self.freightForwarderCode := _ti.freightForwarderCode;
	
	self.destinationPort	:= _ti.destinationPort;
	self.dischargePort	:= _ti.dischargePort;
	self.myTranshipToPort	:= _ti.myTranshipToPort;
	self.isoType	:= _ti.getISOType;

	self.operatorCode	:= _ti.myOperator.code;
	if _ti.myOperator = null and _ti.operatorCode &lt;&gt; null then
		self.operatorCode := _ti.operatorCode;
	endif;
	self.consignorCode   := _ti.consignor;

	self.cargoType	:= _ti.myCargoType.id;
	
	self.voyageCode		:= _ti.myVoyage.code;
	if _ti.myVoyage = null and _ti.voyageCode &lt;&gt; null then
		self.voyageCode	 := _ti.voyageCode;
	endif;
	
	if _ti.getImExStatusObject &lt;&gt; null then
		self.imexStatus := _ti.getImExStatusObject.code;
	else
		self.imexStatus := TI_IMEX_STATUS_EXPORT;
	endif;
	self.imExStatus := app.myRoot.allImexStatuses[self.imexStatus];		
	
	self.length :=_ti.length;
	self.height := _ti.height;
	self.width := _ti.width;	
	//self.weight:=_ti.weight;					//-cnwml2 MSL CCMS 1017
	self.weightTare := _ti.weightTare;			//+cnwml2 MSL CCMS 1017
	self.weightCargo := _ti.weightCargo;		//+cnwml2 MSL CCMS 1017
	self.weightDeclared := _ti.weightDeclared;	//+cnwml2 MSL CCMS 1017
	self.isWeightCertified := _ti.isWeightCertified;	//+cnwml2 MSL CCMS 1017
	//self.weightTotal:=_ti.weight;				//-cnwml2 MSL CCMS 1017
	self.weightTotal := _ti.totalWeight;
	_ti.allDischargePorts.copy(self.allDischargePorts);
	
	//cnwrd1 20.11.08 CCMS JMT 1743/1764 
	self.operatorExportReleaseNumber :=  _ti.getOperatorExpReleaseNo();
	
		//cnwrd1 par 23337 17.5.2010
	self.clientRef := _ti.clientRef;
	
	_ti.allTIHazards.copy(self.allTIHazards);	
//	foreach  haz in _ti.allTIHazards discreteLock do
//		self.allHazards.add(haz.getTableDisplay(false, true));
//	endforeach;
		
//	foreach stop in _ti.getAllStops() discreteLock do	// cnwrl1 15/12/2009 PAR 21889 - what it was
	create allStops transient;
	_ti.getAllActiveStops( allStops );
	foreach stop in allStops do
		self.allStops.add(stop.id);
	endforeach;
	self.quantity := _ti.quantity;
	
	if _ti.isKindOf(CM_Container) then
		container := _ti.CM_Container;
		self.availabilityGrade := container.availabilityGrade; 
		tmpReal := container.getTemperature;
		self.carriageTempC := app.temperatureDisplayString(tmpReal).Real;
		self.carriageTempF := app.temperatureDisplayString(app.temperatureConversion(true, tmpReal)).Real;
		self.hasCOU := container.getCou &lt;&gt; null;
		self.setHumidity( container.getHumidity );
		self.setOxygen( container.getOxygen );
		self.curtainsIn := container.getCurtainsIn;
		self.setCarbonDioxide( container.getCarbonDioxide );
		self.ventilation := container.getVentilation; //cnwrs1 nov 2008 18451
		self.setCarbonDioxide( container.getCarbonDioxide );
		
		self.description := container.description;
		self.isToBeInspected := container.isToBeInspected;
		
		// CCMS 1017 add new overdimension fields
		self.overHeight := container.overHeight;
		self.overLengthFront := container.overLengthFront;
		self.overLengthRear := container.overLengthRear;
		self.overWidthLeft := container.overWidthLeft;
		self.overWidthRight := container.overWidthRight;
        self.offsiteCleaned := container.offsiteCleaned; //cnwgb1 PAR 37172 correction 29/12/2015
        self.offsitePreTrip := container.offsitePreTrip; //cnwgb1 PAR 37172 correction 29/12/2015
        
	// PAR #21827 allow for updating break-bulk
	elseif _ti.isKindOf(CM_BreakBulkGeneric) then
		bbg := _ti.CM_BreakBulkGeneric;
		self.colour := bbg.colour;
		self.heightString := bbg.heightString;
		self.lengthString := bbg.lengthString;
		self.widthString := bbg.widthString;
		self.type := bbg.type;
		self.preSlung := bbg.preSlung;
		self.quantity := bbg.unsplitQuantity;
		self.volume := bbg.unsplitVolume;
		self.weight := bbg.unsplitWeight;
		self.isoType := null;
		// jlika1 TFS 53316 --&gt;
		//self.diameter 			:= bbg.diameter;
		self.diameter			:= bbg.getDiameter().Decimal; 		// ### TFS 54021 29June2022 NAVPW1
		//self.grade 				:= bbg.grade;
		self.grade 				:= bbg.getGrade();			  		// ### TFS 54021 29June2022 NAVPW1
		//self.grammage 			:= bbg.grammage;
		self.grammage 			:= bbg.getGrammage().Decimal;		// ### TFS 54021 29June2022 NAVPW1
		//self.rollingLength 		:= bbg.rollingLength;
		self.rollingLength 		:= bbg.getRollingLength().Decimal;	// ### TFS 54021 29June2022 NAVPW1
		// jlika1 TFS 53316 &lt;--
	endif;
	
	if _ti.myReeferProperties &lt;&gt; null then 
        self.allowableTimeOffPower := _ti.myReeferProperties.allowableTimeOffPower; //cnwgb1 PAR 37172 correction 29/12/2015
        self.packDate := _ti.myReeferProperties.packDate;
        self.packTime := _ti.myReeferProperties.packTime;
        if _ti.myReeferProperties.packTempC &lt;&gt; null then
            self.packTempC := _ti.getPackTemp();
            self.packTempF := app.temperatureConversion(true,_ti.getPackTemp());
        elseif _ti.myReeferProperties.packTempF &lt;&gt; null then
            self.packTempF := _ti.myReeferProperties.packTempF.Real;
        endif;
		self.isExternallyMonitored :=_ti.myReeferProperties.hasExternalMonitoring; //epr TFS 3581 6/3/17
		self.onPowerDuringTransit := _ti.myReeferProperties.onPowerDuringTransit;	//19 Oct 2017	NDL	TFS 7426
		self.transitOnPowerDate := _ti.myReeferProperties.transitOnPowerDate;	//19 Oct 2017	NDL	TFS 7426
		self.transitOnPowerTime := _ti.myReeferProperties.transitOnPowerTime;	//19 Oct 2017	NDL	TFS 7426
		self.transitOnPowerRemarks := _ti.myReeferProperties.transitOnPowerRemarks;	//19 Oct 2017	NDL	TFS 7426
    endif;
    self.coolingType := _ti.getCoolingType(); //cnwgb1 PAR 37172 correction 29/12/2015 //app.coolingTypeENumToString(container.getCoolingType, false).Integer;
    self.voltageType := _ti.getVoltageType(); //cnwgb1 PAR 37172 correction 29/12/2015 //app.voltageTypeENumToString(container.getVoltageType, false).Integer;
    self.customExportEntryNumber := _ti.customExportEntryNumber;
	self.damaged := _ti.damaged;
	self.eirNumber := _ti.eirNumber;
	self.mark := _ti.mark;
	self.markNumber := _ti.markNumber;
	
	self.id := _ti.id;
	self.statusString := app.getIMEXStringFromIMEXStatus(_ti.getImExStatus);
	self.carrier := _ti.carrier;
	self.density := _ti.density;
	self.volume := _ti.getMyTotalVolume;

	//self.hasAttachments := not _ti.allChildren.isEmpty;//PAR 22954
	self.hasAttachments := _ti.hasChildren;
	if _ti.myBookingRef &lt;&gt; null then
		self.bookingReference := _ti.myBookingRef.bookingReference;
	else
		self.bookingReference := _ti.bookingReference;	// TFS4322 MAP 25/5/17
	endif;	
	self.myBookingRefItem := _ti.myBookingRefItem;
	self.myProduct := _ti.myProduct;	// PAR #23320
	self.billOfLading := _ti.billOfLading;	// PAR #23357
	
	self.alternativeId := _ti.alternativeId;	// TFS4322 MAP 25/5/17
	self.weightCertifiedName := _ti.weightCertifiedName;	// TFS4322 MAP 25/5/17
	self.weightCertifiedReference := _ti.weightCertifiedReference;	// TFS4322 MAP 25/5/17
	self.consignorVoyageCode := _ti.consignorVoyageCode;	// TFS4322 MAP 25/5/17
	if _ti.myCustomsAgent &lt;&gt; null then
		self.customsAgentCode := _ti.myCustomsAgent.code;	// TFS4322 MAP 25/5/17
	endif;
	if _ti.releaseCarrier &lt;&gt; null then
		self.releaseCarrierCode := _ti.releaseCarrier;
	endif;
	self.purchaseOrder := _ti.purchaseOrder;	// TFS4322 MAP 25/5/17
	self.serviceOrder := _ti.serviceOrder;	// TFS4322 MAP 25/5/17
	self.shippingReference := _ti.shippingReference;	// TFS4322 MAP 26/5/17
	_ti.allDebtorsByType.copy(self.allDebtorsByType);	// TFS4322 MAP 26/5/17
	self.directDelivery := _ti.directDelivery;	// TFS4322 MAP 1/6/17
	self.expiryDate := _ti.getExpiryDate();	// TFS4322 MAP 1/6/17
	self.houseBOL := _ti.houseBillOfLading;	// TFS4322 MAP 1/6/17
	
	self.remarks := _ti.remarks;	//30 Apr 2020	NDL	TFS 49199
	
	self.myCustomerPriority := _ti.myCustomerPriority;
	
epilog
	delete allStops;
	
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setGateItemDetail" id="c5cba391-c891-4d64-a40e-165002428738">
        <source>setGateItemDetail(_git : CM_GateItemDetail input);
// ---------------------------------------------------------------------------
// Created:     16 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if _git = null then
		return;
	endif;
	
	_git.id := self.id;
	_git.cargoType := self.cargoType;
	_git.bookingRef := self.bookingReference;
	_git.isoTypeCode := self.isoType;
	
	
epilog

end;</source>
        <Parameter name="_git" type="CM_GateItemDetail" usage="input"/>
    </JadeMethod>
