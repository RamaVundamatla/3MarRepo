    <JadeMethod name="getUserCode" id="2e580b27-b3c1-418f-832c-8ea18a9ebe5f">
        <source>getUserCode() : String;
//
// 03 Jan 2013	cnwrs1	Par 32983 getUsercode
//
vars
	isInvalid : Boolean;
begin
	if self.myUser &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, self.myUser, isInvalid);
		return self.myUser.code;
		if isInvalid then
			return null;
		endif;
	endif;
	return null;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="incrementCount" id="c12ca9bb-6b74-47af-a938-c63636d8a556">
        <updating/>
        <source>incrementCount() updating;
//
//16 Aug 2013	cnwrs1	Par 31212 update completion date time for backups
//
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
vars

begin
	if not app.isSDSSecondaryDB then	// CCMS1150 cnwrs1 16 June 2011
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' myCurrentRequest='&amp;self.myCurrentRequest.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		self.numCompleted := self.numCompleted + 1;
		self.dateTimeLastCompleted := app.actualTimeServer;
//		self.myCurrentRequest := null;	//16 Aug 2013	cnwrs1	Par 31212 update completion date time for backups
		self.causeEvent(BGP_Object.BGP_DisplayUpdate, false, null);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="initApp" id="3db12120-7e96-4fe2-81e0-19371d8768ca">
        <updating/>
        <source>initApp() updating;
/*
Date		Who		Reason
12 Aug 2008	cnwkpd1	PAR #17713 - Set alias based on controller class for JSM moitoring of
					critical applications
23 Sep 2008	cnwkpd1	PAR #18009 - Allow ini file control of transient check
06 Nov 2012	cnwrs1	Par 28355 - Hand Shaking with SDS app
03 Jan 2013	cnwrs1	32983 crash after user deleted.
16 Nov 2023	navdap1	TFS 59458 EUP | EDI Specific Performance
*/
vars
	ls			: Boolean;
	tmpClass	: Class;
	str,
	errorText	: String;
	errorCode	: Integer;
	msg : String;
begin
//	on Exception do app.alertExceptionHandler(exception, null, 'BGP Controller', errorCode, errorText, true, false) global;
	on Exception do self.xHandlerGlobal(exception) global;
	on LockException do app.alertLockExceptionHandler(exception) global;

	str := self.getOidString();
	str.replaceChar('.' , '_');
	app.logFileNameSpecific := 'BGPController_' &amp; self.logFileName() &amp; '_' &amp; str; //cnwrs1 par 17287 June 2008
	
	app.setCnAppAlias(self.class.name);		// PAR #17713 //epr TFS 36655 29/4/19
	
	app.initialize();
	app.writeLog(class.name&amp;'::'&amp;method.name, LogTRACE);
	app.setIsBackGroundApp(true);
 	if app.myPassport &lt;&gt; null then
 		app.myPassport.setMyUser(self.myUser);
  	endif;
  	
	// TFS 59458 set deadlock priority lower than the UI
	app.myPassport.setupForDeadlockReplay(-200, 3);
	app.setIsFromEDIviaWeb(true);
	
	app.cmsBeginLoad(ls);
	exclusiveLock(self);

  	if self.isRunning() then
  		app.isBGPAppAbort := true;
		msg := 'ERR &gt;&gt; app is already running';
		app.writeLog(msg, LogFATAL);	//25 Nov 2019	NDL	TFS 47053
		app.exitLogFile();
		terminate;
		return;
	endif;
	
	app.myTrxUA.trxUpdateBGPControllerProcess(self, process, process.signOnTime, true, app.myPassport);
	
	self.beginNotification(self, BGP_Object.BGP_TerminateAppRequest, Response_Cancel , null);
	self.beginNotification(self, BGP_Object.BGP_Initilize, Response_Cancel , null);
	self.beginNotification(self, BGP_Object.BGP_DebugLevelChangeEvent, Response_Continuous , null);
	self.beginNotification(self, BGP_Object.BGP_OutputInfo, Response_Continuous , null);
	self.beginNotification(self, BGP_Object.BGP_ApplicationStartRequest, Response_Continuous , null);
	self.beginNotification(self, BGP_Object.BGP_SDSSecondaryProcess, Response_Continuous , null);
	self.beginNotification(self, BGP_Object.BGP_DeleteBGPBackupDB, Response_Continuous , null);

	self.causeEvent(BGP_Object.BGP_Initilize, true, null);

	if app.isSDSSecondaryDB then	// CCMS1150 cnwrs1 16 June 2011
		self.beginTimer(BGP_Object.BGP_HandShakeInterval, Timer_OneShot, TimerCheck_Event_Tag);
	else
		if app.myRoot.myBackup &lt;&gt; null and
		   app.myRoot.myBackup.sdsSecondaryBackup then
			self.beginTimer(BGP_Object.BGP_HandShakeInterval, Timer_OneShot, TimerCheck_Event_Tag);
		endif;
	endif;
epilog
	app.cmsEndLoad(ls);
end;</source>
    </JadeMethod>
