        <updating/>
        <source>drawVoyGlobAct(_frame : SHP_BayDrawingFrame input) updating, protected;
//----------------------------------------------------------------
//	Created:	04 August 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin


epilog

end;</source>
        <access>protected</access>
        <Parameter name="_frame" type="SHP_BayDrawingFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllSelectedDischgPlanTis" id="fe27d564-41fe-4bcc-a3d9-910d2fa7be4e">
        <source>getAllSelectedDischgPlanTis(theTIs: CM_TIArray io);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 August 2011	cnwndl1	Initial creation	Par 28035

*/

vars
	anObject : Object;
	slotCont : CM_SlotController;
	slotRequest : CM_SlotRequest;
	job : CM_Job;
	voyageJob : CM_VoyageJob;
	wle : CM_VoyageWLE;
	ti : CM_TrackedItem;
begin
	if theTIs = null then
		return;
	endif;
	
	foreach anObject in self.allSelectedObjects discreteLock do
		if anObject.isKindOf(CM_SlotController) then
			slotCont := anObject.CM_SlotController;
			slotRequest :=slotCont.mySlotRequestDischarge;
			if slotRequest = null then
				continue;
			endif;
			job := slotRequest.myJob;
			if job = null or not job.isVoyageJob then
				continue;
			endif;
			voyageJob :=job.CM_VoyageJob;
			foreach ti in slotCont.allTrackedItems do
				wle := job.getWLEForTI(ti).CM_VoyageWLE;
				if wle &lt;&gt; null and wle.status = WLE_UNACTIONED then
					if ti.myPrimaryPlannedLocation = null then
						theTIs.addExclusive( ti );
					endif;
				endif;
			endforeach;
		endif;
	endforeach;

	return;

	
	inheritMethod(theTIs);	// just to provide a reference...

epilog

end;</source>
        <Parameter name="theTIs" type="CM_TIArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAllSelectedTIs" id="aa1af0be-dfff-409d-9f72-5859e152bf4d">
        <updating/>
        <source>getAllSelectedTIs(_tis: CM_TIArray input) updating;
//------------------------------------------------
// Created: 08 May 2006 By: cnwgd1
//05/11/2015 cnwma1 PAR #36723 Bulk Edit Onship Container error
//------------------------------------------------
vars
	anObject : Object;
	ti		 : CM_TrackedItem;
begin
	if _tis = null then
		return;
	endif;
	
	foreach anObject in self.allSelectedObjects discreteLock do
		if anObject.isKindOf(CM_SlotController) then
			//anObject.CM_SlotController.allTrackedItems.copyNoDuplicates(_tis);	//05/11/2015 cnwma1 PAR #36723
			foreach ti in anObject.CM_SlotController.allTrackedItems do		        //05/11/2015 cnwma1 PAR #36723
				_tis.addExclusive(ti);
			endforeach;
		endif;
	endforeach;
end;</source>
        <Parameter name="_tis" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getBayFrameFromXY" id="7fc00ca9-2944-4dc9-b3b3-c9207ea3b508">
        <source>getBayFrameFromXY(x : Real; y : Real) : SHP_BayDrawingFrame;
// ---------------------------------------------------------------------------
// Created:		07 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpFrame : SHP_BayDrawingFrame;
	
	fLeft, fTop, fWidth, fHeight : Real;
begin

	foreach tmpFrame in self.allBayDrawingFramesById do
		fLeft := tmpFrame.left;
		fWidth := (tmpFrame.clientWidth + fLeft);
		fTop := tmpFrame.top;
		fHeight := (tmpFrame.clientHeight + fTop);
		
		if x &gt;= fLeft and x &lt;= fWidth
		and y &gt;= fTop and y &lt;= fHeight then
			return tmpFrame;
		endif;
	endforeach;
	
	return null;
end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <ReturnType type="SHP_BayDrawingFrame"/>
    </JadeMethod>
    <JadeMethod name="getClone" id="20600936-4705-4987-b7d8-078ff54f5c5e">
        <source>getClone(): SelfType;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theClone : SelfType;
begin
	theClone :=  inheritMethod();
	theClone.shipShowISOType := self.shipShowISOType;
	theClone.myDrawingAttrController.shipShowISOType := self.shipShowISOType;
	return theClone;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfoObject" id="e4dc44a9-4f07-466d-a388-f435a6510d42">
        <source>getExtraInfoObject(): Object;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	idx, theBayAreaMode		: Integer;
	aSlotRequest : CM_SlotRequest;
	theSlotController : CM_SlotController;
begin
	theBayAreaMode := self.displayMode;
	theSlotController := self.myLocationsController.CM_SlotController;

	if theBayAreaMode = ShpDisplayMode_ColCodeDisch then
		aSlotRequest := theSlotController.mySlotRequestDischarge;
	elseif theBayAreaMode = ShpDisplayMode_ColCodeLoad then
		aSlotRequest := theSlotController.mySlotRequestLoad;
	endif;	
	if aSlotRequest &lt;&gt; null then
		return aSlotRequest;
	else
		return self;
	endif;

end;</source>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfoTI" id="9788189f-479b-460e-a92d-30aba15f9e06">
        <source>getExtraInfoTI(x: Real; y: Real; _dataContainer : CM_DataContainer);
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25 June 2003 sgp			Use CM_DataContainer to hold data
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------

vars
	theTI	: CM_TrackedItem;
	numTIs,
	idx		: Integer;
	tmpSlotController : CM_SlotController;
	block : CM_DataContainerBlock;
	theTIs : CM_TIArray;
	theBayAreaMode : Integer;
begin
	theBayAreaMode := self.displayMode;
	
	if self.myLocationsController &lt;&gt; null then
		tmpSlotController := self.myLocationsController.CM_SlotController;
		
		if theBayAreaMode = ShpDisplayMode_Actual or  theBayAreaMode = ShpDisplayMode_EDI then
			theTIs := tmpSlotController.allTrackedItems;
	   	elseif theBayAreaMode = ShpDisplayMode_Proposed then
	   		create theTIs transient;
			tmpSlotController.getAllPlannedTrackedItems(theTIs, true, false);
		endif;
		if theTIs &lt;&gt; null then
			numTIs := theTIs.size;
			if numTIs = 1 then
				theTI := theTIs.first;
				if theTI &lt;&gt; null then	
					theTI.getExtraInfo(_dataContainer);
				endif;
			else
				foreach theTI in theTIs do
					if theTI &lt;&gt; null then	
						idx := idx + 1;
						theTI.getExtraInfo(_dataContainer);
						if numTIs &lt;&gt; idx then
							block := _dataContainer.addNewBlock;
							block.addNewItem(GridPointStringMoreCargo, DC_MoreInfo, 1, null);
						endif;
					endif;
				endforeach;
			endif;
	   	
	   	endif;
	else
		theTI := self.getTI(x, y);
		if theTI &lt;&gt; null then	
			theTI.getExtraInfo(_dataContainer);
		endif;
	endif;
epilog
	if theBayAreaMode = ShpDisplayMode_Proposed then
		delete theTIs;
	endif;

end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getFillColourForRequest" id="23fab719-8d72-4d23-a153-785603afa09d">
        <source>getFillColourForRequest(_sr: CM_SlotRequest): Integer;
// ---------------------------------------------------------------------------
// Created:		27 February 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpCol : Integer;
	known : Boolean;
	aPort : CM_Port;
	isoGrp : CM_ISOTypeGroup;
	isoType : CM_ISOType;
	commodity : CM_CommodityGroup;
begin
	if self.viewMode = VIEW_DISPORT then
		aPort := _sr.getAttrDischargePort(); // PAR 23426
		
		
		if aPort &lt;&gt; null then
			known := self.myDrawingAttrController.allDischargePorts.includes(aPort);
		endif;
	elseif self.viewMode = VIEW_ISOGROUP and self.shipShowISOType then // TFS 37556
		isoType := _sr.getAttrISOType(); 
		
		if isoType &lt;&gt; null then
			known := self.myDrawingAttrController.allISOTypes.includes(isoType);
		endif;
	elseif self.viewMode = VIEW_ISOGROUP then // TFS 37556
		isoGrp := _sr.getAttrIsoGroup(); 
		
		if isoGrp &lt;&gt; null then
			known := self.myDrawingAttrController.allISOTypeGroups.includes(isoGrp);
		endif;
	 // TFS 37556
	elseif self.viewMode = VIEW_COMMODITY then
		commodity := _sr.getAttrCommodityGroup(); 
		
		if commodity &lt;&gt; null then
			known := self.myDrawingAttrController.allCommodityGroups.includes(commodity);
		endif;
	endif;
	
	tmpCol := self.myDrawingAttrController.getColourForCC(self.viewMode, _sr);

	if not known and self.myVoyageAreaForm &lt;&gt; null then
		self.myVoyageAreaForm.doNotesForLegendStartStop(self.viewMode);
	endif;
	
	return tmpCol;

end;</source>
        <Parameter name="_sr" type="CM_SlotRequest"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getFrameForBay" id="afb94559-3264-4e85-95d6-75dea291bebb">
        <source>getFrameForBay(_bay : CM_Bay) : SHP_BayDrawingFrame;
// ---------------------------------------------------------------------------
// Created:     05 July 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if _bay = null then
		return null;
	endif;
	
	return self.allBayDrawingFramesById[_bay.id];

end;</source>
        <Parameter name="_bay" type="CM_Bay"/>
        <ReturnType type="SHP_BayDrawingFrame"/>
    </JadeMethod>
    <JadeMethod name="getFrameHeightForBay" id="27a81041-14f6-46d5-88b4-13e172f8e71c">
        <source>getFrameHeightForBay(_bay : CM_Bay; _overDeckHeight, _underDeckHeight : Integer output) : Integer;
// ---------------------------------------------------------------------------
// Created:     08 June 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpMaxOn,
	tmpMaxUnder,
	tmpHeight,
	tmpTopMargin,
	tmpHatchPos, tmpOnDeckPos, tmpUnderDeckEndPos, tmpUnderDeckPos : Integer;
	tmpTier : CM_TierDefn;
begin

	// PAR 26760 
	if self.displayMode = ShpDisplayMode_Defn then
		tmpMaxOn := _bay.allTiersOnDeck.size;
		tmpMaxUnder := _bay.allTiersUnderDeck.size;
	else
		tmpMaxOn := _bay.getNumTiersTotallyAvailable(true);
		tmpMaxUnder := _bay.getNumTiersTotallyAvailable(false);
	endif;
	
	self.getYDrawingPositions(12, tmpMaxOn, tmpMaxUnder,
					tmpTopMargin, tmpHeight, tmpHatchPos, 
					tmpOnDeckPos, tmpUnderDeckEndPos, tmpUnderDeckPos);
	
	_overDeckHeight		:= tmpHatchPos;
	_underDeckHeight	:= tmpHeight - tmpHatchPos;
	
	return tmpHeight;
	
end;</source>
        <Parameter name="_bay" type="CM_Bay"/>
        <Parameter name="_overDeckHeight" type="Integer" usage="output"/>
        <Parameter name="_underDeckHeight" type="Integer" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getFrameWidthForBay" id="b650ae74-012c-42b9-9051-b64558402da6">
        <source>getFrameWidthForBay(_maxCells, _colWidth : Integer) : Integer;
// ---------------------------------------------------------------------------
// Created:     11 June 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	return self.sideDrawingMargin + (_maxCells * _colWidth) + self.sideDrawingMargin;
end;</source>
        <Parameter name="_maxCells" type="Integer"/>
        <Parameter name="_colWidth" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getHazardClass" id="164f786d-91af-4345-a63d-da1cf8497187">
        <source>getHazardClass(_ti : CM_TrackedItem) : CM_HazardClass;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 20/05/2015	cnwdap1		Initial creation PAR #36206 Graphical Representation of Hazard Class
// 06/08/2015	cmwmh5		Change to use right ti hazard collection
// 01/10/2015	cnwdap1		PAR #36999 Allocation criteria could have comma-delimited hazards - have to get the first
//
vars
	ti : CM_TrackedItem;
	request : CM_SlotRequest;
	allocation : CM_YardAllocation;
	criteria : CM_YACriteria;
	hazardClass : CM_HazardClass;
	dataValue : String;						// PAR #36999
	hazCode : String;						// PAR #36999
	pos : Integer;							// PAR #36999

begin
	// do we have a TI? - get the hazard class from there
	if _ti &lt;&gt; null then
		ti := _ti;
	else
		ti := self.allTrackedItems.first;
	endif;
	if ti &lt;&gt; null and not ti.allTIHazards.isEmpty then
		hazardClass := app.myRoot.allHazardClasses[ti.allTIHazards.first.code];
		return hazardClass;
	endif;
		
	// if no TI, do we have a slot request with a voyage allocation for hazard class
	if self.myLocationsController &lt;&gt; null and not self.myLocationsController.CM_SlotController.allSlotRequestsLoad.isEmpty then
		request := self.myLocationsController.CM_SlotController.allSlotRequestsLoad.first;
		criteria := request.getAttrByType(YACriteriaType_Hazardous);
		if criteria &lt;&gt; null then
			dataValue := criteria.myYAData.getDataValue.String;										// PAR #36999
			if dataValue.pos(",", 1) &lt;&gt; null then													// PAR #36999
				pos := 1;																			// PAR #36999
				hazCode := dataValue.cnGetToken(pos, ",");											// PAR #36999
			else																					// PAR #36999
				hazCode := dataValue;																// PAR #36999
			endif;																					// PAR #36999
			//hazardClass := app.myRoot.allHazardClasses[criteria.myYAData.getDataValue.String];	// PAR #36999
			hazardClass := app.myRoot.allHazardClasses[hazCode];									// PAR #36999
			return hazardClass;
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_HazardClass"/>
    </JadeMethod>
    <JadeMethod name="getIconsForFlatRackEnds" id="955eafd4-d951-427a-8def-5ef802673968">
        <source>getIconsForFlatRackEnds(_attrCode : String; _iconArray : StringArray io; _slotRequest : CM_SlotRequest);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/11/2019	jlgdap1		Initial creation TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
//
vars
	alloc : CM_YardAllocation;
	crit : CM_YACriteria;

begin
	foreach alloc in _slotRequest.allAllocations discreteLock do
		foreach crit in alloc.allCriteria discreteLock do
			if _attrCode = PicTIFlatRackEndsUp and crit.myYACriteriaType.isKindOf(CM_YATypeFlatRackStatus) then
				if crit.myYAData.CM_YADataPattern.pattern = app.flatRackEndsEnumToString(TI_DOORSDIRN_ENDUP).toUpper then
					_iconArray.add(PicTIFlatRackEndsUp);
				endif;
			endif;
			if _attrCode = PicTIFlatRackEndsDown and crit.myYACriteriaType.isKindOf(CM_YATypeFlatRackStatus) then
				if crit.myYAData.CM_YADataPattern.pattern = app.flatRackEndsEnumToString(TI_DOORSDIRN_ENDDOWN).toUpper then
					_iconArray.add(PicTIFlatRackEndsDown);
				endif;
			endif;
		endforeach;
	endforeach;
epilog

end;</source>
        <Parameter name="_attrCode" type="String"/>
        <Parameter name="_iconArray" type="StringArray" usage="io"/>
        <Parameter name="_slotRequest" type="CM_SlotRequest"/>
    </JadeMethod>
    <JadeMethod name="getLineHeight" id="55fdec2e-ec13-4dcc-8006-8f253e94da40">
        <source>getLineHeight(_lineNo : Integer ) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 March 2018	jlgns1	Initial creation
21/03/2018 		Jlgns1	Bug 37525: SNO - (re Ticket 36886): Header in bay plan printing
//This value was equivilant of (_lineNo * 7 ) + 1
*/

vars
	newVar : Real;
begin
	newVar := 	(self.defaultFontSize * _lineNo.Real) + (_lineNo * 2).Real + 1;

	return newVar.roundedUp();

epilog

end;</source>
        <Parameter name="_lineNo" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
