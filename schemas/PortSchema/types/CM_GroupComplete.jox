    <JadeMethod name="deleted" id="6db72a38-c8a4-42c3-8479-cba295ea297e">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>deleted(set: Boolean; _value: Boolean io) updating, mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Aug 2015	cnwndl1	Initial creation	Par 36608
27 Jun 2018	jlgkpd1	TFS #39132 - Need to re-derive the current complete flag value on the
					parent CM_CargoGroup if a Complete transaction is deleted or undeleted
					
*/

vars

begin
	inheritMethod(set, _value);
	
	if set then
		if self.myTrackedItem &lt;&gt; null then
			if self.myTrackedItem.isKindOf(CM_CargoGroup) then
				self.myTrackedItem.CM_CargoGroup.setCompleteFromTransactions();
			endif;
			self.updateObjectEdition( self.myTrackedItem );
		endif;
	endif;
end;
</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="81d926e6-840c-4f86-98f5-6321e45c0672">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 August 2015	cnwndl1	Initial creation	Par 36608

*/

vars

	lDetail : String;
	measureType : CM_MeasurementType;
	minStr : String;
	maxStr : String;
	actStr : String;

begin
	
	if _attrName = ETRow_Details  then
	
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
		
			measureType := app.getDefaultMeasurementForType(Type_Weight);
			
			if self.assignmentNumber &lt;&gt; null then
				lDetail := "Cargo Group Assignment = " &amp; self.assignmentNumber &amp; ". ";
			endif;
			
			if self.minWeight &gt; 0 or self.maxWeight &gt; 0 then
				
				if measureType = null then
					minStr := "0";
					maxStr := "0";
					actStr := self.actualWeight.asStringWeightJMT;
					if self.minWeight &gt; 0 then
						minStr := self.minWeight.asStringWeightJMT;
					endif;
					if self.maxWeight &gt; 0 then
						maxStr := self.maxWeight.asStringWeightJMT;
					endif;
				else
					minStr := app.convertMeasurementForDisplay(measureType.shortName, 0);
					maxStr := app.convertMeasurementForDisplay(measureType.shortName, 0);
					actStr := app.convertMeasurementForDisplay(measureType.shortName, self.actualWeight);
					if self.minWeight &gt; 0 then
						minStr := app.convertMeasurementForDisplay(measureType.shortName, self.minWeight);
					endif;
					if self.maxWeight &gt; 0 then
						maxStr :=  app.convertMeasurementForDisplay(measureType.shortName, self.maxWeight);
					endif;
				endif;
				
				lDetail := lDetail &amp; "Min/Max weight = " &amp; minStr &amp; "/"  &amp; maxStr &amp; ". ";
					
			endif;
	
			lDetail := lDetail &amp; "Total weight = " &amp; actStr &amp; ". ";
	
			return lDetail;
			
		endif;

	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="57db7caf-3fd7-446c-ae80-fb17545c8b53">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_CargoGroupComplete; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 August 2015	cnwndl1	Initial creation	Par 36608

*/

vars

begin

	self.assignmentNumber := _tiTransCntrl.assignmentNumber;
	self.minWeight := _tiTransCntrl.minWeight;
	self.maxWeight := _tiTransCntrl.maxWeight;
	self.actualWeight := _tiTransCntrl.actualWeight;
	
	inheritMethod(_tiTransCntrl, _passport);

epilog

end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_CargoGroupComplete"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
