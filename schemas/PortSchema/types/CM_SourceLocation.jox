    <JadeMethod name="isCertified" id="8172f0a5-30e5-440c-9923-aac88f51951c">
        <source>isCertified() : Boolean;
/* ---------------------------------------------------------------------------
Created:	05 November 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin
	
	if self.isSourceLocation() and self.isFSC then
		return true;
	endif;

	return false;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSourceLocation" id="ef87da64-8a8b-4770-80c8-177348e27dca">
        <source>isSourceLocation() : Boolean;
/* ---------------------------------------------------------------------------
Created:	04 November 2009	by cnwvu1

Purpose:	ccms jml 1105, par 21535.
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	
	if self.myCodeGroup.groupType = CodeGroup_SourceLocation then
		return true;	// this is Source Location.
	endif;

	// Here can be Loading Contractor or Logging Contractor. See MCUI_CodesMaintTree form
	return false;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForProxy" id="4737e88e-bea5-40df-9025-541ef87d8fb2">
        <updating/>
        <source>setForProxy(pCode, pDescription : String; _isFSC : Boolean; _notAvailableForEntry:Boolean; pCodeGroup : CM_CodeGroup)updating;
//--------------------------------------------------------------
//Created: 11 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);
	self.setSuperClassDetailsForProxy(pCode, pDescription, _notAvailableForEntry, pCodeGroup);
	
	self.isFSC := _isFSC;	//ccms jml 1105, par 21535 Nov 2009
	
end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pDescription" type="String"/>
        <Parameter name="_isFSC" type="Boolean"/>
        <Parameter name="_notAvailableForEntry" type="Boolean"/>
        <Parameter name="pCodeGroup" type="CM_CodeGroup"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="e3f74b03-6d47-4215-bcd0-74b7d0451542">
        <updating/>
        <source>setForUpdate(_proxy: CM_SourceLocation) updating;
/* ---------------------------------------------------------------------------
Created:	03 November 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	inheritMethod(_proxy);

	self.isFSC := _proxy.isFSC;		//ccms jml 1105, par 21535 Nov 2009

end;</source>
        <Parameter name="_proxy" type="CM_SourceLocation"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="edb2f58e-126f-4247-9ca5-efa1231bc13f">
        <source>validateForDelete();

/*
Date			Who		Reason
26 May 2010	cnwar2	Initial creation

*/
vars

begin
	if (not self.allSubLocations.isEmpty) then
		app.raiseCMException2(ObjectStillHasEntries, app.getErrorString(Source_location) &amp; ' ' &amp; self.description, 
							  self.allSubLocations.size.String &amp; ' ' &amp; app.getErrorString(Sub_Location), null, null);
	endif;

end;</source>
    </JadeMethod>
</Class>
