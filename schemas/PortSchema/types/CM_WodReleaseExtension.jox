    <JadeMethod name="pxyCreateUpdateProxy" id="006bde14-88af-400b-a2f5-521517131e8f">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 March 2019	jlgndl1	Initial creation	TFS 43405

*/

vars
	pxy : SelfType;
	completedOK : Boolean;

begin
	pxy := inheritMethod();
	
	pxy.myReleaseRequest := self.getMyReleaseRequest;
	pxy.myReleaseWorkOrder := self.myReleaseWorkOrder;
	completedOK := true;
	return pxy;
	
epilog
	if not completedOK then
		delete pxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="bef5f096-8096-41ad-bc56-36808af84292">
        <updating/>
        <source>setForUpdate(_pxyWoDDtl: CM_WodReleaseExtension) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
12 March 2019		jlgndl1	Initial creation	TFS 43405
03 October 2019		jlgzm1	TFS 46736 Expired Date

*/

vars

begin

	inheritMethod(_pxyWoDDtl);
	
	self.myReleaseWorkOrder := _pxyWoDDtl.myReleaseWorkOrder;
	self.myReleaseRequest := _pxyWoDDtl.getMyReleaseRequest;
	
	//04 Apr 2019	NDL	TFS 43405
	if self.requiredByDT.isValid and self.getMyParent &lt;&gt; null then
		if self.getMyParent.requiredByDT &lt;&gt; self.requiredByDT then
			self.getMyParent.setRequiredByDT( self.requiredByDT );
		endif;
	endif;
	
	if self.myReleaseRequest &lt;&gt; null and self.requiredByDT.isValid then			// TFS 46736
		self.myReleaseRequest.setExpiryTimeStampDate(self.requiredByDT.date);	// TFS 46736
		self.myReleaseRequest.setExpiryTimeStampTime(self.requiredByDT.time);	// TFS 46736
	endif;

epilog

end;</source>
        <Parameter name="_pxyWoDDtl" type="CM_WodReleaseExtension"/>
    </JadeMethod>
    <JadeMethod name="setProxyWodReleaseExt" id="c37c344e-4a2f-44c5-94c7-f0029b9d466e">
        <updating/>
        <source>setProxyWodReleaseExt( _wodRelease : CM_WodRelease ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 March 2019	jlgndl1	Initial creation	TFS 43405
//1/04/2019	JLGNS1	Bug 44134: PEL1 - Container Services - Release Extension (Release Work Order drop down not responding)
*/

vars

begin

	self.myReleaseWorkOrder := _wodRelease;
	if _wodRelease &lt;&gt; null then
		self.myReleaseRequest := _wodRelease.getMyReleaseRequest();	//Bug 44134
	endif;

epilog

end;</source>
        <Parameter name="_wodRelease" type="CM_WodRelease"/>
    </JadeMethod>
    <JadeMethod name="validate" id="687ce8ec-164b-44af-9566-7ca112fd4679">
        <source>validate() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 March 2019	jlgndl1	Initial creation	TFS 43405

*/

vars

begin

	inheritMethod();
	
	if self.myReleaseWorkOrder = null then
		//has to be associated with an existing Wo Release
		app.raiseCMException( Cargo_releas_work_order_select, null, null );
		return;
	elseif self.getMyReleaseRequest = null then
		//has to be extending a valid bulk release
		app.raiseCMException( No_Release_request, null, null );
		return;
	elseif self.getMyReleaseRequest.isComplete then
		app.raiseCMException1( Relase_already_complete, self.getMyReleaseRequest.code, null, null );
	endif;
	
	if not self.requiredByDT.date.isValid then
		app.raiseCMException( Require_date_must_valid, null, null );
	elseif self.requiredByDT &lt;= self.myReleaseWorkOrder.getMyParent.approvalExpiryTS then
		app.raiseCMException( Requi_date_must_valid_great_th, null, null );
	endif;
	
	

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
