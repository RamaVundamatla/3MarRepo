    <JadeMethod name="resetOnDateChange" id="67599008-a6b0-4dd4-b810-c5cf02b9953a">
        <source>resetOnDateChange( _date : Date ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 January 2019	jlgndl1	Initial creation	TFS 43018

*/

vars

	year : String;
	
begin

	if lastGeneratedDate.isValid then
		if self.resetSeqOn = Reset_On_Year_Chg_Int then
			if lastGeneratedDate.year &lt;&gt; _date.year then
				return true;
			endif;
		endif;
		
		if self.resetSeqOn = Reset_On_Month_Chg_Int then
			if lastGeneratedDate.year &lt;&gt; _date.year then
				return true;
			endif;
			if lastGeneratedDate.month &lt;&gt; _date.month then
				return true;
			endif;
		endif;
		
		if self.resetSeqOn = Reset_On_Date_Chg_Int then
			if lastGeneratedDate &lt;&gt; _date then
				return true;
			endif;
		endif;
	
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_date" type="Date"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="1d67e1a8-a387-4f8b-8c5a-c121e37e9657">
        <updating/>
        <source>setForCreate( _proxy : CM_AutoIdGenerator ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2014	cnwndl1	Initial creation	Par 34660
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin

	_proxy.raiseExceptionIfNotTransient(method);
	
	//self.lastIdGeneratedYear := app.actualTimeServer.Date.format("yy");	// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.lastGeneratedDate := app.actualTimeServer.Date;	//23 Jan 2018	NDL	TFS 43018
	self.setForUpdate(_proxy);
	
	self.validateMe;
	
epilog

end;</source>
        <Parameter name="_proxy" type="CM_AutoIdGenerator"/>
    </JadeMethod>
