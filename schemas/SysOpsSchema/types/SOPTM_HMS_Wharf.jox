    <JadeMethod name="clearThumbnailData" id="fd2a172c-6efa-4a89-a43e-5e0e862244a1">
        <updating/>
        <source>clearThumbnailData() updating;
//--------------------------------------------------------------
//Created: 04 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	theForm : SOP_HMS_TableMaintForm;
begin
	inheritMethod();
	theForm := self.myForm.SOP_HMS_TableMaintForm;
	theForm.tblInput1.clearValues();
	theForm.mulSelect1.setSelected(null);  	
	self.setTblData1Rows(null); // to clear resourses table 
end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="6a0842bb-b318-4221-8b3e-a7027c5bf681">
        <updating/>
        <source>create() updating;
//--------------------------------------------------------------
//Created: 04 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.name := SOP_TableMaintForm.Table_Wharf;
	self.permissionView	 := PmHMSWharfView;
	self.permissionMaint := PmHMSWharfMaint;
	self.myDataClass := HMS_Wharf;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="1e8017c4-4d5d-434e-8cb0-f2998a5e8c2b">
        <updating/>
        <source>doSave(): Boolean updating;
//--------------------------------------------------------------
//Created: 09 July 2003 By: cnwgd1
//--------------------------------------------------------------
// 27/09/2011	cnwcs5	CCMS 2130 / par 28261 - Minimum residence time
vars
	pxyWharf	: HMS_Wharf;
	maintFormObj	: SOP_HMS_TableMaintForm;
	theHarbour	: HMS_Harbour;
	
begin
  	maintFormObj	:=	self.myForm.SOP_HMS_TableMaintForm;
	
	if maintFormObj.myProxyObject = null then
		if maintFormObj.mode = maintFormObj.Mode_Add then
			create maintFormObj.myProxyObject as HMS_Wharf transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	pxyWharf	:=	maintFormObj.myProxyObject.HMS_Wharf;
	pxyWharf.allTerminals.clear();
	maintFormObj.mulSelect2.getSelected(pxyWharf.allTerminals);
	maintFormObj.tblInput1.setObjectFromTable(pxyWharf, 'setObjectFromTableSpecial', false);
	
	pxyWharf.setProxy(maintFormObj.myHarbour, self.jadeCode, app.myPassport.userCode);

	self.doSaveResourcesTbl(pxyWharf);

	if maintFormObj.mode = maintFormObj.Mode_Add then
		app.myTrxCA.trxCreateHMSObject(pxyWharf, maintFormObj.myCurrentObject, app.myPassport);
	elseif maintFormObj.mode = maintFormObj.Mode_Update then
		app.myTrxUA.trxUpdateHMSObject(pxyWharf, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; maintFormObj.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveResourcesTbl" id="f96a74aa-c784-4cdd-8d59-03f65937cf39">
        <source>doSaveResourcesTbl(_pxyWharf : HMS_Wharf);
// ---------------------------------------------------------------------------
// Created:     21 February 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	
	theForm 	: SOP_TableMaintForm;
	idx			: Integer;
	tmpDataTable	: CM_DataTable;
	obj			: Object;
	harbour	: HMS_Harbour;
	prxyResourceForWharf	: HMS_ResourceForWharf;
	arrResource,
	depResource,
	shiftResource :	HMS_Resource;
	order : Integer;
begin

	theForm := self.myForm; 
	harbour := _pxyWharf.getHarbourReal;

	tmpDataTable := self.myForm.tblData1;
	foreach idx in 2 to tmpDataTable.rows do
		order := order + 1;
		arrResource 		:= tmpDataTable.accessCell(idx, 2).itemObject.HMS_Resource;
		depResource 		:= tmpDataTable.accessCell(idx, 3).itemObject.HMS_Resource;
		shiftResource 		:= tmpDataTable.accessCell(idx, 4).itemObject.HMS_Resource;		

		prxyResourceForWharf := _pxyWharf.allResourcesForWharf[harbour,_pxyWharf,order];
		
		if prxyResourceForWharf = null then
				create prxyResourceForWharf transient;
		endif;
		prxyResourceForWharf.setResourceOrder(order);
		prxyResourceForWharf.setProxy(_pxyWharf,harbour,arrResource,depResource,shiftResource);

	endforeach;

end;</source>
        <Parameter name="_pxyWharf" type="HMS_Wharf"/>
    </JadeMethod>
