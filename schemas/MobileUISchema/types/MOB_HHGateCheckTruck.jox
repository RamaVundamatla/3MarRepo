    <JadeMethod name="doResizeControls" id="2e0b39c6-6b5b-4e09-b83a-ffb782790841">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	left : Real;
	top : Real;
	stdWidth : Real;
	stdHeight : Real;
	term : CM_Terminal;

begin

	self.setResizeableMarginAndFontSize();
	left := self.resizedMargin;
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	top := self.resizedMargin;
	self.cmbGate.move( 	left,
						top,
						stdWidth,
						stdHeight );
						
	top := self.resizedMargin + self.cmbGate.height + self.cmbGate.top;
	self.cmbLane.move(	left,
						top,
						stdWidth,
						stdHeight );
						
	top := self.resizedMargin + self.cmbLane.height + self.cmbLane.top;
	self.txtTruck.move( left,
						top,
						stdWidth,
						stdHeight );
						
						
	//07 Apr 2015	NDL	Par 35990
	top := self.resizedMargin + self.txtTruck.height + self.txtTruck.top;
	self.txtState.visible := self.myMobileGenericAgent.showState;
	if self.txtState.visible then
		self.txtState.move(	left,
							top,
							stdWidth,
							stdHeight );
		top := self.resizedMargin + self.txtState.height + self.txtState.top;
	endif;
	
	term := self.myMobileDataAgent.myTerminal;
	if term.getConfig(SiteHasSecurityGate).Boolean then
		self.txtBatNo.move(	left,
							top,
							stdWidth,
							stdHeight );
		top := self.resizedMargin + self.txtBatNo.height + self.txtBatNo.top;
	endif;
	
	self.txtAssignTrailer.move( left,
								top,
								stdWidth,
								stdHeight );
											
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findTrailer" id="4c439568-9290-4310-9272-f7a6f96ce4cb">
        <source>findTrailer( _trailerStr : String; _error : String output ):CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2014	cnwndl1	Initial creation	Par 34562
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
*/

vars

	trailer : CM_TrackedItem;
	term : CM_Terminal;
	allTrailers : CM_TISet;

begin

	if _trailerStr.trimBlanks = null or _trailerStr = lblAssignTrailer.caption.toUpper then
		_error := app.getErrorString(Trailer_required);
		return null;
	endif;
	
	term := self.myMobileDataAgent.myTerminal;
	create allTrailers transient;
	term.lookupAllOnsiteTrailers( null, _trailerStr, allTrailers, false, null);
	
	if allTrailers = null then
		_error := app.getErrorString1(Could_find_chassis_with, _trailerStr);
		return null;
	endif;
	
	trailer := allTrailers.first;
	return trailer;

epilog

	delete allTrailers;

end;</source>
        <Parameter name="_trailerStr" type="String"/>
        <Parameter name="_error" type="String" usage="output"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="findTruck" id="d0918b9b-0699-4691-925b-0355a74720da">
        <source>findTruck( errMsg : String output; _ignoreValidation : Boolean ) : CM_Vehicle;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/01/2010	cnwndl1	Initial creation	CCMS MES 1005
10/06/2014	cnwdap1	PAR #34354 Do truck validation after finding truck via BAT number
*/
vars

	truckString : String;
	term : CM_Terminal;
	truck : CM_Vehicle;
	state : String;
//	visitRecord : CM_VehicleVisitRecord;
	
begin
	
	truckString := txtTruck.text;
	if txtState.text.trimBlanks = null or txtState.text = lblState.caption.toUpper then
		state := null;
	else
		state := txtState.text.trimBlanks;
	endif;
	
	if truckString.trimBlanks = null or truckString = lblTruck.caption.toUpper then
		
		//20 Dec 2013	NDL	Par 32849
		truck := self.findTruckFromBatNumber();
		if truck &lt;&gt; null then
			self.isValidTruckForLane(truck, errMsg);				// PAR #34354
			return truck;
		endif;
	
		errMsg := app.getErrorString(Enter_truck);
		truck := null;
		
	else
		// identify the truck from the value entered.
		term := self.myMobileDataAgent.myTerminal;
		truck := term.vehicles[truckString.toUpper, state];
		
		if truck = null then
			
			if state &lt;&gt; null then
				errMsg := app.getErrorString2( Err_Unknown_Truck_Rego_State, truckString, state );
			else
			//17 Jun 2013	NDL	Par 31780
				// try value as a visit number.
		//		visitRecord := term.getVehicleVisitRecordByTran(truckString.toUpper);
		//		if visitRecord &lt;&gt; null then
		//			truck := visitRecord.vehicle;
		//		endif;
		//		if truck = null then
					errMsg := app.getErrorString2( ERR_Truck_Unknown, truckString, null );
		//		endif;
			endif;
			
		endif;
		
	endif;
	
//	if truck &lt;&gt; null then
	if truck &lt;&gt; null and not _ignoreValidation then	//15 Jukly 2014	NDL	Par 34562
		self.isValidTruckForLane(truck, errMsg);
	endif;
	
	return truck;
	
epilog

end;</source>
        <Parameter name="errMsg" type="String" usage="output"/>
        <Parameter name="_ignoreValidation" type="Boolean"/>
        <ReturnType type="CM_Vehicle"/>
    </JadeMethod>
    <JadeMethod name="findTruckFromBatNumber" id="c8167ef5-f751-4d72-91a4-04185722727d">
        <source>findTruckFromBatNumber():CM_Vehicle;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 December 2013	cnwndl1	Initial creation	Par 32849

*/

vars

	term : CM_Terminal;
	vvr : CM_VehicleVisitRecord;
	batNum : String;

begin

	batNum := self.txtBatNo.text.toUpper;
	if batNum = null or batNum = self.lblBatNo.caption.toUpper then
		return null;
	endif;

	term := self.myMobileDataAgent.myTerminal;
	if term &lt;&gt; null then
		vvr := term.getVehicleVisitForBatNumber( batNum );
		if vvr &lt;&gt; null then
			return vvr.vehicle;
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_Vehicle"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="e3effc09-08fe-4e14-b93e-0f8791adcefa">
        <updating/>
        <source>handleBtnOne() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
22 January 2010	cnwndl1	Initial creation	CCMS MES 1005
25/02/2010		cnwcs5	Removed reference to old CM_GateLaneController class
*/

vars

	errorMess : String;

begin

	if not self.checkFindAndAssignTrailer() then
		return;
	endif;

	self.myMobileGenericAgent.setTruck( self.findTruck( errorMess, false ) );

	if errorMess &lt;&gt; null then
		self.msgBox(errorMess, app.getErrorString(Error), MsgBox_OK_Only, true);
		return;
	endif;
	
	if self.myMobileGenericAgent.myTruck = null then
		return;
	endif;
	// 09 Mar 2010 NDL	Par 22985
	if self.myMobileGenericAgent.myTruck.visitRecords.isEmpty then
		errorMess := app.getErrorString(Truck_has_no_visit_record);
		self.msgBox(errorMess, app.getErrorString(Error), MsgBox_OK_Only, true);
		return;
	endif;

	if self.myMobileGenericAgent.myTruck.myPrimaryActualLocation &lt;&gt; null and 
		self.myMobileGenericAgent.myTruck.myPrimaryActualLocation.isKindOf(CM_GateAreaLaneController) then	// 25/02/2010 cnwcs5
	
		self.gotoForm( MOB_HHGateCheckAllCargo, false );
		
	else

		if not self.myMobileGenericAgent.moveTruckToLane(errorMess) then
			self.msgBox(errorMess ,app.getErrorString(Error), MsgBox_OK_Only, true);
			return;
		endif;
	
		self.gotoForm( MOB_HHGateCheckAllCargo, false );
		
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleBtnTwo" id="3b23b75f-ae00-4434-a1ee-b70c5ceb6e88">
        <updating/>
        <source>handleBtnTwo() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22/01/2010	cnwndl1	Initial creation	CCMS MES 1005
08/03/2010	cnwdap1	PAR #22656 Reset lane controller (was being done in MOB_HHGateCheckAllCargo previously)
*/
vars

begin

	self.myMobileGenericAgent.clearAll();
	self.myMobileGenericAgent.setGateAreaLaneController(null, true);	// reset lane controller
	self.doBackButtonClick();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="isValidTruckForLane" id="8ec1df5d-acc4-41f0-b19e-3b6309dd728d">
        <source>isValidTruckForLane(truck : CM_Vehicle io; errMsg : String output);
/*
Purpose:			
Parameters:			
Return Value:		

Date			Who		Reason
25 January 2010	cnwndl1	Initial creation	CCMS MES 1005
25/02/2010		cnwcs5	Removed references to old CM_GateLaneController class
10/02/2011		cnwdap1	PAR #26102 Check truck has a location and at least one job 
*/
vars
	truckString 		: String;
	inward 				: Boolean;
	job 				: CM_RoadJob;
	outwardLane 		: Boolean;
	inYard 				: Boolean;
	inYardInterChange 	: Boolean;
	glc : CM_GateAreaLaneController;
	
begin
	
	if truck &lt;&gt; null then
		
		// PAR #26102 start
		if truck.myPrimaryActualLocation = null and truck.allRoadJobs.isEmpty then
			errMsg := app.getErrorString(Truck_no_jobs);
			truck := null;
			return;
		endif;
		// PAR #26102 end
		
		glc := cmbLane.listObject.CM_GateAreaLaneController;
		if glc &lt;&gt; null then
			if glc.hasVehicles then
				if not glc.allVehicleMachines.includes(truck) then
					// this lane alreday has a truck associated with it, and its not this truck.
					// Par 22679
					errMsg := app.getErrorString1(Lane_In_Use, self.myMobileGenericAgent.myGateAreaLaneController.getNiceName);
					truck := null;
					return;
				endif;
			endif;
		else

			errMsg := app.getErrorString(INV_Please_Select_A) &amp; app.getErrorString(Lane);
			truck := null;
			cmbLane.setFocus;
			return;
		endif;
	
		
		inward := self.myMobileGenericAgent.inward;

		if inward then
		
			inYard := false;
			outwardLane := false;
			if truck.myPrimaryActualLocation &lt;&gt; null then
				inYard := truck.myPrimaryActualLocation.CM_YardController.isInsideYard;
				if truck.myPrimaryActualLocation.isKindOf(CM_GateAreaLaneController) then
					outwardLane := truck.myPrimaryActualLocation.CM_GateAreaLaneController.laneDirection = CM_GateAreaLaneController.Is_Out_Lane;
				endif;
			endif;
		
			
			if truck.myPrimaryActualLocation &lt;&gt; null and inYard then
				if ( truck.myPrimaryActualLocation.isKindOf(CM_GateAreaLaneController) and  		// 25/02/2010 cnwcs5
					truck.myPrimaryActualLocation.CM_GateAreaLaneController.laneDirection = CM_GateAreaLaneController.Is_In_Lane ) then // 25/02/2010 cnwcs5
					// this means we have selected a truck that is already in a lane, i.e. we have already started
					// to confirm it, but got interupted for some reason.  This is OK.
				else
					// problem here this truck is already in the yard, but an inward lane has been selected.
					truckString := self.txtTruck.text;
					errMsg := app.getErrorString2(Truck_In_Yard, truckString, self.myMobileGenericAgent.myGateAreaLaneController.getNiceName);
					truck := null;
					return;
				endif;
				
			else
				if outwardLane then
					// truck is already in an outward lane...
					truckString := self.txtTruck.text;
					errMsg := app.getErrorString(Truck_outward_no_move_inward);
					truck := null;
					return;
				else
					// This truck is outside the yard i.e. Pre-Gate, ( heading for an inward lane )
				endif;
			endif;
			
		else
		
			outwardLane := false;
			inYard := false;
			if truck.myPrimaryActualLocation &lt;&gt; null then
				if truck.myPrimaryActualLocation.isKindOf(CM_GateAreaLaneController) then
					outwardLane := truck.myPrimaryActualLocation.CM_GateAreaLaneController.laneDirection = CM_GateAreaLaneController.Is_Out_Lane;
				endif;
				inYard := truck.myPrimaryActualLocation.CM_YardController.isInsideYard;
				inYardInterChange := truck.myPrimaryActualLocation.CM_YardController.isYardInterchangeAreaLocation;
			endif;
			
			if truck.myPrimaryActualLocation = null or ( not inYard and not inYardInterChange and not outwardLane ) then
						
				// problem here this truck is already outside the yard or in an inward lane.
				truckString := self.txtTruck.text;
				errMsg := app.getErrorString2(Truck_Outside_Yard, truckString, self.myMobileGenericAgent.myGateAreaLaneController.getNiceName);
				truck := null;
				return;
				
			else
				// This truck is in the yard (heading for an outward lane...) 
				job := truck.allRoadJobs.first.CM_RoadJob;
				if job &lt;&gt; null and job.status &lt;&gt; JOB_COMPLETE then
					errMsg := app.getErrorString1(ERR_JOB_NOT_COMPLETE,job.jobId);
					truck := null;
					return;
				endif;
				
			endif;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="truck" type="CM_Vehicle" usage="io"/>
        <Parameter name="errMsg" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="setupCmbGate" id="81b10d34-6604-4d80-83ba-1c26bed29c1c">
        <updating/>
        <source>setupCmbGate() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 January 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars
	
	term : CM_Terminal;
	index : Integer;
	gate : CM_Gate;
	defaultGate : CM_Gate;
	iter : Iterator;

begin

	self.setResizeableMarginAndFontSize();
	self.cmbGate.visible := true;
	self.cmbGate.move( self.resizedMargin,
						 self.resizedMargin,
						 self.clientWidth - self.resizedMargin - self.resizedMargin,
						 self.getStdControlHeight );

	self.cmbGate.clear();
	term := self.myMobileDataAgent.myTerminal;
	
	//add index 1 which is really just the labekl for the combo.
	index := self.cmbGate.addItem(lblGate.caption);
	self.cmbGate.itemForeColor[index] := Grey;
	
	iter := term.allGates.createIterator;
	while iter.next( gate ) do
		if not gate.hasPGateAreas then
			continue;
		endif;
		self.cmbGate.itemObject[self.cmbGate.addItem(gate.name)] := gate;
	endwhile;
	
	if self.cmbGate.listCount = 2 then
		// There is only one real gate, so select it.
		self.cmbGate.listIndex := 2;
	else
		defaultGate := term.getDefaultGate_IN;	// Par 22616

		if defaultGate &lt;&gt; null then
			index := cmbGate.findObject(defaultGate);
		endif;
		
		if index &gt; 0 then
			// the defualt inward gate.
			self.cmbGate.listIndex := index;
		else
			// the default label.
			self.cmbGate.listIndex := 1;
		endif;
	endif;
	
epilog

	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupCmbLane" id="67027e71-7d89-4645-b16f-6d7479e89c67">
        <updating/>
        <source>setupCmbLane() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 January 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	gate : CM_Gate;
	index : Integer;
	iter : Iterator;
	gateAreaUsage : CM_GateAreaUsage;
	gateArea : CM_TerminalArea;
	laneColl : CM_ObjectArray;
	obj : Object;
	glc : CM_GateAreaLaneController;

begin

	self.setResizeableMarginAndFontSize();
	self.cmbLane.clear();

	self.cmbLane.visible := true;
	self.cmbLane.move( self.resizedMargin,
						 self.resizedMargin + self.cmbGate.height + self.cmbGate.top,
						 self.clientWidth - self.resizedMargin - self.resizedMargin,
						 self.getStdControlHeight );

	self.cmbLane.clear();
	
	index := self.cmbLane.addItem(lblLane.caption);
	self.cmbLane.itemForeColor[index] := Grey;
	
	gate := self.cmbGate.listObject.CM_Gate;
	
	if gate = null then
		self.cmbLane.enabled := false;
		self.cmbLane.listIndex := 1;
		return;
	endif;
	
	self.cmbLane.enabled := true;
	create laneColl transient;
	
	//all inward gate areas.
	iter := gate.allGateAreas_IN.createIterator;
	while iter.next( gateAreaUsage ) do
		gateArea := gateAreaUsage.myGateArea;
		if gateArea &lt;&gt; null then
			if not gateArea.CM_GateArea.isPGate then
				continue;
			endif;
			laneColl.clear();
			gateArea.CM_GateArea.getAllLaneControllers (laneColl);
			foreach obj in laneColl discreteLock do
				glc	:= obj.CM_GateAreaLaneController;
				if glc.isUnavailable then
					continue;
				endif;
				if glc.laneDirection &lt;&gt; CM_GateAreaLaneController.Is_In_Lane then
					continue;
				endif;
				self.cmbLane.itemObject[self.cmbLane.addItem(glc.getNiceName)] := glc;
			endforeach;
		endif;
	endwhile;
	delete iter;
	
	//all outward gate areas.
	iter := gate.allGateAreas_OUT.createIterator;
	while iter.next( gateAreaUsage ) do
		gateArea := gateAreaUsage.myGateArea;
		if gateArea &lt;&gt; null then
			if not gateArea.CM_GateArea.isPGate then
				continue;
			endif;
			laneColl.clear();
			gateArea.CM_GateArea.getAllLaneControllers (laneColl);
			foreach obj in laneColl discreteLock do
				glc	:= obj.CM_GateAreaLaneController;
				if glc.isUnavailable then
					continue;
				endif;
				if glc.laneDirection &lt;&gt; CM_GateAreaLaneController.Is_Out_Lane then
					continue;
				endif;
				self.cmbLane.itemObject[self.cmbLane.addItem(glc.getNiceName)] := glc;
			endforeach;
		endif;
	endwhile;
	delete iter;
	
	if self.myMobileGenericAgent.myGateAreaLaneController &lt;&gt; null then
		self.cmbLane.listIndex := cmbLane.findObject(self.myMobileGenericAgent.myGateAreaLaneController);
	elseif self.cmbLane.listCount = 2 then
		self.cmbLane.listIndex := 2;
		self.myMobileGenericAgent.setGateAreaLaneController( cmbLane.itemObject[2].CM_GateAreaLaneController, true );
	else
		self.cmbLane.listIndex := 1;
		self.myMobileGenericAgent.setGateAreaLaneController( null, true );
	endif;

	self.setupTxtTruck();
	
epilog

	delete iter;
	delete laneColl;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupControls" id="42cba716-4469-4324-ab61-fb82271d5724">
        <updating/>
        <source>setupControls() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

begin

	if self.myMobileGenericAgent.myGate = null then 
		self.setupCmbGate();
		self.setupCmbLane();
		self.setupTxtTruck();
	
	else
		//we are returning to this screen with a gate.
		self.setupCmbGate();
		cmbGate.listIndex := cmbGate.findObject(self.myMobileGenericAgent.myGate);
		self.setupCmbLane();
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="c7981f78-7e15-4ccf-ae31-86148935931b">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 January 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars
	
begin

	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;

	inheritMethod();
	
	self.setupCmdButtons( 2, app.getErrorString(Next), app.getErrorString(Menu), null, null, null );
	
	self.setupControls();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupTxtTruck" id="b076c460-e33d-48ed-b275-3a7957feacc0">
        <updating/>
        <source>setupTxtTruck() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 January 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	glc : CM_GateAreaLaneController;
	truck : CM_Vehicle;
	top : Real;
	stdWidth : Real;
	stdHeight : Real;
	term : CM_Terminal;

begin

	self.setResizeableMarginAndFontSize();
	stdHeight := self.getStdControlHeight;

	glc := self.myMobileGenericAgent.myGateAreaLaneController;
	
	top := self.resizedMargin + self.cmbLane.height + self.cmbLane.top;
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	
	self.txtTruck.visible := true;
	self.txtTruck.move( self.resizedMargin,
						 top,
						 stdWidth,
						 stdHeight );
	
	self.txtTruck.text := lblTruck.caption.toUpper;
	
	top := self.resizedMargin + self.txtTruck.height + self.txtTruck.top;
	self.txtState.visible := self.myMobileGenericAgent.showState;
	self.txtState.move( self.resizedMargin,
						 top,
						 stdWidth,
						 stdHeight );
	
	self.txtState.text := self.lblState.caption.toUpper;
	
	//20 Dec 2013	NDL	Par 32849
	if self.txtState.visible then
		top := self.resizedMargin + self.txtState.height + self.txtState.top;
	endif;
	term := self.myMobileDataAgent.myTerminal;
	self.txtBatNo.visible := term.getConfig(SiteHasSecurityGate).Boolean;
	self.txtBatNo.move( self.resizedMargin,
						 top,
						 stdWidth,
						 stdHeight );
	self.txtBatNo.text := self.lblBatNo.caption.toUpper;
	
	//14 July 2014	NDL	Par 34562
	if self.txtBatNo.visible then
		top := self.resizedMargin + self.txtBatNo.height + self.txtBatNo.top;
	endif;
	self.txtAssignTrailer.visible := false;
	self.txtAssignTrailer.move( self.resizedMargin,
						 top,
						 stdWidth,
						 stdHeight );
	self.txtAssignTrailer.text := self.lblAssignTrailer.caption.toUpper;
	
	
	if glc = null then
		return;
	endif;
	
	truck := glc.allVehicleMachines.first.CM_Vehicle;
	if truck &lt;&gt; null then
		self.txtTruck.text := truck.regNumber;
		self.txtState.text := truck.state;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="7648ad4d-63e6-4ec5-afba-3f5faf81d665">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 31 July 2014.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0015175, locale);
	lblAssignTrailer.translateCaption(Xlat_0019770, locale);
	lblBatNo.translateCaption(Xlat_0019498, locale);
	lblGate.translateCaption(Xlat_0013954, locale);
	lblLane.translateCaption(Xlat_0013955, locale);
	lblState.translateCaption(Xlat_0014238, locale);
	lblTruck.translateCaption(Xlat_0013956, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
