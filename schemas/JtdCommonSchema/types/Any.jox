<PrimType name="Any">
    <JadeMethod name="atcgDisplayWithType" id="7c6042c7-ded8-4101-ad84-c6bf4a72033b">
        <source>atcgDisplayWithType():String;

vars
	s:String;
	type:Type;
begin
	type:=self.cnGetType;
	if type = null then
		return "null";
	endif;
	if type.name = "Object" then
		return self.String;
	else
		s:=s&amp;type.name&amp;"=";
		if type = String or type = TimeStamp then
			s:=s&amp;'"'&amp;self.asString&amp;'"';
		else
			s:=s&amp;self.getName;
		endif;
		return s;
	endif;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
</PrimType>
