    <JadeMethod name="doShowPhotos" id="697084d6-8478-403d-8e56-190477d5180c">
        <source>doShowPhotos();

//1/12/2009 cnwdz2 	par21808
//15/6/2015	cnwdap1	PAR #36421 Hazardous Materials Handling
//08 Aug 2025	navhl20 Story MTN-35650: TPT | Uploading of Photos into MTN Production | 2 | Thin Client Changes

vars
