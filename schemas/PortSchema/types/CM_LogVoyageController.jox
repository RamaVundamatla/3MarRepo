    <JadeMethod name="getSpecsForOperator" id="aff26332-9ff4-4f76-90df-e9574f1aac93">
        <source>getSpecsForOperator(	_operator 	: CM_Operator;
						_allSpecies,
						_allGrades	 : CM_CodeSet input);

vars
	
	iter	: Iterator;
	soh		: CM_SOHLocation;

begin

	iter := self.allProductLocations.createIterator;
	while iter.next(soh) do
		if soh.allTrackedItems.size &gt; 0 
		and soh.myOperator = _operator then
			if not _allGrades.includes(soh.myProduct.CM_ProductLog.myLogGrade) then
				_allGrades.add(soh.myProduct.CM_ProductLog.myLogGrade);
			endif;
			if not _allSpecies.includes(soh.myProduct.CM_ProductLog.myLogSpecies) then
				_allSpecies.add(soh.myProduct.CM_ProductLog.myLogSpecies);
			endif;
		endif;
	endwhile;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_allSpecies" type="CM_CodeSet" usage="input"/>
        <Parameter name="_allGrades" type="CM_CodeSet" usage="input"/>
    </JadeMethod>
