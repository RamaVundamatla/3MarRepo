        <updating/>
        <source>txtFind_firstChange(textbox: TextBox input) updating;

/*

Purpose:		If we change the find details then start searching from the beginning

Date			Who		Reason
04/09/2012		cnwmh5	Initial creation

*/

vars

begin

	self.resetFindStart();
	
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="be79a120-3ef5-4a8e-9854-85ebe675ca5a">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(_eventType: Integer; _object: Object; _eventTag: Integer; _userInfo: Any) updating;

vars
	event 	: Integer;
	object 	: CM_Object;
begin 
	event 	:= self.myTerminal.getEventFromTerminalEvent(_eventType);
	object	:= _userInfo.CM_Object;
	
	//self.handleUserNotification(object, event);	//27/03/2025	navkc1 JIRA Story MTN-34156

	//27/03/2025	navkc1 JIRA Story MTN-34156
	if self.notificationLevel = self.NoteLevelDoNotes then
		self.beginTimerForNotifications(_object, event, _eventTag, object);
	endif;
	
end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
        <Parameter name="_userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
