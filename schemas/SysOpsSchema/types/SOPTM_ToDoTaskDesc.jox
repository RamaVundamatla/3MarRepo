    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="1a4ae259-c2cd-4b8e-b4f3-82b06ad70a6a">
        <updating/>
        <source>setControlsForAddEdit() updating;
// 19/06/2013	cnwcs5	par 31657 - tidy up while fixing par
// 09/07/2013	cnwdap1	PAR #31959 - fix userInputEnabled for mulSelect3 and mulSelect6
//						Must be done at the end of themethod, as self.showThumbnail sets userInputEnabled to false
// 17 Nov 2022  navhl20 ChangeRequest 56634[54259]: EUP - Todo Task Description Maintenance
// 22/12/2022   navcs2	ChangeRequest 56006: EUP - New VAS Workorder Subscription (task 56008)
//13th March 2024 	navra1		BUG 62783 - FR - System Admin / To Do Task Description and Resources Type Edits
vars
	form    : SOP_TableMaintForm;
	table	: CM_EntryTable;
	proxy	: CM_ToDoTaskDesc;
begin
	form 	:= self.myForm;
	table	:= form.tblInput1;
	
	form.tblInput1.userInputEnabled 	:= true;
	form.mulSelect1.userInputEnabled	:= true;
	form.mulSelect2.userInputEnabled 	:= true;
	//form.mulSelect3.userInputEnabled 	:= true;	//13 Oct 2010	NDL Par 23991		// PAR #31959
	//form.mulSelect6.userInputEnabled 	:= true;	//13 Oct 2010	NDL Par 23991		// PAR #31959
	form.chkAnyTriggField.visible 		:= false;	//13 Oct 2010	NDL Par 23991
	
	if form.mode = form.Mode_Add then
		table.clearValues;
		table.enableRowByName(ETRow_Description);
		table.enableRowByName(ETRow_ShortDescription);
		table.enableRowByName(ETRow_ReportDescription);
		table.enableRowByName(ETRow_TransactionToCreate);
		table.enableRowByName(ETRow_TrxToCreateOnCreation); //cnwrs1 CCMS 1826 29 July 2010
		table.setFocus;
		table.moveFirst();
		
		form.mulSelect1.setSelected(null);
		form.mulSelect2.setSelected(null);
		form.mulSelect3.setSelected(null);
		form.mulSelect6.setSelected(null);	//13 Oct 2010	NDL Par 23991
		form.mulSelect41.setSelected(null);
		form.mulSelect42.setSelected(null);
		form.loadCmbType(TODO_TYPE_GROUP_TI_STR, true);		//17/11/2022 navhl20 TFS 56634[54259] // ### TFS 56634[54259] 21NOV2022 NAVAB1 added class
		
		// 22/12/2022 navcs2 ChangeRequest 56006 (task 56008)
		if not app.myPassport.isVASEnabled then
			form.tblInput1.setValueByName(ETRow_Type,app.getToDoTaskIntToString(TODO_TYPE_GROUP_TI));
			form.tblInput1.disableRowByName(ETRow_Type);
		else
			table.enableRowByName(ETRow_Type);
		endif;
	else
		proxy := form.myProxyObject.CM_ToDoTaskDesc;
		
		// refresh the data from the newly created proxy
		self.showThumbnail(proxy);
		
		// cannot update code
		//table.disableRowByName(ETRow_Type);									//navra1 - 13th March 2024 - BUG 62783
		table.enableRowByName(ETRow_Description);
		table.enableRowByName(ETRow_ShortDescription);
		table.enableRowByName(ETRow_ReportDescription);
		table.enableRowByName(ETRow_TransactionToCreate);
		
		form.mulSelect1.setSelected(proxy.allCargoTypes);
		form.mulSelect2.setSelected(proxy.allResourceTypes);
		form.mulSelect3.setSelected(proxy.allAllowedReleaseTerms);	//13 Oct 2010	NDL Par 23991
		form.mulSelect6.setSelected(proxy.allAllowedEditSubTerms);	//13 Oct 2010	NDL Par 23991
		

	endif;
	
	self.enableMulSelect1Contents();
	self.enableMulSelect2Contents();
	form.mulSelect3.userInputEnabled 	:= true;										// PAR #31959
	form.mulSelect6.userInputEnabled 	:= true;										// PAR #31959
	
	form.lblTBDataTable1.visible := true;	// TFS 2443
end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="48a8edc2-184e-45da-bffe-ab1fba19daef">
        <updating/>
        <source>setCtrlsForView() updating;
// 19/06/2013	cnwcs5	par 31657 - tidy up while fixing par
vars
	form 	: SOP_TableMaintForm;
	table	: CM_EntryTable;
	
begin
	//cnwmc5 - 17 Oct 2013 - PAR 32622
	inheritMethod();
	
	form 	:= self.myForm;
	table 	:= form.tblInput1;
	
	table.userInputEnabled := false;
	
	form.mulSelect1.setSelected(null);
	form.mulSelect2.setSelected(null);
	form.mulSelect3.setSelected(null);		//13 Oct 2010	NDL Par 23991
	form.mulSelect6.setSelected(null);		//13 Oct 2010	NDL Par 23991
	
	form.chkAnyTriggField.visible := false;	//13 Oct 2010	NDL Par 23991

	form.shtDataTable1.enabled	:= true;	// 18/8/16	MAP	TFS 2443
	form.btnDT1_Edit.enabled := false;
	
	form.lblTBDataTable1.visible := false;	// TFS 2443
	
	table.cnEcResizeContents();

end;</source>
    </JadeMethod>
    <JadeMethod name="setTableDisplayForTerminal" id="c7526ef5-9420-4e5c-974b-e4d38c2c3b17">
        <source>setTableDisplayForTerminal(_crit: CM_TaskCriteria; _table: CM_DataTable input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 August 2016	cnwmp6	Initial creation	TFS 2443

*/

vars
	terminal		: CM_Terminal;
	toDoTaskDesc	: CM_ToDoTaskDesc;
	type			: Integer;
	
begin
	if _crit = null then
		_table.addItemObject(null, app.getErrorString(Not_Setup));
	else
		terminal := _crit.myTerminal;
		// ### TFS 63920 (63924) 01May2024 NAVPW1
		toDoTaskDesc := _crit.myToDoTaskDesc;
		
		if toDoTaskDesc &lt;&gt; null then
			type := toDoTaskDesc.type;
		endif;
		
		// ### TFS 63920 (63924) 01May2024 NAVPW1
		if type = TODO_TYPE_GROUP_CARGOGROUP or type = TODO_TYPE_GROUP_TI then // ### TFS 63920 (63924) 01May2024 NAVPW1
			_table.addItemObject(terminal, app.getErrorString(Criteria) &amp; Tab &amp; _crit.getCriteriaSummary(Comma_And_Space));
			
			_table.addItemObject(terminal, StopApplyPackCompleteStr &amp; Tab &amp; _crit.allAutoApplyActions.includes(TRANS_TYPE_PackComplete).getYesNo);
			_table.addItemObject(terminal, StopApplyUnpackCompleteStr &amp; Tab &amp; _crit.allAutoApplyActions.includes(TRANS_TYPE_UnpackComplete).getYesNo);
			_table.addItemObject(terminal, app.getErrorString(Repair) &amp; Tab &amp; _crit.allAutoApplyActions.includes(TRANS_TYPE_REPAIR).getYesNo);
			
			if _crit.moveOnCreation = -1 then
				_table.addItemObject(terminal, app.getErrorString(Move_creation) &amp; Tab &amp; app.getErrorString(None));
			else
				_table.addItemObject(terminal, app.getErrorString(Move_creation) &amp; Tab &amp; app.moveModeStatusEnumToString(_crit.moveOnCreation));
			endif;
			if _crit.moveOnCompletion = -1 then
				_table.addItemObject(terminal, app.getErrorString(Move_completion) &amp; Tab &amp; app.getErrorString(None));
			else
				_table.addItemObject(terminal, app.getErrorString(Move_completion) &amp; Tab &amp; app.moveModeStatusEnumToString(_crit.moveOnCompletion));
			endif;
			
		endif;
		
		// ### TFS 58761 (60739) 16Nov2023 NAVPW1
		if app.myPassport.isVASEnabled then
			_table.addItemObject(terminal, app.getErrorString(Available_resource_groups) &amp; Tab &amp; _crit.allAvailableResourceGroups.listString(Comma, CM_ResourceTypeGroup::code.name));
			_table.addItemObject(terminal, app.getErrorString(Mandatory_resource_groups) &amp; Tab &amp; _crit.allMandatoryResourceGroups.listString(Comma, CM_ResourceTypeGroup::code.name));
		endif;
		// ### TFS 58761 (60739) 16Nov2023 NAVPW1
	endif;
end;</source>
        <Parameter name="_crit" type="CM_TaskCriteria"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupResources" id="2d46db1f-9ffe-4b90-8f83-180e6ad3acdf">
        <source>setupResources(_type : Integer);
/*
Purpose:			

Date		Who		Reason
18NOV2022	NAVAB1	ChangeRequest 56635:[54261] EUP - Todo Task Resources Maintenance
*/

vars
	form 			: SOP_TableMaintForm;
	row,
	category,
	type 			: Integer;
	trxType			: CM_TransactionType;
	comboComplete, comboCreate		: ComboBox; 
	str				: String;	
	eventType	: CM_EventType;
	coll 			: CM_ObjectSetActual;
	resourceType    : CM_ResourceType;
begin
	form 				:= self.myForm;
	// Only show those which are available
	create coll transient;

	foreach resourceType in app.myRoot.allTaskResourceTypes 
		where (resourceType.type = _type or resourceType.type = TODO_TYPE_GROUP_ALL) // ### TFS #56635[54261] 21NOV2022 NAVAB1
		and resourceType.isAvailable do 	
		coll.add(resourceType);
	endforeach;

	self.setupMultiSelect2(app.getErrorString(ToDoTaskResources), coll, SOP_TableMaintForm::displayToDoResourceType.name);

end;</source>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="4e4bf572-c2a7-4b88-a630-296b00e510b5">
        <source>setupThumbnailDetails();
// 18 Jun 2013	cnwcs5	par 31657 - trx types for todo task completion

vars
	form 			: SOP_TableMaintForm;
 	comboExtra		: ComboBox; 
	
begin
	form 				:= self.myForm;
	form.useProxyObject := true;
	
	form.setTblDataEntRows(ETDef_ToDoTaskTbl);
	
	form.setupMTReportColumnCombo();

	form.shtTblInput1.caption := 'Details';
	
	form.initTblInput(form.tblInput1, ETDef_ToDoTaskDescMaint);
	
	form.shtTblInput1.visible := true;
	
	form.mulSelect1.formDisplayEntryMethodName := null;
	form.mulSelect2.formDisplayEntryMethodName := null;
	form.mulSelect3.formDisplayEntryMethodName := null;	//13 Oct 2010	NDL Par 23991
	form.mulSelect6.formDisplayEntryMethodName := null;	//13 Oct 2010	NDL Par 23991
	
	//19 Feb 2010	#cnwdz2	par22432 SFW 1071
	comboExtra := form.cmbExtraInfo;
	
	comboExtra.clear();
	comboExtra.addItem("");
	comboExtra.addItem(EXTRA_INFO_DAMAGE);
	comboExtra.addItem(EXTRA_INFO_DIMENSION);
	//comboExtra.addItem(EXTRA_INFO_HAZARD_SYMBOLS); //doesn't do anything looks like it was moved to cargo checks
	//comboExtra.addItem(EXTRA_INFO_IS_OD);//doesn't do anything looks like it was moved to cargo checks
	//comboExtra.addItem(EXTRA_INFO_PHOTO);		// 27/03/2014 cnwar2 #35918
	comboExtra.addItem(EXTRA_INFO_SEALS);
	comboExtra.addItem(EXTRA_INFO_SPECIAL_LIFT);	//31 May 2010	NDL	Par 23903
	comboExtra.addItem(EXTRA_INFO_WEIGHT);

end;</source>
    </JadeMethod>
    <JadeMethod name="setupTransactionTypes" id="9b9c16db-a2ae-4b57-b5ab-92ba425ab8f0">
        <source>setupTransactionTypes(_type : Integer);
/*
Purpose:			
Date				Who			Reason
FEBRUARY 2015		CNWAB1		Initial creation
31 Oct 2022 		navma1 		ChangeRequest 56636[54258]: EUP - Adding New Event Type for VAS TodoTask Description
22 May 2023 	    navmv20     CR 57924 Task 57920: UI - Work Order Trans Types on TO DO Tasks
11 Dec 2023			jlizm1		TFS 61654 CUX ToDo Task don't block RTL
*/
vars
	form 			: SOP_TableMaintForm;
	category,					
	type 			: Integer;	
	trxType			: CM_TransactionType;
	comboComplete, 
	comboCreate		: ComboBox; 
	str				: String;	
	eventType		: CM_EventType;	
	todotype 		: CM_ToDoTaskDesc;
begin
	form 				:= self.myForm;
	comboComplete 		:= form.cmbTransaction;	
	comboComplete.clear();
	comboComplete.addItem("");
	
	comboCreate := form.cmbTrxOnCreation;	
	
	comboCreate.clear();
	comboCreate.addItem("");
	
	if _type = null then
		todotype := form.cmbType.listObject.CM_ToDoTaskDesc; // ### TFS  #56634[54259] 28NOV2022 NAVAB1
		if todotype &lt;&gt; null then 							 // ### TFS  #56634[54259] 28NOV2022 NAVAB1
			type := todotype.type; 							 // ### TFS  #56634[54259] 28NOV2022 NAVAB1
		else
			type := TODO_TYPE_GROUP_TI; 					// ### TFS   #56634[54259] 28NOV2022 NAVAB1
		endif;
	else 
		type := _type;
	endif;
	
	if type = TODO_TYPE_GROUP_CARGOGROUP or type = TODO_TYPE_GROUP_TI then //02/11/2022 navds20 TFS  #56634[54259]
		form.shtDataTable1.visible   := true;
		form.shtMultiSelect1.visible := true;
		form.shtMultiSelect6.visible := true;
		form.shtMultiSelect3.visible := true;
		form.tblInput1.showRowByName(ETRow_RequiredExtraInfo,false);
		form.tblInput1.showRowByName(ETRow_EmptyReportColumn,false);
		form.tblInput1.showRowByName(ETRow_RequiresWorkOrder,false);
		form.tblInput1.showRowByName(ETRow_DoNotBlockRTL, false);

		foreach trxType in app.myRoot.allTransactionTypes do
			if not trxType.useInTodoTaskMaintenance() then // PAR 33570
				continue;
			endif;
			
			// ### JIRA 14793 24OCT2024 NAVAB1 add WO Transaction types
			if trxType.isForWorkOrder()
			and not trxType.doesMatchToDoType(type) then
				continue;
			endif;

			//str := trxType.description; //22/05/2023  navmv20 CR 57924 Task 57920
			str := app.getTrxGrpIntToString(trxType.trxGroup) &amp; " " &amp; trxType.description; //22/05/2023  navmv20 CR 57924 Task 57920
			
			comboComplete.itemObject[comboComplete.addItem(str)] := trxType;
			comboCreate.itemObject[comboCreate.addItem(str)]     := trxType;
		endforeach;
		
		//22/05/2023  navmv20 CR 57924 Task 57920 - START
		if app.myPassport.isVASEnabled() then
			trxType := app.myRoot.allTransactionTypes[TRANS_TYPE_WO_TITODO_COMPLET];
			if trxType &lt;&gt; null then
				str := app.getTrxGrpIntToString(trxType.trxGroup) &amp; " " &amp; trxType.description;
				comboComplete.itemObject[comboComplete.addItem(str)] := trxType;
			endif;
			trxType := app.myRoot.allTransactionTypes[TRANS_TYPE_WO_TITODO_CREATED];
			if trxType &lt;&gt; null then
				str := app.getTrxGrpIntToString(trxType.trxGroup) &amp; " " &amp; trxType.description;
				comboCreate.itemObject[comboCreate.addItem(str)]     := trxType;
			endif;
		endif;
		//22/05/2023  navmv20 CR 57924 Task 57920 - END
	else 
		form.shtDataTable1.visible   := false;
		// ### TFS 63920 (63924) 01May2024 NAVPW1
		if app.myPassport.isVASEnabled then
			form.shtDataTable1.visible   := true;
		endif;
		// ### TFS 63920 (63924) 01May2024 NAVPW1
		form.shtMultiSelect1.visible := false;
		form.shtMultiSelect6.visible := false;
		form.shtMultiSelect3.visible := false;
		form.tblInput1.hideRowByName(ETRow_RequiredExtraInfo,false);
		form.tblInput1.hideRowByName(ETRow_EmptyReportColumn,false);
		form.tblInput1.hideRowByName(ETRow_RequiresWorkOrder,false);
		form.tblInput1.hideRowByName(ETRow_DoNotBlockRTL, false);

		if type = TODO_TYPE_GROUP_VOYAGE then
			category := CM_EventType.VOYAGE_EVENT;
		elseif type = TODO_TYPE_GROUP_TRAIN then
			category := CM_EventType.TRAIN_EVENT;
		elseif type = TODO_TYPE_GROUP_WAGON then
			category := CM_EventType.WAGON_EVENT;
		elseif type = TODO_TYPE_GROUP_VEHICLEBOOKING then		//31.10.2022 navma1 #56636[54258]
			category := CM_EventType.VBS_EVENT;				
		elseif type = TODO_TYPE_GROUP_VEHICLE then
			category := CM_EventType.TRUCK_EVENT;			
		elseif type = TODO_TYPE_GROUP_NONOPS then				//31.10.2022 navma1 #56636[54258]
			category := CM_EventType.NONOPS_EVENT;
		endif;
		
		foreach eventType in app.myRoot.allEventTypesByType where eventType.category = category do
			str := app.getErrorString(Event_Abbr) &amp; " " &amp; eventType.name; //22/05/2023  navmv20 CR 57924 Task 57920
			//str := eventType.name; //22/05/2023  navmv20 CR 57924 Task 57920
			
			comboComplete.itemObject[comboComplete.addItem(str)] := eventType;
			comboCreate.itemObject[comboCreate.addItem(str)] 	 := eventType;
		endforeach;
		
		// ### JIRA 14793 24OCT2024 NAVAB1 add WO Transaction types
		foreach trxType in app.myRoot.allTransactionTypes do
			if trxType.isSystemTransType then
				continue;
			endif;
			if not trxType.isForWorkOrder then
				continue;
			endif;
			
			if not trxType.doesMatchToDoType(type) then
				continue;
			endif;
			
			str := app.getTrxGrpIntToString(trxType.trxGroup) &amp; " " &amp; trxType.description;
			
			comboComplete.itemObject[comboComplete.addItem(str)] := trxType;
			comboCreate.itemObject[comboCreate.addItem(str)]     := trxType;
		endforeach;
		
	endif;
	
end;</source>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="139e3bfb-29fd-4619-acb8-eaa213c49434">
        <updating/>
        <source>showThumbnail(_todoTask: CM_ToDoTaskDesc) updating;
// 19/06/2013	cnwcs5	par 31657 - tidy up while fixing par
// 31/10/2022   navds20 ChangeRequest 56634[54259]: EUP - Todo Task Description Maintenance
// 22 May 2023  navmv20 CR 57924 Task 57920: UI - Work Order Trans Types on TO DO Tasks
// 11/12/2023	jlizm1	TFS 61654 CUX ToDo Task don't block RTL
vars
	form			: SOP_TableMaintForm;
	table			: CM_EntryTable;
	combo			: CMUI_ComboBox;
	idx       		: Integer;
	trxType 		: CM_TransactionType; 
	coll 			: CM_ObjectSetActual;
	resourceType    : CM_ResourceType;
	eventtype		: CM_EventType;	
	type 			: Integer;	
begin
	self.setupTransactionTypes(null);	//02/11/2022 navds20 TFS  #56634[54259]
	self.setupResources(null); 			// ### TFS  #56634[54259] 18NOV2022 NAVAB1
	
	self.getTerminalsForUser();	// TFS 2443

	form	:=	self.myForm;
	table	:= form.tblInput1;
	
	table.clearValues();
	
	table.setValueByName(ETRow_Description,	_todoTask.description);
	table.setValueByName(ETRow_SortKey, _todoTask.sortKey);
	table.setValueByName(ETRow_ShortDescription, _todoTask.shortDescription);
	table.setValueByName(ETRow_ReportDescription, _todoTask.reportDescription);
	table.setValueByName(ETRow_RequiresWorkOrder, _todoTask.requiresWorkOrder);			//+cnwml2 SFW CCMS 1075
	table.setValueByName(ETRow_DoNotBlockRTL, _todoTask.doNotBlockRTL);
	

	form.tblInput1.setValueByName(ETRow_Type,app.getToDoTaskIntToString(_todoTask.type));	// 31/10/2022 navds20 TFS  #56634[54259]
	form.loadCmbType(app.getToDoTaskIntToString(_todoTask.type), true); 					// ### TFS  #56634[54259] 21NOV2022 NAVAB1 added class
	
	//19 Feb 2010	#cnwdz2	par22432 SFW 1071
	if _todoTask.requiredExtraInfo &lt;&gt; null then
		idx := form.cmbExtraInfo.findStringExact(0, _todoTask.requiredExtraInfo);
		
		form.cmbExtraInfo.listIndex := idx;
		
		table.setValueByName(ETRow_RequiredExtraInfo, _todoTask.requiredExtraInfo);
	else
		form.cmbExtraInfo.listIndex := -1;
	endif;
	
	if form.cmbMTReportCol.listCount &gt;= _todoTask.emptyReportColumn and _todoTask.emptyReportColumn &gt; 0 then
		form.cmbMTReportCol.listIndex	:=	_todoTask.emptyReportColumn;
		
		table.setValueByName(ETRow_EmptyReportColumn, form.cmbMTReportCol.text);
	endif;
	
	// PAR 22099 - Nedd to do the following as may be historical data, or someone may have changed flag on
	// ToDo Task screen - avoids an object not in collection expection

	// Transaction to create on COMPLETION
	if _todoTask.myTransactionType &lt;&gt; null then		//02/11/2022 navds20 TFS  #56634[54259]
		trxType := _todoTask.myTransactionType;
		combo	:= form.cmbTransaction;
		
		if trxType &lt;&gt; null then
			if (combo.findObject(trxType) &lt;= 0) then
				combo.addItemObject(trxType.description, trxType);
			endif;
		endif;
		
		combo.listObject := trxType;
		
		table.setValueByName(ETRow_TransactionToCreate, combo.text);

		// Transaction to create on CREATION
		combo := form.cmbTrxOnCreation;
		
		if _todoTask.trxTypeOnCreation &lt;&gt; null then
			trxType := _todoTask.getTrxTypeOnCreation();
			
			if (combo.findObject(trxType) &lt;= 0) then
				combo.addItemObject(trxType.description, trxType);
			endif;
		//22/05/2023  navmv20 CR 57924 Task 57920 - START
			if trxType = null then
				eventtype := app.myRoot.allEventTypesByType[_todoTask.trxTypeOnCreation];
			
				if (combo.findObject(eventtype) &lt;= 0) then
					combo.addItemObject(eventtype.description, eventtype);
				endif;
			endif;
		//22/05/2023  navmv20 CR 57924 Task 57920 - end
		else
			trxType := null;
		endif;
		
		//22/05/2023  navmv20 CR 57924 Task 57920 - start
		if eventtype &lt;&gt; null then
			combo.listObject := eventtype;
		else
			combo.listObject := trxType;
		endif;
		//combo.listObject := trxType;
		//22/05/2023  navmv20 CR 57924 Task 57920 - end
		
		table.setValueByName(ETRow_TrxToCreateOnCreation, combo.text);
	//start 02/11/2022 navds20 TFS  #56634[54259]
	else
		eventtype := _todoTask.myEventType;
		combo	:= form.cmbTransaction;
		
		if eventtype &lt;&gt; null then
			if (combo.findObject(eventtype) &lt;= 0) then
				combo.addItemObject(eventtype.description, eventtype);
			endif;
		endif;
		
		combo.listObject := eventtype;
		
		table.setValueByName(ETRow_TransactionToCreate, combo.text);

		// Transaction to create on CREATION
		combo := form.cmbTrxOnCreation;
		
		if _todoTask.trxTypeOnCreation &lt;&gt; null then
			eventtype := app.myRoot.allEventTypesByType[_todoTask.trxTypeOnCreation];
			
			if (combo.findObject(eventtype) &lt;= 0) then
				combo.addItemObject(eventtype.description, eventtype);
			endif;
			
			//22/05/2023  navmv20 CR 57924 Task 57920 - start
			if eventtype = null then
				trxType := _todoTask.getTrxTypeOnCreation();
				
				if (combo.findObject(trxType) &lt;= 0) then
					combo.addItemObject(trxType.description, trxType);
				endif;
			endif;
			//22/05/2023  navmv20 CR 57924 Task 57920 - end
		else
			eventtype := null;
		endif;
		
		//22/05/2023  navmv20 CR 57924 Task 57920 - start
		if trxType &lt;&gt; null then
			combo.listObject := trxType;
		else
			combo.listObject := eventtype;
		endif;
		//combo.listObject := eventtype;
		//22/05/2023  navmv20 CR 57924 Task 579200 - end
		
		table.setValueByName(ETRow_TrxToCreateOnCreation, combo.text);
	endif;
	//end 02/11/2022 navds20 TFS  #56634[54259]
	
	//DVB COME BACK TO THIS AFTER MODEL UPDATE	
	form.mulSelect1.setSorted(true);
	form.mulSelect1.setSelected(_todoTask.allCargoTypes);
	
	self.disableMulSelect1Contents();
	
	//start 07/11/2022 navds20 TFS  #56634[54259]
	create coll transient;
	type:= self.myForm.myCurrentObject.CM_ToDoTaskDesc.type;
	foreach resourceType in app.myRoot.allTaskResourceTypes where resourceType.isAvailable do 
		if resourceType.type = TODO_TYPE_GROUP_ALL  			// ### TFS  #56634[54259] 21NOV2022 NAVAB1
		or resourceType.type = type  then
			coll.add(resourceType);
		endif;
	endforeach;
	//end 07/11/2022 navds20 TFS  #56634[54259]
	self.setupMultiSelect2(app.getErrorString(ToDoTaskResources), coll, SOP_TableMaintForm::displayToDoResourceType.name);
	
	form.mulSelect2.setSorted(true);
	form.mulSelect2.setSelected(_todoTask.allResourceTypes);
	
	self.disableMulSelect2Contents();
	
	//13 Oct 2010	NDL Par 23991
	form.mulSelect3.setSorted(true);
	form.mulSelect3.setSelected(_todoTask.allAllowedReleaseTerms);
	form.mulSelect3.userInputEnabled := false;
	
	form.mulSelect6.setSorted(true);
	form.mulSelect6.setSelected(_todoTask.allAllowedEditSubTerms);
	form.mulSelect6.userInputEnabled := false;
	
	showThumbnail_Terminal(_todoTask);	// TFS 2443
	
epilog
	
end;</source>
        <Parameter name="_todoTask" type="CM_ToDoTaskDesc"/>
    </JadeMethod>
    <JadeMethod name="showThumbnail_Terminal" id="b0d96658-897b-431a-8a75-eaef07d04741">
        <source>showThumbnail_Terminal(_todoTask: CM_ToDoTaskDesc);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 August 2016	cnwmp6	Initial creation	TFS 2443

*/

vars
	table		:CM_DataTable;
	terminal	:CM_Terminal;
	row			:Integer;
	template	:CM_TaskCriteria;
begin
	table 		:= self.myForm.tblData1;
	table.rows 	:= 0;

	
	foreach terminal in self.allTerminalsForThisUser do		
		row 	:= table.addItemObject (terminal, app.getErrorString (Terminal) &amp; ': ' &amp; terminal.code);
		table.accessRow(row).fontBold := true;
		table.accessRow(row).backColor := Gray;

		template := _todoTask.allTaskCriteria.getAtKeyGeq(terminal, _todoTask.code);	// ### TFS 62186 (62196) 02Feb2024 NAVPW1
		
		if template = null or 
			terminal.code &lt;&gt; template.myTerminal.code or	//The terminal could be different. 
			template.myToDoTaskDesc = null or 				//The object oid of the terminal being looked for can be less then the one in the collection
			template.myToDoTaskDesc.code &lt;&gt; _todoTask.code 
		then	// ### TFS 62186 (62196) 02Feb2024 NAVPW1
			row := self.myForm.tblData1.addItemObject (terminal, app.getErrorString (Not_Setup));
		else
			self.setTableDisplayForTerminal(template, table);
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_todoTask" type="CM_ToDoTaskDesc"/>
    </JadeMethod>
</Class>
