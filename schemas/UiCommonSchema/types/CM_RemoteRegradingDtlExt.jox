<Class name="CM_RemoteRegradingDtlExt">
    <JadeMethod name="loadRemoteTable" id="a9609782-04c8-4bb4-864e-a768242247d8">
        <updating/>
        <source>loadRemoteTable(_table: CM_EntryTable io) updating;

// cnwdvb1 31 March 2003 

vars

	tmpRow	: Integer;
	extra	: CM_RemoteDataExtra;

begin

	inheritMethod(_table);
	_table.setColumnHeadings('Item', 'Value');
	self.addRemoteRow(_table, 'Area', self.area, null);
	self.addRemoteRow(_table, 'Location', self.location, null);
	self.addRemoteRow(_table, 'Supplier', self.supplier, null);
	self.addRemoteRow(_table, 'Species', self.species, null);
	self.addRemoteRow(_table, 'Grade', self.grade, null);
	self.addRemoteRow(_table, 'Type', self.type, null);
	self.addRemoteRow(_table, 'Treatment', self.treatment, null);
	self.addRemoteRow(_table, 'length', self.length, null);
		
	foreach extra in self.allRemoteDataExtra do
		self.addRemoteRow(_table, 'Regraded Log ' &amp; extra.CM_RemoteRegradingExtra.itemId, Click, extra);
	endforeach;
end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="io"/>
    </JadeMethod>
</Class>
