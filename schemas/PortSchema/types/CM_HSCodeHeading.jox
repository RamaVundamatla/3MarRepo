    <JadeMethod name="getDisplayStringForAttribute" id="9343e116-c35c-4e82-9d04-b21903b3abcf">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
09 December 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars

begin
	if _attrName = ETRow_Type then
		return app.getErrorString(Heading);
	elseif _attrName = ETRow_HsParentChapter then
		if self.myHSChapter &lt;&gt; null then
			return self.myHSChapter.id;			
		endif;
		return null;		
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFullDescription" id="7c7135f5-719c-46cb-a2f8-db13cc730d95">
        <source>getFullDescription(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
09 December 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars

begin
	
	if self.myHSChapter = null then
		return inheritMethod();
	endif;
	
	return self.myHSChapter.getFullDescription() &amp; ": " &amp; self.description;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
