    <JadeMethod name="initialize" id="e3be4d00-dd27-4d8e-94b4-657a92472783">
        <updating/>
        <source>initialize() updating;
// ---------------------------------------------------------------------------
// Created:     12 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//30 Apr 2024 navrv30 ChangeRequest 63860: EUP | Performance Async Workers workorder operations - Refactor
// ---------------------------------------------------------------------------
vars
	aswManager : ASW_Manager;   
begin

	inheritMethod();

//	getErrorText is called as it creates a shared transient compiler interlock object 
//	This is needs to be created now as may create error this object is 
//	attempted to be created by a process later while in shared transient transaction 
//	relates to JADE par 36513 and JMT par 9854
	process.getErrorText(1268);	// can be any error code, just need method to be called. 

	self.myCmuiRoot := app.getSingleton(CMUI_Root).CMUI_Root;
	
	self.setPrinterDocumentType(true); //epr par 16671 6/5/08  // 17/01/2011 cnwmh5 #26743
	
	if self.name = JMTerminal then
		create aswManager transient;
		aswManager.startAsyncWorkers();                         //30.04.2024 navrv30 #63860
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="isInside" id="0a802c79-284f-4030-b748-52945cb7f1fb">
        <source>isInside(_toCheck : Point; _pts : PointArray) : Boolean;
// ---------------------------------------------------------------------------
// Created:     15 July 2005 by cnwrs2
//
// Purpose:     Takes a point to check and a points array and returns true
//				if the point to check is inside the enclosed points array
// ---------------------------------------------------------------------------
vars
	tmpPoint,
	prevPoint,
	nextPoint	: Point;
	numPts,
	idx			: Integer;
	x1, x2, y1, y2,
	x, y, 
	prevAngle,
	nextAngle,
	chkAngle,
	maxAngle,
	minAngle	: Real;
	
	
begin

	numPts := _pts.size;
	if numPts &lt; 3 then
		// need at least 3 points to enclose another point
		return false;
	endif;
	
	foreach tmpPoint in _pts do
		idx := idx + 1;
		if idx = 1 then
			// must be the first time
			prevPoint := _pts.last;
		else
			prevPoint := _pts[idx - 1];
		endif;
		if idx = numPts then
			nextPoint := _pts.first;
		else
			nextPoint := _pts[idx + 1];
		endif;

		// the following determines the bearing between 2 points
		// So take current point as origin and determine bearing to
		// prev &amp; next points.  The determine bearing to point _toCheck
		// and if this lies between concave side of prev/next bearings
		// then can assue ok for this point.
		// If point _toCheck falls within these bounds for all points
		// then is enclosed.
		
		prevAngle := self.getBearing(tmpPoint, prevPoint);
		nextAngle := self.getBearing(tmpPoint, nextPoint);
		chkAngle := self.getBearing(tmpPoint, _toCheck);
		
		maxAngle := prevAngle.max(nextAngle);
		minAngle := prevAngle.min(nextAngle);

app.writeStatement( 'checking ' &amp; _toCheck.x.String &amp; ', ' &amp; _toCheck.y.String &amp; ' ' &amp; 
	maxAngle.String &amp; Tab &amp;
	minAngle.String &amp; Tab &amp; chkAngle.String);
		
		if (maxAngle - minAngle) &lt; 180 then
			if chkAngle &gt; maxAngle or
			   chkAngle &lt; minAngle then
				return false;
			endif;
		else
			if chkAngle &gt; minAngle or
			   chkAngle &lt; maxAngle then
				return false;
			endif;
		endif;

	endforeach;
	
	return true;

end;</source>
        <Parameter name="_toCheck" type="Point"/>
        <Parameter name="_pts" type="PointArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
