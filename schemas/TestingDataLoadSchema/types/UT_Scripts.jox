begin
	trackedItemId := "id";
	read trackedItemId;
	foreach ti in self.getTerminal.allOffsiteTIsByIdCargoType do
		if trackedItemId[trackedItemId.length] = "*" then
			prefix := trackedItemId[1:trackedItemId.length-1];
