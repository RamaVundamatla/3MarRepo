    <JadeMethod name="runProformaReport" id="61ebe496-4ae9-4450-89fa-b9cdb9f42f59">
        <source>runProformaReport(_voyages : CM_VoyageByCodeArrivalDT; _tis : CM_TrackedItemArray);

/*
Purpose:	

Date		Who		Reason
27 August 2024	navab1	CR 65820 TASK 65821
*/

vars
	reports : CM_QryReportUserDict;
	report : CM_QryReportUser;
	filter : CMQF_InvoiceProforma;
	term : CM_Terminal;
	voyage : CM_Voyage;
	numItems : Integer;
	reportAgent : CMUI_ReportAgent;
	noEmail : Boolean;
	reportStr : String;
	frm : CMUI_ChooseOutputFormat;
	result, outputFormat : Integer;
	fileName : String;
	fileobj : File;
begin
	
	reportStr := self.myTerminal.getConfig(InvProformaInvoiceReport).String;
	report := app.myRoot.getQryReport(reportStr).CM_QryReportUser;
	
	create filter transient;
	filter.ignoreCurrentInvoiceLines := true; // JIRA 32861 27SEP2024 NAVAB1 - Accruals Performance

	if _voyages &lt;&gt; null then
		_voyages.copy(filter.allVoyages);
	endif;
	
	if _tis &lt;&gt; null then
		_tis.copy(filter.allTrackedItems);
	endif;
	
	create reportAgent transient;
	
	if report.canOutputToText() then
	
		// ### JIRA 34041 12FEB2025 NAVAB1
		create frm transient;
		frm.setMyTerminal(self.myTerminal);
		frm.myParent := self;
		frm.myReport := report;
		frm.reportName := report.reportName;
		frm.createMyAssistant(CMUI_Assistant);
		frm.centreOverParent(0);
		frm.showModal();
	
		fileobj := frm.myFile;
		if result = IDOK 
		and fileobj &lt;&gt; null then
			fileName := fileobj.fileName;
			fileobj.close;
			
			outputFormat := frm.cmbFormats.itemData[frm.cmbFormats.listIndex];
			reportAgent.runForegroundReport(report,filter,null,null,outputFormat,fileName,null, true,noEmail);
			
		else
			return;
		endif;		
	else	
		reportAgent.runForegroundReport(report,filter,null,null,JadeReportWriterReport.PRINTER,null,null,true,noEmail); 
	endif;
	
	global.beep;
epilog	
	delete filter;
	delete reportAgent;
	delete fileobj;

end;</source>
        <Parameter name="_voyages" type="CM_VoyageByCodeArrivalDT"/>
        <Parameter name="_tis" type="CM_TrackedItemArray"/>
    </JadeMethod>
