Return Value:		


Date		Who		Reason
10 August 2009	cnwndl1	Initial creation	NDL Rework for CCMS 1031 par 20474

*/

vars

begin
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return false;
	endif;

	return doTblCraneContextMenu(conwin, mouse, x, y);
epilog

end;</source>
