    <JadeMethod name="getItemLength" id="deed580b-2229-4b34-9b68-d3a3a5f30b3f">
        <source>getItemLength(_ti : CM_TrackedItem): Decimal;
/*
Purpose:			
Date		Who		Reason
30 November 2011	cnwab1	Initial creation
*/

vars
	lengthMetres : Decimal[12,2];
begin
	if _ti = null then
		return inheritMethod(_ti);
	endif;
	
	lengthMetres := _ti.getLengthInMetres();
	
	if lengthMetres &lt;= 0 then
		return 12; // metres
	endif;

	return lengthMetres;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="60d69c41-e9cc-4112-b342-13fd1418d165">
        <updating/>
        <source>setForCreate(_proxyDeckItem: SelfType; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	inheritMethod(_proxyDeckItem, _passport);

	self.myDeckLayerLayout := _proxyDeckItem.myDeckLayerLayout;
	self.xMetres := _proxyDeckItem.xMetres;
	self.yMetres := _proxyDeckItem.yMetres;

epilog

end;</source>
        <Parameter name="_proxyDeckItem" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyDeckLayerLayout" id="8cc3ddb5-568c-4701-83a1-df1ff1ea061c">
        <updating/>
        <source>setMyDeckLayerLayout(_layout : CM_DeckLayerLayout) updating;
/*
Purpose:			
Date		Who		Reason
04 December 2013	cnwab1	Initial creation
*/

vars

begin
	self.myDeckLayerLayout := _layout;
epilog

end;</source>
        <Parameter name="_layout" type="CM_DeckLayerLayout"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="9b21252b-ed25-4cd4-b071-65b7dc3e3986">
        <updating/>
        <source>setProxy(_structure: CM_Object;
		_code: String; 
		_desc: String; 
		_remarks: String; 
		_deckItemLayout: CM_DeckItemLayout; 
		_deck: CM_Deck; 
		_deckLayerLayout: CM_DeckLayerLayout;
		_xMetres,_yMetres : Decimal) updating;
/*
Purpose:			
Date				Who			Reason
JUNE 2011		CNWAB1		Initial creation
*/

vars

begin
	self.setCode( _code, false );
	self.description := _desc;
	self.remarks := _remarks;
	self.xMetres := _xMetres;
	self.yMetres := _yMetres;
	self.myDeck := _deck;
	self.myDeckLayerLayout := _deckLayerLayout;
	self.myLayout := _deckItemLayout;
	
epilog

end;</source>
        <Parameter name="_structure" type="CM_Object"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_desc" type="String"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_deckItemLayout" type="CM_DeckItemLayout"/>
        <Parameter name="_deck" type="CM_Deck"/>
        <Parameter name="_deckLayerLayout" type="CM_DeckLayerLayout"/>
        <Parameter name="_xMetres" type="Decimal"/>
        <Parameter name="_yMetres" type="Decimal"/>
    </JadeMethod>
</Class>
