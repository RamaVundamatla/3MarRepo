    <JadeMethod name="getPermissionByConstValue" id="037ced23-83fb-480f-8eb6-4038ff4de81b">
        <source>getPermissionByConstValue(_constantValue : Integer) : CM_PermissionObject;
/*

Purpose: Returns the 

Parameters:			

Return Value:		

Date		Who		TFS		Reason
05 Sep 2019	jlgdi1	45802	Initial creation
*/
vars
	object : Object;
	
begin
	if _constantValue = 0 then
		return null;
	endif;

	if self.allPermissionByConstValue.isEmpty then
		self.populatePermissions();
	endif;
	
	object := self.allPermissionByConstValue[_constantValue];
	
	if object &lt;&gt; null then 	
		return self.allPermissionByConstValue[_constantValue].CM_PermissionObject;
	else
		return null;
	endif;
end;</source>
        <Parameter name="_constantValue" type="Integer"/>
        <ReturnType type="CM_PermissionObject"/>
    </JadeMethod>
    <JadeMethod name="getProductFromProdCode" id="f098dcd8-edb6-4972-add1-8485b7aa1285">
        <updating/>
        <source>getProductFromProdCode( _term 			: CM_Terminal; 
						_oper 			: CM_Operator; 
						_prodString 	: String; 
						_byCode 		: Boolean; 
						_byDescription  : Boolean ):CM_Product updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Apr 2019	jlgndl1	Initial creation	TFS 44194
20 Jun 2019	NDL		Cater for terminal and Operator to be checked too.
13 Aug 2019	NDL		TFS 45868 - 1090 UHE - using wrong variable
28 Nov 2024 navma1	MTN-19124 STWO - Uploading an EDI file 'freezes' MTN.
*/

vars

	product 		: CM_Product;
	iter 			: Iterator;
	productToCheck  : CM_Product;
	prodStrUpper	: String;
begin

	if _prodString = null then
		return null;
	endif;
	
	if self.productDictNeedsRefresh or self.allProductsByCode.isEmpty then
		self.populateProducts( null );	
	endif;

	prodStrUpper := _prodString.toUpper;	//28.11.2024 navma1 #MTN-19124
	
	if _byCode then
		product := self.allProductsByCode.getAtKey( _prodString ).CM_Product;
		if product &lt;&gt; null then // we have teh first one, is it valid for the term and oper selected....
			if _oper &lt;&gt; null then // we want to check this product is valid for this operator
				if product.myOperator &lt;&gt; null and product.myOperator &lt;&gt; _oper then
					iter := self.allProductsByCode.createIterator;
					iter.startAtObject( product );
					product := null;
				endif;
			endif;
			if product &lt;&gt; null then // we still have a product, so the operator is allowed to see it, or it isn't being checked
				if _term &lt;&gt; null then	// we want to check the terminal too.
					if not product.myCargoType.allTerminals.includes( _term ) then
						iter := self.allProductsByCode.createIterator;
						iter.startAtObject( product );
						product := null;
					endif;
				endif;
			endif;
			if product = null and iter &lt;&gt; null then
				// the first one we found doen't match something .... carry on.
				while iter.next( productToCheck ) do
					if productToCheck.code.toUpper &lt;&gt; prodStrUpper then					//28.11.2024 navma1 #MTN-19124
						break;
					endif;
					if _oper &lt;&gt; null then
						if productToCheck.myOperator = _oper // only valid for this operator
						or productToCheck.myOperator = null // valid for all operators
						then
							// all good, keep going
						else
							// doesn't match, skip this one
							continue;
						endif;
					endif;
					if _term &lt;&gt; null then
						if not productToCheck.myCargoType.allTerminals.includes( _term ) then
							// doesn't match, skip this one
							continue;
						endif;
					endif;
					
					product := productToCheck;
					break;
						
				endwhile;
				delete iter;
			endif;	
		endif;
	endif;
	
	if product = null then
		if _byDescription then
			product := self.allProductsByDescription.getAtKey( _prodString ).CM_Product;
			if product &lt;&gt; null then // we have teh first one, is it valid for the term and oper selected....
			if _oper &lt;&gt; null then // we want to check this product is valid for this operator
				if product.myOperator &lt;&gt; null and product.myOperator &lt;&gt; _oper then
					iter := self.allProductsByDescription.createIterator;
					iter.startAtObject( product );
					product := null;
				endif;
			endif;
			if product &lt;&gt; null then // we still have a product, so the operator is allowed to see it, or it isn't being checked
				if _term &lt;&gt; null then	// we want to check the terminal too.
					if not product.myCargoType.allTerminals.includes( _term ) then
						iter := self.allProductsByDescription.createIterator;
						iter.startAtObject( product );
						product := null;
					endif;
				endif;
			endif;
			if product = null and iter &lt;&gt; null then
				// the first one we found doen't match something .... carry on.
				while iter.next( productToCheck ) do
					if productToCheck.description.toUpper &lt;&gt; prodStrUpper then			//28.11.2024 navma1 #MTN-19124
						break;
					endif;
					if _oper &lt;&gt; null then
						if productToCheck.myOperator = _oper // only valid for this operator
						or productToCheck.myOperator = null // valid for all operators
						then
							// all good, keep going
						else
							// doesn't match, skip this one
							continue;
						endif;
					endif;
					if _term &lt;&gt; null then
						if not productToCheck.myCargoType.allTerminals.includes( _term ) then
							// doesn't match, skip this one
							continue;
						endif;
					endif;
					
					product := productToCheck;
					break;
						
				endwhile;
				delete iter;
			endif;	
		endif;
		endif;
	endif;  
	
	return product;

epilog

	delete iter;

end;</source>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_oper" type="CM_Operator"/>
        <Parameter name="_prodString" type="String"/>
        <Parameter name="_byCode" type="Boolean"/>
        <Parameter name="_byDescription" type="Boolean"/>
        <ReturnType type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="populateAll" id="cd9c8edb-e6e8-46c9-a396-13f63c6e63c1">
        <updating/>
        <source>populateAll( _term : CM_Terminal ) updating;
/*

Purpose:		Only used in Unit Test, to pre-populate everything, otherwise the first caller gets an
				erroneous transient leak. ( of x2 JadeSlobContainer objects and so reports as a fail)

Parameters:			

Return Value:		

Date		Who		Reason
04 April 2019	jlgndl1	Initial creation	TFS 44194
05 Sep 2019	jlgdi1	45802	Added a call to method populatePermissions()
*/

vars

begin

	self.populateCargoTypes();
	self.populateCarriers();
	self.populateCommodities();
	self.populateOperators();
	self.populateProducts( _term );
	self.populatePermissions();
	self.populateGnrcIfaceDvc(); // ### TFS 52773 06May2022 NAVPW1
epilog

end;</source>
        <Parameter name="_term" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="populateCargoTypes" id="e8168d7c-ae56-41cf-9c69-49a76964834b">
        <updating/>
        <source>populateCargoTypes()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 April 2019	jlgndl1	Initial creation	TFS 44194

*/

vars

	root : CM_Root;
	iter : Iterator;
	cargoType : CM_CargoType;

begin

	root := app.myRoot;

	if not self.allCargoTypesByAbbrDict.isValid then
		self.allCargoTypesByAbbrDict.setMembership( CM_CargoType );
		self.allCargoTypesByAbbrDict.addMemberKey( CM_CargoType::abbreviation.name, false, true );
		self.allCargoTypesByAbbrDict.endKeys( true );
	else
		self.allCargoTypesByAbbrDict.clear();
	endif;
	
	root.allCargoTypesById.copy( self.allCargoTypesByAbbrDict );
		
	if not self.allCargoTypesByDescription.isValid then
		self.allCargoTypesByDescription.setMembership( CM_CargoType );
		self.allCargoTypesByDescription.addMemberKey( CM_CargoType::description.name, false, true );
		self.allCargoTypesByDescription.endKeys( true );
	else
		self.allCargoTypesByDescription.clear();
	endif;
	
	root.allCargoTypesById.copy( self.allCargoTypesByDescription );
	

	if app.isCargoGroupEnabled then
		self.allCargoGroups.clear();
		iter := root.allCargoTypesById.createIterator;
		while iter.next( cargoType ) do
			if cargoType.isCargoGroup() then
				self.allCargoGroups.add( cargoType );
			endif;
		endwhile;
	endif; 
	
	self.cargoTypeDictNeedsRefresh := false;
	
epilog

	delete iter;

end;</source>
    </JadeMethod>
