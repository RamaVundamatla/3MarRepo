    <JadeMethod name="showDutyDocMaintForm" id="1e64581c-6ab1-451d-82d6-f939a1143031">
        <source>showDutyDocMaintForm(_dutyDoc : CM_DutyDoc);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 December 2012	cnwer1	Initial creation HAT 2189

*/

vars

	form : CMUI_DutyDocMaintForm;
begin
			
	form := app.loadForm(CMUI_DutyDocMaintForm, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_DutyDocMaintForm;
	// PAR # 26984
	form.setMyDutyDoc(_dutyDoc);
