    <JadeMethod name="getFullId" id="4d905212-9e6e-4fc2-921a-4212b124e664">
        <source>getFullId() : String;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
//	ti : CM_TrackedItem;
	tmpStr : String;
begin
	
	if self.myVoyage &lt;&gt; null then
		tmpStr := self.myVoyage.code.trimRight;
	endif;
	return tmpStr &amp; " " &amp; self.ident;
end;</source>
