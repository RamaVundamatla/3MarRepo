    <JadeMethod name="validateForDelete" id="e58354f6-3517-4299-8937-944818643dd2">
        <source>validateForDelete();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2022	navak20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars

begin
	if self.allDamageInstances.isNotEmpty then
		app.raiseCMException1(Cannot_Delete_RepairReason, self.code, null, null);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="2163e76e-852e-40a0-9c66-43180d04e88d">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2022	navak20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars
	realRepairReason,
	existingRepairReason		: CM_RepairReason;
begin
	if self.code = null then
		app.raiseCMException(Input_required_field_code, ETRow_Code, self);
	endif;
	
	if self.description = null then
		app.raiseCMException(Input_required_field_desc, ETRow_Description, self); 
	endif;
	
	
	existingRepairReason	:= self.myTerminal.allRepairReasons[self.code];
	realRepairReason		:= self.pxyGetRealObject();
	
	if existingRepairReason &lt;&gt; null and
	   (realRepairReason = null or //in which case we are trying add a new one that is duplicate
	   realRepairReason &lt;&gt; existingRepairReason) //in which case we are trying update one to be same as another
	   then
		app.raiseCMException1(RepairReason_already_exist, self.code.String, null, null); 
	endif;
	
epilog

end;</source>
    </JadeMethod>
</Class>
