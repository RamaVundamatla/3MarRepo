    <JadeMethod name="setupForm" id="6b54a6ee-b046-4651-95fa-3e4260ff998d">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

begin

	inheritMethod();
	
	self.setupCmdButtons( 1, app.getErrorString(Back), null, null, null, null );
	
	// position scroll bar so that the left column is visible.
	self.tblCargo.leftColumn := 1;
	
	self.tblCargo.column := 1;
	self.tblCargo.accessCell(1,1);
	self.tblCargo.setFocus();


epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="c9716b25-700e-4856-9bcc-450d7c850286">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014399, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
