    <JadeMethod name="validateMe" id="8ff827e5-071d-4fc0-b596-a72eef0eddc3">
        <source>validateMe();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 March 2019	jlgndl1	Initial creation	TFS 43687

*/

vars

	realForCheck : CM_InvTypeGroupingMinCharge;
	existing : CM_InvTypeGroupingMinCharge;
	matchingLineType : CM_InvoiceLineDesc;

begin

	if self.minimumChargeAmount &gt; CM_InvoiceTypeSurchargeExempt.HighValue_15_2 then	//rework again 24 Jul 2019	NDL TFS 45509
		app.raiseCMException2(ERR_LOWER_GT_UPPER, app.getErrorString(Minimum_charge), CM_InvoiceTypeSurchargeExempt.HighValue_15_2.asStringJMT, null, null); 
	elseif self.minimumChargeAmount = 0 then
		app.raiseCMException(Minim_charg_must_great_than_ze, null,null);
		return;
	endif;
	

	if self.mySurchargesAndExemptions = null then
		app.raiseCMException(Current_surcharge_exemptions, null,null);
		return;
	endif;
	
	if self.getMinimumChargeInvLineType = null then
		app.raiseCMException(Minim_charg_line_type_must_sel, null,null);
		return;
	endif;
	
	if self.description = null then
		app.raiseCMException(Input_required_field_Desc, null,null);
		return;
	endif;
	
	if self.allLineTypesForMinimumCharge.isEmpty then
		app.raiseCMException(Invoice_line_types_selecte, null,null);
		return;
	endif;
	
	if self.groupLinesBy = CM_InvTypeGroupingMinCharge.GroupTypeMovement and self.moveType = null then
		app.raiseCMException(Input_required_field_moveType, null,null);
		return;
	endif;
	
	if self.isTransient then
		realForCheck := self.pxyGetRealObject();
	else
		realForCheck := self;
	endif;
	
	existing := self.mySurchargesAndExemptions.allInvTypeGroupingMinCharges.getOverlapping( self, matchingLineType );
	if existing = null or existing = realForCheck then
		//we can carry on.
	else
		//This key is already used.
		app.raiseCMException1(Not_selec_line_type_multi_mini, matchingLineType.narration, null, null);
		return;
	endif;
	

epilog

end;</source>
    </JadeMethod>
