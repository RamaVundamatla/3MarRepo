	if self.jobType = JobTypePriority_DischargeDLR20 
		or self.jobType = JobTypePriority_DischargeDLR40 
		or self.jobType = JobTypePriority_DischargeIMP20
		or self.jobType = JobTypePriority_DischargeIMP40 then
		return true;
	endif;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
