    <JadeMethod name="handleInvalidProperty" id="401657df-4c16-49ac-bda6-583f58868b8d">
        <source>handleInvalidProperty( _exception : Exception; _error : Boolean output ) : Integer protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 December 2009	cnwndl1	Initial creation	CCMS 1023

*/

vars

begin

	if _exception.errorCode = 1010			// Invalid metoh for this class
	or _exception.errorCode = 1011 then		// Invalid property for this class
		_error	:= true;	
		return Ex_Resume_Next;	
	endif;
	
	return Ex_Pass_Back;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_exception" type="Exception"/>
        <Parameter name="_error" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="myTerminal" id="83b5e2de-c4ea-43ad-b450-827f8bb93781">
        <methodInvocation>mapping</methodInvocation>
        <source>myTerminal(set: Boolean; _value: CM_Terminal io) mapping;
// ---------------------------------------------------------------------------
// Created:     15 December 2009 by cnwcs5
// Purpose:     CCMS 1028 - summary mappings
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if set then
		// set code here
		app.raiseSetVirtualError (self.class.name, method.name);
	else
		// get code here
		_value := self.mySnapshotData.myTerminal;
	endif;


epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_Terminal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="persistReferences" id="874c7456-065f-4bd6-941a-8d4069a2767d">
        <source>persistReferences( pxyDynaSnapshot : CM_DynamicObject_Snapshot );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 December 2009	cnwndl1	Initial creation	CCMS 1023

*/

vars

	pxySSField : CM_SnapshotField;
	ssField : CM_SnapshotField;
	
begin

	foreach pxySSField in pxyDynaSnapshot.allFields do
		ssField := pxySSField.cloneSelf (false);
		self.allFields.add(ssField);
	endforeach;
	
	self.allObjects.clear();
	if not pxyDynaSnapshot.allObjects.isEmpty then
		pxyDynaSnapshot.allObjects.copy( self.allObjects );
	endif;
	
	//cnwjo3 par 26336.  no need to clear or populate allValues
	/*self.allValues.clear();
	if not pxyDynaSnapshot.allValues.isEmpty then
		pxyDynaSnapshot.allValues.copy( self.allValues );
	endif;*/
	
epilog

end;</source>
        <Parameter name="pxyDynaSnapshot" type="CM_DynamicObject_Snapshot"/>
    </JadeMethod>
    <JadeMethod name="setupProperties" id="e18dc964-6ed8-4bb1-bd17-3add6b899fed">
        <updating/>
        <source>setupProperties(_format :CM_OutputFormat_SS)updating;

/*

Purpose:			

Parameters:	_format	- this defineds the properties for the snapshot	

Return Value:		


Date		Who		Reason
07 December 2009	cnwndl1	Initial creation

*/

vars
	grouping 	:CM_XTABGrouping;
	prop		:CM_QueryProperty;
begin
	foreach grouping in _format.allGroupings do
		prop := grouping.getQueryProperty;
		
		self.addProperty (prop.propertyName, String);
	endforeach;
epilog

end;</source>
        <Parameter name="_format" type="CM_OutputFormat_SS"/>
    </JadeMethod>
</Class>
