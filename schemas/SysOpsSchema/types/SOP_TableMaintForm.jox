    <JadeMethod name="doClonedMenuClickSpecial" id="7bf64ca6-a610-4f0e-9398-801a92ccce7d">
        <updating/>
        <source>doClonedMenuClickSpecial(menuItem: MenuItem input) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	06 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	tagReader			: CM_RFIDTagReader;
	currentTag			: CM_RFIDTag;
	roadJob : CM_RoadJob;
begin

	if menuItem.caption = "Set road job to null" then
		if CM_RFIDTag.hasInstance(self.myCurrentObject) then
			roadJob := self.myCurrentObject.CM_RFIDTag.myRoadJob;
			if roadJob &lt;&gt; null then
				app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '- ' &amp; self.myCurrentObject.String &amp; ' road job set to null');
				
				if CM_RoadJob.hasInstance(roadJob) then	// 24 Apr 2012	NDL	Par 29417
					app.myTrxUA.trxUpdateClearRoadJobRFIDTag(roadJob, app.myPassport);	
				else
					beginTransaction;
					self.myCurrentObject.CM_RFIDTag.setPropertyValue('myRoadJob', null);
					commitTransaction;
				endif;
				
			else
				app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '- ' &amp; self.myCurrentObject.String &amp; ' road job was already null');
				
			endif;
			return;
		endif;
	endif;
	
	if (not CM_RFIDTagReader.hasInstance(menuItem.userObject)) or
	   (not CM_RFIDTag.hasInstance(self.myCurrentObject)) then
		return;
	endif;
	
	if self.myCurrentObject &lt;&gt; null then//Par14586
		tagReader := menuItem.userObject.CM_RFIDTagReader;
		currentTag := self.myCurrentObject.CM_RFIDTag;
		tagReader.doTagRead(currentTag.serialNumber);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCmbSortOrderBuild" id="2f61c266-83ab-4075-8291-4b4c5cb368cb">
