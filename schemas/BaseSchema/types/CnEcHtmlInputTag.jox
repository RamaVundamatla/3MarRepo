    <PrimAttribute name="inputAlign" id="572666d7-9264-4394-af76-5fa1d2529270">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <text>If the input is of type TYPE_IMAGE (see inputType property), this
property positions text at ALIGN_TOP, ALIGN_BOTTOM or ALIGN_CENTER
of the image.</text>
    </PrimAttribute>
    <PrimAttribute name="inputName" id="e616c81b-12a4-4cf0-a369-06a3cad5d682">
        <length>101</length>
        <embedded/>
        <type name="String"/>
        <text>Specifies the name of the field.</text>
    </PrimAttribute>
    <PrimAttribute name="inputType" id="476d3a5d-cabb-4f3c-a80c-d91857137afc">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>The value of this propery must match one of the "TYPE_..." constants
defined on this class.</text>
    </PrimAttribute>
    <PrimAttribute name="inputValue" id="d0046a30-22c9-491a-a999-1304e9b3b48a">
        <type name="String"/>
        <text>Specifies the default value of the field.</text>
    </PrimAttribute>
    <JadeMethod name="buildTagBody" id="78df86cf-9dff-4ea2-8531-cab40e1c19c7">
        <source>buildTagBody(): String protected;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	htmlString	: String;

begin
	htmlString	:=	'TYPE="' &amp; self.inputType &amp; '" NAME="' &amp; self.inputName &amp; '"';

	if self.inputValue &lt;&gt; null then
		htmlString	:=	htmlString &amp; ' VALUE="' &amp; self.inputValue &amp; '"';
	endif;
	
	htmlString	:=	htmlString &amp; inheritMethod();
	
	return htmlString;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHtml" id="2c602de8-4000-4dc7-b478-70e1276d2356">
        <source>getHtml(): String;
// --------------------------------------------------------------------------------
// Created:		28 April 2000 by cnwdad2
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return '&lt;INPUT ' &amp; self.buildTagBody() &amp; '&gt;' &amp; CrLf;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isValidAlign" id="ae7f301f-14fc-4320-a17d-b8ddb0cb4a0e">
        <source>isValidAlign(pAlign:String):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		01 May 2000 by cnwdad2
//
// Purpose:		Validates the receiver's alignment setting.
//
// Parameters:	pAlign - The receiver's alignment setting.
//
// Returns:		True if the alignment setting is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pAlign = self.ALIGN_TOP
	or pAlign = self.ALIGN_BOTTOM
	or pAlign = self.ALIGN_CENTER
	then
		return true;
	else
		CnEcBaseHtmlException.raise_(CNEC_X_22000, '"' &amp; pAlign &amp; '" is not a valid Input tag alignment');
	endif;

	return false;
end;</source>
        <access>protected</access>
        <Parameter name="pAlign" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
