    <JadeMethod name="setMyMenuRoot" id="64259a67-00ac-4dad-92a2-224911019ed3">
        <updating/>
        <source>setMyMenuRoot(_menuRoot : CM_MenuRoot) updating;
// ---------------------------------------------------------------------------
// Created:     10 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _menuRoot.isKindOf(CM_MenuRootForRoot) and
		not _menuRoot.CM_MenuRootForRoot.allMenuItems.includes(self) then
		self.myMenuRoot := _menuRoot.CM_MenuRootForRoot;
		self.myMenuReportRoot := null;
		
	elseif _menuRoot.isKindOf(CM_MenuRootReportForRoot) and
		not _menuRoot.CM_MenuRootReportForRoot.allMenuItems.includes(self) then
		self.myMenuReportRoot := _menuRoot.CM_MenuRootReportForRoot;
		self.myMenuRoot := null;
	endif;

end;</source>
        <Parameter name="_menuRoot" type="CM_MenuRoot"/>
    </JadeMethod>
