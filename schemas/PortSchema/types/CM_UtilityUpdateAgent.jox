    <JadeMethod name="utlUpdateFile" id="34d5d508-42bc-4cb4-bf7e-7abd4305de9c">
        <source>utlUpdateFile(_pxyFileData : CM_FileData io;
					  _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/12/2022  navvt20 TFS CR 55299  Task 55520: UI - File Load and File Attachment UI changes

*/

vars
	realFileData			: CM_FileData;
	expectedEdition 		: Integer;
begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_pxyFileData, 'File Data proxy');
	
	_pxyFileData.pxyGetRealObjectAndEdition(realFileData, expectedEdition);
	self.raiseExceptionIfNull(realFileData, 'File Data Category');
	
		
	if not _passport.noErrors then
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realFileData, true);
	endif;
	
	realFileData.setForUpdate(_pxyFileData);
	
	if _passport.noErrors and realFileData.myParent &lt;&gt; null then
		realFileData.myParent.causeEvent(EventFileUpdate, false, realFileData);
		if realFileData.myParent.isKindOf(CM_CargoBOLType) then
			self.updateObjectEdition (realFileData.myParent);	
		endif;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realFileData, false);
	endif;
epilog

end;

</source>
        <Parameter name="_pxyFileData" type="CM_FileData" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateFileCategory" id="4cc2b1c0-236b-402b-a0bd-80e6faff149f">
