    <JadeMethod name="validateSameTIForMove" id="bbdfee13-530a-4bab-a6d2-76c8f1454331">
        <source>validateSameTIForMove(_controller : CMIF_MoveController);
//--------------------------------------------------
// Created:	03 September 2003 By: cnwgd1
//--------------------------------------------------
vars
	moveTI,
	myTI : CM_TrackedItem;
	isReservedTBA : Boolean;
begin
	if _controller.isOverstowMove then
		return;
	endif;
	
	//if self.myTrackedItem.isKindOf(CM_BreakBulkGeneric) then //could be a split so wont be the same ti as on the wle cnwrd1 ccms 2274
	if self.myTrackedItem.myCargoType &lt;&gt; null and self.myTrackedItem.myCargoType.isBulkMulti then	//17 Nov 2015	NDL	Par 37092
		return; 
	endif;
	
	moveTI := _controller.myTrackedItem;
	if moveTI = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Tracked Item param is null');
		return;
	endif;
	myTI := self.myTrackedItem;
	if myTI &lt;&gt; null then
		if moveTI &lt;&gt; myTI then
			isReservedTBA := myTI.isTBAorIsRRP() and self.myRequest &lt;&gt; null and self.myRequest.isHoldRequest() and self.myRequest.CM_HoldRequest.myBulkReleaseReserveDetail &lt;&gt; null; // TFS 3190
			//jlier1 TFS 54701 20/9/22- could be moving the trailer with the cargo on it
			if _controller.myRTQueueEntry &lt;&gt; null and _controller.myRTQueueEntry.machineTypeGroup = MACHINETYPEGRP_TRACTOR and _controller.myRTQueueEntry.myNextRelatedEntry &lt;&gt; null  then
				if _controller.myRTQueueEntry.myRTMoveMethodRule &lt;&gt; null and _controller.myRTQueueEntry.myRTMoveMethodRule.myRTMoveMethod.type = RTMoveMethod_40 then
					if moveTI &lt;&gt; myTI.getCurrentTrailer then
						app.raiseCMException2(VB_DRAG_WRONG_TI, moveTI.id, self.getFullDescription(), null, null);				
					endif;
					return;
				endif;
			endif;
			
			if not isReservedTBA then // TFS 3190
				app.raiseCMException2(VB_DRAG_WRONG_TI, moveTI.id, self.getFullDescription(), null, null);
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="_controller" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="validateUnqueueRequest" id="f25f3414-e502-4264-bbf1-64cfe490700b">
        <source>validateUnqueueRequest();
//--------------------------------------------------------------
//Created: 07 February 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	app.raiseCMWarning2(VB_CONF_UNQUEUE,
						self.myRequest.getTotalRequested.String,
						self.queueId, null, null, self);
end;</source>
    </JadeMethod>
    <JadeMethod name="validateVbsMaxWeight" id="95ee04cb-62d9-43d9-b34a-d01a9cdab7c7">
        <source>validateVbsMaxWeight(_reserveDetail : CM_ReserveDetail; _weight : Decimal);
/*

Purpose:			Validates whether the VBS Max Weight on the Vehicle booking timeslot item on the gate entity has been exceeded

Parameters:			_reserveDetail	CM_ReserveDetail	
					_weight			Decimal				

Return Value:		NONE

Date				Who		Reason
23 October 2024		navpw1	Initial creation JIRA MTN-12518
31 October 2024		navpw1	JIRA: MTN-14770 - Refactored code as new methods were added for getDeliveryRequest, getVbsti to Work List Entry as these are used often
16 December 2024	navpw1	JIRA: MTN-33630 - Max Weight check now comes from the Gate Entities Release Weight

*/

vars
	deliveryRequest : CM_DeliveryRequest;
	gteEntity		: CMGTE_Entity;
	releaseWeight	: Decimal [14,4];
	desc			: String;
	
begin
	//Todo Comment code and explain what it does. Also include a custom exception message explaining the error. Also refactor code and fix de-referencing
	//Check we have a request
	deliveryRequest := self.getDeliveryRequest();
	if deliveryRequest = null then
		return;
	endif;
	
	//Get Gate Entity
	gteEntity := deliveryRequest.myGateEntity;
	if gteEntity = null or not gteEntity.isRelease then
		return;
	endif;
	
	releaseWeight := gteEntity.CMGTE_Release.releaseWeight;
	
	//If this is a reserve selection and a release by type by weight and the max weight has been set then validate
	if _reserveDetail.isReserveSelection and 
		//_reserveDetail.byTypeByWeight and		//Not Needed as we can do quantity as weight too using vbs max weight 	
		releaseWeight &gt; 0
	then
		//Validate we can still load weight to the truck by checking the max weight minus the weight loaded minus the weight we are trying to load
		//If it is less than 0 then raise an exception
		if releaseWeight - _reserveDetail.getWeightLoaded()  - _weight &lt; 0 then
			//desc := releaseWeight.asStringJMT() &amp; ' x ' &amp; _reserveDetail.getCargoTypeDescr &amp; Space &amp; _reserveDetail.getProductISOTypeDescr();
			desc := app.getWeightForDefaultDisplay(releaseWeight) &amp; ' x ' &amp; _reserveDetail.getCargoTypeDescr &amp; Space &amp; _reserveDetail.getProductISOTypeDescr();
			app.raiseCMException1(Vbs_max_weight_exceeded_load, desc, null, self );
		endif;
	endif;
	
end;</source>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
        <Parameter name="_weight" type="Decimal"/>
    </JadeMethod>
</Class>
