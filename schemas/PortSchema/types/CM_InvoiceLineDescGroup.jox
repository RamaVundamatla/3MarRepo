    <JadeMethod name="validateForDelete" id="2c05547e-7850-4b0a-bf23-236a147f9e76">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if not self.lineDescriptions.isEmpty then
		app.raiseCMException(This_grp_invoi_line_tps_ca_del,null,null);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="face854e-ac94-4fbd-9c6c-04fb13ddfd42">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//23/06/2022 		NAVDS20 			TFS 53760  DuplicateItem not Translatable
// ---------------------------------------------------------------------------

vars
	aBank : CM_Bank;
	realMe, checkMe : CM_InvoiceLineDescGroup;
begin
	
	// Par 10879
	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Description), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Description), null, null); // cnwdb2	PAR 35364
	endif;
	realMe := self.pxyGetRealObject();
	if realMe &lt;&gt; null then
		aBank := realMe.bank;
	else
		aBank := self.bank;			// 35872
	endif;
	
	// PAR 13276
	checkMe := aBank.invLineDescGroups[self.description];
	if checkMe &lt;&gt; null and checkMe &lt;&gt; realMe then
		//app.raiseCMException2(DuplicateItem, "'" &amp; self.description &amp; "'", "Invoice Line Groups. It has already been used, try a different code.", null, null); //23/06/2022 NAVDS20 TFS 53760
		// ' %1 ' already exists for Invoice Line Groups. It has already been used, try a different code. : Alrea_exist_invoi_line_group_a
		app.raiseCMException1(Alrea_exist_invoi_line_group_a,  self.description , null, null); //23/06/2022 NAVDS20 TFS 53760
	
	endif;
	
	//epr TFS 2903 20/1/17
	if self.minimumChargeAmount &lt;&gt; null then							
		if self.myMinimumChargeInvoiceLineType = null then
			app.raiseCMException(Invoi_line_type_min_invtype,null,null);
		endif;
	endif;
	if self.myMinimumChargeInvoiceLineType &lt;&gt; null then				
		if self.minimumChargeAmount = null then
			app.raiseCMException(Invoi_line_type_min_amount,null,null);
		endif;
	endif;
	
end;</source>
    </JadeMethod>
</Class>
