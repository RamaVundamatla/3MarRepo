    <JadeMethod name="setForUpdate" id="e7227dc5-cd42-4bc4-a801-1c4b3b1b2621">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
//
//11 Dec 2015	cnwrs1	Par 37402 TFS 1192 MultiLine Release Request
//16 Jan 2024	jlirs1	TFS 61640 EUP Release Request by Type by Weight//
vars
	prop : Property;
	propDict : PropertyNDict;
begin
	inheritMethod(_proxyEDITI);
	
	propDict := self.class.getProperties;
	foreach prop in propDict do
		if self.canUserSet(prop.name) then
			// bypass all type integrity checking in the name of convenience!!!
			self.setPropertyValue(prop.name, _proxyEDITI.getPropertyValue(prop.name));
		endif;
	endforeach;
	self.setByTypeByWeight(_proxyEDITI.getByTypeByWeight());		//16 Jan 2024	jlirs1	TFS 61640 EUP Release Request by Type by Weight
end;</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setFromGood" id="4dd2e390-065b-48dd-a667-c451491ce424">
        <updating/>
        <source>setFromGood(_good : CMIF_JsonGoodEUP; _header : CM_EDIRequestHeaderTI io; _ediRequest : CM_EDIDataRequestMultiLine; _xlationOperator : CM_Operator; _transport : CMIF_JsonTransportFullEUP) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 10/07/2023	navdap1		Initial creation TFS 58923 EUP CallOff EDI Data Type / EDI Load
// 18 Jul 2023	jlirs1		TFS 59004 Country of origin not being loaded
// 08 Aug 2023	navra1		TFS 59671 EUP - Incoming Manifest and CallOff data is case sensitive
// 29/08/2023	navdap1		TFS 60115 EUP FR CallOff
// 30/08/2023	navdap1		TFS 60150 EUP | FR 53824 - Road Manifest IMPORT cargo
// 01/09/2023	navcs2		Bug 60159: EUP | FR 54536 - Damage and Repair CAMS - Transform Change (ID)
// 25/10/2023	navdap1		TFS 60390 EUP | FR 53824 - Goods/Good/ID and Item grouping
// 19/01/2024	navhn30		Bug 61946: EUP - consignor/consignor held in different fields for Call Off and Transport Manifest
// 21/08/2024	navmd1		TFS 61725 Convert from UTC to local time
// 02/12/2024	navcs2		MTN-33047 EUP - NTO-1000 - EUP - Additional Data Fields in EDI Operations
// 06 May 2025	naviv1		MTN-34689 - EUP FR | 54084 - CallOff - Weight is not populated on the release detail line in CallOffStockMove
vars
	terminal : CM_Terminal;
	measurement : CM_MeasurementType;
	measurename : String;
	foundMatch : Boolean;
	criteria : CM_EDIRequestCriteriaTI;
	cargoTypeStr : String;
	cargoTypeObj : CM_CargoType;
	subTypeStr : String;
	subTypeObj : CM_Product;
	consignStr : String;
	address : CMIF_JsonAddressEUP;
	sortingStr : String;
	yaGrade : CM_YATypeGrade;
	yaColour : CM_YATypeColour;
	yaWidth : CM_YATypeCargoWidth;
	yaLength : CM_YATypeCargoLength;
	yaHeight : CM_YATypeCargoHeight;
	yaDiameter : CM_YATypeDiameter;
	yaGrammage : CM_YATypeGrammage;
	yaCommodity : CM_YATypeCommodity;
	yaSorting : CM_YATypeSortingMethod;
	yaCargoGroup : CM_YATypeCargoGroup;		// TFS 60115
	foundCargoGroup : CM_CargoGroup;		// TFS 60115
	instructionCode : String;
	originalVoyageCode : String;
	vesselName : String;
	lloydsNumber : String;
	yaVoyageInbound : CM_YATypeVoyageInbound;
	voyageCode : String;
	xlatCommodity,
    xlatLoadStr,
    xlatUnloadPort,
    xlatFinalDestPort: String;
begin
	terminal := _ediRequest.getMyTerminal();
	
	self.setMyEDIData(_ediRequest);
	self.releaseRequestNumber := _header.releaseRequestNumber;
	self.lineNumber := _good.iD.Integer; // 01/09/2023 navcs2 Bug 60159
	self.requestDetailID := self.releaseRequestNumber &amp; "_" &amp; self.lineNumber.String.padLeadingZeros(2);
	self.messageMode := _header.messageMode;
	
	self.billOfLading := _good.bOLNumber;
	self.cargoGroupId := _good.keyMarks.toUpper();			//navra1 - TFS 59671 - 8th Aug 2023
	self.mark := _good.reference;
	// TFS 60390 Don't set order number unless we have a mill order number 
	if _good.millOrderNumber &lt;&gt; null then
		self.cargoMatchOrderNumber := _good.millOrderNumber;
	endif;
	if _good.millOrderLineNumber &lt;&gt; null then
		if self.cargoMatchOrderNumber &lt;&gt; null then
			self.cargoMatchOrderNumber := _good.millOrderNumber &amp; "|" &amp; _good.millOrderLineNumber;
		endif;
	endif;
	// TFS 60390 end
	
	// Export Voyage Code - header level data
	voyageCode := _good.exportVoyage.toUpper();				//navra1 - TFS 59671 - 8th Aug 2023
	if voyageCode &lt;&gt; null then
		if _xlationOperator &lt;&gt; null then
			voyageCode := _xlationOperator.getXlationSystemCode_Voyage(voyageCode, null, null, null, foundMatch);
			_header.setVoyageCode(voyageCode);
		endif;
	endif;
	
	// Grade, Colour, Width, Length, Height, Diameter, Grammage, Commodity are all extra criteria
	if _good.grade &lt;&gt; null then
		create criteria persistent;
		criteria.releaseRequestNumber := self.releaseRequestNumber;
		criteria.messageMode := self.messageMode;
		create yaGrade transient;
		criteria.criteriaName := yaGrade.getTypeName();
		criteria.criteriaValue := _good.grade;
		criteria.setMyEDIData(_ediRequest);
		criteria.requestDetailID := self.requestDetailID;
	endif;
	if _good.colour &lt;&gt; null then
		create criteria persistent;
		criteria.releaseRequestNumber := self.releaseRequestNumber;
		criteria.messageMode := self.messageMode;
		create yaColour transient;
		criteria.criteriaName := yaColour.getTypeName();
		criteria.criteriaValue := _good.colour;
		criteria.setMyEDIData(_ediRequest);
		criteria.requestDetailID := self.requestDetailID;
	endif;
	
	if _good.lengthUOM &lt;&gt; null then
		measurement := app.getMeasurementTypeByNameDesc(_good.lengthUOM);
		if measurement &lt;&gt; null then
			measurename := measurement.shortName;
		endif;
	endif;
	if _good.width &lt;&gt; null then
		create criteria persistent;
		criteria.releaseRequestNumber := self.releaseRequestNumber;
		criteria.messageMode := self.messageMode;
		create yaWidth transient;
		criteria.criteriaName := yaWidth.getTypeName();
		if measurename &lt;&gt; null then
			criteria.criteriaValue := app.convertMeasurementForStorage(measurename, _good.width).asStringJMT;
		else
			criteria.criteriaValue := _good.width.asStringJMT;
		endif;
		criteria.setMyEDIData(_ediRequest);
		criteria.requestDetailID := self.requestDetailID;
	endif;
	if _good.length &lt;&gt; null then
		create criteria persistent;
		criteria.releaseRequestNumber := self.releaseRequestNumber;
		criteria.messageMode := self.messageMode;
		create yaLength transient;
		criteria.criteriaName := yaLength.getTypeName();
		if measurename &lt;&gt; null then
			criteria.criteriaValue := app.convertMeasurementForStorage(measurename, _good.length).asStringJMT;
		else
			criteria.criteriaValue := _good.length.asStringJMT;
		endif;
		criteria.setMyEDIData(_ediRequest);
		criteria.requestDetailID := self.requestDetailID;
	endif;
	if _good.thickness &lt;&gt; null then
		create criteria persistent;
		criteria.releaseRequestNumber := self.releaseRequestNumber;
		criteria.messageMode := self.messageMode;
		create yaHeight transient;
		criteria.criteriaName := yaHeight.getTypeName();
		if measurename &lt;&gt; null then
			criteria.criteriaValue := app.convertMeasurementForStorage(measurename, _good.thickness).asStringJMT;
		else
			criteria.criteriaValue := _good.thickness.asStringJMT;
		endif;
		criteria.setMyEDIData(_ediRequest);
		criteria.requestDetailID := self.requestDetailID;
	endif;
	if _good.diameter &lt;&gt; null then
		create criteria persistent;
		criteria.releaseRequestNumber := self.releaseRequestNumber;
		criteria.messageMode := self.messageMode;
		create yaDiameter transient;
		criteria.criteriaName := yaDiameter.getTypeName();
		if measurename &lt;&gt; null then
			criteria.criteriaValue := app.convertMeasurementForStorage(measurename, _good.diameter).asStringJMT;
		else
			criteria.criteriaValue := _good.diameter.asStringJMT;
		endif;
		criteria.setMyEDIData(_ediRequest);
		criteria.requestDetailID := self.requestDetailID;
	endif;
	if _good.grammage &lt;&gt; null then
		create criteria persistent;
		criteria.releaseRequestNumber := self.releaseRequestNumber;
		criteria.messageMode := self.messageMode;
		create yaGrammage transient;
		criteria.criteriaName := yaGrammage.getTypeName();
		criteria.criteriaValue := _good.grammage.asStringJMT;
		criteria.setMyEDIData(_ediRequest);
		criteria.requestDetailID := self.requestDetailID;
	endif;
	if _good.quality &lt;&gt; null then
		create criteria persistent;
		criteria.releaseRequestNumber := self.releaseRequestNumber;
		criteria.messageMode := self.messageMode;
		create yaCommodity transient;
		criteria.criteriaName := yaCommodity.getTypeName();
        xlatCommodity := _good.quality;
        if _xlationOperator &lt;&gt; null then
            xlatCommodity := _xlationOperator.getXlationSystemCode_Commodity(xlatCommodity, foundMatch, null);//Translate//09.Aug.2023 navsp1 TFS 59656
        endif;
		criteria.criteriaValue := xlatCommodity;
		criteria.setMyEDIData(_ediRequest);
		criteria.requestDetailID := self.requestDetailID;
	endif;
	
	// Cargo Type / Cargo Sub Type
	cargoTypeStr := _good.cargoType;
	if _xlationOperator &lt;&gt; null then
		cargoTypeStr := _xlationOperator.getXlationSystemCode(cargoTypeStr, XLATION_TYPE_CARGOTYPE_BYOP, foundMatch);
	endif;
	
	//Translation return id for the cargo type object
	if cargoTypeStr.isInteger then											//07.Aug.2023 navsp1 TFS 59656
		cargoTypeObj := app.myRoot.allCargoTypesById[cargoTypeStr.Integer];
	else
		cargoTypeObj := app.myRoot.getCargoTypeFromAbbrevOrDescr(cargoTypeStr);
	endif;
	
	if cargoTypeObj &lt;&gt; null then
		self.setCargoType(cargoTypeObj.id);
	else
		self.cargoTypeDescr := cargoTypeStr;
	endif;
	if _good.packageType &lt;&gt; null then
		subTypeStr := _good.packageType;
		if _xlationOperator &lt;&gt; null then
			subTypeStr := _xlationOperator.getXlationSystemCode_CargoSubT(subTypeStr, cargoTypeObj, foundMatch);	// TFS 60150
		endif;
		if cargoTypeObj &lt;&gt; null then
			subTypeObj := cargoTypeObj.allProducts[null, subTypeStr];
			if subTypeObj &lt;&gt; null then
				self.cargoSubType := subTypeStr;
			else
				self.cargoSubType := subTypeStr;
			endif;
		else
			self.cargoSubType := subTypeStr;
		endif;
	endif;
	
	// If we don't have a cargo type, and we have no items, find a cargo group based on the KeyMarks attribute
	// If there's no cargo group yet, then create an extra criteria for cargo group
	if self.cargoType = null and self.cargoTypeDescr = null and _good.keyMarks &lt;&gt; null then
		self.cargoGroupId := _good.keyMarks.toUpper();			//navra1 - TFS 59671 - 8th Aug 2023
		// TFS 60115 start
		foundCargoGroup := terminal.allCargoGroupsByCargoTypeId[terminal.defaultCargoGroupType, self.cargoGroupId].CM_CargoGroup;
		
		if foundCargoGroup = null then
			create criteria persistent;
			criteria.releaseRequestNumber := self.releaseRequestNumber;
			criteria.messageMode := self.messageMode;
			create yaCargoGroup transient;
			criteria.criteriaName := yaCargoGroup.getTypeName();
			criteria.criteriaValue := self.cargoGroupId;
			criteria.setMyEDIData(_ediRequest);
			criteria.requestDetailID := self.requestDetailID;
		endif;
		// TFS 60115 end
	endif;
	
	self.quantity := _good.quantityExpected;
	self.quantityPieces := _good.piecesPerPack;						//02/12/2024	navcs2		MTN-33047
	self.weightRequested := _good.grossWeightExpected;
	if self.quantity = null and self.weightRequested &gt; 0 then //JIRA-34689
		self.setByTypeByWeight(true); 
	endif;
	if _good.weightUOM &lt;&gt; null then
		measurement := app.getMeasurementTypeByNameDesc(_good.weightUOM);
		if measurement &lt;&gt; null then
			measurename := measurement.shortName;
			self.weightRequested := app.convertMeasurementForStorage(measurename, _good.grossWeightExpected);
		else
			self.weightRequested := _good.grossWeightExpected;
		endif;
	endif;
	self.volume := _good.volumeExpected;
	if _good.volumeUOM &lt;&gt; null then
		measurement := app.getMeasurementTypeByNameDesc(_good.volumeUOM);
		if measurement &lt;&gt; null then
			measurename := measurement.shortName;
			self.volume := app.convertMeasurementForStorage(measurename, _good.volumeExpected);
		else
			self.volume := _good.volumeExpected;
		endif;
	endif;
	
	// Instructions
	if _good.instruction &lt;&gt; null and _good.instruction.code &lt;&gt; null then
		instructionCode := _good.instruction.code;
		if _xlationOperator &lt;&gt; null then
			instructionCode := _xlationOperator.getXlationSystemCode_Instruct(instructionCode, foundMatch);
		endif;
		self.instructionType := instructionCode;
		self.instructionExternal := _good.instruction.remark;
		self.instructionInternal := _good.instruction.internalRemark;
	endif;
	
	// Consignee / Consignor / Freight Forwarder are at the header level
	if _good.mill &lt;&gt; null then
		consignStr := _good.mill.code;
		if _xlationOperator &lt;&gt; null then
			consignStr := _xlationOperator.getXlationSystemCode(consignStr, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch);
		endif;
		_header.consignor := consignStr;				//19.01.24	 navhn30		TFS #61946
	endif;
	if _good.buyer &lt;&gt; null then
		consignStr := _good.buyer.code;
		if _xlationOperator &lt;&gt; null then
			consignStr := _xlationOperator.getXlationSystemCode(consignStr, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch);
		endif;
		_header.consignee := consignStr;				//19.01.24	 navhn30		TFS #61946
	endif;
	if _good.forwardingAgent &lt;&gt; null then
		consignStr := _good.forwardingAgent.code;
		if _xlationOperator &lt;&gt; null then
			consignStr := _xlationOperator.getXlationSystemCode(consignStr, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch);
		endif;
		_header.freightForwarder := consignStr;
	endif;
	
	// Sorting Method is an extra criteria
	sortingStr := _good.sortingMethod;
	if sortingStr &lt;&gt; null then
		if _xlationOperator &lt;&gt; null then
			sortingStr := _xlationOperator.getXlationSystemCode(sortingStr, XLATION_TYPE_SORTINGMETHD_BYOP, foundMatch);
		endif;
		create criteria persistent;
		criteria.releaseRequestNumber := self.releaseRequestNumber;
		criteria.messageMode := self.messageMode;
		create yaSorting transient;
		criteria.criteriaName := yaSorting.getTypeName();
		criteria.criteriaValue := _good.sortingMethod;
		criteria.setMyEDIData(_ediRequest);
		criteria.requestDetailID := self.requestDetailID;
	endif;
	
	self.condition := _good.certificate;
	
	// Load / Discharge / Destination Port are at the header level
    xlatLoadStr         := _good.loadingPort.toUpper();						//navra1 - TFS 59671 - 8th Aug 2023
    xlatUnloadPort      := _good.unloadingPort.toUpper();					//navra1 - TFS 59671 - 8th Aug 2023
    xlatFinalDestPort   := _good.finalDestinationPort.toUpper();			//navra1 - TFS 59671 - 8th Aug 2023
    if _xlationOperator &lt;&gt; null then
        xlatLoadStr         := _xlationOperator.getXlationSystemCode(xlatLoadStr, XLATION_TYPE_PORT_BYOP, foundMatch);      //09.Aug.2023 navsp1 TFS 59656
        xlatUnloadPort      := _xlationOperator.getXlationSystemCode(xlatUnloadPort, XLATION_TYPE_PORT_BYOP, foundMatch);   //09.Aug.2023 navsp1 TFS 59656
        xlatFinalDestPort   := _xlationOperator.getXlationSystemCode(xlatFinalDestPort, XLATION_TYPE_PORT_BYOP, foundMatch);//09.Aug.2023 navsp1 TFS 59656
    endif;
	_header.loadPort        := xlatLoadStr;
	_header.dischargePort   := xlatUnloadPort;
	_header.destinationPort := xlatFinalDestPort;
	_header.countryOfOriginCode := _good.countryOfOrigin;	// 18 Jul 2023	jlirs1	TYFS 59004 Country of origin not being loaded
	self.cargoMatchIMDGCode := _good.uNCode;
	self.customerReference := _good.customerReference;
	
	// Any Amount / Any Id
	if _good.reservationType.toUpper.pos("Any Id".toUpper,1) &lt;&gt; null then
		self.defaultAnyId := true;
	endif;
	if _good.reservationType.toUpper.pos("Any Amount".toUpper, 1) &lt;&gt; null then
		self.defaultAnyAmount := true;
	endif;
	
	// Delivery Party - need to store address details in case delivery party doesn't exist yet
	if _good.deliveryParty &lt;&gt; null then
		self.deliveryPartyCode := _good.deliveryParty.code;
		self.deliveryPartyName := _good.deliveryParty.name;
		self.deliveryFrom :=_good.deliveryDateTimeFrom.asUTCTimeStamp.utcToLocalTime;	//22.Jan.25 navsp1 UT Fixes  - asLocalTimeStampJMT() not handling the daylight savings properly.
		self.deliveryTo :=_good.deliveryDateTimeTo.asUTCTimeStamp.utcToLocalTime;		//22.Jan.25 navsp1 UT Fixes 
		
		// if the delivery party doesn't exist, we're going to have to create it later
		if app.myRoot.allDeliveryParties[self.deliveryPartyCode] = null then
			if _good.deliveryParty.address &lt;&gt; null then
				address := _good.deliveryParty.address;
				// store address details
				self.addressStreet1 := address.street1;
				self.addressStreet2 := address.street2;
				self.addressCity := address.city;
				self.addressCounty := address.county;
				self.addressCountry := address.country;
				self.addressCountryCode := address.countryCode;
				self.addressPostCode := address.postalCode;
			endif;
		endif;
	endif;
	
	// Original Transport - Voyage Inbound extra criteria (translated)
	originalVoyageCode := _good.originalTransport.toUpper();				//navra1 - TFS 59671 - 8th Aug 2023
	if _transport.vesselInfo &lt;&gt; null then
		vesselName := _transport.vesselInfo.vesselName;
		lloydsNumber := _transport.vesselInfo.iMO;
	endif;
	if originalVoyageCode &lt;&gt; null then
		if _xlationOperator &lt;&gt; null then
			originalVoyageCode := _xlationOperator.getXlationSystemCode_Voyage(originalVoyageCode, vesselName, lloydsNumber, null, foundMatch);
		endif;
		create criteria persistent;
		criteria.releaseRequestNumber := self.releaseRequestNumber;
		criteria.messageMode := self.messageMode;
		create yaVoyageInbound transient;
		criteria.criteriaName := yaVoyageInbound.getTypeName();
		criteria.criteriaValue := originalVoyageCode;
		criteria.setMyEDIData(_ediRequest);
		criteria.requestDetailID := self.requestDetailID;
	endif;
	
	
epilog
	delete yaGrade;
	delete yaColour;
	delete yaWidth;
	delete yaLength;
	delete yaHeight;
	delete yaDiameter;
	delete yaGrammage;
	delete yaCommodity;
	delete yaSorting;
	delete yaVoyageInbound;
end;</source>
        <Parameter name="_good" type="CMIF_JsonGoodEUP"/>
        <Parameter name="_header" type="CM_EDIRequestHeaderTI" usage="io"/>
        <Parameter name="_ediRequest" type="CM_EDIDataRequestMultiLine"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <Parameter name="_transport" type="CMIF_JsonTransportFullEUP"/>
    </JadeMethod>
    <JadeMethod name="setFromReserveSelection" id="738246ab-d857-4d14-84f4-c30889a3c667">
        <updating/>
        <source>setFromReserveSelection(_reserveDetail : CM_ReserveSelection) updating;
//
//19 Dec 2017	jlgrs1	Initial creation
//16 Jan 2024	jlirs1	TFS 61640 EUP Release Request by Type by Weight
//
vars
	int : Integer;
begin
	foreach int in _reserveDetail.allAvailabilityGrades do
		self.availabilityGrades := int.String&amp;' ';
	endforeach;
	if _reserveDetail.myBOLIn &lt;&gt; null then
		self.billOfLading := _reserveDetail.myBOLIn.number;
	endif;
//	self.cargoSubType := _reserveDetail.cargoSubType;
	self.checkISOGroup := _reserveDetail.doISOGroupCheck;
	self.clean := _reserveDetail.clean;
	self.heavyDuty := _reserveDetail.heavyRated;
//	self.ids := _reserveDetail.ids;
//	self.isChild := _reserveDetail.isChild;
//	self.isGeneratorAttachment := _reserveDetail.isGeneratorAttachment;
	if _reserveDetail.myISOType &lt;&gt; null then
		self.isoType := _reserveDetail.myISOType.code;
	endif;
	if _reserveDetail.myISOGroup &lt;&gt; null then
		self.isoTypeGroup := _reserveDetail.myISOGroup.code;
	endif;
	self.quantity := _reserveDetail.quantitySelection;
	if _reserveDetail.myReserveHeader &lt;&gt; null then
		self.releaseRequestNumber := _reserveDetail.myReserveHeader.code;
	endif;
	self.remarks := _reserveDetail.remarks;
//	self.requestDetailID := _reserveDetail.requestDetailID;
	self.sequence := _reserveDetail.sequence;
//	self.stopsToApply := _reserveDetail.stopsToApply;
//	self.taskToApply := _reserveDetail.taskToApply;
	self.volume := _reserveDetail.volumeSelection;
	self.weight := _reserveDetail.weightSelection;
	self.mark := _reserveDetail.markSelection;	//29 Aug 2019	NDL	TFS 46118
	self.setByTypeByWeight(_reserveDetail.byTypeByWeight);		//16 Jan 2024	jlirs1	TFS 61640 EUP Release Request by Type by Weight

epilog

end;</source>
        <Parameter name="_reserveDetail" type="CM_ReserveSelection"/>
    </JadeMethod>
    <JadeMethod name="setFromReserveTi" id="2072dcf7-0c0a-4118-bd19-bcc7544c16cf">
        <updating/>
        <source>setFromReserveTi(_reserveDetail : CM_ReserveTI) updating;
//
//19 Dec 2017	jlgrs1	Initial creation
//23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
//16 Jan 2024	jlirs1	TFS 61640 EUP Release Request by Type by Weight
//
vars
	ti : CM_TrackedItem;
//	int : Integer;
	allTis	: CM_TISet;
begin
	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
//	foreach int in _reserveDetail.allAvailabilityGrades do
//		self.availabilityGrades := int.String&amp;' ';
//	endforeach;
	if _reserveDetail.myBOLIn &lt;&gt; null then
		self.billOfLading := _reserveDetail.myBOLIn.number;
	endif;
//	self.cargoSubType := _reserveDetail.cargoSubType;
//	self.checkISOGroup := _reserveDetail.doISOGroupCheck;
//	self.clean := _reserveDetail.clean;
//	self.heavyDuty := _reserveDetail.heavyRated;
	_reserveDetail.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
	//foreach ti in _reserveDetail.allTrackedItems do
	foreach ti in allTis do //23/06/2023	navkc1	CR 58406 Task 58408
		self.ids := ti.id&amp;' ';
	endforeach;
//	self.isChild := _reserveDetail.isChild;
//	self.isGeneratorAttachment := _reserveDetail.isGeneratorAttachment;
//	if _reserveDetail.myISOType &lt;&gt; null then
//		self.isoType := _reserveDetail.myISOType.code;
//	endif;
//	if _reserveDetail.myISOGroup &lt;&gt; null then
//		self.isoTypeGroup := _reserveDetail.myISOGroup.code;
//	endif;
	self.quantity :=1; //
	if _reserveDetail.myReserveHeader &lt;&gt; null then
		self.releaseRequestNumber := _reserveDetail.myReserveHeader.code;
	endif;
	self.remarks := _reserveDetail.remarks;
//	self.requestDetailID := _reserveDetail.requestDetailID;
	self.sequence := _reserveDetail.sequence;
//	self.stopsToApply := _reserveDetail.stopsToApply;
//	self.taskToApply := _reserveDetail.taskToApply;
//	self.volume := _reserveDetail.volumeSelection;
//	self.weight := _reserveDetail.weightSelection;
	self.setByTypeByWeight(_reserveDetail.byTypeByWeight);		//16 Jan 2024	jlirs1	TFS 61640 EUP Release Request by Type by Weight
epilog
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
        <Parameter name="_reserveDetail" type="CM_ReserveTI"/>
    </JadeMethod>
