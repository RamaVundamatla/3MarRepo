    <JadeMethod name="populateCombos" id="8868a6d4-0bff-4f04-bf80-4b5fcaf194d5">
        <updating/>
        <source>populateCombos() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2012	cnwndl1	Initial creation

*/

vars

	theForm : SOP_HMS_TableMaintForm;
	index : Integer;

begin

	theForm := self.myForm.SOP_HMS_TableMaintForm;

	theForm.cmbOperator.clear();
	theForm.cmbCriteria.clear();
	
	index := theForm.cmbOperator.addItem( HMS_PilotExemptionRule.Oper_Equals_Str );
	theForm.cmbOperator.itemData[index] := HMS_PilotExemptionRule.Oper_Equals;
	
	index := theForm.cmbOperator.addItem( HMS_PilotExemptionRule.Oper_GEQ_Str );
	theForm.cmbOperator.itemData[index] := HMS_PilotExemptionRule.Oper_GEQ;
	
	index := theForm.cmbOperator.addItem( HMS_PilotExemptionRule.Oper_Greater_Str );
	theForm.cmbOperator.itemData[index] := HMS_PilotExemptionRule.Oper_Greater_Than;
	
	index := theForm.cmbOperator.addItem( HMS_PilotExemptionRule.Oper_LEQ_Str );
	theForm.cmbOperator.itemData[index] := HMS_PilotExemptionRule.Oper_LEQ;
	
	index := theForm.cmbOperator.addItem( HMS_PilotExemptionRule.Oper_Less_Than_Str );
	theForm.cmbOperator.itemData[index] := HMS_PilotExemptionRule.Oper_Less_Than;
	
	index := theForm.cmbCriteria.addItem( HMS_PilotExemptionRule.Criteria_Draft_Str );
	theForm.cmbCriteria.itemData[index] := HMS_PilotExemptionRule.Criteria_Draft;
	
	index := theForm.cmbCriteria.addItem( HMS_PilotExemptionRule.Criteria_Length_Str );
	theForm.cmbCriteria.itemData[index] := HMS_PilotExemptionRule.Criteria_Length;
	
	index := theForm.cmbCriteria.addItem( HMS_PilotExemptionRule.Criteria_Weight_Str );
	theForm.cmbCriteria.itemData[index] := HMS_PilotExemptionRule.Criteria_Weight;
	
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="0018a143-fee4-4d37-941a-179650d02dd7">
        <updating/>
        <source>setControlsForAddEdit() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2012	cnwndl1	Initial creation

*/

vars
	theForm : SOP_HMS_TableMaintForm;
begin
	theForm := self.myForm.SOP_HMS_TableMaintForm;
	theForm.tblInput1.userInputEnabled := true;
	self.populateCombos();
			
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
//		theForm.tblInput1.enableRowByName(ETRow_Code);
//		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
//		theForm.tblData1.enabled := true;
		theForm.tblData1.userInputEnabled := true;
		theForm.fldInput.initSheetBackColors();	

	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.HMS_PilotExemptionRule);
		// cannot update code
	//	theForm.tblInput1.enableRowByName(ETRow_Code);
	//	theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblData1.userInputEnabled := true;
	endif;

epilog

end;</source>
    </JadeMethod>
