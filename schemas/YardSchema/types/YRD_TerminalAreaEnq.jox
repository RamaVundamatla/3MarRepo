    <JadeMethod name="btnAreaTypes_click" id="17a9957e-1f0f-4bba-825f-eb2a19e45058">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAreaTypes_click(btn: Button input) updating;
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 11 September 2003
//
//-----------------------------------------------------------------------

vars

begin
	if self.frmSearch.visible then
		if (not self.fldSearch.topSheet = self.shtAreaTypes) then
			self.fldSearch.topSheet := self.shtAreaTypes;
		else
			self.frmSearch.visible := false;
		endif;
	else
		if (not self.fldSearch.topSheet = self.shtAreaTypes) then
			self.fldSearch.topSheet := self.shtAreaTypes;
		endif;

		self.frmSearch.visible := true;
	endif;
	
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
