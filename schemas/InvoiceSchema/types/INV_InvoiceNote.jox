    <JadeMethod name="createInvoiceNotes" id="bb9769ee-ac84-4a9a-a1b8-983416900e42">
        <updating/>
        <source>createInvoiceNotes() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 February 2022	navtnr20	Initial creation	52771.010

*/

vars
	result : Integer;
	pxyInvoiceNotes: CM_InvoiceNote;

begin
	if self.myCurrentInvoice = null then
		return;
	endif;
	
	create pxyInvoiceNotes transient;
	pxyInvoiceNotes.setProxyForCreate(self.txtNotes.text, self.chkInternalOnly.value, self.myCurrentInvoice);
	
	while true do
		app.myTrxCA.trxCreateInvoiceNote(pxyInvoiceNotes, self.myCurrentNote, self.myCurrentInvoice, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			slNotes.caption := app.getErrorString(Invoice_Notes_Saved);
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(CM_Invoice_Notes_Create), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
		endif;
		break;
	endwhile;

epilog
	delete pxyInvoiceNotes;
end;</source>
    </JadeMethod>
    <JadeMethod name="deleteInvoiceNotes" id="29eadf73-5399-486d-aa0a-a32135cdf107">
        <updating/>
        <source>deleteInvoiceNotes() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 February 2022	navtnr20	Initial creation	52771.010

*/

vars
	result 			: Integer;
	pxyInvoiceNote 	: CM_InvoiceNote;
	
begin
	if self.myCurrentInvoice = null or
	   self.myCurrentNote = null then
		return;
	endif;
	if app.msgBox(app.getErrorString2(CONF_REMOVE,"Invoice Notes for Invoice", "(" &amp; self.myCurrentInvoice.sequenceNum.String &amp; ")"), app.getErrorString(CONFIRM_REMOVAL), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;

	create pxyInvoiceNote transient;
	beginLoad;
		pxyInvoiceNote := self.myCurrentNote.pxyCreateUpdateProxy();
	endLoad;
	
	while true do
		app.myTrxUA.trxClearInvoiceNote(pxyInvoiceNote, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			self.unloadForm();
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(CM_Invoice_Notes_Delete), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);
		endif;
		
		break;
	endwhile;	

epilog
	delete pxyInvoiceNote;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doPermissionCheck" id="dd87845e-8e12-4da1-b84d-a1e764a10231">
        <updating/>
        <source>doPermissionCheck() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 February 2022	navhl20	Initial creation	52771.010
11 Mar 2022  navnk20     TFS #53072 MTN - Remove Notes State

*/

vars

begin
	self.btnClose.enabled:= true;
	self.btnRemove.enabled:= false; 		
	self.btnSave.enabled:= false;
    if app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		//self.btnRemove.enabled:= true;												//11 mar 2022  navnk20	TFS #53072
		if self.myCurrentNote &lt;&gt; null  and self.myCurrentNote.note &lt;&gt; null  then		//11 mar 2022  navnk20	TFS #53072
			self.btnRemove.enabled:= true;												//11 mar 2022  navnk20	TFS #53072			
		endif;																			//11 mar 2022  navnk20	TFS #53072
		self.btnSave.enabled:= true;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveNotes" id="e88df8cb-1ea8-4979-8340-151de5ca73e5">
        <updating/>
        <source>doSaveNotes() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 February 2022	navhl20	Initial creation	52771.010
11 Mar 2022  navnk20     TFS #53072 MTN - Remove Notes State

*/

vars

begin
	
	if self.myCurrentNote = null then 
		self.createInvoiceNotes();
	else
		self.updateInvoiceNotes();
	endif;	 
	  
	if self.myCurrentInvoice &lt;&gt; null and self.myCurrentInvoice.myInvoiceNote &lt;&gt; null then
		if self.myCurrentInvoice.myInvoiceNote.getAllAuditObjects().size &gt; 0 then
			self.btnAudit.enabled := true;
		endif;
		if self.myCurrentInvoice.myInvoiceNote.note &lt;&gt; null then  			//11 mar 2022  navnk20	TFS #53072
			self.btnRemove.enabled := true;									//11 mar 2022  navnk20	TFS #53072
		endif;																//11 mar 2022  navnk20	TFS #53072
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doViewAudits" id="1473d385-661d-4d1f-8177-525654002f33">
        <updating/>
        <source>doViewAudits() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 February 2022	navtnr20	Initial creation	52771.010

*/

vars

begin
	if self.myCurrentNote = null then
		return;
	endif;

	if self.myAssistant = null then
		create self.myAssistant as INV_Assistant transient;
		self.myAssistant.setMyTerminal(self.myTerminal);		
	endif;
	
	app.viewAuditForm(self.myCurrentNote, self.myAssistant.class, self.myTerminal);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="b7d3e9ea-e303-4ace-8e8c-408bb63cfe82">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who			Reason
09 Feb 2022	navtnr20	Initial creation	52771.010
14 Mar 2022 navma1		Bug 53073: MTN - Invoice Notes Form Modality (in conjunction with Audits)     
22 Feb 2023	navvt20		TFS CR 55683 Task 56503: UI - Invoice Notes
*/

vars

begin
	inheritMethod();
	self.handleMenusForModalDisplay();
	if self.myCurrentInvoice = null then
		self.unloadForm();
		return;
	endif;
	
	doPermissionCheck();
	self.frmQuery.visible	:= false;
	self.splMain.visible    := false;
	self.btnCancel.visible	:= false;
	self.btnAudit.enabled 	:= false;
	//self.frmInvoice.top 	:= 380;	// 22 Feb 2023 navvt20 TFS 56503
	
	//self.caption := self.caption &amp; " - " &amp; app.getErrorString(CM_Invoice_GC) &amp; "(" &amp; self.myCurrentInvoice.sequenceNum.String &amp;")"; // 22 Feb 2023 navvt20 TFS 56503
	self.caption := self.caption &amp; " - " &amp; app.getErrorString(CM_Invoice_GC)  &amp; self.myCurrentInvoice.bank.code &amp; "-" &amp; "(" &amp; self.myCurrentInvoice.sequenceNum.String &amp;")"; // 22 Feb 2023 navvt20 TFS 56503
	if self.myCurrentNote &lt;&gt; null then
		self.btnAudit.enabled 	   := true;
		self.txtNotes.text 		   := self.myCurrentNote.note;
		self.chkInternalOnly.value := self.myCurrentNote.internalOnly;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="ccc65945-647c-4130-906a-098fded7eada">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 March 2022 11:30:32.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0024617, locale);
	btnAudit.translateCaption(Xlat_0024618, locale);
	btnClose.translateCaption(Xlat_0024619, locale);
	btnRemove.translateCaption(Xlat_0024620, locale);
	btnSave.translateCaption(Xlat_0024621, locale);
	chkInternalOnly.translateCaption(Xlat_0024622, locale);
	lblNotes.translateCaption(Xlat_0024623, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="updateInvoiceNotes" id="c17d433c-0cf0-402f-bbc7-39743d558845">
        <updating/>
        <source>updateInvoiceNotes() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 February 2022	navtnr20	Initial creation	52771.010

*/

vars
	result : Integer;
	pxyInvoiceNote: CM_InvoiceNote;
begin
	if self.myCurrentInvoice = null then
		return;
	endif;

	create pxyInvoiceNote transient;
	beginLoad;
		pxyInvoiceNote := self.myCurrentNote.pxyCreateUpdateProxy();
	endLoad;
	pxyInvoiceNote.setProxyForUpdate(self.txtNotes.text, self.chkInternalOnly.value);
	
	while true do
		app.myTrxUA.trxUpdateInvoiceNote(pxyInvoiceNote,app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			slNotes.caption := app.getErrorString(Invoice_Notes_Updated);
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(CM_Invoice_Notes_Update), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);
		endif;
		
		break;
	endwhile;	

	
epilog
	delete pxyInvoiceNote;
	
end;</source>
    </JadeMethod>
</GUIClass>
