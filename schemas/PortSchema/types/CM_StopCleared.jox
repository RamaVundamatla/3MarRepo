    <JadeMethod name="validateCMIF_TITransCntrl" id="7760c499-5204-4228-adba-8e3ed86d6df4">
        <source>validateCMIF_TITransCntrl( _tiTransCntrl : CMIF_TITransactionController ) : Boolean;
//--------------------------------------------------
// Created:	31 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	invObj : Boolean;
begin

	/* cnwrl1 31/08/2010 PAR 23697 - what it was
	// NOTE: THIS CODE NEVER ACTUALLY DID ANYTHING BUT inheritMethod !!!!
	return inheritMethod(_tiTransCntrl);
	if _tiTransCntrl.myStop = null then
		app.raiseCMException1(REQUIRED_FIELD, 'myStop', null, null);
		return false;
	endif;
	cnwrl1 31/08/2010 PAR 23697 - end of what it was */
	
	if not app.isInProformaMode then
		// cnwrl1 31/08/2010 PAR 23697 - start of replacement coding
		if _tiTransCntrl.myStop = null and not self.isStopClearedDocAction then
		//	app.raiseCMException1( REQUIRED_FIELD, 'myStop', null, null );
			app.raiseCMException(Input_required_field_myStop, null, null ); // cnwdb2	PAR 35364

		elseif not self.isStopClearedDocAction and _tiTransCntrl.myStop.myStopsTable = null then
		//	app.raiseCMException1( REQUIRED_FIELD, 'myStopTable', null, null );
			app.raiseCMException(Input_required_field_myStopTab, null, null ); // cnwdb2	PAR 35364
		endif;
	endif;
	
	
	return inheritMethod( _tiTransCntrl );
	
	// cnwrl1 31/08/2010 PAR 23697 - end of coding
	
epilog
	
end;
</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
