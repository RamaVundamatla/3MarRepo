    <JadeMethod name="setupForm" id="e977b08c-c27e-48dc-9886-e8a1ac4611c7">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Mar 2025	navlc30	Initial creation
25 Mar 2025 navlc30 JIRA 34264-TPT | FR 33661.020 VBS - One Release Request and VBS slot per Truck - No VBS Appointment
*/

vars

begin
	inheritMethod();
	
	self.maxButton := false;
	self.minButton := false;
	self.width := 530;
	self.height := 170;	
	self.lblMsg.fontSize := 11;

	self.lblMsg.caption := app.getErrorString(Vehicle_booking_not_available);

epilog

end;</source>
