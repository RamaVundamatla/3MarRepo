<GUIClass name="Window">
    <JadeMethod name="drawEllipse1" id="25df184e-4e84-4cac-9617-267b97fc18d3">
        <executionLocation>client</executionLocation>
        <source>drawEllipse1(_x1: Real; _y1: Real; _x2: Real; _y2: Real; _color: Integer) clientExecution;
/*

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 September 2011	cnwndl1	Initial creation	par 27984

	Drawing an elipse has resizing issues when running over remote connections where as drawing a pie doesn't

*/

vars

	drawError : Boolean;

begin

	if self.drawFillColor = _color then
		// draws a spoke on the circle, but it wont be seen if being filled the same colour...
		on Exception do self.handleNotImplementedError( exception, drawError ); 	//07 Feb 2012	NDL	Par 29086
		self.drawPie(_x1, _y1, _x2, _y2, null, null, null, null, _color);
		if drawError then	//07 Feb 2012	NDL	Par 29086
			self.drawEllipse(_x1, _y1, _x2, _y2, _color);
		endif;
	else
		// differnt fill colour, just have to put up with the weird behaviour...
		self.drawEllipse(_x1, _y1, _x2, _y2, _color);
	endif;

epilog

end;</source>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
        <Parameter name="_color" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawEllipse2" id="48e129db-67b7-460b-afac-de1fdec6a428">
        <executionLocation>client</executionLocation>
        <source>drawEllipse2(_x1: Real; _y1: Real; _x2: Real; _y2: Real; _color: Integer) clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 September 2011	cnwndl1	Initial creation	Par 27984

*/

vars


	wheelWidth : Real;
	spokeLeft : Real;
	cornerRounding : Real;
	
	drawError : Boolean;

begin

//	self.drawEllipse(_x1, _y1, _x2, _y2, _color);
	
	wheelWidth := (_x2 - _x1 );
	spokeLeft := _x1 + ( wheelWidth / 2 );
	on Exception do self.handleNotImplementedError( exception, drawError ); 	//07 Feb 2012	NDL	Par 29086
	self.drawPie(_x1, _y1, _x2, _y2, spokeLeft, _y1, spokeLeft, _y1, _color);
	if drawError then	//07 Feb 2012	NDL	Par 29086
		self.drawEllipse(_x1, _y1, _x2, _y2, _color);
	endif;
	
end;
</source>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
        <Parameter name="_color" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawParabola" id="8061d320-a5d3-4d75-b935-ad14c217a330">
        <source>drawParabola(_startX,
				_startY,
				_width,
				_height : Real;
				_concave : Boolean; //inward curving
				_colour : Integer);
/*

Purpose:		draw a parobala of height (_height) and width (_width) starting a point _startX,_startY

				y is calculated from the quadratic equation y=ax^2 + bx + c
				
				concave  - if true inward curving i.e. like a circle cut in half
				not concave - outward curving i.e. like a hill
				
Return Value:		


Date		Who		Reason
18 December 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	a, b, c,
	x, y : Real;
	xys : RealArray;
begin
	//cacluate a 
	a:=(_height/_width)/(_width/4);
	//caluate b
	
	b:=-(a*2)*(_width/2);
	
	create xys transient;
	x:=0;
	while x &lt;= _width  do
		//work out y from quadratic equation
		y:=(a*(x^2))+(b*x)+_startY;
		//add start x
		xys.add(x+ _startX);
		if _concave then
			xys.add(y);
		else
			xys.add(_startY + (_startY-y));
		endif;
		x:=x+1;	
	endwhile;
	self.drawPolygon(xys,_colour);

epilog
	delete xys;
end;</source>
        <Parameter name="_startX" type="Real"/>
        <Parameter name="_startY" type="Real"/>
        <Parameter name="_width" type="Real"/>
        <Parameter name="_height" type="Real"/>
        <Parameter name="_concave" type="Boolean"/>
        <Parameter name="_colour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleNotImplementedError" id="bc654122-6aec-4fbc-b0b8-ab39ffd49a3a">
        <source>handleNotImplementedError( _exc : Exception; _error : Boolean output ):Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 February 2012	cnwndl1	Initial creation	Par 29086

Windows CE doesn't support drawPie......

*/

vars

	returnVal		: Integer;

begin

	returnVal := Ex_Pass_Back;
	
	if _exc.errorCode = 14217 then
		_error := true;
		returnVal := Ex_Resume_Next;
	endif;
	
epilog

	return returnVal;

end;</source>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_error" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setBackForeColor" id="12c1bea3-aae8-40f6-9bd8-c2ad18702deb">
        <updating/>
        <source>setBackForeColor(_backColor:Integer; _foreColor:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		09 February 2006 by cnwdad1
//
// Purpose:		Sets the background and fore colors of the receiver. Not all Windows
//				or its subclasses have both a background and foreground, so this
//				method is reimplemented where necessary.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.backColor	:=	_backColor;
end;</source>
        <Parameter name="_backColor" type="Integer"/>
        <Parameter name="_foreColor" type="Integer"/>
    </JadeMethod>
</GUIClass>
