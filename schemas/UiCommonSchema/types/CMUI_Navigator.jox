    <JadeMethod name="setupForm" id="dd2752a9-0c26-4bc5-a444-c52744912792">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     22 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	user		: CM_User;
begin
	self.lstTest.defaultLineHeight := self.lstTest.getLineHeight + 2;	//15;
	/*
	user := app.getMyUser();
	
	if user.myMenuUserToolbarRoot &lt;&gt; null and user.myMenuUserToolbarRoot.showCaption then
		self.clientHeight := self.getMdiFrame.height.Integer - 200;
	else
		self.clientHeight := self.getMdiFrame.height.Integer - 150;
	endif;
	*/

	if app.isUsingSkin() then
		self.lstTest.move(0, 4, self.clientWidth, self.clientHeight - 4);
	else
		self.lstTest.move(0, 0, self.clientWidth, self.clientHeight);
	endif;
	
	self.loadNavData();
	self.lstTest.bubbleHelp := "To Search press Ctrl-F";
	
	//cnwmc5 - PAR 31334
	self.lstTest.stretchHeight := true;
	
	/*if process.isMitchell() then
		self.height := app.mainForm.clientHeight - 16;
		self.borderStyle := BorderStyle_None;
		self.left := 0;
		self.top := 0;
	endif;*/
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="742388df-3252-4776-a561-9e2db7290a2f">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 17 March 2025 09:29:59.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007822, locale);
	btnCloseSearchTV.translateCaption(Xlat_0000563, locale);
	btnCollapseNav.translateCaption(Xlat_0027041, locale);
	btnResetSearchTV.translateCaption(Xlat_0000564, locale);
	btnSearchTV.translateCaption(Xlat_0000565, locale);
	mnuDockTopLeft2.translateCaption(Xlat_0007823, locale);
	mnuOrganiseMenu.translateCaption(Xlat_0007824, locale);
	mnuOrganize.translateCaption(Xlat_0007825, locale);
	mnuOrganizeTerminals.translateCaption(Xlat_0007826, locale);
	mnuResetAllUserMenus.translateCaption(Xlat_0007827, locale);
	mnuResetFromSystem.translateCaption(Xlat_0007828, locale);
	mnuResetToDefault.translateCaption(Xlat_0007829, locale);
	mnuSaveToAdmin.translateCaption(Xlat_0007830, locale);
	mnuSaveToSystem.translateCaption(Xlat_0007831, locale);
end;</source>
    </JadeMethod>
</GUIClass>
