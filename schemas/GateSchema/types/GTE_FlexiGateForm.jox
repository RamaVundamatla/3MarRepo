    <JadeMethod name="btnFind_click" id="81725f9a-e1dc-4524-9819-59f4838b66a0">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnFind_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     29 July 2008 by cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 14/09/2016		cnwma1			TFS #2619:SPT - Road Gate loading incorrect release/prenote details when entering the Reg Code
// ---------------------------------------------------------------------------

vars
	vvr : CM_VehicleVisitRecord;
begin
	if self.detailsChangedVehicle then
		// PAR 18560
		if self.hasVehicleDataBeenEntered() then 
			if app.msgBox("You have started entering data, your entered data will be lost if you do a search." &amp; Cr &amp;  "Do you want to do a search?","Problem", MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_No then
				return;
			endif;
		endif;
	endif;
	//self.doQuery();  // 14/09/2016 cnwma1 TFS #2619
	self.doQuery(vvr); // 14/09/2016 cnwma1 TFS #2619
	self.hasChanged := false;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
