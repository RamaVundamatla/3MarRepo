    <JadeMethod name="finITSApplication" id="ec09bd89-1b98-4932-aa2a-4bf4ff2659bf">
        <updating/>
        <source>finITSApplication() updating;

/*

Purpose:			Finalise method for ITS Interface applications (JMTITSInterfaceApp, JMTRTNotificationApp and JMTITSWorkerApp)

Parameters:			None

Return Value:		None


Date		Who		Reason
24 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin
	if self.myInterfaceController &lt;&gt; null then
		self.myInterfaceController.finish();
		delete self.myInterfaceController;
	endif;	
	
	app.finalize();
	
epilog

end;</source>
    </JadeMethod>
