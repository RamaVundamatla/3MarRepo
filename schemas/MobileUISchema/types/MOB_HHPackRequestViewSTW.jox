    <JadeMethod name="setMyBulkRelease" id="56fc15f0-9ad7-4d52-8ded-5b0bff1be8fd">
        <updating/>
        <source>setMyBulkRelease( _bulkRelease : CM_BulkRelease ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2018	jlgndl1	Initial creation	TFS 38083
*/

vars
	
	isPack : Boolean;
	iter : Iterator;
	reserveDetail : CM_ReserveDetail;
	index :Integer;
	doEnable : Boolean;
	defColour : Integer;
	colour : Integer;

begin

	self.myBulkRelease := _bulkRelease;
	
	self.lstRelItems.clear();
	defColour := self.lstRelItems.backColor;
	
	if self.myBulkRelease = null then
		self.lstRelItems.addItemAt( app.getErrorString(No_request_found), 1 );
			
	else
		if self.myBulkRelease.isPackingType then
			isPack := true;
			iter := self.myBulkRelease.allReservePackingChildren.createIterator;
		else
			iter := self.myBulkRelease.allReserveDetails.createIterator;
		endif;
		
		if iter &lt;&gt; null then
			while iter.next( reserveDetail ) do		
				index := self.lstRelItems.addItem( reserveDetail.getStwHHCmbDetails37200( defColour, colour ) );
				self.lstRelItems.itemBackColor[index] := colour;	//20 Dec 2018	NDL	TFS 38083
				doEnable:= true;	
			endwhile;	
		endif;
	
	endif;
	
	self.lstRelItems.enabled := doEnable;
	self.btnOne.enabled := self.lstRelItems.enabled;
	
epilog

end;</source>
        <Parameter name="_bulkRelease" type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="setupControls" id="729d1ef4-1be0-4bf8-bb34-e10e82e830f7">
        <updating/>
        <source>setupControls() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2018	jlgndl1	Initial creation	TFS 38083

*/

vars
	
	errMsg : String;
	index : Integer;

begin
	
	self.doResizeControls(true);
	
	//reset if returning from somewhere else...
	
	if self.myMobileGenericAgent.myBulkRelease &lt;&gt; null then
		self.txtRequestId.text := self.myMobileGenericAgent.myBulkRelease.code;
		self.setMyBulkRelease(self.myMobileGenericAgent.myBulkRelease);
		self.myMobileGenericAgent.setMyBulkRelease( null );
	else
		self.setMyBulkRelease( null );
	endif;
	
	self.findRequest( true );
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="6918778c-e35d-4d88-b5e1-a6e2bdd2bbcc">
        <updating/>
        <source>setupForm() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2018	jlgndl1	Initial creation	TFS 38083

*/

vars

begin

	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	
	if app.myMobileCargoFindAgent = null then
		create app.myMobileCargoFindAgent transient;
	endif;
	
	inheritMethod();
	
	self.setupCmdButtons( 2, app.getErrorString(Next), app.getErrorString(Back), null, null, null );

	self.setupControls();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="090f474c-e728-4e58-974c-ae519fbfd7e6">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 20 December 2018 08:47:54.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023127, locale);
	lblRequest.translateCaption(Xlat_0023128, locale);
	lblRequestId.translateCaption(Xlat_0023129, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtRequestId_gotFocus" id="1c25bba7-1bde-424d-94bf-5366bfb8a50f">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtRequestId_gotFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 August 2014	cnwndl1	Initial creation	Par 34717 / CCMS 2384

*/

vars

begin

	if txtRequestId.text = lblRequestId.caption.toUpper then
		//txtTruck.text := null;
		txtRequestId.selStart := 0;
		txtRequestId.selLength := lblRequestId.caption.length;
	endif;
	
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtRequestId_lostFocus" id="145844f0-1e0c-40f5-afc1-e85efd78b7da">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtRequestId_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 August 2014	cnwndl1	Initial creation	Par 34717 / CCMS 2384

*/

vars

begin

	if txtRequestId.text.trimBlanks = null then
		txtRequestId.text := lblRequestId.caption.toUpper;
	endif;
	
	txtRequestId.selStart := 0;
	txtRequestId.selLength := 0;
	
	if self.myBulkRelease = null or self.myBulkRelease.code &lt;&gt; txtRequestId.text then
		self.findRequest( false );
	endif;
	

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
</GUIClass>
