    <JadeMethod name="addNewPageFrameIfRequired" id="3440bf5d-77bc-4e09-865f-057b9465073f">
        <updating/>
        <source>addNewPageFrameIfRequired( _frame : CMUI_Frame input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 October 2015	cnwndl1	Initial creation	Par 36777

*/

vars

	extraFrame : CMUI_Frame; 

begin

	if ( _frame.top + _frame.height ) &lt; self.frmFooter.top then
		//this one fits nothing to do
		return;
	endif;
	
	//it would run over, clone a new main frame
	self.pageCount := self.pageCount + 1;
	extraFrame := self.frmMain.loadControl( self.pageCount ).CMUI_Frame;
	extraFrame.parent := self;
	extraFrame.move(self.frmMain.left, self.frmMain.top, self.frmMain.width, self.frmMain.height );
	
	//re-position this frame near the top of the cloned main frame.
	_frame.parent := extraFrame;
	_frame.top := self.frmSect1.top;
	
	//re parent the rest of the frames
	if _frame = self.frmSect2 then
		self.frmSect3.parent := extraFrame;
		self.frmSect4.parent := extraFrame;
		self.frmSect5.parent := extraFrame;
	elseif _frame = self.frmSect3 then
		self.frmSect4.parent := extraFrame;
		self.frmSect5.parent := extraFrame;
	elseif _frame = self.frmSect4 then
		self.frmSect5.parent := extraFrame;
	endif;

epilog

end;</source>
        <Parameter name="_frame" type="CMUI_Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="adjustHeight" id="eba1985b-13e3-4fa2-905c-acf9e38ba75e">
        <source>adjustHeight( _label : CMUI_Label input ) : Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 October 2015	cnwndl1	Initial creation	Par 36777

*/

vars

	newHeight : Real;

begin

	newHeight := _label.getTextHeightForWidth( _label.caption, _label.width.Integer );
	if newHeight &gt; _label.height then
		_label.height := newHeight;
	endif;
	return _label.height;

epilog

end;</source>
        <Parameter name="_label" type="CMUI_Label" usage="input"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="moveDataLabel" id="c85f6b85-24ef-4609-8fc0-bd72f9cf4b1e">
        <source>moveDataLabel(	_parent : Control input;	
				_label : CMUI_Label input;
				_topPixels : Real;
				_heightPixels : Real;
				_leftMMs : Real;
				_rightMMs : Real;
				_align : Integer;
				_doLayoutCheck : Boolean
				) protected;
/*
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 August 2015	cnwndl1	Initial creation`	Par 36777

*/

vars

	vLeft : Real;
	vWidth : Real;
	
	testIndex : Integer;

begin

	
	_label.parent := _parent;
	
	vLeft := _leftMMs * self.pixelsPerMM;
	vWidth := ( _rightMMs -_leftMMs ) * self.pixelsPerMM;
	
	_label.move( vLeft, _topPixels, vWidth, _heightPixels );
	_label.alignment := _align;
	_label.fontName := "Courier New";
	_label.fontSize := 9;
	
	if _doLayoutCheck then
		if _label = self.lbl26 then
			foreach testIndex in 1 to 30 do
				_label.caption := _label.caption &amp; " 12345, abc defgh ijk lmnop qrstuv wxyz 12 34567 890 ABCD EFGHIJK LMN OPQRS TUV WXYZ.";
			endforeach;
		elseif _label = self.lbl25 or _label = self.lbl27 then
			foreach testIndex in 1 to 15 do
				_label.caption := _label.caption &amp; "ABCD EFGHIJK LMN OPQRS TUV WXYZ.";
			endforeach;
		endif;
	endif;
	
	
//	if _doLayoutCheck then
//		_label.borderStyle := 1;
	//	_label.caption := _label.caption &amp; "@" &amp; _leftMMs.String &amp; "," &amp; _topMMs.String &amp; "-" &amp; _rightMMs.String &amp; "," &amp; _bottomMMs.String &amp; "mm";
//	else
		_label.borderStyle := 0;	
//	endif;
	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_parent" type="Control" usage="input"/>
        <Parameter name="_label" type="CMUI_Label" usage="input"/>
        <Parameter name="_topPixels" type="Real"/>
        <Parameter name="_heightPixels" type="Real"/>
        <Parameter name="_leftMMs" type="Real"/>
        <Parameter name="_rightMMs" type="Real"/>
        <Parameter name="_align" type="Integer"/>
        <Parameter name="_doLayoutCheck" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="movePicture" id="cb23c36a-47a6-463e-850f-bd541ff07f5d">
        <source>movePicture(	_parent : Control input;	
				_pic : CMUI_Picture input;
				_topMMs : Real;
				_leftMMs : Real;
				_rightMMs : Real;
				_bottomMMs : Real;
				_doLayoutCheck : Boolean
				) protected;
/*
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 August 2015	cnwndl1	Initial creation`	Par 36777

*/

vars

	vTop : Real;
	vLeft : Real;
	vWidth : Real;
	vHeight : Real;
	
	dummyLabel : CMUI_Label;
	text : String;
	picture : Binary;

begin

	if _parent &lt;&gt; null then
		_pic.parent := _parent;
	endif;

//	vTop := ( _topMMs - self.frameTopOffset ) * self.pixelsPerMM;
//	vLeft := ( _leftMMs - self.frameLeftOffset ) * self.pixelsPerMM;
	vTop := _topMMs * self.pixelsPerMM;
	vLeft := _leftMMs * self.pixelsPerMM;
	vWidth := ( _rightMMs -_leftMMs ) * self.pixelsPerMM;
	vHeight := ( _bottomMMs -_topMMs ) * self.pixelsPerMM;

	_pic.move( vLeft, vTop, vWidth, vHeight );
	
	if _doLayoutCheck then
		_pic.borderStyle := 1;
		dummyLabel := self.lbl1.loadControl(1).CMUI_Label;
		text := "30@" &amp; _leftMMs.String &amp; "," &amp; _topMMs.String &amp; "-" &amp; _rightMMs.String &amp; "," &amp; _bottomMMs.String &amp; "mm";
		dummyLabel.width := vWidth;
		dummyLabel.height := vHeight;
		dummyLabel.caption := text;
		picture := dummyLabel.createPicture(false, false, 32);
		self.pic30.picture := picture;
	else
		_pic.backColor := White;
		_pic.borderStyle := 0;
	endif;


epilog

	delete dummyLabel;

end;</source>
        <access>protected</access>
        <Parameter name="_parent" type="Control" usage="input"/>
        <Parameter name="_pic" type="CMUI_Picture" usage="input"/>
        <Parameter name="_topMMs" type="Real"/>
        <Parameter name="_leftMMs" type="Real"/>
