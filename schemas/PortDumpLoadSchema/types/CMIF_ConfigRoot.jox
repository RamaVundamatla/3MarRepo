<Class name="CMIF_ConfigRoot">
    <JadeMethod name="exportAttrIgnorePDXML" id="2e06f207-8942-42ea-95b1-6e85fb790aaa">
        <source>exportAttrIgnorePDXML(_attrName:String) :Boolean;

vars

begin
	if _attrName = CMIF_ConfigRoot::portLogoPic.name or
	   _attrName = CMIF_ConfigRoot::systemBackgroundPic.name then
		return true;
	endif;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLReference" id="78f15af0-82f6-4d72-b836-b3185670f75a">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = CMIF_Config::myObject.name then
		return app.myRoot;
	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</Class>
