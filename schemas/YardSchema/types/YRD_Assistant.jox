    <JadeMethod name="showWagonEnquiry" id="c7307ce8-169a-4357-9b0b-7a90d19a509e">
        <source>showWagonEnquiry(_allWagons : ObjectSet; _train : CM_Train; _inward, _confirmInMode : Boolean; _masterMenuAction : CMUI_MenuAction; _callerForm: CM_BaseForm);
// ---------------------------------------------------------------------------
// Created:     June 2009 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	frm					: YRD_TrainWagonEnquiry;
	defaultTrain		: CM_Train;
	objs : ObjectSet;
begin
//	frm := app.getForm(YRD_TrainWagonEnquiry.name).YRD_TrainWagonEnquiry;
//	if frm = null then
		frm := app.loadForm(YRD_TrainWagonEnquiry, YRD_Assistant, false, false, false, self.myTerminal, _masterMenuAction).YRD_TrainWagonEnquiry;
//	endif;
	
	if frm = null then
		return;
	endif;
	defaultTrain := _train;
	
	if _allWagons &lt;&gt; null and not _allWagons.isEmpty() then
		frm.allWagons.clear();
		_allWagons.copy(frm.allWagons);
	endif;
	
	frm.setPropertyValue("myCurrentTrain",_train);
	frm.setPropertyValue("confirmInMode",_confirmInMode);
	frm.setDirection(_inward);
	frm.setParentForm( _callerForm );	//26 Feb 2021	NDL	TFS 50837
	
	frm.show();
epilog
	objs := _allWagons;
	delete objs;
end;








</source>
        <Parameter name="_allWagons" type="ObjectSet"/>
        <Parameter name="_train" type="CM_Train"/>
        <Parameter name="_inward" type="Boolean"/>
        <Parameter name="_confirmInMode" type="Boolean"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_callerForm" type="CM_BaseForm"/>
    </JadeMethod>
    <JadeMethod name="showYardTrainReport" id="c772391c-8c69-48e3-b796-68598825bffd">
        <source>showYardTrainReport(_rail : CM_Rail; _train : CM_Train; _parent : CM_BaseForm; _menuAction : CMUI_MenuAction; _term : CM_Terminal);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 August 2009	cnwndl1	Initial creation CCMS 1094

*/

vars

	reportForm : YRD_TrainReport; 
	
begin

	reportForm := app.loadForm(YRD_TrainReport, YRD_Assistant, false, false, true, _term, _menuAction).YRD_TrainReport;

	if reportForm = null then
		return;
	endif;

	reportForm.setParentForm(_parent);
	reportForm.setMyTerminal(_term);	
	reportForm.myDefaultTrain := _train;
	reportForm.myDefaultRail := _rail;
	
	reportForm.showModal;

epilog

end;</source>
        <Parameter name="_rail" type="CM_Rail"/>
        <Parameter name="_train" type="CM_Train"/>
        <Parameter name="_parent" type="CM_BaseForm"/>
        <Parameter name="_menuAction" type="CMUI_MenuAction"/>
        <Parameter name="_term" type="CM_Terminal"/>
    </JadeMethod>
</Class>
