    <JadeMethod name="getOrdinalsForSorting" id="2cd536bb-d45f-45b8-9246-8f81bd028530">
        <source>getOrdinalsForSorting(_direction : Integer; _ord1, _ord2 : Integer output);
/*
Purpose:			
Date		Who		Reason
21 April 2011	cnwab1	Initial creation
*/

vars
	tmpPoint : Point;
begin
	if _direction = AFPS_Value then
		// ### Aft to Forward, Port to Starboard, i.e. left to right, top to bottom
		tmpPoint := self.getExtremePoint(self.Position_Left);
		_ord1 := tmpPoint.x;
		tmpPoint := self.getExtremePoint(self.Position_Top);
		_ord2 := tmpPoint.y;
	elseif _direction = FAPS_Value then
		// ### Forward to Aft, Port to Starboard, i.e. right to left, top to bottom
		tmpPoint := self.getExtremePoint(self.Position_Right);
		_ord1 := tmpPoint.x;
		tmpPoint := self.getExtremePoint(self.Position_Top);
		_ord2 := tmpPoint.y;
	elseif _direction = AFSP_Value then
		// ### Aft to Forward, Starboard to Port, i.e. left to right, bottom to top
		tmpPoint := self.getExtremePoint(self.Position_Left);
		_ord1 := tmpPoint.x;
		tmpPoint := self.getExtremePoint(self.Position_Bottom);
		_ord2 := tmpPoint.y * -1;
	elseif _direction = FASP_Value then
		// ### Forward to Aft, Starboard to Port, i.e. right to left, bottom to top
		tmpPoint := self.getExtremePoint(self.Position_Right);
		_ord1 := tmpPoint.x;
		tmpPoint := self.getExtremePoint(self.Position_Bottom);
		_ord2 := tmpPoint.y;
	elseif _direction = SPAF_Value then
		// ### Starboard to Port, Aft to Forward i.e. bottom to top, right to left
		tmpPoint := self.getExtremePoint(self.Position_Right);
		_ord2 := tmpPoint.x;
		tmpPoint := self.getExtremePoint(self.Position_Bottom);
		_ord1 := tmpPoint.y * -1;
	elseif _direction = SPFA_Value then
		// ### Starboard to Port, Forward to Aft i.e. bottom to top, left to right
		tmpPoint := self.getExtremePoint(self.Position_Right);
		_ord2 := tmpPoint.x * -1;
		tmpPoint := self.getExtremePoint(self.Position_Bottom);
		_ord1 := tmpPoint.y * -1;
	elseif _direction = PSFA_Value then 
		// ### Port to Starboard, Forward to Aft i.e. top to bottom, right to left 
		tmpPoint := self.getExtremePoint(self.Position_Right);
		_ord1 := tmpPoint.y;
		tmpPoint := self.getExtremePoint(self.Position_Top);
		_ord2 := tmpPoint.x * -1;
	elseif _direction = PSAF_Value then 
		// ### Port to Starboard, Aft to Forward i.e. top to bottom, left to right
		tmpPoint := self.getExtremePoint(self.Position_Right);
		_ord1 := tmpPoint.y * -1;
		tmpPoint := self.getExtremePoint(self.Position_Top);
		_ord2 := tmpPoint.x * -1;
		
	else // default
		// ### Aft to Forward, Port to Starboard, i.e. left to right, top to bottom
		tmpPoint := self.getExtremePoint(self.Position_Left);
		_ord1 := tmpPoint.x;
		tmpPoint := self.getExtremePoint(self.Position_Top);
		_ord2 := tmpPoint.y;
	endif;

epilog

end;</source>
        <Parameter name="_direction" type="Integer"/>
        <Parameter name="_ord1" type="Integer" usage="output"/>
        <Parameter name="_ord2" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getPointsWithCrLfForJRW" id="f68414a7-a172-48de-81d7-cde98d84f945">
        <source>getPointsWithCrLfForJRW() : String;
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 28 November 2011
//
// Implemented version: JMT 7.9.2
// Date  		User  		Change
//----------------------------------------------------------------------
vars
	index,
	arraySize,
	fileIndex : Integer;
	decimalArray : DecimalArray;
	polygonString : String;
begin
	if self.myPolygonCMs = null then
		return null;
	endif;
	decimalArray := self.myPolygonCMs;
	
	arraySize := self.myPolygonCMs.size();
	index := 1;
	fileIndex := 1;
	while index &lt;= arraySize do
		polygonString := polygonString &amp; 'P' &amp; ',' &amp;self.myDeckItem.code &amp; ',' &amp; fileIndex.String;
		polygonString := polygonString &amp; ',' &amp; decimalArray[index].String;
		index := index + 1;
		polygonString := polygonString &amp; ',' &amp; decimalArray[index].String &amp; CrLf;
				
		index := index + 1;
		fileIndex := fileIndex + 1;
	endwhile;
	
	return polygonString;
epilog
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
