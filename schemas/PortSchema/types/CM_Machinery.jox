// ---------------------------------------------------------------------------
// Created:     17 August 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);
	self.isoType := _value[1:4];
end;</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
