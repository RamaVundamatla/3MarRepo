    <JadeMethod name="qryVoyageLoadListSummary" id="d992c534-5c39-4c0f-a1ea-e643a045de47">
        <updating/>
        <source>qryVoyageLoadListSummary(_filter : CMQF_VoyageLoadListSummary input; _passport : CM_Passport) : Integer updating;
//----------------------------------------------------------------
