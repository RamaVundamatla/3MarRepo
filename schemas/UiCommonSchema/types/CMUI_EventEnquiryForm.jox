	if (not self.filtIncludesUserEventType) and (not self.filtIncRollSplitBookingDiscrep) then
		self.setTblDataEntRows(ETDef_SysEventData);
	else
		self.setTblDataEntRows(ETDef_SysEventWarnings);
	endif;
	


end;

</source>
