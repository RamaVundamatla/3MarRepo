epilog

end;</source>
        <Parameter name="_proxyVehicleType" type="CM_VehicleType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="fe02dc73-c2eb-40ac-8011-f64bcfafdcf4">
        <updating/>
        <source>setProxy( _type : String ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 January 2013	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	self.raiseExceptionIfNotTransient(method);

	self.type 			:= _type;
	self.myDutyDocRoot 	:= app.myDutyDocRoot;
epilog

end;</source>
        <Parameter name="_type" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="7ed06bed-ce2a-4270-8ee7-04d160bb6b55">
        <source>validateForCreate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 January 2013	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	if app.myDutyDocRoot.allVehicleTypes[self.type] &lt;&gt; null then 
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.type, null, null);
		return;
	endif;
	
	validateMe();
epilog

end;</source>
    </JadeMethod>
