<Class name="JadeScriptMPD" id="db34de15-9dc5-47b2-9865-77e8e64526c5">
    <superclass name="JadeScript"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="dev"/>
    <JadeMethod name="mpdAnalyseStateData" id="c47dd22e-8f2e-4269-b3eb-8b97df86f5f6">
        <executionLocation>server</executionLocation>
        <source>mpdAnalyseStateData() serverExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 February 2022	navmd1	Initial creation

*/

vars
	classCol 		: ClassColl;
	cls				: Class;
	classObjSize,
	classBlobSize	: Integer;
	instances,
	estimatedSize	: Integer64;
	str				: String;
begin
	app.initialize();
	app.setIsBackGroundApp(true);
	
	create classCol transient;
	// cmstate.dat
	classCol.add(CM_ObjectArrayActual);		// What *is* this ?
	classCol.add(CM_Sound);					// Ummm... What?
	
	classCol.add(CM_StateBinary);
	classCol.add(CM_StateCollection);
	classCol.add(CM_StateData);
	classCol.add(CM_StateDataDict);
	classCol.add(CM_StateDateArray);
	classCol.add(CM_StateDecimal);
	classCol.add(CM_StateInteger);
	classCol.add(CM_StateIntegerArray);
	classCol.add(CM_StateObject);
	classCol.add(CM_StateObjectArray);
	classCol.add(CM_StateReal);
	classCol.add(CM_StateReference);
	classCol.add(CM_StateSound);
	classCol.add(CM_StateString);
	classCol.add(CM_StateStringArray);
	
	classCol.add(StringArrayStateData);
	
	foreach cls in classCol do
		cls.cnEcGetObjectSize(classObjSize, classBlobSize);
		instances := cls.instances.size;
		str := cls.name &amp; Tab &amp; "Instances: " &amp; instances.String &amp; Tab &amp; "Obj Size: " &amp; classObjSize.String &amp; Tab &amp; "Blob Size: " &amp; classBlobSize.String;
		//write str;
		app.writeLog(str, LogINFO);
		estimatedSize += instances * classObjSize;	// +/- blobs/slobs
	endforeach;
	
	str := "Total Estiamted Size: (" &amp; estimatedSize.String &amp; " bytes) " &amp; (estimatedSize / 1024 / 1024).roundedTo(2).String &amp; " Mb";
	
	//write "";
	//write str;
	
	app.writeLog("", LogINFO);
	app.writeLog(str, LogINFO);
epilog
	delete classCol;
end;</source>
    </JadeMethod>
    <JadeMethod name="mpdBitShiftTest" id="f5f0cae1-6715-466f-8799-443479b0c507">
        <source>mpdBitShiftTest();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 February 2020		jlgmd1	Initial creation

*/

vars
	c1, c2 : Byte;
begin
	c1 := 5.Byte;
	c2 := 71.Byte;
	
	write c1.Integer.leftBitShift(8);
	write c2.Integer.leftBitShift(0);
	
	// A dummy change to trigger git commit
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="mpdCheckAllEventTransactions" id="7355a96e-57e9-42be-90ba-0cc8e6fc5866">
        <source>mpdCheckAllEventTransactions();
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
06 December 2024		navmd1	Initial creation

*/

vars
	cls			: Class;
	txn 		: CM_Transaction;
	allCls 		: ClassColl;
	count,
	total		: Integer;
begin
	cls := rootSchema.getSchema(PortSchemaName).getClass("CM_Transaction");
	
	create allCls transient;
	cls.withAllSubclasses(allCls);
	
	foreach cls in allCls do
		count := cls.instances.size;
		total += count;
		write cls.name &amp; " " &amp; count.String;
	endforeach;
	
	write "Total: " &amp; total.String;
	
epilog
	delete allCls;
end;</source>
    </JadeMethod>
    <JadeMethod name="mpdCheckConfigValues" id="dc907d9e-fafe-44ab-a1f3-b67e7d6b9439">
        <source>mpdCheckConfigValues();
/*

Purpose:			Write out config values for all Terminals to see which ones need fixing

Parameters:			

Return Value:		

Date			Who		Reason
25 January 2023	navmd1	Initial creation

*/

vars
	root : CM_Root;
	term : CM_Terminal;
begin
	app.initialize();
	root := app.myRoot;
	
	foreach term in root.allTerminals do
		write term.code &amp; Tab &amp; term.name &amp; Tab &amp; "CAMS File Directory: " &amp; term.getConfig(CamsFileDirectory).String;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="mpdCheckGlobalConstantModBy" id="3224130d-74d9-41d0-a5d0-27b87aed4db3">
        <source>mpdCheckGlobalConstantModBy();
/*

Purpose:			Display who by and when a global constant was last updated

Parameters:			

Return Value:		

Date			Who		Reason
07 June 2023	navmd1	Initial creation

*/

vars
	cg : GlobalConstant;
begin
	// NB. CGs are looked up by Name, not Definition!
	cg := rootSchema.getSchema('PortSchema').getConstant('ETDef_VisitRecordForEnquir');
	if cg = null then
		write "No global constant with that NAME found";
		return;
	endif;
	
	write "Global Constant: " &amp; cg.name;
	write "Last Updated: " &amp; cg.getModifiedTimestamp().String;
	write "By: " &amp; cg.getModifiedByJMT();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="mpdCheckJadeHTTPIni" id="c4a9926c-b8db-4706-9db1-6f1db81052a3">
        <executionLocation>server</executionLocation>
        <source>mpdCheckJadeHTTPIni() serverExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 April 2021	navmd1	Initial creation

*/

vars
	miscPath,
	timeout		: String;
	ff			: FileFolder;
begin

	app.initialize();
	
	miscPath := app.cnGetServerMiscPath();
	
	create ff transient;
	ff.usePresentationFileSystem := false;
	ff.fileName := miscPath;
	if not ff.isAvailable then
		app.msgBox("Unable to locate c_misc path", "Error", MsgBox_OK_Only);
		return;
	endif;
	
	ff.fileName := miscPath &amp; "\bin_public_jadehttp\ini\jadehttp.ini";
	if not ff.isAvailable then
		app.msgBox("Unable to locate jadehttp.ini file", "Error", MsgBox_OK_Only);
		return;
	endif;
	
	timeout := app.getProfileString(ff.fileName, "JMTWebService", "MessageTimeout", "&lt;Not Found&gt;");
	app.msgBox("MessageTimeout: " &amp; timeout, "JadeHTTP Config", MsgBox_OK_Only);

epilog
	delete ff;
end;</source>
    </JadeMethod>
    <JadeMethod name="mpdCheckPreviousLicenses" id="724ac637-a739-4da1-a924-8a48b9bdb863">
        <source>mpdCheckPreviousLicenses();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
27 January 2025		navmd1	Initial creation

*/

vars
	scm		: Schema;
	cls		: Class;
begin
		
	scm := rootSchema.getSchema("JSSLicenseKeySchema");
	if scm = null then
		app.msgBox("Invalid Schema - JSSLicenseKeySchema not found!", "Error", MsgBox_OK_Only);
		return;
	endif;
	
	cls := scm.getClass("JSSLKCustomerLicense");
	if cls = null then
		app.msgBox("Invalid Class - JSSLKCustomerLicense not found", "Error", MsgBox_OK_Only);
		return;
	endif;
	
	cls.inspect;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="mpdCleanupBadData" id="2d249ea8-e1c0-4f85-8198-af055e480d83">
        <source>mpdCleanupBadData();
/*

Purpose:			Clean up some of the crap data left over in DMAST

Parameters:			

Return Value:		

Date			Who		Reason
20 August 2018	jlgmd1	Initial creation TFS 40386

*/
constants
	UpdateMode = false;
vars
	objArr		: ObjectArray;
	obj 		: Object;
	t 			: CM_TITransaction;
	invalid 	: Boolean;
	term 		: CM_Terminal;
	start, 
	start1,
	trxTime		: TimeStamp;
	finish 		: TimeStampInterval;
	i,
	total		: Integer;
	trxColl		: CM_TITransactionSet;
	ti			: CM_TrackedItem;
	wa			: CM_WorkArea;
	cms			: CM_Strings;
begin
	/*on Exception do self.mpdHandleAllExceptions(exception, invalid, false);
	
	create trxColl transient;
	
	write start.String;
	write "Getting all transactions...";
	create objArr transient;
	CM_TITransaction.allInstances(objArr, 0, true);
	finish := app.actualTime - start;
	write "    ... Done! [" &amp; (finish.getMilliseconds/1000).String &amp; " seconds]";
	
	write "Checking refs...";
	foreach obj in objArr do
		i := i + 1;
		invalid := false;
		t := obj.CM_TITransaction;
		
		term := t.myTerminal;
		if term &lt;&gt; null then
			term.edition;
		endif;
		
		if term = null or invalid then
			//write "Invalid Terminal:" &amp; Tab &amp; t.getOidString;
			trxColl.add(t);
			continue;
		endif;
		
		ti := t.myTrackedItem;
		if ti &lt;&gt; null then
			ti.edition;
		endif;
		
		if ti = null or invalid then
			//write "Invalid TI:" &amp; Tab &amp; t.getOidString;
			trxColl.add(t);
			continue;
		endif;
		
	endforeach;
	
	finish := app.actualTimeServer - start1;
	write "    ... Done [" &amp; (finish.getMilliseconds/1000).String &amp; " seconds]";
	write "Found " &amp; i.String &amp; " references to fix.";
	write "";
	
	write "Setting myTerminal ref for any Transactions that still have a TI,";
	write "And removing any Transactions that no longer have a TI...";
	start1 := app.actualTime;
	
	if UpdateMode then
		// Only do stuff if we are in UpdateMode, otherwise, just log
		beginTransaction;
		trxTime := app.actualTimeServer;
	endif;
	
	i := 0;
	total := trxColl.size;
	foreach t in trxColl do
	
		// Don't hold trxn state for ever!
		if UpdateMode then
			if app.actualTimeServer &gt; trxTime.addSeconds(30) then
				commitTransaction;
				write "Commited " &amp; i.String &amp; " Updates of " &amp; total.String;
				beginTransaction;
				trxTime := app.actualTimeServer;
			endif;
		endif;
	
		i := i + 1;
		invalid := false;
		ti := t.myTrackedItem;
		
		if ti = null then
			if not UpdateMode then
				write "Deleting Txn 1";
			else
				delete t;
			endif;
			continue;
		else
			ti.edition;
			if invalid then
				if not UpdateMode then
					write "Deleting Txn 2";
				else
					delete t;
				endif;
				continue;
			endif;
		endif;
		
		term := t.myTerminal;
		if term &lt;&gt; null then
			term.edition;
		endif;
		
		if term = null or invalid then
			invalid := false;
			term := ti.myTerminal;
			if term &lt;&gt; null then
				term.edition;
			endif;
			
			if term &lt;&gt; null and not invalid then
				if not UpdateMode then
					write "Setting terminal 1";
				else
					t.setMyTerminal(term);
				endif;
				continue;
			else
				// Next Terminal to check
				invalid := false;
				term := ti.getPropertyValue('myOffsiteTerminal').CM_Terminal;
				if term &lt;&gt; null then
					term.edition;
				endif;
				
				if term &lt;&gt; null and not invalid then
					if not UpdateMode then
						write "Setting terminal 2";
					else
						t.setMyTerminal(term);
					endif;
					continue;
				else
				
					write "no term 2";
					write t.getOidString;
					break;
					
				endif;
				
			endif;
		endif;
		
	endforeach;
	
	if UpdateMode then
		commitTransaction;
	endif;
	
	finish := app.actualTime - start1;
	write "    ... Done [" &amp; (finish.getMilliseconds/1000).String &amp; " seconds]";
	
	write "Clearing Invalid Refs from SubTerminalAreas...";
	start1 := app.actualTime;
	wa := "11572.2".asOid.CM_WorkArea;
	if UpdateMode then
		beginTransaction;
		wa.allTerminalAreas.rebuild();
		commitTransaction;
	endif;
	
	finish := app.actualTime - start1;
	write "    ... Done [" &amp; (finish.getMilliseconds/1000).String &amp; " seconds]";
	
	finish := app.actualTime - start;
	write "All Done! [" &amp; (finish.getMilliseconds/1000).String &amp; " seconds]";
	*/
	

	create objArr transient;
	
	foreach cms in CM_Strings.instances do
		if cms.myObject = null then
			objArr.add(cms);
		endif;
	endforeach;

	if objArr.size &gt; 0 then
		beginTransaction;
		objArr.purge();
		commitTransaction;
	endif;

epilog
	delete objArr;
	delete trxColl;
	write app.actualTime.String;
	
	if process.isInTransactionState then
		abortTransaction;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="mpdDevSrcExtract" id="23085564-e342-4f56-95cf-406ba9aabb0f">
        <source>mpdDevSrcExtract();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 July 2025	navmd1	Initial creation

*/

vars
	agent		: DEV_ReleaseExtractAgent;
	serverPath,
	clientPath	: FileFolder;
begin
	app.initialize();
	// A dummy change

	create serverPath transient;
	serverPath.usePresentationFileSystem := false;	// server
	if app.isDevelopmentSystemMain() then
		serverPath.fileName := "D:\navDmast\server\c_misc\mpd\tempSrcExtract";
	else
		serverPath.fileName := "D:\navWmast\server\c_misc\mpd\tempSrcExtract";
	endif;
	
	if not serverPath.isAvailable then
		serverPath.make();
	endif;
	
	create clientPath transient;
	clientPath.usePresentationFileSystem := true;	// client
	if app.isDevelopmentSystemMain() then
		clientPath.fileName := "E:\DmastSrcExtract";
	else
		clientPath.fileName := "C:\temp\WmastSrcExtract";
	endif;
	
	if not clientPath.isAvailable then
		clientPath.make();
	endif;
	
	create agent transient;
	agent.doDailyExtractsForSVN(serverPath.fileName, clientPath.fileName);
epilog
	delete agent;
	delete serverPath;
	delete clientPath;
end;</source>
    </JadeMethod>
    <JadeMethod name="mpdExtractReports" id="b21042f1-2442-4ddb-82be-940cd1fc4956">
        <source>mpdExtractReports();

/*

Purpose:			Manually re-extract reports, post cut

Parameters:			

Return Value:		


Date					Who		Reason
26 February 2018		jlgmd1	Initial creation

*/

constants
	FilePath = "D:\cnwDmast\server\c_misc\mpd\";		//Server directory - should already exist (include the trailing slash)
	RWAName = "156allJRW";								//No file extension required
vars
	agent : DEV_ReleaseExtractAgent;
begin
	app.initialize();
	
	create agent transient;
	agent.setDefaultsForFullRelease();
	
	agent.extractReports(FilePath, RWAName);
	
epilog
	delete agent;
	app.finalize();
end;</source>
    </JadeMethod>
    <JadeMethod name="mpdExtractSecurityPermissions" id="2b98862c-cf7d-48fc-9a81-a35cdbf83b58">
        <source>mpdExtractSecurityPermissions();
/*

