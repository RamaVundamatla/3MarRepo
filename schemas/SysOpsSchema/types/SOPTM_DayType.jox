    <JadeMethod name="showThumbnail" id="1e784f41-313f-44ff-ac63-524e7eb83644">
        <updating/>
        <source>showThumbnail(pObj: CM_DayType) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 October 2010	cnwndl1	Initial creation	Par 25530

*/

vars
	theForm : SOP_TableMaintForm;
	realDayType : CM_DayType;
	size : Integer;
	table : CM_EntryTable;
	effectiveRows : Integer;
	parentHeight : Real;
	maxHeight : Real;
	rowHeight : Real;
	idealHeight : Real;
begin
  
    theForm := self.myForm;
	theForm.tblInput1.clearValues;

	theForm.tblInput1.setValueByName(ETRow_Code, pObj.code);
	theForm.tblInput1.setValueByName(ETRow_Description,	pObj.description);
	theForm.tblInput1.hideRowByName(ETRow_Calendars, false);
	
	// use the persitant to list the calendars it is used by. ( they are not maintainable from this end anyway)
	if pObj.isTransient then
		realDayType := pObj.pxyGetRealObject;
	endif;
	if realDayType = null then
		realDayType := pObj;
	endif;	
	theForm.tblInput1.showRowByName(ETRow_CalendarList, false);
	theForm.tblInput1.setValueByName(ETRow_CalendarList, realDayType.getAllCalendarsList);
	
	
	
	//adjust the size of the table to make as many as possible rows visible.
	if realDayType &lt;&gt; null then
		size := realDayType.allCalendars.size;	// number of 'lines' in the 'Selected Calendars' row.
		if size &gt; 0 then
			effectiveRows := 3 + size;	// 3 base rows in the ent table def. 
			table := theForm.tblInput1;
			parentHeight := table.parent.Control.clientHeight;
			maxHeight := parentHeight - table.top - table.distanceFromBottom;
			rowHeight := table.accessRow(1).height;
			idealHeight := rowHeight * effectiveRows;
			if table.height &gt;= idealHeight then
				return;
			elseif idealHeight &gt;= maxHeight then
				idealHeight := maxHeight;
			endif;
			table.height := idealHeight;
		endif;
	endif;

end;</source>
        <Parameter name="pObj" type="CM_DayType"/>
    </JadeMethod>
</Class>
