    <JadeMethod name="btnDefault_click" id="c9744df3-0193-4b41-904b-743d2e9d2aaa">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDefault_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

begin
	if self.myVoyage &lt;&gt; null then
		txtExchDate.setDate(self.myVoyage.shipExchangeDate.date);
		txtExchTime.setTime(self.myVoyage.shipExchangeDate.time);
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
