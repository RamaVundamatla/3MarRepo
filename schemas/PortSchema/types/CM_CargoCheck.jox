    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="859af2d5-71e6-4dcb-823a-db2be0787923">
        <source>validateForUpdate();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2010	cnwdap1	Initial creation
16/12/2014  cnwdb2	PAR 35364
*/
vars

begin
	if self.context = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Context', null, null);
		app.raiseCMException(Input_required_field_context, null, null); // cnwdb2	PAR 35364
		return;
	endif;

epilog

end;</source>
    </JadeMethod>
