    <JadeMethod name="populateCopyPath" id="0d666e81-9ca7-483e-a9ad-f5b6fce40e67">
        <updating/>
        <source>populateCopyPath(_currentItem : CM_FinancialObject; _currentLevelItem : CM_FinancialObject) protected, updating;
// populate the path to copy to
vars
	path	: String;
	currentPath	: String;
	obj		: Object;
	index	: Integer;
	pathList : CMUI_ListBox;
	paths	: HugeStringArray;
	items	: ObjectArray;
begin
	pathList := self.lstCopyPath;
	pathList.clear();
	pathList.sorted := true;
	// show the current path - prefix with space to get it first when sorted
	currentPath := " " &amp; _currentItem.getPath();
	pathList.itemObject[pathList.addItem(currentPath)] := _currentItem;
	create paths transient;
	create items transient;
		
	// get and show all other paths to the same level
	self.myCurrentMapTM.getAllPaths(_currentLevelItem, paths, items);
	foreach path in paths do
		index := index + 1;
		obj := items[index];
		if obj = _currentItem then
			continue;
		endif;
		pathList.itemObject[pathList.addItem(path)] := obj;
	endforeach;
	// highlight the current path
	pathList.listIndex := 1;

epilog
	delete paths;
	delete items;
end;</source>
        <access>protected</access>
        <Parameter name="_currentItem" type="CM_FinancialObject"/>
        <Parameter name="_currentLevelItem" type="CM_FinancialObject"/>
    </JadeMethod>
