    <JadeMethod name="doMnuNewInvDiffCargo" id="f5114f50-374f-403b-ba01-9d254f5da0bd">
        <source>doMnuNewInvDiffCargo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2023  navmv20 TFS 55304 Task 55545: UI - Invoice Line List Changes

*/

vars
	form : INV_LineCopyDiffCargoNewInv;
	rowSt,
	rowEnd,
	index : Integer;
	objSet : CM_InvoiceLineSet;
	invLine : CM_InvoiceLine;
begin
	
	rowSt := tblData.fixedRows + 1;
	rowEnd := tblData.rows;
	create objSet transient;
	foreach index in rowSt to rowEnd do
		if tblData.accessRow(index).selected then
			invLine := tblData.accessRow(index).itemObject.CM_InvoiceLine;
			objSet.add(invLine);
		endif;
	endforeach;
	
	if objSet.isEmpty() then
		app.msgBox(app.getErrorString(Record_selected), app.getErrorString(Warning),MsgBox_OK_Only);
		return;
	endif;
	
	form := app.loadForm(INV_LineCopyDiffCargoNewInv, 
					INV_Assistant, 
					false, 
					false,
					false, 
					self.myTerminal,
					null).INV_LineCopyDiffCargoNewInv;	
	
	if form = null then
		return;
	endif;
	form.createMyAssistant(INV_Assistant);
	form.setCurrentInvoice(self.myCurrentInvoice);
	form.setMyCurrentBank(self.myCurrentBank);
	objSet.copy(form.allSelectedInvoiceLines);
	form.showModal();
epilog
	delete objSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuNewInvSameCargo" id="5ee7a3ae-ba9f-4932-b1e1-779477f471c2">
