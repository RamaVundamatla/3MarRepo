					&lt;id&gt;BOL122&lt;/id&gt;
					&lt;messageMode&gt;A&lt;/messageMode&gt;
					&lt;remarks&gt;Details remarks 01&lt;/remarks&gt;
				&lt;/BOLDetails&gt;
				&lt;BOLDetails&gt;
