    <JadeMethod name="getBRefItemFromMenuAction" id="f056c75f-c660-49fd-a2f0-8a1108f5f21c">
        <source>getBRefItemFromMenuAction() : CM_BookingRefItem;
// ---------------------------------------------------------------------------
// Created:     10 March 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	menuAction		: CMUI_MenuAction;
begin
	menuAction := self.myMenuAction;
	if menuAction = null then
		return null;
	endif;

	if CM_BookingRefItem.hasInstance(menuAction.myObject) then
		return menuAction.myObject.CM_BookingRefItem;
	endif;
	return null;
end;</source>
        <ReturnType type="CM_BookingRefItem"/>
    </JadeMethod>
    <JadeMethod name="getBookingRefFromMenuAction" id="9a962fb1-e9e5-4b94-9df0-28a9d28c8033">
        <source>getBookingRefFromMenuAction() : CM_BookingRef;
/*
----------   ----------  --------------------------------------------------
Created:	13 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	menuAction		: CMUI_MenuAction;
begin
	menuAction := self.myMenuAction;
	if menuAction = null then
		return null;
	endif;

	if CM_BookingRefItem.hasInstance(menuAction.myObject) then
		return menuAction.myObject.CM_BookingRefItem.myBookingReference;
	endif;
	
	if (not CM_BookingRef.hasInstance(menuAction.myObject)) then
		return null;
	endif;

	return menuAction.myObject.CM_BookingRef;
end;</source>
        <ReturnType type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="getCargoBOLType" id="6b5098fe-5ecb-4fcd-a894-342e7db58eae">
        <source>getCargoBOLType() : CM_CargoBOLType;
// ---------------------------------------------------------------------------
// Created:     08 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cmb				: ComboBox;
	cargoBOLType	: CM_CargoBOLType;

begin

	cmb := self.getControlByName(GTE_InOutForm.Cntrl_cmbTiType).ComboBox;
	if cmb = null then
		return null;
	endif;

	if cmb.listObject = null then
		return null;
	endif;
	
	if cmb.listObject.isKindOf(CM_CargoBOLType) then
		cargoBOLType := cmb.listObject.CM_CargoBOLType;
	
	endif;
	
	return cargoBOLType;
	
end;</source>
        <ReturnType type="CM_CargoBOLType"/>
    </JadeMethod>
    <JadeMethod name="getCargoBOLTypeId" id="20504232-4269-4f2c-aa24-5582ae5c5c58">
        <source>getCargoBOLTypeId() : Integer;
// ---------------------------------------------------------------------------
// Created:     21 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cmb			: ComboBox;
	tmpObj		: Object;

begin

	cmb := self.getControlByName(GTE_InOutForm.Cntrl_cmbTiType).ComboBox;
	if cmb = null then
		return TI_CargoType_Null;
	endif;

	if cmb.listObject = null then
		return TI_CargoType_Null;
	endif;

	tmpObj := cmb.listObject;
	
	if tmpObj.isKindOf(CM_CargoType) then
		return tmpObj.CM_CargoType.id;
	elseif tmpObj.isKindOf(CM_BOLType) then
		return tmpObj.CM_BOLType.id;
	endif;

	return TI_CargoType_Null;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
