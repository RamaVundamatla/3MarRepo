    <JadeMethod name="getLastRunTime" id="220abcb3-4ec6-481b-8e40-75d41c758435">
        <source>getLastRunTime() : TimeStamp protected;
/*

Purpose:			Returns the last time a (runnable) UnitTest was run

Parameters:			

Return Value:		

Date			Who		Reason
20 June 2019	jlgmd1	Initial creation

*/

vars
	root 		: UM_Root;
	className,
	methodName	: String;
	stack		: ProcessStackArray;
	methCall	: MethodCallDesc;
	utcm		: UM_UnitTestClassMethod;
	result		: UM_UnitTestResult;
begin
	root := UM_Root.firstInstance;
	
	// Get our calling method
	// Its expected this is called from a unit test
	create stack transient;
	process.currentStack(stack);
	methCall := stack[3];	// our calling method is 3 levels down
	
	if methCall &lt;&gt; null then
		className := methCall.method.schemaType.name;
		methodName := methCall.method.name;
	endif;
	
	utcm := root.allRunnableUTClassesMethods[className, methodName];
	if utcm = null then
		return null;
	endif;
	
	result := utcm.allUnitTestResults.first;
	if result = null then
		return null;
	endif;
	
	return result.methodRunStartTS;
epilog
	stack.purge();
	delete stack;
end;</source>
        <access>protected</access>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
