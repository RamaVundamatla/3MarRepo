// ---------------------------------------------------------------------------
// Created:     17 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 03/05/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// ---------------------------------------------------------------------------
// 29 Sept 2022 navvt20 	ChangeRequest 54937: MTN - Selector Property Auto Select
vars
	qProp			: CM_QueryProperty;
begin
	qProp := combobox.listObject.CM_QueryProperty;
	if qProp = null then
		return;
	endif;
	self.loadOperationCombo(qProp);
	self.doCmbOperatorClick(qProp.getDefaultOperator);
	self.queryLineChanged := true;
	self.clearArgument();
	self.loadMeasureCombo(qProp);									// PAR #31155
	self.criteriaCheck();				// 29 Sept 2022 navvt20 TFS 54937

end;</source>
