    <JadeMethod name="translateForm" id="22a8c259-30dd-484b-ae3d-04a01aa07891">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 30 January 2018 11:19:07.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019092, locale);
	chkDamage.translateCaption(Xlat_0019609, locale);
	chkHazards.translateCaption(Xlat_0019610, locale);
	chkStops.translateCaption(Xlat_0019611, locale);
	chkToDo.translateCaption(Xlat_0019612, locale);
	lblCargoWeight.translateCaption(Xlat_0022194, locale);
	lblDamageQty.translateCaption(Xlat_0019613, locale);
	lblExistingCargo.translateCaption(Xlat_0019093, locale);
	lblId.translateCaption(Xlat_0019094, locale);
	lblIdSuffix.translateCaption(Xlat_0019095, locale);
	lblOperator.translateCaption(Xlat_0019096, locale);
	lblQuantity.translateCaption(Xlat_0019097, locale);
	lblTareWeight.translateCaption(Xlat_0022195, locale);
	optBreakBulk.translateCaption(Xlat_0019098, locale);
	optPieceBBB.translateCaption(Xlat_0019099, locale);
end;</source>
    </JadeMethod>
