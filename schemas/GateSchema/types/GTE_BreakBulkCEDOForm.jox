	self.lblFromDate.visible := false;
	self.lblToDate.visible := false;
	self.txtStartDate.visible := false;
	self.txtEndDate.visible := false;

	self.shtQuery2.visible := false;

	self.frmQueryToolbar.positionToolbarControls();

end;</source>
