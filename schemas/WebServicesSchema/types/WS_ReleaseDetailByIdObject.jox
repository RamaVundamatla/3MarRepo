<Class name="WS_ReleaseDetailByIdObject" id="6fe255f0-ac3a-4d13-808c-1998e81085d2">
    <superclass name="WS_ReleaseDetailBaseObject"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="restwebservice"/>
    <PrimAttribute name="bookingId" id="e1f95913-9b9f-43c0-ac94-c404cac58b68">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="cargoId" id="19cfdffa-4fd3-4d6e-9f1c-79a5efc7da27">
        <length>21</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="state" id="096dd490-5e5f-46e5-925b-f0aa15f74d77">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="6c432d90-5c2b-4817-ac80-8d7722576481">
        <updating/>
        <source>setProxyFromObject(_reserveDetail: CM_ReserveDetail) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/06/2024	navdap1		Initial creation TFS 63107 CUX | GET /releaseRequest API to return release request line items
// 29/07/2024   navsp1      ChangeRequest 65419: CUX | GET /releaseRequest - Add bookingId and state to Release Detail
vars
	reserveTI : CM_ReserveTI;

begin
	inheritMethod(_reserveDetail);
	
	reserveTI := _reserveDetail.CM_ReserveTI;
	self.cargoId := reserveTI.getCargoID();
	self.state		:= reserveTI.getTIState();				//TFS 65419
	self.bookingId 	:= reserveTI.getTIBookingReference();	//TFS 65419
epilog

end;</source>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
    </JadeMethod>
</Class>
