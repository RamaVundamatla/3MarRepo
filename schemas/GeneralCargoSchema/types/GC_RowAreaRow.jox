<Class name="GC_RowAreaRow" id="20d351cd-af48-4eb5-922e-cd3e908d63ee">
    <superclass name="CMUI_GridRow"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>
This is NOT the equivalent of the CM_RowAreaRow because the
RowAreas are drawn with the rows as columns the YRD_RowAreaColumn
is actually the local equivalent of the CM_RowAreaRow.</text>
    <DbClassMap file="Yard"/>
    <JadeMethod name="drawSelf" id="d9d33541-4b73-4282-917f-1feda349af76">
