    <JadeMethod name="tAddYATemplate_HazardLimited" id="e4567225-cf18-4c6b-bacf-8eee0cd5ed18">
        <source>tAddYATemplate_HazardLimited();
// cnwndl1
//17 July 2008	cnwdw1	
//
vars
	yATemplate: CM_YATemplate;
	hazard: String;
begin
	hazard := "1.2L, 1.0";
	yATemplate := self.addYATemplate("YATemplate",  YACriteriaType_Hazardous, hazard);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "YATemplate failed");
	self.assertTrueMsg(yATemplate &lt;&gt; null, "yATemplate is null");
	self.assertTrueMsg(yATemplate.myYardAllocation &lt;&gt; null, "yATemplate.myTemplate is null");
	self.assertTrueMsg(yATemplate.myYardAllocation.allCriteria.first.myYAData.isA(CM_YADataString), "Incorrect criteria myYAData");
	self.assertEqualMsg(yATemplate.myYardAllocation.allCriteria.first.getDescription(), "Hazardous "&amp;hazard, "Incorrect criteria description");
	self.assertTrueMsg(yATemplate.myYardAllocation.myTerminal = null, "yATemplate.myTemplate.myTerminal is not null");
	self.assertTrueMsg(app.getMyTerminalDO_NOT_USE.getYATemplate("YATemplate") &lt;&gt; null, "YATemplate is not in Terminal collection");
epilog
end;</source>
