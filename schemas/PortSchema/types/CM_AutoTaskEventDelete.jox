    </PrimAttribute>
    <JadeMethod name="getEntryTableViewName" id="bf3abfa1-9848-4c47-913c-be678deaa77b">
        <source>getEntryTableViewName(): String;
/*
----------   ----------  --------------------------------------------------
Created:	26 July 2007 By cnwth2

