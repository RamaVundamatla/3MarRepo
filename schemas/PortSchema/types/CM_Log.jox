    <JadeMethod name="getDataForDef" id="38d47bf5-61fa-4d64-8d52-ce6232220624">
        <source>getDataForDef(_entTableDef: EntTableDef; _headings: StringArray input; _data: HugeStringArray input; _terminal : CM_Terminal);
//--------------------------------------------------------------
//Created: 05 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	entTableRow			: EntTableRow;
	tmpStr 				: String;
	ctTerminal			: CM_TerminologyHdr;
begin
	//ctTerminal := self.myCargoType.allTerminologyCTTerminalHdrs[_terminal];
	
	foreach entTableRow in _entTableDef.allEntTableRows do
		if entTableRow.isGroupRow() then
			continue;
		endif;
		if _entTableDef.name = ETDef_LogData then		
			self.getDataForAttribute(entTableRow.name, entTableRow.getHeading(self.myCargoType, self.myTerminal, app.myCurrentLocale), _headings, _data);
		else
			tmpStr := getDisplayStringForAttribute(entTableRow.name, false);
			_headings.add(entTableRow.getHeading(self.myCargoType, self.myTerminal, null));
			_data.add(tmpStr);
		endif;		
	endforeach;
end;</source>
        <Parameter name="_entTableDef" type="EntTableDef"/>
        <Parameter name="_headings" type="StringArray" usage="input"/>
        <Parameter name="_data" type="HugeStringArray" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getDataForDefSpecial" id="68aedfa0-c645-4a22-8169-f3d97ebcd929">
        <source>getDataForDefSpecial(_attrName: String; _heading: String; _headings: StringArray input; _data: HugeStringArray input): Boolean protected;
//--------------------------------------------------------------
//Created: 04 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpMin,
	tmpMax,
	tmpMean,
	locationStr	: String;
	scaled  : Boolean;

begin

	if _attrName = ETRow_LogData then
		if self.sedMin &lt;&gt; NULL_UNSCALED_LOG_SED then
			tmpMin := self.sedMin.sedString;
		endif;
		if self.sedMax &lt;&gt; NULL_UNSCALED_LOG_SED then
			tmpMax := self.sedMax.sedString;
		endif;
		if self.sedMean &lt;&gt; NULL_UNSCALED_LOG_SED then
			tmpMean := self.sedMean.sedString;
		endif;

		scaled := not self.isAverageScaled;
	
		if self.locationId &lt;&gt; null then 
			locationStr := self.locationId;
		elseif self.state = TI_STATE_DELETED then // Par 9821
			locationStr :=  '&lt;Deleted&gt;';			// Par 9821	
		else
			locationStr := self.getPrimaryLocationId(REAL_MODE);
		endif;

		_data.add(self.id &amp; Tab &amp; tmpMin &amp; Tab &amp; tmpMax &amp; Tab &amp; 
				 tmpMean &amp; Tab &amp; self.getMyTotalVolume.jasVolumeString &amp; Tab &amp; self.scalerCode &amp; Tab &amp;
				 locationStr  &amp; Tab &amp; scaled.getYesNo());//CNWTH2 changed for PAR8604 - used to be self.getPrimaryLocationId(REAL_MODE)
				 				 								 //don't want to see stack height for logs 
				 				 								 //HJG added isUnscaled to end, Par 9917
				 				 								 //HJG no location returned if ti has been rejected Par 9821
		return true;
	else
		return inheritMethod(_attrName, _heading, _headings, _data);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_headings" type="StringArray" usage="input"/>
        <Parameter name="_data" type="HugeStringArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDetailForRemoteQuery" id="e1447080-35d4-4b09-9b0b-ecb128bf179b">
        <source>getDetailForRemoteQuery(_type : String; _version : Integer): String;

vars
	xml,
	operator,
	locationStr,
	area,
	bol			: String;
	theLocation	: CM_LocationsController;
	origBol		: CM_BOLIn;
	
begin

	if _type = CM_RemoteDataObject.Type_Full then
		if self.myOperator &lt;&gt; null then
			operator := self.myOperator.code.trimBlanks();
		endif;	
		theLocation	:= self.getPrimaryLocation(REAL_MODE);
		
		if theLocation &lt;&gt; null and self.site = TI_SITE_ONSITE then
			locationStr := theLocation.getID.trimBlanks();
			area		:= theLocation.myTerminalArea.getID.trimBlanks();
		else
			locationStr := 'Offsite';
		endif;
		
		origBol := self.myReceivalBOL;
		if origBol &lt;&gt; null then
			bol := origBol.number;
		endif;
	
		if _version &gt;= 2 then
			xml := 
				self.id &amp; ',' &amp;
				operator &amp; ',' &amp;
				self.speciesCode &amp; ',' &amp;
				self.gradeCode &amp; ',' &amp;
				self.typeCode &amp; ',' &amp; 
				self.treatmentCode &amp; ',' &amp;
				self.logLength.String &amp; ',' &amp;
				self.getMyTotalVolume.jasVolumeString &amp; ',' &amp;
				self.weightTonnes.roundedTo(3).String &amp; ',' &amp; 
				self.sedMin.Integer.String &amp; ',' &amp; 
				self.sedMax.Integer.String &amp; ',' &amp; 
				bol &amp; ',' &amp; 
				area &amp; ',' &amp; 
				locationStr;
	
		else
			xml := 
				self.id &amp; ',' &amp;
				operator &amp; ',' &amp;
				self.speciesCode &amp; ',' &amp;
				self.gradeCode &amp; ',' &amp;
				self.typeCode &amp; ',' &amp; 
				self.treatmentCode &amp; ',' &amp;
				self.logLength.String &amp; ',' &amp;
				self.getMyTotalVolume.jasVolumeString &amp; ',' &amp;
				self.weightTonnes.roundedTo(3).String &amp; ',' &amp;
				bol &amp; ',' &amp;
				locationStr;
		endif;
	endif;
	return xml;
end;</source>
        <Parameter name="_type" type="String"/>
        <Parameter name="_version" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDetailForWLE" id="5ce9125e-ce88-4360-9213-baddf0f10cf0">
        <source>getDetailForWLE(): String;

vars

	response	: String;

begin
	response := 
		self.speciesCode 	&amp; ',' &amp;
		self.gradeCode		&amp; ',' &amp;
		self.typeCode		&amp; ',' &amp;
		self.treatmentCode	&amp; ',' &amp;
		self.logLength.String &amp; ',' &amp;
		self.getMyTotalVolume.jasVolumeString;

	return response;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="73285b0f-edc7-4e14-a49d-fcb7907b6b1b">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------------------
//Created: 12 June 2002 By: cnwgd1
//--------------------------------------------------------------
// 05 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	tmpLC			: CM_LocationsController;
begin

	if _attrName = ETRow_FellDate then
		if self.fellDate.isValid then
			return self.fellDate.shortFormatJMT();
		else
			return null;
		endif;
	elseif _attrName = ETRow_Date then
		//return self.fellDate.formatAsYYYYMMDD;		
		return self.fellDate.shortFormatJMT();		
	elseif _attrName = ETRow_JasVolume then
		return self.getMyTotalVolume.jasVolumeString; //userNumberFormat($Decimal3LeadingZero);
	//elseif _attrName = ETRow_LocationId then
		/*
		tmpLC := self.getPrimaryLocation(REAL_MODE);
		if tmpLC &lt;&gt; null then
			return tmpLC.getFullIdForTI();
		else
			return self.locationId; //Use the locationId property as it includes the height of the ti.
		endif;
		*/
	elseif _attrName = ETRow_Opt  then
		return 'false';		
	elseif _attrName = ETRow_MatchDate then
		if self.myReceivalBOL &lt;&gt; null then
			return self.systemToLocalTime(self.myReceivalBOL.matchTime).date.shortFormatJMT();// 05 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		return null;
	elseif _attrName = ETRow_IsInspected then 	// 10/09/2009 cnwar2 CCMS-1107/#20627
		return self.getIsInspected.getYesNo();
	elseif _attrName = ETRow_IsFumigated then 	// 10/09/2009 cnwar2 CCMS-1107/#20627
		return self.getIsFumigated.getYesNo();
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDrawingColour" id="e34ca1a9-5e07-4acd-941a-ec306d463a1b">
        <source>getDrawingColour(pColourMode: Integer) : Integer;
// ---------------------------------------------------------------------------
// Created:		April  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//06-06-2022 navtnr20	53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
// ---------------------------------------------------------------------------
vars
	tmpCommodityGrp	: CM_CommodityGroup;
	tmpConsignee	: CM_ConsigneeConsignor;
	tmpISOTypeGrp	: CM_ISOTypeGroup;
	tmpTempRange	: CM_TempRange;
	tmpPort 		: CM_Port;
	ls				: Boolean;

begin

	app.cmsBeginLoad(ls);
	if pColourMode = TI_ColourMode_Consignee then
		tmpConsignee := self.myConsignee;
		if tmpConsignee &lt;&gt; null then
			sharedLock(tmpConsignee);
			return tmpConsignee.colour;
		endif;

	elseif pColourMode = TI_ColourMode_Operator then
		if self.myOperator &lt;&gt; null then
			sharedLock(self.myOperator);
			return self.myOperator.colour;
		endif;
		
	elseif pColourMode = TI_ColourMode_Product then
		if self.myProduct &lt;&gt; null then
			sharedLock(self.myProduct);
			return self.myProduct.colour;
		endif;
		
	elseif pColourMode = TI_ColourMode_DischargePort then
		if self.dischargePort &lt;&gt; null then
			//tmpPort := app.myRoot.allPorts[self.dischargePort.trimBlanks];
			tmpPort := app.myRoot.allPorts[self.dischargePort.trimBlanks];
			sharedLock(tmpPort);
			return tmpPort.colour;
		endif;

	elseif pColourMode = TI_ColourMode_Status then
		return self.contentsStatusColour();
	elseif pColourMode = TI_ColourMode_Voyage then
		if self.myVoyage &lt;&gt; null then
			sharedLock(self.myVoyage);
			return self.myVoyage.colour;
		endif;
		
		//Start 07-06-2022 navtnr20 53204
	elseif pColourMode = TI_ColourMode_ShippingLine then
		if self.myShippingLine &lt;&gt; null then
			sharedLock(self.myShippingLine);
			return self.getShippingLineColor();		// 14.07.2022 navsrk20 53195
		endif;
		//end	07-06-2022 navtnr20 53204

	endif;
	
	return LightYellow;	// The default colour

epilog
	app.cmsEndLoad(ls);
end;</source>
        <Parameter name="pColourMode" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDrawingIconAttributesBB" id="08ceda8c-c50d-4dd5-bed9-5c34c3af4e5f">
        <source>getDrawingIconAttributesBB(_displayMode: Integer; _iconAttributes: StringArray input) protected;
// ---------------------------------------------------------------------------
// Created:		April  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	_iconAttributes.add(PicTITimber);
end;</source>
        <access>protected</access>
