    <JadeMethod name="doSave" id="4c8eb54c-86b3-4abf-84a6-8495e4251e7a">
        <updating/>
        <source>doSave(): Boolean updating;

// cnwdvb1 22 April 2003 

vars

	description,
	logicalPrinterName,
	physicalPrinterName	: String;
	isPDFPrinter		: Boolean;
	theForm				: SOP_TableMaintForm;
	proxyPrinterDef		: CM_PrinterDef;

begin
 	
 	theForm := self.myForm; 
	description := theForm.tblInput1.getValueByName(ETRow_Description).String;
	logicalPrinterName := theForm.tblInput1.getValueByName(ETRow_LogicalPrinterName).String;
	physicalPrinterName := theForm.tblInput1.getValueByName(ETRow_PhysicalPrinterName).String;
	isPDFPrinter		:= theForm.tblInput1.getValueByName(ETRow_PrinterIsPDF).Integer.Boolean;

	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_PrinterDef transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyPrinterDef := theForm.myProxyObject.CM_PrinterDef;
	proxyPrinterDef.setProxy(description, logicalPrinterName, physicalPrinterName,isPDFPrinter);

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreatePrinterDef(proxyPrinterDef, theForm.myCurrentObject, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdatePrinterDef(proxyPrinterDef,app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	return app.myPassport.trxCompletedOK;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
