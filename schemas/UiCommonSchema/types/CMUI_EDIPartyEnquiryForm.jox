    <JadeMethod name="doTblDataDBClick" id="d284888c-f9e5-4606-9b18-392a97bdfb05">
        <updating/>
        <source>doTblDataDBClick(_table: CM_DataTable input) updating;
/*
Date		Who		Reason
22 November 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
