    <JadeMethod name="getPositionDataFromText" id="3620045a-9891-4d9c-a0aa-388b8aff508a">
        <source>getPositionDataFromText(_integerArray : IntegerArray io) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     August 2009 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	wagFrom, wagTo : Integer;
	int, idx : Integer;
	
begin

	wagFrom := txtWagonRange1.text.Integer;
	wagTo := txtWagonRange2.text.Integer;

	if wagTo &lt; wagFrom then
		app.msgBox(app.getErrorString(INVALID_RANGE_NUMBERS), app.getErrorString(Parameters), MsgBox_Exclamation_Mark_Icon);
		return false;
	elseif wagTo = 0 or wagFrom = 0 then
		app.msgBox(app.getErrorString(INVALID_RANGE_NUMBERS), app.getErrorString(Parameters), MsgBox_Exclamation_Mark_Icon);
		return false;
	
	endif;
	
	foreach int in wagFrom to wagTo do
		idx := idx +1;
		_integerArray[idx] := int;
	endforeach;
	
	return true;
epilog

	
end;</source>
        <access>protected</access>
        <Parameter name="_integerArray" type="IntegerArray" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
