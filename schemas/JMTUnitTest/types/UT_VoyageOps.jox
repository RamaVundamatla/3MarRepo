    <JadeMethod name="createVesselVoyage" id="0ad042cd-d669-4e47-aa77-aad269323ea0">
        <updating/>
        <source>createVesselVoyage(_voyage : String; _vessel : String; _operator :CM_Operator) : CM_Voyage updating;
// ---------------------------------------------------------------------------
// Created:     28 May 2010 by NAVAB1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	voyage : CM_Voyage;
	vessel : CM_Vessel; 
	
begin
	voyage := self.getVoyage(null);
	if voyage &lt;&gt; null then
		self.loadAllJobsToOps(voyage, false);
	endif;
	
	deleteVoyage(_voyage);
	deleteVessel(_vessel);
	
	vessel := self.addVesselLOLOholdsRORO(_vessel, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	self.addVesselDefnReefer40(vessel);

	voyage := self.addVoyageWithConRORO(_voyage, _vessel, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, null, 0, false, true);
	
	return voyage;
epilog

end;</source>
        <Parameter name="_voyage" type="String"/>
        <Parameter name="_vessel" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="createVesselVoyageOLD" id="544ed482-1057-4a53-829e-e8b715639117">
        <updating/>
        <source>createVesselVoyageOLD() : CM_Voyage updating;
// ---------------------------------------------------------------------------
// Created:     28 May 2010 by NAVAB1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	voyage1: CM_Voyage;
	vessel: CM_Vessel; 
	
begin
	voyage1 := self.getVoyage("UTBISH9");
	if voyage1 &lt;&gt; null then
		self.loadAllJobsToOps(voyage1, false);
	endif;
	deleteVoyage("UTBISH9");
	deleteVessel("UTBISHOP");
	
	vessel := self.addVesselLOLOholdsRORO("UTBISHOP", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	
	self.addVesselDefnReefer40(vessel);

	voyage1:=self.addVoyageWithConRORO("UTBISH9", "UTBISHOP", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, null, 0, false, true);
	
	return voyage1;
epilog

end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="createVoyageLoadJobsVA" id="2172e94b-a9ba-4dc1-b919-7caf0487ac69">
        <updating/>
        <source>createVoyageLoadJobsVA() : CM_VoyageJob updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 December 2008	cnwer1	Initial creation

*/

vars
	altRoroLCs, roroLCs : CM_VoyageROROControllerArray;
	realAlloc 				: CM_VoyageAllocation;
	voyage : CM_Voyage;
	altSlots, slots : CM_SlotControllerArray;
	tmpLoadCC	: CMIF_LoadColorCode;
	theLCs: CM_LCArray;
	ct : CM_CargoType;
	product: CM_Product;
	theEditions : CM_ObjectByOidEditionDict;
	voyageJob : CM_VoyageJob;
begin
	ct	:= self.getTerminal.getFirstNonSystemCargoType().CM_CargoType;
	product := ct.allProducts.first;

	//create a voyage job for bay 
	
	voyage := self.getVoyage("UTBISH9");
	create theLCs transient;
	create slots transient;
	create altSlots transient;
	create theEditions transient;

	// ### GET SLOTS. NOTE - tier ordinals start at bottom left, cell tiers start at top left.
	// 20 GENL PRENOTES
	self.getJobSlotControllers("UTBISH9","05",DeckOnDeck,1,1,6,slots);
	realAlloc := self.addVoyageAllocation(voyage, "NZAKL", "GEN2", null, TI_CargoType_Container, false, false);
	self.addLCsToLOLOAllocation(true, realAlloc, slots, altSlots);

	
	/// ## MAKE SLOT JOB
	voyageJob:=self.addVoyageJob(voyage,"CRN1",slots, false);
	assertTrue(voyageJob &lt;&gt; null);
	
	slots.clear;
	
	return voyageJob;

epilog
	delete slots;
	delete theLCs;
	delete altRoroLCs;
	delete roroLCs;
	delete tmpLoadCC;
	delete altSlots;
	delete theEditions;

end;</source>
        <ReturnType type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="iLanderIMVForkLift" id="8feaaf5b-e74c-4ed7-9223-1a442c9e075f">
        <source>iLanderIMVForkLift();

// 15/08/2012 cnwmh5

constants
	VoyageName = 'UTMDHVOY4';
	ShipName = 'UTMDHVES4';
	TestOperator = 'MSK';
	CraneTransferAreaId	= "UTC1T6";
	IMV1 = "UTIM";
vars
	cta							: CM_CraneTransferArea;
	bs							: CM_BlockStack;
	vessel 						: CM_Vessel;
	voyage 						: CM_Voyage;
	queue						: CM_VoyageQueue;
	rampQueue					: CM_VoyageCraneQueue;
	cargo1						: CM_TrackedItem;
	crane						: CM_Machine;
	imv							: CM_Machine;
	wle 						: CM_WorkListEntry;
	job 						: CM_VoyageJob;
	forkLift					: CM_Machine;
	task						: CM_RTQueueTask;
	slotsFrom					: CM_SlotControllerArray;
	tmpLoadCC					: CMIF_LoadColorCode;
	theSlot 					: CM_LocationsController;
	
	strs 						: StringArray;
	tas							: StringArray;
	
	idx							: Integer;
		pxyTask						: CM_RTQueueTask;
	success: Boolean;
	agent: CM_MobileAgent;
	result: String;
	imvSetting: Boolean;
		
begin
	create agent transient;

	self.setTerminalConfig(AllowIMVWorkRTLoggedOff, true);
	
	self.disableAllYA(true);
	bs:= self.addBlockStack("UBMS1", 100, null);
	self.addYACatchAll("UTMYA", bs);
	
	self.deleteMachine("UTMC");
	cta := self.addCraneTransferArea(CraneTransferAreaId);

	create tas transient;
	tas.add(cta.id);
	tas.add(bs.id);
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta);
	crane := self.addCrane("UTMC", null, tas, null);
	
	self.addMachineRule (cta, bs, RTMoveMethod_7);
	
	self.deleteVoyage(VoyageName);
	self.deleteVessel(ShipName);
	vessel := self.addVesselLOLOholdsRORO(ShipName, self.getOperator(TestOperator));
	voyage	:= self.addVoyageWithConRORO(VoyageName,
													ShipName,
													TestOperator, 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString,
													null, 10, false, true);
	queue := self.addVoyageQueue(voyage);
	rampQueue := self.addVoyageCraneQueue(voyage, queue, crane);
	
	create strs transient;
	deleteContainer("UTMDHJ00001");
	strs.clear;
	strs.add("010682");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo1 := self.addContainerAtLocnDisch("UTMDHJ00001", "2200", "MT", TI_IMEX_STATUS_IMPORT, theSlot, app.myRoot.allPorts["NZPOE"], voyage);
	
	// colour code the discharge slots
	create slotsFrom transient;
	self.getJobSlotControllers(VoyageName, "01", DeckOnDeck, 1, 1, 1, slotsFrom);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	job := self.addVoyageJob(voyage, crane.code, slotsFrom, true);
	assertTrue(job &lt;&gt; null);
	
	// load to job ops
	self.loadAllJobsToOps(voyage, true);
	

	imv := self.addIMV(IMV1, 93, tas, rampQueue.id);
	self.machineAssignToQueue(imv, rampQueue);
	forkLift := self.addForkLift("UTMF", 94, tas, rampQueue.id);
	self.machineAssignToQueue(forkLift, rampQueue);
	
	// Lander puts cargo on IMV
	wle := cargo1.allWorklistEntries.first;
	//success := agent.moveTIToMachine(imv, cargo1, wle, job);
	//assertTrue(success);
	//assertTrue(wle.isCompleteForJob);
	//assertEqual(cargo1.myPrimaryActualLocation, imv.myMachineController);
	self.logMessage("$$$$$$$ Start MOVE $$$$$$$");
	app.myTrxUA.trxUpdateShipMoveImport(imv, cargo1, wle, job ,null,null,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.logMessage("$$$$$$$ Done MOVE $$$$$$$");
		
	// Forklift sets down into yard
	self.machineLogon(forkLift);
	task := self.machineTaskRequest(forkLift);
	
	// Remove Machine from Task
	beginLoad;
	pxyTask := task.pxyCreateUpdateProxy();
	endLoad;
	app.myTrxUA.trxUpdateTaskRemoveMachine(pxyTask,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNull(task.machine);
	self.assertEqual(task.machineId,"");

	self.machineLogon(forkLift);
	
	///task := self.machineTaskRequest(forkLift);		// 08/11/2016 cnwmh5 - Suspect Copy and Paste issue
	///self.assertNotNull(task.machine);
	
	self.machineAcceptTask(forkLift, wle.allRTQueueEntries.last.allTasks.first);
	self.machinePickup(forkLift);
	
	self.machineSetdown(forkLift, cargo1, bs.id);
	self.machineLogOff(forkLift);
	
	
	// Commented out until 30234 has been completed.  Noted on par
	//self.checkTIForTxnOfType(cargo1, TRANS_TYPE_REC_SHIP);				// 15/08/2012 cnwmh5
	//self.checkTIForTxnOfType(cargo1, TRANS_TYPE_WHARFAGE);				// 15/08/2012 cnwmh5
	
epilog
	self.disableAllYA(false);
	delete slotsFrom;
	delete strs;
	delete tas;
	delete pxyTask;
	delete agent;
	
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;MDHFAILSTEST&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="iPlanningWarningsOnOversize" id="1e863970-042d-4429-8baf-457827c75d7e">
        <updating/>
        <source>iPlanningWarningsOnOversize() updating;

/*

Purpose:		This test is for Out Of Gauge or Over Dimensional cargo. This test is not for HiCube containers.
				The warnings for voyage work should be shown if planning or queuing on top of flat racks, 
				platforms or O/Dimensional containers.

Date			Who		Reason
22/07/2015		cnwmh5	Initial creation

*/

constants

	VoyageId					: String = "UTMHVOYOD";
	VesselId					: String = "MESDIAM";

vars

	voyage						: CM_Voyage;
	bs							: CM_BlockStack;
	ti							: CM_TrackedItem;
	voyageJob 					: CM_VoyageJob;
	realAlloc 					: CM_VoyageAllocation;
	request						: CM_Request;
	wle							: CM_WorkListEntry;
	tmpLoadCC					: CMIF_LoadColorCode;
	
	tiArray						: CM_TIArray;
	tiArray2					: CM_TIArray;
	wles 						: CM_WLEArray;
	slots 						: CM_SlotControllerArray;
	altSlots					: CM_SlotControllerArray;
	
	jobSlotContrDetails			: String;
	allocationDetails			: String;

begin

	self.setTerminalConfig(AllowRTSwithoutVGM, true);					// 10/06/2016 cnwmh5

	self.deleteVoyage(VoyageId);
	voyage := self.addVoyageWithConRORO(VoyageId, VesselId, self.getProfileSetting(UT_Profile.P_OPERATOR).asString(), 
		self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), self.getProfileSetting(UT_Profile.P_TRADE).asString(), 
		0, false, true);
	self.assertNotNull(voyage);
	
	bs := self.addBlockStack("UTMHBSX", 50, null);
	self.assertNotNull(bs);
	
	create tiArray transient;
	tiArray.clear();
	self.opts.purge();
	self.opts.addAssoc("ReturnTIs", true);
	self.opts.addAssoc("DischargePort", "NZAKL");
	self.opts.addAssoc("Voyage", voyage);
	self.addQuickCargo(bs, null, 15, tiArray);
	
	create tiArray2 transient;
	
	/*************************************************************************
	 * Over dimension - LOLO - Load
	 *************************************************************************/
	tiArray2.clear();
	self.opts.purge();
	self.opts.addAssoc("OverHeight", 10.00.Decimal);
	self.opts.addAssoc("OverFront", 5.00.Decimal);
	self.opts.addAssoc("OverRear", 6.00.Decimal);
	self.opts.addAssoc("OverLeft", 7.00.Decimal);
	self.opts.addAssoc("OverRight", 8.00.Decimal);
	self.addQuickCargo(voyage, null, 1, tiArray2);
	
	jobSlotContrDetails := '01,'&amp; DeckUnderDeck.String &amp; ',1,2,6';
	allocationDetails := 'NZAKL,GEN2,,' &amp; TI_CargoType_Container.String &amp; ',' &amp; 
		false.String &amp; ',' &amp; false.String;
	self.xPlanningWarningOnOversize(voyage, tiArray[1], jobSlotContrDetails, allocationDetails, true, true, Cannot_contain_underne_overhei);
	
	/*************************************************************************
	 * Flat - LOLO - Load
	 *************************************************************************/
	tiArray2.clear();
	self.opts.purge();
	self.opts.addAssoc("ISOType", "2060");
	self.addQuickCargo(voyage, "010602", 1, tiArray2);
	
	jobSlotContrDetails := '01,'&amp; DeckUnderDeck.String &amp; ',2,2,6';
	self.opts.purge();
	self.opts.addAssoc("Colour", 13915647);
	allocationDetails := 'NZAKL,GEN2,,' &amp; TI_CargoType_Container.String &amp; ',' &amp; 
		false.String &amp; ',' &amp; false.String;
	self.xPlanningWarningOnOversize(voyage, tiArray[2], jobSlotContrDetails, allocationDetails, true, true, Container_flat_platform);
	
	/*************************************************************************
	 * Over Length or Over Width - LOLO - Load
	 *************************************************************************/
	self.opts.purge();
	self.updateTIDimensions(tiArray[3], 6.00, 5.00, 0.00, 0.00, 0.00, null, false);
	self.opts.addAssoc("Colour", 5635967);
	self.opts.addAssoc("BreakOut1", true);
	jobSlotContrDetails := '01,'&amp; DeckUnderDeck.String &amp; ',6,1,1';
	allocationDetails := 'NZAKL,GEN2,,' &amp; TI_CargoType_Container.String &amp; ',' &amp; 
		false.String &amp; ',' &amp; false.String;
	self.xPlanningWarningOnOversize(voyage, tiArray[3], jobSlotContrDetails, allocationDetails, true, true, TI_TestReqOverDim);
	
	self.updateTIDimensions(tiArray[4], 0.00, 0.00, 0.00, 0.00, 13.00, null, false);
	self.opts.purge();
	self.opts.addAssoc("Colour", 5635967);
	self.opts.addAssoc("BreakOut1", true);
	jobSlotContrDetails := '01,'&amp; DeckUnderDeck.String &amp; ',6,5,1';
	allocationDetails := 'NZAKL,GEN2,,' &amp; TI_CargoType_Container.String &amp; ',' &amp; 
		false.String &amp; ',' &amp; false.String;
	self.xPlanningWarningOnOversize(voyage, tiArray[4], jobSlotContrDetails, allocationDetails, true, true, TI_TestReqOverDim);
	
	/*************************************************************************
	 * Over Dimension only - LOLO - Load
	 *************************************************************************/	
	self.opts.purge();
	self.opts.addAssoc("OverDimension", true);
	self.opts.addAssoc("BreakOut1", true);
	self.updateTI(tiArray[5]);
		
	self.opts.purge();
	self.opts.addAssoc("Colour", 5631267);
	self.opts.addAssoc("BreakOut1", true);
	jobSlotContrDetails := '01,'&amp; DeckUnderDeck.String &amp; ',7,1,1';
	allocationDetails := 'NZAKL,GEN2,,' &amp; TI_CargoType_Container.String &amp; ',' &amp; 
		false.String &amp; ',' &amp; false.String;
	self.xPlanningWarningOnOversize(voyage, tiArray[5], jobSlotContrDetails, allocationDetails, true, true, TI_TestReqOverDim);
	
	/*************************************************************************
	 * Over dimension - RORO - Load
	 *************************************************************************/
	tiArray2.clear();
	self.opts.purge();
	self.opts.addAssoc("OverHeight", 10.00.Decimal);
	self.opts.addAssoc("OverFront", 5.00.Decimal);
	self.opts.addAssoc("OverRear", 6.00.Decimal);
	self.opts.addAssoc("OverLeft", 7.00.Decimal);
	self.opts.addAssoc("OverRight", 8.00.Decimal);
	self.opts.addAssoc("RORO", true);
	self.addQuickCargo(voyage, "D4231384", 1, tiArray2);
	
	self.opts.purge();
	jobSlotContrDetails := '4,,D4231386';
	allocationDetails := 'NZAKL,GEN2,,' &amp; TI_CargoType_Container.String &amp; ',' &amp; 
		false.String &amp; ',' &amp; false.String;
	self.xPlanningWarningOnOversize(voyage, tiArray[6], jobSlotContrDetails, allocationDetails, false, true, Cannot_contain_underne_overhei);
	 
	/*************************************************************************
	 * Flat - RORO - Load
	 *************************************************************************/
	tiArray2.clear();
	self.opts.purge();
	self.opts.addAssoc("ISOType", "2060");
	self.opts.addAssoc("RORO", true);
	self.addQuickCargo(voyage, "D4251384", 1, tiArray2);
	
	self.opts.purge();
	jobSlotContrDetails := '4,,D4251386';
	allocationDetails := 'NZAKL,GEN2,,' &amp; TI_CargoType_Container.String &amp; ',' &amp; 
		false.String &amp; ',' &amp; false.String;
	self.xPlanningWarningOnOversize(voyage, tiArray[7], jobSlotContrDetails, allocationDetails, false, true, Container_flat_platform);
	
	/*************************************************************************
	 * Over Length or Over Width - RORO - Load
	 *************************************************************************/
	self.updateTIDimensions(tiArray[8], 6.00, 5.00, 0.00, 0.00, 0.00, null, false);
	self.opts.purge();
	self.opts.addAssoc("Colour", 5635967);
	self.opts.addAssoc("BreakOut1", true);
	jobSlotContrDetails := '4,,D4271384';
	allocationDetails := 'NZAKL,GEN2,,' &amp; TI_CargoType_Container.String &amp; ',' &amp; 
		false.String &amp; ',' &amp; false.String;
	self.xPlanningWarningOnOversize(voyage, tiArray[8], jobSlotContrDetails, allocationDetails, false, true, TI_TestReqOverDim);
	
	self.updateTIDimensions(tiArray[9], 0.00, 0.00, 0.00, 0.00, 13.00, null, false);
	self.opts.purge();
	self.opts.addAssoc("Colour", 5635967);
	self.opts.addAssoc("BreakOut1", true);
	jobSlotContrDetails := '4,,D4291384';
	allocationDetails := 'NZAKL,GEN2,,' &amp; TI_CargoType_Container.String &amp; ',' &amp; 
		false.String &amp; ',' &amp; false.String;
	self.xPlanningWarningOnOversize(voyage, tiArray[9], jobSlotContrDetails, allocationDetails, false, true, TI_TestReqOverDim);
	
	/*************************************************************************
	 * Over Dimension only - RORO - Load
	 *************************************************************************/	
	self.opts.purge();
	self.opts.addAssoc("OverDimension", true);
	self.opts.addAssoc("BreakOut1", true);
	self.updateTI(tiArray[10]);
		
	self.opts.purge();
	self.opts.addAssoc("Colour", 5631267);
	self.opts.addAssoc("BreakOut1", true);
	jobSlotContrDetails := '4,,D4211384';
	allocationDetails := 'NZAKL,GEN2,,' &amp; TI_CargoType_Container.String &amp; ',' &amp; 
		false.String &amp; ',' &amp; false.String;
	self.xPlanningWarningOnOversize(voyage, tiArray[10], jobSlotContrDetails, allocationDetails, false, true, TI_TestReqOverDim);
	
	/*************************************************************************
	 * Over dimension - LOLO - Discharge / Load
	 *************************************************************************/
	tiArray2.clear();
	self.opts.purge();
	self.opts.addAssoc("OverHeight", 10.00.Decimal);
	self.opts.addAssoc("OverFront", 5.00.Decimal);
	self.opts.addAssoc("OverRear", 6.00.Decimal);
	self.opts.addAssoc("OverLeft", 7.00.Decimal);
	self.opts.addAssoc("OverRight", 8.00.Decimal);
	self.addQuickCargo(voyage, "030602", 1, tiArray2);
	
	self.opts.purge();
	self.opts.addAssoc("BreakOut2", true);
	jobSlotContrDetails := '03,'&amp; DeckUnderDeck.String &amp; ',2,1,1';
	allocationDetails := 'NZAKL,GEN2,,' &amp; TI_CargoType_Container.String &amp; ',' &amp; 
		false.String &amp; ',' &amp; false.String;
	self.xPlanningWarningOnOversize(voyage, tiArray[11], jobSlotContrDetails, allocationDetails, true, false, null);
	
	self.opts.purge();
	self.opts.addAssoc("BreakOut3", true);
	jobSlotContrDetails := '03,'&amp; DeckUnderDeck.String &amp; ',2,2,6';
	allocationDetails := 'NZAKL,GEN2,,' &amp; TI_CargoType_Container.String &amp; ',' &amp; 
		false.String &amp; ',' &amp; false.String;
	self.xPlanningWarningOnOversize(voyage, tiArray[11], jobSlotContrDetails, allocationDetails, true, true, null);
	
	/*************************************************************************
	 * Over dimension - RORO - Discharge / Load
	 *************************************************************************/
	tiArray2.clear();
	self.opts.purge();
	self.opts.addAssoc("OverHeight", 10.00.Decimal);
	self.opts.addAssoc("OverFront", 5.00.Decimal);
	self.opts.addAssoc("OverRear", 6.00.Decimal);
	self.opts.addAssoc("OverLeft", 7.00.Decimal);
	self.opts.addAssoc("OverRight", 8.00.Decimal);
	self.opts.addAssoc("RORO", true);
	self.addQuickCargo(voyage, "D4151384", 1, tiArray2);
	
	self.opts.purge();
	self.opts.addAssoc("BreakOut2", true);
	jobSlotContrDetails := '4,,D4151384';
	allocationDetails := 'NZAKL,GEN2,,' &amp; TI_CargoType_Container.String &amp; ',' &amp; 
		false.String &amp; ',' &amp; false.String;
	self.xPlanningWarningOnOversize(voyage, tiArray[12], jobSlotContrDetails, allocationDetails, false, false, null);
	
	self.opts.purge();
	self.opts.addAssoc("BreakOut3", true);
	jobSlotContrDetails := '4,,D4151386';
	allocationDetails := 'NZAKL,GEN2,,' &amp; TI_CargoType_Container.String &amp; ',' &amp; 
		false.String &amp; ',' &amp; false.String;
	self.xPlanningWarningOnOversize(voyage, tiArray[12], jobSlotContrDetails, allocationDetails, false, true, null);
	
epilog

	app.myPassport.setWarningsAcknowledged(false);
	app.myPassport.setWarningsIgnored(false);

	delete tiArray;
	delete tiArray2;
	delete slots;
	delete altSlots;
	delete wles;

end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;Fails1006&lt;/Category&gt;
    &lt;Category CanDelete="true"&gt;WorkPointDeleteIssue&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
