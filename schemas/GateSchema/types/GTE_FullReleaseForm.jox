    <JadeMethod name="initFilterTable" id="f0300e31-8f7e-44ac-a29b-9f2d1e0ddf36">
        <updating/>
        <source>initFilterTable() updating;
// ---------------------------------------------------------------------------
// Created:     08 December 2000 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	entTableDef		: EntTableDef;
	theRow			: Integer;
	theTable		: CM_EntryTable;
	assistant		: GTE_Assistant;
	
begin

	theTable := tblSearch;
	
	entTableDef := app.myController.getEntTableDef(ETDef_FullReleaseFind);
	
	if entTableDef &lt;&gt; null then
		theTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
		theTable.adjustHeight(200);
		theTable.accessColumn(1).width := 130;	//22 July 2014	NDL	Par 34036

		assistant := self.myAssistant.GTE_Assistant;
		// need an "All" option in tiType combo
		assistant.comboBoxCargoBolType(cmbTiType, null, true, true, true, true);
		// This is the new one for after 7.4.1 release
	//	assistant.comboBoxCargoBOLTypeGate(cmbTiType, null, true, true, true);
		
		assistant.comboBoxCarrier(cmbFiltCarrier, null);
//		assistant.comboBoxConsignor(cmbFiltConsignee, null);
//		assistant.comboBoxOperator(cmbFiltOperator, null, null); initialised on got focus
		assistant.comboBoxVoyageCurrent(cmbFiltVoyage,
										app.getMyCurrentVoyage(), //cnwjo3 par 23105 //app.myCurrentVoyage,
										true,
										false,
										true,
										true,
										true,
										true,
										true,
										false,
										false);

		if self.userPermissionMode = PmGteFullReleaseCarrierMaint  
		or self.userPermissionMode = PmGteFullReleaseForward 
		or self.userPermissionMode = PmGteFullReleaseMaint then
			// allow query by PIN
		else
			theTable.hideRowByName(ETRow_FilterPIN, false);
		endif;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntTableDef FullReleaseFind not found');
		return;
	endif;

	self.cmbFiltVoyage.lostFocus(cmbFiltVoyage);
	self.myFilterVoyage := self.myAssistant.getVoyageFromCombo(cmbFiltVoyage.text);
end;</source>
    </JadeMethod>
    <JadeMethod name="initForm" id="fe677a30-7299-4ed0-bad4-3c3fe6a226df">
        <updating/>
        <source>initForm() updating;
// ---------------------------------------------------------------------------
// Created:     19 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	parent,
	navObj	: CMUI_NavigatorObject;
	theType	: String;
	canUpdate : Boolean;
begin

	self.allowAdd := false;
	self.allowDelete := false;
	//changed by cnwyl1 PAR - 11554
	self.allowPrint  	:= true;
	self.allowExportCSV	:= true;
	//was...
//	self.allowPrint  := false;	//Buttons not implemented as of 15/6/01
	self.filterCargoType	:= TI_CargoType_Null;
	cmbTiType.listObject 	:= null;
	self.useNumRowsShown	:= true;
/*
	parent := self.myParentNavigatorObject;
*/
//	theType := NavObj_GTE_ReleaseById;
//	navObj := self.createNavigatorObject(theType &amp; 'TV', 'Table View', '', theType);
//	navObj.setTableDefs(navObj.myParent.mainTableDef, navObj.myParent.extraTableDef);
//	self.myNavigatorObject := navObj;

	if app.myCurrentUserCan(self.myTerminal, PmGteFullReleaseMaint) then
		self.userPermissionMode := PmGteFullReleaseMaint;
		self.permissionMaint := PmGteFullReleaseMaint;
		// can only generate pin if user has both of these permissions
		self.allowGeneratePin := app.myCurrentUserCan(self.myTerminal, PmGteGeneratePinNo);
	elseif app.myCurrentUserCan(self.myTerminal, PmGteFullReleaseCarrierMaint) then
		self.userPermissionMode := PmGteFullReleaseCarrierMaint;
		self.permissionMaint := PmGteFullReleaseCarrierMaint;
	elseif app.myCurrentUserCan(self.myTerminal, PmGteFullReleaseForward) then
		self.userPermissionMode := PmGteFullReleaseForward;
		self.permissionMaint := PmGteFullReleaseForward;
	elseif app.myCurrentUserCan(self.myTerminal, PmGteFullReleaseOperatorMaint) then
		self.userPermissionMode := PmGteFullReleaseOperatorMaint;
		self.permissionMaint := PmGteFullReleaseOperatorMaint;
	else
		self.userPermissionMode := PmGteFullReleaseView;
	endif;
	
//self.userPermissionMode := PmGteFullReleaseCarrierMaint;
//self.permissionMaint := PmGteFullReleaseCarrierMaint;

	canUpdate := (self.userPermissionMode &lt;&gt; PmGteFullReleaseView);
	self.allowUpdate := canUpdate;

	initMainTable();
	initExtraTable();
	self.initTableCustEntry();
	
	self.sptMain.setLeftToRightRatioAndResize(50);
	
//	self.setAllTrackedItems();

//	beginClassNotification(CM_TrackedItem, false, self.myTerminal.getTerminalEvent(TIEvent_Terminal_Receival), Response_Continuous, 0);
	self.cmbFreightFwdr.setType(FREIGHT_FORWARDER);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initMainTable" id="92f4436a-d809-4ac5-bcc6-734aa84b44e6">
        <source>initMainTable();
// ---------------------------------------------------------------------------
// Created:     12 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26 Jun 2008	cnwkpd1		PAR #17183 - Turn off optimiseRowHeight to fix scrolling
//							issue with Custom Entry table open for data entry
// ---------------------------------------------------------------------------
vars
	entTableDef		: EntTableDef;
	intRow			: Integer;
	theTable		: CM_EntryTable;
	aStopTable			: CM_StopsTable;
	rowName			: String;
	theUser			: CM_User;
	term			: CM_Terminal;
	allowedStopTables	: CM_StopsTableByIdDict;
begin

	theTable := tblMain;
	theTable.warningMethod := 'entTableWarning';
	
	
	theTable.stretchToParent := true;
	theTable.optimiseRowHeight := false;		// PAR #17183
//	theTable.optimiseRowHeight := true;
			
	entTableDef := app.myController.getEntTableDef(self.myMasterMenuAction.mainTableDef);
	theTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	
	theUser := app.myPassport.myUser;
	term := app.myPassport.myTerminal;
	
	if theUser &lt;&gt; null then
		//users only see this stuff in edit mode so...
		allowedStopTables := theUser.getStopsToMaintForTerminal(self.myTerminal);
	else
		allowedStopTables := app.myRoot.allStopsTable;
	endif;
	
	// Stops are in a class of their own now so add all of them AKB2002JUNE
//	foreach aStop in app.myRoot.allStopsTable do
	foreach aStopTable in allowedStopTables do
		//rowName := aStop.heading &amp; " Stop";
		//theTable.addAttribute(rowName, rowName, Table.InputType_CheckBox, null, true);
		if theUser.canViewStop(term, aStopTable) and aStopTable.isValidForTerminal(self.myTerminal) then
			theTable.addAttribute(aStopTable.getAttrName(), aStopTable.getAttrHeading(), Table.InputType_CheckBox, null, true);
		endif;
	endforeach;

	theTable.adjustHeight(200);

	theTable.optimiseHeadingColumn();
	
	//Par 5846 23092003 CNWSH3
	//Used in doCancel method to check if a change has occured on the CM_EntryTable control
	theTable.changeMode := theTable.ChangeMode_All;		//changed to All - bulk edit needs to know which rows have changed. JC 06/2004
end;</source>
    </JadeMethod>
    <JadeMethod name="initTableCustEntry" id="7294f70e-ebf6-44e0-8f94-58b8678502b5">
        <source>initTableCustEntry();

vars

begin
	self.tblCustEntry.inputType := Table.InputType_TextBox;
	self.tblCustEntry.userInputEnabled := true;
	self.tblCustEntry.rows := 10;
end;
</source>
    </JadeMethod>
    <JadeMethod name="keyDown" id="a2e013ed-48d8-47e8-b5e0-362dd6acf5b6">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     09 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theActiveControl	: Control;

begin

	inheritMethod(keyCode, shift);
	
	if keyCode = J_key_Tab then
		if tblExtra.visible then
			tblMain.handleFormTab(keyCode, shift, tblData, tblExtra);
			tblExtra.handleFormTab(keyCode, shift, tblMain, tblData);
		else
			tblMain.handleFormTab(keyCode, shift, tblData, tblData);
		endif;

		theActiveControl := app.activeControl;
		if theActiveControl.parent.isKindOf(CM_EntryTable) then
			theActiveControl := theActiveControl.parent.CM_EntryTable;
		endif;
		if theActiveControl.isKindOf(CM_EntryTable) then
			theActiveControl.CM_EntryTable.handleTableTab(shift);
		endif;
	endif;
	
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="populateOnShipCargoFor" id="03fb021f-77e1-415b-913c-61ac4bf86d48">
        <source>populateOnShipCargoFor( _obj : CM_Object; secondDict :  CM_TIByIdCargoTypeDict input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2014	cnwndl1	Initial creation	Par 34036

*/

vars

	theVoyages : CM_VoyageSet;
	voyage : CM_Voyage;
	term : CM_Terminal;
	oper : CM_Operator;
	ti : CM_TrackedItem;

begin

	if _obj.isKindOf(CM_Terminal) then
		term := _obj.CM_Terminal;
	elseif _obj.isKindOf(CM_OperatorTerminal) then
		term := _obj.CM_OperatorTerminal.myTerminal;
		oper := _obj.CM_OperatorTerminal.myOperator;
	endif;

	create theVoyages transient;
	term.getAllCurrentVoyages(theVoyages, true, false, false);
	
	if oper &lt;&gt; null then
		foreach voyage in theVoyages do
			foreach ti in voyage.allOnshipTIsByIdCargoType do
				secondDict.addNoDuplicates( ti, false );
			endforeach;
		endforeach;
	else
		foreach voyage in theVoyages do
			voyage.allOnshipTIsByIdCargoType.copy( secondDict );
		endforeach;
	endif;

epilog

	delete theVoyages;

end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="secondDict" type="CM_TIByIdCargoTypeDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="resetNotifications" id="6341aa22-1193-40ea-a4c2-a3522154fad2">
        <source>resetNotifications();
//--------------------------------------------------
// Created:	29 October 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();
	beginClassNotification(CM_TrackedItem, false, self.myTerminal.getTerminalEvent(TIEvent_Terminal_Receival), Response_Continuous, 0);
end;</source>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="24ba4382-c4bd-4db1-828a-657e300ad127">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     27 November 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_colorControl);
	
	self.setColorsForEntryTable(self.tblExtra);
	self.setColorsForEntryTable(self.tblMain);

end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="3760f4b8-3406-4151-af9a-a5e7d666379c">
        <updating/>
        <source>setControlsForAddEdit() updating;
// ---------------------------------------------------------------------------
// Created:     12 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	filterRatio	: Integer;
	tiObj : CM_TrackedItem;
	showImportPIN : Boolean;
	
begin
	inheritMethod();
	
	tiObj	:=	self.myCurrentObject.CM_TrackedItem;
	sptThumbEdit.showRightControl(40, true);
	
	tblMain.clearValues();
	tblExtra.clearValues();
	tblMain.clearAllSelected();
	tblExtra.clearAllSelected();
	
	if tiObj &lt;&gt; null and tiObj.myOperator &lt;&gt; null and tiObj.myOperator.getRequiresImpOperatorPIN() then //cnwgb1 26.11.2010 JMT 2032
		showImportPIN := true;
	endif;

	self.setDefaults();
	
	if self.userPermissionMode = PmGteFullReleaseCarrierMaint then
		tblMain.showHideRowsByViewName('CarrierView', CM_EntryTable.ShowHideRows, false);
		//epr par 15357 19/11/07
		if not app.myCurrentUserCan(self.myTerminal, PmGteFullReleaseForward) then
			tblMain.hideRowByName(ETRow_FreightForwarder, true);
		endif;
		tblMain.hideRowByName(ETRow_GeneratePinNo, true);
		//tblMain.hideRowByName(ETRow_OperatorImportReleasePIN, true); //cnwrd1 6.11.08 CCMS JMT 1743/1764 
		if showImportPIN then
			tblMain.showRowByName(ETRow_OperatorImportReleasePIN, false); //cnwgb1 26.11.10 CCMS JMT 2032
		else
			tblMain.hideRowByName(ETRow_OperatorImportReleasePIN, false); //cnwrd1 6.11.08 CCMS JMT 1743/1764 
		endif;
		
	elseif self.userPermissionMode = PmGteFullReleaseForward then
		tblMain.showHideRowsByViewName('ForwarderView', CM_EntryTable.ShowHideRows, false);
		tblMain.hideRowByName(ETRow_GeneratePinNo, true);
		if showImportPIN then
			tblMain.showRowByName(ETRow_OperatorImportReleasePIN, false); //cnwgb1 26.11.10 CCMS JMT 2032
		else
			tblMain.hideRowByName(ETRow_OperatorImportReleasePIN, false); //cnwrd1 6.11.08 CCMS JMT 1743/1764 
		endif;
			
	elseif self.userPermissionMode = PmGteFullReleaseOperatorMaint then
		tblMain.showHideRowsByViewName('OperatorView', CM_EntryTable.ShowHideRows, false);
		tblMain.hideRowByName(ETRow_GeneratePinNo, true);
		if showImportPIN then
			tblMain.showRowByName(ETRow_OperatorImportReleasePIN, false); //cnwgb1 26.11.10 CCMS JMT 2032
		else
			tblMain.hideRowByName(ETRow_OperatorImportReleasePIN, false); //cnwrd1 6.11.08 CCMS JMT 1743/1764 
		endif;
	else
	//	tblMain.hideRowByName(ETRow_OperatorImportReleasePIN, true); //cnwrd1 6.11.08 CCMS JMT 1743/1764  // cnwrd1 removed for par 26735 we want to show this for everybody now
		tblMain.hideRowByName(ETRow_CustomsEntryCheckNo, true);
		self.tblMain.hideRowByName(ETRow_EmailOptions, true);
		
		if self.allowGeneratePin then
			tblMain.showRowByName(ETRow_GeneratePinNo, true);
			self.tblMain.disableRowByName(ETRow_EmailOptions);
		else
			tblMain.hideRowByName(ETRow_GeneratePinNo, true);
		endif;
	endif;
	
	
	
	
// cnwdad1 27/08/2008 - CCMS 1739: This should show the Booking Reference field for any user if these conditions are met.
	if self.canViewBookingRef() then
		if tiObj.myOperator = null or tiObj.myFreightForwarder = null then
			tblMain.hideRowByName(ETRow_BookingReference, false);
		else
			if tiObj.myOperator.allFFsForBookRefUpdate.includes(tiObj.myFreightForwarder) then
// The following was only required for the 7.5.3 and 7.6.2 hotfixes.
//		if tiObj.myOperator.getConfig(OperatorForwarder).Object = tiObj.myFreightForwarder then
				tblMain.showRowByName(ETRow_BookingReference, false);
			else
				tblMain.hideRowByName(ETRow_BookingReference, false);
			endif;
		endif;
	else
		tblMain.hideRowByName(ETRow_BookingReference, false);
	endif;
	
	tblMain.visible		:=	true;
	tblExtra.visible	:=	false;

	// calculate the % of the left control (filter form) that we want to show).
	
	sptThumbEdit.showLeftControl(50, true);

	filterRatio := (100 - 1 - ((tblExtra.height / sptThumbEdit.height)) * 100).Integer;

	sptThumbEdit.setLeftToRightRatioAndResize(filterRatio);
	
	self.btnGeneratePin.enabled := false;
	self.btnDeletePin.enabled	:= false;
	
	tblMain.moveFirst();
	tblMain.setFocus();
end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForView" id="862dde63-7e87-4970-96d2-1b798fd0cf0c">
        <updating/>
        <source>setControlsForView() updating;
// ---------------------------------------------------------------------------
// Created:     12 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	inheritMethod();

	tblMain.visible		:=	false;
	tblExtra.visible	:=	false;
	self.btnGeneratePin.enabled	:=	true;
	self.btnDeletePin.enabled	:=	true;
	
	if self.myEmailDefaults &lt;&gt; null then
		delete self.myEmailDefaults;
	endif;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnEditTV.enabled := false;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setCustEntryTable" id="521e71e3-1cb9-4e03-8011-c5ca0e85d0ee">
        <source>setCustEntryTable(_numNumbers: String);
//----------------------------------------------------------------
//	Created:	22 November 2007	by Deb Hutchison
//----------------------------------------------------------------
vars
	tbl			: CM_Table;
	numsList	: StringArray;
	intRow		: Integer;
	strNum		: String;
begin
	tbl := self.tblCustEntry;
	tbl.clear;
	
	create numsList transient;
	_numNumbers.getTokensForDelimiter(',', numsList);
	
	intRow := tbl.fixedRows + 1;
	foreach strNum in numsList do
		tbl.accessCell(intRow, 1).text := strNum.trimBlanks;
		intRow := intRow + 1;	
	endforeach;
	
epilog
	delete numsList;
end;</source>
        <Parameter name="_numNumbers" type="String"/>
    </JadeMethod>
    <JadeMethod name="setDefaults" id="4c1fcf79-ae98-4432-8c94-5e7474037f98">
        <updating/>
        <source>setDefaults() updating, protected;
// ---------------------------------------------------------------------------
// Created:     20 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//20 Oct 2022	navsj20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
// ---------------------------------------------------------------------------
vars
	defCarrier			: CM_Carrier;
	defConsignee		: CM_ConsigneeConsignor;
	defISOType			: CM_ISOType;
	defOperator			: CM_Operator;
	defConsignorVoyage	: String;
	defDeliveryReason	: String;
	defRemoveStops		: Boolean;
	defReleaseByType	: Boolean;
	defReasonDescr		: String;
	theTi, theRealTi	: CM_TrackedItem;
	aStopTable			: CM_StopsTable;
	passport			: CM_Passport;
	stopTablesDict		: CM_StopsTableByIdDict;
	checked				: Boolean;
	failedDAC  			: CM_DataAccessController;
	
begin
	if self.mode = Mode_Add then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Attempt to add a cargo release - this is not permitted');
		return;
	endif;
	
	passport := app.myPassport;
	
	theTi := self.myProxyObject.CM_TrackedItem;
	theRealTi := self.myCurrentObject.CM_TrackedItem;
	
	// Removed following as this just replaced a JADE error for a meaningless error.  Further investigation is required
	// to try and determine how get here with self.myProxyObject = null (RJS - Nov 2008)
	//Par 17619 AER 30/07/2008
	//if theTi = null then
	//	app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy Object Deleted');
	//	return;
	//endif;
	
	defCarrier := app.myRoot.allCarriers[theTi.releaseCarrier];
	if defCarrier &lt;&gt; null and (not defCarrier.canUserAccessSelf(null, failedDAC, passport)) then
		defCarrier := null;
	endif;
	
	self.cmbCustomsAgent.setObject(theTi.myCustomsAgent);
	
//	self.myAssistant.GTE_Assistant.comboBoxCarrier(cmbCarrier, defCarrier);
	self.cmbCarrier.setObject(defCarrier);
	
//	tblMain.setValueByName(ETRow_ReleaseCarrier, cmbCarrier.text);
	self.tblMain.setValueByName(ETRow_ReleaseCarrier, self.cmbCarrier.text);
	self.cmbFreightFwdr.setObject(theTi.myFreightForwarder);
	tblMain.setValueByName(ETRow_FreightForwarder, self.cmbFreightFwdr.text);
	
//	tblMain.setValueByName(ETRow_CustomsEntryNumber, theTi.customsEntryNumber);
	tblMain.setValueByName(ETRow_CustomsEntryNumber, theTi.getCustEntryNumList); // dh 22/11/2007 ccms 1616
	tblMain.setValueByName(ETRow_DeliveryReleaseNumber, theTi.deliveryRelease);
	tblMain.setValueByName(ETRow_EmailOptions, DblClickToUpdate);
	if theTi.myCustomsAgent &lt;&gt; null then
		self.tblMain.setValueByName(ETRow_MyCustomsAgent, theTi.myCustomsAgent.code);
	endif;
	
	if passport.myUser &lt;&gt; null then
		if self.mode = self.Mode_Update then
			stopTablesDict := passport.myUser.getStopsToMaintForTerminal(self.myTerminal);
		else
			stopTablesDict := passport.myUser.getStopsToViewForTerminal(self.myTerminal);
		endif;
	else
		stopTablesDict := app.myRoot.allStopsTable;
	endif;

	foreach aStopTable in stopTablesDict do
	
//	foreach aStop in app.myRoot.allStopsTable do
		checked := theRealTi.isStopSet(aStopTable.id);
		//tblMain.setValueByName(aStop.heading &amp; " Stop", checked); // PAR 7753 added space to "Stop"
		tblMain.setValueByName(aStopTable.getAttrName(), checked); 
		//if not aStopTable.isValidForCargoType(theRealTi.cargoType) or not (app.myRoot.allAvailableStopsTables.includes(aStopTable) or checked) then		//20.10.2022	navsj20	TFS 53862
		if not aStopTable.isValidForStopCriteria(theRealTi) or not (app.myRoot.allAvailableStopsTables.includes(aStopTable) or checked) then			//20.10.2022	navsj20	TFS 53862
			//tblMain.hideRowByName(aStop.heading &amp; "Stop", true);
			tblMain.hideRowByName(aStopTable.getAttrName(), true);
		endif;
	endforeach;

	tblMain.setValueByName(ETRow_Consignee, theTi.consignee);
	tblMain.setValueByName(ETRow_CarrierRemarks, theTi.carrierRemarks);
	tblMain.setValueByName(ETRow_Remarks, theTi.remarks);
	tblMain.setValueByName(ETRow_ClientRef, theTi.clientRef); //cnwrd1 par 233337 17.5.2010
	tblMain.setValueByName(ETRow_BookingReference, theTi.bookingReference);
	
	//cnwrd1 10.11.08 CCMS JMT 1743/1764 
	if self.userPermissionMode = PmGteFullReleaseOperatorMaint  then
		tblMain.setValueByName(ETRow_OperatorImportReleasePIN, theTi.getOperatorImportReleasePIN);	
	else
		tblMain.setValueByName(ETRow_OperatorImportReleasePIN, '');
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setFilterDefaults" id="6e1de163-344f-428b-9fc7-e9667f45ab56">
        <updating/>
        <source>setFilterDefaults() updating;
// ---------------------------------------------------------------------------
// Created:     06 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.filterId				:= null;

	self.filterCarrierCode		:= null;
	self.myFilterCarrier		:= null;
	cmbFiltCarrier.listObject	:= null;
	
	self.filterConsigneeCode	:= null;
	self.myFilterConsignee		:= null;
	cmbFiltConsignee.listObject	:= null;

	self.filterOperatorCode		:= null;
	self.myFilterOperator		:= null;
	self.cmbFiltOperator.setObject(null);
	
	self.filterVoyageCode		:= null;
	self.myFilterVoyage			:= null;
	cmbFiltVoyage.listObject	:= null;

	self.filterCargoType		:= TI_CargoType_Null;
	cmbTiType.listObject 		:= null;
	
	self.filterPIN				:= null;
	//PAR17737 - CCMS1035 - allow filtering by BOL
	self.filterBOL 				:= null;
	self.filterIncludeOnShip := false;	//22 July 2014	NDL	Par 34036

end;</source>
    </JadeMethod>
    <JadeMethod name="setFilterValues" id="2fba0540-c50a-4d87-b805-61ee38125323">
        <updating/>
        <source>setFilterValues() updating;
// ---------------------------------------------------------------------------
// Created:     06 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	//tmpCargoType	: CM_CargoType;//par 14296
	tmpCargoBOLType	: CM_CargoBOLType;	
begin
	self.filterId			:= tblSearch.getValueByName(ETRow_FilterId).String;
	self.myFilterCarrier	:= cmbFiltCarrier.listObject.CM_Carrier;
	self.myFilterOperator	:= cmbFiltOperator.myObject.CM_Operator;
	self.myFilterVoyage		:= self.myAssistant.getVoyageFromCombo(cmbFiltVoyage.text);  //cmbFiltVoyage.listObject.CM_Voyage;
//PAR7251 Combo box changed to listCollection a String Array so no Consignee was associated with listIndex.
//Changed to find the consignee based on text in cmbFiltConsignee	
	self.myFilterConsignee	:= cmbFiltConsignee.myObject.CM_ConsigneeConsignor;
//	self.myFilterConsignee	:= cmbFiltConsignee.listObject.CM_ConsigneeConsignor;
//	self.myFilterConsignee := self.myAssistant.getConsignFromCombo(cmbFiltConsignee.text);
	
	/*tmpCargoType := cmbTiType.listObject.CM_CargoType;
	if tmpCargoType &lt;&gt; null then
		filterCargoType := tmpCargoType.id;
	else
		filterCargoType := TI_CargoType_Null;
	endif;
	
	if self.myFilterCarrier &lt;&gt; null then
		self.filterCarrierCode := self.myFilterCarrier.code.trimRight;
	else
		self.filterCarrierCode := null;
	endif;

	if self.myFilterConsignee &lt;&gt; null then
		self.filterConsigneeCode := self.myFilterConsignee.code.trimRight;
	
	else
		self.filterConsigneeCode := null;
	endif;

	if self.myFilterOperator &lt;&gt; null then
		self.filterOperatorCode := self.myFilterOperator.code.trimRight;
	else
		self.filterOperatorCode := null;
	endif;

	if self.myFilterVoyage &lt;&gt; null then
		self.filterVoyageCode := self.myFilterVoyage.code.trimRight[1:10];
		app.myCurrentVoyage := self.myFilterVoyage;
	else
		self.filterVoyageCode := null;
	endif;*///par 14296
	tmpCargoBOLType := cmbTiType.listObject.CM_CargoBOLType;
	if tmpCargoBOLType &lt;&gt; null then
		filterCargoType := tmpCargoBOLType.id;
	else
		filterCargoType := TI_CargoType_Null;
	endif;
	
	if self.myFilterCarrier &lt;&gt; null then
		self.filterCarrierCode := self.myFilterCarrier.code.trimRight;
	else
		self.filterCarrierCode := null;
	endif;

	if self.myFilterConsignee &lt;&gt; null then
		self.filterConsigneeCode := self.myFilterConsignee.code.trimRight;
	else
		self.filterConsigneeCode := null;
	endif;

	if self.myFilterOperator &lt;&gt; null then
		self.filterOperatorCode := self.myFilterOperator.code.trimRight;
	else
		self.filterOperatorCode := null;
	endif;

	if self.myFilterVoyage &lt;&gt; null then
		self.filterVoyageCode := self.myFilterVoyage.code.trimRight[1:10];
		//app.myCurrentVoyage := self.myFilterVoyage;
		//cnwjo3 par 23105
		app.setMyCurrentVoyage(self.myFilterVoyage);
	else
		self.filterVoyageCode := null;
	endif;

	self.filterPIN	:= tblSearch.getValueByName(ETRow_FilterPIN).String.trimBlanks;
	
	//PAR17737 - CCM1035 APM Gate BOL Gaps 15/8/2008  Allow search by BOL Number
	self.filterBOL := self.tblSearch.getValueByName(ETRow_FilterDocketNumber).String.trimBlanks;
	
	self.filterIncludeOnShip := self.tblSearch.getValueByName(ETRow_IncludeOnShip).Boolean;	//22 July 2014	NDL	Par 34036
end;

</source>
    </JadeMethod>
