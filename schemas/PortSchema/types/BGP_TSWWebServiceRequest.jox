<Class name="BGP_TSWWebServiceRequest" id="0bba4462-8c69-49a1-9c88-8c62025b3a20">
    <superclass name="BGP_Request"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;TSW Web Service&lt;/display&gt;
&lt;displayShort&gt;TSW Web Service&lt;/displayShort&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <PrimAttribute name="name" id="926c4732-8c45-4911-a7d9-3d299a1d01e9">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
