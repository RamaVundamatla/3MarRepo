    <JadeMethod name="getXMLSettingsForSave" id="183bb797-189c-47c2-9f14-00e25045eddb">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*
----------   ----------  --------------------------------------------------
Created:	01 March 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
27/07/2022	 navkc1		 ChangeRequest 53629: PNL-Cargo Comparison - Different fields save on close for Load List and Discharge List.	
----------   ----------  --------------------------------------------------
*/
vars
type,
	xmlStr			: String;
	obj				: Object;
	selectedFields : ObjectArray;	//par 25235 cnwrs1 3 aug 2010
	xmlFields		: String;
begin

	xmlStr := inheritMethod();
	
	xmlStr := xmlStr &amp; self.tblData.getXmlStrForColumns(true);
	
	//par 25235 cnwrs1 3 aug 2010 
	create selectedFields transient;
	
	self.mulSelectIgnore.getSelected(selectedFields);
	
	xmlStr := xmlStr &amp; CrLf &amp; '&lt;Availablefields&gt;';
	
	foreach obj in selectedFields do
		//xmlStr := xmlStr &amp; global.formatAsXML("ignore" &amp; obj.CM_Association.asString, true.String);		// 27/07/2022	navkc1	 #53629		
		xmlFields := xmlFields &amp; global.formatAsXML("ignore" &amp; obj.CM_Association.asString, true.String);	// 27/07/2022	navkc1	 #53629		
	endforeach;
	
	selectedFields.clear();
	
	self.mulSelectUpdate.getSelected(selectedFields);
	
//	xmlStr := xmlStr &amp; CrLf &amp; global.formatAsXML('UpdateAvailable', null);

	foreach obj in selectedFields do
		//xmlStr := xmlStr &amp; global.formatAsXML("update" &amp; obj.CM_Association.asString, true.String);		// 27/07/2022	navkc1	 #53629		
		xmlFields := xmlFields &amp; global.formatAsXML("update" &amp; obj.CM_Association.asString, true.String);	// 27/07/2022	navkc1	 #53629		
	endforeach;
	
	selectedFields.clear();
	
	self.mulSelTranship.getSelected(selectedFields);
	
//	xmlStr := xmlStr &amp; CrLf &amp; global.formatAsXML('TranshipAvailable', null);

	foreach obj in selectedFields do
		//xmlStr := xmlStr &amp; global.formatAsXML("tranship" &amp; obj.CM_Association.asString, true.String);		// 27/07/2022	navkc1	 #53629		
		xmlFields := xmlFields &amp; global.formatAsXML("tranship" &amp; obj.CM_Association.asString, true.String);	// 27/07/2022	navkc1	 #53629		
	endforeach;
	
	// 27/07/2022	navkc1	 #53629	Save fields based on the Comparison mode --&gt;
	if self.comparisonMode = LOAD_COMPARISON then
		self.loadXML := xmlFields;
	elseif self.comparisonMode = DISCHARGE_COMPARISON then
		self.dischargeXML := xmlFields;
	endif;		// &lt;-- 27/07/2022	navkc1	 #53629
	
	self.loadXML := global.formatAsXML("Load", self.loadXML);		// 27/07/2022	navkc1	 #53629		enclose xml tags
	self.dischargeXML := global.formatAsXML("Discharge", self.dischargeXML);		// 27/07/2022	navkc1	 #53629		enclose xml tags
	
	//xmlStr := xmlStr &amp; CrLf &amp; '&lt;/Availablefields&gt;';
	xmlStr := xmlStr &amp; CrLf &amp; self.loadXML &amp; CrLf &amp; self.dischargeXML &amp; CrLf &amp; '&lt;/Availablefields&gt;'; // 27/07/2022	navkc1	 #53629
	
	//th2 for PAR 14646
	//ignore check boxes
/*	xmlStr := xmlStr &amp; CrLf &amp; global.formatAsXML(self.chkIgnoreISO.name, self.chkIgnoreISO.value.String)
							&amp; global.formatAsXML(self.chkISOGroup.name, self.chkISOGroup.value.String)
							&amp; global.formatAsXML(self.chkIgnoreBooking.name, self.chkIgnoreBooking.value.String)
							&amp; global.formatAsXML(self.chkIgnoreCmdty.name, self.chkIgnoreCmdty.value.String)
							&amp; global.formatAsXML(self.chkIgnoreDestPor.name, self.chkIgnoreDestPor.value.String)
							&amp; global.formatAsXML(self.chkIgnoreDisPort.name, self.chkIgnoreDisPort.value.String)
							&amp; global.formatAsXML(self.chkIgnoreCnsgnee.name, self.chkIgnoreCnsgnee.value.String)
							&amp; global.formatAsXML(self.chkIgnoreHaz.name, self.chkIgnoreHaz.value.String)
							&amp; global.formatAsXML(self.chkIgnoreHum.name, self.chkIgnoreHum.value.String)
							&amp; global.formatAsXML(self.chkIgnoreODim.name, self.chkIgnoreODim.value.String)
							&amp; global.formatAsXML(self.chkIgnoreOp.name, self.chkIgnoreOp.value.String)
							&amp; global.formatAsXML(self.chkIgnoreTemp.name, self.chkIgnoreTemp.value.String)
							&amp; global.formatAsXML(self.chkIgnoreVent.name, self.chkIgnoreVent.value.String)
							&amp; global.formatAsXML(self.chkIgnoreWC.name, self.chkIgnoreWC.value.String)
							&amp; global.formatAsXML(self.chkIgnoreWeight.name, self.chkIgnoreWeight.value.String)
							&amp; global.formatAsXML(self.chkIgnoreSealNum.name, self.chkIgnoreSealNum.value.String)
							&amp; global.formatAsXML(self.chkIgnoreCA.name, self.chkIgnoreCA.value.String)
							&amp; global.formatAsXML(self.chkIgnoreCargTyp.name, self.chkIgnoreCargTyp.value.String);		// 10/02/2009 cnwar2 CCMS1797 (PAR18881)
*/	
	//update field check boxes
/*	xmlStr := xmlStr &amp; CrLf &amp; global.formatAsXML(self.chkUpdateBookRef.name, self.chkUpdateBookRef.value.String)
							&amp; global.formatAsXML(self.chkUpdateCmdty.name, self.chkUpdateCmdty.value.String)
							&amp; global.formatAsXML(self.chkUpdateDest.name, self.chkUpdateDest.value.String)
							&amp; global.formatAsXML(self.chkUpdateDisPort.name, self.chkUpdateDisPort.value.String)
							&amp; global.formatAsXML(self.chkUpdateCnsgnee.name, self.chkUpdateCnsgnee.value.String)
							&amp; global.formatAsXML(self.chkUpdateHum.name, self.chkUpdateHum.value.String)
							&amp; global.formatAsXML(self.chkUpdateISO.name, self.chkUpdateISO.value.String)
							&amp; global.formatAsXML(self.chkUpdateOper.name, self.chkUpdateOper.value.String)
							&amp; global.formatAsXML(self.chkUpdateTemp.name, self.chkUpdateTemp.value.String)
							&amp; global.formatAsXML(self.chkUpdateVent.name, self.chkUpdateVent.value.String)
							&amp; global.formatAsXML(self.chkUpdateWC.name, self.chkUpdateWC.value.String)
							&amp; global.formatAsXML(self.chkUpdateWeight.name, self.chkUpdateWeight.value.String)
							&amp; global.formatAsXML(self.chkUpdateSealNum.name, self.chkUpdateSealNum.value.String)
							&amp; global.formatAsXML(self.chkUpdateCargTyp.name, self.chkUpdateCargTyp.value.String)	// 10/02/2009 cnwar2 CCMS1797 (PAR18881)
							&amp; global.formatAsXML(self.chkUpdateVoy.name, self.chkUpdateVoy.value.String);	// 26 Apr 2010	NDL Par 23912		
*/	
	//19 May 2010	NDL	Par 24243
	xmlStr := xmlStr &amp; CrLf &amp; global.formatAsXML(self.chkInclOtherVoy.name, self.chkInclOtherVoy.value.String)
							&amp; global.formatAsXML(self.chkExclImport.name, self.chkExclImport.value.String)
							&amp; global.formatAsXML(self.chkExclEmpty.name, self.chkExclEmpty.value.String)
	//						&amp; global.formatAsXML(self.chkISOGroup.name, self.chkISOGroup.value.String) //par 25235 cnwrs1 3 aug 2010
							&amp; global.formatAsXML(self.chkTranshipAdd.name, self.chkTranshipAdd.value.String); //par 25235 cnwrs1 3 aug 2010
	
	xmlStr := xmlStr &amp; global.formatAsXML( self.chkCurrentVoys.name, self.chkCurrentVoys.value.String );	//23 Feb 2021	NDL	TFS 50836
	
	return xmlStr;
epilog
	delete selectedFields;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleNotification" id="1b3704a8-8804-4d7a-ab33-d10083d1ea76">
        <updating/>
        <source>handleNotification(_eventType: Integer; _item: Object) updating;
//----------------------------------------------------------------
//	Created:	04 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	isInvalid		: Boolean;							// cnwrl1 09/08/2010 PAR 24337
	iEdition		: Integer;							// cnwrl1 09/08/2010 PAR 24337
	ediTI			: CM_EDITrackedItem;
	redisplayEDITIs	: CM_EDITISet;
	ignoreFields	: StringArray;
	row : Integer;
	
begin
	/* cnwrl1 09/08/2010 PAR 24337 - what it was
	if (not global.isValidObject(_item)) or _item = null then
		return; 
	endif;
	//this is likely to be in the table
	cnwrl1 09/08/2010 PAR 24337 - end of what it was */
	
	// cnwrl1 09/08/2010 PAR 24337 - start of coding
	// Handle the deletion of the possible objects valid the agent processing.
	on Exception do app.handleDeletedObject( exception, _item, isInvalid );
	// Check availability by doing a de-reference
	iEdition	:= _item.edition();
	if isInvalid then
		self.myLLCAgent.validateAgentReferences( _item );
		if _item.isKindOf( CM_EDIDataLoadList ) or
		   _item.isKindOf( CM_Voyage ) then
			self.doCmbVoyageBuild();
		endif;
		if _item.isKindOf( CM_EDILoadListTI ) then	//01 Aug 2013	NDL	Par 31544
			if self.tblData.findObjectInRow( _item, row ) then
				if row &gt; self.tblData.fixedRows and row &lt;= self.tblData.rows then
					self.tblData.removeItem( row );
				endif;
			endif;
		endif;
		return;
	endif;
	// cnwrl1 09/08/2010 PAR 24337 - end of coding
	
	create redisplayEDITIs;
	
	create ignoreFields transient;
	self.myCurrentVoyage.myTerminal.myEDIComparisonConfig.ignoreFields.copy(ignoreFields);
	self.getIgnoreFields(ignoreFields);
	
	self.myLLCAgent.reCompareItem(_item.CM_Object, self.myCurrentVoyage, ignoreFields, redisplayEDITIs, app.myPassport); //cnwrs1 CCMS 1137 15 June 2010 put chkIsoGroup in ignoreFields list

	foreach ediTI in redisplayEDITIs do
		self.redisplayItem(ediTI);	
	endforeach;

epilog	
	delete redisplayEDITIs;
	delete ignoreFields;
end;
</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_item" type="Object"/>
    </JadeMethod>
    <JadeMethod name="hideComparisonControls" id="20d8fb2d-e677-4586-a42d-ab11d29ecc4b">
        <updating/>
        <source>hideComparisonControls(_show : Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 November 2009	cnwas3	Initial creation

