<GUIClass name="INV_CashCollectionComments" id="54599790-a8f9-45d7-ba78-fd55b1f74ca1">
    <superclass name="CMUI_Modal"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Used to enter comments for both cash receipts and cash credits.
Called from INV_CashCredit and INV_CashReceiptBOL.</text>
    <ImplicitInverseRef name="lblTitle" id="7596e634-3983-4043-bdd3-2884367fd2de">
        <embedded/>
        <type name="CMUI_Label"/>
    </ImplicitInverseRef>
    <PrimAttribute name="strComments" id="2ee14e0d-4e68-45f4-a3d7-7edf58150d9b">
        <type name="String"/>
    </PrimAttribute>
    <ImplicitInverseRef name="txtComments" id="204aff51-6846-40f6-b03a-ed487133c63d">
        <embedded/>
        <type name="CMUI_TextBox"/>
    </ImplicitInverseRef>
    <JadeMethod name="doOK" id="d1a55f28-2660-4186-ad81-6de1ceb9e99d">
        <updating/>
        <source>doOK() updating;
/*
Purpose:			
Date		Who		Reason
06 May 2015	cnwab1	Initial creation
*/

vars

begin
	strComments := txtComments.text;

	inheritMethod();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="cf68064e-dfa9-42ae-bc0b-a46a4ae7fad2">
        <updating/>
        <source>setupForm() updating;
/*
Purpose:			
Date				Who			Reason
MAY 2015		CNWAB1		Initial creation
*/

vars

begin
	inheritMethod();

	self.handleMenusForModalDisplay();
	
	self.txtComments.text := strComments;
	self.txtComments.setFocus();
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, PmGteCashCollectionMaint) then
		self.btnOk.enabled := false;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="02340c29-30cc-462b-9ead-f71a8a64a1ae">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 07 May 2015.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0020677, locale);
	lblTitle.translateCaption(Xlat_0020678, locale);
end;</source>
    </JadeMethod>
</GUIClass>
