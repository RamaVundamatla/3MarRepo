    <JadeMethod name="setProxyFromObject" id="0c62674f-9202-4693-aca5-ccc3292612de">
        <updating/>
        <source>setProxyFromObject(_object : CM_ISOType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 March 2024	jlier1	Initial creation 62855

*/

vars
	weights : WS_RestWeightObject;
begin
	self.id := _object.code;
	self.description := _object.description;
	if _object.myCargoType &lt;&gt; null then
		self.cargoTypeId:= _object.myCargoType.id.asStringJMT;
	endif;
	if _object.myISOTypeGroup &lt;&gt; null then
		self.groupId:=_object.myISOTypeGroup.code;
	endif;
	self.colour := _object.colour;
	self.flat	:=  _object.isFlat();
	self.reefer := _object.isReefer();
	self.general:= _object.isGeneral;
	create weights transient;
	weights.tare:=_object.tareKilos;
	self.weights:=weights;
epilog

end;</source>
        <Parameter name="_object" type="CM_ISOType"/>
    </JadeMethod>
</Class>
