<Class name="UM_TestRun" id="7e94a2db-9b84-44d9-b011-f83760aa963c">
    <superclass name="UM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="unitTest"/>
    <ExplicitInverseRef name="allTestResults" id="266764db-a1ae-4974-8be5-cbfdb7bb3a51">
        <type name="UM_TestResultsByName"/>
        <access>readonly</access>
        <Inverse name="UM_TestResult::myTestRun"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myRoot" id="2c79d135-3e5e-4e32-a515-5a413ca470ec">
        <kind>child</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="UM_Root"/>
        <access>readonly</access>
        <Inverse name="UM_Root::allTestRuns"/>
    </ExplicitInverseRef>
    <PrimAttribute name="startTimestamp" id="a03b5a0c-b33e-4937-8848-4c2f30114eaa">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="create" id="ba19bec5-f874-4395-9dbb-3cbce457c691">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 February 2011	cnwndl1	Initial creation
// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
*/

vars

	root : UM_Root;

begin

	self.startTimestamp := app.actualTimeServer;// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
	root := UM_Root.firstInstance;
	if root = null then
		create root;
	endif;
	self.myRoot := root;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="fedba74c-0636-4d5b-adab-efa1c3e5c459">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 February 2011	cnwndl1	Initial creation

*/

vars

	test : UM_TestResult;

begin

	foreach test in self.allTestResults do
		delete test;
	endforeach;

epilog

end;</source>
    </JadeMethod>
</Class>
