<Class name="CM_QDateDayLessThan" id="8bd67742-0675-4115-a4f7-bf87a9e5d4d6">
    <superclass name="CM_QueryDateDayOperators"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Days passed less than is  0  means - Today
Days passed less than is  1  means - Yesterday
Days passed less than is  2  means - Day before yesterday

Current day - Days passed less than value = filter date</text>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="820d1d16-63da-430e-810e-306502bb8f0c">
        <updating/>
        <source>create() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
08 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.description := 'Days passed ' &amp; self.Operator_LessThan;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMatch" id="58613c28-c02c-46ef-97d5-f180786eea75">
        <source>doMatch(_value: Any): Boolean;
/*

Purpose:			


Return Value:		


Date		Who		Reason
08 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if not _value.Date.isValid then //par #17512. Ready for 7.7.1
		return false;
	endif;

	return  searchValue.Integer &gt;= (app.actualTimeServer.date - _value.Date);


epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaLineDefinitionForRT" id="54bccb99-123b-4664-82f3-093f59c10ccc">
        <source>getCriteriaLineDefinitionForRT( _prop : CM_QueryProperty;
								_searchValueA, _searchValueB : String output; _searchValueBoolean : Boolean output;
								_isStringProperty, _isStringBetweenProperty, _isBooleanProperty : Boolean output);
// -------------------------------------------
// Created 03 may 2008 by cnwvu1
// -------------------------------------------

vars

begin
	
	_searchValueA			:= self.searchValue.asStringJMT();
	_searchValueB			:= null;
	_searchValueBoolean		:= null;
	_isStringProperty		:= true;
	_isStringBetweenProperty:= false;
	_isBooleanProperty		:= false;
	
end;
</source>
        <Parameter name="_prop" type="CM_QueryProperty"/>
        <Parameter name="_searchValueA" type="String" usage="output"/>
        <Parameter name="_searchValueB" type="String" usage="output"/>
        <Parameter name="_searchValueBoolean" type="Boolean" usage="output"/>
        <Parameter name="_isStringProperty" type="Boolean" usage="output"/>
        <Parameter name="_isStringBetweenProperty" type="Boolean" usage="output"/>
        <Parameter name="_isBooleanProperty" type="Boolean" usage="output"/>
    </JadeMethod>
