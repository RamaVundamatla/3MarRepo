    <JadeMethod name="testLocationYA" id="0b956b0f-6bd5-4b4f-8fa8-56b58630fc67">
        <source>testLocationYA(_yaAgent : CM_YAAutoplanAgent input; _isIn : Boolean) : Boolean;

vars
	ti : CM_TrackedItem;
	
begin
	if _isIn then
		// cnwdad1 03/06/2008 - CCMS #1618.  Mobile Schema has new form(s) to allow devices (such as forklift)
		// to maintain Yard Allocations.
		if self.status = LC_Status_Closed then
			_yaAgent.addLogEntry(AP_Log_YA_Default,self.getFullId() &amp; " rejected because location is closed.", true);
			return false;
		endif;
		
		ti := _yaAgent.getMyCurrentTrackedItem();
		return self.valMoveToForHazTIAutoplan(ti, _yaAgent);
	endif;
	
	return true;
end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <Parameter name="_isIn" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
