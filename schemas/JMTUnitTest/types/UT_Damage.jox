    <JadeMethod name="tAddDamageToCargoTxns" id="08649b1c-2a8a-45af-92ad-91a912ab6429">
        <source>tAddDamageToCargoTxns();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
03 October 2023	navcs2	ChangeRequest 60695: EUP | FR 54536 - Damage and Repair - Transaction Changes

*/

constants
	Cargo_Type		: String = "UTREBAR";
vars
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	bs1				: CM_BlockStack;
	cargoType 		: CM_CargoType;
	ti1,
	pxyTi1			: CM_TrackedItem;
	lc				: CM_LocationsController;
	height			: Integer;
	tis				: CM_TISet;
	expected,
	received, 
	damaged			: Integer;
	damageInstance,
	damage1,
	damage2,
	pDamage1,
	pDamage2		: CM_DamageInstance;
	damageSet		: CM_DamageInstanceSet;
	damagedTxn		: CM_Damage;
	repaired,
	newDamage		: Boolean;
begin
	/*
	Setup section
	*/

	vessel := self.addVesselWithHolds("UT_VDAM", 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc("UT_VDAM", vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	
	bs1 := self.addBlockStack("UTBS1", 9999, null);

	cargoType := app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	
	self.getTerminal.findLocationFromString("UT_VDAM 0101", true, lc, height); 
	
	self.deleteCargo("UTREBAR60695", cargoType);
	
	
	ti1 := self.addCargoBreakBulkAtLocation("UTREBAR60695", cargoType, 50, lc, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator);
	self.opts.addAssoc("TotalWeight", 50);
	self.updateTI(ti1);
	self.assertEqual(ti1.totalQuantity, 50);
	
	// Damage the ti
	self.addDamage(ti1, "BENT", "All", null, 1, "Damage 1");	
	self.addDamage(ti1, "DENT", "Bottom", null, 1, "Damage 2");	

	// Check the ti has been damaged
	damagedTxn := ti1.getLastTransOfClass(CM_Damage).CM_Damage;
	self.assertNotNullMsg(damagedTxn, "Tracked Item does not have a damaged transaction");
	
	// Check a damage location transaction has been created for each damage instance
	damage1 := ti1.allDamageInstances.first;
	damage2	:= ti1.allDamageInstances.last;
	
	self.assertNotNullMsg(damage1.myDamageLocationTrx, "Damage instance 1 damage location transaction");
	self.assertNotNullMsg(damage2.myDamageLocationTrx, "Damage instance 2 damage location transaction");
	
	// Check the transaction and the damage instance match for the first instance
	self.assertEqualMsg(damage1.myDamageDefinition.code, damage1.myDamageLocationTrx.damageDefCode, "The Damage code for damage instance 1 and its transaction do not match");
	self.assertEqualMsg(damage1.myDamageParty.code, damage1.myDamageLocationTrx.damagePartyCode, "The Damage party for damage instance 1 and its transaction do not match");
	self.assertEqualMsg(damage1.myDamagePosition.code, damage1.myDamageLocationTrx.damagePosCode, "The Damage position for damage instance 1 and its transaction do not match");
	self.assertEqualMsg(damage1.myDamagePlace.code, damage1.myDamageLocationTrx.damagePlaceCode, "The Damage place for damage instance 1 and its transaction do not match");
	self.assertEqualMsg(damage1.myDamageReason.code, damage1.myDamageLocationTrx.damageReasonCode, "The Damage reason for damage instance 1 and its transaction do not match");
	self.assertEqualMsg(damage1.myDamageSeverity.code, damage1.myDamageLocationTrx.damageSeverityCode, "The Damage severity for damage instance 1 and its transaction do not match");
	
	// Check the transaction and the damage instance match for the second instance
	self.assertEqualMsg(damage2.myDamageDefinition.code, damage2.myDamageLocationTrx.damageDefCode, "The Damage code for damage instance 2 and its transaction do not match");
	self.assertEqualMsg(damage2.myDamageParty.code, damage2.myDamageLocationTrx.damagePartyCode, "The Damage party for damage instance 2 and its transaction do not match");
	self.assertEqualMsg(damage2.myDamagePosition.code, damage2.myDamageLocationTrx.damagePosCode, "The Damage position for damage instance 2 and its transaction do not match");
	self.assertEqualMsg(damage2.myDamagePlace.code, damage2.myDamageLocationTrx.damagePlaceCode, "The Damage place for damage instance 2 and its transaction do not match");
	self.assertEqualMsg(damage2.myDamageReason.code, damage2.myDamageLocationTrx.damageReasonCode, "The Damage reason for damage instance 2 and its transaction do not match");
	self.assertEqualMsg(damage2.myDamageSeverity.code, damage2.myDamageLocationTrx.damageSeverityCode, "The Damage severity for damage instance 2 and its transaction do not match");
	
	
	/*
	Edit a damage instance but do not repair it
	Update the code and position
	*/
	
	pxyTi1	 	:= app.createUpdateProxy(ti1).CM_TrackedItem;
	pDamage1	:= pxyTi1.allDamageInstancesByPos.first;
	pDamage1.setMyDamageDefinition(app.myRoot.allDamageDefinitionCodes["DENT"]);
	pDamage1.setMyDamagePosition(app.myRoot.allDamagePositionsByCode["Bottom"]);
	repaired 	:= false;
	newDamage	:= false;
	
	app.myTrxUA.trxUpdateDamageInstance(pDamage1, ti1, null, newDamage, repaired, app.myPassport);
	delete pxyTi1;
	
	// Check the damage instance has been changed
	self.assertEqualMsg(damage1.myDamageDefinition.code, "DENT", "The damage code does not match what is expected after edit");
	
	// Check the transaction and the damage instance match for the first instance after the update
	self.assertEqualMsg(damage1.myDamageDefinition.code, damage1.myDamageLocationTrx.damageDefCode, "The Damage code for damage instance 1 and its transaction do not match");
	self.assertEqualMsg(damage1.myDamageParty.code, damage1.myDamageLocationTrx.damagePartyCode, "The Damage party for damage instance 1 and its transaction do not match");
	self.assertEqualMsg(damage1.myDamagePosition.code, damage1.myDamageLocationTrx.damagePosCode, "The Damage position for damage instance 1 and its transaction do not match");
	self.assertEqualMsg(damage1.myDamagePlace.code, damage1.myDamageLocationTrx.damagePlaceCode, "The Damage place for damage instance 1 and its transaction do not match");
	self.assertEqualMsg(damage1.myDamageReason.code, damage1.myDamageLocationTrx.damageReasonCode, "The Damage reason for damage instance 1 and its transaction do not match");
	self.assertEqualMsg(damage1.myDamageSeverity.code, damage1.myDamageLocationTrx.damageSeverityCode, "The Damage severity for damage instance 1 and its transaction do not match");
	
	
	/*
	Repair one of the damage instances
	*/
	repaired 	:= true;
	pxyTi1	 	:= app.createUpdateProxy(ti1).CM_TrackedItem;
	pDamage1	:= pxyTi1.allDamageInstancesByPos.first;
	pDamage1.setStatus(DamageStatusRepaired);
	
	app.myTrxUA.trxUpdateDamageInstance(pDamage1, ti1, null, newDamage, repaired, app.myPassport);
	
	// Check that a repair detail ahs be created for damage instance 1 and that the damage location txn has been logically deleted
	self.assertNotNullMsg(damage1.myRepairDetail, "Repair detail 1");
	self.assertEqualMsg(damage1.myDamageLocationTrx.deleted, true, "Damage instance 1 still has a damage location transaction after repair (it should be logically deleted)");
	self.assertNullMsg(ti1.getLastTransOfClass(CM_Repair), "A repair transaction should not be created yet as both damage instacnes have not been repaired");
	delete pxyTi1;
	
	// Check the ti is still damaged as not all damage instances have been repaired
	self.assertTrueMsg(ti1.damaged, "The tracked item should still be damaged before both damage instances have been repaired");
	
	
	/*
	Repair the second damage instance
	*/
	pxyTi1	 	:= app.createUpdateProxy(ti1).CM_TrackedItem;
	pDamage2	:= pxyTi1.allDamageInstancesByPos.last;
	pDamage2.setStatus(DamageStatusRepaired);
	
	app.myTrxUA.trxUpdateDamageInstance(pDamage2, ti1, null, newDamage, repaired, app.myPassport);
	
	// Check that a repair detail ahs be created for damage instance 2 and that the damage location txn has been logically deleted
	self.assertNotNullMsg(damage2.myRepairDetail, "Repair detail 2");
	self.assertEqualMsg(damage2.myDamageLocationTrx.deleted, true, "Damage instance 2 still has a damage location transaction after repair (it should be logically deleted)");
	self.assertNotNullMsg(ti1.getLastTransOfClass(CM_Repair), "A repair transaction should now be created as the ti should be repaired");
	
	// Check the ti has been repaired
	self.assertFalseMsg(ti1.damaged, "The tracked item should no longer be damaged after both damage instances have been repaired");
epilog
	delete tis;
	delete pxyTi1;
end;</source>
    </JadeMethod>
</Class>
