<CollClass name="CM_LCSet" id="e866e789-f3a5-472f-88e0-7c99c9e414bc">
    <memberType name="CM_LocationsController"/>
    <superclass name="CM_ObjectSet"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="location"/>
    <JadeMethod name="getFullId" id="04609344-b3e9-42ae-a347-c6edb73caa69">
        <source>getFullId( _delim : String ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2017	cnwndl1	Initial creation	TFS 4016

*/

vars

	str : String;
	lc : CM_LocationsController;

begin

	foreach lc in self do
		if str &lt;&gt; null then
			str := str &amp; _delim;
		endif;
		str := str &amp; lc.getFullId();
	endforeach;


	return str;

epilog

end;</source>
        <Parameter name="_delim" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
