    <JadeMethod name="configureCarrier" id="92fb3b68-074c-4d1c-bda8-b23ca3051def">
        <updating/>
        <source>configureCarrier(_exportClass: CM_ExportImportClass io) updating;
/*

Purpose:			

Parameters:			

