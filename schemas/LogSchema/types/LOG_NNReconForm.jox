    <JadeMethod name="toolbarShowCaptions" id="b0ec5e5d-02b5-4b42-a850-3d312ac842ca">
        <updating/>
        <source>toolbarShowCaptions(_showCaptions: Boolean) updating;
//
//17 Jan 2017	cnwrs1	TFS 3137 - resize the find/trplace form when show captions is on
//
vars
	currentHeight : Real;
	newHeight : Real;
	heightDiff : Real;
begin
	currentHeight := self.frmToolbar.height;
	inheritMethod(_showCaptions);
	newHeight := self.frmToolbar.height;
	heightDiff := newHeight - currentHeight;
	self.lblLogVoyage.top := self.lblLogVoyage.top + heightDiff;
	self.lblLot.top := self.lblLot.top + heightDiff;
	self.lblSupplier.top := self.lblSupplier.top + heightDiff;
	self.cmbVoyage.top := self.cmbVoyage.top + heightDiff;
	self.cmbLot.top := self.cmbLot.top + heightDiff;
	self.cmbOperator.top := self.cmbOperator.top + heightDiff;
	self.splMain.top := self.splMain.top + heightDiff;
	self.splMain.height := self.splMain.height - heightDiff;
	self.doResize();
end;
</source>
        <Parameter name="_showCaptions" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="9b8d71b4-68c0-48c5-baa2-e00ae7f02567">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006320, locale);
	btnNext.translateBubbleHelp(Xlat_0006321, locale);
	btnNext.translateCaption(Xlat_0006322, locale);
	btnSelectAllT.translateCaption(Xlat_0002409, locale);
	grpUpdate.translateCaption(Xlat_0002410, locale);
	lblLogVoyage.translateCaption(Xlat_0002411, locale);
	lblLot.translateCaption(Xlat_0002412, locale);
	lblSupplier.translateCaption(Xlat_0002413, locale);
	optKeep.translateCaption(Xlat_0002414, locale);
	optLoad.translateCaption(Xlat_0002415, locale);
	optOffload.translateCaption(Xlat_0002416, locale);
	optReject.translateCaption(Xlat_0002417, locale);
	optReturn.translateCaption(Xlat_0002418, locale);
	optSwap.translateCaption(Xlat_0002419, locale);
end;</source>
    </JadeMethod>
