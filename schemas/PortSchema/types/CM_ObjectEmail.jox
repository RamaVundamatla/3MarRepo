    </JadeMethod>
    <JadeMethod name="delete" id="4a149bdf-bf18-4b12-ab53-de4d2d2053e6">
        <updating/>
        <source>delete() updating;
// cnwrs1 june 2006 was missing
vars
	
begin
	
	self.resetAuditsDuringDelete();	//21 Jan 2021	NDL	TFS 50152
	
	if self.isTransient() then
		delete self.myEmailController;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="f95d05c6-4616-4477-8993-49cad54beceb">
        <source>getAuditText(): String;
//----------------------------------------------------------------
//	Created:	06 March 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	txt		: String;
	str		: String;
begin
	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();
	
	foreach str in self.allIncludedFields do
		//txt := txt &amp; self.getAuditTextForStringArray(self.allIncludedFields);
		txt := txt &amp; 'Email Field ' &amp; str &amp; AuditStringSeparator &amp; '4' &amp; AuditStringSeparator &amp; 'true' &amp; AuditStringSeparator;
	endforeach;
	
	return txt;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBccAddresses" id="84ad193c-526c-4009-a8d8-a397c8533330">
        <source>getBccAddresses(): String;
//----------------------------------------------------------------
//	Created:	24 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if self.myEmailController &lt;&gt; null then
		return self.myEmailController.freeTxtBccAddesses;
	else
		return "";
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
