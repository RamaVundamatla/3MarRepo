    <JadeMethod name="doComplete" id="e4f1a2ca-5035-408b-8d06-4c2b1f024466">
        <source>doComplete():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 July 2011	cnwndl1	Initial creation	Par 26476
19 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
*/

vars

	tiObj 		: CM_TrackedItem;
	operator	: CM_Operator;
	subterminal	: CM_SubTerminal;
	pxyTI		: CM_TrackedItem;
	result		: Integer;
	packRequest : CM_BulkRelease;
	
	errorMess : String;
	childTi : CM_TrackedItem;
	errString : String;

begin

	//pxyTI := app.createUpdateProxy(self.myPackContainer).CM_TrackedItem;
	app.myMobileAgent.setMyProxy( self.myPackContainer );		// 25/1/17 MAP TFS3135 
	pxyTI := app.myMobileAgent.getMyProxyObject().CM_TrackedItem;
	
	operator :=	self.cmbOperator.listObject.CM_Operator;
	if operator &lt;&gt; pxyTI.myOperator then
		pxyTI.zSetPxyOperator(operator);
	endif;
	
	if app.isSubTerminalsOn(self.myTerminal) then
		subterminal	:=	self.cmbSubTerminal.listObject.CM_SubTerminal;
		
		if subterminal &lt;&gt; pxyTI.mySubTerminal then
			pxyTI.zSetPxySubTerminal(subterminal);
		endif;
	endif;
	
	if app.isCargoGroupEnabled then	//14 Dec 2015	NDL	Par 37288
		//its steinweg...  We are going to pass in the pack request to be completed if appropriate.
		packRequest := self.myMobileGenericAgent.myBulkRelease;
		if self.myMobileGenericAgent.myBulkRelease &lt;&gt; null then
			if not packRequest.isPackingType then
				packRequest := null;
			endif;
		endif;
	endif;
	
	//02 Dec 2016	NDL	TFS 2967
	foreach childTi in self.myPackContainer.allChildren do
		if childTi.hasUnactionedDocumentActions(false,false,errString) then // TFS 3972 added warning
			if errorMess &lt;&gt; null then
				errorMess := errorMess &amp; CrLf;
			endif;
			errorMess := errorMess &amp; errString;
		endif;
	endforeach;
	if errorMess &lt;&gt; null then
		if self.msgBox(errorMess, app.getErrorString(SHP_Do_You_Want_To_Continue), MsgBox_Yes_No, false) &lt;&gt; MsgBox_Return_Yes then
			return false;
		endif;
	endif;
	errorMess := null;
	
	while true do
		app.myTrxUA.trxUpdateTIPackComplete(pxyTI, packRequest, null, app.myPassport);		//19.03.2024 navhl20 #62863
		if app.myPassport.trxCompletedOK() then
			// Clear errors/warnings from form and err/warnings window
			app.myPassport.clearErrorsWarnings();
			return true;
			
		else
			result := app.showErrorWarningDialog(app.getErrorString(PackUnpack), app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors()
			and result = IDOK
			then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			break;
		endif;
	endwhile;
	
	return false;
	
epilog

	//delete pxyTI;
	app.myMobileAgent.setMyProxy(null);		// 25/1/17 MAP TFS3135 
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="868c9738-a870-4f0e-b04e-42d7bb705c71">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	tabIndex : Integer;
	stdLeft : Real;
	top : Real;
	stdWidth : Real;
	stdHeight : Real;

begin

	self.setResizeableMarginAndFontSize();
	tabIndex := 4000;
	stdLeft :=  self.resizedMargin;
	top := self.resizedMargin;
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	if _initialSetup then
		self.cmbOperator.setAndIncrementTabIndex( tabIndex );
		self.cmbOperator.visible := true;
	endif;
	self.cmbOperator.move(	stdLeft,
							top,
							stdWidth,
							stdHeight );
	
	top := self.cmbOperator.top + self.cmbOperator.height + self.resizedMargin;
	if _initialSetup then
		self.cmbSubTerminal.setAndIncrementTabIndex( tabIndex );
		self.cmbSubTerminal.visible := true;
	endif;
	self.cmbSubTerminal.move(	stdLeft,
								top,
								stdWidth,
								stdHeight );
								
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="435f03b4-b9f2-4fe5-bcf0-c914195abca7">
        <updating/>
        <source>handleBtnOne() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

	formClassSet : ClassSet;
	checksSubCargo : CM_TrackedItem;
	bulkRelease : CM_BulkRelease;
	retClassWillBe : Class;

begin

	//08 Mar 2017	NDL	TFS 3635
	if self.myMobileGenericAgent.isWaitingOnRequiredChecks(CONT_CHECK_CONTEXT_PACK, self.myPackContainer, checksSubCargo) &lt;&gt; null then //28 May 2010	NDL	Par 23698
		self.handleBtnTwo();
		return;
	endif;

	if self.doComplete() then
		if self.myMobileGenericAgent.myBulkRelease &lt;&gt; null then	//01 Sep 2014	Par 34717 / CCMS 2384
		
			bulkRelease := self.myMobileGenericAgent.myBulkRelease;
			
			self.myMobileGenericAgent.clearAll();
			
			create formClassSet transient;	//18 Aug 2015	NDL	Par 36782
			formClassSet.add( MOB_HHPackRequest );
			formClassSet.add( MOB_HHPackRequestViewSTW );	//12 Apr 2018	NDL	TFS 38083
			formClassSet.add( MOB_HHPackLoadByBAT );
			
			retClassWillBe := self.getSessionAgent.findLastOfInTheStack(formClassSet);
			if retClassWillBe = MOB_HHPackRequestViewSTW then
				self.myMobileGenericAgent.setMyBulkRelease(bulkRelease);
			endif;
			
			self.goBackToFirstOf( formClassSet );
		else
		//	self.goBackToFirst( MOB_HHPackForm );
			self.myMobileGenericAgent.clearAll();
			create formClassSet transient;	//14 Sep 2015	NDL	Par 36900
			formClassSet.add( MOB_HHPackForm );
			formClassSet.add( MOB_HHMultiCargoMovePack );
			self.goBackToFirstOf( formClassSet );
		endif;
	endif;

epilog

	delete formClassSet;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
