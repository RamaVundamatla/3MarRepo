    <JadeMethod name="getExtraInfo" id="51911e8d-7a5b-4bd6-8818-a961c1d77d1a">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
06 January 2023	navcs2	ChangeRequest 56833:[56834] EUP - VAS Train Work Order

*/

vars
	block   	: CM_DataContainerBlock;
	addStr  	: String;
begin
	
	inheritMethod(_dataContainer);
	
	addStr := self.allTrains.listString(Comma,CM_Train::code.name);
	
	if addStr &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Train), DC_Label, 1, self.allTrains.first);
		block.addNewItem(addStr, DC_Data, 1, self.allTrains.first);
	endif;	
epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getMyDebtor" id="6d45a4bb-cb9d-4306-9a02-dab95aa73e9b">
        <source>getMyDebtor() : CM_Debtor;
/*
Purpose:			

Date		Who		Reason
23JUN2023	NAVAB1	 BUG 58790
*/

vars
	debtor : CM_Debtor;
	train : CM_Train;
begin
	 // ### TFS CR 56814 TASK 56813 07JUL2023 NAVAB1
	if self.myDebtor &lt;&gt; null then
		return self.myDebtor;
	endif;

	train := self.allTrains.first;
	if train = null then
		train := self.allTrainsCompleted.first;
	endif;
	
	if train &lt;&gt; null then
		if train.myCarrier &lt;&gt; null then
			debtor := train.myCarrier.myDebtor;
		endif;
	endif;
	
	if debtor = null then
		debtor :=  self.myParent.getMyDebtor();  // ### TFS BUG 58790 23JUN2023 NAVAB1
	endif;
	
	return debtor;
epilog

end;</source>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
