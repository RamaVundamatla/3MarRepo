    <JadeMethod name="addGridController" id="47475693-39eb-4ebe-9702-0d444d329c94">
        <updating/>
        <source>addGridController(_gridController : CM_GridController) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 February 2010	cnwer1	Initial creation

*/

vars
	invalidGridController : Boolean;
begin
	//11/10/2011 cnwdz2 par28354 start
	on Exception do app.handleDeletedObject( exception, _gridController, invalidGridController);
	if _gridController = null then
		return;
	endif;
	_gridController.edition();
	if invalidGridController then
		return;
	endif;
	//11/10/2011 cnwdz2 par28354 end
	
	if not self.allGridControllers.includes(_gridController) then
		self.allGridControllers.add(_gridController);
	endif;
epilog

end;</source>
        <Parameter name="_gridController" type="CM_GridController"/>
    </JadeMethod>
    <JadeMethod name="clearAllGridControllers" id="692a8809-7ea5-4a77-85f4-8d855d53e9e2">
