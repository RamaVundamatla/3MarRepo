    <JadeMethod name="getDisplayStringForAttribute" id="1082e512-1335-4792-9ee3-fbce892ba8c3">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
11 March 2024	navcs2	ChangeRequest 60397: EUP | FR 54085 - Load Confirmation / Goods Receipt - Multiple Move transaction criteria, Event Only Trigger

*/

vars
	terminalAreaType : CM_TerminalAreaType;
begin
	if _attrName = ETRow_FromTerminalAreaType then
		if self.fromTaType = CM_CamsMoveTATypeCritieria.AnyArea then		
			return app.getErrorString(MoveTATypeAnyArea);
		elseif self.fromTaType = CM_CamsMoveTATypeCritieria.VoyageArea then
			return app.getErrorString(MoveTATypeVoyage);
		elseif self.fromTaType = CM_CamsMoveTATypeCritieria.TruckArea then
			return app.getErrorString(MoveTATypeTruck);
		elseif self.fromTaType = CM_CamsMoveTATypeCritieria.WagonLocation then		
			return app.getErrorString(MoveTATypeWagon);
		else
			terminalAreaType := app.myRoot.allTerminalAreaTypes[self.fromTaType];
			return terminalAreaType.description.trimRight;
		endif;

		return null;
	elseif _attrName = ETRow_ToTerminalAreaType then
		if self.toTAType = CM_CamsMoveTATypeCritieria.AnyArea then		
			return app.getErrorString(MoveTATypeAnyArea);
		elseif self.toTAType = CM_CamsMoveTATypeCritieria.VoyageArea then
			return app.getErrorString(MoveTATypeVoyage);
		elseif self.toTAType = CM_CamsMoveTATypeCritieria.TruckArea then
			return app.getErrorString(MoveTATypeTruck);
		elseif self.toTAType = CM_CamsMoveTATypeCritieria.WagonLocation then		
			return app.getErrorString(MoveTATypeWagon);
		else
			terminalAreaType := app.myRoot.allTerminalAreaTypes[self.toTAType];
			return terminalAreaType.description.trimRight;
		endif;

		return null;
	elseif _attrName = ETRow_NotToTAType then
		if self.notToTAType = CM_CamsMoveTATypeCritieria.AnyArea then		
			return app.getErrorString(MoveTATypeAnyArea);
		elseif self.notToTAType = CM_CamsMoveTATypeCritieria.VoyageArea then
			return app.getErrorString(MoveTATypeVoyage);
		elseif self.notToTAType = CM_CamsMoveTATypeCritieria.TruckArea then
			return app.getErrorString(MoveTATypeTruck);
		elseif self.notToTAType = CM_CamsMoveTATypeCritieria.WagonLocation then		
			return app.getErrorString(MoveTATypeWagon);
		elseif self.notToTAType = -1 then
			return null;
		else
			terminalAreaType := app.myRoot.allTerminalAreaTypes[self.notToTAType];
			return terminalAreaType.description.trimRight;
		endif;

		return null;
	endif;
epilog

end;
</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="52475ade-4503-497d-8b69-47844771203c">
        <source>pxyCreateUpdateProxy(): SelfType;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 10 July 2023
TFS#		: 58636
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	proxyCamsMoveTATypeCriteria	: CM_CamsMoveTATypeCritieria;
	completedOK					: Boolean;
begin

	proxyCamsMoveTATypeCriteria:= inheritMethod();
	
	completedOK := true;			
	return proxyCamsMoveTATypeCriteria;
	
epilog
	if not completedOK then			
		delete proxyCamsMoveTATypeCriteria;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
