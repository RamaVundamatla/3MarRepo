    <JadeMethod name="populateJRWReports" id="49e1ff24-f0c3-45b8-95e5-7d7080f6d198">
        <updating/>
        <source>populateJRWReports() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 Dec 2009	cnwphb1	Initial creation
16 Mar 2010 consw1	PAR #23203 - Leaking transients

*/

vars
	transientRep 		: JadeReportWriterReport;
	reportManager		: JadeReportWriterManager;
	folders 			: HugeStringArray;
	names 				: StringArray;
	viewName,
	reportName			: String;
	
begin
	if areReportsPopulated then
		return;
	endif;
	
	create folders transient;
	create names transient;
	create reportManager transient;
	reportManager.getAllReportNames(folders, names);
	
	foreach reportName in names do		
		transientRep := reportManager.getReport(reportName);
		viewName := transientRep.getReportingViewName();		
		if viewName = CM_TrackedItemView then
			self.allJRWReportsTrackedItemView.add(reportName);
		elseif viewName = CM_TransactionView then
			self.allJRWReportsTransactionView.add(reportName);
		endif;
		delete transientRep;
	endforeach;
	
epilog
	self.areReportsPopulated:=true;
	delete transientRep;
	delete reportManager;
	delete names;
	delete folders;
end;
</source>
    </JadeMethod>
    <JadeMethod name="refreshHistoryItem" id="dcb387e6-84e6-4696-b74c-da1b232630bc">
        <source>refreshHistoryItem(_camTaskHistory: CM_CamTaskHistory; _tableRow: Integer);
// ---------------------------------------------------------------------------
// Created:		27 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
//04 May 2016	cnwrs1	Par 37829 single transaction per file not sending output file when the are some discardable transactions
//22 Apr 2020   cnwma1  Bug 49078: MTN - UE Floods 
vars
	table : CM_DataTable;
begin
	
	table := self.myForm.tblDataView1;
	table.setCellText(_tableRow, 1, _camTaskHistory.displayString);     //22.04.2020 cnwma1 #49078
	table.accessRow(_tableRow).itemObject := _camTaskHistory;

	if _camTaskHistory.seqNumber.isEven then
		table.accessRow(_tableRow).backColor := self.myForm.colorRow1;
	else
		table.accessRow(_tableRow).backColor := self.myForm.colorRow2;
	endif;
end;</source>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory"/>
        <Parameter name="_tableRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setAvailableCargoTypes" id="03877eb8-4213-48ed-9dd1-cabbedb2f2cb">
        <source>setAvailableCargoTypes(_camProtocol : CM_CamProtocol; _newProtocolDesc : CM_CamProtocolDesc);
//
// 15 May 2014	cnwrs1	Par 34159 - include Chassis in Codeco
//
// 11 Jun 2014	cnwrs1	Par 34159 - include CargoType in cam protocol
// 20 Jun 2014	cnwrs1	Par 3441 - 1090 when createing a new cam protcocol
vars
	cc : ClassColl;
	cls : Class;
	tmpCargoType	: CM_CargoType;
	availCargoTypeColl : CM_CargoTypesByIdDict;
	protocolDesc : CM_CamProtocolDesc;
begin
	protocolDesc := _newProtocolDesc;
	if protocolDesc = null and
 	   _camProtocol &lt;&gt; null then
		protocolDesc := _camProtocol.protocolDesc;
	endif;
	if protocolDesc = null then
		return;
	endif;
	
	create cc transient;
  	create availCargoTypeColl transient;
	if protocolDesc.type = EDIFileTypeCams_UserDef or
	   protocolDesc.type = EDIFileTypeCams_UserDefEvent then		// ccms 1070 - par 22306 begin
		app.myRoot.allCargoTypesById.copy(availCargoTypeColl);		
		if availCargoTypeColl.size &gt; 0 then
			self.myForm.mulSelect8.setAvailable(availCargoTypeColl, true);   
		endif;
		return;
	endif;
	protocolDesc.availableCargoTypes(cc);
	foreach cls in cc do
		//For each CM_TrackedItem type find all the cargotypes that craete this type of ti
		foreach tmpCargoType in app.myRoot.allCargoTypesById do
			if tmpCargoType.classNameToCreate = cls.name then
				if (not availCargoTypeColl.includes(tmpCargoType)) then
					availCargoTypeColl.add(tmpCargoType);
				endif;
			endif;
		endforeach;
	endforeach;
	self.myForm.mulSelect8.setAvailable(availCargoTypeColl, true);   
epilog
	delete cc;
  	delete availCargoTypeColl;
end;

</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_newProtocolDesc" type="CM_CamProtocolDesc"/>
    </JadeMethod>
    <JadeMethod name="setAvailableEvents" id="35fe064f-562b-47c9-8a86-86e6d2f17101">
        <source>setAvailableEvents(_protocolDesc : CM_CamProtocolDesc);
/*

Purpose: Set up the Available Events for a CAM Protocol			

Parameters:			

Return Value:		

Date		Who		Reason
17 Nov 2014	cnwgb1	Initial creation PAR 35255 CCMS 2405 AST

*/

vars
	events : IntegerArray;
	cls : Class;
	eventType	: CM_EventType;
	eventTypeNum : Integer;
	availEventTypeColl : CM_EventTypeByTypeDict;
begin
  	if _protocolDesc = null then
		return;
	endif;
    
  	create availEventTypeColl transient;
	create events transient;
    
	_protocolDesc.availableEvents(events);
	foreach eventTypeNum in events do
		eventType := app.myRoot.allEventTypesByType[eventTypeNum];
		if eventType &lt;&gt; null then
			if (not availEventTypeColl.includes(eventType)) then
				availEventTypeColl.add(eventType);
			endif;
		endif;
	endforeach;
    
	self.myForm.mulSelect7.setAvailable(availEventTypeColl, true);   
epilog
	delete events;
  	delete availEventTypeColl;
end;</source>
        <Parameter name="_protocolDesc" type="CM_CamProtocolDesc"/>
    </JadeMethod>
    <JadeMethod name="setAvailableTransactions" id="6a97576a-f32b-4305-bb16-b29cd2bcac02">
        <source>setAvailableTransactions(_protocolDesc : CM_CamProtocolDesc);

vars
	cc : ClassColl;
	cls : Class;
	tmpTransType	: CM_TransactionType;
	tmpTransTypeNum : Integer;
	availTransTypeColl : CM_TransactionTypeByType;
begin
  	if _protocolDesc = null then
		return;
	endif;
	create cc transient;
  	create availTransTypeColl transient;
	if _protocolDesc.type = EDIFileTypeCams_UserDef then		// ccms 1070 - par 22306 begin
		app.myRoot.allTransactionTypes.copy(availTransTypeColl);		
		if availTransTypeColl.size &gt; 0 then
			self.myForm.mulSelect2.setAvailable(availTransTypeColl, true);   
		endif;
		return;
	endif;																// ccms 1070 - par 22306 end
	_protocolDesc.availableTransactions(cc);
	foreach cls in cc do
		tmpTransTypeNum := global.getTiTxnTypeForClass(cls);
		//Find the transaction type first to make sure we have something
		tmpTransType := app.myRoot.allTransactionTypes[tmpTransTypeNum];
		if tmpTransType &lt;&gt; null then
			if (not availTransTypeColl.includes(tmpTransType)) then
				availTransTypeColl.add(tmpTransType);
			endif;
		endif;
	endforeach;
	self.myForm.mulSelect2.setAvailable(availTransTypeColl, true);   
epilog
	delete cc;
  	delete availTransTypeColl;
end;
</source>
        <Parameter name="_protocolDesc" type="CM_CamProtocolDesc"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="096d6678-a0df-4761-a8f9-fe34d81579a4">
        <updating/>
        <source>setControlsForAddEdit() updating;
// ---------------------------------------------------------------------------
// Created:     11 September 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
/* Changes

Date		Name	TFS#			Description
============================================================================
18/05/2011	cnwcs5	CCMS SCT 2058 
					/ par 27460  	user defined special charac	ters
19 Apr 2012	cnwrs1	par 29516
15 May 2014	cnwrs1	Par 34159 		include Chassis in Codeco
05 Jun 2014	cnwrs1	Par 34323 		cargo type in Cam Protocol
28 Jun 2016 cnwma1  TFS #2226 		POL - Update to VERMAS structure from Ship Operators
05 Oct 2016	cnwma1	TFS #2712 		CPL - Container Number in VERMAS DOC segment
12 Jul 2017	jlgrs1	TFS 4465 		SNO standard Codedo/Coarri
22 Aug 2017	jlgrs1	TFS 6560 		SNO Damaged/Repair
19 Sep 2017	jlgrs1	TFS 6957 		Codeco/Coarri VGM extra details
18 Dec 2017 jlgrh7 	TFS 7781 		SNO - VERMAS with EDIFACT codes required
12 Nov 2018	jlgsl4	TFS 39345 		SNO - add LOC+7,LOC+PDS/LOC+11 to TDT+30
15 Mar 2019	jlgka1  TFS 41641		SSL - X12 322 Equipment ID Check.
19 Mar 2019	jlgsl4	TFS 41786 		SNO - output DAM segment for Standard Coarri/Codeco
24 Apr 2019 jlgka1	TFS 43785		STWR - CAMS STANDARD CODECO for Non-Structure Voyage.
28 May 2019	jlgsl4	TFS 43706		PEN - output Enhanced Genset segment details
26 Jun 2019	jlgka1	TFS 44737 		PNL Hapag CODECO on Weighing.
11 Mar 2020	jlgdap1	TFS 48785		SNO COARRI Issue
03 Feb 2021	jlgdap1	TFS 50726		GPHA CODECO Message to Differentiate Between Inter-Terminal Transfer and Delivery
29 Mar 2022	jlika1	TFS 53181		GPHA - Voyage Code Translation for Multiple Terminals and Co-Loaders
18 Jul 2022	jlizm1	TFS 54142 		AAT - Add NAD+MS to Standard COARRI SMDG213
07 Jul 2023	jlika1	TFS 58636		EUP - Goods Receipt - Move Transaction area triggers
04 Aug 2023	jlika1	TFS 59582		EUP Goods Receipt - Move Area Type Config - Filter options
27 Sep 2023	navdap1	TSF 60601		EUP | FR 53853 GoodsReceipt - Incorrect UOM Value
============================================================================*/
vars
	theForm : SOP_TableMaintForm;
	time    : Time;	
begin
    theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	theForm.tblInput2.userInputEnabled := true;
	theForm.mulSelect1.userInputEnabled := true;
	theForm.mulSelect2.userInputEnabled := true;
	theForm.mulSelect3.userInputEnabled := true;
	theForm.mulSelect41.userInputEnabled := true;
	theForm.mulSelect42.userInputEnabled := true;
	theForm.mulSelect8.userInputEnabled := true;
	theForm.mulSelIn21.userInputEnabled := true;
	theForm.timelistBox1.enabled := true;
	theForm.btnTimeAdd.enabled := true;
	theForm.btnTimeRemove.enabled := true;
	theForm.txtTimeBox1.enabled := true;
	theForm.txtTimeInterval.enabled := true;	//19 Apr 2012	cnwrs1	Par 29516
	theForm.txtTimeIntStart.enabled := true;
	theForm.txtTimeIntEnd.enabled := true;
	theForm.comboBox1.enabled := true;
//	theForm.chkNonPlanned.enabled := true;	//31 Jan 2018	NDL	TFS 36466
// PAR 33644	theForm.chkNonWorked.enabled := true;
	theForm.chkNullVoyage.enabled := true;
	theForm.chkPandoRInUnPck.enabled := true;
	theForm.chkPandoSntPack.enabled := true;
	theForm.chkPonOperator.enabled := false;
	theForm.chkMSCForNZPOE.enabled := false;
	theForm.chkDaysLookBack.enabled := false;
	theForm.chkTempFormat.enabled := false;
	theForm.chkEDIXlatCtn.enabled	:= true;	// cnwrl1 06/07/2009 PAR 20192 - CCMS 1818
	theForm.chkIncludeChild.enabled	:=	true;	// cnwdad1 26/01/2010 - PAR #22199.
	self.chkReprocessChangeID.enabled := false;
	self.chkHLCSel_Suppress.enabled := false;
	self.chkIncludeChassis.enabled := false;		
	self.chkPackUnpackStatusChange.enabled := false;		
	self.chkIncludeRestowShifter.enabled := false;		
	self.chkCOARRIBGM.enabled := false;			//cnwmc5 - 4 Feb 2016 - PAR 37503
	self.chkCOARRIBGM4446.enabled := false;		//26Jan2023 navsp1 TFS 56282
	self.chkVERMASNAD.enabled := false;          //28/06/2016 cnwma1 TFS #2226 
	self.chkVERMASDOC.enabled := false;			// 05/10/2016 cnwma1 TFS #2712
	self.lblBGMDamCode.enabled := false;
	self.txtBGMDamCode.enabled := false;
	self.lblBGMRepCode.enabled := false;
	self.txtBGMRepCode.enabled := false;
	self.chkIncludeExtraVGM.enabled := false;
	// jlgka1 TFS 44737 --&gt;
	self.lblVGMBGMMsgCode.enabled := false;
	self.txtVGMBGMMsgCode.enabled := false;
	// jlgka1 TFS 44737 &lt;--
	theForm.chkCliRefBooking.enabled := false; // cnwrd par 34369
	self.chkTShipImports.enabled := false;			// TFS 48785

	theForm.chkSendCarrier.enabled	:= false;	// par 27460 cnwcs5
	theForm.chkUseCarrierRef.enabled	:= false;	// par 27460 cnwcs5
	theForm.lblDelayMins.enabled	:= false;	//08 Sep 2015	NDL	Par 36876
	theForm.txtDelayMins.enabled	:= false;	//08 Sep 2015	NDL	Par 36876
	
	theForm.chkRelaxedIdChecking.enabled := false; //jlgka1 TFS 41641
	theForm.chkUseCodecoNonStruc.enabled := false; //jlgka1 TFS 43785
	theForm.chkDGSDetailsInGroup14.enabled := false; //JIRA-20814
	theForm.shtViewTable1.enabled := false;
	
	theForm.shtViewTable2.enabled := false;
	
	theForm.txtDateStart.enabled := false;
	theForm.txtDateEnd.enabled := false;
	theForm.txtTimeStart.enabled := false;
	theForm.txtTimeEnd.enabled := false;
	theForm.btnRunAdhoc.enabled := false;
	theForm.cmbMul7.enabled:=true;
	theForm.cmbCargoType2.enabled:=true;
	theForm.btnTransactionFilter.enabled := false;
	self.chkVERMASVer10.enabled := false;					///+TFS7781
	self.chkCoarri95BLocPDS.enabled := false;	// TFS 39345
	self.chkProduceDAMSegment.enabled := false; // TFS 41786
	self.chkEnhancedGensetInfo.enabled := false; // TFS 43706
	self.chkIncludeRFFBM162.enabled := false;	//26 Jan 2021	NDL	TFS 50708
	self.chkIncludeLOC7InterTerm.enabled := false;		// TFS 50726
	self.chkIsCustomsProtocol.enabled := false;		// TFS 53181
	self.chkIncludeNADMSForSMDG213.enabled := false; // TFS 54142
	
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput2.clearValues;
		theForm.cmbCamGroup.setObject(null);
		theForm.cmbConsignee.setObject(null);
		theForm.cmbEmailAddress.setObject(null);
		theForm.cmbCamProtDesc.setObject(null);
		theForm.myAssistant.comboBoxOperator(theForm.cmbOperator,null,null);	//15 May 2012	NDL	Par 29529
//		theForm.cmbFTPEntity.setObject(null);	// CCMS 1143 cnwrs1 10 Aug 2010
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.setValueByName(ETRow_FirstRunTime, time.String);
		theForm.tblInput1.setValueByName(ETRow_LastRunTime, time.String);
		theForm.tblInput1.setValueByName(ETRow_FirstRunDate,"");
		theForm.tblInput1.setValueByName(ETRow_LastRunDate,"");
		//theForm.tblInput1.setValueByName(ETRow_LogExcludeTransactions,true);
		//ccms 1535
		theForm.tblInput2.enableRowByName(ETRow_TerminalActivity);
		theForm.tblInput2.enableRowByName(ETRow_DepotActivity);
		theForm.tblInput2.enableRowByName(ETRow_PackGateInFull);
		theForm.tblInput2.enableRowByName(ETRow_PackGateOutMT);
		theForm.tblInput2.enableRowByName(ETRow_UnpackGateInMT);
		theForm.tblInput2.enableRowByName(ETRow_UnpackGateOutFull);
		
		theForm.mulSelect1.setSelected(null);
		theForm.mulSelect2.setAvailable(null, true);
		theForm.mulSelect2.setSelected(null);
		theForm.mulSelect3.setSelected(null);
		theForm.mulSelect6.setSelected(null);
		theForm.mulSelect7.setSelected(null);	// PAR 21905 CCMS MES 1008 - PHB
		theForm.mulSelect8.setAvailable(null, true);
		theForm.mulSelect8.setSelected(null);
		theForm.mulSelIn21.setSelected(null);
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		self.txtBGMDamCode.text := null;
		self.txtBGMRepCode.text := null;
		if theForm.myProxyObject.isKindOf(CM_CamProtocol) and (theForm.myProxyObject.CM_CamProtocol.isGoodsReceipt() or theForm.myProxyObject.CM_CamProtocol.isLoadConfirmation()) then	
			if theForm.myProxyObject.CM_CamProtocol.hasMoveTransaction() then	
				theForm.btnTransactionFilter.visible := true;
			else
				theForm.btnTransactionFilter.visible := false;
			endif;
		else
			theForm.btnTransactionFilter.visible := false;
		endif;
		theForm.loadCmbWebService();			// TFS 60601
	else
		self.showThumbnail(theForm.myProxyObject.CM_CamProtocol);
		self.setEnableObjects(theForm.myProxyObject.CM_CamProtocol.protocolDesc);
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="885f0ee1-e687-48cd-bf65-2151e3f503be">
        <updating/>
        <source>setCtrlsForView() updating;
// ---------------------------------------------------------------------------
// Created:     11 September 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
/* Changes

Date		Name	TFS#			Description
============================================================================
18/05/2011	cnwcs5	CCMS SCT 2058 
					/ par 27460 	user defined special charac	ters
19 Apr 2012	cnwrs1	par 29516
15 May 2014	cnwrs1	Par 34159 		include Chassis in Codeco
28 Jun 2016 cnwma1  TFS #2226 		POL - Update to VERMAS structure from Ship Operators
05 Oct 2016	cnwma1	TFS #2712 		CPL - Container Number in VERMAS DOC segment
13 Dec 2016 cnwma1	TFS #2801*		Special Protocol Settings sheet display issues 
12 Jul 2017	jlgrs1	TFS 4465 		SNO standard Codedo/Coarri
22 Aug 2017	jlgrs1	TFS 6560 		SNO Damaged/Repair
19 Sep 2017	jlgrs1	TFS 6957 		Codeco/Coarri VGM extra details
18 Dec 2017 jlgrh7 	TFS 7781 		SNO - VERMAS with EDIFACT codes required
12 Nov 2018	jlgsl4	TFS 39345 		SNO - add LOC+7,LOC+PDS/LOC+11 to TDT+30
15 Mar 2019	jlgka1  TFS 41641		SSL - X12 322 Equipment ID Check.
19 Mar 2019	jlgsl4	TFS 41786 		SNO - output DAM segment for Standard Coarri/Codeco
24 Apr 2019 jlgka1	TFS 43785		STWR - CAMS STANDARD CODECO for Non-Structure Voyage.
28 May 2019	jlgsl4	TFS 43706		PEN - output Enhanced Genset segment details
26 Jun 2019	jlgka1	TFS 44737 		PNL Hapag CODECO on Weighing.
11 Mar 2020	jlgdap1	TFS 48785		SNO COARRI Issue
03 Feb 2021	jlgdap1	TFS 50726		GPHA CODECO Message to Differentiate Between Inter-Terminal Transfer and Delivery
29 Mar 2022	jlika1	TFS 53181		GPHA - Voyage Code Translation for Multiple Terminals and Co-Loaders
18 Jul 2022	jlizm1	TFS 54142 		AAT - Add NAD+MS to Standard COARRI SMDG213
07 Jul 2023	jlika1	TFS 58636		EUP - Goods Receipt - Move Transaction area triggers
04 Aug 2023	jlika1	TFS 59582		EUP Goods Receipt - Move Area Type Config - Filter options
============================================================================*/
vars
	theForm : SOP_TableMaintForm;
begin
	inheritMethod();
    theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := false;
	theForm.tblInput2.userInputEnabled := false;
//	theForm.txtCamFirstTime.enabled := false;
//	theForm.txtCamFirstTime.readOnly := true;
	theForm.comboBox1.enabled := false;
	theForm.shtViewTable1.enabled := true;
	theForm.shtViewTable2.visible := false;
	theForm.tblDataView1.readOnly := false;
	theForm.tblDataView1.visible := true;
	theForm.tblView1.visible := false;

// cnwdad1 17/09/2010, commented out because you can't scroll when not in edit mode.
//	theForm.timelistBox1.enabled := false;	
	theForm.btnTimeAdd.enabled := false;
	theForm.btnTimeRemove.enabled := false;
	theForm.txtTimeBox1.enabled := false;
	theForm.txtTimeInterval.enabled := false;	//19 Apr 2012	cnwrs1	Par 29516
	theForm.txtTimeIntStart.enabled := false;
	theForm.txtTimeIntEnd.enabled := false;


//	theForm.chkNonPlanned.enabled := false;
// PAR 33644	theForm.chkNonWorked.enabled := false;
	theForm.chkNullVoyage.enabled := false;
	theForm.chkPandoRInUnPck.enabled := false;
	theForm.chkPandoSntPack.enabled := false;
	theForm.chkPonOperator.enabled := false;
//	theForm.chkFullsOnly.enabled := false;
//	theForm.chkMTsOnly.enabled := false;
	theForm.chkMSCForNZPOE.enabled := false;
	theForm.chkDaysLookBack.enabled := false;
	theForm.chkTempFormat.enabled := false;
	theForm.chkEDIXlatCtn.enabled	:= false;		// cnwrl1 06/07/2009 PAR 20192 - CCMS 1818
	theForm.chkIncludeChild.enabled	:=	false;		// cnwdad1 26/01/2010 - PAR #22199.
	self.chkReprocessChangeID.enabled := false;
	self.chkHLCSel_Suppress.enabled := false;
	self.chkIncludeChassis.enabled := false;
	self.chkPackUnpackStatusChange.enabled := false;
	self.chkIncludeRestowShifter.enabled := false;
	self.chkCOARRIBGM.enabled := false;			//cnwmc5 - 4 Feb 2016 - PAR 37503
	self.chkCOARRIBGM4446.enabled := false; 	//26Jan2023 navsp1 TFS 56282
	self.chkVERMASNAD.enabled := false;     //28/06/2016 cnwma1 TFS #2226 
	self.chkVERMASDOC.enabled := false;	   // 05/10/2016 cnwma1 TFS #2712
	self.chkVERMASVer10.enabled := false;				//+TFS7781
	self.chkCoarri95BLocPDS.enabled := false;	// TFS 39345
	self.chkProduceDAMSegment.enabled := false; // TFS 41786
	self.chkEnhancedGensetInfo.enabled := false; // TFS 43706
	self.lblBGMDamCode.enabled := false;
	self.txtBGMDamCode.enabled := false;
	self.lblBGMRepCode.enabled := false;
	self.txtBGMRepCode.enabled := false;
	self.chkIncludeExtraVGM.enabled := false;
	//jlgak1 TFS 44737 --&gt;
	self.lblVGMBGMMsgCode.enabled := false;
	self.txtVGMBGMMsgCode.enabled := false;
	//jlgak1 TFS 44737 &lt;--
	self.chkTShipImports.enabled := false;			// TFS 48785
	theForm.chkSendCarrier.enabled		:= false;	// par 27460 cnwcs5
	theForm.chkUseCarrierRef.enabled	:= false;	// par 27460 cnwcs5
	theForm.lblDelayMins.enabled	:= false;	//08 Sep 2015	NDL	Par 36876
	theForm.txtDelayMins.enabled	:= false;	//08 Sep 2015	NDL	Par 36876
	theForm.chkRelaxedIdChecking.enabled := false; //jlgka1 TFS 41641
	theForm.chkUseCodecoNonStruc.enabled := false; //jlgka1 TFS 43785
	theForm.chkDGSDetailsInGroup14.enabled := false; //JIRA-20814
	//31 Jan 2017	NDL	TFS 36466 - removed
//	theForm.lblDelayMins.top:=362;
//	theForm.lblDelayMins.left :=34;				//13/12/2016 cnwma1	 TFS #2801
	theForm.txtDelayMins.maxLength :=2;			//13/12/2016 cnwma1	 TFS #2801
//	theForm.txtDelayMins.width :=20;			//13/12/2016 cnwma1	 TFS #2801
//	theForm.txtDelayMins.top :=362;
	theForm.chkCliRefBooking.enabled := false; // cnwrd par 34369
	self.chkIncludeRFFBM162.enabled := false;	//26 Jan 2021	NDL	TFS 50708
	self.chkIncludeLOC7InterTerm.enabled := false;		// TFS 50726
	self.chkIsCustomsProtocol.enabled := false;		// TFS 53181
	self.chkIncludeNADMSForSMDG213.enabled := false;	// TFS 54142
	
	//correct
	theForm.txtDateStart.enabled := true;
	theForm.txtDateEnd.enabled := true;
	theForm.txtTimeStart.enabled := true;
	theForm.txtTimeEnd.enabled := true;
	theForm.btnRunAdhoc.enabled := true;
	
	theForm.cmbMul7.enabled:=false;
	theForm.cmbCargoType2.enabled:=false;
	theForm.btnTransactionFilter.enabled := true;
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(theForm.myTerminal, self.permissionMaint) then
		theForm.frmAdhoc.enabled := false;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setEnableObjects" id="247309e5-1cac-42b1-9f0c-97fc77ccb70f">
        <updating/>
        <source>setEnableObjects(pCamProtocolDesc: CM_CamProtocolDesc) updating;
// ---------------------------------------------------------------------------
// Created:     19 September 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
/* Changes

Date		Name	TFS#			Description
============================================================================
18/05/2011	cnwcs5	CCMS SCT 2058 
					/ par 27460 	user defined special charac	ters
15 May 2014	cnwrs1	Par 34159 		include Chassis in Codeco
28 Jun 2016 cnwma1  TFS #2226 		POL - Update to VERMAS structure from Ship Operators
05 Oct 2016	cnwma1	TFS #2712 		CPL - Container Number in VERMAS DOC segment
12 Jul 2017	jlgrs1	TFS 4465 		SNO standard Codedo/Coarri
22 Aug 2017	jlgrs1	TFS 6560 		SNO Damaged/Repair
19 Sep 2017	jlgrs1	TFS 6957 		Codeco/Coarri VGM extra details
18 Dec 2017 jlgrh7 	TFS 7781 		SNO - VERMAS with EDIFACT codes required
12 Nov 2018	jlgsl4	TFS 39345 		SNO - add LOC+7,LOC+PDS/LOC+11 to TDT+30
15 Mar 2019	jlgka1  TFS 41641		SSL - X12 322 Equipment ID Check.
19 Mar 2019	jlgsl4	TFS 41786 		SNO - output DAM segment for Standard Coarri/Codeco.
24 Apr 2019 jlgka1	TFS 43785		STWR - CAMS STANDARD CODECO for Non-Structure Voyage.
28 May 2019	jlgsl4	TFS 43706		PEN - output Enhanced Genset segment details
26 Jun 2019	jlgka1	TFS 44737 		PNL Hapag CODECO on Weighing.
11 Mar 2020	jlgdap1	TFS 48785		SNO COARRI Issue
03 Feb 2021	jlgdap1	TFS 50726		GPHA CODECO Message to Differentiate Between Inter-Terminal Transfer and Delivery
29 Mar 2022	jlika1	TFS 53181		GPHA - Voyage Code Translation for Multiple Terminals and Co-Loaders
18 Jul 2022	jlizm1	TFS 54142 		AAT - Add NAD+MS to Standard COARRI SMDG213
============================================================================*/
vars
	theForm			: SOP_TableMaintForm;
	camProtocolDesc	: CM_CamProtocolDesc;
	theObj			: Object;
begin
	camProtocolDesc := pCamProtocolDesc;
  	theForm := self.myForm;
  	
  	theForm.shtMultiSelect3.enabled := false;
	theForm.chkNullVoyage.enabled := false;
//	theForm.chkNonPlanned.enabled := false;
// PAR 33644	theForm.chkNonWorked.enabled := false;
	theForm.chkPandoRInUnPck.enabled := false;
	theForm.chkPandoSntPack.enabled := false;
	theForm.chkPonOperator.enabled := false;
	theForm.chkMSCForNZPOE.enabled := false;
	theForm.chkDaysLookBack.enabled := false;
	theForm.chkTempFormat.enabled := false;
	theForm.chkEDIXlatCtn.enabled	:= false;	// cnwrl1 06/07/2009 PAR 20192 - CCMS 1818
	theForm.chkIncludeChild.enabled	:=	false;	// cnwdad1 26/01/2010 - PAR #22199.

	theForm.chkCliRefBooking.enabled := false; // cnwrd par 34369
	
	theForm.chkSendCarrier.enabled		:= false;	// par 27460 cnwcs5
	theForm.chkUseCarrierRef.enabled	:= false;	// par 27460 cnwcs5
	theForm.lblDelayMins.enabled	:= false;	//08 Sep 2015	NDL	Par 36876
	theForm.txtDelayMins.enabled	:= false;	//08 Sep 2015	NDL	Par 36876
	
	theForm.chkRelaxedIdChecking.enabled := false; //jlgka1 TFS 41641
	theForm.chkUseCodecoNonStruc.enabled := false; //jlgka1 TFS 43785
	theForm.chkDGSDetailsInGroup14.enabled := false; //JIRA-20814
	
	self.chkReprocessChangeID.enabled := false;
	self.chkHLCSel_Suppress.enabled := false;
	self.chkIncludeChassis.enabled := false;
	self.chkPackUnpackStatusChange.enabled := false;
	self.chkIncludeRestowShifter.enabled := false;
	self.chkCOARRIBGM.enabled := false;			//cnwmc5 - 4 Feb 2016 - PAR 37503
	self.chkCOARRIBGM4446.enabled := false;		//26Jan2023 navsp1 TFS 56282
	self.chkVERMASNAD.enabled := false;          //28/06/2016 cnwma1 TFS #2226 
	self.chkVERMASDOC.enabled := false;			// 05/10/2016 cnwma1 TFS #2712
	self.chkVERMASVer10.enabled :=false;		//+TFS7781
	self.chkCoarri95BLocPDS.enabled := false;	// TFS 39345
	self.chkProduceDAMSegment.enabled := false; // TFS 41786
	self.chkEnhancedGensetInfo.enabled := false; // TFS 43706
	self.lblBGMDamCode.enabled := false;
	self.txtBGMDamCode.enabled := false;
	self.lblBGMRepCode.enabled := false;
	self.txtBGMRepCode.enabled := false;
	self.chkIncludeExtraVGM.enabled := false;
	//jlgka1 TFS 44737 --&gt;
	self.lblVGMBGMMsgCode.enabled := false;
	self.txtVGMBGMMsgCode.enabled := false;
	//jlgka1 TFS 44737 &lt;--
	self.chkTShipImports.enabled := false;		// TFS 48785
	self.chkIncludeRFFBM162.enabled := false;	//26 Jan 2021	NDL	TFS 50708
	self.chkIncludeLOC7InterTerm.enabled := false;		// TFS 50726
	self.chkIsCustomsProtocol.enabled := false;		// TFS 53181
	self.chkIncludeNADMSForSMDG213.enabled := false;	// TFS 54142
	
	theObj := theForm.myCurrentObject;
	if theObj &lt;&gt; null and theObj.CM_CamProtocol.status = CAM_HOLDSTATUS then
		//allow adhoc run
		theForm.txtDateStart.enabled := true;
		theForm.txtDateEnd.enabled := true;
		theForm.txtTimeStart.enabled := true;
		theForm.txtTimeEnd.enabled := true;
		theForm.btnRunAdhoc.enabled := true;
	else	
		theForm.txtDateStart.enabled := false;
		theForm.txtDateEnd.enabled := false;
		theForm.txtTimeStart.enabled := false;
		theForm.txtTimeEnd.enabled := false;
		theForm.btnRunAdhoc.enabled := false;
	endif;
	
	if camProtocolDesc &lt;&gt; null then
		theForm.shtSingleSelect2.enabled := true; //cnwgb1 PAR 26559 29.12.2010
		if camProtocolDesc.isCoarri then
			theForm.shtMultiSelect3.enabled := true;
		elseif camProtocolDesc.isPandoIntracon then
			theForm.shtMultiSelect3.enabled := true;
			if theForm.cmbCamGroup.myObject &lt;&gt; null then 
				theForm.shtMultiSelect4.enabled := true;
			endif;
		endif;
	endif;

	// call this to set the check boxes correctly if
	// the special protocol sheet is the top sheet
	self.sheetChange(theForm.fldInput);

end;</source>
        <Parameter name="pCamProtocolDesc" type="CM_CamProtocolDesc"/>
    </JadeMethod>
    <JadeMethod name="setLocalControlsOnForm" id="4f234446-e81e-4872-8411-17a8afa54a8e">
        <source>setLocalControlsOnForm( theForm	: SOP_TableMaintForm input );
/*

Purpose:			The place where we do the base stuff to controls that have
					been created locally on this SOPTM instead of the on the form....
					Migrated from initShtMultiSelect as part of TFS 36466
					
					Do the re-positioning of these controls in SOP_TableMaintForm::initShtMultiSelect
					NOT here or anywhere else... 

Parameters:			

Return Value:		

/* Changes

Date		Name	TFS#		Description
============================================================================
31 Jan 2018	jlgndl1	TFS 36466	Initial creation
12 Nov 2018	jlgsl4	TFS 39345 	SNO - add LOC+7,LOC+PDS/LOC+11 to TDT+30
19 Mar 2019	jlgka1  TFS 41641 	Change the bottom controller from self.chkIncludeExtraVGM 
								to form.chkRelaxedIdChecking. Adjust the picture scroll bar.
19 Mar 2019	jlgsl4	TFS 41786 	SNO - output DAM segment for Standard Coarri/Codeco.					
24 Apr 2019 jlgka1	TFS 43785	STWR - CAMS STANDARD CODECO for Non-Structure Voyage.
28 May 2019	jlgsl4	TFS 43706	PEN - output Enhanced Genset segment details
26 Jun 2019	jlgka1	TFS 44737 	PNL Hapag CODECO on Weighing.
11 Mar 2020	jlgdap1	TFS 48785	SNO COARRI Issue
03 Feb 2021	jlgdap1	TFS 50726	GPHA CODECO Message to Differentiate Between Inter-Terminal Transfer and Delivery
29 Mar 2022	jlika1	TFS 53181	GPHA - Voyage Code Translation for Multiple Terminals and Co-Loaders
18 Jul 2022	jlizm1	TFS 54142 	AAT - Add NAD+MS to Standard COARRI SMDG213
============================================================================*/
begin

	self.chkReprocessChangeID.parent := theForm.picSingleSelect2;  //13/12/2016 cnwma1	 TFS #2801
	self.chkReprocessChangeID.visible := true;
	if self.chkReprocessChangeID.form = null then
		theForm.addControl(self.chkReprocessChangeID);
	endif;
	
	self.chkHLCSel_Suppress.parent := theForm.picSingleSelect2;   //13/12/2016 cnwma1	 TFS #2801
	self.chkHLCSel_Suppress.visible := true; 
	if self.chkHLCSel_Suppress.form = null then
		theForm.addControl(self.chkHLCSel_Suppress);
	endif;
	
	self.chkIncludeChassis.parent := theForm.picSingleSelect2;   //13/12/2016 cnwma1	 TFS #2801
	self.chkIncludeChassis.visible := true;
	if self.chkIncludeChassis.form = null then
		theForm.addControl(self.chkIncludeChassis);
	endif;
	
	self.chkCOARRIBGM.parent := theForm.picSingleSelect2;   //13/12/2016 cnwma1	 TFS #2801
	self.chkCOARRIBGM.visible := true;
	if self.chkCOARRIBGM.form = null then
		theForm.addControl(self.chkCOARRIBGM);
	endif;
	
	self.chkCOARRIBGM4446.parent := theForm.picSingleSelect2;   // 26Jan2023 navsp1 TFS 56282
	self.chkCOARRIBGM4446.visible := true;
	if self.chkCOARRIBGM4446.form = null then
		theForm.addControl(self.chkCOARRIBGM4446);
	endif;
	
	self.chkVERMASNAD.parent := theForm.picSingleSelect2;    //13/12/2016 cnwma1	 TFS #2801
	self.chkVERMASNAD.visible := true;
	if self.chkVERMASNAD.form = null then
		theForm.addControl(self.chkVERMASNAD);
	endif;
	
	self.chkVERMASDOC.parent := theForm.picSingleSelect2;   //13/12/2016 cnwma1	 TFS #2801
	self.chkVERMASDOC.visible := true;
	if self.chkVERMASDOC.form = null then
		theForm.addControl(self.chkVERMASDOC);
	endif;

	self.chkPackUnpackStatusChange.parent := theForm.picSingleSelect2;
	self.chkPackUnpackStatusChange.visible := true;
	if self.chkPackUnpackStatusChange.form = null then
		theForm.addControl(self.chkPackUnpackStatusChange);
	endif;

	self.chkIncludeRestowShifter.parent := theForm.picSingleSelect2;
	self.chkIncludeRestowShifter.visible := true;
	if self.chkIncludeRestowShifter.form = null then
		theForm.addControl(self.chkIncludeRestowShifter);
