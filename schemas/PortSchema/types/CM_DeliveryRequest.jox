    <JadeMethod name="doUpdateAuditing" id="f14ffddc-ebe4-456a-95e4-630a47834ee3">
        <source>doUpdateAuditing(pBulkRelease: CM_BulkRelease; pProxyRequest: CM_DeliveryRequest);
// ---------------------------------------------------------------------------
// Created:     23 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	int : Integer;
	oldGrades, newGrades : String;
begin

	inheritMethod(pBulkRelease, pProxyRequest);

	//if self.availabilityGrade &lt;&gt; pProxyRequest.availabilityGrade then
	//	app.myAA.auditUpdate(pBulkRelease, "availabilityGrade", self.availabilityGrade);
	//endif;
	
	if self.allAvailabilityGrades.size &gt; 0 then
		foreach int in self.allAvailabilityGrades do
			oldGrades := oldGrades &amp; ", " &amp; int.String;
		endforeach;
	endif;
	if pProxyRequest.allAvailabilityGrades.size &gt; 0 then
		foreach int in pProxyRequest.allAvailabilityGrades do
			newGrades := newGrades &amp; ", " &amp; int.String;	
		endforeach;
	endif;
	
	if oldGrades &lt;&gt; newGrades then
		app.myAA.auditUpdate(pBulkRelease, "availabilityGrade", newGrades);	
	endif;
	
	if self.clean &lt;&gt; pProxyRequest.clean then
		app.myAA.auditUpdate(pBulkRelease, "clean", self.clean);
	endif;

	if self.doISOGroupCheck &lt;&gt; pProxyRequest.doISOGroupCheck then
		app.myAA.auditUpdate(pBulkRelease, "doISOGroupCheck", self.doISOGroupCheck);
	endif;

	if self.heavyRated &lt;&gt; pProxyRequest.heavyRated then
		app.myAA.auditUpdate(pBulkRelease, "heavyRated", self.heavyRated);
	endif;

	if self.isoType &lt;&gt; pProxyRequest.isoType then
		app.myAA.auditUpdate(pBulkRelease, "isoType", self.isoType);
	endif;
	
	//10 May 2010	NDL Par 24064
	if self.isoGroup &lt;&gt; pProxyRequest.isoGroup then
		app.myAA.auditUpdate(pBulkRelease, "isoGroup", self.isoGroup);
	endif;

	if self.operatorCode &lt;&gt; pProxyRequest.operatorCode then
		app.myAA.auditUpdate(pBulkRelease, "operatorCode", self.operatorCode);
	endif;

	if self.totalRequested &lt;&gt; pProxyRequest.totalRequested then
		app.myAA.auditUpdate(pBulkRelease, "totalRequested", self.totalRequested);
	endif;

end;</source>
        <Parameter name="pBulkRelease" type="CM_BulkRelease"/>
        <Parameter name="pProxyRequest" type="CM_DeliveryRequest"/>
    </JadeMethod>
    <JadeMethod name="getAVGrade" id="eaed70e1-c9ae-4b45-9d42-6ccac9d0bc91">
        <source>getAVGrade(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 August 2010	cnwrd1	Initial creation
//cnwrd1 par 25441 17.8.2010
*/

vars
	str 			: String;
	tmpAvailCode 	: Integer;
	tmpAvail		: CM_MTGrade;
	operator 		: CM_Operator;
	code			: CM_MTGradeCode ;
	canDisplay		: Boolean;
	sep				: String;
begin

	if self.operatorCode &lt;&gt; null then
		operator := app.myRoot.allOperators[self.operatorCode];
	endif;
		
			
	foreach tmpAvailCode in  self.allAvailabilityGrades do
		tmpAvail := app.myRoot.allAvailabilityGrades[tmpAvailCode];
		if tmpAvail &lt;&gt; null then
			if operator &lt;&gt; null then
				tmpAvail.getTranslationForOperator(tmpAvail, operator, null, code, canDisplay);
			endif;
			if code &lt;&gt; null then
				str := str &amp; sep &amp;  code.description  ;
				sep := ',';
			elseif canDisplay then
				str := str  &amp; sep &amp;  tmpAvail.description.String ;
				sep := ',';
			endif;
		endif;
	endforeach;

	return str;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAvailabilityGrades" id="745aedce-46ee-47b8-ab1e-192bdda5d366">
        <source>getAvailabilityGrades():String;

vars
	numGrades, i : Integer;
	grade      : Integer;
	gradesDesc,desc  : String;
	obj        : CM_MTGrade;
begin

	if allAvailabilityGrades.size&lt;=0 then
		return null;
	endif;
	numGrades := self.allAvailabilityGrades.size;
	foreach i in 1 to numGrades do
	    grade := self.allAvailabilityGrades.at(i);	  
        obj := app.myRoot.allAvailabilityGrades[grade];
        if obj&lt;&gt;null then
			desc := obj.description.trimBlanks; 
			//gradesDesc := desc &amp; "," &amp; gradesDesc ;
			//02 Aug 2017	NDL	TFS 5652
			if gradesDesc &lt;&gt; null then
				gradesDesc := gradesDesc &amp; ", ";
			endif;
			gradesDesc := gradesDesc &amp; desc;
        endif;
	endforeach;
	return gradesDesc;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
