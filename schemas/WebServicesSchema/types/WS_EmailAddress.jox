<Class name="WS_EmailAddress" id="3a200837-7f48-42ba-9e3a-1c90edb938da">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>The Email Address ,contact information about e-mail addresses.</text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="emailAddress" id="8621c73f-bb28-4b92-8eb3-5bdb5cb5f7f2">
        <type name="String"/>
        <access>readonly</access>
        <text>A Valid e-mail address.</text>
    </PrimAttribute>
    <PrimAttribute name="name" id="4dfa5862-6b41-485e-8b79-466357841ccd">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>Email address name </text>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="040a8763-09e4-4e81-bc76-c8fd4bc89a4f">
        <updating/>
        <source>setProxyFromObject(_object: CM_EmailEntity) updating;

/*

Date		Who		Reason
27 Jan 2009	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars
	name,
	userPrefix		: String;
	prefixLength	: Integer;
	user			: CM_User;
	
begin
	inheritMethod(_object);

	name := _object.name;
	
	// Strip the user prefix from the name before returning it
	user := app.getMyUser();
	if user &lt;&gt; null then
		userPrefix := app.getMyUser().code &amp; "_";
		prefixLength := userPrefix.length;
		if name.length &gt; prefixLength and name[1:prefixLength] = userPrefix then
			name := name[prefixLength + 1:end];
		endif;
	endif;
	
	self.name := name;
	
	if _object.isKindOf(CM_EmailAddress2) then
		self.emailAddress := _object.CM_EmailAddress2.emailAddress;
	endif;
	
	if _object.isKindOf(CM_EmailGroup) then
		self.emailAddress := _object.CM_EmailGroup.getEmailAddress();		
	endif;
	
epilog

end;</source>
        <Parameter name="_object" type="CM_EmailEntity"/>
    </JadeMethod>
</Class>
