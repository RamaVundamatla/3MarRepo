    <JadeMethod name="utlReverseDeckingOrderGridRow" id="aa635a6b-3645-45df-a1bb-8b5759c5c4e7">
        <updating/>
        <source>utlReverseDeckingOrderGridRow(_theGridRow: CM_GridRow; _passport : CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	18 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	pxyDeckingOptions	: CM_YADeckingOptions;
	newDeckingOptionsRow,
	pxyDeckingOptionsRow: CM_YADeckingOptionsRow;
	reverseIn,
	reverseOut			: Boolean;
begin

	self.initialiseActivity();

	if _theGridRow.myDeckingOptions = null then
		create pxyDeckingOptionsRow transient;
		pxyDeckingOptionsRow.setProxy(false, true, _theGridRow);
		pxyDeckingOptionsRow.setProxyRules(DeckingRule_Default, DeckingRule_Default);
		
		create newDeckingOptionsRow;
		newDeckingOptionsRow.setForCreate(pxyDeckingOptionsRow);
		
		//app.raiseUnexpectedProgramError(class.name, method.name, 'grid row decking options is NULL');
	endif;

	//IN
	if _theGridRow.myDeckingOptions.inOptionType = DeckingRule_Custom then		
		//reverse all Locn cells based on pad position	
		_theGridRow.myDeckingOptions.reverseLocnCellsIn(_theGridRow);
	else
		reverseIn := true;
	endif;
	
	//OUT
	if _theGridRow.myDeckingOptions.outOptionType = DeckingRule_Custom then		
		//reverse all Locn cells based on pad position	
		_theGridRow.myDeckingOptions.reverseLocnCellsOut(_theGridRow);
	else
		reverseOut := true;
	
	endif;

	if reverseIn or reverseOut then
		pxyDeckingOptions := _theGridRow.myDeckingOptions.pxyCreateUpdateProxy();
		if reverseIn then
			pxyDeckingOptions.reverseRulesIn();
		endif;
	
		if reverseOut then
			pxyDeckingOptions.reverseRulesOut();
		endif;
	
		self.utlUpdateDeckOptionsApplyRules(pxyDeckingOptions, DeckingLevel_YA, _passport);
	endif;
	
epilog
	if global.isValidObject(pxyDeckingOptions) then
		delete pxyDeckingOptions;		
	endif;
end;</source>
        <Parameter name="_theGridRow" type="CM_GridRow"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlReverseDeckingOrderYABlock" id="9b920b04-2d78-4052-befe-f032ff30b76a">
        <updating/>
        <source>utlReverseDeckingOrderYABlock(_theBlock: CM_YABlockGridArea; _passport : CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	19 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	pxyDeckingOptions	: CM_YADeckingOptions;
	reverseIn,
	reverseOut			: Boolean;
	gridRow				: CM_GridRow;
	gridController		: CM_GridController;
begin

	self.initialiseActivity();

	if _theBlock.allYardControllers.isEmpty then
		return;
	endif;
	 
	if CM_GridController.hasInstance(_theBlock.allYardControllers.first) then
		gridController := _theBlock.allYardControllers.first.CM_GridController;
		gridRow := gridController.myGridRow;
	endif;
	  
	if gridRow = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'cannot determine row for allocation block');
		return;
	endif;
	
	if _theBlock.myDeckingOptions = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'grid row decking options is NULL');
	endif;

	//IN
	if _theBlock.myDeckingOptions.inOptionType = DeckingRule_Custom then		
		//reverse all Locn cells based on pad position	
		_theBlock.myDeckingOptions.reverseLocnCellsIn(gridRow);
	else
		reverseIn := true;
	endif;
	
	//OUT
	if _theBlock.myDeckingOptions.outOptionType = DeckingRule_Custom then		
		//reverse all Locn cells based on pad position	
		_theBlock.myDeckingOptions.reverseLocnCellsOut(gridRow);
	else
		reverseOut := true;
	
	endif;

	if reverseIn or reverseOut then
		pxyDeckingOptions := _theBlock.myDeckingOptions.pxyCreateUpdateProxy();
		if reverseIn then
			pxyDeckingOptions.reverseRulesIn();
		endif;
	
		if reverseOut then
			pxyDeckingOptions.reverseRulesOut();
		endif;
	
		self.utlUpdateDeckOptionsApplyRules(pxyDeckingOptions, DeckingLevel_YA, _passport);
	endif;
	
epilog
	if global.isValidObject(pxyDeckingOptions) then
		delete pxyDeckingOptions;		
	endif;
	
end;</source>
        <Parameter name="_theBlock" type="CM_YABlockGridArea"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlSapEstimateResponse" id="5d18afca-7805-47ec-8070-484cae089f04">
        <source>utlSapEstimateResponse(_wo : CM_WorkOrder;_woStatus: Integer;_doApprove :Boolean ;_passport : CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 Aug 2018  cnwma1	ChangeRequest 39698: PEL1 - SAP Enable SAP interfaces
30 Jan 2019 cnwma1	ChangeRequest 42943: PEL1 - Recheck Finance for WSDL 1.4 on Web Portal
*/
vars
	voyage 			: CM_Voyage;
	voyageStatus	: CM_VoyageStatus;
	wo		    	: CM_WorkOrder;
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(false);
	app.writeLog( method.qualifiedName &amp; "isDoApprove :" &amp; _doApprove.asStringJMT,LogINFO);
	app.writeLog( method.qualifiedName &amp; "_woNewStatus :" &amp; _woStatus.asStringJMT,LogINFO);
	wo := _wo;

	app.setContinueCMExceptions(true);
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(wo, true);       //30.01.2019 cnwma1 Bug #42943
		
		wo.setTaskStatus(_woStatus);
		
		if app.myPassport.noErrors then
			app.writeLog( method.qualifiedName &amp; "WO Current Status:" &amp; wo.getStatusString,LogINFO);
		else
			app.writeLog( method.qualifiedName &amp; "Errors While Updating Wo:" &amp; app.myPassport.getErrorsAndWarningsAsString,LogINFO);
		endif;
		
		self.myUpdateAuditAgent.audUpdateGeneric(wo, false);  	   //30.01.2019 cnwma1 Bug #42943
	endif;
epilog

end;</source>
        <Parameter name="_wo" type="CM_WorkOrder"/>
        <Parameter name="_woStatus" type="Integer"/>
        <Parameter name="_doApprove" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlSapWSDL19Success" id="258b1f6d-5fcc-4896-b1ef-252b7eb0c80c">
        <updating/>
        <source>utlSapWSDL19Success( realInvoice : CM_Invoice input; _kinerjaDT : TimeStamp;_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 July 2019	jlgndl1	Initial creation	TFS 45330

*/

vars

begin
	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	if (not self.checkValidationWithPassport(_passport)) then
		return;	
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realInvoice);
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realInvoice, true);
	endif;
	if _passport.noErrors then
		realInvoice.setKinerjaDT(_kinerjaDT);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realInvoice, false);
		realInvoice.causeEvent(realInvoice.myTerminal.getTerminalEvent(Event_InvoiceUpdate), false, realInvoice);	
	endif;
epilog

end;</source>
        <Parameter name="realInvoice" type="CM_Invoice" usage="input"/>
        <Parameter name="_kinerjaDT" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlSetActualBayPlanFromVoyage" id="7818b16e-428c-4127-8765-61b8a17e1545">
        <updating/>
        <source>utlSetActualBayPlanFromVoyage(_transControl: CM_TermTransferVoyController; _passport : CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	06 August 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	voyageTo	: CM_Voyage;
begin

	self.initialiseActivity();
	
	// do validation
	self.raiseExceptionIfNull(_transControl, 'transfer controller');
	_transControl.validate(_passport);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	voyageTo := _transControl.myVoyageTo;
	
	app.setContinueCMExceptions(true);

	//update
	_transControl.doTransfer(_passport);

	if _passport.noErrors then
		// This will update the display on screen of this voyage
		if voyageTo.myTerminal &lt;&gt; null then
			voyageTo.causeEvent(voyageTo.myTerminal.getTerminalEvent(EVENT_REFRESH_VOYAGE_AREA), false, null);
		endif;
	endif;

end;</source>
        <Parameter name="_transControl" type="CM_TermTransferVoyController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlSetAllowedTAFromMachineType" id="2891f3b5-23b6-4125-ac94-1046ae73257b">
        <source>utlSetAllowedTAFromMachineType(_machineType : CM_MachineType; _passport : CM_Passport);

// cnwdvb1 25 June 2003 

vars

	machine : CM_Machine;
	iter	: Iterator;
	type	: Integer;

begin

	if _machineType = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, method.name, 'Machine Type', null, null, null);
	endif;
	self.exclusiveLock(_machineType);
	type := _machineType.type;
	iter := app.myRoot.allMachines.createIterator;
	while iter.next(machine) do
		if machine.machineType &lt;&gt; type then
			continue;
		endif;
		self.exclusiveLock(machine);
		machine.setTerminalAreasFromType(_machineType.allAllowedTATypes);
	endwhile;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_machineType" type="CM_MachineType"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="utlSetBookRefsStatus" id="ce93728f-6877-4c07-9b8a-45979c77fa08">
        <source>utlSetBookRefsStatus(_status:Integer; _allBookingRefs:CM_BookingRefSet; _passportObj:CM_Passport input);
// --------------------------------------------------------------------------------
// Created:		19 March 2009 by cnwdad1
//
// Purpose:		Sets the status of all Booking References in the specified set to the
//				specified Status.
//
// Parameters:	_status - The status to set the Booking Refs's to.
//				_allBookingRefs - A reference to the set of BR's to set.
//				_passportObj - A reference to the current User's passport object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// 20 April 2010	RJS		Add in auditting (PAR 23587)
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	bookRefObj		: CM_BookingRef;
	tmpTerminal		: CM_Terminal;
	termEvent		: Integer;
	audAgent		: CM_UpdateTransactionAuditAgent;
	
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(false);
	
	// Do validation.
	self.raiseExceptionIfNull(_allBookingRefs, "list of Booking References");
	
	if _status &lt;&gt; BOOKING_REF_ACTIVE
	and _status &lt;&gt; BOOKING_REF_ARCHIVED
	and _status &lt;&gt; BOOKING_REF_CLOSED
	and _status &lt;&gt; BOOKING_REF_PENDING
	then
		app.raiseCMException2(ERR_FIELD_VALUE, app.getString(BookingRef) &amp; " " &amp; app.getString(Status), _status.String, null, null);
	endif;
	
	if _allBookingRefs.isEmpty then
		return;
	endif;
	
	tmpTerminal := _allBookingRefs.first.myTerminal;
	if tmpTerminal = null then
		self.raiseExceptionIfNull(tmpTerminal, "terminal");
		return;
	endif;
	
	termEvent := tmpTerminal.getTerminalEvent(Event_BookingRefUpdate);
	
	audAgent := self.myUpdateAuditAgent;
	
	if _passportObj.noErrors() then
		foreach bookRefObj in _allBookingRefs do
			audAgent.audUpdateGeneric(bookRefObj, true);

			bookRefObj.setStatus(_status);
			
			if _passportObj.hasErrors then
				break;
			endif;
			
			audAgent.audUpdateGeneric(bookRefObj, false);
			bookRefObj.causeEvent(termEvent, false, bookRefObj);

		endforeach;
	endif;
end;</source>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_allBookingRefs" type="CM_BookingRefSet"/>
        <Parameter name="_passportObj" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlSetControllerStatusWithYA" id="8fc4b57c-3dfe-451c-8906-93061ddcd87a">
        <updating/>
        <source>utlSetControllerStatusWithYA(	_status:Integer;
								_controllerObj:CM_LocationsController input;
								_edition:Integer;
								_allAllocationsObj:CM_YardAllocationSet input;
								_passport:CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		03 June 2008 by cnwdad1:2
//
// Purpose:		Refer to transaction method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allocationObj	: CM_YardAllocation;
	invalidObject	: Boolean;
	
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(false);
	app.myValUA.valSetControllerStatusWithYA(_status, _controllerObj, _allAllocationsObj, _passport);
	
	on Exception do app.handleDeletedObject(exception, allocationObj, invalidObject);
	invalidObject	:=	false;
	
	foreach allocationObj in _allAllocationsObj do
		allocationObj.validateForDelete();
	endforeach;
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	exclusiveLock(_controllerObj);

	if _passport.noErrors() and _controllerObj.edition &lt;&gt; _edition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, "Locations Controller", null, null);
		return;
	endif;
	
	if _passport.noErrors() then
		self.myUpdateAuditAgent.audUpdateGeneric(_controllerObj, true);
	endif;
	
	if _passport.noErrors() then
		_controllerObj.setStatus(_status);
		
		if _passport.noErrors() then
			invalidObject	:=	false;
			
			foreach allocationObj in _allAllocationsObj do
				if allocationObj.allYardControllers.includes(_controllerObj.CM_YardController) then
					allocationObj.allYardControllers.remove(_controllerObj.CM_YardController);
				endif;
				
				if invalidObject then
					invalidObject	:=	false;
				endif;
			endforeach;
			
			_allAllocationsObj.purge();
		endif;
	endif;
	
	if _passport.noErrors() then
		self.myUpdateAuditAgent.audUpdateGeneric(_controllerObj, false);
	endif;
end;</source>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_controllerObj" type="CM_LocationsController" usage="input"/>
        <Parameter name="_edition" type="Integer"/>
        <Parameter name="_allAllocationsObj" type="CM_YardAllocationSet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlSetDfltDischargeColourCode" id="584fcadc-1a7b-4348-a4dc-ea6ae9730cb5">
        <updating/>
        <source>utlSetDfltDischargeColourCode(_structure : CM_CellularVoyageStructure input; _passport : CM_Passport input) updating;
/*
------------------------------------------------------------------------
Created:			26 February 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		See Method signature above. Special comment:
Returns:			See Method signature above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
31 Mar 2025 	navma1  		MTN-34387 MTN - Removing Unnecessary Audits
------------------------------------------------------------------------
*/
vars
	realObject		: CM_TrxTestObject;
	expectedEdition	: Integer;

begin

	self.initialiseActivity();
	
	// do any pre-validation locks
	
	// do validation
	self.raiseExceptionIfNull(_structure, 'Cellular Voyage Structure Object');
	self.raiseExceptionIfNull(_passport, 'Passport');

	app.setContinueCMExceptions(true);
	
	// do updates
	_structure.createDefaultDischargeCC(_passport);
	
	app.myUtilityCA.utlCreateVoyageOOWCreation(_structure,_passport); // PAR 16676 PAR 17802 put this back


	if _passport.noErrors and _structure.myVoyage &lt;&gt; null then
		_structure.causeEvent(_structure.myVoyage.myTerminal.getTerminalEvent(EVENT_OOWCREATION_UPDATE), false, _structure); // PAR 16676
	endif;

end;</source>
        <Parameter name="_structure" type="CM_CellularVoyageStructure" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlSetEDIAsActualBayPlan" id="6ba6e111-b044-46cd-a932-734bf96520e7">
        <updating/>
        <source>utlSetEDIAsActualBayPlan(_voyage : CM_Voyage input; _ediBP : CM_VoyageEDIBayPlanController input; _clearDetails, _mergeRetainAllCargo, _mergeRetainEDICargo, _mergeRetainManCargo, _mergeRetainNoCargo, _mergePlanning :Boolean; _passport : CM_Passport input) updating;
/*
------------------------------------------------------------------------
Created:			27 February 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		See Method signature above. Special comment:
Returns:			See Method signature above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
July 2008 cnwrs1 Par 17595 additional parameters
20/05/2010		cnwcs5			Changed merge parameters to be usage constant
------------------------------------------------------------------------
*/
vars
//	try : Integer;
begin

	self.initialiseActivity();
	
	// do any pre-validation locks
	// do validation
	self.raiseExceptionIfNull(_voyage, 'Voyage Object');
	self.raiseExceptionIfNull(_ediBP, 'EDI Bay Plan Controller');
	app.setContinueCMExceptions(true);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

/*	dont need this anymore - with collections created in the voyage constructor	the voyage is not locked
	//try to get the voyage lock now 
	try := 0;
	while true do
		try := try + 1;
		if self.tryLock(_voyage, Exclusive_Lock, Transaction_Duration, LockTimeout_Immediate) then
			break;	
		else
			if try &gt; 3 then
				app.raiseCMException(LOCKED, 'voyage', null);
				return;
			endif;
			process.sleep(2000);
		endif;
	endwhile;
*/
	
	// do updates
	_ediBP.setAsActualBayPlan(_clearDetails, _mergeRetainAllCargo, _mergeRetainEDICargo, _mergeRetainManCargo, _mergeRetainNoCargo, _mergePlanning, _passport);
	
	if _passport.noErrors then
		// ################################
		// This will update the display on screen of this voyage
		if _voyage.myTerminal &lt;&gt; null then
			_voyage.causeEvent(_voyage.myTerminal.getTerminalEvent(EVENT_REFRESH_VOYAGE_AREA), false, null);
		endif;
	endif;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_ediBP" type="CM_VoyageEDIBayPlanController" usage="input"/>
        <Parameter name="_clearDetails" type="Boolean"/>
        <Parameter name="_mergeRetainAllCargo" type="Boolean"/>
        <Parameter name="_mergeRetainEDICargo" type="Boolean"/>
        <Parameter name="_mergeRetainManCargo" type="Boolean"/>
        <Parameter name="_mergeRetainNoCargo" type="Boolean"/>
        <Parameter name="_mergePlanning" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlSetEDICallOffAction" id="0909ce10-aa38-430c-91c3-80e3ea3689ea">
        <updating/>
        <source>utlSetEDICallOffAction(_ediData : CM_EDIDataCallOff; _status : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2024	naviv1	TFS 63174 - EUP* | FR - 54084 CallOff Work Order Created Despite Error During DBLoad

*/

vars
	ediData: CM_EDIDataCallOff;
begin
	self.initialiseActivity();
	
	ediData := _ediData;
	ediData.statusString := _status;
end;</source>
        <Parameter name="_ediData" type="CM_EDIDataCallOff"/>
        <Parameter name="_status" type="String"/>
    </JadeMethod>
    <JadeMethod name="utlSetEDIDataStatus" id="5ad2cac8-7559-417e-9ffe-042d2f11d361">
        <source>utlSetEDIDataStatus(_realEdiData: CM_EDIData; _newStatus: Integer; _passport: CM_Passport input);
//----------------------------------------------------------------
//	Created:	11 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 16 Aug 2016	cnwrs1	TFS 2534 Par 38135 - dead locking between edidata process and edidata deletion
// 27 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage 4
// 14 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 14 May 2025 naviv1    MTN-19104 - MTN - Transport Manifest Handling of locking in EDI Operations
vars
	ediConfig : CM_EDIConfig;
	ediData: CM_EDIData;
begin
	ediData := _realEdiData;
	if ediData.status &lt;&gt; _newStatus then
		ediConfig := ediData.ediConfig;
		if ediConfig &lt;&gt; null then
			if not tryLock(ediConfig, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
				self.exclusiveLock(ediConfig);
			endif;
		endif;
	//	self.initialiseActivity();
		
		//self.exclusiveLock(ediData); //07 Apr 2011	NDL	Par 27214
	 if not tryLock(ediData, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then //JIRA-19104
		self.exclusiveLock(ediData);
	  endif;
		
		ediData.setStatus(_newStatus);
	endif;
end;</source>
        <Parameter name="_realEdiData" type="CM_EDIData"/>
        <Parameter name="_newStatus" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlSetEDIDataStatusAfterVerify" id="40da1a2a-dc53-4398-a775-25563676e013">
        <source>utlSetEDIDataStatusAfterVerify(_ediData: CM_EDIData input; _status: Integer);
//
//cnwrs1 par27392 13 Apr 2011
//
// 07/08/2012	cnwcs5	par 30136 - not all EDI data types store persistent errors
// 08/08/2013	cnwcs5	CCMS POL 2221 / par 32094(2) - move all error saving to copyErrors
//18 Sep 2013	cnwrs1	Par 31150 EDI Pack not restarting after lock error
// 16 Aug 2016	cnwrs1	TFS 2534 Par 38135 - dead locking between edidata process and edidata deletion
// 19 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage 3
// 27 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage 4
vars
//	ediConfig : CM_EDIConfig;
begin
//	ediConfig := _ediData.ediConfig;
	_ediData.copyErrors();
	
	if _status &lt;&gt; null then
//		self.exclusiveLock(_ediData);
//		if ediConfig &lt;&gt; null then
//			self.exclusiveLock(ediConfig);
//		endif;
		app.myUtilityUA.utlSetEDIDataStatus(_ediData, _status, null);
	endif;
end;
</source>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
        <Parameter name="_status" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="utlSetReleaseRequestsStatus" id="b2038323-6afa-4233-b70f-9dae286c891f">
        <source>utlSetReleaseRequestsStatus(
	_status				: Integer;
	_allReleaseRequests	: CM_BulkReleaseSet;
	_passportObj		: CM_Passport input );
	
/*
Purpose:		Sets the status of all Release Requests in the specified set to the specified Status.

Date				Who		Reason
24 July 2009		cnwrl1	Initial creation as part of CCMS 1827 - PAR 20349 - Archive Empty Release Requests
*/
	
vars
	bulkRelease		: CM_BulkRelease;
	
begin
	self.initialiseActivity();
	app.setContinueCMExceptions( false );
	
	// Do validation.
	self.raiseExceptionIfNull( _allReleaseRequests, 'list of Release Requests' );	// can not be nothing to change
	
	// must have supplied correct status to change to.
	if _status &lt;&gt; BR_ACTIVE and
	   _status &lt;&gt; BR_ARCHIVE and
	   _status &lt;&gt; BR_COMPLETE and
	   _status &lt;&gt; BR_PENDING then				// NOTE null = 0 = BOOKING_REF_PENDING
		app.raiseCMException2(	ERR_FIELD_VALUE,
								app.getString( Release_request ) &amp; Space &amp; app.getString( Status ),
								_status.display,
								null,
								null );
	endif;
	
	if _passportObj.noErrors() then
		// OK do updating.
		foreach bulkRelease in _allReleaseRequests do
		
			if _passportObj.noErrors then //cnwrd1 par 31782
				self.myUpdateAuditAgent.audUpdateGeneric(bulkRelease, true);
			endif;
	
			bulkRelease.setStatus( _status, false, false );
			
			if _passportObj.noErrors then //cnwrd1 par 31782
				self.myUpdateAuditAgent.audUpdateGeneric(bulkRelease, false);
			endif;
		endforeach;
	endif;
	
epilog
	
end;
</source>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_allReleaseRequests" type="CM_BulkReleaseSet"/>
        <Parameter name="_passportObj" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlSetVoyageExtraMoveDtl" id="3da22dd4-389b-4ee3-a51a-e93c997b57fe">
        <source>utlSetVoyageExtraMoveDtl(_extraMoveDtl : CMIF_VoyageExtraMoveDtl; _passport : CM_Passport input);
/*
/*

Date		    Who			Reason
16 June 2010	cnwas3	  ccms 1134

*/

vars
	tmpVoyage	: CM_Voyage;
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);	

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	tmpVoyage := _extraMoveDtl.myVoyage;

	exclusiveLock(tmpVoyage);

	if _passport.noErrors and tmpVoyage.edition &lt;&gt; _extraMoveDtl.voyageEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Voyage ' &amp; tmpVoyage.code, null, null);
		return;
	endif;

	self.myUpdateAuditAgent.audUpdateGeneric(tmpVoyage, true);

	tmpVoyage.setExtraMoveDtls(_extraMoveDtl, _passport);

//	realMoveDtl.myVoyage.resetKPIExtraMoveDtls();
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(tmpVoyage, false);
	endif;

end;</source>
        <Parameter name="_extraMoveDtl" type="CMIF_VoyageExtraMoveDtl"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlSetupCamTaskHistory" id="83864bd9-b0fe-4ce9-85cf-c7c80ab7438e">
        <updating/>
        <source>utlSetupCamTaskHistory(_camProtocol : CM_CamProtocol input; _camAgent : CM_CamControllerAgent input; _camFile : CM_CamFile input; _runDateTime : TimeStamp;
		   _unhSeqNumber : Integer io; _seqNumber : Integer; _terminal : CM_Terminal; _allTransactions : CM_MemberKeyDictionary; _contextObj : Object; _transactions : CM_TITransactionSet) updating;
//----------------------------------------------------------------
// Created:	April 2008 cnwrs1
// 
// 2/9/09   	J Harliwich MES1011  Want to update transfer file name to task history for file transfer. Also update standard filename if null
//
// 10/05/2010	cnwcs5		par23967 - do not update transaction collections
// 19 June 2012	cnwrs1		Par 29821 - CAMS single transaction per file
// 18 Jul 2012	cnwrs1		CCMS 1269 CAMS remove CM_CamTask
// 01 Aug 2012	cnwrs1		CCMS 1269 CAMS remove CM_CamTask
// 16 Nov 2012	cnwrs1		Par 30728	fail with message and alert if directory disappears
// 05 Dec 2012	cnwcs5		CCMS SFW 1294/par 30855 - now creates CM_InfoEDISent transactions
// 11 Nov 2014	cnwrs1		CCMS 2405 - Alabama Steel Cams
// 06/06/2018 	JLGNS1		Bug 38722: Penn - EDI file names generated with no data.
// 09 Jan 2020	jlgdap1		TFS 48016 SNO Deletion CODECO - new _transactions parameter
// 07 Dec 2022	navdap1		TFS 55159 MTN - Export CAMS to JSON API Endpoint
// 13 Jan 2023	navra1		TFS 55859 - Passed null for the new json parameter in the call to CM_CamControllerAgent::createOutputJson	
// 17 Mar 2023	navmd1		TFS 57092 Revert both 55159 and 55859 changes. Just like ftpentities the cam protocol will be in charge of sending to an endpoint, not the agent
// 26 Apr 2023	navmd1		TFS 57678 Fix number Ad hoc tasks still having old information on them
// 25 Sep 2023	navdap1		TFS 60365 EUP | FR 53853 - Goods Receipt Message Grouping
//								Changed _contextObj from CM_Object to Object
// 27 Jan 2025	jlizm1		MTN 19326 CAMS stuck repeating old run because didn't create empty file
// 18 Jul 2025	navlw1		JIRA 35131: LINX | CAMS Protocol creating files with 0 transactions
// 01 Sep 2025	navdap1		MTN-35871 MTN - CAMS message not generated for Voyage Departed event
//----------------------------------------------------------------
vars
	camTaskHistory	: CM_CamTaskHistory;
	fileNameCreated,
	rawDataStr		: String;	// MES1011
begin 
	self.initialiseActivity();
	
	camTaskHistory := _camProtocol.taskHistoryByProtocolSeq[_camProtocol, _seqNumber];
	
	// build up file contents on the CAM Task History
	//_camProtocol.protocolDesc.outputFile(_camProtocol, _camAgent, _camFile, _camAgent.runDateTime, camTaskHistory, _unhSeqNumber, _seqNumber, _terminal, _contextObj);				// TFS 48016
	_camProtocol.protocolDesc.outputFile(_camProtocol, _camAgent, _camFile, _camAgent.runDateTime, camTaskHistory, _unhSeqNumber, _seqNumber, _terminal, _contextObj, _transactions);	// TFS 48016
	
	// CCMS SFW 1294 - create any CAMS Info transactions
	// If output to file fails the Jade transaction will be aborted and no TI transaction will remain.
	_camAgent.createCAMSInfoSentTransactions (_camAgent, _camProtocol, _camFile, _allTransactions); 
	if _camFile.messageCount &gt; 0 then
		_camProtocol.protocolDesc.setTransmissionNumber(_camProtocol.protocolDesc.getTransmissionNumber() + 1);
	else																					//Bug 38722
		if not _camProtocol.sendMtFiles and camTaskHistory.getRawDataString = null then		//Bug 38722		//09.Jan.2024 navsp1 TFS 61086
			camTaskHistory.setStatus(CAM_COMPLETESTATUS);									//Bug 38722
			// Yeah, but if we're updating the Ad-Hoc history, then the rest of the data needs to be cleared too!
			camTaskHistory.setMessageCount(0);
			camTaskHistory.setFileName(null);
			return;																			//Bug 38722
		endif;																				//Bug 38722
	endif;
	
	// 18/07/2025 navlw1 JIRA #35131
	// check if rawDataStr contains BGM or TDT or DTM. If it doesn’t then we should be returning at that point
	// a sensible Cams file will always have a BGM / TDT / DTM / Header segment
	// The header section comes from a Goods Receipt, so we needed to add this 24/07/2025 navlw1 JIRA#35578
	if not _camProtocol.sendMtFiles and _camProtocol.protocolDesc.isKindOf(CM_CamEDIFACTDesc) then	// MTN-35871
		rawDataStr := camTaskHistory.getRawDataString;
		if rawDataStr.pos("BGM",1) = 0 and rawDataStr.pos("TDT",1) = 0 and rawDataStr.pos("DTM",1) = 0 and rawDataStr.pos("Header",1) = 0 then
			return;
		endif;
	endif;
	
	// write file contents to disk
	if not _camAgent.createOutputFile(_camProtocol, camTaskHistory, fileNameCreated) then	// MES1011 Add filename output parameter
	
		camTaskHistory.setStatus(CAM_ERRORSTATUS);		
		_camAgent.setStatus(CAM_ERRORSTATUS);
		
		return;	//16 Nov 2012	cnwrs1	Par 30728
	endif;
	
	// record number of messages in file
	camTaskHistory.setMessageCount(_camFile.messageCount);
	
	// MES1011 Store the filename created
	if  fileNameCreated &lt;&gt; null then
		if _camProtocol.isUserDefinedReport  or					 			// for user defined, camTask.createOutputFile creates the 'transfer' file. camTask.fileName is created by the JRW earlier on
		   _camProtocol.isUserDefinedEventReport then						// PAR 21905 CCMS MES 1008 - PHB
			camTaskHistory.setTransferFileName 	(fileNameCreated);
			
		elseif camTaskHistory.fileName = null then 
			camTaskHistory.setFileName (fileNameCreated);					// make sure we have stored the filename it used
		endif;
	endif;
		
	if _camProtocol.isSingleTransPerFile then
		camTaskHistory.setStatus(CAM_COMPLETESTATUS);
	else
		camTaskHistory.setStatus(CAM_SENDSTATUS);
	endif;
end;</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol" usage="input"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_runDateTime" type="TimeStamp"/>
        <Parameter name="_unhSeqNumber" type="Integer" usage="io"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_allTransactions" type="CM_MemberKeyDictionary"/>
        <Parameter name="_contextObj" type="Object"/>
        <Parameter name="_transactions" type="CM_TITransactionSet"/>
    </JadeMethod>
    <JadeMethod name="utlSetupEDI" id="cf7a53ed-6fe2-4c1c-8668-6eb51bf1c0f1">
        <updating/>
        <source>utlSetupEDI(_addCountCams, _addCountEDI: Integer output; _passport: CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	25 August 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 22 Jun 2017	cnwrs1	TFS 4259 _ Penn Seaboard implimentation
// 12 Jan 2018	jlgrs1	TFS 36631 - allow Cam Protocol Desc name to be changed during release Request
vars
	tmpAgent		: CM_EDIFileTypeAgent;
	pxyFileType,
	realFileType	: CM_EDIFileType;
	theRoot			: CM_Root;
	pxyCAMDesc,
	realCAMDesc		: CM_CamProtocolDesc;
	tmpCAMDesc	: CM_CamProtocolDesc;
	camsNewName : String;
begin
	self.initialiseActivity();
	
	create tmpAgent transient;
	tmpAgent.init();

//EDI
    _addCountEDI := 0;
    
    theRoot := app.myRoot;
    
    foreach pxyFileType in tmpAgent.allEDIFileTypes do
	    realFileType := theRoot.allEDIFileTypes.getAtKeyGeq(pxyFileType.type, null);
	    if realFileType = null or realFileType.type &lt;&gt; pxyFileType.type then
	        create realFileType as pxyFileType.class;
	        realFileType.setMyRoot();
	        _addCountEDI := _addCountEDI + 1;
	    endif;
    endforeach;

//CAMS
    _addCountCams := 0;

    foreach pxyCAMDesc in tmpAgent.allCAMProtocolDescs do
	    realCAMDesc := theRoot.allCamProtocolDescs[pxyCAMDesc.name];
		// this code can be removed after class CM_CamSEABX12322Desc has been deleted ie after 8.6.1 it should stay for 8.6.1 001 upgrade
		if pxyCAMDesc.class.name = "CM_CamSEABX12322Desc" then
			if realCAMDesc &lt;&gt; null then
				delete realCAMDesc;
			endif;
	    elseif realCAMDesc = null then
			foreach tmpCAMDesc in theRoot.allCamProtocolDescs do
				if tmpCAMDesc.type = pxyCAMDesc.type then
					realCAMDesc := tmpCAMDesc;
					break;
				endif;
			endforeach;
			if realCAMDesc &lt;&gt; null then
				create tmpCAMDesc as pxyCAMDesc.class transient;
				camsNewName := tmpCAMDesc.name;
				delete tmpCAMDesc;
				realCAMDesc.name := camsNewName;
			else
				create realCAMDesc as pxyCAMDesc.class;
				realCAMDesc.setMyRoot();
				_addCountCams := _addCountCams + 1;
			endif;
	    endif;
    endforeach;
epilog
	delete tmpAgent;
//	delete tmpCAMDesc;
end;</source>
        <Parameter name="_addCountCams" type="Integer" usage="output"/>
        <Parameter name="_addCountEDI" type="Integer" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlSetupEDIInfoTransaction" id="c85c8f82-d66d-4771-b294-8a9823b47423">
        <source>utlSetupEDIInfoTransaction(_ti : CM_TrackedItem input; _ediRawDataArray : StringArray512);
//
// ccms1845 cnwrs1 nov 2009
//
vars
	
begin
	if _ediRawDataArray = null or _ediRawDataArray.size = 0 then
		return;
	endif;
	
	_ti.createInfomationTransaction(EDIDetails, _ediRawDataArray, null, app.myPassport);
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_ediRawDataArray" type="StringArray512"/>
    </JadeMethod>
    <JadeMethod name="utlSetupEWSTypes" id="6b39326f-c0a4-4b2e-a391-1f195edd79de">
        <updating/>
        <source>utlSetupEWSTypes(_addCountEP, _addCountEWS: Integer output; _passport: CM_Passport input) updating;
/*
Purpose - 	
Who - NAVAB1
Date - 12DEC2024
ADO - JIRA 33542
*/

vars
	tmpAgent		: CM_EWSTypeAgent;
	pxyEWSType,
	realEWSType	: CM_ExternalWebServiceType;
	theRoot			: CM_Root;
	pxyEPType,
	realEPType		: CM_EWSEndpointType;
	tmpCAMDesc	: CM_EWSEndpointType;
	camsNewName : String;
begin
	self.initialiseActivity();
	
	create tmpAgent transient;
	tmpAgent.init();

//EWS
	_addCountEWS := 0;
	
	theRoot := app.myRoot;
	
	foreach pxyEWSType in tmpAgent.allEWSTypesByType do
		realEWSType := theRoot.allExternalWebServiceTypes[pxyEWSType.type];
		if realEWSType = null or realEWSType.type &lt;&gt; pxyEWSType.type then
			create realEWSType as pxyEWSType.class;
			realEWSType.setMyRoot();
			_addCountEWS := _addCountEWS + 1;
		endif;
	endforeach;

//ENDPOINTS
	_addCountEP := 0;

	foreach pxyEPType in tmpAgent.allEWSEndpointTypeByType do
		realEPType := theRoot.allEWSEndpointTypes[pxyEPType.type];
		
		if realEPType = null then
			create realEPType as pxyEPType.class;
			realEPType.setMyRoot();
			_addCountEP := _addCountEP + 1;
		endif;
	endforeach;
epilog
	delete tmpAgent;

end;</source>
        <Parameter name="_addCountEP" type="Integer" usage="output"/>
        <Parameter name="_addCountEWS" type="Integer" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlShiftJobInJobSheet" id="9dba0c7d-762e-4076-b0ed-2f41860c608c">
        <updating/>
        <source>utlShiftJobInJobSheet(_job : CM_Job input; _passport : CM_Passport input; _shiftBy : Integer) updating;
/*
------------------------------------------------------------------------
Created:			31 March 2003 by cnwdwq1
Purpose:			Shifts a job in the OOW. Note, _shiftBy could be -ve.
							I've also fixed this so it shifts any jobs in any job sheet! Cool!
Parameters:		
Returns:			
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
begin

	self.initialiseActivity();
	
	// do any pre-validation locks
	
	// do validation
	self.raiseExceptionIfNull(_job, 'Job Object');

	app.setContinueCMExceptions(true);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	// do update
	_job.shift(_shiftBy);
	
end;</source>
        <Parameter name="_job" type="CM_Job" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_shiftBy" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="utlSortMenuEntityChildren" id="583aab21-1d91-4bf5-bce6-e6af4613d801">
        <source>utlSortMenuEntityChildren(_menuEntityObj:CM_MenuEntity; _isDescending:Boolean; _isParentsFirst:Boolean; _passport : CM_Passport input);
// --------------------------------------------------------------------------------
// Created:		27 October 2005 by cnwdad1
//
// Purpose:		Sorts the array of children on the specified Menu Entity.
//
// Parameters:	_menuEntityObj - A reference to the Menu Entity who's children to sort.
//				_isDescending - If true, the children will be sorted in descending order.
//				_isParentsFirst - If true, the entities with children will be placed
//					at the top or the sort order (or bottom if descending order),
//					followed by entities with no children.
//				_passport - The user passport thingy.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
// --------------------------------------------------------------------------------
vars

	
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);

	if _menuEntityObj = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_MenuUserItem.name, null, null);
		return;
	endif;
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(_menuEntityObj);
	
	if _passport.noErrors then
		_menuEntityObj.sortChildren(_isDescending, _isParentsFirst);
	endif;

end;</source>
        <Parameter name="_menuEntityObj" type="CM_MenuEntity"/>
        <Parameter name="_isDescending" type="Boolean"/>
        <Parameter name="_isParentsFirst" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlSplitBreakBulkToNewID" id="3bf80dd8-83a6-4cc9-9891-bfaee961fd87">
        <source>utlSplitBreakBulkToNewID( _sourceTi : CM_Cargo input;
							_newId : String; 
							_newTi : CM_Cargo output; 
							_quantity : Integer;
							_weight : Decimal;
							_operator : CM_Operator; 
							_includeStops ,
							_includeToDo,
							_includeDamage,
							_includeHaz : Boolean;
							_effectiveTS : TimeStamp;
							_passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2013	cnwndl1	Initial creation	CCMS 2274 Break Bulk
01 Apr 2014	NDl	CCMS 1366
22 Oct 2015	cnwma1	PAR #36678 When splitting a cargo with Stops the new cargoes don't have theirs
*/

vars

	cmifMoveController : CMIF_MoveController;

begin

	create cmifMoveController transient;
	cmifMoveController.setMoveMode( REAL_MODE );
	if _sourceTi.isBulkByQuantity then
		cmifMoveController.setQuantity( _quantity );
	elseif _sourceTi.isBulkByWeight or _sourceTi.isBulkByVolume then
		cmifMoveController.setWeight( _weight );
	endif;
	cmifMoveController.setMyToPrimaryLocation( _sourceTi.myPrimaryActualLocation );
	cmifMoveController.setMyPassport( _passport );
	if _effectiveTS &lt;&gt; null and _effectiveTS.Date.isValid then
		cmifMoveController.setEffectiveTimeStampOverride( _effectiveTS );
	endif;

	if _sourceTi.isKindOf(CM_BreakBulkGeneric) then
		//_newTi := _sourceTi.CM_BreakBulkGeneric.createNewBreakBulkNewId(cmifMoveController, _newId );  						//22/10/2015 cnwma1 PAR #36678
		_newTi := _sourceTi.CM_BreakBulkGeneric.createNewBreakBulkNewId(cmifMoveController, _newId,_includeStops,_includeToDo,_includeDamage,_includeHaz,_passport );
	elseif _sourceTi.isKindOf(CM_Bulk) then
		_newTi := _sourceTi.CM_Bulk.createNewBulkNewId(cmifMoveController,
														_newId,
														_includeStops ,
														_includeToDo,
														_includeDamage,
														_includeHaz );
	endif;
	
	if _passport.hasErrors or _newTi = null then
		return;
	endif;
	
	if _newTi.myOperator &lt;&gt; _operator and _operator &lt;&gt; null then
		_newTi.setMyOperator( _operator );
		_newTi.changeState(_newTi.state, _passport);
	endif;
	
epilog

	delete cmifMoveController;

end;</source>
        <Parameter name="_sourceTi" type="CM_Cargo" usage="input"/>
        <Parameter name="_newId" type="String"/>
        <Parameter name="_newTi" type="CM_Cargo" usage="output"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_includeStops" type="Boolean"/>
        <Parameter name="_includeToDo" type="Boolean"/>
        <Parameter name="_includeDamage" type="Boolean"/>
        <Parameter name="_includeHaz" type="Boolean"/>
        <Parameter name="_effectiveTS" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlSplitRollBooking" id="7df7c266-0680-4a3c-a4de-0589b3186d68">
        <source>utlSplitRollBooking(_tis : CM_TISet; _oldBooking, _newBooking : CM_BookingRef io; _isSplit :Boolean; _remarks :String; _passport : CM_Passport input);
//
// Changed On	By			Reason
// ----------	--------	---------------------------------------------------------
// 26/10/2011	cnwdap1		PAR #28524 CCMS POL 2096 If new rolled booking is the same as old booking, don't close it
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 21/05/2018	jlgmd1		TFS38657 PEN - Prevent Roll/Split when cargo is planned or queued to the original voyage

//
vars
	ti					: CM_TrackedItem;
	eventType			: Integer;
	et					: CMEVT_SplitRollBooking;
	terminal			: CM_Terminal;
	planQueueWarnAsErr	: Boolean;
	cmifEventCtrl 		: CMIF_SplitRollBookingCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
begin
	terminal := _newBooking.myTerminal;																		//TFS38657
	planQueueWarnAsErr := terminal.getConfig(BookingPlanQueWarnErr).Boolean;								//TFS38657

	app.setContinueCMExceptions(true);																		//TFS38657
	foreach ti in _tis do
		//ti.setBookingRefForSplitRoll(_newBooking, _isSplit, _remarks, _passport);
		ti.setBookingRefForSplitRoll(_newBooking, _isSplit, _remarks, planQueueWarnAsErr, _passport);		//TFS38657
	endforeach;
	app.setContinueCMExceptions(false);																		//TFS38657
	
	_newBooking.setSplitFromBooking(_oldBooking);
	if _oldBooking &lt;&gt; _newBooking then			// PAR #28524
		_oldBooking.setStatusClosed(_isSplit);
	endif;										// PAR #28524
	if _isSplit then
		eventType	:= EVT_SplitBooking;
	else
		eventType	:= EVT_RollBooking;
	endif;
	/* //17/02/2025	navkc1 JIRA Bug MTN-33582
	et := app.createEvent(	eventType, 
							app.actualTimeServer, // 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
							_passport.myTerminal, 
							_passport.userCode, 
							false, false,0).CMEVT_SplitRollBooking;
	if et &lt;&gt; null then
		et.setBookingReferences(_oldBooking, _newBooking, _remarks);
	endif;
	*/
	
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - Starts
	create cmifEventCtrl transient;
	cmifEventCtrl.type := eventType;
	cmifEventCtrl.dateTime := app.actualTimeServer();
	cmifEventCtrl.myTerminal := _passport.myTerminal;
	cmifEventCtrl.userCode := _passport.userCode;
	cmifEventCtrl.remarks := _remarks;
	cmifEventCtrl.myOldBookingReference := _oldBooking;
	cmifEventCtrl.myNewBookingReference := _newBooking;
	
	et := app.createEventUsingCMIF(cmifEventCtrl).CMEVT_SplitRollBooking;
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - Ends
epilog
	delete cmifEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
end;
</source>
        <Parameter name="_tis" type="CM_TISet"/>
        <Parameter name="_oldBooking" type="CM_BookingRef" usage="io"/>
        <Parameter name="_newBooking" type="CM_BookingRef" usage="io"/>
        <Parameter name="_isSplit" type="Boolean"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlSplitWLEforRailAssign" id="a8367500-9f39-4fa9-a01c-0abc7e77c312">
        <updating/>
        <source>utlSplitWLEforRailAssign(	_originalWle : CM_WorkListEntry input;
							_splitWt : Decimal;
							_splitQty : Integer;
							_newWle : CM_WorkListEntry output;
							_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
03 December 2020	jlgndl1	Initial creation	TFS 50164
19 October 2022		jlizm1	TFS 54118 Divide by 0 error from density

*/

vars

	cargoType : CM_CargoType;
	rrpReserveDet : CM_ReserveDetail;
	newRRP : CM_TrackedItem;

begin

	if _originalWle = null then
		return;
	else
		cargoType := _originalWle.getCargoType();
	endif;
	
	if cargoType = null or not cargoType.isAllowDuplicates then
		return;
	elseif cargoType.isBulk then
			//Neither of these two should ever occur, cos we alreday check in the split for assign form
		if _originalWle.weight = _splitWt then
			_newWle := _originalWle;
		elseif _originalWle.weight &lt; _splitWt then
			return;
		endif;
	elseif cargoType.isBreakBulk then
		//Neither of these two should ever occur, cos we alreday check in the split for assign form
		if _originalWle.quantity = _splitQty then
			_newWle := _originalWle;
		elseif _originalWle.quantity &lt; _splitQty then
			return;
		endif;
	endif;
	
	_newWle := _originalWle.cloneSelf(false);
	_newWle.setJob( _originalWle.job );
	_newWle.updateRequest( _originalWle.myRequest );
	
	//set the amounts on the new wle
	if cargoType.isBulk then
		_newWle.setWeight( _splitWt );
		_originalWle.setWeight( _originalWle.weight - _splitWt );
	elseif cargoType.isBreakBulk then
		_newWle.setQuantity( _splitQty );
		_originalWle.setQuantity( _originalWle.quantity - _splitQty );
	endif;

	//set the ti on teh new wle
	if _originalWle.myTrackedItem &lt;&gt; null then
		if _originalWle.myTrackedItem.isRRP then
			//adjust original ti amount to match the update wle, and create new RRP ti for the new wle
			if cargoType.isBulk then
				if cargoType.isTrackByVolume then
					_originalWle.myTrackedItem.setTotalVolumeWithoutTrans(  _originalWle.weight / _originalWle.getDensity() );
				else
					_originalWle.myTrackedItem.setTotalWeightWithoutTrans( _originalWle.weight );
				endif;
			elseif cargoType.isBreakBulk then
				_originalWle.myTrackedItem.setTotalQuantity( _originalWle.quantity );
			endif;
			
			rrpReserveDet := _originalWle.myTrackedItem.myRRPReserveDetail;
			
			if rrpReserveDet &lt;&gt; null then
				newRRP := rrpReserveDet.createPlanningTrackedItem( null, null, false );
				if newRRP &lt;&gt; null then
					_newWle.setMyTrackedItem( newRRP );
					if _splitWt &gt; 0 then
						if cargoType.isTrackByVolume then
							newRRP.setTotalVolumeWithoutTrans(  _splitWt / _originalWle.getDensity() );
						else
							newRRP.setTotalWeightWithoutTrans( _splitWt );
						endif;
					endif;
					if _splitQty &gt; 0 then
						newRRP.setTotalQuantity( _splitQty );
					endif;
				endif;
			endif;
			
		else
			//Just link to the same ti
			_newWle.setMyTrackedItem( _originalWle.myTrackedItem );
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_originalWle" type="CM_WorkListEntry" usage="input"/>
        <Parameter name="_splitWt" type="Decimal"/>
        <Parameter name="_splitQty" type="Integer"/>
        <Parameter name="_newWle" type="CM_WorkListEntry" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlSplitWOTransportJobs" id="d80ca51b-640f-47b8-8b3e-9a2a35e71d58">
        <source>utlSplitWOTransportJobs(_oldDtl, _newDtl : CM_WorkOrderTIDtl; _term : CM_Terminal; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 May 2023	navhl20	ChangeRequest 56631:[56185] EUP - Transport Mode change - UI Changes
06 Jun 2023 navma1  ChangeRequest 58339: EUP | Delivery Dispatch Screen - Road Operation
13 Dec 2023 naviv1	ChangeRequest 61543: EUP - Transport  Mode Change should create a new Work Order 
21 Dec 2023 navhl20 Bug 61861: EUP | Work Order Transport Mode change - issues
04 Jan 2024 navlc30 ChangeRequest 59997: EUP | Work Order Transport Mode change - Rail Receive
10 Jan 2023 navhl20 Defect 62018: EUP - Ship job got created when changing the transport mode from Road to Ship with the Approved status.
26 Jan 2024	navpw1	TFS: 59411 (61855) - Changed type of _oldDtl, _newDtl to type CM_WorkOrderTIDtl
08 Feb 2024	navpw1	TFS: 59411 (62272) - Inverted if statement isUseYardJobsForCargoWo to make reading easier.
						Fixed isKindOf Checks to use isRail &amp; isRoadJob
04 Jul 2024	navpw1	TFS: 64889 - Fixed defect caused by roadJob.allReceiveTrackedItems being empty and we were trying to remove something from it.
20 Nov 2024 navsaa30 MTN-12361 EUP - Changing the transport mode from Ship to Rail for the Part Complete status is completing the Ship Job
*/

vars
	wle 			: CM_WorkListEntry;
	job				: CM_Job;
	wodToDo			: CM_WodToDo;
	wodRelease		: CM_WodRelease;
	wleArr			: CM_WLESet;
	roadJob			: CM_RoadJob;
	wo				: CM_WorkOrderTI;
	railJob			: CM_RailJob;
	jobArr			: CM_JobArray;
	voyJob			: CM_VoyageWorkPointJob;
	isRoadJob,
	isRailJob		: Boolean;
	request			: CM_Request;
	wodCargoRequest	: CM_WOReleaseCargoRequest;
	releaseRequest	: CM_BulkRelease;
	reserveDetail	: CM_ReserveDetail;
	ti				: CM_TrackedItem;
	workOrderJob	: CM_WorkOrderJob;
	flag_incomplete	: Boolean;
	
begin
	if not _term.isUseYardJobsForCargoWo then
		return;
	endif;
	
	// ### TFS 59411 (62272) 12Feb2024 NAVPW1
	if _oldDtl.isWodRelease and _oldDtl.CM_WodRelease.myReleaseRequest &lt;&gt; null and _oldDtl.CM_WodRelease.myReleaseRequest.releaseByType then
		wodRelease := _oldDtl.CM_WodRelease;
		//Delete old work list entries
		//Modify the CM_WOReleaseCargoRequest request to have a totalRequested matching the reserve detail line
		//Then regenerate the wle's for the CM_WOReleaseCargoRequest request for the total requested
		job := wodRelease.allJobs.first; //Assumption only 1 job
		
		if job.isWorkOrderJob then
			workOrderJob := job.CM_WorkOrderJob;
		endif;
		
		if workOrderJob = null then
			app.writeLog("Job is not a work order job for WO ID: " &amp; wodRelease.myParent.id, LogDEBUG);
			return;
		endif;
		
		releaseRequest	:= wodRelease.myReleaseRequest;
		reserveDetail	:= wodRelease.myReserveDetail;
		
		if reserveDetail = null then
			app.writeLog("Reserve Detail is null for WO ID: " &amp; wodRelease.myParent.id &amp; " | Release: " &amp; releaseRequest.code, LogDEBUG);
			return;
		endif;
		
		foreach ti in workOrderJob.allTrackedItems do
			if not _newDtl.allSelectedTIs.includes(ti) then
				continue;
			endif;
			workOrderJob.allTrackedItems.remove(ti);
		endforeach;
		
		request := workOrderJob.allRequests.first; //Assumption only 1 request
		
		if request.isWOReleaseCargoRequest then
			wodCargoRequest := request.CM_WOReleaseCargoRequest;
		endif;
		
		if wodCargoRequest = null then
			app.writeLog("Request is null for WO ID: " &amp; wodRelease.myParent.id, LogDEBUG);
			return;
		endif;
		
		wodCargoRequest.setTotalRequested(reserveDetail.totalRequested);
		
		wodCargoRequest.allWorkListEntries.purge; //Purge all original worklist entries
		
		//create wleArr transient;
		//request.allWorkListEntries.copy(wleArr);
		//foreach wle in wleArr do
		//	wle.erase(NORMAL_ERASE);
		//endforeach;
		//delete wleArr;
		
		wodCargoRequest.createWLEs(); //Create new work list entries (Will do this for release by type)
		
		//Multi
		//foreach reserveDetail in releaseRequest.allReserveDetails as CM_ReserveSelection do :reserveLoop
		//	foreach request in job.allRequests as CM_WOReleaseCargoRequest do :requestLoop
		//		if request.myReserveDetail &lt;&gt; reserveDetail then
		//			continue requestLoop;
		//		endif;
		//		
		//		request.setTotalRequested(reserveDetail.totalRequested);
		//		request.allWorkListEntries.purge;
		//		request.createWLEs();
		//		continue reserveLoop;
		//	endforeach;
		//endforeach;
	// ### TFS 59411 (62272) 12Feb2024 NAVPW1
	else
		create wleArr transient;
		if _oldDtl.allJobs.isNotEmpty then
			job := _oldDtl.allJobs.first.CM_Job;
			foreach wle in job.workListEntries do
				if _newDtl.allSelectedTIs.includes(wle.myTrackedItem) then
					wleArr.add(wle);
				endif;
			endforeach;
			
			foreach wle in wleArr do
				job.CM_WorkOrderJob.allTrackedItems.remove(wle.myTrackedItem);
				wle.erase(NORMAL_ERASE);
			endforeach;
			
			if job.workListEntries.isEmpty() then				//21.11.2023 navhl20 #61861
				job.changeStatus(JOB_COMPLETE);
			else
				foreach wle in  job.workListEntries do
					if wle.status = WLE_UNACTIONED then			//20/11/24 navsaa30 #12361
						flag_incomplete := true;
						break;
					endif;
				endforeach;
				if not flag_incomplete then
					job.changeStatus(JOB_COMPLETE);
				endif;
			endif;
			
			if _oldDtl.getTransport() = TI_TRANSMODE_SHIP then			//10.01.2023 navhl20 #62018
				jobArr := job.getAllVoyJobs();
				
				if jobArr &lt;&gt; null and jobArr.isNotEmpty() then
					foreach voyJob in jobArr as CM_VoyageWorkPointJob do
						voyJob.completeWLE(null);
					endforeach;
				endif;
			endif;
		endif;
		
		wodToDo := _oldDtl.allToDoRequests.first;
		if _oldDtl.allToDoRequests.isNotEmpty() and wodToDo.allJobs.isNotEmpty() then
			wleArr.clear();
			foreach wle in wodToDo.allJobs.first.workListEntries do
				if _newDtl.allSelectedTIs.includes(wle.myTrackedItem) then
					wleArr.add(wle);
				endif;
			endforeach;
			job := wodToDo.allJobs.first;		//13.12.2023 naviv1 #61543
			foreach wle in wleArr do
				job.CM_WorkOrderJob.allTrackedItems.remove(wle.myTrackedItem);
				wle.erase(NORMAL_ERASE);
			endforeach;
			
			job.rebuildStatus();					//21.11.2023 navhl20 #61861
		endif;
		
		//21.11.2023 navhl20 #61861
		wo := _oldDtl.myParent.CM_WorkOrderTI;
		//job := _oldDtl.allJobs.first.workListEntries.first.CM_WOWLE.myOperationalWLE.job.CM_Job; //Should we be using this instead of the lookup below which could get the wrong one.
		job := _term.myWOJobSheet.allJobsByRequiredDTPriority[wo.requiredByDT,3].CM_Job;
		
		//if job.isKindOf(CM_RoadJob) then
		//	roadJob := job.CM_RoadJob;
		//elseif 	job.isKindOf(CM_RailJob) then														//04.01.2024 navlc30 #59997
		//	railJob := job.CM_RailJob;
		//endif;
		
		isRoadJob := job.isRoadJob;
		isRailJob := job.isRail;
		
		if isRoadJob then
			roadJob := job.CM_RoadJob;
			wleArr.clear();
			foreach wle in roadJob.workListEntries do
				if _newDtl.allSelectedTIs.includes(wle.myTrackedItem) then
					wleArr.add(wle);
				endif;
			endforeach;
			
			foreach wle in wleArr do
				//roadJob.allReceiveTrackedItems.remove(wle.myTrackedItem);	// ### TFS 64889 04Jul2024 NAVPW1
				wle.erase(NORMAL_ERASE);
			endforeach;
			
			roadJob.rebuildStatus();
			
		//if railJob &lt;&gt; null then																		//04.01.2024 navlc30 #59997
		elseif isRailJob then
			railJob := job.CM_RailJob;
			wleArr.clear();
			foreach wle in railJob.workListEntries do
				if _newDtl.allSelectedTIs.includes(wle.myTrackedItem) then
					wleArr.add(wle);
				endif;
			endforeach;
			
			foreach wle in wleArr do
				railJob.allReceiveTrackedItems.remove(wle.myTrackedItem);
				wle.erase(NORMAL_ERASE);
			endforeach;
			
			railJob.rebuildStatus();
			
		endif;
	endif;
	
epilog
	delete wleArr;
	
end;</source>
        <Parameter name="_oldDtl" type="CM_WorkOrderTIDtl"/>
        <Parameter name="_newDtl" type="CM_WorkOrderTIDtl"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlStageMultiCargoForRelease" id="4400171c-1e7e-491e-9d1e-682f3f5f30d5">
        <updating/>
        <source>utlStageMultiCargoForRelease(	_tis : CM_TISet;
															_reserveDetail : CM_ReserveDetail input;
															_targetLocation : CM_LocationsController;
															_passport : CM_Passport input
																) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2018	jlgrh7	Initial creation TFS38573 STWR - "Stage all" function in staging app takes a long time processing items

*/

vars
	ti 							: CM_TrackedItem;
	moveController : CMIF_MoveController;
	target					: CM_LocationsController;
	br 							: CM_BulkRelease;
	wle 						: CM_WorkListEntry;
	targetLocation 	: CM_LocationsController;
	yardWle 				: CM_YardWLE;
	tbaTI						: CM_TrackedItem;
	cmif 						: CMIF_MoveController;
	quantity				: Integer;
	weight					 : Decimal[16,4];
begin
foreach ti in _tis do 
			create moveController transient;																						//set up CMIF_MoveController
			moveController.setMyTrackedItem( ti );
			moveController.setMoveMode( REAL_MODE );
			if ti.isBulkByQuantity then	
				if quantity &lt;&gt; 0 then
					moveController.setQuantity(quantity);
				elseif ti.totalQuantity &lt;&gt; 0 then
					moveController.setQuantity(ti.totalQuantity);
				endif;
			elseif ti.isBulkByWeight or ti.isBulkByVolume then
				if weight &lt;&gt; 0 then
					moveController.setWeight(weight);
				elseif ti.totalWeight &lt;&gt; 0 then
					moveController.setWeight(ti.totalWeight);
				endif;
			endif;
			moveController.setMyToPrimaryLocation( _targetLocation );
			target := moveController.myToPrimaryLocation;
			if ti.myPrimaryActualLocation &lt;&gt; target then
				app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
			endif;
			ti := moveController.myTrackedItem;	// in case it has been split off
			app.myUtilityUA.utlAddToReserveDetail(_reserveDetail, ti, _passport);
			br := _reserveDetail.myReserveHeader;
			if br &lt;&gt; null then
				if br.isShipType then
					//set the voyage and discharge port on assigned cargo item to the values on the release request and set the imex to export
						ti.setShipRelAssignedValues( _reserveDetail, _passport );
				elseif br.isRailType then
							//11 Jan 2017	NDL	TFS 3192/2877
							// see if we can find a WLE that is assigned to a Wagon for our release, that this ti matches AND
							// that has not yet got a TI associated with it (or has a 'tba' assigned to it) and do the needfull,
							// i.e. magically associate the newly 'staged/assigned' rail release cargo, with the 'director' tasks
							// that might have already been created and assigned to wagons for this reserve detail.
						wle := br.getRailWleToAssignTiTo( _reserveDetail, ti );
						if wle &lt;&gt; null then
								targetLocation := wle.getTargetLocation;
								if targetLocation = null then
												// it will be if its only assigned and not queued
										if wle.isKindOf(CM_YardWLE) then
											yardWle := wle.CM_YardWLE;
										endif;
										if yardWle &lt;&gt; null and not yardWle.allLocationControllers.isEmpty then
												targetLocation := yardWle.allLocationControllers.first;
										endif;
								endif;
								if targetLocation &lt;&gt; null then
										tbaTI := wle.myTrackedItem; //get a reference to this sucker, so we can delete the tba if it has one
										wle.setMyTrackedItem( ti );
										create cmif transient;
										cmif.setMyWorkListEntry(wle);
										cmif.setMyTrackedItem(ti);
										cmif.setMyToPrimaryLocation(targetLocation);
										if wle.allRTQueueEntries.isEmpty then
												cmif.setMoveMode(PLANNING_MODE);
										else
											cmif.setMoveMode(QUEUE_MODE);
										endif;
										app.myUtilityUA.utlUpdateWLEAssignTI(cmif, _passport);
										if tbaTI &lt;&gt; null then
											tbaTI.erase(NORMAL_ERASE);
										endif;
										delete cmif;
								endif;
						endif;
				endif;
			endif;
			delete moveController;
endforeach;		
epilog

end;</source>
        <Parameter name="_tis" type="CM_TISet"/>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail" usage="input"/>
        <Parameter name="_targetLocation" type="CM_LocationsController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlSwapMachineTandemTasks" id="f052734c-3cdf-4755-8a5b-285b28155c5a">
        <updating/>
        <source>utlSwapMachineTandemTasks(_machine : CM_Machine input; _rtTask, _secondTask : CM_RTQueueTask input; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2010	cnwer1	Initial creation

*/

vars

begin
	
	_rtTask.swapTaskOrder(_secondTask);
epilog

end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_rtTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_secondTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlSwapTIPlannedLocations" id="d58b2fba-21fb-4f87-869c-3dbe7c9704fb">
        <source>utlSwapTIPlannedLocations( _ti : CM_TrackedItem;
							_slotLC : CM_SlotController);
/*
 Swap the planned location of the trackedItem, with the planned location of the tracked item associated with 
 the slotController. This is usually done when a bulk release is being loaded out of sequence

Date		Who		Reason
16 May 2017	cnwer1	Initial creation TFS 995 refactored moved from MobileServerSchema::CM_UtilityRTAgent::utlSwapPlannedLocations

*/

vars

slotController1, slotController2 : CM_SlotController;
	trackedItem1, trackedItem2 : CM_TrackedItem;
	slotRequest1, slotRequest2 : CM_SlotRequest;
	workListEntry1, workListEntry2 : CM_WorkListEntry;
	locationTarget1, locationTarget2 : String;
	futureMove1, futureMove2 : CM_FutureMovePlanned;
begin
	trackedItem1 := _ti;
	slotController1 := _ti.getLocationsArray(PLANNING_MODE, 1).first.CM_SlotController; 
	slotRequest1 := slotController1.mySlotRequestLoad; 
	workListEntry1 := slotRequest1.getWLEForTI(trackedItem1);
	locationTarget1 := workListEntry1.locationTarget;
	futureMove1 := workListEntry1.myFutureMove.CM_FutureMovePlanned; 
	
	slotController2 := _slotLC;
	trackedItem2 := _slotLC.getFirstPlannedTIMove();
	slotRequest2 := slotController2.mySlotRequestLoad; 
	workListEntry2 := slotRequest2.getWLEForTI(trackedItem2);
	locationTarget2 := workListEntry2.locationTarget;
	futureMove2 := workListEntry2.myFutureMove.CM_FutureMovePlanned; 

	workListEntry1.updateRequest(slotRequest2);
	workListEntry1.setLocations(workListEntry1.locationSource, locationTarget2);
	futureMove1.removeLocationController(slotController1);
	futureMove1.addLocationController(slotController2);
	
	workListEntry2.updateRequest(slotRequest1);
	workListEntry2.setLocations(workListEntry1.locationSource, locationTarget1);
	if futureMove2 &lt;&gt; null then									// 01/07/2010 cnwmh5 #24574
		futureMove2.removeLocationController(slotController2);
		futureMove2.addLocationController(slotController1);
	endif;
	

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_slotLC" type="CM_SlotController"/>
    </JadeMethod>
    <JadeMethod name="utlSwapTandemTasksTargetLoc" id="f53c4905-7cd8-4e9d-aede-603c7ce35c7e">
        <updating/>
        <source>utlSwapTandemTasksTargetLoc(_firstTask, _secondTask : CM_RTQueueTask input) updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 09 January 2020
TFS#		: 48161
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	targetLocation1 : CM_LocationsController;
	targetLocation2 : CM_LocationsController;
	moveController	: CMIF_MoveController;
	trackedItem		: CM_TrackedItem;
begin
	targetLocation1 := _firstTask.targetLocation;
	targetLocation2 := _secondTask.targetLocation;
	
	//epr TFS 52595 11/2/22 if targets are same would get error which would stop the tasks being swapped
	if targetLocation1 = targetLocation2 then
		return;
	endif;
	
	//Change first task taget location
	trackedItem := _firstTask.ti;
	
	create moveController transient;
	moveController.setMoveMode(QUEUE_MODE);
	moveController.isRadioTelemetryMove := true;
	moveController.setMyTrackedItem(trackedItem);
	moveController.setMyToPrimaryLocation(targetLocation2);
	moveController.updatePassportAndUser(app.myPassport);
	
	app.myValUA.valRTTaskTarget(moveController, targetLocation2);
	if app.myPassport.hasErrors() then
		return;
	endif;
	
	_firstTask.changeTargetLocation(moveController,true);
	
	//Change second task target location
	trackedItem := _secondTask.ti;		
	
	moveController.setMoveMode(QUEUE_MODE);
	moveController.isRadioTelemetryMove := true;
	moveController.setMyTrackedItem(trackedItem);
	moveController.setMyToPrimaryLocation(targetLocation1);
	moveController.updatePassportAndUser(app.myPassport);
	
	app.myValUA.valRTTaskTarget(moveController, targetLocation1);
	if app.myPassport.hasErrors() then
		return;
	endif;
	
	_secondTask.changeTargetLocation(moveController,true);
epilog
	delete moveController;
end;</source>
        <Parameter name="_firstTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_secondTask" type="CM_RTQueueTask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlSwapTruckTasks" id="0a6a3e75-7218-421f-b467-061e451bab1c">
        <updating/>
        <source>utlSwapTruckTasks(_wle1 , _wle2 : CM_WorkListEntry ; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 November 2013	cnwrd1	Initial creation

*/

vars
	wle1,
	wle2 	: CM_WorkListEntry;
	request1,
	request2 : CM_Request;
	job1, 
	job2	: CM_Job;
	ti1,
	ti2 	: CM_TrackedItem;
	truck1,
	truck2	: CM_LocationsController;
begin

	//assume we have a valid pair of wle's for swaping ti's (and rt tasks...)
	
	/*
	do we move the wle to th other job?
	
	or move the ti from one wle to the other?
	then sort out the rt tasks if needed
	
	*/
	wle1 := _wle1;
	wle2 := _wle2;
	request1 := wle1.myRequest;
	request2 := wle2.myRequest;
	job1 := wle1.job;
	job2 := wle2.job;
	ti1 := wle1.myTrackedItem;
	ti2 := wle2.myTrackedItem;
	
	truck1 := wle1.job.CM_RoadJob.myVehicle.locationsController;
	truck2 := wle2.job.CM_RoadJob.myVehicle.locationsController;
	
	//swap requests
	
	if ti1 &lt;&gt; null then
		job1.removeTI(ti1,request1);
	endif;
	if ti2 &lt;&gt; null then	
		job2.removeTI(ti2, request2);
	endif;
	if ti2 &lt;&gt; null then
		job1.CM_RoadJob.updateReleaseTI(ti2);
	endif;
	
	if ti1 &lt;&gt; null then
		job2.CM_RoadJob.updateReleaseTI(ti1);
	endif;
	
	request1.setJob(job2);
	request2.setJob(job1);
	wle1.moveToNewRequest(request1);
	wle2.moveToNewRequest(request2);
	

	//wle2 is now on request 1 job 1
//	request1.CM_TIRequest.myTrackedItemIfRelease := null;
	
/*	if ti2 &lt;&gt; null then
		request1.CM_TIRequest.setTrackedItem(ti2);
	endif;
	
	if ti1 &lt;&gt; null then
		request2.CM_TIRequest.setTrackedItem(ti1);
	endif;*/
	
	//wle1 is now on request 2 job 2
	
	if wle1.allRTQueueEntries.last &lt;&gt; null and wle1.allRTQueueEntries.last.allTasks.last &lt;&gt; null then
		if wle1.myTrackedItem &lt;&gt; null then
			app.myUtilityUA.utlUpdateRTTaskTargetLocation(truck2, wle1.allRTQueueEntries.last.allTasks.last , null,_passport);	
		else
			wle1.allRTQueueEntries.last.allTasks.last.setTargetLocation(truck2);
		endif;
	endif;
	
	if wle2.allRTQueueEntries.last &lt;&gt; null and wle2.allRTQueueEntries.last.allTasks.last &lt;&gt; null then
		if wle2.myTrackedItem &lt;&gt; null then
			app.myUtilityUA.utlUpdateRTTaskTargetLocation(truck1, wle2.allRTQueueEntries.last.allTasks.last , null,_passport);	
		else
			wle2.allRTQueueEntries.last.allTasks.last.setTargetLocation(truck1);
		endif;
	endif;
		
//	wle1.setNewLocationTarget(truck2);
//	wle2.setNewLocationTarget(truck1);

	self.utlUpdateVehicleVisitRecordTIs(job1.CM_RoadJob);
	self.utlUpdateVehicleVisitRecordTIs(job2.CM_RoadJob);
	
	app.myEventManager.createSingleObjInfoNoteEvt(wle1, wle1.job.getMyTerminal.getTerminalEvent(WLE_Update_Event), wle1);
	app.myEventManager.createSingleObjInfoNoteEvt(wle2, wle2.job.getMyTerminal.getTerminalEvent(WLE_Update_Event), wle2);
epilog

end;</source>
        <Parameter name="_wle1" type="CM_WorkListEntry"/>
        <Parameter name="_wle2" type="CM_WorkListEntry"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlSwapWLEJobCargo" id="dcb300cf-9b48-44e7-ac29-a759594aae1a">
        <updating/>
        <source>utlSwapWLEJobCargo(_wle1, _wle2 : CM_WorkListEntry; _targetLocation, _twinTargetLocation : String io; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/10/2025	navkc1 JIRA 36186 PNL | Vehicle App Swap behaviour with Release Requests - DB Changes / Jade / Form

*/

vars
	wle1,
	wle2		: CM_WorkListEntry;
	request1,
	request2	: CM_Request;
	job1,
	job2		: CM_Job;
	ti1,
	ti2			: CM_TrackedItem;
	reserve1,
	reserve2	: CM_ReserveDetail;
	truck1,
	truck2		: CM_VehicleController;
	rtqTask1,
	rtqTask2	: CM_RTQueueTask;
	terminal	: CM_Terminal;
	event		: Integer;
begin
	self.initialiseActivity();
	
	app.myValUA.valSwapWLEJobCargo(_wle1, _wle2, _targetLocation, _twinTargetLocation, _passport);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	wle1 := _wle1; 
	wle2 := _wle2;
	
	request1 := wle1.myRequest; 
	request2 := wle2.myRequest;
	
	job1 := wle1.job; 
	job2 := wle2.job;
	
	ti1 := wle1.myTrackedItem; 
	ti2 := wle2.myTrackedItem;
	
	reserve1 := request1.myReserveDetail;
	reserve2 := request2.myReserveDetail;
	
	truck1 := job1.CM_RoadJob.myVehicle.locationsController;
	truck2 := job2.CM_RoadJob.myVehicle.locationsController;
	
	// Swap TI between jobs
	// Remove 	TI 1 	from 	Job 1
	// Add		TI 1 	to 		Job 2
	// Remove 	TI 2 	from 	Job 2	
	// Add 		TI 2 	to 		Job 1
		if ti1 &lt;&gt; null then
			job1.removeTI(ti1,request1);
			job2.CM_RoadJob.updateReleaseTI(ti1);
		endif;
		
		if ti2 &lt;&gt; null then	
			job2.removeTI(ti2, request2);
			job1.CM_RoadJob.updateReleaseTI(ti2);
		endif;
		
	// Swap TI between release requests
	// Remove 	TI 1 from 	Release 1
	// Remove 	TI 2 from 	Release 2
	// Add 		TI 1 to 	Release 2
	// Add 		TI 2 to 	Release 1
		request1.removeBulkReleaseTI(ti1);	
		request2.removeBulkReleaseTI(ti2);	
		request1.setBulkReleaseTI(ti2);	
		request2.setBulkReleaseTI(ti1);
	
	// Swap TI between WLEs
	// Set TI 1 to WLE 2
	// Set TI 2 to WLE 1
		wle1.setMyTrackedItem(ti2); 
		wle2.setMyTrackedItem(ti1);
	
	// Swap TI between RT Tasks
	if wle1.allRTQueueEntries.last &lt;&gt; null and wle1.allRTQueueEntries.last.allTasks.last &lt;&gt; null then
		rtqTask1 := wle1.allRTQueueEntries.last().allTasks.last();
		if wle1.myTrackedItem &lt;&gt; null then
			rtqTask1.setDetails(rtqTask1.sourceLocation, rtqTask1.targetLocation, rtqTask1.status, rtqTask1.taskType, ti2);
		else
			wle1.allRTQueueEntries.last.allTasks.last.setTargetLocation(truck2);
		endif;
	endif;
	
	if wle2.allRTQueueEntries.last &lt;&gt; null and wle2.allRTQueueEntries.last.allTasks.last &lt;&gt; null then
		rtqTask2 := wle2.allRTQueueEntries.last().allTasks.last();
		if wle2.myTrackedItem &lt;&gt; null then
			rtqTask2.setDetails(rtqTask2.sourceLocation, rtqTask2.targetLocation, rtqTask2.status, rtqTask2.taskType, ti1);
		else
			wle2.allRTQueueEntries.last.allTasks.last.setTargetLocation(truck1);
		endif;
	endif;
	
	// Update VVR details to have same TI as Job
	self.utlUpdateVehicleVisitRecordTIs(job1.CM_RoadJob);
	self.utlUpdateVehicleVisitRecordTIs(job2.CM_RoadJob);
	
	// Switch the target location and pass back to the calling method for set down
	_targetLocation := rtqTask1.targetLocation.getFullId();
	_twinTargetLocation := rtqTask2.targetLocation.getFullId();
	
	
	// Send notification
	terminal := job1.getMyTerminal();
	if terminal &lt;&gt; null then
		event := terminal.getTerminalEvent(WLE_Update_Event);
		
		if event &lt;&gt; null then
			app.myEventManager.createSingleObjInfoNoteEvt(wle1, event, wle1);
			app.myEventManager.createSingleObjInfoNoteEvt(wle2, event, wle2);
		endif;
	endif;
	
epilog
	
end;</source>
        <Parameter name="_wle1" type="CM_WorkListEntry"/>
        <Parameter name="_wle2" type="CM_WorkListEntry"/>
        <Parameter name="_targetLocation" type="String" usage="io"/>
        <Parameter name="_twinTargetLocation" type="String" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlSwapWlePlannedLocations" id="0a73ecc6-f5ee-43b8-ba11-622594577eb9">
        <source>utlSwapWlePlannedLocations( _yardWLE1 : CM_YardWLE io; _yardWLE2 : CM_YardWLE io; _passport : CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 November 2010	cnwndl1	Initial creation	Par 25422

*/

vars

	newLocs1 : CM_WagonControllerArray;
	newLocs2 : CM_WagonControllerArray;
	task1 : CM_RTQueueTask;
	task2 : CM_RTQueueTask;

begin

	// get a copy of the respective coll of controllers (to be)
	create newLocs1 transient;
	create newLocs2 transient;
	_yardWLE1.allLocationControllers.copy( newLocs2 );
	_yardWLE2.allLocationControllers.copy( newLocs1 );
	
	// clear the existing collections ( and their inverses)
	_yardWLE1.allLocationControllers.clear();
	_yardWLE2.allLocationControllers.clear();
	
	// find the task(s) of the WLE's that we will be swapping locations with.
//	task1 := _yardWLE1.findFirstIncompleteTask();
//	task2 := _yardWLE2.findFirstIncompleteTask();
	task1 := _yardWLE1.findFinalIncompleteTask();	//23 Dec 2010	NDL	Par 26498 - handle multi move
	task2 := _yardWLE2.findFinalIncompleteTask();	//23 Dec 2010	NDL	Par 26498 - handle multi move
	
	// set the location controllers on the WLEs
	newLocs1.copy( _yardWLE1.allLocationControllers );
	newLocs2.copy( _yardWLE2.allLocationControllers );
	
	// set the location on the Tasks based on teh new loactions
	if task1 &lt;&gt; null then 
		task1.setTargetLocation( _yardWLE1.allLocationControllers.first );
		task1.myEntry.causeEvent(_passport.myTerminal.getTerminalEvent(RTQueueEntry_Update_Event), false, null);
	endif;
	if task2 &lt;&gt; null then
		task2.setTargetLocation( _yardWLE2.allLocationControllers.first );
		task2.myEntry.causeEvent(_passport.myTerminal.getTerminalEvent(RTQueueEntry_Update_Event), false, null);
		task2.myEntry.sendNotesForRelatedEntry();
	endif;
	
	// send notes to the world to let them know of the change
	app.myEventManager.createSingleObjInfoNoteEvt(_yardWLE1, _passport.myTerminal.getTerminalEvent(WLE_Update_Event), _yardWLE1);
	app.myEventManager.createSingleObjInfoNoteEvt(_yardWLE2, _passport.myTerminal.getTerminalEvent(WLE_Update_Event), _yardWLE2);
	
epilog

	delete newLocs1;
	delete newLocs2;

end;</source>
        <Parameter name="_yardWLE1" type="CM_YardWLE" usage="io"/>
        <Parameter name="_yardWLE2" type="CM_YardWLE" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlSwitchInvContracts" id="1246c224-8170-41a6-8e34-057e6453f19e">
        <source>utlSwitchInvContracts(_pxyObjectPrimary : CM_InvoiceContract; _pxyObjectOther : CM_InvoiceContract; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 March 2024 navrv30 Initial creation - Bug 62682: FR - 54089 - Primary status - Invoice contracts

*/
vars
	realObjectPrimary,
	realObjectOther : CM_InvoiceContract;
	theTerminal : CM_Terminal;
begin

	self.initialiseActivity();
	
	// do any pre-validation locks
	
	// do validation
	self.raiseExceptionIfNull(_pxyObjectPrimary, 'Invoice Contract');
	// do validation
	self.raiseExceptionIfNull(_pxyObjectOther, 'Invoice Contract');

	app.setContinueCMExceptions(true);
	
	app.myValUA.valUpdateInvContSwitchPrimary(_pxyObjectPrimary, _pxyObjectOther);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	realObjectPrimary := self.getRealObjectAndEditionCheck(_pxyObjectPrimary, 'Invoice Contract', _passport).CM_InvoiceContract;
	realObjectOther := self.getRealObjectAndEditionCheck(_pxyObjectOther, 'Invoice Contract', _passport).CM_InvoiceContract;

	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realObjectPrimary, true);
		self.myUpdateAuditAgent.audUpdateGeneric(realObjectOther, true);
	endif;

	if _passport.noErrors then	
		realObjectPrimary.setForUpdate(_pxyObjectPrimary);	
		
		realObjectOther.setForUpdate(_pxyObjectOther);
	endif;

	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realObjectPrimary, false);
		self.myUpdateAuditAgent.audUpdateGeneric(realObjectOther, false);	
		theTerminal := realObjectPrimary.getMyTerminal();
		app.myEventManager.createSingleObjInfoNoteEvt(realObjectPrimary.myBusinessUnit,theTerminal.getTerminalEvent(Event_InvContractUpdate),realObjectPrimary);
		app.myEventManager.createSingleObjInfoNoteEvt(realObjectOther.myBusinessUnit,theTerminal.getTerminalEvent(Event_InvContractUpdate),realObjectOther);
	endif;

end;</source>
        <Parameter name="_pxyObjectPrimary" type="CM_InvoiceContract"/>
        <Parameter name="_pxyObjectOther" type="CM_InvoiceContract"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlTISplit" id="5eeedb20-0d3e-49db-89d7-6c3cc2c3d875">
        <updating/>
        <source>utlTISplit(_tiToSplit : CM_TrackedItem input; _expectedEdition : Integer; _tisToCreate : CMIF_TISplitSet; 
	 _cloneTransactions : Boolean; _reasonCode, _recoveryCode, _comment	: String;
		_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     11 November 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	realObject		: CM_TrxTestObject;	
	expectedEdition	: Integer;
	totWeight	: Decimal[14,4];
	totLength,
	totQuantity	: Integer;
	totVolume	: Decimal[16,4];
	tmpTISplit	: CMIF_TISplit;
	updCntrl,
	updCntrl2	: CMIF_TIUpdateController;
	newTI		: CM_TrackedItem;
	moveController		: CMIF_MoveController;
	startingLocation	: CM_LocationsController;
	tmpSplitByLength,
	tmpSplitByQuantity,
	tmpSplitByVolume,
	tmpSplitByWeight	: Boolean;
	

begin

	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_tiToSplit, '_tiToSplit');
	self.raiseExceptionIfNull(_tisToCreate, '_tisToCreate');
	
	if _passport.hasErrors then
		return;
	endif;	

	_tiToSplit.raiseExceptionIfTransient(method);

	if _reasonCode &lt;&gt; null then
		if app.myRoot.allLogRejectCodes[_reasonCode] = null then
			app.raiseCMException2(ERR_FIELD_REASON, _reasonCode, app.getErrorString(Reason_Code), ETRow_ReasonCode, null);
		endif;
	endif;

	if _recoveryCode &lt;&gt; null then
		if (not app.myRoot.allLogRejectRecoveryCodes.includesKey(_recoveryCode)) then
			app.raiseCMException2(ERR_FIELD_RECOVERY, _recoveryCode, app.getErrorString(Recovery_Code), ETRow_RecoveryCode, null);
		endif;
	endif;

	exclusiveLock(_tiToSplit);

	if _tiToSplit.edition &lt;&gt; _expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, app.getErrorString(TrackedItem), null, null);
		return;
	endif;
	
	if _tiToSplit.hasChildren then
//		Tracked item %1 has children.  You cannot split a tracked item with children.
		app.raiseCMException1(CannotSplitTIWithChildren, _tiToSplit.id, null, null);
	endif;

	if _tisToCreate.isEmpty then
		// You have not specified any tracked items to split %1 into
		app.raiseCMException1(NoTIsForSplit, _tiToSplit.id, null, null);
	endif;

	if _passport.hasErrors then
		return;
	endif;	

	app.setContinueCMExceptions(true);
	
	foreach tmpTISplit in _tisToCreate do
		tmpTISplit.validateMe(_tiToSplit.myTerminal, _tiToSplit.cargoType);
		if _passport.hasErrors then
			return;
		endif;
		if tmpTISplit.isSplitByLength then
			tmpSplitByLength := true;
			totLength	:= totLength + tmpTISplit.length;
		endif;
		if tmpTISplit.isSplitByQuantity then
			tmpSplitByQuantity := true;
			totQuantity	:= totQuantity + tmpTISplit.quantity;
		endif;
		if tmpTISplit.isSplitByVolume then
			tmpSplitByVolume := true;
			totVolume	:= totVolume + tmpTISplit.volume;
		endif;
		if tmpTISplit.isSplitByWeight then
			tmpSplitByWeight := true;
			totWeight	:= totWeight + tmpTISplit.weight;
		endif;
	endforeach;
	
	if tmpSplitByLength and _tiToSplit.length &lt;&gt; totLength then
//		The total %1 for the split tracked items (%2) does not match the %1 of the original tracked item (%3)
		app.raiseCMException3(SplitTIsDontAddToParentQVW, app.getErrorString(Length), totLength.String, _tiToSplit.length.String, null, null);
	endif;
	if tmpSplitByQuantity and _tiToSplit.quantity &lt;&gt; totQuantity then
		app.raiseCMException3(SplitTIsDontAddToParentQVW, app.getErrorString(Quantity), totQuantity.String, _tiToSplit.quantity.String, null, null);
	endif;
	if tmpSplitByVolume and _tiToSplit.getMyTotalVolume &lt;&gt; totVolume then
		app.raiseCMException3(SplitTIsDontAddToParentQVW, app.getErrorString(Volume), totVolume.String, _tiToSplit.getMyTotalVolume.String, null, null);
	endif;
	//if tmpSplitByWeight and _tiToSplit.weight &lt;&gt; totWeight then				//-cnwml2 MSL CCMS 1017
	if tmpSplitByWeight and _tiToSplit.totalWeight &lt;&gt; totWeight then			//+cnwml2 MSL CCMS 1017
		//app.raiseCMException3(SplitTIsDontAddToParentQVW, app.getErrorString(Weight), totWeight.asStringWeightJMT(), _tiToSplit.weight.asStringWeightJMT(), null, null);		//-cnwml2 MSL CCMS 1017
		app.raiseCMException3(SplitTIsDontAddToParentQVW, app.getErrorString(Weight), totWeight.asStringWeightJMT(), _tiToSplit.totalWeight.asStringWeightJMT(), null, null);		//-cnwml2 MSL CCMS 1017
	endif;

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	// ==============================
	// Now validated so do the update
	// ==============================
	
	updCntrl := app.createTIUpdateControl(TI_UPDMODE_RECEIPT, _passport.userCode, null);
	updCntrl.transactionType := TRANS_TYPE_REASSEMBLY;	

	updCntrl.comment		:= _comment;
	updCntrl.reasonCode 	:= _reasonCode;
	updCntrl.recoveryCode 	:= _recoveryCode;

	// Initialise move controller parameters.
	create moveController transient;
	moveController.setMoveMode(REAL_MODE);
	moveController.isSystemMove := true;

	// Process each new TI.
	updCntrl2 := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);	
	foreach tmpTISplit in _tisToCreate do
		// Get cloned copy of old TI.
		newTI := _tiToSplit.cloneSelf(false);
		tmpTISplit.myNewTI := newTI;
		moveController.setMyToPrimaryLocation(_tiToSplit.myPrimaryActualLocation);
		newTI.setFromCMIF_TISplit(tmpTISplit, _tiToSplit, _cloneTransactions, updCntrl, moveController, _passport);
		if (not _passport.noErrors) then
			break;
		endif;
		newTI.validateTrackedItem(updCntrl2, _passport);
		if (not _passport.noErrors) then
			break;
		endif;
		
		startingLocation := newTI.getPrimaryLocation(REAL_MODE);

		if startingLocation &lt;&gt; tmpTISplit.myLocation then
			// Set new location if it is not the same as the old location
			moveController.setMyTrackedItem(newTI);
			moveController.setMyToPrimaryLocation(tmpTISplit.myLocation);
			app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);			
		endif;
		
		if (not _passport.noErrors) then
			break;
		endif;
	endforeach;

	if _passport.noErrors then
		//use the same updCntrl as it will have all the reassembly transaction from above set
		updCntrl.transactionType 	:= TRANS_TYPE_DISASSEMBLY;
		_tiToSplit.rejectTrackedItem(updCntrl, _passport);
	endif;

epilog
	delete updCntrl;
	delete updCntrl2;
	delete moveController;


end;</source>
        <Parameter name="_tiToSplit" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_expectedEdition" type="Integer"/>
        <Parameter name="_tisToCreate" type="CMIF_TISplitSet"/>
        <Parameter name="_cloneTransactions" type="Boolean"/>
        <Parameter name="_reasonCode" type="String"/>
        <Parameter name="_recoveryCode" type="String"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlTransferCompletedJobs" id="d4c74557-ccf7-430c-80c9-73af45ffcb43">
        <updating/>
        <source>utlTransferCompletedJobs(_fromJob : CM_VoyageJob; _toJob : CM_VoyageJob; _requests : CM_RequestSet; _passport : CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		16 September 2010 by cnwjo3
//
// Purpose:		ccms 1178 par 23366
//
vars
	fromJob, toJob : CM_VoyageJob;
	fromJobSheet, toJobSheet : CM_JobSheet;
	term : CM_Terminal;
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(false);
	term := _fromJob.getMyTerminal();
	
	if term = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, app.getErrorString(ERROR_NULL_Terminal), null, null);
		return;
	endif;
	
	//lock on both voyage jobs
	fromJob := _fromJob;
	toJob := _toJob;
	
	exclusiveLock(fromJob);
	exclusiveLock(toJob);
	
	fromJob.splitCompletedJobs(toJob,_requests);
	
	if _passport.hasErrors then				
		return;
	endif;		
	
	//cause notifications so forms pick it up
	fromJob.causeTerminalEvent(fromJob.Event_Mode_Update);
	if fromJob.myJobSheet &lt;&gt; null then
		fromJob.myVoyage.causeEvent(term.getTerminalEvent(JobSheet_Update_Event), false,fromJob.myJobSheet);
	endif;

	if toJob.myJobSheet &lt;&gt; null and fromJob.myJobSheet &lt;&gt; null then
		//ok.  we know they are both not null.  now we need to check if they are the same
		if toJob.myJobSheet &lt;&gt; fromJob.myJobSheet then
		//if they are the same we don't need to cause 2 events/notifications since this will cause the screen
		//Ship Job Controller to update twice.  Which is pointless
			toJob.myVoyage.causeEvent(term.getTerminalEvent(JobSheet_Update_Event), false,toJob.myJobSheet);
		endif;
	endif;
	
	toJob.causeTerminalEvent(fromJob.Event_Mode_Update);
	toJob.causeTerminalEvent(toJob.Event_Mode_Update);
end;</source>
        <Parameter name="_fromJob" type="CM_VoyageJob"/>
        <Parameter name="_toJob" type="CM_VoyageJob"/>
        <Parameter name="_requests" type="CM_RequestSet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlTransitTransfer" id="892628e2-8112-48b3-aaa3-5c23fd48e40a">
        <updating/>
        <source>utlTransitTransfer(_allCMIFBOLS : CMIF_Array; _voyageController : CM_LogVoyageController;
				_passport : CM_Passport input) updating;

vars
	originalBOL,
	newBOL		: CM_BOLOut;
	helper		: CMIF_DocketLocationHelper;
	iter,
	iter2		: Iterator;
	log			: CM_Log;
begin
	
	self.initialiseActivity();

	app.myValUA.valTransitTransfer(_allCMIFBOLS, _voyageController);
	if not _passport.noErrors() then
		return;
	endif;

	iter := _allCMIFBOLS.createIterator;
	while iter.next(helper) do
		originalBOL := helper.myBOL.CM_BOLOut;
		exclusiveLock(originalBOL);

		// Always create a new bol as they may only be transferring some logs on the old bol (DB/RJS 24Mar03)

		// Get Bol we will be using based on old bol number and voyage of specified controller.
		// newBOL := originalBOL.myStevedore.allBOLOutByNumberVoyage[originalBOL.number, _voyageController.myVoyage];

		// If we can't find one we need to create one based on original BOL specs.
		//if newBOL = null then
			newBOL := originalBOL.cloneSelf(false);
			newBOL.changeID(originalBOL.number, app.serverTimestampAtTrxStart);
			newBOL.cloneReferences(originalBOL, false);
			newBOL.resetTransitReferences(_voyageController);		
		//endif;
		
		// If it is a different docket then detach logs and reattach to new docket.
		//if newBOL &lt;&gt; originalBOL then
			iter2 := helper.allTIs.createIterator;
			while iter2.next(log) do
				self.exclusiveLock(log);
				originalBOL.detachTI(log);
				//epr TFS 5282 6/10/17 - logging
				if (newBOL &lt;&gt; null) then
					app.writeLog(method.qualifiedName &amp; " setting release BOL for log" &amp; log.id,  LogINFO);	
				endif;	
				log.setMyReleaseBOL(newBOL);
			endwhile;
			delete iter2;
		//endif;

		newBOL.myExtension.doVoyageTransfer(REAL_MODE, _voyageController, _passport);
	endwhile;

epilog
	delete iter;
	delete iter2;
end;</source>
        <Parameter name="_allCMIFBOLS" type="CMIF_Array"/>
        <Parameter name="_voyageController" type="CM_LogVoyageController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUnAssignWleFromWagon" id="5a49b658-8646-4175-9934-4513d98252af">
        <source>utlUnAssignWleFromWagon(_wle : CM_YardWLE input; _passport : CM_Passport input);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24/08/2009	cnwndl1	Initial creation CCMS 1094
08/11/210	cnwdap1	PAR #23794 CCMS MES 1102 Cause event on WLE for Load List screen
29 May 2025 navnk30	JIRA 34807: MTN | Rail Operations - Unassign Releases from Wagons - not updated in second screen
*/

vars
	wagonController	: CM_LocationsController;
	wagon			: CM_Wagon;
	updatedWagons	: CM_WagonSet;
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(false);
	
	self.raiseExceptionIfNull(_wle, app.getErrorString(Release_request));
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	create updatedWagons transient;		//29.05.2025 navnk30 JIRA 34807 START
	foreach wagonController in _wle.allLocationControllers where CM_WagonController.hasInstance(wagonController) do
		updatedWagons.tryAddIfNotNull(wagonController.CM_WagonController.myWagon);
	endforeach;							//29.05.2025 navnk30 JIRA 34807 END
	
	_wle.allLocationControllers.clear;
	app.myEventManager.createSingleObjInfoNoteEvt(_wle, _passport.myTerminal.getTerminalEvent(WLE_Update_Event), _wle);		// PAR #23794
	
	foreach wagon in updatedWagons do		//29.05.2025 navnk30 JIRA 34807 START
		app.myEventManager.createSingleObjInfoNoteEvt(wagon, _passport.myTerminal.getTerminalEvent(Wagon_Update_Event), wagon);
	endforeach;
epilog
	delete updatedWagons;
end;</source>
        <Parameter name="_wle" type="CM_YardWLE" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUndeleteTITransaction" id="6de28e57-de4b-48ed-ba0e-8a90a57a17d9">
        <updating/>
        <source>utlUndeleteTITransaction(_txn : CM_TITransaction input; 
						_passport : CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	12 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

	theTI : CM_TrackedItem;
begin

	self.initialiseActivity();
	//no validation required for undelete at this stage
	app.setContinueCMExceptions(false);

	app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(_txn, true);		// 15/10/18 MAP TFS41191

	theTI := _txn.myTrackedItem;
	theTI.unDeleteTransaction(_txn, _passport);

	app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(_txn, false);		// 15/10/18 MAP TFS41191
end;</source>
        <Parameter name="_txn" type="CM_TITransaction" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdInvStatusToReturned" id="ae760f2e-75e4-4334-acfe-d2deac55618c">
        <source>utlUpdInvStatusToReturned(_creditCMIF : CMIF_InvoiceStatus input; 
										_creditInv : CM_Invoice output; 
										_pendingInv : CM_Invoice output; 
										_passport : CM_Passport input);
/*

Purpose:			 // TFS 39618 PATCH 1
						 // TFS 39618 PATCH 1 put code in UTIL so can do audits and notification

Parameters:			

Return Value:		

Date		Who		Reason
30 January 2019	jlgab1	Initial creation

*/

vars
	returningInvoice : CM_Invoice;
begin
	self.initialiseActivity();

	if _creditCMIF &lt;&gt; null then	
		returningInvoice := _creditCMIF.myInvoice;
	endif;
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(returningInvoice, true);
	endif;
	
	app.setContinueCMExceptions(true);
	
	// ### TFS CR 58085 TASK 61348 11JAN2024 NAVAB1
	app.myValUA.valInvStatusToReturned(returningInvoice);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;	
	
	returningInvoice.doReturnProcessing(	_creditCMIF, //_creditCMIF : CMIF_InvoiceStatus;
											_creditInv,	//_creditInv : CM_Invoice output;
											_pendingInv,	//_pendingInv : CM_Invoice output;
											_passport	//_passport : CM_Passport input
											);
	
	if _passport.noErrors then // TFS 39618 PATCH 1
		self.myUpdateAuditAgent.audUpdateGeneric(returningInvoice, false);// TFS 39618 PATCH 1
		returningInvoice.causeEvent(returningInvoice.myTerminal.getTerminalEvent(Event_InvoiceUpdate), false, returningInvoice);// TFS 39618 PATCH 1
	endif;

epilog

end;</source>
        <Parameter name="_creditCMIF" type="CMIF_InvoiceStatus" usage="input"/>
        <Parameter name="_creditInv" type="CM_Invoice" usage="output"/>
        <Parameter name="_pendingInv" type="CM_Invoice" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
