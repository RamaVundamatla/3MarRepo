    <JadeMethod name="dumpJournal" id="efe19f87-53eb-48e9-9ca8-b07b75816a10">
        <updating/>
        <source>dumpJournal(file : File) updating;

vars

	user			: AAUser;
	puser			: AAUser;
	trans			: AATransaction;
	type			: Integer;
	objectType		: Integer;
	serialNumber	: Decimal[20];
	transactionId 	: Decimal[20];
	offset			: Integer;
	counter 		: Integer;
	recordOffset	: Integer;
	classNumber		: Integer;
	edition 		: Integer;
	timestamp		: TimeStamp;
	oid				: String;
	str 			: String;
	userName		: String;
	userIndex		: Integer;
	cUserName		: String;
	cUserIndex		: Integer;
begin

	while jaa.getNextRecord(type, objectType, recordOffset, timestamp, serialNumber, transactionId, oid, classNumber, edition) do
		if filterEndTime &lt;&gt; null and timestamp &gt; filterEndTime then
			break;
		endif;
		if type = JadeAuditAccess.Jaa_Type_ReorgDiscontinuity then
			write timestamp.String &amp; " REORG";
		endif;
		if type = JadeAuditAccess.Jaa_Type_NoAuditDiscontinuity then
			write timestamp.String &amp; " NoAuditDiscontinuity !";
		endif;
		if objectType = JadeAuditAccess.Jaa_Object_Null then
			if type = JadeAuditAccess.Jaa_Type_BeginTransaction then
				jaa.getUserData(userName, userIndex);
				newTransaction(userIndex, userName, timestamp, serialNumber, transactionId);
			endif;
			if type = JadeAuditAccess.Jaa_Type_CommitTransaction then
				trans := transactions[transactionId];
				if trans &lt;&gt; null then
					if timestamp &gt;= filterStartTime then
						
//if trans.includesOpsForClassNumber(2332) then						
						trans.dump(file, timestamp);
//endif;
					endif;
					endTransaction(transactionId);
					delete trans;
				else
//					write "tran: " &amp; transactionId.String &amp; " not found";
				endif;
			endif;
			if type = JadeAuditAccess.Jaa_Type_UserSignOn then
				jaa.getUserData(userName, userIndex);
				write "Sign on :" &amp; userIndex.String &amp; " " &amp; userName;
				addUser(userIndex, userName);
			endif;
			if type = JadeAuditAccess.Jaa_Type_UserSignOff then
				jaa.getUserData(userName, userIndex);
				write "Sign off :" &amp; userIndex.String &amp; " " &amp; userName;
				removeUser(userIndex) ;
			endif;
			if type = JadeAuditAccess.Jaa_Type_ChangeUser then
				jaa.getChangeUserData(userName, userIndex, cUserName, cUserIndex);
				write "change :" &amp; userIndex.String &amp; " " &amp; userName;
				changeUser(userIndex, userName);
			endif;
		endif;
		if objectType = JadeAuditAccess.Jaa_Object_Object then
			if type = JadeAuditAccess.Jaa_Type_Create then
				if timestamp &lt; filterStartTime then
					// skip object update records prior to startTime
					continue;
				endif;
				trans := transactions[transactionId];
				if trans &lt;&gt; null then
					trans.addObjectOp("Cre", objectType, oid, timestamp, edition);
				endif;
			endif;
			if type = JadeAuditAccess.Jaa_Type_Update then
				if classNumber = 187 then
					trans := transactions[transactionId];
					if trans &lt;&gt; null then
						userName := root.getProcessId(oid, timestamp);
						if userName &lt;&gt; null then
							trans.user.name := userName;
						endif;
					endif;
				else
					trans := transactions[transactionId];
				endif;
				if timestamp &lt; filterStartTime then
					// skip object update records prior to startTime
					continue;
				endif;
				if trans &lt;&gt; null then
					trans.addObjectOp("Upd", objectType, oid, timestamp, edition);
				endif;
			endif;
			if type = JadeAuditAccess.Jaa_Type_Delete then
				if timestamp &lt; filterStartTime then
					// skip object update records prior to startTime
					continue;
				endif;
				trans := transactions[transactionId];
				if trans &lt;&gt; null then
					trans.addObjectOp("Del", objectType, oid, timestamp, edition);
				endif;
			endif;
		endif;
	endwhile;

end;
</source>
        <Parameter name="file" type="File"/>
    </JadeMethod>
    <JadeMethod name="dumpJournals" id="45972baf-3c1d-4890-b671-f6dbb2f48ede">
        <updating/>
        <source>dumpJournals(outputFileName : String; path : String; startJournal : Integer; endJournal : Integer; startTime, endTime : TimeStamp) updating;

vars
	file			: File;
	offset			: Integer;
	result			: Integer;
	jnlNum			: Integer;
begin
	on Exception do jdExceptionHandler(exception, result);
	
	create file	   transient;
	file.openOutput(outputFileName);

	jaa.setAccessMode(4);
	if startTime &lt;&gt; null then
		// register termintation time with jaa
		jaa.registerFilterTimeRange(null, filterEndTime);
		// start time filtering is performed by dumpJournal since we need to process
		// signOn and change user records prior to the startTime
		filterStartTime := startTime;
		filterEndTime := endTime;
	endif;
	jaa.getJournal(path, startJournal, offset);
	while result = 0 do
		jnlNum := jaa.getJournalNumber();
		process.causeEvent(StartJournalEvent, true, jnlNum);
		dumpJournal(file);
		if jnlNum = endJournal then
			break;
		endif;
		jaa.getNextJournal();
		/*
		if result = JErr_DbFileNotFound or result = 3125 then
			process.causeEvent(MissingJournalEvent, true, result);
			result := 0;
		endif;
		*/
	endwhile;

	if result = 0 then
		process.causeEvent(JobCompletedEvent, true, 0);
	elseif result &lt;&gt; JErr_InterpUserInterrupt then	
		process.causeEvent(JobAbortedEvent, true, result);
	endif;

epilog
	file.close();
	delete file;
end;
</source>
        <Parameter name="outputFileName" type="String"/>
        <Parameter name="path" type="String"/>
        <Parameter name="startJournal" type="Integer"/>
        <Parameter name="endJournal" type="Integer"/>
        <Parameter name="startTime" type="TimeStamp"/>
        <Parameter name="endTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="endTransaction" id="793aa233-f805-4c13-b3c4-61bc5521d903">
        <updating/>
        <source>endTransaction(transactionId: Decimal) updating;

vars

begin
	transactions.removeKey(transactionId);
end;
</source>
        <Parameter name="transactionId" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="exceptor" id="d1990bc2-7d4e-4d49-9a8b-fcc2a98fa99d">
        <source>exceptor(ex : Exception) : Integer;

vars

begin
	if ex.errorCode = 1301 then
		return Ex_Resume_Next;
	endif;

	return Ex_Abort_Action;
end;
</source>
        <Parameter name="ex" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getUser" id="73b1a894-1e64-41c2-b246-a6f0b9da3918">
        <source>getUser( index : Integer) : AAUser;

begin
	return users[index];
end;
</source>
        <Parameter name="index" type="Integer"/>
        <ReturnType type="AAUser"/>
    </JadeMethod>
    <JadeMethod name="jdExceptionHandler" id="3f67b1a9-9b20-4cfe-b812-7e0cdda8898c">
        <source>jdExceptionHandler(ex : Exception; result : Integer output) : Integer ;
begin
	result := ex.errorCode;

	if result = JErr_InterpUserInterrupt or
	   result = JErr_DbFileNotFound or
	   result = 3125 					then
		return Ex_Resume_Next;
	endif;
		
	return Ex_Pass_Back;
end;
</source>
        <Parameter name="ex" type="Exception"/>
        <Parameter name="result" type="Integer" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
