<PrimType name="TimeStampOffset">
    <JadeMethod name="asLocalTimeStampJMT" id="363a0f09-9f6e-4d48-954e-7a0fa28026a8">
        <source>asLocalTimeStampJMT() : TimeStamp;
/*

Purpose:			JADEs implementation of asLocalTimeStamp/utcToLocalTime is not daylight savings aware (See Contact 55992 / NFS 43393)
					So use our helper method which is, instead

Parameters:			

Return Value:		

Date				Who		Reason
16 July 2024		navmd1	Initial creation TFS 65226

*/

vars

begin
	// The assumption here is that app has been initialised!
	// Please think carefully if you need to break that assumption
	return app.myTimeZoneHelper.convertTimeFromUtc(self.asUTCTimeStamp, app.systemTimeZoneID);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
</PrimType>
