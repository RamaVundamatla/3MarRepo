    <JadeMethod name="cnEcGetServerLocaleInfo" id="caf45b10-36c2-4d54-9f14-68398598f64e">
        <executionLocation>server</executionLocation>
        <source>cnEcGetServerLocaleInfo(pLocaleInfoObj:LocaleFullInfo io) serverExecution;
// -----------------------------------------------------------------------------
// Created:		24 December 2001 by cnwdad1
//
// Purpose:		Copies the Full Locale Information of the database server node
//				to the specified LocaleFullInfo parameter.
//
// Parameters:	pLocaleInfoObj - The locale info object to copy the server's
//					locale info onto.
//
// Returns:		The populated locale full info object as an IO parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	pLocaleInfoObj.cnEcCopyInfo(app.currentLocaleInfo);
end;</source>
        <Parameter name="pLocaleInfoObj" type="LocaleFullInfo" usage="io"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetXmlFormat" id="b4557b13-cdde-4765-80ef-df8946163e4a">
        <source>cnEcGetXmlFormat(pName : String) : CnEcXmlFormat;
// --------------------------------------------------------------------------------
// Created:		10 October 2000 by cnwdad1
//
// Purpose:		Returns a CnEcXmlFormat object corresponding to the specfified name.
//				If the format name is null found, a null value will be returned.
//
// Parameters:	pName - The name of the XML format.
//
// Returns:		The XML format object if the name is found, otherwise null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if app.isValidObject(self.myBaseRoot) then
		return self.myBaseRoot.getXmlFormat(self.myCnEcXmlSchema.name, pName);
	else
		CnEcBaseXmlException.raise_(CNEC_X_12000, "CnEcBaseRoot is null or does not exist.");
	endif;

	return null;
end;</source>
        <Parameter name="pName" type="String"/>
        <ReturnType type="CnEcXmlFormat"/>
    </JadeMethod>
    <JadeMethod name="cnEcInitializeBNZBuyLine" id="f7556660-77c1-41fa-8c08-78829023bab3">
        <updating/>
        <source>cnEcInitializeBNZBuyLine() updating;

vars
	buyLineMangerObj	: CnEcBNZBuyLineMgr;
	
begin
	app.cnActivateKarmaControl(Cn_Fat_Client, null, null);
	self.cnEcInitializeBaseSchema();

	buyLineMangerObj	:=	self.myBaseRoot.myBuyLineMgr;
		
	if buyLineMangerObj &lt;&gt; null then
		buyLineMangerObj.checkUnsentVoids();				
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="cnEcInitializeBackShed" id="dcf502e7-ee60-4bb4-a5f8-fe59a9ef52f5">
        <updating/>
        <source>cnEcInitializeBackShed()updating;
// -----------------------------------------------------------------------------
// Created:		14 December 2001 by cnwndl1
//
// Purpose:		Initialize method for the Background Scheduler application.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	app.cnActivateKarmaControl(Cn_Fat_Client, null, null);
	self.cnEcInitializeBaseSchema();

	self.myBackShedManager := CnEcBackShedManager.firstInstance();
	
	if self.myBackShedManager = null then
		beginTransaction;
			create self.myBackShedManager; 
		commitTransaction;
	endif;
	
	self.myBackShedManager.startApplication();
end;</source>
    </JadeMethod>
