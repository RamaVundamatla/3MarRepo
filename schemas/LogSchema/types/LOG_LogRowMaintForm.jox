    <JadeMethod name="doArchiveRows" id="1f361d0a-ebed-49a5-824d-d8ed55c2fbbb">
        <updating/>
        <source>doArchiveRows() updating;
// ---------------------------------------------------------------------------
// Created:     27 January 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	inputBox	: CMUI_InputBox;
	numHours	: Integer;
	errorSet	: CM_ErrorSet;
	theError	: CM_Error;
begin

	create inputBox transient;
	create errorSet transient;
	
//	inputBox.init(app.getErrorString(LBLHours), app.getErrorString(LBLEnterNumberHoursBeenEmpty),	// cnwrl1 05/06/2009 PAR 19574 - what it was
//				'8', 3, TextBox.DataType_Numeric, false);											// cnwrl1 05/06/2009 PAR 19574 - what it was
	inputBox.init(	app.getErrorString(LBLHours), app.getErrorString(LBLEnterNumberHoursBeenEmpty),
					'8', 3, TextBox.DataType_Numeric, TextBox.Case_None, false, false);
	
	inputBox.showModal;
	if inputBox.modalResult &lt;&gt; IDOK then
		return;
	endif;
	
	app.mousePointer := self.MousePointer_HourGlass;
	
	numHours := inputBox.txtInput.text.Integer;
	// self.myTerminal.archiveEmptyLocationsByType(TA_TYPE_LOGAREA, numHours, true, errorSet); // Mohammad par#13881 18-4-2007
	self.myTerminal.archiveEmptyLocationsByType(TA_TYPE_LOGAREA, numHours, false, errorSet);

	if not errorSet.isEmpty then
		app.myPassport.clearErrorsWarnings();
		foreach theError in errorSet do
			if theError.warningOnly then
				//app.addWarningFullPassport(RemoteDataError, theError.text, null, null, app.myPassport);
				app.addWarningFullPassport(theError.errorCode, theError.text, null, null, app.myPassport);	//13 Sep 2012	NDL	30366
			else
				//app.addErrorFullPassport(RemoteDataError, theError.text, null, null, app.myPassport);
				app.addErrorFullPassport(theError.errorCode, theError.text, null, null, app.myPassport);	//13 Sep 2012	NDL	30366
			endif;
		endforeach;
		app.showErrorWarningDialog('Archive', app.myPassport, ErrWarnMode_Update);
		self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
	else
		self.clearErrorWarnings();
	endif;

epilog
	delete inputBox;
	if errorSet &lt;&gt; null then
		errorSet.purge();
		delete errorSet;
	endif;
	app.mousePointer := self.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCancel" id="12dd8f50-a229-4e73-b394-3a7d86f7298f">
        <updating/>
        <source>doCancel(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     12 July 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	self.currentSelectedOperators.clear(); //28/08/2009 cnwdz2 PAR20519
	self.currentSelectedSpecies.clear();
	doEnableControls(false);

	return inheritMethod();

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doComboPositions" id="8104aa7c-345a-4ada-96aa-eb7a4c150e13">
        <source>doComboPositions() protected;

vars

	area : CM_TerminalArea;

begin

	// Load operator combo box.
//	self.myAssistant.comboBoxAddOperator(self.cmbOperator,app.myRoot.allOperators); now loaded on CMUI_ComboBoxObject::gotfocus
	self.allTerminalAreas.clear;
	foreach area in self.myTerminal.allTerminalAreas do
		if area.myType.type = TA_TYPE_LOGAREA then
			// Double check for invalid objects for now.
			if area.isKindOf(CM_RowArea) then
				self.allTerminalAreas.add(area);
			endif;
		endif;
	endforeach;
	
	// Load block combobox with available log areas.
	self.cmbBlock.listCollection(self.allTerminalAreas, false, 0);
	
	// Load transport combo box.
	self.cmbTransport.clear;
	self.cmbTransport.addItem('1' &amp; Tab &amp; 'Road');
	self.cmbTransport.addItem('2' &amp; Tab &amp; 'Rail');
	self.cmbTransport.addItem('3' &amp; Tab &amp; 'Both');
	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDelete" id="2a7ba2ae-fe80-45aa-bcdb-33012016629a">
        <updating/>
        <source>doDelete(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     25 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	result			: Boolean;
	controller		: CM_LogController;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin

	// Get current log controller.
	controller := self.myCurrentObject.CM_LogController;
	// Call trx delete row controller method.
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteRowController(controller, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			self.setVisibility(false);
			result := true;
			break;
		else
			theResult := app.showErrorWarningDialog('Row Maintenance', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		result := false;
		break;
		
	endwhile;

	return result;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doEnableControls" id="df84574c-9b94-4177-a36e-8bfe4e938df4">
        <source>doEnableControls(_enable : Boolean) protected;
	
begin

	// Enable or disable user input for input table.
	if _enable then
		self.tblInput1.userInputEnabled := true;
	else
		self.tblInput1.userInputEnabled := false;
	endif;
	
	// sgp 20 May 2003: self.allowArchive property is used to
	// determine the visiblity of btnArchive
//	if (not app.getMyUser.canDo(self.myTerminal, PmLogRowMaint)) then
//		btnArchive.visible := false;
//	else
//		btnArchive.visible := not _enable;
//	endif;
	
	// Enable or disable multi group boxes.
	self.multiOne.readOnly := not _enable;
	self.multiTwo.readOnly := not _enable;
	self.multiThree.readOnly := not _enable;
	self.multiFour.readOnly := not _enable;
	self.multiFive.readOnly := not _enable;
	self.multiSix.readOnly := not _enable;
	self.multiSeven.readOnly := not _enable;
	self.multiEight.readOnly := not _enable;
	
	// Enable or disable sheets.
	if not _enable then
		self.shtOne.visible := false;
		self.shtTwo.visible := false;
		self.shtThree.visible := false;
		self.shtFour.visible := false;			
		self.shtFive.visible := false;
		self.shtSix.visible := false;
		self.shtSeven.visible := false;
		self.shtEight.visible := false;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doGetPreviousData" id="3bc59318-ea7f-4115-9635-0195d192af34">
        <source>doGetPreviousData(_label : String; _typeOfSearch : Integer) protected;

vars

	previousName	: String;
	prevDistance	: Real;

begin
	if self.myCurrentLogArea &lt;&gt; null then
		// Call the rowArea method to return previous row controller.
		self.myCurrentLogArea.getPreviousData(_label, previousName, prevDistance, _typeOfSearch);
		if previousName = _label then	// adm 300708 Par 17575 do not set previous row to self
			previousName := null;
		endif;
		self.tblInput1.setValueByName(ETRow_PreviousRow, previousName);
		self.cmbPreviousRow.text := previousName;
		// If area is gap managed then set the distance from previous value.
		if self.myCurrentLogArea.isGapManaged then
			self.tblInput1.setValueByName(ETRow_DistanceFromPrevious, prevDistance);
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_label" type="String"/>
        <Parameter name="_typeOfSearch" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doLoadLabels" id="e059e471-9a7b-46d0-a7a7-be56a3da9ec2">
        <source>doLoadLabels(_area : CM_RowArea) protected;

vars

	string : String;

begin

	// Load row id and starting label combo boxes with labels from row area.
	if _area &lt;&gt; null then
		self.cmbRowId.clear;
		self.cmbStartingLabel.clear;
		foreach string in _area.allLabels do
			self.cmbRowId.addItem(string);
			self.cmbStartingLabel.addItem(string);
		endforeach;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_area" type="CM_RowArea"/>
    </JadeMethod>
    <JadeMethod name="doLoadLogCombos" id="94919893-8cda-4b6e-aa84-25bfff8718ee">
        <source>doLoadLogCombos(_logGrade : CM_LogGrade) protected;

vars

	logLength 		: CM_LogLength;
	logTreatment	: CM_LogTreatment;
	logType			: CM_LogType;

begin

	if self.myCurrentLogRestriction &lt;&gt; null then
		logLength 		:= self.myCurrentLogRestriction.allLogLengths.first.CM_LogLength;
		logTreatment	:= self.myCurrentLogRestriction.allLogTreatments.first.CM_LogTreatment;
		logType			:= self.myCurrentLogRestriction.allLogTypes.first.CM_LogType;
	endif;
	// Load combo boxes with available lengths, treatments and types.
	if _logGrade &lt;&gt; null then
		self.tblInput1.setValueByName(ETRow_LogGrade, self.displayGrades(_logGrade));
		self.cmbLogGrade.setObject(_logGrade);
		self.tblInput1.setValueByName(ETRow_LogGrade, self.displayGrades(_logGrade));
		self.cmbLogLength.setObjectAndGrade(logLength,_logGrade);
		self.tblInput1.setValueByName(ETRow_LogLength, self.displayLengths(logLength));
		self.cmbLogTreatment.setObjectAndGrade(logTreatment,_logGrade);
		self.tblInput1.setValueByName(ETRow_LogTreatment, self.displayTreatments(logTreatment));
		self.cmbLogType.setObjectAndGrade(logType,_logGrade);
		self.tblInput1.setValueByName(ETRow_LogType, self.displayTypes(logType));

	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_logGrade" type="CM_LogGrade"/>
    </JadeMethod>
    <JadeMethod name="doLoadPreviousRows" id="93f7bf3b-c0bd-47fa-a8a1-e9b763e4d02d">
        <source>doLoadPreviousRows(_area : CM_RowArea; _controller :CM_LogController) protected;

vars

	controller	: CM_RowController;
	
begin
	// Load previous row and split row combo boxes with available row controllers for row area.
	self.cmbPreviousRow.clear;
	self.cmbSplitRow.clear;
	self.cmbPreviousRow.addItem(' ');
	foreach controller in _area.allRowControllersById do	
		if _controller &lt;&gt; null and controller.id &lt;&gt; _controller.id then // adm 300708 Par 17575 do not load self into previous row combo
			self.cmbPreviousRow.addItem(controller.CM_LogController.id);
		endif;
		self.cmbSplitRow.addItem(controller.CM_LogController.id);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_area" type="CM_RowArea"/>
        <Parameter name="_controller" type="CM_LogController"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="e17fae87-7fb7-4feb-9361-f8e6e19860d2">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:     27 January 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();
	
	self.shtTblInput1.cnEcResizeContents();
	
	//11 Mar 2011	NDL	Par 27176
	if self.isSearcherVisible then
		if not self.isSearcherFloating then 
			self.searcherDockUndock(true);
		else
			self.tblSearch.adjustHeight(self.clientHeight); // is floating so just resize frm
			self.frmSearch.height := tblSearch.height + tblSearch.top + 15;
		endif;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="7bdf080b-18fe-42f6-8cfe-7f3601414a06">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     02 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	result 			: Boolean;
	newRow			: CM_LogController;

begin
	self.updateSheetsSelection();//28 August 2009	#cnwdz2	  PAR20519
	
	// Create cmif transient to transport detail.
	create self.cmif_LogRow transient;
	// Set cmif object attributes from form.
	if self.setCMIFObject() then
	
		if self.mode = Mode_Add then
			result := self.doSaveAdd(self.cmif_LogRow);
		else
			result := self.doSaveUpdate(self.cmif_LogRow);
		endif;

		if result then
			self.doEnableControls(false);
			//28/08/2009 cnwdz2 PAR20519
			self.currentSelectedOperators.clear();
			self.currentSelectedSpecies.clear();
		endif;
	else
	 	return false;
	endif;
	
	return result;
epilog

	delete self.cmif_LogRow;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveAdd" id="16f61573-f6ee-4130-8d2c-de96ecaf699f">
        <updating/>
        <source>doSaveAdd(_cmifLogRow: CMIF_LogRowRestriction input): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     02 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	result 			: Integer;
	newRow			: CM_LogController;
	returnVal		: Boolean;
begin

	while true do		
		app.myTrxCA.trxCreateLogRow(_cmifLogRow, newRow,app.myPassport);
		if app.myPassport.trxCompletedOK then
			returnVal := true;
			self.myCurrentObject := newRow;
			break;
		endif;
		result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
		if app.myPassport.noErrors and
		result = IDOK then
			// there must have just been warnings that the user has acknoledged so ..
			app.myPassport.warningsAcknowledged	:= true;
			continue;
		endif;

		returnVal := false;
		break;
	endwhile;
epilog	
	return returnVal;
end;</source>
        <Parameter name="_cmifLogRow" type="CMIF_LogRowRestriction" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveUpdate" id="168212ce-e68e-462f-a543-1cd179360f63">
        <updating/>
        <source>doSaveUpdate(_cmifLogRow: CMIF_LogRowRestriction input): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     02 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	result 			: Integer;
	returnVal		: Boolean;
begin

	// If updating pass proxy log controller into trx using cmif object.
	_cmifLogRow.myProxyLogController := self.myProxyObject.CM_LogController;
	// Get persistent row area reference.
	_cmifLogRow.myRowAreaRow := self.myCurrentObject.CM_RowController.myRow;

	while true do		
		app.myTrxUA.trxUpdateLogRow(_cmifLogRow,app.myPassport);
		if app.myPassport.trxCompletedOK then
			returnVal := true;
			break;
		endif;
		result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
		if app.myPassport.noErrors and
		result = IDOK then
			// there must have just been warnings that the user has acknoledged so ..
			app.myPassport.warningsAcknowledged	:= true;
			continue;
		endif;
	
		returnVal := false;
		break;
	endwhile;

epilog	
	return returnVal;
end;</source>
        <Parameter name="_cmifLogRow" type="CMIF_LogRowRestriction" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="fldInput_sheetChg" id="902c2d94-5099-499c-a094-a1c1f8b714d6">
        <controlMethod name="Folder::sheetChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>fldInput_sheetChg(folder: Folder input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 August 2009	#cnwdz2	  PAR20519

*/

vars
begin
	
	if self.previousSheet = self.shtOne and folder.topSheet &lt;&gt; self.shtThree then
		self.updateOperatorSelection();
	endif;	
	
	if self.previousSheet = self.shtTwo and folder.topSheet = self.shtThree then
		self.updateLogSpeciesSelection();
	endif;
	
	self.previousSheet := folder.topSheet;
epilog
end;</source>
        <Parameter name="folder" type="Folder" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAvailableCodesForRestrict" id="36f6e49c-e176-4fd0-b0c7-63fda3ec416b">
        <source>getAvailableCodesForRestrict(_allCodes : CM_CodesByCodeDict io; _currentRestrictCodes :CM_CodeSet);
// ---------------------------------------------------------------------------
// Created:     06 October 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	code			: CM_Code;
begin

	foreach code in _allCodes discreteLock do 
		if code.notAvailableForEntry then 
			if _currentRestrictCodes &lt;&gt; null and _currentRestrictCodes.includes(code) then
				// is in exsisting restriction so leave it in. 
				continue;
			endif;
			
			_allCodes.remove(code);
		endif;			
		
	endforeach;

end;</source>
        <Parameter name="_allCodes" type="CM_CodesByCodeDict" usage="io"/>
        <Parameter name="_currentRestrictCodes" type="CM_CodeSet"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="11c8c6f9-6a35-4900-ab0e-566f0cc4a429">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 March 2011	cnwndl1	Initial creation	Par 27176	/ CCMS 1117

*/

vars

	xmlStr	: String;

begin

	xmlStr := inheritMethod();
	
	xmlStr := xmlStr &amp; global.formatAsXML('IsSearcherVisible', self.isSearcherVisible.String);
	
	return xmlStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="05336f8f-ea9b-4a41-87d0-3beabbfe79ed">
        <updating/>
        <source>getXMLSettingsForSetup() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 March 2011	cnwndl1	Initial creation	Par 27176	/ CCMS 1117

*/

vars

	theXML : String;
	theXMLValue : String;
	userWindow : CM_UserWindow;

begin

	inheritMethod();

	userWindow := app.getUserWindow(self.name, false);
	
	if userWindow = null then
		self.showFilterOnStartup := true;
		return;
	endif;
	
	theXML := userWindow.xmlInfo;
	theXMLValue := theXML.cnEcGetTagValueOfName('IsSearcherVisible');
	
	self.showFilterOnStartup := theXMLValue.Boolean;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="hideStartingLabels" id="2680030a-89ed-41d2-931c-38ef0c4fc026">
        <source>hideStartingLabels(_isMarkedUp : Boolean) protected;

begin

	// This method hides and shows rows on the input table.
	
	// Is this area marked up.
	if  _isMarkedUp then
		// If we are in update mode or add mode and we aren't doing a split then enable.
		if not self.isRowSplit and (self.mode = self.Mode_Update or self.mode = self.Mode_Add) then		
			self.tblInput1.showRowByName(ETRow_StartRow, false);
			return;
		endif;
	endif;
	// Just hide.
	self.tblInput1.hideRowByName(ETRow_StartRow, false);
	
	
epilog
	
	if self.isRowSplit then
	//	self.tblInput1.hideRowByName(ETRow_DistanceFromPrevious, false);
		if (self.mode = self.Mode_Update or self.mode = self.Mode_Add) then
			self.tblInput1.showRowByName(ETRow_RowToSplit, false);
		else
			self.tblInput1.hideRowByName(ETRow_RowToSplit, false);
		endif;
		
	else
		self.tblInput1.hideRowByName(ETRow_RowToSplit, false);
		if self.myCurrentLogArea.isGapManaged then
			self.tblInput1.showRowByName(ETRow_DistanceFromPrevious, false);
		else
			self.tblInput1.hideRowByName(ETRow_DistanceFromPrevious, false);
		endif;
	endif;
	self.tblInput1.adjustHeight(1000);
end;</source>
        <access>protected</access>
        <Parameter name="_isMarkedUp" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initDataTable" id="88f0182e-4dad-49e9-becf-1cb418db3dfd">
        <updating/>
        <source>initDataTable() updating;
// ---------------------------------------------------------------------------
// Created:     30 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	
	self.zClearSortColumns();
	self.zAddSortColumn(ETRow_Id, false);
	self.tblData.setTerminologyRelevant(app.myRoot.allCargoTypesById[TI_CargoType_Log], self.myTerminal);
	self.setTblDataEntRows(ETDef_LogMaintDataTbl);	

end;</source>
    </JadeMethod>
    <JadeMethod name="initFilterTable" id="fb606c17-55f9-4480-8f10-54107066737c">
        <updating/>
        <source>initFilterTable() updating;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	entTableDef		: EntTableDef;
	theRow			: Integer;
	theTable		: CM_EntryTable;
	controller		: CMUI_Controller;
	startDate,
	endDate			: Date;	
	yes : String;
	no : String;
begin

	theTable := tblSearch;
	theTable.setTerminologyRelevant(app.myRoot.allCargoTypesById[TI_CargoType_Log], self.myTerminal);
	controller := app.myController;
	entTableDef := controller.getEntTableDef(ETDef_LogRowSearchFilter);
	
	if entTableDef &lt;&gt; null then
		theTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
		theTable.adjustHeight(200);
		self.cmbSearchBlock.listCollectionWithAny(self.allTerminalAreas, ETRow_Id);
		self.tblSearch.setValueByName(ETRow_Block, Any_String);

	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntTableDef TAFind not found');
	endif;

	self.cmbFiltStatus.addItem(Status_OpenClosed);
	self.cmbFiltStatus.addItem(Status_Open_Only);
	self.cmbFiltStatus.addItem(Status_Closed_Only);
	self.cmbFiltStatus.addItem(Status_Archived);
	self.cmbFiltStatus.addItem(Status_Empty);
	self.tblSearch.setValueByName(ETRow_FiltStatus, Status_OpenClosed);
	self.filterStatus := Status_OpenClosed;
	self.cmbFiltStatus.listIndex := 1;
	
	//10 Mar 2011	NDL	Par 27176	/ CCMS 1117
	self.myAssistant.comboBoxOperator(self.cmbFiltOperator, null, null);
	self.cmbFiltOperator.addItemAt(Any_String,1);
	self.tblSearch.setValueByName(ETRow_FiltSupplier, Any_String);
	self.cmbFiltOperator.listIndex := 1;
	self.cmbFiltOperator.lostFocus(self.cmbFiltOperator);
	
	yes := app.getErrorString(Yes);
	no := app.getErrorString(No);
	self.cmbFiltDocket.addItemAt(Any_String,1);
	self.cmbFiltDocket.addItemAt(yes,2);
	self.cmbFiltDocket.addItemAt(no,3);
	self.tblSearch.setValueByName(ETRow_FiltDocketChecked, Any_String);
	self.cmbFiltDocket.listIndex := 1;
	self.cmbFiltDocket.lostFocus(self.cmbFiltDocket);
	
	self.cmbFiltInspected.addItemAt(Any_String,1);
	self.cmbFiltInspected.addItemAt(yes,2);
	self.cmbFiltInspected.addItemAt(no,3);
	self.tblSearch.setValueByName(ETRow_FiltInspected, Any_String);
	self.cmbFiltInspected.listIndex := 1;
	self.cmbFiltInspected.lostFocus(self.cmbFiltInspected);
	
	self.cmbFiltFumigated.addItemAt(Any_String,1);
	self.cmbFiltFumigated.addItemAt(yes,2);
	self.cmbFiltFumigated.addItemAt(no,3);
	self.tblSearch.setValueByName(ETRow_FiltFumigated, Any_String);
	self.cmbFiltFumigated.listIndex := 1;
	self.cmbFiltFumigated.lostFocus(self.cmbFiltFumigated);
	
	self.cmbFiltScaled.addItemAt(Any_String,1);
	self.cmbFiltScaled.addItemAt(yes,2);
	self.cmbFiltScaled.addItemAt(no,3);
	self.tblSearch.setValueByName(ETRow_FiltCheckScaled, Any_String);
	self.cmbFiltScaled.listIndex := 1;
	self.cmbFiltScaled.lostFocus(self.cmbFiltScaled);
	// end of 27176
	
	//set status change default dates
	app.getDatesThisMonth(startDate, endDate);
	self.tblSearch.setValueByName(ETRow_StatusDateFrom, startDate);
	self.tblSearch.setValueByName(ETRow_StatusDateTo, endDate);
		
	self.showFilterViewForStatus();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initForm" id="f5e59b7b-061a-42ce-aee3-bfb8f366dbd9">
        <updating/>
        <source>initForm() updating;
// ---------------------------------------------------------------------------
// Created:     30 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin

	if self.amInitialisingWithObject then
		self.allowAdd	 := false;
		self.allowDelete := false;
	endif;
	
	self.initTblInput(self.tblInput1, ETDef_LogRowMaint);
	self.useTblThumb := true;
	self.frmDetailsBottom.visible := false;
	self.allowPrint  	:= false;
	self.allowExportCSV	:= false;
	self.fldInput.stretchToParent := true;
	self.tblInput1.warningMethod := 'entTableWarning';
	self.setTblInput1ViewForLogs();
	create myViewer as CMUI_ViewLogArea2 transient;
	self.setVisibility(false);
	self.shtTblInput1.caption := app.getErrorString(Detail);
	self.doComboPositions();
	
	self.getXMLSettingsForSetup();	//11 Mar 2011	NDL	Par 27176	/ CCMS 1117
//	self.showFilterOnStartup := true; //11 Mar 2011	NDL	Par 27176	/ CCMS 1117
	
	self.sptDataFilter.setLeftToRightRatioAndResize(50);
	
	self.fldInput.useSheetBackColors := true;
	self.fldInput.setDefaultSheetBackColors();
	self.fldInput.initSheetBackColors();


end;</source>
    </JadeMethod>
    <JadeMethod name="initTblInput" id="2072c37c-faad-4f68-aebb-ae8a722cdfbd">
        <source>initTblInput(pTable : CM_EntryTable; pDef : String) protected;
// ---------------------------------------------------------------------------
// Created:     30 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	entTableControl	: EntTableDef;
	theTable		: CM_EntryTable;
	
begin
	
	theTable := pTable;
	theTable.rows := 0;
	
	theTable.setTerminologyRelevant(app.myRoot.allCargoTypesById[TI_CargoType_Log], self.myTerminal);
	theTable.optimiseRowHeight := true;
	
	entTableControl := app.myController.getEntTableDef(pDef);
	theTable.setEntTableDef(entTableControl, null, 'entTableDefSetupWarning');
	
	theTable.top 	:= 5;
	theTable.left	:= 5;
	theTable.parentTopMargin	:= theTable.top;
	theTable.parentLeftMargin	:= theTable.left;
	theTable.parentRightMargin	:= 15;
	theTable.parentBottomMargin := 10;

	theTable.lockBottom := false;
	theTable.lockRight	:= false;
	theTable.stretchHeight := true;
	theTable.stretchWidth := true;
	
	theTable.pictureViewMethod := 'picViewMethod';
	theTable.pictureLoadMethod := 'picLoadMethod';
	theTable.pictureExtractMethod := 'picExtractMethod';
	theTable.resetSize();
	theTable.optimiseHeadingColumn();
	
	self.myAssistant.LOG_Assistant.comboBoxLogCntrlStatus(theTable, ETRow_Status);
		
end;</source>
        <access>protected</access>
        <Parameter name="pTable" type="CM_EntryTable"/>
        <Parameter name="pDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="cec7993f-f349-4360-969a-80fad08f8c68">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:     04 July 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod();
	self.tblThumb.cnAdjustColumnWidths();
	self.tblInput1.repositionAfterResize();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadTblInput1" id="04cff910-df6b-4499-a5b5-bac870d58ec5">
        <updating/>
        <source>loadTblInput1(_controller : CM_LogController) protected, updating;

vars
	realLogController : CM_LogController;

begin

	// We need a few details about the rowAreaRow which does not have a proxy.
	if _controller.isTransient then
		realLogController := self.myCurrentObject.CM_LogController;	
	else
		realLogController := _controller;
	endif;
	
	// Clear references and tables.
	self.tblInput1.clearValues;
	self.tblInput1.setTerminologyRelevant(app.myRoot.allCargoTypesById[TI_CargoType_Log], self.myTerminal);
	
	resetTblInput1(true);
	
	// Get reference to the controller.
	self.myCurrentLogRow := _controller;
	// Get reference to restriction.
	self.myCurrentLogRestriction := realLogController.myLocationRestriction.CM_LocationRestrictLog;
	// Set the rowArea.
	setCurrentArea(self.myCurrentLogRow.myTerminalArea.CM_LogArea);
	
	// Determine whether the rowArea row has more than one controller.
	if realLogController.myRow &lt;&gt; null and
	   realLogController.myRow.allRowControllers.size &gt; 1 then 
		self.isRowSplit := true;
		self.tblInput1.setValueByName(ETRow_RowSplit, true);
	else
		self.isRowSplit := false;
	endif;
	
	// Load up combos with the current rowArea labels.	
	doLoadLabels(self.myCurrentLogArea);
	// Load up combos with available controllers for this area.
	doLoadPreviousRows(self.myCurrentLogArea, _controller); // adm 300708 Par 17575 do not load selected row into previous row combo
	// Set mixed from reference from area.
	self.isMixedRow := self.myCurrentLogRestriction.mixedRow;
	self.tblInput1.setValueByName(ETRow_MixedRow, self.isMixedRow);
	setTransportMode(0);

	// Load correct view.
	setTblInput1ViewForLogs();
	// Hide or display rows depending on rowArea setup.
	hideStartingLabels(self.myCurrentLogArea.isMarkedUp);
	
	self.setOperators();//26/08/2009 cnwdz2 PAR20519
	self.setSpecies();
	self.setSelected(self.myCurrentLogRestriction, false);
	self.multiOne.getSelected(self.currentSelectedOperators);
	self.multiTwo.getSelected(self.currentSelectedSpecies);
	
	// Search for previous controllers.
	doGetPreviousData(_controller.getID, CM_RowArea.SEARCH_ACTUAL);
	// Adjust a few visibility parameters.
	setVisibility(false);
	
	// Set remainder of values every time.
	self.tblInput1.setValueByName(ETRow_TerminalAreaId, self.myCurrentLogRow.myTerminalArea.id);
	self.cmbBlock.listObject := self.myCurrentLogRow.myTerminalArea;
	self.tblInput1.setValueByName(ETRow_Id, self.myCurrentLogRow.getID);
	self.cmbRowId.text := self.myCurrentLogRow.getID;
	self.tblInput1.setValueByName(ETRow_MaxLength, self.myCurrentLogRestriction.maxLogLength);
	self.tblInput1.setValueByName(ETRow_EstimatedMaxVolume, self.myCurrentLogRestriction.estimatedMaxVolume);
	self.tblInput1.setValueByName(ETRow_Comment, self.myCurrentLogRestriction.comment);
	self.tblInput1.setValueByName(ETRow_Colour, self.myCurrentLogRestriction.colour);
	self.tblInput1.setValueByName(ETRow_Status, global.lcStatusEnumToString(realLogController.status));
	self.tblInput1.setValueByName(ETRow_IgnoreArchiving, self.myCurrentLogRow.ignoreArchiving.Integer);
	self.tblInput1.setValueByName(ETRow_DocketChecked, self.myCurrentLogRow.docketChecked);
	self.tblInput1.setValueByName(ETRow_CheckScaled, self.myCurrentLogRow.checkScaled);
	self.tblInput1.setValueByName(ETRow_IsInspected, self.myCurrentLogRow.isInspected);	// 10/09/2009 cnwar2 CCMS-1107/#20627
	self.tblInput1.setValueByName(ETRow_IsFumigated, self.myCurrentLogRow.isFumigated);	// 10/09/2009 cnwar2 CCMS-1107/#20627
	self.tblInput1.setValueByName(ETRow_IsExternallyVisible, self.myCurrentLogRow.isExternallyVisible);	//cnwrd1 ccms 1134 par 35101
	
	
	if realLogController.myRow &lt;&gt; null then
		self.tblInput1.setValueByName(ETRow_Width, realLogController.myRow.width);
	else
		self.tblInput1.setValueByName(ETRow_Width, 0);
	endif;	
end;</source>
        <access>protected</access>
        <Parameter name="_controller" type="CM_LogController"/>
    </JadeMethod>
    <JadeMethod name="resetTblInput1" id="17d68e48-375e-4a2a-82db-eb548e7dc7ca">
        <updating/>
        <source>resetTblInput1(_isOperator : Boolean) protected, updating;

vars

begin

	setSelected(null, true);
	self.myLogSpecies := null;
	if _isOperator then
		self.myOperator := null;
		self.cmbLogSpecies.clear;
		self.cmbLogSpecies.setObjectAndOperator(null,null);
	endif;
	self.cmbLogGrade.clear;
	self.cmbLogGrade.setObjectAndSpecies(null,null);
	self.cmbLogLength.clear;
	self.cmbLogLength.setObjectAndGrade(null,null);
	self.cmbLogTreatment.clear;
	self.cmbLogTreatment.setObjectAndGrade(null,null);
	self.cmbLogType.clear;
	self.cmbLogType.setObjectAndGrade(null,null);
	self.tblInput1.setValueByName(ETRow_LogSpecies, null);
	self.tblInput1.setValueByName(ETRow_LogTreatment, null);
	self.tblInput1.setValueByName(ETRow_LogLength, null);
	self.tblInput1.setValueByName(ETRow_LogType, null);
	self.tblInput1.setValueByName(ETRow_LogGrade, null);

end;</source>
        <access>protected</access>
        <Parameter name="_isOperator" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setCMIFObject" id="1a4736a9-0695-4e3d-96f0-8e9a3a18153a">
        <updating/>
        <source>setCMIFObject() : Boolean protected, updating;
//
// 16 Jan 2017	cnwrs1	TFS 3202 Length is not dependant on species
//
vars
	grade, type,
	treatment, length, species		: String;
	maxLogLength, transport			: Integer;
	estimatedMaxVolume				: Decimal[12,2];
	theSpecies						: CM_LogSpecies;
	object							: Object;
	tmpStatusStr					: String;
	// next, variables with p - memans parameters for setting cmif_LogRow object
	p_isMixedRow	: Boolean;
	p_rowArea		: CM_LogArea;
	p_logRowId		: String;
	p_allOperators,		// p_ means parameter variable for setting _cmifLogRow
	p_allSpecies,
	p_allGrades,
	p_allLogTypes,
	p_allTreatments,
	p_allLengths	: ObjectArray;
	p_status		: Integer;
	p_comment		: String;
	p_docketChecked,
	p_checkScaled,
	p_inspected,
	p_fumigated		: Boolean;
	p_estimatedMaxVolume: Real;
	p_transport			: Integer;
	p_ignoreArchiving	: Boolean;
	p_width				: Real;
	p_isSplit			: Boolean;
	p_user				: String;
	p_myRowAreaRowTo	: CM_RowAreaRow;
	p_previousRow		: String;
	p_distanceFromPrevious: Real;
	p_isExternallyVisible : Boolean;
begin
	p_logRowId	:= self.tblInput1.getValueByName(ETRow_Id).String.toUpper;
	p_rowArea := self.myCurrentLogArea.CM_LogArea;
	
	if p_logRowId = null then 
		app.msgBox("You have not entered a Row Id.", 
				'Missing Field', MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	
	if self.myCurrentLogArea = null then 
		app.msgBox("You have not entered a Block.", 
				'Missing Field', MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	
	create p_allOperators	transient;
	create p_allSpecies		transient;
	create p_allGrades		transient;
	create p_allLogTypes	transient;
	create p_allTreatments	transient;
	create p_allLengths		transient;
	
	//28 August 2009	#cnwdz2	 PAR20519
	//if self.myOperator &lt;&gt; null then //no operator, no restriction
		// Only check these if it is mixed row.
	if self.isMixedRow and self.currentSelectedOperators.size &gt; 0  then
		//26/08/2009 cnwdz2 PAR20519	
		self.multiOne.getSelected(p_allOperators);
		self.multiTwo.getSelected(p_allSpecies);
		self.multiSix.getSelected(p_allLengths);		
		if (not p_allSpecies.isEmpty()) then	// when no log species selected, all others should be null. #24512 30/06/2010
			self.multiThree.getSelected(p_allGrades);
			if (not p_allGrades.isEmpty) then		// if there are no grades, types, treatments and lengths should be null, too. #24512 29/06/2010
				self.multiFour.getSelected(p_allLogTypes);
				self.multiFive.getSelected(p_allTreatments);
			endif;
		endif;
	endif;
		
		// Only move on to check combo boxes if operator is not null.
	if not self.isMixedRow and self.myOperator &lt;&gt; null then
		p_allOperators.add(self.myOperator);
		species := self.tblInput1.getValueByName(ETRow_LogSpecies).String; 		
		theSpecies := self.myOperator.getLogSpecies(species);
		// Do we have a species.
		if theSpecies &lt;&gt; null then
			p_allSpecies.add(theSpecies);
		// If we are not mixed row and we have an operator and species we can continue.
			grade := self.tblInput1.getValueByName(ETRow_LogGrade).String; 		
			object := self.myOperator.getLogGrade(species, grade);
			if object &lt;&gt; null then
				p_allGrades.add(object);
			endif;
			type := self.tblInput1.getValueByName(ETRow_LogType).String; 		
			object := self.myOperator.getLogType(type);
			if object &lt;&gt; null then
				p_allLogTypes.add(object);
			endif;
			treatment := self.tblInput1.getValueByName(ETRow_LogTreatment).String; 		
			object := self.myOperator.getLogTreatment(treatment);
			if object &lt;&gt; null then
				p_allTreatments.add(object);
			endif;
			length := self.tblInput1.getValueByName(ETRow_LogLength).String; 		
			object := self.myOperator.getLogLength(length);
			if object &lt;&gt; null then
				p_allLengths.add(object);
			endif;
			
		endif;
	endif;
	// Populate cmif object with form values.
	//self.cmif_LogRow.myRowArea := self.myCurrentLogArea;
	p_estimatedMaxVolume := self.tblInput1.getValueByName(ETRow_EstimatedMaxVolume).Real;
	p_transport := self.tblInput1.getValueByName(ETRow_TransportMode).Integer;
	p_isMixedRow := self.isMixedRow;
	
	tmpStatusStr := self.tblInput1.getValueByName(ETRow_Status).String;
	p_status := global.lcStatusStringToEnum(tmpStatusStr);
	p_ignoreArchiving := self.tblInput1.getValueByName(ETRow_IgnoreArchiving).Integer = 1;

	p_isSplit := self.isRowSplit;
	//p_width := setRowWidth(self.tblInput1.getValueByName(ETRow_Width).Real);  // commented by ccms 1119, PAR 27433. setRowWidth() moved on cmif_LogRow
	p_width	:= self.tblInput1.getValueByName(ETRow_Width).Real;		// ccms 1119, PAR 27433. 
	
	p_user := app.getMyUserCode;
	p_comment := self.tblInput1.getValueByName(ETRow_Comment).String;
	// If we are a split we only want a refence to the to RowAreaRow.
	if p_isSplit then
		p_myRowAreaRowTo := self.myCurrentLogArea.getRowForSplit(self.tblInput1.getValueByName(ETRow_RowToSplit).String);
	endif;
	// We want previous row controller and distance.
	p_previousRow := self.tblInput1.getValueByName(ETRow_PreviousRow).String;
	p_distanceFromPrevious := self.tblInput1.getValueByName(ETRow_DistanceFromPrevious).Real;
	
	p_docketChecked	:= self.tblInput1.getValueByName(ETRow_DocketChecked).Boolean;
	p_checkScaled	:= self.tblInput1.getValueByName(ETRow_CheckScaled).Boolean;
	p_inspected	:= self.tblInput1.getValueByName(ETRow_IsInspected).Boolean; 	// 10/09/2009 cnwar2 CCMS-1107/#20627
	p_fumigated	:= self.tblInput1.getValueByName(ETRow_IsFumigated).Boolean; 	// 10/09/2009 cnwar2 CCMS-1107/#20627
	p_isExternallyVisible := self.tblInput1.getValueByName(ETRow_IsExternallyVisible).Boolean; 	 //cnwrd1 ccms 1134 par 35101
	 
	self.cmif_LogRow.set(p_rowArea,
						p_logRowId,
						p_allOperators,
						p_allSpecies,
						p_allGrades,
						p_allLogTypes,
						p_allTreatments,
						p_allLengths,
						p_status,
						p_comment,
						p_docketChecked,
						p_checkScaled,
						p_inspected,
						p_fumigated,
						p_isMixedRow,
						p_estimatedMaxVolume,
						p_transport,
						p_ignoreArchiving,
						p_width,
						p_isSplit,
						p_user,
						p_myRowAreaRowTo,
						p_previousRow,
						p_distanceFromPrevious,
						p_isExternallyVisible);
	
	
	return true;

epilog
	delete p_allOperators;
	delete p_allSpecies;
	delete p_allGrades;
	delete p_allLogTypes;
	delete p_allTreatments;
	delete p_allLengths;
	
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="694e0df0-ea7f-4ed2-a595-5f6cbd7b6a09">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     23 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theBackColor	: Integer;

begin
	inheritMethod(_colorControl);

	theBackColor	:= self.backColor;
	
	self.fldInput.backColor	:= theBackColor;
	self.shtTblInput1.backColor	:= theBackColor;

	self.shtOne.backColor	:= theBackColor;
	self.shtTwo.backColor	:= theBackColor;
	self.shtThree.backColor	:= theBackColor;
	self.shtFour.backColor	:= theBackColor;
	self.shtFive.backColor	:= theBackColor;
	self.shtSix.backColor	:= theBackColor;
	self.shtSeven.backColor	:= theBackColor;
