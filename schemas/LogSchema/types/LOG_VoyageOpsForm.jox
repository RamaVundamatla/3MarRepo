    <JadeMethod name="setupShtShipsideScan" id="bc2036c2-0d1c-4ea9-9ab0-ebd874588e95">
        <updating/>
        <source>setupShtShipsideScan() updating;
// ---------------------------------------------------------------------------
// Created:     31 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpTop : Real;			
begin
	if self.fldInfo.topSheet &lt;&gt; self.shtSSScan then
		return;
	endif;
	tmpTop := tblDownloadInfo.top;
	tblDownloadInfo.height := shtSSScan.height - (tmpTop*2) - btnSelectAll.height - 12;
	tblDownloadInfo.width := (shtSSScan.width/2) - WinLeftMargin*3;

	lblDwnLogFile.move(shtSSScan.width/2, tmpTop, lblDwnLogFile.width, lblDwnLogFile.height);	
	btnSSSExportFile.move(shtSSScan.width - btnSSSExportFile.width - WinLeftMargin, tmpTop + VerticalSpacing + txtDwnLogFile.height, btnSSSExportFile.width, btnSSSExportFile.height);	
	btnDwnBrowseLog.move(btnSSSExportFile.left - btnDwnBrowseLog.width - HorizontalSpacing, tmpTop, btnDwnBrowseLog.width, btnDwnBrowseLog.height);
	txtDwnLogFile.width := shtSSScan.width - lblDwnLogFile.left - lblDwnLogFile.width - WinLeftMargin - btnDwnBrowseLog.width - btnSSSExportFile.width - HorizontalSpacing*3;
	txtDwnLogFile.move(lblDwnLogFile.left + HorizontalSpacing + lblDwnLogFile.width, tmpTop, txtDwnLogFile.width, txtDwnLogFile.height);

	lblDwnShipFile.move(lblDwnLogFile.left, txtDwnShipFile.top, lblDwnShipFile.width, lblDwnShipFile.height);
	btnDwnBrowseShip.move(btnDwnBrowseLog.left, btnDwnBrowseLog.top + btnDwnBrowseLog.height + VerticalSpacing, btnDwnBrowseShip.width, btnDwnBrowseShip.height);
	txtDwnShipFile.move(txtDwnLogFile.left, btnDwnBrowseShip.top, txtDwnLogFile.width, txtDwnLogFile.height);

	lblsssLine.top := lblDwnShipFile.top + VerticalSpacing + txtDwnShipFile.height;

	lblImportFile.top := lblsssLine.top + lblsssLine.height + VerticalSpacing; 
	btnImportBrowse.move(btnDwnBrowseShip.left, lblImportFile.top + lblImportFile.height, btnImportBrowse.width, btnImportBrowse.height);
	btnImportLogOut.move(btnSSSExportFile.left, btnImportBrowse.top, btnImportLogOut.width, btnImportLogOut.height);

	self.btnSelectChanges.left := tblDownloadInfo.left + tblDownloadInfo.width - btnSelectChanges.width;
	self.btnSelectAll.left := btnSelectChanges.left - HorizontalSpacing - btnSelectAll.width;
	
	//Changed to allow for skin settings that were causing caption to be 'cut off'.  
	self.btnSSSLoad.left := self.btnImportLogOut.left + self.btnImportLogOut.width - self.btnSSSLoad.width;
	self.btnSSSSelect.left := btnSSSLoad.left - btnSSSLoad.width - HorizontalSpacing;	
	//self.btnSSSExport.move(btnSSSSelect.left - HorizontalSpacing - btnSSSSelect.width, btnSSSSelect.top, btnSSSExport.width, btnSSSExport.height);
	self.fldSSSLoadOut.left := lblDwnLogFile.left;
	self.fldSSSLoadOut.top := btnImportLogOut.top + btnImportLogOut.height + tmpTop;
	self.fldSSSLoadOut.width := shtSSScan.width/2 - WinLeftMargin;
	self.fldSSSLoadOut.height := tblDownloadInfo.height - btnImportLogOut.top - btnImportLogOut.height;
	self.fldSSSLoadOut.cnEcResizeContents();
	
	lblsssLine.move(lblDwnLogFile.left, lblsssLine.top, fldSSSLoadOut.width, lblsssLine.height);

	lblImportFile.left := lblsssLine.left;
	txtImportFile.width := shtSSScan.width - lblsssLine.left - btnImportLogOut.width - btnImportBrowse.width - WinLeftMargin - HorizontalSpacing*2;
	txtImportFile.move(lblsssLine.left, btnImportBrowse.top, txtImportFile.width, txtImportFile.height);		
	
	/*self.setEnableObjectsSSS();
	tblDownloadInfo.rows := tblDownloadInfo.fixedRows;
	tblSSSEDIData.rows := tblSSSEDIData.fixedRows;
	tblSSSDockets.rows := tblSSSDockets.fixedRows;		
		
	if self.myCurrentVoyage = null then
		self.showCannotAccessSheetMsg(shtSSScan, 'You must select a terminal in the list box before you can do a download');
		return;
	else
		self.hideCannotAccessSheetMsg(shtSSScan);
	endif;
	if (not self.myCurrentVoyage.isKindOf(CM_LogVoyage)) then
		app.msgBox('Current voyage is not a log voyage.  Cannot continue', 'Error', MsgBox_OK_Only);
		return;
	endif;
	
	self.mySSSLogVoyage := self.myCurrentVoyage.CM_LogVoyage;
	self.showDownloadData();
	self.sssShowEDIData();
	self.sssShowDocketsToBeLoaded();*/

end;</source>
    </JadeMethod>
