    <JadeMethod name="createBULKOnVoyage" id="bd40521e-9e79-4105-a5e0-433b2b921850">
        <source>createBULKOnVoyage(_delete : Boolean; _contractId,_id : String; _cargoType : CM_CargoType; _operator : CM_Operator; _voyage : CM_Voyage; _port : CM_Port; _weight : Decimal; _volume : Decimal; _quantity : Integer; _cargoGroup : CM_CargoGroup input) : CM_TrackedItem;
/*
Purpose - 	
Who - NAVAB1
Date - 05MAR2024
ADO -  BUG 62748
*/

vars
	cargo : CM_TrackedItem;
	lc : CM_LocationsController;
	product : CM_Product;
	prevOp : CM_Operator;
begin
	if _delete then
		self.deleteCargo(_id, _cargoType);
	endif;
	
	lc := _voyage.myShipBlockStack;
	
	
	product := _cargoType.allProducts.first;   ////////getProductFromCode("12POUNDER-12");
	if product&lt;&gt; null
	and product.myOperator &lt;&gt; null 
	and product.myOperator &lt;&gt; _operator then
		prevOp := product.myOperator;
		beginTransaction;
		product.setMyOperator(_operator);
		commitTransaction;
	endif;
	//create cargo on ship
	self.opts.addAssoc("Product", product);
	self.opts.addAssoc("TotalQuantity",_quantity); 
	cargo := lc.createNewCargoForLCDetailed(_cargoType,product, _id, _port.code, TI_IMEX_STATUS_IMPORT, _voyage,_operator, _quantity, _cargoGroup).CM_Cargo;// ### TFS CR 59942 TASK 59943 23AUG2023 NAVAB1
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(cargo);
	self.opts.addAssoc("Commodity", "COM2");
	self.opts.addAssoc("TotalVolume", _volume.Integer);
	self.opts.addAssoc("CargoLength", 111.0);
	self.opts.addAssoc("CargoWidth", 222.0);
	self.opts.addAssoc("CargoHeight", 333.0);
	self.opts.addAssoc("Description", "CargoDesc2");
	self.opts.addAssoc("ClientRef", "ClientRef2");
	self.opts.addAssoc("Consignee", "UTDDC");
	self.opts.addAssoc("Consignor", "UTMO1");
	self.opts.addAssoc("ContractId",_contractId);
	self.opts.addAssoc("TotalWeight", _weight.Integer);
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); // ### TFS CR 59615 TASK 59620 15AUG2023 NAVAB1
	
	self.updateTI(cargo);
	assertEqual(cargo.totalQuantity, _quantity);
	assertEqual(cargo.totalWeight, _weight.Decimal);
	assertEqual(cargo.totalVolume, _volume.Decimal);

	self.assertTrueMsg(cargo.contractId = _contractId, "Cargo Contract Id is wrong");
	
	if prevOp &lt;&gt; null then
		beginTransaction;
		product.setMyOperator(prevOp);
		commitTransaction;
	
	endif;
	
	return cargo;
epilog

end;</source>
        <Parameter name="_delete" type="Boolean"/>
        <Parameter name="_contractId" type="String"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_port" type="CM_Port"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_volume" type="Decimal"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_cargoGroup" type="CM_CargoGroup" usage="input"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="createCargoOnShip" id="fe3b947f-dc05-4e04-8a03-0d7cff6e2385">
        <source>createCargoOnShip(_voyage : CM_Voyage; _number : Integer);
// ---------------------------------------------------------------------------
// Created:     31 May 2010 by NAVAB1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//	Create cargo in the ship block stack and for a limited number of items
// ---------------------------------------------------------------------------

vars
	location : CM_LocationsController;
	cargo : CM_TrackedItem;
	idx : Integer;
	aPort : CM_Port;
	id,
	isoType,
	commod	: String;
	ids,
	isoTypes,
	commodities	: StringArray;
begin

	aPort := app.myRoot.allPorts[_voyage.myTerminal.getConfig(PortDestCode).String];
	location := _voyage.myShipBlockStack;
	
	create ids transient;
	create isoTypes transient;
	create commodities transient;
	
	self.getOnshipIds(ids, isoTypes, commodities);
	
	foreach id in ids do
		idx := idx + 1;
		if idx &lt;= _number then
			isoType := isoTypes[idx];
			commod := commodities[idx];
		
			self.deleteContainer(id);
			cargo := self.addContainerAtLocnDisch(id, isoType, commod, TI_IMEX_STATUS_IMPORT, location, aPort, _voyage);
			self.assertTrueMsg((cargo.getImExStatus() = TI_IMEX_STATUS_IMPORT), "ImEx on Imports is wrong" );
		endif;
	endforeach;

epilog
	delete ids;
	delete isoTypes;
	delete commodities;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_number" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="createCargoOnSite" id="fc14c65e-f582-4a98-840d-cd76eee80c33">
        <updating/>
        <source>createCargoOnSite(_voyage : CM_Voyage; _number : Integer; _daysBack : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     4/08/2016 version which returns the number of requested cargo items (don't need all of these for most tests)
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// Create cargo in a given block stack and for a limited number of items
// 10 September 2023 navmv20 CR 58250 Task 58252: Jade - New mapping methods
// 28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
// ---------------------------------------------------------------------------

vars
	idx			: Integer;
	now			: Date;
	baseDate	: Date;
	bs: CM_BlockStack;
	location : CM_LocationsController;
	voy : CM_Voyage;
	cargo : CM_TrackedItem;
	containers	: ObjectArray;
	obj	: Object;
	aPort : CM_Port;
	id,
	isoType,
	commod	: String;
	ids,
	isoTypes,
	commodities	: StringArray;
begin
	voy := _voyage;

	aPort := app.myRoot.allPorts["NZAKL"];

	create containers transient;
	
	bs:= self.getTerminalArea("UTINVBS").CM_BlockStack;
	if bs &lt;&gt; null then
		self.deleteInvoiceLines(bs.myLocationsController);
	endif;
	deleteTerminalArea("UTINVBS");
	bs:= addBlockStack("UTINVBS", 100, null);
	location := bs.myLocationsController;

	create ids transient;
	create isoTypes transient;
	create commodities transient;
	
	self.getOnsiteIds(ids, isoTypes, commodities);

	foreach id in ids do
		idx := idx + 1;
		if idx &lt;= _number then
			isoType := isoTypes[idx];
			commod := commodities[idx];
		
			self.deleteContainer(id);
			cargo := self.addContainerAtLocnDisch(id, isoType, commod, TI_IMEX_STATUS_EXPORT, location, aPort, _voyage);
			containers.add(cargo);
		endif;
	endforeach;

	// set transaction dates back the given number of days
	baseDate := now - _daysBack;	// cargo create date
	foreach obj in containers do
		cargo := obj.CM_TrackedItem;
		self.setTransactionDate(cargo, baseDate);
		beginTransaction; // ### TFS BUG 60548 10OCT2023 NAVAB1
		cargo.evaluateFreeStorageDays(null,true); //10/09/2023 navmv20 CR 58250 Task 58252		//28.05.2024 navma1 #64224
		commitTransaction;
	endforeach;

epilog
	delete ids;
	delete isoTypes;
	delete commodities;
	delete containers;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_number" type="Integer"/>
        <Parameter name="_daysBack" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="createContainerOnShip" id="1685e2cc-225d-425b-8001-78836abcabf7">
        <source>createContainerOnShip(_contractId, _id : String; _operator : CM_Operator; _voyage : CM_Voyage; _port : CM_Port; _weight : Integer) : CM_Container;
/*
Purpose:			

Date		Who		Reason
13FEB2023	NAVAB1	CR 56446 TASK 56447  
*/

vars
	cont : CM_Container;
begin
	self.deleteContainer(_id);
	
	cont := self.addContainerOnShip( _id , _operator, "2200", "GENL", null, _voyage, _port.code, _voyage.code).CM_Container;
	self.assertNotNull(cont);
	self.opts.addAssoc("Description", "CargoDesc1");
	self.opts.addAssoc("ClientRef",  "ClientRef21");
	self.opts.addAssoc("Consignee",  "UTDDC");
	self.opts.addAssoc("Consignor",  "UTMO1");
	self.opts.addAssoc("ContractId",_contractId);
	self.opts.addAssoc("TotalWeight",_weight);

	if _id[1:2] = "OD" then
		self.opts.addAssoc("OverDimension", true);
	endif;
	
	self.updateTI(cont);

	self.assertTrueMsg(cont.contractId = _contractId, "Container Contract Id is wrong");
	assertEqual(cont.totalWeight, _weight.Decimal);

	return cont;
epilog

end;</source>
        <Parameter name="_contractId" type="String"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_port" type="CM_Port"/>
        <Parameter name="_weight" type="Integer"/>
        <ReturnType type="CM_Container"/>
    </JadeMethod>
    <JadeMethod name="createFileCategory" id="d6dce50e-5400-4e7e-9b2c-dd6483dbf449">
        <source>createFileCategory(pxyFileCategory : CM_FileDataCategory input ;
				   realFileCategory: CM_FileDataCategory output		
									);
