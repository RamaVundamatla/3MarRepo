    <JadeMethod name="initShtDataTable1" id="7bc0bc42-6fe3-4893-9bb8-55e7c2f726c8">
        <updating/>
        <source>initShtDataTable1() updating;
// ---------------------------------------------------------------------------
// Created:     21 February 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
sht							: CMUI_Sheet;
	tbl							: CM_DataTable;
begin
//	inheritMethod();
	sht := self.myForm.shtDataTable1;
	tbl := self.myForm.tblData1;

	tbl.tabKey := J_key_Tab;
	
	sht.caption := 'Line Company Resources';
	sht.visible := true;

	tbl.rows := 1;
	tbl.columns := 4;
//	tbl.accessColumn(1).inputType := Table.InputType_CheckBox;
	
	tbl.accessCell(1,1).text := 'Harbour' &amp; Tab &amp; 
								'Arrival Resource' &amp; Tab &amp; 
								'Departure Resource' &amp; Tab &amp; 
								'Shift Resource';
	
//	self.myForm.cmbResourceArr.automaticCellControl := true;
//	self.myForm.cmbSystemRole.automaticCellControl := true;
//	self.myForm.cmbCargoBOLType.automaticCellControl := true;

	// this should really be done by calling the superclass method !!!
	self.myForm.frmTBDataTable1.visible	:= false;	// par 19830 concms1 june2009
end;</source>
    </JadeMethod>
