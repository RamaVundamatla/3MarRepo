    <JadeMethod name="displayEvents" id="3a76d186-8299-470e-9158-3e33dba04d34">
        <source>displayEvents();
/*
Purpose:			
Date		Who		Reason
03 February 2017	cnwab1	Initial creation
*/

vars
	str : String;
    eventType : CM_EventType;
	event : CM_EventTransaction;
	idx, completedColumn : Integer;
	isCompleted : Boolean;
begin
	self.tblData.rows := self.tblData.fixedRows;
	
	if self.tblData = null then
		return;
	endif;
	
	endNotificationForSubscriber(self);
	
	foreach eventType in self.myCurrentVoyage.allAllocatedEvents discreteLock do
		str := eventType.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);

		self.tblData.addItemObject(eventType, str);
	endforeach;
	
	completedColumn := self.tblData.getColumnByHeading(ETRow_Completed);

	foreach idx in self.tblData.fixedRows + 1 to self.tblData.rows discreteLock do
		eventType := self.tblData.accessRow(idx).itemObject.CM_EventType;
		if eventType= null then
			self.tblData.accessCell(idx,completedColumn).text := "No";
		else
			event := self.myCurrentVoyage.getEventOfTypeShiftFirst(eventType, self.myCurrentShift);
			
			isCompleted := event &lt;&gt; null;
			
			self.tblData.accessCell(idx,completedColumn).text := isCompleted.cnEcGetYesNo();
			if isCompleted then
				self.tblData.accessedRow.itemObject := event;
				
				self.beginNoteForEvent(event);
			endif;
		endif;
	endforeach;
	self.beginClassNotification(CMEVT_VoyageEvent, false, Object_Create_Event, Response_Continuous, 0);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="c08e04c1-fc33-4243-98b1-732bc4c87db6">
        <updating/>
        <source>doBaseFormSave() updating, protected;
/*
Purpose:			
Date		Who			Reason
FEB 2017	CNWAB1		Initial creation
29/05/2017	cnwdap1		TFS 4248 LNX Voyage Event Allocation
*/


vars
	realEvent, proxyEvent : CM_EventTransaction;
	allPreWarnings : HugeStringArray;
	eventType 	: CM_EventType;
	timeStamp 	: TimeStamp;
	endTimeStamp: TimeStamp;
	endDate 	: Date;
	endTime 	: Time;
	loadState 	: Boolean;
	date : Date;
	time : Time;
	noCharge : Boolean;
	theReturn : Integer;
	amount : Decimal[16,4]; 
begin
	
	date := self.txtDate.getDate;
	time := self.txtTime.getTime;
	timeStamp.setDate(date);
	timeStamp.setTime(time);
	endTimeStamp := null;
	if self.txtEndDate.visible then
		endDate := self.txtEndDate.getDate;
		endTime := self.txtEndTime.getTime;
		endTimeStamp.cnEcSetDateAndTime(endDate,endTime);
	endif;
	noCharge :=  true;
	amount := self.txtAmount.text.asDecimalJMT;
	
	if self.mode = self.Mode_Add then
		eventType := self.myCurrentEventType;
		create allPreWarnings transient;
		if eventType = null then
			allPreWarnings.add(app.getErrorString(Must_select_event_type));
		endif;
		if not allPreWarnings.isEmpty then
			app.showErrorWarningDialogArray(app.getErrorString(Train_event_update), allPreWarnings, null, ErrWarnMode_CanAckWarnings);
		endif;
		proxyEvent:=eventType.createEvent(self.localToSystemTime(timeStamp),self.myTerminal,app.myPassport.myUser.code,true,noCharge, amount);
		if proxyEvent.isKindOf(CMEVT_VoyageEvent) then
			proxyEvent.CMEVT_VoyageEvent.setMyVoyage(self.myCurrentVoyage);
			proxyEvent.CMEVT_VoyageEvent.setEndDataTime(eventType.isFromToDateTimeRequired,endTimeStamp);
			proxyEvent.CMEVT_VoyageEvent.setUnitDescription(eventType.unitDescription);					 
			proxyEvent.CMEVT_VoyageEvent.setRemarks(self.txtRemarks.text);								 
			proxyEvent.CMEVT_VoyageEvent.setJobDetails(self.myCurrentJob, self.myCurrentJobSheet);		// TFS 4248
			proxyEvent.setShiftDetails(self.myCurrentShift);
		endif;
			
		
	else
		realEvent:= self.tblData.accessRow(self.tblData.row).itemObject.CM_EventTransaction;
		app.cmsBeginLoad(loadState);
		proxyEvent:=realEvent.pxyCreateUpdateProxy;	
		app.cmsEndLoad(loadState);
		proxyEvent.setDateTime(self.localToSystemTime(timeStamp));
		proxyEvent.setNoCharge(noCharge);
		proxyEvent.setAmount(amount);
		if proxyEvent.isKindOf(CMEVT_VoyageEvent) then
			proxyEvent.setShiftDetails(self.myCurrentShift);
			proxyEvent.CMEVT_VoyageEvent.setJobDetails(self.myCurrentJob, self.myCurrentJobSheet);		// TFS 4248
			proxyEvent.CMEVT_VoyageEvent.setEndDataTime(realEvent.myEventType.isFromToDateTimeRequired,endTimeStamp);
			proxyEvent.CMEVT_VoyageEvent.setRemarks(self.txtRemarks.text);
		endif;
		
	endif;
	
	while true do
		if realEvent = null then
			app.myTrxCA.trxCreateEventTransaction(proxyEvent,realEvent,app.myPassport);
		else
			app.myTrxUA.trxUpdateEventTransaction(proxyEvent,app.myPassport);
		endif;
		if  not app.myPassport.trxCompletedOK then
			theReturn := app.showErrorWarningDialog(app.getErrorString(Errors), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			break;
		endif;	
		break;
	endwhile;
	
epilog
	delete proxyEvent;
	delete allPreWarnings;
	app.cmsEndLoad(loadState);	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSelectEvent" id="d84726e5-fe9b-4d97-9154-3815ddd58f97">
        <updating/>
        <source>doSelectEvent( _event : CM_EventTransaction ) updating;
/*
Purpose:			
Date				Who			Reason
Feb 2017		CNWAB1		Initial creation
*/


	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	localDateTime	 : TimeStamp;
	localEndDateTime : TimeStamp;
begin

	self.mode := self.Mode_Update;

	self.lblDate.caption := app.getFormCaptionsString(Xlat_0020017);
	self.lblTime.caption := app.getFormCaptionsString(Xlat_0020019);
	self.lblAmount.caption := app.getFormCaptionsString(Xlat_0020198);
	

	if _event = null then
	else
		self.mnuInspectObj.userObject := _event;
		self.myCurrentEventType := _event.myEventType;
		localDateTime := self.systemToLocalTime(_event.dateTime);	
			self.doShowEndDateControls(_event.myEventType.isFromToDateTimeRequired);	
		self.chkComplete.value := true;
		self.txtAmount.text:=null;
		self.txtAmount.decimals:=_event.myEventType.amountDecimalPlaces;
		self.txtAmount.maxLength := 8;
		if self.txtAmount.decimals &gt; 0 then
			self.txtAmount.maxLength := 9 + self.txtAmount.decimals;		
		endif;
		self.txtAmount.text := _event.getAmountDisplay;
		self.txtEventType.text := _event.myEventType.name;

		self.txtDate.setDate(localDateTime.Date);
		self.txtTime.setTime(localDateTime.Time);

		if _event.isKindOf(CMEVT_VoyageEvent) then
			txtRemarks.text := _event.CMEVT_VoyageEvent.remarks;
			
			if _event.myEventType.isFromToDateTimeRequired then
				localEndDateTime := self.systemToLocalTime(_event.CMEVT_VoyageEvent.dateTimeEnd);

				self.lblDate.caption := app.getFormCaptionsString(Xlat_0014748); 
				self.lblTime.caption := app.getFormCaptionsString(Xlat_0015903);
				
				if _event.myEventType.unitDescription &lt;&gt; "" then
					self.lblAmount.caption := app.getFormCaptionsString(Xlat_0020198) &amp; " (" &amp; _event.myEventType.unitDescription &amp; ")";
				endif;
				
				self.txtEndDate.setDate(localEndDateTime.date());
				self.txtEndTime.setTime(localEndDateTime.time());
			endif;	
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_event" type="CM_EventTransaction"/>
    </JadeMethod>
    <JadeMethod name="doShowEndDateControls" id="4b3b71c8-059a-4520-a87b-4cb7e76405f5">
        <source>doShowEndDateControls(_visible : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 January 2017	cnwns1	Initial creation

*/

vars

begin
	lblEndDate.visible := _visible;
	txtEndDate.visible := _visible;
	lblEndTime.visible := _visible;
	txtEndTime.visible := _visible;
epilog

end;</source>
        <Parameter name="_visible" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUnselectEvent" id="f17e0702-26f7-4120-899e-8a2847e656ad">
        <updating/>
        <source>doUnselectEvent(_eventType : CM_EventType) updating;
/*
Purpose:			
Date		Who		Reason
03 February 2017	cnwab1	Initial creation
*/

	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars

begin
	self.mode := self.Mode_Add;
	
	self.myCurrentEventType := _eventType;
	
	
	self.lblDate.caption := app.getFormCaptionsString(Xlat_0020017);
	self.lblTime.caption := app.getFormCaptionsString(Xlat_0020019);
	self.lblAmount.caption := app.getFormCaptionsString(Xlat_0020198);
	
	if _eventType.isFromToDateTimeRequired then
		self.lblDate.caption := app.getFormCaptionsString(Xlat_0014748); 
		self.lblTime.caption := app.getFormCaptionsString(Xlat_0015903);
		
		if _eventType.unitDescription &lt;&gt; "" then
			self.lblAmount.caption := app.getFormCaptionsString(Xlat_0020198) &amp; " (" &amp; _eventType.unitDescription &amp; ")";
		endif;
		self.txtEndDate.visible := true;
		self.txtEndTime.visible := true;
		self.lblEndDate.visible := true;
		self.lblEndTime.visible := true;
	else
		self.txtEndDate.visible := false;
		self.txtEndTime.visible := false;
		self.lblEndDate.visible := false;
		self.lblEndTime.visible := false;
	endif;	
	

	self.chkComplete.value := false;
	self.txtEventType.text := _eventType.name;
	self.txtDate.setDate(null);
	self.txtTime.setTime(null);
	self.txtRemarks.text := "";
	self.txtAmount.text := "";
	self.txtDate.setDate(self.effectiveTS.date);
	self.txtTime.setTime(self.effectiveTS.time);
	
epilog

end;</source>
        <Parameter name="_eventType" type="CM_EventType"/>
    </JadeMethod>
    <JadeMethod name="initTable" id="c9f9e83b-0817-4f0b-9460-52a73e1def4f">
        <source>initTable();
/*
Purpose:			
Date		Who		Reason
03 February 2017	cnwab1	Initial creation
*/

vars
	entDef : EntTableDef;
begin
	self.tblData.rows := 1;
	
	entDef := app.myController.getEntTableDef(ETDef_EventCheckList);
	self.tblData.setMyEntTableDef( entDef );
	self.tblData.setTblDataEntRowsFromDef( entDef );
	self.tblData.selectMode := Table.SelectMode_CurrentRow;

epilog

end;</source>
