<Class name="Object">
    <JadeMethod name="jtdGetInstanceIdForObject" id="89a55630-7a38-4241-a94e-7936f83b1c34">
        <source>jtdGetInstanceIdForObject(obj : Object) : Integer;

vars
	i, n : Integer;
	s : String;
	
begin
	if obj = null then
		return 0;
	endif;
	
	s := getOidStringForObject(obj);

	// first dot separates the class id and instance id
	i := s.pos('.', 1);

	if i &lt; 1 or i &gt;= s.length then
	
		return 0; // no first dot!
	endif;

	i := i + 1; // first character after first dot
	
	// if this is a mid or full oid, we need to find the second dot
 	n := s.pos('.', i);
	
	if n &lt; i then
		// didn't find another dot, so we have a short oid
		return s[i : end].Integer;
	endif;
	
	if n = i then
		// belts and braces - should never happen, so assume null
		return 0;
	endif;
	
	// otherwise we have a mid or full oid
	return s[i : n - i].Integer;
end;</source>
        <Parameter name="obj" type="Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
