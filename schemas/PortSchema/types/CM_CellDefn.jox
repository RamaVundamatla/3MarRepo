    <JadeMethod name="cloneMySelf" id="018caf9a-e6f5-46b9-b21b-ad955c747d96">
        <source>cloneMySelf() : SelfType;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	selfCopy:SelfType;
begin
	selfCopy := self.cloneSelf(false);
	return selfCopy;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="exportAsXMLDocIgnoreAttr" id="0e7544bb-e27c-4dc8-b4b3-50b1260ac86e">
        <source>exportAsXMLDocIgnoreAttr(_property: Property input): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 April 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars

begin
	if _property = CM_CellDefn::ordinalConvertedTo7 then
		return true;
	else

		return inheritMethod(_property);
	endif;

epilog

end;</source>
        <Parameter name="_property" type="Property" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getBottomAvailableSlotCont" id="53edb9fa-2f15-4bfe-999b-3625e57ed1d8">
        <source>getBottomAvailableSlotCont():CM_SlotController;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 August 2010	cnwndl1	Initial creation		par 25127

*/

vars

	iter : Iterator;
	theSlotDefn : CM_SlotDefn;
	slotController : CM_SlotController;

begin

	iter := self.allSlotDefinitions.createIterator;
	while iter.next( theSlotDefn ) do
		if theSlotDefn.unavailable then
			continue;
		endif;
		if CM_SlotDefnVoyage.hasInstance(theSlotDefn) then
			slotController := theSlotDefn.CM_SlotDefnVoyage.mySlotController;
			return slotController;
		endif;
	endwhile;
	
	return null;
		
epilog

	delete iter;
	
end;</source>
        <ReturnType type="CM_SlotController"/>
    </JadeMethod>
    <JadeMethod name="getBottomMostSlotRequest" id="f6565047-3166-416d-8d37-4ffe4d204a19">
        <source>getBottomMostSlotRequest( _mode : Integer ):CM_SlotRequest;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 September 2010	cnwndl1	Initial creation	Par 25256

*/

vars

	iter : Iterator;
	theSlotDefn : CM_SlotDefn;
	slotController : CM_SlotController;
	slotRequest : CM_SlotRequest;

begin

	iter := self.allSlotDefinitions.createIterator;
	while iter.next( theSlotDefn ) do
		if theSlotDefn.unavailable then
			continue;
		endif;
		if CM_SlotDefnVoyage.hasInstance(theSlotDefn) then
			slotController := theSlotDefn.CM_SlotDefnVoyage.mySlotController;
			if _mode = Load then
				if slotController.mySlotRequestLoad &lt;&gt; null then
					return slotController.mySlotRequestLoad;
				endif;
			elseif _mode = Discharge then
				if slotController.mySlotRequestDischarge &lt;&gt; null then
					return slotController.mySlotRequestDischarge;
				endif;
			endif;
		endif;
	endwhile;
	
	return null;
		
epilog

	delete iter;
	
end;
</source>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="CM_SlotRequest"/>
    </JadeMethod>
    <JadeMethod name="getBottomOfPileTI" id="e445903a-fd7e-4854-8825-f6a1b56f3276">
        <source>getBottomOfPileTI( _mode : Integer ) : CM_TrackedItem;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 August 2010	cnwndl1	Initial creation	par 25127

*/

vars

	bottomTi : CM_TrackedItem;
	slotController : CM_SlotController;
	theTIs : CM_TIArray;
	
begin

	slotController := self.getBottomAvailableSlotCont;

	if slotController &lt;&gt; null then
		if _mode = ShpDisplayMode_Proposed then
			create theTIs transient;
			slotController.getProposedTIs(theTIs);
			if not theTIs.isEmpty then
				bottomTi := theTIs.first;
			else
				bottomTi := null;
			endif;
		else 
			bottomTi := slotController.allTrackedItems.first;
		endif;
		return bottomTi;
	endif;
	

	return null;
	
epilog

	delete theTIs;
	
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getDrawingPosX" id="9420cd9e-bb8a-4ac6-b9b5-f58024bf46f7">
        <source>getDrawingPosX(_cellWidth : Integer) : Integer;
// ---------------------------------------------------------------------------
// Created:     13 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	noCells : Integer;
begin
	// PAR 26760
//	if self.myBayOD &lt;&gt; null then
//		noCells := self.myBayOD.getNumCellsTotallyUnavailable(true);
//	endif;
//	if  self.alignment &gt;= 7 then
	//	noCells := -2;
	//endif;
	return (((self.alignment + noCells) * _cellWidth) - _cellWidth).Integer;
end;</source>
        <Parameter name="_cellWidth" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfoForPlanning" id="3f263bae-95dd-4e80-a805-f3e9347b646d">
        <source>getExtraInfoForPlanning( _dataContainer : CM_DataContainer; _mode : Integer );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 August 2010	cnwndl1	Initial creation	CCMS 1140 / Par 25127

*/

vars

	block : CM_DataContainerBlock;
	weightUsed : Integer;
	heightUsed : Decimal [6,2];
	tonnesString : String;
	metresString : String;
	weight20s : Integer;
	weightOthers : Integer;
	maxPileWeight : Integer;
	theSlotDefn : CM_SlotDefn;
	slotController : CM_SlotController;
	isFortyBack : Boolean;
	maxPileHeight : Decimal [12,4];
	hideRemaining : Boolean;
	weightConsistsOf : String;
	maxWeight20 : Integer;
	maxWeight40 : Integer;
	displayHeading : String;
	bayString : String;
	
begin
	
	tonnesString := app.getErrorString( Tonnes );
	metresString := app.getErrorString( Metres );
	bayString := " (" &amp; app.getErrorString( Bay ) &amp; ")";
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Cell_Details) , DC_MoreInfo, 1, null);
	
	//Max 20 Weight
	maxWeight20 := self.maxPileWeight20;
	displayHeading := app.getErrorString(Max_20_Weight);
	if maxWeight20 = 0 then
		displayHeading := displayHeading &amp; bayString;
		if self.myBayOD &lt;&gt; null then
			theSlotDefn := self.allSlotDefinitions.first;
			if theSlotDefn &lt;&gt; null then
				if theSlotDefn.isOutboard then
					maxWeight20 := (self.myBayOD.maxPileWeight20OB / 1000).Integer;
				else
					maxWeight20 := (self.myBayOD.maxPileWeight20IB / 1000).Integer;
				endif;
			endif;
		elseif self.myBayUD &lt;&gt; null then
			maxWeight20 := (self.myBayUD.maxPileWeightUD / 1000).Integer;
		endif;
	endif;
	block := _dataContainer.addNewBlock;
	block.addNewItem( displayHeading , DC_Label, 1, null);
	block.addNewItem(maxWeight20.String &amp; tonnesString, DC_Data, 1, null);
	
	//Max 40 Weight
	maxWeight40 := self.maxPileWeight40;
	displayHeading := app.getErrorString(Max_40_Weight);
	if maxWeight40 = 0 then
		displayHeading := displayHeading &amp; bayString;
		if self.myBayOD &lt;&gt; null then
			theSlotDefn := self.allSlotDefinitions.first;
			if theSlotDefn &lt;&gt; null then
				if theSlotDefn.isOutboard then
					maxWeight40 := (self.myBayOD.maxPileWeight40OB / 1000).Integer;
				else
					maxWeight40 := (self.myBayOD.maxPileWeight40IB / 1000).Integer;
				endif;
			endif;
		elseif self.myBayUD &lt;&gt; null then
			maxWeight40 := (self.myBayUD.maxPileWeightUD / 1000).Integer;
		endif;
	endif;
	block := _dataContainer.addNewBlock;
	block.addNewItem( displayHeading , DC_Label, 1, null);
	block.addNewItem(maxWeight40.String &amp; tonnesString, DC_Data, 1, null);
	
	//Total weight of Cargo
/*	slotController := self.getBottomAvailableSlotCont;	// the bottom one.
	if slotController &lt;&gt; null then
		isFortyBack := slotController.isFortyBack;
	endif; */
	isFortyBack := self.isAftBay();	// 28 Mar 2011	NDL	Par 27203
	
	self.getPileWeight(weight20s, weightOthers, weightUsed, maxPileWeight, _mode, weightConsistsOf);
	if isFortyBack and weight20s = 0 then
		hideRemaining := true;
	endif;
	block := _dataContainer.addNewBlock;
	block.addNewItem( app.getErrorString(Weight_all_cargo) , DC_Label, 1, null);
	block.addNewItem(weightUsed.String &amp; tonnesString, DC_Data, 1, null);
	
	if maxPileWeight &gt;= weightUsed then
		if not hideRemaining then
			//Total weight that the cell is over by
			block := _dataContainer.addNewBlock;
			block.addNewItem( app.getErrorString(Remaining_weight) , DC_Label, 1, null);
			block.addNewItem((maxPileWeight - weightUsed).String &amp; tonnesString, DC_Data, 1, null);
		endif;
	else
		//How much is the cell under weight by
		block := _dataContainer.addNewBlock;
		block.addNewItem( app.getErrorString(Over_weight_by) , DC_Warning, 1, null);
		block.addNewItem((weightUsed - maxPileWeight).String &amp; tonnesString, DC_Data, 1, null);
	endif;
	
	//A comment on how the Total cargo weight was derived
	if weightUsed &gt; 0 then
		if weightConsistsOf &lt;&gt; null then
			block := _dataContainer.addNewBlock;
			block.addNewItem( app.getErrorString(Weight_consists_of) , DC_Label, 1, null);
			block.addNewItem(weightConsistsOf, DC_Data, 1, null);
		endif;
	endif;
	
	//Max cell height
	maxPileHeight := self.getMaxPileHeight();
	block := _dataContainer.addNewBlock;
	block.addNewItem( app.getErrorString(Max_Height) , DC_Label, 1, null);
	block.addNewItem(maxPileHeight.asStringJMTWithPrecision(2,false) &amp; metresString, DC_Data, 1, null);
	
	//Total height of all cargo
	heightUsed := self.getTotalHeightUsedInMetres;
	block := _dataContainer.addNewBlock;
	block.addNewItem( app.getErrorString(Height_all_cargo) , DC_Label, 1, null);
	block.addNewItem(heightUsed.asStringJMTWithPrecision(2,false) &amp; metresString, DC_Data, 1, null);
	
	if maxPileHeight &gt;= heightUsed then
		//How much the height is under by
		block := _dataContainer.addNewBlock;
		block.addNewItem( app.getErrorString(Remaining_height) , DC_Label, 1, null);
		block.addNewItem( (maxPileHeight - heightUsed).asStringJMTWithPrecision(2,false) &amp; metresString, DC_Data, 1, null);
	else
		//Total height that the cell is over by
		block := _dataContainer.addNewBlock;
		block.addNewItem( app.getErrorString(Over_height_by) , DC_Warning, 1, null);
		block.addNewItem((heightUsed - maxPileHeight).asStringJMTWithPrecision(2,false) &amp; metresString, DC_Data, 1, null);
	endif;
						
epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getHatchLids" id="5798893a-e345-4afe-8691-5ea0c3441ac7">
        <source>getHatchLids(_theHatchLidSet : CM_HatchLidArray input);
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		Works out which hatch lids are over or under this cell
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theBay : CM_Bay;
	aLid : CM_HatchLid;
	isOnDeck : Boolean;
begin
	
	if self.myBayOD &lt;&gt; null then
		theBay := self.myBayOD;
		isOnDeck := true;
	elseif self.myBayUD &lt;&gt; null then
		theBay := self.myBayUD;
		isOnDeck := false;
	endif;

	if theBay &lt;&gt; null then
		foreach aLid in theBay.allHatchLids do
			if isOnDeck then
				if aLid.ordinalODStartCell &lt;= self.ordinal and aLid.ordinalODEndCell &gt;= self.ordinal then
					if not _theHatchLidSet.includes(aLid) then
						_theHatchLidSet.add(aLid);
					endif;
				endif;
			else
				if aLid.ordinalUDStartCell &lt;= self.ordinal and aLid.ordinalUDEndCell &gt;= self.ordinal then
					if not _theHatchLidSet.includes(aLid) then
						_theHatchLidSet.add(aLid);
					endif;
				endif;
			
			endif;
		endforeach;
	endif;
end;</source>
        <Parameter name="_theHatchLidSet" type="CM_HatchLidArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getHeightStatsString" id="c2b57409-b892-4fec-aea1-c3d905bd1041">
        <source>getHeightStatsString() : String;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theString : String;
	totAvail, totUsed : Real;
begin
	totAvail := self.getTotalHeightAvailable();
	totUsed := self.getTotalHeightUsed(ShpDisplayMode_Actual);
	
	theString := "Cell Height: " &amp; totAvail.String &amp; "ft. ";
	theString := theString &amp; "Used: " &amp; totUsed.String &amp; "ft.";
	theString := theString &amp; "Left: " &amp; (totAvail - totUsed).String &amp; "ft.";
	
	return theString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMaxPileHeight" id="646c93e0-b4b5-409a-8fb0-cdf33b61b772">
        <source>getMaxPileHeight():Decimal;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 August 2010	cnwndl1	Initial creation

*/

vars
	feet : Real;
	metres : Real;
begin
	if self.maxHeight &gt; 0 then
		metres := self.maxHeight;
		
	elseif self.myBayUD &lt;&gt; null then
		feet := self.getTotalHeightAvailable();
		// convert to metres.
		//feet * 12 (inches in a foot) / 39.37 (inches in a metre)
		if feet &gt; 0 then
			metres := ( feet * 12 / 39.37 );
		endif;
		
	endif;
	 
	 return metres;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getMaxPileWeight" id="3eeb8dba-102e-4bcf-97b5-efe9a59405ac">
        <source>getMaxPileWeight( _mode : Integer ):Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 August 2010	cnwndl1	Initial creation

*/

vars

	theBay : CM_Bay;
	bottomTi : CM_TrackedItem;
	lengthInUnits : Real;
	iter : Iterator;
	slotDefn : CM_SlotDefn;
	theSlotDefn : CM_SlotDefn;
	
	isFortyBack : Boolean;
	maxWeight : Real;
	slotRequest : CM_SlotRequest;
	
begin

	bottomTi := self.getBottomOfPileTI(_mode);
		
	if bottomTi &lt;&gt; null then
		lengthInUnits := bottomTi.getLengthInUnits;
	else
		// no Ti, find the length from a slot that has a load request
		slotRequest := self.getBottomMostSlotRequest(Load);
		if slotRequest &lt;&gt; null then
			slotRequest := self.getBottomMostSlotRequest(Discharge);
		endif;
		if slotRequest &lt;&gt; null then
			if slotRequest.is20 then
				lengthInUnits := 2;
			else
				// Any value bigger than 2 is longer than a 20 footer.
				lengthInUnits := 4;
			endif;
		endif;
	endif;
	
	if maxPileWeight20 = 0 and maxPileWeight40 = 0 then
		// use the IB / OB / UD values.
		
		if self.myBayOD &lt;&gt; null then
			theBay := self.myBayOD;
			iter := self.allSlotDefinitions.createIterator;	
			while iter.next (slotDefn) do
				if slotDefn.unavailable then
					continue;
				endif;
				theSlotDefn := slotDefn;	// the bottom one.
				break;
			endwhile;

			if CM_SlotDefnVoyage.hasInstance(theSlotDefn) then
				if lengthInUnits &gt; 2 then 
					if theSlotDefn.CM_SlotDefnVoyage.isOutboard = true then
						maxWeight := theBay.maxPileWeight40OB;
					else 
						maxWeight := theBay.maxPileWeight40IB;
					endif;
				else
					if theSlotDefn.CM_SlotDefnVoyage.isOutboard = true then
						maxWeight := theBay.maxPileWeight20OB;
					else 
						maxWeight := theBay.maxPileWeight20IB;
					endif;
				endif;
			endif;
			
		else
			theBay := self.myBayUD;
			maxWeight := theBay.maxPileWeightUD;
			
		endif;
		
		return ( maxWeight / 1000 ).Integer;

	else
		// individual cell defn values
	/*	slotController := self.getBottomAvailableSlotCont;
		if slotController &lt;&gt; null then
			isFortyBack := slotController.isFortyBack;
		endif; */
		isFortyBack := self.isAftBay();	// 28 Mar 2011	NDL	Par 27203
	
		
		if lengthInUnits &gt; 2 then
			//we have a container greater than 20 foot.
			if isFortyBack then
				// we don't show weights here..
				return 0;
			else
				return maxPileWeight40;
			endif;
		else
			// we have a twenty footer.
			return maxPileWeight20;
		endif;
		
	endif;
	
	return 0;
	
epilog

	delete iter;
	
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMaxPileWeightForBottomTI" id="ed0dde1b-7458-4adc-8b71-a9aba1e64ac6">
        <source>getMaxPileWeightForBottomTI(_bottomTi : CM_TrackedItem;
							_bottomSlotRequest : CM_SlotRequest;
							_bottomSlotDefn : CM_SlotDefnVoyage) : Integer;
/*

Date		Who		Reason
31 January 2017	cnwer1	Initial creation TFS 3284

*/

vars
	theBay : CM_Bay;
	lengthInUnits : Real;	
	isFortyBack : Boolean;
	maxWeight : Real;

begin
	if _bottomTi &lt;&gt; null then
		lengthInUnits := _bottomTi.getLengthInUnits;
	else
		
		if _bottomSlotRequest &lt;&gt; null then
			if _bottomSlotRequest.is20 then
				lengthInUnits := 2;
			else
				// Any value bigger than 2 is longer than a 20 footer.
				lengthInUnits := 4;
			endif;
		endif;
	endif;
	
	if maxPileWeight20 = 0 and maxPileWeight40 = 0 then
		// use the IB / OB / UD values.
		
		if self.myBayOD &lt;&gt; null then
			theBay := self.myBayOD;
			if _bottomSlotDefn &lt;&gt; null then
				if lengthInUnits &gt; 2 then 
					if _bottomSlotDefn.isOutboard = true then
						maxWeight := theBay.maxPileWeight40OB;
					else 
						maxWeight := theBay.maxPileWeight40IB;
					endif;
				else
					if _bottomSlotDefn.isOutboard = true then
						maxWeight := theBay.maxPileWeight20OB;
					else 
						maxWeight := theBay.maxPileWeight20IB;
					endif;
				endif;
			endif;
			
		else
			theBay := self.myBayUD;
			maxWeight := theBay.maxPileWeightUD;
			
		endif;
		
		return ( maxWeight / 1000 ).Integer;

	else
		// individual cell defn values
	/*	slotController := self.getBottomAvailableSlotCont;
		if slotController &lt;&gt; null then
			isFortyBack := slotController.isFortyBack;
		endif; */
		isFortyBack := self.isAftBay();	// 28 Mar 2011	NDL	Par 27203
	
		
		if lengthInUnits &gt; 2 then
			//we have a container greater than 20 foot.
			if isFortyBack then
				// we don't show weights here..
				return 0;
			else
				return maxPileWeight40;
			endif;
		else
			// we have a twenty footer.
			return maxPileWeight20;
		endif;
		
	endif;
	
	return 0;
epilog

end;</source>
        <Parameter name="_bottomTi" type="CM_TrackedItem"/>
        <Parameter name="_bottomSlotRequest" type="CM_SlotRequest"/>
        <Parameter name="_bottomSlotDefn" type="CM_SlotDefnVoyage"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMyAftCell" id="be92257e-3736-4b7f-969c-3cce22ae88cc">
        <source>getMyAftCell() : CM_CellDefn;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpBay, tmpAftBay : CM_Bay;
	tmpAftCell : CM_CellDefn;
	onDeck : Boolean;
begin
	onDeck := self.onDeck();
	
	if onDeck then
		tmpBay := self.myBayOD;
	else
		tmpBay := self.myBayUD;
	endif;

	if tmpBay = null then
		return null;
	endif;
	if not tmpBay.isForwardBay then
		return null;
	endif;
	
	tmpAftBay := tmpBay.myAftBay;
	
	if tmpAftBay = null then
		return null;	
	endif;
	
	if onDeck then
		tmpAftCell := tmpAftBay.allCellsOnDeck[self.id];
	else
		tmpAftCell := tmpAftBay.allCellsUnderDeck[self.id];
	
	endif;
	
	return tmpAftCell;
end;</source>
        <ReturnType type="CM_CellDefn"/>
    </JadeMethod>
    <JadeMethod name="getPileHeights" id="cabe00ae-3cc8-41ed-9c74-607dfb25de12">
        <source>getPileHeights( _mode : Integer;
				_usedHeight, 
				_availHeight,
				_maxHeight : Integer output);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 22/05/2015	cnwdap1		Initial creation PAR #36269 Graphical Display of Pile Heights
//							Heights are in feet, so convert to metres
//
vars

begin
	//epr par 37334 14/1/16 added mode to get the planned
	_usedHeight := (self.getTotalHeightUsed(_mode) * 0.3048).roundedTo(0).Integer;
	_maxHeight := (self.getTotalHeightAvailable() * 0.3048).roundedTo(0).Integer;
	_availHeight := _maxHeight  - _usedHeight;  
	
epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_usedHeight" type="Integer" usage="output"/>
        <Parameter name="_availHeight" type="Integer" usage="output"/>
        <Parameter name="_maxHeight" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getPileWeight" id="99cf66c3-0e94-42f9-a34d-a587139e1c53">
        <source>getPileWeight(	_weight20s 	   : Integer output;
				_weightOthers  : Integer output;
				_displayWeight : Integer output;
				_maxPileWeight : Integer output;
				_mode 		   : Integer;
				_makeUpComment : String output
				);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 Aug 2010	cnwndl1	Initial creation
12 May 2021	navma1	Bug 51149: SNO - Planning containers with mismatching weight
*/

vars
	bottomSlotDefn  	: CM_SlotDefnVoyage;
	theSlotDefn 		: CM_SlotDefn;
	slotController  	: CM_SlotController;
	theTIs 				: CM_TIArray;
	ti 					: CM_TrackedItem;
	unitLength 			: Real;
	isFortyBack 		: Boolean;
	term 			    : CM_Terminal;
	fortyForwardAlways  : Boolean;
	bottomTi 			: CM_TrackedItem;
	bottomRequest,
	bottomDischRequest,
	bottomLoadRequest 	: CM_SlotRequest;
begin

	create theTIs transient;

	foreach theSlotDefn in self.allSlotDefinitions do
	
		if CM_SlotDefnVoyage.hasInstance(theSlotDefn) then
		
			slotController := theSlotDefn.CM_SlotDefnVoyage.mySlotController;
			theTIs.clear;
			
			if _mode = ShpDisplayMode_Actual then 
				slotController.allTrackedItems.copy(theTIs); 
			else //if _mode = ShpDisplayMode_Proposed then 
				slotController.getProposedTIs(theTIs);
			endif;
			
			//epr TFS 3284 1/2/17
			if not theSlotDefn.unavailable then
				if bottomSlotDefn = null  then
					bottomSlotDefn:=theSlotDefn.CM_SlotDefnVoyage;
				endif;		
				if bottomDischRequest = null and 
					slotController.mySlotRequestDischarge &lt;&gt; null then
						bottomDischRequest:= slotController.mySlotRequestLoad;
				endif;
				if bottomDischRequest = null and 
					slotController.mySlotRequestDischarge &lt;&gt; null then
						bottomDischRequest:= slotController.mySlotRequestDischarge;
				endif;
			endif;
			
			foreach ti in theTIs do
				//epr TFS 3284 1/2/17
				if bottomTi = null and not theSlotDefn.unavailable then
					bottomTi :=ti;
				endif;
			
				unitLength := ti.getLengthInUnits;
				if unitLength = 2 then	// 20 footer
					_weight20s := _weight20s + ti.totalWeight.Integer;
				else
					_weightOthers := _weightOthers + ti.totalWeight.Integer;
				endif;
			endforeach;
			
		endif;
		
	endforeach;
	
	isFortyBack := self.isAftBay();	// 28 Mar 2011	NDL	Par 27203
	
	if isFortyBack and _weight20s = 0 then
		// forties (actually non 20's) only at the back	- display NO weight
		_displayWeight := 0;
		
	elseif not isFortyBack and _weight20s &gt; 0 and _weightOthers = 0 then
		// 20's only at the front
		//_displayWeight := ( _weight20s / 1000 ).Integer;	// divide by 1000 to give tonnes    /12.05.2021 cnwma1 #51149
		_displayWeight := ( _weight20s / 1000 ).rounded();	// divide by 1000 to give tonnes   //12.05.2021 cnwma1 #51149
		_makeUpComment :=  app.getErrorString(Only20_full_weight);
		
	elseif not isFortyBack and _weight20s = 0 and _weightOthers &gt; 0 then
		// forties (actually non 20's) only at the front	- display total 40 weight
		_makeUpComment :=  app.getErrorString(Non20_Full_weight_forward);
		//_displayWeight := ( _weightOthers / 1000 ).Integer;	// divide by 1000 to give tonnes  //12.05.2021 cnwma1 #51149
		_displayWeight := ( _weightOthers / 1000 ).rounded;  	// divide by 1000 to give tonnes  //12.05.2021 cnwma1 #51149
	else
		if _weight20s &gt; 0 or _weightOthers &gt; 0 then
			if self.myBayOD &lt;&gt; null then
				if self.myBayOD.isKindOf(CM_BayVoyage) then
					term:= self.myBayOD.CM_BayVoyage.myCellularVoyageStructure.myVoyage.myTerminal;
				endif;
			elseif self.myBayUD &lt;&gt; null then
				if self.myBayUD.isKindOf(CM_BayVoyage) then
					term:= self.myBayUD.CM_BayVoyage.myCellularVoyageStructure.myVoyage.myTerminal;
				endif;
			endif;
			//28 Mar 2011	NDL	Par 27203
			if term &lt;&gt; null then
				fortyForwardAlways := term.getConfig(FortyWeightForwardCell).Boolean; 
			endif;
		
			if fortyForwardAlways then
				if isFortyBack then	//mixture in aft bay - display all 20 weight only
					//_displayWeight := ( _weight20s / 1000 ).Integer;	// divide by 1000 to give tonnes //12.05.2021 cnwma1 #51149
					_displayWeight := ( _weight20s / 1000 ).rounded;	// divide by 1000 to give tonnes //12.05.2021 cnwma1 #51149
					_makeUpComment :=  app.getErrorString(Mix_Full20_IgnoreNon20);
				elseif not isFortyBack then	//mixture in forward bay- display all 20 weight and all 40 weight
					//_displayWeight := (( _weight20s + _weightOthers ) / 1000 ).Integer;	// divide by 1000 to give tonnes  //12.05.2021 cnwma1 #51149
					_displayWeight := (( _weight20s + _weightOthers ) / 1000 ).rounded;    // divide by 1000 to give tonnes   //12.05.2021 cnwma1 #51149   
					_makeUpComment :=  app.getErrorString(Mix_Full20_FullNon20);
				endif;
			else
				//mixture - display all 20 weight and half 40 weight
				//_displayWeight := ( (_weight20s + (_weightOthers / 2 )) / 1000 ).Integer;	// divide by 1000 to give tonnes //12.05.2021 cnwma1 #51149
				_displayWeight := ( (_weight20s + (_weightOthers / 2 )) / 1000 ).rounded;	// divide by 1000 to give tonnes //12.05.2021 cnwma1 #51149
				_makeUpComment :=  app.getErrorString(Mix_Full20_HalfNon20);
			endif;
		endif;
	endif;
	
	if bottomLoadRequest &lt;&gt; null then
		bottomRequest:=bottomLoadRequest;
	else
		bottomRequest:=bottomDischRequest;
	endif;
	//epr TFS 3284 1/2/17
	_maxPileWeight:= self.getMaxPileWeightForBottomTI(bottomTi,bottomRequest,bottomSlotDefn);
	
epilog
	delete theTIs;
end;</source>
        <Parameter name="_weight20s" type="Integer" usage="output"/>
        <Parameter name="_weightOthers" type="Integer" usage="output"/>
        <Parameter name="_displayWeight" type="Integer" usage="output"/>
        <Parameter name="_maxPileWeight" type="Integer" usage="output"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_makeUpComment" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getSlotControllers" id="7f5010ab-646f-44b2-91e6-37fa2047a0a9">
        <source>getSlotControllers(_slotControllers : ObjectSet input);
/*

Date		Who		Reason
07 January 2016	cnwer1	Initial creation PAR 37142

*/

vars
	slotDefn : CM_SlotDefn;
	slotDefnVoyage : CM_SlotDefnVoyage;
begin
	
	if self.myBayOD = null and self.myBayUD = null then
		return;
	endif;
	
	if self.myBayOD &lt;&gt; null and not self.myBayOD.isKindOf(CM_BayVoyage) then
		return;
	endif;
	
	if self.myBayUD &lt;&gt; null and not self.myBayUD.isKindOf(CM_BayVoyage) then
		return;
	endif;

	foreach slotDefn in self.allSlotDefinitions do
		slotDefnVoyage:=slotDefn.CM_SlotDefnVoyage;
		_slotControllers.add(slotDefnVoyage.mySlotController);
	endforeach;


epilog

end;</source>
        <Parameter name="_slotControllers" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTotalHeightAvailable" id="cbd03abe-c13b-41f7-8f1b-6170a2279ec4">
        <source>getTotalHeightAvailable() : Real;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		Available height in feet
// ---------------------------------------------------------------------------
vars
	numSlot : Integer;
	aSlot : CM_SlotDefn;
begin
	foreach aSlot in self.allSlotDefinitions where aSlot.unavailable = false do
		numSlot := numSlot + 1;
	endforeach;
	return numSlot * HEIGHT_FULL_NORMAL;
//		return self.allSlotDefinitions.size * HEIGHT_FULL_NORMAL;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getTotalHeightLeft" id="99141f5c-3b28-46f1-a49a-627071302baf">
        <source>getTotalHeightLeft(_mode : Integer) : Real;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theHeight : Real;
begin
	//epr par 37334 14/1/16 
	theHeight := self.getTotalHeightAvailable() - self.getTotalHeightUsed(_mode);
	return theHeight;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getTotalHeightUsed" id="c940a4c1-bd1b-4c23-8bc7-903d117078dc">
        <source>getTotalHeightUsed(_mode : Integer) : Real;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

	theHeight : Real;
	theSlotDefn : CM_SlotDefn;
	theController : CM_SlotController;
	theTI : CM_TrackedItem;
	theTIs : CM_TIArray;
begin

	create theTIs transient;
	foreach theSlotDefn in self.allSlotDefinitions where theSlotDefn.unavailable = false do
		if CM_SlotDefnVoyage.hasInstance(theSlotDefn) then
			theController := theSlotDefn.CM_SlotDefnVoyage.mySlotController;
			
			//epr par 37334 13/1/16
			theTIs.clear;
			if _mode = ShpDisplayMode_Actual then 
				theController.allTrackedItems.copy(theTIs); 
			elseif _mode = ShpDisplayMode_Proposed then 
				theController.getProposedTIs(theTIs);
			endif;
			
			foreach theTI in theTIs do	
				theHeight := theHeight + theTI.getActualHeight();
			endforeach;
		endif;
	endforeach;
	
	return theHeight;
epilog
	delete theTIs;

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getTotalHeightUsedInMetres" id="dff248ea-dced-4d57-a6a9-6ebdd710d42b">
        <source>getTotalHeightUsedInMetres() : Decimal;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 August 2010	cnwndl1	Initial creation

*/

vars

	feet : Real;
	inches : Real;
	metres : Decimal [6,2];
	
begin

	feet := self.getTotalHeightUsed(ShpDisplayMode_Actual);
	
	inches := feet * 12;	// inches per feet
	
	metres := inches / 39.37;// inches per metre.
	
	return metres;

epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getTotalPileWeights" id="7a359a36-6719-4166-a8a8-33afbb537ac2">
        <source>getTotalPileWeights(_weight20s,_weightOthers : Integer ) : Integer;
/*

Date		Who		Reason
02 February 2017	cnwer1	Initial creation TFS 3284
12 May 2021	navma1	Bug 51149: SNO - Planning containers with mismatching weight
*/

vars
	isFortyBack : Boolean;
	fortyForwardAlways : Boolean;
	term : CM_Terminal;
begin
	isFortyBack := self.isAftBay();	// 28 Mar 2011	NDL	Par 27203
	
	if isFortyBack and _weight20s = 0 then
		// forties (actually non 20's) only at the back	- display NO weight
		return 0;
		
	elseif not isFortyBack and _weight20s &gt; 0 and _weightOthers = 0 then
		// 20's only at the front
		//return  ( _weight20s / 1000 ).Integer;	// divide by 1000 to give tonnes
		return  ( _weight20s / 1000 ).rounded();	// divide by 1000 to give tonnes   //12.05.2021 cnwma1 #51149
		
	elseif not isFortyBack and _weight20s = 0 and _weightOthers &gt; 0 then
		// forties (actually non 20's) only at the front	- display total 40 weight
		//return ( _weightOthers / 1000 ).Integer;	// divide by 1000 to give tonnes
		return ( _weightOthers / 1000 ).rounded();	// divide by 1000 to give tonnes   //12.05.2021 cnwma1 #51149
	else
		if _weight20s &gt; 0 or _weightOthers &gt; 0 then
			
			if self.myBayOD &lt;&gt; null then		
				term:= self.myBayOD.getMyTerminal;			
			elseif self.myBayUD &lt;&gt; null then			
				term:= self.myBayUD.getMyTerminal;			
			endif;
			//28 Mar 2011	NDL	Par 27203
			if term &lt;&gt; null then
				fortyForwardAlways := term.getConfig(FortyWeightForwardCell).Boolean; 
			endif;
		
			if fortyForwardAlways then
				if isFortyBack then	//mixture in aft bay - display all 20 weight only
					//return  ( _weight20s / 1000 ).Integer;	// divide by 1000 to give tonnes            //12.05.2021 cnwma1 #51149
					return  ( _weight20s / 1000 ).rounded();  	// divide by 1000 to give tonnes            //12.05.2021 cnwma1 #51149
				elseif not isFortyBack then	//mixture in forward bay- display all 20 weight and all 40 weight
					//return (( _weight20s + _weightOthers ) / 1000 ).Integer;	// divide by 1000 to give tonnes  //12.05.2021 cnwma1 #51149
					return (( _weight20s + _weightOthers ) / 1000 ).rounded();	// divide by 1000 to give tonnes  //12.05.2021 cnwma1 #51149
				endif;
			else
				//mixture - display all 20 weight and half 40 weight
				//return ( (_weight20s + (_weightOthers / 2 )) / 1000 ).Integer;	// divide by 1000 to give tonnes
				return ( (_weight20s + (_weightOthers / 2 )) / 1000 ).rounded();	// divide by 1000 to give tonnes
			endif;
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_weight20s" type="Integer"/>
        <Parameter name="_weightOthers" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getUnderDeckAlignedCell" id="082ec0a5-1891-4c0a-911c-464c3c297b66">
        <source>getUnderDeckAlignedCell() : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 January 2013	cnwer1	Initial creation HAT 2189

*/

vars
	cell : CM_CellDefn;
	iter : Iterator;
	alignedCell : Integer;
begin
	if self.myBayOD = null then
		return null;
	endif;
	
	iter:=self.myBayOD.allCellsUnderDeckByOrdinal.createIterator;
	while iter.next(cell) do
		if (cell.alignment &gt;= self.alignment and cell.alignment &lt; (self.alignment +1)) 
		or ((cell.alignment+ 1) &gt; self.alignment and (cell.alignment+ 1) &lt;= (self.alignment +1)) then
		
			alignedCell:=cell.ordinal;	
		endif;	
		
		
	endwhile;
	if alignedCell = 0 and cell &lt;&gt; null then
			alignedCell:=cell.ordinal;	
	endif;
	
	return alignedCell;
epilog
	delete iter;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="isAftBay" id="a0f4b583-0cae-4885-ae1d-b297ce117d89">
        <source>isAftBay():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 March 2011	cnwndl1	Initial creation	Par 27203

*/

vars

begin

	if self.myBayOD &lt;&gt; null then
		return self.myBayOD.isAftBay;
	elseif self.myBayUD &lt;&gt; null then
		return self.myBayUD.isAftBay;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTotallyUnavailable" id="1c352c73-706d-45a9-bf7c-00ac8022a3aa">
        <updating/>
        <source>isTotallyUnavailable() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     February 2010 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpSlotDefn	: CM_SlotDefn;
begin
	foreach tmpSlotDefn in self.allSlotDefinitions where (not tmpSlotDefn.unavailable) do
		return false;
	endforeach;
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="onDeck" id="71f098b2-f8d0-4d68-bd23-0ac2868d5019">
        <source>onDeck():Boolean;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

begin
	return (self.myBayOD &lt;&gt; null);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="b7a91cd7-a9ff-46c2-8d8b-530070da59af">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     09 February 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	proxy:SelfType;
	completedOK		: Boolean;
	
begin

	proxy := inheritMethod();
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setAlignment" id="74a48b44-735d-4167-abb3-50cd8436a78a">
        <updating/>
        <source>setAlignment(_alignment:Real) updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.alignment = _alignment then
		return;
	endif;
	
	self.alignment := _alignment;

end;</source>
        <Parameter name="_alignment" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="5e1a9800-c498-449c-bd0b-2f72153092f8">
        <updating/>
        <source>setForCreate(	_proxy:SelfType; 
				_theRealBayDefn : CM_Bay input;
				_onDeck : Boolean;
				_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	_proxy.raiseExceptionIfNotTransient(method);

	if _onDeck then
		//PAR 15510
		if _theRealBayDefn.allCellsOnDeck[self.id] &lt;&gt; null then
			app.raiseCMException2(DUPLICATE_ID_ERROR, "Cell", "Bay " &amp; _theRealBayDefn.id &amp; " has a duplicate ondeck Cell ID '" &amp; self.id &amp; "'.", null, _theRealBayDefn);
			return;
		endif;
		self.myBayOD := _theRealBayDefn; 
	else
		//PAR 15510
		if _theRealBayDefn.allCellsUnderDeck[self.id] &lt;&gt; null then
			app.raiseCMException2(DUPLICATE_ID_ERROR, "Cell", "Bay " &amp; _theRealBayDefn.id &amp; " has a duplicate underdeck Cell ID '" &amp; self.id &amp; "'.", null, _theRealBayDefn);
			return;
		endif;
		self.myBayUD := _theRealBayDefn; 
	endif;
	
	self.setForUpdate(_proxy,_theRealBayDefn,_passport);

end;</source>
        <Parameter name="_proxy" type="SelfType"/>
        <Parameter name="_theRealBayDefn" type="CM_Bay" usage="input"/>
        <Parameter name="_onDeck" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="c5e7f04a-23fb-4d39-bb13-7a976ad9c629">
        <updating/>
        <source>setForUpdate(	_proxy:SelfType;
				_theRealBayDefn : CM_Bay input;
				_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.id := _proxy.id;
	self.alignment := _proxy.alignment;
	self.maxNumHighCubesIfFull := _proxy.maxNumHighCubesIfFull;
	self.ordinal := _proxy.ordinal;
	self.maxHeight := _proxy.maxHeight;	//Par 25127	/ CCMS 1140
	self.maxPileWeight20 := _proxy.maxPileWeight20;	//Par 25127	/ CCMS 1140
	self.maxPileWeight40 := _proxy.maxPileWeight40;	//Par 25127	/ CCMS 1140
	
	//created for JATOS epr 19/8/2013
	self.setForUpdateLayouts(_proxy,_passport);
end;</source>
        <Parameter name="_proxy" type="SelfType"/>
        <Parameter name="_theRealBayDefn" type="CM_Bay" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setHasAvailableSlot" id="3b83057d-2e98-4a1d-97fe-5c09d533bb04">
        <updating/>
        <source>setHasAvailableSlot() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     02 April 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpSlotDefn	: CM_SlotDefn;
begin
	foreach tmpSlotDefn in self.allSlotDefinitions where (not tmpSlotDefn.unavailable) do
		return true;
	endforeach;
	return false;
end;</source>
