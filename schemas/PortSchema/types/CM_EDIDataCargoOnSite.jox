    <JadeMethod name="createTIUpdateController" id="43bbe2a6-fb5d-44a1-93f4-2fe6eb30bf07">
        <source>createTIUpdateController() : CMIF_TIUpdateController;
/*
Purpose:		PAR 34535	
Date		Who		Reason
09 July 2014	cnwab1	Initial creation
*/

vars
	updateController		:CMIF_TIUpdateController;

begin
	updateController := app.createTIUpdateControl(TI_UPDMODE_NORMAL, null, null);
	
	return updateController;
epilog

end;</source>
