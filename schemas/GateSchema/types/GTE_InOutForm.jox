/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2009	cnwmh5	Initial creation

*/

vars
	
	sheet			: GTE_Sheet;
	combobox2Update	: CMUI_ComboBox;
	table2Update	: CM_EntryTable;
begin

	// get the correct sheet to update can't get from current combobox as not type GTE_Combobox
	sheet := self.topSheet;
	
	// get the cmbSysSubType from the correct sheet
	combobox2Update := sheet.getControlByName(Cntrl_cmbSysSubType).CMUI_ComboBox;
	table2Update := sheet.getControlByName(self.tblExtra.name).CM_EntryTable;
	
	self.myAssistant.comboboxSysSubType(combobox.listObject.CM_Product, sheet.getControlByName(self.cmbTiType.name).CMUI_ComboBox.listObject.CM_CargoType, null, combobox2Update, table2Update);
		
	//self.setCellTextFromControl(sheet, combobox2Update, combobox2Update.text);
	
epilog

end;</source>
