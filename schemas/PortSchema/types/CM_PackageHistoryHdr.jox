    <JadeMethod name="addEmailHistory" id="741f757a-d057-4a7a-be04-2cd9b720ea29">
        <updating/>
        <source>addEmailHistory(_package : CM_Package) updating;
// CPL CCMS 2120 Nov 2011 MSC electronic invoicing via emailed XML fronm report
vars

begin
	if _package &lt;&gt; null and
	   _package.myEmailTemplate &lt;&gt; null then
		self.emailBccRecipients := _package.myEmailTemplate.getAllBCCAddressesOrNames(false);
		self.emailCcRecipients := _package.myEmailTemplate.getAllCCAddressesOrNames(false);
		self.emailToRecipients := _package.myEmailTemplate.getAllToAddressesOrNames(false);
	endif;
end;
</source>
        <Parameter name="_package" type="CM_Package"/>
    </JadeMethod>
    <JadeMethod name="addHistoryFromHdrs" id="01a1494d-1960-4066-b5fa-91e97a967fba">
        <updating/>
        <source>addHistoryFromHdrs(_allHdrs : CM_FileDataStorageHdrSet; _allEventData : CM_EventDataByTypeDict) updating;

// Created by cnwdvb1 on 27 June 2006

vars

	newHdr,
	oldHdr 		: CM_FileDataStorageHeader;
	eventData	: CM_EventData;

begin

	// Clone some headers.
	foreach oldHdr in _allHdrs do
		newHdr := oldHdr.cloneHdr();
		if newHdr &lt;&gt; null then
			self.allAttachedFiles.add(newHdr);
		endif;
	endforeach;
	
	// Get the history description
	foreach eventData in _allEventData do
		self.packageDataStr := eventData.getEventDataDesc();
		return;
	endforeach;
	
	if self.packageDataStr = null then
		self.packageDataStr := 'None Specified';
	endif;

end;</source>
        <Parameter name="_allHdrs" type="CM_FileDataStorageHdrSet"/>
        <Parameter name="_allEventData" type="CM_EventDataByTypeDict"/>
    </JadeMethod>
    <JadeMethod name="extractHistoryDataToFile" id="11e3a988-52ed-4d96-9177-554730f0b1bf">
        <source>extractHistoryDataToFile();

// Created by cnwdvb1 on 28 June 2006

vars

	hdr			: CM_FileDataStorageHeader;
	folder		: FileFolder;
	path,
	folderString: String;


begin

	create folder;

	folderString := folder.browseForFolder(null, 'c:\');
	
	if folderString = null then
		return;
	endif;
	app.mousePointer := Window.MousePointer_HourGlass;

	foreach hdr in self.allAttachedFiles do
		app.writeBinaryToFile(hdr, folderString &amp; '\');
	endforeach;
	
	
epilog
	app.mousePointer := Window.MousePointer_Default;	
	delete folder;
end;</source>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="4dfee1c5-b9da-4b04-994e-cd7865455a87">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

// Created by cnwdvb1 on 28 June 2006

vars
	result	: String;
begin
	
	if _attrName = ETRow_CreatedTs then
		return self.createdTime.shortCurrentLocaleFormat();
	elseif _attrName = ETRow_PackageData then
		result := self.packageDataStr;
		// CCMS 2120 Nov 2011
		if self.emailToRecipients &lt;&gt; null then
			result := result &amp; CrLf &amp;  "to: " &amp; self.emailToRecipients;
		endif;
		if self.emailCcRecipients &lt;&gt; null then
			result := result &amp; CrLf &amp;  "cc: " &amp; self.emailCcRecipients;
		endif;
		if self.emailBccRecipients &lt;&gt; null then
			result := result &amp; CrLf &amp;  "bcc: " &amp; self.emailBccRecipients;
		endif;
		return result;
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
