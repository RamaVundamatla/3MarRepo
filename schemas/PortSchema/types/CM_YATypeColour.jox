<Class name="CM_YATypeColour" id="c22c5fca-58c9-4bf7-b43c-ecad33f87543">
    <superclass name="CM_YACriteriaType"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="getAllCriteriaValues" id="9401bb8a-2902-4482-bac4-9cd1dd6c4f1e">
        <source>getAllCriteriaValues(_terminalObj: CM_Terminal; _allCriteriaValues: ObjectSet input; _filter: Integer; _allDependentObjs : CM_ObjectArray);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 13/08/2013	cnwdap1		Initial creation PAR #32123
//17 September 2013	cnwmc5	PAR 31255 - allowing dependent objects the criteria is based on.
vars

begin
	if _terminalObj.getConfig(ValidateColour).Boolean then
		app.myDutyDocRoot.allVehicleColours.copy(_allCriteriaValues);
	else
		inheritMethod(_terminalObj, _allCriteriaValues, _filter, _allDependentObjs);
	endif;
epilog

end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_allCriteriaValues" type="ObjectSet" usage="input"/>
        <Parameter name="_filter" type="Integer"/>
        <Parameter name="_allDependentObjs" type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="getAllYAIdentifiers" id="d9c85f56-1129-43b3-b68d-e34bf8f7fede">
        <source>getAllYAIdentifiers(_yaIdentifiers: StringArray input): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 13/08/2013	cnwdap1		Initial creation PAR #32123 Sometimes Colour can be a "select" type criteria
//17 September 2013	cnwmc5	PAR 31255 - allowing dependent objects the criteria is based on.
vars
	criteriaColl	: ObjectSet;
	obj				: Object;
	name			: String;

begin
	if app.getMyTerminalDO_NOT_USE.getConfig(ValidateColour).Boolean then
		_yaIdentifiers.clear;
		create criteriaColl transient;
		self.getAllCriteriaValues(app.getMyTerminalDO_NOT_USE, criteriaColl, YAFilterOpt_None, null);
		foreach obj in criteriaColl do
			name := self.getDisplay(obj).toUpper();
			_yaIdentifiers.add(name);
		endforeach;
		return true;
	else		
		return inheritMethod(_yaIdentifiers);
	endif;

epilog
	delete criteriaColl;
end;</source>
        <Parameter name="_yaIdentifiers" type="StringArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaValueForTi" id="0aeb5959-55d4-42fd-af22-6203dbb41ef5">
        <source>getCriteriaValueForTi(_ti: CM_TrackedItem; _criteriaValue: Any output);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/11/2010	cnwdap1	Initial creation PAR #26184
17/09/2013	cnwdap1	PAR #32215 CM_Car is also valid for colour criteria
*/
vars

begin
	if _ti.isKindOf(CM_BreakBulkGeneric) then
		_criteriaValue := _ti.CM_BreakBulkGeneric.colour;
	elseif _ti.isKindOf(CM_Car) then							// PAR #32215
		_criteriaValue := _ti.CM_Car.colour;					// PAR #32215
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_criteriaValue" type="Any" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getDataDisplay" id="af8ecb2e-9618-49df-82b7-b6b6c26b7349">
        <source>getDataDisplay(pDataObj : CM_YAData) : String;
//01 August 2008	cnwdw1
begin
	return pDataObj.CM_YADataString.getDataDisplay(self);
end;</source>
        <Parameter name="pDataObj" type="CM_YAData"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="d9306e0a-31fb-4aae-beff-21547ea9c2bb">
        <source>getDisplay(dataObj: Object): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 13/08/2013	cnwdap1		Initial creation PAR #32123
//
vars

begin
	return dataObj.CM_VehicleColour.colour;

epilog

end;</source>
        <Parameter name="dataObj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
