    <JadeMethod name="doCSV" id="19aa5433-ddf8-4128-aaef-75d3beee0e96">
        <updating/>
        <source>doCSV() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 February 2014	cnwndl1	Initial creation	Par 33607

*/

vars

	form : CMUI_EDITranshipSummary;
	table : CM_DataTable;
	voyage : CM_Voyage;
	voyCode : String;

begin

	if self.myParentForm &lt;&gt; null and self.myParentForm.isKindOf(CMUI_EDITranshipSummary) then
		form := self.myParentForm.CMUI_EDITranshipSummary;
		voyage := form.myCurrentVoyage;
		if voyage &lt;&gt; null then
			voyCode := voyage.code;
		endif;
	endif;

	if form &lt;&gt; null then
	
		app.mousePointer := MousePointer_HourGlass;
	
		if self.chkTranship.value then
			table := form.tblTranship;
			if table.rows &lt;= table.fixedRows then
				app.raiseCMException(ERR_NoDataToExtract, 'Table Data', table);
				return;
			endif;
			
			table.outputAsCSV(voyCode &amp; "_Tranships");
		endif;
		if self.chkFulls.value then
			table := form.tblFulls;
			if table.rows &lt;= table.fixedRows then
				app.raiseCMException(ERR_NoDataToExtract, 'Table Data', table);
				return;
			endif;
			
			table.outputAsCSV(voyCode &amp; "_Disch_Fulls");
		endif;
		if self.chkEmpties.value then
			table := form.tblEmpties;
			if table.rows &lt;= table.fixedRows then
				app.raiseCMException(ERR_NoDataToExtract, 'Table Data', table);
				return;
			endif;
			
			table.outputAsCSV(voyCode &amp; "_Disch_Empties");
		endif;
			
	endif;	
		
	self.modalResult := IDOK;
	self.unloadForm;

epilog

	app.mousePointer := MousePointer_Default;

end;</source>
    </JadeMethod>
