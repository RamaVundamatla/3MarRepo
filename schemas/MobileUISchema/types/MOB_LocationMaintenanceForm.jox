    <JadeMethod name="setupForm" id="a90f5fdd-2475-49e7-a9b8-98a463b9b8b3">
        <updating/>
        <source>setupForm() updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 May 2008 by cnwdad1
//
// Purpose:		Standard form setup method.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	
	self.tableInitializeAllocations();
	self.doEnableControls();
	self.modalResult	:=	self.MB_MODAL_CANCEL;
	txtLocation.setFocus();
	
	if self.aLocation &lt;&gt; null then
		txtLocation.text := aLocation;
		self.doFindAllocationsForLocation();
		self.doEnableControls();
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="tableInitializeAllocations" id="ef30c6b1-e5b2-4dc8-b5d2-eabb735cb2ec">
        <source>tableInitializeAllocations() protected;
// --------------------------------------------------------------------------------
// Created:		03 June 2008 by cnwdad1
//
// Purpose:		Initializes the Yard Allocations table control.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableObj		: Table;
	allocationObj	: CM_YardAllocation;
	rowPointer		: Integer;
begin
	tableObj			:=	tblLocation;
	tableObj.allowResize:= Table.AllowResize_Any;

	tableObj.rows		:=	1;
	tableObj.columns	:=	2;
	tableObj.setCellText(1, 1, "Code" &amp; Tab &amp; "Description");
	tableObj.wordWrap:=true;
	tableObj.accessColumn(1).width := 200;
	tableObj.accessColumn(2).width :=420;
	tableObj.accessColumn(2).marginRight := 2;
	
	rowPointer:=1;
	foreach allocationObj in self.aAllYardAllocations do
		tableObj.cnEcAddItem(allocationObj.getTableDisplay(), allocationObj);
		rowPointer:=rowPointer + 1;
		tableObj.accessCell(rowPointer,2).wordWrap:=true;
	endforeach;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="tableRemoveAllocation" id="2a94e806-8fe2-4f68-a138-1238c0c62d4c">
        <source>tableRemoveAllocation() protected;
// --------------------------------------------------------------------------------
// Created:		03 June 2008 by cnwdad1
//
// Purpose:		Removes the selected Yard Allocation from the table.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableObj		: Table;
	allocationObj	: CM_YardAllocation;
	
begin
	tableObj		:=	tblLocation;
	allocationObj	:=	self.getSelectedAllocation();
	
	if allocationObj = null then
		app.msgBox("Please select the Yard Allocation to remove.", app.getString(Error), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return;
	endif;
	
	if tableObj.cnEcRemoveObjectRow(allocationObj) then
		self.aAllRemovedAllocations.add(allocationObj);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
