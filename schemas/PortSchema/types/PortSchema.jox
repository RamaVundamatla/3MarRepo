    <JadeMethod name="alertExceptionHandler" id="79bda603-3577-470d-a650-0cb3f07de883">
        <updating/>
        <source>alertExceptionHandler(	exObj 			: Exception;
						_remoteHeader	: CM_RemoteDataHdr;
						_description	: String;
						_error			: Integer output;
						_errStr			: String output;
						_alertMe,
						_emailMe		: Boolean) : Integer updating;

/*

Date		Who		Reason
23 Sep 2008	cnwkpd1	PAR #18009 - Prevent transient leaks
11 Jun 2010	cnwkpd1	PAR #17097 - Handle exceptions that occur in Alert creation
27 Mar 2013	cnwmh5  PAR #31047 - Handle _description correctly for CAMS Request Errors
08 Nov 2016	cnwrs1	TFS 2913 Par 38341 EDI files that are open are not being processed
04 Jul 2019	jlgrs1	TFS45051 JMT terminate on a SDS secondary exception ie a takeover has happened.
19 Jan 2024	navmd1	TFS 55021 Provide more useful errors when .NET exception occurr (Email Architect specifically)
22 Mar 2024	navmd1	TFS 63103 Show large .NET errors better
*/

vars
	longErrStr,
	errStr,
	msgStr,
	aStr,
	theDisplay		: String;
	error			: CM_Error;
	lockEx			: LockException;
	aTime 			: TimeStamp;
	errorArray		: StringArray512;
	callStack		: ProcessStackArray;
	methCallDesc	: MethodCallDesc;
	alertMe			: Boolean;
	emailMe 		: Boolean;
	lockedBy		: Process;
	invalidProcess	: Boolean;
	invalidBGP		: Boolean;
	returnVal		: Integer;
	msg 			: String;
	idx				: Integer;
begin
	if exObj.errorCode = 1228 or 
	   exObj.errorCode = 1295 or 
	   exObj.errorCode = 3015 or 
	   exObj.errorCode = 3037 then
		abortTransaction;
		abortTransientTransaction;
		msg := class.name&amp;'::'&amp;method.name&amp;' SDS Exception, cant continue,'&amp;exObj.errorCode.String&amp;' '&amp;exObj.extendedErrorText&amp;' processApp= '&amp;process.persistentApp.name&amp;' '&amp;process.userInfo&amp;' ('&amp;process.node.String&amp;", "&amp;process.String&amp;')';
		app.writeLog(msg, LogFATAL);	//25 Nov 2019	NDL	TFS 47053
		
		terminate;
	endif;

	returnVal := Ex_Pass_Back;
	
	abortTransaction;
	abortTransientTransaction;
	
	// PAR #17097 - set up last resort exception handler
	on Exception do self.alertExceptionHandlerFinal(exception);
	
	longErrStr := _description;
	errStr := '(' &amp; exObj.errorCode.String &amp; '). ' &amp; exObj.extendedErrorText;
   	_error := exObj.errorCode;
   	create errorArray transient;
   	alertMe := _alertMe;
	emailMe := _emailMe;
	
   	if emailMe then
   		alertMe := true;
   	endif;
	if longErrStr.cnContains("EDI") then 
		if exObj.errorCode = 5030 then
			alertMe := false;
			emailMe := false;
		endif;
	endif;

	// Get specific information.
	app.writeLog(	'INFO &gt;&gt; Exception handled by alertExceptionHandler. Alert generated = ' &amp; alertMe.String &amp;
					' Email generated = ' &amp; emailMe.String &amp;
					' (' &amp; exObj.errorCode.String &amp; ')', LogINFO);
	
	// 26/03/2013 cnwmh5 3107 - CAMS Error only
	if longErrStr.cnContains("CAMS") and longErrStr.cnContains("Environment:") and 
	   longErrStr.cnContains("Terminal:") and longErrStr.cnContains("Protocol") then
		errorArray.add(longErrStr);
		longErrStr := longErrStr[1:5];
	endif;
	
	// 19/01/2024 navmd1 TFS 55021 BGP .NET errors (Email Architect)
	if (longErrStr.cnContains("Target:") and longErrStr.cnContains("Source:") and longErrStr.cnContains("Inner exception:")) or
		longErrStr.cnContains("AADSTS")	// 30/08/2024 navmd1 TFS 65917 AAD Oauth errors
	then
		idx := 1;
		msg := longErrStr.scanUntil(CrLf, idx);	// Keep the BGP Name
		longErrStr := longErrStr[idx+2:end];	// But add the .NET output at the top
		errorArray.setFromLongString(longErrStr, CrLf);
		longErrStr := msg;						// Then reuse the BGP Name later
	endif;
	
	if not exObj.isKindOf(CM_Exception) and alertMe then
   		errStr := errStr &amp; '(' &amp;  exObj.text &amp; ')';
   		app.doDumpStack(exObj);
   		// cut back the stack to the current method
   		
   		if exObj.errorCode = 1027 then
   			if exObj.isKindOf(LockException)  then
   				lockEx := exObj.LockException;
				
				if lockEx.lockType = Share_Lock then
					msgStr := " Share_Lock ";
				elseif lockEx.lockType =  Reserve_Lock then
					msgStr := " Reserve_Lock ";
				elseif lockEx.lockType =  Exclusive_Lock then
					msgStr :=  " Exclusive_Lock ";
				endif;
				
				msgStr := msgStr &amp; " Of Object :" &amp; getOidStringForObject(lockEx.lockTarget); //getName;
				errorArray.add(msgStr[1:256]);
				
				lockedBy := lockEx.targetLockedBy;			// PAR #17097
				if lockedBy = null then
					invalidProcess := true;
				else 
					on Exception do app.handleDeletedObject(exception, lockedBy, invalidProcess);
					msgStr := " By " &amp; lockEx.targetLockedBy.userCode &amp; " " &amp; lockEx.targetLockedBy.userInfo;
					on Exception do null;
				endif;
				if invalidProcess then
					msgStr := " By unknown user";
				endif;
				
				process.getLockDuration(lockEx.lockTarget, aTime, aStr);
				msgStr := msgStr &amp; " Locked on" &amp; aTime.display &amp; " for " &amp; aStr;
				errorArray.add(msgStr[1:256]);
				errStr := errStr &amp; ' Background Lock exception';
			endif;
		endif;
	endif;
	
	if alertMe then
		// get the stack for the current process
		//-------------
		create callStack;
		process.currentStack(callStack);
		
		//-------------
		// cut back the stack to the current method
		//-------------
		while callStack.size &gt; 0 and callStack[1].method &lt;&gt; exObj.currentMethodDesc.method do
			delete callStack.removeAt(1);		// PAR #18009
		endwhile;
		
		//-------------
		//Add the call stack to the alert
		//-------------
		foreach methCallDesc in callStack do
			theDisplay := methCallDesc.display();
			if theDisplay.length &gt; 0 then
				errorArray.add(theDisplay[1:256]);
			endif;
		endforeach;
		
		//Exception 1271  (An attempt was made to perform an operation eg. beginTransaction etc that is prohibited in this context.
		if exObj.errorCode &lt;&gt; 1271 then //cnwrs1 Sept 2007 par 14953 we are just going around in circles
			self.remoteErrorWarningToAlert(longErrStr &amp; ' ' &amp; errStr, _remoteHeader,  null, errorArray, emailMe, true);
		endif;
	endif;
	
	if self.myBGPObject &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, self.myBGPObject, invalidBGP);
		self.myBGPObject.causeEvent(BGP_Object.BGP_DisplayUpdate, true, null);
		on Exception do null;
	endif;
	
	_errStr := errStr;
	
	// PAR #17097 - make exception handling more robust
	if exObj.resumable then
		returnVal := Ex_Resume_Next;
	else
		returnVal := Ex_Abort_Action;
	endif;
	
	
epilog
	if callStack &lt;&gt; null then
		callStack.purge;
		delete callStack;
	endif;
	delete errorArray;
	return returnVal;
	
end;</source>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="_remoteHeader" type="CM_RemoteDataHdr"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_error" type="Integer" usage="output"/>
        <Parameter name="_errStr" type="String" usage="output"/>
        <Parameter name="_alertMe" type="Boolean"/>
        <Parameter name="_emailMe" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="alertExceptionHandlerFinal" id="ea649b0b-05c0-406a-8ab2-db38f484c6b1">
        <source>alertExceptionHandlerFinal(_exc : Exception) : Integer;

/*

Purpose:			Exception handler of last resort to be used when handling an Alert,
					to ensure we do not get nested exceptions

Parameters:			Exception Object

Return Value:		Exception return code


Date		Who		Reason
11 Jun 2010	cnwkpd1	PAR #23525 - System performance enhancements

*/

vars
	returnVal		: Integer;
	
begin
	returnVal := Ex_Abort_Action;
	
	abortTransaction;
	abortTransientTransaction;
	
	// If we get to here, there is nothing more we can do, so we must abort the 
	// current action
	app.writeLog('INFO &gt;&gt; Exception (' &amp; _exc.errorCode.String &amp; ') handled by ' &amp; method.qualifiedName &amp;
				 ', transaction aborted and returning Ex_Abort_Action', LogINFO);
	
	
epilog
	return returnVal;
	
end;</source>
        <Parameter name="_exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="alertLockExceptionHandler" id="6b9cdaa5-c87f-4591-8af7-8251d4d38243">
        <source>alertLockExceptionHandler(le : LockException) : Integer;
/*

Date		Who		Reason
11 Jun 2010	cnwkpd1	PAR #17097 - Handle exceptions in Alert creation
03 May 2011 cnwrs1  par 27333 - wait longer on try lock and retry only 5 times this gixes us 100secs before time out rather than 20secs
15 Jun 2012	cnwkpd1	PAR #29594 - Revert wait back to 20 seconds for generic usage, as 100 seconds is too long

*/

constants
	RetryTimeout	= 20000;			// 20 seconds

vars
	lockedBy		: Process;
	lockedByUserCode : String;
	retryCount		: Integer;
	invalidProcess	: Boolean;
	returnVal		: Integer;
	startRetry		: Decimal[20];
	
begin
	// PAR #17097 - rework to ensure code is more robust, to prevent 1092, 1238 exceptions
	returnVal := Ex_Pass_Back;
	
	lockedBy := le.targetLockedBy;
 	if lockedBy = null then
		invalidProcess := true;
	else
		on Exception do app.handleDeletedObject(exception, lockedBy, invalidProcess);
 		lockedByUserCode := lockedBy.userCode;
		on Exception do null;
 	endif;
	if invalidProcess then
		lockedByUserCode := 'not available';
	endif;

	// PAR #29594 - Log when we get in here unconditionally, but only retry once (for 20 seconds)
	app.writeLog('INFO &gt;&gt; Alert lock found, (' &amp; le.errorCode.String &amp; ') Locked by ' &amp; lockedByUserCode , LogINFO);
	startRetry := app.relativeMachineTime();
	if tryLock(le.lockTarget, le.lockType, le.lockDuration, RetryTimeout) then
		app.writeLog('INFO &gt;&gt; Alert lock cleared on retry after ' &amp; (app.relativeMachineTime() - startRetry).String &amp; ' ms', LogINFO);

		returnVal := Ex_Continue;				// must have the lock if we get to here
		return returnVal;
	endif;
	
	// Didn't get the lock on retry, so pass back the the exception
	app.writeLog('INFO &gt;&gt; Alert lock exception generated (' &amp; le.errorCode.String &amp; ') Locked by ' &amp; lockedByUserCode , LogINFO);
	app.writeLogLockException(le);

	returnVal := Ex_Pass_Back;		// let another handler deal with it

epilog
	return returnVal;

end;</source>
        <Parameter name="le" type="LockException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="appReloadEDIFileFormats" id="a2b47137-383a-4e98-86ad-8811993b861c">
        <source>appReloadEDIFileFormats();
//----------------------------------------------------------------
//	Created:	12 August 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	formatsAgent	: CM_EDIFileFormatAgent;
	rtnValue		: Boolean;
	str, rtnStr		: String;
	newFormatGC		: Integer;
begin
	
	//any NEW formats?
	newFormatGC := FonterraPack;
	
	app.initialize();
	create formatsAgent transient;

	formatsAgent.myRoot := app.myRoot;

	rtnValue := formatsAgent.trxLoadFormatsFromGlobalConsts();

	// If we have true then we will only have warnings.
	if rtnValue then
		foreach str in formatsAgent.allErrorStrings do
			rtnStr := rtnStr &amp; str &amp; CrLf;
		endforeach;
	else
		rtnStr := 'Fatal Error';
	endif;

	app.writeStatement( rtnStr);
	app.writeStatement( 'Finished loading formats.');
	
epilog
	delete formatsAgent;
end;</source>
    </JadeMethod>
    <JadeMethod name="auditTypeEnumToString" id="0133e7bb-00a4-49d2-a46f-dba16b0bfd70">
        <source>auditTypeEnumToString(_enum: Integer): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 June 2018	jlgmp6	Initial creation	TFS37718

*/

vars

begin
	if _enum = AuditCreated then
		return AuditCreated_str;
	elseif _enum = AuditUpdated then
		return AuditUpdated_str;
	elseif _enum = AuditDeleted then
		return AuditDeleted_str;
	elseif _enum = AuditInformation then
		return AuditInformation_str;
	else
		return null;
	endif;

epilog

end;</source>
        <Parameter name="_enum" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
