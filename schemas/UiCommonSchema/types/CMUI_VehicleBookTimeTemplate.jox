    <JadeMethod name="cmbTSType_lostFocus" id="500cf209-25ec-4267-8ef0-0e69fe646a92">
        <controlMethod name="CMUI_ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbTSType_lostFocus(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 june 2022 navtnr20 ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types

*/

vars
	theForm : CMUI_VehicleBookTimeTemplate;
	obj 	: CM_VehicleBookingTimeSlotType;
	vbs 	: CM_VBSProcess;
begin
	
	obj := combobox.listObject.CM_VehicleBookingTimeSlotType;
	
	if obj &lt;&gt; null then
		vbs := obj.myVBSProcess;
	endif;
	
	if  obj &lt;&gt; null and vbs &lt;&gt; null  and vbs.isVbsSlotValidation  then 
		self.txtTimeStart.setTime(obj.startTime);			
		self.txtDuration.text := obj.duration.String;
	else
		self.txtTimeStart.setTime( null );
		self.txtDuration.text := "1";	
	endif;		

epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
