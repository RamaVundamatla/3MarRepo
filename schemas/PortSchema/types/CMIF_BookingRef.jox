    <JadeMethod name="setProxyFromEDI" id="d6dc0ea1-a2c9-49ec-94f7-7760ae9bd679">
        <updating/>
        <source>setProxyFromEDI(_ediBookingRefTI : CM_EDIBookingRefTI;
				_terminal : CM_Terminal) updating;
/*
	Created on 04 March 2008
	
	by Debby Hutchison
	
	Purpose:
/* Changes

Date		Name	TFS#		Description
============================================================================
21 May 2011	cnwcs5	CCMS SCT 	2058/par 27460 - add carrier reference
02 Feb 2012	cnwrs1	Par 29076 	Fix up Hazard Processing in EDI
23 Apr 2012	cnwdap1	PAR #29475 	CCMS PNL 2155 transfer packing container requirements from EDI item
27 May 2013	cnwdap1	PAR #31596 	added freight forwrder parameter to setProxy method
28 May 2013	cnwrs1	Par 31596 	add freight forwarder to EDI booking
05 Jun 2018	jlgrs1	TFS 39018 	SNO Cargo Operator in COPRAR
12 Jun 2019	jlgka1	TFS 44416 	PNL Loading Default Cargo Type Settings via EDI
02 Oct 2020 cnwma1 				ChangeRequest 50112: ASPA - GCI Stevedores
============================================================================*/
vars
	tmpHazards 				: ObjectArray;
	consignee,
	consignor				: CM_ConsigneeConsignor;
	freightForwarder 		: CM_ConsigneeConsignor;
	operator 				: CM_Operator;
	bookingConsignorRef		: String;
	tmpPorts 				: StringArray;
	misVersionBookingRef 	: Boolean; //ccms 1855 cnwrs1 sept 2009
	ediBookingRefTI 		: CM_EDIBookingRefTI;
	idx						: Integer;					// PAR #29475
	type					: String;					// PAR #29475
	nbr						: Integer;					// PAR #29475
	stevedore               : CM_Stevedore;
begin
	// PAR #29475 start
	foreach idx in 1 to _ediBookingRefTI.containerTypes.size do
		type := _ediBookingRefTI.containerTypes[idx];
		nbr := _ediBookingRefTI.containerNbrs[idx];
		if not self.containerTypes.includes(type) then
			self.containerTypes.atPut(idx, type);
			self.containerNbrs.atPut(idx, nbr);
		endif;
	endforeach;
	// PAR #29475 end
	
	ediBookingRefTI := _ediBookingRefTI;
	misVersionBookingRef := _terminal.getConfig(ProcessMISVersionBkRef).Boolean; //cnwrs1 ccms 1855 Sept 2009

	consignee	:= ediBookingRefTI.getConsign(ediBookingRefTI.consignee);
	if consignee = null then
		consignee := self.myProxyBookingRef.myConsignee;
	endif;
	
	consignor	:= ediBookingRefTI.getConsign(ediBookingRefTI.consignor);
	if consignor = null then
		consignor := self.myProxyBookingRef.myConsignor;
	endif;
	freightForwarder	:= ediBookingRefTI.getConsign(ediBookingRefTI.freightForwarder);
	if freightForwarder = null then
		freightForwarder := self.myProxyBookingRef.myFreightForwarder;
	endif;
	
	create tmpPorts transient;	//Par18738, Jan 2008
	if self.myRealBookingRef &lt;&gt; null and self.myRealBookingRef.allDischargePorts.size &gt; 0 then
		tmpPorts.clear;
		self.myRealBookingRef.allDischargePorts.copy(tmpPorts);
	endif;
	
	operator := app.myRoot.allOperators[ediBookingRefTI.operatorCode];
	
	//02.10.2020 cnwma1 TFS #50112
	stevedore	:= ediBookingRefTI.getStevedore(ediBookingRefTI.stevedore);
	if stevedore = null then
		stevedore := self.myProxyBookingRef.myStevedore;
	endif;
	
	create tmpHazards transient;
	//create tmpPorts transient;
	ediBookingRefTI.getProxyHazards(ediBookingRefTI.imCodes, tmpHazards, false);
	
	self.myProxyBookingRef.setProxy(ediBookingRefTI.getId(misVersionBookingRef), //cnwrs1 sept 2009 ccms 1855 // adm 160310 Par 22937 remove bolType
					ediBookingRefTI.cargoType,
					self.myProxyBookingRef.clean, 			//null,PAR 13417		//ediTI.clean.Boolean,
					ediBookingRefTI.commodity,
					self.myProxyBookingRef.consignorReference, 
					self.myProxyBookingRef.description,	
					ediBookingRefTI.destinationPort,
					ediBookingRefTI.dischargePort,null,
					tmpPorts,//stringArray
					tmpHazards,//objarray
					self.myProxyBookingRef.getHumidity,
					self.myProxyBookingRef.inspected,		//null,PAR 13417		//ediTI.inspected.Boolean,
					ediBookingRefTI.isoType,
					consignor,	//Par18738, Jan 2008	//ediBookingRefTI.getConsign(ediBookingRefTI.consignor),
					consignee,	//Par18738, Jan 2008	//ediBookingRefTI.getConsign(ediBookingRefTI.consignee),
					operator,
//					_terminal.lookupVoyage(ediBookingRefTI.voyageCode, null, false),	// cnwrl1 09/06/2010 PAR 24299 - what it was
					_terminal.lookupVoyage(ediBookingRefTI.getVoyageCode(), null, false),
					ediBookingRefTI.number,
					//ediBookingRefTI.quantity,		// 03/03/2014 cnwar2 #33016
					ediBookingRefTI.bookingRemarks,//booking remarks
					ediBookingRefTI.remarks,
					ediBookingRefTI.temperature,    //FD for 1749
					self.myProxyBookingRef.ventilation,		//null,PAR 13417		//vent
					ediBookingRefTI.height, //height
					ediBookingRefTI.length, //length
					ediBookingRefTI.width, //width
					self.myProxyBookingRef.heightString,
					self.myProxyBookingRef.lengthString,
					self.myProxyBookingRef.widthString,
					self.myProxyBookingRef.typeString,
					ediBookingRefTI.density,		// MES1008 JMH 28/9/09
					ediBookingRefTI.volume, //volume
					//self.myProxyBookingRef.productQuantity,//0,PAR 13417			// product quantity
					ediBookingRefTI.productQuantity,		// 03/03/2014 cnwar2 #33016
					ediBookingRefTI.weight,
					ediBookingRefTI.volume,//cubic metres
					_terminal, 
					ediBookingRefTI.getProduct(ediBookingRefTI.operatorCode, ediBookingRefTI.product), // jlgka1 TFS 44416
					false,	//pIsMultiItem
					ediBookingRefTI.isStockBookingRef,
					ediBookingRefTI,
					ediBookingRefTI.rawEDIData,
					ediBookingRefTI.shippingRef,
					null, 	// _carrierReference String	par 27460 cnwcs5
					null, 	//_consignorDesc String
					null, 	//_consigneeDesc String
					null, 	//_custPriority CM_CustomerPriority
					null,	//_specialStow CM_SpecialStow
					false, 	//_holdPartials
					false, 	//_noFullIsAllowedIn
					false, 	//_noEmptiesOut
					false, 	//_isMilitary
					null, 	//_vNumber String
					false, 	//_overrideCutoff
					false, 	//_overDimension
					false, 	//_fumigationNeeded
					false, 	//_isStopped
					BOOKING_REF_ACTIVE,  //cnwjo3 par #20476, all EDIs are set to active
					ediBookingRefTI.ediFileIssueDateTime, 
					null, 					// _specialLift ObjectArray
					null, 					// _allLinkedStockBookingItems : CM_BookingRefItemSet
					false, 					// _receiveAsTranship
					null, 					// _transhipVoyage : CM_Voyage
					0,						// _packAs
					null,					// customsAgent	// cnwrl1 18/02/2010 PAR 22393
					null, 					//voyageName
					null,					//vesselname //cnwrs1 CCMS 1882 03 June 2010
					null,					// direct delivery
					freightForwarder,		// freight forwarder	// PAR #31596
					null, 					//carrier
					stevedore 				//Stevedore //02.10.2020 cnwma1 TFS #50112
					);
epilog
	if tmpHazards &lt;&gt; null then
		tmpHazards.purge();
	endif;
	delete tmpHazards;
	delete tmpPorts;
end;
</source>
        <Parameter name="_ediBookingRefTI" type="CM_EDIBookingRefTI"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromEDIBooking" id="e9dea5a9-6b9a-4536-96a7-31608609114c">
        <updating/>
        <source>setProxyFromEDIBooking(_ediTI : CM_EDIBookingHeaderTI; _terminal : CM_Terminal) updating;
//
// par21718 cnwrs1 dec 2009
// 21 May 2011	cnwcs5		CCMS SCT 2058/par 27460 - add carrier reference
// 06 Mar 2013 	cnwcs5		par 30849 - set carrier reference (also a bit of a tidy up)
// 27 may 2013	cnwdap1		PAR #31596 Added freight forwarder parameter to setProxy method
// 28 May 2013	cnwrs1	Par 31596 add freight forwarder to EDI booking
// 05 Jun 2018	jlgrs1	TFS 39018 SNO Cargo Operator in COPRAR
vars
	dummy 					: ObjectArray;
	consignee, 
	consignor 				: CM_ConsigneeConsignor;
	freightForwarder		: CM_ConsigneeConsignor;
	operator 				: CM_Operator;
	portColl 				: StringArray;
	misVersionBookingRef 	: Boolean;
	transhipVoyage			: CM_Voyage;			// cnwrl1 18/02/2010 PAR 22393
	packAsInteger			: Integer;				// cnwrl1 16/04/2010 PAR 23624
	proxy, 
	booking					: CM_BookingRef;
	carrier 				: CM_Carrier;
	stevedore               : CM_Stevedore;        //02.10.2020 cnwma1 TFS #50112
begin
	misVersionBookingRef 	:= _terminal.getConfig(ProcessMISVersionBkRef).Boolean; //cnwrs1 ccms 1855 Sept 2009
	proxy					:= self.myProxyBookingRef;
	booking					:= self.myRealBookingRef;
	
	consignee 				:= _ediTI.getConsign(_ediTI.consignee);
	if consignee = null then
		consignee := proxy.myConsignee;
	endif;
	
	consignor := _ediTI.getConsign(_ediTI.consignor);
	if consignor &lt;&gt; null and not consignor.isConsignor then		// 09/07/2013 cnwar2 #31233 - only use consignor if actually a consignor
		consignor := null;
	endif;
	
	if consignor = null then
		consignor := proxy.myConsignor;
	endif;
	
	carrier := app.myRoot.allCarriers[_ediTI.carrierCode];

	freightForwarder := _ediTI.getConsign(_ediTI.freightForwarder);
	if freightForwarder = null then
		freightForwarder := proxy.myFreightForwarder;
	endif;

	create portColl transient;	//Par18738, Jan 2008
	
	if booking &lt;&gt; null and booking.allDischargePorts.size &gt; 0 then
		booking.allDischargePorts.copy(portColl);
	endif;
	
	operator := app.myRoot.allOperators[_ediTI.operatorCode];
	
	stevedore := _ediTI.getStevedore(_ediTI.stevedore);   	//02.10.2020 cnwma1 TFS #50112
	create dummy transient;
	
	// cnwrl1 18/02/2010 PAR 22393 - search for the tranship original voyage including archived voyages.
	transhipVoyage	:= _terminal.lookupVoyage( _ediTI.getTranshipOriginalVoyage, null, true );	
	packAsInteger	:= app.bookingPackAsStringToEnumb( _ediTI.packAs );	// cnwrl1 16/04/2010 PAR 23624
	
	proxy.setProxy(_ediTI.getId(misVersionBookingRef), 				//cnwrs1 sept 2009 ccms 1855 // adm 160310 Par 22937 remove bolType
									_ediTI.cargoType,
									proxy.clean, 									//null,PAR 13417		//ediTI.clean.Boolean,
									null, 	// commodity,
									proxy.consignorReference, 
									proxy.description,	
									_ediTI.destinationPort,
									_ediTI.dischargePort,
									null,	//pMyTranshipToPort
									portColl,//stringArray
									dummy,	//objarray
									proxy.getHumidity,
									proxy.inspected,		//null,PAR 13417		//ediTI.inspected.Boolean,
									null, 	// isoType,
									consignor,	//Par18738, Jan 2008	//_ediBookingRefTI.getConsign(_ediBookingRefTI.consignor),
									consignee,	//Par18738, Jan 2008	//_ediBookingRefTI.getConsign(_ediBookingRefTI.consignee),
									operator,
									_terminal.lookupVoyage(_ediTI.getVoyageCode(), null, false),
									null, 	// number,
									_ediTI.bookingRemarks,//booking remarks
									_ediTI.remarks,
									null, 	// temperature,    //FD for 1749
									proxy.ventilation,		//null,PAR 13417		//vent
									null, 	// height, //height
									null, 	// length, //length
									null, 	// width, //width
									proxy.heightString,
									proxy.lengthString,
									proxy.widthString,
									proxy.typeString,
									null, 	// density,		// MES1008 JMH 28/9/09
									null, 	// volume, //volume
									proxy.productQuantity,//0,PAR 13417			// product quantity
									null, 	// weight,
									null, 	// volume,//cubic metres
									_terminal, 
									null, 	// getProduct(_ediBookingItemTI.product),
									false,	//pIsMultiItem
									_ediTI.isStockBookingRef,
									null, 	//_ediBookingTI,
									_ediTI.rawEDIData, 		//cnwrs1 26 Oct 2010 par 26044
									_ediTI.shippingRef,
									_ediTI.carrierReference, 	// par 30849 carrierReference	par 27460 cnwcs5
									null, 	//_consignorDesc
									null, 	//_consigneeDesc
									null, 	//_custPriority
									null,	//_specialStow
									false, 	//_holdPartials
									false, 	//_noFullIsAllowedIn
									false, 	//_noEmptiesOut
									false, 	//_isMilitary
									null, 	//_vNumber
									false, 	//_overrideCutoff
									false, 	//_overDimension
									false, 	//_fumigationNeeded
									false, 	//_isStopped
									BOOKING_REF_ACTIVE,  						//cnwjo3 par #20476, all EDIs are set to active
									_ediTI.ediFileIssueDateTime, 
									null, 	//_specialLift
									null, 	//_allLinkedStockBookingItems
									_ediTI.receiveAsTranship,		// cnwrl1 18/02/2010 PAR 22393
									transhipVoyage,								// cnwrl1 18/02/2010 PAR 22393
									packAsInteger,								// cnwrl1 16/04/2010 PAR 23624
									_ediTI.customsAgent,			// cnwrl1 18/02/2010 PAR 22393
									_ediTI.getVoyageCode(), 		//cnwrs1 CCMS 1882 03 June 2010
									_ediTI.vesselName,
									null,	// direct delivery
									freightForwarder,	// freight frowarder	// PAR #31596
									carrier, 	        //carrier
									stevedore);         //stevedore //02.10.2020 cnwma1 TFS #50112
	
epilog
	delete dummy;
	delete portColl;
end;
</source>
        <Parameter name="_ediTI" type="CM_EDIBookingHeaderTI"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="2ccffdda-e027-4de6-bc9e-f76eac248d33">
        <updating/>
        <source>validateForCreate(_passport : CM_Passport input; pUserObject : Object) updating;
/*
	Created on 13 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	interfaceItem : CMIF_BookingRefItem;
	
begin
	myProxyBookingRef.raiseExceptionIfNotTransient(method);
	
	if self.allCMIF_BRItems.size = 0 then
		app.raiseCMException1(AddNewItem, 'Add Item', null, null);
	endif;

	myProxyBookingRef.validateForCreate(_passport, pUserObject, self);
	
	foreach interfaceItem in self.allCMIF_BRItems do
		interfaceItem.validateForCreate(_passport);
	endforeach;

	self.validateHazardsOnBookingItems();
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="pUserObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="d07b6947-d8fd-4da8-8344-b037b74937db">
        <updating/>
        <source>validateForUpdate(_passport : CM_Passport input; pUserObject : Object) updating;
/*
	Created on 14 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	cmif_BRItem : CMIF_BookingRefItem;
	
begin
	if allCMIF_BRItems.size &gt; 1 
	and	not myProxyBookingRef.isMultiItemBookingRef then
		app.raiseCMException(BookRefMustBeMulti, null, null);
	endif;
	if allCMIF_BRItems.size = 0 then
		app.raiseCMException(BookRefHasNoItems, null, null);
	endif;
	myProxyBookingRef.validateForUpdate(_passport, pUserObject, self);
	
	foreach cmif_BRItem in allCMIF_BRItems do
		cmif_BRItem.validateForUpdate(_passport);
	endforeach;
	self.validateHazardsOnBookingItems();
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="pUserObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="validateHazardsOnBookingItems" id="db8352be-5d15-422d-bc6f-c19b0a8a9443">
        <source>validateHazardsOnBookingItems();
/*

Purpose:  check if hazard items exist on the booking items but not on the booking			

Parameters:			

Return Value:		


Date		Who		Reason
15 September 2008	cnwer1	Initial creation

*/

vars
	iter : Iterator;
	cmifHazBookingItem : CMIF_BookingRefItem;
	tiHazard : CM_TIHazard;
begin
	if not app.myPassport.myTerminal.getConfig(UseBookingSummView).Boolean then
		return;
	endif;
		
	foreach cmifHazBookingItem in self.allCMIF_BRItems do
		delete iter;
		iter:=cmifHazBookingItem.allTIHazards.createIterator;
		while iter.next(tiHazard) do
			if self.allTIHazards[tiHazard.code] = null then
				app.raiseCMWarning1(WARN_HAZ_REMOVE_BOOKING,tiHazard.code,"Hazards",null,null);
				return;
			endif;
		endwhile;	
	endforeach;
epilog
	delete iter;
end;</source>
    </JadeMethod>
</Class>
