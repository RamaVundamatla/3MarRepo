    <JadeMethod name="clear" id="60322128-6804-40d7-aa87-f1d42de4b75e">
        <updating/>
        <source>clear() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2011	cnwndl1	Initial creation	Par 27731
*/

vars

	mtPoolEnqLine : CM_MTPoolingEnquiryLine;

begin

	foreach mtPoolEnqLine in self.allMTPoolingEnquiryLines do
		delete mtPoolEnqLine;
	endforeach;
	
	self.allSelectedMTThresholds.clear();
	
	self.myFiltOperator := null;
	self.myFiltIsoGroup := null;
	self.myFiltGrade := null;
	self.myFiltReceivalDate := null;
	self.myFiltReleaseDate := null;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="clearAllExpiredLastNotified" id="58731467-613d-4fe5-b590-097c09ca7c80">
        <source>clearAllExpiredLastNotified( _ts : TimeStamp );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

	iter : Iterator;
	thresh : CM_MTThreshold;
	
begin

	//Clear the last notifieds on thresholds whose last notified value + re-notify time is less than the time stamp.
	//They are either finished with or can re notified again.

	iter := self.myFiltTerminal.allMTThresholds.createIterator;
	while iter.next( thresh ) do
		if thresh.lastNotified.Date.isValid then
			beginTransaction;
			thresh.resetLastNotifiedIfExpiredAt(_ts);
			commitTransaction;
		endif;
	endwhile;

epilog

	delete iter;

end;</source>
        <Parameter name="_ts" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="clearLastNotifiedOnNonBreached" id="1e9d5c4a-f1ae-4a1f-bad6-3a739b5877b9">
        <source>clearLastNotifiedOnNonBreached( _allBreachLines : CM_MTPoolingEnquiryLineDict );

/*

Purpose:			Find all thresholds that have a last notified value (these will be current),
					and clear any that are no longer included in the breaches.
					I.e. the ones that someone has remedied within the re-notify time.

Parameters:			

Return Value:		


Date		Who		Reason
22 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

	iter : Iterator;
	thresh : CM_MTThreshold;
	
begin

	iter := self.myFiltTerminal.allMTThresholds.createIterator;
	while iter.next( thresh ) do
		if thresh.lastNotified.Date.isValid then
			if not _allBreachLines.includesThreshold( thresh ) then
				beginTransaction;
				thresh.setLastNotified( null );
				commitTransaction;
			endif;
		endif;
	endwhile;

epilog

	delete iter;

end;</source>
        <Parameter name="_allBreachLines" type="CM_MTPoolingEnquiryLineDict"/>
    </JadeMethod>
    <JadeMethod name="createMTPoolingEnqLines" id="f77e1f20-f82f-4651-af7b-a756f3707a54">
        <source>createMTPoolingEnqLines();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2011	cnwndl1	Initial creation

*/

vars

	iter : Iterator;
	thresh : CM_MTThreshold;
	mtPoolEnqLine : CM_MTPoolingEnquiryLine;

begin

	iter := self.allSelectedMTThresholds.createIterator;
	while iter.next( thresh ) do
		create mtPoolEnqLine transient;
		mtPoolEnqLine.setBaseData( thresh, self );
	endwhile;

epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="getAllBreachedPoolingEnqLines" id="62cc6f30-e92d-432a-9e30-441d3596c2a4">
        <source>getAllBreachedPoolingEnqLines( _allBreachLines : CM_MTPoolingEnquiryLineDict io);

/*

Purpose:			

Parameters:			Get current lines that have breaches.

Return Value:		


Date		Who		Reason
22 June 2011	cnwndl1	Initial creation

*/

vars

	mtPoolEnqLine : CM_MTPoolingEnquiryLine;

begin

	foreach mtPoolEnqLine in self.allMTPoolingEnquiryLines do
		if mtPoolEnqLine.isMinBreached or mtPoolEnqLine.isMaxBreached then
			_allBreachLines.addNoDuplicates(mtPoolEnqLine, false);
		endif;
	endforeach; 

epilog

end;</source>
        <Parameter name="_allBreachLines" type="CM_MTPoolingEnquiryLineDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processBulkReleases" id="34d3929d-9469-45d5-94f5-52b4486795e3">
        <source>processBulkReleases(_subTerminal : CM_SubTerminal);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 June 2011	cnwndl1	Initial creation
05 Sep 2019	jlgdi1	46124	Added condition check for sub terminal parameter
*/

vars
	bulkRel : CM_BulkRelease;
	iterBR : Iterator;
	includedBRs : CM_BulkReleaseByTypeStCodeDict; 
	statusesOfInterest : IntegerArray;
	typesOfInterest : IntegerArray;
	status,brType : Integer;
	thresh : CM_MTThreshold;
	mtPoolEnqLine : CM_MTPoolingEnquiryLine;
	avaGrades : IntegerArray;
	firstAvaGrade : Integer;
	invalidObject : Boolean;
	
begin
	create includedBRs transient;
	create statusesOfInterest transient;
	create typesOfInterest transient; 
	
	typesOfInterest.add(BR_TYPE_ROAD);
	typesOfInterest.add(BR_TYPE_RAIL);
	typesOfInterest.add(BR_TYPE_SHIP);
	typesOfInterest.add(BR_TYPE_PACKING);
	
	statusesOfInterest.add(BR_PENDING);
	statusesOfInterest.add(BR_ACTIVE);
	
	iterBR := myFiltTerminal.allBulkReleaseByTypeByStByCd.createIterator();
	
	on Exception do app.handleDeletedObject( exception, bulkRel, invalidObject );
	
	foreach brType in typesOfInterest do	
		foreach status in statusesOfInterest do
			myFiltTerminal.allBulkReleaseByTypeByStByCd.startKeyGeq(brType,status, null,null, iterBR);
			while iterBR.next(bulkRel) do
				invalidObject := false;
				if bulkRel.type &lt;&gt; brType then
					break;
				endif;
				if invalidObject then
					continue;
				endif;
				if bulkRel.status &lt;&gt; status then
					break;
				endif;
				if bulkRel.fullRelease then	// only want releases for empties.
					continue;
				endif;
				if bulkRel.dateEstimatedRequired.Date.isValid and self.myFiltReleaseDate.isValid then
					if bulkRel.dateEstimatedRequired.Date &gt; self.myFiltReleaseDate then
						continue;
					endif;
				endif;
				
				// 46124
				if _subTerminal &lt;&gt; null then
					if _subTerminal &lt;&gt; bulkRel.mySubTerminal then
						continue;
					endif;
				endif;
				
				if invalidObject then
					continue;
				endif;
				includedBRs.addNoDuplicates(bulkRel,false);
			endwhile;
		endforeach;
	endforeach;	
	
	foreach bulkRel in includedBRs discreteLock do
		foreach mtPoolEnqLine in self.allMTPoolingEnquiryLines do
			thresh := mtPoolEnqLine.myMTThreshold;
			if thresh.myOperator &lt;&gt; null then
				if thresh.myOperator.code &lt;&gt; bulkRel.getOperatorCode then
					continue;
				endif;
			endif;
			if thresh.myISOTypeGroup &lt;&gt; null then
				if thresh.myISOTypeGroup &lt;&gt; bulkRel.getISOGroup then
					continue;
				endif;
			endif;
			if thresh.myMTGrade &lt;&gt; null then
				avaGrades := null;
				firstAvaGrade := 0;
				avaGrades := bulkRel.getAllAvailabilityGrades();
				if avaGrades &lt;&gt; null and (not avaGrades.isEmpty) then
					firstAvaGrade := avaGrades.first;
				endif;
				if thresh.myMTGrade.code &lt;&gt; firstAvaGrade then
					continue;
				endif;
			endif;
			invalidObject := false;
			if bulkRel.getTotalStorageEmpties = 0 then
				//this one is eother zero or has been totally supplied, no point in including.
				continue;
			endif;
			if invalidObject then
				continue;
			endif;
			mtPoolEnqLine.addBookingReq(bulkRel);
			break;
		endforeach;
	endforeach;
	
epilog
	
	delete iterBR;
	delete includedBRs;
	delete statusesOfInterest;
	delete typesOfInterest;
	
end;</source>
        <Parameter name="_subTerminal" type="CM_SubTerminal"/>
    </JadeMethod>
    <JadeMethod name="processEmpties" id="39d5505d-844c-44ac-afff-686976bd2cf6">
        <source>processEmpties(_subTerminal : CM_SubTerminal);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2011	cnwndl1	Initial creation
05 Sep 2019	jlgdi1	46124	Added condition check for sub terminal parameter
*/

vars
	iter : Iterator;
	startObject : CM_TrackedItem;
	ti : CM_TrackedItem;
	cont : CM_Container;
	mtPoolEnqLine : CM_MTPoolingEnquiryLine;
	thresh : CM_MTThreshold;
	
begin
	//start with the onsite storage empties.
	startObject := self.myFiltTerminal.allOnsiteTIsByCargoTypeId.getAtKeyGeq(TI_CargoType_Container,null);
	if startObject &lt;&gt; null then
		iter := self.myFiltTerminal.allOnsiteTIsByCargoTypeId.createIterator;
		iter.startAtObject(startObject );
		
		while iter.next( ti ) do
			if ti.cargoType &lt;&gt; TI_CargoType_Container then
				break;
			endif;
			if ti.getImExStatus &lt;&gt; TI_IMEX_STATUS_STORAGE then
				continue;
			endif;
			
			cont := ti.CM_Container;
			if not cont.isEmpty then
				continue;
			endif;
			
			// 46124
			if _subTerminal &lt;&gt; null then
				if _subTerminal &lt;&gt; ti.mySubTerminal then
					continue;
				endif;
			endif;
			
			foreach mtPoolEnqLine in self.allMTPoolingEnquiryLines do
				thresh := mtPoolEnqLine.myMTThreshold;
				if thresh.myOperator &lt;&gt; null then
					if thresh.myOperator &lt;&gt; cont.myOperator then
						continue;
					endif;
				endif;
				if thresh.myISOTypeGroup &lt;&gt; null then
					if thresh.myISOTypeGroup &lt;&gt; cont.getISOTypeGroupObject then
						continue;
					endif;
				endif;
				if thresh.myMTGrade &lt;&gt; null then
					if thresh.myMTGrade.code &lt;&gt; cont.availabilityGrade then
						continue;
					endif;
				endif;
				
				mtPoolEnqLine.addOnsiteMT(cont);
				break;
			endforeach;
		endwhile;
		
		delete iter;
	endif;

epilog
	delete iter;
end;</source>
        <Parameter name="_subTerminal" type="CM_SubTerminal"/>
    </JadeMethod>
    <JadeMethod name="processPreNotes" id="58c6dba9-6301-4466-a188-c52348f8c093">
        <source>processPreNotes(_subTerminal : CM_SubTerminal);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 June 2011	cnwndl1	Initial creation	Par 27331
05 Sep 2019	jlgdi1	46124	Added condition check for sub terminal parameter
*/

vars
	iter : Iterator;
	startObject : CM_TrackedItem;
	ti : CM_TrackedItem;
	cont : CM_Container;
	expectedDate : Date;
	mtPoolEnqLine : CM_MTPoolingEnquiryLine;
	thresh : CM_MTThreshold;
	voyages : CM_VoyageSet;
	iter2 : Iterator;
	voyage : CM_Voyage;
	imex : Integer;
	invalidObject : Boolean;

begin
	on Exception do app.handleDeletedObject( exception, ti, invalidObject );

	//start with the prenotified empties.  (Road and Rail)
	startObject := self.myFiltTerminal.allNotifiedTIsByCargoTypeId.getAtKeyGeq(TI_CargoType_Container,null);
	if startObject &lt;&gt; null then
		iter := self.myFiltTerminal.allNotifiedTIsByCargoTypeId.createIterator;
		iter.startAtObject(startObject );
		while iter.next( ti ) do
			invalidObject := false;
			if ti.cargoType &lt;&gt; TI_CargoType_Container then
				break;
			endif;
			
			if invalidObject then
				continue;
			endif;
			
			if ti.getImExStatus &lt;&gt; TI_IMEX_STATUS_STORAGE then
				continue;
			endif;			
			
			// 46124
			if _subTerminal &lt;&gt; null then
				if _subTerminal &lt;&gt; ti.mySubTerminal then
					continue;
				endif;
			endif;
			
			cont := ti.CM_Container;
			if not cont.isEmpty then
				continue;
			endif;
						
			//expectedDate := cont.expectedArrivalDate;
			expectedDate := cont.getExpectedArrivalDate;	//29 Jul 2013	NDL	Par 31763
			if expectedDate.isValid and myFiltReceivalDate.isValid then
				if expectedDate &gt; myFiltReceivalDate then
					continue;
				endif;
			endif;
			
			foreach mtPoolEnqLine in self.allMTPoolingEnquiryLines do
				thresh := mtPoolEnqLine.myMTThreshold;
				if thresh.myOperator &lt;&gt; null then
					if thresh.myOperator &lt;&gt; cont.myOperator then
						continue;
					endif;
				endif;
				if thresh.myISOTypeGroup &lt;&gt; null then
					if thresh.myISOTypeGroup &lt;&gt; cont.getISOTypeGroupObject then
						continue;
					endif;
				endif;
				if thresh.myMTGrade &lt;&gt; null then
					if thresh.myMTGrade.code &lt;&gt; cont.availabilityGrade then
						continue;
					endif;
				endif;
				
				if invalidObject then
					continue;
				endif;
				mtPoolEnqLine.addPreNote(cont);
				break;
			endforeach;
		endwhile;
		
		delete iter;
	endif;
	
	//get a collection of current and future voyages.
	create voyages transient;
	self.myFiltTerminal.getAllCurrentVoyages(voyages, true, false, false);
	
	iter := voyages.createIterator;
	while iter.next( voyage ) do
	
		expectedDate := voyage.getArrivalDT.Date;
		if expectedDate.isValid and myFiltReceivalDate.isValid then
			if expectedDate &gt; myFiltReceivalDate then
				continue;
			endif;
		endif;
		
		startObject := voyage.allOnshipTIsByCargoTypeId.getAtKeyGeq(TI_CargoType_Container,null);
		if startObject &lt;&gt; null then
			iter2 := voyage.allOnshipTIsByCargoTypeId.createIterator;
			iter2.startAtObject(startObject );
			while iter2.next( ti ) do
				invalidObject := false;
				if ti.cargoType &lt;&gt; TI_CargoType_Container then
					break;
				endif;
				
				if invalidObject then
					continue;
				endif;
				
				imex := ti.getImExStatus;
				if imex = TI_IMEX_STATUS_EXPORT then
					continue;
				endif;
				if imex = TI_IMEX_STATUS_TRANSHIP then
					continue;
				endif;
				
				// 46124
				if _subTerminal &lt;&gt; null then
					if _subTerminal &lt;&gt; ti.mySubTerminal then
						continue;
					endif;
				endif;
				
				cont := ti.CM_Container;
				if not cont.isEmpty then
					continue;
				endif;
	
				foreach mtPoolEnqLine in self.allMTPoolingEnquiryLines do
					thresh := mtPoolEnqLine.myMTThreshold;
					if thresh.myOperator &lt;&gt; null then
						if thresh.myOperator &lt;&gt; cont.myOperator then
							continue;
						endif;
					endif;
					if thresh.myISOTypeGroup &lt;&gt; null then
						if thresh.myISOTypeGroup &lt;&gt; cont.getISOTypeGroupObject then
							continue;
						endif;
					endif;
					if thresh.myMTGrade &lt;&gt; null then
						if thresh.myMTGrade.code &lt;&gt; cont.availabilityGrade then
							continue;
						endif;
					endif;
					
					if invalidObject then
						break;
					endif;
					mtPoolEnqLine.addPreNote(cont);
					break;
				endforeach;
			
			endwhile;
			delete iter2;
		endif;
	endwhile;
	
epilog
	delete iter;
	delete voyages;
	delete iter2;
end;</source>
        <Parameter name="_subTerminal" type="CM_SubTerminal"/>
    </JadeMethod>
    <JadeMethod name="setBaseData" id="4b3ae1fe-4eab-4e1b-a336-98b01a6941a8">
        <updating/>
        <source>setBaseData(	_terminal : CM_Terminal;	
				_operator : CM_Operator;
				_isoGroup : CM_ISOTypeGroup;
				_grade : CM_MTGrade;
				_receivalDate : Date;
				_releaseDate : Date
				) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2011	cnwndl1	Initial creation
*/

vars

	iter : Iterator;
	thresh : CM_MTThreshold;
	
begin

	self.myFiltTerminal := _terminal;
	self.myFiltOperator := _operator;
	self.myFiltIsoGroup := _isoGroup;
	self.myFiltGrade := _grade;
	self.myFiltReceivalDate := _receivalDate;
	self.myFiltReleaseDate := _releaseDate;
	
	iter := self.myFiltTerminal.allMTThresholds.createIterator;
	while iter.next( thresh ) do
		if not thresh.isActive then
			continue;
		endif;
		if self.myFiltOperator &lt;&gt; null then
			if thresh.myOperator &lt;&gt; self.myFiltOperator then
				continue;
			endif;
		endif;
		if self.myFiltIsoGroup &lt;&gt; null then
			if thresh.myISOTypeGroup &lt;&gt; self.myFiltIsoGroup then
				continue;
			endif;
		endif;
		if self.myFiltGrade &lt;&gt; null then
			if thresh.myMTGrade &lt;&gt; self.myFiltGrade then
				continue;
			endif;
		endif;
		
		self.allSelectedMTThresholds.add(thresh);
	endwhile;
	
	self.createMTPoolingEnqLines();

epilog

	delete iter;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_isoGroup" type="CM_ISOTypeGroup"/>
        <Parameter name="_grade" type="CM_MTGrade"/>
        <Parameter name="_receivalDate" type="Date"/>
        <Parameter name="_releaseDate" type="Date"/>
    </JadeMethod>
</Class>
