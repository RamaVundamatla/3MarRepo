    <JadeMethod name="e999_tidyUp" id="59a016e9-30b1-4e32-8753-439002f3996a">
        <updating/>
        <source>e999_tidyUp():Integer updating;

vars
	cmbVoyage:ComboBox;
	cmbVessel:ComboBox;
	txtVoyageCode:TextBox;
	txtInwardCode:TextBox;
begin
	cmbVoyage:=mySHP_VoyageDefinitionForm.getPropertyValue('cmbVoyage').ComboBox;
	cmbVoyage.gotFocus(cmbVoyage);
	cmbVoyage:=mySHP_VoyageDefinitionForm.getPropertyValue('cmbVoyage').ComboBox;
	cmbVoyage.lostFocus(cmbVoyage);
	cmbVessel:=mySHP_VoyageDefinitionForm.getPropertyValue('cmbVessel').ComboBox;
	cmbVessel.gotFocus(cmbVessel);
	cmbVessel:=mySHP_VoyageDefinitionForm.getPropertyValue('cmbVessel').ComboBox;
	cmbVessel.lostFocus(cmbVessel);
	txtVoyageCode:=mySHP_VoyageDefinitionForm.getPropertyValue('txtVoyageCode').TextBox;
	txtVoyageCode.text:='AOR0000';
	txtVoyageCode.lostFocus(txtVoyageCode);
	app.doWindowEvents(shortPause);
	txtVoyageCode.change(txtVoyageCode);
	txtInwardCode:=mySHP_VoyageDefinitionForm.getPropertyValue('txtInwardCode').TextBox;
	txtInwardCode.text:='';
	txtInwardCode.lostFocus(txtInwardCode);
	app.doWindowEvents(shortPause);
	txtInwardCode.change(txtInwardCode);
	cmbVoyage:=mySHP_VoyageDefinitionForm.getPropertyValue('cmbVoyage').ComboBox;
	cmbVoyage.gotFocus(cmbVoyage);
	if app.isValidObject(mySHP_VoyageDefinitionForm) then
		mySHP_VoyageDefinitionForm.unloadForm;  // 14:17:14
	endif;
	mySHP_VoyageDefinitionForm:=null;
	if app.isValidObject(myYRD_GridAreasForm) then
		myYRD_GridAreasForm.unloadForm;  // 14:17:17
	endif;
	myYRD_GridAreasForm:=null;
	return 0;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="runTest" id="b9e617eb-b08c-4ded-bb6d-ee55fa0ce0eb">
        <updating/>
        <source>runTest():Integer updating;

vars
	sa:StringArray;
	meth:String;
begin
	create sa transient;
	sa.add('e002_CUN_lstTest_click');
	sa.add('e002v_CUN_lstTest_click');
	sa.add('e004_CUN_lstTest_dblClick');
	sa.add('e004v_CUN_lstTest_dblClick');
	sa.add('e006_YGAF_mnuGridHideToolbar_c');
	sa.add('e008_YGAF_listbox_click');
	sa.add('e008v_YGAF_listbox_click');
	sa.add('e010_YGAF_listbox_dblClick');
	sa.add('e010v_YGAF_listbox_dblClick');
	sa.add('e012_YGAF_btnSelectAreclick');
	sa.add('e012v_YGAF_btnSelectAreclick');
	sa.add('e014_YGAF_overlay_DRAGclick');
	sa.add('e014v_YGAF_overlay_DRAGclick');
	sa.add('e016_YGAF_overlay_DRAGdblClick');
	sa.add('e016v_YGAF_overlay_DRAGdblClic');
	sa.add('e018_CCEF_tblEdit1_click');
	sa.add('e018v_CCEF_tblEdit1_click');
	sa.add('e020_CCEF_tblEdit1_dblClick');
	sa.add('e020v_CCEF_tblEdit1_dblClick');
	sa.add('e022_YGAF_table_click');
	sa.add('e022v_YGAF_table_click');
	sa.add('e024_YGAF_table_dblClick');
	sa.add('e024v_YGAF_table_dblClick');
	sa.add('e026_SVDF_optBerth_click');
	sa.add('e026v_SVDF_optBerth_click');
	sa.add('e999_tidyUp');

	foreach meth in sa do
		app.doWindowEvents(longPause);
		userPreTransaction(meth);
		retCode:=self.sendMsg(meth).Integer;
		userPostTransaction(meth);
		app.atcgDetectMissedMsgBoxes;
		if app.atcgReplayFailure then
			app.atcgReplayFailure:=false;
			break;
		elseif retCode = 0 then
			app.logMessage("Test "&amp;self.class.name&amp;"::"&amp;meth&amp;" succeeded");
		else
			app.logMessage("Test "&amp;self.class.name&amp;"::"&amp;meth&amp;" failed with error code "&amp;retCode.String);
			break;
		endif;
	endforeach;
	app.logMessage("Finished");
	return 0;
epilog
	delete sa;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="startup" id="36fa0362-0abb-40dc-b37b-0fe02d595d4e">
        <updating/>
        <source>startup() updating;

begin
	inheritMethod();
end;</source>
