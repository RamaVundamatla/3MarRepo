    <JadeMethod name="deactivate" id="0d1e030b-73fd-460a-88cd-a1f81f376f22">
        <controlMethod name="Form::deactivate"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>deactivate() updating;
// --------------------------------------------------------------------------------
// Created:		27 July 2010 by cnwjo3
//
// Purpose:		par 25114
//
vars
	idx : Integer;
	f : Form;
begin
	f := app.activeForm;
	if f = null then
		return;
	endif;	
	
	if f &lt;&gt; self.myParentForm and not ( f.isKindOf(CMUI_VoyageAllocationsListForm) or f.isKindOf(CMUI_VoyageAllocsLoadListForm)) then
		self.myParentForm.deactivate();
	endif;			//cnwas3 par 27769
	
	/*if f.isKindOf(CMUI_VoyageAllocationsListForm) or f.name = "SHP_VoyageAreaForm2" then
	else
		foreach idx in 1 to app.formsCount do
			f := app.forms(idx);
			if f.name = "SHP_VoyageAreaForm2" then
				f.deactivate();
			endif;
		endforeach;
	endif;*/
end;</source>
    </JadeMethod>
    <JadeMethod name="deleteVoyAllocation" id="33d9fc77-bc9a-4455-a81d-cde0f8b0ccfe">
        <updating/>
        <source>deleteVoyAllocation() : Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	cnwas3	Initial creation

*/

vars
	
	realAlloc 				: CM_VoyageAllocation;
	voyCode 				: String;
	result 					: Integer;
begin	
	if self.myVoyage = null then		
		return false;
	endif;
	
	if self.updateMode then
		// realAlloc := self.myVoyage.getAllocationWithSameCriteria(self.myYardAllocation.CM_VoyageAllocation);		
		realAlloc := self.myYardAllocation.CM_VoyageAllocation;
	endif;									
	
	if realAlloc = null then
		return false;
	endif;
	
	while true do
		app.myTrxDA.trxDeleteVoyageAllocation(realAlloc, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			self.updateMode := false;
			self.doCriteriaReset();
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Voyage_load_colour_coding), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		
		break;
	endwhile;	
	
	//self.unloadForm;
epilog	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doBtnCopyClick" id="34700055-0988-4fe1-a3be-b48d3617652b">
        <updating/>
        <source>doBtnCopyClick() updating;
// ---------------------------------------------------------------------------
// Created:     08 March 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 07/11/2011		cnwmh5			#28627 - Change so sets update mode back to what it was
//									before if was run.  Reason for this is they change and click
//									save then it saves it doesn't do what it does under normal
//									circumstances which is to update the one with the same name
// ---------------------------------------------------------------------------

vars
	tmpUpdateMode		: Boolean;
begin
	tmpUpdateMode := self.updateMode;
	self.updateMode := false;
	self.saveData(true);
epilog
	self.updateMode := tmpUpdateMode;
end;</source>
    </JadeMethod>
