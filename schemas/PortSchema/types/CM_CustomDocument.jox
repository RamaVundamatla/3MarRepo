    <JadeMethod name="validateForUpdate" id="332320b7-c281-470e-ac17-3ba201a34319">
        <source>validateForUpdate();
// ##### CR 56094  TASK 59616 NAVAB1 08AUG2023
//01/09/2023	navkc1	CR 59937 Task 59939: UI - Cust Doc Mandatory Fields
//03 Sep 2024 	navlc30 Bug 65321: FR - 53715 - Customs - Registration screen - EP feedback
vars
	prevDoc, uniqDoc, realme : CM_CustomDocument;
	cdd : CM_CustomDocumentDetail;
	docType,
	prevDocType : CM_CustomDocumentType;
	mandatoryAttr	: String;
	ti : CM_TrackedItem;
	partialClearanceForSingleTI : Boolean;
begin
	self.validateTIs();
	
	if app.myPassport.hasErrors() then
		return;
	endif;
	
	if self.code = null then
		app.raiseCMException(Custom_docume_must_have_code,null,null);
	endif;
	
	/* Not in BRD
	if self.description = null then
		app.raiseCMException(Custom_docume_must_have_descri,null,null);
	endif;
	*/
	docType := self.myCustomDocumentType; //01/09/2023	navkc1	CR 59937 Task 59939
	
	if docType = null then
		app.raiseCMException(Custom_docume_type_must_specif,null,null);
	endif;
	
	// ### TFS CR 59615 TASK 59620 15AUG2023 NAVAB1
	realme := self.pxyGetRealObject().CM_CustomDocument;
	
	foreach uniqDoc in self.myTerminal.allCustomDocuments discreteLock where uniqDoc.code = self.code  do
		if uniqDoc = realme then
			continue;
		endif;
		
		 if uniqDoc.code = self.code
		 and uniqDoc.myCustomDocumentType = self.myCustomDocumentType						//03.09.2024 navlc30 #65321
		 and uniqDoc.itemNumber = self.itemNumber then
			app.raiseCMWarning2(Custo_docum_with_docum_numbe_l,self.code, self.itemNumber.String,null,null,null);
		 endif;
		 // ### TFS BUG 62187 14FEB2024 NAVAB1
		 if uniqDoc.code = self.code
		 //and uniqDoc.myCustomDocumentType = self.myCustomDocumentType then				//03.09.2024 navlc30 #65321
		 and uniqDoc.myCustomDocumentType &lt;&gt; self.myCustomDocumentType then					//03.09.2024 navlc30 #65321	 
			app.raiseCMException4(Custo_docum_alrea_exist_docum_,uniqDoc.myCustomDocumentType.code, self.code, self.code.String,uniqDoc.dateTime.asStringJMT(),null, null);
		 endif;
	endforeach;

	/* //01/09/2023	navkc1	CR 59937 Task 59939 - Moved to configurable list below
	// ### TFS CR 59615 TASK 59620 15AUG2023 NAVAB1
	if not self.dateTime.isValid() then
		app.raiseCMException(Custo_docum_must_have_valid_da,null,null);
	endif;
	*/
	// check for accidental silly dates
	if self.dateTime &lt; self.systemToLocalTime(app.actualTimeServer).subtractYears(100) then
		app.raiseCMWarning(Custo_docum_date_canno_more_pt, null, null, null);
	endif;
	if self.dateTime &gt; self.systemToLocalTime(app.actualTimeServer).addYears(100) then
		app.raiseCMWarning(Custo_docum_date_canno_more_th ,null, null, null);
	endif;
	
	prevDoc := self.getPreviousCustomDocument();
	if prevDoc &lt;&gt; null then
		if self.dateTime &lt; prevDoc.dateTime then
			app.raiseCMException2(Previ_docum_date_this_docum_ca, prevDoc.code, self.systemToLocalTime( prevDoc.dateTime).asStringJMT,  null,null);
		endif;
		
		prevDocType := prevDoc.myCustomDocumentType;
			
		// check that I have a doc type that is correct for the process
		if prevDocType &lt;&gt; null
		and not prevDocType.allNextDocumentTypes.includes(self.myCustomDocumentType) then
			// ### TFS CR 60922 TASK 60980 07NOV2023 NAVAB1
			ti := self.allTrackedItems.first;
			if ti &lt;&gt; null then
				partialClearanceForSingleTI := ti.getCustDocIsPartiallyCleared();
			endif;
		
			/* // ### TFS CR 60922 TASK 60980 07NOV2023 NAVAB1
		
			// ### TFS CR 60424 TASK 60549 02OCT2023 NAVAB1
			if self.allTrackedItems.size = 1 then
				cdd := ti.allCustomDocDetails.last; // current detail
				if cdd &lt;&gt; null and cdd.clearedQuantity &lt; ti.totalQuantity then
					partialClearanceForSingleTI := true;
				endif;
			endif;
			*/
			
			if not partialClearanceForSingleTI then
				app.raiseCMException4(Custo_docum_docum_type_this_no,self.code, self.myCustomDocumentType.code,prevDoc.code, prevDocType.code,null,null);
			endif;
		endif;
		/*
	else
		if self.allTrackedItems.isNotEmpty() then
			if self.myCustomDocumentType.allPrevDocumentTypes.isNotEmpty() then
				app.raiseCMException2(Custo_docum_docum_type_this_do,self.code, self.myCustomDocumentType.code,null,null);
			
			endif;
		endif;
		*/
	endif;
	
	//01/09/2023	navkc1	CR 59937 Task 59939
	if docType &lt;&gt; null then
		foreach mandatoryAttr in docType.allMandatoryFields do
			if mandatoryAttr = ETRow_CustAgent and self.myCustomsAgent = null then
				app.raiseCMException(Custom_agent_mandato_field, null, null);
			elseif mandatoryAttr = ETRow_HsCodes and self.myHSCode = null then
				app.raiseCMException(Code_mandatory_field, null, null);
			elseif mandatoryAttr = ETRow_CustLicense and self.myCustomLicense = null then
				app.raiseCMException(Custom_license_mandato_field, null, null);
			elseif mandatoryAttr = ETRow_Direction and self.direction = -1 then
				app.raiseCMException(Direction_mandatory_field, null, null);
			elseif mandatoryAttr = ETRow_Remarks and self.remarks = null then
				app.raiseCMException(Remarks_mandatory_field, null, null);
			elseif mandatoryAttr = ETRow_ItemNumber and self.itemNumber = null then
				app.raiseCMException(Item_number_mandato_field, null, null);
			elseif mandatoryAttr = ETRow_Description and self.description = null then
				app.raiseCMException(Descriptio_mandatory_field, null, null);
			elseif mandatoryAttr = ETRow_DateTime and not self.dateTime.isValid() then
				app.raiseCMException(Custo_docum_must_have_valid_da,null,null);
			elseif mandatoryAttr = ETRow_ExternalRef1 and self.externalRef1 = null then
				app.raiseCMException(Externa_referen_mandato_field, null, null);
			endif;
		endforeach;
	endif;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateTIs" id="95c12b9f-bf06-4b1a-9261-84685a0a5df9">
        <source>validateTIs();
/*
Purpose:			

Date		Who		Reason
16 August 2023	navab1	CR 59615 TASK 59620
*/

vars
	ti : CM_TrackedItem;
	prevDocType : CM_CustomDocumentType;
	prevDoc, custdoc, realme : CM_CustomDocument;
	cdd, cddother : CM_CustomDocumentDetail;
begin
	if not self.pxyIsProxy then
		return;
	endif;

	// Check that all the TIs have the same previous document type
	// NOTE - self (proxy) has the TIs added to self.allTrackedItems, however the inverse does not show on the persistant TI, so using 'last' gets the last persistant cust doc.
	// ### TFS CR 59942 TASK 59943 28AUG2023 NAVAB1
	foreach ti in self.allTrackedItems discreteLock do
		if ti.isZombie() then
			continue;
		endif;
		prevDoc := ti.getPreviousCustomDocument(null); // current document on the TI
		if prevDoc &lt;&gt; null then
			prevDocType := prevDoc.myCustomDocumentType;
		
			// check that I have a doc type that is correct for the process
			if prevDocType &lt;&gt; null
			and not prevDocType.allNextDocumentTypes.includes(self.myCustomDocumentType) then
				app.raiseCMException(Items_this_custo_docum_must_ha,null,null);
			
			endif;
		endif;
		
	endforeach;
	
	// ### TFS BUG 62187 14FEB2024 NAVAB1
	realme := self.pxyGetRealObject().CM_CustomDocument;
	foreach cdd in realme.allCustomDocumentDetails discreteLock do
		ti := cdd.myTrackedItem;
		foreach cddother in ti.allCustomDocDetails discreteLock do
			custdoc:= cddother.getCustomDocumentHeader();
			if custdoc.dateTime &gt; self.dateTime then
			
				app.raiseCMException5(Custo_docum_that_date_which_be,ti.id,custdoc.code, custdoc.dateTime.asStringJMT(), self.code, self.dateTime.asStringJMT(),   null,null);
			endif;
		
		endforeach;
	
	endforeach;
epilog

end;</source>
    </JadeMethod>
</Class>
