    <JadeMethod name="setHighlightLCs" id="6bdda59f-be3c-4795-ac66-bdbe0d686f4d">
        <source>setHighlightLCs( _tiSet : ObjectSet);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 May 2010	cnwjk3	Initial creation

*/

vars
	obj 	: Object;
	ti 		: CM_TrackedItem;
	lc		: CM_GridController;
	key		: String;
	height	: Integer;
begin
	if _tiSet = null then 
		return;
	endif;

	self.allHighlightLCsByID.clear();
	
	foreach obj in _tiSet do
		if not obj.isKindOf(CM_TrackedItem) then
			continue;
		endif;
		
		ti := obj.CM_TrackedItem;
	
		if not ti.myPrimaryActualLocation.isKindOf(CM_GridController) then
			continue;
		endif;

		lc := ti.myPrimaryActualLocation.CM_GridController;
		
		if self.drawMode = CMIF_RDTDrawElement.MODE_FACE then
			// A gridded side view, so we need to include the height of the TI in the key
			height := lc.getActualStackPositionOfTI(ti); 
		endif;
		
		
		//key := lc.getFullId().toUpper();
		//if height &gt; 0 then
		//	key := key &amp; '_' &amp; height.String;
		//endif;
		
		key := self.genHighlightedLCKey(lc, height);
		
		if not self.allHighlightLCsByID.includesKey(key) then
			self.allHighlightLCsByID[key] := lc;
		endif;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_tiSet" type="ObjectSet"/>
    </JadeMethod>
