    <JadeMethod name="setComboValues" id="667f3648-929c-4ab8-8d81-47c56dd5e553">
        <source>setComboValues(_combo : ComboBox input; _params : CM_QueryCriteriaLineHolder; _queryOperator : CM_QueryOperator; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     06 March 2003		cnwth2	
//
// Purpose:     		 
//
// Changed On	Changed By	Reason
// ----------   ----------  --------------------------------------------------
// 08/06/2022	navdap1		TFS 53362 EUP Master Data interface customers between TOS and ERP
vars
	op			: CM_Operator;
	opDict		: CM_OperatorByCodeDict;
	byName		: Boolean;			// TFS 53362
	
begin
	_combo.clear();
	opDict := app.myRoot.allOperators;
	byName := app.myRoot.getConfig(ComboByNameOperator).Boolean;						// TFS 53362
	
	foreach op in opDict do
		if byName then																	// TFS 53362
			_combo.itemObject[_combo.addItem(op.description &amp; Tab &amp; op.code)] := op;	// TFS 53362
		else																			// TFS 53362
			_combo.itemObject[_combo.addItem(op.code &amp; Tab &amp; op.description)] := op;
		endif;																			// TFS 53362
	endforeach;

	if CM_QStringLookup.hasInstance(_queryOperator) then
		_combo.listObject := opDict[_queryOperator.CM_QStringLookup.selectionValue];
	elseif CM_QStringLookupNotEqual.hasInstance(_queryOperator) then
		_combo.listObject := opDict[_queryOperator.CM_QStringLookupNotEqual.selectionValue];
	endif;

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="b9558162-74f9-4565-8385-3ad3f25808da">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 13 February 2007
//
//----------------------------------------------------------------------

vars
	operator 		: CM_Operator;
	operatorDict 	: CM_OperatorByCodeDict;
	selectionValue,
	idx				: Integer;
	array			: ObjectArray;
begin
	
	operatorDict := app.myRoot.allOperators;
	
	_tbl.rows := _tbl.fixedRows;
	
	//doesn't know about CMUI_ListTable - so have to do this:
	array := _tbl.getPropertyValue('allSelectedObjects').ObjectArray;
	array.clear;
	
	foreach operator in operatorDict do
		selectionValue := 0;
		if _operator &lt;&gt; null and  _operator.CM_QStringIsOneOf.allSelectionValues.includes(operator.code) then
			selectionValue := 1;
			array.add(operator);
		endif;
		idx := _tbl.addItem(selectionValue.String &amp; Tab  &amp; operator.code &amp; ' (' &amp; operator.description&amp; ')');
		_tbl.accessRow(idx).itemObject := operator;
	endforeach;
	
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="875d2113-0f5d-49bc-9063-497f07e5f701">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 13 February 2007
//
//----------------------------------------------------------------------

vars
	operator : CM_Operator;
	//grade		: CM_MTGrade;
	str			: String;
	numRows,
	idx			: Integer;
	sa			: StringArray;

begin

	create sa transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			operator := _tbl.accessRow(idx).itemObject.CM_Operator;
			//grade := _tbl.accessRow(idx).itemObject.CM_MTGrade;
			sa.add(operator.code);
		endif;
	endforeach;
	
	_op.setSearchValue(sa);

epilog
	delete sa;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="db4f46af-21f6-4c33-be90-3ed6d235de01">
        <source>translateToDisplayValue(_value: Any): String;
// ---------------------------------------------------------------------------
// Created:     06 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _value.isKindOf(CM_Operator) then
		if _value &lt;&gt; null then
			return _value.CM_Operator.code;
		else 
			return null;
		endif;
	else
		return _value.String;
	endif;


end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="bea06001-4382-4916-b51f-bedb925fc34b">
        <source>translateToSearchValue(_value: Any): Any;
// ---------------------------------------------------------------------------
// Created:     17 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
06 Oct 2008	cnwkpd1	PAR #18099 - Correct Selector query processing
22 Oct 2008	cnwkpd1	PAR #18348 - Prevent 1002 exceptions in Selector query processing with isOneOf

*/

vars
	invalidObj 		: Boolean;
	object			: CM_Operator;
	returnVal		: String;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			// PAR #18348
			return _value;
		endif;
		
		if _value.isKindOf(CM_Operator) then
			object := _value.CM_Operator;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.code;
	endif;
	
	return returnVal;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="02f859b4-7240-4da4-a07d-15491a3a7ab8">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	str, returnVal : String;
	strArray : StringArray;
	operator : CM_Operator;

begin
	if _value.isKindOf(StringArray) then
		foreach str in _value.StringArray do
			returnVal := returnVal &amp; str &amp; CNEC_COMMA &amp; Space;
		endforeach;
		returnVal := returnVal[1:returnVal.length-2];
		return returnVal;
		
	elseif _value.isKindOf(String) then
		if _value.String.cnContains("|") then
			str := _value.String;
			create strArray transient;
			str.getTokensForDelimiter("|", strArray);
			return strArray;
		endif;
		
		operator := app.myRoot.allOperators[_value.String];
		if operator &lt;&gt; null then
			return operator.code;
		endif;
		
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
