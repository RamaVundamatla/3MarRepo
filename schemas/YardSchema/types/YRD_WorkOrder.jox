    <JadeMethod name="doSaveToDoSpecialRate" id="24f8e86c-4f4c-4c52-aec9-431ad44dbbfb">
        <source>doSaveToDoSpecialRate(_wodtl : CM_WorkOrderToDoDtl input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Mar 2023 navma1 ChangeRequest 56840:[54265] EUP - [Framework] - VAS Work Order Maintenance Screen
02 Mar 2023	navtnr20  Task 56815: EUP - Work Order Contract Id
06 Apr 2023 navhl20 ChangeRequest 57477:[57478] EUP - Moving No charge Option to be under Financial Tab
*/

vars

// ### TFS CR 56814 TASK 56813 06JUL2023 NAVAB1	overrideCalcType		: Integer;
// ### TFS CR 56814 TASK 56813 06JUL2023 NAVAB1	overrideRate 			: Decimal [23,6];
// ### TFS CR 56814 TASK 56813 06JUL2023 NAVAB1	overridingDebtorType	: CM_DebtorType;
// ### TFS CR 56814 TASK 56813 06JUL2023 NAVAB1	calcType				: CM_CalculationType;
	contractid				: String;
	noCharge				: Boolean;
	debtor : CM_Debtor;
begin
	noCharge 				:= self.chkNoCharge.value;														//06.4.2023 navhl20	#57477[57478]
// ### TFS CR 56814 TASK 56813 06JUL2023 NAVAB1	overrideRate		    := self.txtSpecialRate.text.Decimal;
// ### TFS CR 56814 TASK 56813 06JUL2023 NAVAB1	overridingDebtorType	:= self.getSelectedChargeTo();
	contractid				:= self.txtInvContractId.text;			 //navtnr20 02-03-2023 56815
	
// ### TFS CR 56814 TASK 56813 06JUL2023 NAVAB1	calcType				:= self.getSelectedCalcType();
// ### TFS CR 56814 TASK 56813 06JUL2023 NAVAB1	if calcType &lt;&gt; null then
// ### TFS CR 56814 TASK 56813 06JUL2023 NAVAB1		overrideCalcType := calcType.calculationType;
// ### TFS CR 56814 TASK 56813 06JUL2023 NAVAB1	endif;
	
// ### TFS CR 56814 TASK 56813 06JUL2023 NAVAB1	_wodtl.setProxySpecialRate(overrideCalcType,overrideRate,overridingDebtorType,contractid,noCharge);		//06.4.2023 navhl20	#57477[57478]

	 // ### TFS CR 56814 TASK 56813 07JUL2023 NAVAB1
	if _wodtl.isKindOf(CM_WodToDoNonOperational) then
		debtor := null;
	else
		debtor := self.cmbDebtors.listObject.CM_Debtor;
	endif;
	_wodtl.setProxySpecialRate(debtor,contractid,noCharge);
epilog

end;</source>
        <Parameter name="_wodtl" type="CM_WorkOrderToDoDtl" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doSaveToDoTaskDetails" id="c891eaad-a221-4abb-bf5e-0af4190d9a2d">
        <source>doSaveToDoTaskDetails(_wodtl : CM_WorkOrderToDoDtl input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Mar 2023 navhl20	ChangeRequest 56840:[54265] EUP - [Framework] - VAS Work Order Maintenance Screen
17 Mar 2023	navcs2	ChangeRequest 56842:[56843]: EUP - VAS Task Priority
20 Mar 2023 navma1  Defect 57195: MTN - WO - Priority is showing some random number on the to do work orders on the yard operations form
06 Apr 2023 navhl20 ChangeRequest 57477:[57478] EUP - Moving No charge Option to be under Financial Tab
*/

vars
	remarks			: String;
	priority		: Integer;
	allToDoTasks 	: CM_ToDoTaskDescSet;
begin
	remarks 		:= self.txtToDoRemarks.text;
	
	if self.chkPriority.value then							//17.03.2023	navcs2	#56842:[56843] 20.03.2023 navma1 #57195
		priority := CM_WorkOrder.WO_Priority_High;			//17.03.2023	navcs2	#56842:[56843]
	endif;													//17.03.2023	navcs2	#56842:[56843]
	
	// Get the Todo tasks 
	create allToDoTasks transient;
	self.mulToDoTasks.getSelected( allToDoTasks );
	
	_wodtl.setProxyToDoTaskDetails(remarks,priority,allToDoTasks);			//06.4.2023 navhl20	#57477[57478]
epilog

end;</source>
        <Parameter name="_wodtl" type="CM_WorkOrderToDoDtl" usage="input"/>
    </JadeMethod>
