    <JadeMethod name="isHOLDSorSHIP" id="78110894-9726-451d-a003-27aa87e90065">
        <source>isHOLDSorSHIP() : Boolean;
/*
Purpose:			
Date		Who		Reason
05 Mar 2014	cnwab1	Initial creation
30 Jun 2025 navma1  MTN-34090  MTN | Dead lock (1081) on CM_TIByIdCargoTypeRelseDictRev
*/

vars
	notLOLORORO   : Boolean;
	isLOLOnotRORO : Boolean;
	notLOLOisRORO : Boolean;
	isHOLDS 	  : Boolean;
	isSHIP 		  : Boolean;
	cellStructure : CM_CellularVoyageStructure;
	roroStructure : CM_ROROVoyageStructure;
begin
	
	cellStructure	:= self.myCellularVoyageStructure;							//30.06.2025 navma1 #MTN-34090
	roroStructure   := self.myROROStructure;									//30.06.2025 navma1 #MTN-34090
	
	notLOLORORO   := (cellStructure = null  and roroStructure = null);			//30.06.2025 navma1 #MTN-34090
	isLOLOnotRORO := (cellStructure &lt;&gt; null and roroStructure = null);			//30.06.2025 navma1 #MTN-34090
	notLOLOisRORO := (cellStructure = null  and roroStructure &lt;&gt; null);			//30.06.2025 navma1 #MTN-34090
	
	
	// ## bit of a bodge, the following had to be added because of CAMS unit tests
	if not notLOLORORO then
		if isLOLOnotRORO then
			if cellStructure.allBayVoyagesById.isEmpty() then
				notLOLORORO := true;
			endif;
		elseif notLOLOisRORO then
			if roroStructure.allDecks.isEmpty() then
				notLOLORORO := true;
			endif;
		endif;
	endif;
	
	isHOLDS := self.myGeneralCargoVoyage &lt;&gt; null;
	isSHIP  := self.myShipBlockStack &lt;&gt; null;
	
	if (notLOLORORO and isHOLDS) or (notLOLORORO and isSHIP) then
		return true;
	endif;
	
	return false;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isLOLOorRORO" id="5d4436c9-1ec2-435e-aaba-2d4e77352205">
