end;</source>
        <Parameter name="dataObj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getObjects" id="6992bd99-ea39-4c0b-a8a5-2c35827353ea">
        <source>getObjects(objects: ObjectLongNameDict input);
//03 August 2008	cnwdw1	
// Return a dict of objects for this criteria type
vars
	type: CM_TILCType;
begin
	foreach type in app.myRoot.allTILCTypes do
		objects[type.getYAIdentifier] := type;
	endforeach;
end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
