    <JadeMethod name="getCargoTypeByAbbreviation" id="c2089159-15d6-4664-acec-97c41cdc3805">
        <source>getCargoTypeByAbbreviation( _abbrev : String ):CM_CargoType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 July 2015	cnwndl1	Initial creation

*/

vars

	iter : Iterator;
	ct : CM_CargoType;

begin

	iter := self.createIterator;
	while iter.next( ct ) do
		if ct.abbreviation = _abbrev then
			return ct;
		endif;
	endwhile;
	
	return null;

epilog

	delete iter;

end;</source>
        <Parameter name="_abbrev" type="String"/>
        <ReturnType type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="getDisplayCodes" id="f200b30f-50eb-4c3f-a6ac-0056887c5cc8">
        <source>getDisplayCodes(_short : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:		13 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	aCT : CM_CargoType;
	line : String;
	invalid : Boolean;
	
begin
	on Exception do app.handleDeletedObject(exception, aCT, invalid);
	
	foreach aCT in self discreteLock do
//		if not global.isValidObject(aCT) then
//			continue;
//		endif;
		if _short then
			if line = null then
				line := aCT.description;
			else
				line := line &amp; ", " &amp; aCT.description;
			endif;
			
		else
			if line = null then
				line := aCT.abbreviation;
			else
				line := line &amp; ", " &amp; aCT.abbreviation;
			endif;
		endif;
	endforeach;
	
	return line;
end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
