begin
	startTime	:=	app.clock();
	
	create theParameter transient;
	theParameter.baseDirectory			:=	"c:\temp";
	theParameter.isIncludeClassText		:=	true;
	theParameter.isIncludeSource		:=	true;
	theParameter.isIncludeJadeClasses	:=	false;
	
	CnEcBaseRoot.cnEcDocumentSelf(theParameter, null, null, null, null, "c:\temp", null, "c:\temp\index.htm");
epilog
