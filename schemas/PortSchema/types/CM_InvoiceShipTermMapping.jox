    <JadeMethod name="getAuditText" id="cf2c7e82-cc98-4080-91de-3fc80ef275c8">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Jan 2023 navtnr20	Bug 56310: EUP - Invoice Contract Shipping Terms Mapping Not Auditing Updates

*/

vars
	txt,
	tmpStr		: String;
	invLineDesc : CM_InvoiceLineDesc;
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	if self.allInvoiceLineTypes.size &gt; 0 then
		foreach invLineDesc in self.allInvoiceLineTypes do
			if invLineDesc &lt;&gt; null then
				tmpStr := invLineDesc.narration &amp;" "&amp; tmpStr ;
			endif;
		endforeach;
		txt := txt &amp; app.getErrorString(Mapping) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	tmpStr := null;
	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="17470a50-de80-4bff-8846-934fe7cbfa7f">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Jan 2023 navtnr20	TFS CR 55622 Task 55692: UI - Shipping Terms Maint

*/

vars
	invLineDesc			: CM_InvoiceLineDesc;
begin
	if _attrName = ETRow_Charge then
		return self.myDebtorType.description;
	elseif _attrName = ETRow_Lines then
		//if not self.allInvoiceLineTypes.my
		return self.allInvoiceLineTypes.size.String;
	else
		return null;
	endif;
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="bda4070b-f607-4dd1-823e-503232d6aaa1">
        <source>pxyCreateUpdateProxy(): SelfType;
/*
Purpose:			

Date		Who		Reason
12 January 2023	navtnr20	TFS CR 55622 Task 55690: Jade - Shipping Terms TRX
*/

vars
	pxyME : SelfType;
begin
	pxyME :=  inheritMethod();
	
	pxyME.myDebtorType := self.myDebtorType;
	pxyME.myShippingTerm := self.myShippingTerm;
	self.allInvoiceLineTypes.copy(pxyME.allInvoiceLineTypes);
	
	return pxyME;

epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
