end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCSV" id="5e239443-8e3f-4cf9-91f9-627ac9fba787">
        <source>doCSV();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2010	cnwrd1	Initial creation
// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	aServ : CM_Service;
	aServObj : CM_ServiceObject;
	aRate : CM_Rate;
	aDebtor,eDebtor : CM_DebtorNode;
	anAudit : CM_Audit;
	allDs : CM_DebtorNodeByNameDict;
	printedAudit	: Boolean;
	file	: File;
	fileStrings : HugeStringArray;
	str		: String;
	fmDebtor : CM_DebtorNode;
	fmBank : CM_Bank;
	fmService : CM_Service;
	dateFromLocal,
	dateToLocal,
	dateFrom,
	dateTo : TimeStamp;
	fileName : String;
	rdg : CM_RootDebtorGroup;
	fileEx:        FileException;
begin

	on FileException do app.fileExceptionHandler(fileEx);  // handles any file issues we have
	
	fmBank := self.myCurrentBank;
	fmDebtor := self.cmbDebtorPrt.listObject.CM_DebtorNode;
	fmService := self.cmbServicePrt.listObject.CM_Service;
	rdg := fmBank.getRootDebtorGroup();
	
	dateFromLocal.setDate(self.txtDateFrom.getDate());	// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	dateFromLocal.setTime(self.txtTimeFrom.getTime());	// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	dateToLocal.setDate(self.txtDateTo.getDate());		// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	dateToLocal.setTime(self.txtTimeTo.getTime());		// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	dateFrom := self.localToSystemTime(dateFromLocal);	// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	dateTo := self.localToSystemTime(dateToLocal);		// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	fileName := self.txtFileName.text; 
	
	if fileName = null then
		return;
	endif;

	
	create fileStrings transient;
	create allDs transient;
	
	if fmDebtor &lt;&gt; null then
		allDs.add(fmDebtor);
	else
		app.myRoot.myRootCompany.debtorNodes.copy(allDs);
	endif;
	
	fileStrings.add('"Debtor","Code","Service","Default Rate","Old Rate","New Rate","% Changed","User","Edited","Effective"'); // add header line
	
	
	
	foreach eDebtor in allDs do
	foreach aServObj in fmBank.serviceObjects discreteLock
		where (fmService = null or fmService = aServObj)  do : servLoop

		if not aServObj.isKindOf(CM_Service) then
			continue;
		endif;
		aServ := aServObj.CM_Service;
		
		foreach aRate in aServ.debtorNodeRates discreteLock do : rateLoop
			aDebtor := aRate.CM_DebtorRate.debtorNode;
//			if self.myDebtor &lt;&gt; null and aDebtor &lt;&gt; self.myDebtor then
			if aDebtor &lt;&gt; eDebtor then
				continue rateLoop;
			endif;
			
			foreach anAudit in aRate.qualifiedAudits 
				where anAudit.createdTime &gt;= dateFrom and anAudit.createdTime &lt;= dateTo do
			
				str :=  self.csvAudit(anAudit.CM_FinAuditRateHistory, aServ, true, aDebtor,rdg, fmBank );
				if str &lt;&gt; null then
					fileStrings.add ( str );
				endif;
				
				printedAudit := true;
			endforeach;

			foreach anAudit in aRate.unqualifiedAudits 
				where anAudit.createdTime &gt;= dateFrom and anAudit.createdTime &lt;= dateTo do
				str := self.csvAudit(anAudit.CM_FinAuditRateHistory, aServ, false, aDebtor,rdg, fmBank);
				if str &lt;&gt; null then
					fileStrings.add ( str );
				endif;				
				printedAudit := true;
			endforeach;

		endforeach;
	endforeach;
	endforeach;
	

	if  printedAudit then

		create file transient;
		file.fileName := fileName;
		file.mode := File.Mode_Output;
	
		// write file here
		foreach str in fileStrings do		
			file.writeLine(str);
		endforeach;
	
	endif;
	
epilog
	delete fileStrings;
	delete allDs;
	
	if file &lt;&gt; null then
		if file.isOpen() then
			file.close();
		endif;
		
		delete file;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbBankBuild" id="5b4b12ed-5d98-4f16-9fd7-8da6f245cc25">
        <source>doCmbBankBuild();
//	35874 build combo for business unit query
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 38/03/2018	jlgdap1		TFS 37794 PEL1 Vessel Rates
// 07 Jun 2018  cnwma1		ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types
vars
	company			: CM_Bank;
	businessUnits	: CM_CompanyByCodeDict;
	currentBU		: CM_Bank;
	combo			: CMUI_ComboBox;
begin

	combo := self.cmbBank;
	create businessUnits transient;
	currentBU := self.myTerminal.getAvailableCompanies(businessUnits);
	foreach company in businessUnits do
		combo.addItem(company.code);
		combo.itemObject[combo.newIndex] := company;
	endforeach;
	if currentBU &lt;&gt; null then
		combo.listObject := currentBU;
	endif;
epilog
	delete businessUnits;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doComboBerthBuild" id="6e5640b7-a9c0-43e5-83ae-8fce993a3c02">
        <source>doComboBerthBuild();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jun 2018 cnwma1	ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types

*/

vars
	harbour : HMS_Harbour;
begin
	if self.myTerminal &lt;&gt; null then
		if self.myTerminal.myHarbour &lt;&gt; null then
			harbour := self.myTerminal.myHarbour;
		endif;
	endif;
	self.myAssistant.comboBoxHMSBerth(self.cmbBerth,harbour, self.myCurrentBerth,true);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doComboDebtorBuild" id="7263f3c0-b3be-42c0-8933-46891ee9c6d8">
        <source>doComboDebtorBuild();
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 17/06/2014	cnwdap1		PAR #34422 Remove beginLock / endLock
vars
	root, debtor : CM_DebtorNode;

begin

	//beginLock;			// PAR #34422

	self.cmbDebtor.clear;
	self.cmbDebtorPrt.clear;
	self.cmbDebtorPrt.sorted := true;
	foreach debtor in app.myRoot.myRootCompany.debtorNodes do
		if debtor.isRootDebtorGroup then
			root := debtor;
			continue;
		endif;
		self.cmbDebtor.addItem(debtor.getListName()); // so default debtor is not 'RDG'
		self.cmbDebtor.itemObject[self.cmbDebtor.newIndex] := debtor;

		self.cmbDebtorPrt.addItem(debtor.getListName()); // so default debtor is not 'RDG'
		self.cmbDebtorPrt.itemObject[self.cmbDebtor.newIndex] := debtor;
	endforeach;

	self.cmbDebtorPrt.sorted := false;
	self.cmbDebtorPrt.addItemAt("ALL",1);

	// PAR 16503
	self.cmbDebtor.sorted := false;
	if root &lt;&gt; null then
		self.cmbDebtor.addItemAt("&lt;" &amp; root.getListName() &amp; "&gt;", 1); // TFS 38524 index 1
		self.cmbDebtorPrt.addItemAt("&lt;" &amp; root.getListName() &amp; "&gt;", 2);
		//PAR18345 - cnwsh3 22/10/2008 Was getting invalid property values and 1090s because we were occasionally looking at the wrong listIndex.
		//self.cmbDebtor.itemObject[1] := root;
		self.cmbDebtor.itemObject[1] := root; // TFS 38524 index 1
		self.cmbDebtorPrt.itemObject[2] := root;
	endif;

epilog
	//endLock;				// PAR #34422

end;</source>
    </JadeMethod>
    <JadeMethod name="doComboServicesBuild" id="02a2e576-01c5-446a-9f18-f7048655b4ab">
        <source>doComboServicesBuild();
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 17/06/2014	cnwdap1		PAR #34422 Remove beginLock / endLock
// 27/03/2018	jlgdap1		TFS 37794 PEL1 Vessel Rates
// 07 Jun 2018  cnwma1		ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types
// 18/07/2018	jlgdap1		TFS 39782 PEL1 Vessel Rates need to filter Services
vars

	service : CM_Service;
	bank : CM_Bank;

begin
	bank := self.myCurrentBank;
	self.cmbServicePrt.clear;
	self.cmbServicePrt.sorted := true;
	self.cmbDebtorService.clear; // PAR 31657
	self.cmbDebtorService.sorted := true; // PAR 31657
	self.cmbTradeService.clear; // PAR 31657
	self.cmbTradeService.sorted := true; // PAR 31657
	self.cmbVesselService.clear;														// TFS 37794
	self.cmbVesselService.sorted := true;												// TFS 37794
	self.cmbVesselTypeService.clear;		   //07.06.2018 cnwma1 ChangeRequest #38953
	self.cmbVesselTypeService.sorted := true; //07.06.2018 cnwma1 ChangeRequest #38953
	
	self.cmbVisitTypeService.clear;		   	  //07.06.2018 cnwma1 ChangeRequest #38953
	self.cmbVisitTypeService.sorted := true;  //07.06.2018 cnwma1 ChangeRequest #38953
	
	self.cmbBerthService.clear;		   //07.06.2018 cnwma1 ChangeRequest #38953
	self.cmbBerthService.sorted := true; //07.06.2018 cnwma1 ChangeRequest #38953
	
	foreach service in bank.services where not service.isNotAvailableForEntry do
		self.cmbTradeService.addItem(service.name);
		self.cmbTradeService.itemObject[self.cmbTradeService.newIndex] := service;
		self.cmbDebtorService.addItem(service.name);
		self.cmbDebtorService.itemObject[self.cmbDebtorService.newIndex] := service;
		self.cmbServicePrt.addItem(service.name);
		self.cmbServicePrt.itemObject[self.cmbServicePrt.newIndex] := service;
		if service.defaultRateTable = CM_Service.VESSEL_RATE_TABLE then			// TFS 39782
			self.cmbVesselService.addItem(service.name);									// TFS 37794
			self.cmbVesselService.itemObject[self.cmbVesselService.newIndex] := service;	// TFS 37794
		endif;																	// TFS 39782
		if service.defaultRateTable = CM_Service.VESSELTYPE_RATE_TABLE then		// TFS 39782
			self.cmbVesselTypeService.addItem(service.name);										//07.06.2018 cnwma1 ChangeRequest #38953
			self.cmbVesselTypeService.itemObject[self.cmbVesselTypeService.newIndex] := service;	//07.06.2018 cnwma1 ChangeRequest #38953
		endif;																	// TFS 39782
		if service.defaultRateTable = CM_Service.VISITTYPE_RATE_TABLE then		// TFS 39782
			self.cmbVisitTypeService.addItem(service.name);										//07.06.2018 cnwma1 ChangeRequest #38953
			self.cmbVisitTypeService.itemObject[self.cmbVisitTypeService.newIndex] := service;	//07.06.2018 cnwma1 ChangeRequest #38953
		endif;																	// TFS 39782
		if service.defaultRateTable = CM_Service.BERTH_RATE_TABLE then			// TFS 39782
			self.cmbBerthService.addItem(service.name);											//07.06.2018 cnwma1 ChangeRequest #38953
			self.cmbBerthService.itemObject[self.cmbBerthService.newIndex] := service;			//07.06.2018 cnwma1 ChangeRequest #38953
		endif;																	// TFS 39782
		
	endforeach;
	self.cmbServicePrt.sorted := false;
	self.cmbServicePrt.addItemAt("ALL",1);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doComboTradeBuild" id="62629ae5-5571-41f9-9fe9-56904507bda5">
