    <JadeMethod name="tMTReleaseUsingLander" id="616b6f69-6cf9-44db-86d6-9ce88a496d47">
        <source>tMTReleaseUsingLander();
// cnwer1
//25 August 2010	cnwdw1	
// Work a Ship MT Release from start to finish using Lander
//04Sep2012	cnwrs1	Par30321	if the trx is to be retried then setup the effective date again
// 10 Sep 2019	cnwrs1	TFS 46030
// 08 Jan 2024	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests
vars
	voyage1: CM_Voyage;
	voyage2: CM_Voyage;
	vessel: CM_Vessel; 
	slots : CM_SlotControllerArray;
	tmpLoadCC	: CMIF_LoadColorCode;
	voyageJob : CM_VoyageJob;
	releaseRequest: CM_BulkRelease;
	dischargePort: CM_Port;
	ti1, ti2, ti3: CM_TrackedItem;
	bs1, bs2: CM_BlockStack;
	straddle: CM_Machine;
	targetArea, sourceArea: CM_TerminalArea;
	tas: StringArray;
	queue: CM_RadioTelemetryQueue;
	queueEntry: CM_RTQueueEntry;
	queuetask: CM_RTQueueTask;
	craneName: String;
	crane: CM_Crane;
//	agent: CM_MobileAgent;
	agent : CMIF_MobileGenericAgent;
	wle: CM_WorkListEntry;
	bay: CM_BayDefn;
	configTBA: Boolean;
	autoPlanMTReleaseStrategy : Boolean;	
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	dischargePort := app.myRoot.allPorts["NZAKL"];
	craneName := self.getProfileSetting(UT_Profile.P_CRANE).asString;

	bs1 := addBlockStack(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString, 100, null);
	bs2 := addBlockStack(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString&amp;"X", 100, null);

	self.setTerminalConfig(AutoPlanMTReleaseStrategy, AutoPlanMTRelStrategyTerminal);
	self.setTerminalConfig(ShowRelReqOnShipLoadList, false);

	// createVoyage
	deleteVoyage("UTMTREL");
	deleteVessel("UTMTREL");
	vessel := addVesselCellular("UTMTREL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	foreach bay in vessel.myCellularVesselStructure.allBaysByLabel do//04Sep2012	cnwrs1	Par30321	if the trx is to be retried then setup the effective date again
		beginTransaction;
		bay.setPropertyValue(CM_BayDefn::maxPileWeight20IB.name, 6000);
		bay.setPropertyValue(CM_BayDefn::maxPileWeight20OB.name, 6000);
		commitTransaction;
	endforeach;	
	voyage1 := addVoyageWithContainerStructur("UTMTREL", "UTMTREL", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);

	// Create some mt cargo
	self.deleteContainer("TEST0000002");  // Shouldn't get this cargo is not in bs1
	ti2 := self.addContainerAtLocnDisch("TEST0000002", "UT20", "MT", TI_IMEX_STATUS_EXPORT, bs2.myLocationsController, dischargePort, voyage1);
	self.opts.purge;
	self.opts.addAssoc("CENum", "123");
	self.deleteStops(ti2);
	self.setCargoReadyToShip(ti2);
	
	self.deleteContainer("TEST0000001");  // This is the one we should get as it is in bs1
	ti1 := self.addContainerAtLocnDisch("TEST0000001", "UT20", "MT", TI_IMEX_STATUS_EXPORT, bs1.myLocationsController, dischargePort, voyage1);
	self.opts.purge;
	self.opts.addAssoc("CENum", "123");
	self.deleteStops(ti1);
	self.setCargoReadyToShip(ti1);

	self.deleteContainer("TEST0000003");  // This is the one we should get as it is in bs1
	ti3 := self.addContainerAtLocnDisch("TEST0000003", "UT20", "MT", TI_IMEX_STATUS_EXPORT, bs1.myLocationsController, dischargePort, voyage1);
	self.opts.purge;
	self.opts.addAssoc("CENum", "123");
	self.deleteStops(ti3);
	self.setCargoReadyToShip(ti3);

	// create Release
	deleteReleaseRequest("UTMTREL");
	self.opts.purge;
	self.opts.addAssoc("Number", 2);
	self.opts.addAssoc("ISOGroup", "U40G");
	self.opts.addAssoc("ISOGroup2", "UT20");
	self.opts.addAssoc("Voyage", voyage1);
	self.opts.addAssoc("DischargePort", dischargePort);
	self.opts.addAssoc("TerminalArea", bs1);   // Make sure only get cargo from bs1
	releaseRequest := addReleaseByTypeRequestOpts("UTMTREL", BR_TYPE_SHIP, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	assertEqual(releaseRequest.allReserveDetails.size, 2);

	crane := self.getCrane(craneName);
	assertNotNull(crane);
	self.addMachineRule(bs1, crane.transferArea, RTMoveMethod_23);   // Straddle only

	// colourCodeLoad
	create slots transient;
	create tmpLoadCC transient;
	tmpLoadCC.overrideMoveType := true;
	tmpLoadCC.myDischargePort := dischargePort;
	tmpLoadCC.myBulkReleaseReserveDetail := releaseRequest.allReserveDetails.last;

	self.getJobSlotControllers("UTMTREL","01",DeckOnDeck,1,1,2,slots);
	self.markSlotsAsLoadJob(slots,tmpLoadCC);
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Empty);
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_AssignRelease);
		
	voyageJob:=self.addVoyageJob(voyage1,craneName,slots, false);
		assertTrueMsg(voyageJob &lt;&gt; null, "Voyage job was null");
		assertTrue(slots.first.mySlotRequestLoad.getAttrEmpty);

	self.loadAllJobsToOps(voyage1, true);
	
	self.deleteStops(ti1);
	self.deleteStops(ti2);
	self.deleteStops(ti3);

	self.moveAllCargoOnVoyage(voyage1, QUEUE_MODE);
		assertNotNull(voyage1.allVoyageJobs.first.workListEntries.first.allRTQueueEntries.first.allTasks.first.targetLocation);
		assertTrue(voyage1.allVoyageJobs.first.workListEntries.first.allRTQueueEntries.first.allTasks.first.targetLocation.isKindOf(CM_SlotController));
	
	queueEntry := voyage1.allVoyageJobs.first.workListEntries.first.allRTQueueEntries.first;
	wle := queueEntry.myWorkListEntry;
	queuetask := queueEntry.allTasks.first;
	queue := queueEntry.myQueue;
	targetArea := queueEntry.allTasks.first.targetLocation.myTerminalArea;
	sourceArea := queueEntry.allTasks.first.sourceLocation.myTerminalArea;
	
	assertEqual(sourceArea, bs1);
	
	// workJob to CTA
	self.deleteMachine("UTS1");
	self.deleteRTDevice("91");
	create tas transient;
	tas.add(bs1.id);// tas.add(targetArea.id);
	self.addStraddle("UTS1", 91, tas, queue.id);
	
	straddle := self.getMachine("UTS1");
	assertNotNull(straddle);
	
	app.isRTApp:=true;  
	self.machineLogon(straddle);
	self.machineAcceptSpecifiedTask(straddle, queueEntry);
	self.machineDirector(straddle, ti1);

	// Use Lander to move to ship
	create agent transient;
	agent.setDoNotShowMsgBox(true);
	agent.moveTI( ti1, null, slots.first, wle, true, 0, 0, null );
	
	self.machineLogOff(straddle);

	assertTrue(wle.isCompleteForJob);
	
	assertEqual(ti1.myPrimaryActualLocation, slots.first);
	assertEqual(ti1.getImExStatus, TI_IMEX_STATUS_EXPORT);
	assertEqual(ti1.myVoyage, voyage1);
	self.checkTIForTxnOfType(ti1, TRANS_TYPE_REL_SHIP);				// 15/08/2012 cnwmh5
	self.checkTIForTxnOfType(ti1, TRANS_TYPE_WHARFAGE);				// 15/08/2012 cnwmh5
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	app.isRTApp:=false;  
	
	delete slots;
	delete tmpLoadCC;
	delete tas;
	delete agent;
end;
</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;Emmet_Fails&lt;/Category&gt;
    &lt;Category CanDelete="true"&gt;Fails&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
