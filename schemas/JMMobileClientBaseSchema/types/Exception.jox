<ExceptionClass name="Exception">
    <JadeMethod name="isAppError" id="b17191fd-7b91-45d0-bee3-99577ea3e33d">
        <source>isAppError():Boolean;
// --------------------------------------------------------------------------------
// Created:		14 October 2005 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the exception was raised
//				by the application.
//
// Parameters:	None
//
// Returns:		True if the exception was raised by the application, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSoapError" id="e53af29d-ff94-41b9-a403-7d52a18539c4">
        <source>isSoapError():Boolean;
// --------------------------------------------------------------------------------
// Created:		14 October 2005 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the exception is a SOAP
//				error.
//
// Parameters:	None
//
// Returns:		True if the exception is a SOAP error, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</ExceptionClass>
