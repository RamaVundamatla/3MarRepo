    </JadeMethod>
    <JadeMethod name="delete" id="b05d6f28-8cc9-491f-b316-8c72838e46b9">
        <updating/>
        <source>delete() updating;
// --------------------------------------------------------------------------------
// Created:		22 August 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
epilog
	delete self.myIterator;
	delete self.myObjectSet;
	
	endNotificationForSubscriber(self);
end;</source>
    </JadeMethod>
    <ExternalMethod name="displayEntry" id="7a38fc40-ec7a-440c-ab9d-1f6b5f9c66f1">
        <updating/>
        <entrypoint>CallControlEvent</entrypoint>
        <library name="jadpmap"/>
        <source>displayEntry(
			browsebuttons: CnEcBrowseButtons input; 
			browseType: Integer; 
			obj: Object) is "CallControlEvent" in "jadpmap" updating, number = 1005;</source>
        <Parameter name="browsebuttons" type="CnEcBrowseButtons" usage="input"/>
        <Parameter name="browseType" type="Integer"/>
        <Parameter name="obj" type="Object"/>
    </ExternalMethod>
    <JadeMethod name="listCollection" id="b2963538-870f-4c8f-82d7-12858c857be1">
        <updating/>
        <source>listCollection(coll:Collection; update:Boolean; showHow:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		22 August 1999 by cnwdad1
//
// Purpose:		Sets up an iterator for the collection to be browsed.
//
// Parameters:	coll (Collection) - The collection to be browsed.
//				update (Boolean) - Indicates whether to detect changes to the collection.
//				showHow (Integer) - If '1', the collection order is reversed.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myIterator &lt;&gt; null then
		delete self.myIterator;
	endif;

	if self.myObjectSet &lt;&gt; null then
		delete self.myObjectSet;
	endif;

	if coll &lt;&gt; null then
		if coll.isKindOf(VirtualColl) then
			create self.myObjectSet transient;
			coll.copy(self.myObjectSet);
			self.myIterator	:=	self.myObjectSet.createIterator();
		else
			self.myIterator	:=	coll.createIterator();
		endif;

		if update then
			beginNotification(coll, Any_System_Event, Response_Continuous, 1);
		endif;

		self.showUpdates	:=	update;
		self.isReversed		:=	(showHow = 1);
	endif;
end;</source>
        <Parameter name="coll" type="Collection"/>
        <Parameter name="update" type="Boolean"/>
        <Parameter name="showHow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="6cdbd2f7-9249-464c-aaac-d53983b97406">
        <updating/>
        <source>sysNotify(browsebuttons:CnEcBrowseButtons input; eventType:Integer; theObject:Object; eventTag:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		22 August 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	showHow	: Integer;

begin
	app.mousePointer	:=	Busy;
	inheritMethod(browsebuttons, eventType, theObject, eventTag);

	if app.isValidObject(theObject) and theObject.isKindOf(Collection) then
		if self.isReversed then
			showHow	:=	1;
		else
			showHow	:=	0;
		endif;

		self.listCollection(theObject.Collection, self.showUpdates, showHow);

		if self.currentObject &lt;&gt; null then
			self.myIterator.startAtObject(self.currentObject);
			self.displayEntry(browsebuttons, 0, self.currentObject);
		endif;
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="browsebuttons" type="CnEcBrowseButtons" usage="input"/>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
