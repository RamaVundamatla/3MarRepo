<Class name="CMQF_BookingRefDiscrepancy">
    <JadeMethod name="setFromAgent" id="a7aa4b31-45f9-4386-befb-a97f2a628b73">
        <updating/>
        <source>setFromAgent(_agent: CMUI_ReportAgent input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 September 2009	cnwndl1	Initial creation	CCMS 1609 Par 20521

*/

vars
	
begin

	

	inheritMethod(_agent);

	
	self.allEventTypes.clear();
	self.allEventTypes.add(EVT_BookingRefDiscrep);
	
	self.setMyVoyage( null );
	if _agent.isRowIncluded(ETRow_Voyage) then
		self.setMyVoyage( _agent.getSelectedVoyage() );
	endif;
	
	self.myOperator := null;
	if _agent.isRowIncluded(ETRow_Operator) then
		self.myOperator :=_agent.getSelectedOperator();
	endif;
	
	self.state := null;
	if _agent.isRowIncluded(ETRow_State) then
		self.state :=_agent.getSelectedState();
	endif;
	
	self.cargoId := null;
	if _agent.isRowIncluded(ETRow_CargoId) then
		self.cargoId :=_agent.getValueByName(ETRow_CargoId).String;
	endif;
	
	self.bookingRef := null;
	if _agent.isRowIncluded(ETRow_BookingRef) then
		self.bookingRef :=_agent.getValueByName(ETRow_BookingRef).String;
	endif;

epilog

end;</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
