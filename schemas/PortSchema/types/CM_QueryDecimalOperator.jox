    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <PrimAttribute name="searchValue" id="71c30b4b-bc9a-4bbd-af29-8d58cc7ba372">
        <precision>14</precision>
        <scaleFactor>4</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getSearchValue" id="2084af63-f47c-409c-a4c7-71dd8208b50e">
        <source>getSearchValue(): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars

begin
	return self.searchValue;

epilog

end;</source>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getSearchValueStr" id="8f660c7b-4745-44cc-a71d-1f3e7f0cc9dc">
        <source>getSearchValueStr(_prop: CM_QueryProperty): String;
// ---------------------------------------------------------------------------
// Created:     17 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	return _prop.translateToDisplayValue(self.searchValue);


end;</source>
        <Parameter name="_prop" type="CM_QueryProperty"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setSearchValue" id="03b970fa-fde8-4f0b-ae92-70330d444138">
        <updating/>
        <source>setSearchValue(_value: Any) updating;
// ---------------------------------------------------------------------------
// Created:     05 March 2003		cnwth2	
//
// Purpose:     		 
//
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 03/10/2017	jlgdap1		TFS 7204 STWR Issues with decimal / real values in locales where decimal place is not a .
vars
	stringValue		: String;
	//decimalValue	: Decimal[12,3];
	decimalValue	: Decimal[14,4]; //par 19252
	
begin
	if _value &lt;&gt; null then    // par 18123
		stringValue := _value.String;
		//if stringValue.isDecimal then					// TFS 7204
		//	decimalValue := stringValue.Decimal;		// TFS 7204
		if stringValue.isDecimalJMT then				// TFS 7204
			decimalValue := stringValue.asDecimalJMT;	// TFS 7204
		else
			app.raiseCMException1(VB_INVALID_NUM, stringValue, null, null);
		endif;		
	endif;
	
	self.searchValue := decimalValue;
	
end;</source>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
</Class>
