    <JadeMethod name="getName" id="43b77019-7be3-435c-b433-8f68ac435cfa">
        <source>getName() : String;

vars
	returnStr	 : String;
	
begin
	returnStr	:=	inheritMethod() &amp; Tab &amp; self.creationTime.cnEcShortFullFormat &amp; Tab &amp; self.id.padBlanks( 20 );
	
	if self.myTerminal &lt;&gt; null then
		returnStr	:= returnStr &amp; Tab &amp; self.myTerminal.code;
	endif;
	
	return returnStr;
	
epilog
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
