    <JadeMethod name="doSelectTermSubArea" id="1cd407a4-a134-422f-8687-ec287868e5db">
        <updating/>
        <source>doSelectTermSubArea(_termSubArea: CM_TerminalSubArea;_theFrame : CMUI_GridAreaFrame input) updating;
// ---------------------------------------------------------------------------
// Created:     02 June 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.allTerminalSubAreas.size &lt;&gt; 0 then
