    <JadeMethod name="cmbBays_click" id="9869f106-1802-430f-81de-c0b26c84b9e1">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbBays_click(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aBay : CM_BayVoyage;
	aHold : CM_Hold;
	theVoyage	: CM_Voyage;
begin
	aBay := combobox.listObject.CM_BayVoyage;
	aHold := aBay.myHold;
		
	if self.btnSelBayTwin.value then
		// we are displaying all the bays in the hold
		if self.allSelectedHolds.includes(aHold) and self.allSelectedHolds.size = 1 then
			// this bay should already be displayed
			return;
		endif;
	endif;
	
	theVoyage := aBay.myCellularVoyageStructure.myVoyage;
	
	if theVoyage &lt;&gt; self.myCurrentVoyage then
		// this should never happen but try and fixup if it does
		self.setMyCurrentVoyage(theVoyage, false, true);
		// need to reset this as this combo is reloaded in the
		// above method.
		combobox.listObject := aBay;
	endif;
	
	self.allSelectedHolds.clear;
	//Par13681 - If a Bay has not been set up with a hold, a 1311 was occurring.  Changed to display a blank form as per
	//other selections that are null.
	if aHold &lt;&gt; null then
		self.allSelectedHolds.add(aHold);
	endif;
	
	self.voyageLoad(self.displayMode);

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
