    <JadeMethod name="doesVesselNameExist" id="200c2b53-4021-4e86-a048-45f341763602">
        <source>doesVesselNameExist(_vesselName: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Mar 2023	navra1	Initial creation for 57263
08 Jan 2026 navma1  MTN-36897 PEN - Transient File Growth in PEN Production Environment 
*/

vars
	ediTi			: CM_EDITrackedItem;
	voyageEventTI   : CM_EDIVoyageEventTI;
	terminal		: CM_Terminal;
	voyage 			: CM_Voyage;
	vslName			:String;
begin
	
	vslName := _vesselName.toUpper();					//08.01.2026 navma1 #MTN-36897
	
	foreach ediTi in self.allEDITrackedItems do
		if ediTi.isKindOf(CM_EDIVoyageEventTI) then
			voyageEventTI := ediTi.CM_EDIVoyageEventTI;
			terminal := voyageEventTI.getMyTerminal;
			if terminal &lt;&gt; null then
				voyage := terminal.lookupVoyage(voyageEventTI.voyageCode, null, false);
				if voyage &lt;&gt; null then
					if voyage.vesselName.toUpper().compareEql(vslName, true, false, null) then
						return true;
					endif;
				endif;
			endif;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <Parameter name="_vesselName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
