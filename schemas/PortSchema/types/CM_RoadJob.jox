    <JadeMethod name="getTotalQuantity" id="b936a317-96cd-46ea-9d7b-4f7c314759e8">
        <source>getTotalQuantity(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Sep 2023	navlw1	Bug 60382: MTN - The Work Order Operations form's column organizer is missing some fields.
26 Mar 2024 navhl20 Defect 63074: Release by type work orders is not displaying on the work order operations form
06 Mar 2025 navma1 MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	qty 	: Integer;
	wle		: CM_WorkListEntry;
begin

	foreach wle in self.workListEntries discreteLock do		//06.03.2025 navma1 #MTN-34179
		if not wle.isChassis then
			qty := qty + wle.quantity.max(1);			//26.03.2024 navhl20 #63074
		endif;
	endforeach;

	return qty;
epilog

end;</source>
