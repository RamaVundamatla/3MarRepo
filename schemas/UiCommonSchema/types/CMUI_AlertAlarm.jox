    <JadeMethod name="resize" id="f7c2d514-89f5-4e5c-b729-793b6bcfdb9a">
        <controlMethod name="Form::resize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>resize() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
25 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	realUserWindow : CM_UserWindowForOpen;
begin

	realUserWindow := app.getUserWindow(self.name, true);	// get realUserWindow  not proxy
	if realUserWindow &lt;&gt; null then
		realUserWindow.setProxy(app.getMyUser, self.name, null, self.top, self.left, self.width, self.height, self.windowState);
	endif;

	if self.windowState = Form.WindowState_Minimized then
		self.windowState := Form.WindowState_Normal;
		setupMinimized;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setPosition" id="fc1ed58a-408c-4427-92fb-13d7dc4a1f6b">
        <updating/>
        <source>setPosition(_height, _width : Real) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
15 June 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	superForm :Form;
	userWindow	: CM_UserWindow;
	str,tmpStr : String;
	tmpLeft,tmpTop,
	defaultTop,
	defaultLeft: Real;
begin
	if userWindow = null then
		userWindow := app.getUserWindow(self.name, false);
		superForm:=app.mainForm;
		defaultTop:=superForm.top + (superForm.clientHeight/2);
		defaultLeft:=(superForm.left + (superForm.width/2));
		if userWindow &lt;&gt; null then	

			if superForm &lt;&gt; null then
				tmpLeft:=userWindow.left + userWindow.width - _width;
				if tmpLeft &lt; superForm.left then
					tmpLeft:=defaultLeft;//superForm.left + 50;
				elseif tmpLeft + _width &gt; (superForm.left + superForm.clientWidth) then
					tmpLeft:=defaultLeft;//((superForm.left + superForm.width)- 110); 
				else
					tmpLeft:=tmpLeft;
				endif;
				self.left:=tmpLeft;
				tmpTop:=userWindow.top;
				if tmpTop &lt; superForm.top then
					tmpTop := defaultTop;
					
				elseif (tmpTop + _height) &gt; (superForm.top + superForm.clientHeight) then
					tmpTop := defaultTop;
				endif; 
				self.top:=tmpTop;
			endif;
		else
			self.left:=defaultLeft;
			self.top:=defaultTop;
		endif;
	endif;	

epilog

end;</source>
        <Parameter name="_height" type="Real"/>
        <Parameter name="_width" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="915cba3c-ffd4-4ee6-b238-5ecd09759218">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
25 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
begin
	self.alwaysOnTop(true);
	self.addToolbarControls();
	self.frmAlert.height	:=	frmAlert.height + 4;
	self.frmAlert.width		:=	frmAlert.width + 4;
	self.tblData.autoSize	:=	Table.AutoSize_Row;
	self.tblData.wordWrap	:=	true;
	self.loadAlerts();
	self.caption	:=	'System Alerts for ' &amp; app.myPassport.myUser.code;
	self.setFormParent(app.mainForm);
	self.setupMinimized();
end;</source>
    </JadeMethod>
    <JadeMethod name="setupMaximized" id="6e124cab-d137-4a5a-b440-3ac2342c82c6">
        <updating/>
        <source>setupMaximized() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
25 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

	superForm :Form;
	userWindow	: CM_UserWindow;
	row : Integer;
	str,tmpStr : String;
	cellHeight : Integer;
	tblColumn		: JadeTableColumn;
begin
	self.borderStyle:=Form.BorderStyle_Sizable;
	self.maxButton:=false;
	self.minButton:=true;
	self.controlBox:=true;
	self.height:=280;
	self.width:=380;
	//&lt;cnwgb1 PAR 23419 22.4.2010&gt;
	if self.caption = null and self.titleText &lt;&gt; null then
		self.caption := self.titleText;
	endif;
	//&lt;/cnwgb1 PAR 23419 22.4.2010&gt;
	lblInstns.visible:=true;
	tblData.visible:=true;
	frmAlert.top:=lblInstns.top;
	frmAlert.left:=lblInstns.left + lblInstns.width;
	frmAlert.borderStyle:=Form.BorderStyle_None;
	tblColumn := tblData.accessColumn(1);
	tblColumn.width	:=tblData.width.Integer;

	frmToolbar.visible := true;

	tblData.resetRowHeightForText(1);
	
	self.setPosition(self.height,self.width);
/*	if userWindow = null then
		userWindow := app.getUserWindow(self.name, false);
		if userWindow &lt;&gt; null then
			superForm:=app.mainForm;
			if superForm &lt;&gt; null then
				self.left:=userWindow.left;
				self.top:=userWindow.top;
			endif;
		endif;
	endif;*/

epilog
	//frmAlert.visible:=false;


end;</source>
    </JadeMethod>
    <JadeMethod name="setupMinimized" id="01899ffc-a824-4954-aa4d-c1de59c85f4c">
        <updating/>
        <source>setupMinimized() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
25 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
begin
	self.setPosition(frmAlert.height, frmAlert.width);
	
	frmToolbar.visible	:=	false;
	lblInstns.visible	:=	false;
	tblData.visible		:=	false;
	//&lt;cnwgb1 PAR 23419&gt;
	//self.borderStyle	:=	Form.BorderStyle_Single;
	//self.maxButton:=false;
	//self.minButton:=false;
	//self.controlBox:=true;
	//self.clientHeight	:=	frmAlert.clientHeight;
	//self.clientWidth	:=	frmAlert.clientWidth;
	if self.caption &lt;&gt; null then
		self.titleText  := self.caption;
		self.caption := null;
	endif;
	//&lt;/cnwgb1 PAR 23419 22.4.2010&gt;
		
	self.borderStyle	:=	Form.BorderStyle_None;
	self.maxButton:=false;
	self.minButton:=false;
	self.controlBox:=false;
	self.height	:=	frmAlert.height;
	self.width	:=	frmAlert.width;
	frmAlert.borderStyle	:=	Form.BorderStyle_Single;
	frmAlert.top	:=	0;
	frmAlert.left	:=	0;
	self.frmAlert.parentBottomOffset	:=	0;
	self.frmAlert.parentRightOffset		:=	0;
epilog
	self.frmAlert.visible	:=	true;
	self.frmAlert.setFocus();
	self.frmAlert.refreshNow();
end;</source>
    </JadeMethod>
