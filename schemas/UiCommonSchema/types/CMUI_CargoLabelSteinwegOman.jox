    <JadeMethod name="printReport" id="c41fc95a-93a9-4377-ac31-91b159407d8e">
        <source>printReport();
// TFS 985
//   this method used to draw the lines and then the frame with the data
vars
	binary	: Binary;
	colour	: Integer;
	imex	: Integer;
	frame	: Frame;
	terminal	: CM_Terminal;
	cargoType	: CM_CargoType;
	product		: CM_Product;
	ti		: CM_TrackedItem;
	voyage	: CM_Voyage;
	qrStringValue : String;
	qrCodeBinary : Binary;
	
begin
	
//	app.printer.documentType := 83;		// A6 rotated
//	custom paper size parameters are width and height in tenths of mm - A6 is 105 x 148 mm, values below are rotated to be landscape
	app.printer.setCustomPaperSize(1480, 1050); // A6 landscape
//	app.printer.documentType := 70;	// 70=A6		//  Print_A5;		// A5 landscape
//	app.printer.orientation := Print_Landscape;		// A5 landscape
	app.printer.leftMargin := 5;		// so it fits better
	
	frame := self.frmMain;
	colour := Grey;
	// draw lines
	frame.drawWidth := 2;
	frame.drawStyle := self.DrawStyle_Dash;
	frame.autoRedraw := true;
	
	// horizontal
	frame.drawLine(2, 68, 381, 68, colour);
	frame.drawLine(2, 104, 381, 104, colour);
	frame.drawLine(2, 110, 381, 110, colour);
	frame.drawLine(2, 150, 381, 150, colour);
	frame.drawLine(2, 175, 381, 175, colour);
	frame.drawLine(2, 196, 381, 196, colour);
	frame.drawLine(2, 217, 381, 217, colour);
	frame.drawLine(2, 240, 381, 240, colour);

	frame.drawLine(2, 250, 501, 250, colour);	
	frame.drawLine(2, 277, 501, 277, colour);
	frame.drawLine(2, 299, 501, 299, colour);
	frame.drawLine(2, 324, 501, 324, colour);
	frame.drawLine(2, 350, 501, 350, colour);
	
	// vertical
	frame.drawLine(2, 68, 2, 101, colour);
	frame.drawLine(380, 68, 380, 101, colour);
	frame.drawLine(2, 110, 2, 150, colour);
	frame.drawLine(380, 110, 380, 150, colour);
	frame.drawLine(2, 153, 2, 240, colour);
	frame.drawLine(380, 153, 380, 240, colour);
	
	frame.drawLine(125, 153, 125, 240, colour);
	frame.drawLine(140, 250, 140, 350, colour);
	
	frame.drawLine(2, 250, 2, 351, colour);
	frame.drawLine(500, 250, 500, 351, colour);
	
	// cargo data
	ti := self.myTrackedItem;
	terminal := ti.myTerminal;
	binary := terminal.getConfig(PortLogoPic).Binary;
	self.picLogo.stretch := 3;
	self.picLogo.picture := binary;
	
	cargoType := ti.myCargoType;
	product := ti.myProduct;
	voyage := ti.myVoyage;
	
//	qrStringValue := ti.myCargoType.description &amp; ":" &amp; ti.id;
	qrStringValue := ti.id;	//21 Apr 2016	NDL	TFS 1593....
	qrCodeBinary := app.convertStringToQRCode( qrStringValue );
	self.picBarcode.stretch := 3;
	self.picBarcode.picture := qrCodeBinary;
	

	if cargoType &lt;&gt; null and
	   cargoType.productType = ProductType_Vehicle then
		self.lblReportType.caption := "RoRo Cargo Label:";
		self.lblID.caption := "VIN No:";
	else
		self.lblReportType.caption := "BreakBulk Cargo Label:";
		self.lblID.caption := "Cargo ID:";
	endif;
	self.lblSizeValue.caption := ti.length.roundedTo(2).String &amp; " x " &amp; ti.width.roundedTo(2).String &amp; " x " &amp; ti.height.roundedTo(2).String;
	imex := ti.getImExStatus();
	if imex = TI_IMEX_STATUS_IMPORT then
		self.lblImex.caption := "D";		// discharge, import
	elseif imex = TI_IMEX_STATUS_EXPORT then
		self.lblImex.caption := "L";		// load, export
	elseif imex = TI_IMEX_STATUS_TRANSHIP then
		self.lblImex.caption := "Ts";		// tranship
	else
		self.lblImex.caption := "";
	endif;
	self.lblWeightValue.caption := ti.totalWeight.roundedTo(3).asStringJMT() &amp; " kg";
	self.lblVoyRotValue.caption := "";
	self.lblVessel.caption := "";
	self.lblShipValue.caption := "";
	self.lblPackValue.caption := "";
	self.lblPackSubtypeValue.caption := "";

	if voyage &lt;&gt; null then
		self.lblVoyRotValue.caption := voyage.inwardCode;
		if voyage.myVessel &lt;&gt; null then
			self.lblVessel.caption := voyage.myVessel.name;
		else
			self.lblVessel.caption := voyage.vesselName;
		endif;
		if voyage.myShippingLine &lt;&gt; null then
			self.lblShipValue.caption := voyage.myShippingLine.description;
		endif;
	endif;
	if cargoType &lt;&gt; null then
		self.lblPackValue.caption := cargoType.description;
	endif;
	if product &lt;&gt; null then
		self.lblPackSubtypeValue.caption := product.description;
	endif;
	self.lblBLNoValue.caption := self.myTrackedItem.billOfLading;
	self.lblIDValue.caption := ti.id;

	// print the report
	app.printer.newPage();		// rely on the printer driver for top-of-label positioning
	
	/*write method.qualifiedName;
	write "app.printer.documentType = " &amp; app.printer.documentType.String;
	write "app.printer.orientation = " &amp; app.printer.orientation.String;
	write "app.printer.pageWidth = " &amp; app.printer.pageWidth.String;
	write "app.printer.pageHeight = " &amp; app.printer.pageHeight.String;
	write "app.printer.leftMargin = " &amp; app.printer.leftMargin.String;
	write "app.printer.rightMargin = " &amp; app.printer.rightMargin.String;
	write "app.printer.topOfPage = " &amp; app.printer.topOfPage.String;
	write "app.printer.bottomOfPage = " &amp; app.printer.bottomOfPage.String;
	write "self.frmMain.top = " &amp; self.frmMain.top.String;
	write "self.frmMain.left = " &amp; self.frmMain.left.String;
	write "self.frmMain.height = " &amp; self.frmMain.height.String;
	write "self.frmMain.width = " &amp; self.frmMain.width.String;
	write "app.printer.frameFits( frame ) = " &amp; app.printer.frameFits( frame ).String;
	*/
	
	app.printer.print( frame );
	app.printer.close();
	
epilog
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="run" id="9870b363-29c2-483a-a7f1-3fedd525f7f3">
        <updating/>
        <source>run(_isPrintPreview, _isCSV : Boolean; _extraDetail : CM_ExtraDetail) : Binary updating;
// this method is called from BGP_ReportRequest::createReports for non-JRW reports
//   and is defined against CMUI_ReportBaseForm but needs to be defined here for this report to be run from BG
vars
	jrwTrans	: CM_JRWTransient;
begin
	// this CM_JRWTrackedItems has just been created in CM_QueryAgentFilter qryAnyDataObject called from BGP_ReportRequest runReport
	foreach jrwTrans in app.myQAFilter.allJRWTransients do
		if jrwTrans.isKindOf(CM_JRWTrackedItems) then
			break;
		endif;
	endforeach;

	if jrwTrans &lt;&gt; null and
	   jrwTrans.isKindOf(CM_JRWTrackedItems) then
		self.myTrackedItem := jrwTrans.CM_JRWTrackedItems.allTrackedItems.first;
		self.printReport();
	endif;

	return null;
epilog
	delete jrwTrans;
end;
</source>
        <Parameter name="_isPrintPreview" type="Boolean"/>
        <Parameter name="_isCSV" type="Boolean"/>
        <Parameter name="_extraDetail" type="CM_ExtraDetail"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
</GUIClass>
