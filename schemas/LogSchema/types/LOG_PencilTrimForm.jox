    <JadeMethod name="populateTblNewSpecs" id="e290acc0-689a-4c07-8df9-1f89b7972341">
        <source>populateTblNewSpecs();
//--------------------------------------------------------------
//Created: 11 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	productLog : CM_ProductLog;
	assist : LOG_Assistant;
//	tmpCodeGroup		: CM_CodesByCodeDict;
//	codeGrpLogType 		: CM_LogTypeByCodeDict;
//	codeGrpTreatment	: CM_LogTreatmentsByCodeDict;
//	codeGrpLength		: CM_LogLengthsByCode;	
begin
	
	tblNewSpecs.clearValues();
	if self.myCurrentSOHLocation = null then
		return;
	endif;
	
	productLog := myCurrentSOHLocation.myProduct.CM_ProductLog;
	
	if productLog = null then
		return;
	endif;
	
	assist := self.myAssistant.LOG_Assistant;
	assist.comboBoxLogLotOperators(self.cmbSupplier, self.myCurrentLogLot, myCurrentSOHLocation.myOperator);		
	cmbSupplier.lostFocus(cmbSupplier);
	
//	tmpCodeGroup := myCurrentSOHLocation.myOperator.getAllLogSpecies();
//	assist.comboBoxCodes(self.cmbSpecies, productLog.myLogSpecies, tmpCodeGroup, false);
	self.cmbSpecies.setObjectAndOperator(productLog.myLogSpecies, myCurrentSOHLocation.myOperator);
	cmbSpecies.lostFocus(cmbSpecies);
//	tmpCodeGroup := productLog.myLogSpecies.allLogGrades;	
//	assist.comboBoxCodes(self.cmbGrade, productLog.myLogGrade, tmpCodeGroup, false);
	self.cmbGrade.setObjectAndSpecies(productLog.myLogGrade,productLog.myLogSpecies);
	cmbGrade.lostFocus(cmbGrade);
//	codeGrpLogType := productLog.myLogGrade.allLogTypes;
//	assist.comboBoxLogType(self.cmbType, productLog.myLogType, codeGrpLogType, false);
	self.cmbType.setObjectAndGrade(productLog.myLogType,productLog.myLogGrade);
	cmbType.lostFocus(cmbType);
//	codeGrpTreatment := productLog.myLogGrade.allLogTreatments;	
//	assist.comboBoxLogTreatment(self.cmbTreatment, productLog.myLogTreatment, codeGrpTreatment, false);
	self.cmbTreatment.setObjectAndGrade(productLog.myLogTreatment, productLog.myLogGrade); 
	cmbTreatment.lostFocus(cmbTreatment);
//	codeGrpLength := productLog.myLogGrade.allLogLengths;		
//	assist.comboBoxLogLength(self.cmbLength, productLog.myLogLength, codeGrpLength, false);
	self.cmbLength.setObjectAndGrade(productLog.myLogLength, productLog.myLogGrade); 
	cmbLength.lostFocus(cmbLength);					

end;</source>
    </JadeMethod>
    <JadeMethod name="setCMIF_LogRegrade" id="399b26a5-9a3c-4c80-b575-dbc821f00e87">
        <updating/>
        <source>setCMIF_LogRegrade(_logRegrade : CMIF_LogRegrade input; _sohLocn : CM_SOHLocation) updating;
//--------------------------------------------------------------
//Created: 11 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	operator		: CM_Operator;
	species,
	grade	, treatment,
	type	, length: String;
	sedMIN, sedMAX	: Decimal[12,2];		
	isLogId			: Boolean;
	regradeCode		: CM_LogRegradeCode;
begin

	operator 	:= self.cmbSupplier.listObject.CM_Operator;
	species		:= self.tblNewSpecs.getValueByName(ETRow_LogSpeciesCode).String;
	grade		:= self.tblNewSpecs.getValueByName(ETRow_LogGradeCode).String;	
	treatment	:= self.tblNewSpecs.getValueByName(ETRow_LogTreatmentCode).String;
	type		:= self.tblNewSpecs.getValueByName(ETRow_LogTypeCode).String;
	length		:= self.tblNewSpecs.getValueByName(ETRow_Length).String;
	regradeCode := self.cmbRegrade.listObject.CM_LogRegradeCode;
	
	_logRegrade.init(operator, species, grade, treatment, type, length,
					 sedMIN, sedMAX, isLogId, regradeCode, _sohLocn.allTrackedItems);

end;</source>
        <Parameter name="_logRegrade" type="CMIF_LogRegrade" usage="input"/>
        <Parameter name="_sohLocn" type="CM_SOHLocation"/>
    </JadeMethod>
