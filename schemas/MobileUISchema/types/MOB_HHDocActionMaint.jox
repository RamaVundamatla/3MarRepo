    <JadeMethod name="setupForm" id="bbc7fe98-76fe-43ec-afad-e0fb10ff686c">
        <updating/>
        <source>setupForm() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 November 2016	cnwndl1	Initial creation	TFS 2918 / 2419

*/

vars

	errMess : String;
	resDetStr : String;
	str : String;
	ti : CM_TrackedItem;

begin

	self.setupCmdButtons( 2, app.getErrorString(Save), app.getErrorString(Back), null, null, null );
	
	if not self.myMobileGenericAgent.allReserveDetails.isEmpty then
		self.myReserveDetail := self.myMobileGenericAgent.allReserveDetails.first();
		if self.myReserveDetail &lt;&gt; null then
			self.myDocumentAction := self.myReserveDetail.myReserveDetailActions;
		endif;
	endif;
	if not self.myMobileGenericAgent.allBookingRefItems.isEmpty then
		self.myBookingRefItem := self.myMobileGenericAgent.allBookingRefItems.first();
		if self.myBookingRefItem &lt;&gt; null then
			self.myDocumentAction := self.myBookingRefItem.myBookingRefItemActions;
		endif;
	endif;

	inheritMethod();
	
	self.setupControls();
	
	if self.myDocumentAction &lt;&gt; null then
		self.caption := self.caption &amp; " " &amp; self.myDocumentAction.getParentDocId &amp; "  /  " &amp; self.myDocumentAction.getDocumentId;
		if self.myDocumentAction.isBookingItemAction then
			self.allowMaint := app.myCurrentUserCan( self.myTerminal, PmGteBookingRefMaint ) and app.myCurrentUserCan( self.myTerminal, PmAdmDocActionsMaint );
		elseif self.myDocumentAction.isReserveDetailAction then
			self.allowMaint := app.myCurrentUserCan( self.myTerminal, PmGteEmptyReleaseMaintAll ) and app.myCurrentUserCan( self.myTerminal, PmAdmDocActionsMaint );
		endif;
		//20 Dec 2016	NDL	Remove again TFS 3122 / 2419/ 2001
		//if not self.myDocumentAction.validateChangeActions(false,errMess) then
		//	self.allowMaint := false;
		//	app.msgBox(errMess,app.getErrorString(Warning),MsgBox_OK_Only);
		//endif;
	elseif self.myBookingRefItem &lt;&gt; null then
		self.caption := self.caption &amp; " " &amp; self.myBookingRefItem.myBookingReference.bookingReference &amp; "  /  " &amp; self.myBookingRefItem.getDisplayString;
		self.allowMaint := app.myCurrentUserCan( self.myTerminal, PmGteBookingRefMaint ) and app.myCurrentUserCan( self.myTerminal, PmAdmDocActionsMaint );
	elseif self.myReserveDetail &lt;&gt; null then
		resDetStr := self.myReserveDetail.myReserveHeader.getDescription(false) &amp; "  /  ";
		if self.myReserveDetail.isKindOf(CM_ReserveSelection) then
			resDetStr := resDetStr &amp; self.myReserveDetail.getTotalRequestedDisplay() &amp; ' x ' &amp; self.myReserveDetail.getProductISOTypeDescr();
			if self.myReserveDetail.getCargoType = null then	
				resDetStr := resDetStr &amp; " " &amp; app.getErrorString(Unspecified_Cargo_Type);
			endif;
		elseif self.myReserveDetail.isKindOf(CM_ReserveTI) then
			ti := self.myReserveDetail.CM_ReserveTI.getTI;
			if ti &lt;&gt; null then
				str := self.myReserveDetail.CM_ReserveTI.getTotalRequestedDisplay();
				if str = 0.String then
					str := null;
				endif;
				if str &lt;&gt; null then
					str := str &amp; " x " ;
				endif;
				resDetStr := resDetStr &amp; str &amp; ti.id;
			endif;
		endif;
		self.caption := self.caption &amp; " " &amp; resDetStr;
		self.allowMaint := app.myCurrentUserCan( self.myTerminal, PmGteEmptyReleaseMaintAll ) and app.myCurrentUserCan( self.myTerminal, PmAdmDocActionsMaint );
	endif;
	
	self.btnOne.enabled := self.allowMaint;
	self.btnAdd.enabled := self.allowMaint;
	self.btnRemove.enabled := self.allowMaint;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
