    <JadeMethod name="doBtnLinesNewClick" id="155b0289-2f4c-4a66-a904-9e27f808371a">
        <updating/>
        <source>doBtnLinesNewClick() updating, protected;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin

	// 35872 use parent form business unit
	self.loadMappingsAddRow(self.tblLines.rows + 1, self.myTranMapForm.myCurrentBank.voidInvoiceLineDesc, self.myTranMapForm.myCurrentBank.getInvLineGroupAll(), null, null, null, null, null);
	self.doSBMapSetEnableObjects();
	
	self.recolourTable(self.tblLines);
	
end;</source>
