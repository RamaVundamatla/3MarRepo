    <JadeMethod name="getPath" id="accbab21-c9d0-43d2-936b-126b4f68ea19">
        <source>getPath(): String;

vars
	path	: String;
begin
	path := self.myServiceBroker.getPath() &amp; "/";
	if self.myDebtorNode = null then
		path := path &amp; "Default (Debtor)";
	else
		path := path &amp; self.myDebtorNode.name;
	endif;

	return path;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
