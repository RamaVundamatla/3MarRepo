    <JadeMethod name="delete" id="13bd2975-0fd1-4d58-91c7-7547bcc2f146">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
13 May 2019		jlgmd1	Initial creation TFS 39667 - JMT - API Documentation

*/

vars

begin
	if self.allInputs.size &gt; 0 then
		self.allInputs.purge();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getMethodOutput" id="46221cd0-584e-4f0c-9bb6-c270d2b8f2b7">
        <source>getMethodOutput() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
13 May 2019		jlgmd1	Initial creation TFS 39667 - JMT - API Documentation

*/

vars
	idx			: Integer;
	retClass	: String;
begin
	// something(a, b : String; c : Integer input; d : StringArray output) : Boolean;
	// something() : WS_Response;
	// updateOrAddWagon(request : WS_WagonAddOrUpdRequest) : WS_WagonAddOrUpdResponse updating, webService;
	//																						  ^ &lt;-- this!

	if self.signature &lt;&gt; null then
		idx := 1;
		retClass := self.signature.reverse.scanUntil(":", idx).reverse;
		
		idx := 1;
		// Skip any spaces at the beginning
		retClass.scanWhile(" ", idx);
		// Strip anything after a space or ; at the end
		retClass := retClass.scanUntil("; ", idx);
		
		return retClass;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
