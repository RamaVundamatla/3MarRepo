    <JadeMethod name="finish" id="05d5d470-1e2f-4a8f-b0a8-441610dc4989">
        <updating/>
        <source>finish() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2021	navndl1	Initial creation	TFS 51443

*/

vars

begin

	inheritMethod();

//	self.endClassNotification( BGP_DeferredChargingRequest, false,  Object_Create_Event );
	if self.timerInProgress then
		self.endTimer( DeferredMinTimer );
	endif;
	
epilog

	self.causeEvent( EVENT_Upd_BGP_Deferred_Cont, true, 0 );

end;</source>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="7fb12a27-b3e6-45c5-af8f-9508a02ccea2">
        <source>getDisplay(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 July 2021	navndl1	Initial creation	TFS 51443

*/

vars

	start,
	queued	: String;
	request : BGP_Request;
	invalid	: Boolean;
	new : Integer;
	retry : Integer;
	beingProcessed : Integer;

begin

	on Exception do self.xHandlerDisplay(exception);

	request :=  self.myCurrentRequest;
	if request &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, request, invalid);
		start := request.processingStartTime.bgpDisplay();
		on Exception do null;
	endif;

	if self.myDeferredChargesRoot = null then
		queued := null;
	else
		new := self.myDeferredChargesRoot.allNewDeferredReqs.size;
		retry := self.myDeferredChargesRoot.allRequestsToRetry.size;
		beingProcessed := self.myDeferredChargesRoot.allRequestsBeingActioned.size;
		if new = 0 and retry = 0 and beingProcessed = 0 then
			queued := null;
		else
			queued := new.asStringJMT &amp; " new, " &amp; retry.asStringJMT &amp; " to retry, " &amp; beingProcessed.asStringJMT &amp; " processing"; 
		endif;
	endif;	
	
	return Tab &amp; Tab &amp; Tab &amp; self.displayString &amp; Tab &amp;
							self.machineName &amp; Tab &amp;
							self.dateTimeLastStarted.bgpDisplay() &amp;  Tab &amp;
							queued &amp; Tab &amp;
							start &amp; Tab &amp;
							self.dateTimeLastCompleted.bgpDisplay() &amp; Tab &amp;
							self.isRunning().asRunningStopped(self.isSetup) &amp; Tab &amp;
							self.isRunningSDSDisplay();

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initApp" id="42d9b475-72cd-4626-8322-82e68e24f4e8">
        <updating/>
        <source>initApp() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2021	navndl1	Initial creation	TFS 51443

*/

vars

	load : Boolean;
	str : String;
	msg : String;

begin

	on Exception do self.xHandlerGlobal(exception) global;
	on LockException do app.alertLockExceptionHandler(exception) global;
	
	str := self.getOidString();
	str.replaceChar('.' , '_');
	app.logFileNameSpecific := 'BGPController_' &amp; self.logFileName() &amp; '_' &amp; str; 
	
	app.setCnAppAlias(self.class.name);	
	
	app.initialize();

	app.setIsBackGroundApp(true);
 	app.cmsBeginLoad( load );
	exclusiveLock(self);
	if self.isRunning() then
		app.isBGPAppAbort := true;
		msg := 'ERR &gt;&gt; app is already running';
		app.writeLog(msg, LogFATAL);
		
		app.exitLogFile();
		terminate;
	endif;
	
	if app.myPassport &lt;&gt; null then
 		app.myPassport.setMyUser(self.myUser);
  	endif;
	app.myTrxUA.trxUpdateBGPControllerProcess(self, process, process.signOnTime, true, app.myPassport);
	
	self.beginNotification(self, BGP_Object.BGP_TerminateAppRequest, Response_Cancel , null);
	self.beginNotification(self, BGP_Object.BGP_DebugLevelChangeEvent, Response_Continuous , null);
	self.beginNotification(self, BGP_Object.BGP_OutputInfo, Response_Continuous , null);
	self.beginNotification(self, BGP_Object.BGP_ApplicationStartRequest, Response_Continuous , null);
	
	self.beginClassNotification( BGP_DeferredChargingRequest, false,  Object_Create_Event, Response_Continuous , null);
	
	beginTransaction;
	self.working := true;
	commitTransaction;
	self.causeEvent( EVENT_Upd_BGP_Deferred_Cont, true, 0 );
	
	self.wakeMeUp();
	
epilog

	app.cmsEndLoad( load );
	
end;</source>
    </JadeMethod>
    <JadeMethod name="processCharges" id="0c712ff1-5dc7-47af-9082-cf072edec773">
        <source>processCharges( _doSetTimer : Boolean output; _noneLeft : Boolean output );
/*

Purpose:			Finds a request to process and if its successfull, gets rid of the request.

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2021	navndl1	Initial creation	TFS 51443

*/

vars
	
	request : BGP_DeferredChargingRequest;  //Essentially a pointer to a CM_Transaction that needs to behave its charges calculated.
	oneMinute : TimeStampInterval;
	aMinuteAgo : TimeStamp;
	iter : Iterator;
	aReq : BGP_DeferredChargingRequest;
	success : Boolean;
	trx : CM_Transaction;
	deleteRequest : Boolean;

begin

	request := self.myDeferredChargesRoot.allNewDeferredReqs.first();
	
	if request = null then
		oneMinute.set(0,60000);
		aMinuteAgo := app.actualTimeServer - oneMinute;
	else
		app.writeLog(method.qualifiedName &amp; "-found new one", LogTRACE);
	endif;
	
	if request = null
	and not self.myDeferredChargesRoot.allRequestsToRetry.isEmpty
	then 	
		iter := self.myDeferredChargesRoot.allRequestsToRetry.createIterator;
		while iter.next( aReq ) do
			if not aReq.lastRetryTS.isValid or aReq.lastRetryTS &lt; aMinuteAgo then
				//It hasn't been retired yet or was last retried more than a minute ago
				request := aReq;
				app.writeLog(method.qualifiedName &amp; "-found a retry", LogTRACE);
				break;
			endif;
		endwhile;
		delete iter;
	endif;
	
	if request = null
	and not self.myDeferredChargesRoot.allRequestsBeingActioned.isEmpty
	then
		iter := self.myDeferredChargesRoot.allRequestsBeingActioned.createIterator;
		while iter.next( aReq ) do
			if not aReq.processingStartTime &lt; aMinuteAgo then
				//If it was started more than a minute ago, sounds like a nasty fail
				//lets try processing it.
				app.writeLog(method.qualifiedName &amp; "-found an old 'being processed'", LogTRACE);
				request := aReq;
				break;
			endif;
		endwhile;
		delete iter;
	endif;
	
	if request = null then
		if self.myDeferredChargesRoot.allRequestsToRetry.isEmpty
		and self.myDeferredChargesRoot.allRequestsBeingActioned.isEmpty
		then
			app.writeLog(method.qualifiedName &amp; "-None left", LogTRACE);
			_noneLeft := true;
		else
			app.writeLog(method.qualifiedName &amp; "-Some more, but nothing ready", LogTRACE);
			_doSetTimer := true;
		endif;
		return;
	endif;
	
	
	trx := request.myTransaction;
	if trx = null then
		deleteRequest := true;
		app.writeLog(method.qualifiedName &amp; "-Request with no trx", LogTRACE);
	else
		on Exception do app.handleDeletedObject( exception, trx, deleteRequest );
		if trx.isDeleted then
			deleteRequest := true;
			app.writeLog(method.qualifiedName &amp; "-Request trx marked as 'deleted'", LogTRACE);
		endif;
	endif;
	
	if not deleteRequest then
		app.writeLog(method.qualifiedName &amp; "-processing " &amp; request.getName, LogTRACE);
		success := request.action();
	endif;
	
	if success or deleteRequest then
		//its all good, get rid of it.
		beginTransaction;
		delete request;
		commitTransaction;
	endif;

epilog

	delete iter;

end;</source>
        <Parameter name="_doSetTimer" type="Boolean" usage="output"/>
        <Parameter name="_noneLeft" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="setAttributesForCreate" id="a743403d-89b4-4a9f-a338-9e2e68ec6099">
        <updating/>
        <source>setAttributesForCreate() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2021	navndl1	Initial creation	TFS 51443

*/

vars

begin
	self.name				:= 'Deferred Trx Charging';
	self.schemaName			:= 'UiCommonSchema';
	self.isEditable			:= true;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
