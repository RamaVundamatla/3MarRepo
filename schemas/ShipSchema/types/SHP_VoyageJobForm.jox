    <JadeMethod name="setControlsForAddEdit" id="0eb1dd0b-617a-4ef2-9e0a-897bdaa74886">
        <updating/>
        <source>setControlsForAddEdit() updating;
//--------------------------------------------------------------
//Created: 23 April 2003 By: cnwgd1
//--------------------------------------------------------------
// 16/05/2016	cnwns1	TFS 488 - Multi Timezone Support
// 07/03/2017	cnwdap1	TFS 3516 LNX Hold Planning Quantity
// 22/04/2020   cnwma1  Bug 49078: MTN - UE Floods
vars
	theJob         : CM_VoyageJob;
	jobSheet       : CM_VoyageJobSheet;
	sysRemark      : CM_PredefinedRemark;
	theJobType     : CM_JobType;
	invalidJobType : Boolean;
	jobTypeOid 	   : String;
	craneObject	   : CM_Object;
	theBay         : CM_Bay;
	aHLJob         : CM_VoyageHatchLidJob;
	nowLocal       : TimeStamp;
begin
	self.tblJobEdit.userInputEnabled:=true;
	
	self.tblJobEdit.showRowByName(ETRow_BayId,false);
	self.tblJobEdit.hideRowByName(ETRow_DeckId,false);
	self.tblJobEdit.showRowByName(ETRow_JobTypeId,false);
	self.tblJobEdit.showRowByName(ETRow_TheHatchLids,false);
	
	self.tblJobEdit.hideRowByName(ETRow_JobStatus,false);
	self.tblJobEdit.hideRowByName(ETRow_LoadedToOps,false);
	self.tblJobEdit.hideRowByName(ETRow_JobCreatedDate,false);
	
	self.doComboCraneWorkPointBuild();
	
	if self.mode = Mode_Add then
		self.cmbHatchLids.setSelected(null);
		self.cmbBayId.listObject := null;
		self.tblJobEdit.clearValues();
		self.tblJobEdit.clearAllSelected;
		self.doComboHatchLidsBuild();
		return;
	endif;
	
	theJob := self.myProxyObject.CM_VoyageJob;
	if self.myCurrentObject.CM_Job.status = JOB_COMPLETE then
		self.tblJobEdit.userInputEnabled:=false;
	endif;
	
	nowLocal := self.systemToLocalTime(app.actualTimeServer);// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	if not theJob.actualStartTs.isValid then
		if self.isStart  then
			self.tblJobEdit.setValueByName(ETRow_ActualStartDate,	nowLocal.date);		// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			self.tblJobEdit.setValueByName(ETRow_ActualStartTime, nowLocal.time.Time);	// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
	endif;
	if not theJob.actualEndTs.isValid then
	if self.isEnd then
			self.tblJobEdit.setValueByName(ETRow_ActualEndDate,	nowLocal.date);			// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			self.tblJobEdit.setValueByName(ETRow_ActualEndTime, nowLocal.time.Time);	// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;	
	endif;
	
	jobSheet:=theJob.myVoyageJobSheet;
	if jobSheet &lt;&gt; null then	
		//if jobSheet.isKindOf(CM_VoyageDeckJobSheet) then		// TFS 3516
		if jobSheet.isKindOf(CM_VoyageDeckJobSheet) 			// TFS 3516
		or jobSheet.isKindOf(CM_VoyageHoldJobSheet) then		// TFS 3516
			craneObject :=jobSheet.myWorkPoint;
		else
			craneObject := jobSheet.getMyCrane;		
		endif;
		self.cmbCrane.listObject := craneObject;
	endif;
	
	sysRemark := app.myRoot.allPreDefinedRemarks[theJob.systemRemarks.trimBlanks];
	self.cmbSysRemarks.listObject := sysRemark;
	
	on Exception do app.handleDeletedObject(exception,theJobType,invalidJobType);
	
	if theJob.jobType = JOB_TYPE_USER then
		theJobType:=theJob.myUserJobType;
		//epr TFS 1924 29/4/16
		if theJobType &lt;&gt; null then
			jobTypeOid:=theJobType.getOidString;
			if not invalidJobType then
				self.cmbJobType.listObject := theJob.myUserJobType;
			endif;
		endif;
		
		// all user defined jobs are hatch lid jobs
		if self.myProxyObject.isKindOf(CM_VoyageHatchLidJob) then  //22.04.2020 cnwma1 #49078
			aHLJob := self.myProxyObject.CM_VoyageHatchLidJob;
		endif;
		
		if  aHLJob &lt;&gt; null and aHLJob.myDeck &lt;&gt; null  then  //22.04.2020 cnwma1 #49078
			self.tblJobEdit.hideRowByName(ETRow_BayId,false);
			self.tblJobEdit.showRowByName(ETRow_DeckId,false);
			self.cmbDeckId.listObject := aHLJob.myDeck;
			self.tblJobEdit.hideRowByName(ETRow_TheHatchLids,false);
		else
			
			theBay := self.filterVoyage.myCellularVoyageStructure.allBayVoyagesById[aHLJob.bayId.trimBlanks];
			self.cmbBayId.listObject := theBay;
			self.doComboHatchLidsBuild();
			self.cmbHatchLids.setSelected(aHLJob.allHatchLids);
		endif;
	else
		self.tblJobEdit.hideRowByName(ETRow_BayId,false);
		self.tblJobEdit.hideRowByName(ETRow_JobTypeId,false);
		self.tblJobEdit.hideRowByName(ETRow_TheHatchLids,false);
	endif;
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForView" id="d59e7f62-d6e0-47a9-801c-c017b1e1cfa5">
        <updating/>
        <source>setControlsForView() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 July 2011	cnwer1	Initial creation CCMS MES 1033
*/

vars

begin
	
	self.tblJobEdit.userInputEnabled:=false;
	
	self.tblJobEdit.showRowByName(ETRow_JobTypeId,false);
	self.tblJobEdit.showRowByName(ETRow_LoadedToOps,false);
	self.tblJobEdit.showRowByName(ETRow_JobCreatedDate,false);
	self.tblJobEdit.showRowByName(ETRow_JobStatus,false);
	
epilog

end;</source>
