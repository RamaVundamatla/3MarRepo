    <JadeMethod name="setupCargo" id="3d462739-1c68-41fd-ae1d-e05190fdfd1b">
        <updating/>
        <source>setupCargo() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 January 2010	cnwndl1	Initial creation	CCMS MES 1005


*/

vars
	
begin
	
	self.setupOnTruck();
	self.setupReserveSelect();
	self.setupForNotifications();
	self.doResizeControls(true);
	self.showAmounts();
	if self.inYardButtonCount &gt; 0 then	
		self.shtInYard.setFocus();
	else
		self.shtOnTruck.setFocus();
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForNotifications" id="705b408f-26d6-4073-9974-1d1c2dafa5a9">
        <source>setupForNotifications( ) protected;
/*

Date		Who		Reason
22 September 2015	cnwer1	Initial creation PAR

*/

vars
	wle : CM_WorkListEntry;
begin
	
	self.endNotifications();
	foreach wle in self.myMobileGenericAgent.allLoadedWles do
		self.beginNotification( wle, wle.getMyTerminal.getTerminalEvent(WLE_Status_Event), Response_Continuous, 0 );
	endforeach;
	
	foreach wle in self.myMobileGenericAgent.allWlesToLoad do
		self.beginNotification( wle, wle.getMyTerminal.getTerminalEvent(WLE_Status_Event), Response_Continuous, 0 );
	endforeach;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="cb782d6d-2bd9-409e-8944-5cc5e4d93cb2">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 January 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars
	truck : CM_Vehicle;
begin

	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	truck := self.myMobileGenericAgent.myTruck;

	if truck &lt;&gt; null then
		self.caption := self.caption &amp; " " &amp; truck.getDisplayDetails(true);
	endif;
	
	inheritMethod();
	
	self.setupCmdButtons( 2, app.getErrorString(Complete), app.getErrorString(Back), null, null, null );
	
		
	self.setupCargo();
	

	
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupOnTruck" id="fe7406e1-3282-4f29-944d-6faeabe1c486">
        <updating/>
        <source>setupOnTruck() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 January 2010	cnwndl1	Initial creation	CCMS MES 1005
22 May 2013	NDL	- CCMS 2274 Break Bulk
*/

constants

	TAB_INDEX_START = 1000;
	
vars

	menuButton : MOB_Button;
	buttonOffset : Integer;
	buttonNumber : Integer;
	buttonWidth : Real;
	tiArray: CM_TIArray;
	ti : CM_TrackedItem;
	size : Integer;
	buttonHeight : Integer;	
	
begin
	self.myMobileGenericAgent.setTruck(self.myMobileGenericAgent.myTruck);
	tiArray := self.myMobileGenericAgent.allLoadedTis;
	size := tiArray.size;
	
	while self.onTruckButtonCount &gt; size do
		menuButton:= self.btnOnTruckTemp.getControl(self.onTruckButtonCount).MOB_Button;
		if menuButton &lt;&gt; null then
			delete menuButton;
		endif;
		self.onTruckButtonCount:=self.onTruckButtonCount -1;
	endwhile;
	
	buttonHeight := self.getScrollingButtonHeight();
	self.btnOnTruckTemp.height := buttonHeight;
	buttonWidth := getButtonWidthSetScrollBar( size, self.frmCargoOnTruck, self.btnOnTruckTemp.height, self.scrCargoOnTruck );

	self.onTruckButtonCount := 0;
	foreach ti in tiArray do
		
		buttonNumber := buttonNumber + 1;
		menuButton:= self.btnOnTruckTemp.getControl(buttonNumber).MOB_Button;
		if menuButton = null then
			menuButton := self.btnOnTruckTemp.loadControl( buttonNumber ).MOB_Button;
		endif;
		menuButton.move(0, buttonOffset, buttonWidth, buttonHeight-4 );
		
		menuButton.userObject := ti;
		if ti.canSplitTotalQuantity and ti.isBulkByQuantity then
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.totalQuantity.String &amp; ")" ;
		elseif ti.isBulkByWeight and ti.isBulkByVolume then
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.CM_Bulk.getBulkTrackByDisplayForWeight(true) &amp; ")"; 
		else
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id ;
		endif;
		
		self.addHazDetailsToButton( menuButton, ti, CrLf ); //30 May 2017	NDL	TFS 4587
		
		buttonOffset := buttonOffset + buttonHeight-2;
		menuButton.tabIndex := TAB_INDEX_START + buttonNumber;
	endforeach;
		
	self.onTruckButtonCount := buttonNumber;
	
	self.btnOnTruckTemp.visible := false;
	self.frmCargoOnTruck.caption := null;
	
	if size = 0 then
		lblNoCargoTruck.visible := true;
	else
		lblNoCargoTruck.visible := false;
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupReserveSelect" id="fa858b89-f82a-4c74-abf6-311283ec50d5">
        <updating/>
        <source>setupReserveSelect() protected, updating;
/*

Date		Who		Reason
11 September 2015	cnwer1	Initial creation PAR
30 Aug     2016 TFS #2597:PEN - Truck Warehouse Release Loader not showing all Rel Req lines
*/
constants

	TAB_INDEX_START = 1000;
	
vars
	wle : CM_WorkListEntry;
	truck : CM_Vehicle;
	job 	: CM_RoadJob;
	buttonHeight,
	buttonWidth : Real;
	buttonNumber,
	size : Integer;
	menuButton : MOB_Button;
	buttonOffset : Real;
	reserveDetail : CM_ReserveDetail;
	buttonCaption : String;
	sortedTIRequests		: DynaDictionary;
	iter : Iterator; 
	currentReseveDetailDesc,
	reserveDetailDesc : String;
	reserveAmount 	: String;
	moveQuantity : Integer;
	moveWeight 	: Decimal[14,4];
	cargoType : CM_CargoType;
begin
	
	truck:=self.myMobileGenericAgent.myTruck;
	job:=truck.getCurrentRoadJob;
	
	buttonHeight := self.getScrollingButtonHeight();
	buttonWidth := getButtonWidthSetScrollBar( size, self.frmCargoInYard, self.btnReserveSelect.height, self.scrCargoInYard );
	create sortedTIRequests transient;
	sortedTIRequests.setMembership(CM_WorkListEntry);
	sortedTIRequests.addExternalKey(String,50,true,false); //cargo product description    //30/9/2014  cnwma1 PAR#34956
	sortedTIRequests.endKeys(true);
	
	foreach wle in job.workListEntries where wle.status &lt;&gt; WLE_COMPLETED do
		if wle.myRequest = null then
			continue;
		endif;
	
		reserveDetail:=wle.myRequest.myReserveDetail;	
		if reserveDetail.myReserveHeader = null then
			continue;
		endif;	
		if wle.isReleaseByType then		
			if wle.myTrackedItem &lt;&gt; null then
				continue;
			endif;		
		endif;
		sortedTIRequests.putAtKey(reserveDetail.myReserveHeader.code &amp; " " &amp;  reserveDetail.getProductISOTypeDescr(), wle);
	endforeach;
	
	iter:= sortedTIRequests.createIterator;
	while iter.next(wle) do
		iter.getCurrentKeys(reserveDetailDesc);
		reserveDetail:=wle.myRequest.myReserveDetail;
		if currentReseveDetailDesc &lt;&gt; reserveDetailDesc then	
			buttonNumber := buttonNumber + 1;
			menuButton:= self.btnReserveSelect.getControl(buttonNumber);
			if menuButton = null then
				menuButton := self.btnReserveSelect.loadControl( buttonNumber ).MOB_Button;
			endif;
			menuButton.move(0, buttonOffset, buttonWidth, buttonHeight-4 );
			
			buttonCaption := null;
			create menuButton.userObject as CM_WLEArray transient;
			allTransientObjs.add(menuButton.userObject);
			moveQuantity:=null;
			moveWeight:=null;
			cargoType:=reserveDetail.getCargoType();
			
			buttonCaption:=reserveDetail.myReserveHeader.code &amp; " ";
			buttonCaption:=buttonCaption &amp;  reserveDetail.getRemainingAmountForJob(job)   &amp;  " x " &amp;  reserveDetail.getProductISOTypeDescr; // wle.getMoveAmountDisplay(true)
			
			menuButton.caption := buttonCaption;
			buttonOffset := buttonOffset + buttonHeight-2;
			menuButton.tabIndex := TAB_INDEX_START + buttonNumber;
			
			currentReseveDetailDesc:=reserveDetailDesc;
		endif;
		menuButton.userObject.CM_WLEArray.add(wle);

		//if reserveDetail.isKindOf(CM_ReserveTI) then  //30/08/2016 cnwma1 TFS #2597
			if cargoType.isBulkMulti then
				moveWeight:=moveWeight + wle.weight;
				reserveAmount:=wle.getMoveAmountForWeight(moveWeight,true);
			else
				moveQuantity:= moveQuantity + wle.getQuantity;
				reserveAmount:=moveQuantity.asStringJMT;
			endif;
			menuButton.caption :=reserveDetail.myReserveHeader.code &amp; " " &amp; reserveAmount &amp;  " x " &amp;  reserveDetail.getProductISOTypeDescr; 
		//endif;
	endwhile;
	
	
	while self.inYardButtonCount &gt; buttonNumber do
		menuButton:= self.btnReserveSelect.getControl(self.inYardButtonCount).MOB_Button;
		if menuButton &lt;&gt; null then
			delete menuButton;
		endif;
		self.inYardButtonCount:=self.inYardButtonCount -1;
	endwhile;
	
	
	self.inYardButtonCount := buttonNumber;	//05 Aug 2014	NDL	Par 34675

	
	self.btnReserveSelect.visible := false;
	self.frmCargoInYard.caption := null;
	
epilog
	delete sortedTIRequests;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showAmounts" id="7b303a3d-da94-4fc1-8df8-e4f905946f56">
        <source>showAmounts() protected;
/*

Date		Who		Reason
15 September 2015	cnwer1	Initial creation PAR

*/

vars
	truck : CM_Vehicle;
	ti : CM_TrackedItem;
	weight : Decimal[14,4];
	totWeight : Decimal[18,4];
begin
	truck := self.myMobileGenericAgent.myTruck;
	
	if truck = null then
		lblWeightValue.caption := app.getErrorString(CM_Load_Weight) &amp; " : ";
		lblCountValue.caption := app.getErrorString(Count) &amp; " : ";
	else
		foreach ti in self.myMobileGenericAgent.allLoadedTis do
			weight := ti.totalWeight;
			totWeight := totWeight + weight;
		endforeach;
		lblWeightValue.caption := app.getErrorString(CM_Load_Weight) &amp; " : " &amp; self.myMobileDataAgent.getMeasureConvertedForDisplay(null,Type_Weight,totWeight) &amp; self.myMobileDataAgent.getMeasureLabelUnit(null,Type_Weight);
		lblCountValue.caption := app.getErrorString(Count) &amp; " : " &amp; self.myMobileGenericAgent.getOnTruckCargoCount().String;
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="d228d73d-bc52-487a-a8f6-025c7d2adbf8">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 22 September 2015.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0020930, locale);
	//btnOnTruckTemp.translateCaption(Xlat_0020962, locale);
	//btnReserveSelect.translateCaption(Xlat_0020963, locale);
	//frmCargoOnTruck.translateCaption(Xlat_0020964, locale);
	//lblCountValue.translateCaption(Xlat_0020965, locale);
	//lblNoCargoTruck.translateCaption(Xlat_0020966, locale);
	//lblWeightValue.translateCaption(Xlat_0020967, locale);
	shtInYard.translateCaption(Xlat_0020935, locale);
	shtOnTruck.translateCaption(Xlat_0020936, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
