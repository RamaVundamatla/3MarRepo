    <JadeMethod name="utlAmendBreakBulkRTQuantity" id="ae828e20-1db6-4843-a0ba-342a84124bc9">
        <updating/>
        <source>utlAmendBreakBulkRTQuantity( _wle : CM_WorkListEntry; _newQuantity : Integer; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 May 2013	cnwrd1	Initial creation

*/

vars
	aWle : CM_WorkListEntry;
	aEntry	: CM_RTQueueEntry;
begin

	self.initialiseActivity();
	
	aWle := _wle;

	if _newQuantity = 0 then
		return;
	endif;
	
	if aWle.quantity &lt;&gt; _newQuantity then
		aWle.setQuantity(_newQuantity);
	
		foreach aEntry in aWle.allRTQueueEntries do
	//	aEntry := aWle.allRTQueueEntries.first;	
			if aEntry &lt;&gt; null then
			// send notes for RT entries
				aEntry.setQuantity(_newQuantity);
				app.myEventManager.createSingleObjInfoNoteEvt( aEntry,app.myPassport.myTerminal.getTerminalEvent(RTQueueEntry_Update_Event), null);
			endif;
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_newQuantity" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlAmendBulkRTWeight" id="882d4ee4-87da-4ec2-ade0-6a435cff84e3">
        <updating/>
        <source>utlAmendBulkRTWeight( _wle : CM_WorkListEntry; _newWeight : Decimal; _passport : CM_Passport input) updating;
/*

Date		Who		Reason
09 March 2015	cnwer1	Initial creation PAR 35702

*/

vars
	wle : CM_WorkListEntry;
	entry	: CM_RTQueueEntry;
begin

	self.initialiseActivity();
	if _newWeight = 0 then
		return;
	endif;
	
	//13 Apr 2016	NDL	TFS 1809
	wle := _wle;
	if wle = null then
		return;
	endif;
	
	if wle.weight &lt;&gt; _newWeight then
		wle.setWeight(_newWeight);
	
		foreach entry in wle.allRTQueueEntries do
			if entry &lt;&gt; null then
			// send notes for RT entries
				entry.setWeight(_newWeight);
				app.myEventManager.createSingleObjInfoNoteEvt( entry,app.myPassport.myTerminal.getTerminalEvent(RTQueueEntry_Update_Event), null);
			endif;
		endforeach;
	endif;

epilog

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_newWeight" type="Decimal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlApplyDeckingRule" id="19122337-981c-45b1-8269-7304341ba02f">
        <updating/>
        <source>utlApplyDeckingRule(_theDeckingOptions: CM_YADeckingOptions; _passport : CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	06 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.initialiseActivity();

	//rearrange all Locn cells based on rules		
	_theDeckingOptions.applyDeckingRulesToCellOrder();

end;</source>
        <Parameter name="_theDeckingOptions" type="CM_YADeckingOptions"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlArchiveEmptyLocation" id="1f1015d0-947c-4e37-be7d-ad37fef7452c">
        <updating/>
        <source>utlArchiveEmptyLocation(_lc : CM_LocationsController input; _emptySince : TimeStamp;
					_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     10 January 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
/* Changes

Date		Name	TFS#		Description
============================================================================
30/05/2019	jlgka1	TFS 44953	C3 - Archive Rows - Recent Rows being Archived.
								Add more audit logging information.
============================================================================*/
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(false);

	sharedLock(_lc);
	
	_lc.validateForArchive(_emptySince);

	if _passport.noErrors() then
		self.myUpdateAuditAgent.audUpdateGeneric(_lc, true);	 // jlgka1 TFS 44958
		_lc.setToArchived();
		self.myUpdateAuditAgent.audUpdateGeneric(_lc, false);	// jlgka1 TFS 44958		
	endif;

end;</source>
        <Parameter name="_lc" type="CM_LocationsController" usage="input"/>
        <Parameter name="_emptySince" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlArchiveVoyage" id="34ea95cb-158e-4c13-a9b6-06040812cf63">
        <updating/>
        <source>utlArchiveVoyage(_voyage : CM_Voyage input; _controller : CMIF_ArchiveVoyage; _passport : CM_Passport input) updating;
/*
------------------------------------------------------------------------
Created:			20 February 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		See Method signature above. Special comment:
Returns:			See Method signature above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars

begin

	self.initialiseActivity();
	
	// do any pre-validation locks
	
	// do validation
	app.raiseCMException2(MethodWithNullParam, method.name, 'Voyage reference', null, null);

	app.setContinueCMExceptions(true);
	
	_voyage.archive(_controller, _passport);

end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_controller" type="CMIF_ArchiveVoyage"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlAssignWleToWagonControllers" id="12039ba2-9a20-48eb-bd6e-0f44e88a12dc">
        <source>utlAssignWleToWagonControllers(_wle : CM_YardWLE input; _stackPos : Integer; _controllers : CM_WagonControllerArray input; _passport : CM_Passport input);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21/08/2009	cnwndl1	Initial creation
08/11/2010	cnwdap1	PAR #23794 CCMS MES 1102 add causeEvent for WLE update so Rail Load List knows the WLE has been planned
*/
vars 

	wagonCont : CM_WagonController;
	lastController : CM_WagonController;
	term : CM_Terminal;
	autoAssignCargoToWagon : Boolean;
	req : CM_Request;
	resDet : CM_ReserveDetail;
	ti : CM_TrackedItem;
	cmif : CMIF_MoveController;
	rrpForRailTI : CM_TrackedItem;
	unplannedQty : Integer;
	unplannedWeight : Decimal [16,4];
	enhancedReleaseHandling : Boolean;
	wagon : CM_Wagon;	//02 Dec 2020	NDL	TFS 50164
	wagons : CM_WagonSet;	//02 Dec 2020	NDL	TFS 50164
	
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(false);
	
	self.raiseExceptionIfNull(_wle, app.getErrorString(Release_request));

	foreach wagonCont in _controllers do
		app.myValUA.valAssignWleToWagonController(_wle, wagonCont, _stackPos, wagonCont);
		lastController := wagonCont;
	endforeach;

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	foreach wagonCont in _controllers do
		_wle.allLocationControllers.add(wagonCont);
		// PAR #23794 create an event for the Rail Load List screen
//		app.myEventManager.createSingleObjInfoNoteEvt(_wle, _passport.myTerminal.getTerminalEvent(WLE_Update_Event), _wle);		// moved down. 	
	endforeach;
	
	//27 Jan 2017	NDL	TFS 3193 Auto assign to box-cars for STW
	term := _wle.getMyTerminal;
	if term = null then
		term := _passport.myTerminal;
	endif;
	if term &lt;&gt; null then
		autoAssignCargoToWagon := term.getConfig( AutoAssignToWagon ).Boolean;
		enhancedReleaseHandling := term.getConfig(RailReleaseAssignEnhance).Boolean;	//02 Dec 2020	NDL	TFS 50164
		wagonCont := _controllers.first;
		req := _wle.myRequest;
	endif;
	
	if  _wle.myTrackedItem &lt;&gt; null and  _wle.myTrackedItem.isRRP then
		rrpForRailTI := _wle.myTrackedItem;
	endif;
					
//	if autoAssignCargoToWagon and req &lt;&gt; null and wagonCont &lt;&gt; null and wagonCont.isBoxcarCont then
	if autoAssignCargoToWagon and req &lt;&gt; null and wagonCont &lt;&gt; null and ( wagonCont.isBoxcarCont or enhancedReleaseHandling ) then	//02 Dec 2020	NDL	TFS 50164
		// TFS 3193 says
		// "if the reserve detail of the WLE has only 1 cargo item assigned then plan that cargo to the WLE.
		// This means that the rail ops will show the cargo ID and the planned wagon:"
		resDet := req.myReserveDetail;
		if resDet &lt;&gt; null then
			ti := resDet.getTiForRailAssignIfOnlyOne();
			if ti &lt;&gt; null and ti.isOnSite then
				ti.getUnPlannedAmount( unplannedQty, unplannedWeight );	//27 Feb 2017	NDL	TFS 3514
				if not ti.isQueued() and not ti.myPrimaryActualLocation.isWagon and ( unplannedQty &gt; 0 or unplannedWeight &gt; 0 ) then
				//	if  _wle.myTrackedItem &lt;&gt; null and  _wle.myTrackedItem.isRRP then
				//		rrpForRailTI := _wle.myTrackedItem; //get a reference to this sucker, so we can delete the RRP if it has one
				//	endif;
					_wle.setMyTrackedItem( ti );
					
					create cmif transient;
					cmif.setMyWorkListEntry(_wle);
					cmif.setMyTrackedItem(ti);
					cmif.setMyToPrimaryLocation(wagonCont);
					cmif.setMoveMode(PLANNING_MODE);
					
					app.myUtilityUA.utlUpdateWLEAssignTI(cmif, _passport);
					
					if rrpForRailTI &lt;&gt; null then
						rrpForRailTI.erase(NORMAL_ERASE);
						rrpForRailTI := null;
					endif;
				
				endif;
			endif;			
		endif;
		
	endif;
	
	//23 Mar 2020	NDL	TFS 47004
	if rrpForRailTI &lt;&gt; null and rrpForRailTI.myRRPTrain = null and wagonCont &lt;&gt; null then
		//RRP must have been generated from a Bulk Release without an assgined train, set it now we know the wagon / train
		rrpForRailTI.setMyRRPTrain( wagonCont.myWagon.myTrainOutwards );
	endif;
	
	create wagons transient;	//02 Dec 2020	NDL	TFS 50164
	foreach wagonCont in _controllers do
		app.myEventManager.createSingleObjInfoNoteEvt(_wle, _passport.myTerminal.getTerminalEvent(WLE_Update_Event), _wle);
		//02 Dec 2020	NDL	TFS 50164
		wagon := wagonCont.myWagon;	
		if wagon &lt;&gt; null then
			wagons.addNoDuplicates( wagon, false );
		endif;
	endforeach;
	
	//02 Dec 2020	NDL	TFS 50164
	foreach wagon in wagons do
		app.myEventManager.createSingleObjInfoNoteEvt(wagon, _passport.myTerminal.getTerminalEvent(Wagon_Update_Event), wagon);
	endforeach;

epilog

	delete cmif;
	delete wagons;
	
end;</source>
        <Parameter name="_wle" type="CM_YardWLE" usage="input"/>
        <Parameter name="_stackPos" type="Integer"/>
        <Parameter name="_controllers" type="CM_WagonControllerArray" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlAttachTIsToBOLDtl" id="6f59ba4c-6917-4119-a7bd-0e9c6a06680c">
        <source>utlAttachTIsToBOLDtl(_tis : CM_TISet input; _bolDtl : CM_BOLDtl input; _passport : CM_Passport input);
vars
	ti : CM_TrackedItem;
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(false);
	
	foreach ti in _tis do
		ti.attachToBOL(_bolDtl.myBOL);
		ti.setBOLDtl(_bolDtl);
	endforeach;	
end;
</source>
        <Parameter name="_tis" type="CM_TISet" usage="input"/>
        <Parameter name="_bolDtl" type="CM_BOLDtl" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlAutoDisabilityUserNotify" id="2a6e380c-20d0-4759-b927-44960650c063">
        <source>utlAutoDisabilityUserNotify(_passport : CM_Passport input);
//12/12/2014  cnwma1 PAR #35328 JH - New User disabled by Administrator
vars
	
	body		: String;
	autoDisabilityPeriod : Integer;
	userSet : CM_UserSet;
	user : CM_User;
	
begin
	
	autoDisabilityPeriod := app.myRoot.getConfig(AutoDisabilityPeriod).Integer;
	if autoDisabilityPeriod = 0 then
		app.remoteErrorWarningToAlert('Input please Auto Disable Inactive User Period (days) in the System Config screen.', null, null, null, false, true);
		return;
	endif;
	
	create userSet transient;
	foreach user in app.myRoot.allUsers discreteLock do
//		if user.code = 'VVV' then
			if user.allowAutomaticDisability  
			  and (user.status &lt;&gt; DisabledBySysAdminUser or not user.isNotAvailableForEntry) then
				if user.lastLoginTS &lt;&gt; null then  				 //12/12/2014 cnwma1 PAR  35328
					if  (app.actualTimeServer.date - user.lastLoginTS.date) &gt; autoDisabilityPeriod then
						userSet.add(user);
					endif;
				elseif  user.lastLoginTS = null then			//12/12/2014 cnwma1 PAR  35328
					if  (app.actualTimeServer.date - user.dateCreated.date) &gt; autoDisabilityPeriod then
						userSet.add(user);
					endif;
				endif;
			endif;
//		endif;
	endforeach;

	if userSet.size = 0 then
		return;
	endif;
	
	body := 'The following user(s) have been automatically disabled as they have not logged onto the system for more than ' &amp; app.myRoot.getConfig(AutoDisabilityPeriod).String &amp; ' day(s).' &amp;  CrLf;
	
	foreach user in userSet do
		self.exclusiveLock(user);
		// to get state before for audit
		if _passport.noErrors then
			self.myUpdateAuditAgent.audUpdateGeneric( user, true);
		endif;
		user.disableUser();
		body := body &amp; CrLf &amp; user.userName &amp; ' ' &amp; user.code  &amp; ' Last Logged on ' &amp; user.lastLoginTS.shortCurrentLocaleFormat();
		// to get state after and execute the audit
		if _passport.noErrors then
			self.myUpdateAuditAgent.audUpdateGeneric( user, false);
		endif;
	endforeach;
	
	app.myUtilityCA.utlCreateEmailSendRequest( true,
		'User(s) automatically disabled.',		
		app.myRoot.getConfig(AutoDisableEmailAddress).String,	 
		app.myRoot.getConfig(AutoSendersEmailAddress).String,	
			null, null,											
		'JMT Users Automatically Disabled',						
		body,													
		null, null, 
		null, null,												
		EmailSource_System,										
		null,													
		app.myPassport);

epilog
	delete userSet;
end;
</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlAutoIdGenerator" id="2e374e95-9a22-44e5-af6f-68c37d0a0c83">
        <source>utlAutoIdGenerator(_proxy : CM_AutoIdGenerator; _real : CM_AutoIdGenerator io; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2014	cnwndl1	Initial creation	Par 34660

*/

vars

begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValUA.valAutoIdGenerator(_real, _proxy);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(_real);

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_real, true);
	endif;
	
	if _passport.noErrors then
		_real.setForUpdate(_proxy);
	endif;
	
	if _passport.noErrors then
		_real.addActivityRecord( false );
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_real, false);
	endif;

epilog

end;</source>
        <Parameter name="_proxy" type="CM_AutoIdGenerator"/>
        <Parameter name="_real" type="CM_AutoIdGenerator" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlAutoPlanOnPickupTI" id="8f28ed83-50d5-4b09-afb9-d2077ed14b54">
        <updating/>
        <source>utlAutoPlanOnPickupTI( _ti : CM_TrackedItem; _wle : CM_WorkListEntry; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 March 2011	cnwrd1	Initial creation

*/

vars

	ti : CM_TrackedItem;

begin

	self.initialiseActivity();
	
	ti := _ti;
	
	ti.autoPlanOnPickup(_wle, _passport);

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlAutoPlanOverstowedCargo" id="e5f7620d-b71a-4ecc-9162-3a184830d5b1">
        <source>utlAutoPlanOverstowedCargo(_ti : CM_TrackedItem input;
							_allOverstowedCargo : CM_TIArray;
							_terminalArea : CM_TerminalArea;
							_gridRow		: CM_GridRow;
							_gridColumn		: CM_GridColumn;
							_location		: CM_LocationsController;
							_tryToMoveExisting : Boolean;
							_passport	: CM_Passport input);
/*

Purpose:			

Parameters:			_tryToMoveExisting if this is set before it does any overstow autoplanning it will try and
					see if moving any existing rt queue entries will solve the overstow problem

Return Value:		


Date		Who		Reason
23 Dec 2009	cnwer1	Initial creation
09 Nov 2010	cnwkpd1	PAR #26113 - Send event to ITS Queue Monitor if successful 
28 Jul 2011	cnwmh5	PAR	#27774 - Change so that uses same queue as overstowed item
27 Jun 2013	cnwer1	PAR 31576  - if finding overstow from YA fails find closest pos based on TA decking rules
*/

vars
	rtQueueEntry		: CM_RTQueueEntry;
	ti 					: CM_TrackedItem;
	iter 				: Iterator;
	futureMove 			: CM_FutureMove;
	futureQueuedMove 	: CM_FutureMoveQueued;
	foundLC				: CM_LocationsController;
	allRestrictingLCs 	: CM_LCSet;
	doAutoPlan 			: Boolean;
	moveController 		: CMIF_MoveController;
begin
	self.initialiseActivity();
	
	if	_allOverstowedCargo = null then
		return;
	endif;
	
	if _ti = null then
		return;
	endif;
	
	
	rtQueueEntry:=_ti.getQueueEntry;
	//need to get all locations we don't want stuff queued to
	doAutoPlan:=true;
	if app.myYAAgent = null then
		app.initialiseForStartAutoPlan(app.myPassport);
		if 	app.myYAAgent = null then
			doAutoPlan:=false;
		endif;
	endif;
	if doAutoPlan then
		create allRestrictingLCs transient;
		_ti.getSideAccessRestrictingLCs(allRestrictingLCs);
	endif;
	

	iter:=_allOverstowedCargo.createIterator;
	while iter.next(ti) do :outerLoop
		if ti = _ti then
			continue;
		endif;
		
		if _tryToMoveExisting then
			if ti.allQueuedFutureMoves.size &gt; 0 then
				//want to see if we could  move any of the queue entries above the current one to avoid overstowing
				foreach futureMove in ti.allQueuedFutureMoves do
					futureQueuedMove:=futureMove.CM_FutureMoveQueued;
					if futureQueuedMove.moveQueueEntryAbove(rtQueueEntry,allRestrictingLCs) then
						continue outerLoop;
					endif;
				endforeach;
			endif;
		endif;
		
		if doAutoPlan then
			foundLC:=_location;
			if foundLC = null then
				foundLC :=app.autoPlanOverstowUsingYA(_ti.myTerminal,_terminalArea,_gridRow,_gridColumn,ti,allRestrictingLCs,false);
				
				//epr par 31576 24/6/13
				if foundLC = null then
					foundLC:= _ti.getResequenceLocFromDecking(REAL_MODE,allRestrictingLCs,false);
				endif;
			endif;
			if foundLC &lt;&gt; null then
				create moveController transient;
				moveController.hazardSegregationValidated := true;//because it's considered when getting a valid autoplan location
				moveController.setMyTrackedItem(ti);
				moveController.setMyToPrimaryLocation(foundLC);
				moveController.setMoveIndex(1); //epr Par 25285 force the overstow move to be first future move
				moveController.setMoveMode(QUEUE_MODE);
			
				//For Queue and Planned moves
				moveController.setMyOriginatingLocation(ti.myPrimaryActualLocation);
				if _location &lt;&gt; null then	//28 May 2010	NDL Par 23756 - Need to perform validation if the location has been user supplied.
					moveController.isForcedMove := false;
				else
					moveController.isForcedMove := true; // PAR 8120. cos we have autoplanned this, we have already validated the location so just create a move to the location
				endif;
				app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
				
				if _passport.hasErrors then
					break;
				endif;
				if app.myYAAgent &lt;&gt; null then
					ti.createInfomationTransaction(YardAllocationLogging, app.myYAAgent.getLoggingArray(true), null, _passport);
				
					//really want to try to reposition the container in the queue again
					if moveController.myWorkListEntry &lt;&gt; null and
						 moveController.myWorkListEntry.myFutureMove &lt;&gt; null then
						 if moveController.myWorkListEntry.myFutureMove.isKindOf(CM_FutureMoveQueued) then
							futureQueuedMove:=moveController.myWorkListEntry.myFutureMove.CM_FutureMoveQueued;
							futureQueuedMove.setOverstowedQueueEntries(_ti); //epr TFS 5254 10/7/17 refactored into method	
						endif;
					endif;
				endif;
				delete moveController;
			else
				
				if not _tryToMoveExisting then
					app.raiseCMWarning1(Unable_find_overst_move_locati,ti.id &amp; " " &amp; app.getErrorString(Check_Yard_Allocation_Logging),null,null,null);
				endif;
				if app.myYAAgent &lt;&gt; null then
					ti.createInfomationTransaction(YardAllocationLogging, app.myYAAgent.getLoggingArray(true), null, _passport);
					continue;
				endif;
			endif;	
		endif;		
	endwhile;
	
	// PAR #26113 - Send notification of successful move overstow for ITS Queue Monitor
	if rtQueueEntry &lt;&gt; null and not _passport.hasErrorsOrWarnings then
		rtQueueEntry.causeEvent(_ti.myTerminal.getTerminalEvent(EVENT_RTQUEUE_MOVE_OVERSTOW), false, null);
	endif;
	
	
epilog	
	delete iter;
	delete allRestrictingLCs;
	delete moveController;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_allOverstowedCargo" type="CM_TIArray"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_gridRow" type="CM_GridRow"/>
        <Parameter name="_gridColumn" type="CM_GridColumn"/>
        <Parameter name="_location" type="CM_LocationsController"/>
        <Parameter name="_tryToMoveExisting" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlAutoPlanTiSimple" id="d47321f4-6ef8-4e24-80c2-f579fbb60215">
        <updating/>
        <source>utlAutoPlanTiSimple(_wle  : CM_WorkListEntry input; _moveMode : Integer; _passport : CM_Passport input) updating;

// Created by cnwdvb1 on 01 May 2006

vars

	ti : CM_TrackedItem;

begin

	self.initialiseActivity();
	
	ti := _wle.myTrackedItem;
	
	ti.autoPlan(_moveMode, _wle.job, null, null, _passport);
	
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="input"/>
        <Parameter name="_moveMode" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlAutoProcessExpiredToDoTask" id="ac40b63d-d8d1-4da6-96f4-1b2a3962fc06">
        <source>utlAutoProcessExpiredToDoTask(_tiSet : CM_TISet; _toDoTaskDesc : CM_ToDoTaskDesc; _passport : CM_Passport input);
//-----------------------------------------
//Created: June 2003 By: cnwgd1
//-----------------------------------------
vars
	ti : CM_TrackedItem;
begin

	self.initialiseActivity();
			
	foreach ti in _tiSet do
		exclusiveLock(ti);
		ti.autoCreateToDoTask(_toDoTaskDesc, _passport);
	endforeach;

end;</source>
        <Parameter name="_tiSet" type="CM_TISet"/>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlAutoResequenceOnPickup" id="f0a4b18f-7eb9-4635-9743-676d00c3e2cc">
        <updating/>
        <source>utlAutoResequenceOnPickup(	_machine 		: CM_Machine;
							_rtQueueEntry : CM_RTQueueEntry input;
							_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 Jan 2010	cnwer1	Initial creation
25 Oct 2012	cnwkpd1	PAR #30276 - Do not auto-resequence if the queue entry override flags are set
27 Jun 2013	cnwer1	PAR 31576  - if finding overstow from YA fails find closest pos based on TA decking rules also now resequence for straddle stack if height is exceeded
06 Nov 2024	navdap1	MTN-18897 EUP | FR 53485 EUP - Warehouse Yard Allocation
*/

vars
	setdownTask 			: CM_RTQueueTask;
	terminal 				: CM_Terminal;
	origSetdownLocation,
	bestLocation		 	: CM_LocationsController;
	gridController 			: CM_GridController;
	ti,
	existingTI,
	overstowOfTI			: CM_TrackedItem;
	allRestrictingTIs		: CM_TIArray;
	ta 						: CM_TerminalArea;
	gridArea   				: CM_GridArea;
	moveController  		: CMIF_MoveController;
	allLCsToIgnore  		: CM_LCSet;
	iter					: Iterator;
	overstowRTQEntry 		: CM_RTQueueEntry;
	vehicleConfig			: CM_RTVehicleConfig;
	maxHeight,
	heightOfTI				: Integer;
	plannedToFullArea		: Boolean;		// MTN-18897
begin

	terminal:=_rtQueueEntry.getMyTerminal();
	vehicleConfig:=terminal.getRTVehicleConfigForObject(_machine);
	if not vehicleConfig.autoResequenceJobs then
		return;
	endif;

	setdownTask:=_rtQueueEntry.getTaskOfType(TASK_SETDOWN,null);
	if setdownTask = null then
		return;
	endif;
	
	ti := setdownTask.ti;
	if ti = null then
		return;
	endif;
	
	origSetdownLocation:=setdownTask.targetLocation;
	//epr par 23385 24/3/10  going to an IMV 
	if origSetdownLocation  = null then
		return;
	endif;
	
	ta:=origSetdownLocation.myTerminalArea;
	//only applicable to Grid Areas
	if not ta.isKindOf(CM_GridArea) then
		return;
	endif;
	
	// PAR #30276 - Do not auto-resequence if the override flags are set
	if _rtQueueEntry.overRideFlags &lt;&gt; 0 then
		return;
	endif;

	gridArea := ta.CM_GridArea;
	
	//04/08/2011 cnwdz2 27008  start
	if gridArea.isKindOf(CM_RTGArea) or gridArea.isKindOf(CM_StraddleStack) then
		gridController := origSetdownLocation.CM_GridController;
		maxHeight := gridArea.heightOfStack * Ti_Full_Height;
		heightOfTI := ti.getHeightOfTI();	
		foreach existingTI in gridController.allTrackedItems discreteLock do
			heightOfTI := heightOfTI + existingTI.getHeightOfTI();	
		endforeach;
		if heightOfTI &gt; maxHeight then
			if app.myYAAgent = null then
				app.initialiseForStartAutoPlan(app.myPassport);
				if 	app.myYAAgent = null then
					return;
				endif;
			endif;
			//22/08/2011 cnwdz2 28044
			bestLocation :=app.autoPlanForFullTargetLocUseYA(ti.myTerminal,ta,gridController.myGridRow,gridController.myGridColumn,ti,false);
		else
			//epr par 32208 24/9/13
			bestLocation:=origSetdownLocation;
		endif;
	else
		//that use side access rules
		if not gridArea.useSideAccessRules then
			return;
		endif;
	
		//just re auto plan it to a location in the terminal area
		if _rtQueueEntry.myOverstowOfEntry &lt;&gt; null then
			// we really need the original overstowed ti to get lcs to ignore
			//this is only forklift so just put the column from source lc
			create allLCsToIgnore transient;
			overstowOfTI:=_rtQueueEntry.myOverstowOfEntry.getTrackedItem;
			if overstowOfTI = null then
				return;
			endif;
			overstowOfTI.getSideAccessRestrictingLCs(allLCsToIgnore);
			iter:=_rtQueueEntry.myOverstowOfEntry.allOverstowQueueEntries.createIterator;
			while iter.back(overstowRTQEntry)do
				if overstowRTQEntry =_rtQueueEntry then
					break;
				endif;
				if overstowRTQEntry.getTrackedItem = null then
					continue;
				endif;
				overstowRTQEntry.getTrackedItem.getSideAccessRestrictingLCs(allLCsToIgnore);
			endwhile;
			bestLocation:=app.autoPlanOverstowUsingYA(terminal,ta,null,origSetdownLocation.CM_GridController.myGridColumn,ti,allLCsToIgnore,true);
		else
			bestLocation:=app.autoPlanJobTiYA(terminal,ta,null,origSetdownLocation.CM_GridController.myGridColumn, ti,null, true, null, plannedToFullArea);   // 25813	// MTN-18897
		endif;
	endif;
	//04/08/2011 cnwdz2 27008 end
	
	if bestLocation = null then
		
		//epr par 31576 25/6/13
		bestLocation:=ti.getResequenceLocFromDecking(QUEUE_MODE,null,true);
		if bestLocation = null then
			return;
		endif;
		
	endif;
	
	//it is the same place can return;
	if bestLocation = origSetdownLocation then
		return;
	endif;
	//now planned to go somewhere completely different just return
	if bestLocation.myTerminalArea &lt;&gt; origSetdownLocation.myTerminalArea then
		return;
	endif;
	
	//write bestLocation.getFullId;
	
	create moveController transient;
	moveController.setMoveMode(QUEUE_MODE);
	moveController.setMyTrackedItem(ti);
	moveController.setMyToPrimaryLocation(bestLocation);
	moveController.setMyPassport(_passport);    // PAR 26948 
	moveController .isPlannedToFullGCArea := plannedToFullArea;			// MTN-18897
	
	setdownTask.changeTargetLocation(moveController,true);
epilog
	delete allRestrictingTIs;
	delete moveController;
	delete allLCsToIgnore;
end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_rtQueueEntry" type="CM_RTQueueEntry" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlBaysEditionCheck" id="492affac-21e2-4b24-b1af-6103525702ec">
        <source>utlBaysEditionCheck(_proxyStructure: CM_CellularVesselStructure; _passport : CM_Passport input);
/*

Date		    Who			Reason
14 March 2011	cnwas3	  par 21579

*/

vars
	proxyBay,realBay:CM_Bay;
	expectedEdition:Integer;
	
begin

	self.initialiseActivity();
	
	foreach proxyBay in _proxyStructure.allBaysByLabel do	
	
		app.setContinueCMExceptions(true);
	
		proxyBay.pxyGetRealObjectAndEdition(realBay, expectedEdition);
		
		if realBay = null then			
			continue;
		endif;
	
		app.myValUA.valBay(realBay, proxyBay);
		
		if not self.checkValidationWithPassport(_passport) then
			return;
		endif;
		
		app.setContinueCMExceptions(false);
	
		exclusiveLock(realBay);
	
		if _passport.noErrors and realBay.edition &lt;&gt; expectedEdition then
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, app.getErrorString(Bay)&amp;' (' &amp; realBay.id &amp; ")", null, null); 
			return;
		endif;	
	endforeach;

end;</source>
        <Parameter name="_proxyStructure" type="CM_CellularVesselStructure"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlBreakBulkMasterAccept" id="dd0fb0d0-fc87-45fe-954e-64e8455189d1">
        <source>utlBreakBulkMasterAccept(	_rtQueueTask : CM_RTQueueTask input ;
							_newQueueTask : CM_RTQueueTask output);
/*

Purpose:	Machine has accepted a break bulk master. We need to create a new entry and pickup/setdown tasks and return the pickup task for the machine to work	


Parameters:			

Return Value:		

Date		Who		Reason
10 June 2013	cnwer1	Initial creation CCMS DPH 2274 PAR 31743

*/

vars
	arbiter : CM_RTQueueArbiter;
	aJob : CM_Job;
	aWLE : CM_WorkListEntry;
	aTI : CM_TrackedItem;
begin
	
	aJob := _rtQueueTask.myEntry.myJob;
	aWLE := _rtQueueTask.myEntry.myWorkListEntry;
	aTI := aWLE.myTrackedItem;
	
	create arbiter transient;

	arbiter.job := aJob;
	arbiter.wle := aWLE;
	arbiter.ti := aWLE.myTrackedItem;
	arbiter.queue := _rtQueueTask.myEntry.myQueue;
	arbiter.setMyTerminal( aJob.getMyTerminal); 
	arbiter.myBulkReleaseMaster := _rtQueueTask.myEntry;
	arbiter.isDriverInitiatedMove:=_rtQueueTask.myEntry.isMachineInitiatedMove;
	
	if aWLE.myTrackedItem &lt;&gt; null then
		arbiter.enqueueTI();
	else
		arbiter.enqueueRequest(_rtQueueTask.sourceLocation);
	endif;
	
	_newQueueTask := arbiter.allRTQueueEntries.last.allTasks.first;

epilog
	delete arbiter;

end;</source>
        <Parameter name="_rtQueueTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_newQueueTask" type="CM_RTQueueTask" usage="output"/>
    </JadeMethod>
    <JadeMethod name="utlBreakBulkOverage" id="2d2c2d36-a901-4a73-bf37-fc2aaff003d6">
        <updating/>
        <source>utlBreakBulkOverage(_ti : CM_TrackedItem input;
					_quantity : Integer;
					_weight : Decimal;
					_cargoWeight : Decimal;	//25 Jan 2018	NDL	TFS 36697
					_tareWeight : Decimal;	//25 Jan 2018	NDL	TFS 36697
					_reason : String;
					_isShortlanded : Boolean; //29/03/2023	navkc1	CR# 56430 TASK 56435
					_isOverlanded : Boolean; 
					_autoZero : Boolean;	//12/04/2023	navkc1	CR 56431 Task 56438
					_passport : CM_Passport input
					) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 May 2013	cnwrd1	Initial creation
24 Jun 2013 cnwer1  Par 31727
29/03/2023	navkc1	CR# 56430 Task 56435 Jade - Tracked Item Methods
12/04/2023	navkc1	CR 56431 Task 56438: UI - Cargo Enquiry
17/05/2023	jlika1	TFS 56398 EUP - OUT - Overlanded Cargo Handling - Web
*/

vars

begin
	
	//epr par 31727 24/6/13 refactored into method on CM_BreakBulkGeneric
	_ti.setBreakBulkOverage(_quantity, _weight, _cargoWeight, _tareWeight, _reason, _isShortlanded, _isOverlanded, _autoZero, _passport);
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_cargoWeight" type="Decimal"/>
        <Parameter name="_tareWeight" type="Decimal"/>
        <Parameter name="_reason" type="String"/>
        <Parameter name="_isShortlanded" type="Boolean"/>
        <Parameter name="_isOverlanded" type="Boolean"/>
        <Parameter name="_autoZero" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlBuildPriorityRailOps" id="fd0b14e1-18a0-44b3-84ea-69f8f4f5a59d">
        <updating/>
        <source>utlBuildPriorityRailOps(_cmifBuildPriority : CMIF_BuildPriority input; _passport : CM_Passport input) updating;
//-----------------------------------------
//Created: March 2003 By: cnwgd1
//-----------------------------------------
vars

begin

	self.initialiseActivity();
	self.raiseExceptionIfNull(_cmifBuildPriority, 'Build Priority Object');
	app.setContinueCMExceptions(true);

	_cmifBuildPriority.validate();
	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;

	_cmifBuildPriority.action();
	
	if _cmifBuildPriority.myReserveHeader &lt;&gt; null then
		_cmifBuildPriority.myReserveHeader.causeUpdateEvent();
	endif;
end;</source>
        <Parameter name="_cmifBuildPriority" type="CMIF_BuildPriority" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCalcLocationStats" id="1d2344a2-6717-42cf-a722-d158134bd915">
        <updating/>
        <source>utlCalcLocationStats(	_allTerminalsSet : CM_TerminalSet;
						_termAreaSet : CM_TerminalAreaSet;
						_allGridRowSet,
						_allGridColSet: CM_GridObjectSet;
						_yaBlockSet : CM_YABlockSet;
						_movementLogArray : ObjectArray io;
						_passport : CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		06 November 2008 by cnwdad1
//
// Purpose:		Calculates Location Statistics for all relevant Terminal Areas and
//				Yard Allocations.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	terminalObj	: CM_Terminal;
	areaObj		: CM_TerminalArea;
	
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(false);
	
	self.utlCalcLocationStatsYABlock(_yaBlockSet, _movementLogArray, _passport);
	self.utlCalcLocationStatsGridRow(_allGridRowSet, _passport);
	self.utlCalcLocationStatsGridColumn(_allGridColSet,_passport);
	foreach areaObj in _termAreaSet do
		areaObj.buildLocationStatistics();
	endforeach;
	
	foreach terminalObj in _allTerminalsSet do
		terminalObj.buildLocationStatistics();
		terminalObj.causeEvent(terminalObj.getTerminalEvent(EVENT_LOCATION_STATS_CHANGE), false, terminalObj.myLocationStatistics);
	endforeach;
end;</source>
        <Parameter name="_allTerminalsSet" type="CM_TerminalSet"/>
        <Parameter name="_termAreaSet" type="CM_TerminalAreaSet"/>
        <Parameter name="_allGridRowSet" type="CM_GridObjectSet"/>
        <Parameter name="_allGridColSet" type="CM_GridObjectSet"/>
        <Parameter name="_yaBlockSet" type="CM_YABlockSet"/>
        <Parameter name="_movementLogArray" type="ObjectArray" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCalcLocationStatsGridColumn" id="f61cabb5-0101-4020-b2dd-b73b597564d9">
        <updating/>
        <source>utlCalcLocationStatsGridColumn(_gridColumnSet       : CM_GridObjectSet; 
                             _passport         : CM_Passport input) updating;
/*

Purpose:			Calculate Location Statistics for the given set of GridRows

Parameters:			Set of GridRows

Return Value:		

Date		Who		Reason
02 September 2008	conkc1	Initial creation

*/
vars
	gridCol     : CM_GridColumn;
	gridObject  : CM_GridObject;
	
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(false);

	foreach gridObject in _gridColumnSet do
		gridCol := gridObject.CM_GridColumn;
		exclusiveLock(gridCol);
		gridCol.buildLocationStatistics();
	endforeach;

epilog

end;</source>
        <Parameter name="_gridColumnSet" type="CM_GridObjectSet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCalcLocationStatsGridRow" id="d2f0d6d5-41c5-46fe-ae0f-83085e8d99b0">
        <updating/>
        <source>utlCalcLocationStatsGridRow(gridRowSet       : CM_GridObjectSet; 
                             _passport         : CM_Passport input) updating;
/*

Purpose:			Calculate Location Statistics for the given set of GridRows

Parameters:			Set of GridRows

Return Value:		

Date		Who		Reason
02 September 2008	conkc1	Initial creation

*/
vars
	gridRow     : CM_GridRow;
	gridObject  : CM_GridObject;
	
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(false);
	
	foreach gridObject in gridRowSet do
		gridRow := gridObject.CM_GridRow;
		exclusiveLock(gridRow);
		gridRow.buildLocationStatistics();
	endforeach;
end;</source>
        <Parameter name="gridRowSet" type="CM_GridObjectSet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCalcLocationStatsYABlock" id="bfcfe4b6-8e33-4d0a-92b0-36775b8958de">
        <updating/>
        <source>utlCalcLocationStatsYABlock(yaBlockSet       : CM_YABlockSet; 
                            movementLogArray : ObjectArray io;
                           _passport         : CM_Passport input) updating;
/*

Purpose:			Calculate Location Statistics for the given set of YABlock

Parameters:			Set of Yard Allocation Blocks
					Array of CM_MovementLogs (can be null)

Return Value:		


Date		Who		Reason
22 August 2008	conkc1	Initial creation

*/
vars
	yardAllocationBlock	: CM_YABlock;
	
begin
	app.setContinueCMExceptions(false);

	foreach yardAllocationBlock in yaBlockSet do
		exclusiveLock(yardAllocationBlock);
		yardAllocationBlock.buildLocationStatistics();
	endforeach;
	//
	// Now purge the movementLogArray - this maybe empty
	//
	if movementLogArray &lt;&gt; null then
		movementLogArray.purge();
	endif;
end;</source>
        <Parameter name="yaBlockSet" type="CM_YABlockSet"/>
        <Parameter name="movementLogArray" type="ObjectArray" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCancelDirectorWithTITask" id="a0fb39cc-4839-48da-b472-1c36344bfb5f">
        <updating/>
        <source>utlCancelDirectorWithTITask(	_rtQueueTask : CM_RTQueueTask input;
				_machine 	: CM_Machine input ;
				 _passport         : CM_Passport input) updating;
/*
Purpose:			
Parameters:			
Return Value:		

Date			Who		Reason

*/

vars
	invalidTask 	: Boolean;
	entry 			: CM_RTQueueEntry;
	directorTask 	:CM_RTQueueTask;
	job 			: CM_Job;
	lc,
	taLocation			: CM_LocationsController;
	alert				: CM_SystemAlert;
	wle					: CM_WorkListEntry;
	deliveryRequest		: CM_DeliveryRequest;
	tmpTargetLocation	: String;
	ta					: CM_TerminalArea;
	request				: CM_Request;
	foundHeight			: Integer;
	lMoveControl			: CMIF_MoveController;
	machineStatus,
	status,oldStatus: Integer;
begin
	on Exception do app.handleDeletedObject(exception, _rtQueueTask, invalidTask);
	
	exclusiveLock(_rtQueueTask);
	if invalidTask then
		return;
	endif;
	
	entry := _rtQueueTask.myEntry;
	exclusiveLock(entry);
	directorTask := entry.allTasks.first;
	wle := entry.myWorkListEntry;
	
	// here we want to undo all the stuff we did when we picked and assigned a TI - see utlDoBestPickAssignTI
	_rtQueueTask.setStatusUnactioned;
	_rtQueueTask.getNextMachineTask.setStatusUnactioned;
	
	delete lMoveControl;
	create lMoveControl transient;
	lMoveControl.setMoveMode(QUEUE_MODE);
	lMoveControl.setMyTrackedItem(_rtQueueTask.ti);
	lMoveControl.setMyWorkListEntry(wle);	
	lMoveControl.setMyMachine( _machine);
	lMoveControl.isDirectorWithTIUndo := true;
	app.myUtilityUA.utlUpdateMoveTIUndo(lMoveControl, app.myPassport);	
	
	directorTask := entry.allTasks.first;
	
	if directorTask.machine &lt;&gt; _machine then
		directorTask.setMachine(_machine);
	endif;
	
	status := directorTask.status;
	if status &lt; TASK_ACCEPTED then  //should be unactioned
		while directorTask.status &lt; TASK_ACCEPTED do
			directorTask.setStatus(status);
			status:=status+1;
		endwhile;
	endif;

epilog

end;</source>
        <Parameter name="_rtQueueTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCargoFieldUpdate" id="9ee79d9e-d56b-4fb9-a46a-f7b312ff977c">
        <updating/>
        <source>utlCargoFieldUpdate(_ediDataCargoFieldUpdate :CM_EDIDataCargoFieldUpdate; _isValidateOnly:Boolean; _passportObj:CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		14 December 2009 by cnwdad1
//
// Purpose:		Processed the EDI Cargo Field Update objects by updating the relevant
//				TI's with the specified field value.
//
// Parameters:	_allCargoTIsObj - An array of Tracked Item objects to update.
//				_isValidateOnly - True if we are only validating the EDI data.
//				_passportObj - The user's passport.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	
	prof		    : JadeProfiler;
	startTM 		: Decimal[19,0];
begin
	app.myRoot.startJadeProfiler(prof,method.getNiceName() ,20,true,'CS',startTM);
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	app.myValUA.valCargoFieldUpdate(_ediDataCargoFieldUpdate, _passportObj);
	
	_ediDataCargoFieldUpdate.doLoadDB(_isValidateOnly, _passportObj);

epilog
			app.myRoot.stopJadeProfiler(prof,startTM);
end;</source>
        <Parameter name="_ediDataCargoFieldUpdate" type="CM_EDIDataCargoFieldUpdate"/>
        <Parameter name="_isValidateOnly" type="Boolean"/>
        <Parameter name="_passportObj" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCargoGroupAddTi" id="a5a4195a-07e4-4560-8799-08e5408f1f9e">
        <source>utlCargoGroupAddTi( _cargoGroup : CM_CargoGroup input; _tiToAdd : CM_TrackedItem input; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Jun 2015	cnwndl1	Initial creation	Par 36338
10 Nov 2022	navkc1	Bug 55382: MTN - Cargo Group Details recalculated after each change to TI when bulk editing
*/

vars
	cargoGroupTrxAction  : CMIF_TrxActionCargoGroup;

begin
	_cargoGroup.addAssignedCargo( _tiToAdd, _passport );
	
	CMIF_TrxActionCargoGroup@createAction(_tiToAdd, null, _passport); // 10/11/2022	navkc1	#55382
	
	/* 
	// 10/11/2022	navkc1	#55382 Moved to CMIF_TrxActionCargoGroup@createAction
	//TFS 53390
	if _passport.noErrors then
		create cargoGroupTrxAction transient;
		cargoGroupTrxAction.setMyCargoGroup(_cargoGroup);
		_passport.addTrxPostAction(cargoGroupTrxAction);
	endif;
	*/ // 10/11/2022	navkc1	#55382

epilog

end;</source>
        <Parameter name="_cargoGroup" type="CM_CargoGroup" usage="input"/>
        <Parameter name="_tiToAdd" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCashReceiptAPIUpdateStatus" id="f21c9231-2354-43ff-b25a-0ec20ad6372a">
        <updating/>
        <source>utlCashReceiptAPIUpdateStatus(_pxyCashReceipt : CM_CashReceipt; _status : Integer; _remarks : String; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11/07/2024	navkc1 CR 64837 Task 64851: Jade - New API putProformaForExternal

*/

vars
	status					: Integer;
	realCashRec 			: CM_CashReceipt;
	nextSeqNumber			: Integer;
	expectedEditiion 		: Integer;
	cashPayment 			: CM_CashPayment;
	root 					: CM_Root;
	invoiceLine				: CM_InvoiceLine;
	
begin
	self.initialiseActivity();
	
	_pxyCashReceipt.raiseExceptionIfNotProxy(method);
	
	app.setContinueCMExceptions(true);
	
	_pxyCashReceipt.pxyGetRealObjectAndEdition(realCashRec, expectedEditiion);
	
	if realCashRec = null then
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_CashReceipt.name, null, null);
		return;
	endif;
	
	// Validate
	app.myValUA.valCashReceiptAPIUpdateStatus(_pxyCashReceipt, realCashRec, _status);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	exclusiveLock(realCashRec);
	
	if _passport.noErrors() and realCashRec.edition() &lt;&gt; expectedEditiion then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave,app.getErrorString(Invoice), null, null);
		return;
	endif;
	
	if _passport.noErrors() then
		self.myUpdateAuditAgent.audUpdateGeneric(realCashRec, true);
	endif;
	
	if _passport.noErrors() then
		root := app.myRoot;
		
		status := _status;
		
		if _status = CM_CashReceipt.API_RECEIPT_CANCELLED then
		/* 	==========
			CANCELLED
			========== */
			// Delete the BGP
			root.deleteFutureActor(realCashRec, CM_CashStatusAdvanceProcess);
			
			//01/10/2024 navkc1 JIRA 19366
			// Void the draft receipts and payments
			foreach cashPayment in realCashRec.allCashPayments do
				// Void the cash payment
				//cashPayment.setVoided(true); Wrong way to void the cash payment
				
				//30/04/2025	navkc1 JIRA Bug MTN-34734 - Do not void the cash payment
				//cashPayment.setStatus(CM_CashPayment.Status_Void); //24/02/2025	navkc1 JIRA Bug MTN-34043 Correct way to void the cash payment
				
				// Detach the invoice line, so MTN will calculate the amount again
				invoiceLine  := cashPayment.myInvoiceLine;
				if invoiceLine &lt;&gt; null then
					// Void the invoice line as well
					//invoiceLine.setVoided(true); //24/02/2025	navkc1 JIRA Bug MTN-34043 Wrong way to void the invoice line
					
					//30/04/2025	navkc1 JIRA Bug MTN-34734 - Do not void the invoice lines
					//invoiceLine.setStatus(CM_InvoiceLine.STATUS_VOIDED); //24/02/2025	navkc1 JIRA Bug MTN-34043 correct way to void the invoice line
					
					//cashPayment.setInvoiceLine(null); //24/02/2025	navkc1 JIRA Bug MTN-34043 They want us to keep the link so we can display the invoice/invoice line narration in the cash receipt enq screen
				endif;
				
				// Detach the proforma line, so MTN will calculate the amount again
				//cashPayment.setProformaDetail(null); //24/02/2025	navkc1 JIRA Bug MTN-34043 They want us to keep the link so we can display the invoice/invoice line narration in the cash receipt enq screen
			endforeach;
			
		elseif _status = CM_CashReceipt.API_RECEIPT_HOLD then
		/* 	==========
			HOLD
			========== */
			
			root.deleteFutureActor(realCashRec, CM_CashStatusAdvanceProcess);
			
			realCashRec.setExternalFields(_pxyCashReceipt.externalReceiptNumber, _pxyCashReceipt.externalFinancialId, _pxyCashReceipt.externalRef1, _pxyCashReceipt.externalTransaction,
											_pxyCashReceipt.externalUserCode, _remarks);
			
		elseif _status = CM_CashReceipt.API_RECEIPT_FINAL then
		/* 	==========
			FINAL
			========== */
			realCashRec.setExternalFields(_pxyCashReceipt.externalReceiptNumber, _pxyCashReceipt.externalFinancialId, _pxyCashReceipt.externalRef1, _pxyCashReceipt.externalTransaction,
											_pxyCashReceipt.externalUserCode, _remarks);
			
		elseif _status = CM_CashReceipt.API_RECEIPT_PAID then
		/* 	==========
			PAID
			========== */
			root.deleteFutureActor(realCashRec, CM_CashStatusAdvanceProcess);
			
			realCashRec.setExternalFields(_pxyCashReceipt.externalReceiptNumber, _pxyCashReceipt.externalFinancialId, _pxyCashReceipt.externalRef1, _pxyCashReceipt.externalTransaction,
											_pxyCashReceipt.externalUserCode, _remarks);
			nextSeqNumber := realCashRec.getNextRecSeqNum();
			realCashRec.setSequenceNumber(nextSeqNumber);
			
			realCashRec.setPaymentStatus(status); // Do this here to it generate the ext invoice number
			realCashRec.genExternalReceiptNum();
			
			/*
			===============
			For QT - When they send in PAID, they want to set the paymentStatus to FINAL
			This may requires a configuration in the future as it will be generic and other clients might want to keep it as PAID.
			===============
			*/
			status := CM_CashReceipt.API_RECEIPT_FINAL;	
			realCashRec.setPaymentStatus(status); 

		endif;
		
		realCashRec.setPaymentStatus(status);
		realCashRec.setRemarks(_remarks);
		
	endif;
	
	if _passport.noErrors() then
		self.myUpdateAuditAgent.audUpdateGeneric(realCashRec, false);
		if realCashRec.myWorkOrder &lt;&gt; null then
			self.updateObjectEdition(realCashRec.myWorkOrder);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_pxyCashReceipt" type="CM_CashReceipt"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCashReceiptJMTUpdateStatus" id="33a0ba62-659f-46df-8caf-39b7916a3426">
        <updating/>
        <source>utlCashReceiptJMTUpdateStatus(_pxyCashReceipt : CM_CashReceipt; _status : Integer; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/06/2025	navkc1 JIRA MTN 34779 MTN | Cash Status Change for Special Users.

*/

vars
	realCashRec 			: CM_CashReceipt;
	nextSeqNumber			: Integer;
	expectedEditiion 		: Integer;
	root 					: CM_Root;
begin
	self.initialiseActivity();
	
	_pxyCashReceipt.raiseExceptionIfNotProxy(method);
	
	app.setContinueCMExceptions(true);
	
	_pxyCashReceipt.pxyGetRealObjectAndEdition(realCashRec, expectedEditiion);
	
	if realCashRec = null then
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_CashReceipt.name, null, null);
		return;
	endif;
	
	// Validate
	app.myValUA.valCashReceiptJMTUpdateStatus(_pxyCashReceipt, realCashRec, _status);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	exclusiveLock(realCashRec);
	
	if _passport.noErrors() and realCashRec.edition() &lt;&gt; expectedEditiion then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave,app.getErrorString(Invoice), null, null);
		return;
	endif;
	
	if _passport.noErrors() then
		self.myUpdateAuditAgent.audUpdateGeneric(realCashRec, true);
	endif;
	
	if _passport.noErrors() then
		root := app.myRoot;
		
		if _status = CM_CashReceipt.API_RECEIPT_DRAFT then
			// Set to Draft
			realCashRec.setPaymentStatus(_status);
			
			// Create BGP
			if realCashRec.requiresBGPRequestForStatus() then
				realCashRec.doBGPAdvanceRequest();
			endif;
			
		elseif _status = CM_CashReceipt.API_RECEIPT_CANCELLED then
		/* 	==========
			CANCELLED
			========== */
			// Set to Cancelled
			realCashRec.setPaymentStatus(_status);
			
			// Delete the BGP
			root.deleteFutureActor(realCashRec, CM_CashStatusAdvanceProcess);
			
		elseif _status = CM_CashReceipt.API_RECEIPT_FINAL then
		/* 	==========
			FINAL
			========== */
			// Delete BGP
			root.deleteFutureActor(realCashRec, CM_CashStatusAdvanceProcess);
			
			// Get proper sequence number
			nextSeqNumber := realCashRec.getNextRecSeqNum();
			realCashRec.setSequenceNumber(nextSeqNumber);
			// Set to Final
			realCashRec.setPaymentStatus(_status); // Do this here to it generate the ext invoice number
			// Get External Receipt number
			realCashRec.genExternalReceiptNum();
			
		endif;
	endif;
	
	if _passport.noErrors() then
		self.myUpdateAuditAgent.audUpdateGeneric(realCashRec, false);
		if realCashRec.myWorkOrder &lt;&gt; null then
			self.updateObjectEdition(realCashRec.myWorkOrder);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_pxyCashReceipt" type="CM_CashReceipt"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlChangeRTEntryMoveRule" id="bc89c5e8-c1df-4a66-8475-56df33ded5c4">
        <source>utlChangeRTEntryMoveRule(_rtQueueEntry : CM_RTQueueEntry; _newRTMoveMethodRule : CM_RTMoveMethodRule; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 February 2010	cnwer1	Initial creation

*/

vars
	ti : CM_TrackedItem;
	arbiter 			: CM_RTQueueArbiter;
	shiftBeforeEntries,
	oldQueues	: ObjectArray;
	theSubQueue : CM_SubQueue;
	tmpQueuedLocn,
	tmpSourceLocn 		: CM_LocationsController;
	wle					: CM_WorkListEntry;
	shiftBeforeEntry,
	rtQueueEntry		: CM_RTQueueEntry;
	oldRTMultMachineRule	: CM_RTQueueMultiRule;
	rtQueueEntriesToDelete  : CM_RTQueueEntryArray;
	aTerminal 			: CM_Terminal;
	allValidRules : CM_RTMoveMethodRuleDict;
	oldIndex,i 		: Integer;
	oldIndexes 		: IntegerArray;
	oldQueue  		: Object;
begin
	self.initialiseActivity();
		
	if _rtQueueEntry = null and _newRTMoveMethodRule  = null then
		return;
	endif;
	ti:=_rtQueueEntry.getTrackedItem;
	wle:=_rtQueueEntry.myWorkListEntry;
	//cnwrd1 par 28196 1.11.11
	tmpSourceLocn := wle.allRTQueueEntries.first.allTasks.first.sourceLocation;
	tmpQueuedLocn := _rtQueueEntry.getUltimateTargetLocation();
	aTerminal := _rtQueueEntry.getMyTerminal();
	
	if _rtQueueEntry.myRTMoveMethodRule = _newRTMoveMethodRule then
		return;
	endif;
	
	//now we can do bulk update need to validate that the move method is valid
	create allValidRules transient;
	_rtQueueEntry.myWorkListEntry.getAllValidRTMoveMethodRules(allValidRules);
	if not allValidRules.includes(_newRTMoveMethodRule) then

		//raise exception
		app.raiseCMException1(Move_metho_rule_not_valid_task,_rtQueueEntry.allTasks.first.tiId,null,null);
		return;
	endif;
	
	oldRTMultMachineRule:=_rtQueueEntry.myRTMoveMethodRule.myRTQueueMultiRule;
	
	// we want to keep the future moves but just delete the queued entries
	// the arbiter still needs the queued future move for the queueing and the target location has not changed so the future move is still relevant
	//only want to delete all if the first rtQueue entry is unactioned or we are changing to a rule not valid for the current rt multi machine rule
	
	//wle.unQueueWLE(_passport); //deletes the rtQueue and tasks - don't reference this again or will get a error 4
	create rtQueueEntriesToDelete transient;
	foreach rtQueueEntry in wle.allRTQueueEntries reversed do
		if oldRTMultMachineRule = _newRTMoveMethodRule.myRTQueueMultiRule then
			if rtQueueEntry.status = ENTRY_COMPLETE then
				continue;
			elseif rtQueueEntry.status = ENTRY_WORKING then
				app.raiseCMException(Change_RTMoveMethod_Working,null,null);
				return;
			endif;
		endif;
		rtQueueEntriesToDelete.add(rtQueueEntry);
	endforeach;
	
	create oldQueues transient;
	create oldIndexes transient;
	
	foreach rtQueueEntry in rtQueueEntriesToDelete do
		/* epr par 31016 15/2/13
			Get the old queues &amp; index of first entry.  If there are more than one entry in same queue only using first index
			Will then try to re-order those new entries that are in the same queue to the old index
		*/
		i:=oldQueues.indexOf(rtQueueEntry.myQueue);
		if i &lt;= 0 then
			oldQueues.add(rtQueueEntry.myQueue);
			oldIndexes.add(rtQueueEntry.myQueue.allEntries.indexOf(rtQueueEntry));
		else
			oldIndexes[i]:=rtQueueEntry.myQueue.allEntries.indexOf(rtQueueEntry);
		endif;
		rtQueueEntry.deleteEntry( false, null);
	endforeach;

	if oldQueues.size &gt; 0 then
		create shiftBeforeEntries transient;
		i:=1;
		foreach oldQueue in oldQueues do
			oldIndex:=oldIndexes[i];
			if oldQueue.CM_RadioTelemetryQueue.allEntries.size &gt;= oldIndex then
				shiftBeforeEntry:=oldQueue.CM_RadioTelemetryQueue.allEntries[oldIndex];
			else
				shiftBeforeEntry:=null;
			endif;
			shiftBeforeEntries.add(shiftBeforeEntry);
			i:=i+1;
		endforeach;
	endif;


	if _passport &lt;&gt; null then
		//can be null as no need to cause update event when erasing self as the delete event will be sent
		app.myEventManager.createSingleObjInfoNoteEvt(wle, _passport.myTerminal.getTerminalEvent(WLE_Update_Event), wle);
	endif;
	
	
	if _passport.hasErrorsOrWarnings then
		return;
	endif;
	
	// then create the arbiter set details and buildQueueEntries with the new move method
	create arbiter transient;
	arbiter.reset();
	arbiter.wle := wle;
	arbiter.ti := ti;
	arbiter.job:=wle.job;
	arbiter.setMyTerminal( aTerminal ); // AKB2002NOV added
	if ti &lt;&gt; null then // AKB2002NOV added
		arbiter.sourceLocation		:= ti.getPrimaryLocation(REAL_MODE);
	else //cnwrd1 par 28196 1.11.11
		arbiter.sourceLocation := tmpSourceLocn;
	endif;
	
	if arbiter.sourceLocation &lt;&gt; null then
		theSubQueue				:= arbiter.sourceLocation.getOverrideQueue();
	endif;
	
	//epr 30485 15/10/12
	if theSubQueue = null and tmpQueuedLocn &lt;&gt; null then
		theSubQueue := tmpQueuedLocn.getOverrideQueue();
	endif;
	arbiter.queue				:= theSubQueue;
	arbiter.targetLocation 	:= tmpQueuedLocn;
	arbiter.ignoreExtraChecks	:= false;
	// RE initialize the arbiter references.
	arbiter.myCurrentMachineTypeGroup	:= null;
	arbiter.myRTMoveMethod	:= null;
	arbiter.myPreviousRTQueueEntry		:= null;
	arbiter.allRTQueueEntries.clear();
	arbiter.setMyRTMoveMethodRule(_newRTMoveMethodRule);
	arbiter.myRTMoveMethod:=_newRTMoveMethodRule.myRTMoveMethod;	
	
	arbiter.myRTMoveMethod.buildQueueEntries(arbiter);
	
	
	if _passport.hasErrorsOrWarnings then
		return;
	endif;
	
	//epr par 31016 14/2/13 
	if oldQueues.size&gt;0 then
		//check that new queue entries queue is the same as the oldQueue
		foreach rtQueueEntry in arbiter.allRTQueueEntries do
			i:=oldQueues.indexOf(rtQueueEntry.myQueue);
			if i &gt; 0 then
				shiftBeforeEntry:=shiftBeforeEntries[i].CM_RTQueueEntry;
				if shiftBeforeEntry &lt;&gt; null then
					rtQueueEntry.shiftEntry(shiftBeforeEntry);
				endif;
			endif;
		endforeach;
	endif;
		
epilog
	delete arbiter;
	delete rtQueueEntriesToDelete;
	delete allValidRules;
	delete oldQueues;
	delete oldIndexes;
	delete shiftBeforeEntries;
end;</source>
        <Parameter name="_rtQueueEntry" type="CM_RTQueueEntry"/>
        <Parameter name="_newRTMoveMethodRule" type="CM_RTMoveMethodRule"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlChangeTaskStatus" id="8745f7f6-6149-4fd5-8495-96da0aa6e2c9">
        <source>utlChangeTaskStatus(_rtQueueTask : CM_RTQueueTask input;
					_machine : CM_Machine input;
					_newStatus : Integer;
					_passport : CM_Passport input);
/*

Purpose:			


Return Value:		


Date		Who		Reason
03 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	machineStatus,
	status,oldStatus: Integer;
begin


	if _rtQueueTask.machine &lt;&gt; _machine then
		_rtQueueTask.setMachine(_machine);
	endif;
	if _rtQueueTask &lt;&gt; null then	
		//hopefully doing it in this order will stop the exceptions
		oldStatus:=_rtQueueTask.status;
	
		status:=oldStatus;
	
		if _newStatus &gt; status then
			while _rtQueueTask.status &lt; _newStatus do
				_rtQueueTask.setStatus(status);
				status:=status+1;
			endwhile;
		else
			_rtQueueTask.setStatus(_newStatus);
		endif;
		_rtQueueTask.setStatusToRestoreTo(_rtQueueTask.status);
	endif;

epilog

end;</source>
        <Parameter name="_rtQueueTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_newStatus" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
