    <JadeMethod name="getIDForSwapStack" id="5168aa15-2cd6-4e38-87c2-474be19f32c1">
        <source>getIDForSwapStack():String protected;
// ---------------------------------------------------------------------------
// Created:     18 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	length	:Integer;
	str		:String;
begin
	length	:= CM_SwapStack::id.length;
	str 	:= self.id.trimBlanks;
	
	if str.length + 5 &gt; length then
		return "SWAP_" &amp; self.id[1 : length-5] ;
	else		
		return "SWAP_" &amp; str;
	endif;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getIsEmptyValue" id="6d8f5126-1883-4b6b-a614-f1900f5290a9">
        <source>getIsEmptyValue(): Boolean protected;
// ---------------------------------------------------------------------------
// Created:     10 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	rtnValue			: Boolean;
	lc					: CM_LocationsController;
begin
	rtnValue := true;
	
	foreach lc in self.allLocationsControllers do
		if (not lc.allTrackedItemsById.isEmpty) then
			rtnValue := false;
			break;
		endif;
	endforeach;

	return rtnValue;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getLCGateController" id="1ecdfd8a-e0e5-46e1-817b-83917ffe1bcb">
        <source>getLCGateController(_preGate : Boolean): CM_LocationsController;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 23 March 2007
//
//----------------------------------------------------------------------

vars
	iter : Iterator;
	lc : CM_LocationsController;
begin
	iter := self.allLocationsControllers.createIterator;
	while iter.next(lc) do
		if not CM_BlockController.hasInstance(lc) then
			continue;
		endif;
		
		if _preGate then
			if lc.CM_BlockController.myPreGateVTA &lt;&gt; null then
				break;
			endif;
		else
			if lc.CM_BlockController.myPostGateVTA &lt;&gt; null then
				break;
			endif;
		endif;
		
		lc := null;
	endwhile;
	
	return lc;
epilog
	delete iter;
end;</source>
        <Parameter name="_preGate" type="Boolean"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
