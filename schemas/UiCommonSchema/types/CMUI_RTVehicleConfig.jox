vars
	bothVisible : Boolean;
begin
	if not checkbox.value then
		if not self.chkTaskGetNext.value then
			checkbox.value:=true;
		endif;
	endif;
	
	self.setDefaultTaskModeVisibility();
	
	if bothVisible then 
		self.lblDefList.caption := app.getErrorString(Default);
		self.lblDefGetNext.caption:= app.getErrorString(SetDefault);
	endif;
	
epilog

end;</source>
