    <JadeMethod name="cmbHatchLids_lostFocus" id="4d77b308-ef02-4f2d-b262-8b0cf33730d0">
        <controlMethod name="Table::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbHatchLids_lostFocus(table: Table input) updating;
//--------------------------------------------------
// Created:	26 September 2003 By: cnwgd1
//--------------------------------------------------
vars
	obj : Object;
	lid : CM_HatchLid;
	str : String;
begin
	foreach obj in self.cmbHatchLids.allSelectedObjects do
		if str = null then
			str := obj.CM_HatchLid.getDescription(self.cmbBayId.listObject.CM_Bay);
		else
			str:= str &amp; CrLf &amp;  obj.CM_HatchLid.getDescription(self.cmbBayId.listObject.CM_Bay);
		endif;
	endforeach;
		
	self.tblJobEdit.setValueByControlName(table.name, str);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
