        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mySDF_dragDrop(frame: Frame input; win: Window input; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
