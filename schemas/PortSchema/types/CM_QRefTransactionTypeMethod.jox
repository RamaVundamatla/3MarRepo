    <JadeMethod name="create" id="29996cfb-d405-47ec-a041-a3d7fcada9dd">
        <updating/>
        <source>create() updating;
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries
vars
	oper : CM_QueryOperator;
begin
	if self.isTransient then 
		return;
	endif;

	create oper as CM_QReferenceIsOneOf persistent;
	self.allAllowedOperators.add(oper);	
end;
</source>
    </JadeMethod>
