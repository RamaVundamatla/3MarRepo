	tmpLeft	: Integer;

begin

	inheritMethod();
	self.sptMain.setLeftToRightRatioAndResize(45);

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="cc90d221-4a83-4b14-863e-fd57834e9bdb">
        <updating/>
        <source>doSave(): Boolean updating;

// cnwdvb1 18 October 2002 

vars

	rtnValue		: Boolean;
	stockHdr,
	newHdr			: CM_StockOrderHeader;
	realLineAlloc	: CM_StockOrderAllocation;
	alloc			: CM_StockOrderLineAlloc;
	allocSet		: CM_StockOrderAllocationSet;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin

	create allocSet transient;
	if self.myProxyObject = null then
		if self.mode = Mode_Add then
			create self.myProxyObject as CM_StockOrderHeaderGeneric transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
	
	stockHdr := self.myProxyObject.CM_StockOrderHeader;	
	if self.setProxyData(stockHdr.CM_StockOrderHeaderGeneric) then
	
		//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			if stockHdr.pxyIsProxy then
				app.myTrxUA.trxUpdateStockOrder(stockHdr, app.myPassport);
			else
				app.myTrxCA.trxCreateStockOrder(stockHdr, newHdr, app.myPassport); 
			endif;
		
			if app.myPassport.trxCompletedOK then
				rtnValue := true;
				if stockHdr.pxyIsProxy then
					newHdr := stockHdr.pxyGetRealObject();
				endif;
				break;
			else
				theResult := app.showErrorWarningDialog('Releases', app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			return false;
			
		endwhile;
	
	endif;
	
	self.myCurrentObject := newHdr;

	
epilog
	delete allocSet;
	return rtnValue;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doThumbnailForLogs" id="6d29910c-798a-4f54-b2de-c000a08ccbbe">
        <source>doThumbnailForLogs(_header : CM_StockOrderHeaderGeneric; _order : CM_StockOrderProductLine) protected;

// cnwdvb1 24 October 2002 

vars

	productLog	: CM_ProductLog;
	bolOut		: CM_BOLOut;
	noNumbers	: Integer;

begin

	productLog := _order.myProduct.CM_ProductLog;
	self.tblThumb.addItem('Audit' &amp; Tab &amp; _header.isAudit.getYesNo);
	self.tblThumb.addItem('Transfer' &amp; Tab &amp; _header.isTransfer.getYesNo);
	if _header.myConsignee &lt;&gt; null then
		self.tblThumb.addItem('Consignee' &amp; Tab &amp; _header.myConsignee.code);
	endif;
	if _header.myTransferTerminal &lt;&gt; null then
		self.tblThumb.addItem('Terminal' &amp; Tab &amp; _header.myTransferTerminal.code);
	endif;
	self.tblThumb.addItem('Supplier' &amp; Tab &amp; _header.myOperator.code);
	self.tblThumb.addItem('Species' &amp; Tab &amp; productLog.speciesCode);
	self.tblThumb.addItem('Grade' &amp; Tab &amp; productLog.gradeCode);
	self.tblThumb.addItem('Type' &amp; Tab &amp; productLog.typeCode);
	self.tblThumb.addItem('Treatment' &amp; Tab &amp; productLog.treatmentCode);
	self.tblThumb.addItem('Length' &amp; Tab &amp; productLog.lengthCode);
	if _header.allStockOrderAllocations.size &gt; 0 then
		if _header.allStockOrderAllocations.first.myLocationsController &lt;&gt; null then
			self.tblThumb.addItem('Yard Location' &amp; Tab &amp; _header.allStockOrderAllocations.first.myLocationsController.getID());
		endif;
	endif;
	self.tblThumb.addItem('Unit of measure' &amp; Tab &amp; self.convertUnitsOfMeasure(_order.unitOfMeasure));
	self.tblThumb.addItem('Quantity' &amp; Tab &amp; _order.reqdQuantity.Integer.String);
	self.tblThumb.addItem('Comments' &amp; Tab &amp; _order.comments);
	
	self.tblThumb.addItem('Date/time created' &amp; Tab &amp; _header.user &amp; ' - ' &amp;_header.createdTime.Date.shortFormatJMT());
	self.tblThumb.addItem('Changes');
	self.tblThumb.addItem('Quantity delivered to date' &amp; Tab &amp; _header.getQuantityDelivered().String);
	self.tblThumb.addItem('Total number of dockets' &amp; Tab &amp; _header.allBOLOuts.size.String);
	foreach bolOut in _header.allBOLOuts do
		self.tblThumb.addItem('Docket - ' &amp; bolOut.number &amp; Tab &amp; bolOut.createdTime.Date.shortFormatJMT());
		if bolOut.myExtension &lt;&gt; null then 
			noNumbers := noNumbers + bolOut.myExtension.CM_BOLExtLogOut.allNoNumberLogs.size;
		endif;
	endforeach;
	self.tblThumb.addItem('Total no-numbers' &amp; Tab &amp; noNumbers.String);

end;</source>
        <access>protected</access>
        <Parameter name="_header" type="CM_StockOrderHeaderGeneric"/>
        <Parameter name="_order" type="CM_StockOrderProductLine"/>
    </JadeMethod>
    <JadeMethod name="enableRows" id="5561a33d-eeb1-4951-8465-f3b4ac3767de">
        <source>enableRows(_enable, _clear : Boolean) protected;

// cnwdvb1 22 October 2002 

vars

begin

	if _enable then
		self.tblInput1.enableRowByName(ETRow_CargoType);
		self.tblInput1.enableRowByName(ETRow_OrderNo);
	else
		self.tblInput1.disableRowByName(ETRow_CargoType);
		self.tblInput1.disableRowByName(ETRow_OrderNo);
	endif;
	
	if _clear then
		self.tblInput1.setValueByName(ETRow_OrderNo, null);
//		self.tblInput1.setValueByName(ETRow_Transfer, Choice_No);
//		self.cmbTransfer.text := Choice_No;
//		self.tblInput1.setValueByName(ETRow_Audit, Choice_No);
//		self.cmbAudit.text := Choice_No;
		self.tblInput1.setValueByName(ETRow_WholeRow, Choice_All);
		self.cmbWhole.text := Choice_All;
	endif;
	


end;</source>
        <access>protected</access>
        <Parameter name="_enable" type="Boolean"/>
        <Parameter name="_clear" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getProductType" id="04e2378f-18ef-44e6-98b0-6085f8bfafe1">
        <source>getProductType() : CM_Product protected;

// cnwdvb1 22 October 2002 

vars

	theCode			: String;
	myOperator		: CM_Operator;
	species,
	grade,
	type,
	treatment,
	length			: String;

begin

	if self.myCargoType.id = TI_CargoType_Log then
//		myOperator := self.cmbOperator.listObject.CM_Operator;
		myOperator := self.cmbOperator.myObject.CM_Operator;
		if myOperator = null then
			return null;
		endif;
		if self.cmbSpecies.myObject &lt;&gt; null then
			species := self.cmbSpecies.myObject.CM_Code.code;			
		endif;
		if self.cmbGrade.myObject &lt;&gt; null then
			grade := self.cmbGrade.myObject.CM_Code.code;			
		endif;
		
		if self.cmbType.myObject &lt;&gt; null then
			type := self.cmbType.myObject.CM_Code.code;			
		endif;
		
		if self.cmbTreatment.myObject &lt;&gt; null then
			treatment := self.cmbTreatment.myObject.CM_Code.code;			
		endif;
		
		if  self.cmbLength.myObject &lt;&gt; null then
			length := self.cmbLength.myObject.CM_Code.code;			
		endif;
		
		theCode := app.buildLogProductCode(	 species, grade, type, treatment, length);

		return myOperator.allProducts[TI_CargoType_Log, theCode];
	else
		return self.cmbProduct.listObject.CM_Product;
	endif;

end;</source>
        <access>protected</access>
        <ReturnType type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="getSOH" id="564cdb25-4b6a-4aaf-95a0-d39ee7a432c7">
        <source>getSOH(_location : CM_LocationsController) : CM_SOHLocation protected;

// cnwdvb1 23 October 2002 

vars

	index : Integer;

begin

	index := self.allLocations.indexOf(_location);
	if index &lt;&gt; 0 then
		return self.allSohLocations[index].CM_SOHLocation;
	endif;	

end;</source>
        <access>protected</access>
        <Parameter name="_location" type="CM_LocationsController"/>
        <ReturnType type="CM_SOHLocation"/>
    </JadeMethod>
    <JadeMethod name="includeObject" id="33dde3a7-0aac-4513-b154-20d693fb2fc3">
        <updating/>
        <source>includeObject(_order : CM_StockOrderHeader; _passport : CM_Passport): Boolean updating;


vars

	cargoType	: Integer;
	operator	: CM_Operator;
	stockOrder	: CM_StockOrderProductLine;


begin

	if _order.type = StockOrderHeaderType_Domestic then
		cargoType	:= self.cmbCargoTypeFlt.listObject.CM_CargoType.id;
		operator	:= self.cmbOperatorFlt.myObject.CM_Operator;
		stockOrder := _order.allStockOrderLines.first.CM_StockOrderProductLine;
		if stockOrder = null then
			return true;
		endif;
		if stockOrder.myProduct = null then
			return true;
		endif;
		if stockOrder.myProduct.cargoType = cargoType then
			if  operator = null or operator = _order.myOperator then
				return true;
			endif;
		endif;
	endif;
	return false;

end;</source>
        <Parameter name="_order" type="CM_StockOrderHeader"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initDataTable" id="c9dad414-4cfe-4851-8a2d-d3980b71b63b">
