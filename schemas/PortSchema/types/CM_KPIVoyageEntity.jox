    <JadeMethod name="getDisplayStringForAttribute" id="ba732896-b0ee-41ed-8d8e-7b8cf8c4605d">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Date		Who		Reason
08 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars

begin
	if _attrName = ETRow_VoyageCode then
		if self.myVoyage &lt;&gt; null then
			return self.myVoyage.code;
		else
			return null;
		endif;
	elseif _attrName = ETRow_TotalREEF then
		return self.getAllREEF().String;
	elseif _attrName = ETRow_TotalGENL then
		return self.getAllGENL().String;
	elseif _attrName = ETRow_TotalTI then
		return self.movesTI.String;
		//return self.getAllCARGO().String;
	elseif _attrName = ETRow_TotalExports then
		return self.getLoadAllItems().String;
	elseif _attrName = ETRow_TotalImports then
		return self.getDischargeAllItems().String;
	else
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDownHours" id="8aa07691-abb1-4595-b3ae-b4554676f668">
        <source>getDownHours():Decimal;
// ---------------------------------------------------------------------------
// Created:     05 August 2014 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// PAR 34360
// ---------------------------------------------------------------------------

vars
	aKPI		:CM_KPI;
	result	:Decimal [23, 8];
begin
	foreach aKPI in self.myVoyage.allVoyageKPIEntities discreteLock where aKPI.type = KPI_Type_VoyageCraneShift  do
		
		result := result + aKPI.CM_KPIVoyageCraneShift.hoursDown;	
	endforeach;
	
	return result.roundedTo (2);
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getGrossContainersPerHour" id="69293193-7afb-44ee-a2ec-ea91a4c02c2a">
        <source>getGrossContainersPerHour():Decimal;

/*

Purpose:		Data for Vessel Summary Report 

Parameters:			

Return Value:	Return containers per hour (gross)			


Date			Who		Reason
22 July 2008	concms1	Par 17586 - Initial creation

*/

vars
	hours	:Decimal[23,2];
begin
	hours := self.getGrossHours;
	
	if hours &lt;&gt; 0 then
		return (self.getTotalContainers / hours).roundedTo (1);
	endif;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getGrossHours" id="f06aa09d-9d34-49f0-afe6-33762ece2ead">
        <source>getGrossHours():Decimal;
/*
Date			Who		Reason
AUGUST 2010 AKB	Vessel Operations reports - Initial creation
*/

vars
	aKPI		:CM_KPI;
	result	:Decimal [23, 8];
begin
	foreach aKPI in self.myVoyage.allVoyageKPIEntities discreteLock where aKPI.type = KPI_Type_VoyageCraneShift  do
		result := result + aKPI.CM_KPIVoyageCraneShift.hoursGross;
	endforeach;
	
	return result.roundedTo (2);
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getGrossHours_Crane" id="6255c956-432f-40e7-bde7-16cfad9d26dd">
        <source>getGrossHours_Crane(_crane :CM_Crane):Decimal;
/*
Date			Who		Reason
30 July 2008	concms1	Vessel Operations reports - Initial creation
*/

vars
	kpi : CM_KPI;
	result	:Decimal [23, 8];
begin
	foreach kpi in self.myVoyage.allVoyageKPIEntities where kpi.type = KPI_Type_VoyageCraneShift  do
		if kpi.CM_KPIVoyageCraneShift.myCrane &lt;&gt; _crane then
			continue;
		endif;
		result := result + kpi.CM_KPIVoyageCraneShift.hoursGross;
	endforeach;
	
	return result;
epilog

end;</source>
        <Parameter name="_crane" type="CM_Crane"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getGrossMovesPerHour" id="fdfe51a3-e816-4709-aeb3-6b2608b49dd8">
        <source>getGrossMovesPerHour():Decimal;

/*

Purpose:		Data for Vessel Summary Report 

Parameters:			

Return Value:	Return moves per hour (gross)	


Date			Who		Reason
22 July 2008	concms1	Par 17586 - Initial creation

*/

vars
	hours	:Decimal [23,8];
	totMoves : Integer;
begin
	hours := self.hoursGross;
	
	if hours &lt;&gt; 0 then
		totMoves := self.getTotalMoves();

		return (totMoves / hours).roundedTo (1);
	endif;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getHoursNetLessDownTime" id="d32b4da5-a166-4888-9ada-c65bd7e61655">
        <source>getHoursNetLessDownTime(): Decimal;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars

begin

	return self.hoursNet - self.hoursDown;

epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
