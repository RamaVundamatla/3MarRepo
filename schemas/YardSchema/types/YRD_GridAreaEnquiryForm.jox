	self.myAssistant.showRestrictionsForm(theTA, YRD_PadArea.AreaMode_Labour, restrictionLabour,
										false,false, self.myMasterMenuAction);

end;</source>
        <access>protected</access>
        <Parameter name="_ta" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="doScrollToCorners" id="fe585da2-3d39-4680-b78e-2bc02d6a9838">
        <updating/>
        <source>doScrollToCorners(pCorner: Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     23 August 2004 by cnwrs2
