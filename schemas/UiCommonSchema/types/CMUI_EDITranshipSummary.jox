    <JadeMethod name="addToolbarControls" id="d747f0c0-c9c5-43dc-ab5a-fc6bf2ee47ba">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:     September 2007 cnwrs1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	toolbar	: CMUI_Toolbar;
begin
	inheritMethod();
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnShowSelector, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	toolbar.positionToolbarControls();
	toolbar.visible := true;

	toolbar := self.frmSelectToolbar;
	toolbar.addButton(self.btnSelect, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnResetSelector, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnCloseSelector, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.positionToolbarControls();
	toolbar.visible := true;
	self.setToolbarSearch();
end;</source>
        <access>protected</access>
    </JadeMethod>
