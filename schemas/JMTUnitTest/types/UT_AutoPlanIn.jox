    <JadeMethod name="tIsHazardousCriteria" id="daae1df2-a489-4af3-9a84-c04fe4f2c637">
        <source>tIsHazardousCriteria();
// cnwndl1
//29 August 2008	cnwdw1	
//
vars
	locations : CM_LCArray;
	ya: CM_YardAllocation;
	ti, tiHaz, tiHazLmtd, proxyTI: CM_TrackedItem;
	location: CM_LocationsController;
	hazards	: CM_HazardByCodeDict;
	hazard: CM_TIHazard;
	ta: CM_GridArea;
begin
	deleteTerminalArea("UTSTRD");
	ta := addStraddleStack("UTSTRD", 2, 2, 1);
	assertNotNullMsg(ta, "straddleStack");

	// Test that when Termuinal Config option is set, a limited haz is treated as hazardous
	setTerminalConfig(IncludeLQasHazardous, true);
	self.deleteContainer("TEST0000003");
	tiHazLmtd := self.addContainerOpts("TEST0000003", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	addTIHazard(tiHazLmtd, "1.0", true);
	self.assertTrueMsg(tiHazLmtd.isHazardous, "tiHazLmtd is not hazardous");

	setTerminalConfig(IncludeLQasHazardous, false);
	self.deleteContainer("TEST0000001");
	ti := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	self.deleteContainer("TEST0000002");
	tiHaz := self.addContainerOpts("TEST0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	addTIHazard(tiHaz, "1.0", false);
	self.assertTrueMsg(tiHaz.isHazardous, "tiHaz is not hazardous");

	self.deleteContainer("TEST0000003");
	tiHazLmtd := self.addContainerOpts("TEST0000003", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	addTIHazard(tiHazLmtd, "1.0", true);
	self.assertFalseMsg(tiHazLmtd.isHazardous, "tiHazLmtd is hazardous");
	
	create locations transient;
	locations.add(ta.allGridControllersByRowColumn[1, 1]);
	locations.add(ta.allGridControllersByRowColumn[1, 2]);
	
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_IsHazardous, CM_YADataBoolean.VALUE_FALSE, locations);
	location := app.autoPlanTiYA(self.getTerminal, ta, ti);
	self.assertEqualMsg(location, locations.first, "Did not autoplan non haz to correct location");

	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_IsHazardous, CM_YADataBoolean.VALUE_TRUE, locations);
	location := app.autoPlanTiYA(self.getTerminal, ta, ti);
	self.assertTrueMsg(location = null, "Location not null - planned non haz to haz ya");
	
	self.deleteYA("UT");
	// Should be able to plan a Hazard TI to a non hazardous YA
	ya := self.addYA1("UT", YACriteriaType_IsHazardous, CM_YADataBoolean.VALUE_TRUE, locations);
	location := app.autoPlanTiYA(self.getTerminal, ta, tiHaz);
	self.assertEqualMsg(location, locations.first, "Did not autoplan haz to correct location");

	self.deleteYA("UT");
	// Should be able to plan a Limited Hazard TI to a non hazardous YA
	ya := self.addYA1("UT", YACriteriaType_IsHazardous, CM_YADataBoolean.VALUE_FALSE, locations);
	location := app.autoPlanTiYA(self.getTerminal, ta, tiHazLmtd);
	self.assertEqualMsg(location, locations.first, "Did not autoplan hazLmtd to correct location");

	self.deleteYA("UT");
	// Should not be able to plan a Limited Hazard TI to a hazardous YA
	ya := self.addYA1("UT", YACriteriaType_IsHazardous, CM_YADataBoolean.VALUE_TRUE, locations);
	location := app.autoPlanTiYA(self.getTerminal, ta, tiHazLmtd);
	self.assertTrueMsg(location = null, "Location not null - planned ltd haz to haz ya");
	
	self.deleteYA("UT");
	// Add a Limited Hazard to a hazardous TI, should still be hazardous
	addTIHazard(tiHaz, "2", true);
	self.assertTrueMsg(tiHaz.isHazardous, "tiHaz is not hazardous");
	ya := self.addYA1("UT", YACriteriaType_IsHazardous, CM_YADataBoolean.VALUE_TRUE, locations);
	location := app.autoPlanTiYA(self.getTerminal, ta, tiHaz);
	self.assertEqualMsg(location, locations.first, "Did not autoplan haz to correct location");


epilog
	delete locations;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tIsTwentyCriteria" id="0f8ee65c-4e1b-4566-b490-eb9f72b6daee">
        <source>tIsTwentyCriteria();
// cnwndl1
//29 August 2008	cnwdw1	
//
vars
	locations : CM_LCArray;
	ya: CM_YardAllocation;
	ti20, ti40: CM_TrackedItem;
	location: CM_LocationsController;
	ta: CM_GridArea;
begin
	deleteTerminalArea("UTSTRD");
	ta:= addStraddleStack("UTSTRD", 2, 2, 1);
	assertNotNullMsg(ta, "straddleStack");

	self.deleteContainer("TEST0000001");
	self.deleteContainer("TEST0000002");
	ti20 := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	ti40 := self.addContainerOpts("TEST0000002", "4000", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	create locations transient;
	locations.add(ta.allGridControllersByRowColumn[1, 1]);
	locations.add(ta.allGridControllersByRowColumn[1, 2]);
	
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_IsTwenty, CM_YADataBoolean.VALUE_TRUE, locations);
	location := app.autoPlanTiYA(self.getTerminal, ta, ti20);
	self.assertEqualMsg(location, locations.first, "Did not autoplan 20 to correct location");

	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_IsTwenty, CM_YADataBoolean.VALUE_FALSE, locations);
	location := app.autoPlanTiYA(self.getTerminal, ta, ti20);
	self.assertTrueMsg(location = null, "Location not null");
	
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_IsTwenty, CM_YADataBoolean.VALUE_TRUE, locations);
	location := app.autoPlanTiYA(self.getTerminal, ta, ti40);
	self.assertTrueMsg(location = null, "Location not null");

	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_IsTwenty, CM_YADataBoolean.VALUE_FALSE, locations);
	location := app.autoPlanTiYA(self.getTerminal, ta, ti40);
	self.assertEqualMsg(location, locations.first, "Did not autoplan 40 to correct location");

epilog
	delete locations;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tMarkCriteria" id="8817f294-8d53-4d1f-88d0-3b7a8da9810b">
        <source>tMarkCriteria();
// cnwndl1
//29 August 2008	cnwdw1	
//
vars
	locations : CM_LCArray;
	ya: CM_YardAllocation;
	ti1, ti2: CM_TrackedItem;
	location: CM_LocationsController;
	bs1, bs2 : CM_BlockStack;
begin
	bs1 := addBlockStack("UTBS1", 100, null);
	bs2 := addBlockStack("UTBS2", 100, null);

	ti1 := self.addCannonAtLocation("UCAN1", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), bs1);
	self.opts.addAssoc("Mark", "XXX");
	self.opts.addAssoc("TotalWeight", 25);
	self.updateTI(ti1);
	assertEqual(ti1.mark, "XXX");
	
	ti2 := self.addCannonAtLocation("UCAN2", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), bs1);
	self.opts.addAssoc("Mark", "YY");
	self.opts.addAssoc("TotalWeight", 25);
	self.updateTI(ti2);
	assertEqual(ti2.mark, "YY");
	
	// Create a YA to match a container colour
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_Mark, "XXX", bs2.allLocationsControllers.first);
	assertEqual(ya.allCriteria.size, 1);
	assertTrue(ya.allCriteria.first.myYAData.isKindOf(CM_YADataString));

	// Test that a matching colour succeeds
	location := app.autoPlanTiYA(self.getTerminal, bs2, ti1);
	self.assertEqualMsg(location, bs2.allLocationsControllers.first, "Did not autoplan to correct location");

	// Test that a non matching colour fails
	location := app.autoPlanTiYA(self.getTerminal, bs2, ti2);
	self.assertNull(location);

epilog
end;
</source>
    </JadeMethod>
    <JadeMethod name="tMinMaxHeight1" id="78e6cc73-d975-4b55-b1bf-774c6ea8cabc">
        <source>tMinMaxHeight1();
// cnwndl1
//20 November 2008	cnwdw1	
// Test that a container can be planned to a location with min/max height set to 1
vars
	locations : CM_LCArray;
	ya: CM_YardAllocation;
	yaBlock: CM_YABlock;
	ti1, ti2, ti3: CM_TrackedItem;
	location: CM_LocationsController;
	ta: CM_GridArea;

begin
	deleteTerminalArea("UTSTRD");
	ta:= addStraddleStack("UTSTRD", 2, 2, 1);
	assertNotNullMsg(ta, "straddleStack");

	self.deleteContainer("TEST0000001");
	ti1 := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.deleteContainer("TEST0000002");
	ti2 := self.addContainerOpts("TEST0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.deleteContainer("TEST0000003");
	ti3 := self.addContainerOpts("TEST0000003", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	create locations transient;
	locations.add(ta.allGridControllersByRowColumn[1, 1]);
	locations.add(ta.allGridControllersByRowColumn[1, 2]);
	
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_IsTwenty, CM_YADataBoolean.VALUE_TRUE, locations);
	self.opts.purge();
	self.opts.addAssociation("MinHeight", 1);
	self.opts.addAssociation("MaxHeight", 1);
	yaBlock := ya.allYABlocksIn.first;
	self.updateYABlock(yaBlock);
	
	location := app.autoPlanTiYA(self.getTerminal, ta, ti1);
	self.assertEqualMsg(location, locations.first, "Did not autoplan ti1 to correct location");
	self.move(ti1, location);
	self.assertEqualMsg(ti1.myPrimaryActualLocation, location, "Did not move ti1 to correct location");

	location := app.autoPlanTiYA(self.getTerminal, ta, ti2);
	self.assertEqualMsg(location, locations.last, "Did not autoplan ti2 to correct location " &amp; CrLf &amp; getYAAutoPlanMessages);
	self.move(ti2, location);
	self.assertEqualMsg(ti2.myPrimaryActualLocation, location, "Did not move ti2 to correct location");

	// Try to autoplan a 3rd ti, should fail as YA is now full
	location := app.autoPlanTiYA(self.getTerminal, ta, ti3);
	self.assertNullMsg(location, "Did not fail to autoplan");
	
epilog
	delete locations;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tMinMaxHeight2" id="2f10ac24-2960-4723-8380-6a598a9d0bda">
        <source>tMinMaxHeight2();
// cnwndl1
//20 November 2008	cnwdw1	
// Test that a container can be planned to a location with min/max height set to 2
vars
	locations : CM_LCArray;
	ya: CM_YardAllocation;
	yaBlock: CM_YABlock;
	ti1, ti2, ti3: CM_TrackedItem;
	location: CM_LocationsController;
	ta: CM_GridArea;

begin
	deleteTerminalArea("UTSTRD");
	ta:= addStraddleStack("UTSTRD", 2, 2, 2);
	assertNotNullMsg(ta, "straddleStack");

	self.deleteContainer("TEST0000001");
	ti1 := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.deleteContainer("TEST0000002");
	ti2 := self.addContainerOpts("TEST0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.deleteContainer("TEST0000003");
	ti3 := self.addContainerOpts("TEST0000003", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	create locations transient;
	locations.add(ta.allGridControllersByRowColumn[1, 1]);
	locations.add(ta.allGridControllersByRowColumn[1, 2]);
	
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_IsTwenty, CM_YADataBoolean.VALUE_TRUE, locations);
	self.opts.purge();
	self.opts.addAssociation("MinHeight", 2);
	self.opts.addAssociation("MaxHeight", 2);
	yaBlock := ya.allYABlocksIn.first;
	self.updateYABlock(yaBlock);
	assertEqualMsg(yaBlock.getMinHeight, 2, "Minheight");
	assertEqualMsg(yaBlock.getMaxHeight, 2, "Maxheight");
	
	// Should fail as there are no containers at height 1
	location := app.autoPlanTiYA(self.getTerminal, ta, ti1);
	self.assertNullMsg(location, "Did not fail to autoplan");

	// Move a container to height 1
	self.move(ti1, locations.first);
	self.assertEqualMsg(ti1.myPrimaryActualLocation, locations.first, "Did not move ti1 to correct location");

	// try to autoplan again
	location := app.autoPlanTiYA(self.getTerminal, ta, ti2);
	self.assertEqualMsg(location, locations.first, "Did not autoplan ti2 to correct location");
	self.move(ti2, location);
	self.assertEqualMsg(ti2.myPrimaryActualLocation, locations.first, "Did not move ti2 to correct location");

	// Try to autoplan a 3rd ti, should fail as next free location at height 2 does not have conatiner at height 1
	location := app.autoPlanTiYA(self.getTerminal, ta, ti3);
	self.assertNullMsg(location, "Did not fail to autoplan");
	
epilog
	delete locations;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tOperatorCriteria" id="99f73962-99b1-496f-a40b-95d2aad7f5a7">
        <source>tOperatorCriteria();
// cnwndl1
//29 August 2008	cnwdw1	
//
vars
	locations : CM_LCArray;
	ya: CM_YardAllocation;
	ti: CM_TrackedItem;
	location: CM_LocationsController;
	ta: CM_TerminalArea;
begin
	deleteTerminalArea("UTSTRD");
	ta:= addStraddleStack("UTSTRD", 2, 2, 1);
	assertNotNullMsg(ta, "straddleStack");

	self.deleteYA("UT");
	self.deleteContainer("TEST0000001");
	
	create locations transient;
	locations.add(ta.allLocationsControllers.first.CM_YardController);
	ya := self.addYA1("UT", YACriteriaType_OperatorItem, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, locations);
	ti := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	location := app.autoPlanTiYA(self.getTerminal, ta, ti);
	self.assertEqualMsg(location, locations.first, "Did not autoplan to correct location");
	
epilog
	delete locations;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tOperatorPatternCriteria" id="bbb7d7d7-b21b-479b-8b17-8d77892acd8d">
        <source>tOperatorPatternCriteria();
// cnwndl1
//29 August 2008	cnwdw1	

vars
	locations : CM_LCArray;
	ya: CM_YardAllocation;
	ti1, ti2: CM_TrackedItem;
	location: CM_LocationsController;
	bs: CM_BlockStack;
	operator: CM_Operator;
begin
	self.disableAllYA(true);
	deleteTerminalArea("UTBS1");
	bs:= addBlockStack("UTBS1", 100, null);
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.deleteContainer("TEST0000001");
	ti1 := self.addContainerOpts("TEST0000001", "2200", "APPL", operator);
	
	// Create a YA to match pattern D*
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_OperatorItem, "UT*", bs.allLocationsControllers.first);
	assertEqual(ya.allCriteria.size, 1);
	assertTrue(ya.allCriteria.first.myYAData.isKindOf(CM_YADataPattern));

	// Test that a matching id succeeds
	location := app.autoPlanTiYA(self.getTerminal, bs, ti1);
	self.assertEqualMsg(location, bs.allLocationsControllers.first, "Did not autoplan  to correct location " &amp; self.getYAAutoPlanMessages);

	// Test that a non matching id fails
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_OperatorItem, "ZZZ*", bs.allLocationsControllers.first);
	assertEqual(ya.allCriteria.size, 1);
	assertTrue(ya.allCriteria.first.myYAData.isKindOf(CM_YADataPattern));

	location := app.autoPlanTiYA(self.getTerminal, bs, ti1);
	self.assertNullMsg(location, self.getYAAutoPlanMessages);

	// Create a YA to match pattern !A*
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_OperatorItem, "!ZZZ*", bs.allLocationsControllers.first);
	assertEqual(ya.allCriteria.size, 1);
	assertTrue(ya.allCriteria.first.myYAData.isKindOf(CM_YADataPattern));

	// Test that a matching id succeeds
	location := app.autoPlanTiYA(self.getTerminal, bs, ti1);
	self.assertEqualMsg(location, bs.allLocationsControllers.first, "Did not autoplan  to correct location " &amp; self.getYAAutoPlanMessages);

	// Test that a non matching id fails
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_OperatorItem, "!UT*", bs.allLocationsControllers.first);
	assertEqual(ya.allCriteria.size, 1);
	assertTrue(ya.allCriteria.first.myYAData.isKindOf(CM_YADataPattern));

	location := app.autoPlanTiYA(self.getTerminal, bs, ti1);
	self.assertNullMsg(location, self.getYAAutoPlanMessages);
	
	// Create a YA to match pattern A*,D*
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_OperatorItem, "A*,UT*", bs.allLocationsControllers.first);
	assertEqual(ya.allCriteria.size, 1);
	assertTrue(ya.allCriteria.first.myYAData.isKindOf(CM_YADataPattern));

	// Test that a matching id succeeds91
	location := app.autoPlanTiYA(self.getTerminal, bs, ti1);
	self.assertEqualMsg(location, bs.allLocationsControllers.first, "Did not autoplan to correct location " &amp; self.getYAAutoPlanMessages);

	// Test that a non matching id fails
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_OperatorItem, "A*,C*", bs.allLocationsControllers.first);
	assertEqual(ya.allCriteria.size, 1);
	assertTrue(ya.allCriteria.first.myYAData.isKindOf(CM_YADataPattern));

	location := app.autoPlanTiYA(self.getTerminal, bs, ti1);
	self.assertNullMsg(location, self.getYAAutoPlanMessages);

epilog
	self.disableAllYA(false);
end;
</source>
    </JadeMethod>
    <JadeMethod name="tOverstowCargo" id="c9e5ad3f-3e2d-479f-97c4-9ce152b4fcbd">
        <source>tOverstowCargo();
// cnwndl1
// 08 October cnwml2
// PAR25712
// Test that a container will fail if trying to autoplan to be above an overdimensional container
vars
	locations : CM_LCArray;
	ya: CM_YardAllocation;
	yaBlock: CM_YABlock;
	ti1, ti2, ti3: CM_TrackedItem;
	location: CM_LocationsController;
	ta: CM_GridArea;

begin
	self.disableAllYA(true);
	
	//create stradle stack
	deleteTerminalArea("UTSTRD");
	ta:= addStraddleStack("UTSTRD", 1, 1, 2);
	assertNotNullMsg(ta, "straddleStack");

	//create two containers, one which will be autplaned and the other which will be moved as an overdimensional ti
	self.deleteContainer("TEST0000001");
	self.opts.addAssociation(UTTI_OverHeight, 20);
	ti1 := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.deleteContainer("TEST0000002");
	ti2 := self.addContainerOpts("TEST0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	//setup valid locations for YA
	create locations transient;
	locations.add(ta.allGridControllersByRowColumn[1, 1]);
	
	//set config to false
	//self.setTerminalConfig(AutoPlanUseOverstowRules, false);		no need to do this now.
	
	//create YA
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_IsTwenty, CM_YADataBoolean.VALUE_TRUE, locations);
	self.opts.purge;
	yaBlock := ya.allYABlocksIn.first;
	self.updateYABlock(yaBlock);
	
	//move first ti to first location in straddle
	self.move(ti1, ta.allGridControllersByRowColumn[1, 1]);

	//try autoplanning second container on top of the first overdimensional container, this should fail
	location := app.autoPlanTiYA(self.getTerminal, ta, ti2);
	self.assertEqualMsg(location, null, "ti should not autoplan");
	self.assertEqualMsg(ti2.myPrimaryActualLocation, null, "ti hasn't been moved so should have no location");
	
epilog
	self.disableAllYA(false);
	delete locations;
end;</source>
    </JadeMethod>
    <JadeMethod name="tScenarioCargoType" id="0bffa737-9289-4364-95c7-c24ea36b4c54">
        <source>tScenarioCargoType();
// cnwndl1
//29 August 2008	cnwdw1	
// Test scenario planning 

vars
	ya: CM_YardAllocation;
	bs: CM_BlockStack;
	tiProxy: CM_Container;
	cmif: CMIF_YAAutoPlanSenario;
	numberOfLocations: Integer;
	cannon: CM_CargoType;
begin
	self.disableAllYA(true);
	deleteTerminalArea("UTBS1");
	bs:= addBlockStack("UTBS1", 100, null);

	// Create a YA to match pattern D*
	self.deleteYA("UT");
	cannon := self.getCargoType("CANNON");
	ya := self.addYA1("UT", YACriteriaType_CargoType, cannon, bs.allLocationsControllers.first);
	assertEqual(ya.allCriteria.size, 1);
	assertTrue(ya.allCriteria.first.myYAData.isKindOf(CM_YAData));

	// Test that a matching id succeeds
	create cmif transient;
	create tiProxy transient;
	tiProxy.setCargoType(cannon.id);
	cmif.attachTI(tiProxy);
	app.autoPlanSenario(self.getTerminal, null, cmif, numberOfLocations);
	self.assertEqual(numberOfLocations, 1);

epilog
	self.disableAllYA(false);
	delete cmif;
	delete tiProxy;
end;
</source>
    </JadeMethod>
