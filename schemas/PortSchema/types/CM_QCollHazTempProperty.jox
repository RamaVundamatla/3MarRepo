    <JadeMethod name="setComboValues" id="ce6bd346-9089-4617-be3b-bd120bb9fe39">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/11/2016	cnwdap1		Initial creation TFS 2844 STWR Hazardous Details Enhancements
//
vars
	hazTemp : CM_HazTempRange;
	hazTempDict : CM_HazTempRangeByValueDict;

begin
	_combo.clear();
	hazTempDict := app.myRoot.allHazTempRanges;
	
	foreach hazTemp in hazTempDict do
		_combo.itemObject[_combo.addItem(hazTemp.getDisplayDetails(false))] := hazTemp;
	endforeach;
epilog

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="7528137e-2485-4695-8a07-e00a8825a685">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/11/2016	cnwdap1		Initial creation TFS 2844 STWR Hazardous Details Enhancements
//
vars
	hazTempRange : CM_HazTempRange;
	hazTempRangeDict : CM_HazTempRangeByValueDict;
	idx, cnt, selectionValue : Integer;

begin
	_tbl.rows := _tbl.fixedRows;
	
	if _params = null then
		return;
	endif;
	hazTempRangeDict := app.myRoot.allHazTempRanges;
	foreach hazTempRange in hazTempRangeDict do
		selectionValue := 0;
		if _operator &lt;&gt; null and _operator.CM_QCollIncludesOneOf.allSelectionValues.includes(hazTempRange) then
			selectionValue := 1;
		endif;
		// to check
		if idx &gt;= JadeTableRowLimit then
			app.msgBox('Maximum number of entries in table exceeded.  Only the first ' &amp; JadeTableRowLimit.String &amp; ' will be shown', 'Error', MsgBox_OK_Only);
			break;
		endif;
		
		idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; hazTempRange.getDisplayDetails(false));
		_tbl.accessRow(idx).itemObject := hazTempRange;
		_tbl.row := idx;
		_tbl.change(_tbl);
	endforeach;

epilog

end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="7977547a-d183-4bc0-bcd7-dcb1ca0d29f1">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/11/2016	cnwdap1		Initial creation TFS 2844 STWR Hazardous Details Enhancements
//
vars
	str : String;
	numRows, idx : Integer;
	hazTempRangeDict : CM_HazTempRangeByValueDict;
	hazTempRange : CM_HazTempRange;

begin
	create hazTempRangeDict transient;
	
	numRows :=_tbl.rows;
	foreach idx in _tbl.fixedRows + 1 to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			hazTempRange := _tbl.accessRow(idx).itemObject.CM_HazTempRange;
			hazTempRangeDict.add(hazTempRange);
		endif;
	endforeach;
	
	_op.setSearchValue(hazTempRangeDict);

epilog
	delete hazTempRangeDict;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="913aab58-da14-4561-adcb-83d0f8d28e8e">
        <source>translateToDisplayValue(_value: Any): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/11/2016	cnwdap1		Initial creation TFS 2844 STWR Hazardous Details Enhancements
//
vars
	haz : CM_Hazard;
	str : String;

begin
	if _value.isKindOf(CM_HazTempRange) then
		if _value &lt;&gt; null then
			return _value.CM_HazTempRange.getDisplayDetails(false);
		else
			return null;
		endif;
		
	elseif _value.isKindOf(CM_HazardByCodeDict) then
		foreach haz in _value.CM_HazardByCodeDict do
			if str = null then
				str := haz.CM_TIHazard.getDisplayStringForAttribute(ETRow_Flashpoint, false);
			else
				str := SemiColon &amp; Space &amp; haz.CM_TIHazard.getDisplayStringForAttribute(ETRow_Flashpoint, false);
			endif;
		endforeach;
		return str;
	endif;
	
	return _value.String;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="ae3271f6-c732-4fce-9b76-e1e923aa2240">
        <source>translateToSearchValue(_value: Any): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/11/2016	cnwdap1		Initial creation TFS 2844 STWR Hazardous Details Enhancements
//
vars
	invalidObj : Boolean;
	object : CM_HazTempRange;
	returnVal : String;

begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then
			return _value;
		endif;
		
		if _value.isKindOf(CM_HazTempRange) then
			object := _value.CM_HazTempRange;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.getDisplayDetails(false);
	endif;
	
	return returnVal;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="c5b2b476-dd45-4612-99cf-e225f9f690d1">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	objSet : ObjectSet;
	object : Object;
	tempRange : CM_HazTempRange;
	result : String;
	hazTemp : CM_HazTempRange;
	collStr : String;
	coll : CM_HazTempRangeByValueDict;
	strArray : StringArray;
	str : String;

begin
	if _value.isKindOf(ObjectSet) then
		objSet := _value.ObjectSet;
		foreach object in objSet do
			tempRange := object.CM_HazTempRange;
			result := result &amp; tempRange.getDisplayDetails(false) &amp; CNEC_COMMA &amp; Space;
		endforeach;
		result := result[1:result.length-2];
		return result;
		
	elseif _value.isKindOf(String) then
		collStr := _value.String;
		if collStr.cnContains("|") then
			create strArray transient;
			create coll transient;
			collStr.getTokensForDelimiter("|", strArray);
			foreach str in strArray do
				foreach hazTemp in app.myRoot.allHazTempRanges discreteLock do
					if hazTemp.getDisplayDetails(false) = str then
						coll.addNoDuplicates(hazTemp, false);
					endif;
				endforeach;
			endforeach;
			return coll;
		endif;
		
		foreach hazTemp in app.myRoot.allHazTempRanges discreteLock do
			if hazTemp.getDisplayDetails(false) = _value.String then
				object := hazTemp;
				break;
			endif;
		endforeach;
	endif;
	
	return inheritMethod(_value, _sending);

epilog
	delete strArray;
end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
