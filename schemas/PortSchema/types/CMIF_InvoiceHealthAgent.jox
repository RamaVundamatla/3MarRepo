    <JadeMethod name="checkTransactionMap" id="e2b0c321-83e9-4084-a086-42573e0e9f04">
        <source>checkTransactionMap();
/*
Purpose:			
Date		Who		Reason
13 October 2016	cnwab1	Initial creation
*/

vars
	iter01 : Iterator;
	oArray : ObjectArray;
	theObj : CM_TranMap;
	allocTranMap : CM_TranMapCargoAllocation;
	eventTranMap : CM_TranMapEvent;
	voyTranMap : CM_TranMapVoyage;
	smap : CM_TranMapSSSummary;
	qmap : CM_QuantityMap;
	message : String;
	term : CM_Terminal;
	resourceBroker : CM_TransResourceServiceBroker;
	bu : CM_Bank;
begin

	// ### CARGO TRANS MAP
	create oArray transient;
	CM_TranMap.allInstances(oArray,0,true);
	iter01 := oArray.createIterator;
	
	while iter01.next(theObj) do
		bu := theObj.getBank();
		if bu = null then
			continue;
		endif;
		if not self.allBusinessUnits.includes(bu) then
			continue;
		endif;

		theObj.healthCheckIsValid(self);
		
	endwhile;
	delete oArray;

	
	
	// ### ALLOCATION TRANS MAP
	create oArray transient;
	CM_TranMapCargoAllocation.allInstances(oArray,0,true);
	iter01 := oArray.createIterator;
	
	while iter01.next(allocTranMap) do
		bu := allocTranMap.getBank();
		if bu = null then
			continue;
		endif;
		if not self.allBusinessUnits.includes(bu) then
			continue;
		endif;

		allocTranMap.healthCheckIsValid(self);
		
	endwhile;
	delete oArray;
	
	
	// ### EVENT TRANS MAP
	create oArray transient;
	CM_TranMapEvent.allInstances(oArray,0,true);
	iter01 := oArray.createIterator;
	
	while iter01.next(eventTranMap) do
		bu := eventTranMap.getBank();
		if bu = null then
			continue;
		endif;
		if not self.allBusinessUnits.includes(bu) then
			continue;
		endif;
		eventTranMap.healthCheckIsValid(self);
		
	endwhile;
	delete oArray;
		
	
	// ### VOYAGE TRANS MAP
	create oArray transient;
	CM_TranMapVoyage.allInstances(oArray,0,true);
	iter01 := oArray.createIterator;
	
	while iter01.next(voyTranMap) do
		bu := voyTranMap.getBank();
		if bu = null then
			continue;
		endif;
		if not self.allBusinessUnits.includes(bu) then
			continue;
		endif;
		voyTranMap.healthCheckIsValid(self);
		
	endwhile;
	delete oArray;
	
	// ### SUMMARY TRANS MAP
	create oArray transient;
	CM_TranMapSSSummary.allInstances(oArray,0,true);
	iter01 := oArray.createIterator;
	
	while iter01.next(smap) do
		bu := smap.getBank();
		if bu = null then
			continue;
		endif;
		if not self.allBusinessUnits.includes(bu) then
			continue;
		endif;
		smap.healthCheckIsValid(self);
		
	endwhile;
	delete oArray;
	
	
	
	
	// ### TASK RESOURCE TRANS MAP
	create oArray transient;
	CM_TransResourceServiceBroker.allInstances(oArray,0,true);
	iter01 := oArray.createIterator;
	
	while iter01.next(resourceBroker) do
		bu := resourceBroker.getBank();
		if bu = null then
			continue;
		endif;
		if not self.allBusinessUnits.includes(bu) then
			continue;
		endif;
		resourceBroker.healthCheckIsValid(self);
		
	endwhile;
	delete oArray;
	
	
	// ### QUANTITY MAP
	create oArray transient;
	CM_QuantityMap.allInstances(oArray,0,true);
	iter01 := oArray.createIterator;
	
	while iter01.next(qmap) do
		bu := qmap.getBank();
		if bu = null then
			continue;
		endif;
		if not self.allBusinessUnits.includes(bu) then
			continue;
		endif;
		qmap.healthCheckIsValid(self);
		
	endwhile;
	delete oArray;
	
	
	
epilog
	delete oArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="doHealthCheck" id="01829c4d-8d1b-4d9e-94e4-e68add551c35">
        <source>doHealthCheck();
/*
Purpose:			
Date		Who		Reason
14 September 2016	cnwab1	Initial creation
*/

vars

begin
	self.allHealthCheckDetails.purge();
	
	if self.itemTypesToQuery.isEmpty() then
		return;
	endif;
	
	if self.itemTypesToQuery.includes(CMIF_InvoiceHealthAgent.ItemType_InvoiceLineType) then
		self.checkInvoiceLineTypes();
		self.checkInvoiceLineMappings();
	endif;
	if self.itemTypesToQuery.includes(CMIF_InvoiceHealthAgent.ItemType_Service) then
		self.checkServices();
	endif;
	if self.itemTypesToQuery.includes(CMIF_InvoiceHealthAgent.ItemType_CalculationType) then
		self.checkCalculationTypes();
	endif;
	if self.itemTypesToQuery.includes(CMIF_InvoiceHealthAgent.ItemType_TranMapCargo) then
		self.checkTransactionMap();
	endif;
	if self.itemTypesToQuery.includes(CMIF_InvoiceHealthAgent.ItemType_InvoiceType) then
		self.checkInvoiceTypes();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="isValid" id="a9fe8ef2-9333-41e9-bb6d-9395cd3303c6">
        <source>isValid(_object : Object; _message : String output) : Boolean;
/*
Purpose:			
Date		Who		Reason
13 September 2016	cnwab1	Initial creation
*/

vars

begin
	if _object = null then
		_message := "Null Reference";
		return false;
	endif;
	if not global.isValidObject(_object) then
		_message := "Invalid Reference";
		return false;
	
	endif;
	return true;
epilog

end;</source>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_message" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
