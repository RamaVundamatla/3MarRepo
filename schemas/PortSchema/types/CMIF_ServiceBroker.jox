    <JadeMethod name="cloneMySelf" id="d5bda955-00ab-40ad-b628-e4297305bc2d">
        <source>cloneMySelf() : SelfType;
// ---------------------------------------------------------------------------
// Created:     14 May 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	copySelf : SelfType;
begin
	copySelf := self.cloneSelf(true);
	
	copySelf.haveCharged := self.haveCharged;
	copySelf.myBank := self.myBank;
	copySelf.myDebtor := self.myDebtor;
	copySelf.myEventTransaction :=  self.myEventTransaction;
	copySelf.myInvoiceLineDesc := self.myInvoiceLineDesc;
	copySelf.myServiceBroker := self.myServiceBroker;
	copySelf.myTrackedItem := self.myTrackedItem;
	copySelf.myTransaction := self.myTransaction;
	copySelf.myVTMISTransaction := self.myVTMISTransaction; 
	copySelf.myBOLTransaction := self.myBOLTransaction;
	
	return copySelf;
epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="getQRMFromLineType" id="bdb1ea73-fb58-4134-baa8-8e6b218d3330">
        <source>getQRMFromLineType(_ild : CM_InvoiceLineDesc) : CM_QuantityRangeMap;
// ---------------------------------------------------------------------------
// Created:     15 March 2011 by cnwab1  // PAR 27193
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 24/06/2015		cnwma1			PAR #36455 Null object issue
// ---------------------------------------------------------------------------

vars
	qrm : CM_QuantityRangeMap;
	obj : Object;
	mapping : CM_TranMapInvoiceLineMapping;
begin
	foreach obj in self.allQuantityRangeMaps  discreteLock do
		if obj &lt;&gt; null then										//24/06/2015 cnwma1 PAR #36455
			qrm := obj.CM_QuantityRangeMap;
			
			foreach mapping in qrm.allTMInvoiceLineMappings do // TFS 40620
				 // TFS 40620 if qrm.allInvoiceLinesUsed.includes(_ild) then 
				if _ild = mapping.myTMInvoiceLineDesc then // TFS 40620
					return qrm;
				endif;
			endforeach;// TFS 40620
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_ild" type="CM_InvoiceLineDesc"/>
        <ReturnType type="CM_QuantityRangeMap"/>
    </JadeMethod>
    <JadeMethod name="getQRMFromRange" id="68738a9c-e780-4c95-8480-6153301b92df">
        <source>getQRMFromRange(_start : Real) : CM_QuantityRangeMap;
//	CCMS SFW 1279 May 2012 Storage Escalating Charges
// 24/06/2015		cnwma1			PAR #36455 Null object issue
vars
	qrm : CM_QuantityRangeMap;
	obj : Object;
begin
	foreach obj in self.allQuantityRangeMaps  discreteLock do
		if obj &lt;&gt; null then										//24/06/2015 cnwma1 PAR #36455
			qrm := obj.CM_QuantityRangeMap;
			if qrm.rangeStart = _start then
				return qrm;
			endif;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_start" type="Real"/>
        <ReturnType type="CM_QuantityRangeMap"/>
    </JadeMethod>
</Class>
