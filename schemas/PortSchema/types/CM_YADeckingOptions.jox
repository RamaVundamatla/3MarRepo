    <JadeMethod name="getDisplayStringInOut" id="cab22273-b560-4dcc-a047-b82f77b1d80a">
        <source>getDisplayStringInOut(_in: Boolean): String;
//11 February 2009	cnwwc2	Initial creation

vars
	rule: CM_YADeckingRule;	
	optIn, optFilling, optOut : String;
begin
	if _in then
		if self.isAdvanced(DeckingDirectionIn) then
			rule := self.getAdvancedRule(DeckingDirectionIn); 
			if rule.areaRule = DeckingRule_ByStack or rule.areaRule = DeckingRule_ByStackFill then		
				optIn := app.getErrorString(DeckingStack) &amp; " " &amp; self.getStringFromConstant(rule.stackRule) &amp; ", ";
				optFilling := app.getErrorString(DeckingFillPattern) &amp; " " &amp;  self.getStringFromConstant(rule.patternRule) &amp; ", ";
				optOut := app.getErrorString(DeckingRow) &amp; " " &amp; self.getStringFromConstant(rule.rowRule);
			else
				optIn := app.getErrorString(DeckingRow) &amp; " " &amp; self.getStringFromConstant(rule.rowRule) &amp; ", ";
				optFilling :=app.getErrorString(DeckingFillPattern) &amp; " " &amp; self.getStringFromConstant(rule.patternRule) &amp; ", ";
				optOut := app.getErrorString(DeckingStack) &amp; " " &amp; self.getStringFromConstant(rule.stackRule);
			endif;
		else
			optIn := self.getStringFromConstant(DeckingRule_Custom);
		endif;
	else
		if self.isReverseOut then
			optIn := self.getStringFromConstant(DeckingRule_ReverseOfOther);
		else
			if self.isAdvanced(DeckingDirectionOut) then
				rule := self.getAdvancedRule(DeckingDirectionOut); 
				if rule.areaRule = DeckingRule_ByStack or rule.areaRule = DeckingRule_ByStackFill then		
					optIn := app.getErrorString(DeckingStack) &amp; " " &amp; self.getStringFromConstant(rule.stackRule) &amp; ", ";
					optFilling := app.getErrorString(DeckingFillPattern) &amp; " " &amp;  self.getStringFromConstant(rule.patternRule) &amp; ", ";
					optOut := app.getErrorString(DeckingRow) &amp; " " &amp; self.getStringFromConstant(rule.rowRule);
				else
					optIn := app.getErrorString(DeckingRow) &amp; " " &amp; self.getStringFromConstant(rule.rowRule) &amp; ", ";
					optFilling :=app.getErrorString(DeckingFillPattern) &amp; " " &amp; self.getStringFromConstant(rule.patternRule) &amp; ", ";
					optOut := app.getErrorString(DeckingStack) &amp; " " &amp; self.getStringFromConstant(rule.stackRule);
				endif;
			else
				optIn := self.getStringFromConstant(DeckingRule_Custom);
			endif;
		endif;
	
	endif;
	
	return optIn &amp; optFilling &amp; optOut;
end;</source>
        <Parameter name="_in" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
