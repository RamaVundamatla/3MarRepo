    <JadeMethod name="validateForUpdate" id="89c28555-1ba6-4f7a-9727-49e2db7de8b3">
        <source>validateForUpdate();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2011	#cnwdz2	 

*/

vars
	realClass : CM_DataExtractClass;
	testClass : CM_DataExtractClass;
begin
	self.validateCommon();
	
	realClass := self.pxyGetRealObject;
	if realClass = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, self.class.name, null, null);
	endif;	

	//testClass := app.myRoot.allDataExtractClasses[self.className];
	testClass := CM_DataExtractRoot.firstInstance.allDataExtractClasses[self.className];
	
	if testClass &lt;&gt; null and testClass &lt;&gt; realClass then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.className, null, null);
	endif;
epilog

end;</source>
    </JadeMethod>
</Class>
