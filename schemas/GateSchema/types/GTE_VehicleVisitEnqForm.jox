        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuAssocBooking_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

	vvr : CM_VehicleVisitRecord;

begin

	if not self.myTerminal.isVehicleBookingEnabled then
		return;
	endif;
	
	if self.myCurrentObject &lt;&gt; null then
		vvr := self.myCurrentObject.CM_VehicleVisitRecord;
	endif;
	
	if vvr = null or vvr.myVehicleBookingTimeslot &lt;&gt; null then
		return;
	endif;
	
	self.myAssistant.showVehicleBookingAssociation( self, vvr, null, null );

epilog

end;</source>
