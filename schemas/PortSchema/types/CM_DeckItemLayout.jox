    <JadeMethod name="hideContainerPositionsUnderGC" id="238d42f9-4cad-4ba3-99d0-49039cd93597">
        <updating/>
        <source>hideContainerPositionsUnderGC(_gcLayout : CM_DeckItemLayout) updating;
/*
Purpose:			
Date		Who		Reason
21 July 2011	cnwab1	Initial creation
*/

vars
	oldCoveringPolygon, 
	newCoveringPolygon : CM_DeckItemLayout;
begin
	if self = _gcLayout then
		return;
	endif;

	/* PAR 31166
	oldCoveringPolygon:=self.allCoveringPolygons[_gcLayout.type];
	if oldCoveringPolygon &lt;&gt; null then
		self.allCoveringPolygons.remove(oldCoveringPolygon);
	endif;
	*/
	if not self.allCoveringPolygons.includes(_gcLayout) then
		self.allCoveringPolygons.add(_gcLayout);
	endif;
	
epilog

end;</source>
