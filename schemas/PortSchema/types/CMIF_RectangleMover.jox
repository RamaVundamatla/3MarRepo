<Class name="CMIF_RectangleMover" id="50744a98-5256-42c0-ac55-4f080245ea4f">
    <superclass name="CMIF_RectangleManipulator"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="temp"/>
    <JadeMethod name="calculateOutline" id="2796e158-2f9e-48e1-8807-ea8dd03232bf">
        <updating/>
        <source>calculateOutline(currentX: Real; currentY: Real) updating;
// ---------------------------------------------------------------------------
// Created:		November 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	cosineVal, sineVal : Real;
	point, newPoint : Point;
	delta : Real;
	tmpOrient : Real;
	theCurrentX, theCurrentY : Integer;
begin
	
	theCurrentX := (currentX.Integer - self.originalX.Integer);
	theCurrentY := currentY.Integer - self.originalY.Integer;
	
	newPoints.clear;
	
	foreach point in self.originalPoints do
		newPoint.setX(point.x + theCurrentX);
		newPoint.setY(point.y + theCurrentY);
		newPoints.add(newPoint);
	endforeach;				

end;</source>
        <Parameter name="currentX" type="Real"/>
        <Parameter name="currentY" type="Real"/>
    </JadeMethod>
</Class>
