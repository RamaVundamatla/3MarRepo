    <JadeMethod name="convertPositionToColumn" id="c2ae05e5-443f-4a76-9af6-564e9184097b">
        <updating/>
        <source>convertPositionToColumn(xPos : Real) : Integer updating;
//
//	return the table column who's left &amp; width position covers the x coordinate passed
//
vars
	originalColumn		: Integer;
	loopIndex			: Integer;
	rightMostPos		: Real;
	rightMost			: Integer;
begin
	originalColumn := self.column;

	if self.fixedColumns &gt; 0 then
		loopIndex := 1;
		while loopIndex &lt;= self.fixedColumns do
			self.column := loopIndex;
			if self.positionLeft &lt;= xPos then
				if self.columnVisible[loopIndex] then
					if xPos &lt;= (self.positionLeft + self.columnWidth[loopIndex]) then
						self.column := originalColumn;
						return(loopIndex);
					endif;
				endif;
			endif;
			if self.positionLeft &gt; rightMostPos then
				rightMostPos := self.positionLeft;
				rightMost := loopIndex;
			endif;
			loopIndex := loopIndex + 1;
		endwhile;
		rightMostPos := 0;
		rightMost := 0;
	endif;

	loopIndex := self.leftColumn;
	while loopIndex &lt;= self.columns do
		self.column := loopIndex;
		if self.positionLeft &lt;= xPos then
			if self.columnVisible[loopIndex] then
				if xPos &lt;= (self.positionLeft + self.columnWidth[loopIndex]) then
					self.column := originalColumn;
					return(loopIndex);
				endif;
			endif;
		endif;
		if self.positionLeft &gt; rightMostPos then
			rightMostPos := self.positionLeft;
			rightMost := loopIndex;
		endif;
		loopIndex := loopIndex + 1;
	endwhile;
	if rightMost = 0 then
		rightMost := 1;
	endif;

	self.column := originalColumn;
	return(rightMost);
end;</source>
        <Parameter name="xPos" type="Real"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="convertToCrLf" id="4f2dcc35-e399-4f31-a9bf-31a2fb1bb854">
        <source>convertToCrLf(textIn : String) : String;

vars
	headingText				: String;
	pos						: Integer;
begin
	headingText := textIn;
	pos := headingText.pos('|',1);
	while pos &gt; 0 do
		if pos &lt; headingText.length then
 			headingText := headingText[1:pos-1] &amp; CrLf &amp; headingText[pos+1:end];
 		else
 			headingText := headingText[1:pos-1] &amp; CrLf;
 		endif;
		pos := headingText.pos('|',1);
	endwhile;
	return(headingText);
end;</source>
        <Parameter name="textIn" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="copyToClipboard" id="efed5a0c-1067-4345-b3d1-11c7b8d0f170">
        <updating/>
        <source>copyToClipboard(selectedOnly:Boolean) updating;


vars
	thisRow,
	thisCol, 
	maxCol,
	hMem 					: Integer;
	pMem 					: Integer;
	hClipMem				: Integer;
	s 						: String ;
	obj						: Object;
	wasInLoadState			: Boolean;	
	iter					: Iterator;
begin
	if selectedOnly then 
		iter := selectedObjects.createIterator();
	elseif not disableVirtualScroll then
		iter := myIterator.getCollection.createIterator();
	else
		thisRow:=2;
		while thisRow &lt;= rows do
			thisCol:=2;
			while thisCol &lt;= columns do
				if thisCol = 2 then
					s := s &amp; getCellText(thisRow, thisCol);
				else
					s := s &amp; Tab &amp; getCellText(thisRow, thisCol);
				endif;
				thisCol := thisCol + 1;
			endwhile;
			thisRow := thisRow + 1;
			s := s &amp; CrLf;
		endwhile;
	endif;

	// If iter is not null then we are doing a collection rather than the table
	if iter &lt;&gt; null then
		wasInLoadState := process.isInLoadState;
		if not wasInLoadState then
			beginLoad;
		endif;

		// Go through and build the text for each object 
		while iter.next(obj) do
			// Make sure the object is not excluded from the table
			if not excludeObject(obj) then
				thisCol := 2;
				maxCol := self.columns;		
				// Build each column for this object using displayEntry
				//    Note that combo boxes do not have a value put out
				while thisCol &lt;= maxCol do
					if columnInputTypeArray[thisCol - 1][1:1] &lt;&gt; Table.InputType_ComboBox.String then
						if thisCol = 2 then
							s:= s &amp; self.displayEntry(self, obj, columnHeadingArray[thisCol - 1]);
						else
							s:= s &amp; Tab &amp; self.displayEntry(self, obj, columnHeadingArray[thisCol - 1]);
						endif;							
					endif;
					thisCol := thisCol + 1;
				endwhile;
				s := s &amp; CrLf;
			endif;
		endwhile;
	endif;

	// allocate moveable memory
	hMem := call cnEcGlobalAlloc(GHND,s.length + 1);
	// lock the block and get a pointer
	pMem := call cnEcGlobalLock(hMem);
	// copy from my string to the memory location
	pMem := call cnEcLstrcpyToInteger(pMem,s);
	// unlock the global memory
	if not (call cnEcGlobalUnlock(hMem).Boolean) then
		if (call cnEcGetLastError &lt;&gt; 0) then
			app.msgBox('Could not unlock memory', app.name, MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;		
	endif;
	// open the clipboard
	if not (call cnEcOpenClipboard(null)).Boolean then
			app.msgBox('Could not open clipboard', app.name, MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
	endif;			
	// empty its contents
    call cnEcEmptyClipboard;
    // now copy the moveable memory filled with our string to the clipboard
    hClipMem := call cnEcSetClipboardData(1,hMem);
epilog
	// close the clpboard	
	if not (call cnEcCloseClipboard()).Boolean then
	   app.msgBox("Could not close clipboard", app.name, MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);  	   
	   return;
	endif;

	if iter &lt;&gt; null then
		delete iter;
	endif;

	if not wasInLoadState then
		endLoad;
	endif;
end;</source>
        <Parameter name="selectedOnly" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="76965b38-b1c8-4dbf-a75a-aa71ac13ee85">
