<Class name="WS_RestRelReqByIdResponse" id="5fd24df1-0e26-4ef3-8c81-99ed5181f9b7">
    <superclass name="WS_RestReleaseRequestRes"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="restwebservice"/>
    <ImplicitInverseRef name="cargo" id="e8224a7d-7ac0-4559-887e-965bf1e02b80">
        <memberTypeInverse/>
        <type name="WS_ReleaseDetailByIdObjArray"/>
    </ImplicitInverseRef>
    <JadeMethod name="delete" id="1baf4492-06de-4266-8db8-ad0b377a0cac">
        <updating/>
        <source>delete() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/06/2024	navdap1		Initial creation TFS 63107 CUX | GET /releaseRequest API to return release request line items
//
vars

begin
	if self.cargo &lt;&gt; null then
		self.cargo.purge;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="7c6457fd-3e65-4a83-98e5-94106739ba19">
        <updating/>
        <source>setProxyFromObject(_releaseReq: CM_BulkRelease) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/06/2024	navdap1		Initial creation TFS 63107 CUX | GET /releaseRequest API to return release request line items
//
vars
	detail : CM_ReserveDetail;
	tiDetail : CM_ReserveTI;
	resDetail : WS_ReleaseDetailByIdObject;

begin
	inheritMethod(_releaseReq);
	
	foreach detail in _releaseReq.allReserveDetails do
		if not detail.isKindOf(CM_ReserveTI) then
			continue;
		endif;
		
		tiDetail := detail.CM_ReserveTI;
		create resDetail transient;
		resDetail.setProxyFromObject(tiDetail);
		
		self.cargo.add(resDetail);
	endforeach;
epilog

end;</source>
        <Parameter name="_releaseReq" type="CM_BulkRelease"/>
    </JadeMethod>
</Class>
