Date		Who		Reason
05 September 2013	cnwer1	Initial creation PAR 32408

*/

vars
	ct : CM_CargoType;
begin
	if self.getTrackedItem &lt;&gt; null then
		
		return false;
	endif;
	
	//17 Jul 2017	NDL	TFS 5408
	if self.isAnyAmount then
