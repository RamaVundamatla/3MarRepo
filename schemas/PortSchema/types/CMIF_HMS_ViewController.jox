    <JadeMethod name="buildView_PermVoyagesInPort" id="d5a98b27-14c1-42f1-a776-b13c9c4ca908">
        <updating/>
        <source>buildView_PermVoyagesInPort() updating;
//-----------------------------------------
// Created: 14 June 2005 By: cnwgd1
//-----------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 19/06/2014	cnwdap1		PAR #34422 Remove beginLock / endLock
// 30/03/2016	cnwdap1		PAR #35843 Make monitor time-based rather that number of objects based
vars
	voyage:				CM_Voyage;
	termIter,
	iter1,
	iter2:				Iterator;
	lastVoyageInRange:	Boolean;
	terminal:			CM_Terminal;
	theUser:			CM_User;
	tmpMonitor:			CMIF_Monitor;
	message:			String;
	partsDone,
	partsInJob,
	count:				Integer;
	lastUpdated:		Decimal [20];						// PAR #35843
	
begin
	// PAR 10234 - if ship arrives before start date and leaves after start date then it should be displayed.
	/*
	1: Ships arriving within the view window period
	2: Ships leaving within the view window period
	3: Ships which neither arrive nor leave, but whose visit overlaps the view window period
   	*/
   		
	// Clear collection
	self.allPermanentVoyagesInView.clear();
	
	// Clear selected movement 
	self.setMySelectedMovement(null);

   	if self.myHarbour = null then
   		return;
   	endif;
   	
   	tmpMonitor := app.myPassport.myCMIFMonitor;
	
   	if tmpMonitor &lt;&gt; null then
   		partsDone := tmpMonitor.partsDone;
   		partsInJob := tmpMonitor.partsInJob;
   		message := tmpMonitor.message;
   	endif;
   	
   	theUser := app.getMyUser();
	termIter := self.allTerminalsSelectedForView.createIterator();
	
	while termIter.next(terminal) do
		if (not theUser.canDo(terminal, PmHMSGraphicalView)) then
			// The user does not have permission to view voyages for this terminal
			continue;
		endif;

		iter1 := terminal.allVoyagesByArrivalDTCode.createIterator;
		
		// PAR 14203 Reset this boolean so we can see voyages in other terminals
		lastVoyageInRange:=false; 
		
		// Get voyages for this terminal that are in port at some stage during the date range
		count := 0;	
		
		while (iter1.next(voyage) and (not lastVoyageInRange)) do
			if tmpMonitor &lt;&gt; null then
				// count only applicable if monitor is being used			
				count := count + 1;
				
				//if count mod 200 = 0 then																	// PAR #35843
				if (app.relativeMachineTime - lastUpdated) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	// PAR #35843
					if (not tmpMonitor.updateProgress(message, partsInJob, partsDone)) then	
						return;
					endif;
					lastUpdated := app.relativeMachineTime;													// PAR #35843
				endif;
			endif;
	
			if voyage.myHMSVoyageData = null then
				// Voyage does not have any harbour data and therefore cannot be displayed in view
				continue;
			endif;
			
			if self.includeVoyageInView(voyage) then				
				// This voyage should be included the view
				self.allPermanentVoyagesInView.add(voyage);
			else
				if voyage.arrivedDT &gt;= self.viewFinishDT then 
				    // No other voyages need be considered
					lastVoyageInRange := true;
				endif;
			endif;
			
			//endLock;			// PAR #34422
		endwhile;
		
		delete iter1; 
	endwhile;
epilog
	endLock;					// PAR #34422
	delete termIter;
	delete iter1;
	delete iter2;
end;</source>
    </JadeMethod>
    <JadeMethod name="buildView_RangeChange" id="1b157fd7-7d2c-453f-8a7b-ac24a6c06917">
        <updating/>
        <source>buildView_RangeChange() updating;
//-----------------------------------------
// Created: September 2004 By: cnwgd1
//-----------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 19/06/2014	cnwdap1		PAR #34422 Remove beginLock / endLock
constants
	LOOKBACKDAYS = 200;	//The time in days prior to the start DT that we enter the arrivedDT dict.
vars
	voyage:				CM_Voyage;
	termIter,
	iter1,
	iter2:				Iterator;
	lastVoyageInRange:	Boolean;
	lookFromDT: 		TimeStamp;
	terminal:			CM_Terminal;
	theUser:			CM_User;
begin
	
	self.view_BuildBackground();
	
   	if self.myHarbour = null then
   		return;
   	endif;
   	
   	theUser := app.getMyUser();
//	lookFromDT := ((viewStartDT.Date - LOOKBACKDAYS).String &amp; ", 00:00:00:00").TimeStamp;
	lookFromDT.setDate(viewStartDT.date - LOOKBACKDAYS);
	lookFromDT.setTime(null);
	termIter := self.allTerminalsSelectedForView.createIterator();	
	
	while termIter.next(terminal) do
		if (not theUser.canDo(terminal, PmHMSGraphicalView)) then
			continue;
		endif;
		iter1 := terminal.allVoyagesByArrivalDTCode.createIterator;
		terminal.allVoyagesByArrivalDTCode.startKeyGeq(lookFromDT, null, iter1);	
		
		// PAR 14203 Reset this boolean so we can see voyages in other terminals
		lastVoyageInRange:=true;
		
		while (iter1.next(voyage) and lastVoyageInRange=false) do
			if voyage.myHMSVoyageData = null then
				continue;
			endif;
			// add to range only, will be added to below
			if self.voyage_AddToRange(voyage.myHMSVoyageData) = null then			
			//if self.voyage_AddToView(voyage.myHMSVoyageData) = null then
				if voyage.arrivedDT &gt; viewFinishDT then 
				    //No other voyages need be considered
					lastVoyageInRange:=true;
				endif;
			endif;
			endLock;			// PAR #34422
		endwhile;
		delete iter1; 
	endwhile;

	self.view_BuildEntireForeground();
	//self.view_BuildForegroundForXViews();	
	
epilog
	endLock;					// PAR #34422
	delete termIter;
	delete iter1;
	delete iter2;
end;</source>
    </JadeMethod>
    <JadeMethod name="buildView_WharfCollections" id="5463fed8-ac25-43ba-ade0-18bde86aa1cb">
        <updating/>
        <source>buildView_WharfCollections() updating;

vars
begin
	// Copy all wharves from harbour.allWharves into a transient collection on the controller
	self.allWharves.clear;
	if self.myHarbour = null then
		return;
	endif;
	self.myHarbour.allWharves.copy(self.allWharves);
end;</source>
    </JadeMethod>
    <JadeMethod name="buildView_WorkingVoyageAndMove" id="5bb3f264-ede5-4758-b569-7db31da5a375">
        <updating/>
        <source>buildView_WorkingVoyageAndMove() updating;
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 19/06/2014	cnwdap1		PAR #34422 Remove beginLock / endLock
// 30/03/2016	cnwdap1		PAR #35843 Make monitor time based raher than object count based
// 07 Jan 2025	navah1 		Bug 8441: EUP - 1310 UHE in Graphical View
vars
	permanentVoyage: 	CM_Voyage;
	workingVoyage:		CMIF_HMS_WorkingVoyage;
	workingMovement:	CMIF_HMS_WorkingMovement;
	msgBoxType:			Integer;
	msgString:			String;
    selectDT : 			TimeStamp;
	tmpMonitor: 		CMIF_Monitor;
	partsDone,
	partsInJob,
	count:				Integer;
	message:			String;
	globalVoyage		: CM_VoyageGlobal;
	cmifGlobalVoyage	: CMIF_VoyageGlobal;
	allCMIFGlobalVoyages : DynaDictionary;
	lastUpdated			: Decimal [20];									// PAR #35843
begin
	tmpMonitor := app.myPassport.myCMIFMonitor;
	if tmpMonitor &lt;&gt; null then
		message := tmpMonitor.message;
		partsDone := tmpMonitor.partsDone;
		partsInJob := tmpMonitor.partsInJob;
	endif;

	//self.checkAllChanges(); 
	
	// Build new collection of permanent voyages that are in the current view 
	//self.buildView_PermVoyagesInView();
	self.buildView_PermVoyagesInPort();

	// Clear existing deleted movement and voyage collections
	self.allDeletedVoyages.clear;
	self.allDeletedMovements.clear;

	// Clear all changes
	self.allChanges.purge;
	self.allNotableObjects.clear;

	self.currentChangeStackPosition:=0;

	// Clear existing view voyage and movement collections
	self.allVoyagesViewedByArrvDT.clear;
	self.allVoyagesViewedByCode.clear;
	self.allVoyagesViewedByDeptDT.clear;
	self.allMovementsInViewByDT.clear;


	// Delete all existing working voyages and movements
	self.allWorkingVoyages.purge;
	self.allWorkingMovements.purge;

	// Delete all existing working resources used
	self.allWorkingResourcesUsed.purge;

	create allCMIFGlobalVoyages transient;
	allCMIFGlobalVoyages.setMembership(CMIF_VoyageGlobal);
	allCMIFGlobalVoyages.addMemberKey(CMIF_VoyageGlobal::voyageCode.name,false,true);
	allCMIFGlobalVoyages.endKeys(false);
	// Create working voyages (and movements) and add the working voyages
	// to the view voyage collections
	count := 0;
  	foreach permanentVoyage in self.allPermanentVoyagesInView do
		workingVoyage:=self.createWorkingVoyageMovement(permanentVoyage);
		if globalVoyage = null or globalVoyage &lt;&gt; permanentVoyage.getGlobalVoyage then
			cmifGlobalVoyage:=allCMIFGlobalVoyages.getAtKey(permanentVoyage.code).CMIF_VoyageGlobal;
			
			if permanentVoyage.getGlobalVoyage &lt;&gt; null and cmifGlobalVoyage = null then
				create cmifGlobalVoyage transient;
				cmifGlobalVoyage.setFromPersistent(permanentVoyage.getGlobalVoyage);
				
				if allCMIFGlobalVoyages.getAtKey(cmifGlobalVoyage.voyageCode) = null then					// 07.01.2025 navah1 #8441 
					allCMIFGlobalVoyages.add(cmifGlobalVoyage);
				endif;
			endif;
		endif;
		workingVoyage.setMyCMIF_VoyageGlobal(cmifGlobalVoyage);
		globalVoyage:=permanentVoyage.getGlobalVoyage;
		if tmpMonitor &lt;&gt; null then		
			count := count + 1;
			//if count mod 100 = 0 then																		// PAR #35843
			if (app.relativeMachineTime - lastUpdated) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then		// PAR #35843
				if (not tmpMonitor.updateProgress(message, partsInJob, partsDone)) then
					return;
				endif;
				lastUpdated := app.relativeMachineTime;														// PAR #35843
			endif;
		endif;
  	endforeach;

  	// Build collection of working movements
  	/*foreach workingVoyage in allVoyagesViewedByCode do
  		foreach workingMovement in workingVoyage.allWorkingMovements do
  			workingMovement.myViewControllerCurrent := self;
  		endforeach;
  	endforeach;*/

  	// Update wharves collection
	//self.buildView_WharfCollections(); 
	// update view
	//view_BuildBackground;
	//view_BuildEntireForeground;
	
epilog
	delete allCMIFGlobalVoyages;
	//endLock;							// PAR #34422
end;</source>
    </JadeMethod>
    <JadeMethod name="causeEventForObjects" id="c884cfed-09c0-4a7e-87be-234603a533f2">
        <source>causeEventForObjects();
//--------------------------------------------------
// Created:	30 July 2004 By: cnwgd1
//--------------------------------------------------
// 30 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
vars
	voyageDataObj	: HMS_VoyageData;
	voyageObj		: CM_Voyage;
	globalObj		: CM_VoyageGlobal;
	allGlobalsObj	: CM_VoyageGlobalSet;
	
begin
	create allGlobalsObj transient;
	
	foreach voyageDataObj in self.allNotableObjects do
		if not global.isValidObject(voyageDataObj) then
			continue;
		endif;
		
		self.updateObjectEdition(voyageDataObj);	// par 30292
		
		voyageObj	:=	voyageDataObj.myVoyage;
		
		if voyageObj &lt;&gt; null then
			self.updateObjectEdition(voyageObj);	// par 30292
			
			globalObj	:=	voyageObj.myVoyageGlobalArrival;
		endif;
		
		if globalObj &lt;&gt; null and (not allGlobalsObj.includes(globalObj)) then
			allGlobalsObj.add(globalObj);
		endif;
	endforeach;
	
	foreach globalObj in allGlobalsObj do
		self.updateObjectEdition(globalObj);	// par 30292
	endforeach;
epilog
	delete allGlobalsObj;
end;</source>
    </JadeMethod>
    <JadeMethod name="changeApply" id="7ea889ba-123b-40a6-8650-3425afd1a0c7">
        <updating/>
        <source>changeApply(change: CMIF_HMS_StackChange; redoChange, _refreshView : Boolean) updating;

/*

Date		Who		Reason
14 Apr 2008	cnwkpd1	PAR #16517 - Handle possiblity of stacked changes being out of synch with
					pointer.
					
*/

vars
  	changeToApply:	CMIF_HMS_StackChange;
  	stackPosn:		Integer;
  	changeToDelete:	CMIF_HMS_StackChange;	
  	previousChange:	CMIF_HMS_StackChange;
begin
	changeToApply := change;

 	// If currentChangeStackPosition is not at end of stack, 
 	// then delete all changes from current position to end of stack
 	if redoChange = false then
 		stackPosn := self.currentChangeStackPosition;
 		if stackPosn &lt; self.allChanges.size then
 			// Delete changes down to end of stack
 			while self.currentChangeStackPosition &lt; self.allChanges.size do
 				stackPosn := self.currentChangeStackPosition+1;
 				if allChanges[stackPosn].isKindOf(CMIF_HMS_VoyageAdd) then
 					delete allChanges[stackPosn].CMIF_HMS_VoyageAdd.appliesToVoyage;
 				elseif allChanges[stackPosn].isKindOf(CMIF_HMS_VoyageEdit) then
 					delete allChanges[stackPosn].CMIF_HMS_VoyageEdit.appliesToVoyage;
 				elseif allChanges[stackPosn].isKindOf(CMIF_HMS_MovementAdd) then
 					delete allChanges[stackPosn].CMIF_HMS_MovementAdd.appliesToMovement;
 				elseif allChanges[stackPosn].isKindOf(CMIF_HMS_MovementEdit) then
 					delete allChanges[stackPosn].CMIF_HMS_MovementEdit.appliesToMovement; 
 				endif;
 				changeToDelete := self.allChanges[stackPosn];
 				self.allChanges.remove(changeToDelete);
 				delete changeToDelete;
 			endwhile;
 		endif;
		// Add change to stack
 		self.allChanges.add(changeToApply);
 	endif;

	changeToApply.applyChange();

	// Check to see if any clearances need to be recalculated
	// Modified by Russell 15/10/99 
	// -------------------------------------
	// Only check clearances when both movements in a "change pair" have been applied
	if changeToApply.redoNext=false and changeToApply.undoNext=false then
		// Single change only - ie no pairs - check clearances now
		recalc_Clearances(changeToApply,RecalcClearance_Mode_Apply);
	elseif changeToApply.redoNext=true and changeToApply.undoNext=false then
		// First movement in change pair - don't check clearances yet
	elseif changeToApply.redoNext = false 
	and changeToApply.undoNext = true 
	and self.currentChangeStackPosition &gt;= 1 then
		// Check clearances for both changes
		// Get previous change and check clearances
		if self.currentChangeStackPosition &lt;= self.allChanges.size then		// PAR #16517
			previousChange := self.allChanges[self.currentChangeStackPosition];
			if previousChange &lt;&gt; null then
				self.recalc_Clearances(previousChange, RecalcClearance_Mode_Apply);
			endif;
		endif;
		// Check clearances for this change
		self.recalc_Clearances(changeToApply, RecalcClearance_Mode_Apply);	
	endif;
	// -------------------------------------

 	// Move changeStack pointer down 
 	self.currentChangeStackPosition := currentChangeStackPosition+1;

 	// Refresh views
 	if changeToApply.isKindOf(CMIF_HMS_VoyageAdd) 
 	or changeToApply.isKindOf(CMIF_HMS_VoyageDelete) 
 	or changeToApply.isKindOf(CMIF_HMS_VoyageEdit) then
 		self.view_BuildEntireForeground();
 		return;
 	endif;
 	
 	if (not _refreshView) then
		//Don't refresh view as done outside this method to prevent multi refresh
 	elseif changeToApply.isKindOf(CMIF_HMS_MovementAdd) then
    	self.view_ChangeAPPLY(changeToApply.CMIF_HMS_MovementAdd.appliesToMovement.versionPrevious,changeToApply.CMIF_HMS_MovementAdd.appliesToMovement);
  
    elseif changeToApply.isKindOf(CMIF_HMS_MovementEdit) then
    	self.view_ChangeAPPLY(changeToApply.CMIF_HMS_MovementEdit.appliesToMovement.versionPrevious,changeToApply.CMIF_HMS_MovementEdit.appliesToMovement);

    elseif changeToApply.isKindOf(CMIF_HMS_MovementDelete) then
    	self.view_ChangeAPPLY(changeToApply.CMIF_HMS_MovementDelete.appliesToMovement,changeToApply.CMIF_HMS_MovementDelete.appliesToMovement.versionPrevious);
    endif;

end;</source>
        <Parameter name="change" type="CMIF_HMS_StackChange"/>
        <Parameter name="redoChange" type="Boolean"/>
        <Parameter name="_refreshView" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="changeRedo" id="825652ec-564a-4237-a480-2c3621745b70">
        <updating/>
        <source>changeRedo() updating;

vars
	nextChange:	CMIF_HMS_StackChange;
begin
	// This method is called when the redo button is clicked. The method calls the
	// redoChange method on the HMS_StackChange object that is currently being pointed 
	// to in the allChanges array, and rolls foward the change stack pointer.

	if self.currentChangeStackPosition &lt; self.allChanges.size then  
		// There are changes in the stack that can be redone
		nextChange := self.allChanges[self.currentChangeStackPosition+1];
		self.changeApply(nextChange, true, true);

		// Redo next change if it is part of a pair
		if nextChange.redoNext = true then
			self.changeRedo();
		endif;		

 	endif;


end;</source>
    </JadeMethod>
    <JadeMethod name="changeUndo" id="7c36f3bb-9ce4-4f38-ab9a-64fc3a41a4b7">
        <updating/>
        <source>changeUndo() updating;

vars
	lastChange:	CMIF_HMS_StackChange;
	nextChange:	CMIF_HMS_StackChange;
begin
	// This method is called when the undo button is clicked. The method calls the
	// undoChange method on the HMS_StackChange object that is currently being pointed 
	// to in the allChanges array, and rolls back the change stack pointer.

	if self.currentChangeStackPosition &gt; 0 
	and self.currentChangeStackPosition &lt;= self.allChanges.size then  
		// There are changes in the stack that can be undone
		lastChange := self.allChanges[self.currentChangeStackPosition];
		self.currentChangeStackPosition := self.currentChangeStackPosition-1;
 		lastChange.undoChange;

 		// Check to see if any clearances need to be recalculated
		//recalc_Clearances(lastChange);


		// Check to see if any clearances need to be recalculated
		// Modified by Russell 15/10/99 
		// -------------------------------------
		// Only check clearances when both movements in a "change pair" have been undone
		if lastChange.redoNext=false and lastChange.undoNext=false then
			// Single change only - ie no pairs - check clearances now
			recalc_Clearances(lastChange,RecalcClearance_Mode_Undo);
		elseif lastChange.redoNext=true and lastChange.undoNext=false and currentChangeStackPosition+2&lt;=allChanges.size then
			// First movement in change pair - check clearances now
			// Check clearances for first change in pair
			recalc_Clearances(lastChange,RecalcClearance_Mode_Undo);
			// Get 2nd change in pair and check clearances
			nextChange:=allChanges[currentChangeStackPosition+2];
			if nextChange&lt;&gt;null then
				recalc_Clearances(nextChange,RecalcClearance_Mode_Undo);
			endif;
		elseif lastChange.redoNext=false and lastChange.undoNext=true then
			// Last movement in change pair - don't check clearances yet		
		endif;
		// -------------------------------------

		// Refresh views
 		if lastChange.isKindOf(CMIF_HMS_VoyageAdd) or lastChange.isKindOf(CMIF_HMS_VoyageDelete) then
 			view_BuildEntireForeground();
 		elseif lastChange.isKindOf(CMIF_HMS_VoyageEdit) then
 			view_BuildEntireForeground();
 		elseif lastChange.isKindOf(CMIF_HMS_MovementAdd) then
  		  	view_ChangeAPPLY(lastChange.CMIF_HMS_MovementAdd.appliesToMovement.versionPrevious,lastChange.CMIF_HMS_MovementAdd.appliesToMovement);
  		elseif lastChange.isKindOf(CMIF_HMS_MovementEdit) then
   		 	view_ChangeAPPLY(lastChange.CMIF_HMS_MovementEdit.appliesToMovement.versionPrevious,lastChange.CMIF_HMS_MovementEdit.appliesToMovement);
    	elseif lastChange.isKindOf(CMIF_HMS_MovementDelete) then
    		view_ChangeAPPLY(lastChange.CMIF_HMS_MovementDelete.appliesToMovement.versionPrevious,lastChange.CMIF_HMS_MovementDelete.appliesToMovement);
    	endif;

    	// Modified by Russell 08/04/99
		// ---------------------------------------------------------------
		// Undo next change if it is part of a pair
		if lastChange.undoNext=true then
			changeUndo;
		endif;		
		// ---------------------------------------------------------------
 	endif;


end;</source>
    </JadeMethod>
    <JadeMethod name="changeViewRange" id="b709f108-0280-46be-b2e0-af9c559c7f7e">
        <updating/>
        <source>changeViewRange(_newStartDT, _newEndDT : TimeStamp; _selectedTerminals : Collection) : Boolean updating;
//--------------------------------------------------
// Created:	02 August 2004 By: cnwgd1
//--------------------------------------------------
vars
	origStartDT,
	origEndDT : TimeStamp;
	userChoice,
	msgBoxType:	Integer;
	msgString :	String;	
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	origStartDT := self.viewStartDT;
	origEndDT := self.viewFinishDT;
	
	if origStartDT = _newStartDT
	and origEndDT = _newEndDT then
		if _selectedTerminals = null then
			return true;
		endif;
	endif;
	
	if _newStartDT &gt;= _newEndDT then
		app.raiseCMException1(EndBeforeStart, 'Range', null, null);
		return false;
	endif;		


	if self.allChanges.size &gt; 0 then
 		// Changes in stack - discard y/n
 		msgBoxType := MsgBox_Yes_No_Cancel+MsgBox_Question_Mark_Icon;
		msgString := app.getErrorString(MSGBOX_UnsavedChanges); 
		userChoice := app.msgBox(msgString, app.getErrorString(MSGBOX_UnsavedChangesTitle), msgBoxType);
		if userChoice = MsgBox_Return_Yes then
			// return yes - save changes, then refresh view
			if self.saveViewChanges() then
				self.viewStartDT := _newStartDT;
				self.viewFinishDT := _newEndDT;
				self.setSelectedTerminals(_selectedTerminals);
				self.doRefreshView(true);
			else
				return false;					
			endif;
		elseif userChoice = MsgBox_Return_No then
			// return no - refresh view below
	 		msgBoxType := MsgBox_Yes_No_Cancel+MsgBox_Question_Mark_Icon;
			msgString := app.getErrorString(MSGBOX_Discard_Unsaved_Changes); 
			userChoice := app.msgBox(msgString, app.getErrorString(MSGBOX_UnsavedChangesTitle), msgBoxType);

			self.setSelectedTerminals(_selectedTerminals);
			self.viewStartDT := _newStartDT;
			self.viewFinishDT := _newEndDT;						
			
			if userChoice = MsgBox_Return_No then
				// change range only, do not discard unsaved changes			
				self.buildView_RangeChange();
			else
				// rebuild entire view, changes will be lost
				self.doRefreshView(true);					
			endif;
		endif;	
 	else
 		// No changes for this user - Proceed with update
		self.viewStartDT := _newStartDT;
		self.viewFinishDT := _newEndDT;
		self.setSelectedTerminals(_selectedTerminals);
		// Refresh the visit view as a result of the changed view range dates
		self.doRefreshView(true);		
 	endif;

	return true;
epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="_newStartDT" type="TimeStamp"/>
        <Parameter name="_newEndDT" type="TimeStamp"/>
        <Parameter name="_selectedTerminals" type="Collection"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createWorkingVoyageMovement" id="3704a48e-f0ff-475a-a1f0-b0bbf365e989">
        <source>createWorkingVoyageMovement(_permanentVoyage : CM_Voyage) : CMIF_HMS_WorkingVoyage protected;
//--------------------------------------------------
// Created:	05 August 2004 By: cnwgd1
//--------------------------------------------------
vars
	workingMovement : CMIF_HMS_WorkingMovement;
	workingVoyage : CMIF_HMS_WorkingVoyage;
begin
	create workingVoyage transient;
	workingVoyage.copyVoyage(_permanentVoyage,self);
	// Add workingVoyage to view voyage collections
	workingVoyage.ofCurrentView := self;

  	// Build collection of working movements
	foreach workingMovement in workingVoyage.allWorkingMovements do
		workingMovement.myViewControllerCurrent := self;
	endforeach;

	return workingVoyage;
end;</source>
        <access>protected</access>
        <Parameter name="_permanentVoyage" type="CM_Voyage"/>
        <ReturnType type="CMIF_HMS_WorkingVoyage"/>
    </JadeMethod>
