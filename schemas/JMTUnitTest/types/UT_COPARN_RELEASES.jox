    <JadeMethod name="doCheckEDITiRequestMulti" id="f0d7fb29-702d-43d9-9426-7c4121cfb820">
        <source>doCheckEDITiRequestMulti(_ediHeaderTI :CM_EDIRequestHeaderTI; _ediItemTI :CM_EDIRequestDetailTI; _mode, _releaseNo, _voyageCode, _vesselName, _operatorCode, _consignorCode, _consigneeCode, 
						_isoType, _extraTextAAI, _extraTextSIN,_extraTextHAN  :String;
						_quantity :Integer; _ediPartyRules :CM_EDIPartyCoparnRules; _reqTS, _estReqTS :TimeStamp; 
						_isUnknownVoyage, _checkDefaultGrades, _checkGenerator, _checkDates, _heavyRated, _releaseByType :Boolean) protected;
/*
Date		Who		Reason
01/12/2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
05/03/2012	cnwcs5	par 29210 - include vessel name in consignor voyage
23/04/2012	cnwcs5	CCMS POL 2172 / par 29480 - coparn release updates
19/02/2012	cnwcs5	CCMS pnl 2243 / PAR 31185
21/02/2013	cnwcs5	CCMS PNL 2243 / par 31185
// 17 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
*/
vars
	isoType	:CM_ISOType;
	tokens	:StringArray;
	today	:Date;
	str		:String;	// par 29210 - March 2012
begin
	self.assertEqualMsg (_ediHeaderTI.messageMode, _mode, _releaseNo &amp; ' Type should be ' &amp; _mode);
	self.assertEqualMsg (_ediHeaderTI.releaseRequestNumber, _releaseNo, _releaseNo &amp; ' Release number incorrect');
	self.assertEqualMsg (_ediHeaderTI.releaseByType, _releaseByType, _releaseNo &amp; ' Release by type not set');
	self.assertEqualMsg (_ediHeaderTI.cargoType, TI_CargoType_Container, _releaseNo &amp; ' Cargo type incorrect');
	self.assertEqualMsg (_ediHeaderTI.cargoSubType, null, _releaseNo &amp; ' Cargo sub type incorrect');
	self.assertEqualMsg (_ediHeaderTI.bookingRef, null, _releaseNo &amp; ' Booking incorrect');
	
	if _isUnknownVoyage then
		self.assertEqualMsg (_ediHeaderTI.getVoyageCode, _ediPartyRules.myDefaultVoyage.code, _releaseNo  &amp; '(' &amp; _mode &amp; ')  Voyage is incorrect');
	else
		self.assertEqualMsg (_ediHeaderTI.getVoyageCode, _voyageCode, _releaseNo &amp; '(' &amp; _mode &amp; ')  Voyage is incorrect');
	endif;
	
	self.assertEqualMsg (_ediHeaderTI.vesselName, _vesselName, 'Vessel is incorrect');
	self.assertEqualMsg (_ediItemTI.billOfLading, null, 'BOL is not null');
	self.assertEqualMsg (_ediHeaderTI.releaseType, _ediPartyRules.defaultReleaseType.String, 'Release type incorrect');
	self.assertEqualMsg (_ediHeaderTI.statusBulkRelease, app.releaseStatusEnumToString(_ediPartyRules.defaultReleaseStatus), 'Status incorrect');		// par 31185 Feb 3012
	
	if _checkDates then 
		if _reqTS &lt;&gt; null then
			self.assertEqualMsg (_ediHeaderTI.requestDate, _reqTS, _releaseNo &amp; ' Request date incorrect'); 
		endif;
		
		if _estReqTS &lt;&gt; null then
			self.assertEqualMsg (_ediHeaderTI.estimatedRequiredDate, _estReqTS, _releaseNo &amp; ' Estimated required date incorrect'); 
		endif;
	else
		self.assertNotNullMsg (_ediHeaderTI.requestDate, _releaseNo &amp; ' Request date should have a value');
		self.assertEqualMsg (_ediHeaderTI.requestDate.date, today, _releaseNo &amp; ' Request date should be today');
	endif;
	
	self.assertEqualMsg (_ediHeaderTI.carrierCode,_ediPartyRules.myDefaultCarrier.code, ' Carrier incorrect');
	// self.assertEqualMsg (_ediHeaderTI.dischargePort, ???, ' Discharge port incorrect');
	// self.assertEqualMsg (_ediHeaderTI.loadPort, ???, 'Load port incorrect');
	self.assertEqualMsg (_ediHeaderTI.operatorCode, _operatorCode, ' Operator incorrect');
	self.assertEqualMsg (_ediHeaderTI.operatorGroup, null, 'Operator group incorrect');
	self.assertEqualMsg (_ediHeaderTI.consignee, _consigneeCode, _releaseNo &amp; ' Consignee incorrect');
	self.assertEqualMsg (_ediHeaderTI.consignor, _consignorCode, 'Consignor incorrect');
	// consignor voyage should be set as follows:
	// - voyage code if file contained xlation for voyage
	// - code from file if voyage was not xlated
	if _isUnknownVoyage then
		str := _voyageCode &amp; ' ' &amp; _vesselName;	// par 29210 - March 2012
		
		if str.length &gt; 20 then					// par 29210 - March 2012
			str := str [1:20];					// par 29210 - March 2012
		endif;									// par 29210 - March 2012
		
		self.assertEqualMsg (_ediHeaderTI.consignorVoyage, str, 'Consignor voyage incorrect - should equal voyage code from file');	// par 29210 - March 2012	
	else
		str := _ediHeaderTI.getVoyageCode &amp; ' ' &amp; _ediHeaderTI.vesselName;	// par 29210 - March 2012
		
		if str.length &gt; 20 then					// par 29210 - March 2012
			str := str [1:20];					// par 29210 - March 2012
		endif;									// par 29210 - March 2012

		self.assertEqualMsg (_ediHeaderTI.consignorVoyage, str, 'Consignor voyage incorrect - should match voyage code');	// par 29210 - March 2012
	endif;
	
	self.assertEqualMsg (_ediHeaderTI.freightForwarder, null, 'Freight forwarder incorrect');
	self.assertEqualMsg (_ediHeaderTI.businessUnit, null, 'Business unit incorrect');
	self.assertEqualMsg (_ediHeaderTI.deliveryReason, _ediPartyRules.defaultDeliveryReasonCode, 'delivery reason incorrect');// delivery reason
	//self.assertEqualMsg (_ediHeaderTI.???, ????, 'Additional required information incorrect');// additional req information
// TFS 2686	self.assertEqualMsg (_ediHeaderTI.removeStops, false, 'Remove stops incorrect');// remove stops
	self.assertEqualMsg (_ediHeaderTI.mtRelease, true, _releaseNo &amp; ' MT Release should be true');// MTs only
	//self.assertEqualMsg (_ediHeaderTI.???, ???, 'Destination terminal incorrect');// destination terminal
	self.assertEqualMsg (_ediItemTI.isoType, _isoType, _releaseNo &amp; ' ISO Type incorrect');// ISO type
	
	isoType := app.myRoot.allISOTypes [_isoType];
	
	self.assertNotNullMsg (isoType, 'ISO type not defined');
	
	if _ediPartyRules.useISOGroupForReleaseRequests then
		// check ISO group
		self.assertEqualMsg (_ediItemTI.checkISOGroup, true, 'Check ISO group incorrect');
		
		// ISO Group
		if isoType.myISOTypeGroup &lt;&gt; null then
			self.assertEqualMsg (_ediItemTI.isoTypeGroup, isoType.myISOTypeGroup.code, 'ISO Type Group incorrect'); 
		endif;
	endif;
	
	if _checkDefaultGrades then
		tokens := _ediItemTI.availabilityGrades.getTokens (); 
		
		if isoType.isReefer then
			self.assertTrueMsg (tokens.includes (_ediPartyRules.defaultAvailabilityGradeReefer.String) ,_releaseNo &amp; ' Default Reefer Availability grade incorrect'); 
		else
			self.assertTrueMsg (tokens.includes(_ediPartyRules.defaultAvailabilityGrade.String),_releaseNo &amp; ' Default Availability grade incorrect'); 
		endif;	
	else
		// must have come from file - TBA
		// ???
	endif;
	// clean should default to true for reefers and false otherwise
	if isoType.isReefer then													// par 29137
		self.assertEqualMsg (_ediItemTI.clean, true, 'Clean setting incorrect- should be true for reefer');	// par 29137
	else																		// par 29137
		self.assertEqualMsg (_ediItemTI.clean, false, 'Clean setting incorrect - should false for non-reefer');	// par 29137
	endif;																		// par 29137
	
	self.assertEqualMsg (_ediItemTI.heavyDuty, _heavyRated, _ediHeaderTI.releaseRequestNumber &amp; ' - Heavy duty incorrect');
    if _quantity = 0 then
       str := "Humbug";
    endif;
	self.assertEqualMsg (_ediItemTI.quantity, _quantity, 'Quantity incorrect');
	
	if _extraTextAAI &lt;&gt; null then	
		self.assertNotNull (_ediHeaderTI.remarks);
		self.assertTrueMsg (_ediHeaderTI.remarks.pos (_extraTextAAI, 1) &gt; 0, _releaseNo &amp; ' Additional text from FTX+AAI not stored in cargo remarks');
	endif;
	if _extraTextSIN &lt;&gt; null then
		self.assertNotNull (_ediHeaderTI.remarks);
		self.assertTrueMsg (_ediHeaderTI.remarks.pos (_extraTextAAI, 1) &gt; 0, _releaseNo &amp; ' Additional text from FTX+SIN not stored in cargo remarks');
	endif;
	if _extraTextHAN &lt;&gt; null then
		self.assertNotNull (_ediHeaderTI.remarks);
		self.assertTrueMsg (_ediHeaderTI.remarks.pos (_extraTextHAN, 1) &gt; 0, _releaseNo &amp; ' Additional text from FTX+HAN not stored in cargo remarks');
	endif;

	
	self.assertEqualMsg (_ediItemTI.ids, null, 'ID mask incorrect');
	self.assertEqualMsg (_ediHeaderTI.customsAgent, null, 'Customa agent incorrect');
	self.assertEqualMsg (_ediHeaderTI.customsAssistance, false, 'Customa assistance incorrect');
	self.assertEqualMsg (_ediHeaderTI.allowCargoMultiReleases, false, 'Allow multi-release cargo incorrect');

epilog
	delete tokens;
end;</source>
