    <JadeMethod name="setForCreateInternal" id="6051913b-31e1-4bb5-8c38-1d0825abb3ab">
        <updating/>
        <source>setForCreateInternal(_packInternalJobParam : CMIF_WorkOrderJobParams;_terminal : CM_Terminal) updating;


/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 July 2009	cnwrd1	Initial creation

*/


vars
	req : CM_PackRequest;
begin

	self.myTerminal := _terminal;
	self.id := _packInternalJobParam.jobId;
	//self.type := _todoInternalJobParam.typeToCreate;

	self.allTrackedItems.clear();
	_packInternalJobParam.allTIs.copy(self.allTrackedItems);
	
	self.isPackParentJob := _packInternalJobParam.isPackParentJob;
	self.myWODtl := _packInternalJobParam.myWorkOrderDtl.CM_WorkOrderTIDtl;
	
	
	//---------------
	//Build a Request
	//---------------
	create req;	
	req.setForCreateInternal(self, _packInternalJobParam);
	//---------------
	//Build the WLEs' from the request.
	//---------------
	self.createWLEs();

	self.addToJobSheet();
	

end;</source>
        <Parameter name="_packInternalJobParam" type="CMIF_WorkOrderJobParams"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
