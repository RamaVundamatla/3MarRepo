    <JadeMethod name="deleteAllLogModuleTest" id="57980692-4d11-44ed-9e56-d91bb6914bc3">
        <source>deleteAllLogModuleTest();
//03 September 2010	cnwvu1

vars
	
begin
	
	//-----------------------------------------------------------------
	//			delete your locations, dockets, logs etc. here. 
	//			P.S. A log row is deleted in self.deleteLogArea()
	//-----------------------------------------------------------------

	self.deleteAllForWeightUpdate();
	self.deleteAllForConsignorTest();
	self.deleteAllForUpdateTest();
	

	//-----------------------------------------------------------------
	//				COMMON Log Test Objects deletion
	//-----------------------------------------------------------------
	self.deleteLogArea(LogAreaCode);
	self.deleteRTDevice(RTDeviceId);
	self.deleteVehicle(VehicleId);
	self.deleteCarrier(CarrierCode);
	self.createDelProductForLogModuTest(false);
	self.deleteOperator(OperatorCode);
	self.deleteLogSpecs(LogSpecsName);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="iLotRJDtesttemp" id="cf43c3a7-bc6a-48f5-9bec-d13456232495">
        <source>iLotRJDtesttemp();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 May 2014	cnwrd1	Initial creation
// 17/08/2016 cnwrh7	TFS	2501

*/


vars
	//codeGroup		: CM_CodeGroup;
	logSpecs		: CM_CodeGroupLogSpecs;
	logType			: CM_LogType;
	logTreatment	: CM_LogTreatment;
	logLen			: CM_LogLength;
	logSpecies		: CM_LogSpecies;
	logGrade		: CM_LogGrade;
	operator		: CM_Operator;
	logArea			: CM_LogArea;

begin

	//-------------------------------------------------------------------------
	//				Creation of objects for Log Module Test
	//              17/08/2016 cnwrh7	TFS	2501
	//-------------------------------------------------------------------------
	//delete whole log spec
	self.setStrictBOLNumberRule(true);
	self.deleteAllLogModuleTest();
	
	logSpecs	:= self.addLogSpecs(LogSpecsName);
	logType		:= self.addLogType(		LogSpecsTypeBoff,		LogSpecsTypeBoffDesc,		false, logSpecs);
	logType		:= self.addLogType(		LogSpecsTypeBon,		LogSpecsTypeBonDesc,		false, logSpecs);
	logTreatment:= self.addLogTreatment(LogSpecsTreatmentUTN,	LogSpecsTreatmentUTNDesc,	false, logSpecs);
	logTreatment:= self.addLogTreatment(LogSpecsTreatmentUTT,	LogSpecsTreatmentUTTDesc,	false, logSpecs);
	logLen		:= self.addLogLength(	LogSpecsLength2,		LogSpecsLength2Desc,		false, logSpecs);
	logLen		:= self.addLogLength(	LogSpecsLength6,		LogSpecsLength6Desc,		false, logSpecs);
	logLen		:= self.addLogLength(	LogSpecsLength8,		LogSpecsLength8Desc,		false, logSpecs);
	logSpecies	:= self.addLogSpecies(	LogSpecsSpeciesOak,		LogSpecsSpeciesOakDesc,		false, logSpecs);
	self.createGradesForLogModuleTest();
	
	operator := self.addOperatorForLogs(OperatorCode,OperatorDesc,LogSpecsName);

	// need to create CM_ProductLog for possible all combinations	
	self.createDelProductForLogModuTest(true);
	
	self.createVehicleForLogModuleTest();
	self.addRTDevice(RTDevice_HandHeld, RTDeviceId, RTDeviceModel, "PC_LOGS_UT", null, false, false,false); // when creating BOLIn and logs via XML, it requires some RT Device code,   // +17/08/2016 cnwrh7	TFS	2501

	logArea := self.addLogArea(LogAreaCode, "UT Log Area");

	//------------------------------------------------------------------------------
	//							ALL LOG TESTS SECTION
	//------------------------------------------------------------------------------
	
	// DOCKET WEIGHT UDPATE TEST
	self.logBolAutoTest();

		
epilog
	self.setStrictBOLNumberRule(false);
	app.myPassport.getTIAuditController().initialiseTransaction;	// deletes the subTransactionController transient.
end;</source>
    </JadeMethod>
