    <JadeMethod name="setLabel" id="5995e863-f429-4479-8ae9-1405d53068e0">
        <updating/>
        <source>setLabel(pLabel : String; pIdx : Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     04 December 2001 by cnwrs2
//
// Purpose:     If the label is null then we set to '_' and the row or column.
//				This is because we have a unique index by label.  Validation
//				ensures that users cannot input a code with a leading '_'.
//
// Parameters:  pLabel = the label.
//				pIdx = the row or column
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if pLabel = null then
		self.label	:= '_' &amp; pIdx.padLeadingWith("0",4);
	else
		self.label	:= pLabel;
	endif;


end;</source>
        <access>protected</access>
        <Parameter name="pLabel" type="String"/>
        <Parameter name="pIdx" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setPxyGPS" id="5e7144a0-477a-4c7f-b2e2-1455e72fa26b">
