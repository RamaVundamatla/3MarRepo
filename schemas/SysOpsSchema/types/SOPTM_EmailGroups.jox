    <JadeMethod name="initShtMultiSelect" id="d2f13d3e-3f08-4e86-b198-7517353a0f07">
        <source>initShtMultiSelect();
// -------------------------------------------
// Created 18 September 2003 by cnwdvb1
// -------------------------------------------
vars

	theForm	: SOP_TableMaintForm;
	
begin

	theForm := self.myForm;
	inheritMethod;	
	self.setupMultiSelect1('Email Addresses',self.allEmailAddresses,SOP_TableMaintForm::displayEntryEmailGroups.name);
	theForm.mulSelect1.mySelectedListBox.sorted := false;	

end;</source>
    </JadeMethod>
