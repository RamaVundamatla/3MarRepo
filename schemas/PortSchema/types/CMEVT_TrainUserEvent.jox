<Class name="CMEVT_TrainUserEvent" id="e78be7db-4418-45b9-bf86-b677fa6ef5fc">
    <superclass name="CM_EventTransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="eventTrans"/>
    <ExplicitInverseRef name="myTrain" id="ca2eff7d-8a1a-4ace-b7e1-30b28d82863d">
        <transientToPersistentAllowed/>
        <embedded/>
        <type name="CM_Train"/>
        <access>readonly</access>
        <Inverse name="CM_Train::allTransactions"/>
    </ExplicitInverseRef>
    <JadeMethod name="convertForCCMS1405" id="e43a4909-c7b8-44f5-8c44-1015d2bb8599">
        <source>convertForCCMS1405() :CMEVT_TrainTransaction;
/*

Date		Who		Reason
04 December 2014	cnwer1	Initial creation PAR

*/

vars
	t			: CMEVT_TrainTransaction;
	i : CM_InvoiceLine;
begin
	t:=self.cloneSelfAs(CMEVT_TrainTransaction,false).CMEVT_TrainTransaction;		
	t.setPropertyValue(CMEVT_TrainTransaction::myTrain.name,self.myTrain);
	t.setPropertyValue(CM_EventTransaction::myTerminal.name,self.myTerminal);
	t.setPropertyValue(CM_EventTransaction::myEventType.name,self.myEventType);
	t.setPropertyValue(CM_EventTransaction::myDebtor.name,self.myDebtor);
	foreach i in self.allInvoiceLines do
		i.setMyTransactionEvent(t);
	endforeach;	
	
	return t;
epilog

end;</source>
        <ReturnType type="CMEVT_TrainTransaction"/>
    </JadeMethod>
    <JadeMethod name="getDebtor" id="fca19e00-3698-4569-af2c-eff723a46e6f">
        <source>getDebtor(): CM_Debtor;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 August 2017	jlgndl1	Initial creation	TFS 5646

*/

vars

	debtor : CM_Debtor;
	
begin

	if self.myTrain &lt;&gt; null then
		debtor :=self.myTrain.getDebtor();
	endif;
	
	if debtor &lt;&gt; null then
		return debtor;
	endif;
	
	return inheritMethod();

epilog

end;</source>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="getDisplayID" id="deb246a7-f915-4379-8aa3-9fb8de45a155">
        <source>getDisplayID(): String;
//
//30 Apr 2015	cnwrs1	Par35784 - increased exclusion reason logging to include non excluded
//
vars

begin
	if self.myTrain &lt;&gt; null then
		return self.myEventType.name&amp;' '&amp;self.myTrain.code;
	else
		return inheritMethod();
	endif;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="3a836cf2-4ddb-4bcb-9651-3b5b8ee6e2aa">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

begin

	if _attrName = ETRow_Train  then
		if self.myTrain &lt;&gt; null then
			return self.myTrain.getCodeDateString;
		else
			return null;
		endif;
	elseif _attrName = ETRow_Description then
		return self.getDescription();
	
	elseif _attrName = ETRow_WagonNumber  then
		return null;
		
	elseif _attrName = ETRow_Id  then
		return null;
		
	elseif _attrName = ETRow_InWard  then
		return null;
		
	elseif _attrName = ETRow_SourceLocation then
		return null;
		
	elseif _attrName = ETRow_TargetLocation then
		return null;
		
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTrain" id="f472831d-5790-484c-8400-6fddfe047b51">
        <source>getTrain(): CM_Train;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 December 2009	cnwphb1	Initial creation (PAR 21905 CCMS MES 1008 - used by JRW)

*/

vars

begin
	return self.myTrain;
end;</source>
        <ReturnType type="CM_Train"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="a2472173-715a-42e0-bde6-b1207c3f1fb4">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
30 October 2009	cnwndl1	Initial creation	Par 21519
20/04/2011		cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
						trying to create the proxy
*/

vars
	proxy : SelfType;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	
	if proxy &lt;&gt; null then
		proxy.myTrain 	:= self.myTrain;
	endif;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
</Class>
