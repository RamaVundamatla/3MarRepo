<Class name="CM_QTrailerCategoryMethod" id="a1b196a3-6d2b-4184-ae43-c86433b302bb">
    <superclass name="CM_QIntegerLookupMethod"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="659368ab-3321-49fa-8feb-cd1a5295352f">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 September 2022	jlier1	Initial creation

*/

vars
	oper : CM_QueryOperator;

begin
	if self.isTransient then 
		return;
	endif;
	
	self.allAllowedOperators.purge();	
	create oper as CM_QIntegerLookupEqual persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QIntegerLookupNotEqual persistent;
	self.allAllowedOperators.add(oper);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayNull" id="51b3f130-18f9-46dd-b9e2-9826c8c14b5a">
        <methodInvocation>mapping</methodInvocation>
