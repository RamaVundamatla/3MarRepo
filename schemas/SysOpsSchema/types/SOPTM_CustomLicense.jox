    <JadeMethod name="create" id="16a6dc24-9e3d-4427-9ae3-cc0265baa4b2">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//07/08/2023	navkc1	CR 59571   Task 59705: UI - Cust Lic Maint

*/

vars

begin
	self.name := SOP_TableMaintForm.Table_CustomLicense;
	self.permissionView		:= PmAdmCustomLicenseView;	
	self.permissionMaint	:= PmAdmCustomLicenseMaint;
	self.myDataClass := CM_CustomLicense;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="384acef9-1317-4dc2-9673-71b584a4e519">
        <updating/>
        <source>doDelete(pObj: Object io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//07/08/2023	navkc1	CR 59571   Task 59705: UI - Cust Lic Maint

*/

vars

begin
	
	app.myTrxDA.trxDeleteCustLicense(pObj.CM_CustomLicense, app.myPassport);

epilog

end;</source>
        <Parameter name="pObj" type="Object" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doPopulateMsgForAdd" id="fba3b0f5-aaee-49ed-872f-ab6fcc68503d">
        <source>doPopulateMsgForAdd();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//07/08/2023	navkc1	CR 59571   Task 59705: UI - Cust Lic Maint

*/

vars
	ta				: CM_TerminalArea;
	allTAs			: CM_TerminalAreaSet;
	theForm			: SOP_TableMaintForm;
	terminal		: CM_Terminal;
	customDocType	: CM_CustomDocumentType;
	allDocTypes		: CM_CustomDocumentTypeByCode;
	
begin
	create allTAs transient;
	create allDocTypes transient;
	theForm := self.myForm;
	
	terminal := theForm.myTerminal;
	
	// Terminal Areas
	foreach ta in terminal.allTerminalAreas discreteLock do
		if ta.myCustomLicense &lt;&gt; null then
			continue;
		endif;
		
		allTAs.add(ta);
	endforeach;
	theForm.mulSelect1.setAvailable(allTAs, true);
	
	// Custom Document Types
	foreach customDocType in terminal.allCustomDocumentTypes discreteLock do
		if customDocType.notAvailForEntry then
			continue;
		endif;
		
		allDocTypes.add(customDocType);
	endforeach;
	theForm.mulSelect2.setAvailable(allDocTypes, true);
	
	
epilog
	delete allTAs;
	delete allDocTypes;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="29220461-f45a-4ecf-91e0-a184eabe05c2">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//07/08/2023	navkc1	CR 59571   Task 59705: UI - Cust Lic Maint

*/

vars
	pxyCustomLicense			: CM_CustomLicense;
	lCode,lDescription			: String;
	nafe						: Boolean;
	allTAs						: CM_TerminalAreaSet;
	theForm 					: SOP_TableMaintForm;
	terminal					: CM_Terminal;
	allCustomDocTypes			: CM_CustomDocumentTypeByCode;
begin
	
	theForm := self.myForm; 
  	
	terminal := theForm.myTerminal;
	
	lCode 			:= theForm.tblInput1.getValueByName(ETRow_Code).String;
	lDescription 	:= theForm.tblInput1.getValueByName(ETRow_Description).String;
	nafe 			:= theForm.tblInput1.getValueByName(ETRow_NotAvailForEntry).Boolean;

	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_CustomLicense transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	pxyCustomLicense := theForm.myProxyObject.CM_CustomLicense;
	
	create allTAs transient;
	create allCustomDocTypes transient;
	theForm.mulSelect1.getSelected(allTAs);
	theForm.mulSelect2.getSelected(allCustomDocTypes);
	
	pxyCustomLicense.setProxy(lCode, lDescription, terminal, nafe, allCustomDocTypes, allTAs);
	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateCustLicense(pxyCustomLicense, theForm.myCurrentObject, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateCustLicense(pxyCustomLicense, app.myPassport);
		
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK();

epilog
	delete allTAs;
	delete allCustomDocTypes;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCollection" id="99133277-56fd-4cc5-a082-2fc24f2bdef3">
        <source>getCollection(): Collection;
