    <JadeMethod name="utlDeleteFileCategory" id="bf619f7f-8653-4c88-8e2c-dffc9aaa3471">
        <source>utlDeleteFileCategory(_fileDataCategory : CM_FileDataCategory io; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/11/2022 navmv20  TFS CR 55299 TASK 55516: Jade - Write TRX for new file category

*/

vars

begin
	if not self.exclusiveLockObjectToDelete(_fileDataCategory) then
	    return;
	endif;
	_fileDataCategory.validateForDelete();
	
	if not _passport.noErrors then
		return;
	endif;
	
	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(_fileDataCategory);
	endif;
	
	_fileDataCategory.erase(NORMAL_ERASE);
epilog

end;</source>
