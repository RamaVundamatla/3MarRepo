    <JadeMethod name="isAutoApplyResourceUsage" id="df24ec1e-027d-482d-872a-a5950023327b">
        <source>isAutoApplyResourceUsage() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Dec 2023 navlc30 ChangeRequest 60748: EUP | VAS Mobile App - [53813.070] [BackEnd] Automatic VAS Resources

*/

vars

begin
	
	if  self.myResourceType &lt;&gt; null and 
		self.myResourceType.myResourceTypeLinked &lt;&gt; null then	
