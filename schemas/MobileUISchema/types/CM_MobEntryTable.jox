    </JadeMethod>
    <JadeMethod name="doChangedComparison" id="2fd20f4a-acd7-42a8-8187-0cce4cfaa38d">
        <updating/>
        <source>doChangedComparison(theRow : Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 March 2010	cnwndl1	Initial creation

*/

vars
	origValue,
	newValue			: String;
	theCell				: JadeTableCell;
	entRowTrans			: EntTableRowTransient;
begin
	if self.changeMode = self.ChangeMode_None or
	   (self.changeMode = self.ChangeMode_FirstOnly and self.hasChanged) then
		return;
	endif;
	
	if theRow &lt; 1
	or theRow &gt; self.rows then
		return;
	endif;

	theCell := self.accessCell(theRow, ColumnValue);
	
	entRowTrans := self.accessRow(theRow).itemObject.EntTableRowTransient;
	if entRowTrans = null then //raise exception, or just return?
		return;	//need to blow the form away because this is called on the got focus - which happens when the exception dialog is closed
		//app.raiseUnexpectedProgramError(class.name, method.name, 'Entry Table Row Transient Object' &amp; CrLf &amp;
		//								'behind cell #' &amp; theCell.String &amp; ' was null');
	endif;									

	if entRowTrans.hasChanged then
		// already flagged as a change so can return
		return;
	endif;
	
	newValue := theCell.text;
	origValue := entRowTrans.originalValue;
	
	if ((origValue = 'false') and (newValue = '0')) or
	   ((origValue = 'true') and (newValue = '1')) then
		return;
	endif;
	//never set hasChanged to false - if its changed BACK to its original value,
	//that still counts as a change
	if origValue &lt;&gt; newValue then
		entRowTrans.hasChanged := true;	
		self.hasChanged := true;
		
		if self.changeMode = ChangeMode_All then
			theCell.backColor := self.hasChangedColor;
		endif;
	endif;
	
end;</source>
        <Parameter name="theRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getEntRowTranUsingName" id="0db1921a-15d0-4d88-8b63-149c9df800e2">
        <source>getEntRowTranUsingName( _name : String ):EntTableRowTransient;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 September 2013	cnwndl1	Initial creation	Par 32413

*/

vars
	
	obj : Object;
	entRowTransient : EntTableRowTransient;
	
begin
	
	foreach obj in self.allEntRowTransients do
		if EntTableRowTransient.hasInstance(obj) then
			entRowTransient := obj.EntTableRowTransient;
			if entRowTransient.controlName = _name then
				return entRowTransient;
			endif;
		endif;
	endforeach;
	
	return null;
			
end;</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="EntTableRowTransient"/>
    </JadeMethod>
    <JadeMethod name="getMeasureConvertedRowIndex" id="eae0f04b-8246-40de-b323-b90c01fbbb49">
        <updating/>
        <source>getMeasureConvertedRowIndex( _type : String; _attr : String ) : Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 September 2013	cnwndl1	Initial creation	Par 32413

*/

vars
	idx					: Integer;
	numRows				: Integer;
	saveRow,
	saveCol				: Integer;
	rowFound			: Integer;
	entRowTrans			: EntTableRowTransient;
	obj					: Object;
	tmpAttrName			: String;
	length : Integer;
begin
	
	if _attr = null or _type = null then
		return null;
	endif;
	
	tmpAttrName := ( app.getMeasurementPrefixFromType(_type)  &amp; _attr.trimBlanks &amp; '_' ).String[1:35]; 
	length := tmpAttrName.length;

	saveRow := self.row;
	saveCol	:= self.column;
	
	numRows := self.rows;
	
	foreach idx in topNonHeadingRow to numRows do

		obj := self.accessRow(idx).itemObject;
		
 		if EntTableRowTransient.hasInstance(obj) and
 		   obj.EntTableRowTransient.name[1:length] = tmpAttrName then
			rowFound := idx;
			break;
		endif;
	endforeach;


	self.row 	:= saveRow;
	self.column	:= saveCol;

	return rowFound;
	
end;</source>
        <Parameter name="_type" type="String"/>
        <Parameter name="_attr" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRow" id="5619d7c7-2d64-4b67-87db-40dc8919f921">
        <updating/>
        <source>getRow(pAttrName : String) : Integer updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 January 2010	cnwndl1	Initial creation

*/

vars
	idx					: Integer;
	numRows				: Integer;
	saveRow,
	saveCol				: Integer;
	rowFound			: Integer;
	entRowTrans			: EntTableRowTransient;
	obj					: Object;
	tmpAttrName			: String;
begin
	tmpAttrName := pAttrName[1:35].trimBlanks;
	if tmpAttrName = null then
		return null;
	endif;

	
	saveRow := self.row;
	saveCol	:= self.column;
	
	numRows := self.rows;
	
	foreach idx in topNonHeadingRow to numRows do

		obj := self.accessRow(idx).itemObject;
		
 		if EntTableRowTransient.hasInstance(obj) and
 		   obj.EntTableRowTransient.name = tmpAttrName then
			rowFound := idx;
			break;
		endif;
	endforeach;


	self.row 	:= saveRow;
	self.column	:= saveCol;

	return rowFound;
	
end;</source>
        <Parameter name="pAttrName" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRowByControlName" id="469f62d4-3efc-4ae9-9301-cfae35412e71">
        <updating/>
        <source>getRowByControlName(pControlName : String) : Integer updating;

vars
	idx		: Integer;
	maxRows		: Integer;
	obj			: Object;
begin

	maxRows := self.allEntRowTransients.size;
	foreach idx in 1 to maxRows do
		obj := self.allEntRowTransients[idx];
		if EntTableRowTransient.hasInstance(obj) and obj.EntTableRowTransient.controlName = pControlName then
			return idx;
		endif;
	endforeach;
	
	return 0;
			
end;</source>
        <Parameter name="pControlName" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRowByName" id="8d51b07c-8fea-4b47-a399-3d96974356a0">
        <updating/>
        <source>getRowByName(_attrName : String) : Integer updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 March 2013	cnwrd1	Initial creation

*/

vars
	idx		: Integer;
	maxRows	: Integer;
	rowTrans	: EntTableRowTransient;
begin
	
	if self.allEntRowTransients.size = null then
		if self.myEntTableDef &lt;&gt; null then
			return self.myEntTableDef.getRowByName(_attrName);
		endif;
	endif;
	
	maxRows := self.rows;
	foreach idx in self.fixedRows + 1 to maxRows do
		rowTrans := self.accessRow(idx).itemObject.EntTableRowTransient;
		if rowTrans = null then
			continue;
		endif;
		if rowTrans.name = _attrName then
			return idx;
		endif;
	endforeach;
	
	return 0;
			
end;</source>
        <Parameter name="_attrName" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getValue" id="752faa97-ce73-4d30-afc8-ac822b14498d">
        <updating/>
        <source>getValue(pRow : Integer) : Any updating;
// ---------------------------------------------------------------------------
// Created:     09 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11/04/2006	cnwdad1		Added a check (and raise an exception) in the case
//							where the transient row object is not found.
// ---------------------------------------------------------------------------
vars
	cellObj			: JadeTableCell;
	entRowTrans		: EntTableRowTransient;
	rowInputType	: Integer;
	
begin
	if self.isValidRow(pRow) then
		entRowTrans	:=	self.accessRow(pRow).itemObject.EntTableRowTransient;
		
// cnwdad1 11/04/2006 - To protect against the case where the row object is not found!
		if entRowTrans = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'entRowTrans is null, CM_EntryTable has not been initialised correctly');
			return null;
		endif;
		
		cellObj			:=	self.accessCell(pRow, ColumnValue);
		rowInputType	:=	entRowTrans.inputType;

		if rowInputType = InputType_CheckBox then
			if cellObj.text.length &gt; 0 and cellObj.text[1] = '1' then
				return true;
			else
				return false;
			endif;
			
		elseif rowInputType = InputType_Date then
			return cellObj.text.asDateJMT();

		elseif rowInputType = InputType_Time then
			if cellObj.text.asTimeJMT().isValid() then
				return cellObj.text.asTimeJMT();
			else
				return null;
			endif;

		elseif rowInputType = InputType_Picture then
			return cellObj.picture;
	/*
	// too dangerous?
		elseif rowInputType = InputType_TextNumeric then //cnwrd1 3.8.09 par 20346 start
		// check for number of decimal places
			if entRowTrans.myEntTableCellControl &lt;&gt; null then
				if entRowTrans.myEntTableCellControl.EntTableTextNumeric.decimals &gt; 0 then
					//treat as decimal
					return cellObj.text.asDecimalJMT();
				else
					// treat as integer
					return cellObj.text.asIntegerJMT();
				endif;
			else
				// no cellcontroll treat as integer
				return cellObj.text.asIntegerJMT();
			endif;
		elseif rowInputType = InputType_SignedNumeric then 
		// check for number of decimal places
			if entRowTrans.myEntTableCellControl &lt;&gt; null then				
				if entRowTrans.myEntTableCellControl.EntTableSignedNumeric.decimals &gt; 0 then
					//treat as decimal
					return cellObj.text.asDecimalJMT();
				else
					// treat as integer
					return cellObj.text.asIntegerJMT();
				endif;
			else
				// no cellcontroll treat as integer
				return cellObj.text.asIntegerJMT();
			endif;			
		//cnwrd1 3.8.09 par 20346 end
		*/
		
		elseif cellObj.inputType = InputType_ComboBox
		and rowInputType = InputType_ColourSelection
		then
			if cellObj.backColor = self.backColor then
				// set to the default
				return White;
			else
				return cellObj.backColor;
			endif;
		else
			// added trimBlanks so can trap for users only entering spaces	
			return cellObj.text.trimBlanks;
		endif;
	else
		if self.warningMethod &lt;&gt; null then
			self.form.sendMsgWithParams(self.warningMethod, self.name, method.name, 'Cannot get value for row (' &amp; pRow.String &amp; ') - row is invalid');
		endif;
	endif;
end;</source>
        <Parameter name="pRow" type="Integer"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="gotFocus" id="a5a071f5-9b38-4e73-8f88-fa79bf54318a">
        <controlMethod name="Table::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>gotFocus(table: Table input) updating, clientExecution;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 March 2010	cnwndl1	Initial creation

*/

vars

begin

	self.tabKey := J_key_Tab;
	
	inheritMethod(table);
	
	self.handleCellGotFocus();

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="handleCellGotFocus" id="8484ac50-39c2-40a8-ab54-96a2d2fbf5a7">
        <updating/>
        <source>handleCellGotFocus() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 March 2010	cnwndl1	Initial creation

*/

vars
	obj					: Object;
	theCell				: JadeTableCell;
	theRow				: Integer;
	entTableControl		: EntTableCellControl;
	ctrl				: Control;
	entRowTrans			: EntTableRowTransient;
	tmpEditMask			: JadeEditMask;
begin
	theRow := self.row;

	if not self.isValidRow(theRow) then // &lt;= 0 or theRow &gt; self.rows then
		return;
	endif;

	obj := self.accessRow(theRow).itemObject;	
	
	if (obj = null) or (not EntTableRowTransient.hasInstance(obj)) then
		return;
	endif;
	
	entRowTrans := obj.EntTableRowTransient;
	entTableControl := entRowTrans.myEntTableCellControl;
	theCell := self.accessCell(theRow, ColumnValue);

	if entTableControl &lt;&gt; null and global.isValidObject(entTableControl) then
		// Initialise the cell attributes
		entTableControl.initialiseCellControl(theCell);
	else
		self.setSelectionStyle(theRow, false);
	endif;

	if self.changeMode &lt;&gt; self.ChangeMode_None and
	   (not entRowTrans.hasChanged) then
		entRowTrans.originalValue := theCell.text;
	endif;

	// Call the method on the form to do custom gotFocus if required.
	if entRowTrans.gotFocusMethodName &lt;&gt; null then
		form.sendMsgWithParams(entRowTrans.gotFocusMethodName, self, theRow, entRowTrans.name, self.getValue(theRow));
	endif;

	ctrl := theCell.cellControl;
	if ctrl &lt;&gt; null then
		if Table.hasInstance(ctrl) then
			ctrl.Table.userInputEnabled := entRowTrans.inputEnabled;
		else
			ctrl.enabled := entRowTrans.inputEnabled;
			if JadeEditMask.hasInstance(ctrl) then
			   	tmpEditMask := ctrl.JadeEditMask;
			   	// *** Appears Jade 6.0.22 now does not require reset of mask ***
			   	// reset the mask otherwise selectionStyle does not work consistently
			   	// where consecutive cells have the same edit mask
			   	
				//tmpEditMask.mask := theCell.editMask;				
				//tmpEditMask.autoTab := false;
			   	tmpEditMask.selectionStyle := JadeEditMask.SelectionStyle_Select;
			endif;
		endif;

		
	elseif theCell.inputType = Table.InputType_CheckBox and
	   	   (not entRowTrans.inputEnabled) then
		if (not self.useSavedUserInputEnabled) then
			self.saveUserInputEnabled := self.userInputEnabled;
			self.useSavedUserInputEnabled := true;
		endif; 
		theCell.enabled := entRowTrans.inputEnabled;//11570
		self.userInputEnabled := false;	// entRowTrans.inputEnabled;
		
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleCellLostFocus" id="13da9977-7b94-4868-b77e-2ec2937565ec">
        <updating/>
        <source>handleCellLostFocus() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 March 2010	cnwndl1	Initial creation

*/

vars
	entTableRow		: EntTableRowTransient;
	obj				: Object;
	theCell			: JadeTableCell;
	theRow			: Integer;
	tmpCntrl		: Control;
	cntrlName		: String;
	tmpDate			: Date;
		
begin

	theRow := self.row;

	if theRow = 0 then
		return;
	endif;

	theCell := self.accessCell(theRow, ColumnValue);
	if self.useSavedUserInputEnabled then
		self.userInputEnabled := self.saveUserInputEnabled;
		self.useSavedUserInputEnabled := false;
	endif;

	obj := self.accessRow(theRow).itemObject;
	if obj &lt;&gt; null and EntTableRowTransient.hasInstance(obj) then
		entTableRow := obj.EntTableRowTransient;
		if entTableRow.inputType = self.InputType_Date then
			tmpDate := theCell.text.asDateJMT();
			if tmpDate.isValid() then
				theCell.text := tmpDate.shortFormatJMT();
			endif;
		endif;
		if entTableRow.lostFocusMethodName &lt;&gt; null then
			form.sendMsgWithParams(entTableRow.lostFocusMethodName, self, theRow, entTableRow.name, self.getValue(theRow));
		endif;
	endif;

	tmpCntrl := theCell.cellControl;
	if tmpCntrl &lt;&gt; null and 
	   tmpCntrl.name[1] &lt;&gt; '_' and 
	   (not tmpCntrl.automaticCellControl) then
		// No point in calling "doChangeComparism" here as the table
		// relies on the lostFocus event on the control to update the
		// table text.  We do not want to explicitly fire the lostFocus
		// as this will mean it is done twice.
		// In the lostFocus event the user should call the method
		// self.doChangedCompareForEntryTable()
		/*
		if tmpCntrl.isKindOf(ComboBox) then
			tmpCntrl.ComboBox.lostFocus(tmpCntrl.ComboBox);
		elseif tmpCntrl.isKindOf(TextBox) then
			tmpCntrl.TextBox.lostFocus(tmpCntrl.TextBox);
		elseif tmpCntrl.isKindOf(ListBox) then
			tmpCntrl.ListBox.lostFocus(tmpCntrl.ListBox);
		endif;
		*/
		
		// par 18271 cnwrd1 2.4.09 for checkboxes as cellcotnrolls we need to manualy call lostfocus as there is no auto cell controll.
		if tmpCntrl.isKindOf(CheckBox) then
			tmpCntrl.CheckBox.lostFocus(tmpCntrl.CheckBox);
		endif;
	else
		// check to see if a change has occured
		self.doChangedComparison(self.row);
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleFormTab" id="d4f5da9d-ead2-4611-b2ab-cf185b49d542">
        <updating/>
        <source>handleFormTab(keyCode: Integer io; shift: Integer; pPrev, pNext : Control) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 March 2010	cnwndl1	Initial creation

*/

vars
	entTable	: CM_MobEntryTable;
	lastRowControl,
	prevControl,
	nextControl,
	theActiveControl,
	tmpControl	: Control;
	
begin

	if keyCode &lt;&gt; J_key_Tab then
		// Tab has not been pressed so no need to handle
		return;
	endif;

	theActiveControl := app.activeControl;
	if CM_MobEntryTable.hasInstance(theActiveControl.parent) then
		theActiveControl := theActiveControl.parent.Control;
	endif;
	
	prevControl := pPrev;
	nextControl := pNext;

	if shift = 0 and theActiveControl = prevControl then
		// moving forward into table
		if CM_MobEntryTable.hasInstance(prevControl) then
			entTable := prevControl.CM_MobEntryTable;
			if entTable.row = entTable.bottomEntryRow then
				// on last row of previous table so move to first row of this table
				self.moveFirst();
			endif;
		else
			self.moveFirst();
		endif;
		
	elseif shift = 1 and theActiveControl = nextControl then
		// moving back into table
		
		if CM_MobEntryTable.hasInstance(nextControl) then
			entTable := nextControl.CM_MobEntryTable;
			if entTable.row = entTable.topEntryRow then
				// on top row of next table so move to last row of this table
				self.moveLast();
			endif;
		else
			self.moveLast();
		endif;
	endif;

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="pPrev" type="Control"/>
        <Parameter name="pNext" type="Control"/>
    </JadeMethod>
    <JadeMethod name="handleTableTab" id="d87ff47b-4fee-41cf-848f-c50641198ad0">
        <updating/>
        <source>handleTableTab(shift : Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 March 2010	cnwndl1	Initial creation

*/

vars
	tmpCntrl	: Control;
	tmpRow		: Integer;

begin

	// entry table is the current active control so determine if
	// we move in/out of this.
	tmpRow := self.row;
	
	if tmpRow = self.bottomEntryRow and 
	   self.column = ColumnValue and shift = 0 then
		tmpCntrl := self.accessCell(tmpRow, ColumnValue).cellControl;
		if tmpCntrl &lt;&gt; null and tmpCntrl.automaticCellControl then
			// as the tbl lostFocus event is not fired in this case
			self.lostFocus(self);
		endif;
		self.tabKey := 0;
		self.form.tabNext();
		self.selected := false;
	elseif tmpRow = self.topEntryRow and 
	   self.column = ColumnValue and shift = 1 then
		tmpCntrl := self.accessCell(tmpRow, ColumnValue).cellControl;
		if tmpCntrl &lt;&gt; null and tmpCntrl.automaticCellControl then
			// as the tbl lostFocus event is not fired in this case
			self.lostFocus(self);
		endif;
		self.tabKey := 0;
		self.form.tabPrior();
		self.selected := false;
	endif;

end;</source>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hasHeading" id="6446b46d-547e-43fd-aa4f-db13e91a033e">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>hasHeading(set : Boolean; _value : Boolean io) mapping, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 January 2010	cnwndl1	Initial creation

*/

vars

begin

	if set then
		hasHeading := _value;
		if hasHeading then
			if self.rows = 0 then
				self.rows := 1;
				self.fixedRows := 1;
			endif;
			topNonHeadingRow := 2;
		else
			// not sure if following is required?
			if self.fixedRows &lt;&gt; 0 then
				self.fixedRows := 0;
			endif;
			topNonHeadingRow := 1;
		endif;
	else
		_value := hasHeading;
	endif;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="hideRow" id="6411abac-56dd-4ef5-a024-dd84df74fadb">
        <updating/>
        <source>hideRow(pRow : Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 February 2010	cnwndl1	Initial creation

*/

vars
	tmpRow	: JadeTableRow;
	
begin

	if self.isValidRow(pRow) then
		tmpRow := self.accessRow(pRow);
		if (not tmpRow.visible) then
			// row is already hidden
			return;
		endif;
		
		tmpRow.visible := false;
		if pRow = topEntryRow then
			resetTopEntryRow();
		endif;
		if pRow = bottomEntryRow then
			resetBottomEntryRow();
		endif;
	else
		if self.warningMethod &lt;&gt; null then
			self.form.sendMsgWithParams(self.warningMethod, self.name, method.name, 'Cannot hide row (' &amp; pRow.String &amp; ') - invalid row');
		endif;
	endif;

end;</source>
        <Parameter name="pRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hideRowByName" id="7d970cdc-27f9-43f5-bcbc-e1b51a5b9b93">
        <updating/>
        <source>hideRowByName(pName : String; pGiveWarning : Boolean) : Integer updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 February 2010	cnwndl1	Initial creation

*/

vars
	tmpRow	: Integer;
	
begin

	tmpRow := getRow(pName);
	
	if tmpRow &gt; 0 then
		hideRow(tmpRow);
	else
		if pGiveWarning and self.warningMethod &lt;&gt; null then
			self.form.sendMsgWithParams(self.warningMethod, self.name, method.name, 'Cannot hide row (' &amp; pName &amp; ') - not found on table');
		endif;
	endif;

	return tmpRow;
	
end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pGiveWarning" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initCellForDate" id="1cd8ed10-a70b-43cf-8b84-c432efa65be6">
        <source>initCellForDate(_cell : JadeTableCell input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 January 2010	cnwndl1	Initial creation

*/

vars
	tmpControl	: Control;

begin
	if _cell = null then
		return;
	endif;
	_cell.inputType := InputType_EditMask;
	_cell.editMask  := app.getDateEditMaskForShortFormat();

	tmpControl := _cell.cellControl;
	if tmpControl &lt;&gt; null and
	   tmpControl.isKindOf(JadeEditMask) then
		tmpControl.JadeEditMask.insertMode := false;
	endif;

end;</source>
        <Parameter name="_cell" type="JadeTableCell" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initCellForTime" id="e2a25998-8ffd-4877-9fb9-9161d0146271">
        <source>initCellForTime(_cell : JadeTableCell input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 January 2010	cnwndl1	Initial creation

*/

vars
	tmpControl	: Control;
begin
	if _cell = null then
		return;
	endif;
	
	_cell.inputType := InputType_EditMask;
	//_cell.editMask  := EditMask_Time;							// cnwdad1 16/06/2009 - PAR #19942.
	_cell.editMask  := app.getTimeEditMaskShortFormat(false);	// cnwdad1 16/06/2009 - PAR #19942.
	
	tmpControl := _cell.cellControl;
	if tmpControl &lt;&gt; null and tmpControl.isKindOf(JadeEditMask) then
		tmpControl.JadeEditMask.insertMode := false;
	endif;


end;</source>
        <Parameter name="_cell" type="JadeTableCell" usage="input"/>
    </JadeMethod>
    <JadeMethod name="isRowVisible" id="a462e4c7-4bb4-46f8-b4d2-51d171e2e1cb">
        <updating/>
        <source>isRowVisible(pName : String) : Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 February 2010	cnwndl1	Initial creation

*/

vars
	tmpRow	: Integer;
	
begin

	tmpRow := getRow(pName);

	if tmpRow &gt; 0 then
		return self.accessRow(tmpRow).visible;
	else
		return false;
	endif;
		
end;</source>
        <Parameter name="pName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidRow" id="ac1d60f9-1c6d-4010-8385-d935d78a2b5f">
        <source>isValidRow(pRow : Integer) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 January 2010	cnwndl1	Initial creation

*/

vars

begin

	if pRow &gt;= self.topNonHeadingRow and pRow &lt;= self.rows then
		return true;
	endif;
	
	return false;

end;</source>
        <Parameter name="pRow" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadEntRowTransients" id="e0ad8e59-ec57-4f70-8ec5-80151c14b7da">
        <updating/>
        <source>loadEntRowTransients(_defName : String; 
					_allEntRows : EntTableRowArray;
					pGetControlMethod, 
					pWarningMethod : String) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 January 2010	cnwndl1	Initial creation

*/

vars
	entTableRow		: EntTableRow;
	entTableControl	: EntTableCellControl;
	idx,
	theRow			: Integer;
	cntrl			: Control;
	found			: Boolean;
	msg				: String;
	tmpNum			: Integer;
	entRowTrans		: EntTableRowTransient;
	usingLocalDict,
	ls				: Boolean;
	tmpControlsDict	: MOB_ControlsByNameDict;
	numControls		: Integer;
	tmpLocale		: CM_Locale;
	
begin

	tmpLocale := app.myCurrentLocale;

	if pGetControlMethod = null then
	//	if self.form.isKindOf(CM_BaseForm) then
	//		tmpControlsDict := self.form.CM_BaseForm.getAllControlsByNameDict();
	//	else
			usingLocalDict := true;
			create tmpControlsDict transient;
			numControls := self.form.controlCount;
			foreach idx in 1 to numControls do
				cntrl := form.controls(idx);
				tmpControlsDict.add(cntrl);
			endforeach;
	//	endif;
	endif;
	
	foreach entTableRow in _allEntRows do
		entTableControl := entTableRow.myEntTableCellControl;
		tmpNum := 0;
		if entTableControl &lt;&gt; null then
			if EntTableSignedNumeric.hasInstance(entTableControl) then
				tmpNum := entTableControl.EntTableSignedNumeric.decimals;
			elseif EntTableTextNumeric.hasInstance(entTableControl) then
				tmpNum := entTableControl.EntTableTextNumeric.decimals;
			elseif EntTableTextBox.hasInstance(entTableControl) then
				tmpNum := entTableControl.EntTableTextBox.maxLength;
			endif;
		endif;
		theRow := self.addAttribute(entTableRow.myEntTableRowHeader.name, entTableRow.getHeading(self.myTerminologyCargoBOLType, self.myTerminologyTerminal, tmpLocale), entTableRow.inputType, tmpNum, entTableRow.visible);
		//the entRowTrans will have the above params set on it - now set the rest from the entRow persistent object
		entRowTrans := self.accessRow(theRow).itemObject.EntTableRowTransient;
		entRowTrans.setEntTableCellControl(entTableRow.myEntTableCellControl);
		entRowTrans.setSelf(entTableRow);
		
		if entTableRow.controlName &lt;&gt; null then
			// a user created control has been specified
			found := false;
			if pGetControlMethod &lt;&gt; null then
				cntrl := form.sendMsgWithParams(pGetControlMethod, entTableRow.controlName).Control;
				if cntrl &lt;&gt; null then
					found := true;
				endif;
			else
				// find the control on the form with this name
				cntrl := tmpControlsDict[entTableRow.controlName].Control;
				if cntrl &lt;&gt; null then
					found := true;
				endif;
			endif;
			if found then
				self.setControl(theRow, cntrl);
				//if cntrl.height.Integer &gt; maxControlHeight then
				//	maxControlHeight := cntrl.height.Integer;
				//endif;
			else
				if pWarningMethod &lt;&gt; null then
					if pGetControlMethod &lt;&gt; null then
						msg := 'Control (' &amp; entTableRow.controlName &amp; ') not found on form - Form::' &amp; pGetControlMethod &amp; ' method needs modifying';
					else
						msg := 'Control (' &amp; entTableRow.controlName &amp; ') not found on form';
					endif;
					form.sendMsgWithParams(pWarningMethod, self.name, _defName, entTableRow.controlName, msg);
				endif;
			endif;
		endif;

	endforeach;

	/*	makes no sense to size the rows to the height of the largest row		JC 17/03/2005
	if maxControlHeight &gt; 0 then
		self.defaultRowHeight := self.rowHeight[1].max(maxControlHeight);
	endif;
	*/
	self.defaultRowHeight := self.EntryTableViewRowHeight;
	
	self.optimiseHeadingColumn();
	
epilog
	if usingLocalDict then
		delete tmpControlsDict;
	endif;

end;</source>
        <Parameter name="_defName" type="String"/>
        <Parameter name="_allEntRows" type="EntTableRowArray"/>
        <Parameter name="pGetControlMethod" type="String"/>
        <Parameter name="pWarningMethod" type="String"/>
    </JadeMethod>
    <JadeMethod name="lostFocus" id="7e36c2c1-19f4-4fe4-a1ac-e02734ce370a">
        <controlMethod name="Table::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>lostFocus(table: Table input) updating, clientExecution;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 March 2010	cnwndl1	Initial creation

*/

vars

begin
	inheritMethod(table);

	self.handleCellLostFocus();
	
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="moveFirst" id="72a5a0bf-1ea0-450e-bb6c-24bbe07c31ae">
        <updating/>
        <source>moveFirst() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 March 2010	cnwndl1	Initial creation

*/

vars

begin

	self.resetTopEntryRow();
	if self.topEntryRow &gt; 0 then
		self.row := self.topEntryRow;
	else
		self.row := self.rows;
	endif;
	self.column := ColumnValue;
	if self.row &gt; 0 then
		self.topRow := self.row;
		self.setSelectionStyle(self.row, true);
	endif;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="moveLast" id="3e9e811b-2864-4e69-b06a-d39dc9e55eb5">
        <updating/>
        <source>moveLast()updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 March 2010	cnwndl1	Initial creation

*/

vars

begin

	if self.bottomEntryRow &gt; 0 and self.bottomEntryRow &lt;= self.rows then
		self.row := self.bottomEntryRow;
	else
		resetBottomEntryRow();
		if self.bottomEntryRow &lt;&gt; 0 then
			self.row := self.bottomEntryRow;
		else
			self.row := self.rows;
		endif;
	endif;
	self.column := ColumnValue;

	if self.row &gt; 0 then
		// set this row to the topRow to ensure it is visible
		self.topRow := self.row;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="optimiseHeadingColumn" id="145d0bea-bd79-46d0-9f02-1e3e9ae5fd1c">
        <updating/>
        <source>optimiseHeadingColumn() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 January 2010	cnwndl1	Initial creation

*/

vars
	idx			: Integer;
	xWidth		: Integer;
	numRows,
	maxWidth	: Integer;

begin

	if self.columns &lt; ColumnHeading then
		return;
	endif;
	
	//self.column := ColumnHeading; - removed 10 August 2005

	numRows := self.rows;

	// First do fixed header rows
	foreach idx in 1 to numRows do

		// self.row := idx;  // Why set current row to this?
		
		xWidth := self.getTextExtent(self.getCellText(idx, ColumnHeading));
		if fontItalic then
			xWidth := xWidth + 4;
		endif;
		if fontBold then
			xWidth := (xWidth * 1.2).rounded;
		endif;
		if self.fixed3D then
			xWidth := xWidth + 1;
		endif;
		maxWidth := maxWidth.max(xWidth);

	endforeach;
	
	self.headingColumnWidth := maxWidth + 4;
end;</source>
    </JadeMethod>
    <JadeMethod name="optimiseHeightForRow" id="908b4a5a-9ce0-4b8e-b4b4-c8e9b9a59085">
        <updating/>
        <source>optimiseHeightForRow(_cellInputType, _row : Integer; _inputText : String) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 January 2010	cnwndl1	Initial creation

*/

vars
	newRowHeight : Integer;
begin
	
	if _cellInputType &lt;&gt; InputType_None and
	   _cellInputType &lt;&gt; InputType_TextBox then
		return;
	endif;
	if _row &gt; self.rows then
		return;
	endif;
	if (not self.optimiseRowHeight) then
		return;
	endif;

	if _inputText &lt;&gt; null then
		newRowHeight := (self.getTextHeight(_inputText) + 5);
	endif;

	if newRowHeight &lt;&gt; self.rowHeight[_row] then
		self.rowHeight[_row] := newRowHeight;
	endif;

end;</source>
        <Parameter name="_cellInputType" type="Integer"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_inputText" type="String"/>
    </JadeMethod>
    <JadeMethod name="queryRowColChg" id="62012b8a-36a3-46af-8e54-9692329470cc">
        <controlMethod name="Table::queryRowColChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>queryRowColChg(table: Table input; newSheet: Integer; newRow: Integer; newCol: Integer): Boolean updating, clientExecution;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 March 2010	cnwndl1	Initial creation

*/

vars
	rtnCode			: Boolean;
begin
	rtnCode := inheritMethod(table, newSheet, newRow, newCol);
	if (not rtnCode) then
		// user could not move to new row
		return false;
	endif;
	
	if table.row &lt;&gt; newRow then
		// Do After row processing here
		self.handleCellLostFocus();
	endif;

	return true;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="newSheet" type="Integer"/>
        <Parameter name="newRow" type="Integer"/>
        <Parameter name="newCol" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="resetBottomEntryRow" id="6aea7970-4166-4197-9a58-e0b8be544379">
        <updating/>
        <source>resetBottomEntryRow() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 January 2010	cnwndl1	Initial creation

*/

vars
	idx		: Integer;
	max		: Integer;
	endRow	: Integer;
	
begin

	max := self.rows;
	if hasHeading then 
		endRow := 2;
	else
		endRow := 1;
	endif; 
	
	bottomEntryRow := 0;
	
	foreach idx in max to endRow step -1 do
		if self.accessRow(idx).visible then
			bottomEntryRow := idx;
			break;
		endif;
	endforeach; 

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resetTopEntryRow" id="81bf307d-3101-4df0-8e1f-874029d77faa">
        <updating/>
        <source>resetTopEntryRow() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 January 2010	cnwndl1	Initial creation

*/

vars
	idx			: Integer;
	max			: Integer;
	
begin

	max := self.rows;
	
	topEntryRow := 0;
	
	foreach idx in topNonHeadingRow to max do
		if self.accessRow(idx).visible and (idx &gt; self.fixedRows)  then // ### AKB added fixedRows
			topEntryRow := idx;
			break;
		endif;
	endforeach;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resize" id="25f6b0ab-35c9-451c-9939-b2583c5f0fc1">
        <updating/>
        <source>resize() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2010	cnwdap1	Initial creation
*/
vars
	jadeCol	: JadeTableColumn;

begin
	if self.columns = ColumnValue then
		jadeCol := self.accessColumn(ColumnHeading);
		jadeCol.width := (self.width / 2).Integer;
		jadeCol.alignment := Alignment_Left_Top;
		
		jadeCol := self.accessColumn(ColumnValue);
		jadeCol.width := (self.width - self.accessColumn(ColumnHeading).width).Integer;
		jadeCol.alignment := Alignment_Left_Top;
	else
		jadeCol := self.accessColumn(ColumnHeading);
		jadeCol.width := (self.width * 2 / 3).Integer;
		jadeCol.alignment := Alignment_Left_Top;
		
		jadeCol := self.accessColumn(ColumnValue);
		jadeCol.width := (self.width / 6).Integer - 1;
		jadeCol.alignment := Alignment_Left_Top;
		
		jadeCol := self.accessColumn(ColumnValueExtra);
		jadeCol.width := (self.width / 6).Integer - 1;
		jadeCol.alignment := Alignment_Left_Top;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="rowColumnChg" id="a99579bf-d955-4297-b28e-368b3f1ebd76">
        <controlMethod name="CM_MobTable::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>rowColumnChg(table: Table input) updating, clientExecution;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 March 2010	cnwndl1	Initial creation

*/

vars

begin

	inheritMethod(table);
	self.handleCellGotFocus();

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setControl" id="6cc2ed84-4347-4bb8-bcd7-9f381424d43e">
        <updating/>
        <source>setControl(pRow : Integer; pControl : Control input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 January 2010	cnwndl1	Initial creation

*/

vars
	entRowTrans	: EntTableRowTransient;
	cntrlName	: String;

begin

	if self.isValidRow(pRow) then
		self.accessCell(pRow, ColumnValue).cellControl := pControl;
		entRowTrans := self.accessRow(pRow).itemObject.EntTableRowTransient;
		cntrlName := pControl.name;
		if entRowTrans &lt;&gt; null and cntrlName &lt;&gt; entRowTrans.controlName then
			entRowTrans.setControlName(cntrlName);
		endif;
		pControl.parent := self;
	else
		if self.warningMethod &lt;&gt; null then
			self.form.sendMsgWithParams(self.warningMethod, self.name, method.name, 'Cannot set control for row (' &amp; pRow.String &amp; ') - invalid row');
		endif;
	endif;

end;</source>
        <Parameter name="pRow" type="Integer"/>
        <Parameter name="pControl" type="Control" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setEntTableDef" id="52fc8965-9024-4f57-b4c2-9697a19cc31a">
        <updating/>
        <source>setEntTableDef(pDef : EntTableDef; pGetControlMethod, pWarningMethod : String) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 January 2010	cnwndl1	Initial creation

*/

vars
	
begin
	
	self.myEntTableDef := pDef;

	self.clearValues();
	self.rows := self.fixedRows;

	if pDef = null then
		return;
	endif;
	self.allEntRowTransients.purge();
	self.loadEntRowTransients(pDef.name, pDef.allEntTableRows, pGetControlMethod, pWarningMethod);

end;</source>
        <Parameter name="pDef" type="EntTableDef"/>
        <Parameter name="pGetControlMethod" type="String"/>
        <Parameter name="pWarningMethod" type="String"/>
    </JadeMethod>
    <JadeMethod name="setEntTableFromView" id="c34f03fb-0747-451c-be84-d22b2b05c216">
        <updating/>
        <source>setEntTableFromView(pDef : EntTableDef;_view : EntTableView; pGetControlMethod, pWarningMethod : String) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 January 2010	cnwndl1	Initial creation

*/

vars
oldEntRowTransients : CM_ObjectArray;
	obj 				: Object;
	entRowTransient : EntTableRowTransient;
	theRow 			: Integer;
begin
	if _view = null then
		self.setEntTableDef(pDef, pGetControlMethod, pWarningMethod);
		return;
	endif;
	self.myEntTableDef := pDef;

	
	self.clearEntTableRowTransients();
	self.rows := self.fixedRows;
	
	if pDef = null then
		return;
	endif;
	
	
	//want to keep old table values 
	create oldEntRowTransients transient;
	self.allEntRowTransients.copy(oldEntRowTransients);
	self.allEntRowTransients.clear();
	
	self.loadEntRowTransients(pDef.name, _view.allEntTableRows, pGetControlMethod, pWarningMethod);
	
	foreach obj in oldEntRowTransients do
		entRowTransient:=obj.EntTableRowTransient;
		theRow:=self.getRow(entRowTransient.name);
		if theRow &lt;&gt; null then
		
			self.setValue(theRow,entRowTransient.originalValue);
		endif;
	endforeach;
	
epilog

	oldEntRowTransients.purge;

end;</source>
        <Parameter name="pDef" type="EntTableDef"/>
        <Parameter name="_view" type="EntTableView"/>
        <Parameter name="pGetControlMethod" type="String"/>
        <Parameter name="pWarningMethod" type="String"/>
    </JadeMethod>
    <JadeMethod name="setSelectionStyle" id="5d2f9b6c-280c-414c-a98d-282b250e360c">
        <updating/>
        <source>setSelectionStyle(theRow : Integer; _selectAll : Boolean) updating;

vars
	ctrl 	: Control;
	txtBox	: TextBox;
begin

	if theRow = 0 or theRow &gt; self.rows then
		return;
	endif;

	ctrl := self.accessCell(theRow, ColumnValue).cellControl;
	
	if ctrl &lt;&gt; null then
		if TextBox.hasInstance(ctrl) then
			txtBox := ctrl.TextBox;
			txtBox.selectionStyle := TextBox.SelectionStyle_SelectAll;
			if _selectAll then
				txtBox.selStart 	:= 0;
				txtBox.selLength	:= -1;	// select all
			endif;
		elseif JadeEditMask.hasInstance(ctrl) then
		   	ctrl.JadeEditMask.selectionStyle := JadeEditMask.SelectionStyle_Select;
		endif;
	endif;

end;</source>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="_selectAll" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setValue" id="c6888d1d-4394-44d1-b2ad-7bc11cbf6295">
        <updating/>
        <source>setValue(pRow : Integer; pValue : Any) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 January 2010	cnwndl1	Initial creation

*/

vars
	cell				: JadeTableCell;
	entRowInputType,
	cellInputType,
	numDecimals,
	startPos			: Integer;
	valueStr,
	noTabString			: String;
	entRowTrans			: EntTableRowTransient;
	obj					: Object;
	ctrl				: Control;
	
begin
	if self.isValidRow(pRow) then
		obj := self.accessRow(pRow).itemObject;
		
		if (obj = null) or (not EntTableRowTransient.hasInstance(obj)) then
			return;
		endif;
		entRowTrans := obj.EntTableRowTransient;
		
		cell := self.accessCell(pRow, ColumnValue);
		
//		if (not entRowTrans.isOriginalValueSet) then
//			entRowTrans.originalValue := pValue.String;
//		endif;

		entRowInputType := entRowTrans.inputType;
		cellInputType	:= cell.inputType;
		if entRowInputType = InputType_CheckBox then
			if pValue.isKindOf(String) and 
			    (pValue.String[1] = '1' or pValue.String = app.getYesNo(true)) then // par 17461 display yes for the inoput string "Yes". --cnwdz2  
				// if value sometimes comes through as number
				cell.text := '1';
			else
				cell.text := pValue.Boolean.cnEcGetTableCheckBoxValue;	
			endif;
						
		elseif entRowInputType = InputType_Date then
		//epr par 12833 19/10/06 changed from and to or
			if (pValue.isKindOf(Date) or pValue.Date.isValid) then
				cell.text := pValue.Date.shortFormatJMT();
			elseif pValue.isKindOf(String) then
				cell.text := pValue.String;
			else
				cell.text := null;
			endif;

		elseif entRowInputType = InputType_Time then
			if (pValue.isKindOf(Time) or pValue.isKindOf(String)) and 
			   pValue.Time.isValid then
// cnwdad1 17/06/2009 - PAR #19942.
				//cell.text := pValue.Time.currentLocaleFormatJMT();
				cell.text := pValue.Time.format(app.getTimeShortFormat(false));
			else
				cell.text := null;
			endif;
			
		elseif (cellInputType = InputType_ComboBox) and (entRowInputType = InputType_ColourSelection) then
			cell.backColor := pValue.Integer;
			cell.foreColor := pValue.Integer.getInverseColour();

		elseif entRowInputType = InputType_Picture then
			//Check we can accommodate the type as .gifs are not yet supported by Jade.
			if pValue.Binary.isPictureValid then
				cell.picture := pValue.Binary;
			endif;
		else
			if cellInputType = Table.InputType_TextNumeric or 
			   cellInputType = Table.InputType_SignedNumeric then

				if pValue = null and entRowTrans.displayNullIfZero then
					valueStr := null;
				elseif pValue.isKindOf(String) and
					   pValue.String = null then
					   /*and
					   (entRowTrans.name = ETRow_CarriageTempF or
					   entRowTrans.name = ETRow_CarriageTempC or
					   entRowTrans.name = ETRow_PackTempF or
					   entRowTrans.name = ETRow_PackTempC)
					   then
					   */
					valueStr := null;
				else
					numDecimals := cell.decimals;
					if pValue.isKindOf(Real) then
						valueStr := pValue.Real.roundedTo(numDecimals).asStringJMT;
					elseif pValue.isKindOf(Decimal) then
						valueStr := pValue.Decimal.roundedTo(numDecimals).asStringJMT();
					elseif pValue.isKindOf(String) then
						valueStr := pValue.String.asDecimalJMT.roundedTo(numDecimals).asStringJMT;	//asStringJMT();
					else
						valueStr := pValue.Decimal.roundedTo(numDecimals).asStringJMT;	//asStringJMT();
						// PAR 13701
						// Need to assume a decimal and roundedTo will return a
						// decimal of the precision indicated by numDecimals so
						// we get the correct trailing zeros.
						//valueStr := pValue.Real.roundedTo(numDecimals).String;
					endif;
				endif;
			
			elseif pValue = null then
				valueStr := null;					
			
			elseif pValue.isKindOf(Date) then
				valueStr := pValue.Date.shortFormatJMT();
			elseif pValue.isKindOf(Decimal) then
				valueStr := pValue.Decimal.asStringJMT();
			else
				valueStr := pValue.String;
			endif;

			if cell.text &lt;&gt; valueStr then		
				cell.text := valueStr;
				cell.alignment := Alignment_Left_Top;
				if self.optimiseRowHeight then
					// PAR 9317 
					self.optimiseHeightForRow(cellInputType, pRow, valueStr);
				endif;
			endif;
			
			if pValue = null then
				// we are clearing the values
				ctrl := cell.cellControl;
				if ctrl &lt;&gt; null
				and ctrl.name[1] &lt;&gt; '_' then // This is NOT one of our controls.
				   	// this is one of our controls
				   	if ComboBox.hasInstance(ctrl) then
				   		ctrl.ComboBox.listObject := null;
				   	elseif TextBox.hasInstance(ctrl) then
				   		ctrl.TextBox.text := null;
				   	endif;
				endif;
			endif;
		endif;

		entRowTrans.isOriginalValueSet := true;
		
	else
		if self.warningMethod &lt;&gt; null then
			self.form.sendMsgWithParams(self.warningMethod, self.name, method.name, 'Cannot set value for row (' &amp; pRow.String &amp; ') - invalid row');
		endif;
	endif;
end;</source>
        <Parameter name="pRow" type="Integer"/>
        <Parameter name="pValue" type="Any"/>
    </JadeMethod>
    <JadeMethod name="setValueByControlName" id="ca2214b6-e63e-425f-9f4b-12a9824ea074">
        <updating/>
        <source>setValueByControlName(pControlName : String; pValue : Any) : Integer updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 January 2010	cnwndl1	Initial creation

*/

vars
	maxRows,
	idx,
	theRow	: Integer;

begin
	
	maxRows := self.allEntRowTransients.size;
	foreach idx in 1 to maxRows do
		if self.allEntRowTransients[idx].EntTableRowTransient.controlName = pControlName then
			theRow := idx;
			break;
		endif;
	endforeach;
	
	if theRow &lt;&gt; 0 then
		self.setValue(theRow, pValue);
	else
		if self.warningMethod &lt;&gt; null then
			self.form.sendMsgWithParams(self.warningMethod, self.name, method.name, 'Cannot set value by controlName (' &amp; pControlName &amp; ') - not found on table');
		endif;
	endif;
	
	return theRow;

end;</source>
        <Parameter name="pControlName" type="String"/>
        <Parameter name="pValue" type="Any"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setValueByName" id="32b6b585-1b78-4c77-87ac-c5b4e14b659b">
        <updating/>
        <source>setValueByName(pName : String; pValue : Any) : Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 March 2013	cnwrd1	Initial creation

*/
// ---------------------------------------------------------------------------
vars
	theRow	: Integer;

begin
	
	theRow := self.getRow(pName);

	if theRow &lt;&gt; 0 then
		self.setValue(theRow, pValue);
	else
		if self.warningMethod &lt;&gt; null then
			self.form.sendMsgWithParams(self.warningMethod, self.name, method.name, 'Cannot set value by name (' &amp; pName &amp; ') - not found on table');
		endif;
	endif;

	return theRow;

end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pValue" type="Any"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showRow" id="707a0c54-3adb-4f0d-adc5-6df1cbc0b6fb">
        <updating/>
        <source>showRow(pRow : Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 February 2010	cnwndl1	Initial creation

*/

vars
	tmpRow	: JadeTableRow;
	
begin

	if self.isValidRow(pRow) then
		tmpRow := self.accessRow(pRow);
		if tmpRow.visible then
			return;
		endif;
		
		tmpRow.visible := true;
		if pRow &lt; topEntryRow or topEntryRow = 0 then
			topEntryRow := pRow;
		endif;
		if pRow &gt; bottomEntryRow or bottomEntryRow = 0 then
			bottomEntryRow := pRow;
		endif;
	else
		if self.warningMethod &lt;&gt; null then
			self.form.sendMsgWithParams(self.warningMethod, self.name, method.name, 'Cannot show row (' &amp; pRow.String &amp; ') - invalid row');
		endif;
	endif;

end;</source>
        <Parameter name="pRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showRowByName" id="7d1d064e-9627-4a00-9709-8fab64a5ace6">
        <updating/>
        <source>showRowByName(pName : String; pGiveWarning : Boolean) : Integer updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 February 2010	cnwndl1	Initial creation

*/

vars
	tmpRow	: Integer;
	
begin
	tmpRow := getRow(pName);

	if tmpRow &gt; 0 then
		showRow(tmpRow);
	else
		if pGiveWarning and self.warningMethod &lt;&gt; null then
			self.form.sendMsgWithParams(self.warningMethod, self.name, method.name, 'Cannot show row (' &amp; pName &amp; ') - not found on table');
		endif;
	endif;
		
	return tmpRow;

end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pGiveWarning" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showRowByNameAndUseShortName" id="20153194-b54b-49ff-9052-bc6148f0f054">
        <updating/>
        <source>showRowByNameAndUseShortName( _attrName : String ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2013	cnwndl1	Initial creation	Par 32215

*/

vars

	tmpRow	: Integer;
	entTrans : EntTableRowTransient;
	shortHeading : String;

begin

	tmpRow := self.getRow( _attrName );
	if tmpRow &gt; 0 then
		self.showRow(tmpRow);
		if self.allEntRowTransients.size &gt;= tmpRow then
			entTrans := self.allEntRowTransients[tmpRow].EntTableRowTransient;
			if entTrans &lt;&gt; null then
				shortHeading := entTrans.shortHeading;
				if shortHeading.trimBlanks &lt;&gt; null then
					self.accessCell(tmpRow,1).text := shortHeading;
				endif;
			endif;
		endif;
	endif;

				

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="d375f1ec-d7f3-4326-a49b-56627daa9f5b">
        <controlMethod name="CM_MobTable::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 January 2010	cnwndl1	Initial creation

*/

vars
	jadeCol	: JadeTableColumn;
	
begin

	inheritMethod(cntrl, persistCntrl);
	
	self.columns := ColumnValue;
	
	if hasHeading then
		self.rows := 1;
		self.fixedRows := 1;
		self.topNonHeadingRow := 2;
	else
		self.rows := 0;
		self.fixedRows := 0;
		self.topNonHeadingRow := 1;
	endif;
	
	self.resetTopEntryRow();
	self.resetBottomEntryRow();
	
	self.fixedColumns := ColumnHeading;

	jadeCol := self.accessColumn(ColumnHeading);
	jadeCol.width := (self.width / 2).Integer;
	jadeCol.alignment := Alignment_Left_Top;
	
	jadeCol := self.accessColumn(ColumnValue);
	jadeCol.width := (self.width - self.accessColumn(ColumnHeading).width).Integer;
	jadeCol.alignment := Alignment_Left_Top;
	
	self.setMargins();
	self.partialTextIndication := true;
	
	self.column := ColumnValue;
	
	self.hasChangedColor := self.ROWCHANGED_COLOUR;
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
