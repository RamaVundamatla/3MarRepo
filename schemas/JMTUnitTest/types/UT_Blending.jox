<Class name="UT_Blending" id="e7810d18-3a4b-454e-9b5a-d178be7293b1">
    <superclass name="UT_DSL"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
