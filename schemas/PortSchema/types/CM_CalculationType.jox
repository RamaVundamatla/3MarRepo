    <JadeMethod name="healthCheckIsValid" id="e808b5f5-33d2-4596-90ae-bb9b15163930">
        <source>healthCheckIsValid(_agent : CMIF_InvoiceHealthAgent) : Boolean;
/*
Purpose:			
Date		Who		Reason
13 September 2016	cnwab1	Initial creation
*/
vars
	message : String;
	resultType : Integer;
	detail : CMIF_InvoiceHealthAgentDetail;
	term : CM_Terminal;
begin

	
	// ### QUANTITY HOOK CODE
	if _agent.checkTypesToQuery.includes(CMIF_InvoiceHealthAgent.CheckType_HookQuantity)
	and self.healthCheckObject(self.myHookCodeQuantity, resultType) and resultType = CMIF_InvoiceHealthAgent.ResultType_Valid then
		create detail transient;
		detail.setForCreate(_agent, CMIF_InvoiceHealthAgent.CheckType_HookQuantity, self.description, CMIF_InvoiceHealthAgent.ItemType_CalculationType, self.getMyTerminal(), resultType, self);
		return false;
	endif;
	// ### RATE HOOK CODE
	if _agent.checkTypesToQuery.includes(CMIF_InvoiceHealthAgent.CheckType_HookRate)
	and self.healthCheckObject(self.myHookCodeRate, resultType) and resultType = CMIF_InvoiceHealthAgent.ResultType_Valid then
		create detail transient;
		detail.setForCreate(_agent, CMIF_InvoiceHealthAgent.CheckType_HookRate, self.description, CMIF_InvoiceHealthAgent.ItemType_CalculationType, self.getMyTerminal(), resultType, self);
		return false;
	endif;
	// ### REMARKS HOOK CODE		22/2/18 MAP TFS37124
	if _agent.checkTypesToQuery.includes(CMIF_InvoiceHealthAgent.CheckType_HookRemarks)
	and self.healthCheckObject(self.myHookCodeRemarks, resultType) and resultType = CMIF_InvoiceHealthAgent.ResultType_Valid then
		create detail transient;
		detail.setForCreate(_agent, CMIF_InvoiceHealthAgent.CheckType_HookRemarks, self.description, CMIF_InvoiceHealthAgent.ItemType_CalculationType, self.getMyTerminal(), resultType, self);
		return false;
	endif;
	// ### CALENDARS
	if _agent.checkTypesToQuery.includes(CMIF_InvoiceHealthAgent.CheckType_Calendar) then
		if self.requiresCalendar() then
			if not self.healthCheckObject(self.myCalendarType1, resultType)  then
				create detail transient;
				detail.setForCreate(_agent, CMIF_InvoiceHealthAgent.CheckType_Calendar, self.description, CMIF_InvoiceHealthAgent.ItemType_CalculationType, self.getMyTerminal(), resultType, self);
				return false;
			endif;
			if not self.healthCheckObject(self.myCalendarType2, resultType)  then
				create detail transient;
				detail.setForCreate(_agent, CMIF_InvoiceHealthAgent.CheckType_Calendar, self.description, CMIF_InvoiceHealthAgent.ItemType_CalculationType, self.getMyTerminal(), resultType, self);
				return false;
			endif;
		endif;
	endif;
	// ### MEASUREMENT
	if _agent.checkTypesToQuery.includes(CMIF_InvoiceHealthAgent.CheckType_Measure) then
		if self.requiresMeasurement() then
			if not self.healthCheckObject(self.myMeasurementType, resultType)  then
				create detail transient;
				detail.setForCreate(_agent, CMIF_InvoiceHealthAgent.CheckType_Measure, self.description, CMIF_InvoiceHealthAgent.ItemType_CalculationType, self.getMyTerminal(), resultType, self);
				return false;
			endif;
		endif;
	endif;

	return true;
	
epilog
end;</source>
        <Parameter name="_agent" type="CMIF_InvoiceHealthAgent"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isCargoType" id="1c2491bb-42fd-44f8-9c07-2fb80cb9072b">
        <source>isCargoType() : Boolean;

// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//












// Purpose:		used in CONVERSION jadsescript only






// ### &gt;&gt;&gt;&gt;&gt;&gt;		use CM_Calculation.isCargoCalcType











//
// ---------------------------------------------------------------------------

constants
	TagType = "TYPE";

vars
	appScm : Schema;
	category : ConstantCategory;
	const : Constant;
	calTypeValue	: Integer;

begin
	
	appScm := rootSchema.getSchema(PortSchemaName);
	if appScm = null then
		return null;
	endif;
	
	category := appScm.getCategory(InvoiceCalculationTypes);
	if category = null then
		return null;
	endif;

	foreach const in category.getConstants do
		calTypeValue := const.GlobalConstant.valueAsInteger;
		if self.calculationType = calTypeValue then
			return const.text.String.cnEcGetTagValueOfName(TagType) = "CARGO";
		endif;
	endforeach;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isEventType" id="1db78ea4-cc00-4604-925e-1443e17800f7">
        <source>isEventType() : Boolean;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//












// Purpose:		used in CONVERSION jadsescript only







// ### &gt;&gt;&gt;&gt;&gt;&gt;		use CM_Calculation.isEventCalcType










//
// ---------------------------------------------------------------------------

constants
	TagType = "TYPE";

vars
	appScm : Schema;
	category : ConstantCategory;
	const : Constant;
	calTypeValue, descPos, catPos : Integer;
	lenTagLabel, len : Integer;
	label : String;

begin
	
	appScm := rootSchema.getSchema(PortSchemaName);
	if appScm = null then
		return null;
	endif;
	
	category := appScm.getCategory(InvoiceCalculationTypes);
	if category = null then
		return null;
	endif;

	foreach const in category.getConstants do
		calTypeValue := const.GlobalConstant.valueAsInteger;
		if self.calculationType = calTypeValue then
			return const.text.String.cnEcGetTagValueOfName(TagType) = "EVENT";
		endif;
	endforeach;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
