    <JadeMethod name="getNumFiles" id="cb4123c2-6564-4e35-b447-ccf0b0e50344">
        <source>getNumFiles() : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
15 March 2022		jlizm1	Initial creation TFS 52834 SAL file attachments filter by work order

*/

vars
	total 	: Integer;
	wo 		: CM_WorkOrder;
	
begin

	total := 0;
	total := total + self.allFiles.size();
	
	foreach wo in self.allWorkOrders do
		total := total + wo.allFiles.size();
	endforeach;
	
	return total;

epilog

end;</source>
