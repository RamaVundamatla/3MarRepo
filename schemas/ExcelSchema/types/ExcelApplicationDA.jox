    <JadeMethod name="timerEvent" id="1e78724f-8b5d-4be8-8b79-9bb59ee05413">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;

/*****************************************************
	Written by	:	cnwpra1		26 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	on Exception do app.defaultExceptionHandler(exception);
	
	if eventTag = 1 then
		if self.shouldWorkbooksBeDeleted then
			myFileManagementDA.removeFile;
			myFileManagementDA.removeFolder;
		endif;
		
		delete self;
	endif;
epilog

end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
</Class>
