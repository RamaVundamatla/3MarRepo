    <JadeMethod name="isSameAs" id="8ef9beb6-d5bf-453f-9293-bb3a95700c93">
        <source>isSameAs(_hazard: CM_Hazard): Boolean;
//----------------------------------------------------------------
//	Created:	14 February 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	//compare code only
	if self.code &lt;&gt; _hazard.code then
		return false;
	endif;
	
	return true;
	
end;</source>
        <Parameter name="_hazard" type="CM_Hazard"/>
        <ReturnType type="Boolean"/>
