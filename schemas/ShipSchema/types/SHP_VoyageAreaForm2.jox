    <JadeMethod name="doMnuWorkEDIActClick" id="8cb57867-5c33-456d-b12e-514fb5bcdd67">
        <updating/>
        <source>doMnuWorkEDIActClick() updating;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//July 2008 cnwrs1 Par 17595 additional parameters
// ---------------------------------------------------------------------------

vars
	theReturn, theIndex : Integer;
	mergeOptionsForm : CMUI_EDIBayPlanMerge;
	clearDetails : Boolean;
	mergeRetainAllCargo : Boolean;
	mergeRetainEDICargo : Boolean;
	mergeRetainManCargo : Boolean;
	mergeRetainNoCargo : Boolean;
	mergePlanning,
	hasCargo,
	hasPlanning : Boolean; 
	completed, unactioned, partCompleted, exportCargo : Integer;
begin
	if self.myCurrentEDIBayPlan = null then
		app.msgBox('You must select an EDI plan', "Error", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

// ccms 1022 cnwrs1 june 2006	
	self.myCurrentVoyage.getJobTotals(completed, unactioned, partCompleted, exportCargo);
	if completed &gt; 0 or partCompleted &gt; 0 and exportCargo &gt; 0 then
		app.msgBox("The current bay plan cannot be made actual because the current voyage" &amp; CrLf &amp; 
				   "has jobs that have been worked.  You will need to either delete any" &amp; CrLf &amp; 
				   "worked jobs or create a new voyage.", "EDI Update", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;	
	endif;
//	if not self.myCurrentVoyage.allVoyageJobs.isEmpty  then
//		//if self.myCurrentVoyage.hasVoyageWorkStarted() then
//		app.msgBox("The current bay plan cannot be made actual because the current voyage" &amp; CrLf &amp; 
//				   "has jobs that may have been worked.  You will need to either delete all" &amp; CrLf &amp; 
//				   "jobs or create a new voyage.", "EDI Update", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
//		return;	
//	endif;
	hasCargo := not self.myCurrentVoyage.allOnshipTIsByCargoTypeId.isEmpty;
	hasPlanning := self.myCurrentVoyage.hasVoyageStartedPlanning();
	if  not hasCargo and
	   	not hasPlanning then
		theReturn := app.msgBox("Make EDI Bay Plan " &amp; self.myCurrentEDIBayPlan.description &amp; " Actual?", "EDI Update", MsgBox_Yes_No);
	else
		mergeOptionsForm := app.loadForm(CMUI_EDIBayPlanMerge, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_EDIBayPlanMerge;
		if mergeOptionsForm = null then
			return;
		endif;
		mergeOptionsForm.hasCargo := hasCargo;
		mergeOptionsForm.hasPlanning := hasPlanning;
		if mergeOptionsForm.showModal() &lt;&gt; IDOK then
			return;
		endif;
		// now get input options
		clearDetails := mergeOptionsForm.chkClear.value;
		if not clearDetails then
			mergeRetainAllCargo := mergeOptionsForm.optRetnAllCargo.value; //par 17595 cnwrs1 July 2008
			mergeRetainEDICargo := mergeOptionsForm.optRetnEDICargo.value;
			mergeRetainManCargo := mergeOptionsForm.optRetnManCargo.value;
			mergeRetainNoCargo := mergeOptionsForm.optRetnNoCargo.value;
			mergePlanning := mergeOptionsForm.optRetainPlannin.value;
		endif;
//		theReturn := app.msgBox("Merge EDI Bay Plan " &amp; self.myCurrentEDIBayPlan.description &amp; Cr &amp; " Into Actual?", "EDI Merge", MsgBox_Yes_No);
		theReturn := MsgBox_Return_Yes;
	endif;
	if theReturn = MsgBox_Return_Yes then
		app.mousePointer := Window.MousePointer_HourGlass;
		self.showMessageForBigUpdate(true, "Making Actual For ");
		while true do
			app.myTrxUA.trxSetEDIAsActualBayPlan(self.myCurrentVoyage, self.myCurrentEDIBayPlan, clearDetails, mergeRetainAllCargo, mergeRetainEDICargo, mergeRetainManCargo, mergeRetainNoCargo, mergePlanning, app.myPassport); //par 17595 cnwrs1 July 2008
			if app.myPassport.trxCompletedOK then
				self.switchDisplayMode(ShpDisplayMode_Actual, true);
				global.beep;
				break;
			else
				theReturn := app.showErrorWarningDialog('EDI Set To Actual', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			break;
		endwhile;
	endif;
epilog
	self.showMessageForBigUpdate(false, null); // hide frame
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuWorkEDIDeleteBuild" id="418ae397-1ccc-4977-aca4-26f65cf7957d">
        <source>doMnuWorkEDIDeleteBuild();
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	idx : Integer;
	aVoyage : CM_Voyage;
	theEDIController : CM_VoyageEDIBayPlanController;
	subMenu : MenuItem;
begin
	aVoyage := self.myCurrentVoyage;
	
	self.doPurgeSubMenus(self.mnuWorkEDIDelete);

	foreach theEDIController in aVoyage.allEDIBayPlans do
		idx := idx + 1;
		subMenu := self.mnuWorkEDIDelete.getMenuItem(idx);
		if subMenu = null then
			subMenu := self.mnuWorkEDIDelete.loadSubMenu(idx);
		endif;

		subMenu.caption := theEDIController.shortDescription;
		subMenu.userObject := theEDIController;

	endforeach;

	if idx = 0 then
		self.mnuWorkEDI.visible := false;
	else
		self.mnuWorkEDI.visible := true;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuWorkEDIDeleteClick" id="95a6139f-f7fb-47bc-beba-f72a49cbbccd">
        <updating/>
        <source>doMnuWorkEDIDeleteClick(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theReturn, theIndex : Integer;
	anEDI : CM_VoyageEDIBayPlanController;
	aVoyage : CM_Voyage;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin

	if menuItem.userObject = null then
		return;
	endif;
	
	anEDI := menuItem.userObject.CM_VoyageEDIBayPlanController;

	theReturn := app.msgBox("DELETE EDI Bay Plan " &amp; anEDI.description &amp; "?", "EDI Delete", MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
	if theReturn = MsgBox_Return_Yes then
		app.mousePointer := Window.MousePointer_HourGlass;
		aVoyage := self.myCurrentVoyage;
		
		//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxDA.trxDeleteEDIBayPlan(aVoyage, anEDI,app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				self.doMnuWorkEDIFilesBuild();
				self.doMnuWorkEDIDeleteBuild();
				break;
			else
				theResult := app.showErrorWarningDialog('EDI Delete', app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			return;
			
		endwhile;

	endif;
	
epilog
	app.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuWorkEDIDischClick" id="bb964ca0-e646-4ffb-988c-0934b3172d4b">
        <updating/>
        <source>doMnuWorkEDIDischClick(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 05/03/2018	jlgdap1		TFS 37322 QNS Auto Discharge colour after loading sequence and plan
// ---------------------------------------------------------------------------

vars
	result : Integer;				// TFS 37322

begin
//	user has agreed to perform the selected tasks
	app.mousePointer := Window.MousePointer_HourGlass;

	if self.chkAutoColorCode.value then	//should always be true
		
		// TFS 37322 this trx used to be done without a while loop, and without ErrWarnMode_CanAckWarnings
		// which meant if there were any warnings there was no Save button on the subsequent dialog.
		// and no way of acknowledging the warnings and repeating the update
		while true do
			app.myTrxUA.trxSetDfltDischargeColourCode(self.myCurrentVoyage.myCellularVoyageStructure, app.myPassport);
	
			if (not app.myPassport.trxCompletedOK) then
				//app.showErrorWarningDialog('Auto Discharge Colour Code', app.myPassport, ErrWarnMode_Update);
				result := app.showErrorWarningDialog('Auto Discharge Colour Code', app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
				//self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
				if app.myPassport.noErrors and result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				return;
			else
				break;
			endif;
		endwhile;
		
		global.beep;
		
		if self.chkImportTasks.value then
			app.myTrxUA.trxRunImportTasksOnShip(self.myCurrentVoyage, app.myPassport);
	
			if (not app.myPassport.trxCompletedOK) then
				app.showErrorWarningDialog('Run Import Tasks', app.myPassport, ErrWarnMode_Update);
				return;
			endif;
		else
			if self.myCurrentVoyage.importTasksLastRunDT.isValid
			and self.myTerminal.getConfig(ShipImportTaskOptions).Boolean then
				app.msgBox("Import tasks were last run on this voyage " &amp; self.systemToLocalTime(self.myCurrentVoyage.importTasksLastRunDT).shortCurrentLocaleFormat &amp; "."	
							&amp; CrLf &amp; "You may need to re-run this to process new import cargo.", $Warning, MsgBox_OK_Only + MsgBox_Information_Icon);	// 9/5/16 cnwmp6 TFS 488 - Multi timezone support
			endif;
		endif;

		global.beep;
		
		if self.chkCustomsEDI.value then
			app.myTrxUA.trxProcessStopsEDIOnShip(self.myCurrentVoyage, app.myPassport);
	
			if (not app.myPassport.trxCompletedOK) then
				app.showErrorWarningDialog('Process Customs EDI', app.myPassport, ErrWarnMode_Update);
				return;
			endif;
		endif;

		global.beep;

	endif;
						
epilog
	self.frmAutoDischCC.visible := false;
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuWorkEDIFilesBuild" id="085e438b-4b37-431a-818f-2277982a9c7e">
        <source>doMnuWorkEDIFilesBuild();
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	idx : Integer;
	aVoyage : CM_Voyage;
	theEDIController : CM_VoyageEDIBayPlanController;
	subMenu : MenuItem;
begin
	aVoyage := self.myCurrentVoyage;
	
	self.doPurgeSubMenus(self.mnuWorkEDIFiles);
	
	foreach theEDIController in aVoyage.allEDIBayPlans do
		idx := idx + 1;
		subMenu := self.mnuWorkEDIFiles.getMenuItem(idx);
		if subMenu = null then
			subMenu := self.mnuWorkEDIFiles.loadSubMenu(idx);
		endif;

		subMenu.caption := theEDIController.shortDescription &amp; ", " &amp; theEDIController.allPlannedFutureMoveEDIs.size.String &amp; " items.";
		if theEDIController.lastLoadToActualBayPlansDT.isValid() then
			subMenu.caption := subMenu.caption &amp; " (Loaded " &amp; self.systemToLocalTime(theEDIController.lastLoadToActualBayPlansDT).String &amp; ")";	// 9/5/16 cnwmp6 TFS 488 - Multi timezone support
		endif;
		subMenu.userObject := theEDIController;
	endforeach;

	self.mnuWorkEDIActual.enabled := false;
	self.mnuWorkEDILoad.enabled := false;
	self.mnuWorkEDIDisch.enabled := true;
	
	if idx = 0  then
		self.mnuWorkEDI.visible := false;
	else
		self.mnuWorkEDI.visible := true;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuWorkEDIFilesClick" id="1c447856-dd6f-4dc8-b616-ca4c8006f331">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>doMnuWorkEDIFilesClick(menuItem: MenuItem input) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theReturn, theIndex : Integer;
	anEDI : CM_VoyageEDIBayPlanController;
	theXMLCompressed: Binary;
begin

	if menuItem.userObject = null then
		return;
	endif;
	
	anEDI := menuItem.userObject.CM_VoyageEDIBayPlanController;
	theReturn := app.msgBox("View EDI Bay Plan " &amp; anEDI.description &amp; "?", "EDI View", MsgBox_Yes_No);
	
	if theReturn = MsgBox_Return_Yes then
		app.mousePointer := Window.MousePointer_HourGlass;
		self.myCurrentEDIBayPlan := anEDI;
		self.myBayDrawingController.currentEDIIndex := self.myCurrentVoyage.allEDIBayPlans.indexOf(anEDI);
		self.switchDisplayMode(ShpDisplayMode_EDI, true);
	endif;
epilog
	app.mousePointer := Window.MousePointer_Default;
	

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
