    <JadeMethod name="isCMIFDataMatch" id="b48802a3-1bea-4eaf-810a-0e4bbcf4f70e">
        <source>isCMIFDataMatch(_cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YADataObjects): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/09/2013	cnwdap1		Initial creation PAR #32215
//
vars

begin
	return _cmifAutoPlan.isVehicleType_Match(_yaData);

epilog

end;</source>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSnapShotDataMatch" id="b194683e-b6e5-471a-a324-a566e30b7a83">
        <source>isSnapShotDataMatch(_criteria: CM_YACriteria; _yaType: Integer; _propertyValue: String): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/09/2013	cnwdap1		Initial creation PAR #32215
//
vars
	obj		: Object;

begin
	if _yaType &lt;&gt; self.type then
		return false;
	endif;
	
	foreach obj in _criteria.myYAData.CM_YADataObjects.allObjects do
		if obj.CM_Car.carType = _propertyValue then
			return true;
		endif;
	endforeach;
	
	if _criteria.myYAData.isKindOf(CM_YADataPattern) and
	   _criteria.myYAData.CM_YADataPattern.pattern = null then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_yaType" type="Integer"/>
        <Parameter name="_propertyValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
