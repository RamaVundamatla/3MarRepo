    <JadeMethod name="setTableFromObjectSpecial" id="a34be134-29d0-4d13-80c7-ec05b11be6d5">
        <source>setTableFromObjectSpecial(	pTbl : CM_EntryTable input;
							pAttrName : String;
							pRow : Integer;
							pObj : Object
							): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 July 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	string : String;
	rtnValue : Boolean;
	cga : CM_CargoGroupAssignment;
	
begin
	
	cga := pObj.CM_CargoGroupAssignment;

	rtnValue := true;

	if pAttrName = ETRow_AssignmentId then
		string := cga.id;
		
/*	elseif pAttrName = ETRow_CargoType then
		if cgn.myCargoType &lt;&gt; null then
			string := cgn.myCargoType.abbreviation;
			self.cmbCargoType.listIndex := self.cmbCargoType.findObject( cgn.myCargoType );
		endif;
		
	elseif pAttrName = ETRow_CargoSubType then
		if cgn.myCargoSubType &lt;&gt; null then
			string := cgn.myCargoSubType.description;
			self.cmbSubCargoType.listIndex := self.cmbSubCargoType.findObject( cgn.myCargoSubType );
		endif;
		
	elseif pAttrName = ETRow_Operator then
		if cgn.myOperator &lt;&gt; null then
			string := cgn.myOperator.code;
			self.cmbOperator.listIndex := self.cmbOperator.findObject( cgn.myOperator );
		endif;
	
	elseif pAttrName = ETRow_MinWeight then
		self.setConvertedDisplayValue( self.tblCGNInput, ETRow_MinWeight, cgn.minWeight, app.getDefaultMeasurementForType(Type_Weight) );
	
	elseif pAttrName = ETRow_MaxWeight then
		self.setConvertedDisplayValue( self.tblCGNInput, ETRow_MaxWeight, cgn.maxWeight, app.getDefaultMeasurementForType(Type_Weight) );
	*/	
	else
		rtnValue := false;
		
	endif;
			
			
	if string &lt;&gt; null then
		pTbl.setValue(pRow, string);
	endif;
	
	return rtnValue;

epilog

end;</source>
        <Parameter name="pTbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="pAttrName" type="String"/>
        <Parameter name="pRow" type="Integer"/>
        <Parameter name="pObj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="7f99a2f2-6f76-4676-976a-1282a464514a">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 July 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	entTableDef : EntTableDef;

begin

	inheritMethod();
	
	self.populateFilterCombos();
	
	self.resize();
	
	self.sptThumbEdit.showRightControl(67, true);
	
	entTableDef := app.myController.getEntTableDef(ETDef_CGNData);
	self.tblCGN.setTblDataEntRowsArray( entTableDef, null, self.xmlStrTblCGN);
	
	self.splitThumbCGN.showRightControl(50, true);
	
	self.tblCGNid.rows := 0;
	
	self.setCaption( app.getErrorString( Cargo_group_assignment ) );
	
	self.tblSearch.setValueByControlName(self.cmbCargoType.name, self.cmbCargoType.text);
	self.tblSearch.setValueByControlName(self.cmbStatus.name, self.cmbStatus.text);
	self.tblSearch.setValueByControlName(self.cmbCGAType.name, self.cmbCGAType.text);
	
	self.allowMultiSelectDelete := self.allowUpdate;
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="b9509a09-ac84-4dc3-a2b7-7dbc96648987">
        <updating/>
        <source>showThumbnailData( _cga : CM_CargoGroupAssignment ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 July 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	entTableDef : EntTableDef;
	gotException : Boolean;
	edition : Integer;
	
	//cgn : CM_NotifiedCargoGroup;
	cargoGroups : CM_TIByIdCargoTypeDict;
	cg : CM_TrackedItem;	//CM_CargoGroup;
	string : String;
	
	canUpdate : Boolean;

begin

	canUpdate := _cga &lt;&gt; null;

	self.btnGroupMaint.enabled := canUpdate;
	self.btnEditTV.enabled := canUpdate and self.allowUpdate;
	self.btnDeleteTV.enabled := canUpdate and self.allowUpdate;
	
	if _cga = null then
		self.tblThumb.rows := 0;
		self.tblCGN.rows := 0;
		self.tblCGNid.rows := 0;
		return;
	endif;
	
	on Exception do app.handleDeletedObject (exception, _cga, gotException);
	
	edition := _cga.edition;
	
	if gotException then
		return;
	endif;

	self.tblThumb.rows := 0;
	self.tblThumb.columns := 2;
	
	self.showThumbnailForDef(ETDef_CGAData, _cga);
	self.setNavigatorHeading( _cga.id );
	
	self.tblThumb.cnEcResizeContents();
	
	//-------------------------------------------------------------
	
	self.tblCGN.rows := 1;
	self.tblCGN.selectMode := CM_Table.SelectMode_CurrentRow;
	
	entTableDef := app.myController.getEntTableDef(ETDef_CGNData);
	self.tblCGN.setTblDataEntRowsArray( entTableDef, null, self.xmlStrTblCGN);

	create cargoGroups transient;
	_cga.getAllCargoGroupsByIdDict( cargoGroups );
	foreach cg in cargoGroups do
		string := cg.getAttributeStringForDefArray(self.tblCGN.allTblDataEntRows);
		self.tblCGN.addItemObject( cg, string );
	endforeach;
	
/*	foreach cgn in _cga.allNotifiedCargoGroupByIdDict do
		string := cgn.getAttributeStringForDefArray(self.tblCGN.allTblDataEntRows);
		self.tblCGN.addItemObject( cgn, string );
	endforeach; */
	self.tblCGN.colourRows(self.colorRow1, self.colorRow2);
	
	self.splitThumbCGN.cnEcResizeContents();

	//--------------------------------------------------------------	
	
	self.tblCGNid.rows := 0;
		

epilog

	delete cargoGroups;

end;</source>
        <Parameter name="_cga" type="CM_CargoGroupAssignment"/>
    </JadeMethod>
