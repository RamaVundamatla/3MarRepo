    <JadeMethod name="notifiedIncludesCargoType" id="dbe90dbf-3781-47b3-9719-cc79c031746c">
        <source>notifiedIncludesCargoType( _cargoType : CM_CargoType ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 July 2018	jlgndl1	Initial creation	TFS 37882

*/

vars

	notifiedCargoGroup : CM_NotifiedCargoGroup;
	cg : CM_CargoGroup;
	ct : CM_CargoType;
	
	ti : CM_TrackedItem;

begin

	//02 Oct 2018	NDL	TFS 39186
	foreach ti in self.allCargoGroupsByIdDict do
		ct := ti.CM_CargoGroup.getCargoGroupCargoType();
		if ct = _cargoType then
			return true;
		endif;
	endforeach;

	foreach notifiedCargoGroup in self.allNotifiedCargoGroupByIdDict do
		cg := notifiedCargoGroup.getMatchingCargoGroup();
		if cg = null then
			continue;
		endif;
		ct := cg.getCargoGroupCargoType();
		if ct = _cargoType then
			return true;
		endif;
	endforeach;
	
	return false;

epilog

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
