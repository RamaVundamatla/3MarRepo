    <JadeMethod name="isTaskNowDue" id="3e5f3c1b-e300-4f1e-9af9-53e28dc3bf77">
        <source>isTaskNowDue(_runDateTime : TimeStamp; _startDateTime, _endDateTime : TimeStamp output) : Boolean;
//
// Parameters:	_runDateTime	- the time this task wil be run - server time (generally)
//
// Returns:		_startDateTime	-
//				_endDateTime	-
//
// 17 May 2012	cnwrs1	Par 26914 - make cam task transient and remove camprotocol::camTask
// 11 Dec 2012	cnwcs5	par 30855 / CCMS SFW 1294 - 
//06 Jul 2016	cnwrs1	Par 38021 - Review Cam logging
vars
	logCode			: String;
	delayedDateTime	: TimeStamp; //end date with delayTime added
	delayTime		: Time; //5 mins
begin
	logCode	:= self.code.trimRight;
	
	// if there is no schedule it will never be due
	if self.scheduleTimes.size = 0 then
		app.writeLog(logCode &amp; " No schedule. Will never be due.", LogERROR);
		return false;
	endif;

	// if currently busy test for stall 
	self.dueDateTimes(_runDateTime, _startDateTime, _endDateTime);

	//add n mins to endDate so we start n min after the protocol is due
	delayTime.setTime(0, terminal.getConfig(CamsDelayTime).Integer, 0, 0);
	
	delayedDateTime := _endDateTime + delayTime;
	
	app.writeLog(logCode &amp; " Next process date:" &amp; _endDateTime.String &amp; " will run at " &amp; delayedDateTime.time.String, LogWARN);

	if (not self.firstRunDateTime.isValid) then
	
		if _runDateTime &gt; delayedDateTime then
			app.writeLog(logCode &amp; " Past delay date/time (first run by date/time is invalid).", LogERROR);
			return true;
		endif;
		
		app.writeLog(logCode &amp; " First run by date/time is invalid for this protocol.", LogINFO);
		
		return false;
		
	elseif _runDateTime &gt; self.firstRunDateTime and _runDateTime &gt; delayedDateTime then  
		// ok to run - we have waited long enough to get started
		app.writeLog(logCode &amp; " Past first run by date/time.", LogWARN);
		
		return true;
	else
		// we have a first run timestamp (probably in the future) so don't run
		app.writeLog(logCode &amp; " Not past first run by date/time as yet.", LogWARN);
		
		return false;
	endif;

	// *** don't think we will ever get to this point ***
	if _runDateTime &gt; _startDateTime and _runDateTime &gt; delayedDateTime then
		app.writeLog(logCode &amp; " Run date past next end date.", LogWARN);
		return true;
	endif;
	
	return false;
end;</source>
        <Parameter name="_runDateTime" type="TimeStamp"/>
        <Parameter name="_startDateTime" type="TimeStamp" usage="output"/>
        <Parameter name="_endDateTime" type="TimeStamp" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTerminalActivity" id="bc890d5d-1a5b-4cee-b06a-76b8e70dba4b">
        <source>isTerminalActivity() : Boolean;
//
// par 16040 cnwrs1 Mar 2008
//
vars

begin
	if self.depotActivity and self.terminalActivity then //both set 
		return true;
	elseif ( not self.depotActivity) and (not self.terminalActivity) then //neither set 
		return true;
	else
		return self.terminalActivity;
	endif;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
