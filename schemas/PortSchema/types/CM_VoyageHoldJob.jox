    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>#################
#################

These jobs are for HOLD vessels that are using the HOLD Planning &amp; HOLD Operations screens. 
These jobs do have a CM_VoyageHoldJobSheet job sheet

#################
#################</text>
    <DbClassMap file="operatn"/>
    <ExplicitInverseRef name="allDLRLoadJobs" id="1f69ed82-68ff-4995-897e-42342837528d">
