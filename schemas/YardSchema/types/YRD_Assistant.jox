<Class name="YRD_Assistant" id="b0f40d11-991c-4e5b-adab-2c7eb8c25b92">
    <superclass name="CMUI_Assistant"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
