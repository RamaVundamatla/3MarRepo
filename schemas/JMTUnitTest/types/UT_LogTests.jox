    <JadeMethod name="addOperatorForLogs" id="2fe7e80b-79e6-4432-ad17-d469f807480b">
        <source>addOperatorForLogs(_code, _description, _logSpecsName: String): CM_Operator;
//09 September 2010	by cnwvu1

vars
	operator		: CM_Operator;
	logSpecs		: CM_CodeGroupLogSpecs;
	configCMIF		: CMIF_ConfigOperator;
	codeGroupsColl	: CM_CodeGroupsByTypeDict;	
	emailAddresses	: CM_EmailEntityByTypeNameDict;

begin

	create configCMIF transient;		// this is required to pass some extra fields
	create codeGroupsColl transient;
	create emailAddresses transient;	// need to put empty emailAddresses, otherwise there is UE 1090

	logSpecs := self.getLogSpecs(_logSpecsName);
	codeGroupsColl.add(logSpecs);
	
	//operator := self.addOperator(_code, _description, null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,codeGroupsColl,null,null,null,null,emailAddresses,null,configCMIF, false);		// PAR #28524 CCMS POL 2096
	operator := self.addOperator(_code, _description, null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,codeGroupsColl,null,null,null,null,emailAddresses,null,configCMIF, false, false);	// PAR #28524 CCMS POL 2096 
	self.assertNoTrxErrorsOrWarnings();

	return operator;

epilog
	delete configCMIF;
	delete codeGroupsColl;
	delete emailAddresses;

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_logSpecsName" type="String"/>
        <ReturnType type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="createBOLIn" id="c232e55c-5d4e-4b2d-b7a5-16f06c398ac2">
        <source>createBOLIn(_locationID, _bolInCode, _logPrefix: String; _logNumber: Integer);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 May 2014	cnwrd1	Initial creation

*/
vars
	operator	: CM_Operator;
	bolIn		: CM_BOLIn;
	logArray	: StringArray;
	tmpSED		: Integer;
	tmpPortion	: Real;
	portionSED	: Integer;
	i			: Integer;

begin

	operator	:= self.getOperator(OperatorCode);
	
	//-------------------------------------------------------------------
	//			Creating docket BOLInNumber_WeightUpdate
	//-------------------------------------------------------------------
	
	bolIn := self.addBOLIn(
					_bolInCode, 
					RTDeviceId,
					//_time			: TS; need to be set automatically
					VehicleId,
					CarrierCode,
					true, //_jasSacled
					100, //_percentagescaled
					true,	//_hundredticketed
					VehicleId, //_truckno, can be the same as vehicleId
					operator.code,				//_supplier
					LogSpecsSpeciesOak,		//_species
					LogSpecsGradeH,			//_grade
					LogSpecsTypeBoff,		//_logtype
					LogSpecsTreatmentUTT,	//_treatment
					LogSpecsLength8,		//_length
					_logNumber,			//_noitems, number of logs
					//_fellingdate	: string;  need to set automatically "20100901"
					//_scalerinitials	: String; 	//CNWVU1. Need to put usercode
					LogAreaCode &amp;","&amp; _locationID,	//_yardlocation	//LOGUT,LOGROW
					null,			//_forest, F1
					null,			//_compartment,	F1-1
					true,			//_fsc
					null,			//_loggingorg, LJL
					0.000,			//_grossweight
					0.000,			//_tareweight
					10,				//_netweight
					false			//_automatch
					);
	
	//if we are running the bad bol no test then return ehre
	if _bolInCode = self.BOLInNumber_BadNumber then
		return;
	endif;
	
	//-------------------------------------------------------------------
	//								Creating logs
	//-------------------------------------------------------------------
		
	

	
epilog	
	
end;</source>
        <Parameter name="_locationID" type="String"/>
        <Parameter name="_bolInCode" type="String"/>
        <Parameter name="_logPrefix" type="String"/>
        <Parameter name="_logNumber" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="createBOLInLogsForLogModuleTst" id="ea18acc8-1d17-4bad-b905-b536d5322241">
        <source>createBOLInLogsForLogModuleTst(_locationID, _bolInCode, _logPrefix: String; _logNumber: Integer);
// 28 January 2011	cnwvu1

vars
	operator	: CM_Operator;
	bolIn		: CM_BOLIn;
	logArray	: StringArray;
	tmpSED		: Integer;
	tmpPortion	: Real;
	portionSED	: Integer;
	i			: Integer;

begin

	operator	:= self.getOperator(OperatorCode);
	
	//-------------------------------------------------------------------
	//			Creating docket BOLInNumber_WeightUpdate
	//-------------------------------------------------------------------
	
	bolIn := self.addBOLIn(
					_bolInCode, 
					RTDeviceId,
					//_time			: TS; need to be set automatically
					VehicleId,
					CarrierCode,
					true, //_jasSacled
					100, //_percentagescaled
					true,	//_hundredticketed
					VehicleId, //_truckno, can be the same as vehicleId
					operator.code,				//_supplier
					LogSpecsSpeciesOak,		//_species
					LogSpecsGradeH,			//_grade
					LogSpecsTypeBoff,		//_logtype
					LogSpecsTreatmentUTT,	//_treatment
					LogSpecsLength8,		//_length
					_logNumber,			//_noitems, number of logs
					//_fellingdate	: string;  need to set automatically "20100901"
					//_scalerinitials	: String; 	//CNWVU1. Need to put usercode
					LogAreaCode &amp;","&amp; _locationID,	//_yardlocation	//LOGUT,LOGROW
					null,			//_forest, F1
					null,			//_compartment,	F1-1
					true,			//_fsc
					null,			//_loggingorg, LJL
					0.000,			//_grossweight
					0.000,			//_tareweight
					10,				//_netweight
					false			//_automatch
					);
	
	//if we are running the bad bol no test then return ehre
	if _bolInCode = self.BOLInNumber_BadNumber then
		return;
	endif;
	
	//-------------------------------------------------------------------
	//								Creating logs
	//-------------------------------------------------------------------
		
	
	// prepare log info
	create logArray transient;
	self.assertEqual(_logNumber, bolIn.numItems);
	
	tmpPortion := (100-10) / (_logNumber-1);
	portionSED := tmpPortion.rounded;
	
	foreach i in 1 to _logNumber do
		if i = 1 then 
			tmpSED := 10; // First log has SED = 10
		else
			tmpSED := tmpSED + portionSED;	// all other logs have SED growing
		endif;
		logArray.add( 	_logPrefix &amp; i.String &amp;Tab&amp;	// logId + i
						tmpSED.String &amp;Tab&amp;		// minSED
						tmpSED.String );		// maxSED
	endforeach;
	
	self.addLogsFromScaleData(_bolInCode, logArray, OperatorCode);	
	
epilog	
	delete logArray;
	
	
end;</source>
        <Parameter name="_locationID" type="String"/>
        <Parameter name="_bolInCode" type="String"/>
        <Parameter name="_logPrefix" type="String"/>
        <Parameter name="_logNumber" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="createBOLInLogs_WeightUdpdate" id="6a017da6-04df-4220-9583-dbef4f1d7c9f">
        <source>createBOLInLogs_WeightUdpdate();
// 16 September 2010	cnwvu1

vars
	operator	: CM_Operator;
	bolIn		: CM_BOLIn;
	logArray	: StringArray;
	logId		: String;
	i			: Integer;

begin

	operator	:= self.getOperator(OperatorCode);
	
	//-------------------------------------------------------------------
	//			Creating docket BOLInNumber_WeightUpdate
	//-------------------------------------------------------------------
	
	bolIn := self.addBOLIn(
					BOLInNumber_WeightUpdate, 
					RTDeviceId,
					//_time			: TS; need to be set automatically
					VehicleId,
					CarrierCode,
					true, //_jasSacled
					100, //_percentagescaled
					true,	//_hundredticketed
					VehicleId, //_truckno, can be the same as vehicleId
					operator.code,				//_supplier
					LogSpecsSpeciesOak,		//_species
					LogSpecsGradeH,			//_grade
					LogSpecsTypeBoff,		//_logtype
					LogSpecsTreatmentUTT,	//_treatment
					LogSpecsLength8,		//_length
					10,			//_noitems, number of logs
					//_fellingdate	: string;  need to set automatically "20100901"
					//_scalerinitials	: String; 	//CNWVU1. Need to put usercode
					LogAreaCode &amp;","&amp; LocationWeightUpdCode,	//_yardlocation	//LOGUT,LOGROW
					null,			//_forest, F1
					null,			//_compartment,	F1-1
					true,			//_fsc
					null,			//_loggingorg, LJL
					0.000,			//_grossweight
					0.000,			//_tareweight
					10,				//_netweight
					false			//_automatch
					);
	
	//-------------------------------------------------------------------
	//								Creating logs
	//-------------------------------------------------------------------

	// prepare log info
	create logArray transient;
	self.assertEqual(10, bolIn.numItems);	// we creating 10 logs for now
	
	logId := self.BOLInNumber_WeightUpdate[1:4] &amp; "LOG";
	foreach i in 1 to bolIn.numItems do
		logArray.add( 	logId &amp; i.String &amp;Tab&amp;	// logId
						(i*10).String &amp;Tab&amp;		// minSED
						(i*10).String );		// maxSED
	endforeach;
	
	self.addLogsFromScaleData(self.BOLInNumber_WeightUpdate, logArray, OperatorCode);	
	
epilog	
	delete logArray;
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="createBOLInLogs_nextTest" id="761908a1-e043-4bca-a735-95e9479b22b2">
