    <JadeMethod name="convertMetresToPoints" id="9e06a3e5-2c0c-426c-a0e1-5ed9807da990">
        <source>convertMetresToPoints( _metrePoints : DecimalArray; _newPoints : PointArray input);
//////////////////////////////////////////////////////////////
//															//
//					cnwmc5 - 6/9/2012						//
//															//
//	Copied from: CM_DeckItemLayout::convertMetresToPoints 	//
//															//
//////////////////////////////////////////////////////////////
vars
	pointCM,
	pointX,
	pointY : Decimal[12,2];
	aPoint : Point;
	xP, yP : Integer;
	newPoint : Boolean;
begin
	if _metrePoints = null then
		return;
	endif;
		
	_newPoints.clear;
	newPoint := true; 

	foreach pointCM in _metrePoints do
		if newPoint then 
			pointX:= pointCM;
			newPoint := false;
			continue;
		else
			pointY:=pointCM;
		endif;
		
		//1 m = 10 pixel
		xP := (pointX * 10).Integer;
		xP := xP + 200;
		yP := (pointY * 10).Integer;
		yP := yP + 300;
		
		aPoint.setX(xP);
		aPoint.setY(yP);
		
		
		_newPoints.add(aPoint);
		
		newPoint := true;
	endforeach;
epilog

end;</source>
        <Parameter name="_metrePoints" type="DecimalArray"/>
        <Parameter name="_newPoints" type="PointArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="convertPixelsToMetres" id="2e2e6c24-f0b9-407e-be3b-d6f867f9d61f">
        <source>convertPixelsToMetres(_point : Point io) : Point;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 April 2013	cnwmc5	Initial creation

*/

vars
	xP, yP : Integer;
begin
	xP := _point.x;
	yP := _point.y;

	_point.setX(((xP/10) - (200 /10)).Integer);
	_point.setY((-1 *  ((300/10) - (yP /10))).Integer);
	
	return _point;
epilog

end;</source>
        <Parameter name="_point" type="Point" usage="io"/>
        <ReturnType type="Point"/>
    </JadeMethod>
    <JadeMethod name="convertPolygonFromXML" id="e53cdfd1-8a09-438f-8041-582d43665846">
        <source>convertPolygonFromXML();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2013	cnwmc5	Initial creation

*/

vars
	realArray : RealArray;
	xmlStr : String;
begin
	drawFrame.clearGraphics();
	
	create realArray transient;
	//xmlStr := '&lt;Path Data="M0.5,0.5 L280.5,44.5 M0.50000042,0.50000495 L111.523,110.81001 M280,45.000008 L112.5,109.50001" Margin="8,150,0,0"/&gt;';
	//xmlStr := '&lt;Path Data="M63.165985,105.16599 L243.16599,41.832996 M63.166,106.16599 L0.5000003,67.165985 M0.50000137,67.166008 L96.500008,41.833004 M97.000015,41.833 L98.000015,68.166 M98.500015,67.166008 L159.16602,25.833002 M94.500023,41.833004 L97.500023,68.166 M160.166,25.833002 L327.16599,0.50000048 M328.16599,0.50000381 L277.16599,203.83301 M277.16602,204.83302 L153.83299,130.50002 M153.83301,130.5 L244.16602,41.833004" Margin="88.667,78.667,222.667,196"/&gt;';
	//xmlStr := '&lt;Path Data="M33.832996,113.166 L159.83299,0.50000072 M160.83301,0.5 L351.16602,141.16602 M352.16599,142.16599 L267.16599,167.83299 M267.16602,168.83299 L201.166,77.833 M201.16599,77.833 L121.16599,189.83299 M121.16598,190.83299 L77.165977,114.16599 M77.166,114.16599 L0.5,203.16599 M0.50000095,204.16599 L33.833,114.166" Margin="108.667,54.667,178.667,220.667"/&gt;';
	xmlStr := '&lt;Path Data="M0.50000238,65.834 L1.1670024,131.16701 M0.50000668,132.16699 L109.83301,132.16699 M111.33299,132.16701 L112.33299,163.834 M111.83299,164.834 L206.49998,79.167 M207.49998,79.166992 L111.83299,0.5 M110.83299,0.50000012 L110.83299,55.167 M107.83301,56.167 L0.50000095,56.167 M0.5,56.167 L0.5,65.834" Margin="136,49.333,296,0"/&gt;';
	xmlStr.convertPolygonFromXML(realArray);
	
	//Do draw here
	drawFrame.drawPolygon(realArray, Red);
epilog
	delete realArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDrawPoly" id="e6f3d5f3-5c26-485d-88a2-badbdf0ae250">
        <source>doDrawPoly(_polyType : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 August 2012	cnwmc5	Initial creation


	KEY FOR _polyType :
		1 = rectangle
		2 = octagon

*/

vars
	frame 		: Frame;
	points 		: RealArray;
	point		: Point;
	pointArr,
	pointArrNew : PointArray;
	pos			: Integer;
	decArr		: DecimalArray;
	x1,y1,x2,y2 : Integer;
	
begin
	frame := self.drawFrame;
	frame.autoRedraw := true;
	
	pos := 1;
	
	create points transient;
	create pointArr transient;
	create pointArrNew transient;
	create decArr transient;
	
	// Create a polygon
	if _polyType = 1 then
		point.set(10,10);
		pointArr.add(point);
		point.set(100,10);
		pointArr.add(point);
		point.set(100,50);
		pointArr.add(point);
		point.set(10,50);
		pointArr.add(point);
		self.writePointsInEDIFormat(pointArr, _polyType);
	elseif _polyType = 2 then
		point.set(160,10);
		pointArr.add(point);
		point.set(190,10);
		pointArr.add(point);
		point.set(220,40);
		pointArr.add(point);
		point.set(220,70);
		pointArr.add(point);
		point.set(190,100);
		pointArr.add(point);
		point.set(190,100);
		pointArr.add(point);
		point.set(160,100);
		pointArr.add(point);
		point.set(130,70);
		pointArr.add(point);
		point.set(130,40);
		pointArr.add(point);
		self.writePointsInEDIFormat(pointArr, _polyType);
	elseif _polyType = 3 then
		point.set(300,10);
		pointArr.add(point);
		point.set(360,10);
		pointArr.add(point);
		point.set(360,150);
		pointArr.add(point);
		point.set(240,150);
		pointArr.add(point);
		point.set(240,70);
		pointArr.add(point);
		point.set(300,70);
		pointArr.add(point);
		self.writePointsInEDIFormat(pointArr, _polyType);
	elseif _polyType = 4 then
		point.set(10,60);
		pointArr.add(point);
		point.set(30,60);
		pointArr.add(point);
		point.set(30,100);
		pointArr.add(point);
		point.set(100,100);
		pointArr.add(point);
		point.set(100,150);
		pointArr.add(point);
		point.set(10,150);
		pointArr.add(point);
		self.writePointsInEDIFormat(pointArr, _polyType);
	elseif _polyType = 5 then
		point.set(10,160);
		pointArr.add(point);
		point.set(10,210);
		pointArr.add(point);
		point.set(60,210);
		pointArr.add(point);
		point.set(60,260);
		pointArr.add(point);
		point.set(10,260);
		pointArr.add(point);
		point.set(10,310);
		pointArr.add(point);
		point.set(150,310);
		pointArr.add(point);
		point.set(150,260);
		pointArr.add(point);
		point.set(100,260);
		pointArr.add(point);
		point.set(100,210);
		pointArr.add(point);
		point.set(150,210);
		pointArr.add(point);
		point.set(150,160);
		pointArr.add(point);
		self.writePointsInEDIFormat(pointArr, _polyType);
	elseif _polyType = 6 then
		point.set(160,160);
		pointArr.add(point);
		point.set(160,300);
		pointArr.add(point);
		point.set(210,260); 	//changed to 100 from 150
		pointArr.add(point);
		point.set(210,260);
		pointArr.add(point);
		point.set(260,260);
		pointArr.add(point);
		point.set(260,300);
		pointArr.add(point);
		point.set(310,300);	//changed to 100 from 150
		pointArr.add(point);
		point.set(310,160);
		pointArr.add(point);
		point.set(260,160);
		pointArr.add(point);
		point.set(260,210);
		pointArr.add(point);
		point.set(210,210);
		pointArr.add(point);
		point.set(210,160);
		pointArr.add(point);
		self.writePointsInEDIFormat(pointArr, _polyType);
	elseif _polyType = 7 then
		point.set(60,10);
		pointArr.add(point);
		point.set(90,30);
		pointArr.add(point);
		point.set(90,40);
		pointArr.add(point);
		//point.set(120,70);
		//pointArr.add(point);
		point.set(90,100);
		pointArr.add(point);
		point.set(90,100);
		pointArr.add(point);
		//point.set(60,100);
		//pointArr.add(point);
		point.set(30,70);
		pointArr.add(point);
		//point.set(30,40);
		//pointArr.add(point);
	elseif _polyType = 8 then
		point.set(530,80);
		pointArr.add(point);
		point.set(410,80);
		pointArr.add(point);
		point.set(410,60);
		pointArr.add(point);
		point.set(450,60);
		pointArr.add(point);
		point.set(450,30);
		pointArr.add(point);
		point.set(490,5);
		pointArr.add(point);
		point.set(530,5);
		pointArr.add(point);
		self.writePointsInEDIFormat(pointArr, _polyType);
	elseif _polyType = 10 then
		self.buildLargePoly(decArr);
		self.convertMetresToPoints(decArr, pointArrNew);
		self.writePointsInEDIFormat(pointArrNew, _polyType);
		foreach point in pointArrNew do
			//point.setX(point.x - 200);
			//point.setY(point.y - 200);
			pointArr.add(point);
		endforeach;
	endif;
	
	// Convert pointArr to points (a RealArray)
	foreach point in pointArr do
		points[pos] := point.x;
		pos := pos + 1;
		points[pos] := point.y;
		pos := pos + 1;
	endforeach;
	
	// Draw poly
	frame.drawFillColor := White;
	frame.drawFilledPolygon(points, null);
	
	// Call method to find out where to place text
	//self.doDrawText(pointArr);
	
	self.calcBestPlace(pointArr);
	
	//pointArr.getExtremesForText(x1,y1,x2,y2);
	//frame.drawRectangle(x1,y1,x2,y2,Red);
	
epilog
	delete points;
	delete pointArr;
	delete pointArrNew;
	delete decArr;
end;</source>
        <Parameter name="_polyType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doDrawText" id="e29c1328-763e-48c1-bdda-b4e09c63ab16">
        <source>doDrawText(_points : PointArray);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 August 2012	cnwmc5	Initial creation

*/

vars
	frame 		: Frame;
	point 		: Point;
	lowPoint 	: Point;
	realArr		: RealArray;
	minX, maxX 	: Point;
	startX, 
	startY 		: Integer;
begin
	frame := self.drawFrame;
	
	minX := null;
	maxX := null;
	
	// Work out where to place text...
	/*foreach point in _points do
		if lowPoint = null then
			lowPoint := point;
		else
			if point.x &lt; lowPoint.x then
				lowPoint := point;
			elseif point.x = lowPoint.x and point.y &lt; lowPoint.y then
				lowPoint := point;
			else
				continue;
			endif;
		endif;
	endforeach;*/
	
	//TEST
	foreach point in _points do
		if minX = null then
			minX := point;
		elseif point.x &lt; minX.x then
			minX := point;
		elseif point.x = minX.x and point.y &lt; minX.y then
			minX := point;
		endif;
		if maxX = null then
			maxX := point;
		elseif point.x &gt; maxX.x then
			maxX := point;
		elseif point.x = maxX.x and point.y &lt; maxX.y then
			maxX := point;
		endif;
	endforeach;
	if maxX.y &gt; minX.y then
		maxX.set(minX.x, maxX.y);
		lowPoint := maxX;
	else
		lowPoint := minX;
	endif;
	//END TEST
	
	write "Max X: " &amp; maxX.x.String &amp; ". Y: " &amp; maxX.y.String;
	write "Min X: " &amp; minX.x.String &amp; ". Y: " &amp; minX.y.String &amp; CrLf;
	
	
	// Set of the TEXT (red mark)
	startX := lowPoint.x + 5;
	startY := lowPoint.y + 5;
	
	create realArr transient;
	
	realArr[1] := startX;
	realArr[2] := startY;
	realArr[3] := startX + 5;
	realArr[4] := startY;
	realArr[5] := startX;
	realArr[6] := startY + 5;
	
	// Place red dot
	//write "END: " &amp; lowPoint.x.String &amp; " " &amp; lowPoint.y.String;
	frame.drawFillColor := Red;
	frame.drawFilledPolygon(realArr ,Red);
	
	//TESTING
	frame.drawLine(minX.x, minX.y, maxX.x, maxX.y, Red);
	//self.drawLineFromPoints();
epilog
	delete realArr;
end;</source>
        <Parameter name="_points" type="PointArray"/>
    </JadeMethod>
