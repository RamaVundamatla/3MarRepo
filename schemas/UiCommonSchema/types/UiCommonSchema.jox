        <source>toolbarHidden(set: Boolean; _value: Boolean io) updating, mapping;
// ---------------------------------------------------------------------------
// Created:     10 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theMdiFrame		: Form;
	superAppForm	: CMUI_SuperAppForm2;
	toolbarFrame	: CMUI_Toolbar;

begin

	if (not set) then
		return;
	endif;

	theMdiFrame := app.mainForm;
	if theMdiFrame &lt;&gt; null and theMdiFrame.isKindOf(CMUI_SuperAppForm2) then
		superAppForm := theMdiFrame.CMUI_SuperAppForm2;
		
		toolbarFrame := superAppForm.frmToolbar;
		
		toolbarFrame.updateSelfForPermissions(self.getMyUser, self.getMyTerminalDO_NOT_USE);

		toolbarFrame.visible := (not _value);

/*
if toolbarFrame.visible then
	superAppForm.loadToolbar();
	process.debug;
	toolbarFrame.visible := true;
endif;
*/
		toolbarFrame.refreshNow();
		superAppForm.mnuViewToolbar.checked := (not _value);
		
		// need to set this before calling doResize
		self.toolbarHidden := _value;
	
		// Forces the client height to be updated and the form redrawn. This is done 
		superAppForm.doResize();
	
		if superAppForm.activeChild &lt;&gt; null then
			if superAppForm.activeChild.windowState = superAppForm.WindowState_Maximized then
				// Resize the active child window as its size may have changed.
				superAppForm.activeChild.resize();
			endif;
			if superAppForm.activeChild.isKindOf(CM_BaseForm) then
				superAppForm.activeChild.CM_BaseForm.mnuViewToolbar.checked := (not _value);
			endif;
		endif;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="unloadAllForms" id="65563e63-d5c0-47d9-b8ac-d0ba4047e945">
        <source>unloadAllForms();
// ---------------------------------------------------------------------------
// Created:     08 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx		: Integer;
	form	: Form;

begin

	idx := app.formsCount;
	while idx &gt; 0 do
		form := app.forms(idx);
		if form &lt;&gt; null and 
		   (not form.isKindOf(CMUI_SuperAppForm2)) then //and 
		 //  form &lt;&gt; self.myErrorWarningForm then
			// the error warning form is unloaded in the app.logout method.
			form.unloadForm;
			delete form;
		endif;
		idx := idx - 1;
	endwhile;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="useDisableWindowsGhosting" id="37a8bd9c-4bff-428b-9f10-d703ee4972ca">
        <source>useDisableWindowsGhosting():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 June 2012	cnwndl1	Initial creation	Par 29508

*/

vars

	returnValue : Boolean;
	isAppServer	: Boolean;
	iniFileName : String;
	iniValue : String;

begin

	// We want to use this feature unless the user specifically turns it off.  I.e. default to true
	// and only return false if the ini setting really is false.
	
	isAppServer	:= node.isApplicationServer;
	if isAppServer then
		iniFileName := self.getIniFileNameAppServer();
		iniValue := self.getProfileStringAppServer(iniFileName, JMTerminal, 'DisableWindowsGhosting', 'true').toLower;
	else
		iniFileName := self.getIniFileName();
		iniValue := self.getProfileString(iniFileName, JMTerminal, 'DisableWindowsGhosting', 'true').toLower;
	endif;
	
	if iniValue = 'false' then
		returnValue := false;
	else
		returnValue := true;
	endif;
	
	return returnValue;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="useTiledView" id="2eef7ccb-b59e-4273-b151-70bd5452c8fe">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>useTiledView(set: Boolean; _value: Boolean io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:     12 June 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set then
		self.useTiledView := _value;
		if _value then
			self.doTileWindows();
		endif;
	else
		_value := self.useTiledView;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="viewAuditForm" id="d39be860-4334-4bd1-aa3d-3711e3e67c9d">
        <source>viewAuditForm(pObj : CM_Object; pAssistantClass : Class; pTerminal : CM_Terminal);
// ---------------------------------------------------------------------------
// Created:     29 January 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	form : CM_AuditViewForm;	

begin

	form := app.loadForm(CM_AuditViewForm, pAssistantClass, false, false, false, pTerminal, null).CM_AuditViewForm;
	
	if form = null then
		// user must not have permission to view
		return;
	endif;

	if pObj &lt;&gt; null then
		//Preload the form with audit details for that object
		//form.CM_AuditViewForm.setWithDefinedObject(pObj);
		form.myAudittedObject := pObj;
	endif;

	form.show();

end;</source>
        <Parameter name="pObj" type="CM_Object"/>
        <Parameter name="pAssistantClass" type="Class"/>
        <Parameter name="pTerminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="viewAuditFormModal" id="6a2b7aca-9d58-4b85-b655-3388ad6ec9d9">
        <source>viewAuditFormModal(pObj : CM_Object; pAssistantClass : Class; pTerminal : CM_Terminal);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 December 2017	jlgndl1	Initial creation		Modal version	TFS 8095

*/

vars
	form : CM_AuditViewFormModal;	

begin

	form := app.loadForm(CM_AuditViewFormModal, pAssistantClass, false, false, true, pTerminal, null).CM_AuditViewFormModal;
	
	if form = null then
		// user must not have permission to view
		return;
	endif;

	if pObj &lt;&gt; null then
		//Preload the form with audit details for that object
		//form.CM_AuditViewForm.setWithDefinedObject(pObj);
		form.myAudittedObject := pObj;
	endif;

	form.showModal();

end;</source>
        <Parameter name="pObj" type="CM_Object"/>
        <Parameter name="pAssistantClass" type="Class"/>
        <Parameter name="pTerminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="viewReleaseHistory" id="288467d2-bbe2-43af-b7e2-bdc2e7e77690">
        <updating/>
        <source>viewReleaseHistory() updating;
// ---------------------------------------------------------------------------
// Created:     23 October 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	form	: CnEcReleaseHistoryForm;
begin

	if self.myBaseRoot = null then
		self.cnEcInitializeBaseSchema();
	endif;
	app.defaultMdi := true;
	form := self.loadForm(CnEcReleaseHistoryForm, null, false, false, false, app.getMyTerminalDO_NOT_USE(), null).CnEcReleaseHistoryForm;
	if form &lt;&gt; null then
		form.show;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="xHandlerUI" id="8ccb3cd1-2ce1-4dce-b552-d7399f8d9335">
        <source>xHandlerUI(_exceptionObj:UserInterfaceException):Integer protected;
// --------------------------------------------------------------------------------
// Created:		29 September 2008 by cnwdad1
//
// Purpose:		This exception handler is used to explicitly deal with the situation
//				where Windows GDI resources are all used up.
//
// Parameters:	_exceptionObj - A reference to the exception object.
//
// Returns:		A code to indicate how Jade should proceed following the exception.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 17/02/2010	cnwjo3		PortSchema::myMessageForm was invalid.  Now dealing with invalid objects.  par 20712
// --------------------------------------------------------------------------------
constants
	WINDOW_CREATE_FAILED	: Integer = 14063;
	
vars
	formCount	: Integer;
	messageForm : CMS_UserMessageForm;
	invalidForm : Boolean;
	msg : String;
	title : String;
	flags : Integer;
begin
	if _exceptionObj.errorCode = WINDOW_CREATE_FAILED then
		formCount	:=	app.formsCount();
		app.writeLog("GDI resources exhausted - there are " &amp; formCount.String &amp; " forms open.", LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		messageForm := self.myMessageForm;
		if messageForm &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception,messageForm,invalidForm);
			
			messageForm.showMe();
			
			if invalidForm then
				//somehow PortSchema::myMessageForm is invalid!
				msg := app.getErrorString(NoMore_Restrictions);
				title := "";
				flags := MsgBox_OK_Only;
				app.msgBox(msg,title,flags);
			endif;
			
			return Ex_Abort_Action;
		endif;
	endif;
		
	return Ex_Pass_Back;
end;</source>
        <access>protected</access>
        <Parameter name="_exceptionObj" type="UserInterfaceException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
