    <JadeMethod name="displayForXlation" id="0df18c25-3885-4c19-812b-ac2a486517fc">
        <source>displayForXlation(_codeFirst: Boolean): String;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 09 November 2023
TFS#		: 61129
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	if _codeFirst then
		return self.code.trimBlanks&amp;' ['&amp;self.description.trimBlanks&amp;']';
	else
		return self.description.trimBlanks&amp;' ['&amp;self.code.trimBlanks&amp;']';
	endif;
end;
</source>
        <Parameter name="_codeFirst" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="da77bd8a-7f33-4fd2-b364-240e691de477">
        <source>getDisplayDetails(_short: Boolean): String;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 10 November 2023
TFS#		: 61130
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
begin	
	if _short then
		return self.code;
	else
		return self.priority.asStringJMT() &amp; " - " &amp; self.description;
	endif;
end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
