    <JadeMethod name="cp006_SVAF_cmbVoyage_click" id="7288915b-f3fe-4b39-96be-f624b3ee67e6">
        <updating/>
        <source>cp006_SVAF_cmbVoyage_click():Integer updating;

vars
	cmbVoyage:ComboBox;
	picture:Picture;
	mnuBaySelHolds:MenuItem;
begin
	mySHP_VoyageAreaForm2_1:=app.getForm('SHP_VoyageAreaForm2').Form;
	cmbVoyage:=mySHP_VoyageAreaForm2_1.getPropertyValue('cmbVoyage').ComboBox;
	cmbVoyage.gotFocus(cmbVoyage);
	
	/*picture:=app.atcgGetAddedControl(mySHP_VoyageAreaForm2_1, 'Bay Selection Options;picture;CMUI_ToolbarOverlay;0;-20;0;0;|;frame;CMUI_ToolbarButton;24;-360;0;2;|;frmToolbarSelect;CMUI_Toolbar;0;-386;0;0;|').Picture;
	picture.mouseDown(picture, 1, 0, 8, 16);
	app.doWindowEvents(shortPause);
	picture:=app.atcgGetAddedControl(mySHP_VoyageAreaForm2_1, 'Bay Selection Options;picture;CMUI_ToolbarOverlay;0;-20;0;0;|;frame;CMUI_ToolbarButton;24;-360;0;2;|;frmToolbarSelect;CMUI_Toolbar;0;-386;0;0;|').Picture;
	picture.mouseUp(picture, 1, 0, 8, 16);
	app.doWindowEvents(shortPause);
	picture:=app.atcgGetAddedControl(mySHP_VoyageAreaForm2_1, 'Bay Selection Options;picture;CMUI_ToolbarOverlay;0;-20;0;0;|;frame;CMUI_ToolbarButton;24;-360;0;2;|;frmToolbarSelect;CMUI_Toolbar;0;-386;0;0;|').Picture;
	app.doWindowEvents(shortPause);
	picture.click(picture);  // Bay Selection Options  // 12:58:41
	app.doWindowEvents(shortPause);/**/

	mnuBaySelHolds:=mySHP_VoyageAreaForm2_1.getPropertyValue('mnuBaySelHolds').MenuItem;
	mySHP_VoyageAreaForm2_1.sendMsgWithParams('mnuBaySelHolds_click', mnuBaySelHolds);
	app.doWindowEvents(shortPause);

	cmbVoyage:=mySHP_VoyageAreaForm2_1.getPropertyValue('cmbVoyage').ComboBox;
	cmbVoyage.listIndex:=app.atcgGetComboStringIndex(cmbVoyage, 1, 'JBL500N EMMA MAERSK', 35);
	cmbVoyage.closeup(cmbVoyage);
	cmbVoyage:=mySHP_VoyageAreaForm2_1.getPropertyValue('cmbVoyage').ComboBox;
	app.doWindowEvents(shortPause);
	cmbVoyage.listIndex:=app.atcgGetComboStringIndex(cmbVoyage, 1, 'JBL500N EMMA MAERSK', 35);
	cmbVoyage.click(cmbVoyage);  // 14:42:33
	return 0;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cp008_SVAF_button_click" id="ee59ee40-e302-449b-a85c-6b47e2f5ec64">
        <updating/>
        <source>cp008_SVAF_button_click():Integer updating;

vars
	button:Button;
	cmbVoyage:ComboBox;
begin
	button := mySHP_VoyageAreaForm2_1.getPropertyValue("msgHolds").CMUI_MultiSelectGroupBox.myAddAllBtn;
//	button:=app.atcgGetAddedControl(mySHP_VoyageAreaForm2_1, ';button;CM_MultiSelectButton;175;-196;77;0;|;msgHolds;CMUI_MultiSelectGroupBox;5;-381;52;0;|').Button;
	button.mouseDown(button, 1, 0, 9, 9);
	app.doWindowEvents(shortPause);
	cmbVoyage:=mySHP_VoyageAreaForm2_1.getPropertyValue('cmbVoyage').ComboBox;
	cmbVoyage.lostFocus(cmbVoyage);
//	button:=app.atcgGetAddedControl(mySHP_VoyageAreaForm2_1, ';button;CM_MultiSelectButton;175;-196;77;0;|;msgHolds;CMUI_MultiSelectGroupBox;5;-381;52;0;|').Button;
	button.mouseUp(button, 1, 0, 9, 9);
	app.doWindowEvents(shortPause);
//	button:=app.atcgGetAddedControl(mySHP_VoyageAreaForm2_1, ';button;CM_MultiSelectButton;175;-196;77;0;|;msgHolds;CMUI_MultiSelectGroupBox;5;-381;52;0;|').Button;
	app.doWindowEvents(shortPause);
	button.click(button);  // 14:42:35
	return 0;
end;</source>
