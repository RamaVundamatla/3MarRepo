    <JadeMethod name="getDateTimeLocalTZ" id="69ea186d-0d0e-49b5-af65-6c9ea3ee9ae5">
        <source>getDateTimeLocalTZ() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2016	cnwns1	Initial creation
// 30 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	return self.systemToLocalTime(self.dateTime);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getDescriptionText" id="de325253-58ca-4953-adb6-5561a7066e89">
        <source>getDescriptionText(): String protected;
// ---------------------------------------------------------------------------
// Created:		May 2010 cnwjre1 for 23582 changes (add expiry date and ignore options)
//				'Create' text changed at the same time to just show new values
// Purpose:		
//	To build the audit description text in one place
// ---------------------------------------------------------------------------
// 25 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 20 Feb 2018	jlgmd1	TFS 36954 SNO - Error in SCT2 Rate Table  (Swap $CM_RateEntry.decimalPlaces for terminal config)

vars
	theString : String;
	dpl : Integer;
begin
	dpl := self.getRateEntryDecimalPlaces; // TFS 36954 MPD 20 Feb 2018
	if self.isDeleted then
		//theString := "DELETED. Unit cost was " &amp; self.previousCost.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, true)  &amp;
		theString := "DELETED. Unit cost was " &amp; self.previousCost.asStringJMTWithPrecision(dpl, true)  &amp;	// TFS 36954 MPD 20 Feb 2018
		" Start Time was " &amp; self.systemToLocalTime(self.previousStartTime).asStringJMT();		// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if self.previousExpiryTime = null then
			theString := theString &amp; " No Expiry Time";
		else
			theString := theString &amp; " Expiry Time " &amp; self.systemToLocalTime(self.previousExpiryTime).asStringJMT();
		endif;
		theString := theString &amp; " Ignore Entry was " &amp; self.previousIgnoreEntry.asStringJMT();	// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	elseif self.status = self.Status_Create then
		//theString := "Unit cost " &amp; self.newCost.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, true)  &amp;
		theString := "Unit cost " &amp; self.newCost.asStringJMTWithPrecision(dpl, true)  &amp;	// TFS 36954 MPD 20 Feb 2018
		" Start Time " &amp; self.systemToLocalTime(self.newStartTime).asStringJMT();				// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if self.newExpiryTime = null then
			theString := theString &amp; " No Expiry Time";
		else
			theString := theString &amp; " Expiry Time " &amp; self.systemToLocalTime(self.newExpiryTime).asStringJMT();// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		theString := theString &amp; " Ignore Entry " &amp; self.newIgnoreEntry.asStringJMT();
	else
		if self.previousCost &lt;&gt; self.newCost then
			//theString :=  "Rate " &amp; self.previousCost.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, true) &amp; " =&gt; " &amp; 
				//self.newCost.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, true);
			// TFS 36954 MPD 20 Feb 2018
			theString :=  "Rate " &amp; self.previousCost.asStringJMTWithPrecision(dpl, true) &amp; " =&gt; " &amp; 
				self.newCost.asStringJMTWithPrecision(dpl, true);
		else
			theString := "No Change to cost/unit.";
		endif;
		if self.previousStartTime &lt;&gt; self.newStartTime then
			theString := theString &amp; " Start Time " &amp; self.systemToLocalTime(self.previousStartTime).asStringJMT() &amp; " =&gt; " &amp; 
				self.systemToLocalTime(self.newStartTime).asStringJMT() ;
		else
			theString := theString &amp; " No change to Start Time." ;
		endif;
		if self.previousExpiryTime &lt;&gt; self.newExpiryTime then
			theString := theString &amp;	" Expiry Time " &amp; self.systemToLocalTime(self.previousExpiryTime).asStringJMT() &amp; " =&gt; " &amp; 
				self.systemToLocalTime(self.newExpiryTime).asStringJMT() ;
		else
			theString := theString &amp; " Expiry Time unchanged." ;
		endif;
		if self.previousIgnoreEntry &lt;&gt; self.newIgnoreEntry then
			theString := theString &amp; " Ignore Entry " &amp; self.previousIgnoreEntry.asStringJMT() &amp; " =&gt; " &amp;
					self.newIgnoreEntry.asStringJMT() ;
		else
			theString := theString &amp; " Ignore Entry unchanged." ;
		endif;
	endif;
	return theString;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="2feb3011-4814-41d6-9329-5c20dc4b5b22">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//	23582 revised description, now in separate method
// ---------------------------------------------------------------------------
// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	theString : String;
	finObj : CM_FinancialObject;
begin
	if _attrName = ETRow_SequenceNum  then
		return self.sequenceNum.String;	
	elseif _attrName = ETRow_Code  then
		if global.isValidObject(self.myRateEntry) and global.isValidObject(self.myRateEntry.rate) then
			return self.myRateEntry.rate.getCode();
		elseif not self.auditedFOs.isEmpty() then
			foreach finObj in self.auditedFOs discreteLock do
				if finObj.isKindOf(CM_DebtorRate) then
					return finObj.CM_DebtorRate.getCode();
				endif;
			endforeach;
		else
			return null;
		endif;
	elseif _attrName = ETRow_Status  then
		return self.statusDescription;
	elseif _attrName = ETRow_Description  then
		return self.getDescriptionText();
	elseif _attrName = ETRow_User  then
		return self.userId;	
	elseif _attrName = ETRow_EndDate  then
		return self.systemToLocalTime(self.dateTime).String;	// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	elseif _attrName = ETRow_Ti  then
		return null;	
	else
		return inheritMethod(_attrName, _short);
	endif;


end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="8dd68362-ad1c-4044-85a8-3880d844f8f9">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	block : CM_DataContainerBlock;

begin
	inheritMethod(_dataContainer);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Description), DC_Label, 1, self);
	//block.addNewItem(self.sequenceNum.String, DC_Data, 1, self);
	block.addNewItem(self.getDescriptionText().String, DC_Data, 1, self);		// 23582 use the new description method instead

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(User), DC_Label, 1, self);
	block.addNewItem(self.userId, DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Status), DC_Label, 1, self);
	block.addNewItem(self.statusDescription, DC_Data, 1, self);

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getPropertyCol" id="738eaa6e-c67c-4da8-8326-3c5424d7f6d0">
        <source>getPropertyCol(): String;
//----------------------------------------------
//Created: 9 October 2001 By: cnwgd1
//----------------------------------------------
vars
    str	: String;
	dpl : Integer;
begin
	dpl := self.getRateEntryDecimalPlaces; // TFS 36954 MPD 20 Feb 2018
	str := sequenceNum.String &amp; Tab;	
	if (not self.isDeleted) then
		if self.previousCost &lt;&gt; self.newCost then
			//str := str &amp; "Rate " &amp; self.previousCost.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, true) &amp; " =&gt; " &amp; 
				//self.newCost.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, false) &amp; Tab;
			// TFS 36954 MPD 20 Feb 2018
			str := str &amp; "Rate " &amp; self.previousCost.asStringJMTWithPrecision(dpl, true) &amp; " =&gt; " &amp; 
				self.newCost.asStringJMTWithPrecision(dpl, false) &amp; Tab;
			if self.previousStartTime &lt;&gt; self.newStartTime then
				str := str &amp; "Start Time " &amp; self.previousStartTime.date.shortFormatJMT() &amp; " " &amp; 
					self.previousStartTime.time.currentLocaleFormatJMT() &amp; " =&gt; " &amp; 
					self.newStartTime.date.shortFormatJMT() &amp; " " &amp; 
					self.newStartTime.time.currentLocaleFormatJMT() &amp; Tab;
			else
				str := str &amp; "No change to Start Time." &amp; Tab;
			endif;
		else
			if self.previousStartTime &lt;&gt; self.newStartTime then
				str := str &amp; "No Change to cost/unit." &amp; Tab &amp;
					"Start Time " &amp; self.previousStartTime.date.shortFormatJMT() &amp; " " &amp; 
					self.previousStartTime.time.currentLocaleFormatJMT() &amp; " =&gt; " &amp; 
					self.newStartTime.date.shortFormatJMT() &amp; " " &amp; 
					self.newStartTime.time.currentLocaleFormatJMT() &amp; Tab;
			endif;
		endif;
	else
		//str := str &amp; "DELETED. Unit cost was " &amp; self.previousCost.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, true) &amp; Tab &amp;
		// TFS 36954 MPD 20 Feb 2018
		str := str &amp; "DELETED. Unit cost was " &amp; self.previousCost.asStringJMTWithPrecision(dpl, true) &amp; Tab &amp;
			"Start Time was " &amp; self.previousStartTime.date.shortFormatJMT() &amp; " " &amp;
			self.previousStartTime.time.currentLocaleFormatJMT() &amp; Tab;
	endif;
	
	str := str &amp; self.userId &amp; Tab &amp;
		self.dateTime.date.shortFormatJMT() &amp; " " &amp; 
		self.dateTime.time.currentLocaleFormatJMT();	
		
	return str;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRateEntryObject" id="3c92a8f6-1247-4874-9536-8c8988182515">
        <source>getRateEntryObject(_qual : Boolean) : CM_RateEntry;
// ---------------------------------------------------------------------------
// Created:		16 June 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aRate : CM_Rate;
	aRE : CM_RateEntry;
begin
	if global.isValidObject(self.myRateEntry) then // only added in 742 release (2006July), so prior to that is null.
		return self.myRateEntry;
	endif;
	
	
	if _qual then
		aRate := self.auditedFOs.first.CM_Rate;
	else
		aRate := self.unauditedFOs.first.CM_Rate;
	endif;
	
	foreach aRE in aRate.rateEntries discreteLock do
		if aRE.getRawCostPerUnit = self.newCost 
		and aRE.startTimestamp = self.newStartTime then
			return aRE;
		endif;
	endforeach;
	foreach aRE in aRate.rateEntries discreteLock do
		if aRE.getRawCostPerUnit = self.newCost then
			return aRE;
		endif;
	endforeach;
	
	return null;
end;</source>
        <Parameter name="_qual" type="Boolean"/>
        <ReturnType type="CM_RateEntry"/>
    </JadeMethod>
    <JadeMethod name="statusDescription" id="2e981ea2-ac97-4222-b795-90462cd7e0c1">
        <methodInvocation>mapping</methodInvocation>
        <source>statusDescription(set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:		11 July 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if set then
		// set code here
	else
		// get code here
		
		if self.status = self.Status_Create then
			_value :=  "Created";
		elseif self.status = self.Status_Update then
			_value :=  "Updated";
		elseif self.status = self.Status_Delete then
			_value :=  "Deleted";
		else
			_value :=  "";
		endif;
	endif;


end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
</Class>
