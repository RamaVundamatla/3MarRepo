    <JadeMethod name="setArchivedDTForConversion" id="537fd9fd-ffbd-4134-91e4-1302e83197ff">
        <updating/>
        <source>setArchivedDTForConversion(theTime : TimeStamp) updating;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 25 August 2004
//
// Only used during conversion fix up for voyages that should have been 
// archived against their delete transcation.  This was missed during the 
// earlier conversion so changing the status of archive to true and doing
// a retrospective timestamp.
// Not ideal but........
//
//********************************************************************
vars

begin
	self.archivedDT := theTime;
	self.archive(null, app.myPassport);
end;</source>
        <Parameter name="theTime" type="TimeStamp"/>
