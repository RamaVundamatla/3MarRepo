    <JadeMethod name="clearContainerOnlyValues" id="6e83f034-1e17-4124-9703-0ac2addd83df">
        <source>clearContainerOnlyValues( _container_temp : CM_EDIPrenoteTI io ) protected;

/*

Purpose:		This method will reset the field values that are only applicable to each container.
				ie for each SGP or EQD the following records apply to that container only eg temperature.
				This is the fields on the record types:
				DGS
				DIM
				EQD
				MEA
				SEL
				TMP

Date				Who		Reason
30 April 2009		cnwrl1	Initial creation as part of PAR 19510 - CCMS 1812
// 07 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
*/
	
vars
	
begin
//	if _container_temp.id = containerId then	// cnwrl1 22/07/2009 PAR 20319 - what it was
	if self.containerId &lt;&gt; null and self.containerId = _container_temp.id then
		return;
	endif;
	
	_container_temp.setId(self.containerId[1:CM_TrackedItem::id.getLengthForString]);
	_container_temp.length			:= null;
	_container_temp.width			:= null;
	_container_temp.height			:= null;
	_container_temp.volume			:= null;
	_container_temp.setHumidity( NULL_HUMIDITY );
	_container_temp.vent			:= NULL_VENTILATION;
	_container_temp.setOxygen( NULL_OXYGEN );
	_container_temp.setCarbonDioxide( NULL_CARBON_DIOXIDE );
	_container_temp.statusString	:= null;
	_container_temp.fullOrMT		:= null;
	_container_temp.transportMode	:= null;
	_container_temp.wagonNumber		:= null;
	_container_temp.wagonClass		:= null; //13 May 2014	NDL	Par 33615
	_container_temp.vehicle			:= null;
	_container_temp.sealNum			:= null;
	_container_temp.customsSeal		:= null;
	_container_temp.sealShipper		:= null;
	_container_temp.sealTerminalOperator := null;
	_container_temp.sealUnknown := null;
	_container_temp.temperature		:= NULL_TEMPERATURE;
	
	_container_temp.imCodes.clear;
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_container_temp" type="CM_EDIPrenoteTI" usage="io"/>
    </JadeMethod>
    <JadeMethod name="copyDetailsToPrenoteTI" id="b32e53fc-b525-4289-b466-55d198e94105">
        <source>copyDetailsToPrenoteTI(
	_container_temp			: CM_EDIPrenoteTI input;
	_container_EDIPrenoteTI	: CM_EDIPrenoteTI input;
	_tiCargoType			: Integer ) protected;

/*

Purpose:		To copy the transient details from _container_temp to the persistent _container_EDIPrenoteTI
Parameters:		
Return Value:	

Date				Who		Reason
27 April 2009		cnwrl1	Initial creation as part of PAR 19510 - CCMS 1812
//01 Dec 2016	cnwrs1	TFS 2987 if no cooling type check with container Range
// 07 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
*/
	
vars
	cm_ConsigneeConsignor	: CM_ConsigneeConsignor;
	
begin
	// cnwrl1 08/07/2009 PAR 20239 - what it was
	/* Zero is a valid temperature
	if _container_temp.temperature = null then
		// should already been done via self.clearContainerOnlyValues but just in case.
		_container_temp.temperature	:= NULL_TEMPERATURE;
	endif;
	*/
	
	_container_temp.setId(self.containerId[1:CM_TrackedItem::id.getLengthForString]);
	
	_container_EDIPrenoteTI.bol						:= _container_temp.bol;
	_container_EDIPrenoteTI.bookingRef				:= _container_temp.bookingRef;
	_container_EDIPrenoteTI.setCarbonDioxide( _container_temp.getCarbonDioxide );
	_container_EDIPrenoteTI.carrierCode				:= _container_temp.carrierCode;
	_container_EDIPrenoteTI.commodity				:= _container_temp.commodity;
	_container_EDIPrenoteTI.commodityDescription	:= _container_temp.commodityDescription;
	_container_EDIPrenoteTI.consignee				:= _container_temp.consignee;
	_container_EDIPrenoteTI.consignor				:= _container_temp.consignor;
	_container_EDIPrenoteTI.coolingType := _container_temp.coolingType;
	_container_EDIPrenoteTI.customsReference		:= _container_temp.customsReference;	// cnwrl1 09/12/2009 PAR 21907
	_container_EDIPrenoteTI.customsSeal				:= _container_temp.customsSeal;
	_container_EDIPrenoteTI.setDescription( _container_temp.description );	// cnwrl1 14/07/2009 PAR 20247 - CCMS 1859
	_container_EDIPrenoteTI.destinationPort			:= _container_temp.destinationPort;
	_container_EDIPrenoteTI.dischargePort			:= _container_temp.dischargePort;
	_container_EDIPrenoteTI.freightForwarder		:= _container_temp.freightForwarder;
	_container_EDIPrenoteTI.fullOrMT				:= _container_temp.fullOrMT;
	_container_EDIPrenoteTI.height					:= _container_temp.height;
	_container_EDIPrenoteTI.setHumidity( _container_temp.getHumidity );
	_container_EDIPrenoteTI.setId(_container_temp.id);
	_container_EDIPrenoteTI.imexStatus				:= _container_temp.imexStatus;
	_container_EDIPrenoteTI.isoType					:= _container_temp.isoType;
	_container_EDIPrenoteTI.length					:= _container_temp.length;
	_container_EDIPrenoteTI.loadPort				:= _container_temp.loadPort;
	_container_EDIPrenoteTI.mark					:= _container_temp.mark;
	_container_EDIPrenoteTI.markNumber				:= _container_temp.markNumber;
	_container_EDIPrenoteTI.operatorCode			:= _container_temp.operatorCode;
	_container_EDIPrenoteTI.setOxygen( _container_temp.getOxygen );
	_container_EDIPrenoteTI.product					:= _container_temp.product;
	_container_EDIPrenoteTI.productQuantity			:= _container_temp.productQuantity;
	_container_EDIPrenoteTI.receiveDate				:= _container_temp.receiveDate;
	_container_EDIPrenoteTI.remarks					:= _container_temp.remarks;
	_container_EDIPrenoteTI.sealNum					:= _container_temp.sealNum;
	_container_EDIPrenoteTI.sealShipper				:= _container_temp.sealShipper;
	_container_EDIPrenoteTI.sealTerminalOperator := _container_temp.sealTerminalOperator;
	_container_EDIPrenoteTI.sealUnknown := _container_temp.sealUnknown;
	_container_EDIPrenoteTI.statusString			:= _container_temp.statusString;
	_container_EDIPrenoteTI.temperature				:= _container_temp.temperature;
	_container_EDIPrenoteTI.timeAllowedOffPower		:= _container_temp.timeAllowedOffPower;
	_container_EDIPrenoteTI.transportMode			:= _container_temp.transportMode;
	_container_EDIPrenoteTI.vesselName				:= _container_temp.vesselName;
	_container_EDIPrenoteTI.volume					:= _container_temp.volume;
//	_container_EDIPrenoteTI.voyageCode				:= _container_temp.voyageCode;	// cnwrl1 09/06/2010 PAR 24299 - what it was
	// make sure the manual collection on CM_EDIConfig gets maintained
	_container_EDIPrenoteTI.setVoyageCode( _container_temp.getVoyageCode() );
	_container_EDIPrenoteTI.wagonNumber				:= _container_temp.wagonNumber;
	_container_EDIPrenoteTI.wagonClass				:= _container_temp.wagonClass;	//13 May 2014	NDL	Par 33615
	_container_EDIPrenoteTI.weight					:= _container_temp.weight;
	_container_EDIPrenoteTI.width					:= _container_temp.width;
	
	_container_EDIPrenoteTI.setCargoType( _tiCargoType );
	_container_EDIPrenoteTI.imCodes.clear;
	_container_temp.imCodes.copy( _container_EDIPrenoteTI.imCodes );
	
	cm_ConsigneeConsignor	:= app.myRoot.allConsigneeConsignors[ _container_EDIPrenoteTI.consignor ];
	if cm_ConsigneeConsignor &lt;&gt; null then
		_container_temp.customExportEntryNumber			:= cm_ConsigneeConsignor.derogationNumber;
		_container_EDIPrenoteTI.customExportEntryNumber	:= cm_ConsigneeConsignor.derogationNumber;
	endif;
	
	_container_EDIPrenoteTI.setOperatorImportReleasePIN( _container_temp.getOperatorImportReleasePIN() ); //cnwgb1 PAR 21881 15.12.2009 
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_container_temp" type="CM_EDIPrenoteTI" usage="input"/>
        <Parameter name="_container_EDIPrenoteTI" type="CM_EDIPrenoteTI" usage="input"/>
        <Parameter name="_tiCargoType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="create" id="4d6895fb-e883-432c-ac2e-bbe1846c46a4">
        <updating/>
        <source>create() updating;

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
23 April 2009		cnwrl1	Initial creation as part of PAR 19510 - CCMS 1812

*/
	
vars
	
begin
	self.name	:= "IFTMIN - Container Prenotification";
	self.type	:= EDIFileType_IFTMIN;
	
epilog
	
end;
</source>
