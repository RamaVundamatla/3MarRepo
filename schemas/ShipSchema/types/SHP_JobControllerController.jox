begin
//	time:=app.actualTimeAppServer;
/*time:=self.voyageStartTime.addHours(2);
	time := time.addSeconds(37);
	theTime.setTime(8,40,0,0);
	time.setDate("1/2/2007".Date);
	time.setTime(theTime);*/
	return self.currentTime;//time;
epilog

end;</source>
