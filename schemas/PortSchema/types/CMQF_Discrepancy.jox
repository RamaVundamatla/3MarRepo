    <ImplicitInverseRef name="allIMEXStatusCodes" id="97720bfc-24ba-4ae1-b5fe-4134943991bc">
        <memberTypeInverse/>
        <type name="CM_IMEXStatusByCodeDict"/>
    </ImplicitInverseRef>
