	//return tmpStr.asOid.CM_Train;				//12.08.2022 navtnr20 52451
	return app.myPassport.getObjectOfTypeFromOid(tmpStr,CM_Train).CM_Train;		//12.08.2022 navtnr20 52451

epilog

end;</source>
        <ReturnType type="CM_Train"/>
    </JadeMethod>
    <JadeMethod name="getSelectedTransTypes" id="92127c0a-2f41-4a6f-ab4e-dbf9b53c3041">
        <source>getSelectedTransTypes( _transTypeArray : IntegerArray input );
// getSelectedTransTypeDescrs(_transTypeArray: StringArray input);	// cnwrl1 07/09/2009 PAR 20198 - what it was

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 September 2008	cnwkao1	Initial creation - based on WebSchema implementation

*/

vars
	str				: String;
	count			: Integer;
	stringArray		: StringArray;
	transactionType	: CM_TransactionType;
	reportParam		: WS_ReportParameter;
	
begin
	// get the report selection criteria
	reportParam := self.allWSReportParams.getAtKey(ETRow_TransactionType);
	if reportParam &lt;&gt; null then
		str := reportParam.value;
	endif;	
	
	/* cnwrl1 07/09/2009 PAR 20198 - what it was
	_transTypeArray.clear();
	if str.length &gt; 0 then
		str.getTokensForDelimiter("|", _transTypeArray);
	endif;
	cnwrl1 07/09/2009 PAR 20198 - end of what it was */
	
	_transTypeArray.clear();
	if str.length &lt;= null then
		return;
	endif;
	
	create stringArray transient;
	
	// break the report parameters up in to seperate strings
	str.getTokensForDelimiter( "|", stringArray );
	
	// now for each of these strings get the corresponding transaction type for this transaction description.
	foreach str in stringArray do : array_loop
		transactionType := app.myRoot.allTransactionTypesByDesc[ str ];
		if transactionType = null then
			continue array_loop;
		endif;
		_transTypeArray.add( transactionType.trxType );
	endforeach array_loop;
	
epilog
	delete stringArray;
	
end;</source>
        <Parameter name="_transTypeArray" type="IntegerArray" usage="input"/>
    </JadeMethod>
