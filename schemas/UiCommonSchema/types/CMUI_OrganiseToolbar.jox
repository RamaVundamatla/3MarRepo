    <JadeMethod name="setupForm" id="79661225-bb8d-4629-8ee4-a85f6b419ca8">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     21 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod();
	
	self.modalResult := IDCANCEL;
//	self.toolbarShowCaptions(app.myPassport.myUser.myMenuUserToolbarRoot.showCaption);

	self.toolbarStyle	:= self.ToolbarStyle_ShowNoHide;
	self.showToolbar	:= true;
	self.lstNotIncluded.hasTreeLines := false;
	self.lstNotIncluded.hasPlusMinus := false;
	self.lstIncluded.hasTreeLines := false;
	self.lstIncluded.hasPlusMinus := false;
	
	self.lstNotIncluded.defaultLineHeight := DefaultLineHeight;
	self.lstIncluded.defaultLineHeight := DefaultLineHeight;
	self.btnAddSep.caption := '     Add ' &amp; CrLf &amp; 'Separator -&gt;';

	self.lstIncluded.defaultLineHeight := 30; // ### TFS 50421 19OCT2021 NAVAB1
	self.lstIncluded.fontSize := 10; // ### TFS 50421 19OCT2021 NAVAB1
	self.lstNotIncluded.defaultLineHeight := 30; // ### TFS 50421 19OCT2021 NAVAB1
	self.lstNotIncluded.fontSize := 10; // ### TFS 50421 19OCT2021 NAVAB1
end;</source>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="6b787668-7344-40bc-8533-2be786022ecb">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Sep 2023	navhl20	ChangeRequest 59988: MTN - Add a filter to Customize toolbar Multi Selection

*/

vars

begin
	if eventTag = self.Timer_List_Filter then
		self.doFilterList();
	endif;
epilog

end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="35b5a251-c6af-4f5d-818a-48ac82d75e83">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 06 September 2023 11:35:46.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007923, locale);
	btnAdd.translateCaption(Xlat_0000587, locale);
	btnAddSep.translateCaption(Xlat_0000588, locale);
	btnRemove.translateCaption(Xlat_0000589, locale);
	btnclear.translateCaption(Xlat_0026442, locale);
	lblAvailable.translateCaption(Xlat_0000585, locale);
	lblSelected.translateCaption(Xlat_0000586, locale);
	mnuInspect.translateCaption(Xlat_0024552, locale);
	mnuMasterContext.translateCaption(Xlat_0007924, locale);
	mnuSelectPicture.translateCaption(Xlat_0007925, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="txtfilter_keyUp" id="d1480389-de4f-4542-a204-cb459ec552ee">
        <controlMethod name="TextBox::keyUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtfilter_keyUp(textbox: TextBox input; keyCode: Integer io; shift: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Sep 2023	navhl20	ChangeRequest 59988: MTN - Add a filter to Customize toolbar Multi Selection

*/

vars
	type,
	remaining		: Integer;
begin
	if self.getTimerStatus(self.Timer_List_Filter, type, remaining) then
		self.endTimer(self.Timer_List_Filter);
	endif;
	
	self.beginTimer(500, Timer_OneShot, self.Timer_List_Filter);
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
