    <JadeMethod name="setDrawStyleAndColors" id="0a43998e-2945-4f25-9346-b43eab4e540e">
        <updating/>
        <source>setDrawStyleAndColors(_obj : Object; _frame : SHP_BulkDrawingFrame input; _drawFillColor : Integer io;
		_outerColourUpper, _outerColourLower : Integer output) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	tmpDisplayMode : Integer;

begin
	tmpDisplayMode := self.displayMode;

	_frame.drawFillStyle := Frame.DrawFillStyle_Solid;
	_frame.drawStyle := Frame.DrawFillStyle_Solid;
	_frame.drawWidth := 1;

	if self.allSelectedObjects.includes(_obj) then
		_outerColourUpper := DarkGray;
		_outerColourLower := White;

		if (tmpDisplayMode = ShpDisplayMode_ColCodeDisch or
		   tmpDisplayMode = ShpDisplayMode_ColCodeLoad) and
		   self.allSelectedObjectsAlt.includes(_obj) then
			_drawFillColor := Red;
		else
			// ### AKB DIFFERENT SELECT
			_drawFillColor := Gray;
		endif;

	elseif self.allSelectedObjectsAlt.includes(_obj) then
		_outerColourUpper := DarkGray;
		_outerColourLower := White;
		_drawFillColor := DarkGray;

	else
		_outerColourLower := DarkGray;
		if tmpDisplayMode = ShpDisplayMode_Defn or self.amPrinting then
			_outerColourUpper := Gray;
		else
			_outerColourUpper := White;
		endif;
	endif;
	
	self.theDrawFillColor := _drawFillColor;
	_frame.drawFillColor := _drawFillColor;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_frame" type="SHP_BulkDrawingFrame" usage="input"/>
        <Parameter name="_drawFillColor" type="Integer" usage="io"/>
        <Parameter name="_outerColourUpper" type="Integer" usage="output"/>
        <Parameter name="_outerColourLower" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="setDrawingPositions" id="a23fbbfd-ac89-41e1-be22-97ec91cdd49d">
        <updating/>
        <source>setDrawingPositions() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
/*The drawing positions are:

          portPosOD                                starboardPosOD
yOnDeckPos     +------------------------------------------+
               |                                          |
               |               on deck holds              |
               |                                          |
               +------------------------------------------+

yDeckPos	   |-------------- hatch line ------------------|

          portPosUD                                starboardPosUD
yUnderDeckPos  +------------------------------------------+
               +-+                                      +-+
                 +-+          under deck holds        +-+
                   +-+                              +-+
yUnderDeckEndPos     +------------------------------+

*/
vars
	textHeight, topMargin : Integer;
	scaleFactor : Real;
	printStyle, hatchLidHeight : Integer;
	frame : SHP_BulkDrawingFrame;
	hold : CM_GeneralCargoController;
	form : SHP_BulkVoyagePlanningForm;

begin
	textHeight := 12;
	
	scaleFactor 	:= self.scaleFactor;
	printStyle 		:= self.printOutputStyle;
	hatchLidHeight	:= self.HatchLidHeight_Screen;
	
	form := self.myVoyagePlanningForm;
	self.holdWidth := form.frmMiddle.width.Integer;
	self.holdHeight := form.frmMiddle.height.Integer;

	self.getYDrawingPositions(textHeight, topMargin, self.yDeckPos, self.yOnDeckPos, self.yUnderDeckEndPos, self.yUnderDeckPos);

	if self.amPrinting then
		if printStyle = PrintOutput_Small then
			self.hasLabels := false;
		else
			self.hasLabels := true;
		endif;
		hatchLidHeight := HatchLidHeight_Print;
	elseif scaleFactor = ScaleFactor_1 then	
		self.hasLabels := false;
	else
		self.hasLabels := true;
	endif;

	self.topMargin := topMargin;
	
	if printStyle = PrintOutput_Small then
		// at this scale we don't print labels on sides
		self.sideDrawingMargin := self.SideMargin;
	elseif printStyle = PrintOutput_Medium then
		self.sideDrawingMargin := self.SideMargin + self.LabelCharacterWidth_X3;
	elseif scaleFactor = self.ScaleFactor_1 then
		// at this scale we don't print labels on sides
		self.sideDrawingMargin := self.SideMargin;
	else
		//self.sideDrawingMargin := self.SideMargin + self.LabelCharacterWidth_X3 + 6;
		//self.sideDrawingMargin := self.myVoyagePlanningForm.picStern.width.Integer;
		self.sideDrawingMargin := self.getSideDrawingMargin;
	endif;

	if self.displayMode = ShpDisplayMode_Defn or 
	   (scaleFactor = ScaleFactor_1) or
	   (self.amPrinting and printStyle &lt;= PrintOutput_Medium) then
		self.hasWeights := false;
	else
		self.hasWeights := true;
	endif;

	if self.amPrinting then
		if printStyle = self.PrintOutput_Small then
			self.xAxisLabelOffset := 0;
			self.yAxisLabelOffset := 0;
		elseif printStyle = self.PrintOutput_Medium then
			self.xAxisLabelOffset := 5;
			self.yAxisLabelOffset := 5;
		else
			self.xAxisLabelOffset := 15;
			self.yAxisLabelOffset := 10;
		endif;

	elseif scaleFactor = ScaleFactor_1 then
		self.xAxisLabelOffset := 0;
		self.yAxisLabelOffset := 0;
	elseif scaleFactor = ScaleFactor_1_5 then
		self.xAxisLabelOffset := 0;
		self.yAxisLabelOffset := 3;
	elseif scaleFactor = ScaleFactor_2 then
		self.xAxisLabelOffset := 5;
		self.yAxisLabelOffset := 6;
	elseif scaleFactor = ScaleFactor_3 then
		self.xAxisLabelOffset := 5;
		self.yAxisLabelOffset := 9;
	elseif scaleFactor = ScaleFactor_4 then
		self.xAxisLabelOffset := 10;
		self.yAxisLabelOffset := 12;
	elseif scaleFactor = ScaleFactor_6 then
		self.xAxisLabelOffset := 20;
		self.yAxisLabelOffset := 20;
	elseif scaleFactor = ScaleFactor_9 then
		self.xAxisLabelOffset := 35;
		self.yAxisLabelOffset := 40;
	endif;
	
	foreach frame in self.allBulkDrawingFramesById do
		frame.setDrawingPositions(self);
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setFontDefaults" id="86bcf947-6c63-4e42-952b-a0b767a03c9d">
        <updating/>
        <source>setFontDefaults() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	amPrinting : Boolean;
	myDisplayMode,
	myViewMode : Integer;
	factor : Real;
	theFontName : String;
	theFontSize : Real;
	printStyle : Integer;
	
begin
	amPrinting := self.amPrinting;
	
	// reset so that the first redraw with frame will set for new font size
	self.textExtent999 := 0;
	
	factor 	 		:= self.scaleFactor;
	myDisplayMode 	:= self.displayMode;
	myViewMode 	 	:= self.viewMode;
	printStyle		:= self.printOutputStyle;

	theFontName := Font_MicrosoftSansSerif;
	theFontSize := 8;
	
	self.defaultFontName := theFontName;
	self.defaultFontSize := theFontSize;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setFontSizeForAttribute" id="20ea6846-381d-4f45-8fd5-15c04f1bed36">
        <updating/>
        <source>setFontSizeForAttribute() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	theScale,
	theFontSize	: Real;
	printStyle	: Integer;

begin
	theScale := self.scaleFactor;
	printStyle := self.printOutputStyle;

	if self.amPrinting then
		if printStyle = self.PrintOutput_Small then
			theFontSize := 6;
		elseif printStyle = self.PrintOutput_Medium then
			theFontSize := 6;
		else
			theFontSize := 8;
		endif;

	elseif theScale = 1 or theScale = 1.5 then
		theFontSize := 8;

	elseif theScale = 2 then
		if self.displayMode = ShpDisplayMode_Actual 
		or self.displayMode = ShpDisplayMode_Ops then
			theFontSize := 7;
		else
			theFontSize := 12;
		endif;
	elseif theScale = 3 then
		if self.displayMode = ShpDisplayMode_Actual 
		or self.displayMode = ShpDisplayMode_Ops then
			theFontSize := 8;
		else
			theFontSize := 9;
		endif;
	elseif theScale = 4 then
		if self.displayMode = ShpDisplayMode_Actual 
		or self.displayMode = ShpDisplayMode_Ops then
			theFontSize := 10;
		else
			theFontSize := 10;
		endif;
	elseif theScale = 6 then
		if self.displayMode = ShpDisplayMode_Actual 
		or self.displayMode = ShpDisplayMode_Ops then
			theFontSize := 16;
		else
			theFontSize := 20;
		endif;
	elseif theScale = 9 then
		if self.displayMode = ShpDisplayMode_Actual 
		or self.displayMode = ShpDisplayMode_Ops then
			theFontSize := 20;
		else
			theFontSize := 24;
		endif;
	elseif theScale = 20 then
		if self.displayMode = ShpDisplayMode_Actual 
		or self.displayMode = ShpDisplayMode_Ops then
			theFontSize := 35;
		else
			theFontSize := 30;
		endif;
	endif;
	
	self.defaultFontSizeForAttributes := theFontSize;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setFromHold" id="d3063719-e12f-47f5-9c9b-125b5374fc03">
        <updating/>
        <source>setFromHold(_hold : CM_LocationsController; x1, y1, x2, y2 : Real) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	ti : CM_TrackedItem;
	numTIs, dispMode : Integer;
	export, import : Boolean;

begin
	if _hold = null then
		self.setToNULL();
		return;
	endif;

	self.x1	:= x1;
	self.y1	:= y1;
	self.x2	:= x2;
	self.y2	:= y2;

	self.myHold := _hold;

	// attributes from the slotDefn
	if self.displayMode = ShpDisplayMode_Defn then
		self.myCurrentObject := _hold;
		return;
	endif;
	
	dispMode := self.displayMode;
	
	self.myLocationsController := _hold;
	self.myCurrentObject := _hold;
	
	// we get all the trackeditems as we then use these to calculate the weight
	self.allTrackedItems.clear;

	if dispMode = ShpDisplayMode_Actual or dispMode = ShpDisplayMode_ColCodeDisch then
		_hold.allTrackedItems.copy(self.allTrackedItems);
		ti := self.allTrackedItems.first;
		if ti &lt;&gt; null then
			self.myTrackedItem := ti;
			numTIs := self.allTrackedItems.size;
			export := (ti.isExport or ti.isTranshipOutbound or ti.isRehandle or ti.isSOB);
			import := ti.isImport or ti.isTranshipInbound;
		else
			self.myTrackedItem := null;
		endif;
			
	//elseif dispMode = ShpDisplayMode_EDI then
	//	tmpTI := tmpSlot.getTheEDITrackedItemsForIndex(self.currentEDIIndex);
	//	if tmpTI &lt;&gt; null then
	//		self.allTrackedItems.add(tmpTI);
	//		self.myTrackedItem := tmpTI;
	//		tmpNumTIs := 1;
	//		//tmpIsExport := (tmpTI.isExport or tmpTI.isRehandle or tmpTI.isSOB);							// PAR #25021
	//		tmpIsExport := (tmpTI.isExport or tmpTI.isTranshipOutbound or tmpTI.isRehandle or tmpTI.isSOB);	// PAR #25021
	//		//tmpIsImport := tmpTI.isImport;																// PAR #25021
	//		tmpIsImport := tmpTI.isImport or tmpTI.isTranshipInbound;										// PAR #25021
	//	else
	//		self.myTrackedItem := null;
	//	endif;

	elseif dispMode = ShpDisplayMode_ColCodeLoad then
		// getAllPlannedTrackedItems clears the self.allTrackedItems array
		_hold.getAllPlannedTrackedItems(self.allTrackedItems, true, false);
		ti := self.allTrackedItems.first;
		if ti &lt;&gt; null then
			self.myTrackedItem := ti;
			numTIs := self.allTrackedItems.size;
			export := (ti.isExport or ti.isTranshipOutbound or ti.isRehandle or ti.isSOB);
			import := ti.isImport or ti.isTranshipInbound;
		else
			// for load if there is no load ti's we return the actual
			_hold.allTrackedItems.copy(self.allTrackedItems);
			ti := self.allTrackedItems.first;
			if ti &lt;&gt; null then
				self.myTrackedItem := ti;
				// leave numTIs here as 0 as we only want to count planned
				export := (ti.isExport or ti.isTranshipOutbound or ti.isRehandle or ti.isSOB);
				import := ti.isImport or ti.isTranshipInbound;
			else
				self.myTrackedItem := null;
			endif;
		endif;

	elseif dispMode = ShpDisplayMode_Proposed then
		_hold.getProposedTIs(self.allTrackedItems);
		ti := self.allTrackedItems.first;
		if ti &lt;&gt; null then
			self.myTrackedItem := ti;
			numTIs := self.allTrackedItems.size;
			export := (ti.isExport or ti.isTranshipOutbound or ti.isRehandle or ti.isSOB);
			import := ti.isImport or ti.isTranshipInbound;
		else
			self.myTrackedItem := null;
		endif;
		
	endif;

	self.tiInfoNumTI := numTIs;
	self.isExport	 := export;
	self.isImport	 := import;
epilog

end;</source>
        <Parameter name="_hold" type="CM_LocationsController"/>
        <Parameter name="x1" type="Real"/>
        <Parameter name="y1" type="Real"/>
        <Parameter name="x2" type="Real"/>
        <Parameter name="y2" type="Real"/>
    </JadeMethod>
