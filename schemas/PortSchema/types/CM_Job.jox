/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2023	navhl20	ChangeRequest 58543: EUP - Delivery Dispatch – Allocation List - VAS

*/

vars
	vvr	: CM_VehicleVisitRecord;
begin
	if self.isRoadJob then
		vvr := self.CM_RoadJob.myVehicleVisit;
		if vvr &lt;&gt; null and vvr.myBarrierCodeIn &lt;&gt; null then
			return vvr.myBarrierCodeIn.barrierDT.asStringJMT; 
		endif;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
