    <JadeMethod name="trxSetEDIDataStatus" id="784a7b39-c06a-4f39-93a7-2cb579935655">
        <updating/>
        <source>trxSetEDIDataStatus(_realEdiData: CM_EDIData; _newStatus: Integer) updating;
//----------------------------------------------------------------
//	Created:	11 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//
//	Don't touch app.myPassport in this transaction - need to maintain errors on passport while updating edi status
//
//20 Mar 2015	cnwrs1	Par 35827 - for error 88612 set the status to skip processing
//30 Nov 2022 	navma1  ChangeRequest 52499: MTN - Improve the performance of the Edi file verification process.
//14 May 2025 naviv1    MTN-19104 - MTN - Transport Manifest Handling of locking in EDI Operations
vars
	hadDeadLock : Boolean;
	newStatus : Integer;
	gotLockException : Boolean;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(app.myPassport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, app.myPassport);	
	//MTN-19104 --Added silent deadlock retry
	on LockException do agtPassportSilLckExHandlerFlg(exception, 0, gotLockException, app.myPassport); 
	on DeadlockException do agtPassportSilDLckExHandlerFlg(exception, hadDeadLock, app.myPassport);		 	

	// Set up the deadlock reply values
	app.myPassport.setupForDeadlockReplay(-200, 300 + app.random(300)); 
	app.myPassport.silentDeadlockLimit := 5;	

	newStatus := _newStatus;
	
	
	beginTransaction;
	
	while true do
		app.myPassport.clearErrorsWarnings();
		
		app.myUtilityUA.utlSetEDIDataStatus(_realEdiData, newStatus, null);
		
		if gotLockException then
			newStatus := CM_EDIFile.EDI_STATUS_LOCKERROR;
			continue;
		endif;
		
		if hadDeadLock then
			newStatus := CM_EDIFile.EDI_STATUS_LOCKERROR;
			if app.myPassport.silentDeadlockRetryCount &gt; app.myPassport.silentDeadlockLimit then
				break;
			else
				hadDeadLock := false;				
				app.myPassport.silentDeadlockRetryCount := app.myPassport.silentDeadlockRetryCount + 1;
				process.sleep(app.myPassport.silentDeadlockSleepTime);
				continue;
			endif;
		endif;
		break;
	endwhile;
	
epilog
	app.myPassport.resetSilentDeadlockHandler;				
	self.finaliseActivityWithPassport(app.myPassport);
end;</source>
        <Parameter name="_realEdiData" type="CM_EDIData"/>
        <Parameter name="_newStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="trxSetEDIDataStatusAfterVerify" id="09052547-76c9-4207-b4f4-b9b162f067dd">
        <updating/>
        <source>trxSetEDIDataStatusAfterVerify(_realEdiData: CM_EDIData input; _newStatus : Integer) updating;
//
// par 27392 cnwrs1 14 Apr 2011
//
//20 Mar 2015	cnwrs1	Par 35827 - for error 88612 set the status to skip processing
vars
	ediFile : CM_EDIFile;
begin
	app.setContinueCMExceptions(true);
	ediFile := _realEdiData.myEDIFile; 
	if _realEdiData.status = _newStatus then 
		if ediFile &lt;&gt; null then
			if ediFile.fileStatus = _newStatus then
//				return;
			endif;
		else
//			return;
		endif;
	endif;	
	beginTransaction;
	app.myUtilityUA.utlSetEDIDataStatusAfterVerify(_realEdiData, _newStatus);
	app.cmsCommitTransaction(null);
epilog
	//should have committed by now - must be a problem
	if process.isInTransactionState then
		app.cmsAbortTransaction;
	endif;
end;
</source>
        <Parameter name="_realEdiData" type="CM_EDIData" usage="input"/>
        <Parameter name="_newStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="trxSetEDIShipMfStatusAftrVerfy" id="d53b915f-f401-4c09-887f-ff9659fd9e8f">
        <updating/>
        <source>trxSetEDIShipMfStatusAftrVerfy(_ediData :CM_EDIDataShipManifest input; _newStatus : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Aug 2019	jlgns1	Initial creation
01 Aug2019 	JLGNS1	Bug 45797: PEN - Ship Manifest Upload errors
30 Nov 2022 navma1 ChangeRequest 52499: MTN - Improve the performance of the Edi file verification process.
*/
vars
	
	ediTI	 : CM_EDITrackedItem;
	terminal : CM_Terminal;
begin
	app.setContinueCMExceptions(true);
	
	terminal := _ediData.ediConfig.myTerminal;														//30.11.2022 navma1 #52499
	
	beginTransaction;
	
	app.myUtilityUA.utlSetEDIDataStatusAfterVerify(_ediData, _newStatus);
	
	foreach ediTI in _ediData.allEDITrackedItems do
		
		app.myUtilityUA.utlUpdateEDITIStatus(ediTI, _newStatus, null);
		
		//terminal := ediTI.getMyTerminal();															//30.11.2022 navma1 #52499
		
		if terminal &lt;&gt; null then
			//terminal.causeEvent(terminal.getTerminalEvent(EVENT_EDI_EDITI_UPDATE), false, ediTI);		//30.11.2022 navma1 #52499
			terminal.causeEvent(terminal.getTerminalEvent(EVENT_EDI_EDITI_VERIFY), false, ediTI);		//30.11.2022 navma1 #52499
		endif;
	endforeach;
		
	app.cmsCommitTransaction(null);
epilog
	//should have committed by now - must be a problem
	if process.isInTransactionState then
		app.cmsAbortTransaction;
	endif;
end;
</source>
        <Parameter name="_ediData" type="CM_EDIDataShipManifest" usage="input"/>
        <Parameter name="_newStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="trxSetReleaseRequestsStatus" id="4f2d9556-68c5-4a9e-9458-cc9bb19bcced">
        <updating/>
        <source>trxSetReleaseRequestsStatus(
	_status				: Integer;
	_allReleaseRequests	: CM_BulkReleaseSet;
	_passportObj		: CM_Passport input ) updating;

/*
Purpose:		Sets the status of all Release Requests in the specified set to the specified Status.

Date				Who		Reason
24 July 2009		cnwrl1	Initial creation as part of CCMS 1827 - PAR 20349 - Archive Empty Release Requests
*/
	
vars
	
begin
	// Always initialize the activity first.
	self.initialiseActivityWithPassport( _passportObj, method );
	
	// Arm our base exception handlers.
	on Exception do agtPassportExHandler( exception, _passportObj );
	on LockException do agtPassportLockExHandler( exception, _passportObj );
	
	app.setContinueCMExceptions( false );
	_passportObj.useTIDictDeferUpdate 		 := true;
	_passportObj.useTITransactionDeferUpdate := true;
	_passportObj.useEventDeferUpdate 		 := true;
	
	beginTransaction;
	
	app.myUtilityUA.utlSetReleaseRequestsStatus( _status, _allReleaseRequests, _passportObj );
	
	if _passportObj.noErrors then
		_passportObj.doDeferredUpdates();
	endif;
	
epilog
	self.finaliseActivityWithPassport( _passportObj );
end;
</source>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_allReleaseRequests" type="CM_BulkReleaseSet"/>
        <Parameter name="_passportObj" type="CM_Passport" usage="input"/>
    </JadeMethod>
