    <JadeMethod name="isReleaseEmptiesAllowed" id="16fec5de-b28a-498a-b877-4a267a53b603">
        <source>isReleaseEmptiesAllowed() : Boolean;
/* ---------------------------------------------------------------------------
Created:	19 February 2010	by cnwvu1

Purpose:	PAR 21656
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	br	: CM_BulkRelease;
	
begin

	br := self.allReleaseRequests.first;
	
	if br &lt;&gt; null then
		if br.type = BR_TYPE_PACKING and not self.myTerminal.getConfig(PackingRelAsInternalRel).Boolean then	// PAR 21656 19/02/2010. Packing release (Nelson Warehousing) has nothing to do with release empties out in Bookings screen. // cnwrd1 ccms pol 2103 par 27856 14.7.2011
			return false;
		endif;
	endif;
	
	return true;

end;</source>
