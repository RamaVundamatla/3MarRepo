    <JadeMethod name="getDebtor" id="eb0255e2-5bb4-4689-82c0-14977761959a">
        <source>getDebtor(): CM_Debtor;
// ---------------------------------------------------------------------------
// Created:     20 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	debtor : CM_Debtor;
begin

	if self.myCarrier &lt;&gt; null then
		debtor :=  self.myCarrier.myDebtor;
	endif;
	
	if debtor = null then
		
		if self.myTrainInwards = null then
			return null;
		endif;
		
		return self.myTrainInwards.getDebtor();
	else
		return debtor;
	endif;
epilog

end;</source>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="getDestPortCode" id="41828d49-b04e-4e26-a668-b66740a15c59">
        <source>getDestPortCode():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 November 2022	navhl20	ChangeRequest 54281: EUP - Wagon Track Planning
02-May-2023 navtnr20	Bug 57780: EUP -FR 53740 | Wagon Track Planning - Multiple Values
*/

vars
	ti : CM_TrackedItem;
	cont : CM_WagonController;
	data : String;
begin
	foreach cont in self.allLocationsControllers do
		foreach ti in cont.allTrackedItems do
			//return ti.destinationPort;				// start navtnr20 02-05-2023 Bug : 57780
			if ti.destinationPort &lt;&gt; null then
				/*
				if data.pos(ti.destinationPort,1) = 0 then
					if data = null then
						data := ti.destinationPort;
					else
						data := data &amp; ", " &amp; ti.destinationPort;
					endif; // End navtnr20 02-05-2023 Bug : 57780
				endif;
				*/
				
				data.addStringToList(ti.destinationPort, ", "); //04/04/2025	navkc1 JIRA Story MTN-33940
				
			endif;
		endforeach;
	endforeach;
	return data;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDestPortDesc" id="b3e58629-0f29-44cd-a71b-539768bb7d63">
        <source>getDestPortDesc():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 November 2022	navhl20	ChangeRequest 54281: EUP - Wagon Track Planning
02-May-2023 navtnr20	Bug 57780: EUP -FR 53740 | Wagon Track Planning - Multiple Values
*/

vars
	ti : CM_TrackedItem;
	cont : CM_WagonController;
	data : String;
	desc : String;
begin
	foreach cont in self.allLocationsControllers do
		foreach ti in cont.allTrackedItems do
			//return ti.getDestinationPortDescription;	// Start navtnr20 02-05-2023 Bug : 57780
			desc := ti.getDestinationPortDescription();
			if desc &lt;&gt; null then
				/*
				if data.pos(desc,1) = 0 then
					if data = null then
						data := desc;
					else
						data := data &amp; ", " &amp; desc;
					endif;
				endif;		// End navtnr20 02-05-2023 Bug : 57780
				*/
				
				data.addStringToList(desc, ", "); //04/04/2025	navkc1 JIRA Story MTN-33940
			endif;
		endforeach;
	endforeach;
	return data;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDestinationTerminalDesc" id="2d9c74ac-314a-4621-9c9a-74406e27049d">
        <source>getDestinationTerminalDesc() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 January 2018	jlgns1	Initial creation
9/01/2018 JLGNS1 Bug 36407: Wagon Enquiry Issues
*/

vars

begin
	if self.myDestinationTerminal = null then
		return null;
	endif;
	
	return self.myDestinationTerminal.code &amp; ' ' &amp; self.myDestinationTerminal.name;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="7810987a-f6fd-4ee3-a791-247bacf01005">
        <source>getDisplayDetails(_short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 July 2009	cnwndl1	Initial creation

*/

vars
	train : CM_Train;
	trainDesc : String;
begin

	if _short then
		return self.id;
	else
		if self.myTrainInwards &lt;&gt; null then
			train := self.myTrainInwards;
		else
			train := self.myTrainOutwards;
		endif;
		
		if train &lt;&gt; null then
			trainDesc := " " &amp; " (" &amp; app.getErrorString(Train) &amp; " '" &amp; train.code &amp; "')";
		endif;
		
		return self.id &amp; trainDesc;
	endif;
	
	return inheritMethod(_short);

epilog

end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="132670e6-a347-410a-b8c0-eb55be7e4775">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------------------
//Created: 17 March 2003 By: cnwgd1
//02 Oct 2020 cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
//09 Aug 2022 navsj20 ChangeRequest 54281: EUP - Wagon Track Planning
//18 Aug 2022 navhl20 ChangeRequest 54281: EUP - Wagon Track Planning
//02 May 2023 navmk20 Bug 57779: EUP -FR 53740 | Wagon Track Planning - Release Info
//27 Sep 2023 navkc1  CR 60428 Task 60701: UI - Customs Status on Transport UI
//07 Oct 2024 navsp1  JIRA 20762 EUP | General Testing - Search on Client Ref on User Screens
//--------------------------------------------------------------
vars
	tmpStr 			 : String;
	tiArray 		 : CM_TIArray;
	consign			 : CM_ConsigneeConsignor;
	ti				 : CM_TrackedItem; 		//09 Aug 2022	navsj20	TFS 54281
	wagonTotalWeight : Decimal[12,4];
begin
	
	if _attrName = ETRow_RailRake or 
		_attrName = ETRow_RailArea or
		_attrName = ETRow_SourceLocationId or
		_attrName = ETRow_WleCount then
		if self.myRailLine &lt;&gt; null then
			if _attrName = ETRow_RailRake or 
			   _attrName = ETRow_RailArea then
				return self.myRailLine.getFullId();
			else
				return self.myRailLine.getDisplayStringForAttribute(_attrName, _short);
			endif;			
		else
			return null;
		endif;
	elseif _attrName = ETRow_TrainPosition  then
		return self.getMyPositionTrainInwards().String;
	elseif _attrName = ETRow_TrainPositionOut  then
		return self.getMyPositionTrainOutwards().String;	//06 Oct 2009	NDL Par 20834
	elseif _attrName = ETRow_HasDeparted  then
		if (self.myTerminalDeparted &lt;&gt; null) then
			return $CNEC_LIT_YES;
		else
			return null;
		endif;
	elseif _attrName = ETRow_Intransit then
		if self.isInTransit() then
			return $CNEC_LIT_YES;
		else
			return null;
		endif;
		
	elseif _attrName = ETRow_HasDamaged then
	/* // ### TFS BUG 58868 27JUN2023 NAVAB1
		if not self.allDamageInstanceByPos.isEmpty() then
			return $CNEC_LIT_YES;
		else
			return null;
		endif;
		*/
		return (not self.allDamageInstanceByPos.isEmpty() ).getYes();
	elseif _attrName = ETRow_Train then
		if self.myTrainInwards &lt;&gt; null then
			return self.myTrainInwards.code;
		else
			return null;
		endif;
	elseif _attrName = ETRow_TrainOut then	//06 Oct 2009	NDL	 Par 20834
		if self.myTrainOutwards &lt;&gt; null then
			return self.myTrainOutwards.code;
		else
			return null;
		endif;
	elseif _attrName = ETRow_RailLine then
		if self.myRailLine &lt;&gt; null then
			return self.myRailLine.getFullId();
		else
			return null;
		endif;
	elseif _attrName = ETRow_WagonPos or
	   _attrName = ETRow_Position then
		return self.getWagonPosition().String;
	elseif _attrName = ETRow_IsConfirmedIN then
		if self.confirmed then
			return $CNEC_LIT_YES;
		else
			return null;
		endif;
		
	elseif _attrName = ETRow_Destination then
		return self.getCCDestination();
	elseif _attrName = ETRow_FreightForward then
		return self.getCCFreightForwarder();
	elseif _attrName = ETRow_ReleaseNo then
		return self.getCCReleaseNo();
		
	elseif _attrName = ETRow_WagonNumber then
		return self.id.String;
	elseif _attrName = ETRow_WagonType then
		if self.myWagonClass &lt;&gt; null then
			return self.myWagonClass.code;
		else
			return null;
		endif;
	elseif _attrName = ETRow_IsConfirmedOUT then
		if self.confirmedOutwards then
			return $CNEC_LIT_YES;
		else
			return null;
		endif;
		
	elseif _attrName = ETRow_Consignee then //+ 20/05/2009, cnwmd1, CCMS 1067, Par 19710
		//TFS#53362 navsp1 20Jun2022
		if app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean then  
			consign := app.myRoot.allConsigneeConsignors[self.getCCConsignee];
			if consign &lt;&gt; null then
				return consign.description;
			endif;
		endif;
		return self.getCCConsignee;
	elseif (_attrName = ETRow_TrainTSArriveActual  
			or _attrName = ETRow_TrainTSArriveSchedule 
			or _attrName = ETRow_TrainTSDepartureActual  
			or _attrName = ETRow_TrainTSDepartureSchedule)  then
		if self.myTrainInwards = null then
			return null;
		endif;
		return self.myTrainInwards.getDisplayStringForAttribute(_attrName, false);
	elseif _attrName = ETRow_MaxCargoWeight then
		return self.getMaxCargoWeight.asStringMeasurementJMT; //Par 21924
	
	elseif _attrName = ETRow_MaxCargoHeight then
		return self.getMaxCargoHeight.asStringMeasurementJMT; //Par 21924
	
	elseif _attrName = ETRow_TareWeight then
		return getWagonTareWeight.asStringMeasurementJMT;	//07 Oct 2009	NDL Par 20908
	elseif _attrName = ETRow_IsDamaged then			//+cnwml2 PAR26399 MSL CCMS 1105
		// ### TFS BUG 58868 27JUN2023 NAVAB1 return app.getYesNo(self.allDamageInstanceByPos.size &gt; 0);
		return self.getIsDamaged().getYes(); // ### TFS BUG 58868 27JUN2023 NAVAB1
		
	elseif _attrName = ETRow_WagonSeals then
		return self.listWagonSeals();
	
	elseif _attrName = ETRow_ReceiveStevedore then  //02.10.2020 cnwma1 TFS #50112   
		return self.getStevedoreCodeReceive();
	elseif _attrName = ETRow_ReleaseStevedore then  //02.10.2020 cnwma1 TFS #50112   
		return self.getStevedoreCodeRelease();
		
	elseif _attrName = ETRow_NumCargoRec 
	or _attrName = ETRow_NumCargoRel
	or _attrName = ETRow_TotalCargoIn
	or _attrName = ETRow_TotalCargoIntransit
	or _attrName = ETRow_TotalCargoLoaded 
	or _attrName = ETRow_TotalCargoDischarged then
		return self.getCargoTotals(_attrName).String;
	// START 09 Aug 2022	navsj20	TFS 54281
	elseif _attrName = ETRow_WagonCarrier then		
		if self.myCarrier &lt;&gt; null then
			return self.myCarrier.description;
		endif;
		return null;
	elseif _attrName = ETRow_WagonElapsedTime then	
		if self.myTrainInwards = null then
			return null;
		endif;
		return self.myTrainInwards.getDisplayStringForAttribute(_attrName, false);
	elseif _attrName = ETRow_OperatorCode then
		return self.getOperatorCode();
	elseif _attrName = ETRow_CargoTypeDescr then
		return self.getCargoTypeDesc();
	elseif _attrName = ETRow_ProductDescription then
		return self.getProductDesc();
	elseif _attrName = ETRow_CargoSpecialStow then
		return self.getSpecialStow();
	elseif _attrName = ETRow_CargoDestCode then
		return self.getDestPortCode();
	elseif _attrName = ETRow_CargoDestDescr then
		return self.getDestPortDesc();
	elseif _attrName = ETRow_Commodity then
		return self.getCommodity();
	elseif _attrName = ETRow_CargoTotalWeight then
		return self.getCargoTotalWeight();
	elseif _attrName = ETRow_ReleaseOperator then
		return self.getReleaseOperator();
	elseif _attrName = ETRow_WagonPlannedLocation then
		//Start 18.8.2022 navhl20 TFS 54281
		if self.allPlannedFutureMoves.isNotEmpty then
			return self.getPlannedLocation();		
		endif;
		return null;
		//End 18.8.2022 navhl20 TFS 54281
	// END //09 Aug 2022	navsj20	TFS 54281
	// Start 2.5.2023 navmk20 TFS 57779
	elseif _attrName = ETRow_ReleaseCargoSubType then
		return self.getReleaseCargoSubType();
	elseif _attrName = ETRow_ReleaseCargoType then
		return self.getReleaseCargoType();
	elseif _attrName = ETRow_ReleaseCommodity then
		return self.getReleaseCommodityCode();
	elseif _attrName = ETRow_ReleaseCommodityDesc then
		return self.getReleaseCommodityDesc();
	elseif _attrName = ETRow_ReleaseCargoTypeCode then
		return self.getReleaseCargoTypeCode();
	elseif _attrName = ETRow_ReleaseCargoSubTypeCode then
		return self.getReleaseCargoSubTypeCode();
	elseif _attrName = ETRow_ReleaseOperatorCode then
		return self.getReleaseOperatorCode();
	// End 2.5.2023 navmk20 TFS 57779
	elseif _attrName = ETRow_OperatorDesc then	//navtnr20 04-05 -2023 bug 57780
		return self.getOperatorDesc();
	elseif _attrName = ETRow_ProductCode then	//navtnr20 04-05 -2023 bug 57780
		return self.getProductCode();
	elseif _attrName = ETRow_CargoTypeCode then	//navtnr20 04-05 -2023 bug 57780
		return self.getCargoTypeCode();
	elseif _attrName = ETRow_CustomStatus then
		return self.getCustomStatus(); //27/09/2023	navkc1	CR 60428 Task 60701
	elseif _attrName = ETRow_ClientRef then					//JIRA 20762
		return self.getClientRef(null, false);				//JIRA 20762
	endif;
	return inheritMethod(_attrName, _short);
	
epilog
	delete tiArray;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExistingDamageTrx" id="41da1bca-39a9-4eb7-84b4-e2c5cdede033">
        <source>getExistingDamageTrx(_damageInstance: CM_DamageInstance): CMEVT_WagonTransaction;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 June 2011	cnwndl1	Initial creation Par 27543

*/

vars

	trans : CMEVT_WagonTransaction;
	damageTrx : CMEVT_WagonTransaction;
	iter : Iterator;

begin

	iter := self.allTransactions.createIterator;
	while iter.next( trans ) do
		if trans.type = EVT_WagonDamaged then
			damageTrx := trans.CMEVT_WagonTransaction;
			if damageTrx.getDamageDescription &lt;&gt; _damageInstance.description then
				continue;
			endif;
			return damageTrx;
		endif;
	endwhile;

	return null;

epilog

	delete iter;

end;</source>
        <Parameter name="_damageInstance" type="CM_DamageInstance"/>
        <ReturnType type="CMEVT_WagonTransaction"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="83091d6d-59e4-4625-84be-621d4c6bb6da">
        <source>getExtraInfo(_dataContainer: CM_DataContainer) ;
/*
Date		Who		Reason
//9/01/2018 JLGNS1 Bug 36407: Wagon Enquiry Issues

*/
vars
	block : CM_DataContainerBlock;
	dam : CM_DamageInstance;
	lString : String;
	weightType : CM_MeasurementType;
	lengthType : CM_MeasurementType;
	measureString : String;
	lengthInCM : Decimal [16,4];
	cargoRestrict : CM_CargoRestrictionCriteria;
begin

	inheritMethod(_dataContainer);
	
	weightType := app.getDefaultMeasurementForType(Type_Weight);	//11 Sep 2013	NDL	Par 32172
	lengthType := app.getDefaultMeasurementForType(Type_Length);	//9/01/2018 JLGNS1 Bug 36407
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Transit_Rail).trimBlanks(), DC_Label, 1, self);	//9/01/2018 JLGNS1 Bug 36407
	block.addNewItem(self.isInTransit.cnEcGetYesNo(), DC_Data, 1, self);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Wagon_ID).trimBlanks(), DC_Label, 1, self);	//9/01/2018 JLGNS1 Bug 36407
	block.addNewItem(self.id, DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Confirmed).trimBlanks(), DC_Label, 1, self);	//9/01/2018 JLGNS1 Bug 36407
	block.addNewItem(self.confirmed.String.toUpper, DC_Data, 1, self);
	
	block := _dataContainer.addNewBlock;
	//block.addNewItem('Confirmed Outward', DC_Label, 1, self); //- cnwmd1, CCMS 1067, Par 19710
	block.addNewItem(app.getErrorString(Confirmed_outward).trimBlanks(), DC_Label, 1, self); //+ cnwmd1, CCMS 1067, Par 19710	//9/01/2018 JLGNS1 Bug 36407
	block.addNewItem(self.confirmedOutwards.String.toUpper, DC_Data, 1, self);
	
	block := _dataContainer.addNewBlock;
	//block.addNewItem('Train', DC_Label, 1, self); //- cnwmd1, CCMS 1067, Par 19710
	block.addNewItem(app.getErrorString(Inward_train).trimBlanks(), DC_Label, 1, self); //+ cnwmd1, CCMS 1067, Par 19710 		//9/01/2018 JLGNS1 Bug 36407
	block.addNewItem(self.getTrainDescr(), DC_Data, 1, self);
	
	
	block := _dataContainer.addNewBlock;																					 //9/01/2018 JLGNS1 Bug 36407
	block.addNewItem(app.getErrorString(Outward_train ).trimBlanks(), DC_Label, 1, self); //+ cnwmd1, CCMS 1067, Par 19710	 //9/01/2018 JLGNS1 Bug 36407
	block.addNewItem(self.getTrainDescrOut(), DC_Data, 1, self);															 //9/01/2018 JLGNS1 Bug 36407
	
	if self.myWagonClass &lt;&gt; null then													//9/01/2018 JLGNS1 Bug 36407
		lString := self.myWagonClass.code;												//9/01/2018 JLGNS1 Bug 36407
	else																				//9/01/2018 JLGNS1 Bug 36407
		lString := "";																	//9/01/2018 JLGNS1 Bug 36407
	endif;																				//9/01/2018 JLGNS1 Bug 36407
	block := _dataContainer.addNewBlock;											 	//9/01/2018 JLGNS1 Bug 36407
	block.addNewItem(app.getErrorString(Wagon_class ).trimBlanks(), DC_Label, 1, self);	//9/01/2018 JLGNS1 Bug 36407
	block.addNewItem(lString, DC_Data, 1, self);										//9/01/2018 JLGNS1 Bug 36407
																						//9/01/2018 JLGNS1 Bug 36407
	block := _dataContainer.addNewBlock;											 	//9/01/2018 JLGNS1 Bug 36407
	block.addNewItem(app.getErrorString(Carrier ).trimBlanks(), DC_Label, 1, self);	 	//9/01/2018 JLGNS1 Bug 36407
	block.addNewItem(self.getCarrierDescription() , DC_Data, 1, self);				 	//9/01/2018 JLGNS1 Bug 36407
		
	foreach dam in self.allDamageInstanceByPos discreteLock do
		
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Damage).trimBlanks(), DC_Label, 1, dam);	//9/01/2018 JLGNS1 Bug 36407
		block.addNewItem(dam.description, DC_Data, 1, dam);

	endforeach;
		
	if self.allDamageInstanceByPos.size.isOdd() then			 						//9/01/2018 JLGNS1 Bug 36407
		block := _dataContainer.addNewBlock;					 						//9/01/2018 JLGNS1 Bug 36407
		block.addNewItem(Empty_String , DC_Label, 1, self);		 						//9/01/2018 JLGNS1 Bug 36407
		block.addNewItem(Empty_String, DC_Data, 1, self);		 						//9/01/2018 JLGNS1 Bug 36407
	endif;																				//9/01/2018 JLGNS1 Bug 36407
																						//9/01/2018 JLGNS1 Bug 36407
	block := _dataContainer.addNewBlock;												//9/01/2018 JLGNS1 Bug 36407
	block.addNewItem(app.getErrorString(CM_Rail_Area).trimBlanks(), DC_Label, 1, self);	//9/01/2018 JLGNS1 Bug 36407
	block.addNewItem(self.getRailAreaDesc() , DC_Data, 1, self);						//9/01/2018 JLGNS1 Bug 36407
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Location).trimBlanks(), DC_Label, 1, self);	//9/01/2018 JLGNS1 Bug 36407
	block.addNewItem(self.getPositionDescr(), DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Load_Weight).trimBlanks(), DC_Label, 1, self);//9/01/2018 JLGNS1 Bug 36407
	//block.addNewItem(self.getLoadWeight().String &amp; " Kg", DC_Data, 1, self); //- cnwmd1, CCMS 1067, Par 19710
	//block.addNewItem(self.getLoadWeight().asStringWeightJMT() &amp; app.getErrorString(Space_Kg), DC_Data, 1, self); //+ cnwmd1, CCMS 1067, Par 19710
	//11 Sep 2013	NDL	Par 32172
	measureString := app.convertMeasurementForDisplay(weightType.shortName, self.getLoadWeight());
	if measureString = null then
		measureString := "0";
	endif;
	block.addNewItem(measureString &amp; " " &amp; weightType.shortName, DC_Data, 1, self);
	
	measureString := app.convertMeasurementForDisplay(weightType.shortName, self.getMaxCargoWeight());	//9/01/2018 JLGNS1 Bug 36407
	if measureString = null then																		//9/01/2018 JLGNS1 Bug 36407
		lString := "";																					//9/01/2018 JLGNS1 Bug 36407
	else																								//9/01/2018 JLGNS1 Bug 36407
		lString := measureString &amp; " " &amp; weightType.shortName;											//9/01/2018 JLGNS1 Bug 36407
	endif;																								//9/01/2018 JLGNS1 Bug 36407
	block := _dataContainer.addNewBlock;																//9/01/2018 JLGNS1 Bug 36407
	block.addNewItem(app.getErrorString(Maximum_Weight).trimBlanks(), DC_Label, 1, self);				//9/01/2018 JLGNS1 Bug 36407
	block.addNewItem(lString, DC_Data, 1, self);														//9/01/2018 JLGNS1 Bug 36407
																										//9/01/2018 JLGNS1 Bug 36407
	block := _dataContainer.addNewBlock;																//9/01/2018 JLGNS1 Bug 36407
	block.addNewItem(app.getErrorString(Destination_terminal).trimBlanks(), DC_Label, 1, self);			//9/01/2018 JLGNS1 Bug 36407
	block.addNewItem(self.getDestinationTerminalDesc(), DC_Data, 1, self);								//9/01/2018 JLGNS1 Bug 36407
																										//9/01/2018 JLGNS1 Bug 36407
	measureString := app.convertMeasurementForDisplay(weightType.shortName, self.getWagonTareWeight());	//9/01/2018 JLGNS1 Bug 36407
	if measureString = null then																		//9/01/2018 JLGNS1 Bug 36407
		lString := "";																					//9/01/2018 JLGNS1 Bug 36407
	else																								//9/01/2018 JLGNS1 Bug 36407
		lString := measureString &amp; " " &amp; weightType.shortName;											//9/01/2018 JLGNS1 Bug 36407
	endif;																								//9/01/2018 JLGNS1 Bug 36407
	block := _dataContainer.addNewBlock;																//9/01/2018 JLGNS1 Bug 36407
	block.addNewItem(app.getErrorString(Tare_weight).trimBlanks(), DC_Label, 1, self);					//9/01/2018 JLGNS1 Bug 36407
	block.addNewItem(lString, DC_Data, 1, self);														//9/01/2018 JLGNS1 Bug 36407
																										//9/01/2018 JLGNS1 Bug 36407
	measureString := app.convertMeasurementForDisplay( lengthType.shortName, self.getMaxCargoHeight());	//9/01/2018 JLGNS1 Bug 36407
	if measureString = null then																		//9/01/2018 JLGNS1 Bug 36407
		lString := "";																					//9/01/2018 JLGNS1 Bug 36407
	else																								//9/01/2018 JLGNS1 Bug 36407
		lString := measureString &amp; " " &amp; lengthType.shortName;											//9/01/2018 JLGNS1 Bug 36407
	endif;																								//9/01/2018 JLGNS1 Bug 36407
	block := _dataContainer.addNewBlock;																//9/01/2018 JLGNS1 Bug 36407
	block.addNewItem(app.getErrorString(Maximum_cargo_height).trimBlanks(), DC_Label, 1, self);			//9/01/2018 JLGNS1 Bug 36407
	block.addNewItem(lString, DC_Data, 1, self);														//9/01/2018 JLGNS1 Bug 36407
	
	if self.myWagonClass &lt;&gt; null then
		if self.isFlatcarVisit then
			//lString := (self.myWagonClass.lenInUnits * 10).String;
			//11 Sep 2013	NDL	Par 32172
			lengthInCM := ((self.myWagonClass.getLenInUnits * 10) * 30.48 );
			//lengthType := app.getDefaultMeasurementForType(Type_Length);								//9/01/2018 JLGNS1 Bug 36407
			measureString := app.convertMeasurementForDisplay(lengthType.shortName, lengthInCM);
			if measureString = null then
				measureString := "0";
			endif;
			lString := measureString &amp; " " &amp; lengthType.shortName;
		elseif self.isBoxcarVisit then
			lString := self.myWagonClass.getOverallLengthString;
		elseif self.isWellcarVisit then
			lString := self.myWagonClass.getOverallLengthString;
		endif;
	else
		lString := "";
	endif;

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Length).trimBlanks(), DC_Label, 1, self);	//9/01/2018 JLGNS1 Bug 36407
	block.addNewItem(lString, DC_Data, 1, self);
	
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Status).trimBlanks(), DC_Label, 1, self);	//9/01/2018 JLGNS1 Bug 36407
	block.addNewItem(self.getStatus(), DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Remarks_GC).trimBlanks(), DC_Label, 1, self);	//9/01/2018 JLGNS1 Bug 36407
	block.addNewItem(self.remarks, DC_Data, 1, self);
	
	
	
	//th2 added 19/03/2007 - color coding attributes - if any
	//_strArray.add("CC Destination" &amp; Tab &amp; self.getCCDestination);
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(ColorCode_Destination), DC_Label, 1, self);
	block.addNewItem(self.getCCDestination, DC_Data, 1, self);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(ColorCode_FreightFwdr), DC_Label, 1, self);
	block.addNewItem(self.getCCFreightForwarder, DC_Data, 1, self);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(ColorCode_ReleaseNo), DC_Label, 1, self);
	block.addNewItem(self.getCCReleaseNo, DC_Data, 1, self);
	
	// PAR 19989
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(ConsigneeCC), DC_Label, 1, self);
	block.addNewItem(self.getCCConsignee, DC_Data, 1, self);


	// ## RECEIVED CARGO
	lString := self.getAllTrackedItemsString(true, false, true);
	if lString &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Items_received), DC_Label, 1, self);
		block.addNewItem(lString, DC_Data, 1, self);
	else
		// ## UNCONFIRMED RECEIVED CARGO
		lString := self.getAllTrackedItemsString(true, false, false);
		if lString &lt;&gt; null then
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(Unconfirmed) &amp; " " &amp; app.getErrorString(Items_received), DC_Label, 1, self);
			block.addNewItem(lString, DC_Data, 1, self);
		endif;
	endif;
	
	//Cargo Restrictions	12 Feb 2014	NDL	Par 33439
	if self.hasMasterCargoRestriction() then
		cargoRestrict := self.myWagonMaster.getMyObjectMatchCriteriaFor( self.myTerminal );
		if cargoRestrict &lt;&gt; null then
			lString := cargoRestrict.allCriteria.getDisplay;
		endif;
		if lString &lt;&gt; null then
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(Cargo_restrictions), DC_Label, 1, self);
			block.addNewItem(lString, DC_Data, 1, self);
		endif;
	endif;
	
	if self.hasSelectableSealTypes() then
		lString := self.getSealsDetailCurrentForReport();
		if lString = null then
			lString := app.getErrorString(None);
		endif;
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Wagon_seal), DC_Label, 1, self);
		block.addNewItem(lString, DC_Data, 1, self);
	endif;
	
	// ## RELEASED CARGO
	lString := self.getAllTrackedItemsString(false, false, true);
	if lString &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Items_released), DC_Label, 1, self);
		block.addNewItem(lString, DC_Data, 1, self);
	else
		// ## UNCONFIRMED RECEIVED CARGO
		lString := self.getAllTrackedItemsString(false, false, false);
		if lString &lt;&gt; null then
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(Unconfirmed) &amp; " " &amp; app.getErrorString(Items_released), DC_Label, 1, self);
			block.addNewItem(lString, DC_Data, 1, self);
		endif;
	endif;
	
	// ## TRANSIT CARGO
	lString := self.getAllTrackedItemsString(true, true, true);
	if lString &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Items_transit), DC_Label, 1, self);
		block.addNewItem(lString, DC_Data, 1, self);
	endif;
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getFirstLocationFor" id="797ba81b-52ab-427c-bd2a-265f7404f29e">
        <source>getFirstLocationFor( _obj : CM_Object ) : CM_WagonController;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 December 2014	cnwndl1	Initial creation	Par 35346 / CCMS 1408

*/

vars

	index : Integer;
	ti : CM_TrackedItem;
	wc : CM_WagonController;
	wle : CM_WorkListEntry;

begin

	foreach index in 1 to self.allLocationsControllersArray.size do
		wc :=  self.allLocationsControllersArray[index];
		if _obj.isKindOf( CM_TrackedItem) then
			ti := _obj.CM_TrackedItem;
			if wc.allTrackedItems.includes( ti ) then
				return wc;
			endif;
		elseif _obj.isKindOf( CM_WorkListEntry ) then
			wle := _obj.CM_WorkListEntry;
			if wc.allRailWLELoad.includes( wle ) then
				return wc;
			endif;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <ReturnType type="CM_WagonController"/>
    </JadeMethod>
    <JadeMethod name="getIdStrJRW" id="15ec5bc9-73cc-44de-baed-01f808ea4ba6">
