    <JadeMethod name="setExtractDef" id="b50b8a63-0443-4922-93a0-fe4631e54194">
        <updating/>
        <source>setExtractDef(_description: String; _initialiseAllClassesOnCreate: Boolean;
		_overrideExtractFormat: Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     03 June 2003 by cnwsb1
//
// Purpose:		Creates a transient structure for the extract, where each
//				persistent sub-class of the selected classes is present.
//				The actual features for each class are cached on this structure
//				too, as referencing schema attributes is slow.
//				Only call this method once per extract.
//
// Performance:	Set _initialiseAllClassesOnCreate to true if testing more than
//				10 real sub-classes (as it takes approx 7 minutes to initialise
//				all classes, but 1 minute per real sub-class).  So if you
//				leave this as false and extract all classes you are adding
//				1-2 hours to the test.
//				Set _initialiseAllClassesOnCreate to false for real extracts.
// ---------------------------------------------------------------------------
vars
	logStr : String;
	result : Boolean;
	startSetExtractDef, endSetExtractDef : TimeStamp;
	
begin
	logStr := "Setting extract definition: " &amp; _description;
	self.extractClassId := null;
	self.myExtractDefTerminal := null;
	
	delete self.myTransExtractDef;
	self.myExtractDef := app.myRoot.allDataDumpExtractDefs[_description];

	if self.myExtractDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name,
				"Extract Definition has not been set");
		return;
	endif;
	
	self.myExtractDefTerminal := self.myExtractDef.myTerminal;
	
	if _overrideExtractFormat = null then
		// Use the stored extract format for this def
		self.extractFormat := self.myExtractDef.extractFormat;
	else
		// Use the over-ride extract format
		self.extractFormat := _overrideExtractFormat;
	endif;
	
	self.finaliseExternalDatabaseAgent;
	
	self.extractToDateTime := app.actualTimeServer;
	startSetExtractDef := self.extractToDateTime;
	self.totalCreates := 0;
	self.totalDeletes := 0;
	self.totalUpdates := 0;
	
	logStr := logStr &amp; CrLf &amp;
			"Extract Format: " &amp; self.getExtractFormatDescr &amp; CrLf &amp;
			"Initialising Extract Definition (all classes: " &amp;
			_initialiseAllClassesOnCreate.String &amp; ")";	//11 Jul 2013	cnwrs1	Par #31540 - use current time rather than trx transation time from journal
			//&amp; CrLf &amp; "  from : " &amp; startSetExtractDef.dataDumpFormat;	//11 Jul 2013	cnwrs1	Par #31540 - use current time rather than trx transation time from journal
	create self.myTransExtractDef transient;
	self.myTransExtractDef.setForCreate(self.myExtractDef, _initialiseAllClassesOnCreate);
	endSetExtractDef := app.actualTimeServer;
//	logStr := logStr &amp; CrLf &amp; "  to   : " &amp; endSetExtractDef.dataDumpFormat;
	self.cachingSeconds := startSetExtractDef.getSecondsInInterval(endSetExtractDef);
	self.setAlertLimit(self.myExtractDef.alertLimit);
	if self.isExternalDatabaseExtract then
		create self.myExternalDatabaseAgent transient;
		self.myExternalDatabaseAgent.initialise(EDB_PortDss,
				self.myTransExtractDef, self.allSystemAlertMessages,
				self.checkFeatureLength);
	elseif self.isSQLNative() and self.isBulkDataExtract = false then //20/04/2010 cnwdz2
		create self.myExternalDatabaseAgent transient;
		self.myExternalDatabaseAgent.initialise(JMT_SQLNative,
				self.myTransExtractDef, self.allSystemAlertMessages,
				self.checkFeatureLength);
		self.myExternalDatabaseAgent.myExtractionAgent := self;
	endif;
	//
	//  If Definition has been modified - regenerate every thing for SQLNative
	//
	if self.myExtractDef.isFormatSQLNative and self.isBulkDataExtract = false then
		if self.myExtractDef.definitionModified = true then
			result := self.myExternalDatabaseAgent.buildAllStoredProcedures( self.myExtractDef);
		endif;
	endif;

	if self.myExtractDef.isFormatSQLNative and self.isBulkDataExtract = false then
		result := self.generateTransientMethods;
		if result = false then
			//raise an exception"
			logStr := logStr &amp; CrLf &amp; app.getErrorString(TransientMethods_GenFailed);
			app.raiseCMException(TransientMethods_GenFailed, null, null);
		endif;
	endif;

epilog
	self.log(logStr);
end;</source>
        <access>protected</access>
        <Parameter name="_description" type="String"/>
        <Parameter name="_initialiseAllClassesOnCreate" type="Boolean"/>
        <Parameter name="_overrideExtractFormat" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setLoadMode" id="d1467ddc-f160-472a-8024-20722cea0542">
        <updating/>
        <source>setLoadMode(_value: Boolean) updating;

vars

begin
	self.loadMode := _value;
end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="statisticsForExtract" id="a116b460-0f96-4fb0-97d4-563379950a8b">
        <updating/>
        <source>statisticsForExtract() updating, protected;
// ---------------------------------------------------------------------------
// Created:		08 August 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	secs : Integer;

begin
	if self.totalCreates &gt; 0 or self.totalUpdates &gt; 0 or self.totalDeletes &gt; 0 then
		secs := self.extractToDateTime.getSecondsInInterval(app.actualTimeServer);

		self.log("Statistics for entire extract: " &amp;
				self.totalCreates.String &amp; " creates, " &amp;
				self.totalUpdates.String &amp; " updates, " &amp;
				self.totalDeletes.String &amp; " deletes.  " &amp;
				(self.totalCreates + self.totalUpdates + self.totalDeletes).String &amp;
				" changes in " &amp; secs.String &amp; " seconds." &amp; CrLf &amp;
				"Time to cache meta-data: " &amp; self.cachingSeconds.String &amp; " seconds.");
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="writeChangeObj" id="7b2edef6-6ae1-4811-a161-d98638fc3c1a">
        <updating/>
        <source>writeChangeObj(_transClass : CM_DataDumpTransSpecClass; _obj: Object;
		_changedTs: TimeStamp; _created, _updated: Boolean output;
		_filterByTerminal: Boolean; _sqlStatement: String output;
		_changeAction : Integer) : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     04 June 2003 by cnwsb1
//
// Purpose:		Format for objects that have been either created or updated.
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
20 May 2009	cnwkpd1	PAR #19729 - Add in asXml to correctly format values with embedded XML 
					special characters

24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
28/04/2017	cnwdap1		TFS 4129 DPH Data Extract Error - new parameter for createSQLNativeObject and updateSQLNativeObject
// 21 May 2018	jlgrs1	TFS 38693 C3 stop trying to write out CM_LogNoNumbers
*/

vars
	transFeature : CM_DataDumpTransSpecFeature;
	dumpStr : String;
	featureName : String;
	featureValue : Any;
	featureStr : String;
	gotProtectedFeatureError : Boolean;
	featureField : String;
	
begin
	if _obj = null then
		return false;
	endif;
	
	/* 	epr TFS 3418 16/3/17
		sql dumps CM_LogController seperately from all the other locations controllers we make sure only using
		the class created for log controllers
	 */
	if _obj.isKindOf(CM_LogController) then
		if _transClass.myClass &lt;&gt; CM_LogController then
			return false;
		endif;
	endif;
	/* 	likewise sql dumps CM_Log seperately from all the other trackedItems we make sure only using
		the class created for logs
	 */
	if _obj.class.inheritsFrom(CM_Log) then
		if _transClass.myClass &lt;&gt; CM_Log and
		   _transClass.myClass &lt;&gt; CM_LogNoNumber then
			return false;
		endif;
	endif;
	
	// _filterByTerminal will only be true when one of these 4 classes is being extracted
	if _filterByTerminal then
		if CM_TempReading.hasInstance(_obj) then
			if _obj.CM_TempReading.myTerminal &lt;&gt; self.myExtractDefTerminal then
				return false;
			endif;
		elseif CM_TITransaction.hasInstance(_obj) then
			if _obj.CM_TITransaction.myTerminal &lt;&gt; self.myExtractDefTerminal then
				return false;
			endif;
		elseif CM_Voyage.hasInstance(_obj) then
			if _obj.CM_Voyage.myTerminal &lt;&gt; self.myExtractDefTerminal then
				return false;
			endif;
		elseif CM_TrackedItem.hasInstance(_obj) then
			if _obj.CM_TrackedItem.myTerminal &lt;&gt; self.myExtractDefTerminal then
				return false;
			endif;
		endif;
	endif;
	
	if self.isExternalDatabaseExtract then
		// Direct conversation via ODBC
		return self.myExternalDatabaseAgent.updateExternalObj(_obj, _created, _updated, _sqlStatement, self.loadMode);

	elseif self.isXMLFileExtract then
		// Write to File
		dumpStr := (self.ChangeTrackerObject &amp; " " &amp;
				self.ChangeTrackerClassAlias &amp; '="' &amp; _transClass.getClassAlias &amp; '"' &amp; " " &amp;
				self.ChangeTrackerActionChange &amp; " " &amp;
				self.ChangeTrackerChangedTs &amp; '="' &amp; _changedTs.dataDumpFormat &amp; '"'
				).asXmlPrefix &amp; CrLf;
				
		on Exception do self.localProtectedFeatureExHandler(exception,
				_transClass, gotProtectedFeatureError);

		foreach transFeature in _transClass.allTransSpecFeatures do
			transFeature.getFeatureValueForObj(self.extractFormat, _obj, featureName, featureValue);
			featureStr := featureValue.dataDumpFormat;
			featureField := Tab &amp; featureName.asXmlPrefix &amp; featureStr.trimRight.asXML &amp; featureName.asXmlSuffix &amp; CrLf;
			dumpStr := dumpStr &amp; featureField;
		endforeach;
		
		on Exception do null;
		
		if gotProtectedFeatureError then
			app.raiseCMException(DataDumpFeatureErrorsFound, null, null);
		endif;
		
		featureField := self.ChangeTrackerObject.asXmlSuffix &amp; CrLf;
		dumpStr := dumpStr &amp; featureField;
		
		self.myFile.writeString(dumpStr);
		_created := true;
	elseif self.isSQLNative then
		if _changeAction = JSSCTSelectionObject.ACTION_CREATE then
			//return self.myExternalDatabaseAgent.createSQLNativeObject(_obj, _created, _updated);				// TFS 4129
			return self.myExternalDatabaseAgent.createSQLNativeObject(_transClass, _obj, _created, _updated);	// TFS 4129
		elseif _changeAction = JSSCTSelectionObject.ACTION_UPDATE then
			//return self.myExternalDatabaseAgent.updateSQLNativeObject(_obj, _created, _updated);				// TFS 4129
			return self.myExternalDatabaseAgent.updateSQLNativeObject(_transClass, _obj, _created, _updated);	// TFS 4129
		else
			self.createSQLNativeAlert(method.qualifiedName &amp; " " &amp; app.getErrorString1(InvalidChangeAction, _changeAction.String));
			app.raiseCMException1(InvalidChangeAction, _changeAction.String, null, null);
		endif;
	else
		app.raiseCMException1(DataDumpInvalidFormat, self.extractFormat.String, null, null);
	endif;
	
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_transClass" type="CM_DataDumpTransSpecClass"/>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_changedTs" type="TimeStamp"/>
        <Parameter name="_created" type="Boolean" usage="output"/>
        <Parameter name="_updated" type="Boolean" usage="output"/>
        <Parameter name="_filterByTerminal" type="Boolean"/>
        <Parameter name="_sqlStatement" type="String" usage="output"/>
        <Parameter name="_changeAction" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="writeDeleteObj" id="896cfea9-57ac-4c07-85f0-3622e35f3cfa">
        <source>writeDeleteObj(_transClass : CM_DataDumpTransSpecClass; _objId: String; _changedTs: TimeStamp) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     04 June 2003 by cnwsb1
//
// Purpose:		Format for objects that have been deleted.
//
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 28/04/2017	cnwdap1		TFS 4129 DPH Data Extract failing - new parameter for deleteSQLNativeObject
// ---------------------------------------------------------------------------
vars
	dumpStr : String;
	result : Boolean;
begin
	if _objId = null then
		result := false;
		return result;
	endif;

	if self.isExternalDatabaseExtract then
		// Direct conversation via ODBC
		result := self.myExternalDatabaseAgent.deleteExternalObj(_objId);

	elseif self.isXMLFileExtract then
		// Write to File
		dumpStr := (self.ChangeTrackerObject &amp; " " &amp;
				self.ChangeTrackerClassAlias &amp; '="' &amp; _transClass.getClassAlias &amp; '"' &amp; " " &amp;
				self.ChangeTrackerActionDelete &amp; " " &amp;
				self.ChangeTrackerChangedTs &amp; '="' &amp; _changedTs.dataDumpFormat &amp; '"'
				).asXmlPrefix &amp; CrLf &amp;
				DataDumpOid.asXmlPrefix &amp; _objId.oidStringToDataDumpHex &amp;
				DataDumpOid.asXmlSuffix &amp; CrLf &amp;
				self.ChangeTrackerObject.asXmlSuffix &amp; CrLf;
		self.myFile.writeString(dumpStr);
	elseif self.isSQLNative then
		//result := self.myExternalDatabaseAgent.deleteSQLNativeObject(_objId);					// TFS 4129
		result := self.myExternalDatabaseAgent.deleteSQLNativeObject(_transClass, _objId);		// TFS 4129
	else
		app.raiseCMException1(DataDumpInvalidFormat, self.extractFormat.String, null, null);
	endif;
	result := true; //par10908
epilog
	return result; //par10908
end;</source>
        <access>protected</access>
        <Parameter name="_transClass" type="CM_DataDumpTransSpecClass"/>
        <Parameter name="_objId" type="String"/>
        <Parameter name="_changedTs" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
