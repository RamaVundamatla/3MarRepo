    <JadeMethod name="delete" id="3371ab80-efc0-4058-af0b-0d3af732b274">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 Oct 2011	cnwndl1	Initial creation	Par 28303
11 Oct 2022 navlw1  TFS 53812 added new collections for damage
13 Jan 2023 navlw1  TFS 55162 EUP - WMS-Advanced Repair Details
08 Jan 2026 navma1  MTN-36897 PEN - Transient File Growth in PEN Production Environment 
*/

vars

begin

	if not self.allDamageCodes.isEmpty then
		self.allDamageCodes.purge();
	endif;
	if not self.allDamagePositions.isEmpty then
		self.allDamagePositions.purge();
	endif;
	if not self.allDamageSeverities.isEmpty then
		self.allDamageSeverities.purge();
	endif;
	
	// 11 Oct 2022 navlw1
	if not self.allDamageParties.isEmpty then
		self.allDamageParties.purge();
	endif;
	if not self.allDamagePlaces.isEmpty then
		self.allDamagePlaces.purge();
	endif;
	if not self.allDamageReasons.isEmpty then
		self.allDamageReasons.purge();
	endif;
	
	// 13 Jan 2023 navlw1
	if not self.allRepairReasons.isEmpty then
		self.allRepairReasons.purge();
	endif;
	
	delete self.defaultDamageSeverity;		//08.01.2026 navma1 #MTN-36897
epilog

end;</source>
    </JadeMethod>
</Class>
