    <JadeMethod name="compareChanges" id="a0464760-9654-4907-92a6-5b5bd95a12e7">
        <updating/>
        <source>compareChanges() updating;
/*
Purpose:	// ### JIRA 36920 05JAN2026 NAVAB1

Date		Who		Reason
05 January 2026	navab1	JIRA 36920
*/

vars
	tmpClient, tmpClientBefore	: DEV_LicenseClient;
	detailNow, detailBefore : DEV_LicenseDtl;
	permission, idx, licIDX : Integer;
	permVal, permValBefore  : Boolean;
	permExp, permExpBefore : Date;
	permObj : CM_PermissionObject;
	 permAgent : CM_PermissionAgent;
	 ediAgent : CM_EDIFileTypeAgent;
	 dateStr, dateStrBefore : String;
	 notInArray : Boolean;
	 audit : CMUI_LicenseAudit;
	 
	 userCode, clientName, licenseName, changeNote, dateChange : String;
	 changeTS : TimeStamp;
	 
	 ediType : CM_EDIFileType;
	 camType : CM_CamProtocolDesc;
	 ewsType : CM_ExternalWebServiceType;
	 endpointType : CM_EWSEndpointType;
	 autoStr : String;
begin

	userCode := process.signOnUserCode;
	changeTS := app.actualTimeAppServer;
	
	
	foreach tmpClient in self.allClients do
		changeNote := "";
		clientName := tmpClient.name;
		
		tmpClientBefore := self.allClientsBefore[tmpClient.name];
		
		
		// Its a new client, record changes but carry on so that we audit a new license being saved.
		if tmpClientBefore = null then
			changeNote := "New client Added";
			self.addToChangeNote("Number of terminals set to " &amp; self.txtNumTerminals.text,changeNote);
			self.addToChangeNote("New note '" &amp; self.txtNotes.text &amp;"'",changeNote);
			beginTransaction;
			create audit;
			audit.setForCreate(userCode, "New Client", clientName, changeNote, changeTS);
			commitTransaction;	
			changeNote := "";
		// Its an update so check for changes
		else
		
			if tmpClient.numTerminals &lt;&gt; tmpClientBefore.numTerminals then
				self.addToChangeNote("Number of terminals changed from " &amp; tmpClientBefore.numTerminals.String &amp; " to " &amp; tmpClient.numTerminals.String,changeNote);
			endif;
			if tmpClient.notes &lt;&gt; tmpClientBefore.notes then
				self.addToChangeNote("Notes changed from '" &amp; tmpClientBefore.notes.String &amp; "' to '" &amp; tmpClient.notes.String &amp; "'",changeNote);
			endif;
			
			if changeNote &lt;&gt; null then
				beginTransaction;
				create audit;
				audit.setForCreate(userCode, "Client Detail", clientName, changeNote, changeTS);
				commitTransaction;
			endif;
		endif;	
			
		// Compare each license with the version before
		// 1 = system, 2 = EDI, 4 = subscription, 5 = EWS
		foreach detailNow in tmpClient.allLicenseDtls do
			changeNote := "";
			licenseName := detailNow.getLicenseName();
			
			// there may not be a client before if the client is new
			// NOTE. when you add a client, it asks for a name, this is displayed along with '1' as the number of terminals, 
			//			however no client actually exists. When the first license is saved then it creates a client, but there was not one before so this could be null
			if tmpClientBefore &lt;&gt; null then
				detailBefore := tmpClientBefore.allLicenseDtls.getAtKeyGeq(detailNow.type,"");
			endif;
			
			// when the first license is saved and the client is created, it will be the only license on that client, the others are null, so when you save the second license it will not be in the before.
			if detailBefore &lt;&gt; null and detailBefore.type = detailNow.type then
				if detailBefore.expiryDate &lt;&gt; detailNow.expiryDate then
					dateChange := self.getDateChangeNote("License", detailNow.expiryDate, detailBefore.expiryDate);
					
					self.addToChangeNote(dateChange,changeNote);
				endif;
			else
				detailBefore := null;
			endif;
			
			idx := 1;
			
			
			if detailNow.type = DEV_LicenseEntity.LicenseType_EWS then // EWS - check boolean and expiry date
				if detailNow.allDetails.isEmpty then
					continue;
				endif;
				
				foreach ewsType in self.myEWSTypeAgent.allEWSTypesByName do
					idx := ewsType.type;
					
					// MODULE
					if detailBefore &lt;&gt; null then
						permValBefore := detailBefore.allDetails[idx];
					else
						permValBefore := false;
					endif;
					permVal := detailNow.allDetails[idx];
					
					if permValBefore &lt;&gt; permVal then
						self.addToChangeNote(ewsType.name &amp; " module has changed from " &amp; permValBefore.String &amp; " to " &amp; permVal.String,changeNote);
					endif;
					
					// EXPIRY
					permExp := detailNow.allExpiries[idx];
					if detailBefore &lt;&gt; null then
						permExpBefore := detailBefore.allExpiries[idx];
					else
						permExpBefore := null;
					endif;
					
					if permExp &lt;&gt; permExpBefore then
						dateChange := self.getDateChangeNote(ewsType.name, permExp, permExpBefore);
						self.addToChangeNote(dateChange,changeNote);
					endif;
					
				endforeach;
				foreach endpointType in self.myEWSTypeAgent.allEWSEndpointTypeByType do
					idx := endpointType.type;
					// MODULE
					if detailBefore &lt;&gt; null then
						permValBefore := detailBefore.allDetails[idx];
					else
						permValBefore := false;
					endif;
					permVal := detailNow.allDetails[idx];
					
					if permValBefore &lt;&gt; permVal then
						self.addToChangeNote(endpointType.name &amp; " module has changed from " &amp; permValBefore.String &amp; " to " &amp; permVal.String,changeNote);
					endif;
					
					// EXPIRY
					permExp := detailNow.allExpiries[idx];
					if detailBefore &lt;&gt; null then
						permExpBefore := detailBefore.allExpiries[idx];
					else
						permExpBefore := null;
					endif;
					if permExp &lt;&gt; permExpBefore then
						dateChange := self.getDateChangeNote(endpointType.name, permExp, permExpBefore);
						self.addToChangeNote(dateChange,changeNote);
						endif;
				endforeach;

			elseif detailNow.type = DEV_LicenseEntity.LicenseType_EDI  then // EDI - check the boolean
				if detailNow.allDetails.isEmpty then
					continue;
				endif;						
				foreach ediType in self.myEDIFileTypeAgent.allEDIFileTypes do
					idx := ediType.type;
					if detailBefore &lt;&gt; null then
						permValBefore := detailBefore.allDetails[idx];
					else
						permValBefore := null;
					endif;
					permVal := detailNow.allDetails[idx];
					
					if permValBefore &lt;&gt; permVal then
						self.addToChangeNote(ediType.name &amp; " module has changed from " &amp; permValBefore.String &amp; " to " &amp; permVal.String,changeNote);
					endif;
				endforeach;
				foreach camType in self.myEDIFileTypeAgent.allCAMProtocolDescs do
					idx := camType.type;
					if detailBefore &lt;&gt; null then
					permValBefore := detailBefore.allDetails[idx];
					else
						permValBefore := null;
					endif;
					permVal := detailNow.allDetails[idx];
					
					if permValBefore &lt;&gt; permVal then
						self.addToChangeNote(camType.name &amp; " module has changed from " &amp; permValBefore.String &amp; " to " &amp; permVal.String,changeNote);
					endif;
				endforeach;
					
			else // SYS or SUBS - check boolean and expiry date for subs
				if detailNow.type = DEV_LicenseEntity.LicenseType_System then
					permAgent := self.myPermissionAgent;
				elseif detailNow.type = DEV_LicenseEntity.LicenseType_Subscription then
					permAgent := self.mySubscriptionPermAgent;
				endif;

				foreach permVal in detailNow.allDetails do
						if idx = Mod_BaseView or
							idx = PmNum01 or
						   idx = PmNum02 or
						   idx = PmNum03 or
						   idx = PmNum04 or
						   idx = PmNum05 or
						   idx = PmNum06 or
						   idx = PmNum07 or
						   idx = PmNum08 or
						   idx = PmNum09 or
						   idx = PmNum10 or
						   idx = PmAdmInternal or
						   idx = PmSite then
							continue; // IGNORE
						endif;
				
					// ### PERMISSION
					autoStr := "";
					if detailBefore &lt;&gt; null  and idx &lt;= detailBefore.allDetails.size then
						permValBefore := detailBefore.allDetails[idx];
					else
						permValBefore := false; // was not in the array before
					endif;
					if permValBefore &lt;&gt; permVal then
						if detailNow.type = DEV_LicenseEntity.LicenseType_Subscription then
							licIDX := idx + Mod_BaseView;
							permObj := permAgent.allPermissionsByConstValue[licIDX];
							autoStr := self.isAutoAdded(licIDX);
							self.addToChangeNote( autoStr &amp; permObj.description &amp; " module has changed from " &amp; permValBefore.String &amp; " to " &amp; permVal.String,changeNote);
						elseif detailNow.type = DEV_LicenseEntity.LicenseType_System then
							licIDX := idx + Mod_BaseView;
							permObj := permAgent.allPermissionsByConstValue[licIDX];
							autoStr := self.isAutoAdded(licIDX);
							self.addToChangeNote( autoStr &amp;  permObj.description &amp; " module has changed from " &amp; permValBefore.String &amp; " to " &amp; permVal.String,changeNote);
						endif;
					endif;
					
					// #### EXPIRY
					if detailNow.type = DEV_LicenseEntity.LicenseType_Subscription then
						permExp := detailNow.allExpiries[idx];
						if detailBefore &lt;&gt; null then
							permExpBefore := detailBefore.allExpiries[idx];
						else	
							permExpBefore := null;
						endif;
						if permExp &lt;&gt; permExpBefore then
							licIDX := idx + Mod_BaseView;
							permObj := permAgent.allPermissionsByConstValue[licIDX];
							dateChange := self.getDateChangeNote(permObj.description, permExp, permExpBefore);
							
							self.addToChangeNote(dateChange,changeNote);
						endif;
					endif;

					
					
					idx += 1;
				endforeach;
			endif;
			
			if changeNote &lt;&gt; null then
				beginTransaction;
				create audit;
				audit.setForCreate(userCode, licenseName, clientName, changeNote, changeTS);
				commitTransaction;
			endif;
			
		endforeach;

	
	endforeach;
	
	// all the cleints will have been refreshed by the saveToXML in the previous call, now that we have the audits saved, purge and rebuild the 'before' from the same XML
	self.createClientBeforeData(self.myConstant.text);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createClientBeforeData" id="f4a697ea-b658-4c5a-8a21-c07f0219e263">
        <updating/>
        <source>createClientBeforeData(_xml : String) updating, protected;
/*
Purpose - 	copy of licenses before changes so can compare.
Who - NAVAB1
Date - 05JAN2026
// ### JIRA 36920 05JAN2026 NAVAB1
*/

vars
	clientXML	: String;
	pos			: Integer;
	tmpClient	: DEV_LicenseClient;

begin

	self.allClientsBefore.purge();
	pos := 1;
	while (pos &gt; 0) do
		clientXML := _xml.cnEcGetNextTagValueOfName(DEV_LicenseClient.XMLTag_Client, pos);
		if clientXML &lt;&gt; null then
			create tmpClient transient;
			tmpClient.setFromXML(clientXML);
			self.allClientsBefore.add(tmpClient);
		endif;
	endwhile;

end;</source>
        <access>protected</access>
        <Parameter name="_xml" type="String"/>
    </JadeMethod>
    <JadeMethod name="createClientData" id="8d0cdad4-a1ed-4a9d-9a62-fc84c290c451">
        <updating/>
        <source>createClientData(_xml : String) updating, protected;
// ---------------------------------------------------------------------------
// Created:     05 November 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	clientXML	: String;
	pos			: Integer;
	tmpClient	: DEV_LicenseClient;

begin


	pos := 1;
	while (pos &gt; 0) do
		clientXML := _xml.cnEcGetNextTagValueOfName(DEV_LicenseClient.XMLTag_Client, pos);
		if clientXML &lt;&gt; null then
			create tmpClient transient;
			tmpClient.setFromXML(clientXML);
			self.allClients.add(tmpClient);
		endif;
	endwhile;

end;</source>
        <access>protected</access>
        <Parameter name="_xml" type="String"/>
    </JadeMethod>
    <JadeMethod name="delete" id="86904d0c-f528-47f3-885a-384cc70b384c">
        <updating/>
        <source>delete() updating;
// ---------------------------------------------------------------------------
// Created:     05 November 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	delete self.myPermissionAgent;
	delete self.myEDIFileTypeAgent;
	delete myEWSTypeAgent; // ### JIRA 33541 12DEC2024 NAVAB1
	self.allClients.purge;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDeleteDtl" id="5eb5c462-8f56-48b8-8773-4d25986052c1">
        <updating/>
        <source>doDeleteDtl() updating, protected;
// ---------------------------------------------------------------------------
// Created:     06 November 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	termName	: String;
	licDtl		: DEV_LicenseDtl;
	
begin

	if self.myCurrentClient = null then
		app.msgBox('You must select a client', 'Error', 0);
		return;
	endif;
	
	if self.myCurrentLicenseDtl = null then
		app.msgBox('You must select a license to delete', 'Error', 0);
		return;
	endif;
	
	licDtl := self.myCurrentLicenseDtl;
	termName := licDtl.name;

	if app.msgBox('Delete license ' &amp; termName, 'Delete', MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
		return;
	endif;

	if licDtl &lt;&gt; null then
		delete licDtl;
	endif;
	
	self.myCurrentLicenseDtl := null;
	
	self.initComboLicenseType(self.myCurrentClient);
	self.setCurrentLicenseDtl(self.myCurrentClient.mySystemLicense, DEV_LicenseEntity.LicenseType_System);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doExtractAll" id="85141366-cb03-4d92-9207-f08c0a337d96">
        <source>doExtractAll();
/*
Purpose:			
Date		Who		Reason
06 July 2017	cnwab1	Initial creation
// ### JIRA 33543 12DEC2024 NAVAB1 change to use constants
*/
constants
	DELIM = '","';
vars
	tmpClient		: DEV_LicenseClient;
	tmpDtl			: DEV_LicenseDtl;
	line : String;
	file : File;
    permAgent : CM_PermissionAgent;
	tmpIgnore : Boolean;
    permObj : CM_PermissionObject;
    tmpValue : Integer;
    canDoStr : String;
	date : Date;
begin
	app.mousePointer := MousePointer_HourGlass;
	
	create file transient;
	
	
	if self.currentLicenseType = DEV_LicenseEntity.LicenseType_EDI then
		doExtractEDI();
		return;
	// ### JIRA 33543 12DEC2024 NAVAB1
	elseif self.currentLicenseType = DEV_LicenseEntity.LicenseType_EWS then
		self.doExtractEWS();
		return;
	elseif self.currentLicenseType = DEV_LicenseEntity.LicenseType_System then
		doExtractJMT();
		return;
	// ### JIRA 33543 16DEC2024 NAVAB1
	elseif self.currentLicenseType = DEV_LicenseEntity.LicenseType_Subscription then
		doExtractSUB();
		return;
	else
		return;
	endif;
	
epilog
	file.close();
		
	app.mousePointer := MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doExtractEDI" id="f5fc8ad5-5d57-4158-ba94-2aecc9fce0e4">
        <source>doExtractEDI();
/*
Purpose:			
Date		Who		Reason
06 July 2017	cnwab1	Initial creation
// ### JIRA 33543 12DEC2024 NAVAB1 change to use constants
*/
constants
	DELIM = '","';

vars
	tmpClient		: DEV_LicenseClient;
	tmpDtl			: DEV_LicenseDtl;
	ediAgent	: CM_EDIFileTypeAgent;
	ediFileType	: CM_EDIFileType;
	camDescType	: CM_CamProtocolDesc;
	canDoStr, line, filename 	: String;
	idx,
	color1,
	color2,
	theColor,
	tmpValue	: Integer;
	file : File;
 
begin
	app.mousePointer := MousePointer_HourGlass;

	create file transient;
	filename := "C:\temp\" &amp; ProductStr_JMT_EDI &amp; "-All.csv";
	file.openOutput(filename);
	

	ediAgent := self.myEDIFileTypeAgent;

	line := '"Client","LicenseType","Expiry';
	
	foreach ediFileType in ediAgent.allEDIFileTypes do

		line := line &amp; DELIM &amp; ediFileType.name;
	
	endforeach;
	foreach camDescType in ediAgent.allCAMProtocolDescs do

		line := line &amp; DELIM &amp; camDescType.name;
	endforeach;
	
	line := line &amp; '"';
	file.writeLine(line);
	
	foreach tmpClient in self.allClients do : clientloop
	
		tmpDtl := tmpClient.allLicenseDtls.getAtKeyGeq(2,"");
		
		if tmpDtl= null then
			continue;
		endif;
		
		line := '"' &amp; tmpClient.name &amp; DELIM &amp; ProductStr_JMT_EDI 
				&amp; DELIM &amp; tmpDtl.expiryDate.formatAsYYYYMMDD;
		

		foreach ediFileType in ediAgent.allEDIFileTypes do
			tmpValue := ediFileType.type;
			
			canDoStr := 'No';	// so as unchecked
			if tmpDtl &lt;&gt; null then
				if tmpDtl.canDo(tmpValue) then
					canDoStr := 'Yes';	// so as checked
				endif;
			endif;
			
			line := line &amp; DELIM &amp; canDoStr;
	
			
		endforeach;
			
		
		foreach camDescType in ediAgent.allCAMProtocolDescs do
			tmpValue := camDescType.type;
			
			canDoStr := 'No';	// so as unchecked
			if tmpDtl &lt;&gt; null then
				if tmpDtl.canDo(tmpValue) then
					canDoStr := 'Yes';	// so as checked
				endif;
			endif;
			
			line := line &amp; DELIM &amp; canDoStr;
	
			
		endforeach;

		line := line &amp; '"';
		file.writeLine(line);
		
	endforeach;
epilog
	file.close();
	app.msgBox("Extract Complete. File is Called" &amp; CrLf &amp; filename,"Finished",MsgBox_OK_Only);
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doExtractEWS" id="23445572-8c32-4581-8157-c37d209cbbf1">
        <source>doExtractEWS();
/*
Purpose - 	
Who - NAVAB1
Date - 12DEC2024
ADO - JIRA 33543
*/

constants
	DELIM = '","';

vars
	tmpClient		: DEV_LicenseClient;
	tmpDtl			: DEV_LicenseDtl;
	ewsAgent	: CM_EWSTypeAgent;
	ewsType	: CM_ExternalWebServiceType;
	endpointType	: CM_EWSEndpointType;
	canDoStr, expStr, line, filename 	: String;
	idx,
	color1,
	color2,
	theColor,
	tmpValue	: Integer;
	file : File;
	expDate : Date;
begin
	app.mousePointer := MousePointer_HourGlass;

	create file transient;
	filename := "C:\temp\" &amp; ProductStr_EWS &amp; "-All.csv";
	file.openOutput(filename);
	

	ewsAgent := self.myEWSTypeAgent;

	line := '"Client","NumTerms","SiteLicense","RealClient","Expiry","Notes","LicenseType';
	
	foreach ewsType in ewsAgent.allEWSTypesByType do

		line := line &amp; DELIM &amp; ewsType.name;
	
	endforeach;
	foreach endpointType in ewsAgent.allEWSEndpointTypeByType do

		line := line &amp; DELIM &amp; endpointType.name;
	endforeach;
	
	line := line &amp; '"';
	file.writeLine(line);
	
	foreach tmpClient in self.allClients do : clientloop
	
		tmpDtl := tmpClient.allLicenseDtls[DEV_LicenseEntity.LicenseType_EWS, tmpClient.name];
		if tmpDtl= null then
			continue clientloop;		// No EWS modules at all
		endif;
		
		line := '"' &amp; tmpClient.name &amp; DELIM &amp; tmpClient.numTerminals.String &amp; DELIM &amp; 
				tmpClient.hasSiteLicense.String &amp; DELIM &amp; tmpClient.isRealClient.String &amp; DELIM &amp; 
				tmpDtl.expiryDate.formatAsYYYYMMDD &amp; DELIM &amp; tmpClient.notes &amp; DELIM &amp; ProductStr_EWS ;
		

		foreach ewsType in ewsAgent.allEWSTypesByType do
			tmpValue := ewsType.type;
			
			canDoStr := 'No';	// so as unchecked
			expStr := "";
			if tmpDtl &lt;&gt; null then
				if tmpDtl.canDo(tmpValue) then
					canDoStr := 'Yes';	// so as checked
					expDate := tmpDtl.getSubscriptionExpDate(tmpValue);
					expStr := expDate.formatAsYYYYMMDDCSV();
					if expStr &lt;&gt; null then
						expStr := ":" &amp; expStr;
					endif;
				endif;
			endif;
			
			line := line &amp; DELIM &amp; canDoStr &amp; expStr;
	
			
		endforeach;
			
		
		foreach endpointType in ewsAgent.allEWSEndpointTypeByType do
			tmpValue := endpointType.type;
			
			canDoStr := 'No';	// so as unchecked
			expStr := "";
			if tmpDtl &lt;&gt; null then
				if tmpDtl.canDo(tmpValue) then
					canDoStr := 'Yes';	// so as checked
					expDate := tmpDtl.getSubscriptionExpDate(tmpValue);
					expStr := expDate.formatAsYYYYMMDDCSV();
					if expStr &lt;&gt; null then
						expStr := ":" &amp; expStr;
					endif;
				endif;
			endif;
			
			line := line &amp; DELIM &amp; canDoStr;
	
			
		endforeach;

		line := line &amp; '"';
		file.writeLine(line);

	endforeach;
epilog
	file.close();
	app.msgBox("Extract Complete. File is Called" &amp; CrLf &amp; filename,"Finished",MsgBox_OK_Only);
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doExtractJMT" id="d8631b10-5031-4382-916b-d825c1cc2bdf">
        <source>doExtractJMT();
/*
Purpose:			
Date		Who		Reason
06 July 2017	cnwab1	Initial creation
*/
constants
	DELIM = '","';
vars
	tmpClient		: DEV_LicenseClient;
	tmpDtl			: DEV_LicenseDtl;
	line : String;
	file : File;
    permAgent : CM_PermissionAgent;
	tmpIgnore : Boolean;
    permObj : CM_PermissionObject;
    tmpValue : Integer;
    canDoStr, filename : String;
	date : Date;
begin
	app.mousePointer := MousePointer_HourGlass;
	
	create file transient;
	
	filename := "C:\temp\" &amp; $JMTSystemLicense &amp; "-All.csv";
	file.openOutput(filename);
	
	
	
	permAgent := self.myPermissionAgent;
	
	line := '"Client","NumTerms","SiteLicense","RealClient","Expiry","Notes","LicenseType';
	
	foreach permObj in permAgent.allPermissionsByName do
		tmpValue := permObj.constValue;
		if tmpValue = Mod_BaseView or
			tmpValue = PmNum01 or
			tmpValue = PmNum02 or
			tmpValue = PmNum03 or
			tmpValue = PmNum04 or
			tmpValue = PmNum05 or
			tmpValue = PmNum06 or
			tmpValue = PmNum07 or
			tmpValue = PmNum08 or
			tmpValue = PmNum09 or
			tmpValue = PmNum10 or
			tmpValue = PmAdmInternal or
			tmpValue = PmSite then
			continue;
		endif;

		line := line &amp; DELIM &amp; permObj.description;
	
	endforeach;
	
	line := line &amp; '"';
	
	file.writeLine(line);
	
	
	foreach tmpClient in self.allClients do : clientloop
		
		foreach tmpDtl in tmpClient.allLicenseDtls where tmpDtl.type = 1  do : licenseloop
			line := '"' &amp; tmpClient.name &amp; DELIM &amp; tmpClient.numTerminals.String &amp; DELIM &amp; 
					tmpClient.hasSiteLicense.String &amp; DELIM &amp; tmpClient.isRealClient.String &amp; DELIM &amp; 
					tmpDtl.expiryDate.formatAsYYYYMMDD &amp; DELIM &amp; tmpClient.notes &amp; DELIM &amp; $JMTSystemLicense;
		
			
			foreach permObj in permAgent.allPermissionsByName do : permloop
				tmpValue := permObj.constValue;
				
				canDoStr := 'No';	// so as unchecked
				if self.getValueForSysTermPermission(tmpDtl, tmpValue, tmpIgnore, date) then
					canDoStr := 'Yes';	// so as checked
				endif;
				
				if tmpIgnore then
					continue permloop;
				endif;
				line := line &amp; DELIM &amp; canDoStr;
				
				if date &lt;&gt; null then	//17 Jun 2020	NDL	TFS 49569
					line := line &amp; DELIM &amp; date.format('ddMMMyyy');
				endif;
			
			endforeach;

		endforeach;
	
		line := line &amp; '"';
		file.writeLine(line);

	
	endforeach;
epilog
	file.close();
	app.msgBox("Extract Complete. File is Called" &amp; CrLf &amp; filename,"Finished",MsgBox_OK_Only);
	app.mousePointer := MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doExtractSUB" id="ee69ab34-15f4-43bf-9e73-1f9c4e2caf51">
        <source>doExtractSUB();
/*
Purpose - 	
Who - NAVAB1
Date - 16DEC2024
ADO - JIRA 33543
*/

constants
	DELIM = '","';
vars
	tmpClient		: DEV_LicenseClient;
	tmpDtl			: DEV_LicenseDtl;
	line : String;
	file : File;
    permAgent : CM_PermissionAgent;
	tmpIgnore : Boolean;
    permObj : CM_PermissionObject;
    tmpValue : Integer;
    canDoStr, filename : String;
	date : Date;
	expStr : String;

begin
	app.mousePointer := MousePointer_HourGlass;
	
	create file transient;
	
	filename := "C:\temp\" &amp; ProductStr_SUBS &amp; "-All.csv";
	file.openOutput(filename);
	
	
	
	permAgent := self.mySubscriptionPermAgent;
	
	line := '"Client","NumTerms","SiteLicense","RealClient","Expiry","Notes","LicenseType';
	
	foreach permObj in permAgent.allPermissionsByName do
		tmpValue := permObj.constValue;
		if tmpValue = Mod_BaseView or
			tmpValue = PmNum01 or
			tmpValue = PmNum02 or
			tmpValue = PmNum03 or
			tmpValue = PmNum04 or
			tmpValue = PmNum05 or
			tmpValue = PmNum06 or
			tmpValue = PmNum07 or
			tmpValue = PmNum08 or
			tmpValue = PmNum09 or
			tmpValue = PmNum10 or
			tmpValue = PmAdmInternal or
			tmpValue = PmSite then
			continue;
		endif;

		line := line &amp; DELIM &amp; permObj.description;
	
	endforeach;
	
	line := line &amp; '"';
	
	file.writeLine(line);
	
	
	foreach tmpClient in self.allClients do : clientloop
		
		tmpDtl := tmpClient.allLicenseDtls[DEV_LicenseEntity.LicenseType_Subscription, tmpClient.name];
		if tmpDtl= null then
			continue;		// No Subscription modules at all

		endif;
		
		line := '"' &amp; tmpClient.name &amp; DELIM &amp; tmpClient.numTerminals.String &amp; DELIM &amp; 
				tmpClient.hasSiteLicense.String &amp; DELIM &amp; tmpClient.isRealClient.String &amp; DELIM &amp; 
				tmpDtl.expiryDate.formatAsYYYYMMDD &amp; DELIM &amp; tmpClient.notes &amp; DELIM &amp; $JMTSystemLicense;
	
		
		foreach permObj in permAgent.allPermissionsByName do : permloop
			tmpValue := permObj.constValue;
			
			canDoStr := 'No';	// so as unchecked
			expStr := "";

			if self.getValueForSysTermPermission(tmpDtl, tmpValue, tmpIgnore, date) then
				canDoStr := 'Yes';	// so as checked
				expStr := date.formatAsYYYYMMDDCSV();
				if expStr &lt;&gt; null then
					expStr := ":" &amp; expStr;
				endif;
			endif;
			
			if tmpIgnore then
				continue permloop;
			endif;
			
			line := line &amp; DELIM &amp; canDoStr &amp; expStr;
			
		endforeach;

		line := line &amp; '"';
		file.writeLine(line);
	
	endforeach;
epilog
	file.close();
	app.msgBox("Extract Complete. File is Called" &amp; CrLf &amp; filename,"Finished",MsgBox_OK_Only);
	app.mousePointer := MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doGenerate" id="de68af8a-e1ca-4f2b-b8dc-9123a1d31382">
        <updating/>
        <source>doGenerate() updating, protected;
// ---------------------------------------------------------------------------
// Created:     07 November 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	licSet	: DEV_LicenseDtlSet;

begin

	if self.myCurrentClient = null then
		app.msgBox('You must select a client', 'Error', 0);
		return;
	endif;
	
	// ### JIRA 33502 02DEC2024 NAVAB1
	if not app.name = "DevGetClientLicenseKeys" then
		if app.msgBox("###############################" &amp; CrLf &amp; 
							"########## W A R N I N G ##########" &amp; CrLf &amp; 
							"##############################" &amp; CrLf &amp;  CrLf &amp; 
							"Licenses generated, will only work with" &amp; CrLf &amp; 
							"MTN releases from February 2025 (24.12) onwards" &amp; CrLf &amp;  CrLf &amp; 
							"###############################" &amp; CrLf &amp; 
							"###############################",
							"C A U T I O N  22.0.24.12 &gt;&gt;&gt;&gt;&gt;&gt;",
							MsgBox_OK_Cancel) = MsgBox_Return_Cancel then
			global.beep;
			return;
		endif;
	endif;

	if self.hasClientDetailsChanged or
	   self.hasLicenseDtlsChanged then
		if app.msgBox('Data has changed. You must save before generating.  Save Now?', 'Info', MsgBox_Yes_No + MsgBox_Information_Icon) = MsgBox_Return_Yes then
			if (not self.doSave()) then
				return;
			endif;
		else
			return;
		endif;
	endif;
	
	create licSet transient;
	self.myCurrentClient.allLicenseDtls.copy(licSet);
	
	self.outputLicenses(licSet);

epilog
	delete licSet;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doListExpirySYSSUBS" id="e9850d50-f3e9-404d-a174-d1f337ba57dc">
        <updating/>
        <source>doListExpirySYSSUBS() updating;
/*
Purpose - 	
Who - NAVAB1
Date - 12DEC2025
ADO - JIRA 33502
*/

vars
	permObj : CM_PermissionObject;
	idx, currentRow : Integer;
	dateCheck, subDate : Date;
	client : DEV_LicenseClient;
	license : DEV_LicenseDtl;
	ewsType : CM_ExternalWebServiceType;
	ewsEndpoint : CM_EWSEndpointType;
	modName : String;
begin
	dateCheck := dateCheck.addDays(90);

	write "LICENSES:";
	foreach client in self.allClients do
		foreach license in client.allLicenseDtls where license.type = DEV_LicenseDtl.LicenseType_Subscription do
			if license.expiryDate &lt;= dateCheck then
				write license.name &amp; " " &amp; license.getLicenseName() &amp; " " &amp; license.expiryDate.String;
			endif;
		endforeach;
	endforeach;

	write CrLf &amp; "Subscriptions:";
	
	foreach client in self.allClients do
		foreach license in client.allLicenseDtls where license.type = DEV_LicenseDtl.LicenseType_Subscription do : innerloop
			idx := 1;
			foreach subDate in license.allExpiries do
			
				if subDate.isValid and subDate &lt;= dateCheck then
					permObj := self.mySubscriptionPermAgent.allPermissionsByConstValue[idx + Mod_BaseView];
			
					write license.name &amp; " - " &amp; license.getLicenseName() &amp; " " &amp; permObj.description &amp; " expires on " &amp;  subDate.String;
				endif;
			
				idx += 1;
			endforeach;
			
		endforeach;
	endforeach;

	write CrLf &amp; "External Web Services:";
	
	foreach client in self.allClients do
		foreach license in client.allLicenseDtls where license.type = DEV_LicenseDtl.LicenseType_EWS do : innerloop
			idx := 1;
			foreach subDate in license.allExpiries do
			
				if subDate.isValid and subDate &lt;= dateCheck then
					if idx &gt; 100 then
						ewsEndpoint := self.myEWSTypeAgent.allEWSEndpointTypeByType[idx];
						modName := ewsEndpoint.name;
					else
						ewsType := self.myEWSTypeAgent.allEWSTypesByType[idx];
						modName := ewsType.name;
					endif;
			
					write license.name &amp; " - " &amp; license.getLicenseName() &amp; " " &amp; modName &amp; " expires on " &amp;  subDate.String;
				endif;
			
				idx += 1;
			endforeach;
			
		endforeach;
	endforeach;
	
	write CrLf &amp; "FINISHED";
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doListModuleUsage" id="c96144fc-67c9-4928-88c0-a24f5d9a318b">
        <updating/>
        <source>doListModuleUsage() updating;
/*
Purpose - 	
Who - NAVAB1
Date - 09JAN2025
ADO - JIRA 33502
*/

vars
	permObj : CM_PermissionObject;
	idx, currentRow : Integer;
	 
	client : DEV_LicenseClient;
	license : DEV_LicenseDtl;
begin

	if self.cmbLicenseType.text = ProductStr_JMT 
	or self.cmbLicenseType.text = ProductStr_SUBS then
		self.doListModuleUsageSYSSUBS();
	elseif self.cmbLicenseType.text = ProductStr_JMT_EDI then
		self.doListModuleUsageEDI();
	elseif self.cmbLicenseType.text = ProductStr_EWS then
		self.doListModuleUsageEWS();
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doListModuleUsageEDI" id="ce7312b1-44a6-4652-8c11-64849a713586">
        <updating/>
        <source>doListModuleUsageEDI() updating;
/*
Purpose - 	
Who - NAVAB1
Date - 09JAN2025
ADO - JIRA 33502
*/

vars
	ediType : CM_EDIFileType;
	camsType : CM_CamProtocolDesc;
	obj : Object;
	idx, currentRow : Integer;
	 
	client : DEV_LicenseClient;
	license : DEV_LicenseDtl;
begin
	if not self.chkShowAll.value then
		return;
	endif;
	
	currentRow := self.tblLicense.row;
	
	if currentRow &lt;= self.tblLicense.fixedRows then
		return;
	endif;
	
	self.tblLicense.accessRow(currentRow);
	obj := self.tblLicense.accessedRow.itemObject;
	
	if obj.isKindOf(CM_EDIFileType) then
		ediType := obj.CM_EDIFileType;
		write ediType.name;
		idx := ediType.type;
	elseif obj.isKindOf(CM_CamProtocolDesc) then
		camsType := obj.CM_CamProtocolDesc;
		write camsType.name;
		idx := camsType.type;
	endif;
	
	if obj = null then
		return;
	endif;
	
	write "";
	
	foreach client in self.allClients do
		foreach license in client.allLicenseDtls do : innerloop
			if license.type = self.currentLicenseType then
			
				if idx &lt;= license.allDetails.size then
					if license.allDetails[idx] = true then
						write client.name;
						break innerloop;
					endif;
				endif;
			endif;
		endforeach;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doListModuleUsageEWS" id="3e5ef202-b891-47d1-9578-77032a709f28">
