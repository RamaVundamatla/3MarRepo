<Class name="CnEcWebTestResult" id="62c0498b-198f-4b87-826e-d588450020f8">
    <superclass name="CnEcWebTestEntity"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>___________________________________________________________________________

