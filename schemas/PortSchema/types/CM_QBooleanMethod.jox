    <JadeMethod name="getValueForObject" id="f2aa5b9d-4fd1-4b3a-b09a-026669e7a210">
        <source>getValueForObject(_obj: Object; _op: CM_QueryOperator input): Any;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 November 2009	cnwas3	Initial creation

*/

vars

begin
	if _obj = null then
		return null;
	endif;	
	
	return _obj.sendMsg(self.propertyName).Boolean;

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
        <ReturnType type="Any"/>
    </JadeMethod>
