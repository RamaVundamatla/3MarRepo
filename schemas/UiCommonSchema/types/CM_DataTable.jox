    <JadeMethod name="tryAccessCell" id="59627447-a6f2-40fd-895a-e7d9c95dac69">
        <updating/>
        <source>tryAccessCell(_rowIndex : Integer; _column : Integer) : JadeTableCell updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 August 2025	naviv1	Initial creation

*/

vars

begin
	if _column &lt;&gt; null then
		return self.accessCell(_rowIndex,_column);
	endif;
	return null;
epilog

end;</source>
        <Parameter name="_rowIndex" type="Integer"/>
        <Parameter name="_column" type="Integer"/>
        <ReturnType type="JadeTableCell"/>
    </JadeMethod>
    <JadeMethod name="updateItemObject" id="928622db-ca30-40b2-bb77-b4b63e1c28e1">
        <updating/>
        <source>updateItemObject(_object : Object; _colour1, _colour2 : Integer; _passport : CM_Passport) : Integer updating;
//--------------------------------------------------
// Created:	05 May 2005 By: cnwgd1
//--------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
25/05/2010	cnwcs5	par 24292 - allow for fact that mydataClas may not be set
24 Jul 2025 navhn30 MTN-35315: MTN | Pagination - Work Order Maintenance

*/

vars
	rowIdx		: Integer;
	str	: String;
	failedDAC  :CM_DataAccessController;
	invalid 		: Boolean;
	
begin
//	if (not global.isValidObject(_object)) 
	if _object = null or 
		(self.myDataClass &lt;&gt; null and	// par 24292 cnwcs5 25/05/2010
		not self.myDataClass.hasInstance(_object)) then
		return 0;
	endif;
	
	on Exception do app.handleDeletedObject(exception, _object, invalid);
	//epr TFS 830 changed to handle any object
	str := _object.getAttributeStringForDefArray(self.allTblDataEntRows);
	
	if invalid then
		return 0;
	endif;
	
	if not self.findObjectInRow(_object, rowIdx) then
		//not in table
		if not _object.isKindOf(CM_Object) or _object.CM_Object.canUserAccessSelf(null, failedDAC, _passport) then

			rowIdx := self.addItemObject(_object, str);
			if _colour1 &lt;&gt; null and _colour2 &lt;&gt; null and not self.isPaginated then		//24.07.25	navhn30	 MTN-35315
				if rowIdx mod 2 = 0 then
					self.accessRow(rowIdx).backColor := _colour1;
				else
					self.accessRow(rowIdx).backColor := _colour2;			
				endif;	
			endif;
		endif;
	else
		self.setCellText(rowIdx, 1, str);
	endif;
	
	return rowIdx;
	
end;</source>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_colour1" type="Integer"/>
        <Parameter name="_colour2" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
