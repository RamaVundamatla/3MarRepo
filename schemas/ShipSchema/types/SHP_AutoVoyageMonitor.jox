    <JadeMethod name="chkPauseAutoProcess_click" id="39f42ef5-ac62-4422-a6f1-52ba1258279a">
        <controlMethod name="CMUI_CheckBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkPauseAutoProcess_click(checkbox: CheckBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 September 2024	navra1	Initial creation for //navra1 - CR 65823 - 6th Sep 2024

*/

vars

	pause : Boolean;
	pxyVoyageProgress : CM_VoyageProgress;
	voyStatus : CM_VoyageStatus;						//navra1 - MTN-33086 - 21st Oct 2024
	ediDataList : CM_EDIDataArray;						//navra1 - MTN-33086 - 21st Oct 2024
	ediData : CM_EDIData;								//navra1 - MTN-33086 - 21st Oct 2024
	voyage : CM_Voyage;									//navra1 - MTN-33086 - 21st Oct 2024
	operator : CM_Operator;								//navra1 - MTN-33086 - 21st Oct 2024
	dischargeOperatorsSet,
	loadOperatorsSet : CM_OperatorArray;				//navra1 - MTN-33086 - 21st Oct 2024
	voyageStage : CM_VoyageStage;						//navra1 - MTN-33086 - 21st Oct 2024
	voyageProgress : CM_VoyageProgress;					//navra1 - MTN-33086 - 21st Oct 2024
	foundStage : Boolean;								//navra1 - MTN-33086 - 21st Oct 2024
	ediAgent : CM_EDIControllerAgent;					//navra1 - MTN-34829 - 8th May 2025
	
begin

	if self.myCurrentVoyage &lt;&gt; null and self.myCurrentVoyage.myVoyageProgress &lt;&gt; null then
		pause := self.chkPauseAutoProcess.value;
		pxyVoyageProgress := app.createUpdateProxy(self.myCurrentVoyage.myVoyageProgress).CM_VoyageProgress;	
		app.myTrxUA.trxUpdateVoyageProgress(pxyVoyageProgress, null, null, null, null, pause, app.myPassport);
		delete pxyVoyageProgress;																		//navra1 - MTN-33087 - 23rd Oct 2024
	endif;
	
	//navra1 - MTN-33086 - 21st Oct 2024 - start
	if pause then					//if pause has been checked
		if self.myCurrentVoyage &lt;&gt; null then															//you can change a voyage's progress to "Auto Processing Paused" from any state - the user might want to set if as soon as he creates the voyage
			voyStatus := self.myCurrentVoyage.myVoyageProcess.allStatusesById[Voyage_Status_Autoff_Auto];
			if process.isInTransactionState() then
				app.myUtilityUA.utlUpdateVoyageVoyageStatus(self.myCurrentVoyage, voyStatus.id,false,app.myPassport);
			else
				app.myTrxUA.trxUpdateVoyageVoyageStatus(self.myCurrentVoyage, voyStatus.id,false,app.myPassport);
			endif;			
		endif;
	else						//if pause has been un-checked
		
		if self.myCurrentVoyage &lt;&gt; null then //and self.myCurrentVoyage.status = Voyage_Status_Autoff_Auto then			//you can only change a voyage's progress from "Auto Processing Paused" to "Auto Processing" - not from anything else - //navra1 - MTN-34347/MTN-34395 - 19th Mar 2025 - not anymore
			voyStatus := self.myCurrentVoyage.myVoyageProcess.allStatusesById[Voyage_Status_AutoOn_Auto];
			if process.isInTransactionState() then
				app.myUtilityUA.utlUpdateVoyageVoyageStatus(self.myCurrentVoyage, voyStatus.id,false,app.myPassport);
			else
				app.myTrxUA.trxUpdateVoyageVoyageStatus(self.myCurrentVoyage, voyStatus.id,false,app.myPassport);
			endif;
			
			//navra1 - MTN-33087 - 23rd Oct 2024 - start
			//unpause has been done, so go ahead and delete the accruals cargo first
			
			//FORCE clean up the ACCRUALS cargo on site and on the voyage - only then real data can get loaded since they have the same id
			self.myCurrentVoyage.deleteAccrualsCargo();
			
			voyageProgress := self.myCurrentVoyage.myVoyageProgress;
			
			//now look at the EDIs for this voyage waiting at "Verified Successfully" or "Voyage Paused(tried unsuccessfully to do a DBLoad)"
			//ie. those manifests which havent been DBLoaded since voyage was paused
			create ediDataList transient;		
			self.myCurrentVoyage.getMyVerifiedEDIShipManifests(ediDataList);			
			
			//navra1 - MTN-34829 - 8th May 2025 - start
			create ediAgent transient;
			ediAgent.setTerminal(self.myTerminal);
			//navra1 - MTN-34829 - 8th May 2025 - end
			
			foreach ediData in ediDataList do				
				//navra1 - MTN-34829 - 8th May 2025 - start		
				//we need to verify the ediData again since it might have already been worked and this might be a duplicate that was verified,
				//so check and skip if required
				ediAgent.verifyEdiData(ediData);
				
				if ediData.status = CM_EDIFile.EDI_STATUS_VERIFIED or ediData.status = CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS then				
					if ediData.myEDIFile &lt;&gt; null and ediData.myEDIFile.myEDIFileType &lt;&gt; null and ediData.myEDIFile.myEDIFileType.isIFCSUM() then
						app.myPassport.setContext(Context_Pass_EDI_IFSUM_Load);
					endif;
					
					ediData.loadDB(false, app.myPassport);
					app.myPassport.setContext(Context_Pass_Null);
					
					//you tried db loading, maybe it was successful, maybe not, do the auto voyage progression	with the edi				
					if ediData.CM_EDIDataShipManifest.isShipManifestForLoad() then
						voyageProgress.progressStage(CM_VoyageStage.VoyStage_LoadManLoad, ediData, null, CM_VoyageStage.Type_Load);					//navra1 - MTN-34829 - 8th May 2025
					else
						voyageProgress.progressStage(CM_VoyageStage.VoyStage_DischManLoad, ediData, null, CM_VoyageStage.Type_Discharge);					//navra1 - MTN-34829 - 8th May 2025
					endif;
				else
					app.writeLog("The previously verified ship manifest	("&amp;ediData.myEDIFile.fileName &amp; ", uploaded at "  &amp; ediData.myEDIFile.createdTime.String &amp; "), is now failing verification and is being skipped!", LogERROR);
				endif;
				//navra1 - MTN-34829 - 8th May 2025 - end
			endforeach;			
			
			//now look at the EDIs for this voyage that have already been DBLoaded
			//ie. those manifests which have been DBLoaded before the voyage was paused
			ediDataList.clear();			
			self.myCurrentVoyage.getMyDBLoadedEDIShipManifests(ediDataList);
			
			foreach ediData in ediDataList do				
				//this ediData is already DBLoaded
				//check if this manifest has already been processed fully(operator still in the list of operators we maintain)				
				
				//for each of the edidata that have been DBLoaded and is associated with this voyage and the actual operations are still pending (ie. the 
				//operator is found in the list of load/discharge) operators we maintain, trigger the DBLoad stage for the manifest, which will trigger 
				//all the other operations, if the load list is not available, it will complain and create a FAILED line, if it was available it will continue 
				//to do the other steps and complete the load/discharge operation. If the load/dischage list was available but not the manifest, it will be 
				//done when the manifest is loaded)
				operator := app.myRoot.allOperators[ediData.CM_EDIDataShipManifest.getCargoOperatorForShipManif()];	

				if ediData.isShipManifestForLoad() then
					if voyageProgress.allCargoLoadOperators.includes(operator) then					
						voyageProgress.progressStage(CM_VoyageStage.VoyStage_LoadManLoad, ediData, null, CM_VoyageStage.Type_Load);					//navra1 - MTN-34829 - 8th May 2025
					endif;
				else
					if voyageProgress.allCargoDischargeOperators.includes(operator) then
						voyageProgress.progressStage(CM_VoyageStage.VoyStage_DischManLoad, ediData, null, CM_VoyageStage.Type_Discharge);					//navra1 - MTN-34829 - 8th May 2025
					endif;
				endif;				
			endforeach;			
			//navra1 - MTN-33087 - 23rd Oct 2024 - end			
		endif;
	endif;	
	//navra1 - MTN-33086 - 21st Oct 2024 - end
	
epilog
	delete pxyVoyageProgress;								//navra1 - MTN-33086 - 21st Oct 2024
	delete ediDataList;
	delete ediAgent;										//navra1 - MTN-34829 - 8th May 2025
	app.myPassport.setContext(Context_Pass_Null);			//navra1 - MTN-33087 - 23rd Oct 2024
end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
