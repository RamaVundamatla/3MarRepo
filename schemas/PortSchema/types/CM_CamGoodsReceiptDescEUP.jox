    <JadeMethod name="availableEvents" id="347e77df-32a6-4565-8cc5-c8e079be6320">
        <source>availableEvents(_eventList: IntegerArray input);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 14 June 2023
TFS#		: 58506
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	event : CM_EventType;
begin
	_eventList.add(EVT_TruckDeparture);
	_eventList.add(EVT_VoyageDeparture);
	_eventList.add(EVT_TrainDepart);
	
	foreach event in app.myRoot.allEventTypesByType do 
		if event.isUserDefined() then
			if event.category &lt;&gt; CM_EventType.TRAIN_EVENT and
			   event.category &lt;&gt; CM_EventType.TRUCK_EVENT and
			   event.category &lt;&gt; CM_EventType.VOYAGE_EVENT then
				continue;
			endif;
				
			_eventList.add(event.type);
		endif;
	endforeach;
end;</source>
        <Parameter name="_eventList" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="availableTransactions" id="a90b5761-027f-4c16-b5bc-4e3cdd4386bb">
        <source>availableTransactions(_classColl: ClassColl io);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 14 June 2023
TFS#		: 58506
Function	:

*** Changes ***
Date			Name		TFS#		Description
13/11/2024		navcs2		MTN-33410 EUP | FR 53853 - NTO-1054 - Shortlanded is not sent in the GoodsReceipt Message
12 Mar 2025		naviv1		MTN-34323 EUP FR | Discrepancy Ship transaction is missing from Goods Receipt CAM Protool
****************************************************/

vars

begin
	_classColl.add(CM_Move);
	_classColl.add(CM_ReceiveRail);
	_classColl.add(CM_ReceiveRoad);
	_classColl.add(CM_ReceiveShip);
	_classColl.add(CM_Unpack);
	_classColl.add(CM_BBDiscrepancy);
	_classColl.add(CM_OverLanded);
	_classColl.add(CM_ShortLanded);		// 13/11/2024		navcs2		MTN-33410
	_classColl.add(CM_ShipDescrepancy); //JIRA-34323
epilog

end;</source>
        <Parameter name="_classColl" type="ClassColl" usage="io"/>
    </JadeMethod>
    <JadeMethod name="buildEventFile" id="291bc4b5-7469-40ae-ba1f-53a72e02b778">
        <updating/>
        <source>buildEventFile(_camProtocol: CM_CamProtocol input; _camAgent: CM_CamControllerAgent input; _seqNumber: Integer; _unhSeqNumber: Integer io; _terminal: CM_Terminal) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 26 June 2023
TFS#		: 58506
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	allEventTrans			: CM_EventTransByDateTime;
	lastTS   				: TimeStamp;
	seqNo					: Integer;
	transaction				: CM_EventTransaction;
    camFile         		: CM_CamFile;
	camTaskHistory			: CM_CamTaskHistory;
	iterStartTS , 
	startTS, endTS			: TimeStamp;
	transCount				: Integer;
	iter					: Iterator;
	daysToLookBack			: Integer;
	trProcessDateTime		: TimeStamp;
	logExcludedTransaction	: Boolean;
	isFirstTime 			: Boolean;
begin
	seqNo := _seqNumber;
	iter := _terminal.allEventTransactionsByCamsTS.createIterator;
	startTS := _camAgent.startDateTime;	
	endTS := _camAgent.endDateTime;	
	logExcludedTransaction := _camAgent.logExcludedTransactions;
	iterStartTS := startTS;
	create allEventTrans transient;
	create camFile transient;	
	_terminal.allEventTransactionsByCamsTS.startKeyGeq(iterStartTS, iter);

	while iter.next(transaction) do
		if transaction.camsTimeStamp &gt; endTS then
			break;
		endif;
				
		if not transaction.isValidForCamsProcess(startTS, daysToLookBack, trProcessDateTime) then 	
			if logExcludedTransaction then
				_camAgent.logReasonForExclusion (transaction, 'Event transaction was created prior to CAMS start date/time');
			endif;
			continue;
		endif;
		
		transCount := transCount + 1;
		
		if transCount mod 100 = 0 then
			app.writeLog(_camProtocol.code &amp; " Event " &amp; transaction.camsTimeStamp.String &amp; ".", LogWARN);
		endif;
		
		// makes sense to exclude events of the incorrect type 1st
		if not self.isEventTypeToBeProcessed(_camProtocol, transaction) then
			if logExcludedTransaction then
				_camAgent.logReasonForExclusion (transaction, 'Event transaction type does not match CAM proctocol event types');
			endif;
			continue;
		endif;
		
		// we want it
		if _camAgent.logIncludedTransactions then
			_camAgent.logReasonForInclusion(transaction, "Event is correct time period and in Event Type list");
		endif;		
		allEventTrans.add(transaction);
	endwhile;

	if allEventTrans.size = 0 then	// Nothing found 
		app.writeLog(_camProtocol.code &amp; " no events found", LogWARN);
		return;
	endif;
	
	// Process the transactions
	lastTS := null;
	isFirstTime := true;
	foreach transaction in allEventTrans do			// These are now in date seq
		self.processEvent(transaction, _camProtocol, _camAgent, camFile);
				
		if lastTS &lt;&gt; null and lastTS &lt;&gt; transaction.camsTimeStamp then
			// Its okay to update the timestamp now	### incomplete how can we do this???? done in task history but need to know that a trans is the last one for the time stamp####
			lastTS := transaction.camsTimeStamp;
		endif;
			
		if _camProtocol.isSingleTransPerFile and _camAgent.processSeqNumber &lt;&gt; Adhoc_Key then 
			// Create one file for EACH transaction
			if camFile.camVoyages.size &gt; 0 then
				if not isFirstTime then
					self.createNextCamTaskHistory(_camAgent, _camProtocol, seqNo);
				endif;
				isFirstTime	:= false;				
				app.myTrxUA.trxSetupCamTaskHistory(_camProtocol, _camAgent, camFile, _camAgent.runDateTime, camTaskHistory, _unhSeqNumber, seqNo, _terminal, null, null, null);
				camFile.clear();
				seqNo := seqNo + 1;
				_camAgent.setProcessSeqNumber(seqNo);
			endif;
		endif;
	endforeach;
	if _camProtocol.isSingleTransPerFile and _camAgent.processSeqNumber &lt;&gt; Adhoc_Key then 
	else
		app.myTrxUA.trxSetupCamTaskHistory(_camProtocol, _camAgent, camFile, _camAgent.runDateTime, camTaskHistory, _unhSeqNumber, _seqNumber, _terminal, null, null, null);
		if (not app.myPassport.trxCompletedOK) then
			_camAgent.writeCrashLogAlertAndEmail(app.myPassport);
		endif;
	endif;
epilog
	delete allEventTrans;
    delete camFile;
	delete iter;
end;</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol" usage="input"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_unhSeqNumber" type="Integer" usage="io"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="buildFile" id="527d44c6-db45-4412-bad1-a0e54579aceb">
        <updating/>
        <source>buildFile(_camProtocol: CM_CamProtocol input; _camAgent: CM_CamControllerAgent input; _seqNumber: Integer; _unhSeqNumber: Integer io; _terminal: CM_Terminal) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 14 June 2023
TFS#		: 58506
Function	:

*** Changes ***
Date			Name		TFS#		Description
25/09/2023		navdap1		60365		EUP | FR 53853 - Goods Receipt Message Grouping
24/10/2023		navdap1		TFS 60390	EUP | FR 53824 - Goods/Good/ID and Item grouping
****************************************************/
vars
	camFile 				: CM_CamFile;
	camGroup				: CM_CamGroup;
	transaction 			: CM_TITransaction;
	camTaskHistory 			: CM_CamTaskHistory;
	startTS, endTS			: TimeStamp;
	coll					: CM_TITransactionByDtOrdTiDict;
	typeColl				: IntegerArray;
	iter 					: Iterator;
	logExcludedTransaction	: Boolean;		
	transType				: Integer;
	seqNo					: Integer;
	isFirstTime				: Boolean;
	object					: Object;						// TFS 60365
	goodsReceipt			: CMIF_JsonGoodsReceiptEUP;		// TFS 60365
	goodsById				: DynaDictionary;					// TFS 60390
	transport				: CMIF_JsonTransportFullEUP;		// TFS 60390
	good					: CMIF_JsonGoodEUP;					// TFS 60390
begin
	if self.isEventType() then
        self.buildEventFile(_camProtocol, _camAgent, _seqNumber, _unhSeqNumber, _terminal);
		if not _camProtocol.protocolDesc.isAlsoTransactionType then
			return;
		endif;
    endif;
	
	seqNo					:= _seqNumber;
	isFirstTime 			:= 	true;
   
	create camFile transient;
	create coll transient;
	
	camGroup				:= _camProtocol.camGroup;
	startTS					:= _camAgent.startDateTime;
	endTS					:= _camAgent.endDateTime;
	logExcludedTransaction	:= _camAgent.logExcludedTransactions;
	
	iter := _terminal.allTITransactionsByCamsTS.createIterator();

	create typeColl transient;
	
	self.getTransactionTypesToProcess (_camProtocol, typeColl);
	
	// build up colection with all transactions os required type/dates in a collection
	foreach transType in typeColl do
		// str in the transaction type (integer)
		iter.reset;
		
		_terminal.allTITransactionsByCamsTS.startKeyGeq(transType, startTS, iter);
		
		while iter.next (transaction) do
			if transaction.type &lt;&gt; transType or
				transaction.camsTimeStamp &gt; endTS then 
				break;
			endif;
			
			coll.add (transaction);
		endwhile;
	endforeach;
	
	delete iter;
	
	iter := coll.createIterator;
	
	while iter.next(transaction) do		
		// makes sense to exclude transaction of the incorrect type 1st
		if self.includeTransaction (transaction, transaction.camsTimeStamp, startTS, endTS, 
									_camProtocol, camGroup, _camAgent, logExcludedTransaction, null) then
			
			
			//if true and _camAgent.processSeqNumber &lt;&gt; Adhoc_Key then		// TFS 60365
			if _camAgent.processSeqNumber &lt;&gt; Adhoc_Key then					// TFS 60365
				if self.isTransactionToBeProcessed(_camProtocol, transaction, _camAgent) then 		
					// TFS 60365 Leave cam history creation until we have all the JSON objects on the controller
					//if not isFirstTime then
					//	self.createNextCamTaskHistory(_camAgent, _camProtocol, seqNo);
					//endif;
					//isFirstTime := false;
					
					if _camAgent.logIncludedTransactions then
						_camAgent.logReasonForInclusion(transaction, "Transaction is correct time period and in Transaction Type list");
					endif;
					self.processTransaction(transaction, _camProtocol, _camAgent, camFile);				
					app.writeLog(method.qualifiedName &amp; Tab &amp; ' tr=' &amp; transaction.String &amp; ' ti=' &amp; transaction.myTrackedItem.String &amp; ' ' &amp; transaction.myTrackedItem.id, LogDEBUG);
					
					// TFS 60365 Leave cam history creation until we have all the JSON objects on the controller
					//self.buildFileExtra (transaction, _camProtocol, _camAgent, camFile);
					//app.myTrxUA.trxSetupCamTaskHistory(_camProtocol, _camAgent, camFile, _camAgent.runDateTime, camTaskHistory, _unhSeqNumber, seqNo, _terminal, null, null, null);
					//camFile.clear();
					//seqNo := seqNo + 1;
					//_camAgent.setProcessSeqNumber(seqNo);
				endif;
				
			else	// Ad-Hoc, as this can only go against history 0!
				// reasons for excluding have been logged in self.includeTransaction
				if self.isTransactionToBeProcessed(_camProtocol, transaction, _camAgent) then 												
					if _camAgent.logIncludedTransactions then
						_camAgent.logReasonForInclusion(transaction, "Transaction is correct time period and in Transaction Type list");
					endif;
					self.processTransaction(transaction, _camProtocol, _camAgent, camFile);				
					app.writeLog(method.qualifiedName &amp; Tab &amp; ' tr=' &amp; transaction.String &amp; ' ti=' &amp; transaction.myTrackedItem.String &amp; ' ' &amp; transaction.myTrackedItem.id, LogDEBUG);
				endif;
				
				// some protocols do extra processing so this is implemented in the buildFileExtra method 
				self.buildFileExtra (transaction, _camProtocol, _camAgent, camFile);
			endif;
		endif;
	endwhile;
	
	// TFS 60390 create a dyna dict to resort good objects by ID
	create goodsById transient;
	goodsById.setMembership(CMIF_JsonGoodEUP);
	goodsById.addExternalKey(String, 30, false, true);		// ID
	goodsById.endKeys(true);
	// TFS 60390 end of this bit
	
	//if true and _camAgent.processSeqNumber &lt;&gt; Adhoc_Key then		// TFS 60365
	if _camAgent.processSeqNumber &lt;&gt; Adhoc_Key then					// TFS 60365
		// TFS 60365 Now that we have all the message objects in _camAgent.allJsonGoodsReceipt, do the actual output
		app.writeLog(method.qualifiedName &amp; Tab &amp; "there are " &amp; _camAgent.allJsonGoodsReceipt.size.String &amp; " items in _camAgent.allJsonGoodsReceipt", LogINFO);
		foreach object in _camAgent.allJsonGoodsReceipt do
			goodsReceipt := object.CMIF_JsonGoodsReceiptEUP;
			if not isFirstTime then
				self.createNextCamTaskHistory(_camAgent, _camProtocol, seqNo);
			endif;
			isFirstTime := false;
			
			self.buildFileExtra (null, _camProtocol, _camAgent, camFile);
			
			// TFS 60390 resort the good objects for this transport
			foreach transport in goodsReceipt.transports do
				goodsById.clear;
				foreach good in transport.goods do
					goodsById.putAtKey(good.iD, good);
				endforeach;
				transport.goods.clear;
				goodsById.copy(transport.goods);
			endforeach;
			// TFS 60390 end of this bit
			
			app.myTrxUA.trxSetupCamTaskHistory(_camProtocol, _camAgent, camFile, _camAgent.runDateTime, camTaskHistory, _unhSeqNumber, seqNo, _terminal, null, goodsReceipt, null);
			camFile.clear();
			seqNo := seqNo + 1;
			_camAgent.setProcessSeqNumber(seqNo);
		endforeach;
		// TFS 60365 end of this bit
	else
		// TFS 60390 ad-hoc processing - resort things
		goodsReceipt := _camAgent.allJsonGoodsReceipt.first.CMIF_JsonGoodsReceiptEUP;
		if goodsReceipt &lt;&gt; null then
			foreach transport in goodsReceipt.transports do
				goodsById.clear;
				foreach good in transport.goods do
					goodsById.putAtKey(good.iD,	good);
				endforeach;
				transport.goods.clear;
				goodsById.copy(transport.goods);
			endforeach;
		endif;
		// TFS 60390 end of this bit
		
		// this next bit creates the CAMS file and updates the CAM protocol history
		app.myTrxUA.trxSetupCamTaskHistory(_camProtocol, _camAgent, camFile, _camAgent.runDateTime, camTaskHistory, _unhSeqNumber, _seqNumber, _terminal, null, null, null);
		if (not app.myPassport.trxCompletedOK) then
			_camAgent.writeCrashLogAlertAndEmail(app.myPassport);
		endif;
	endif;
epilog
	delete camFile;
	delete iter;
	delete coll;
	delete typeColl;
	delete goodsById;		// TFS 60390
end;</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol" usage="input"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_unhSeqNumber" type="Integer" usage="io"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="checkSpecialLocation" id="7f48f053-a5b8-4757-856e-7d14748ef0f5">
        <source>checkSpecialLocation(_location : CM_LocationsController) : Boolean protected;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 11 July 2023
TFS#		: 58636
Function	: Only check if the terminal area type is one of the special type

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	parentTILC 			: CM_Object;
	terminalArea 		: CM_TerminalArea;
	terminalAreaType 	: Integer;	
begin
		terminalArea := _location.getMyTerminalArea();
		if terminalArea &lt;&gt; null then
			terminalAreaType := terminalArea.type;
		endif;
		
		if terminalAreaType = null then
			if _location.isKindOf(CM_VoyageController) then
				return true;
			elseif _location.isKindOf(CM_WagonController) then	
				return true;
			elseif _location.isKindOf(CM_VehicleController) then	
				return true;
			elseif _location.isKindOf(CM_TILCController) then
				parentTILC := _location.getParent();
				if parentTILC.isKindOf(CM_VehicleController) then
					return true;
				else
					return false;
				endif;
			else//meaning it is not one of Special Location
				return false;
			endif;				
		endif;
		
		if terminalAreaType = CM_CamsMoveTATypeCritieria.AnyArea then			
			return true;
		elseif terminalAreaType = CM_CamsMoveTATypeCritieria.VoyageArea and _location.isKindOf(CM_VoyageController) then
			return true;
		elseif terminalAreaType = CM_CamsMoveTATypeCritieria.WagonLocation and _location.isKindOf(CM_WagonController) then	
			return true;
		elseif terminalAreaType = CM_CamsMoveTATypeCritieria.TruckArea and _location.isKindOf(CM_VehicleController) then	
			return true;
		elseif terminalAreaType = CM_CamsMoveTATypeCritieria.TruckArea and _location.isKindOf(CM_TILCController) then
			parentTILC := _location.getParent();
			if parentTILC.isKindOf(CM_VehicleController) then
				return true;
			else
				return false;
			endif;
		else//meaning it is not one of Special Location
			return false;
		endif;		
end;</source>
        <access>protected</access>
        <Parameter name="_location" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
