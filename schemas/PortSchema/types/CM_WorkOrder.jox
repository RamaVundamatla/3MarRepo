    <JadeMethod name="setProxyWorkOrderSource" id="baa9fd43-70eb-4436-b6a2-914914cb0516">
        <source>setProxyWorkOrderSource(
		_realWOSource : CM_WorkOrderTISource;  //This will only need to be set for persistent objects
		_parent : CM_Object; 
		_cargoType : CM_CargoType; 
		_tiStr : String; 
		_forUpdate : Boolean
		) : CM_WorkOrderTISource;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 August 2009	cnwmd1	Initial creation

*/

vars
	newProxy : CM_WorkOrderTISource;
	cargoTypeId : Integer;
begin
	if _cargoType &lt;&gt; null then
		cargoTypeId := _cargoType.id;
	endif;
	
	if _forUpdate and _realWOSource &lt;&gt; null then
		newProxy := _realWOSource.pxyCreateUpdateProxy(); //Update proxy from real
	else
		create newProxy transient;
		newProxy.setProxy(cargoTypeId, _tiStr);
	endif;
	
	newProxy.setMyParent(_parent);
	return newProxy;
epilog

end;</source>
        <Parameter name="_realWOSource" type="CM_WorkOrderTISource"/>
        <Parameter name="_parent" type="CM_Object"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_tiStr" type="String"/>
        <Parameter name="_forUpdate" type="Boolean"/>
        <ReturnType type="CM_WorkOrderTISource"/>
    </JadeMethod>
    <JadeMethod name="setProxyWorkOrderTask" id="965cf9d3-6126-4b04-9ca9-cdf2b859adee">
        <source>setProxyWorkOrderTask(	_pxyWODtl 	    : CM_WorkOrderDtl input;
						_reqByDT, 
						_startDT		: TimeStamp;
						_autoQueueTask  : Boolean;
						_taskId 		: Integer;
						_toDoTask 		: CM_ToDoTaskDesc
						);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 Aug 2009	cnwmd1	Initial creation
17 Nov 2022 navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs
24 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
24 Mar 2023 navhl20 ChangeRequest 57301:[57303] EUP - [Framework] - Improve Audits on Work orders
*/

vars
	
begin
	_pxyWODtl.setProxyForCreate(self, _taskId);
	//_pxyWODtl.setProxy(_reqByDT, _startDT, _autoQueueTask); //Base details		//24.3.2023 navhl20	#57301[57303]
	_pxyWODtl.setRequiredByDT(_reqByDT);											//24.3.2023 navhl20	#57301[57303]

	//Set the proxy for the appropriate type
	if _pxyWODtl.isKindOf(CM_WodToDo) then
		_pxyWODtl.CM_WodToDo.setProxyWodToDo(_toDoTask);
		
	// 17/11/2022  navcs2	ChangeRequest 54344
	elseif _pxyWODtl.isKindOf(CM_WorkOrderToDoDtl) then
		if _toDoTask &lt;&gt; null then
			_pxyWODtl.CM_WorkOrderToDoDtl.addProxyToDoTask(_toDoTask);
		endif;
	endif;

epilog
	
end;</source>
        <Parameter name="_pxyWODtl" type="CM_WorkOrderDtl" usage="input"/>
        <Parameter name="_reqByDT" type="TimeStamp"/>
        <Parameter name="_startDT" type="TimeStamp"/>
        <Parameter name="_autoQueueTask" type="Boolean"/>
        <Parameter name="_taskId" type="Integer"/>
        <Parameter name="_toDoTask" type="CM_ToDoTaskDesc"/>
    </JadeMethod>
