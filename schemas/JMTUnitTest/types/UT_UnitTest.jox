    <JadeMethod name="getTerminalsUsedAndProfileDtls" id="f58b0999-4cc5-4aa7-a645-1ca47907c2ae">
        <updating/>
        <source>getTerminalsUsedAndProfileDtls(_profileDetails : String; _terminalsUsed : CM_TerminalArray io; _rtnProfile, _rtnTerminals : String output) updating;

/*

Purpose:		Save terminal and profile details	

Date			Who		Reason
13/03/2012		cnwmh5	Initial creation

*/
constants
	UTProfile					: String = "UT_Profile";
vars
	terminal					: CM_Terminal;
	
	pos							: Integer;
	profileStr					: String;
	terminalStr					: String;
begin

	profileStr := _profileDetails;
	pos := profileStr.pos(UTProfile, 1);
	if pos &gt; 0 then
		profileStr := profileStr[pos + UTProfile.length(): end];
	endif;
	pos := 1;
	_rtnProfile := profileStr.scanUntil("/", pos);
	
	if _terminalsUsed &lt;&gt; null then
		_terminalsUsed.removeInvalidObjects();					// 01/07/2015 cnwmh5
		foreach terminal in _terminalsUsed do
			if _rtnTerminals &lt;&gt; null then
				_rtnTerminals := _rtnTerminals.trimBlanks() &amp; ', ';
			endif;
			_rtnTerminals := _rtnTerminals &amp; terminal.code;
		endforeach;
	endif;

epilog
	
end;</source>
        <Parameter name="_profileDetails" type="String"/>
        <Parameter name="_terminalsUsed" type="CM_TerminalArray" usage="io"/>
        <Parameter name="_rtnProfile" type="String" usage="output"/>
        <Parameter name="_rtnTerminals" type="String" usage="output"/>
    </JadeMethod>
