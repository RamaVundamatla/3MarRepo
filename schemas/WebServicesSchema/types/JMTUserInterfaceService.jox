    <JadeMethod name="machineHasControlMessages" id="6038a747-b93d-4575-8a02-a7a5001e47fe">
        <source>machineHasControlMessages() : Boolean ;
/*

Date		Who		Reason
19 June 2017	cnwer1	Initial creation TFS 4620

*/

vars
	iter 			: Iterator;
	history		:CM_MachineHistory;
	infoHistory	 : CM_MachineInfoHistory;
	machine		: CM_Machine;
	lastMessageTS : TimeStamp;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return false ;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
			
	if currentSession = null then
		return false ;
	endif;
	
	machine:=currentSession.myCurrentMachine;
	if currentSession.myCurrentMachine = null then
		return false ;	
	endif;
	
		
	machine:= currentSession.myCurrentMachine;
	lastMessageTS:=machine.lastGetMessagesTS;
	if lastMessageTS = null then	
		
		return false;
	endif;
	
	
	
	iter:=machine.history.createIterator;
	while iter.back(history) do
		
		if history.dateTime &lt; lastMessageTS then
			break;
		endif;
		
		if not history.isKindOf(CM_MachineInfoHistory) then
			continue;
		endif;
		
		infoHistory:= history.CM_MachineInfoHistory;
		if infoHistory.infoType = CM_MachineInfoHistory.InfoType_Status_Change or 
			infoHistory.infoType = CM_MachineInfoHistory.InfoType_Restore_Status then
			continue;
		endif;
		
			//only interested in stuff updated from JMT
		if infoHistory.appName &lt;&gt; JMTerminal then
			continue;
		endif;
		
		return true;
		
	endwhile;
		
	// Got to here, everything is ok

	return false;
	

epilog
	// Tidy up any local transients
	// ...
	delete iter;
	
	
	cnEndTransaction;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeWebServicesMethod name="machineHasIMVTasksChanged" id="9b51812b-13e8-4144-9696-332d6fd39ad6">
        <source>machineHasIMVTasksChanged()  : WS_MachineListChgResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 July 2017	jlger1	Initial creation 5451

*/

vars

	i				: Integer;
	machineTaskState : CM_MachineTaskState;
	task 	: CM_RTQueueTask;
	allTasks : CM_RTQueueTaskArray; 
	machine : CM_Machine;
	completedOK : Boolean;
	response : WS_MachineListChgResponse;
begin
// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Create the response
	create response transient;	
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		completedOK := true;
		return  response ;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
			
	self.validateCurrentMachine(true);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	self.setIgnoreWarnings(true);
	machine:=currentSession.myCurrentMachine;
	
		
	create allTasks transient;
	machine.allCurrentQueueTasks.copy(allTasks);			
	
	//quick test if task size is different 
	if machine.allMachineTaskStates.size &lt;&gt; allTasks.size then
		completedOK := true;
		response.listHasChanged := true;
		return response;
	endif;
	

	i:=1;
	foreach machineTaskState in machine.allMachineTaskStates discreteLock do
		task:=allTasks[i];
		if not machineTaskState.isMatch(task) then
			completedOK := true;
			response.listHasChanged := true;
			return response;
		endif;
		
		i:=i+1;
	endforeach;
	
	response.listHasChanged := false;
	completedOK := true;
	return response;

epilog
	// Tidy up any local transients
	// ...
	delete allTasks;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;	
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;	

	cnEndTransaction;

end;</source>
        <ReturnType type="WS_MachineListChgResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="machineHasListChanged" id="82d2b6f8-ffa1-4d0b-adf8-ef4aecac5ee4">
        <source>machineHasListChanged()  : WS_MachineListChgResponse webService;
/*

Date		Who		Reason
26 June 2017    cnwsc8  Change to use WS_MachineListChgResponse
23 June 2017	cnwer1	Initial creation TFS 4836

*/

vars
	i				: Integer;
	machineTaskState : CM_MachineTaskState;
	task 	: CM_RTQueueTask;
	allTasks : CM_RTQueueTaskArray; 
	machine : CM_Machine;
	completedOK : Boolean;
	response : WS_MachineListChgResponse;
begin
// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Create the response
	create response transient;	
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		completedOK := true;
		return  response ;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
			
	self.validateCurrentMachine(true);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	machine:=currentSession.myCurrentMachine;
	self.setIgnoreWarnings(true);
	//epr tfs 7642 7/11/17  force a refresh with working tasks
	if machine.allCurrentQueueTasks.size &gt; 0 then
		completedOK := true;
		response.listHasChanged := true;
		return response;
	endif;
	
	create allTasks transient;
	machine.getAllAvailableQueuesTasks(allTasks);
	
	//quick test if task size is different 
	if machine.allMachineTaskStates.size &lt;&gt; allTasks.size then
		completedOK := true;
		response.listHasChanged := true;
		return response;
	endif;
	

	i:=1;
	foreach machineTaskState in machine.allMachineTaskStates discreteLock do
		task:=allTasks[i];
		if not machineTaskState.isMatch(task) then
			completedOK := true;
			response.listHasChanged := true;
			return response;
		endif;
		
		i:=i+1;
	endforeach;
	
	response.listHasChanged := false;
	completedOK := true;
	return response;

epilog
	// Tidy up any local transients
	// ...
	delete allTasks;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;	
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;	

	cnEndTransaction;

end;</source>
        <ReturnType type="WS_MachineListChgResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="processRoadExit" id="acf51f1f-8d49-400a-bdf5-fda1196fa98f">
        <source>processRoadExit(roadExitRequest : WS_RoadJobRequest): WS_Response webService;
/*

Purpose:	Process road exit for the given truck		

Parameters:			

Return Value:		

Date			Who		Reason
30 August 2017	jlgam15	TFS-6731 Existing call to complete the road exit has now been moved to a new webservice call
20 Jun 2024 	navsck1 ChangeRequest 63668: FR | 53891 - Delivery Dispatch - turn off other apps
16 Jun 2025		navbs1	Story MTN-34429: MTN - DeadLock Retry Required for trxVehicleRoadExit
*/

vars
	completedOK : Boolean;
	response  	: WS_Response;
	truck 		: CM_Vehicle;
	terminal 	: CM_Terminal;
	truckUnLoaderController: CMIF_MobileTruckLoaderUnloader;
	permissionsToCheck : IntegerArray;
	
begin

	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	create response transient;
	terminal := app.myPassport.myTerminal;
		
	create permissionsToCheck transient;
	//63668 =&gt; add the deliver dispatch app permission, this allows					//20.06.2024 navsck1 #63668
	//for the action to continue if the user has access to the underlaying
	//app via delivery dispatch even if the specific permission is not
	//given.
	permissionsToCheck.add(PmMobDeliveryDispatchApp);								//20.06.2024 navsck1 #63668
	permissionsToCheck.add(PmHandHeldTruckLoader);
	permissionsToCheck.add(PmHHVTLoader);
	permissionsToCheck.add(PmHandHeldTruckUnloader);
	app.myPassport.validateUserHasOnePermission(permissionsToCheck);

	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;	

	if roadExitRequest.regNumber &lt;&gt; null then
		truck:=terminal.findTruck(roadExitRequest.regNumber.toUpper,roadExitRequest.state.toUpper,roadExitRequest.batNumber);
	endif;
	
	if truck = null then
		if roadExitRequest.batNumber &lt;&gt; null then
			app.raiseCMException(Number_no_current_truck,null,null);
		else
			app.raiseCMException1(ERR_Truck_Unknown,roadExitRequest.regNumber.toUpper,null,null);
		endif;
		completedOK:=true;
		return response;
	endif;
	
	create truckUnLoaderController transient;

	truckUnLoaderController.setMyTerminal(terminal);
	truckUnLoaderController.setTruck(truck);
	self.setIgnoreWarnings(roadExitRequest.warningsAcknowledged);
	
	app.myPassport.setupForDeadlockReplay(-10, 2000);		//16.06.2025 navbs1 #34429
	while true do 											//16.06.2025 navbs1 #34429
		truckUnLoaderController.doCompleteOutward();
		if app.myPassport.noTrxReplayAllowed() then
			break;
		endif;
	endwhile;
	
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	completedOK:=true;
	return response;

epilog

	process.setPersistentDeadlockPriority(0);							//16.06.2025 navbs1 #34429
	app.myPassport.replayingDeadlocks := false;							//16.06.2025 navbs1 #34429
	
	delete permissionsToCheck;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				
	endif;
	delete truckUnLoaderController;
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="roadExitRequest" type="WS_RoadJobRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="raiseAlert" id="dfdef0ed-036d-4c5f-a3ff-9e9b7934ba0d">
        <source>raiseAlert(request : WS_RaiseAlertRequest) : WS_Response webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 January 2017	cnwhl1	Initial creation

*/

vars
	response		: WS_Response;
	completedOK		: Boolean;
	linkedObj		: CM_Object;
	obj				: Object;
	actualAlert		: String;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	//epr TFS 5535 9/8/17
	app.checkCurrentUserHasAccess(PmHHRaiseAlert);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;	
	
	if request.linkedUid &lt;&gt; null then
		//epr TFS 5535 9/8/17
		linkedObj :=app.myPassport.getObjectOfTypeFromOid( request.linkedUid,CM_Object).CM_Object;
		if app.myPassport.hasErrors then
			completedOK:=true;
			return response;
		endif;
	endif;
	
	actualAlert := 'Sent from Mobile App, ' &amp; app.myPassport.getUserCode() &amp; ': ' &amp; request.alertMessage;
	
	app.myPassport.createAlert(request.severity, 
			actualAlert,
			EVENT_AT_HandHeldAlert,
			linkedObj);
	//
	beginTransaction;
		app.commitAlert();
	commitTransaction;

	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="request" type="WS_RaiseAlertRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
