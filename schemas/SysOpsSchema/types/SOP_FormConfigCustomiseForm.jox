    <JadeMethod name="hideDraggingRectangle" id="d7c28edc-b4c5-4c37-b3ad-7d8cd33d71f1">
        <updating/>
        <source>hideDraggingRectangle()updating, protected;
// ---------------------------------------------------------------------------
// Created:     04 September 2008 by concms1
// Purpose:     User definable forms - CCMS 1011
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if not self.isDragRectangleVisible then
		return;
	endif;
	
	self.drawDeskTopRectangle (DragRectangle_DrawPattern, self.lastDragLeft , self.lastDragTop , 
								self.lastDragRight, self.lastDragBottom, 
								DragRectangle_DrawColour, DragRectangle_DrawWidth);
	
	self.isDragRectangleVisible := false;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="highlightSelectedControl" id="7784bb29-4c00-464d-8852-581d3abc1ab2">
        <updating/>
        <source>highlightSelectedControl()updating, protected;
// ---------------------------------------------------------------------------
// Created:     02 September 2008 by concms1:1
//
// Purpose:     User definable forms - CCMS 1011
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	control		: Control;
	left, top	: Real;	// beware same as form properties
begin
	self.clearGraphics;
	self.isDragRectangleVisible := false;
	
	if self.mySelectedControl = null then
		return;
	endif;

	control				:= self.mySelectedControl;
	left				:= control.getFormLeft;
	top 				:= control.getFormTop;		
	
	
	self.autoRedraw		:= true;
	self.clipControls 	:= false;
	self.drawWidth		:= 2;
	self.drawFillStyle	:= self.DrawFillStyle_DownDiagonal;
	//
	self.drawRectangle (left, top, left + control.width, top + control.height, Blue);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="keyDown" id="7fba0fb0-d407-4d59-95a5-2cdda8b3b8cc">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     02 September 2008 by concms1:1
//
// Purpose:     User definable forms - CCMS 1011
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	control	:Control;
	int		:Integer;

begin 
	control := self.mySelectedControl;
	
	if control &lt;&gt; null then
		int := 1;
		
		if shift.bitAnd(1) &lt;&gt; 0 then		// shift
			int := 5;
		elseif shift.bitAnd(2) &lt;&gt; 0 then	// cntrl
			int := 10;
		endif;
		
		if keyCode = J_key_LeftArrow then
			self.setControlPosition (control, control.left - (1*int), control.top, true);
		endif;
		if keyCode = J_key_RightArrow then
			self.setControlPosition (control, control.left + (1*int), control.top, true);
		endif;
		if keyCode = J_key_UpArrow then
			self.setControlPosition (control, control.left, control.top - (1*int), true);
		endif;
		if keyCode = J_key_DownArrow then
			self.setControlPosition (control, control.left, control.top + (1*int), true);
		endif;
		
		self.highlightSelectedControl;	// since position has changed
	endif;
	
	inheritMethod (keyCode, shift);
epilog

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
