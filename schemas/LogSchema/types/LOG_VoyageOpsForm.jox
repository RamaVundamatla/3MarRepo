    <JadeMethod name="tblOrderDataSelectRow" id="e3e4c413-6ed5-4edc-b161-6c2af5418a71">
        <updating/>
        <source>tblOrderDataSelectRow(table: Table input) updating;
//--------------------------------------------------------------
//Created: 05 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	savedObj : CM_StockOrderObject;
	savedTerminal : CM_Terminal;
	timerOption : Integer;
	timeRemaining : Integer;
begin

	if self.mode &lt;&gt; Mode_View and self.mode &lt;&gt; Mode_View_Only and self.mode &lt;&gt;  Mode_LimitedEdit then
		//epr par 34877 16/9/14
		if not self.getTimerStatus(self.TimerSheetMessage,timerOption,timeRemaining) then
			self.showCannotAccessSheetMsg(fldInfo.topSheet, 'You are currently adding or editing another elsewhere. Complete this before attempting to allocate rows');
			self.beginTimer(10000,Timer_OneShot,TimerSheetMessage);
		endif;
		//self.doWindowEvents(10000);
		//self.hideCannotAccessSheetMsg(fldInfo.topSheet);
		return;
	endif;

	savedObj := self.myCurrentStockOrderObject;
	
	if savedObj &lt;&gt; null and global.isValidObject(savedObj) then
		savedTerminal := self.myCurrentStockOrderObject.getMyTerminal;	
	endif;
		
	self.myCurrentStockOrderObject := null;		
	
	if table.row &gt; table.fixedRows then
		self.myCurrentStockOrderObject := table.accessRow(table.row).itemObject.CM_StockOrderObject;
		self.showTableDataForCurrentObject();
	endif;
	
	if fldInfo.topSheet = shtAllocateRows then
		if self.myCurrentStockOrderObject = null then
			self.showCannotAccessSheetMsg(shtAllocateRows, 'You must select a stock order line in the table above before you can allocate rows.');
		else
			self.hideCannotAccessSheetMsg(shtAllocateRows);
			self.setupSearchCriteria();
		endif;
	elseif fldInfo.topSheet = shtAllocToDetail then
		if self.myCurrentStockOrderSummary = null then
			self.showCannotAccessSheetMsg(shtAllocToDetail, 'You must select a stock order summary in the table above before you can allocate to details.');
		else
			self.hideCannotAccessSheetMsg(shtAllocToDetail);
		endif;
	elseif fldInfo.topSheet = shtDetails then
		if self.myCurrentStockOrderLine = null then
			self.showCannotAccessSheetMsg(shtDetails, 'You must select a stock order line in the table above before you can Add/Update details.');
		else
			self.hideCannotAccessSheetMsg(shtDetails);
		endif;		
	endif;
	
	if savedObj &lt;&gt; self.myCurrentStockOrderObject
	and self.myCurrentStockOrderObject &lt;&gt; null then
		if savedTerminal &lt;&gt; self.myCurrentStockOrderObject.getMyTerminal then
			self.clearSearchResults();
		endif;
		self.showRequiredAllocatedQtys();
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblOrderDataUpdateObject" id="d30a5411-01af-4fbe-96c3-06d6500da398">
        <updating/>
        <source>tblOrderDataUpdateObject(_orderObject : CM_StockOrderObject; _event : Integer)updating;
//--------------------------------------------------
// Created:	07 July 2004 By: cnwgd1
//--------------------------------------------------
vars
	saveSelected : CM_StockOrderObject;
	rowIdx,
	topRow : Integer;
	itemObj : Object;
begin
	if _event &lt;&gt; LogVoyageOps_Update_Event then
		return;
	endif;
	
	if _orderObject = null then
		return;
	endif;
	
	saveSelected := self.myCurrentStockOrderObject;
	topRow := self.tblOrderData.topRow;			
	
	if self.tblOrderData.findObjectInRow(_orderObject, rowIdx) then
		self.tblOrderData.accessCell(rowIdx, 1).text := self.dataTableDisplayRow(tblOrderData, _orderObject);
	endif;
		
	if _orderObject = saveSelected then
		self.setSelectedTblOrderData(saveSelected, topRow);
	endif;

	if self.tblAllocatedRows.row &gt; self.tblAllocatedRows.fixedRows then
		itemObj := self.tblAllocatedRows.accessRow(self.tblAllocatedRows.row).itemObject;
		if global.isValidObject(itemObj) then
			self.showTxtAllocRowDtls(itemObj.CM_StockOrderAllocation.mySOHLocation);
		endif;
	elseif self.tblSrchResults.row &gt; self.tblSrchResults.fixedRows then
		self.showTxtAllocRowDtls(self.tblSrchResults.accessRow(self.tblSrchResults.row).itemObject.CM_SOHLocation);	
	else
		self.showTxtAllocRowDtls(null);
	endif;			

end;</source>
