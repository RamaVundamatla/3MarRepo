    <JadeMethod name="cmbDelay_displayEntry" id="2631a6a8-57d5-47cf-9110-be9a24fdbc5c">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbDelay_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;
//--------------------------------------------------
// Created:	11 August 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	return self.myAssistant.displayEntryHMSDelay(obj.HMS_Delay);
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
