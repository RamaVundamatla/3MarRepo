    <JadeMethod name="utlUpdateInvoice" id="1a162ab2-dded-43a4-8617-ca88469bebee">
        <source>utlUpdateInvoice(pProxyInvoice:CM_Invoice; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
//29 May 2023  navmv20 Bug 58090: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 050.d
vars
	cancelSave:Boolean;
	realInvoice:CM_Invoice;
	expectedEdition:Integer;
	updateLines : Boolean;
begin

	self.initialiseActivity();

	pProxyInvoice.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyInvoice.pxyGetRealObjectAndEdition(realInvoice, expectedEdition);
	
	if realInvoice = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Invoice.name, null, null);
		return;
	endif;

	app.myValUA.valInvoice(realInvoice, pProxyInvoice);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realInvoice);

	if _passport.noErrors and realInvoice.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Invoice', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realInvoice, true);
	endif;
	
	if _passport.noErrors then
		// ### JIRA 33005 03OCT2024 NAVAB1
		updateLines := pProxyInvoice.debtor &lt;&gt; realInvoice.debtor;
		
		
		realInvoice.setForUpdate(pProxyInvoice);
		realInvoice.setForUpdateSeparations(pProxyInvoice); //29 May 2023  navmv20 Bug 58090
		realInvoice.setExternalRefFields(pProxyInvoice.getExternalFinancialId(), pProxyInvoice.externalTaxNumber, pProxyInvoice.externalNumber); //08/12/2025	navkc1 JIRA 36262
		// ### JIRA 33005 03OCT2024 NAVAB1
		if updateLines then
			realInvoice.updateDebtorInvoiceLines();
		endif;
		
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realInvoice, false);
		realInvoice.causeEvent(_passport.myTerminal.getTerminalEvent(Event_InvoiceUpdate), false, realInvoice);
	endif;

epilog
	
	
end;</source>
        <Parameter name="pProxyInvoice" type="CM_Invoice"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateInvoiceAllocation" id="461aee95-8c09-4930-8f97-4eb73f52cf90">
        <updating/>
        <source>utlUpdateInvoiceAllocation(pProxyObj : CM_InvoiceAllocation input;
						   pAllTransientCriteriaObj : CMIF_Array;
						   _new : Boolean;
						   yardAllocationObj : CM_InvoiceAllocation io;
						   _passport : CM_Passport input) updating;
// --------------------------------------------------------------------------------
// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1
//	add or update invoice allocation plus associated quantity map and quantity range maps
// 10/03/2021	navdap1	TFS 50889 PRP Yard Allocation Performance Improvement
// --------------------------------------------------------------------------------
vars
	found	: Boolean;
	newQRM	: Boolean;
	newILD	: Boolean;
	sssb	: CM_SnapShotServiceBroker;
	bank	: CM_Bank;
	ya		: CM_YardAllocation;
	proxyQuantityMap,
	realQuantityMap	: CM_QuantityMap;
	
	proxyQRM,
	qrm,
	realQRM		: CM_QuantityRangeMap;
	
	ildIn,
	ild			: CM_InvoiceLineDesc;	
	lineMapDict	: CM_TMInvLineMapByCargoAttrDict;
	pxyMapping, lineMapping	: CM_TranMapInvoiceLineMapping;
	lineGroupType	: CM_TranMapInvoiceLineGroupType;

begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	sssb := pProxyObj.myServiceBroker.CM_SnapShotServiceBroker;
	bank := sssb.getBank();
	if bank &lt;&gt; null then
		lineGroupType := bank.getInvLineGroupAll();
	endif;
	foreach ya in sssb.allInvoiceAllocations do
		if ya.isSameAs(pAllTransientCriteriaObj) then
			found := true;
			break;
		endif;
	endforeach;
	if found then
		yardAllocationObj := ya.CM_InvoiceAllocation;
	endif;
	
	if found then
		app.myValUA.valYardAllocation(yardAllocationObj, pProxyObj);
	else
		app.myValCA.valYardAllocation(null, pProxyObj);
	endif;

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	// invoice allocation properties - create persistent instances as needed and update the invoice alloc proxy to reference them
	proxyQuantityMap := pProxyObj.myQuantityMap;
	if found then
		realQuantityMap := yardAllocationObj.myQuantityMap;
	else
		create realQuantityMap persistent;
		realQuantityMap.setForUpdate(proxyQuantityMap);
		pProxyObj.setQuantityMap(realQuantityMap);
	endif;

	proxyQRM := proxyQuantityMap.allQuantityRanges.first;		// only one passed through
	newQRM := true;
	foreach qrm in realQuantityMap.allQuantityRanges do
		if qrm.rangeStart = proxyQRM.rangeStart and
		   qrm.rangeEnd   = proxyQRM.rangeEnd then
			newQRM := false;
			break;
		endif;
	endforeach;
	if newQRM then
		proxyQRM.validateRange(realQuantityMap);
		if not self.checkValidationWithPassport(_passport) then
			return;
		endif;
		create realQRM persistent;
		create realQRM.allRegisteredMethods;
		realQRM.setForUpdate(proxyQRM);
		
		realQRM.setProxy(realQuantityMap, realQRM.rangeStart.Integer, realQRM.rangeEnd.Integer,realQRM.rangeType);
	else
		realQRM := qrm;
	endif;
	
	// 31321 missing from initial QMS 2177 implementation
	lineMapDict := realQRM.allTMInvoiceLineMappings;
	lineMapDict.purge();

	newILD := true;
	
	pxyMapping := proxyQRM.allTMInvoiceLineMappings.first;
	ildIn := pxyMapping.myTMInvoiceLineDesc;
	create lineMapping persistent;
	lineMapping.update(0, ildIn, realQRM, lineGroupType, null, null, null, null, null);
	
	
	// Update the Invoice Allocation object.
	
	if not found then
		create yardAllocationObj persistent;
		yardAllocationObj.setForCreate(pProxyObj);
		// Persist the YA Criteria.
		if _passport.noErrors() then
			yardAllocationObj.persistCriteria(pAllTransientCriteriaObj, _passport);
			yardAllocationObj.terminalMarkDictAdd();										// TFS 50889
		endif;
		sssb.allInvoiceAllocationsByPriory[yardAllocationObj.priorityValue.Integer] := yardAllocationObj;
		yardAllocationObj.setQuantityMap( pProxyObj.myQuantityMap );	//18 Sep 2017	NDL	TFS 6973
		yardAllocationObj.setServiceBroker( pProxyObj.myServiceBroker );//18 Sep 2017	NDL	TFS 6973
	else	// 28 Feb 2019	NDL	TFS 43153 - allow for change of selections and or description.
		yardAllocationObj.setForUpdate(pProxyObj);
		if _passport.noErrors() then
			yardAllocationObj.persistCriteria(pAllTransientCriteriaObj, _passport);
		endif;
	endif;
	realQuantityMap.setAllocationDetails(yardAllocationObj, proxyQuantityMap.mySnapShotQuantityType);
	realQuantityMap.setChargeZero(proxyQuantityMap.chargeZero);
	realQuantityMap.setMappingType(proxyQuantityMap.mappingType);
	
	if newQRM or newILD then
		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_TRANSACTIONMAP_UPDATE), false, sssb);
	endif;
	if not found then	//13 Feb 2019	NDL	TFS 43153
		sssb.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_TRANSACTIONMAP_CREATE), false, yardAllocationObj);
	else// 28 Feb 2019	NDL	TFS 43153 - allow for change of selections and or description.
		sssb.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_TRANSACTIONMAP_UPDATE), false, yardAllocationObj);
	endif;
	
end;</source>
        <Parameter name="pProxyObj" type="CM_InvoiceAllocation" usage="input"/>
        <Parameter name="pAllTransientCriteriaObj" type="CMIF_Array"/>
        <Parameter name="_new" type="Boolean"/>
        <Parameter name="yardAllocationObj" type="CM_InvoiceAllocation" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateInvoiceCargoAlloc" id="9188d3c6-683b-4142-b31a-cee4216b6d80">
        <source>utlUpdateInvoiceCargoAlloc(_update : Boolean;
					_bulkUpdate : Boolean;
					_allTransientCriteriaObj	: CMIF_Array;					
					 _tranMap : CM_TranMapCargoAllocation; 
					 _pxyAlloc : CM_InvoiceCargoAllocation input;
					 _realAlloc : CM_InvoiceCargoAllocation io);

/*
Purpose:			
Date		Who			Reason
MARCH 2015	CNWAB1		Initial creation
31 May 2017	cnwkpd1		TFS #4542 - Invoice performance changes
19 Jun 2017	cnwma1 		TFS #4498 JMT - Cargo Allocation Fix Up Export Script
15 Nov 2017 jlgmd1		TFS #7659 STWO - FW: Transaction Map: PROBLEM
May 12 2023 navmv20 	Bug 57561: STWO - Code :79963. A Yard Allocation with this code () already exists- Issue 1 of 2
28 May 2024	navnk30		ChangeRequest 63897: Jade - Invoice Cargo Allocation Audits

*/
vars

begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);	

	self.raiseExceptionIfNull(_pxyAlloc, 'Invoice Allocation');
	self.raiseExceptionIfNull(_tranMap, 'Transaction map');	
	
	app.setContinueCMExceptions(true);
	//app.myValUA.valInvoiceCargoAlloc(_allTransientCriteriaObj,_tranMap, _pxyAlloc); //12/05/2023 navmv20 Bug 57561
	app.myValUA.valInvoiceCargoAlloc(_allTransientCriteriaObj,_tranMap, _pxyAlloc,_update); //12/05/2023 navmv20 Bug 57561
	
	if not self.checkValidationWithPassport(app.myPassport) then
		return;
	endif;
	
	if not _update then
		create _realAlloc;
		_realAlloc.initialiseProxy(_tranMap); //19/06/2017 cnwma1 TFS #4498
		_realAlloc.persistCriteria(_allTransientCriteriaObj, app.myPassport);

		_realAlloc.setForCreateFromTemplate(_pxyAlloc, _pxyAlloc.myTerminal);
		
		app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(_realAlloc);//28.05.2024 navnk30 #63897
	else
		self.myUpdateAuditAgent.audUpdateGeneric(_realAlloc, true);		//28.05.2024 navnk30 #63897
		
		_realAlloc.persistCriteria(_allTransientCriteriaObj, app.myPassport);
		_realAlloc.setForUpdate(_pxyAlloc);

		self.myUpdateAuditAgent.audUpdateGeneric(_realAlloc, false);	//28.05.2024 navnk30 #63897
	endif;
	
	if not _bulkUpdate then	// TFS 7659
		// TFS #4542 - Need to rebuild the manual collection of allocations by transaction type after any update
		_tranMap.recalcAllocationPriorities();
	endif;
	
	if not app.myPassport.hasErrorsOrWarnings() then
		if not _update then
			app.myEventManager.createSingleObjInfoNoteEvt(_tranMap,app.myPassport.myTerminal.getTerminalEvent(EVENT_INVCARGOALLOC_CREATE),_realAlloc); // TFS 7496
		else
			app.myEventManager.createSingleObjInfoNoteEvt(_tranMap,app.myPassport.myTerminal.getTerminalEvent(EVENT_INVCARGOALLOC_UPDATE),_realAlloc);
		endif;
	endif;

end;</source>
        <Parameter name="_update" type="Boolean"/>
        <Parameter name="_bulkUpdate" type="Boolean"/>
        <Parameter name="_allTransientCriteriaObj" type="CMIF_Array"/>
        <Parameter name="_tranMap" type="CM_TranMapCargoAllocation"/>
        <Parameter name="_pxyAlloc" type="CM_InvoiceCargoAllocation" usage="input"/>
        <Parameter name="_realAlloc" type="CM_InvoiceCargoAllocation" usage="io"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateInvoiceCargoAllocMap" id="49537f0f-4602-435a-b190-68de8632775f">
        <source>utlUpdateInvoiceCargoAllocMap(_update : Boolean;					
					 _pxyQM : CM_QuantityMap input; 
					 _pxyQRM : CM_QuantityRangeMap input;
					 _realServiceBroker : CM_CargoServiceBroker input); // ### TFS 51219 25MAY2021 NAVAB1

/*
Purpose:			
Date				Who			Reason
MARCH 2015		CNWAB1		Initial creation
*/
vars
	expectedEdition, eventUpdateVoyageArea		: Integer;
	realQRM : CM_QuantityRangeMap;
	realQM : CM_QuantityMap;
	alloc : CM_InvoiceAllocation; // ### TFS 51219 25MAY2021 NAVAB1
	tranMap : CM_Object; // ### TFS 51219 25MAY2021 NAVAB1
	
	// need to support update auditing on  2 sepearte objects, need 2 agents.
	audAgentQM : CM_UpdateTransactionAuditAgent;
	audAgentQRM : CM_UpdateTransactionAuditAgent;
	updateQM : Boolean;
begin

	create audAgentQM transient;
	create audAgentQRM transient;

	self.initialiseActivity();
	app.setContinueCMExceptions(true);	

	self.raiseExceptionIfNull(_pxyQM, 'Quantity Map');
	// PAR 36275	self.raiseExceptionIfNull(_realServiceBroker, 'Service Broker Cargo Invoice Allocations');	
	
	app.setContinueCMExceptions(false);
	app.myValUA.valInvoiceCargoAllocMap(_pxyQM);
	app.myValUA.valInvoiceTMQuantityRangeMap(_pxyQRM);
	
	if not self.checkValidationWithPassport(app.myPassport) then
		return;
	endif;
	
	if _update then
		realQRM := _pxyQRM.pxyGetRealObject();
		audAgentQRM.audUpdateGeneric(realQRM, true);	//20 Dec 2017		NDL	TFS 8095 - pre change audit
	else
		create realQRM;
		realQRM.setForCreate(_pxyQRM);
	endif;

	if _realServiceBroker &lt;&gt; null then // PAR 36275
		audAgentQM.audUpdateGeneric(_realServiceBroker.myChildQuantityMap, true);	//20 Dec 2017		NDL	TFS 8095 - pre change audit
		_realServiceBroker.myChildQuantityMap.setForUpdate(_pxyQM);
		updateQM := true;
	endif;
	
	
/*	if _update then
		realQRM := _pxyQRM.pxyGetRealObject();
		audAgentQRM.audUpdateGeneric(realQRM, true);	//20 Dec 2017		NDL	TFS 8095 - pre change audit
	else
		create realQRM;
		realQRM.setForCreate(_pxyQRM);
	endif; */
	
	realQRM.setForUpdate(_pxyQRM);
	
	if not app.myPassport.hasErrorsOrWarnings() then
		if _realServiceBroker &lt;&gt; null then
		 // ### TFS 51219 25MAY2021 NAVAB1  	tranMap := _realServiceBroker.myTransactionMap;
			alloc := _realServiceBroker.getMyAllocation(); // ### TFS 51219 25MAY2021 NAVAB1
			tranMap := alloc.getMyTranMap();
			
			if tranMap&lt;&gt; null and alloc &lt;&gt; null then
					app.myEventManager.createSingleObjInfoNoteEvt(tranMap,app.myPassport.myTerminal.getTerminalEvent(EVENT_INVCARGOALLOC_UPDATE),alloc);
			endif;
		else
			
		endif;
	endif;
	
	//20 Dec 2017		NDL	TFS 8095
	if app.myPassport.noErrors then
		if not _update then
			app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(realQRM);	// create new audit
		else
			audAgentQRM.audUpdateGeneric(realQRM, false);	//post change audit
		endif;
		if updateQM then
			audAgentQM.audUpdateGeneric(_realServiceBroker.myChildQuantityMap, false);	//20 Dec 2017		NDL	TFS 8095 - post change audit
		else
			realQM := _pxyQM.pxyGetRealObject();
			if realQM &lt;&gt; null then
				app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(realQM);	// create new audit
			endif;
		endif;
	endif;

epilog

	delete audAgentQM; 
	delete audAgentQRM; 
	
end;</source>
        <Parameter name="_update" type="Boolean"/>
        <Parameter name="_pxyQM" type="CM_QuantityMap" usage="input"/>
        <Parameter name="_pxyQRM" type="CM_QuantityRangeMap" usage="input"/>
        <Parameter name="_realServiceBroker" type="CM_CargoServiceBroker" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateInvoiceDesc" id="0120cdd0-a716-4de0-9d4c-d878113806af">
        <source>utlUpdateInvoiceDesc(pProxyInvoiceDesc : CM_InvoiceDesc; 	_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	cancelSave		: Boolean;
	realInvoiceDesc	: CM_InvoiceDesc;
	expectedEdition	: Integer;
	
begin

	self.initialiseActivity();

	pProxyInvoiceDesc.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyInvoiceDesc.pxyGetRealObjectAndEdition(realInvoiceDesc, expectedEdition);
	
	if realInvoiceDesc = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_InvoiceDesc.name, null, null);
		return;
	endif;

	app.myValUA.valInvoiceDesc(realInvoiceDesc, pProxyInvoiceDesc);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realInvoiceDesc);

	if _passport.noErrors and realInvoiceDesc.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Invoice Type', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realInvoiceDesc, true);
	endif;
	
	if _passport.noErrors then
		realInvoiceDesc.setForUpdate(pProxyInvoiceDesc);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realInvoiceDesc, false);
	endif;

end;</source>
        <Parameter name="pProxyInvoiceDesc" type="CM_InvoiceDesc"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateInvoiceExternalFinID" id="b6eecaf3-32de-4252-9b9f-950f4091cca7">
        <updating/>
        <source>utlUpdateInvoiceExternalFinID(_invoice : CM_Invoice input; _externalFinID : String;_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2024	jlier1	Initial creation  TFS 65958: CR 65949 NSW | Dynamics Integration - Send Invoice Header

*/

vars

begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	if _invoice = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Invoice.name, null, null);
		return;
	endif;
	if (not self.checkValidationWithPassport(_passport)) then
		return;	
	endif;
	app.setContinueCMExceptions(false);
	exclusiveLock(_invoice);
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_invoice, true);
	endif;
	if _passport.noErrors then
		_invoice.setExternalFinancialId(_externalFinID);
		endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_invoice, false);
	endif;

end;</source>
        <Parameter name="_invoice" type="CM_Invoice" usage="input"/>
        <Parameter name="_externalFinID" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateInvoiceFutureStorage" id="0115d8eb-f47b-4639-90e0-70607e990fd3">
        <source>utlUpdateInvoiceFutureStorage(_update : Boolean;					
					 _pxyQM : CM_QuantityMap input; 
					 _realQM : CM_QuantityMap output; 
					 _pxyQRM : CM_QuantityRangeMap input;
					 _realFutureStorageMap : CM_FutureStorageMapping input;
					 _storageDetail : CM_StorageDetail) : CM_FutureStorageMapping;

/*
Purpose:			
Date				Who			Reason
MARCH 2015		CNWAB1		Initial creation
*/
vars
	newQMCreated : Boolean;
	realQRM : CM_QuantityRangeMap;
	realQM : CM_QuantityMap;
	realFutureStorageMap : CM_FutureStorageMapping;
	
	// need to support update auditing on  3 sepearte objects, need 3 agents.
	audAgentQM : CM_UpdateTransactionAuditAgent;
	audAgentQRM : CM_UpdateTransactionAuditAgent;
begin

	create audAgentQM transient;
	create audAgentQRM transient;

	self.initialiseActivity();
	app.setContinueCMExceptions(true);	

	self.raiseExceptionIfNull(_pxyQM, 'Quantity Map');
	
	app.setContinueCMExceptions(false);
	app.myValUA.valInvoiceCargoAllocMap(_pxyQM);
	app.myValUA.valInvoiceTMQuantityRangeMap(_pxyQRM);
	
	if not self.checkValidationWithPassport(app.myPassport) then
		return null;
	endif;
	realQM := _pxyQM.pxyGetRealObject();
	if realQM = null then
		create realQM;
		newQMCreated := true;
	else
		audAgentQM.audUpdateGeneric(realQM, true);	//19 Dec 2017		NDL	TFS 8095 - pre change audit
	endif;
	
	if _update then
		realQRM := _pxyQRM.pxyGetRealObject();
		audAgentQRM.audUpdateGeneric(realQRM, true);	//19 Dec 2017		NDL	TFS 8095 - pre change audit
		realQRM.setForUpdate(_pxyQRM);
	else
		create realQRM;
		create realQRM.allRegisteredMethods;
		realQRM.setForUpdate(_pxyQRM);		// call setForUpdate rather setForCreate to avoid the initialise
		newQMCreated := true;
	endif;
	
	realQM.setForUpdate(_pxyQM);
	
	// ### TFS CR 58022 TASK 58023 18MAY2023 NAVAB1
	if _pxyQM.myParentFinancialObject &lt;&gt; null then
		realQM.myParentFinancialObject := _pxyQM.myParentFinancialObject;
	endif;
	
	_realQM := realQM;	 // ### TFS CR 58022 TASK 58023 18MAY2023 NAVAB1
	
	if newQMCreated and realQRM.myQuantityMap = null then
		realQRM.setQuantityMap(realQM);
	endif;
	
	if _realFutureStorageMap &lt;&gt; null then  // ### TFS CR 58022 TASK 58023 18MAY2023 NAVAB1 - SUB RANGES
		if _realFutureStorageMap.isTransient then
			create realFutureStorageMap;
			_realFutureStorageMap.setQuantityMap(realQM);
			realFutureStorageMap.setForUpdate(_realFutureStorageMap);	
		else
			realFutureStorageMap := _realFutureStorageMap;
			self.myUpdateAuditAgent.audUpdateGeneric(realFutureStorageMap, true);	//19 Dec 2017		NDL	TFS 8095 - pre change audit
		endif;
		if realFutureStorageMap.myStorageDetail = null then		// this is the default one created with a new storage group
			realFutureStorageMap.setStorageDetail(_storageDetail);
		endif;
	endif;
	//19 Dec 2017		NDL	TFS 8095
	if app.myPassport.noErrors then
		if newQMCreated then
			app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(realQM);	// create new audit
			if not _update then
				app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(realQRM);	// create new audit
			endif;
		else
			audAgentQM.audUpdateGeneric(realQM, false);		// post change audit
			if _update then
				audAgentQRM.audUpdateGeneric(realQRM, false);	//post change audit
			endif;
		endif;

		if _realFutureStorageMap &lt;&gt; null then  // ### TFS CR 58022 TASK 58023 18MAY2023 NAVAB1 - SUB RANGES
			if _realFutureStorageMap.isTransient then
				app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(realFutureStorageMap);	// create new audit
			else
				self.myUpdateAuditAgent.audUpdateGeneric(realFutureStorageMap, false);	//post change audit
			endif;
		endif;
	endif;

	return realFutureStorageMap;
	
epilog

	delete audAgentQM; 
	delete audAgentQRM; 
	
end;</source>
        <Parameter name="_update" type="Boolean"/>
        <Parameter name="_pxyQM" type="CM_QuantityMap" usage="input"/>
        <Parameter name="_realQM" type="CM_QuantityMap" usage="output"/>
        <Parameter name="_pxyQRM" type="CM_QuantityRangeMap" usage="input"/>
        <Parameter name="_realFutureStorageMap" type="CM_FutureStorageMapping" usage="input"/>
        <Parameter name="_storageDetail" type="CM_StorageDetail"/>
        <ReturnType type="CM_FutureStorageMapping"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateInvoiceINCOMapping" id="305012c3-53a7-4070-bd01-a737545d52e3">
        <source>utlUpdateInvoiceINCOMapping(_pxyInvoiceINCOMapping : CM_InvoiceINCOMapping io;
							  _passport 		       : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2023 navtnr20	TFS CR 57983 Task 57984: EUP - INCO Terms TRX Layer

*/

vars
	realINCOMapping:CM_InvoiceINCOMapping;
	expectedEdition:Integer;
	
begin

	self.initialiseActivity();

	_pxyInvoiceINCOMapping.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyInvoiceINCOMapping.pxyGetRealObjectAndEdition(realINCOMapping, expectedEdition);
	
	if realINCOMapping = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_InvoiceINCOTerm.name, null, null);
		return;
	endif;
	


	app.myValUA.valInVINCOMapping(_pxyInvoiceINCOMapping);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realINCOMapping);

	if _passport.noErrors and realINCOMapping.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'INCO Mapping', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realINCOMapping, true);
	endif;
	
	if _passport.noErrors then
		realINCOMapping.setForUpdate(_pxyInvoiceINCOMapping);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realINCOMapping, false);
		app.myEventManager.createSingleObjInfoNoteEvt(realINCOMapping.myINCOTerm.myBusinessUnit,app.myPassport.myTerminal.getTerminalEvent(Event_InvINCOMappingUpdate),realINCOMapping);
	endif;

epilog
	
	
end;</source>
        <Parameter name="_pxyInvoiceINCOMapping" type="CM_InvoiceINCOMapping" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateInvoiceInventAlloc" id="91c3617a-4e33-4dcf-bee8-3ef076bae4f0">
        <source>utlUpdateInvoiceInventAlloc(_update : Boolean;
					_bulkUpdate : Boolean;
					_allTransientCriteriaObj	: CMIF_Array;					
					 _tranMap : CM_TranMapInventoryAllocation; 
					 _pxyAlloc : CM_InvoiceInventoryAllocation input;
					 _realAlloc : CM_InvoiceInventoryAllocation io);

/*
Purpose:			

Date		Who		Reason
26MAY2021	NAVAB1	TFS 51219
May 12 2023 navmv20 Bug Bug 57561: STWO - Code :79963. A Yard Allocation with this code () already exists- Issue 1 of 2
*/

vars
	expectedEdition, eventUpdateVoyageArea		: Integer;
	colourChange				: Boolean;
	slot : CM_SlotController;
	slotReq : CM_SlotRequest;
	slotReqRORO : CM_VoyageRequest;
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);	

	self.raiseExceptionIfNull(_pxyAlloc, 'Invoice Allocation');
	self.raiseExceptionIfNull(_tranMap, 'Transaction map');	
	
	app.setContinueCMExceptions(true);
	//app.myValUA.valInvoiceInventoryAlloc(_allTransientCriteriaObj,_tranMap, _pxyAlloc); //12/05/2023 navmv20 Bug 57561
	app.myValUA.valInvoiceInventoryAlloc(_allTransientCriteriaObj,_tranMap, _pxyAlloc,_update); //12/05/2023 navmv20 Bug 57561
	
	if not self.checkValidationWithPassport(app.myPassport) then
		return;
	endif;
	
	if not _update then
		create _realAlloc;
		_realAlloc.initialiseProxy(_tranMap); //19/06/2017 cnwma1 TFS #4498
		_realAlloc.persistCriteria(_allTransientCriteriaObj, app.myPassport);

		_realAlloc.setForCreateFromTemplate(_pxyAlloc, _pxyAlloc.myTerminal);
	else
		self.myUpdateAuditAgent.audUpdateGeneric(_realAlloc, true);

		_realAlloc.persistCriteria(_allTransientCriteriaObj, app.myPassport);
		_realAlloc.setForUpdate(_pxyAlloc);
	endif;
	
	
	
	if not _bulkUpdate then	// TFS 7659
		// TFS #4542 - Need to rebuild the manual collection of allocations by transaction type after any update
		_tranMap.recalcAllocationPriorities();
	endif;
	
	if not app.myPassport.hasErrorsOrWarnings() then
		if not _update then
			app.myEventManager.createSingleObjInfoNoteEvt(_tranMap,app.myPassport.myTerminal.getTerminalEvent(EVENT_INVCARGOALLOC_CREATE),_realAlloc); // TFS 7496
			app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(_realAlloc);
		else
			self.myUpdateAuditAgent.audUpdateGeneric(_realAlloc, false);

			app.myEventManager.createSingleObjInfoNoteEvt(_tranMap,app.myPassport.myTerminal.getTerminalEvent(EVENT_INVCARGOALLOC_UPDATE),_realAlloc);
		endif;
	endif;
	

end;</source>
        <Parameter name="_update" type="Boolean"/>
        <Parameter name="_bulkUpdate" type="Boolean"/>
        <Parameter name="_allTransientCriteriaObj" type="CMIF_Array"/>
        <Parameter name="_tranMap" type="CM_TranMapInventoryAllocation"/>
        <Parameter name="_pxyAlloc" type="CM_InvoiceInventoryAllocation" usage="input"/>
        <Parameter name="_realAlloc" type="CM_InvoiceInventoryAllocation" usage="io"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateInvoiceKinerjaDT" id="5ed2efdd-2983-44d6-9ba8-a77eb1346e5c">
        <updating/>
        <source>utlUpdateInvoiceKinerjaDT(_pxyInvoice : CM_Invoice; _kinerjaDT : TimeStamp;_passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 Dec 2018	cnwma1	ChangeRequest 38638: PEL1 - SAP Send Performance (Kinerja) Data

*/

vars
	realInvoice : CM_Invoice;
	expectedEdition:Integer;
begin
	self.initialiseActivity();
	
	_pxyInvoice.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyInvoice.pxyGetRealObjectAndEdition(realInvoice, expectedEdition);
	
	if realInvoice = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Invoice.name, null, null);
		return;
	endif;

	if (not self.checkValidationWithPassport(_passport)) then
		return;	
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realInvoice);

	if _passport.noErrors and realInvoice.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave,app.getErrorString(Invoice), null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realInvoice, true);
	endif;
	if _passport.noErrors then
		realInvoice.setKinerjaDT(_kinerjaDT);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realInvoice, false);
		realInvoice.causeEvent(realInvoice.myTerminal.getTerminalEvent(Event_InvoiceUpdate), false, realInvoice);	
	endif;
epilog

end;</source>
        <Parameter name="_pxyInvoice" type="CM_Invoice"/>
        <Parameter name="_kinerjaDT" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
