    <JadeMethod name="txtLocation_lostFocus" id="52f029a4-15b0-453c-b7f1-9b08bed75dbd">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtLocation_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 September 2015	cnwndl1	Initial creation 	Par 36900

*/

vars

	lc : CM_LocationsController;

begin

	if self.txtLocation.text.trimBlanks = self.lblLocation.caption.toUpper then
		//do nothing
	elseif self.txtLocation.text.trimBlanks = null then
		self.txtLocation.text := self.lblLocation.caption.toUpper;
		self.txtLocation.userObject := null;
		
	else
		if self.findLocationToMoveTo( lc ) then
			self.txtLocation.text := lc.getFullId;
			self.txtLocation.userObject := lc;
		else
			self.txtLocation.text := self.lblLocation.caption.toUpper;
			self.txtLocation.userObject := null;
		endif;
		
	endif;
	
	self.txtLocation.selStart := 0;
	self.txtLocation.selLength := 0;
	
epilog

end;</source>
