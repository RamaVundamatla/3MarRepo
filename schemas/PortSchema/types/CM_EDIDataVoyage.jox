        <source>getDisplayStrForDefName(_name: String): String;
//
// cnwrs1 CCMS 1008 1036 cnwrs1 Jan 2010
//
vars

begin
	if _name = ETDef_EDITIVoyage then
		return app.getErrorString(Voyage);
	elseif _name = ETDef_EDITIPort then
		return app.getErrorString(Port);
	elseif _name = ETDef_EDITIVoyageCutoff then  //cnwgb1 PAR 23207 17.3.2010
