    <JadeMethod name="tblList_rowColumnChg" id="5360818a-3169-4d25-b2cc-b6c025b5009d">
        <controlMethod name="CM_DataTable::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblList_rowColumnChg(table: Table input) updating;
/*
Purpose:			Ensure single select unless specifically required

Parameters:			

Return Value:		

Date			Who		Reason
11 March 2010	conkc1	Initial creation

*/
vars

	currentRow : Integer;
	firstSelectedObject : Object;
	thisObject : Object;
	index : Integer;
	br : CM_BulkRelease;

begin
	//epr TFS 4677 27/6/17 
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	self.btnOK.enabled:=true;
	self.btnSelectAll.enabled := true;
	// 29287 Apr 2012 multi-select pre-notes in road gate
	if not self.allowMultiSelect then
		currentRow := self.tblList.row;
		thisObject := self.tblList.accessRow(currentRow).itemObject;
		
		if thisObject &lt;&gt; null and thisObject.isKindOf( CM_ReserveDetail ) then
			br := thisObject.CM_ReserveDetail.myReserveHeader;
			if br &lt;&gt; null and table.selectedCount &gt; 0 then
				if self.tblList.rows &gt; 2 then
					foreach index in 2 to self.tblList.rows do
						if index = currentRow then
							continue;
						endif;
						if not self.tblList.accessRow(index).selected then
							continue;
						endif;
						firstSelectedObject := self.tblList.accessRow(index).itemObject;
						break;
					endforeach;
					self.tblList.row := currentRow;
					if firstSelectedObject &lt;&gt; null and firstSelectedObject.isKindOf( CM_ReserveDetail ) then
						if firstSelectedObject.CM_ReserveDetail.myReserveHeader = br then
							self.tblList.selected := true;
							if self.tblList.selectedCount &gt; 1 then
								self.btnOK.enabled := false;
								self.btnSelectAll.enabled := false;
							endif;
							return;
						endif;
					endif;
				endif;
			endif;
		endif;
		
		self.tblList.clearAllSelected;
		self.tblList.row := currentRow;
		if self.tblList.row &gt; 1 then
			self.tblList.selected := true;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="b74461e7-91bc-45e8-b3c2-3eccaa138053">
