    <JadeMethod name="isMultiCargoDrop" id="548ce6ed-ae18-4c27-9916-3be6c7fb0efd">
        <updating/>
        <source>isMultiCargoDrop(_win: Window input; _gridPoint: CMUI_GridPoint input; _x: Real; _y: Real ):Boolean updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 August 2011	cnwndl1	Initial creation	Par 28035

*/

vars

	theTIs : CM_TIArray;
	moveMode : Integer;
	wagon : CM_Wagon;
	msg : String;

begin

	create theTIs transient;	
	
	self.gridAreaMultiDragGetCargoMode( 	_win,	//_win : Window input;
											moveMode,	//_moveMode : Integer output;
											theTIs	//_theTIs : CM_TIArray io
											);
	
	if moveMode &lt;&gt; QUEUE_MODE and moveMode &lt;&gt; PLANNING_MODE then
		return false;
	endif;
	
	if theTIs.size &gt; 1 then
		if _gridPoint.myLocationsController &lt;&gt; null then
			if _gridPoint.myLocationsController.isWagon then
				wagon := _gridPoint.myLocationsController.CM_WagonController.myWagon;
			endif;
		endif;
		if not self.mnuMultiMove.checked and wagon = null then
			msg := app.getErrorString1(Multi_drop_must_wagon,self.mnuMultiMove.caption);
			app.msgBox(msg, app.getErrorString(Multi_move), MsgBox_OK_Only);
			return true;
		endif;
		return self.doGridAreaDragDropMulti(_win,wagon,moveMode,theTIs,app.myDraggedTrackedItem,_x,_y);
	endif;
	
	return false;
			
epilog
	
	delete theTIs;

end;</source>
        <access>protected</access>
        <Parameter name="_win" type="Window" usage="input"/>
        <Parameter name="_gridPoint" type="CMUI_GridPoint" usage="input"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
