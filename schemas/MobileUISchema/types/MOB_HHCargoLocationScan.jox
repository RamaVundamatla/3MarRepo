    <JadeMethod name="resetProgressCaptions" id="28ff9c0f-f5de-4339-8889-f868641f9666">
        <updating/>
        <source>resetProgressCaptions() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2015	cnwndl1	Initial creation

*/

vars

	ok : Integer;
	extras : Integer;
	missing : Integer;
	index : Integer;
	col2 : Boolean;	// Column 2 ticked = expected, unticked = extra
	col3 : Boolean;	// Column 3 ticked = scanned
	str : String;

begin

	foreach index in 1 to self.tblCargo.rows do
		if self.tblCargo.accessRow(index).itemObject = null then
			continue;
		endif;
		col2 := self.tblCargo.accessCell(index,2).text = "1";
		col3 := self.tblCargo.accessCell(index,3).text = "1";
		
		if col2 = false and col3 = true then
			extras := extras + 1;
		elseif col2 = true and col3 = false then
			missing := missing + 1;
		elseif col2 = true and col3 = true then
			ok := ok + 1;
		endif;
		
	endforeach;
	
	self.lblVerified.caption := app.getErrorString(Verified) &amp; " : " &amp; ok.String;
	self.lblMissing.caption := app.getErrorString(Not_scanned) &amp; " : " &amp; missing.String;
	self.lblExtras.caption := app.getErrorString(Extra_items) &amp; " : " &amp; extras.String;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="selectCargoItem" id="aa8aab1c-760f-471a-82dc-428d0797f7bd">
        <updating/>
        <source>selectCargoItem( manual : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2015	cnwndl1	Initial creation	Par 36608

*/

vars

	cargoId : String;
	term : CM_Terminal;
	firstTi : CM_TrackedItem;
	tiArray : CM_TIArray;
	iter : Iterator;
	ti : CM_TrackedItem;
	location: CM_LocationsController;
	cargoType : CM_CargoType;
	cargoTypeId : Integer;
	
begin

	cargoId := txtCargoId.text.trimBlanks.toUpper;
	if cargoId = lblCargoId.caption.toUpper then
		cargoId := null;
	endif;
	
	if self.myCargoGroup &lt;&gt; null then
		cargoType := self.myCargoGroup.getCargoGroupCargoType();
		if cargoType &lt;&gt; null then
			cargoTypeId := cargoType.id;
		endif;
	endif;

	self.setMyCargo(null);	
	term := self.myMobileDataAgent.myTerminal;
	
	create tiArray transient;
	
	if cargoId &lt;&gt; null then
		firstTi := term.allOnsiteTIsByIdCargoType.getAtKeyGeq(cargoId,cargoTypeId);
		if firstTi &lt;&gt; null and firstTi.id = cargoId then
			iter := term.allOnsiteTIsByIdCargoType.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.id &lt;&gt; cargoId then
					break;
				endif;
				if cargoType &lt;&gt; null and ti.myCargoType &lt;&gt; cargoType then
					break;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
			
		
	endif;
		
	if tiArray.isEmpty then
			self.msgBox( app.getErrorString1(Cargo_item_not_found_site,cargoId),app.getErrorString(Warning), MsgBox_OK_Only, false);
			self.txtCargoId.setFocus();
		return;
		
	else
		foreach ti in tiArray do
			if ti.myPrimaryActualLocation = myLocation then
				self.setMyCargo(ti);
				return;
			endif;
		endforeach;
		
		self.setMyCargo(tiArray.first);
		return;
	
	endif;
	

epilog

	delete tiArray;
	delete iter;
	

end;</source>
        <Parameter name="manual" type="Boolean"/>
    </JadeMethod>
