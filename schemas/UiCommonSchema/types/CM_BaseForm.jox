    <JadeMethod name="zCustomiseForm" id="b5efcfc5-b532-46db-80ab-1321b9ba8d74">
        <updating/>
        <source>zCustomiseForm()updating, protected;
// ---------------------------------------------------------------------------
// Created:     03 September 2008 by concms1
// Purpose:     User definable forms - CCMS 1011
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	agent				:CMUI_FormConfigAgent_Runtime;
	config, configToUse	:CM_FormConfigForm;
begin
	if app.getMyUserCode &lt;&gt; 'CONCMS1' 
		and app.getMyUserCode &lt;&gt; 'CNWRS2' 
		then
		return;
	endif;
	
	foreach config in CM_FormConfigForm.instances do
		if config.formName &lt;&gt; self.name then
			continue;
		endif;
		if config.myTerminal = null then
			configToUse := config;
		endif;
		if self.myTerminal &lt;&gt; null and config.myTerminal = self.myTerminal then
			configToUse := config;
			break;
		endif;
	endforeach;
	
	if configToUse = null then
		return;
	endif;
	
	create agent transient;
	
	agent.setMyFormConfiguration (configToUse);
	agent.customiseForm (self);
epilog
	delete agent;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zSetupToolbar" id="72e575c5-7d29-4dfe-93ec-3987bcec5a3c">
        <updating/>
        <source>zSetupToolbar() updating, protected;
// ---------------------------------------------------------------------------
// Created:     28 July 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	toolbar		: CMUI_Toolbar;
	tmpStyle	: Integer;
begin

	toolbar := self.frmToolbar;
	tmpStyle := self.toolbarStyle;
	
	if tmpStyle = self.ToolbarStyle_None or
	   (tmpStyle = self.ToolbarStyle_ShowAllowHide and
	   (not self.showToolbar)) then
		toolbar.visible := false;
		return;
	endif;
	
	self.refreshToolbar();
	self.mnuBaseShowHideToolbar.caption := 'Hide Toolbar';
	self.frmToolbar.visible := true;
	
	self.topMargin := self.frmToolbar.height;
	
//	self.doResize();
	
end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
