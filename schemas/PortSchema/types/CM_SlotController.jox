        <Parameter name="_value" type="CM_SlotController" usage="io"/>
    </JadeMethod>
    <JadeMethod name="numPlannedTIs" id="aa603c07-4969-479c-8433-b3cb867c0f0e">
        <methodInvocation>mapping</methodInvocation>
        <source>numPlannedTIs(set: Boolean; _value: Integer io) mapping;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

	move : CM_FutureMove;
	fma : CM_FutureMoveArray;
	numTIS : Integer;
begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	fma := self.allPlannedFutureMoves;
	if fma.isEmpty then
		return;
	endif;
	foreach move in fma do
		// not EDI future moves - see self.getAllFutureMovesOfType or similar
		if move.moveType &lt;&gt; TI_FutureMoveEDI then
			numTIS := numTIS + 1;
		endif;
	endforeach;
	_value :=numTIS;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="removeColourCoding" id="7e4373ef-6cc2-4064-9d8c-191e474b0ab6">
        <updating/>
        <source>removeColourCoding() updating;
// ---------------------------------------------------------------------------
// Created:     29 January 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// PAR 23216
// ---------------------------------------------------------------------------

vars

	slot : CM_SlotRequest;
begin
	slot := self.mySlotRequestLoad;
	self.removeSlotRequest(slot);
	slot := self.mySlotRequestDischarge;
	self.removeSlotRequest(slot);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="removeSlotRequest" id="fd27ceb2-2674-4f92-8bc2-54237dbc494c">
        <updating/>
        <source>removeSlotRequest(_slotRequest : CM_SlotRequest input) updating;
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
// 21/10/2003	CNWJC2	Changed to take care of aft SR as well
//----------------------------------------------------------------------------
vars
	otherSlotRequest	: CM_SlotRequest;
	
	invalidObject : Boolean;
begin
	on Exception do app.handleDeletedObject(exception,_slotRequest,invalidObject);

	
	if _slotRequest = null then
		return;
	endif;
	
	if _slotRequest.isLoad then
		if self.allSlotRequestsLoad.includes(_slotRequest) then
			self.allSlotRequestsLoad.remove(_slotRequest);
		endif;

		// always check this in case we get out of sync
		if self.mySlotRequestLoad = _slotRequest then
			self.mySlotRequestLoad := self.allSlotRequestsLoad.first;
		endif;
		
		otherSlotRequest := _slotRequest.mySlotRequestAft;
		if otherSlotRequest &lt;&gt; null then
			self.myAftSlot.removeSlotRequest(otherSlotRequest);
		endif;
	else
		if self.allSlotRequestsDischarge.includes(_slotRequest) then
			self.allSlotRequestsDischarge.remove(_slotRequest);
		endif;

		if self.mySlotRequestDischarge = _slotRequest then
			self.mySlotRequestDischarge := self.allSlotRequestsDischarge.first;
		endif;

		otherSlotRequest := _slotRequest.mySlotRequestAft;
		if otherSlotRequest &lt;&gt; null then
			self.myAftSlot.removeSlotRequest(otherSlotRequest);
		endif;
	endif;
end;</source>
        <Parameter name="_slotRequest" type="CM_SlotRequest" usage="input"/>
    </JadeMethod>
