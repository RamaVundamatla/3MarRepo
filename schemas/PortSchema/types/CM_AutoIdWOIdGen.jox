    <JadeMethod name="setForCreate" id="65b429a2-12c8-480d-a632-2a84122fbdc5">
        <updating/>
        <source>setForCreate(_proxy: CM_AutoIdGenerator) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 June 2018	jlgndl1	Initial creation

*/

vars

	wo : CM_WorkOrder;
	pos : Integer;
	char : Character;
	lastId : String;
	nextSeqNum : Integer;
	theKeySeries : CM_KeySeries;

begin

	inheritMethod(_proxy);
	
	//When initially setting up, if the user has not chosen a start number
	if not self.isTransient and self.nextSequenceNum = 0 then
		//find the last work order ti added, and gets its id
		self.nextSequenceNum := 1; // set it to the default value of one.
		
		//use the key series number if its been set up.
		theKeySeries := self.myTerminal.allKeySeriesByCode[SN_WorkOrder];
		if theKeySeries &lt;&gt; null and theKeySeries.nextKey &lt;&gt; null then
			self.nextSequenceNum := theKeySeries.nextKey.root;
			return;
		endif;
		
		// OK last ditch attempt, try to decipher one from the existing data.
		wo := self.myTerminal.allWorkOrders.last;
		if wo &lt;&gt; null then
			//build a string of the numbers on the right hand end of its id.
			pos := wo.id.length;
			while pos &gt; 0 do
				char := wo.id[pos].Character;
				if char.isNumeric then
					lastId := char.String &amp; lastId;
					pos := pos - 1;
				else
					break;
				endif;
			endwhile;
			if lastId &lt;&gt; null then
				//trim the left hand side of the numeric string to its max allowable length
				while true do
					if lastId.length &lt;= idSeqNumLength then
						break;
					endif;
					lastId := lastId[2:end];
				endwhile;
				// populate the starting point
				nextSeqNum := lastId.Integer + 1;
				self.lastIdGenerated := wo.id;
				self.nextSequenceNum := nextSeqNum;
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_proxy" type="CM_AutoIdGenerator"/>
    </JadeMethod>
</Class>
