<Class name="UM_CleanUpDetailsCompact" id="20318c72-17fc-46e4-9d97-a7979402be7b">
    <superclass name="UM_CleanUpDetails"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="unitTest"/>
    <PrimAttribute name="endSize" id="a34a907f-d130-4095-b7b0-263b621e92f7">
        <precision>15</precision>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myDoNotUse" id="f848ce30-5a2d-4036-ae5c-b27885fecdc4">
        <kind>child</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="UM_Root"/>
        <access>readonly</access>
        <Inverse name="UM_Root::allCleanUpDetailsByMapSETS"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myFileToMapFileName" id="eeb69d46-075d-475d-839b-b8977c1d14d5">
        <kind>child</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="UM_MapFilesToCompact"/>
        <access>readonly</access>
        <Inverse name="UM_MapFilesToCompact::allCleanUpDetails"/>
    </ExplicitInverseRef>
    <PrimAttribute name="startSize" id="d6db6e56-632f-458a-b164-db4fd756506e">
        <precision>15</precision>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="create" id="901f5ca9-f650-4514-9a30-f44604059e65">
        <updating/>
        <source>create() updating;

/*

Purpose:		

Date			Who		Reason
16 April 2015	cnwmh5	Initial creation

*/

vars

begin

	self.taskDescription := self.TaskDescriptionCompact;
	self.myDoNotUse := self.myRoot;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getIncBetweenRuns" id="be0ac6a3-1413-4561-84a5-1f0b81a2cb25">
        <source>getIncBetweenRuns(_cleanUpDetails : UM_CleanUpDetailsCompact) : Decimal;

/*

Purpose:		Get the increase details between passed in run and the previous run	

Date			Who		Reason
11/06/2015		cnwmh5	Initial creation

*/

vars

	cleanUpCompact						: UM_CleanUpDetailsCompact;
	
	iter								: Iterator;

	incBetweenRuns						: Decimal[12,0];

begin

	iter := _cleanUpDetails.myRoot.allCleanUpDetailsCompact.createIterator;
	_cleanUpDetails.myRoot.allCleanUpDetailsCompact.startKeyGeq(_cleanUpDetails.startTS, _cleanUpDetails.endTS, iter);
	iter.back(cleanUpCompact);
	
	while iter.back(cleanUpCompact) do
		if cleanUpCompact.myFileToMapFileName = _cleanUpDetails.myFileToMapFileName	then
			incBetweenRuns := _cleanUpDetails.startSize - cleanUpCompact.endSize;
			break;
		endif;	
	endwhile;

	return incBetweenRuns;
	
epilog

	delete iter;
	
end;
</source>
        <Parameter name="_cleanUpDetails" type="UM_CleanUpDetailsCompact"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="sizeDiffStartingEnding" id="b96fbf53-6e49-44de-819c-a1674ee29938">
        <source>sizeDiffStartingEnding(): Decimal;

/*

Purpose:		Difference between starting and ending size

Date			Who		Reason
17/04/2015		cnwmh5	Initial creation

*/

vars

begin

	return self.endSize - self.startSize;

epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="updateDetailsCompact" id="161c2313-7158-45ce-ae35-61de5e4aec31">
        <updating/>
        <source>updateDetailsCompact(_mapFileName : String; _startTS, _endTS : TimeStamp; _startSize, _endSize : Decimal) updating;

/*

Purpose:		

Date			Who		Reason
16 April 2015	cnwmh5	Initial creation

*/

vars

begin

	self.startTS := _startTS;
	self.endTS := _endTS;
	self.startSize := _startSize;
	self.endSize := _endSize;
	
	if self.myRoot &lt;&gt; null then
		self.myFileToMapFileName := self.myRoot.allMapFilesToCompact[_mapFileName];	
	endif;

epilog

end;</source>
        <Parameter name="_mapFileName" type="String"/>
        <Parameter name="_startTS" type="TimeStamp"/>
        <Parameter name="_endTS" type="TimeStamp"/>
        <Parameter name="_startSize" type="Decimal"/>
        <Parameter name="_endSize" type="Decimal"/>
    </JadeMethod>
</Class>
