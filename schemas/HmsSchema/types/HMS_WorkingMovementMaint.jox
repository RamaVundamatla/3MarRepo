    <JadeMethod name="cmbOrientTo_click" id="bbd293f9-599b-4b54-b379-8609a1714a9c">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbOrientTo_click(combobox: ComboBox input) updating;
/*
// 02/07/2010	cnmwh5	PAR23494 - If the ships orientation doesn't change and bow / bridge mark haven't 
//						changed then we don't need to recalc marks or clearances
*/
vars
	validForDT: Boolean;
begin
	if self.checkAndUpdateMoveDT(validForDT,false,true)=false then
		// DT hasn't changed ie. clearances have not already been checked.
		// The ship orientation has changed, recalc marks and clearances
		if self.checkOrientationHasChanged() then			// 02/07/2010 cnmwh5 #23494
			self.checkAndSetClearances(false, true);
		endif;
	endif;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
