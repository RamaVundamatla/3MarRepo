    <JadeMethod name="createRequests" id="c13bc984-bf39-4840-a628-56c2c29199ff">
        <source>createRequests(pProxyBulkRelease : CM_BulkRelease);
// ---------------------------------------------------------------------------
// Created:     22 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	proxyDeliveryRequest	: CM_DeliveryRequest;
	array 	: StringArray;
	releaseNum : String;
begin
	if self.type = BR_TYPE_BOL then
		releaseNum := self.releaseNo;
	endif;


	create proxyDeliveryRequest transient;
	
	proxyDeliveryRequest.set(self.consigneeCode,
							self.consignorVoyageCode,
							releaseNum,	// deliveryNumber, 
							null,	// eirNumber,
							self.isoType,
							operatorCode,
							self.myOperatorGroup, //tmpOperatorGroup,
							self.myCargoType,
							self.clean,
							self.doISOGroupCheck,	// RDD 8/8/2001 Xpose 1231/POT 147
							TI_DOORSDIRN_NULL,
							self.heavyRated,
							false,
							self.needCOU,
							self.needGenerator, 
							self.removeStops,
							self.totalRequested,
							null,
							self.allAvailabilityGrades, 
							self.deliveryReason,
							self.remarks,
							null,	/*Ids*/
							null,	// pinNo
							self.myTransferToTerminal,
							null,
							self.mySubTerminal,		// cnwdad1 02/07/2009 - CCMS 1735
							self.isoTypeGroup,					// MES1008 JMH 29/9/09 Add iso group
							0, null,
							null,
							null	//18 Feb 2014	NDL	Par 33524
							);

	if idMask &lt;&gt; "" then
		create array transient;
		idMask.convertToDelimitedArray(",", array);
		if array &lt;&gt; null then
			array.copy(ids);
			proxyDeliveryRequest.setIds(ids);
		endif;
	endif;

	proxyDeliveryRequest.setBulkRelease(pProxyBulkRelease);
epilog
	delete array;	
end;</source>
        <Parameter name="pProxyBulkRelease" type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="createReserves" id="db709616-e1ed-437e-adda-53a96a88aee4">
        <source>createReserves(pProxyBulkRelease : CM_BulkRelease input);
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	proxyReserveSelection	: CM_ReserveSelection;
	array 	: StringArray;
begin
	inheritMethod(pProxyBulkRelease);
	
	create proxyReserveSelection transient;
	proxyReserveSelection.setProxyFromCMIF(self);

	if idMask &lt;&gt; "" then
		create array transient;
		idMask.convertToDelimitedArray(",", array);
		if array &lt;&gt; null then
			proxyReserveSelection.setIds(array);
		endif;
	endif;
	proxyReserveSelection.setMyHeader(pProxyBulkRelease);
	
		
epilog
	delete array;	
end;</source>
        <Parameter name="pProxyBulkRelease" type="CM_BulkRelease" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTotalRequested" id="2147e8de-0e21-4432-b688-d0a5e0a075be">
        <source>getTotalRequested(): Integer ;
//--------------------------------------------------
// Created:	26 November 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	return self.totalRequested;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateProxy" id="bc9126ec-4797-457e-8d67-454b4a414a12">
        <updating/>
        <source>updateProxy(pProxyBulkRelease: CM_BulkRelease io) updating;
// ---------------------------------------------------------------------------
// Created:     27 August 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(pProxyBulkRelease);

	pProxyBulkRelease.allocTIsForRelease(self.allTrackedItems, self.doNotAssignTI);
	pProxyBulkRelease.allAvailabilityGrades.clear;
	self.allAvailabilityGrades.copy(pProxyBulkRelease.allAvailabilityGrades);
end;</source>
        <Parameter name="pProxyBulkRelease" type="CM_BulkRelease" usage="io"/>
    </JadeMethod>
</Class>
