    <JadeMethod name="doAddVvrWeighingRecord" id="ff5980b2-3751-4603-8db4-494f2c0d8720">
        <updating/>
        <source>doAddVvrWeighingRecord( _close : Boolean ) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 July 2019	jlger1	Initial creation 44965

*/

vars
	pxyWeighing :CM_VehicleVisitWeighing;
	theReturn : Integer;
begin
	if self.myVehicleVisitRecord = null then
		return;
	endif;
	
	create pxyWeighing transient;
	self.setVVRWeighingProxy( pxyWeighing );
	
	while true do
		app.myTrxUA.trxAddVVRWeighing(self.myVehicleVisitRecord, pxyWeighing, null,  null, null, app.myPassport);

		if not app.myPassport.trxCompletedOK then
			theReturn := app.showErrorWarningDialog(app.getErrorString(Weigh_vehicle), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged     := true;
				continue;
			endif;
			break;
		endif;
		break;
	endwhile;
	
	if app.myPassport.trxCompletedOK and _close then
		self.modalResult := theReturn;	//08 July 2019	NLD	TFS 44965
		self.unloadForm;
	endif;

epilog
	delete pxyWeighing;
end;</source>
        <access>protected</access>
        <Parameter name="_close" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doHandleNotifications" id="387cc1cc-40fb-4bab-9589-24562964320d">
        <updating/>
        <source>doHandleNotifications(eventType: Integer; theObject: Object; eventTag: Integer) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
16 July 2022	navmd1	Initial creation

*/

vars
	invalid,
	detailsChangedVehicle	: Boolean;
	gateScanRecord			: CM_GenericGateScanRecord;
begin
	if theObject = null then
		return;
	endif;
	
	on Exception do app.handleDeletedObject( exception, gateScanRecord, invalid );

	if theObject.isKindOf(CM_GenericGateScanRecord) then
		gateScanRecord := theObject.CM_GenericGateScanRecord;
		gateScanRecord.edition;
		
		// If the note is not for our terminal or device, then ignore it
		if invalid or gateScanRecord.myTerminal &lt;&gt; self.myTerminal or self.myAssistant.allAssociatedDevices[gateScanRecord.deviceId] = null then
			return;
		endif;

		if eventType = Object_Create_Event or eventType = Object_Update_Event then
			self.tblScaleWeight.enabled := true;
			self.myAssistant.populateScanData(true, false, detailsChangedVehicle, null, null, null, null, null, null, null, self.tblScaleWeight, gateScanRecord);
			self.tblScaleWeight.enabled := false;
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
