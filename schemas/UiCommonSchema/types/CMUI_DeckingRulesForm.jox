    <JadeMethod name="delete" id="9a6fea25-3aaa-49f5-9ec5-416abb6fc11c">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>delete() updating, clientExecution;
//16 December 2008	cnwdw1	
//14 July 2010 cnwjo3.  Added exception handling for invalid objects
vars
	invalid : Boolean;
	deckingOptions : CM_YADeckingOptions;
begin
	//delete self.myProxyDeckingOptions;
	deckingOptions := self.myProxyDeckingOptions;
	
	if deckingOptions &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception,deckingOptions,invalid);
	endif;
	
	delete deckingOptions;
	
	locations.purge;
	unload;
end;</source>
    </JadeMethod>
    <JadeMethod name="disableOptions" id="f2835856-e334-4d64-8e5a-0342c50bcfab">
        <source>disableOptions(_disable: Boolean);
//----------------------------------------------------------------
//	Created:	22 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	enabled		: Boolean;
begin

	enabled := not _disable;
	
	self.fldOptions.enabled := enabled;
	self.btnCancel.enabled := enabled;
	self.btnOk.enabled := enabled;
end;</source>
        <Parameter name="_disable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doAddInRule" id="797692c6-8530-41fb-a9c3-4e0a0454f489">
        <source>doAddInRule();
//----------------------------------------------------------------
//	Created:	25 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	pxyRule	: CM_YADeckingRule;
	intFrom, intTo : Integer;
begin
	on Exception do self.addToTableExHandler(exception);

	intFrom := 1;
	intTo := self.myProxyDeckingOptions.getStackHeight;
	
	create pxyRule transient;
	//epr tfs 1919 29/4/16
	self.myProxyDeckingOptions.allDeckingRulesIn.purge; 	
	//add to proxy
	self.myProxyDeckingOptions.allDeckingRulesIn.add(pxyRule);
	
	//set the proxy
	pxyRule.setProxyBasic(DeckingRule_Custom, intFrom, intTo, true);
	
	
		
end;</source>
    </JadeMethod>
    <JadeMethod name="doAddOutRule" id="25238b11-ad57-4564-896a-8c2d46a7a251">
        <source>doAddOutRule();
//----------------------------------------------------------------
//	Created:	25 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	pxyRule	: CM_YADeckingRule;
	intFrom, intTo : Integer;
begin
	on Exception do self.addToTableExHandler(exception);
	
	intFrom := 1;
	intTo := self.myProxyDeckingOptions.getStackHeight;
	
	create pxyRule transient;
	//epr tfs 1919 29/4/16
	self.myProxyDeckingOptions.allDeckingRulesOut.purge;	
	//add to proxy
	self.myProxyDeckingOptions.allDeckingRulesOut.add(pxyRule);
	//set the proxy
	pxyRule.setProxyBasic(DeckingRule_Custom, intFrom, intTo, true);

	

end;</source>
    </JadeMethod>
    <JadeMethod name="doDragDropLstLocations" id="8cdaee7e-77be-475b-a3b1-03abb5e7eb75">
        <updating/>
        <source>doDragDropLstLocations(listbox: ListBox input; win: Window input; x: Real; y: Real) updating;
//----------------------------------------------------------------
//	Created:	22 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

vars
	idx					: Integer;
	yaLocnCellTarget 	: CM_YALocationCell;
	tmpArray			: CM_YALocationCellArray;
	targetIndex			: Integer;
begin
	targetIndex := listbox.dragListIndex;
	
	if targetIndex &lt; 1 then
		return;
	endif;

	yaLocnCellTarget := listbox.itemObject[targetIndex].CM_YALocationCell;

	if yaLocnCellTarget = null then
		return;
	endif;

	if self.allSelectedLocnCells.includes(yaLocnCellTarget) then
		//user is backing out of the drag
		return;
	endif;

	create tmpArray transient;
	foreach yaLocnCellTarget in self.allSelectedLocnCells do
		idx := listbox.findObject(yaLocnCellTarget);
		tmpArray.atPut(idx, yaLocnCellTarget);
	endforeach;

	foreach yaLocnCellTarget in tmpArray reversed do
		if yaLocnCellTarget = null then
			//there'll be heaps of these for big lists
			continue;
		endif;
		idx := listbox.findObject(yaLocnCellTarget);
		listbox.removeItem(idx);
		if idx &lt; targetIndex then
			//keep adjusting for the removal
			targetIndex := targetIndex - 1;
		endif;
		
		self.addItemToListAt(targetIndex, yaLocnCellTarget);
		
		if not self.customOrderHasChanged then
			self.setCustomOrderHasChanged(true);
		endif;
		
	endforeach;

epilog
	delete tmpArray;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doDragOverLstLocations" id="c385ad82-4ce5-4f1b-bb5f-4651d3f46e9f">
        <updating/>
        <source>doDragOverLstLocations(listbox: ListBox input; win: Window input; x: Real; y: Real; state: Integer) updating;
//----------------------------------------------------------------
//	Created:	22 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	indexOver,
	indexBefore : Integer;
begin
	
	indexBefore := self.selectedIndex;
	
	
	//if self.selectedIndex &gt; 0 and self.selectedIndex &lt;= self.lstDeckingLocns.listCount then
	//	self.selectedIndex := ;
	//endif;
	
	indexOver := self.lstDeckingLocns.dragListIndex();

	if indexOver = indexBefore 
	or indexOver &lt; 1 then
		return;
	endif;

	self.lstDeckingLocns.clearAllSelected();

	if indexOver &lt; 1 then
		indexOver := indexBefore;
	endif;
	
	if indexOver &gt; 0 then
		self.selectedIndex := indexOver;
		self.lstDeckingLocns.itemSelected[indexOver] := true;
	endif;
					
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doDragOverScrollArea" id="d7223e06-7c68-4f8f-bbb0-e85ba4303922">
        <updating/>
        <source>doDragOverScrollArea(_top: Boolean) updating;
//----------------------------------------------------------------
//	Created:	24 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	now		: Integer;
begin
	now := app.clock();

	if _top then
		//scroll up
		if self.lstDeckingLocns.topIndex = 1 then
			//stop scrolling
			return;
		endif;
		if (now - self.lastScrollClock) &gt; 10 then	
			self.lstDeckingLocns.topIndex := self.lstDeckingLocns.topIndex - 5;
			self.lastScrollClock := now;
		endif;
	else
		//scroll down
		if (self.lstDeckingLocns.topIndex + self.lstDeckingLocns.lines) &gt; self.lstDeckingLocns.listCount then
			//stop scrolling
			return;
		endif;
		if (now - self.lastScrollClock) &gt; 10 then	
			self.lstDeckingLocns.topIndex := self.lstDeckingLocns.topIndex + 5;
			self.lastScrollClock := now;
		endif;
	endif;
	
end;</source>
        <Parameter name="_top" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMouseDownLstLocations" id="d55811bf-8d89-4d19-b316-dc325753166a">
        <updating/>
        <source>doMouseDownLstLocations(listbox: ListBox input; button: Integer; shift: Integer; x: Real; y: Real) updating;
//----------------------------------------------------------------
//	Created:	22 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	yaLocnCell : CM_YALocationCell;
begin

	if button = Window.MouseButton_Left then
		yaLocnCell := listbox.listObject.CM_YALocationCell;
		self.updateSelectedLocns(yaLocnCell, shift);						
	endif;

	self.dragMode := DragMode_None;	

	self.myCurrentListObject := yaLocnCell;

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doMouseMoveLstLocations" id="36691b33-d752-4c30-90bc-8e57eeb33140">
        <updating/>
        <source>doMouseMoveLstLocations(listbox: ListBox input; button: Integer; shift: Integer; x: Real; y: Real) updating;
//----------------------------------------------------------------
//	Created:	22 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	blnSelected	: Boolean;
	numSelected	: Integer;
begin

	if button = 0 then
		return;
	endif; 
	foreach blnSelected in self.lstDeckingLocns.itemSelected do
		if blnSelected then
			numSelected := numSelected + 1;
		endif;
		if numSelected &gt; 2 then
			break;
		endif;
	endforeach;

	if numSelected &lt; 1 then
		return;
	endif;

	self.dragMode := DragMode_Drag;
	if numSelected = 1 then	
		self.dragCursor := self.lstDeckingLocns.dragCursor;
	else
		self.dragCursor := self.frmCustomSetting.dragCursor;
	endif;

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doOK" id="fc40e3bb-882c-4654-bdc9-78d6452fc21c">
        <updating/>
        <source>doOK() updating;
vars
	deckingRuleIn, deckingRuleOut: CM_YADeckingRule;
	modeIn, modeOut, direction : Integer;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
begin
	if self.optCustomIn.value then
		modeIn := DeckingRule_Custom;
		if not self.chkOutUseRevOfIn.value then
			if self.optCustomOut.value then	
				modeOut := DeckingRule_Custom;
			else
				modeOut := DeckingRule_Advanced;
			endif;
		else
			modeOut := DeckingRule_ReverseOfOther;
		endif;
	else
		modeIn := DeckingRule_Advanced;
		if not self.chkOutUseRevOfIn.value then
			if self.optCustomOut.value then	
				modeOut := DeckingRule_Custom;
			else
				modeOut := DeckingRule_Advanced;
			endif;
		else
			modeOut := DeckingRule_ReverseOfOther;
		endif;	
	endif;

	
	if self.myYaBlock &lt;&gt; null then
		self.myProxyDeckingOptions.setProxy(self.chkShowHeights.value, self.chkOutUseRevOfIn.value, self.myYaBlock);
	else
		self.myProxyDeckingOptions.setProxy(self.chkShowHeights.value, self.chkOutUseRevOfIn.value, self.myTerminalArea);
	endif;
	
	deckingRuleIn := myProxyDeckingOptions.allDeckingRulesIn.first;
	deckingRuleIn.setProxyAndRuleType(modeIn, true, self.getAreaRule(DeckingDirectionIn), self.getStackRule(DeckingDirectionIn), self.getRowRule(DeckingDirectionIn)
						, getPatternRule(DeckingDirectionIn), self.getTopupTier(DeckingDirectionIn));			
	deckingRuleOut := myProxyDeckingOptions.allDeckingRulesOut.first;
	deckingRuleOut.setProxyAndRuleType(modeOut, false, self.getAreaRule(DeckingDirectionOut), self.getStackRule(DeckingDirectionOut), self.getRowRule(DeckingDirectionOut)
						, getPatternRule(DeckingDirectionOut), self.getTopupTier(DeckingDirectionOut));		

	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxApplyDeckingRule(myProxyDeckingOptions, DeckingLevel_YA, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Decking Options', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;

	self.unloadForm;
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doReverseOrderSelection" id="7fb47236-dfd4-41db-8042-ac05493c5f53">
        <updating/>
        <source>doReverseOrderSelection() updating;
//----------------------------------------------------------------
//	Created:	22 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	prevItemSelected,
	outSelection,
	inSelection,
	blnSelected		: Boolean;
	tmpArray		: CM_YALocationCellArray;
	idx,targetIndex	: Integer;
	yaLocnCell		: CM_YALocationCell;
begin
	//rule: selection must be contiguous

	create tmpArray transient;
	idx := 0;
	foreach blnSelected in self.lstDeckingLocns.itemSelected do
		idx := idx + 1;
		if blnSelected then
			if outSelection then
				//non-contiguous selection detected
				app.msgBox("To reverse a selection it must be contiguous.", "Error", MsgBox_OK_Only + MsgBox_Information_Icon);
				return;
			else
				yaLocnCell := self.lstDeckingLocns.itemObject[idx].CM_YALocationCell;
				tmpArray.add(yaLocnCell);
			endif;
		endif;
		if prevItemSelected
		and not blnSelected then
			outSelection := true;
		endif;
		prevItemSelected := blnSelected;
	endforeach;
	
	if tmpArray.isEmpty then
		return;
	endif;
	//must be OK to reverse
	
	targetIndex := self.lstDeckingLocns.findObject(tmpArray[1]);
	foreach yaLocnCell in tmpArray do
		if yaLocnCell = tmpArray[1] then
			//we're going to insert the others above it
			continue;
		endif;	
		idx := self.lstDeckingLocns.findObject(yaLocnCell);
		self.lstDeckingLocns.removeItem(idx);
	
		self.addItemToListAt(targetIndex, yaLocnCell);
		
		if not self.customOrderHasChanged then
			self.setCustomOrderHasChanged(true);
		endif;
	endforeach;
	
	
epilog
	tmpArray.clear;
	delete tmpArray;	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="drawArea" id="ce1b03a3-d8d3-4c84-91c8-ff5b1fbabb3c">
        <source>drawArea(_direction, _rows, _stacks, _tiers: Integer; _rowsLabel, _stacksLabel: String);
//12 December 2008	cnwdw1	
//
vars
	frame: CMUI_Frame;
	top, left, bottom, right: Integer;
	row, stack, tier: Integer;
	stackIncrement, rowOffset: Integer;
	labelOffsetX, labelOffsetY: Integer;
	cellWidth, cellHeight: Integer;
	rect: Rectangle;
	o: String;
	sequencer: CMIF_DeckingSequenceService;
	customMode : Boolean;
begin
	frame := self.frmOrderGraphic;
	frame.autoRedraw := true;
	frame.clearGraphics;
	frame.drawStyle := Frame.DrawStyle_Solid;
	frame.drawWidth := 1;
	frame.drawFillColor := LightGray;
	locations.purge;
	
	stackIncrement := ((frame.height) / 3).Integer;
	rowOffset := 70;
	cellWidth := 30;
	cellHeight := 23;
	labelOffsetX := 20;
	labelOffsetY := 7;
	foreach stack in 1 to _stacks do
		top := (_stacks-stack) * stackIncrement;
		left := stack * rowOffset;
		bottom := top + (cellHeight * _tiers);
		right := left + (cellWidth * _rows);
		
		frame.drawFilledRectangle(left, top, right, bottom, Black);
		foreach tier in 1 to _tiers do
			if tier &lt; _tiers then
				frame.drawLine(left, top+(tier*cellHeight), right, top+(tier*cellHeight), Black);
			endif;
			frame.drawTextAlign := DrawTextAlign_Left;
			frame.drawTextAt("T"&amp;(_tiers+1-tier).String, left-labelOffsetX, top+((tier-1)*cellHeight)+labelOffsetY, Black);
			if tier = 2 then
				frame.drawTextAt(_stacksLabel&amp;(64+stack).Character, right + labelOffsetY, top+((tier-1)*cellHeight)+labelOffsetY, Black);
			endif;
			
			foreach row in 1 to _rows do
				create rect transient;
				rect.left := left+((row-1)*cellWidth) + 1;
				rect.top := top+((_tiers-tier)*cellHeight) + 1;
				rect.right := rect.left + cellWidth - 1;
				rect.bottom := rect.top + cellHeight - 1;
				locations[row, stack, tier] := rect;
			endforeach;
		endforeach;
		foreach row in 1 to _rows do
			if row &lt; _rows then
				frame.drawLine(left+(row*cellWidth), top, left+(row*cellWidth), bottom, Black);
			endif;	
			frame.drawTextAlign := DrawTextAlign_Center;
			frame.drawTextAt("R"&amp;row.String, left+((row-1)*cellWidth)+(cellWidth/2), bottom+1, Black);
		endforeach;
	endforeach;
	
	create sequencer transient;
	sequencer.onCreate(self.getAreaRule(_direction));
	sequencer.setExtent(_stacks, _rows, _tiers);
	sequencer.topupTier := self.getTopupTier(_direction);
	sequencer.setRules(self.getStackRule(_direction), self.getRowRule(_direction), self.getPatternRule(_direction));
	
	if self.fldOptions.topSheet = self.shtIn then
		customMode := self.optCustomIn.value;
	else
		customMode := self.optCustomOut.value;
	endif;
	foreach stack in 1 to _stacks do
		foreach row in 1 to _rows do
			foreach tier in 1 to _tiers do
				if customMode then
					o := "?";
				else
					o := sequencer.getStackingSequence(stack, row, tier).String;
				endif;
				self.drawOrderNumber(row,stack,tier,o);
			endforeach;
		endforeach;
	endforeach;
epilog
	delete sequencer;
end;</source>
        <Parameter name="_direction" type="Integer"/>
        <Parameter name="_rows" type="Integer"/>
        <Parameter name="_stacks" type="Integer"/>
        <Parameter name="_tiers" type="Integer"/>
        <Parameter name="_rowsLabel" type="String"/>
        <Parameter name="_stacksLabel" type="String"/>
    </JadeMethod>
    <JadeMethod name="drawOrderNumber" id="9faf2d11-d057-4910-ab2f-3d0221d7f738">
        <source>drawOrderNumber(_x, _y, _z: Integer; _order: String);
//16 December 2008	cnwdw1	
//
vars
	rect: Rectangle;
	frame: CMUI_Frame;
begin
	rect := self.locations[_x, _y, _z].Rectangle;
	if rect &lt;&gt; null then
		frame := self.frmOrderGraphic;
		frame.drawTextAlign := DrawTextAlign_Center;
		frame.drawTextAt(_order, rect.left + ((rect.right - rect.left) / 2), rect.top + 5, Black);
	endif;
	
end;</source>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <Parameter name="_z" type="Integer"/>
        <Parameter name="_order" type="String"/>
    </JadeMethod>
    <JadeMethod name="enableFormCustomClose" id="f495112d-fd2e-4c41-885f-b0e9d3cdb59f">
        <source>enableFormCustomClose();
//----------------------------------------------------------------
//	Created:	22 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	self.disableOptions(false);
end;</source>
    </JadeMethod>
    <JadeMethod name="fldOptions_sheetChg" id="c07271d3-384f-494f-9ea6-1dc120354342">
        <controlMethod name="Folder::sheetChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>fldOptions_sheetChg(folder: Folder input) updating;

vars
	mode : Integer;
begin
	if self.fldOptions.topSheet = self.shtIn then
		mode := DeckingDirectionIn;
	else
		mode := DeckingDirectionOut;
	endif;
	
	self.showForm;
end;</source>
        <Parameter name="folder" type="Folder" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAreaRule" id="4e8bdab1-7f6c-42f6-9856-7dc760669986">
        <source>getAreaRule(_direction: Integer): Integer;
//06 January 2009	cnwdw1	
//
vars

begin
	if _direction = DeckingDirectionIn then
		if self.optByRowIn.value then
			if self.chkRowFillIn.value then
				return DeckingRule_ByRowFill;
			endif;
			return DeckingRule_ByRow;
		elseif self.optByStackIn.value then
			if self.chkStkFillIn.value then
				return DeckingRule_ByStackFill;
			endif;
			return DeckingRule_ByStack;
		endif;
	elseif _direction = DeckingDirectionOut then
		if self.optByRowOut.value then
			if self.chkRowFillOut.value then
				return DeckingRule_ByRowFill;
			endif;
			return DeckingRule_ByRow;
		elseif self.optByStackOut.value then
			if self.chkStkFillOut.value then
				return DeckingRule_ByStackFill;
			endif;
			return DeckingRule_ByStack;
		endif;
	endif;
	
	return 0;
end;</source>
        <Parameter name="_direction" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getPatternRule" id="f6825e14-7bc2-4923-b705-a6f608d56534">
        <source>getPatternRule(_direction: Integer): Integer;
//30 December 2008	cnwdw1	
//
vars

begin
	if _direction = DeckingDirectionIn then
		if self.optColumnwiseIn.value then
			return DeckingRule_Columnwise;
		elseif self.optTierwiseIn.value then
			return DeckingRule_Tierwise;
		elseif self.optTopupIn.value then
			return DeckingRule_Topup;
		elseif self.optSideToSideIn.value then
			return DeckingRule_SideToSide;
		endif;
	elseif _direction = DeckingDirectionOut then
		if self.optColumnwiseOut.value then
			return DeckingRule_Columnwise;
		elseif self.optTierwiseOut.value then
			return DeckingRule_Tierwise;
		elseif self.optTopupOut.value then
			return DeckingRule_Topup;
		elseif self.optSideToSideOut.value then
			return DeckingRule_SideToSide;
		endif;
	endif;
	
	return DeckingRule_Null;
end;</source>
        <Parameter name="_direction" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRowRule" id="e11b13c4-0967-4296-9576-7fd4c52101ee">
        <source>getRowRule(_direction: Integer): Integer;
//30 December 2008	cnwdw1	
//
vars

begin
	if _direction = DeckingDirectionIn then
		if self.optRowIncreasIn.value then
			return DeckingRule_Increasing;
		elseif self.optRowDecreasIn.value then
			return DeckingRule_Decreasing;
		elseif self.optRowMiddleOutI.value then
			return DeckingRule_MiddleOut;
		endif;
	elseif _direction = DeckingDirectionOut then
		if self.optRowIncreasOut.value then
			return DeckingRule_Increasing;
		elseif self.optRowDecreasOut.value then
			return DeckingRule_Decreasing;
		elseif self.optRowMiddleOutO.value then
			return DeckingRule_MiddleOut;
		endif;	
	endif;
	
	return DeckingRule_Null;
end;</source>
        <Parameter name="_direction" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getStackRule" id="816a8274-31d9-49cb-8e22-0c51c26ab14b">
        <source>getStackRule(_direction: Integer): Integer;
//30 December 2008	cnwdw1	
//
vars

begin
	if _direction = DeckingDirectionIn then
		if self.optStkIncreasIn.value then
			return DeckingRule_Increasing;
		elseif self.optStkDecreasIn.value then
			return DeckingRule_Decreasing;
		elseif self.optStkMiddleOutI.value then
			return DeckingRule_MiddleOut;
		endif;
	elseif _direction = DeckingDirectionOut then
		if self.optStkIncreasOut.value then
			return DeckingRule_Increasing;
		elseif self.optStkDecreasOut.value then
			return DeckingRule_Decreasing;
		elseif self.optStkMiddleOutO.value then
			return DeckingRule_MiddleOut;
		endif;
	endif;
	return DeckingRule_Null;
end;</source>
        <Parameter name="_direction" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTopupTier" id="96ac477a-73ed-42b7-b8af-310a0fe34048">
        <source>getTopupTier(_direction: Integer): Integer;
//30 December 2008	cnwdw1	
//
vars

begin
	if _direction = DeckingDirectionIn then
		if self.optTopupIn.value then
			return self.txtTopupTierIn.text.Integer;
		endif;
	elseif _direction = DeckingDirectionOut then
		if self.optTopupOut.value then
			return self.txtTopupTierOut.text.Integer;
