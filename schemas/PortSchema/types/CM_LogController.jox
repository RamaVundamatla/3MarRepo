    <JadeMethod name="getIsFumigatedSpecial" id="4fdeb823-153c-4ad7-8015-4c573a0d572d">
        <source>getIsFumigatedSpecial(): Boolean;
/* ---------------------------------------------------------------------------
Created:	17 September 2009	by cnwvu1

Purpose:	CCMS1107 / PAR 20627 for Conversion script ccms1107_convertLogRowDetails().
			Used to go from JMT 772 to JMT 773 version.
			
			NEED to be DELETED when JMT is 774 or greater version/
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	if self.myTerminal = null then
		return null;
	endif;
	
	return self.myTerminal.getExtraData(LogRowExtraData_Fumigated &amp; self.getOidString()).Boolean;


end;</source>
