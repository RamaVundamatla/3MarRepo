/*

Purpose:			

Parameters:			used by "frmSelectorPane"	

Return Value:		


Date		Who		Reason
29 July 2011	cnwndl1	Initial creation	par 27890

*/

vars

begin

	self.frmSelectorPane.handleMenuItemClick( menuItem );
	return;
	
	// not called because of the return above, just here to give a reference
	// so some clown doesn't delete the high level one.
	inheritMethod( menuItem );

epilog

end;</source>
