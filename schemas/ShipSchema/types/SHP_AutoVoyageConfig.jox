    <JadeMethod name="cmbDischargeTAType_lostFocus" id="90031e0c-6cdb-4932-94d7-f464793d4118">
        <controlMethod name="CMUI_ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbDischargeTAType_lostFocus(combobox: ComboBox input) updating;
/*
Purpose:

Date		Who		Reason
08 July 2024	navab1	CR 64615 TASK 64649
*/

vars
	areaTypeCode : Integer;
	
begin
	areaTypeCode := TA_TYPE_NULL;
	if combobox.listObject &lt;&gt; null then		
		areaTypeCode := combobox.listObject.CM_TerminalAreaType.type; 
	endif;
	
	self.cmbDischargeTA.gotFocus(self.cmbDischargeTA);	
	self.myAssistant.comboBoxTerminalArea(self.cmbDischargeTA,areaTypeCode,null);
	self.cmbDischargeTA.lostFocus(self.cmbDischargeTA);

epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbDischargeTA_lostFocus" id="8f9b1b83-be74-4138-a008-8be9083b4a6a">
        <controlMethod name="CMUI_ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbDischargeTA_lostFocus(combobox: ComboBox input) updating;
/*
Purpose:		

Date		Who		Reason
08 July 2024	navab1	CR 64615 TASK 64649
*/

vars
	tmpTA 	: CM_TerminalArea;

begin
	tmpTA := combobox.listObject.CM_TerminalArea;
	if tmpTA = null then
		self.cmbDischargeLC.clear();		
	else
		self.doBuildCmbDischLC();
	endif;

epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
