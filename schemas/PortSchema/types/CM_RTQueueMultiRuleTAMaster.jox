<Class name="CM_RTQueueMultiRuleTAMaster" id="fb83336f-65c2-49e7-af98-4bc3308f0dac">
    <superclass name="CM_RTQueueMultiRule"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="planning"/>
    <ExplicitInverseRef name="myFromTAMaster" id="054f7e0a-deee-4ea1-82d9-b28211eade24">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_TerminalAreaMaster"/>
        <access>readonly</access>
        <Inverse name="CM_TerminalAreaMaster::allRTQueueMultiRulesFrom"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myToTAMaster" id="2ee692ac-b7e4-4c6b-883e-626d5943f3c0">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_TerminalAreaMaster"/>
        <access>readonly</access>
        <Inverse name="CM_TerminalAreaMaster::allRTQueueMultiRulesTo"/>
    </ExplicitInverseRef>
    <JadeMethod name="getDisplayStringForAttribute" id="9d5eea7e-2991-4778-88e5-e1e34ae15bd7">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

// Created by cnwdvb1 on 05 September 2006

vars

begin
	
	if _attrName = ETRow_FromTerminalArea then
		if self.myFromTAMaster &lt;&gt; null then
			return self.myFromTAMaster.getID();
		endif;
		return 'Any';
	elseif _attrName = ETRow_ToTerminalArea then
		if self.myToTAMaster &lt;&gt; null then
			return self.myToTAMaster.getID();
		endif;
		return 'Any';
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getName" id="49158fe1-f880-4741-8aea-2cbb0c06d137">
        <source>getName(): String;

// Created by cnwdvb1 on 18 September 2006

vars

begin


	return inheritMethod &amp; ' ' &amp; self.getDisplayStringForAttribute(ETRow_FromTerminalArea, false) &amp; ' / ' &amp; 
	self.getDisplayStringForAttribute(ETRow_ToTerminalArea, false);

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="1e0c7c25-f072-49b4-8da2-95f8fd96223f">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
10 February 2010	cnwer1	Initial creation
20/04/2011			cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
							trying to create the proxy
*/

vars
	pxyRTQueueMultiRuleTAMaster : CM_RTQueueMultiRuleTAMaster;
	completedOK		: Boolean;
begin
	pxyRTQueueMultiRuleTAMaster:= inheritMethod();
	pxyRTQueueMultiRuleTAMaster.myFromTAMaster:=self.myFromTAMaster;
	pxyRTQueueMultiRuleTAMaster.myToTAMaster:=self.myToTAMaster;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyRTQueueMultiRuleTAMaster;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyRTQueueMultiRuleTAMaster;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForProxyTAMaster" id="9ad07f2a-e651-40b2-b996-3f039ad2f8f1">
        <updating/>
        <source>setForProxyTAMaster(_fromTAMaster, _toTAMaster : CM_TerminalAreaMaster;  _terminal : CM_Terminal) updating;

// Created by cnwdvb1 on 29 August 2006

vars

begin

	self.myFromTAMaster	:= _fromTAMaster;
	self.myToTAMaster	:= _toTAMaster;
	
	self.setForProxy( _terminal);

end;</source>
        <Parameter name="_fromTAMaster" type="CM_TerminalAreaMaster"/>
        <Parameter name="_toTAMaster" type="CM_TerminalAreaMaster"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="647ca252-2681-4eab-b5e1-4acf89622a5a">
        <updating/>
        <source>setForUpdate(_pxyRTQueueMultiRule: CM_RTQueueMultiRuleTAMaster) updating;

// Created by cnwdvb1 on 29 August 2006

vars

begin

	self.myFromTAMaster	:= _pxyRTQueueMultiRule.myFromTAMaster;
	self.myToTAMaster	:= _pxyRTQueueMultiRule.myToTAMaster;
	inheritMethod(_pxyRTQueueMultiRule);

end;</source>
        <Parameter name="_pxyRTQueueMultiRule" type="CM_RTQueueMultiRuleTAMaster"/>
    </JadeMethod>
    <JadeMethod name="validateUpdate" id="508c526f-9374-403c-92d5-d5045ed51bf8">
        <source>validateUpdate(_passport: CM_Passport input);

// Created by cnwdvb1 on 05 September 2006

vars
	
	realRule,
	rule : SelfType;

begin
	
	inheritMethod(_passport);
	if self.myFromTAMaster = null and self.myToTAMaster = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'either the From Terminal Area Master or To Terminal Area Master', null, null);
		app.raiseCMException(Input_required_field_frmTrmAra, null, null); // cnwdb2	PAR 35364
	endif;
	
	rule := self.myTerminal.allRTQueueMultiRuleTAMasters[self.myFromTAMaster, self.myToTAMaster];
	
	realRule := self.pxyGetRealObject();
	
	if rule &lt;&gt; null and rule &lt;&gt; realRule then
		app.raiseCMException2(ERR_INVALID_VALUE, "From Terminal Area Master and To Terminal Area Master","A Rule already exists with the same configuration", null, null);
	endif;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
