    <JadeMethod name="create" id="d28500c0-b075-4ed1-8fb4-11a660fdb5a1">
        <updating/>
        <source>create() updating;
//--------------------------------------------------
// Created:	11 August 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.permissionMaint := PmHMSDelayMaint;
	self.permissionView := PmHMSDelayView;	
end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="89b6ae43-a2da-401b-b156-96e3cef56edf">
        <updating/>
        <source>doOK() updating;
//--------------------------------------------------
// Created:	11 August 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.updateVoyageDelay() then
		inheritMethod();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="5c6541fc-92c4-42d0-a7df-c409a09048a8">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
//--------------------------------------------------
// Created:	11 August 2005 By: cnwgd1
//--------------------------------------------------
vars
	now : TimeStamp;
begin
	inheritMethod();
	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	if self.myVoyageDelay &lt;&gt; null then
		self.cmbDelay.listIndex := self.cmbDelay.findObject(self.myVoyageDelay.myDelay);
		self.txtDateFrom.setDate(self.myVoyageDelay.startTime.date);
		self.txtTimeStart.setTime(self.myVoyageDelay.startTime.Time);		
		self.txtDateTo.setDate(self.myVoyageDelay.stopTime.date);
 		self.txtTimeEnd.setTime(self.myVoyageDelay.stopTime.Time);	
		self.cbxChargeable.value := self.myVoyageDelay.isChargeable;
	
	else
		self.txtDateFrom.setDate(now.Date);
		self.txtTimeStart.setTime(now.Time);		
		self.txtDateTo.setDate(now.Date);
 		self.txtTimeEnd.setTime(now.Time);

		if self.cmbDelay.listCount &gt; 0 then
			self.cmbDelay.listIndex := 1;
		endif;	
	 			
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="25f7f6cc-ed63-4bc3-90da-8eb71d348224">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------
// Created:	11 August 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();
	if self.myTerminal.myHarbour &lt;&gt; null then
		self.cmbDelay.listCollection(app.myRoot.allHMSDelays,true,0);
	endif;
	self.modalResult := IDCANCEL;		
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="7c64c0af-2882-4660-b99b-1f025a41d97f">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008249, locale);
	blbStart.translateCaption(Xlat_0001141, locale);
	cbxChargeable.translateCaption(Xlat_0001140, locale);
	lblDelay.translateCaption(Xlat_0001142, locale);
	lblFinish.translateCaption(Xlat_0001143, locale);
	lblInfo.translateCaption(Xlat_0001144, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="updateVoyageDelay" id="ce0dad32-0e47-4a5f-b793-b7fd949c561e">
        <updating/>
        <source>updateVoyageDelay():Boolean updating;
//-----------------------------------------
// Created: August 2005 By: cnwgd1
//-----------------------------------------
vars
	modeUpdate : Boolean;
	result : Integer;
	realDelay : HMS_Object;
	pxyVoyageDelay : HMS_VoyageDelay;
	tsFrom,
	tsTo		: TimeStamp;
begin

	if self.myVoyageDelay = null then
		create pxyVoyageDelay transient;
	else
		modeUpdate := true;
		pxyVoyageDelay := app.createUpdateProxy(self.myVoyageDelay).HMS_VoyageDelay;	
	endif;
	
	tsFrom.setDate(self.txtDateFrom.getDate());
	tsFrom.setTime(self.txtTimeStart.getTime());

	tsTo.setDate(self.txtDateTo.getDate());
	tsTo.setTime(self.txtTimeEnd.getTime());
	
	// params: _archived, _isChargeable, _archivedDT, _startTime, _stopTime, _myDelay
	pxyVoyageDelay.setProxy(self.cbxChargeable.value, tsFrom, tsTo,
						self.cmbDelay.listObject.HMS_Delay,
						self.myHMSVoyageData);	

	while true do
		if modeUpdate then
			app.myTrxUA.trxUpdateHMSObject(pxyVoyageDelay, app.myPassport);
		else
			app.myTrxCA.trxCreateHMSObject(pxyVoyageDelay, realDelay, app.myPassport);		
		endif;
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Voyage Delay', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
		endif;
		return false;
	endwhile;						

	return true;
		
epilog
	delete pxyVoyageDelay;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
