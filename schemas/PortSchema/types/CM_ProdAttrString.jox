    <JadeMethod name="setForUpdate" id="2b68767a-7f1e-4aa2-a531-e2b61644a964">
        <updating/>
        <source>setForUpdate(_pxyAttr: CM_ProdAttrString) updating;
// ---------------------------------------------------------------------------
// Created:     09 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	newCode,
	pxyCode		: CM_ProductAttributeCode;
begin
	inheritMethod(_pxyAttr);
	
	self.allCodes.purge();
	if self.validationType = ValidationType_Codes then
		self.value := null;
		foreach pxyCode in _pxyAttr.allCodes do
			if not self.isTransient then
				create newCode persistent;
			else
				create newCode transient;
			endif;
			
			newCode.setCode(pxyCode.code);
			newCode.setDescription(pxyCode.description);
			newCode.setNotAvailableForEntry(pxyCode.notAvailableForEntry);
			self.allCodes.add(newCode);
		endforeach;
		
		//set default code - ok for this to be set null
		if _pxyAttr.myCode &lt;&gt; null then
			self.myCode := self.allCodes[_pxyAttr.myCode.code];
		endif;	
	
	elseif self.validationType = ValidationType_Value then
		self.myCode := null;
		self.value		:= _pxyAttr.value;
	endif;
	
end;</source>
        <Parameter name="_pxyAttr" type="CM_ProdAttrString"/>
    </JadeMethod>
