    <JadeMethod name="getPositionForRemarks" id="a253c0ee-14c3-482f-ae9a-747e31b812bd">
        <source>getPositionForRemarks(_layout :CM_DeckItemLayout; _left, _top :Real output):Boolean protected;
/*
Date		Who		Reason
30 Jul 2012	cnwcs5	Initial creation - par 29124
*/
vars
	point	:Point;
begin
	// find the top left position for the location
	point := _layout.getExtremePoint(CM_Graphic.Position_Left);	

	if point = null then
		return false;
	endif;
	
	_left 	:= (point.x * self.scaleFactor) + 5;
	_top 	:= (point.y * self.scaleFactor) + 5;

	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_layout" type="CM_DeckItemLayout"/>
        <Parameter name="_left" type="Real" usage="output"/>
        <Parameter name="_top" type="Real" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getRequestsForSelectedAreaBR" id="14759d57-d070-4528-b989-e9593e044f66">
        <source>getRequestsForSelectedAreaBR( _slotArray : CM_LCArray input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 December 2012	cnwrd1	Initial creation

*/

vars
	anObj : Object;
	aReq : CM_RORORequest;
begin

	if _slotArray = null then
		return;
	endif;
		
	foreach anObj in self.myROROPlanDrawController.allSelectedObjects do
		if anObj.isKindOf(CM_RORORequest) then
			aReq := anObj.CM_RORORequest;
			
			if aReq.myBulkReleaseReserveDetail &lt;&gt; null and aReq.isReleaseType then
				_slotArray.add(aReq.myROROControllerLoad);
			endif;
			
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_slotArray" type="CM_LCArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSelectedDLRGCSlots" id="62af9972-15e8-4de3-94d5-9c93cf6fdc56">
        <source>getSelectedDLRGCSlots(_theSlots: CM_LCArray input; _editions: CM_ObjectByOidEditionDict input);
/*
Purpose:			
Date		Who		Reason
09 September 2011	cnwab1	Initial creation
*/

vars

begin
	self.myROROPlanDrawController.getSelectedDLRGCSlots(_theSlots);
	self.myROROPlanDrawController.allObjectEditions.copyNoDuplicates(_editions,false);

