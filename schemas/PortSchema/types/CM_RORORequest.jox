    <JadeMethod name="setForUpdateQuantity" id="03371509-3585-408d-b5c2-5e1616830f52">
        <updating/>
        <source>setForUpdateQuantity(_qty: Decimal) updating;
/*
Purpose:			
Date		Who		Reason
19 January 2012	cnwab1	Initial creation
*/

vars

begin
	inheritMethod(_qty);
	
	self.createWLEs();
	self.myROROController.myVoyage.causeEvent(app.myPassport.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA), false, self.myROROController);
	
	//cnwmc5 - 28/01/2013 - PAR #31058
