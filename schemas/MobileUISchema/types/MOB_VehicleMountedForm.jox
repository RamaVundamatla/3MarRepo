    <JadeMethod name="addEnquiryCargo" id="129c0834-48b2-4e87-9ccd-3fccf6a24293">
        <source>addEnquiryCargo( _allFoundTIs : CM_TIArray; _table : Table io);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 April 2011	cnwndl1	Initial creation

*/

vars

	iter : Iterator;
	ti : CM_TrackedItem;

begin

	if _allFoundTIs = null or _allFoundTIs.isEmpty then
		return;
	endif;
	
	iter := _allFoundTIs.createIterator;
	while iter.next(ti) do
		app.myVMAgent.loadRTTableFromDTORTEntry(_table,ti);
	endwhile;
	
epilog

	delete iter;
end;
</source>
        <Parameter name="_allFoundTIs" type="CM_TIArray"/>
        <Parameter name="_table" type="Table" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addGfxButtons" id="5955b53c-6aff-41d9-89b9-56d18cd948a0">
        <source>addGfxButtons() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 June 2010	cnwjk3	Initial creation

*/

vars
	frmMoveEntryWidth, 
	frmGraphicWidth, 
	parentClientWidth : Integer;
begin		

	if self.myDrawingController.isLandscape or self.isForceLandscapeButtons() then
		self.resizeForGfxButtonsLandscape();
		self.rePosButtonsFrameLandscape();
		self.rePositionButtonsLandscape();
		//self.showButtonsLandscape(_show);
		//self.showButtonsPortrait(false);
	else
		self.resizeForGfxButtonsPortrait();
		self.rePosButtonsFramePortrait();
		self.rePositionButtonsPortrait();
		//self.showButtonsPortrait(_show);
		//self.showButtonsLandscape(false);
	endif;
	//self.showButtonsFrame(_show);	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addInfoDisplay" id="8bdb98e8-4dc6-43a3-bb5f-d84366f2d4c7">
        <source>addInfoDisplay(_message : String) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 April 2010	cnwer1	Initial creation

*/

vars

begin
	
	//epr par 33141 33401 19/2/14
	if self.frmTop.clientHeight &lt;= 1 and _message &lt;&gt; null then
		self.addSevereError(app.getErrorString(Info),_message);
		return;
		
	endif;
	
	self.lblInfo.foreColor := Black;	//10 Mar 2011	NDL	Par 27174	/ CCMS 2046
	self.lblInfo.caption:=_message;
	
	//06 Apr 2011	NDL	Par 27349 - give the user a fighting chance to see the message.
	if self.btnTandem.visible then
		self.lblInfo.left := self.btnTandem.left + self.btnTandem.width + 6;
	else
		self.lblInfo.left := self.btnSearchReset.left + self.btnSearchReset.width + 6;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_message" type="String"/>
    </JadeMethod>
    <JadeMethod name="addOStowInfo" id="15b13a9a-e148-4b20-8873-ac030e9be5a9">
        <source>addOStowInfo(_row : Integer) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 May 2010	cnwer1	Initial creation
01 Jul 2010	cnwer1	PAR 24697
08 Jul 2010 cnwer1  PAR 24911
*/

vars
	dtoRTQueueEntry : DTO_RTQueueEntry;
	rtQueueEntry	: CM_RTQueueEntry;
	rtTask			: CM_RTQueueTask;
	isInvalid,invalidDTO		: Boolean;
	msg 			: String;
	tableRow		: JadeTableRow;
	object			: Object;
	osColumn  : Integer;
	overstowController : CMIF_OverstowController;
begin

	tableRow :=  self.tblTasks.accessRow(_row);
	object := tableRow.itemObject;
	
	osColumn:= self.getOstowColumn();
	if osColumn = 0 then
		return;
	endif;
	
	if  self.tblTasks.columns &lt; osColumn then
		return;
	endif;
	
	if object.isKindOf(DTO_RTQueueEntry) then
		
		dtoRTQueueEntry:=object.DTO_RTQueueEntry;
	endif;
	
	if 	dtoRTQueueEntry = null then
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception, rtQueueEntry, isInvalid);
	on Exception do app.handleDeletedObject(exception, dtoRTQueueEntry, invalidDTO);
	
	rtQueueEntry:=dtoRTQueueEntry.myRealQueueEntry.CM_RTQueueEntry;
	
	if invalidDTO then
		return;
	endif;
	
	rtTask:=rtQueueEntry.allTasks.first;
	
	if isInvalid or rtTask = null then
		return;
	endif;
	//epr par 24911 8/7/10
	//entry could of been deleted need to check for null
	if rtTask = null then
		return;
	endif;
	if rtTask.taskType = TASK_DIRECTOR and
		rtTask.status = TASK_COMPLETE then
		rtTask:=rtQueueEntry.findTaskOfType(TASK_PICKUP,NULL_INTEGER);	
	endif;
	//epr TFS 37584 7/5/18
	create overstowController transient;
	overstowController.setParams(null,rtTask.ti,false,null,self.myMachine);
	dtoRTQueueEntry.isOverstow:=overstowController.getAllOverstows();
	if dtoRTQueueEntry.isOverstow then	
		msg:=overstowController.allOverstowTIs.first.id;
		if overstowController.allOverstowTIs.size &gt; 1 then
			msg:=msg &amp; ' &amp;&amp; ' &amp; (overstowController.allOverstowTIs.size - 1).asStringJMT;
		endif;
		
		self.addInfoDisplay(app.getErrorString1(Overstowed_by,msg));
	endif;
		
	//update the overstow cell 
	self.tblTasks.accessCell(_row,osColumn).text:=dtoRTQueueEntry.isOverstow.getYes;
epilog

	delete overstowController;
end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addSevereError" id="4d0dd9b7-4542-49b1-9ca2-ba8607f735c1">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_VehicleMountedDetails::doSendErrorMessage"/>
        </interfaceImplements>
        <source>addSevereError(_title, _message : String);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 May 2010	cnwer1	Initial creation

*/

vars

begin
	if _title = app.getErrorString(LabourRestriction) then	//10 Mar 2011	NDL	Par 27174 / CCMS 2046
		app.alert(Snd_Exclamation);
		self.lblInfo.foreColor := Red;
		app.msgBox(_message,_title,MsgBox_OK_Only);
	else
		app.beep;
		app.msgBox(_message,_title,MsgBox_OK_Only);
	endif;
epilog

end;</source>
        <Parameter name="_title" type="String"/>
        <Parameter name="_message" type="String"/>
    </JadeMethod>
    <JadeMethod name="beginMoveTimer" id="3ca38407-204c-4540-973e-97db68ffcf45">
        <source>beginMoveTimer() protected;
/*

Date		Who		Reason
30 June 2015	cnwer1	Initial creation PAR

*/

vars

begin
	if app.myVMAgent.getNextMoveState = VehicleMountedGenericAgent.ACCEPT_TASK then
		if app.myVMAgent.getMyRTVehicleConfig.acceptTimerInterval &lt;&gt; 0 then
			self.btnAccept.enabled:=false;
			self.beginTimer(app.myVMAgent.getMyRTVehicleConfig.acceptTimerInterval * 1000,Timer_OneShot,Timer_Move);
		endif;
		
	endif;
	
	if app.myVMAgent.getNextMoveState = VehicleMountedGenericAgent.PICKUP_TASK then
		if app.myVMAgent.getMyRTVehicleConfig.pickupTimerInterval &lt;&gt; 0 then
			self.btnAccept.enabled:=false;
			self.beginTimer(app.myVMAgent.getMyRTVehicleConfig.pickupTimerInterval * 1000,Timer_OneShot,Timer_Move);
		endif;
		
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
