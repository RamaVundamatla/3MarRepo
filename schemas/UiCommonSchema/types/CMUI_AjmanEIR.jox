<GUIClass name="CMUI_AjmanEIR" id="947207d9-4371-43de-91a7-296c987a8ca8">
    <superclass name="CMUI_DotMatrixBaseForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="myTrackedItem" id="3928684f-e03b-4bdf-8a9d-f30454422521">
        <embedded/>
        <type name="CM_TrackedItem"/>
    </ImplicitInverseRef>
    <JadeMethod name="doProcessLabelContents" id="7fde9da7-166a-4157-a90d-fdff160c9841">
        <updating/>
        <source>doProcessLabelContents(_label: CMUI_Label input): Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 November 2012	cnwndl1	Initial creation	Par 30682

*/

vars
	
	damageString : String;
	str : String;
	
	top : Integer;
	lineHeight : Integer;
	
	tempStrings : CM_StringDict;
	strArray : CnStringArray;

begin

	if _label = self.lblY then	// damage details;
		if not _label.caption = null then
			//allow test line up data to work.
			return inheritMethod(_label);
		endif;
		
		
		
		if self.myTrackedItem &lt;&gt; null then
		
			damageString := self.myTrackedItem.getDamageDetailsDescrCrLf(); 
			
			if damageString &lt;&gt; null then
			
				strArray := damageString.cnGetTokens( CrLf );
				
				if not strArray.isEmpty then
					create tempStrings transient;
					top := ( _label.top + 1 ).Integer;
					lineHeight := _label.getTextHeight( "X" );
	
					foreach str in strArray do
						if ( top + lineHeight ) &lt;= ( _label.top + _label.height ) then
							self.createTempSubLabelText( _label, str, top, tempStrings, 0 );
						else
							// truncation of damage details is probably ok.
							break;
						endif;
					endforeach;
					
					self.addMultiplePrintLines( tempStrings );
				endif;
				
			endif;
			
		endif;
		return true;
		
	else
		return inheritMethod(_label);
		
	endif;

epilog

	if tempStrings &lt;&gt; null then
		if not tempStrings.isEmpty then
			tempStrings.purge();
		endif;
		delete tempStrings;
	endif;
	
	if strArray &lt;&gt; null then
		delete strArray;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_label" type="CMUI_Label" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getPageHeight" id="8249d18b-ec4a-4180-91eb-87484ca0cd1c">
        <source>getPageHeight(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2012	cnwndl1	Initial creation	Par 30682

*/

vars

begin

	if app.isDevelopmentSystem and app.printer.getPrinterName[1:5].toUpper &lt;&gt; "EPSON" then
		return inheritMethod();
	endif;

	return 2790;	//	279.0 mm

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="makeLabelsAvailable" id="8d6973ad-b70a-4200-a7cc-71a229b58d82">
        <source>makeLabelsAvailable() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2012	cnwndl1	Initial creation	Par 30682

*/

vars

	obj : Object;
	label : CMUI_Label;

begin

	self.allLabelsArray.add( self.lblA );
	self.allLabelsArray.add( self.lblB );
	self.allLabelsArray.add( self.lblC );
	self.allLabelsArray.add( self.lblD );
	self.allLabelsArray.add( self.lblE );
	self.allLabelsArray.add( self.lblF );
	self.allLabelsArray.add( self.lblG );
	self.allLabelsArray.add( self.lblH );
	self.allLabelsArray.add( self.lblI );
	self.allLabelsArray.add( self.lblJ );
	self.allLabelsArray.add( self.lblK );
	self.allLabelsArray.add( self.lblL );
	self.allLabelsArray.add( self.lblM );
	self.allLabelsArray.add( self.lblN );
	self.allLabelsArray.add( self.lblO );
	self.allLabelsArray.add( self.lblP );
	self.allLabelsArray.add( self.lblQ );
	self.allLabelsArray.add( self.lblR );
	self.allLabelsArray.add( self.lblS );
	self.allLabelsArray.add( self.lblT );
	self.allLabelsArray.add( self.lblU );
	self.allLabelsArray.add( self.lblV );
	self.allLabelsArray.add( self.lblW );
	self.allLabelsArray.add( self.lblX );
	self.allLabelsArray.add( self.lblY );

	foreach obj in self.allLabelsArray do
		label := obj.CMUI_Label;
		label.alignment := Label.Alignment_Center_Top;
	endforeach;
	
	//02 Apr 2013	NDL	Par 31373
	label := self.lblS;
	label.alignment := Label.Alignment_Left_Top;
	
	//08 Apr 2013	NDL	31404
	label := self.lblB;
	label.alignment := Label.Alignment_Left_Top;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateLineUp" id="af545e88-5fae-4df7-b013-2035426d65db">
        <updating/>
        <source>populateLineUp(): String protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 November 2012	cnwndl1	Initial creation	Par 30682

*/

vars

	xxString : String;
	repDetails : String;

begin

	repDetails := inheritMethod();
	
	xxString := self.lblO.caption;
	
	self.lblO.caption := "XX  '" &amp; repDetails &amp; "'  " &amp; xxString;
	
	return repDetails;
	
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="repositionLabels" id="629b9fd9-c0c0-4477-b9b2-79a7055c50ef">
        <source>repositionLabels() protected;
/*

Purpose:			

Parameters:			

