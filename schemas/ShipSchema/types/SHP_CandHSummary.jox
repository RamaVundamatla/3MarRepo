    <JadeMethod name="loadNone" id="d33e2a79-51d9-473e-a64b-e19ced734413">
        <source>loadNone(table : CM_DataTable io; atCol : Integer);
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	i : Integer;

begin
		
	table.accessMode := 1;
	i := 2;
	table.column := table.columns - 1;
	while i &lt; 42 do
		table.row := i;
		if i mod 2 &gt; 0 then
			table.backColor := Grey;
		else
			table.backColor := White;
		endif;
		i := i + 1;
	endwhile;
	table.row := 45;
	table.backColor := Grey;

	i := 2;
	table.column := atCol + 1;
	while i &lt; 42 do
		table.row := i;
		if i mod 2 &gt; 0 then
			table.backColor := White;
		else
			table.backColor := Grey;
		endif;
		i := i + 1;
	endwhile;

	while i &lt;= table.rows do
		if i &lt;&gt; 45 then
			table.row := i;
			table.backColor := Grey;
		endif;
		i := i + 1;
	endwhile;

	table.row := 1;
	table.column := self.tblData.columns - 1;
	table.text := "Total 20";
	table.column := self.tblData.columns;
	table.text := "Total 40";
end;</source>
        <Parameter name="table" type="CM_DataTable" usage="io"/>
        <Parameter name="atCol" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadNoneAlt" id="778429ed-7ea7-4fdd-a783-a70fea31d492">
        <updating/>
        <source>loadNoneAlt(table : CM_DataTable io; atCol : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	i : Integer;

begin

	if self.myCurrentVoyage &lt;&gt; null then
		self.caption := "C&amp;H. " &amp; self.myCurrentVoyage.code &amp; " " &amp; app.getErrorString(SHP_Container_Hatch_Summary) &amp; " (Old Version)";
	endif;
		
	table.accessMode := 1;
	i := 2;
	table.column := table.columns - 1;
	while i &lt; 36 do
		table.row := i;
		if i mod 2 &gt; 0 then
			table.backColor := Black;
		else
			table.backColor := White;
		endif;
		i := i + 1;
	endwhile;
	table.row := 39;
	table.backColor := Black;

	i := 2;
	table.column := atCol + 1;
	while i &lt; 36 do
		table.row := i;
		if i mod 2 &gt; 0 then
			table.backColor := White;
		else
			table.backColor := Black;
		endif;
		i := i + 1;
	endwhile;

	while i &lt;= table.rows do
		if i &lt;&gt; 39 then
			table.row := i;
			table.backColor := Black;
		endif;
		i := i + 1;
	endwhile;

	table.row := 1;
	table.column := self.tblData.columns - 1;
	table.text := "Total 20";
	table.column := self.tblData.columns;
	table.text := "Total 40";
end;</source>
        <Parameter name="table" type="CM_DataTable" usage="io"/>
        <Parameter name="atCol" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadServiceStrings" id="8868b1a0-b685-4e2c-b8eb-2c9989942eef">
        <source>loadServiceStrings();
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
