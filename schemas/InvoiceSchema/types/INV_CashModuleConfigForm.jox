    <JadeMethod name="btnUpdCritAlloc_click" id="b4819090-59ba-4f34-a6a9-12657e6f9184">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnUpdCritAlloc_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	row : Integer;
	proCriteria : CM_ProformaTransactionCriteria;

begin

	row := self.tblCritAlloc.row;
	if row &gt; self.tblCritAlloc.fixedRows and row &lt;= self.tblCritAlloc.rows then
		proCriteria := self.tblCritAlloc.accessRow(row).itemObject.CM_ProformaTransactionCriteria;
	endif;

	if proCriteria = null then
		app.msgBox(app.getErrorString(Nothing_Selected), app.getErrorString(Error), MsgBox_OK_Only);
		return;
	endif;

	self.doAddUpdateClick( proCriteria );

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
