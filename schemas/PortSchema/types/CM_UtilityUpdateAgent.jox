		return;
	endif;

	app.myValUA.valPalletType(realPalletType, pProxyPalletType);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realPalletType);

	if _passport.noErrors and realPalletType.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'ResourceType', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realPalletType, true);
	endif;
	
	if _passport.noErrors then
