<Class name="INV_Assistant" id="31dee278-89b7-4286-88be-3a137d199f1a">
    <superclass name="CMUI_Assistant"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
