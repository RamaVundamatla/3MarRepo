    <JadeMethod name="loadCommands" id="7b119b38-1937-4a48-b185-343ec0ab0639">
        <source>loadCommands(_function : String);
/*

Purpose:			


Return Value:		


Date		Who		Reason
10 May 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin

	self.cmbCommand.clear;
	if _function = self.FUNC_READ_N_WORDS then
		self.cmbCommand.addItem(self.CMD_READER_STATUS);
		self.cmbCommand.addItem(self.CMD_READ_TAG);
		self.cmbCommand.addItem(self.CMD_READ_PRETAG);
	elseif _function = self.FUNC_WRITE_1_BIT then
		self.cmbCommand.addItem(self.CMD_RESET_READER);
		self.cmbCommand.addItem(self.CMD_JBUS_BUZZ);
	elseif _function = self.FUNC_WRITE_1_WORD  then
	
	elseif _function = self.FUNC_WRITE_N_WORDS then
	
	endif;
	
epilog

end;</source>
        <Parameter name="_function" type="String"/>
    </JadeMethod>
    <JadeMethod name="loadFunctions" id="c317e341-5a95-41c6-a5fe-e1586cc7ac4d">
        <source>loadFunctions();
/*

Purpose:			


Return Value:		


Date		Who		Reason
10 May 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.cmbFunc.addItem(self.FUNC_READ_N_WORDS);
	self.cmbFunc.addItem(self.FUNC_WRITE_1_BIT);
	self.cmbFunc.addItem(self.FUNC_WRITE_1_WORD);
	self.cmbFunc.addItem(self.FUNC_WRITE_N_WORDS);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="openCB" id="1a4e2fd2-5e7f-4ebe-aaae-e3d8d0f615d0">
        <source>openCB(_tcp : Connection);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 June 2008	cnwer1	Initial creation

*/

vars

begin
	app.writeLog(class.name &amp; '::' &amp; method.name,LogDEBUG );
	self.btnOpenClose.caption:="Close";
epilog

end;</source>
        <Parameter name="_tcp" type="Connection"/>
    </JadeMethod>
    <JadeMethod name="openConnection" id="87e93e64-4ef5-477a-a46a-5892e4b307b1">
        <updating/>
        <source>openConnection() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
10 May 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if myConnection = null then
		create myConnection as CM_TcpRFIDConnection transient;
		
	endif;

	self.myConnection.name := self.txtAdd.text;
	self.myConnection.port := self.txtPort.text.Integer;
	self.myConnection.timeout	:= 60000;
		//do tag Read now
		if not self.myConnection.usePresentationClient then
			self.myConnection.usePresentationClient:=true;
		endif;
		self.myConnection.fillReadBuffer 	:= false;
	
		if self.myConnection.state &lt;&gt; Connection.Disconnected then
			self.txtReponse.text:="closing connection";
			self.myConnection.close;
			return;
		endif;
	
	//self.myConnection.open;
	self.myConnection.openAsynch(self,JBUSTester::openCB.name);
	
epilog

end;</source>
    </JadeMethod>
