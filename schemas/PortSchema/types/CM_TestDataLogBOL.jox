    <JadeMethod name="getName" id="9e29a0d5-0c25-4a35-94a5-94782c274130">
        <source>getName(): String;
// ---------------------------------------------------------------------------
// Created:     27 April 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	return inheritMethod() &amp; ' ' &amp; number;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="set" id="ab8842ac-85cf-49cf-a524-4a4aa4a56990">
        <updating/>
        <source>set(_number : String; _numLogs : Integer; _operator : CM_Operator) updating;
// ---------------------------------------------------------------------------
// Created:     26 April 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.number		:= _number;
	self.numLogs	:= _numLogs;
	self.myOperator	:= _operator;

end;</source>
        <Parameter name="_number" type="String"/>
        <Parameter name="_numLogs" type="Integer"/>
        <Parameter name="_operator" type="CM_Operator"/>
    </JadeMethod>
</Class>
