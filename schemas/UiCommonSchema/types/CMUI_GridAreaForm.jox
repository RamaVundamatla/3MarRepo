    <JadeMethod name="doMenuUnassignClick" id="563c1965-343a-4a3d-a9c8-8151015de2ba">
        <updating/>
        <source>doMenuUnassignClick(_theTI : CM_TrackedItem input) updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aTI : CM_TrackedItem;
	anObject	: Object;
	brCode				: String;
	tiSet				: CM_TISet;
	realBulkRelease		: CM_BulkRelease;
	tbl					: CM_DataTable;
	passport			: CM_Passport;
	idStr				: String;
	idx					: Integer;
	brID : String;
	theReturn : Integer;
begin
	self.mousePointer := Window.MousePointer_HourGlass;
	
	if (not _theTI.isHeldForRelease) then
		return;
	endif;
	
	brID := _theTI.allBulkReleasesAssigned.first.code;
	
	create tiSet transient;
	tiSet.add(_theTI);
	
	passport := app.myPassport;
	
	while true do
		app.myTrxUA.trxUpdateUnassignRelease(tiSet, passport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			app.msgBox(_theTI.id &amp; ' has been successfully unassigned from Bulk Release ' &amp; brID, 'Release unassign completed...', MsgBox_OK_Only);
			break;
		else
			theReturn := app.showErrorWarningDialog("Bulk Release assignment update", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
	
epilog
	delete tiSet;
	self.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMenuWorkPointOpHrsEdit" id="4e8460ba-9ba5-41e5-a405-8dd3c72cdf38">
        <source>doMenuWorkPointOpHrsEdit( menuItem: MenuItem input );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 April 2012	cnwndl1	Initial creation	par 29369

*/

vars

	obj : Object;
	opHrs : CM_WorkPointOperatingHours;

begin

	obj := menuItem.userObject;
	if obj = null or not obj.isKindOf(CM_WorkPointOperatingHours) then
		return;
	else
		opHrs := obj.CM_WorkPointOperatingHours;
	endif;

	self.myAssistant.showWorkPointHrsForm( opHrs.myVoyage, opHrs, null, null);

epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
