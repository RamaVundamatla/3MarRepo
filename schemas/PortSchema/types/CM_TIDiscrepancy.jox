<Class name="CM_TIDiscrepancy" id="0090084d-114d-4881-b292-6d018102d6a5">
    <superclass name="CM_Discrepancy"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="discrep"/>
    <PrimAttribute name="isBookingRefDiscrepancy" id="0aa185de-69a0-477d-bf62-78e02d7f5362">
        <embedded/>
        <virtual/>
        <type name="Boolean"/>
        <access>readonly</access>
        <text>A virtual that simply returns true if the object is of class CM_BookingRefDiscrepancy</text>
    </PrimAttribute>
    <ExplicitInverseRef name="trackedItem" id="ba4ff97f-37e4-45bc-8220-234ff5d62471">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_TrackedItem"/>
        <access>readonly</access>
        <Inverse name="CM_TrackedItem::allDiscrepancies"/>
    </ExplicitInverseRef>
    <JadeMethod name="isBookingRefDiscrepancy" id="2f0245ed-8c17-4bea-b5b9-930c5d452bfa">
        <methodInvocation>mapping</methodInvocation>
        <source>isBookingRefDiscrepancy(_set: Boolean; _value: Boolean io) mapping;

vars

begin
	if _set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	_value :=  false;
end;</source>
        <Parameter name="_set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setTrackedItem" id="e2fb18a0-0dbb-486c-82db-d9c312882721">
        <updating/>
        <source>setTrackedItem(_ti : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:     09 January 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.trackedItem := _ti;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="updateForCreate" id="cfde58d5-b2cf-40d8-a56f-e3e6b428bfd8">
        <updating/>
        <source>updateForCreate(ti : CM_TrackedItem; txt : String; term : CM_Terminal input; ts : TimeStamp) updating;
// ---------------------------------------------------------------------------
// Created:     12 February 2001 by cnwdwq1
//
// Purpose: 
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.internalText := txt;
	self.trackedItem := ti;
	self.date := ts;
	self.terminal := term;
		//We want an automatic inverse here at some point.
	//We will have to change the dict on terminal from a date/array to a date dict
	//only. A big re-org. DQ 12/2/2001
	if not self.isTransient then		//AA 2/3/01: Don't add to term dicts
		term.addDiscrepancy(self);
	endif;
end;</source>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <Parameter name="txt" type="String"/>
        <Parameter name="term" type="CM_Terminal" usage="input"/>
        <Parameter name="ts" type="TimeStamp"/>
    </JadeMethod>
</Class>
