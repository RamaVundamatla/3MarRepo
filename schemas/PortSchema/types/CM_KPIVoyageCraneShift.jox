vars

begin
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setKPI" id="b000dbc8-34c9-4321-8a19-c82f62c5b3cd">
        <updating/>
        <source>setKPI(_movesTEU :Decimal;
			_movesTI : Integer; _start, _end : TimeStamp; 
			_js : CM_VoyageJobSheet; _shift : CM_Shift; _tis : CM_TISet input; 
			_trans : CM_TITransactionSet input) updating;
// ---------------------------------------------------------------------------
// Created:		01 May 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
12/08/2008	concms1	Par 17592 Fix Result of expression overflows Decimal precision error
22 Jun 2010	cnwkpd1	PAR #24609 - Change in bahaviouor of CM_Terminal::getShiftsFromRange means shift passed in 
					will likely be a transient one, so need to resolve to real shift.
					Signature change to CM_Shift from CM_ShiftEntity

*/

vars
	
begin
	self.myCrane 		:= _js.getMyCrane;
	
	inheritMethod (_movesTEU, _movesTI, _start, _end, _js, _shift, _tis, _trans);
end;</source>
        <Parameter name="_movesTEU" type="Decimal"/>
        <Parameter name="_movesTI" type="Integer"/>
        <Parameter name="_start" type="TimeStamp"/>
        <Parameter name="_end" type="TimeStamp"/>
        <Parameter name="_js" type="CM_VoyageJobSheet"/>
        <Parameter name="_shift" type="CM_Shift"/>
        <Parameter name="_tis" type="CM_TISet" usage="input"/>
        <Parameter name="_trans" type="CM_TITransactionSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setKPIForCreate" id="2872ca29-5700-417d-87db-7cc841f55f4f">
        <updating/>
        <source>setKPIForCreate(_start, _end : TimeStamp; _js : CM_VoyageJobSheet; _shift : CM_Shift; _voy : CM_Voyage; _terminal : CM_Terminal) updating;
// ---------------------------------------------------------------------------
// Created:		01 May 2007 By Andrew Bishop cnwab1
//
// Purpose:		USED by the BGP KPI process to create KPI objects and persistant shifts as necessary
//
// ---------------------------------------------------------------------------
/*
Date		Who		Reason
22 Jun 2010	cnwkpd1	PAR #24609 - Change in bahaviouor of CM_Terminal::getShiftsFromRange means shift passed in 
					will likely be a transient one, so need to resolve to real shift.
					Signature change to CM_Shift from CM_ShiftEntity
*/
vars

	shift : CM_Shift;
	
begin
	self.myCrane 	:= _js.getMyCrane;

	inheritMethod (_start, _end, _js, _shift, _voy, _terminal);
	
	// ### get lids per shift
	if self.myShift &lt;&gt; null and self.myShift.isKindOf( CM_Shift) then		//20 Feb 2018	NDL	TFS 37031
		shift := self.myShift.CM_Shift;
	endif;
	self.movesLid := self.myJobSheet.getShiftLids( shift ,_start,_end);
epilog
	
end;</source>
        <Parameter name="_start" type="TimeStamp"/>
        <Parameter name="_end" type="TimeStamp"/>
        <Parameter name="_js" type="CM_VoyageJobSheet"/>
        <Parameter name="_shift" type="CM_Shift"/>
        <Parameter name="_voy" type="CM_Voyage"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
</Class>
