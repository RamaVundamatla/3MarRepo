<Class name="CM_StateCollection" id="bf36a488-b114-490c-b3e9-3343566e7cfb">
    <superclass name="CM_StateData"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmstate"/>
    <ImplicitInverseRef name="myValue" id="68898c6f-cff3-4829-bc84-9ad34518a338">
        <embedded/>
        <type name="Collection"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="getValue" id="6b06d770-ec0e-4829-8743-8d1f3bccfacc">
        <source>getValue(): Any;

vars
	invalid		: Boolean;
	ed			: Integer;
	value		: Collection;
begin
	value := self.myValue;
	if value &lt;&gt; null then
		// Check if the object is valid.
		on Exception do app.handleDeletedObject(exception, value, invalid);
		ed := value.edition();		// De-reference to check validity
		if not invalid then
			return value;
		endif;
	endif;
	
	return null;

end;</source>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="setValue" id="8f77e0bf-d14c-4d92-8a09-fcd0b75c9e86">
        <updating/>
        <source>setValue(pValue: Any) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2012	cnwjre1	Initial creation

*/

vars

begin
	self.myValue := pValue.Collection;
epilog

end;</source>
        <Parameter name="pValue" type="Any"/>
    </JadeMethod>
</Class>
