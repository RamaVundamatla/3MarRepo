// ----------------------------------------------------------------------------------

vars
	isOwn	: Boolean;
	
begin
	
	if app.is53IncludedForReportsAsColumn( isOwn ) then
		if isOwn then
			return true;
		endif;
	endif;
	
	return false;

end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="is53FooterVisibleIn40Total" id="4c92f7f1-14d2-4ce3-801c-94a2461a759e">
