    <JadeMethod name="create" id="cf68a388-04c5-4302-ad1a-789b4c936358">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		14 January 2003 by cnwdad2
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	SCHEMA_NAME		: String = "JSSLicenseKeySchema";
	CLASS_NAME		: String = "JSSLicenseKeyService";
	
vars
	theRemoteSchema	: Schema;
	theRemoteClass	: Class;
	theRemoteObject	: Object;
	
begin
	theRemoteSchema	:=	rootSchema.getSchema(SCHEMA_NAME);
	
	if theRemoteSchema = null then
		Exception.raise_(99999, "Could not locate the remote schema (" &amp; SCHEMA_NAME &amp; ").");
	else
		theRemoteClass	:=	theRemoteSchema.getClass(CLASS_NAME);
		
		if theRemoteClass = null then
			Exception.raise_(99999, "Could not locate the service interface class (" &amp; CLASS_NAME &amp; ").");
		else
			create theRemoteObject as theRemoteClass transient;
			self.myServiceObject	:=	theRemoteObject;
			theRemoteObject.sendMsgWithParams("setExternalInterface", self);
		endif;
	endif;
end;</source>
    </JadeMethod>
