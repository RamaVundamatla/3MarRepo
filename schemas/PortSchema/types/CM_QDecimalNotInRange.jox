<Class name="CM_QDecimalNotInRange" id="b4c10049-6a48-4b5b-868c-82473d8b56c9">
    <superclass name="CM_QueryDecimalOperator"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <PrimAttribute name="lowerValue" id="27add9fc-e114-4795-b0b3-614d3fc89784">
        <precision>14</precision>
        <scaleFactor>4</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="create" id="a4d4e756-89bc-488a-9ba8-6fed8d722faf">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		24 November 2009 by cnwjo3
//
// Purpose:		when this Operator is created, give it a description
vars

begin
	self.description := "not in the range of";
end;</source>
    </JadeMethod>
    <JadeMethod name="doMatch" id="37bc9d22-f7b4-48f8-a163-371b5f5ec4e8">
        <source>doMatch(_value: Any): Boolean;
// --------------------------------------------------------------------------------
// Created:		24 November 2009 by cnwjo3
//
// Purpose:		This should be where the matching is done
//
vars

begin
	return not ((_value.Decimal &gt;= self.lowerValue) and (_value.Decimal &lt;= self.searchValue));

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getLowerValue" id="f30d7dbf-c8c8-441f-ad36-54d5ed677b01">
        <source>getLowerValue(_prop: CM_QueryProperty): String;
// ---------------------------------------------------------------------------
//	Created:	24 November 2009 cnwjo3
//
//	Purpose:	get the lower value
//
vars

begin
	return _prop.translateToDisplayValue(self.lowerValue);
end;</source>
        <Parameter name="_prop" type="CM_QueryProperty"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSearchValueRange" id="31ff4a64-aa49-4e0f-9e8a-70b399e67e7e">
        <source>getSearchValueRange(_prop: CM_QueryProperty): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2022	jlier1	Initial creation 53515

*/

vars
	weightRange : CM_WeightRange;
	measure : CM_MeasurementType;
	measureStr 	: String;
	pos : Integer;
begin
	pos := _prop.propertyName.pos(CN_UNDERSCORE, 1);
	if pos = null then
		return null;
	endif;
	
	measureStr := _prop.propertyName[1:pos-1];
	measure:=app.myRoot.allMeasurementTypesByShortName[measureStr];
	if measure &lt;&gt; null then
		weightRange:=app.myRoot.allWeightRanges[measure,self.searchValue.Integer];
	endif;
	
	return weightRange;

epilog

end;</source>
        <Parameter name="_prop" type="CM_QueryProperty"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getSearchValueStr" id="9d7954ae-6b6d-413e-9d24-47ea3cc286d5">
        <source>getSearchValueStr(_prop: CM_QueryProperty): String;
// --------------------------------------------------------------------------------
// Created:		24 November 2009 by cnwjo3
//
// Purpose:		set the search value of CM_QueryDecimalOperator
//
vars

begin
	//return _prop.translateToDisplayValue(self.searchValue);
	//this may not be the right place for it but....
	//yep.  Weight is a Decimal but should always be displayed as an Integer.  Cool!
	return lowerValue.Integer.String &amp; "-" &amp; searchValue.Integer.String;
end;</source>
        <Parameter name="_prop" type="CM_QueryProperty"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isValidForRT" id="3d54bd5d-b790-4593-9f51-0ff8f53ed40c">
        <source>isValidForRT(): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 July 2011	cnwndl1	Initial creation	Par 27890

*/

vars

begin
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setLowerValue" id="512aca97-dade-4423-a820-ec1b93e77e02">
        <updating/>
        <source>setLowerValue(_value: Any) updating;
// ---------------------------------------------------------------------------
// Created:		24 novemeber 2003 cnwjo3
//
// Purpose:     set the lower value for range
//
vars
	stringValue		: String;
	decimalValue	: Decimal[14,4];
begin
	if _value &lt;&gt; null then 
		stringValue := _value.String;
		if stringValue.isDecimal then
			decimalValue := stringValue.Decimal;
		else
			app.raiseCMException1(VB_INVALID_NUM, stringValue, null, null);
		endif;		
	endif;
	
	self.lowerValue := decimalValue;
end;</source>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="setSearchValue" id="36e7a7a3-f359-4f28-9c36-61dbde42912f">
        <updating/>
        <source>setSearchValue(_value: Any) updating;
// --------------------------------------------------------------------------------
// Created:		24 November 2009 by cnwjo3
//
vars
	stringValue		: String;
	decimalValue	: Decimal[14,4];
begin
	if _value &lt;&gt; null then
		stringValue := _value.CM_WeightRange.value.String;
		if stringValue.isDecimal then
			decimalValue := stringValue.Decimal;
		else
			app.raiseCMException1(VB_INVALID_NUM, stringValue, null, null);
		endif;		
	endif;
	
	self.searchValue := decimalValue;
	self.lowerValue := _value.CM_WeightRange.lower;
end;</source>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
