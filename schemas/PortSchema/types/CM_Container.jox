    <JadeMethod name="validateReleaseToTermToDoAvail" id="e806db61-d80a-467c-948e-8ca8ca76782f">
        <source>validateReleaseToTermToDoAvail(_targetTerm: CM_Terminal);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 Oct 2010	cnwndl1	Initial creation	Par 23991
31 Oct 2023	navma1  ChangeRequest 60920: EUP | Cargo Enquiry Performance - Work Packet 1
*/

vars

	availGrade : CM_MTGrade;

begin

	inheritMethod(_targetTerm);
	
	if _targetTerm = null then
		return;
	endif;
	
	availGrade := app.myRoot.allAvailabilityGrades[self.availabilityGrade];			//31.10.2023 navma1 #60920
	
	if availGrade = null then
		return;
	endif;
	
	if not availGrade.isSuitableForRelease then
		if not _targetTerm.allAllowedReleaseAvailGrades.includes( availGrade ) then
			app.setContinueCMExceptions(false);
			app.raiseCMException3(No_Release_with_grade, self.id, _targetTerm.name, availGrade.description, null,self);
		endif;  
	endif;

epilog

end;</source>
        <Parameter name="_targetTerm" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="validateRotainerComm" id="3530357b-c488-493a-9e75-f7f0529f6b18">
        <source>validateRotainerComm();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//08/10/2025	navkc1 JIRA 36144

*/

vars
	cTypeForContents 	: CM_CargoType;
	comm				: CM_Commodity;
	
begin
	
	cTypeForContents := self.getCargoTypeForContents();
	comm := app.myRoot.allCommodities[self.commodity.toUpper()];
	
	if not self.isRotatableContainer() or cTypeForContents = null or comm = null then
		return;
	endif;
	
	if not cTypeForContents.isCommodityRequired then
		app.raiseCMException2(CargoType_NotRequire_Commodity, cTypeForContents.description, self.commodity, ETRow_CargoTypeDescr, self);
	else
		if comm.allCargoTypes[cTypeForContents.id] = null then 
			app.raiseCMException2(CargoType_NotValid4_Commodity, cTypeForContents.description, self.commodity, ETRow_CargoTypeDescr, self);
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateSubTerminalChange" id="fdd72773-2f14-48a3-ad1f-f8bd93ce40da">
        <source>validateSubTerminalChange(_newSubTerminal: CM_SubTerminal);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 Oct 2010	cnwndl1	Initial creation	Par 23991
31 Oct 2023	navma1  ChangeRequest 60920: EUP | Cargo Enquiry Performance - Work Packet 1
*/

vars
	availGrade : CM_MTGrade;
begin

	if not app.isSubTerminalsLicensed then
		return;
	endif;
	
	if _newSubTerminal = null then
		return;
	endif;
	
	if self.mySubTerminal = null then	// don't check when setting the original value.
		return;
	endif;
	
	//27 Nov 2014	NDL	Par 35295
	if self.mySubTerminal = _newSubTerminal then
		return;
	endif;
	
	inheritMethod(_newSubTerminal);
	
	availGrade := app.myRoot.allAvailabilityGrades[self.availabilityGrade];		//31.10.2023 navma1 #60920
	
	if availGrade = null then
		return;
	endif;
	
	if not availGrade.isSuitableForRelease then
		if not _newSubTerminal.allAllowedEditAvailGrades.includes( availGrade ) then
			app.raiseCMException3(No_sub_term_with_grade, self.id, _newSubTerminal.code, availGrade.description, null,self);
		endif;  
	endif;

epilog

end;</source>
        <Parameter name="_newSubTerminal" type="CM_SubTerminal"/>
    </JadeMethod>
