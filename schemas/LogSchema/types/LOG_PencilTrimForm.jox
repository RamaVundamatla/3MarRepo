    <JadeMethod name="tblDetails_dblClick" id="1745c92b-01af-4920-97a5-fbcb003a76a8">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblDetails_dblClick(table: Table input) updating;
//--------------------------------------------------------------
//Created: 17 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if table.row &gt; table.fixedRows then
		return;
	endif;
	self.tblDetails.resortTableByColumn(table.column);
	self.tblDetails.colourRows(self.colorRow1, self.colorRow2);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblDetails_rowColumnChg" id="0ab6c5d1-8c74-4286-b6ef-f1eec2685d19">
        <controlMethod name="CM_DataTable::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblDetails_rowColumnChg(table: Table input) updating;
//--------------------------------------------------------------
//Created: 11 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if table.row &lt;= table.fixedRows then
		return;
	endif;
	self.setMyCurrentSOHLocation();
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="toolbarShowCaptions" id="d81685e6-ba2a-4f1f-a76c-2ac9345cd4de">
        <updating/>
        <source>toolbarShowCaptions(_showCaptions: Boolean) updating;
//
//20 Jan 2017	cnwrs1	TFS 3137 - resize the find/trplace form when show captions is on
//
vars
	currentHeight : Real;
	newHeight : Real;
	heightDiff : Real;
begin
	currentHeight := self.frmToolbar.height;
	inheritMethod(_showCaptions);
	newHeight := self.frmToolbar.height;
	heightDiff := newHeight - currentHeight;
	self.cmbVoyage.top := self.cmbVoyage.top + heightDiff;
	self.cmbLot.top := self.cmbLot.top + heightDiff;
	self.lblLot.top := self.lblLot.top + heightDiff;
	self.lblVoyage.top := self.lblVoyage.top + heightDiff;
	self.tblDetails.top:= self.tblDetails.top + heightDiff;
	self.tblDetails.height := self.tblDetails.height - heightDiff;
	self.doResize();
end;</source>
        <Parameter name="_showCaptions" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="6091dea7-c6a2-48df-975f-b3e1822d79f7">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006330, locale);
	grpNewSpecs.translateCaption(Xlat_0002429, locale);
	lblLot.translateCaption(Xlat_0002430, locale);
	lblVoyage.translateCaption(Xlat_0002431, locale);
	mnuShowDetail.translateCaption(Xlat_0006331, locale);
	mnuShowSummary.translateCaption(Xlat_0006332, locale);
	mnuTblLocations.translateCaption(Xlat_0006333, locale);
end;</source>
    </JadeMethod>
</GUIClass>
