    <JadeMethod name="load" id="c9f384c6-c600-4668-93fe-a73d40b6fa05">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

begin
	app.myControllerForm := self;
	app.getJadeVersionNumbers(self.jadeVerRelease, self.jadeVerMajor, self.jadeVerMinor);
	
	targetTranCount:=app.getProfileStringAppServer(app.getIniFileNameAppServer, "JBL", "TargetTranCount", "0").Integer;
	self.initializeRateGraphs;
	
	self.mySelectedCmdTarget := null;
	
	self.mnuDrvPop.visible := false;
	self.mnuDrvPop.enabled := false;
	self.mnuTrxPop.visible := false;
	self.mnuTrxPop.enabled := false;
	
	self.setupDriversTable;

	self.setupTransTable;
	self.refreshTransTable;

	beginNotification(process, ProcessDescriptorUpdated, Response_Continuous, 0);
	beginNotification(process, ProcessDescriptorCreated, Response_Continuous, 0);
	beginNotification(process, ProcessDescriptorDeleted, Response_Continuous, 0);
	
	beginNotification(process, NodeAndProcessDescCreated, Response_Continuous, 0);

	beginNotification(process, TransactionDescriptorUpdated, Response_Continuous, 0);
	beginNotification(process, TransactionDescriptorCreated, Response_Continuous, 0);

	beginNotification(process, SessionDescriptorInitialized, Response_Continuous, 0);

	beginNotification(process, StartBenchmark, Response_Continuous, 0);
	beginNotification(process, StopBenchmark, Response_Continuous, 0);
	beginNotification(process, TerminateBenchmark, Response_Continuous, 0);

	// Listen for a notification telling us to do our first ping. We do this so that
	// if there are lots of driver processes out there, the form has time to show
	// itself before all of the ping responses come in. If we do the ping from this
	// method and there are lots of drivers, the form often doesn't have a chance to
	// show itself completely until all the notifications have been processed. Note
	// that we use Response_Cancel as we only ever have one of these.
	beginNotification(process, InitialFormLoadPing, Response_Cancel, 0);

	self.mnuViewSysNodesProcs.checked := true;
	self.mnuViewSysNodesOnly.checked := false;
	self.mnuViewSysOnly.checked := false;

	self.setupStatsTable;
	self.saveBaselineStatistics;
	self.refreshStatsTable;
	
	self.setDefaultFontForTables;

	if not self.restoreSessionState then
		self.availMemoryWarningThreshold := 10;

		self.doGraphUpdateSpeedNormal;

		self.mnuViewTransTable.checked := true;
		self.mnuViewStatsTable.checked := true;
		self.mnuViewGraphUpdTPS.checked := true;
		self.mnuViewGraphReadTPS.checked := true;
		self.mnuViewGraphTotalTPS.checked := true;

		self.setDefaultDimensions;
	endif;

	self.refreshDriversTable;
	
	self.startGraphTimer;

	app.mySession.maxRunMinutes:=app.getProfileStringAppServer(app.getIniFileNameAppServer, "JBL", "MaxRunMinutes", "0").Integer;
	self.setCaption(true);

	// request our initial ping - see comment above	
	process.causeEvent(InitialFormLoadPing, true, null);
end;</source>
    </JadeMethod>
