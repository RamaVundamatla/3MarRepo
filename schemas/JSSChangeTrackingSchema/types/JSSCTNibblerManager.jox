    <JadeMethod name="createChangeDictForClass" id="2062a015-3dd4-46c3-b115-1d19b7078255">
        <updating/>
        <source>createChangeDictForClass(pClassName: String; pIsDelete: Boolean; pInTransState: Boolean): JSSCTChangeTrackingClass updating, protected;
/*
*/
begin
	self.monitor(self.class.name&amp;'::'&amp;method.name&amp;' ', MONITOR_DEBUG);
	self.myChangeTrackingClassTA.className := pClassName;
	self.myChangeTrackingClassTA.isDelete := pIsDelete;
	if pIsDelete then
		self.myChangeTrackingClassTA.initializing := false;
	else
		self.myChangeTrackingClassTA.initializing := true;
	endif;
	self.myChangeTrackingClassTA.myChangeTrackingClass := null;
	self.myChangeTrackingClassTA.myChangeTrackingRoot := self.myChangeTrackingRoot;
	if pInTransState then
		self.myChangeTrackingClassTA.createEntityInTransState();
		commitTransaction;
		beginTransaction;
	else
		self.myChangeTrackingClassTA.createEntity();
	endif;
	if pIsDelete then
		//	can't initlaize collection of deleted objects!
	else
		self.myClassInitializeRequestTA.applicationClass := pClassName;
		self.myClassInitializeRequestTA.myNotificationObject := self.myNotificationObject.mySharedTransientInstance;
		if self.isStartedApplication then
			self.myClassInitializeRequestTA.applicationSchema := self.myNotificationObject.mySharedTransientInstance.applicationSchema;
		else
			self.myClassInitializeRequestTA.applicationSchema := currentSchema;
		endif;
		self.myClassInitializeRequestTA.createEntitySharedTransient();

		//	start an app to initialize the collection for this class
		self.startClassInitializerApp(self.myClassInitializeRequestTA.myInitializeClassRequest);
	endif;
	return (self.myChangeTrackingClassTA.myChangeTrackingClass);
end;</source>
        <access>protected</access>
        <Parameter name="pClassName" type="String"/>
        <Parameter name="pIsDelete" type="Boolean"/>
        <Parameter name="pInTransState" type="Boolean"/>
        <ReturnType type="JSSCTChangeTrackingClass"/>
    </JadeMethod>
    <JadeMethod name="createCollectionClassEntry" id="813a86e6-5d99-4cc0-8f6e-e8a5181c8cb5">
        <updating/>
        <source>createCollectionClassEntry(pCollectionClass: String; pClass: String) updating, protected;

vars
	collectionEntry: JSSCTCollectionClassEntry;
	classEntry: JSSCTClassCollectionEntry;
begin
	self.monitor(self.class.name&amp;'::'&amp;method.name&amp;' ', MONITOR_DEBUG);
	//	check firstly, to see if we are actually tracking this class
	classEntry := self.allClassCollectionEntries[pClass];
	if classEntry = null then
		if self.trackAllClassesByDefault then
			//	we SHOULD NOT find an ignore entry for this class
			if self.allClassIniFileEntries[pClass] &lt;&gt; null then
				self.monitor("Include Collection entry for '" &amp; pCollectionClass &amp; "' in Class '" &amp; pClass &amp; "' which has been specified to be ignored.", MONITOR_ALWAYS);
				return;
			endif;
		else
			//	we SHOULD find an include entry for this class
			if self.allClassIniFileEntries[pClass] = null then
				self.monitor("Include Collection entry for '" &amp; pCollectionClass &amp; "' in Class '" &amp; pClass &amp; "' which has not been specified to be tracked.", MONITOR_ALWAYS);
				return;
			endif;
		endif;
	endif;
	//	check if we already have this collection entry
	collectionEntry := self.allCollectionClassEntries[pCollectionClass];
	if collectionEntry = null then
		//	create an entry for this collection class
		create collectionEntry transient;
		collectionEntry.collectionClassName := pCollectionClass;
		collectionEntry.myNibblerManager := self;
	else
		//	we already have this colelction entry, but check if we already have it for the specified class
		if collectionEntry.allClassesCollectionIn[pClass] = null then
		else
			self.monitor("Include Collection entry for '" &amp; pCollectionClass &amp; "' in Class '" &amp; pClass &amp; "' already specified.", MONITOR_ALWAYS);
			return;
		endif;
	endif;
	//	we have found or created the collection entry, now plug in the appropriate class
	if classEntry = null then
		//	create an entry for this class
		create classEntry transient;
		classEntry.className := pClass;
		classEntry.myNibblerManager := self;
	else
	/*
		we have already established: 1. Collection Entry created, cannot already exist in Class
									 2. Collection Entry existed, we checked (above) that this class was not in .allClassesCollectionIn
									 3. Class Entry exists, so we have previously checked that it is actually being tracked
	*/
	endif;
	//	add this class to the collection's list
	collectionEntry.allClassesCollectionIn.add(classEntry);
end;</source>
        <access>protected</access>
        <Parameter name="pCollectionClass" type="String"/>
        <Parameter name="pClass" type="String"/>
    </JadeMethod>
    <JadeMethod name="createEntity" id="6944649f-7b8f-4488-85ab-392b074c8c61">
        <updating/>
        <source>createEntity(pNibblerManagerTA: JSSCTNibblerManagerTA) updating;
/*
Date		Who		Reason
03 Feb 2011	cnwrs1	PAR #25828 - using up too many licences
*/
vars
	myChangeTrackingRootTA: JSSChangeTrackingRootTA;
	lMyDBAdminObject: JadeDatabaseAdmin;
begin
	self.debug := app.getProfileStringAppServer(app.getIniFileNameAppServer(), "JSSChangeTracker", "Debug", 'false').Boolean;
	self.myChangeTrackingRoot := JSSCTChangeTrackingRoot.firstInstance;
	if self.myChangeTrackingRoot = null then
		create myChangeTrackingRootTA transient;
		//	process journal locally or on the server
		myChangeTrackingRootTA.createEntityInTransState();
		self.myChangeTrackingRoot := myChangeTrackingRootTA.myChangeTrackingRoot;
		delete myChangeTrackingRootTA;
	endif;
	//	establish the starting audit log number - one before the current one
	create lMyDBAdminObject transient;
//	self.lastAuditFileNumber := lMyDBAdminObject.getCurrentLogNumber() - 2;
	self.lastAuditFileComplete := true;
	delete lMyDBAdminObject;
end;</source>
        <Parameter name="pNibblerManagerTA" type="JSSCTNibblerManagerTA"/>
    </JadeMethod>
    <JadeMethod name="createIgnoreClassEntry" id="bcf69dcb-4c4c-45f5-83a7-a8febf461b3a">
        <updating/>
        <source>createIgnoreClassEntry(pClass: String) updating, protected;

vars
	changeClass: JSSCTChangeTrackingClass;
	deleteClass: JSSCTChangeTrackingClass;
	ignoreEntry: JSSCTIniFileClassEntry;
begin
	self.monitor(self.class.name&amp;'::'&amp;method.name&amp;' ', MONITOR_DEBUG);
	//	check if we already have this entry
	if self.allClassIniFileEntries[pClass] = null then
		//	create an entry for this class in the collection
		create ignoreEntry transient;
		ignoreEntry.className := pClass;
		ignoreEntry.myNibblerManager := self;

		//	check if we already have started tracking this class
		changeClass := self.myChangeTrackingRoot.allChangeClasses[pClass,false];
		if changeClass &lt;&gt; null then
			self.monitor("Already Tracking Ignore Class entry for '" &amp; pClass &amp; "', will now delete.", MONITOR_ALWAYS);
			self.myChangeTrackingClassTA.isDelete := false;
			self.myChangeTrackingClassTA.myChangeTrackingClass := changeClass;
			self.myChangeTrackingClassTA.deleteEntity();
		endif;
		deleteClass := self.myChangeTrackingRoot.allDeleteClasses[pClass,true];
		if deleteClass &lt;&gt; null then
			if changeClass = null then
				self.monitor("Already Tracking Ignore Class entry for '" &amp; pClass &amp; "', will now delete.", MONITOR_ALWAYS);
			endif;
			self.myChangeTrackingClassTA.isDelete := true;
			self.myChangeTrackingClassTA.myChangeTrackingClass := deleteClass;
			self.myChangeTrackingClassTA.deleteEntity();
		endif;
	else
		self.monitor("Ignore Class entry for '" &amp; pClass &amp; "' already specified.", MONITOR_ALWAYS);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pClass" type="String"/>
    </JadeMethod>
    <JadeMethod name="createIgnoreDeletesEntry" id="2c4f9a2f-20e0-4d7e-966f-d85819faa51b">
        <updating/>
        <source>createIgnoreDeletesEntry(pClass: String; pInstanceStart: Integer; pInstanceEnd: Integer) updating, protected;

vars
	ignoreDeletesEntry: JSSCTIgnoreDeletesEntry;
begin
	self.monitor(self.class.name&amp;'::'&amp;method.name&amp;' ', MONITOR_DEBUG);
	//	check if we already have this entry
	ignoreDeletesEntry := self.allClassIgnoreDeletesEntries[pClass];
	if ignoreDeletesEntry = null then
		//	create an entry for this class in the collection
		create ignoreDeletesEntry transient;
		ignoreDeletesEntry.className := pClass;
		ignoreDeletesEntry.instanceStart := pInstanceStart;
		ignoreDeletesEntry.instanceEnd := pInstanceEnd;
		ignoreDeletesEntry.myNibblerManager := self;
	else
		self.monitor("Ignore Deletes Class entry for '" &amp; pClass &amp; "' already specified [" &amp;
														  ignoreDeletesEntry.instanceStart.String &amp; "," &amp;
														  ignoreDeletesEntry.instanceEnd.String &amp; "].", MONITOR_ALWAYS);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pClass" type="String"/>
        <Parameter name="pInstanceStart" type="Integer"/>
        <Parameter name="pInstanceEnd" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="createIncludeClassEntry" id="74d8e885-8e08-4261-a5c7-20015cbab312">
        <updating/>
        <source>createIncludeClassEntry(pClass: String) updating, protected;

vars
	includeEntry: JSSCTIniFileClassEntry;
begin
//	self.monitor(self.class.name&amp;'::'&amp;method.name&amp;' ', MONITOR_DEBUG);
	//	check if we already have this entry
	if self.allClassIniFileEntries[pClass] = null then
		//	create an entry for this class in the collection
		create includeEntry transient;
		includeEntry.className := pClass;
		includeEntry.myNibblerManager := self;
	else
		self.monitor("Include Class entry for '" &amp; pClass &amp; "' already specified.", MONITOR_ALWAYS);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pClass" type="String"/>
    </JadeMethod>
    <JadeMethod name="dumpCallStack" id="b919643a-f7ae-4202-b646-4258b306d5e0">
        <source>dumpCallStack(pClassName: String);

vars
	ts: TimeStamp;
	callStack: ProcessStackArray;
	methCallDesc: MethodCallDesc;
	lMessage: String;
	processOidString: String;
begin
	self.monitor(self.class.name&amp;'::'&amp;method.name&amp;' ', MONITOR_DEBUG);
	processOidString := process.getOidString;
	create callStack;
	//	get the call stack for the current process
	process.currentStack(callStack);
	//	dump the call stack
	foreach methCallDesc in callStack do
		lMessage := app.name &amp; "." &amp; pClassName &amp; "::dumpCallStack " &amp; methCallDesc.getName() &amp; ' at position ' &amp;
																	   methCallDesc.position.String;
		if JSSCTNotificationObject.firstInstance &lt;&gt; null then
			JSSCTNotificationObject.firstInstance.causeEvent(JSSCT_Monitor_Note, true,
															ts.date.format("ddMMMyy ") &amp;
															ts.Time.String &amp; "." &amp; (ts.Time.milliSecond + 1000).String[2:3] &amp; " " &amp;
															processOidString[processOidString.pos(".",1)+1:end] &amp; " | " &amp;
															lMessage);
		endif;
		self.logMessage(lMessage);
	endforeach;
epilog
	callStack.purge;
	delete callStack;
end;</source>
        <Parameter name="pClassName" type="String"/>
    </JadeMethod>
    <JadeMethod name="finalize" id="d8de9369-0b20-41a5-a173-ab022d56c908">
        <updating/>
        <source>finalize() updating;
/*
*/
vars
	notifierTA: JSSCTNotificationObjectTA;
begin
	self.monitor(self.class.name&amp;'::'&amp;method.name&amp;' ', MONITOR_DEBUG);
	self.endNotificationForSubscriber(self);

	//	send a Notification that I am terminating
	if self.myNotificationObject &lt;&gt; null  and
	   self.myNotificationObject.myPersistentInstance &lt;&gt; null then
		self.myNotificationObject.myPersistentInstance.causeEvent(JSSCT_Nibbler_Note, true, self.myNotificationObject.buildNibbler_Terminating(self));
	endif;

	delete self.myDBAdminObject;

	create notifierTA transient;
	notifierTA.myNotificationObject := self.myNotificationObject.mySharedTransientInstance;
	notifierTA.deleteEntitySharedTransient();
	delete notifierTA;
	delete self.myTA;
	self.myTA := null;

	delete self.myNotificationObject;
	self.myNotificationObject := null;//the process may still be running
end;</source>
    </JadeMethod>
    <JadeMethod name="findStartingObject" id="cec03ce4-4e17-4aea-9088-85f1fe5b33b8">
        <source>findStartingObject(pClass: Class; pStartDate: Date): Object /*serverExecution*/;
/*
		Starting from the most recently created class instance, step back 10%
		of the number of instances between the first and last instances and
		check until we get to an object that was created before the starting
		date parameter.
*/
vars
	workObject: Object;
	startingObject: Object;
	createDate: Date;
	classID: String;
	objectID: String;
	firstInstance: Integer;
	lastInstance: Integer;
	instance: Integer;
	decrement: Integer;
begin
	self.monitor(self.class.name&amp;'::'&amp;method.name&amp;' ', MONITOR_DEBUG);
	workObject := pClass.firstInstance;
	if workObject = null then
		return (null);
	endif;
	objectID := self.getOidStringForObject(workObject);
	classID := objectID[1:objectID.pos(".",1)];
	firstInstance := objectID[classID.length+1:end].Integer;

	workObject := pClass.lastInstance;
	objectID := self.getOidStringForObject(workObject);
	instance := objectID[classID.length+1:end].Integer;

	if instance = firstInstance then
		return (null);
	endif;
	decrement := ((instance - firstInstance) * 0.1).Integer;	//	10% of the number of instances created
	if decrement &lt; 1 then
		decrement := 1;
	endif;
	instance := instance - decrement;
	while instance &gt; firstInstance do

		process.sleep(0);
		//	check if we have been asked to stop
		if self.interruptProcessing then
			startingObject := null;
			break;
		endif;
		workObject := (classID &amp; instance.String).asOid();
		if global.isValidObject(workObject) then
			createDate := workObject.creationTime.date;
			if createDate &lt; pStartDate then
				startingObject := workObject;
				return (startingObject);
			else
				instance := instance - decrement;
			endif;
		else
			instance := instance - 1;
		endif;
	endwhile;

epilog
	return (startingObject);
end;</source>
        <Parameter name="pClass" type="Class"/>
        <Parameter name="pStartDate" type="Date"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="getIgnoreClassSubclasses" id="cc51a711-3e7d-4124-8421-5ab5759d8627">
        <updating/>
        <source>getIgnoreClassSubclasses(pClass: Class; pJournalInterface: JSSCTAuditLogInterface; pServerExecuteLog: Boolean) updating, protected;

vars
	subclass: Class;
	classColl: ClassColl;
	className: String;
begin
	self.monitor(self.class.name&amp;'::'&amp;method.name&amp;' ', MONITOR_DEBUG);
	className := pClass.name;
	//	create an entry for this class in the collection
	self.createIgnoreClassEntry(className);

	if pJournalInterface &lt;&gt; null then
		pJournalInterface.registerClass(pServerExecuteLog, pClass.number, 0);
	endif;
	//	do the same for any/all subclass of this class
	if pClass.hasSubclasses() then
		create classColl transient;
		pClass.getSubclasses(classColl);
		foreach subclass in classColl do
			self.getIgnoreClassSubclasses(subclass, pJournalInterface, pServerExecuteLog);
		endforeach;
	endif;
epilog
	delete classColl;
end;</source>
        <access>protected</access>
        <Parameter name="pClass" type="Class"/>
        <Parameter name="pJournalInterface" type="JSSCTAuditLogInterface"/>
        <Parameter name="pServerExecuteLog" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getIncludeClassSubclasses" id="d17e1f8f-149e-4907-b84a-800a26d5f932">
        <updating/>
        <source>getIncludeClassSubclasses(pClass: Class; pJournalInterface: JSSCTAuditLogInterface; pServerExecuteLog: Boolean) updating, protected;
//
// kgd 19/04/2005 now checks for an omitsubclass entry in the ini file.  This will allow selective exclusion of
// classes

vars
	subclass: Class;
	classColl: ClassColl;
	className: String;
	iniFile				: String; // kgd 19/04/2005
	classNumber			: Integer;  // kgd 19/04/2005
	omitSubClassName	: String;  // kgd 19/04/2005
begin
	self.monitor(self.class.name&amp;'::'&amp;method.name&amp;' ', MONITOR_DEBUG);
	className := pClass.name;

	// Omit this sub class if there is an omitsubclass entry for it in the ini file // kgd 19/04/2005
	iniFile := app.getIniFileNameAppServer();
	foreach classNumber in 1 to 999 do	
		omitSubClassName := app.getProfileStringAppServer(iniFile, "JSSChangeTracker", "OmitSubClass" &amp; (classNumber+1000).String[2:3], '');	
		if omitSubClassName = null then
			break;
		endif;
		// if this sub class is to be omitted, return now
		if className = omitSubClassName then
			return;
		endif;
	endforeach;  // kgd 19/04/2005

	//	create an entry for this class in the collection
	self.createIncludeClassEntry(className);

	if pJournalInterface &lt;&gt; null then
		pJournalInterface.registerClass(pServerExecuteLog, pClass.number, 0);
	endif;
	//	do the same for any/all subclass of this class
	if pClass.hasSubclasses() then
		create classColl transient;
		pClass.getSubclasses(classColl);
		foreach subclass in classColl do
			self.getIncludeClassSubclasses(subclass, pJournalInterface, pServerExecuteLog);
		endforeach;
	endif;
epilog
	delete classColl;
end;</source>
        <access>protected</access>
        <Parameter name="pClass" type="Class"/>
        <Parameter name="pJournalInterface" type="JSSCTAuditLogInterface"/>
        <Parameter name="pServerExecuteLog" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getJSSCTUserTranIDDict" id="0d5abc84-4bf4-41b6-8fd7-145438977048">
