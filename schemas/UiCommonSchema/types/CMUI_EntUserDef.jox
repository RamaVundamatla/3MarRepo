    <JadeMethod name="btnSelect_click" id="d037b49a-cf37-4abc-b408-932ed6d21eec">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSelect_click(btn: Button input) updating;

vars
	row : EntTableRow;
begin

	row	:=	self.tblDefs.accessRow(self.tblDefs.row).itemObject.EntTableRow;
	self.tblUserDefs.addItemObject(row, row.name);
	
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
