<Class name="CMIF_GridGPSController" id="235bb80f-16a8-4c43-80d2-25376e3e5307">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <ImplicitInverseRef name="allPxyGridColumns" id="921ee7a7-61f5-4d80-bf96-e9ebfb2e4bcf">
        <memberTypeInverse/>
        <type name="CM_GridColumnDict"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allPxyGridRows" id="8009f707-45e8-4ed4-a464-0b5ae27d974a">
        <memberTypeInverse/>
        <type name="CM_GridRowDict"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myGridArea" id="1bf93b0f-6615-4c34-aa12-c83942f29375">
        <embedded/>
        <type name="CM_GridArea"/>
    </ImplicitInverseRef>
    <JadeMethod name="validate" id="40b375b8-b648-4ad9-8c6b-78db272d8a0f">
        <source>validate();
// ---------------------------------------------------------------------------
// Created:		21 February 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	pxyGridRow, lastGridRow : CM_GridRow;
	pxyGridColumn,lastGridColumn : CM_GridColumn;
	lastGPS : Real;
begin

	lastGPS := 0;
	foreach pxyGridRow in self.allPxyGridRows do
		if pxyGridRow.gpsY = 0 then
			app.setContinueCMExceptions(true);
			/*app.raiseCMException1(Full_Replacement_Message, "Row GPS co-ordinates are Invalid." &amp; Cr &amp; 
											"Row '" &amp; pxyGridRow.getNiceName &amp; "' (" &amp;  pxyGridRow.gpsY.String &amp; ") must be greater than ZERO.", null, null); */ //- cnwmd1, Par 20524
			app.raiseCMException2(Coord_inval_must_great_than_ze, pxyGridRow.getNiceName, pxyGridRow.gpsY.String, null, null);
		
		endif;
		if lastGPS &lt;&gt; 0 and pxyGridRow.gpsY &lt;= lastGPS then
			app.setContinueCMExceptions(true);
			/*app.raiseCMException1(Full_Replacement_Message, "Row GPS co-ordinates are out of sync." &amp; Cr &amp; 
											"Row '" &amp; lastGridRow.getNiceName &amp; "' (" &amp;  lastGridRow.gpsY.String &amp; ") must be greater than" &amp; Cr &amp; 
											"Row '" &amp; pxyGridRow.getNiceName &amp; "' (" &amp;  pxyGridRow.gpsY.String &amp; ").", null, null);*/
			app.raiseCMException4(Coordi_syncro_must_greate_than, lastGridRow.getNiceName, lastGridRow.gpsY.String, pxyGridRow.getNiceName, pxyGridRow.gpsY.String, null, null);
		endif;
		lastGPS := pxyGridRow.gpsY;
		lastGridRow := pxyGridRow;
	endforeach;

	lastGPS := 0;
	foreach pxyGridColumn in self.allPxyGridColumns do
		if pxyGridColumn.gpsX = 0 then
			app.setContinueCMExceptions(true);
			/*app.raiseCMException1(Full_Replacement_Message, "Column GPS co-ordinates are invalid." &amp; Cr &amp; 
											"Row '" &amp; pxyGridColumn.getNiceName &amp; "' (" &amp;  pxyGridColumn.gpsX.String &amp; ") must be greater than ZERO.", null, null); */ //- cnwmd1, Par 20524
			app.raiseCMException2(Colum_coord_inval_must_great_t, pxyGridColumn.getNiceName, pxyGridColumn.gpsX.String, null, null);
		
		endif;
		if lastGPS &lt;&gt; 0 and pxyGridColumn.gpsX &lt;= lastGPS then
			app.setContinueCMExceptions(true);
			/*app.raiseCMException1(Full_Replacement_Message, "Column GPS co-ordinates are out of sync." &amp; Cr &amp; 
											"Column '" &amp; lastGridColumn.getNiceName &amp; "' (" &amp;  lastGridColumn.gpsX.String &amp; ") must be greater than" &amp; Cr &amp; 
											"Column '" &amp; pxyGridColumn.getNiceName &amp; "' (" &amp; pxyGridColumn.gpsX.String &amp; ").", null, null); */ //- cnwmd1, Par 20524
			app.raiseCMException4(Colum_coord_sync_colum_must_gr, lastGridColumn.getNiceName, lastGridColumn.gpsX.String, pxyGridColumn.getNiceName, pxyGridColumn.gpsX.String, null, null);
		
		endif;
		lastGPS := pxyGridColumn.gpsX;
		lastGridColumn := pxyGridColumn;
	endforeach;


end;</source>
    </JadeMethod>
</Class>
