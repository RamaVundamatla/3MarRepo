    <JadeMethod name="getFileString" id="c321b135-a315-4a18-a829-9756805f9f6b">
        <source>getFileString(pFileName: String): String;

vars
	file: File;
	fileString: String;
begin
	create file;
	file.fileName := pFileName;
	file.maxRecordSize := 64 * 1024;
	file.kind := File.Kind_Unknown_Text;	// 25/2/16 cnwmp6 PAR 36286 unicode version
	file.open;

	fileString := file.readLine &amp; CrLf;
	while not file.endOfFile do
		fileString := fileString &amp; file.readLine &amp; CrLf;
	endwhile;

	file.close;
	delete file;

	return(fileString);
end;</source>
        <Parameter name="pFileName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="lblSplitH_mouseDown" id="90379c86-7195-466c-b5ee-d3b74133f21b">
        <controlMethod name="Label::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lblSplitH_mouseDown(label: Label input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*
*/
begin
	if button = Control.MouseButton_Left then
		mouseDownX := x;
		mouseIsDown := true;
	endif;
end;</source>
        <Parameter name="label" type="Label" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="lblSplitH_mouseMove" id="7d36b8ae-8604-431d-8565-2f1ad0ab0f37">
        <controlMethod name="Label::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lblSplitH_mouseMove(label: Label input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*
*/
vars
	moveX: Real;
begin
	if mouseIsDown then
		moveX := x - mouseDownX;
		lstXmlTree.width := lstXmlTree.width + moveX;
		lblSplitH.left := lblSplitH.left + moveX;
		txtXmlDetails.left := txtXmlDetails.left + moveX;
		txtXmlDetails.width := txtXmlDetails.width - moveX;
	endif;
end;</source>
        <Parameter name="label" type="Label" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="lblSplitH_mouseUp" id="683860b7-e014-48a5-8710-3220e49cdc06">
        <controlMethod name="Label::mouseUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lblSplitH_mouseUp(label: Label input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*
*/
begin
	mouseIsDown := false;
end;</source>
        <Parameter name="label" type="Label" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="load" id="a3371134-a9dd-4897-8e4c-09dc5b5763ff">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
/*
*/
begin
	centreWindow;
	create self.myXmlDocument;
	self.myXmlDocument.setListboxColors(Blue, Red);
end;</source>
    </JadeMethod>
    <JadeMethod name="lstXmlTree_click" id="16293128-a530-413f-9a08-554a15b85558">
        <controlMethod name="ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstXmlTree_click(listbox: ListBox input) updating;
/*
*/
vars
	obj: Object;
	element: JSSXmlElement;
	attribute: JSSXmlAttribute;
begin
	obj := listbox.listObject;
	if obj = null then
		txtXmlDetails.text := null;
	else
		if obj.isKindOf(JSSXmlComment) then
			txtXmlDetails.text :=	"Comment = " &amp; obj.JSSXmlComment.tagValue;
		elseif obj.isKindOf(JSSXmlCData) then
			txtXmlDetails.text :=	"CDATA = " &amp; obj.JSSXmlCData.tagValue;
		elseif obj.isKindOf(JSSXmlElement) then
			element := obj.JSSXmlElement;
			txtXmlDetails.text :=	"Element [ Level " &amp; element.level.String &amp; "]" &amp; CrLf &amp; CrLf &amp;
									"    Tag name  = " &amp; element.fullName() &amp; CrLf &amp;
									"    Tag value = " &amp; element.tagValue &amp; CrLf;
			element.myDocument.noIndentation := true;
			txtXmlDetails.text := txtXmlDetails.text &amp; CrLf &amp; "    Xml out = " &amp; element.buildXmlString() &amp; CrLf;
			element.myDocument.noIndentation := false;
		elseif obj.isKindOf(JSSXmlAttribute) then
			attribute := obj.JSSXmlAttribute;
			txtXmlDetails.text :=	"Attribute" &amp; CrLf &amp;
									"    Name  = " &amp; attribute.attributeName &amp; CrLf &amp;
									"    Value = " &amp; attribute.attributeValue &amp; CrLf;
		endif;
	endif;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstXmlTree_dblClick" id="ea23033d-ccc5-4984-aa77-4ff0529093d0">
        <controlMethod name="ListBox::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstXmlTree_dblClick(listbox: ListBox input) updating;
// --------------------------------------------------------------------------------
// Created:		14 October 2002 by cnwwmb1
//
// Purpose:
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	myXmlDocument.inspectModal;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstXmlTree_pictureClick" id="fa674204-95af-4224-904d-cc7b82b3c63b">
        <controlMethod name="ListBox::pictureClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstXmlTree_pictureClick(listbox: ListBox input; picIndex: Integer; whatClicked: Integer) updating;
/*
*/
begin
	listbox.itemExpanded[picIndex] := not listbox.itemExpanded[picIndex];
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="picIndex" type="Integer"/>
        <Parameter name="whatClicked" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="mExit_click" id="58a7eba3-001a-4fce-83d0-37a48ed1fbb5">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mExit_click(menuItem: MenuItem input) updating;
/*
*/
begin
	self.unloadForm;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mLoadFile_click" id="6c513638-1318-482a-a44d-9ef40a81891f">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mLoadFile_click(menuItem: MenuItem input) updating;
/*
*/
vars
	fileCMD: CMDFileOpen;
begin
	create fileCMD;

	if fileCMD.open = 0 then

		app.mousePointer := Busy;

		myXmlDocument.parseDocument(self.getFileString(fileCMD.fileName));
		self.lstXmlTree.clear;
		myXmlDocument.loadListbox(self.lstXmlTree, true);

		txtXmlDetails.text := myXmlDocument.buildXmlSubstring();

	endif;
epilog
	delete fileCMD;
	app.mousePointer := Idle;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="resize" id="e047404f-8e83-4711-9d0a-d7484677c39e">
        <controlMethod name="Form::resize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>resize() updating;
/*
*/
begin
	lstXmlTree.move(lstXmlTree.left, lstXmlTree.top, lstXmlTree.width, self.clientHeight - 10);
	lblSplitH.move(lblSplitH.left, lblSplitH.top, lblSplitH.width, lstXmlTree.height);
	txtXmlDetails.move(txtXmlDetails.left, txtXmlDetails.top, self.clientWidth - txtXmlDetails.left - lstXmlTree.left, lstXmlTree.height);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="1c971917-a4ed-46b5-9c41-2348eb9f5c35">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
/*
*/
begin
	delete myXmlDocument;
end;</source>
    </JadeMethod>
