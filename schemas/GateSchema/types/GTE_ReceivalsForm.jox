    <JadeMethod name="initExtraTable" id="fc6962b4-5a5e-4ace-acb1-a80c1aa20157">
        <source>initExtraTable();
// ---------------------------------------------------------------------------
// Created:     19 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	entTableDef		: EntTableDef;
	theRow			: Integer;
	theTable		: CM_EntryTable;
	
begin

	theTable := tblExtra;
	theTable.warningMethod := 'entTableWarning';
//	theTable.setObjectWarningMethod := 'entTableSetObjectWarning';

	theTable.stretchToParent := true;
	theTable.optimiseRowHeight := true;
	if self.myMasterMenuAction &lt;&gt; null then

		entTableDef := app.myController.getEntTableDef(self.myMasterMenuAction.extraTableDef);
	else
		entTableDef := app.myController.getEntTableDef("BookRefDetails"); //AER CCMS 1037
	endif;

	theTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');

	theTable.adjustHeight(200);
	theTable.optimiseHeadingColumn();
//	self.myAssistant.GTE_Assistant.receival_InitTblExtra(theTable, false);
	

end;</source>
    </JadeMethod>
    <JadeMethod name="initForm" id="f5346fd5-6066-4b5b-93e7-2069f3393b41">
        <updating/>
        <source>initForm() updating;
// ---------------------------------------------------------------------------
// Created:     08 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	navObj	: CMUI_NavigatorObject;
	cmb     : ComboBox;
begin

	if self.isKindOf(GTE_PreNoteForm) then
		self.allowPrint  	:= true;
		self.allowExportCSV	:= true;
	else
		self.allowPrint  	:= false;
		self.allowExportCSV	:= false;
	endif;
	self.useNumRowsShown	:= true;	
	self.lastTransportMode := TI_TRANSMODE_ROAD;
	
	// type can be global constants GTE_BookingRef_Parent (BR) or GTE_PreNote_Parent (PN)
	self.setType;

//	navObj := self.createNavigatorObject(self.type &amp; '_TableView', 'Table View', '', self.type);
//	navObj.setTableDefs(navObj.mainTableDef, navObj.extraTableDef);
//	self.myNavigatorObject := navObj;
	tblMain.visible := false;
	tblExtra.setValueColumn(0, getSystemColor(Color_Window), false, false);
	self.setColorsForEntryTable(tblMain);
	self.setColorsForEntryTable(tblExtra);
	beginLoad;
	
	self.initMainTable();
	self.initExtraTable();

	self.myAssistant.listTableDischarge(lstDischarge, null, null);
	self.myAssistant.resetHazardListTable(lstHazardList);	//CCMS 1203 JC
//	self.myAssistant.comboBoxAvailabilityGrade(self.cmbAvGrade, null);
//	self.myAssistant.comboBoxOperator(cmbFiltOperator, null, null);
 	/*cmbCustomDetails.style := 0;
	cmbCustomDetails.useManualDropDown := true;
    cmb := cmbCustomDetails;
    self.myAssistant.comboBoxCustomDetails(cmb,null,null);*/
    
    self.txtBookingRef.automaticCellControl := true;
    self.cmbBOLType.automaticCellControl := true;
	self.cmbBRItem.automaticCellControl := true;
	self.cmbTiType.automaticCellControl := true;
	self.cmbConsignor.sorted:= true;
	self.cmbConsignor.setType(CONSIGNOR);
	self.cmbFreightFwdr.sorted:= true;
	self.cmbFreightFwdr.setType(FREIGHT_FORWARDER);

epilog
	endLoad;
end;</source>
    </JadeMethod>
    <JadeMethod name="initMainTable" id="aa0a4b20-9851-4790-a1d9-04f4922cccf0">
        <updating/>
        <source>initMainTable()updating;
// ---------------------------------------------------------------------------
// Created:     12 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	entTableDef		: EntTableDef;
	theRow			: Integer;
	theTable		: CM_EntryTable;
	
begin
	if self.myAssistant = null then
		self.createMyAssistant(GTE_Assistant);
	endif;
	theTable := tblMain;
	theTable.warningMethod := 'entTableWarning';
//	theTable.setObjectWarningMethod := 'entTableSetObjectWarning';
		
	theTable.stretchToParent := true;
	theTable.optimiseRowHeight := true;
	if self.myMasterMenuAction &lt;&gt; null then
		entTableDef := app.myController.getEntTableDef(self.myMasterMenuAction.mainTableDef);
	else
		entTableDef := app.myController.getEntTableDef("BookRefHeader"); //AER CCMS 1037
	endif;
	theTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');

	theTable.adjustHeight(200);
	theTable.optimiseHeadingColumn();
	self.myAssistant.GTE_Assistant.receival_InitTblMain(theTable);
end;</source>
    </JadeMethod>
    <JadeMethod name="keyDown" id="7af2d712-5241-4902-855f-be2806cb5bfb">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     09 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theActiveControl	: Control;
	blnToTable			: Boolean;
begin

	inheritMethod(keyCode, shift);
	
	if keyCode = J_key_Tab then

		if tblExtra.visible then
			blnToTable := handleExtraTableTabbing(keyCode, shift); 
		else
			tblMain.handleFormTab(keyCode, shift, tblData, tblData);
		endif;

		theActiveControl := app.activeControl;

		if blnToTable then
			if theActiveControl.parent.isKindOf(CM_EntryTable) then
				theActiveControl := theActiveControl.parent.CM_EntryTable;
			endif;
			if theActiveControl.isKindOf(CM_EntryTable) then
				theActiveControl.CM_EntryTable.handleTableTab(shift);
			endif;
		endif;

	endif;

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadBookingRefItems" id="cdd3d2f8-f20d-4745-bfa6-0314de7bc54e">
        <source>loadBookingRefItems(_br : CM_BookingRef);
// ---------------------------------------------------------------------------
// Created:     28 February 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	cmb					: CMUI_ComboBoxBookRefItem;
	code				: CM_Code;
	conditionDict		: CM_LogConditionCodesByCodeDict;
	brItem				: CM_BookingRefItem;
begin
	cmb := self.cmbBRItem;
	cmb.useDisplayCollection := true;
	if _br = cmb.myBookingRef then  // store the booking ref so don't reload if it has not changed
		return;
	endif;
	cmb.clear;
	cmb.setMyBookingRef(_br);
end;</source>
        <Parameter name="_br" type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="loadOptDischargePorts" id="c07ed06c-0b8d-429c-8132-61c22445a463">
        <source>loadOptDischargePorts(_selVoyage : CM_Voyage);
/*
Date		Who		Reason
23 June 2009	cnwml2	Initial creation //+cnwml2, PAR 20030

*/

vars
	assistant		: GTE_Assistant;
	str 			: String;
	portsArray 		: StringArray;
	port 			: Object;
begin
	create portsArray transient;
	
	assistant := self.myAssistant.GTE_Assistant;

	assistant.listTableDischarge(self.lstDischarge, _selVoyage, null);

	// if existing bookingRef then tick boxes only for the saved ones
	foreach port in self.lstDischarge.allSelectedObjects do
		if _selVoyage = null or 
			 _selVoyage.allPorts.includes(port.CM_Port) then
				portsArray.add(port.CM_Port.code);
			endif;
	endforeach;
	
	
	assistant.setListTablePorts(self.lstDischarge, portsArray);
epilog
	delete portsArray;
end;</source>
        <Parameter name="_selVoyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="lstDischarge_displayRow" id="4a8a882f-dd46-4c02-9792-c7d649d41acb">
