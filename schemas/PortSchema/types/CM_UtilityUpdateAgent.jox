    </JadeMethod>
    <JadeMethod name="utlUpdateSnapshotData" id="7de50f63-681f-49cf-a877-249923b09d17">
        <source>utlUpdateSnapshotData(	_proxySnapshotData : CM_SnapshotData;
						_realSnapshotData : CM_SnapshotData input;
						_passport : CM_Passport input );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 December 2009	cnwndl1	Initial creation	CCMS 1023

*/

vars

begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions( true );
	
	app.myValCA.valSnapshotData( _proxySnapshotData, _realSnapshotData );
	
	if _realSnapshotData = null then	
		app.raiseCMException2( MethodWithNullParam, method.name, '_realSnapshotData', null, null );
		return;
	endif;
	
	if not self.checkValidationWithPassport( _passport ) then
		return;
	endif;
	
	app.setContinueCMExceptions( false );
	
	self.exclusiveLock( _realSnapshotData );
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric( _realSnapshotData, true );
	endif;
	
	if _passport.noErrors then
		_realSnapshotData.setForUpdate( _proxySnapshotData );
	endif;
	
epilog
	
end;</source>
        <Parameter name="_proxySnapshotData" type="CM_SnapshotData"/>
        <Parameter name="_realSnapshotData" type="CM_SnapshotData" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateSortingMethod" id="8f52c6e1-3d2d-4b01-9241-27de6a3e13bc">
        <source>utlUpdateSortingMethod(_pxySortingMethod : CM_SortingMethod; _passport : CM_Passport input);
/*

Purpose:			Updates a Sorting Method Object

Parameters:			_pxySortingMethod	CM_SortingMethod	The proxy sorting method to use to update the real object
					_passport			CM_Passport			The passport to use to hold errors and perform other tasks

Return Value:		NONE

Date			Who		Reason
07 June 2023	navpw1	Initial creation TFS: 57813 (58438)

*/

vars
	realSortingMethod :CM_SortingMethod;
	expectedEdition :Integer;
	
begin
	self.initialiseActivity();

	_pxySortingMethod.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxySortingMethod.pxyGetRealObjectAndEdition(realSortingMethod, expectedEdition);
	
	if realSortingMethod = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_SpecialStow.name, null, null);
		return;
	endif;

	app.myValUA.valSortingMethod(_pxySortingMethod, realSortingMethod);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realSortingMethod);

	if _passport.noErrors and realSortingMethod.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Sorting Method', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realSortingMethod, true);
	endif;
	
	if _passport.noErrors then
		realSortingMethod.setForUpdate(_pxySortingMethod);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realSortingMethod, false);
	endif;
	
end;</source>
        <Parameter name="_pxySortingMethod" type="CM_SortingMethod"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateSourceLocation" id="f7b453d4-993c-444d-a3a7-ec7391f7dbfb">
        <source>utlUpdateSourceLocation(_proxySource:CM_SourceLocation; _realSource : CM_SourceLocation output; _passport : CM_Passport input);
//--------------------------------------------------------------
//Created: 11 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	cancelSave		: Boolean;
	expectedEdition	: Integer;
	
begin

	self.initialiseActivity();

	_proxySource.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxySource.pxyGetRealObjectAndEdition(_realSource, expectedEdition);
	
	if _realSource = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_SourceLocation.name, null, null);
		return;
	endif;

	app.myValUA.valSourceLocation(_realSource, _proxySource);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(_realSource);

	if _passport.noErrors and _realSource.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Source Location', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_realSource, true);
	endif;
	
	if _passport.noErrors then
		_realSource.setForUpdate(_proxySource);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_realSource, false);
