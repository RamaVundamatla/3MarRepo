    <JadeMethod name="loadChildCombo" id="78914ac4-761b-4f1e-9b1c-e38759d18a18">
        <updating/>
        <source>loadChildCombo(_child: CM_Object) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin

	if self.myParent &lt;&gt; null then
		self.myAssistant.comboBoxRORODeckItems(self.cmbChild,self.myParent.CM_Deck,_child.CM_DeckItem);
	endif;

