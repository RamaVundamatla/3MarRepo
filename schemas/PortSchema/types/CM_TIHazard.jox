    <JadeMethod name="setProxy" id="8a5e68ad-d347-419c-9a95-acab67413211">
        <updating/>
        <source>setProxy(	_code, _desc, _unNumbers: String; 
			_ti: CM_TrackedItem; 
			_limitedQuant : Boolean; 
			_packGroup : String; 
			_flashpoint : Real; 
			_isMarinePollutant : Integer; 
			_acidsBases : String	) updating;
//----------------------------------------------------------------
//	Created:	06 April 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------
// 11/06/2015	cnwdap1		PAR #36421 Hazardous Materials Handling
// 09/11/2016	cnwdap1		TFS 2842 Hazardous Details Enhancements
// 08/01/2025   navsp1      MTN-19916 MTN - Hazard Packing Group Behaviour is incorrect
vars

begin
	self.code := _code[1:9];
	self.description := _desc[1:40];
	self.setUNDGCodes(_unNumbers);
	self.myTrackedItem := _ti;
	self.limitedQuantity := _limitedQuant;
	self.packingGroup := _packGroup[1:5];							// PAR #36421 //MTN-19916
	self.flashpointTemperature := _flashpoint;			// TFS 2842
	self.isMarinePollutant := _isMarinePollutant;		// TFS 2842
	self.acidsBases := _acidsBases.toUpper;				// TFS 2842
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_desc" type="String"/>
        <Parameter name="_unNumbers" type="String"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_limitedQuant" type="Boolean"/>
        <Parameter name="_packGroup" type="String"/>
        <Parameter name="_flashpoint" type="Real"/>
        <Parameter name="_isMarinePollutant" type="Integer"/>
        <Parameter name="_acidsBases" type="String"/>
    </JadeMethod>
    <JadeMethod name="setPxyFromEDI" id="fa6cae53-a365-4957-99aa-023f74bd3d75">
        <updating/>
        <source>setPxyFromEDI( _ediHazDetails : CM_EDIHazDetailsTI ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 November 2016	cnwndl1	Initial creation	TFS 2843 / 2604

*/

vars

	strArray : CnStringArray;
	str : String;

begin
	
	self.code := _ediHazDetails.code.trimBlanks[1:9];
	self.description := _ediHazDetails.description.trimBlanks[1:40];
	self.acidsBases := _ediHazDetails.acidsBases[1:10];
	self.flashpointTemperature := _ediHazDetails.flashpointTemperature;
	self.isMarinePollutant := _ediHazDetails.isMarinePollutant;
	self.limitedQuantity := _ediHazDetails.limitedQuantity;
	self.packingGroup := _ediHazDetails.packingGroup[1:5];
	
	if _ediHazDetails.undgCodes.trimBlanks &lt;&gt; null then
		strArray := _ediHazDetails.undgCodes.cnGetTokens(" ");
		if strArray &lt;&gt; null and not strArray.isEmpty then
			foreach str in strArray do
				self.addUNCode( str );
			endforeach;
		endif;
	endif;
	
	//12.Jan.2024 navsp1 TFS 61660
	if _ediHazDetails.allUNDGCodes &lt;&gt; null then
		_ediHazDetails.allUNDGCodes.copyNoDups(self.allUNDGCodes);//09.May.24 navsp1 TFS 61660/64071
	endif;
epilog

	delete strArray;

end;</source>
        <Parameter name="_ediHazDetails" type="CM_EDIHazDetailsTI"/>
    </JadeMethod>
    <JadeMethod name="setUNDGCodes" id="f29abc25-0c33-4b67-a6b0-94cc6e5561ff">
        <updating/>
        <source>setUNDGCodes(_codes: String)updating;
//----------------------------------------------------------------
//	Created:	01 April 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/*

Date		Who		Reason
08 Oct 2008	cnwkpd1	PAR #18009 - Prevent transient leaks

*/
//20 Aug 2012	cnwrs1	Par30198 only allow integer undgCodes
vars
	wrkStr			: String;
	sa				: StringArray;
	undgCode : String;
	wrkStr2 : String;	//24 Sep 2019	NDL	TFS 46633
	wrkStr3 : String;	//24 Sep 2019	NDL	TFS 46633
begin

	self.allUNDGCodes.clear;
	if _codes.trimBlanks = null then
		return;
	endif;
	
	//replace comma with Tab so we can use getTokens - allows for lots of delimiters
	wrkStr2 := _codes.replaceString("...", " ");	//24 Sep 2019	NDL	In case we get the shortened version with "..." passed in
	wrkStr3 := wrkStr2.trimBlanks;	//24 Sep 2019	NDL	Now drop off the blanks.
	
	wrkStr := wrkStr3.replaceString(",", Tab);
	sa := wrkStr.getTokens();			// PAR #18009
	foreach undgCode in sa do  //30198 cnwrs1 20.8.2012
		if not undgCode.isInteger then
			undgCode := undgCode.extractInteger.String;
		endif;
		// do nothing if undg is zero
		if undgCode.Integer &lt;&gt; 0 then
			self.allUNDGCodes.add(undgCode);
		endif;
	endforeach;		
	
epilog
	delete sa;		// PAR #18009

end;</source>
        <Parameter name="_codes" type="String"/>
    </JadeMethod>
    <JadeMethod name="undgCodes" id="9a13db13-07a5-418f-9994-ae42f2825815">
        <methodInvocation>mapping</methodInvocation>
        <source>undgCodes(set: Boolean; _value: String io) mapping;
//----------------------------------------------------------------
//	Created:	31 March 2004	by Jason Chapman  (cnwjc2)
/*
			**************   DON'T use this field (mapping method) except in the Data Extract.

			Use the method 'getUndgCodesAsString', or access 'allUNDGCodes'


*/
//----------------------------------------------------------------
vars
	strCode,
	str		: String;
begin
	if set or self.allUNDGCodes.isEmpty then
		return;
	endif;
	
	foreach strCode in self.allUNDGCodes do
		str := str &amp; ", " &amp; strCode;
	endforeach;	

	_value := str[3:80];

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateTI" id="e11553ca-8a30-4826-9fd8-9bad8c7288be">
        <updating/>
        <source>updateTI(_ti: CM_TrackedItem) updating;
//----------------------------------------------------------------
//	Created:	14 February 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tiHaz		: CM_TIHazard;
begin
	tiHaz := _ti.allTIHazards[self.code].CM_TIHazard;
	
	if tiHaz = null then
		self.myTrackedItem := _ti;
	else
		//already has this haz
		tiHaz.allUNDGCodes.clear;
		if not self.allUNDGCodes.isEmpty then
			self.allUNDGCodes.copy(tiHaz.allUNDGCodes);
		endif;
	endif;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="validateTIHazard" id="767ad88a-73a7-43b5-8f0f-1d412de096fe">
        <source>validateTIHazard( _terminal : CM_Terminal);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Apr 2013	cnwer1	Initial creation CCMS 2280
26 Jun 2014	cnwkpd1	Added return if hazard class not found - in EDI this can be continued, resulting in a subsequent 1090 exception further on
08 Jul 2015	cnwdap1	PAR #36421 Hazardous Materials Handling
17 Nov 2016	cnwdap1	TFS 2843 STWR Hazardous Details Enhancements
21 Mar 2017	cnwdap1	TFS 3486 Check Is Marine Pollutant mandatory
13 Oct 2023	navma1 ChangeRequest 60841: MTN - Improve Performance of Cargo Bulk Edit - First Enhancement
2/8/24  		navsaa30	Bug 65355: MTN - Flashpoint Temperature Field behaviour
07 Jan 2025 navsck1 MTN-33234 CUX - PUT /cargo with hazards error message
*/

vars
	hazClass		: CM_HazardClass;
	strUNDG			: String;
	validateHazUNDG : Boolean;
	undgCode		: CM_UNDangerousGoods;
	hazTempRange	: CM_HazTempRange;			
	root			: CM_Root;
	rangeFound		: Boolean;
begin

	root     := app.myRoot;										//13.10.2023 navma1 #60841
	if self.code &lt;&gt; null then									//13.10.2023 navma1 #60841
		hazClass := root.allHazardClasses[self.code];
	endif;
	
	if hazClass = null then
		app.raiseCMException1(ERR_INVALID_HAZARD,   self.code , null, null);
		return;		
	endif;
	
	if _terminal = null then
		return;
	endif;
	
	validateHazUNDG:=_terminal.getConfig(ValidateHazardousUNDG).Boolean;
	
	foreach strUNDG in self.allUNDGCodes do
		undgCode := root.allUNDangerousGoodsCodes[strUNDG.trimBlanks];
		if undgCode = null then
			if validateHazUNDG then
				app.raiseCMException2(WARN_UNKNOWN_UNDG, strUNDG,  self.code , null, null);
			else
				//only warn if there are undg codes in the system
				if root.allUNDangerousGoodsCodes.isNotEmpty then														//30.10.2023 navma1 #60841
					app.raiseCMWarning2(WARN_UNKNOWN_UNDG, strUNDG, self.code, null, null, self);
				endif;
			endif;
		else
			if validateHazUNDG then
				if not hazClass.allUNDGCodes.includes(undgCode) then
					// PAR #36421 check secondary classes as well														// PAR #36421
					if not undgCode.allClassCodes.includes(hazClass.code) then											// PAR #36421
						app.raiseCMException2(UNDG_Assoc_Haz_Class,strUNDG,hazClass.code,null,null);
					endif;																								// PAR #36421
				endif;
				if self.packingGroup &lt;&gt; null and not undgCode.allPackingGroups.includes(self.packingGroup) then			// PAR #36421
					app.raiseCMException3(Packing_Group_Assoc_Hazard, self.packingGroup, hazClass.code, strUNDG, null, null);	// 07/01/2025 navsck1 #MTN-33234
				endif;																									// PAR #36421
			endif;
			if undgCode.isMarinePollutantMandatory and self.isMarinePollutant = null then								// TFS 3486
				app.raiseCMException1(Marine_Pollutant_Required, undgCode.code, null, null);							// TFS 3486
			endif;																										// TFS 3486
		endif;
	endforeach;
	
	if self.acidsBases &lt;&gt; null and self.acidsBases &lt;&gt; self.ACID and self.acidsBases &lt;&gt; self.BASE then					// TFS 2843
		app.raiseCMException(Acids_Bases_Invalid, null, null);															// TFS 2843
	endif;																												// TFS 2843
	if not root.allHazTempRanges.isEmpty and self.flashpointTemperature &lt;&gt; NULL_TEMPERATURE then						// TFS 2843
		
		/*hazTempRange := root.allHazTempRanges.getAtKeyLeq(self.flashpointTemperature);									// TFS 2843
		
		if hazTempRange = null or hazTempRange.upper &lt; self.flashpointTemperature  or  hazTempRange.lower &gt; self.flashpointTemperature then				//2/8/24   navsaa30 #65355					// TFS 2843
			
			hazTempRange := root.allHazTempRanges.getAtKeyGeq(self.flashpointTemperature);								// TFS 2843
			
			if hazTempRange = null or hazTempRange.upper &lt; self.flashpointTemperature or hazTempRange.lower &gt; self.flashpointTemperature then			//2/8/24   navsaa30 #65355					// TFS 2843
				app.raiseCMException1(Flashpoint_Temp_Not_Found, self.flashpointTemperature.asStringJMT, null, null);	// TFS 2843
			endif;																										// TFS 2843
		endif;*/// TFS 2843
		foreach hazTempRange in app.myRoot.allHazTempRanges do																	//2/8/24   navsaa30 #65355
			if  hazTempRange.lower &lt;= self.flashpointTemperature and hazTempRange.upper &gt;= self.flashpointTemperature then		
				rangeFound := true;
				break;
			endif;
		endforeach;	
		if not rangeFound then
				app.raiseCMException1(Flashpoint_Temp_Not_Found, self.flashpointTemperature.asStringJMT, null, null);
		endif;
	endif;																												
	
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
</Class>
