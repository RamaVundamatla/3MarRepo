    <JadeMethod name="setKeyFileSegCombo" id="0f646709-7cc6-4bbd-820a-bdc3c412565a">
        <source>setKeyFileSegCombo(_cmb: ComboBox input);
//----------------------------------------------------------------
//	Created:	01 September 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	_cmb.clear;
	
	_cmb.addItem(EDIKeySegment_FTXDIN &amp; Tab &amp; ' - MAF Actions');
	_cmb.addItem(EDIKeySegment_FTXQIN &amp; Tab &amp; ' - Quarantine Instruction');

end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="4c307300-30a4-4202-a656-b4a9a0a2d50c">
        <updating/>
        <source>setupThumbnailDetails() updating;

vars
	theForm : SOP_TableMaintForm;
    row     : Integer;
begin
  
  	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_EDIActionTbl);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_EDIActionMaint);
	theForm.shtTblInput1.visible := true;

	theForm.myAssistant.comboBoxEDIFileType(theForm.cmbEDIFileType, null, true);
	theForm.myAssistant.comboBoxEDIActionItem(theForm.cmbActionObject, null);
	self.setActionTypeCombo(theForm.cmbActionType);
	self.setKeyFileSegCombo(theForm.cmbKeyFileSegmt);
	
	theForm.mulSelect1.formDisplayEntryMethodName := null;
	theForm.mulSelect2.formDisplayEntryMethodName := null;

	self.colourColumn := theForm.tblData.getColumnByRowName(ETRow_Colour);			
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="11f1215a-c7a5-46c7-be4c-177ba5613aae">
        <updating/>
        <source>showThumbnail(_ediAction : CM_EDIAction) updating;

vars

	theForm : SOP_TableMaintForm;

begin
  
	theForm := self.myForm;
	theForm.tblInput1.clearValues;
	theForm.tblInput1.setValueByName(ETRow_Name, _ediAction.name);
	theForm.tblInput1.setValueByName(ETRow_Keyword, _ediAction.keyword);
	theForm.tblInput1.setValueByName(ETRow_KeyFileSegment, _ediAction.keyFileSegment);
	theForm.cmbKeyFileSegmt.text := _ediAction.keyFileSegment;
	
	theForm.tblInput1.setValueByName(ETRow_EDIFileType, _ediAction.myEDIFileType.name);
	theForm.cmbEDIFileType.listObject := _ediAction.myEDIFileType;
	
	if global.isValidObject(_ediAction.myActionObject) then
		theForm.tblInput1.setValueByName(ETRow_ActionObject, _ediAction.myActionObject.getEDIActionName);
		theForm.cmbActionObject.listObject := _ediAction.myActionObject;
	else
		theForm.tblInput1.setValueByName(ETRow_ActionObject, "*deleted*");
	endif;
	
	theForm.tblInput1.setValueByName(ETRow_ActionType, _ediAction.actionType);
	theForm.cmbActionType.text := _ediAction.actionType;
	theForm.tblData.accessColumn(2).width := 130;
	
end;</source>
        <Parameter name="_ediAction" type="CM_EDIAction"/>
    </JadeMethod>
