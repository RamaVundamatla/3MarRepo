<CollClass name="CM_CalculationTypeByCodeDict" id="ad77976f-0ff8-4571-8dd1-9e0f3d1f790a">
    <loadFactor>66</loadFactor>
    <memberType name="CM_CalculationType"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="invoice"/>
    <MemberKey>
        <property name="CM_CalculationType::code"/>
    </MemberKey>
    <JadeMethod name="getCalcTypeList" id="e0b9d189-8a86-4dad-8766-d36a29d582f2">
        <source>getCalcTypeList() : String;
/*
Purpose:			
Date		Who		Reason
27 May 2013	cnwab1	Initial creation
*/

vars
	calc : CM_CalculationType;
	tmpStr : String;
begin
	foreach calc in self  discreteLock do
		if tmpStr = null then
			tmpStr := "'" &amp; calc.description &amp; "'";
		else
			tmpStr := tmpStr &amp; ", '" &amp; calc.description &amp; "'";
			endif;
	endforeach;
 
 
	return tmpStr &amp; ".";
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
