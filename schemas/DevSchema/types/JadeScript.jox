    <JadeMethod name="pen4775" id="8f161519-8e82-412f-9133-5a0768588064">
        <source>pen4775();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2017	cnwma1	Initial creation

*/

vars
	fa : CM_FutureStorageProcess;
	fs : CM_FutureStorage;
	ts : TimeStamp;
	date: Date;
	time :Time;
	fsDeleted,infoDeleted,invDeleted : Integer;
	ilDeleted : Integer;
	lFile        : File;
	ti : CM_TrackedItem;
	tit : CM_TITransaction;
	i : Integer;
	invLineSet : CM_ObjectSet;
	inv : CM_Invoice;
begin
	date := "01/01/2000".Date;
	time := "00:00:00.000".Time;
	ts.setDate(date);
	ts.setTime(time);
	ti := "4949.423145".asOid.CM_TrackedItem;
	//First Step
	/*
	
	beginTransaction;
	foreach fa in CM_FutureStorageProcess.instances where fa.actionTimeStamp &lt; ts do
		fa.myTrackedItem.setFutureStorageAnniversary(null);
		delete fa;
		i := i+1;
	endforeach;
	commitTransaction;
	app.msgBox("count :" &amp; i.String,"",0);
	
	*/
	
	//Second Step
	beginTransaction;
	foreach tit in ti.allTransactions   do
		if tit.isKindOf(CM_FutureStorage) then
			if tit.CM_FutureStorage.chargeDateTime &lt; ts then
				if not tit.allInvoiceLines.isEmpty then
					ilDeleted := ilDeleted + tit.allInvoiceLines.size();
					tit.allInvoiceLines.purge;
				endif;
				delete tit;
				
				fsDeleted := fsDeleted +1;
				if fsDeleted mod 5000 = 0 then
					
					commitTransaction;
					beginTransaction;
				endif;
			endif;
		endif;
	endforeach;
	
	commitTransaction;
	
/*
	//Third Step Delete Information
	beginTransaction;
	foreach tit in ti.allTransactions   do
		if tit.isKindOf(CM_Information) then
			if tit.CM_Information.userId = "BGPUSER"
			   and tit.CM_Information.xmlInfo.cnContains("&lt;entry&gt;BGP future timer created for  00:01&lt;/entry&gt;&lt;/array&gt;") then
				delete tit;
				infoDeleted := infoDeleted +1;
				
				if infoDeleted mod 5000 = 0 then
	
					commitTransaction;
					beginTransaction;
				endif;
			endif;
		endif;
	
	
	endforeach;
	commitTransaction;
*/
	
	//4th Step delte invoices
	
	/*
	beginTransaction;
	foreach inv in CM_Invoice.instances where inv.invoiceType.description ="Storage" and inv.invoiceLines.isEmpty and inv.voyageCode=ti.voyageCode do 
	
		if  inv.status =CM_Invoice.INVOICE_OPEN then
			invDeleted := invDeleted +1;
			delete inv;
		endif;
		
		if invDeleted mod 5000 = 0 then

			commitTransaction;
			beginTransaction;
		endif;
				
	endforeach;
	commitTransaction;
	*/
	//Final Step Generate CSV
	create lFile transient;
	lFile.fileName := "C:\TEMP\pen\"&amp;ti.id&amp;".csv";
	lFile.open;
	lFile.writeLine("Tracked Item :"&amp;ti.id&amp; " Total Future Storage Deleted :" &amp;","&amp; fsDeleted.asStringJMT &amp;","&amp; "Invoice Lines Deleted : " &amp;","&amp; ilDeleted.asStringJMT);
	lFile.writeLine("Tracked Item :"&amp;ti.id&amp; " Total Information Deleted :" &amp;","&amp; infoDeleted.asStringJMT );
	lFile.writeLine("Tracked Item :"&amp;ti.id&amp; " Total invoices Deleted :" &amp;","&amp; invDeleted.asStringJMT );
	app.msgBox("Tracked Item :"&amp;ti.id&amp;" Total Future Storage Deleted :" &amp;","&amp; fsDeleted.asStringJMT &amp;","
				&amp;" Total Information Deleted :" &amp;","&amp; infoDeleted.asStringJMT &amp;","
				&amp; "Invoice Lines Deleted : " &amp;","&amp; ilDeleted.asStringJMT,"",0);
	lFile.close;
	delete lFile;
	

epilog

end;
	
</source>
    </JadeMethod>
    <JadeMethod name="pen5559" id="6cbb115d-81ab-439b-a1c6-c455bf36da68">
