    <JadeMethod name="doSpecialRelease" id="d5ee0834-6ebc-4bcb-96c6-f9d40d3aee5c">
        <source>doSpecialRelease() : Boolean;

vars
	portSchemaRelease : PortSchemaRelease;
	objArray : ObjectArray;
	result : Boolean;
begin
	result := false;
	create objArray transient;
	PortSchemaRelease.allInstances(objArray, 0, true);	
	portSchemaRelease := objArray[1].PortSchemaRelease;
	app.writeLog('Creating Drawing Attributes', 0);
	portSchemaRelease.sendMsg(PortSchemaRelease::loadDrawingAttributes.name);
	result := true;
epilog
	delete objArray;		// PAR #27874
	return result;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getClientSettings" id="41c2b45a-88da-4973-97b4-32e98c412410">
        <source>getClientSettings(client : String) protected;
/*

Purpose:			Grabs the latest license from dmast, if it exists.

Parameters:			The name of the client to search for

Return Value:		

Date				Who		Reason
30 November 2017	jlgmd1	Initial creation
15 December	2017	jlgmd1	Only grab the keys if the file/line exists
27 December 2017	jlgmd1	Bail early if we can't even start DMAST (aka, the TFS build server)
09 May 2022			navmd1	TFS 53592 Added Subscription License to Initialize App

*/

constants
	ClientName = "clientName=";
vars
	args 			: StringArray;
	result,
	exitVal 		: Integer;
	
	inputFile 		: File;
	line 			: String;
	pos 			: Integer;
	jmtKeyName,
	jmtKey,
	ediKeyName,
	ediKey,
	ewsKeyName,
	ewsKey,
	subsKeyName,
	subsKey			: String;
begin

	create args transient;
	
	args.clear();
	args.add('appServer=jade1.navdmast.nav.cnw.co.nz');
	args.add('appServerPort=50667');
	args.add('app=DevGetClientLicenseKeys');
	args.add('schema=DevSchema');
	args.add('ini="C:\DevelopmentEnvs\navdmast\navdmast.ini"');
	args.add('endJade');
	args.add(ClientName &amp; client);
	
	result := node.createExternalProcess("C:\DevelopmentEnvs\navdmast\c_bin", '"C:\DevelopmentEnvs\navdmast\c_bin\jade.exe"', args, null, true, true, exitVal);
	if result &lt;&gt; node.ExternalProcess_Successful then return; endif;

	create inputFile transient;
	inputFile.usePresentationFileSystem := true;
	inputFile.fileName := app.getTempDir() &amp; "getClientLicenseKeys.txt";
	inputFile.kind := File.Kind_Unknown_Text;
	
	// Get the JMT license
	line := inputFile.readLine();
	if line &lt;&gt; "" then
		pos := 1;
		jmtKeyName := line.scanUntil(":", pos);
		jmtKey := line[pos+1:end];
		
		// Get the EDI license
		line := inputFile.readLine();
		if line &lt;&gt; "" then
			pos := 1;
			ediKeyName := line.scanUntil(":", pos);
			ediKey := line[pos+1:end];
		endif;
		
		// Keep reading lines until we find the Subscription license
		// Unhelpfully this is just named the same as the Main license, but its always added last
		line := inputFile.readLine();
		while line &lt;&gt; null and line.pos(client,1) = 0 do
			// Skip 'BishPort' and 'Port Otago' license
			line := inputFile.readLine();
		endwhile;
		
		if line &lt;&gt; "" then
			pos := 1;
			subsKeyName := line.scanUntil(":", pos);
			subsKey := line[pos+1:end];
		endif;
		
		// ### JIRA 33543 16DEC2024 NAVAB1 Get the EWS license
		line := inputFile.readLine();
		if line &lt;&gt; "" then
			pos := 1;
			ewsKeyName := line.scanUntil(":", pos);
			ewsKey := line[pos+1:end];
		endif;
	endif;
	
	// Overwrite the JMT license
	if jmtKeyName &lt;&gt; null and jmtKey &lt;&gt; null then
		self.txtLicName.text := jmtKeyName;
		self.txtLicense.text := jmtKey;
	endif;
	
	// Overwrite the EDI license
	if ediKeyName &lt;&gt; null and ediKey &lt;&gt; null then
		self.txtEDILicName.text := ediKeyName;
		self.txtEDILicense.text := ediKey;
	endif;
	
	if subsKeyName &lt;&gt; null and subsKey &lt;&gt; null then
		self.txtSubLicName.text := subsKeyName;
		self.txtSubLicense.text := subsKey;
	endif;
	
	// ### JIRA 33543 16DEC2024 NAVAB1 Get the EWS license
	if ewsKeyName &lt;&gt; null and subsKey &lt;&gt; null then
		self.txtEWSLicName.text := ewsKeyName;
		self.txtEWSLicense.text := ewsKey;
	endif;

epilog
	if inputFile &lt;&gt; null then
		inputFile.close;
		delete inputFile;
	endif;
	delete args;
end;
</source>
        <access>protected</access>
        <Parameter name="client" type="String"/>
    </JadeMethod>
    <JadeMethod name="getMaxPerms" id="768cb1f1-40b3-4733-b126-554dd8193830">
        <source>getMaxPerms() : Integer protected;
// -----------------------------------------------------------------------------
// Created:		22 February 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	maxPerms : Integer;
	category : ConstantCategory;
	constant : Constant;
begin
	maxPerms := 0;
	
	category := currentSchema.getCategory(XLAT_Permissions);		
	
	foreach constant in category.getConstants do
		if constant.valueAsInteger &gt; maxPerms then
			maxPerms := constant.valueAsInteger;
		endif;
	endforeach;
	
epilog
	return maxPerms;
end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
