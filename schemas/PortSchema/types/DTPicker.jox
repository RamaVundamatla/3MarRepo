    <JadeMethod name="getTime" id="7527b397-bc5d-47b1-b77d-3f612b9367fd">
        <updating/>
        <source>getTime(): Time updating;

vars
	time:   Time;
begin
	time.setTime(getHour.Integer,
				 getMinute.Integer,
				 getSecond.Integer,
				 0);

	return time;
end;</source>
        <ReturnType type="Time"/>
    </JadeMethod>
    <JadeMethod name="getTimeStamp" id="3c6385a7-b575-49cd-b9c1-88a362ed9707">
        <updating/>
        <source>getTimeStamp(): TimeStamp updating;

vars
	timestamp:  TimeStamp;
	date:   Date;
	time:   Time;
begin
	date.setDate(getDay.Integer,
				 getMonth.Integer,
				 getYear.Integer);

	time.setTime(getHour.Integer,
				 getMinute.Integer,
				 getSecond.Integer,
				 0);

	timestamp.setDate(date);
	timestamp.setTime(time);

	return timestamp;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
