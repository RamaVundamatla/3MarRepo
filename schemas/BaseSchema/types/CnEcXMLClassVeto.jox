        <updating/>
        <source>lstAvailClasses_click(listbox: ListBox input) updating;

begin
	if lstAvailClasses.selectedCount &gt; 0 then
		btnMakeUnavail.enabled := true;
	else
		btnMakeUnavail.enabled := false;		
	endif;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
