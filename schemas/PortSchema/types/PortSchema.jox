    <JadeMethod name="bookingPackAsStringToEnumb" id="a587675e-589e-4cec-9f1d-0fd6bf851c28">
        <source>bookingPackAsStringToEnumb(_description : String): Integer;
//06 November 2009	cnwml2


vars

begin
	
	if _description = app.getErrorString(PackAs_FCL) then
		return BOOKING_PACKAS_FCL;
	elseif _description = app.getErrorString(PackAs_LCL) then
		return BOOKING_PACKAS_LCL;
	elseif _description = app.getErrorString(PackAs_S) then
		return BOOKING_PACKAS_S;
	else
//		return -1;
