    <JadeMethod name="yaFindLCs" id="719ee0a4-59ff-481c-97fd-9b1776f83ff2">
        <source>yaFindLCs(pFromId: String; pToId: String; pAllControllersObj: CM_LCArray input);
// --------------------------------------------------------------------------------
// Created:		15 April 2005 by cnwdad1:2
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	controllerObj	: CM_LocationsController;
	
begin
	controllerObj	:=	self.myLocationsController;
	
	// For Block Stacks, we won't bother checking for a sub-Block Stack.
	
	if controllerObj &lt;&gt; null
	and CM_YardController.hasInstance(controllerObj)
	then
		pAllControllersObj.add(controllerObj);
	endif;
end;</source>
        <Parameter name="pFromId" type="String"/>
        <Parameter name="pToId" type="String"/>
        <Parameter name="pAllControllersObj" type="CM_LCArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="yaGetBlockType" id="c44d2571-06af-45e4-8f6a-6d2c05015e96">
