end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="picIndex" type="Integer"/>
        <Parameter name="whatClicked" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="menuCopyCut" id="b170aaca-efa9-4a51-bd5c-5f58bd70b3ed">
        <source>menuCopyCut(pIsCutAndPaste:Boolean) protected;
// --------------------------------------------------------------------------------
// Created:		11 July 2002 by cnwdad2
//
// Purpose:		Process a user request (via a menu) to Copy (or Cut) a range of
//				selected files and/or directories.  This is done simply by adding
//				the selected items into a collection to be used later to Paste,
//				Rename or Delete operations.
//
// Parameters:	pIsCutAndPaste - If true, the user has requested a Paste operation,
//					in which case, so when the files/directories are later Pasted,
//					the originals will be deleted.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theContainer	: JSSFMFolder;
	
begin
	self.aAllCutAndPasteObjects.purge();
	create theContainer transient;
	theContainer.setIsCutAndPaste(pIsCutAndPaste);
	
	if self.aMyMenuList &lt;&gt; null then
		self.doGetSelectedListFolder(self.aMyMenuList, theContainer);
	elseif self.aMyMenuTable &lt;&gt; null then
		self.doGetSelectedTableFiles(self.aMyMenuTable, theContainer);
	else
		return;
	endif;
	
	if theContainer.allFileNodes.isEmpty() then
		delete theContainer;
	else
		self.aAllCutAndPasteObjects.add(theContainer);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pIsCutAndPaste" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="menuEnableForList" id="0daba72b-7624-4e02-a255-2c0e559a8b34">
        <updating/>
        <source>menuEnableForList(pTheListbox:ListBox) updating, protected;
// --------------------------------------------------------------------------------
// Created:		04 July 2002 by cnwdad1
//
// Purpose:		Enables menus based on what is currently selected in the specified
//				listbox control.
//
// Parameters:	pTheListbox - The listbox on which to check for selections.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theContainer	: JSSFMFileNode;
	theNode			: JSSFMFileNode;
	nodeType		: Integer;
	nodeName		: String;
	pathName		: String;
	allPathNames	: HugeStringArray;
	isCreateFolder	: Boolean;
	isPasteAllowed	: Boolean;
	
begin
	self.aMyMenuList	:=	pTheListbox;
	self.aMyMenuTable	:=	null;
	
	if self.aAllCutAndPasteObjects.isEmpty() then
		isPasteAllowed	:=	false;
	else
		isPasteAllowed	:=	true;
	endif;
	
	mnuFilePaste.enabled			:=	isPasteAllowed;
	mnuFilePasteBackground.enabled	:=	isPasteAllowed;
	
	if pTheListbox.listIndex = JSS_NULL_INDEX then
		mnuFileNewFolder.enabled		:=	false;
		mnuFileCopy.enabled				:=	false;
		mnuFileCut.enabled				:=	false;
		mnuFileDelete.enabled			:=	false;
		mnuFilePaste.enabled			:=	false;
		mnuFileRename.enabled			:=	false;
	else
		nodeType	:=	pTheListbox.itemData[pTheListbox.listIndex];
		nodeName	:=	pTheListbox.itemText[pTheListbox.listIndex];
		pathName	:=	self.listGetQualifiedName(pTheListbox, pTheListbox.listIndex);
		
		if nodeType = self.LISTBOX_NODE_APP_SERVER_FOLDER then
			allPathNames	:=	self.aAllPathNamesAppServer;
		elseif nodeType = self.LISTBOX_NODE_DB_SERVER_FOLDER then
			allPathNames	:=	self.aAllPathNamesDbServer;
		else
			return;
		endif;
		
		if (not allPathNames.isEmpty()) then
			// If there are restrictions on which directory paths can be accessed, then
			// users cannot edit anything other than the contents of those restricted
			// directories.
			
			if (not self.isPathEditable(pathName, allPathNames, isCreateFolder)) then
				mnuFileNewFolder.enabled	:=	isCreateFolder;
				mnuFileCopy.enabled			:=	false;
				mnuFileCut.enabled			:=	false;
				mnuFileDelete.enabled		:=	false;
				mnuFileRename.enabled		:=	false;
				
				if isCreateFolder then
					mnuFilePaste.enabled	:=	isPasteAllowed;
				else
					mnuFilePaste.enabled	:=	false;
				endif;
				
				return;
			endif;
		endif;
		
		if nodeType = self.LISTBOX_NODE_LOCAL_FOLDER
		or nodeType = self.LISTBOX_NODE_APP_SERVER_FOLDER
		or nodeType = self.LISTBOX_NODE_DB_SERVER_FOLDER
		then
			if nodeName[nodeName.length] = ":" then		// Can't edit a disk drive other than adding a new directory.
				mnuFileNewFolder.enabled	:=	true;
				mnuFileCopy.enabled			:=	false;
				mnuFileCut.enabled			:=	false;
				mnuFileDelete.enabled		:=	false;
				mnuFileRename.enabled		:=	false;
			else										// It must be a directory path.
				mnuFileNewFolder.enabled	:=	true;
				mnuFileCopy.enabled			:=	true;
				mnuFileCut.enabled			:=	true;
				mnuFileDelete.enabled		:=	true;
				mnuFileRename.enabled		:=	true;
			endif;
			
			if self.aAllCutAndPasteObjects.isEmpty() then
				mnuFilePaste.enabled	:=	false;
			else
				mnuFilePaste.enabled	:=	true;
			endif;
		else											// It's not a node folder, so no editing at all.
			mnuFileNewFolder.enabled	:=	false;
			mnuFileCopy.enabled			:=	false;
			mnuFileCut.enabled			:=	false;
			mnuFileDelete.enabled		:=	false;
			mnuFilePaste.enabled		:=	false;
			mnuFileRename.enabled		:=	false;
		endif;
	endif;
	
	// Can only do a background copy if the source and target nodes are the DB Server.
	
	if isPasteAllowed then
		if nodeType = self.LISTBOX_NODE_DB_SERVER_FOLDER
		or nodeType = LISTBOX_NODE_DB_SERVER_FILE
		then
			foreach theContainer in self.aAllCutAndPasteObjects do
				foreach theNode in theContainer.allFileNodes do
					break;
				endforeach;
				
				break;
			endforeach;
			
			if theNode = null then
				mnuFilePasteBackground.enabled	:=	false;
			else
				if theNode.nodeType = self.LISTBOX_NODE_DB_SERVER_FOLDER
				or theNode.nodeType = LISTBOX_NODE_DB_SERVER_FILE
				then
					mnuFilePasteBackground.enabled	:=	true;
				else
					mnuFilePasteBackground.enabled	:=	false;
				endif;
			endif;
		else
			mnuFilePasteBackground.enabled	:=	false;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pTheListbox" type="ListBox"/>
    </JadeMethod>
    <JadeMethod name="menuEnableForTable" id="40177e69-108c-4cc5-bc71-8f51181fb750">
        <updating/>
        <source>menuEnableForTable(pTheTable:Table) updating, protected;
// --------------------------------------------------------------------------------
// Created:		04 July 2002 by cnwdad1
//
// Purpose:		Enables menus based on what is currently selected in the specified
//				table control.
//
// Parameters:	pTheTable - The table on which to check for selections.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theContainer	: JSSFMFileNode;
	theNode			: JSSFMFileNode;
	theListbox		: ListBox;
	listPointer		: Integer;
	nodeType		: Integer;
	pathName		: String;
	allPathNames	: HugeStringArray;
	isCreateFolder	: Boolean;
	isPasteAllowed	: Boolean;
	
begin
	self.aMyMenuList	:=	null;
	self.aMyMenuTable	:=	pTheTable;
	
	if self.aAllCutAndPasteObjects.isEmpty() then
		isPasteAllowed	:=	false;
	else
		isPasteAllowed	:=	true;
	endif;
	
	mnuFilePaste.enabled			:=	isPasteAllowed;
	mnuFilePasteBackground.enabled	:=	isPasteAllowed;
	
	if self.tableIsAnyRowsSelected(pTheTable) then
//		mnuFileNewFolder.enabled	:=	false;
		mnuFileCopy.enabled			:=	true;
		mnuFileCut.enabled			:=	true;
		mnuFileDelete.enabled		:=	true;
		mnuFileRename.enabled		:=	true;
	else
		if pTheTable = tblFilesTop then
			theListbox	:=	lstDirTop;
		elseif pTheTable = tblFilesBottom then
			theListbox	:=	lstDirBottom;
		endif;
		
		listPointer	:=	theListbox.listIndex;
		
		if listPointer &gt; 0 then
			nodeType	:=	theListbox.itemData[listPointer];
			pathName	:=	self.listGetQualifiedName(theListbox, listPointer);
			
			if nodeType = self.LISTBOX_NODE_APP_SERVER_FOLDER then
				allPathNames	:=	self.aAllPathNamesAppServer;
			elseif nodeType = self.LISTBOX_NODE_DB_SERVER_FOLDER then
				allPathNames	:=	self.aAllPathNamesDbServer;
			endif;
			
			if allPathNames &lt;&gt; null and (not allPathNames.isEmpty()) then
				// If there are restrictions on which directory paths can be accessed, then
				// users cannot edit anything other than the contents of those restricted
				// directories.
				
				if (not self.isPathEditable(pathName, allPathNames, isCreateFolder)) then
					mnuFileNewFolder.enabled	:=	isCreateFolder;
					mnuFileCopy.enabled			:=	false;
					mnuFileCut.enabled			:=	false;
					mnuFileDelete.enabled		:=	false;
					mnuFileRename.enabled		:=	false;
					
					if isCreateFolder then
						mnuFilePaste.enabled	:=	isPasteAllowed;
					else
						mnuFilePaste.enabled	:=	false;
					endif;
					
					return;
				endif;
			endif;
			
			if nodeType = self.LISTBOX_NODE_LOCAL_FOLDER
			or nodeType = self.LISTBOX_NODE_APP_SERVER_FOLDER
			or nodeType = self.LISTBOX_NODE_DB_SERVER_FOLDER
			then
				mnuFileNewFolder.enabled	:=	true;
				mnuFileCopy.enabled			:=	false;
				mnuFileCut.enabled			:=	false;
				mnuFileDelete.enabled		:=	false;
				mnuFileRename.enabled		:=	false;
				
				if self.aAllCutAndPasteObjects.isEmpty() then
					mnuFilePaste.enabled	:=	false;
				else
					mnuFilePaste.enabled	:=	true;
				endif;
			else
				mnuFileNewFolder.enabled	:=	false;
				mnuFileCopy.enabled			:=	false;
				mnuFileCut.enabled			:=	false;
				mnuFileDelete.enabled		:=	false;
				mnuFilePaste.enabled		:=	false;
				mnuFileRename.enabled		:=	false;
			endif;
		else
			mnuFileNewFolder.enabled	:=	false;
			mnuFileCopy.enabled			:=	false;
			mnuFileCut.enabled			:=	false;
			mnuFileDelete.enabled		:=	false;
			mnuFilePaste.enabled		:=	false;
			mnuFileRename.enabled		:=	false;
		endif;
	endif;
	
	// Can only do a background copy if the source and target nodes are the DB Server.
	
	if isPasteAllowed then
		if nodeType = self.LISTBOX_NODE_DB_SERVER_FOLDER
		or nodeType = LISTBOX_NODE_DB_SERVER_FILE
		then
			foreach theContainer in self.aAllCutAndPasteObjects do
				foreach theNode in theContainer.allFileNodes do
					break;
				endforeach;
				
				break;
			endforeach;
			
			if theNode = null then
				mnuFilePasteBackground.enabled	:=	false;
			else
				if theNode.nodeType = self.LISTBOX_NODE_DB_SERVER_FOLDER
				or theNode.nodeType = LISTBOX_NODE_DB_SERVER_FILE
				then
					mnuFilePasteBackground.enabled	:=	true;
				else
					mnuFilePasteBackground.enabled	:=	false;
				endif;
			endif;
		else
			mnuFilePasteBackground.enabled	:=	false;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pTheTable" type="Table"/>
    </JadeMethod>
    <JadeMethod name="mnuFileChunkSize_click" id="0908fdf6-2da8-423f-97f7-01d7f7701857">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuFileChunkSize_click(menuItem: MenuItem input) updating;
// --------------------------------------------------------------------------------
// Created:		22 July 2002 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theChunkSizeForm	: JSSFMChunkSizeForm;
	
begin
	self.setState(Busy);
	
	create theChunkSizeForm;
	theChunkSizeForm.setServiceObject(self.aMyServiceObject);
	theChunkSizeForm.setServiceManager(self.aMyServiceManager);
	theChunkSizeForm.setChunkSize(self.aMyServiceObject.fileChunkSize);
	
	theChunkSizeForm.showModal();
epilog
	self.setState(Idle);
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuFileCopy_click" id="7e2e88bd-9b63-4175-ac9a-ebd8a40e6ab3">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuFileCopy_click(menuItem: MenuItem input) updating;
// --------------------------------------------------------------------------------
// Created:		04 July 2002 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	IS_CUT_AND_PASTE	: Boolean = false;
	
begin
	self.setState(Busy);
	self.menuCopyCut(IS_CUT_AND_PASTE);
epilog
	self.setState(Idle);
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuFileCut_click" id="06968438-6ed8-4f97-a4fe-139a35ab729b">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuFileCut_click(menuItem: MenuItem input) updating;
// --------------------------------------------------------------------------------
// Created:		04 July 2002 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	IS_CUT_AND_PASTE	: Boolean = true;
	
begin
	self.setState(Busy);
	self.menuCopyCut(IS_CUT_AND_PASTE);
epilog
	self.setState(Idle);
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuFileDelete_click" id="b61ef445-a387-4d29-a549-12bc36757037">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuFileDelete_click(menuItem: MenuItem input) updating;
// --------------------------------------------------------------------------------
// Created:		04 July 2002 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theContainer	: JSSFMFolder;
	
begin
	self.setState(Busy);
	
	if app.msgBox(	"Are you sure you want to delete the selected files ?",
					"Delete Directory",
					MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
		self.aAllCutAndPasteObjects.purge();
		create theContainer transient;
		
		if self.aMyMenuList &lt;&gt; null then
			self.doGetSelectedListFolder(self.aMyMenuList, theContainer);
		elseif self.aMyMenuTable &lt;&gt; null then
			self.doGetSelectedTableFiles(self.aMyMenuTable, theContainer);
		else
			return;
		endif;
		
		if (not theContainer.allFileNodes.isEmpty()) then
			self.aAllCutAndPasteObjects.add(theContainer);
			self.doDeleteSelectedNodes();
			self.aAllCutAndPasteObjects.purge();
		endif;
	endif;
epilog
	// The container object will be deleted when the cut-and-paste collection is purged (above).
	
	self.setState(Idle);
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuFileExit_click" id="71fb7392-f10e-488e-909e-8ad24a298506">
