    <JadeMethod name="validateUpdate" id="b2ff6bb8-48b7-4ba4-b243-8a297997fe83">
        <source>validateUpdate(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Sep 2023 navhl20 ChangeRequest 60063: EUP | Ship Operations in DD - Terminal Config for grouping attributes

*/

vars
	realWOJobGroup,
	existWOJobGroup		: CM_WorkOrderJobGroupMethod;
begin
	if self.code = null then
		app.raiseCMException(Input_required_field_code, ETRow_Code, self);
	endif;
	
	if self.description = null then
		app.raiseCMException(Input_required_field_desc, ETRow_Description, self); 
	endif;
	
	if self.allWorkOrderDetailTypes.isEmpty then
		app.raiseCMException(Input_requi_work_order_type_fi, ETRow_WorkOrderType, self); 
	endif;
	
	if self.allGroupingCriteria.isEmpty then
		app.raiseCMException(Input_requir_groupi_criter_fie, ETRow_GrpCriteria, self); 
	endif;
	
	existWOJobGroup	:= self.myTerminal.allWOJobGroupMethods[self.code,self.myTerminal];
	realWOJobGroup	:= self.pxyGetRealObject();
	
	if existWOJobGroup &lt;&gt; null and
	   (realWOJobGroup = null or //in which case we are trying add a new one that is duplicate
	   existWOJobGroup &lt;&gt; realWOJobGroup) //in which case we are trying update one to be same as another
	   then
		app.raiseCMException2(Work_order_group_alrea_exist_t, self.code,self.myTerminal.code, null, null); 
	endif;
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
