    <JadeMethod name="msgBGP_IfNotThinCannotRun" id="40b3aada-4303-4440-8cc0-8001a0130d3c">
        <source>msgBGP_IfNotThinCannotRun(_isServerFlagSet:Boolean):Boolean;
// --------------------------------------------------------------------------------
// Created:		04 November 2009 by cnwdad1
//
// Purpose:		Determines whether a BGP Service can be started by the requesting
//				client (BGP stuff can only be run on the Server Node).
//
// Parameters:	_isServerFlagSet - True if the BGP Manager has the "isRunOnServer"
//					flag set to true, otherwise false.
//
// Returns:		True if the BGP Service can be started, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if _isServerFlagSet or (not process.isUsingThinClient()) then
		return true;
	else
		app.msgBox("BGP Services can only be run on the server node.", "Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return false;
	endif;
end;</source>
        <Parameter name="_isServerFlagSet" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="msgBox" id="e37094c0-e10a-4317-b806-c1d6d6b38558">
        <source>msgBox(msg: String; title: String; flags: Integer): Integer;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 16 November 2004
//
//********************************************************************
// 12/04/2011	cnwmh5		PAR #27347 - Raise an error if we are in load / transaction state and call app.msgBox
// 19 May 2011	NDL	Par 27459
vars

	callingMethod: String;
	mess : String;
	
begin

	if process.isInLoadState or process.isInTransactionState then							// 12/04/2011 cnwmh5 #27347
		callingMethod := self.getCallingMethod(3);
		mess := 'app.msgBox called while in Load or Transaction state from ' &amp; callingMethod;
		executeWhen JMTDevelopmentEnvironment;
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, self.class.name, method.name, mess, null, null);
		endExecuteWhen;
		app.writeLog(mess,LogINFO);
	endif;
	
	return inheritMethod(msg, title, flags);

end;</source>
        <Parameter name="msg" type="String"/>
        <Parameter name="title" type="String"/>
        <Parameter name="flags" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="myCurrentUserCan" id="9c812f6f-d2cd-42c8-9f30-851320d2e212">
        <source>myCurrentUserCan(_terminal : CM_Terminal; _doWhat : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:			26 March 2001 by cnwdwq1
// Purpose:			!     
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By		Reason
// ----------			----------			--------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpUser	: CM_User;
	
begin
	tmpUser := app.getMyUser();
	
	if tmpUser = null then
		return false;
	endif;
	
	return tmpUser.canDo(_terminal, _doWhat);
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_doWhat" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
