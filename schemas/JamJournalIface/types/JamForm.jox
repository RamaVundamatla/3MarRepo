    <JadeMethod name="updateUserTracker" id="6f04f61e-8eaf-4d32-9d50-43b484d4c6dd">
        <source>updateUserTracker(userName : String; userIndex : Integer) : AuditAccessUserTracker;

vars
	userTracker		: AuditAccessUserTracker;
	
begin
	userTracker := self.allAuditAccessUsers[userIndex];
	if userTracker = null then
		userTracker := createUserTracker(userName, userIndex, null);
	else
		userTracker.userName := userName;
		updateUserTable;
	endif;
		
	return userTracker;
	

epilog

end;</source>
        <Parameter name="userName" type="String"/>
        <Parameter name="userIndex" type="Integer"/>
        <ReturnType type="AuditAccessUserTracker"/>
    </JadeMethod>
    <JadeMethod name="updateUserTrackerTran" id="299a7831-8bbc-4fda-8b9b-1fcce092a9ed">
        <source>updateUserTrackerTran(userIndex : Integer; tranId : Decimal);

/*

Purpose:			


Return Value:		


Date		Who		Reason
24 January 2005	cnwkpd1	PAR #5202 - SUTARE 1007 Timer Task

*/

vars
	userTracker		: AuditAccessUserTracker;
	
begin
	userTracker := allAuditAccessUsers[userIndex];
	if userTracker = null then
		userTracker := createUserTracker("&lt;Unknown&gt;", userIndex, null);
	endif;

	userTracker.currentTransactionId := tranId;

	updateUserTable;
	

epilog

end;</source>
        <Parameter name="userIndex" type="Integer"/>
        <Parameter name="tranId" type="Decimal"/>
    </JadeMethod>
</GUIClass>
