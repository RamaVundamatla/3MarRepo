<Class name="CM_PermissionAgent">
    <JadeMethod name="getPermissionValuesAndSetIfReqd" id="589d4682-1a72-41b2-9902-90c2467210d9">
        <source>getPermissionValuesAndSetIfReqd(_permissions : BooleanArray input; _isSystemPerm, _isInternalOnly : Boolean; _permissionsToSet : StringArray);

/*

Purpose:		Get permissions array and set any that need to be set

Date			Who		Reason
09/11/2017		jlgm5	Initial creation

*/

vars

	permObj : CM_PermissionObject;

begin

	_permissions.clear;
	foreach permObj in self.allPermissionsByConstValue do
		if _permissionsToSet.includes(permObj.constName) then
			_permissions[permObj.constValue] := true;
		else
			_permissions[permObj.constValue] := false;
		endif;
		/*
		if permObj.isInternal and (not _isInternalOnly) then
			if _permissionsToSet.includes(permObj.constName) then
				_permissions[permObj.constValue] := true;
			else
				_permissions[permObj.constValue] := false;
			endif;
		else
			if _isSystemPerm and permObj.isSystemPermission or
			   (not _isSystemPerm and not permObj.isSystemPermission) then 
				_permissions[permObj.constValue] := permObj.permValue;
			else
				if _permissionsToSet.includes(permObj.constName) then
					_permissions[permObj.constValue] := true;
				else
					_permissions[permObj.constValue] := false;
				endif;
			endif;
		endif;
		*/
	endforeach;

epilog

end;
</source>
        <Parameter name="_permissions" type="BooleanArray" usage="input"/>
        <Parameter name="_isSystemPerm" type="Boolean"/>
        <Parameter name="_isInternalOnly" type="Boolean"/>
        <Parameter name="_permissionsToSet" type="StringArray"/>
    </JadeMethod>
</Class>
