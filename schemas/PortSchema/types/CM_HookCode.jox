    <JadeMethod name="getCurrentJadeCode" id="5621d97a-d086-4283-9380-edf57ae7a630">
        <source>getCurrentJadeCode() : String;
// -------------------------------------------
// Created 07 February 2005 by cnwdvb1
// -------------------------------------------
vars

	history : CM_HookCodeHistory;

begin

	history := self.allHookCodeHistory.first;
	if history &lt;&gt; null then
		return history.jadeCode;
	endif;
	
	return null;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="55c70ccb-e222-4a72-990b-f9e500cf582a">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// -------------------------------------------
// Created 04 February 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	if _attrName = ETRow_Code then
		return self.code;
	elseif _attrName = ETRow_HookType then
		// ### CNWAB1 MARCH2016 added detail
		if self.myHookType.hookType  = HookType_InvoiceQuantity 
		or self.myHookType.hookType  = HookType_InvoiceRate then
			return self.myHookType.description &amp; " " &amp; app.getErrorString(Cargo);
		elseif self.myHookType.hookType  = HookType_HMSInvoiceQuantity 
		or self.myHookType.hookType  = HookType_HMSInvoiceRate then
			return self.myHookType.description &amp; " " &amp; app.getErrorString(HMS);
		endif;
		
		return self.myHookType.description;
	elseif _attrName = ETRow_HookLastUpdated then
		return self.getLastUpdated();
	elseif _attrName = ETRow_HookIterations then
		return self.allHookCodeHistory.size.String;
	elseif _attrName = ETRow_HookNumLinks then
		return self.allHookLinks.size.String;
	elseif _attrName =ETRow_HookClass then
		return self.myHookType.hookClassType;
	else
		return inheritMethod(_attrName, _short);
	endif;


end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLastUpdated" id="3ce4888d-cdb4-48fe-82e9-ad00da7e1a31">
        <source>getLastUpdated() : String;
// -------------------------------------------
// Created 07 February 2005 by cnwdvb1
// -------------------------------------------
vars

	history : CM_HookCodeHistory;

begin

	history := self.allHookCodeHistory.first;
	if history &lt;&gt; null then
		return history.codeCreatedTs.shortCurrentLocaleFormat();
	endif;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="importMyCollectionsXML" id="64ea193b-1161-4787-9f17-ece6070061f4">
        <updating/>
        <source>importMyCollectionsXML(_collectionsBlock: String) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 April 2009	cnwrd1	Initial creation

*/



vars
	newHookHistory 	:  CM_HookCodeHistory;
	newHookLink 		: CM_HookLink;	
	allFieldsBlock,
	fieldBlock		: String;
	blockLength,
	pos				: Integer;
begin

	
	
	allFieldsBlock := _collectionsBlock.cnEcGetTagValueOfName('allHookCodeHistory');

	if allFieldsBlock = null then
		return;
	endif;
	
	pos := 1;
	blockLength := allFieldsBlock.length;
	self.allHookCodeHistory.purge();
	
	while pos &lt; blockLength do
		fieldBlock := allFieldsBlock.cnEcGetNextTagValueOfName(CM_HookCodeHistory.name, pos);
		if pos &lt; 1 then
			break;
		endif;
		
		if fieldBlock = null then
			continue;
		endif;
		
		create newHookHistory transient;
		newHookHistory.importMeXML(fieldBlock);
		newHookHistory.setPropertyValue('myHookCode', self);
	endwhile;

	allFieldsBlock := _collectionsBlock.cnEcGetTagValueOfName('allHookLinks');

	if allFieldsBlock = null then
		return;
	endif;
	
	pos := 1;
	blockLength := allFieldsBlock.length;
	self.allHookLinks.purge();
	
	while pos &lt; blockLength do
		fieldBlock := allFieldsBlock.cnEcGetNextTagValueOfName(CM_HookLink.name, pos);
		if pos &lt; 1 then
			break;
		endif;
		
		if fieldBlock = null then
			continue;
		endif;
		
		create newHookLink transient;
		newHookLink.importMeXML(fieldBlock);
		newHookLink.setPropertyValue('myHookCode', self);
		newHookLink.setPropertyValue('myRoot', self.myRoot);

		newHookLink.setLinkObject(self.myParentObject);

	endwhile;

	

epilog

end;</source>
        <Parameter name="_collectionsBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="importMyReferencesXML" id="f805ebf9-2fab-4a23-9a08-fe01490d7fc1">
        <updating/>
        <source>importMyReferencesXML(_referencesBlock: String) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 April 2009	cnwrd1	Initial creation

*/

vars
	hookTypeCode		: String;
	hookType			: CM_HookType;
begin


	hookTypeCode := _referencesBlock.cnEcGetTagValueOfName('myHookType');
	
	hookType := app.myRoot.allHookTypes[hookTypeCode.Integer];
	if hookType &lt;&gt; null then
		self.myHookType := hookType;
	endif;
	
	


epilog

end;</source>
        <Parameter name="_referencesBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="logicallyDeleteMe" id="adbf2fa9-484e-419a-b279-4419b67a1448">
        <updating/>
        <source>logicallyDeleteMe() updating;
// -------------------------------------------
// Created 07 March 2005 by cnwdvb1
// -------------------------------------------
vars

	hookLink	: CM_HookLink;

begin

	self.isNotAvailableForEntry := true;
	foreach hookLink in self.allHookLinks do
		hookLink.logicallyDeleteMe();
	endforeach;
	
	
	if myHookType.hookType = HookType_WagonClass and self.myParentObject &lt;&gt; null then
		self.myParentObject.CM_Root.setMyWagonClassHookCode(null);
	endif;
	
	//10 Nov 2010	NDL	Par 25530
	if myHookType.hookType = HookType_CalendarDay and self.myParentObject &lt;&gt; null then
		self.myParentObject.CM_Calendar.setMyHookCode(null);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="8b5d5e10-b513-4437-bf0f-b4b44ceea087">
        <source>pxyCreateUpdateProxy(): SelfType;
// -------------------------------------------
// Created 07 February 2005 by cnwdvb1
// -------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars

	pxyCode	: CM_HookCode;
	pxyLink,
	link	: CM_HookLink;
	completedOK		: Boolean;
		
begin
	
	pxyCode := inheritMethod();
	
	pxyCode.myHookType := self.myHookType;
	pxyCode.myRoot := self.myRoot;
	
	foreach link in self.allHookLinks do
		pxyLink := link.pxyCreateUpdateProxy();
		pxyLink.setMyHookCode(pxyCode);
	endforeach;
	
	// Don't create history as we are just adding to the array.
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyCode;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyCode;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxyWithCode" id="b3c40dc1-3ec8-45f2-9a04-3897392c2ebb">
        <source>pxyCreateUpdateProxyWithCode() : SelfType;
// ---------------------------------------------------------------------------
// Created:     15 January 2008 by cnwrs2
//
// Purpose:     Creates a proxy object with the current jade code
// ---------------------------------------------------------------------------
vars
	proxy	: CM_HookCode;
	realHistory,
	pxyHistory	: CM_HookCodeHistory;
begin
	proxy := self.pxyCreateUpdateProxy();
	
	realHistory := self.allHookCodeHistory.first;
	if realHistory &lt;&gt; null then
		pxyHistory := realHistory.pxyCreateUpdateProxy();
		pxyHistory.setMyHookCode(proxy);
	endif;
	
	return proxy;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="0e87a7e7-601a-4179-8099-a6d9061eda54">
        <updating/>
        <source>setForCreate(_pxyHookCode : CM_HookCode) updating;
// -------------------------------------------
// Created 07 February 2005 by cnwdvb1
// -------------------------------------------
vars


begin

	self.setForUpdate(_pxyHookCode);
	self.myRoot	:= _pxyHookCode.myRoot;


end;</source>
        <Parameter name="_pxyHookCode" type="CM_HookCode"/>
    </JadeMethod>
    <JadeMethod name="setForProxy" id="17813e9d-f918-4d4b-b564-3a59e539a2bb">
        <updating/>
        <source>setForProxy(_code : String; _hookType : CM_HookType) updating;
// -------------------------------------------
// Created 07 February 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	self.myHookType := _hookType;
	self.code		:= _code;
	self.myRoot		:= app.myRoot;

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_hookType" type="CM_HookType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="e31d7476-9107-4437-8323-334fac86b85c">
        <updating/>
        <source>setForUpdate(_pxyHookCode : CM_HookCode) updating;
// -------------------------------------------
// Created 07 February 2005 by cnwdvb1
// -------------------------------------------
vars

	pxyLink,
	realLink			: CM_HookLink;
	linkSet				: CM_HookLinkSet;
	expectedEdition		: Integer;
	history				: CM_HookCodeHistory;
	calendar			: CM_Calendar;

begin

	self.code 		:= _pxyHookCode.code;
	self.myHookType	:= _pxyHookCode.myHookType;
	// TFS 2010 modifying logically deleted hook code should make it active again so it shows in the User Code Hook Maintenance screen
	if self.isNotAvailableForEntry then
		self.isNotAvailableForEntry := false;
	endif;
	
	create linkSet transient;
	self.allHookLinks.copy(linkSet);
	
	foreach pxyLink in _pxyHookCode.allHookLinks do
		pxyLink.pxyGetRealObjectAndEdition(realLink, expectedEdition);
		if realLink = null then
			create realLink persistent;
			realLink.setForCreate(pxyLink, self);
		else
			if realLink.edition &lt;&gt; expectedEdition then
				app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'HookLink', null, null);
				return;
			endif;
			self.exclusiveLock(realLink);
			realLink.setForUpdate(pxyLink);
			linkSet.remove(realLink);
		endif;
	endforeach;
	
	foreach realLink in linkSet do
		realLink.erase(NORMAL_ERASE);
	endforeach;
	
	create history persistent;
	history.setForCreate(_pxyHookCode.allHookCodeHistory.last.CM_HookCodeHistory, self);
	
	if _pxyHookCode.myHookType.hookType = HookType_WagonClass then	// 21 Jul 2009	NDL	CCMS 1067
		if app.myRoot.myWagonClassHookCode &lt;&gt; self then
			app.myRoot.setMyWagonClassHookCode(self);
		endif;
	elseif _pxyHookCode.myHookType.hookType = HookType_CalendarDay then	// 10 Nov 2010	NDL Par 25530
		realLink := _pxyHookCode.allHookLinks.first;
		if realLink &lt;&gt; null then
			calendar := realLink.myLinkObject.CM_Calendar;
			if calendar &lt;&gt; null then
				calendar.setMyHookCode( self );
			endif;
		endif;
		
	endif;
	
epilog
	delete linkSet;
end;</source>
        <Parameter name="_pxyHookCode" type="CM_HookCode"/>
    </JadeMethod>
    <JadeMethod name="setJadeCodeForProxy" id="e5eee2d4-0c67-4ab3-8a89-709e9bcc976b">
        <updating/>
        <source>setJadeCodeForProxy(_jadeCode, _userCode : String) updating;
// ---------------------------------------------------------------------------
// Created:     15 January 2008 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	history	: CM_HookCodeHistory;
	
begin
	self.raiseExceptionIfNotTransient(method);
	
	history := self.allHookCodeHistory.first;
	if history = null then
		create history transient;
	endif;
	history.setForProxy(_jadeCode, _userCode, self);

end;</source>
        <Parameter name="_jadeCode" type="String"/>
        <Parameter name="_userCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="validate" id="679f0fb5-1013-46f7-8d26-735af7ac1af6">
        <source>validate();
// -------------------------------------------
// Created 07 February 2005 by cnwdvb1
// -------------------------------------------
vars

	history	: CM_HookCodeHistory;

begin

	if self.myHookType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Hook Type', null, null);
		app.raiseCMException(Input_required_field_hookType, null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Hook Code', null, null);
		app.raiseCMException(Input_required_field_hookCode, null, null); // cnwdb2	PAR 35364


	endif;
	
	if self.allHookLinks.isEmpty() then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Hook Link', null, null);
		app.raiseCMException(Input_required_field_hookLink, null, null); // cnwdb2	PAR 35364


	else
		//10 Nov 2010	NDL	Par 25530
		if myHookType.hookType = HookType_CalendarDay then
			if self.allHookLinks.size &gt; 1 then
				app.raiseCMException(Only_calen_selec_permi_hook_co, null, null);
			endif;
		endif;
	endif;
	
	// Always only one on the proxy.
	history := self.allHookCodeHistory.first;
	
	if history = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Hook Code History', null, null);
		app.raiseCMException(Input_required_field_hokCdeHis, null, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	history.validate();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="21f4f47d-1435-4ad3-8bc3-a8ec2f7bc8cf">
        <source>validateForCreate();
// -------------------------------------------
// Created 07 February 2005 by cnwdvb1
// -------------------------------------------
vars

	link	: CM_HookLink;

begin

	self.validate();
	
	if self.myRoot.allHookCodes[self.code, false] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	endif;
	
	foreach link in self.allHookLinks do
		link.validateForCreate();
	endforeach;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="571584f7-c14a-486f-b96f-0ea8e6517078">
        <source>validateForUpdate();
// -------------------------------------------
// Created 07 February 2005 by cnwdvb1
// -------------------------------------------
vars

	realObjForProxy,
	realObjFound	: CM_HookCode;
	link			: CM_HookLink;
	

begin

	self.validate();
	
	realObjFound	:= self.myRoot.allHookCodes[self.code, false];
	realObjForProxy	:= self.pxyGetRealObject;
	/*
	if realObjFound &lt;&gt; null and realObjFound &lt;&gt; realObjForProxy then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	endif;
*/
	foreach link in self.allHookLinks do
		link.validateForUpdate();
	endforeach;
end;</source>
    </JadeMethod>
</Class>
