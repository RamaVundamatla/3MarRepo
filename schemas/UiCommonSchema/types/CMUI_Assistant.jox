        <source>comboBoxCameraType( pCmb:ComboBox input );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 December 2010	cnwndl1	Initial creation	Par 23831

*/

vars

	index : Integer;

begin

	pCmb.clear();
	pCmb.sorted := false;
	
	index := pCmb.addItem( app.getErrorString(None) );
