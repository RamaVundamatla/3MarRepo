		//app.doCmd("xcopy c:\thinbin\creator \\"&amp;m.hostName&amp;"\c$\thinbin\creator /f /e /y", " &gt;&gt; c:\a\cmd.log");
		//app.doCmd("xcopy c:\thinbin\jblpcre \\"&amp;m.hostName&amp;"\c$\thinbin\jblpcre /f /e /y", " &gt;&gt; c:\a\cmd.log");
		//app.doCmd("dir \\"&amp;m.hostName&amp;"\c$\thinbin\creator\jade.exe", " &gt;&gt; c:\a\cmd.log");
		app.doCmd("xcopy \\cnwchcm24\cnwjbl$\Tools\jblautorun\1.9.5.56\jblautorun.exe \\cnwchcm24\cnwjbl$\Tools\circ\pending\" &amp; m.hostName &amp; " /f /e /y", " &gt;&gt; c:\a\cmd.log");
		app.doCmd("xcopy \\cnwchcm24\cnwjbl$\Tools\jblworker\config\SyncCardinalBin.jbl \\cnwchcs118\jobs\" &amp; m.hostName &amp; "\creatorin /f /e /y", " &gt;&gt; c:\a\cmd.log");
