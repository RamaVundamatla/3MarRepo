        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_secondTrx" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_NAD" id="0748defb-3c8a-4985-af3c-58eb492d240b">
        <updating/>
        <source>outputHeader_NAD (_protocol :CM_CamProtocol; _camMessage :CM_CamMessage input; _camTaskHistory :CM_CamTaskHistory input; _coll :HugeStringArray input) : String updating, protected;
/*
Date		Who		Reason
20/12/2012	cnwcs5	CCMS SFW 1294 /par 30855
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
vars
	code, fCode :String;
	strLine : String;
begin
	// ECN/MOT Requirement - NAD+CF+&lt;Carrier&gt;
	code 	:= _camMessage.camVoyage.getVoyageOperatorCode;
	fCode 	:= self.getXlatedForeignCode(_protocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_CARRIER_BYOP, _protocol.terminal);
	
	if fCode = null then
		fCode := code;
	endif;
	
	strLine := strLine &amp; self.outputFileMessage (_camTaskHistory, self.makeNADSegment (_protocol, null, "CF", fCode, '160', '20'), _coll);
		
	_camMessage.segmentCount := _camMessage.segmentCount + 1;

	strLine := strLine &amp; self.outputFileMessage (_camTaskHistory, self.makeNADSegment (_protocol, null, "MS", _protocol.getSenderCode_NAD_MS, '160', '87'), _coll);
					
	_camMessage.segmentCount := _camMessage.segmentCount + 1;
	return strLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_UNA" id="776c0ff7-50ee-46f1-bde2-378171aa3c83">
        <updating/>
        <source>outputHeader_UNA(_protocol: CM_CamProtocol; _camTaskHistory: CM_CamTaskHistory input) : String updating, protected;
/*
Date		Who		Reason
20/12/2012	cnwcs5	CCMS SFW 1294 /par 30855
*/
vars
	
begin
	// UNA Segment (unconditional for MOT)
	return self.outputFileMessage (_camTaskHistory, self.makeUNASegment (_protocol), null);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_UNB" id="3c27b836-fd52-4244-b398-18d0fdb3f058">
        <updating/>
        <source>outputHeader_UNB(_protocol :CM_CamProtocol; _camTaskHistory: CM_CamTaskHistory input; _seqNumber : Integer; _coll :HugeStringArray input; _contextObj : CM_Object) : String updating, protected;
/*
Date		Who		Reason
20/12/2012	cnwcs5	CCMS SFW 1294 /par 30855
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
vars

	code, result	:String;
	strLine : String;
	ts : TimeStamp;	//30 Apr 2018	NDL	TFS 37406
	
begin

	//30 Apr 2018	NDL	TFS 37406
	ts := _camTaskHistory.runDateTime;
	if _protocol.singleContainerPerUNB and _contextObj &lt;&gt; null then
		_protocol.incrementTSForContext( _contextObj, ts );
	endif;
	
	code := self.getSenderCode_UNB (_protocol);
	
	result := self.makeUNBSegment (_protocol, "UNOA", 2, code, "ZZZ", _protocol.camGroup.recipient.trimBlanks, null, _seqNumber, null, false, ts);	// par 27460 cnwcs5 
		
	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, result, _coll);
	
	return strLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <Parameter name="_contextObj" type="CM_Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
