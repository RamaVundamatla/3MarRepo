        <source>getGridColumnFromLabel(_label : String) : CM_GridColumn;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	aColumn : CM_GridColumn;
begin
	foreach aColumn in  self.allGridColumns do
		if aColumn.label = _label then
			return aColumn;
