    <JadeMethod name="adjustWeights" id="85134f3a-79c9-4a3c-a785-44578480a44b">
        <source>adjustWeights( _fromControl : Control );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 April 2018	jlgndl1	Initial creation	TFS 37621

*/
	
vars

	totalWeight : Decimal[14,4];
	cargoWeight : Decimal[14,4];
	tareWeight : Decimal[14,4];
	
begin

	if self.myTrackedItem = null or not self.myTrackedItem.myCargoType.useTareCargoWeight then
		return;
	endif;

	totalWeight := self.txtWeight.getConvertedValue();
	cargoWeight := self.txtCargoWeight.getConvertedValue();
	tareWeight := self.txtTareWeight.getConvertedValue();
	
	self.adjustTotalCargoTareWeights(	self.myTrackedItem,	//_originalTi : CM_TrackedItem;
										_fromControl,	//_fromControl : Control;	// the one that just lost focus
										totalWeight,	//_totalWeightKgs : Decimal; // the current value in the table for total weight . May actually be populated with volume
										cargoWeight,	//_cargoWeightKgs : Decimal; // the current value in the table for cargo weight
										tareWeight,	//_tareWeightKgs : Decimal;// the current value in the table for tare weight
										self.txtWeight,	//_tblWeight : CMUI_MeasurementTable io;
										self.txtCargoWeight, //_tblCargoWeight : CMUI_MeasurementTable io;
										self.txtTareWeight,	//_tblTareWeight : CMUI_MeasurementTable io;
										false	//_isSplitForm : Boolean
										);
	

epilog

end;</source>
        <Parameter name="_fromControl" type="Control"/>
    </JadeMethod>
    <JadeMethod name="btnWeigh_click" id="8b4a177b-bf2b-4673-930e-4d90df4cbc4b">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnWeigh_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 March 2014	cnwndl1	Initial creation

*/

vars

begin

	self.myAssistant.showWeighForm( self, self.myTrackedItem, null, null );

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbWeightBy_click" id="4beda561-d571-4c2f-8f57-b26e7e15d3e4">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbWeightBy_click(combobox: ComboBox input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/07/2017	jlgdap1		Initial creation TFS 4492 SNO VERMAS Changes
//
vars
	weighAuth, wa : CM_WeighAuthority;
	iter : Iterator;
	idx : Integer;

begin
	self.cmbAuthor.clear();
	weighAuth := combobox.listObject.CM_WeighAuthority;
	if weighAuth = null then
		return;
	endif;
	
	iter := app.myRoot.allWeighAuthorities.createIterator;
	app.myRoot.allWeighAuthorities.startKeyGeq(weighAuth.certifiedName, null, iter);
	while iter.next(wa) do
		if wa.certifiedName &lt;&gt; weighAuth.certifiedName then
			break;
		endif;
		idx := self.cmbAuthor.addItem(wa.authorisedName);
		self.cmbAuthor.itemObject[idx] := wa;
	endwhile;
	if self.cmbAuthor.listCount = 1 then
		self.cmbAuthor.listIndex := 1;
	endif;
epilog
	delete iter;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doOK" id="b53fa4a6-6c1c-465a-ab12-036dfc09456e">
        <updating/>
        <source>doOK() updating;
//27 November 2009	cnwml2
// 25/09/2013	cnwdap1		PAR #32552 Use measurement table for weight value

vars
	result : Integer;
	weight : Decimal [14,4];						// PAR #32552
begin

	//if self.txtWeight.text = null then			// PAR #32552
	weight := self.txtWeight.getConvertedValue();	// PAR #32552
	if weight = null then							// PAR #32552
		app.msgBox('You must enter a Weight value, or cancel', 'Nothing entered', 0);
		self.txtWeight.setFocus();
		return;
	endif;
	
	if self.myTrackedItem.isWeightCertified then
		result := app.msgBox('Cargo already has a certified Weight, do you want to override this?', 'Already a Certified Weight', MsgBox_Yes_No);
		if result = MsgBox_Return_No then
			self.txtWeight.setFocus();
			return;
		endif;
	endif;
	
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getWeighFormObjects" id="1d9fdfc6-812d-4821-9133-0fcda1823214">
        <source>getWeighFormObjects( _obj: CM_Object; _objArray: ObjectArray input ): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars

begin

	if _obj &lt;&gt; null then
		_objArray.addExclusive(_obj);
	endif;

	return true;

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_objArray" type="ObjectArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="init" id="d3d4a745-25bb-4949-b862-64b8109182f4">
        <updating/>
        <source>init(_ti : CM_TrackedItem)updating;
//27 November 2009	cnwml2


vars

begin
	self.myTrackedItem := _ti;
	if _ti &lt;&gt; null then			// TFS 2357 set myTerminal to use in setupForm
		self.myTerminal := self.myTrackedItem.myTerminal;
	endif;
	
	if (	self.myTrackedItem &lt;&gt; null and
			self.myTrackedItem.myTerminal &lt;&gt; null and
			not self.myTrackedItem.myTerminal.allWeighBridges.isEmpty )
	then
		self.myTerminal := self.myTrackedItem.myTerminal;
		self.createMyAssistant(CMUI_Assistant);
		self.btnWeigh.visible := true;
	endif;
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setCaption" id="9c7dce59-b071-4c18-9738-8f4098789460">
        <updating/>
        <source>setCaption(_caption: String) updating;
//27 November 2009	cnwml2


vars

begin
	inheritMethod(_caption);

epilog

end;</source>
        <Parameter name="_caption" type="String"/>
    </JadeMethod>
    <JadeMethod name="setCombos" id="6dd9ca58-3caa-47bb-b2c4-367dcb0dacd2">
        <updating/>
        <source>setCombos() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/07/2017	jlgdap1		Initial creation TFS 4492 SNO VERMAS Changes
//
vars
	weighAuth : CM_WeighAuthority;
	authTerm : CM_WeighAuthTerminal;
	iter : Iterator;

begin
	self.cmbWeightBy.clear();
	self.cmbAuthor.clear();
	
	foreach weighAuth in app.myRoot.allWeighAuthorities discreteLock do
		if weighAuth.notAvailableForUse then
			continue;
		endif;
		self.cmbWeightBy.addItemObject(weighAuth.certifiedName, weighAuth);
	endforeach;
	authTerm := self.myTerminal.getDefaultWeighAuthority();
	if authTerm &lt;&gt; null then
		self.cmbWeightBy.listIndex := self.cmbWeightBy.findObject(authTerm.myWeighAuthority);
		iter := app.myRoot.allWeighAuthorities.createIterator;
		app.myRoot.allWeighAuthorities.startKeyGeq(authTerm.myWeighAuthority.certifiedName, null, iter);
		while iter.next(weighAuth) do
			if weighAuth.certifiedName &lt;&gt; authTerm.myWeighAuthority.certifiedName then
				break;
			endif;
			self.cmbAuthor.addItemObject(weighAuth.authorisedName, weighAuth);
		endwhile;
		if self.cmbAuthor.listCount = 1 then
			self.cmbAuthor.listIndex := 1;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="9dcdf3a3-0a79-44bf-9a73-11f8cebf8591">
        <updating/>
        <source>setupForm() updating;
//27 November 2009	cnwml2
// 11/03/2010	cnwdap1	PAR #23064 If cargo type "can weight be certified" flag is not set, don't show the "Certified" checkbox
// 25/09/2013	cnwdap1	PAR #32552 Use measurement table for entering weight
// 11/07/2017	cnwdap1	TFS 4492 SNO VERMAS Changes
// 22/May/2018	jlgrh7 TFS 38744	PEN - VGM Task wiping out the Tare WT and Cargo Weigh "PRIORITY A"
vars
	authorised,
	certified	: String;
	authTerm : CM_WeighAuthTerminal;		// TFS 4492
	measureType : CM_MeasurementType;
	typeWeight : String;
begin
	inheritMethod();
	
	self.setCaption("Complete Weigh Task for " &amp; self.myTrackedItem.id);
	self.setCombos();						// TFS 4492
	
	if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.myCargoType &lt;&gt; null then
		if not self.myTrackedItem.myCargoType.canWeightBeCertified then
			self.chkCertified.visible := false;
		endif;
		//03 Jun 2016	NDL	TFS 2099
		if self.myTrackedItem.isContainer then	
			self.lblWeightBy.visible := true;
			self.cmbWeightBy.visible := true;
			self.lblAuthor.visible := true;
			self.cmbAuthor.visible := true;
			// TFS 2357 default authorised and certified by from the terminal config values
			//authorised := self.myTerminal.getConfig(DefaultAuthPersonWeight).String;		// TFS 4492
			//certified := self.myTerminal.getConfig(DefaultWeightCertifiedBy).String;		// TFS 4492
			//self.cmbAuthor.text := authorised;											// TFS 4492
			//self.cmbWeightBy.text := certified;											// TFS 4492
			authTerm := self.myTerminal.getDefaultWeighAuthority();							// TFS 4492
			if authTerm &lt;&gt; null then														// TFS 4492
				self.cmbWeightBy.findObject(authTerm.myWeighAuthority);						// TFS 4492
				self.cmbAuthor.findObject(authTerm.myWeighAuthority);						// TFS 4492
			endif;																			// TFS 4492
		else
			self.lblWeightBy.visible := false;
			self.cmbWeightBy.visible := false;
			self.lblAuthor.visible := false;
			self.cmbAuthor.visible := false;
		endif;
	endif;
	
	self.txtWeight.setup(Type_Weight, self.backColor);						// PAR #32552
	self.txtWeight.tabKey := J_key_Tab;										// PAR #32552
	self.txtWeight.rowHeight[1] := (self.txtWeight.height - 1).Integer;		// PAR #32552
	
	
	
	//03 Apr 2018	NDL	TFS 37621
	if self.myTrackedItem &lt;&gt; null
	and self.myTrackedItem.myCargoType &lt;&gt; null
	and self.myTrackedItem.myCargoType.useTareCargoWeight
	then
		self.txtCargoWeight.visible := true;
		self.txtTareWeight.visible := true;
		self.lblCargoWeight.visible := true;
		self.lblTareWeight.visible := true;
		
		self.txtCargoWeight.setup(Type_Weight, self.backColor);						
		self.txtCargoWeight.tabKey := J_key_Tab;										
		self.txtCargoWeight.rowHeight[1] := (self.txtCargoWeight.height - 1).Integer;
		
		self.txtTareWeight.setup(Type_Weight, self.backColor);						
		self.txtTareWeight.tabKey := J_key_Tab;										
		self.txtTareWeight.rowHeight[1] := (self.txtTareWeight.height - 1).Integer;	
		
			
		//if self.myTrackedItem.usesAutoWeightCalculate() then	//23 Apr 2018	NDL	TFS 37621																							//-TFS38774 we need to pre-fill
		measureType := self.myTrackedItem.getDefaultMeasurementForType(Type_Weight);
		typeWeight := measureType.shortName;
		self.txtWeight.setValues(app.convertMeasurementForDisplay(typeWeight, self.myTrackedItem.totalWeight) &amp; Space &amp; typeWeight);
		self.txtCargoWeight.setValues(app.convertMeasurementForDisplay(typeWeight, self.myTrackedItem.weightCargo) &amp; Space &amp; typeWeight);
		self.txtTareWeight.setValues(app.convertMeasurementForDisplay(typeWeight, self.myTrackedItem.weightTare) &amp; Space &amp; typeWeight);
		//endif;
		
	else
		self.txtCargoWeight.visible := false;
		self.txtTareWeight.visible := false;
		self.lblCargoWeight.visible := false;
		self.lblTareWeight.visible := false;
		
	endif;
	
	
	self.btnWeigh.top := self.txtWeight.top;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="1d5ffb40-7603-4284-8ed4-0d2058981d23">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 04 April 2018 07:59:19.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017487, locale);
	btnWeigh.translateBubbleHelp(Xlat_0019550, locale);
	btnWeigh.translateCaption(Xlat_0019551, locale);
	chkCertified.translateCaption(Xlat_0013541, locale);
	lblAuthor.translateCaption(Xlat_0021255, locale);
	lblCargoWeight.translateCaption(Xlat_0022317, locale);
	lblTareWeight.translateCaption(Xlat_0022318, locale);
	lblWeight.translateCaption(Xlat_0013542, locale);
	lblWeightBy.translateCaption(Xlat_0021256, locale);
end;</source>
    </JadeMethod>
