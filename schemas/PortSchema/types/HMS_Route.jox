    <JadeMethod name="setProxy" id="0b47ed07-7526-47ac-9fc3-0c0593b25a2b">
        <updating/>
        <source>setProxy(_code:String; _description:String; _allMovementPathsObj:HMS_MovementPathArray; _rootObj:CM_Root) updating;
// --------------------------------------------------------------------------------
// Created:		13 October 2006 by cnwdad1
//
// Purpose:		Standard method for setting the receiver's property and reference
//				values.  The receiver must be a transient proxy object.
//
// Parameters:	_code - The receiver's code.
//				_description - A description of the receiver.
//				_allMovementPathsObj - A collection of the receiver's Movement Paths.
//				_rootObj - A reference to the system Root object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.raiseExceptionIfNotTransient(method);
	
	self.description	:=	_description;
	self.code			:=	_code;
	
	self.allMovementPaths.clear();
	_allMovementPathsObj.copy(self.allMovementPaths);
	
	self.myRoot			:=	_rootObj;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_allMovementPathsObj" type="HMS_MovementPathArray"/>
        <Parameter name="_rootObj" type="CM_Root"/>
    </JadeMethod>
