begin

	create f;
	f.printPreviewForm := self;
	f.showModal;

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnFirst_click" id="367b2819-09e3-40d1-a30b-0beacb6029fb">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnFirst_click(btn: Button input) updating;
/*
------------------------------------------------------------------------
Created:			04 September 2003 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

begin
	aCurrentPage  := 1;
	getAPage(aCurrentPage);
	aV_findNextPagePos := 0; // reset find position
	aV_findPageImage	  := null;
	self.btnNext.enabled := true;
	self.btnPrev.enabled := false;
	self.btnFirst.enabled := false;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnLast_click" id="95f4f284-f2a9-47ec-92ea-fd45d3ee9bce">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnLast_click(btn: Button input) updating;
/*
------------------------------------------------------------------------
Created:			04 September 2003 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

begin
	aCurrentPage := aMyJadeReport.pageCount;
	aV_findNextPagePos := 0; // reset find position
	aV_findPageImage	  := null;
	self.getAPage(aCurrentPage);
	self.btnNext.enabled := false;	
	self.btnPrev.enabled := true;
	self.btnLast.enabled  := false;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnNext_click" id="0741657a-f855-452f-b005-e77dfd0835e4">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnNext_click(btn: Button input) updating;
/*
-------------------------------------------------------------------------------
Created:		03 September 2003 by cnwdwq1

Purpose:		Advances through the pages. The control will be disabled if we
				are at the end of the list.
							
Parameters:		None

Returns:		Nothing

Changed On		Changed By		Reason
--------------	--------------	-----------------------------------------------
-------------------------------------------------------------------------------
*/
begin
	self.aCurrentPage 		:=	self.aCurrentPage + 1;
	self.aV_findNextPagePos	:=	0; // reset find position
	self.aV_findPageImage	:=	null;
	
	if self.getAPage(self.aCurrentPage) = false then
		btnNext.enabled		:=	false;
		self.aCurrentPage	:=	self.aCurrentPage - 1;
	endif;
	
	if self.aCurrentPage = self.aMyJadeReport.pageCount() then
		btnNext.enabled	:=	false;
		btnLast.enabled	:=	false;
	endif;		

	if self.aCurrentPage &gt; 1 then 
		btnPrev.enabled	:=	true;
	endif;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnPrev_click" id="18a1ddcf-ca5b-46bb-a155-f699cff2c038">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnPrev_click(btn: Button input) updating;
/*
------------------------------------------------------------------------
Created:			03 September 2003 by cnwdwq1
Purpose:			Goes backwards through the pages, the control is disabled if at start.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	aCurrentPage := aCurrentPage - 1;
	aV_findNextPagePos := 0; // reset find position
	aV_findPageImage	  := null;

	self.getAPage(aCurrentPage);

	if aCurrentPage &lt;&gt; 1 then
		return;
	endif;
	btnPrev.enabled := false;
	btnFirst.enabled := false;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnPrintSelect_click" id="97e35c9e-53d3-463b-8e0d-6dfa6c74f028">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnPrintSelect_click(btn: Button input) updating;
/*
------------------------------------------------------------------------
Created:			05 September 2003 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars
	ps 		: CMUI_PrintSelected;
	docType : Integer;
begin
	docType := app.printer.documentType;
	create ps transient;
	ps.myJadeReport := self.aMyJadeReport;
	ps.currentPage := self.aCurrentPage;
	ps.myPrintPreviewForm := self;
	ps.showModal;
epilog
	delete ps;
	app.printer.documentType := docType;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnPrint_click" id="a5cb238f-dd5f-4786-a8e1-becf262490d9">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnPrint_click(btn: Button input) updating;
/*
------------------------------------------------------------------------
Created:			04 September 2003 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
29/05/2019   	cnwma1		Bug 44935: PKT - Creating JMT Reports Printing Issue

*/

vars
	docType : Integer;
	duplex  : Integer;
begin
	docType := app.printer.documentType;
	duplex  := app.printer.duplex;         //29.05.2019 cnwma1 #44935
	app.mousePointer := Busy;

	//added this for testing/investigating funny Page behaviour using JadeReport
	// JADE PAR 34782
	app.printerFixPAR34782(self.aMyJadeReport);
	// to here
	
	app.printer.printReport(self.aMyJadeReport);
	self.unloadForm();
epilog
	app.mousePointer := Idle;
	app.printer.documentType := docType;
	app.printer.duplex := duplex;          //29.05.2019 cnwma1 #44935
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnReduce_click" id="cc9ed32c-6c0e-4799-b687-c71a00734fa1">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnReduce_click(btn: Button input) updating;
/*
------------------------------------------------------------------------
Created:			03 September 2003 by cnwdwq1
Purpose:			Reduce the output, by resizing the picPreview control
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars

begin

	self.aZoomScale := 1;
	self.getAPage(aCurrentPage);
	self.btnReduce.enabled := false;
	self.btnEnlarge.enabled := true;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnSpecific_click" id="ab2516ed-612e-4c3e-93de-fc5be70efc87">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSpecific_click(btn: Button input) updating;
/*
------------------------------------------------------------------------
Created:			04 September 2003 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars
	inputBox : CMUI_InputBox;
	pageNum : String;
	txtStr : String;
	pgCnt : Integer;
	pgSel : Integer;
begin
	//Ask the users which page they want to go to.
	create inputBox transient;
	pgCnt := aMyJadeReport.pageCount;
	while true do
//		inputBox.init(app.getErrorString(LBLGoToPage), app.getErrorString1(LBLEnterPageNumber, pgCnt.String) &amp; txtStr, aCurrentPage.String, 0, TextBox.DataType_Numeric, false);	// cnwrl1 05/06/2009 PAR 19574 - what it was
		inputBox.init(	app.getErrorString(LBLGoToPage), app.getErrorString1(LBLEnterPageNumber, pgCnt.String) &amp; txtStr,
						aCurrentPage.String, 0, TextBox.DataType_Numeric, TextBox.Case_None, false, false);
		inputBox.showModal;
		if inputBox.modalResult &lt;&gt; IDOK then
			return;
		endif;
		pageNum := inputBox.txtInput.text;
		if pageNum.isInteger = false then
			txtStr := app.getErrorString2(LBLMustEnterNumberBetween, "1", pgCnt.String);
			//Because we are going to re-show, we have to delete and re-create the object
			delete inputBox;
			create inputBox transient;
		else
			pgSel := pageNum.Integer;
			//Grab it, check to see if its valid
			if pgSel &gt;= 1 and pgSel &lt;= pgCnt then
				//Is good!
				break;
			else
				txtStr := app.getErrorString2(LBLMustEnterNumberBetween, "1", pgCnt.String);
				//Because we are going to re-show, we have to delete and re-create the object
				delete inputBox;
				create inputBox transient;
			endif;
		endif;	
	endwhile;	
	if pgSel = 1 and btnFirst.enabled then
		btnFirst_click(self.btnCancelBase);
	else
		if pgSel = pgCnt and btnLast.enabled then
			btnLast_click(self.btnCancelBase);
		elseif pgSel = aCurrentPage -1 and btnPrev.enabled then
			btnPrev_click(self.btnCancelBase);
		elseif pgSel = aCurrentPage +1 and btnNext.enabled then
			btnNext_click(self.btnCancelBase);
		else
			//goto the page
			getAPage(pgSel);
		endif;
	endif;

epilog
	delete inputBox;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
