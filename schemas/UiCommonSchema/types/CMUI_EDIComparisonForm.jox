    <JadeMethod name="tblData_queryRowColChg" id="c19024ad-7031-4ca6-8159-d00064f2f0dd">
        <controlMethod name="Table::queryRowColChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_queryRowColChg(table: CM_DataTable input; newSheet: Integer; newRow: Integer; newCol: Integer):Boolean updating;
/*

Date		Who		Reason
08 September 2016	cnwer1	Initial creation TFS

*/

vars

begin
	if self.isEditMode then
		if table.allSelectedObjects.first &lt;&gt; table.accessRow(newRow).itemObject then
			return false;
		endif;
	endif;
	
	return true;
epilog

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
        <Parameter name="newSheet" type="Integer"/>
        <Parameter name="newRow" type="Integer"/>
        <Parameter name="newCol" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="c8137c05-4501-4f92-a993-c17a8e6a23c6">
        <updating/>
        <source>timerEvent(_eventTag: Integer) updating;
/*
Date		Who		Reason
21 Aug 2013	cnwcs5	CCMS POL 2221 / par 32094(2)
17 Aug 2017 cnwma1	TFs #4596 POL - Cannot ignore fields during EDI Release Request Update
// 05 Dec 2017	jlgrs1	TFS 8146 - POL - EDI Release Comparison not supporting adds
*/
vars
	topRow : Integer;
begin
	if _eventTag = self.EVENT_REFRESH then
		if not self.isEditMode then
			topRow := self.tblData.topRow ;  //17.08.2017 cnwma1 TFS #4956
			self.doRefresh;
			if topRow &lt;= self.tblData.rows then
				self.tblData.topRow := topRow;    //17.08.2017 cnwma1 TFS #4956
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_eventTag" type="Integer"/>
    </JadeMethod>
