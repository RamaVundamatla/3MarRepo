    <JadeMethod name="doEdit" id="a53f11e5-67d4-40af-941f-7360939af735">
        <source>doEdit( _locAct : CMEVT_LocationActivity );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2021	navndl1	Initial creation	TFS 50906

*/

vars

	form : CMUI_LocationActivityMaint;
	edition : Integer;
	invalid : Boolean;

begin

	on Exception do app.handleDeletedObject( exception, _locAct, invalid );
	
	if _locAct = null then
		return;
	endif;
	
	edition := _locAct.edition;
	if invalid or not _locAct.isAbleToBeEdited then
		return;
	endif;
	
	create form transient;
	form.setMyTerminal( self.myTerminal );
	form.setMyLocationActivity( _locAct );
	form.showModal();
	
epilog

	delete form;

end;</source>
        <Parameter name="_locAct" type="CMEVT_LocationActivity"/>
    </JadeMethod>
    <JadeMethod name="doLocationActivitySearch" id="0e0ceaa8-d7e3-4fbd-b443-449471eb4259">
        <updating/>
        <source>doLocationActivitySearch() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	user : CM_User;
	nomalStartTime : Time;
	nomalEndTime : Time;
	startTimeStamp : TimeStamp;
	endTimeStamp : TimeStamp;
	qDef : CM_QueryDefinition;
	criteriaHolder : CM_QueryCriteriaLineHolder;
	myEnqController : CM_EnqControllerLocationAct;
	dateArray : DateArray;
	criteriaLine : CM_SelectorCriteriaLine;
	locActivity : CMEVT_LocationActivity;
	atLimit : Boolean;
	
begin

	user 	 := app.getMyUser();
	
	nomalStartTime.setTime( 0, 0, 0, 0 );
	if self.filterDateFrom.isValid then	
		startTimeStamp.setDate(self.filterDateFrom);
	else
		startTimeStamp.setDate(app.actualTimeAppServer.date.cnEcAddDays( ( self.myTerminal.getLocationActivityMaxDays() * -1 ) ) );
	endif;
	startTimeStamp.setTime(nomalStartTime);
	if self.filterDateTo.isValid then
		nomalEndTime.setTime( 23, 59, 59, 999 );
		endTimeStamp.setDate(self.filterDateTo);
		endTimeStamp.setTime(nomalEndTime);
	endif;
	
	//create the selector query object.
	create myEnqController;
	create myEnqController.allObjects as  CMEVT_LocationActivitySet transient;
	create criteriaHolder transient;
	myEnqController.myCriteriaLineHolder := criteriaHolder;
	
	//add the criteria
	qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.Transaction_Query_Type,CM_QueryDefinition.Location_Activity_Query_Mode];
	
	//terminal
	criteriaLine := qDef.createCriteriaLine(CMEVT_LocationActivity::myTerminal.name, CM_QueryOperator.Operator_Equal, self.myTerminal);
	criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
	
	//dates
	if self.filterDateFrom.isValid and self.filterDateTo.isValid then
		create dateArray transient;
		dateArray.add( startTimeStamp.date );
		dateArray.add( endTimeStamp.date );
		criteriaLine := qDef.createCriteriaLine(CMEVT_LocationActivity::dateTime.name, CM_QDateRange.Operator_Between, dateArray );
		criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
	elseif self.filterDateFrom.isValid then
		criteriaLine := qDef.createCriteriaLine(CMEVT_LocationActivity::dateTime.name, CM_QDateRange.Operator_GreaterThan, startTimeStamp.Date - 1 );
		criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
	elseif self.filterDateTo.isValid then
		create dateArray transient;
		dateArray.add( startTimeStamp.date );
		dateArray.add( endTimeStamp.date );
		criteriaLine := qDef.createCriteriaLine(CMEVT_LocationActivity::dateTime.name, CM_QDateRange.Operator_Between, dateArray );
		criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
	endif;

	//Location Activity Type
	if self.filterEventTypes &lt;&gt; null then // ### TFS 51515 13JUL2021 NAVAB1
		criteriaLine := qDef.createCriteriaLine(CMEVT_LocationActivity::myEventType.name, CM_QueryOperator.Operator_IsOneOf, self.filterEventTypes); // ### TFS 51515 13JUL2021 NAVAB1
		criteriaLine.setMyCriteriaLineHolder(criteriaHolder); // ### TFS 51515 13JUL2021 NAVAB1
	endif;
	
	//CargoType
	if self.filterCargoType &lt;&gt; null then
		criteriaLine := qDef.createCriteriaLine(CMEVT_LocationActivity::cargoType.name, CM_QueryOperator.Operator_Equal, self.filterCargoType);
		criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
	endif;
	
	//Operator
	if self.filterOperator &lt;&gt; null then
		criteriaLine := qDef.createCriteriaLine(CMEVT_LocationActivity::operatorCode.name, CM_QueryOperator.Operator_Equal, self.filterOperator);
		criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
	endif;
	
	//Terminal Area
	if self.filterTerminalArea &lt;&gt; null then
		criteriaLine := qDef.createCriteriaLine(CMEVT_LocationActivity::getTerminalAreaIds.name, CM_QStringLookup.Operator_Equal, self.filterTerminalArea.id);
		criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
	endif;
	
	if self.filterLocation &lt;&gt; null then
		criteriaLine := qDef.createCriteriaLine(CMEVT_LocationActivity::getYardLocationIds.name, CM_QStringLookup.Operator_Equal, self.filterLocation.getFullId);
		criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
	endif;
	
	//Voyage
	if self.filterVoyage &lt;&gt; null then
		criteriaLine := qDef.createCriteriaLine(CMEVT_LocationActivity::getVoyageCodes.name, CM_QStringLookup.Operator_Equal, self.filterVoyage.code);
		criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
	endif;
	
	//Vehicle Visit record
	if self.filterVehicleVisitRecord &lt;&gt; null then
		criteriaLine := qDef.createCriteriaLine(CMEVT_LocationActivity::getVvrVisitNumbers.name, CM_QStringLookup.Operator_Equal, self.filterVehicleVisitRecord.visitNumber);
		criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
	endif;
	
	//Train
	if self.filterTrain &lt;&gt; null then
		criteriaLine := qDef.createCriteriaLine(CMEVT_LocationActivity::getTrainCodes.name, CM_QStringLookup.Operator_Equal, self.filterTrain.getCodeDate);
		criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
	endif;
		
	// run the query
	myEnqController.doQuery( qDef );
	
	
	//Add the data to the local collection
	foreach locActivity in myEnqController.allObjects.CMEVT_LocationActivitySet discreteLock do
		atLimit := self.addObjectToCollection(locActivity, user);
		if atLimit then
			break;
		endif;
	endforeach;
	
epilog

	if myEnqController &lt;&gt; null then
		if myEnqController.myCriteriaLineHolder &lt;&gt; null then
			delete myEnqController.myCriteriaLineHolder;
		endif;
	endif;
	
	delete myEnqController;
	delete dateArray;
	
end;</source>
    </JadeMethod>
