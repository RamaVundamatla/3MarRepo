vars

	theForm : SOP_TableMaintForm;

begin
	//cnwmc5 - 17 Oct 2013 - PAR 32622
	inheritMethod();
	
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := false;
	theForm.tblInput1.cnEcResizeContents();
end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="01c4ae2a-95c6-49d4-b1d6-a62aab9f0b13">
        <source>setupThumbnailDetails();
// ---------------------------------------------------------------------------
// Created:     25 March 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theForm : SOP_TableMaintForm;

begin
  
  	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_LogRejectCodeTbl);
	//theForm.zAddColumn('Log Reject Code', 'code', Table.InputType_None, 40);
	//theForm.zAddColumn('Description', 'description', Table.InputType_None, 60);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_LogRejectCodeMaint);
	theForm.shtTblInput1.visible := true;
	
	theForm.tblData.userInputEnabled := false;

	theForm.mulSelect1.formDisplayEntryMethodName := null;
	theForm.mulSelect2.formDisplayEntryMethodName := null;
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="e4ee6ac4-5c48-41bd-8a04-56d6897e7aa8">
        <updating/>
        <source>showThumbnail(pObj: CM_LogRejectCode) updating;
// ---------------------------------------------------------------------------
// Created:     25 March 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	theForm : SOP_TableMaintForm;

begin
  
    theForm := self.myForm;
	theForm.tblInput1.clearValues;
	theForm.tblInput1.setValueByName(ETRow_Code, pObj.code);
	theForm.tblInput1.setValueByName(ETRow_Description,	pObj.description);
	theForm.tblInput1.setValueByName(ETRow_NotAvailableForEntry, pObj.notAvailableForEntry);

end;</source>
        <Parameter name="pObj" type="CM_LogRejectCode"/>
    </JadeMethod>
</Class>
