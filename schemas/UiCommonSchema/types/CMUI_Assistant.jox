        <source>showRackSideViewForm( _objs : ObjectArray; _viewMode : Integer; _masterMenuAction : CMUI_MenuAction );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 August 2013	cnwndl1	Initial creation	Par 32308

*/

vars

	enqForm : Form;
