    <JadeMethod name="setForCreate" id="49b10e1c-9530-4f98-b9c8-a9fa6539e921">
        <updating/>
        <source>setForCreate(_proxy :CM_ForkLiftStack input; _passport : CM_Passport input) updating;
//setForCreate(_proxy : CM_ForkLiftStack; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// 11/02/2022	NAVCS2		ChangeRequest 52838: MTN - New Gridded Area Stack Height Defaults	
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	
	inheritMethod(_proxy, _passport);
	if self.maxHeightFull = 0 then 					//	11/02/2022 NAVCS2	52838
		self.maxHeightFull := heightOfStack * 9.5;
	endif;
	if self.maxHeightMT = 0 then 					//	11/02/2022 NAVCS2	52838
		self.maxHeightMT := heightOfStack * 9.5;
	endif;
	if self.maxHeightPower = 0 then 				//	11/02/2022 NAVCS2	52838
		self.maxHeightPower := heightOfStack * 9.5;
	endif;
	self.setDefalutLocationSize();
	
end;</source>
