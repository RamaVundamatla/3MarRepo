    <JadeMethod name="addTIToDetail" id="fa35fca4-fc32-471a-9315-b803c5d1ca3b">
        <updating/>
        <source>addTIToDetail(_ti : CM_TrackedItem; _deadlock : Boolean output) updating;

/*

Purpose:			
// ### TFS BUG 59912 22AUG2023 NAVAB1, originally there was only one column for this, did not use the measurement types i.e. , 1 column for each measurement type, 
		so it used the measurement type on the product,whatever it was. Then we added measurement types to the column organiser so then value 
		on the CG detail must be in CM, if product measurement type was CM this was ok but if it was not CM like MM the CG detail got a converted 
		value then the column organiser converted it again.
Parameters:			

Return Value:		


Date			Who		Reason
16 May 2022		navam1	Initial creationTFS 53389
1 July 2022		navmv20 ChangeRequest 53888: EUP - Voyage Operations - More Fields for Cargo Groups
25 July 2022	navgm20 ChangeRequest 54184: EUP - New fields in Voyage Operations screen
19 June 2023	navpw1	TFS: 57812 - New cargo item fields: secondary barcode id, itemised, sorting method
07 Sep 2023		navkc1	CR 60376 Task 60377: Jade - Cargo Group Regions
09 Apr 2024		navdap1	TFS 63307 EUP | Performance - Cargo Enquiry Bulk Updates
10 June 2024    navrv30 Task 64477 CR 64475: Jade - New Cargo Group Details II
17 Dec 2024 	navma1  MTN-19298 TN - Performance issue when discharging the cargo items on the Complete job form for Ship jobs
*/

constants
	Ellipsis = "...";
	
vars
	tiColour, tiDischarge, tiHaz, tiImex, tiLoad, tiLoc, 
	tiLocP, tiLocQ, tiMarkNbr, tiMarks, tiOp, tiRemarks, 
	tiBOL, tiBookingRef, tiCarrierDescription, tiCommodity, 
	tiCommodityGroup, tiConsignee, tiConsignor,tiDamagedDetails, 
	tiDestinationPort, tiDiameter, tigrammage, tiHeight,
    tiSpecialStow, tiLength, tiLocationArea,
	tiLocationSubArea, tiOperatorGroup, tiReceiptTransportMode, tiReceiveCarrier,
	tiReleaseCarrier, tiReleaseTransportMode, tiSpecialLift, tiLocationForGroup,
	tiTerminalArea, tiWidth, tiDescription,tiVesselName, tiRollingLength, tiCargoSubType,
	tiClientReference, tiCustomsEntryNumber, tiCustomsReference, 
	tiPurchaseOrder, tiServiceOrder :String;
	tiDamaged, tiHasStops, tiDirectDelivery, tiIsSpecialStow, tiHasTasks, 
	tiHasOverlanded, tiHasShortlanded: Boolean;
	failed 		  : Boolean;				// TFS 63307
	operatorGroup : CM_OperatorGroup;
	lc     		  : CM_LocationsController;
	sortingMethod : CM_SortingMethod;
	tiGram		  : Decimal[23,2];
begin
	on DeadlockException do self.handleDeadlockException(exception, failed);	// TFS 63307
	
	self.allAssignedTrackedItems.add(_ti);
	// TFS 63307 If we got a deadlock error while bulk editing was going on, that means the bulk edit is
	// trying to update TIs in this cargo group. Just leave this cargo group for now, it will be updated
	// later anyway after the bulk edits have finished
	if failed then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Failed to add " &amp; _ti.id &amp; " to cargo groups - global.bulkEditProcess is " &amp; global.bulkEditProcess &amp; ", process.getOidString is " &amp; process.getOidString, LogDEBUG);
		if global.bulkEditProcess &lt;&gt; process.getOidString then
			app.writeLog(method.qualifiedName &amp; Tab &amp; "Failed to add " &amp; _ti.id &amp; " to cargo groups - deadlock but continuing", LogDEBUG);
			_deadlock := failed;
			return;
		endif;
	endif;
	// TFS 63307 end
	
	self.totalQuantity 			 := self.totalQuantity + _ti.totalQuantity;
	self.totalWeight   			 := self.totalWeight   + _ti.totalWeight;
	self.totalVolume   			 := self.totalVolume   + _ti.totalVolume;
	self.weightTare    			 := self.weightTare    + _ti.weightTare;
	
	tiColour    				 := _ti.getColour;
	self.colour 				 := self.createDetailsString(tiColour, self.colour, Ellipsis);
	
	tiDischarge 				 := _ti.dischargePort;
	self.dischargePort 			 := self.createDetailsString(tiDischarge, self.dischargePort, Ellipsis);
	
	tiHaz 			  			 := _ti.getHazardsAsString;
	self.hazardDetails			 := self.createDetailsString(tiHaz, self.hazardDetails, Ellipsis);
	
	tiImex 			   			:= _ti.getImExStatusString;
	self.imexStatus    			:= self.createDetailsString(tiImex, self.imexStatus, Ellipsis);
	
	tiLoad 			 			:= _ti.loadPort;
	self.loadPort 	   			:= self.createDetailsString(tiLoad, self.loadPort, Ellipsis);
	
	tiLoc 			   			:= _ti.locationId;
	self.location 	   			:= self.createDetailsString(tiLoc, self.location, Ellipsis);
	
	tiLocP 						:= _ti.plannedLocnId;
	self.locationPlanned 		:= self.createDetailsString(tiLocP, self.locationPlanned, Ellipsis);
	
	tiLocQ 						:= _ti.queuedLocnId;
	self.locationQueued			:= self.createDetailsString(tiLocQ, self.locationQueued, Ellipsis);
	
	tiMarkNbr 					:= _ti.markNumber;
	self.markNumber 			:= self.createDetailsString(tiMarkNbr, self.markNumber, Ellipsis);
	
	tiMarks 					:= _ti.mark;
	self.marks 					:= self.createDetailsString(tiMarks, self.marks, Ellipsis);
	
	tiOp 						:= _ti.operatorCode;
	self.operator 				:= self.createDetailsString(tiOp, self.operator, Ellipsis);
	
	tiRemarks 					:= _ti.remarks;
	self.remarks 				:= self.createDetailsString(tiRemarks, self.remarks, Ellipsis);
	
	tiBOL 						:=_ti.billOfLading;
	self.billOfLading 			:= self.createDetailsString(tiBOL,self.billOfLading,Ellipsis); 
	
	tiBookingRef				:= _ti.bookingReference;
	self.bookingRef				:= self.createDetailsString(tiBookingRef,self.bookingRef,Ellipsis);
	
	tiCargoSubType				:= _ti.getCargoSubTypeCode;
	self.cargoSubtype			:= self.createDetailsString(tiCargoSubType,self.cargoSubtype,Ellipsis);
	
	tiCarrierDescription 		:= _ti.getCarrierDescription;
	self.carrierDescription 	:= self.createDetailsString(tiCarrierDescription,self.carrierDescription,Ellipsis);
	
	tiCommodity					:= _ti.commodity;
	self.commodity				:= self.createDetailsString(tiCommodity,self.commodity,Ellipsis);
	
	tiCommodityGroup			:=_ti.commodityGroup;
	self.commodityGroup			:= self.createDetailsString(tiCommodityGroup,self.commodityGroup,Ellipsis);
	
	tiConsignee					:= _ti.consignee;
	self.consignee				:= self.createDetailsString(tiConsignee,self.consignee,Ellipsis);
	
	tiConsignor					:= _ti.consignor;
	self.consignor				:= self.createDetailsString(tiConsignor,self.consignor, Ellipsis);
	
	tiDamaged 					:= _ti.damaged;
	self.damaged 				:= self.createDetailsBoolean(tiDamaged,self.damaged);
	
	tiDamagedDetails			:= _ti.getDamageDetailsDescr;
	self.damagedDetails			:= self.createDetailsString(tiDamagedDetails,self.damagedDetails,Ellipsis);
	
	tiDescription				:= _ti.description;
	self.description			:= self.createDetailsString(tiDescription, self.description, Ellipsis);
	
	tiDestinationPort			:= _ti.destinationPort;
	self.destinationPort		:= self.createDetailsString(tiDestinationPort, self.destinationPort, Ellipsis);
	
	tiGram := _ti.getGrammage();						//17.12.2024 navma1 #MTN-19298
	if tiGram &lt;&gt; null then
		tigrammage		:= tiGram.asStringJMT();		// ### TFS 54021 30June2022 NAVPW1
		self.grammage	:= self.createDetailsString(tigrammage,self.grammage, Ellipsis);
	endif;
	
	
	// ### TFS BUG 59912 22AUG2023 NAVAB1
	tiHeight :=  _ti.getCargoGroupDetailHeight().String;
	if tiHeight = null then
		if _ti.isKindOf(CM_BreakBulkGeneric) then
			tiHeight :=_ti.CM_BreakBulkGeneric.getHeightStr();
		endif; 
	endif;
	if tiHeight &lt;&gt; null then
		self.height := self.createDetailsString(tiHeight, self.height, Ellipsis);
	endif;
	
	// ### TFS BUG 59912 22AUG2023 NAVAB1
	tiLength :=  _ti.getCargoGroupDetailLength().String;
	if tiLength = null then
		if _ti.isKindOf(CM_BreakBulkGeneric) then
			tiLength :=_ti.CM_BreakBulkGeneric.getLengthStr();
		endif; 
	endif;
	if tiLength &lt;&gt; null then
		self.length := self.createDetailsString(tiLength, self.length, Ellipsis);
	endif;
	
	// ### TFS BUG 59912 22AUG2023 NAVAB1
	tiWidth :=  _ti.getCargoGroupDetailWidth().String;
	if tiWidth = null then
		if _ti.isKindOf(CM_BreakBulkGeneric) then
			tiWidth	:= _ti.CM_BreakBulkGeneric.getWidthStr();
		endif; 
	endif;
	if tiWidth &lt;&gt; null then
		self.width				:= self.createDetailsString(tiWidth, self.width, Ellipsis);
	endif;
	// ### TFS BUG 59912 22AUG2023 NAVAB1

	tiRollingLength :=  _ti.getRollingLength().String;
	if tiRollingLength &lt;&gt; null then
		self.rollingLength		:= self.createDetailsString(tiRollingLength, self.rollingLength, Ellipsis);
	endif;
	// ### TFS BUG 59912 22AUG2023 NAVAB1
	tiDiameter :=  _ti.getDiameter().String;
	if tiDiameter &lt;&gt; null then
		self.diameter			:= self.createDetailsString(tiDiameter, self.diameter, Ellipsis);
	endif;	
	
	if _ti.myOperator &lt;&gt; null then
		operatorGroup := _ti.myOperator.allOperatorGroups.first;
		if operatorGroup &lt;&gt; null then
			tiOperatorGroup 	:= _ti.myOperator.allOperatorGroups.first.code;
			self.operatorGroup	:= self.createDetailsString(tiOperatorGroup, self.operatorGroup, Ellipsis);  
		endif;
	endif;
	
	tiReceiptTransportMode		:= _ti.getReceiptTransportModeStr;
	self.receiptTransportMode	:= self.createDetailsString(tiReceiptTransportMode,self.receiptTransportMode, Ellipsis);
	
	tiReceiveCarrier 			:= _ti.carrier;
	self.receiveCarrier			:= self.createDetailsString(tiReceiveCarrier,self.receiveCarrier, Ellipsis);
	
	tiReleaseCarrier			:= _ti.getReleaseCarrier;
	self.releaseCarrier			:= self.createDetailsString(tiReleaseCarrier, self.releaseCarrier, Ellipsis);
	
	tiReleaseTransportMode		:= app.transModeToString(_ti.releasedTransportMode);
	self.releaseTransportMode	:= self.createDetailsString(tiReleaseTransportMode,self.releaseTransportMode, Ellipsis);
	
	tiSpecialLift				:= _ti.getSpecialLiftsCodes;
	self.specialLift			:= self.createDetailsString(tiSpecialLift,self.specialLift,Ellipsis);
	
	tiSpecialStow				:= _ti.specialStow;
	self.specialStow			:= self.createDetailsString(tiSpecialStow,self.specialStow,Ellipsis);
	
	tiTerminalArea				:= _ti.terminalAreaId;
	self.terminalArea			:= self.createDetailsString(tiTerminalArea,self.terminalArea, Ellipsis);
	
	
	tiVesselName				:= _ti.vesselName;
	self.vesselName 			:= self.createDetailsString(tiVesselName,self.vesselName,Ellipsis);
	
	lc := _ti.myPrimaryActualLocation;
	if lc &lt;&gt; null then
		tiLocationArea			:= lc.getLocationArea();
		self.locationArea		:= self.createDetailsString(tiLocationArea,self.locationArea,Ellipsis);
		tiLocationSubArea		:= lc.getLocationSubArea();
		self.locationSubArea	:= self.createDetailsString(tiLocationSubArea,self.locationSubArea,Ellipsis);
	endif;
	
	//10 June 2024 navrv30 Task 64477 CR 64475
	tiHasTasks		 			:= _ti.hasToDoTasks;
	self.hasTasks 	 			:= self.createDetailsBoolean(tiHasTasks,self.hasTasks);
	
	tiHasOverlanded 			:= _ti.isOverlanded;
	self.hasOverlanded 			:= self.createDetailsBoolean(tiHasOverlanded,self.hasOverlanded);
	
	tiHasShortlanded 			:= _ti.isShortlanded;
	self.hasShortlanded 		:= self.createDetailsBoolean(tiHasShortlanded,self.hasShortlanded);
	
	tiLocationForGroup			:= _ti.getLocationForGroup();
	self.locationForGroup 		:= self.createDetailsString(tiLocationForGroup,self.locationForGroup,Ellipsis);
	
	tiHasStops					:= _ti.hasStops;
	self.hasStops 				:= self.createDetailsBoolean(tiHasStops,self.hasStops);
	
	tiDirectDelivery			:= _ti.directDelivery;
	self.isDirectDelivery 		:= self.createDetailsBoolean(tiDirectDelivery,self.isDirectDelivery);
	
	tiIsSpecialStow				:=_ti.isSpecialStow;
	self.isSpecialStow 			:= self.createDetailsBoolean(tiIsSpecialStow,self.isSpecialStow);
	

	tiClientReference    		:= _ti.clientRef;
	self.clientReference 		:= self.createDetailsString(tiClientReference,self.clientReference,Ellipsis);

	tiCustomsEntryNumber		:= _ti.getCustEntryNumList();															//17.12.2024 navma1 #MTN-19298											
	self.customsEntryNumber 	:= self.createDetailsString(tiCustomsEntryNumber,self.customsEntryNumber,Ellipsis);
	
    tiCustomsReference			:= _ti.customsReference;
	self.customsReference 		:= self.createDetailsString(tiCustomsReference, self.customsReference, Ellipsis);
	
	self.customsCargoValue 		:= self.customsCargoValue + _ti.customsCargoValue;
	
	tiPurchaseOrder				:= _ti.purchaseOrder;
	self.purchaseOrder 			:= self.createDetailsString(tiPurchaseOrder,self.purchaseOrder,Ellipsis);
	
	tiServiceOrder				:= _ti.serviceOrder;
    self.serviceOrder			:= self.createDetailsString(tiServiceOrder,self.serviceOrder, Ellipsis);
	//25 July 2022 navgm20 54184-End
	
	
	self.itemised := self.createDetailsBoolean(_ti.itemised, self.itemised);		// ### TFS 57812 (58439) 19Jun2023 NAVPW1
	
	sortingMethod := _ti.mySortingMethod;											// ### TFS 57812 (58439) 19Jun2023 NAVPW1
	if sortingMethod &lt;&gt; null then
		self.sortingMethod := self.createDetailsString(sortingMethod.code, self.sortingMethod, Ellipsis);
	endif;
	
	//07/09/2023	navkc1	CR 60376 Task 60377
	self.shippingLineStatus 	  := self.createDetailsString(_ti.getShippingLineStatusCode(), self.shippingLineStatus, Ellipsis);
	self.customStatus 			  := self.createDetailsString(_ti.getCustomsStatus(), self.customStatus, Ellipsis);
	self.countryOriginRegionCode  := self.createDetailsString(_ti.getCountryOfOriginRegionCode(), self.countryOriginRegionCode, Ellipsis);
	self.countryOriginRegionDesc  := self.createDetailsString(_ti.getCountryOfOriginRegionDesc(), self.countryOriginRegionDesc, Ellipsis);
	self.countryDestRegionCode    := self.createDetailsString(_ti.getCountryOfDestRegionCode(), self.countryDestRegionCode, Ellipsis);
	self.countryDestRegionDesc    := self.createDetailsString(_ti.getCountryOfDestRegionDesc(), self.countryDestRegionDesc, Ellipsis);
	
	//28 May 2024 CR 64323 Task 64325: Jade - Accumulate New Detail Fields
	self.cooNumbers 			  := self.createDetailsString(_ti.getCOONumber(), self.cooNumbers, Ellipsis);
	self.cooDates 				  := self.createDetailsString(_ti.getCOODate(), self.cooDates, Ellipsis);
	
	self.cooINCOCodes 			  := self.createDetailsString(_ti.getCOOIncotermCode, self.cooINCOCodes, Ellipsis);
	self.cooINCODescs 			  := self.createDetailsString(_ti.getCOOIncotermDesc(), self.cooINCODescs, Ellipsis);
	
	self.cooOpPrevDescs 		  := self.createDetailsString(_ti.getCOOOperatorOldDesc(), self.cooOpPrevDescs, Ellipsis);
	self.cooOpPrevCodes 		  := self.createDetailsString(_ti.getCOOOperatorOldCode(), self.cooOpPrevCodes, Ellipsis);
	
	self.cooOpNewCodes 			  := self.createDetailsString(_ti.getCOOOperatorNewCode(), self.cooOpNewCodes, Ellipsis);
	self.cooOpNewDescs 			  := self.createDetailsString(_ti.getCOOOperatorNewDesc(), self.cooOpNewDescs, Ellipsis);
	
	self.cooOpOrigCodes 		  := self.createDetailsString(_ti.getCOOOperatorOrigCode(), self.cooOpOrigCodes, Ellipsis);
	self.cooOpOrigDescs 		  := self.createDetailsString(_ti.getCOOOperatorOrigDesc(), self.cooOpOrigDescs, Ellipsis);
	
	self.cooOpRecCodes 			  := self.createDetailsString(_ti.getCOOOperatorOrigCode(), self.cooOpRecCodes, Ellipsis);
	self.cooOpRecDescs 			  := self.createDetailsString(_ti.getCOOOperatorOrigDesc(), self.cooOpRecDescs, Ellipsis);
	
	self.cooOpStoCodes 			  := self.createDetailsString(_ti.getCOOOperatorStorageCode(), self.cooOpStoCodes, Ellipsis);
	self.cooOpStoDescs 			  := self.createDetailsString(_ti.getCOOOperatorStorageDesc(), self.cooOpStoDescs, Ellipsis);
	
	self.cooOpPrevFreeDays		  := self.createDetailsString(_ti.getCOOOperatorOldFreeDays(), self.cooOpPrevFreeDays, Ellipsis);
	self.cooOpNewFreeDays 		  := self.createDetailsString(_ti.getCOOFreeDays(), self.cooOpNewFreeDays, Ellipsis);
	self.cooFreeDaysAdditional 	  := self.createDetailsString(_ti.getCOOFreeDaysAdditional(), self.cooFreeDaysAdditional, Ellipsis);
	
	self.dishPortDescs			  := self.createDetailsString(_ti.dischargePortDescription, self.dishPortDescs,  Ellipsis);
	self.imexStatusDescs 		  := self.createDetailsString(_ti.getImexStatusStrDesc()  , self.imexStatusDescs, Ellipsis);
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_deadlock" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="combine" id="6bbbde28-df13-497c-a403-b23cf2c18455">
        <updating/>
        <source>combine(_dtl : CM_CargoGroupDetail input) updating;
/*

Purpose:			To handle VoyageOps only showing cargo *groups* combine any details for the same site into the one before running getAttributeStringForDefArray on it

Parameters:			

Return Value:		

Date		Who		Reason
13 Apr 2023	navmd1	TFS 56062 Fix Cargo Group Detail headers not updating correctly

*/

vars
	props		: PropertyNDict;
	prop		: Property;
	propName	: String;
	currentVal,
	newVal		: Any;
begin
	if _dtl = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "No Cargo Group Detail - unable to combine data");
		return;
	endif;
	
	_dtl.allAssignedTrackedItems.tryCopy(self.allAssignedTrackedItems);
	
	props := self.class.getProperties();
	foreach prop in props where prop.cnEcIsPrimitive() do		
		propName := prop.name;
		currentVal := self.getPropertyValue(propName);
		newVal := _dtl.getPropertyValue(propName);
		
		if newVal.isKindOf(Boolean) then
			// If any of our dtls are true, then our combined one must be too
			if currentVal.Boolean = false and newVal.Boolean = true then
				self.setPropertyValue(propName, true);
			endif;
		else
			if newVal = null then
				continue;	// skip
			endif;
			
			if newVal.isKindOf(String) then
				if currentVal = null then
					self.setPropertyValue(propName, newVal);
					continue;	// first time round
				endif;
				
				if currentVal &lt;&gt; newVal then
					self.setPropertyValue(propName, currentVal.String &amp; "," &amp; newVal.String);
				endif;
			else
				if newVal.isKindOf(Decimal) then
					self.setPropertyValue(propName, currentVal.Decimal + newVal.Decimal);
				elseif newVal.isKindOf(Integer) then
					self.setPropertyValue(propName, currentVal.Integer + newVal.Integer);
				endif;
			endif;
		endif;
	endforeach;
	
	// Handle special references
	if _dtl.myTrain &lt;&gt; null then
		self.myTrain := _dtl.myTrain;
	endif;
	
	if _dtl.myVoyage &lt;&gt; null then
		self.myVoyage := _dtl.myVoyage;
	endif;
	
epilog

end;</source>
        <Parameter name="_dtl" type="CM_CargoGroupDetail" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createDetailsBoolean" id="c3e11fb3-7078-4cc2-b1c4-ceefe8059480">
        <updating/>
        <source>createDetailsBoolean(_newValue, _currentValue:Boolean) : Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2022	navmv20	ChangeRequest 53888: EUP - Voyage Operations - More Fields for Cargo Groups

*/

vars

begin
	if _currentValue then
		return _currentValue;
	endif;
	
	return _newValue;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_newValue" type="Boolean"/>
        <Parameter name="_currentValue" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createDetailsString" id="9c0b3a8e-aca4-4b68-bbe3-b0042e3947bc">
        <updating/>
        <source>createDetailsString(_newValue, _currentValue, _ellipsis : String) : String updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2022	navam1	Initial creation

*/

vars

begin
	if _newValue = null then
		return _currentValue;
	elseif _currentValue = null then
		return _newValue;
	endif;
	
    if not _currentValue.cnContains(_newValue) then 
		if _currentValue.cnContains(_ellipsis) then
			return _currentValue;
		else
			if (_currentValue.length + _newValue.length) &gt; 30 then
				return _currentValue &amp; Comma &amp; _ellipsis; 
			else
				return _currentValue &amp; Comma &amp; _newValue;
			endif;
		endif;
	endif;
	
	return _currentValue;
end;</source>
        <access>protected</access>
        <Parameter name="_newValue" type="String"/>
        <Parameter name="_currentValue" type="String"/>
        <Parameter name="_ellipsis" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="288eb3b7-0da0-4a22-ac10-b1ea0cc06ba2">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 18/05/2022	navdap1		Initial creation TFS 53389
// 20/06/2022	navdap1		TFS 53362 EUP Master Data interface customers between TOS and ERP
// 22/06/2022	navsrk20	Bug 53887: EUP - Items Cargo Type to be shown instead of Cargo Group Type
// 25/07/2022	navgm20		ChangeRequest 54184: EUP - New fields in Voyage Operations screen
// 13/04/2023	navmd1		TFS 56062 Fix Cargo Group Detail headers not updating correctly
// 07/09/2023	navkc1		CR 60376 Task 60377: Jade - Cargo Group Regions
vars
	str, type : String;
	opObj : CM_Operator;		// TFS 53362

begin

	if _attrName = ETRow_CargoType then
		if self.myCargoGroup.getCargoGroupCargoType &lt;&gt; null then	//22.06.2022 navsrk20 TFS 53887
			return self.myCargoGroup.getCargoGroupCargoType.description;
		endif;
		return null;
	elseif _attrName = ETRow_Colour then
		return self.colour;
	elseif _attrName = ETRow_DischargePort then
		return self.dischargePort;
	elseif _attrName = ETRow_HazardDesc then
		return self.hazardDetails;
	elseif _attrName = ETRow_Id then
		return self.myCargoGroup.id;
	elseif _attrName = ETRow_ImexStatusString then
		return self.imexStatus;
	elseif _attrName = ETRow_LoadPort then
		return self.loadPort;
	elseif (_attrName = ETRow_LocationId or _attrName = ETRow_LocationIdFull) then
		return self.location;
	elseif (_attrName = ETRow_PlannedLocnId or _attrName = ETRow_PlannedLocnFull)then
		return self.locationPlanned;
	elseif _attrName = ETRow_QueuedLocnId then
		return self.locationQueued;
	elseif _attrName = ETRow_MarkNumber then
		return self.markNumber;
	elseif _attrName = ETRow_Mark then
		return self.marks;
	elseif _attrName = ETRow_MyTrainAssigned then
		if self.myTrain &lt;&gt; null then
			return self.myTrain.code;
		else
			return null;
		endif;
	elseif _attrName = ETRow_VoyageCode then
		if self.myVoyage &lt;&gt; null then
			return self.myVoyage.code;
		else
			return null;
		endif;
	elseif _attrName = ETRow_OperatorCode then
		// TFS 53362 start
		if app.myRoot.getConfig(ComboByNameOperator).Boolean then
			opObj := app.myRoot.allOperators[self.operator];
			if opObj &lt;&gt; null then
				return opObj.description;
			endif;
		endif;
		// TFS 53362 end
		return self.operator;
	elseif _attrName = ETRow_Remarks then
		return self.remarks;
	elseif _attrName = ETRow_Site then
		return app.siteEnumToString(self.site);
	elseif _attrName = ETRow_TotalQuantity then
		return self.totalQuantity.asStringJMT;
	elseif _attrName = ETRow_BillOfLading then
		return self.billOfLading;
	elseif _attrName = ETRow_BookingReference then
		return self.bookingRef;
	elseif _attrName = ETRow_CargoSubType then
		if self.myCargoGroup.getCargoGroupCargoSubType &lt;&gt; null then	
			return self.myCargoGroup.getCargoGroupCargoSubType.description;
		endif;
		return null;
	elseif _attrName = ETRow_CarrierDesc then
		return self.carrierDescription;
	elseif _attrName = ETRow_Commodity then
		return self.commodity;
	elseif _attrName = ETRow_CommodityGroup then
		return self.commodityGroup;
	elseif _attrName = ETRow_Consignee then
		return self.consignee;
	elseif _attrName = ETRow_Consignor then
		return self.consignor;
	elseif _attrName = ETRow_Description then
		return self.description;
	elseif _attrName = ETRow_DestinationPort then
		return self.destinationPort;
	// ### TFS BUG 58854 19JUL2023 NAVAB1 elseif _attrName = ETRow_Diameter then
	// ### TFS BUG 58854 19JUL2023 NAVAB1	 return self.diameter;
	elseif _attrName = ETRow_Grammage then
		return self.grammage;
	// ### TFS BUG 58854 19JUL2023 NAVAB1elseif _attrName = ETRow_Height then
	// ### TFS BUG 58854 19JUL2023 NAVAB1	return self.height;
	// ### TFS BUG 58854 19JUL2023 NAVAB1elseif _attrName = ETRow_Length then
	// ### TFS BUG 58854 19JUL2023 NAVAB1	return self.length;
	elseif _attrName = ETRow_LocationArea then
		return self.locationArea;
	elseif _attrName = ETRow_LocationSubArea then
		return self.locationSubArea;
	elseif _attrName = ETRow_DamageDetail then
		return self.damagedDetails;
	elseif _attrName = ETRow_OperatorGroup then
		return self.operatorGroup;
	elseif _attrName = ETRow_ReceiptTransportMode then
		return self.receiptTransportMode;
	elseif _attrName = ETRow_Carrier then
		return self.receiveCarrier;
	elseif _attrName = ETRow_ReleaseCarrier then
		return self.releaseCarrier;
	elseif _attrName = ETRow_ReleasedTransportMode then
		return self.releaseTransportMode;
	// ### TFS BUG 58854 19JUL2023 NAVAB1elseif _attrName = ETRow_RollingLength then
	// ### TFS BUG 58854 19JUL2023 NAVAB1	return self.rollingLength;
	elseif _attrName = ETRow_SpecialLift then
		return self.specialLift;
	elseif _attrName = ETRow_SpecialStowCode then
		return self.specialStow;
	elseif _attrName = ETRow_TerminalAreaId then
		return self.terminalArea;
	elseif _attrName = ETRow_VesselName then
		return self.vesselName;
	// ### TFS BUG 58854 19JUL2023 NAVAB1elseif _attrName = ETRow_Width then
	// ### TFS BUG 58854 19JUL2023 NAVAB1	return self.width;
	elseif	_attrName = ETRow_Damaged then
		return self.damaged.getYesNo;
	elseif _attrName = ETRow_HasStops then
		return self.hasStops.getYesNo;
	elseif _attrName = ETRow_IsSpecialStow then
		return self.isSpecialStow.getYesNo;
	elseif _attrName = ETRow_IsDirectDelivery then
		return self.isDirectDelivery.getYesNo;
	elseif _attrName = ETRow_HasToDoTasks then
		return self.hasStops.getYesNo;
	elseif _attrName = ETRow_IsOverlanded then
		return self.hasOverlanded.getYesNo;
	elseif _attrName = ETRow_IsShortlanded then
		return self.hasShortlanded.getYesNo;
	elseif	_attrName = ETRow_GroupLocation then
		return self.locationForGroup;	
	elseif _attrName = ETRow_ClientReference then
		return self.clientReference;
	elseif _attrName = ETRow_CustomsCargoValue then
		return self.customsCargoValue.String;
	elseif _attrName = ETRow_CustomsEntryNumber then
		return self.customsEntryNumber;
	elseif _attrName = ETRow_CustomsReference then
		return self.customsReference;
	elseif _attrName = ETRow_PurchaseOrder then
		return self.purchaseOrder;
	elseif _attrName = ETRow_ServiceOrder then
		return self.serviceOrder;
	elseif _attrName = ETRow_Itemised then
		return self.itemised.asStringJMT;	
	elseif _attrName = ETRow_SortingMethod then
		return self.sortingMethod;
	elseif _attrName = ETRow_ShippingLineStatus then
		return self.shippingLineStatus;
	elseif _attrName = ETRow_CustomsStatus then
		return self.customStatus;
	elseif _attrName = ETRow_CountryOfOriginRgnCode then
		return self.countryOriginRegionCode;
	elseif _attrName = ETRow_CountryOfOriginRegion then
		return self.countryOriginRegionDesc;
	elseif _attrName = ETRow_CountryOfDestRegionCode then
		return self.countryDestRegionCode;
	elseif _attrName = ETRow_CountryOfDestRegion then
		return self.countryDestRegionDesc;
	// ### TFS BUG 59912 22AUG2023 NAVAB1 - performance put to bottom
	elseif _attrName.isMeasurementType() then
		_attrName.getRowNameMeasureType(str, type);
		return self.getMeasurementStringForAttrib(str, type, _short);
	//07/09/2023	navkc1	CR 60376 Task 60377
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFirstTIForVoyage" id="8a9f4944-6c78-4d52-803d-50b4be763c41">
        <source>getFirstTIForVoyage(currentVoyage : CM_Voyage) : CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		    Who		Reason
16 January 2023	navmp20	Bug 56062: EUP - #3, #4 Incorrect Cargo grouping/heading values

*/

vars
	ti : CM_TrackedItem;
	invalid : Boolean;
begin
	
	on Exception do app.handleDeletedObject(exception,ti,invalid); // ### TFS BUG 60512 25SEP2023 NAVAB1
	
	foreach ti in self.allAssignedTrackedItems do
		// ### TFS BUG 58853 03JUL2023 NAVAB1
		if ti.isChild then
			continue;
		endif;
		 // ### TFS BUG 60512 25SEP2023 NAVAB1
		if invalid then
			return null;
		endif;
		if currentVoyage.code = ti.voyageCode then 
			return ti;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="currentVoyage" type="CM_Voyage"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementStringForAttrib" id="fe4b3ea8-55a1-4692-bbfa-f33fb79d97de">
        <source>getMeasurementStringForAttrib(_attrName: String; _measureType: String; _short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 18 May 2022	navdap1		Initial creation TFS 53389
// 07/07/2022 	navgm20		ChangeRequest 53888: EUP - Voyage Operations - More Fields for Cargo Groups
vars

begin
	if _attrName = ETRow_TotalWeight then
		return app.convertMeasurementForDisplay(_measureType, self.totalWeight);
	elseif _attrName = ETRow_TotalVolume then
		return app.convertMeasurementForDisplay(_measureType, self.totalVolume);
	// Start 07.07.2022 navgm20 TFS 53888
	elseif _attrName = ETRow_Length then
		return app.convertMeasurementForDisplay(_measureType, self.length.Decimal); // ### TFS BUG 58854 19JUL2023 NAVAB1
//		return self.length;
	elseif _attrName = ETRow_Height then
		return app.convertMeasurementForDisplay(_measureType, self.height.Decimal); // ### TFS BUG 58854 19JUL2023 NAVAB1
//		return self.height;
		elseif _attrName = ETRow_Width then
		return app.convertMeasurementForDisplay(_measureType, self.width.Decimal); // ### TFS BUG 58854 19JUL2023 NAVAB1
//		return self.width;
	// End 07.07.2022 navgm20 TFS 53888
	
	// ### TFS BUG 58854 19JUL2023 NAVAB1
	elseif _attrName = ETRow_Diameter then
		return app.convertMeasurementForDisplay(_measureType, self.diameter.Decimal);
	elseif _attrName = ETRow_RollingLength then
		return app.convertMeasurementForDisplay(_measureType, self.rollingLength.Decimal);
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_measureType" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="2f0edf6e-615a-48f6-be0b-52f1012f876b">
        <source>getMyTerminal(): CM_Terminal;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
01 December 2022	navmd1	Initial creation TFS 55379 Refactor VoyageOpsCG Form

*/

vars

begin
	if self.myCargoGroup &lt;&gt; null then
		return self.myCargoGroup.myTerminal;
	endif;
	
	return inheritMethod();

epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="handleDeadlockException" id="860e0bd7-2d99-4d15-bcee-7de4b7342a79">
        <source>handleDeadlockException(_ex : Exception; _failed : Boolean output) : Integer;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/04/2024	navdap1		TFS 63307 EUP | Performance - Cargo Enquiry Bulk Updates
//
vars

begin
	app.writeLog(method.qualifiedName &amp; Tab &amp; "Triggered the deadlock exception handler - bulkEditProcess is " &amp; global.bulkEditProcess, LogDEBUG);
	_failed := process.getOidString &lt;&gt; global.bulkEditProcess;
	if _failed then
		return Ex_Resume_Next;
	else
		return Ex_Pass_Back;
	endif;
epilog

end;</source>
        <Parameter name="_ex" type="Exception"/>
        <Parameter name="_failed" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="6250c617-d1cf-4105-bb75-6ca3b3b00d92">
        <updating/>
        <source>initialise(	_transportCode : String; 
			_site : Integer;
			_cargoGroup : CM_CargoGroup;
			_train : CM_Train;
			_voyage : CM_Voyage	) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 May 2022	navam1	Initial creation
//TFS 53389
22 Jul 2024 navbs1 ChangeRequest 64884: EUP - Retrospective Jobs Grouped by Cargo Group
*/

vars

begin
	self.transportCode := _transportCode;
	self.site := _site;
	if _cargoGroup &lt;&gt; null then 		//22.07.2024 navbs1 #64884
	self.cargoGroupId := _cargoGroup.id; // ### TFS BUG 58853 06JUL2023 NAVAB1
	endif;
	
	self.myCargoGroup := _cargoGroup;
	self.myTrain := _train;
	self.myVoyage := _voyage;
epilog

end;</source>
        <Parameter name="_transportCode" type="String"/>
        <Parameter name="_site" type="Integer"/>
        <Parameter name="_cargoGroup" type="CM_CargoGroup"/>
        <Parameter name="_train" type="CM_Train"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="removeTIToDetail" id="2e124095-7fee-42ad-bdda-c92b3aaf8b72">
        <updating/>
        <source>removeTIToDetail(_ti : CM_TrackedItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Jan 2025	navah1	Bug 33749: MTN - Cargo Group Unit Test Failure - Incorrect On Site Assigned Count returned

*/

vars
begin
	if self.allAssignedTrackedItems.includes(_ti) then
		self.allAssignedTrackedItems.remove(_ti);
		self.totalQuantity	:= self.totalQuantity - _ti.totalQuantity;
	endif;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
