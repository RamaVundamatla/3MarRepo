    <JadeMethod name="getMatchPriority" id="13336295-f83a-47a5-b5af-08ca5da1272c">
        <source>getMatchPriority(	arbiter: CM_RTQueueArbiter io;
					_fromLocation,
					_toLocation 	: CM_LocationsController): Integer;

// 29/06/2011	cnwmh5	#27179 - Change to use arbiter's writeLoggingText
begin
	// master queue can go from anywhere to anywhere
	arbiter.writeLoggingText(Tab &amp; "Match to Master Queue (" &amp; Match_Master.String &amp; ")");  // ### JIRA 35862 01SEP2025 NAVAB1
	return Match_Master;
end;</source>
        <Parameter name="arbiter" type="CM_RTQueueArbiter" usage="io"/>
        <Parameter name="_fromLocation" type="CM_LocationsController"/>
        <Parameter name="_toLocation" type="CM_LocationsController"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
