    <JadeMethod name="doResize" id="7293123b-bdc4-4a81-b217-6fad28cebf05">
        <updating/>
        <source>doResize() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 April 2013	cnwndl1	Initial creation

*/

vars

begin

	inheritMethod();
	
	self.frmBooking.top := 1;
	self.frmBooking.left := 1;
	
	self.width := self.frmBooking.clientWidth + 2;
	self.height := self.frmBooking.clientHeight + 32;

epilog

end;</source>
