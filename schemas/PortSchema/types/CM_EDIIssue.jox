    <JadeMethod name="createPxyEmailTemplate" id="b135d173-78fc-464d-9317-bfefcac30b89">
        <updating/>
        <source>createPxyEmailTemplate() : CM_EmailTemplate updating;
/*
Purpose:	

Date		Who		Reason
10 July 2024	navab1	CR 64617 TASK 64638
*/

vars

	pxyEmailTemplate : CM_EmailTemplate;

begin
	create pxyEmailTemplate transient;
	pxyEmailTemplate.setMyParent(self);
	pxyEmailTemplate.setProxy(null,null,null,null,null,null, null, self.description,null,false);
	return pxyEmailTemplate;


epilog

end;</source>
        <ReturnType type="CM_EmailTemplate"/>
    </JadeMethod>
