    <JadeMethod name="setProxy" id="d236a4e5-4b31-4046-81d5-20ae846cb978">
        <updating/>
        <source>setProxy(pDescription:String; pTerminalAreaObj:CM_TerminalArea) updating;
// --------------------------------------------------------------------------------
// Created:		13 March 2005 by cnwdad1
//
// Purpose:		Standard method for setting the details of a proxy object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
