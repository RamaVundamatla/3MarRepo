    <JadeMethod name="doSummarise" id="65afe385-c58c-47e7-8901-5bac55d2685b">
        <source>doSummarise(_isSelected :Boolean) protected;
/*

Date		Who		Reason
18 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	coll	:CM_TISet;
begin
	create coll transient;

	if _isSelected then
		self.myCargoCounterOutputAgent.getSelectedTrackedItems (self.tblData, coll);
	else
		self.myCargoCounterOutputAgent.getAllTrackedItems (coll);
	endif;	

	self.myAssistant.showXTABSummaryDefinitionForm(coll, false, false, false, false);
epilog
	delete coll;
end;	</source>
        <access>protected</access>
        <Parameter name="_isSelected" type="Boolean"/>
