        <source>setVoyageVesselCategory(_voyage : CM_Voyage input; _cat : HMS_VesselCategory) updating;
/*
Purpose:			

Date		Who		Reason
13 October 2021	navab1	TFS 52132
*/

vars

begin

	if _voyage = null
