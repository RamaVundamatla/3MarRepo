    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="cf2fc84e-ff5c-45be-a993-4d243e55038d">
        <updating/>
        <source>setProxyFromObject(_object : Object)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Sep 2023	navma1 	EUP | Mobile DD - [BackEnd] Mobile App list of Jobs - Road
19 Oct 2023 navma1	ChangeRequest 60646: EUP | Mobile DD - [53891.060] - Special Instructions in the Mobile App
15 Nov 2023 navhl20 ChangeRequest 58757:[60741] EUP | VAS Mobile App - [53813.020] VAS Job Details
24 Nov 2023 navhl20 ChangeRequest 58760:[60746] EUP | VAS Mobile App - [53813.050] VAS Tasks for Release Cargo Work Order
24 Sep 2024 navhl20	ChangeRequest 62456:[66078] EUP* | VAS Mobile App - [53813.040] VAS Tasks in other Operational Mobile Apps - Flow Integration - 2
01 Oct 2024 navhl20 ChangeRequest 14791 EUP | 53856 - New Scanning App - Unpack mode issue
25 Feb 2025 navma1  MTN-34075 MTN | Dead Lock (1081) on CM_JobsByPriorityRequiredDT
*/

vars
	wod		  : CM_WorkOrderDtl;
	job       :	CM_Job;
	todoJob	  : CM_WOToDoTaskJob;
	wsJob	  : WS_RestIntTodoJob;
	wodTodo	  : CM_WodToDo;
begin
	
	inheritMethod(_object);
	job 					:= _object.CM_Job;
	self.priority 			:= job.priority;
	self.status				:= job.status;
	self.statusString       := job.statusString;
	self.jobType			:= job.getWOOperationJobType;
	
	wod := _object.CM_Job.getMyWorkOrderDtl();
	if wod &lt;&gt; null then																		//19.10.2023 navma1 #60646
		self.workOrderDtlUid := wod.getOidAsString();
		self.workOrderUid    := wod.myParent.getOidString();
		self.workOrderId	 := wod.myParent.id;											//15.11.2023 navhl20 #58757[60741]
	endif;
	
	if wod &lt;&gt; null and wod.isKindOf(CM_WorkOrderTIDtl) then									//24.11.2023 navhl20 #58760[60746]
		if wod.CM_WorkOrderTIDtl.allToDoRequests.isNotEmpty() then
			wodTodo := wod.CM_WorkOrderTIDtl.allToDoRequests.first.CM_WodToDo;
			if wodTodo &lt;&gt; null then
				foreach todoJob in wodTodo.allJobs  as CM_WOToDoTaskJob discreteLock do		//25.02.2025 navma1 #MTN-34075

					create wsJob transient;
					wsJob.setProxyFromObject(todoJob);
					self.allTodoJobs.add(wsJob);
				endforeach;
			endif;
		endif;
	endif;
	
	self.jobstartDateTime := job.getOperationStarted();				//01.10.2024 navhl20 #14791
epilog

end;</source>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
</Class>
