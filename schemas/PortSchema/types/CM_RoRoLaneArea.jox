    <JadeMethod name="setProxy" id="85d59056-2828-4d90-93ca-539ce45dcd0d">
        <updating/>
        <source>setProxy(_id :String; _comment :String; _maxLaneLen, _standardGap : Decimal; _terminal :CM_Terminal; _releasePoint, _hideOverview : Boolean; _laneCount : Integer; _leftLabel, _rightLabel : String; 
					_allInterchangeAreas	:CM_InterchangeAreaArray;	// par24292
					_defaultInterchangeArea: CM_InterchangeArea) updating;

/*
Purpose:			
Parameters:			
Return Value:		

Date				Who		Reason
20 November 2009	cnwjk3	Initial creation
26/05/2010			cnwcs5	par 24292 - change _allInterchangeAreas parameter from set to array
*/

vars

begin
	self.raiseExceptionIfNotTransient(method);
	
	self.setProxyTerminalArea(
		_id,
		_comment,
		TA_TYPE_RORO_LANE_AREA,
		_releasePoint,
