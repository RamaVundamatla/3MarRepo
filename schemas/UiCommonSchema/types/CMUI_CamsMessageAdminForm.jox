    <JadeMethod name="doResetSearch" id="c29a8580-dc9b-4d98-9a18-aebac537980b">
        <source>doResetSearch();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
04 July 2024	navcs2	ChangeRequest 63797: EUP | CAMS Search for outgoing messages - CAMS Message Enquiry

*/
vars
	
begin
	inheritMethod();
	
	self.tblCamsProtocols.clearSelected();
	self.buildCmbStatus();
	self.mskDateEnd.text := null;
	self.mskDateStart.text := null;
	self.mskTimeEnd.text := null;
	self.mskTimeStart.text := null;
	self.chkRegex.value := false;
	
	self.txtMessageSearch.text := null;
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="8ca813e9-8701-4c39-bd14-8e2097939c5f">
        <updating/>
        <source>doResize() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
04 July 2024	navcs2	ChangeRequest 63797: EUP | CAMS Search for outgoing messages - CAMS Message Enquiry

*/
vars
	table	:CM_DataTable;
	status	:CMUI_StatusLine;
begin
	inheritMethod();

	// is the status bar is visible make sure it does not cover the horizontal scroll bar on the table
	status 	:= self.staStatusBar;
	table 	:= self.tblData;
	
	if status.visible then
		table.height := table.parent.Control.clientHeight - status.height;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSelectAll" id="2cbaeec9-3e2a-4a4d-954f-c57516aad2b0">
        <source>doSelectAll();
/*

