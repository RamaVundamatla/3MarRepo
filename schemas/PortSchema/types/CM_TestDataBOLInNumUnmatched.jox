<Class name="CM_TestDataBOLInNumUnmatched" id="2a27b5a8-56dd-4f49-8aaf-efec0dab3585">
    <superclass name="CM_TestDataEntity"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="testData"/>
    <PrimAttribute name="lastNum" id="99430f9c-422c-4dd3-9812-60c8381c086a">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myTestDataRoot" id="a185edb2-5326-4b54-afc5-e795b1cb2178">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="CM_TestDataRoot"/>
        <access>readonly</access>
        <Inverse name="CM_TestDataRoot::myBOLInNumUnmatched"/>
    </ExplicitInverseRef>
    <JadeMethod name="incrementNumber" id="b19b73fe-4c2f-4354-829e-4efd3ebea887">
        <updating/>
        <source>incrementNumber() : Integer updating;
// ---------------------------------------------------------------------------
// Created:     06 June 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	exclusiveLock(self);
	
	self.lastNum := self.lastNum + 1;
	return self.lastNum;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setNumberIfGreater" id="a19d454c-4f82-4b03-9ad7-d52bb5523346">
        <updating/>
        <source>setNumberIfGreater(_value : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     23 April 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	exclusiveLock(self);
	if self.lastNum &lt; _value then
		self.lastNum := _value;
	endif;
end;</source>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
</Class>
