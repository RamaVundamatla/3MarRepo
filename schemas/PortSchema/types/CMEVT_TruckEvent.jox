    <JadeMethod name="setDetailsFromCMIF" id="6151e36f-6cde-4fd4-abdc-cce774b1bf63">
        <updating/>
        <source>setDetailsFromCMIF(_eventType: CM_EventType; _cmifEventTrx: CMIF_TruckEventCtrl) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/02/2025	navkc1 JIRA Bug MTN-33582: MTN | Event Charging Refactor

*/

vars
	vvrDetails		: CM_VehicleVisitRecordDetail;
	resourceUsages 	: CM_ResourceTypeUsageSet;
	wod				: CM_WorkOrderToDoDtl;
begin
	
	if _cmifEventTrx.myRoadJob &lt;&gt; null then
		self.setJobActionDetails(_cmifEventTrx.myRoadJob, _cmifEventTrx.isStart, _cmifEventTrx.startEndTimeStamp);
	endif;
	
	self.setMyWOTransaction(_cmifEventTrx.myWOTransaction);
	
	vvrDetails:= _cmifEventTrx.myVehicleVisitRecordDetail;
	
	if vvrDetails &lt;&gt; null then
		self.setMyVisit(vvrDetails.myVehicleVisitRecord);
		
		vvrDetails.setEventInfo(self);
		
		if 	vvrDetails.recordType = VisitRecord_SealAdd or
			vvrDetails.recordType = VisitRecord_SealDelete then
			self.setSealDetails(vvrDetails.getExtraInfo_SealDetails());
		endif;
	endif;
	
	if _cmifEventTrx.allResourceUsages &lt;&gt; null then
		create resourceUsages transient;
		_cmifEventTrx.allResourceUsages.copy(resourceUsages);
		self.addResourcesFromProxys(resourceUsages);
	endif;
	
	wod := _cmifEventTrx.myWorkOrderDetail;
	
	if wod = null then
		wod := self.getWorkOrderDetail().CM_WorkOrderToDoDtl;
	endif;
	
	if wod &lt;&gt; null then
		self.setFromWOD(wod);
	endif;
	
	inheritMethod(_eventType, _cmifEventTrx);

epilog
	delete resourceUsages;
end;</source>
        <Parameter name="_eventType" type="CM_EventType"/>
        <Parameter name="_cmifEventTrx" type="CMIF_TruckEventCtrl"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="17910df3-1505-41a3-ad7b-255ea2902a47">
        <updating/>
        <source>setForCreate(_pxyEvent: CMEVT_TruckEvent) updating;
/*

Date		Who		Reason
10 December 2014	cnwer1	Initial creation PAR
31 May 2023  navmv20 CR 58001 Task 58002: JADE - Storage Config - Truck Load/Unload Event
*/

vars

begin
	self.setMyVisit(_pxyEvent.myVisit);
	//31/05/2023 navmv20 CR 58001 Task 58002 - START
	self.setMyTrackedItem(_pxyEvent.myTrackedItem);
	//31/05/2023 navmv20 CR 58001 Task 58002 - END
	inheritMethod(_pxyEvent);
	
epilog

end;</source>
        <Parameter name="_pxyEvent" type="CMEVT_TruckEvent"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="3d9b6af2-5f33-4bf4-854d-04155b21712f">
        <updating/>
        <source>setForUpdate(_pxyEvent: CMEVT_TruckEvent) updating;
/*

Date		Who		Reason
11 December 2014	cnwer1	Initial creation PAR
08 Jun      2020  	cnwma1 ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
*/

vars

begin
	inheritMethod(_pxyEvent);
	self.myDebtor           := _pxyEvent.myDebtor;          //03/06/2020 cnwma1 TFS #49400
	self.remarks			:= _pxyEvent.remarks;			//20/02/2023 jlizm1	TFS 56675
	
	if self.myVisit &lt;&gt; null then
		if self.pxyGetProxyObject&lt;&gt; null then
			self.myVisit.causeEvent(EventTransaction_Update_Event,false,self);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_pxyEvent" type="CMEVT_TruckEvent"/>
    </JadeMethod>
    <JadeMethod name="setJobActionDetails" id="d2f00213-7718-41d7-b2e2-bec24e7bf961">
        <updating/>
        <source>setJobActionDetails(_job: CM_RoadJob; _isStart : Boolean; _ts : TimeStamp) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/03/2024	navkc1 CR 62896 Task 62897: Jade - Job Create Transactions and Events
16 Oct 2024 navbs1 Bug MTN-23124: EUP - FR | 54883 - Start and End Times for Operations in Mobile App - part 3


*/

vars
	jobSheet	: CM_JobSheet;
begin
	self.jobDesc := _job.getJobTypeDescription();
	self.jobType := _job.getJobClassNiceString();
	self.jobId := _job.getJobId();				//16.10.2024  navbs1  #23124				
	
	if _isStart then
		self.jobStart := _ts;
	else
		self.jobEnd := _ts;
	endif;	
	
	jobSheet := _job.myJobSheet;
	if jobSheet &lt;&gt; null then
		self.jobSheetCode := jobSheet.externalName;
	endif;
	
	self.setMyVisit(_job.myVehicleVisit);
epilog

end;</source>
        <Parameter name="_job" type="CM_RoadJob"/>
        <Parameter name="_isStart" type="Boolean"/>
        <Parameter name="_ts" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="05266686-224f-4ec9-8838-21b35e3977af">
        <updating/>
        <source>setMyTrackedItem(_ti : CM_TrackedItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2023  navmv20 CR 58001 Task 58002: JADE - Storage Config - Truck Load/Unload Event
*/

vars

begin
	if _ti = null then
		return;
	endif;
	self.myTrackedItem := _ti;
	if not self.isTransient and self.myVisit &lt;&gt; null then
		self.myTrackedItem.causeEvent(EventTransaction_Create_Event,false,self);
	endif;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
