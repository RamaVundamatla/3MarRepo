    <JadeMethod name="cmbInvTypeInv_change" id="6083875f-db0b-4b53-a5ea-fe53b0c5da3a">
        <controlMethod name="ComboBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbInvTypeInv_change(combobox: ComboBox input) updating;
/*

Purpose:			Sets the ent table to the value of the combo box

Parameters:			combobox	ComboBox	The combobox that lost focus

Return Value:		NONE

Date		Who		Reason
30 September 2022	navpw1	Initial creation TFS: 54565 (54384)
16 March 2023  navmv20 TFS 56128 Task 56129: UI - Manual Invoice Lines - Multi TI Invoice Line Type
*/

vars
	invoiceDesc			: CM_InvoiceDesc;
	surchargeExemptions	: CM_InvoiceTypeSurchargeExempt; // ### TFS 54565 (54384) 29Sep2022 NAVPW1
	
begin
	self.tblInvProperties.setValueByControlName(combobox.name, combobox.text);
	invoiceDesc := combobox.listObject.CM_InvoiceDesc;
	
	//16/03/2023  navmv20 TFS 56128 Task 56129 - START
	if invoiceDesc = null then
		return;
	endif;
	//16/03/2023  navmv20 TFS 56128 Task 56129 - END
	surchargeExemptions := invoiceDesc.mySurchargeAndExemptions;
	
	if surchargeExemptions = null then
		return;
	endif;
	
	if surchargeExemptions.allInvoiceTypeDebtorSeparation.isEmpty then
		return;
	endif;
	
	if invoiceDesc.invoiceKey = CM_InvoiceDesc.Key_Voyage then
		self.tblInvProperties.enableRowByName(ETRow_Voyage);
	else
		self.tblInvProperties.disableRowByName(ETRow_Voyage);
		self.cmbVoyageInvProp.listIndex := -1;
		self.tblInvProperties.setValueByName(ETRow_Voyage,null);
	endif;
	
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbInvTypeInv_click" id="4ced3ca2-f603-4b4a-9a84-6c9776efb68f">
