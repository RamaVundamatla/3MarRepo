    <JadeMethod name="setDefaultsFromObject" id="4f00a5c7-7a9c-4f49-bfa3-afe6cf888d5e">
        <updating/>
        <source>setDefaultsFromObject(pObj : CM_Object) updating, protected;
/*
	Created on 23 January 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	assistant		: GTE_Assistant;
	defCommodity	: CM_Commodity;
	defConsignor,
	defFreightFwdr	: CM_ConsigneeConsignor;
	//defCustomDetails: String;
	defDestination,
	defDischarge,
	defTranshipPort	: CM_Port;
	defISOType		: CM_ISOType;
	defOperator		: CM_Operator;
	defBOLType		: CM_BOLType;
	defCargoType	: CM_CargoType;
	defVoyage		: CM_Voyage;
	idx,
	tmpRow,
	defTransportMode	: Integer;
	defCompanyCode,
	defTransModeStr		: String;
	defMTGrade		: CM_MTGrade;
	child,
	intFaceAttach	: CMIF_InOutAttachment;
	defProduct		: CM_Product;
	
	hazCode		: String;
	hazObject	: CM_HazardClass;
	tmpStatus	: CM_IMEXStatus;	
	pConsignor  : CM_ConsigneeConsignor;	
	cmb         : ComboBox;	
	id,idz		: Integer;
	defBRItem   : CM_BookingRefItem;
	defBR		: CM_BookingRef;
	defGenType	: CM_GeneratorType;
	
	defQuantity : Integer;
	defWeight	: Decimal[14,4];

begin

	//create children transient;//PAR 22954
	assistant := self.myAssistant.GTE_Assistant;

	self.allAttachments.purge;
	
	if pObj = null then
		defCompanyCode := self.myTerminal.getDefaultCompanyCode();
		defTransportMode := self.lastTransportMode;
		defCargoType := app.myPassport.getDefaultCargoType();
		defMTGrade := app.myRoot.allAvailabilityGrades[self.myTerminal.getConfig(DefAvailabilityGrade).Integer]; 							
	else
		defCommodity 	:= app.getCargoFieldObject(pObj, ETRow_Commodity).CM_Commodity;
		defConsignor	:= app.getCargoFieldObject(pObj, ETRow_ConsignorCode).CM_ConsigneeConsignor;
		defDestination	:= app.getCargoFieldObject(pObj, ETRow_DestinationPort).CM_Port;
		defDischarge	:= app.getCargoFieldObject(pObj, ETRow_DischargePort).CM_Port;
		defTranshipPort	:= app.getCargoFieldObject(pObj, ETRow_MyTranshipToPort).CM_Port;
		defISOType		:= app.getCargoFieldObject(pObj, ETRow_IsoType).CM_ISOType;
		defOperator		:= app.getCargoFieldObject(pObj, ETRow_OperatorCode).CM_Operator;
		defBOLType		:= app.getCargoFieldObject(pObj, ETRow_BolType).CM_BOLType;
		defCargoType	:= app.getCargoFieldObject(pObj, ETRow_CargoType).CM_CargoType;
		defVoyage		:= app.getCargoFieldObject(pObj, ETRow_VoyageCode).CM_Voyage;
		defCompanyCode  := app.getCargoFieldString(pObj, ETRow_CompanyCode);
		defProduct		:= app.getCargoFieldObject(pObj, ETRow_Product).CM_Product;
		defFreightFwdr 	:= app.getCargoFieldObject(pObj, ETRow_FreightForwarderCode).CM_ConsigneeConsignor;
		defMTGrade 		:= app.getCargoFieldObject(pObj, ETRow_AvailabilityGradeCode).CM_MTGrade; 	
		tmpStatus		:= app.getCargoFieldObject(pObj, ETRow_StatusString).CM_IMEXStatus;
		defBR			:= app.getCargoFieldObject(pObj, ETRow_BookingRef).CM_BookingRef;
		defGenType		:= app.getCargoFieldObject(pObj, ETRow_MyGeneratorType).CM_GeneratorType;
		
		if CM_BookingRefItem.hasInstance(pObj) then
			defBRItem := pObj.CM_BookingRefItem;
		else
			defBRItem		:= app.getCargoFieldObject(pObj, ETRow_MyBookingRefItem).CM_BookingRefItem;
		endif;
		if pObj.isKindOf(CM_TrackedItem) then
			defTransportMode:= pObj.CM_TrackedItem.receiptTransportMode;
		else
			defTransportMode := self.lastTransportMode;
		endif;
	endif;

	assistant.mainExtraSetValue(tblMain, tblExtra, ETRow_CompanyCode, defCompanyCode);
	self.cmbCommodity.setObject(defCommodity);

	self.cmbConsignor.setType(CONSIGNOR);
	self.cmbConsignor.setObject(defConsignor);

	self.cmbFreightFwdr.setType(FREIGHT_FORWARDER);
	self.cmbFreightFwdr.setObject(defFreightFwdr);

	self.cmbDestination.myAssistant := self.myAssistant;
	self.cmbDestination.showAllDestinations := true;
	self.cmbDestination.setObject(defDestination);	

	self.cmbDischarge.myAssistant := self.myAssistant;
	self.cmbDischarge.setObjectAndVoyage(defDischarge, defVoyage);
	
	self.cmbTranship.myAssistant := self.myAssistant;
	if defTranshipPort &lt;&gt; null then
		self.cmbTranship.setObject(defTranshipPort);
	endif;
	self.cmbTranship.setObjectAndVoyageDischPort(defDischarge, defVoyage);
	//if defTranshipPort &lt;&gt; null then
	//	self.cmbTranship.setObject(defTranshipPort);
	//endif;	//par 21773 moved before the call of the above function

	self.cmbISOType.setObject(defISOType);
	self.cmbOperator.setObjectAndVoyage(defOperator, defVoyage);
	self.cmbGenSetType.setObject(defGenType);

	self.cmbAvGrade.setObjectAndOperator(defMTGrade, defOperator, null);
	assistant.mainExtraSetValue(tblMain, tblExtra, ETRow_AvailabilityGradeCode, cmbAvGrade.text);
		
	
	idx := tblMain.getRow(ETRow_StatusString);
	if idx &gt; 0 then
		if pObj &lt;&gt; null and pObj.isKindOf(CM_TrackedItem) then
			tmpStatus := pObj.CM_TrackedItem.getImExStatusObject();
		else		
			tmpStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT];	// set default to Export RDD 16/9/2001 POT175/PAR1337 -- made here 16/10/01 RDD
		endif;
		if tmpStatus &lt;&gt; null then
			assistant.comboBoxIMEXStatus(self.cmbImexStatus, tmpStatus.code);
		endif;
	endif;
	
	// PAR 10231 ony display system cargo types
	if defCargoType &lt;&gt; null then
		id := defCargoType.id;
	endif;
	assistant.comboBoxCargoBolType(cmbTiType, id, true, false, true, true);
	
	if defBOLType &lt;&gt; null then
		id := defBOLType.id;
	endif;
	assistant.comboBoxCargoBolType(cmbBOLType, id, false, true, true, true);
	
	// This is the new one for after 7.4.1 release
	//assistant.comboBoxCargoBOLTypeGate(cmbTiType, defCargoType.id, true, false,  true);
	//assistant.comboBoxCargoTypes(cmbTiType, defCargoType);
	//assistant.comboBoxVoyageCode(cmbVoyage, defVoyage, false);

	//PAR 11740 by cnwyl1
	assistant.comboBoxVoyageCurrent(cmbVoyage,
									defVoyage,
									true, //reset
									false, //includeArchived
									false, //includeDeparted
									true, //includeNonPlannedWorked
									true, //includeNullVoyage
									false, //includeLogVoyage
									true, //includeGCVoyage
									false,//isCellularOnly
									true); //excludeInward
	//WAS...
	//assistant.comboBoxVoyageCurrent(cmbVoyage, defVoyage, true, false, false, true, true, true, true);
	
	assistant.mainExtraSetValue(tblMain, tblExtra, ETRow_CargoType, cmbTiType.text);
	assistant.receival_ShowRows(defCargoType, defISOType, tblMain, tblExtra, self.myTerminal);
	self.cmbProduct.setObject(defProduct);	
	assistant.mainExtraSetValue(tblMain, tblExtra, ETRow_MyProduct, cmbProduct.text);

	self.cmbBRItem.setObject(defBRItem);
	assistant.mainExtraSetValue(tblMain, tblExtra, ETRow_MyBookingRefItem, cmbBRItem.text);
	
	idx := tblMain.getRow(ETRow_TransportMode);
	if idx &gt; 0 then
		defTransModeStr := assistant.transModeToString(defTransportMode);
		tblMain.setValue(idx, defTransModeStr);
		assistant.showHideWagonField(tblExtra, defTransModeStr);
	endif;

	if pObj = null then
		// Adding so set controls not already set to null.
		assistant.setListTablePorts(lstDischarge, null);
		assistant.mainExtraSetValue(tblMain, tblExtra, ETRow_AllDischargePorts, null);
		
		self.lstHazardList.loadHazardObjects;
		assistant.resetHazardListTable(lstHazardList);	// CCMS 1203 JC
		assistant.mainExtraSetValue(tblMain, tblExtra, ETRow_AllTIHazards, null);
		
		assistant.clearAttachmentLines(tblExtra);
		return;
	endif;

	
	tblMain.setTableFromObject(pObj, GTE_ReceivalsForm::setDefaultsCallBack.name);
	tblExtra.setTableFromObject(pObj, GTE_ReceivalsForm::setDefaultsCallBack.name);

	
	if pObj.isKindOf(CM_TrackedItem) then
		self.setDefaultsForDimensions(pObj.CM_TrackedItem);
		if pObj.isKindOf(CM_Container) then
			self.setDefaultsForCOU(pObj.CM_Container.getCou);
		endif;
		//pObj.CM_TrackedItem.getAllChildren(children);//PAR 22954
		//self.setDefaultsForAttachments(children);//cnwsh3 - PAR25103 - allChildren collection has been unprotected reversing the need for changes from PAR22954
		self.setDefaultsForAttachments(pObj.CM_TrackedItem.allChildren);
		
	endif;
	self.setTiTypeFields();
epilog

end;</source>
        <access>protected</access>
        <Parameter name="pObj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="setFilterDefaults" id="76de0810-db3a-453c-ba0d-14736e70a9bd">
