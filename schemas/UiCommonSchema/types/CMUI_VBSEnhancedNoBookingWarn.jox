    <JadeMethod name="translateForm" id="fc2c2802-7b01-4d13-bbe6-ed498f467375">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 01 April 2025 15:09:46.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0027064, locale);
	btnContinue.translateBubbleHelp(Xlat_0027065, locale);
	btnContinue.translateCaption(Xlat_0027066, locale);
	btnReject.translateBubbleHelp(Xlat_0027067, locale);
	btnReject.translateCaption(Xlat_0027068, locale);
	lblMsg.translateCaption(Xlat_0027069, locale);
end;</source>
    </JadeMethod>
</GUIClass>
