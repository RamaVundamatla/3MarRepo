vars

begin
	delete self.myProxyObject;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="4ee56f47-bb4d-41e7-9805-990d5d804111">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 May 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	result : Integer;
	row : Integer;
	pxyDeck : CM_DeckVessel;

begin
	
	if self.tblDecks.rows = self.tblDecks.fixedRows then
		app.msgBox(app.getErrorString(Must_EnterValid_FileName_First),app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Stop_Icon);
		return;
	endif;
	
	app.mousePointer := Window.MousePointer_HourGlass; // PAR 28513

	row:=2;
	while row &lt;= self.tblDecks.rows do
		pxyDeck:=self.tblDecks.accessRow(row).itemObject.CM_DeckVessel;
		pxyDeck.setPxyCode(self.tblDecks.accessCell(row,2).text);
	
		row:=row+1;
	endwhile;
	
	
	while true do
		app.myTrxUA.trxImportXMLDocROROVessel(self.myROROVesselStructure,self.myProxyObject,app.myPassport);
		if app.myPassport.trxCompletedOK then
			
			break;
		else
			result := app.showErrorWarningDialog('Vessel Deck', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		
		break;
	endwhile;
	
	
	if app.myPassport.trxCompletedOK then
		inheritMethod();
	endif;
epilog
	app.mousePointer := Window.MousePointer_Default; // PAR 28513
end;	</source>
    </JadeMethod>
    <JadeMethod name="doSelectXMLFile" id="bedf7a11-054b-46d4-9266-b45ef1c97c9a">
        <updating/>
        <source>doSelectXMLFile() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 May 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	theFileName : String;
	pxyObj : CM_Object;
begin
	app.mousePointer := Window.MousePointer_HourGlass; // PAR 28513
	
	pxyObj:=app.importVesselDefnXMLCreateProxy(false,false,true,theFileName);
	if pxyObj = null then
		app.raiseCMException1(Invalid_XML_need_tag,CM_ROROVesselStructure.name &amp; " or " &amp; CM_DeckVessel.name,null,null);
		return;
	endif;
	app.mousePointer := Window.MousePointer_Default; 
	self.tblDecks.rows:=self.tblDecks.fixedRows;
	delete self.myProxyObject;
		
	self.txtFileName.text:=theFileName;
	self.myProxyObject:=pxyObj;
	self.loadFromProxy();
	
epilog
	app.mousePointer := Window.MousePointer_Default; // PAR 28513

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadFromProxy" id="294bbe8e-4b33-4b46-bc74-6dec1e44266f">
        <source>loadFromProxy() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2013	cnwer1	Initial creation CCMS DPH 2280

*/

vars
	pxyDeck,
	pxySubDeck : CM_DeckVessel;
begin
	if self.myProxyObject = null then
		return;
	endif;
	
	if self.myProxyObject.isKindOf(CM_ROROVesselStructure) then
		foreach pxyDeck in self.myProxyObject.CM_ROROVesselStructure.allDecks  discreteLock do
			self.addToTable(pxyDeck);
			foreach pxySubDeck in pxyDeck.allSubDecks discreteLock do
				self.addToTable(pxySubDeck);
			endforeach;
		endforeach;
	elseif self.myProxyObject.isKindOf(CM_DeckVessel) then
		self.addToTable(self.myProxyObject.CM_DeckVessel);
		foreach pxySubDeck in self.myProxyObject.CM_DeckVessel.allSubDecks discreteLock do
			self.addToTable(pxySubDeck);
		endforeach;
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setDetails" id="400f66f0-f294-497d-952e-bbfce5ef4f9f">
        <updating/>
        <source>setDetails(	_roroVesselStructure : CM_ROROVesselStructure;
			_pxyDeck : CM_Object;
			_fileName : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 April 2013	cnwer1	Initial creation CCMS DPH 2280

*/

vars

begin
	self.myROROVesselStructure := _roroVesselStructure;
	self.myProxyObject:=_pxyDeck;
	self.txtFileName.text:=_fileName;
epilog

end;</source>
        <Parameter name="_roroVesselStructure" type="CM_ROROVesselStructure"/>
        <Parameter name="_pxyDeck" type="CM_Object"/>
        <Parameter name="_fileName" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="623f719d-fbc1-4c6e-a04d-ee33d604c679">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 May 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	inheritMethod();
	self.caption :=self.caption &amp; " "  &amp; self.myROROVesselStructure.myVessel.code;
	self.setupTable();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupTable" id="72908020-737c-4d2c-b1c7-4891758e5e7f">
        <source>setupTable() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 May 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	self.tblDecks.columns:=2;
	self.tblDecks.row:=1;
	self.tblDecks.text:="File Deck Name" &amp; Tab &amp; "New Deck Name";
	self.tblDecks.accessMode:= Table.AccessMode_Cell;
	self.tblDecks.accessColumn(1).enabled:=false;
	self.tblDecks.row:=2;
	self.tblDecks.accessColumn(2).inputType:=Table.InputType_TextBox;
	self.tblDecks.rows:=1;
	self.loadFromProxy();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="9e5c8cf6-c179-48e4-8161-41c783c45904">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0015456, locale);
	btnFileOpen.translateCaption(Xlat_0015457, locale);
	lblDescription.translateCaption(Xlat_0015458, locale);
	lblFileName.translateCaption(Xlat_0015459, locale);
end;</source>
    </JadeMethod>
</GUIClass>
