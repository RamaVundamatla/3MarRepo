<Class name="CMQF_ASPAReports">
    <JadeMethod name="setFromAgent" id="f1684511-be90-41bd-bccb-fbe57df4e1a2">
        <updating/>
        <source>setFromAgent(_agent: CMUI_ReportAgent input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2019	jlgndl1	Initial creation	TFS 46131
13 Sep 2019	jlgsl4	TFS 46513 - ASPA - Load/Unload Summary Report errors
*/

vars

	obj : Object;

begin

	inheritMethod(_agent);
	
	if _agent.isRowIncluded(ETRow_DateToRun) then
		if _agent.state = _agent.STATE_TEMPLATE_SAVE or
		   _agent.state = _agent.STATE_TEMPLATE_EDIT then
			self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_DateToRun), 
								self.dateToRunType, self.dateToRunFactor, ETRow_DateToRun);
		else
			self.dateToRun := _agent.getValueByNameIfVisible(ETRow_DateToRun).Date;
		endif;
		
	endif;
	if _agent.isRowIncluded(ETRow_DateYearStart) then
		self.dateYearStart := _agent.getValueByNameForDateIfVisible(ETRow_DateYearStart/*getValueByNameIfVisible*/); //.Date; // TFS 46513
	endif;	
	if _agent.isRowIncluded(ETRow_TimeToRun) then
		self.timeToRun := _agent.getValueByNameIfVisible(ETRow_TimeToRun).Time;	
	endif;
	if _agent.isRowIncluded(ETRow_MyEventStart) then
		self.myEventStart := _agent.CMUI_ReportAgentStd.myCmbEvtStart.listObject.CM_EventType;
	endif;
	if _agent.isRowIncluded(ETRow_MyEventFinish) then
		self.myEventFinish := _agent.CMUI_ReportAgentStd.myCmbEvtFinish.listObject.CM_EventType;
	endif;
	if _agent.isRowIncluded(ETRow_MyEventPlaced) then
		self.myEventPlaced := _agent.CMUI_ReportAgentStd.myCmbEvtPlace.listObject.CM_EventType;
	endif;
	if _agent.isRowIncluded(ETRow_MyEventPulled) then
		self.myEventPulled := _agent.CMUI_ReportAgentStd.myCmbEvtPull.listObject.CM_EventType;
	endif;
	if _agent.isRowIncluded(ETRow_WeightMeasureType) then
		self.myWeightMeasureType := _agent.CMUI_ReportAgentStd.myCmbWtMeasurement.listObject.CM_MeasurementType;
	endif;
	if _agent.isRowIncluded(ETRow_AllVoyageEvents) then
		self.allUnloadEvents.clear();
		foreach obj in _agent.CMUI_ReportAgentStd.myLstTblUnloadEvts.allSelectedObjects do
			self.allUnloadEvents.addNoDuplicates(obj.CM_EventType,false);
		endforeach;
	endif;
	if _agent.isRowIncluded(ETRow_AllBargeVessels) then
		self.allBargeVessels.clear();
		foreach obj in _agent.CMUI_ReportAgentStd.myLstTblBarges.allSelectedObjects do
			self.allBargeVessels.addNoDuplicates(obj.CM_Vessel,false);
		endforeach;
	endif;
	
	if _agent.isRowIncluded(ETRow_AllNonBargeVessels) then
		self.allNonBargeVessels.clear();
		foreach obj in _agent.CMUI_ReportAgentStd.myLstTblNonBarges.allSelectedObjects do
			self.allNonBargeVessels.addNoDuplicates(obj.CM_Vessel,false);
		endforeach;
	endif; 

epilog

end;</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
