    <JadeMethod name="getMinimumSteamingTime" id="5d97164b-85bf-4543-9c82-a0d4ea953c88">
        <source>getMinimumSteamingTime(_vessel : CM_Vessel):Integer;
// ---------------------------------------------------------------------------
// Created:     27 March 2008 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	vesselTime		: HMS_PSD_Vessel;
	
begin
	if _vessel &lt;&gt; null then
		vesselTime := _vessel.allPathSegmentDurations[self];
		if vesselTime &lt;&gt; null then
			return vesselTime.minimumTime;
		endif;
	endif;
	
	return self.minSteamingTime;
end;</source>
        <Parameter name="_vessel" type="CM_Vessel"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSteamingTimeForVessel" id="7c88fb2b-9b47-4f96-b3c1-85a47b4051c3">
        <source>getSteamingTimeForVessel( _vessel : CM_Vessel) : Integer;
//-----------------------------------------------------------------------
//	Created:	17 October 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	psd : HMS_PSD_Vessel;
begin
	
	if _vessel &lt;&gt; null then
		psd := self.allVesselPathSegmentDurations[_vessel];
		
		if psd &lt;&gt; null then
			return psd.estimatedTime;
		endif;
	endif;
	
	return self.steamingTimeAB;

end;</source>
        <Parameter name="_vessel" type="CM_Vessel"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="b83bd5c4-2153-4007-a47f-a7b2084a52dd">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------------------
//Created: 11 July 2003 By: cnwgd1
//--------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxy : HMS_PathSegment;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	proxy.myHarbour := self.myHarbour;
	proxy.myRegionFrom := self.myRegionFrom;
	proxy.myRegionTo := self.myRegionTo;	
	proxy.myRoot := self.myRoot;	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="7d7769ee-fb3e-4940-9560-e22cc2a4a088">
        <updating/>
        <source>setForUpdate(_pxyPathSegment: HMS_PathSegment; _passport: CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	durationObj	: HMS_PathSegmentDuration;
	timeAB		: Integer;
	
begin
	timeAB	:=	self.steamingTimeAB;		// Save off the original estimated time value.
	inheritMethod(_pxyPathSegment, _passport);
	
	self.code				:=	_pxyPathSegment.code.toUpper().trimBlanks();
	self.description		:=	_pxyPathSegment.description;
	self.myHarbour			:=	_pxyPathSegment.myHarbour;
	self.myRegionFrom		:=	_pxyPathSegment.myRegionFrom;
	self.myRegionTo			:=	_pxyPathSegment.myRegionTo;
	self.steamingTimeAB		:=	_pxyPathSegment.steamingTimeAB;
	self.steamingTimeBA		:=	_pxyPathSegment.steamingTimeBA;
	self.minSteamingTime	:=	_pxyPathSegment.minSteamingTime;
	self.myRoot				:=	_pxyPathSegment.myRoot;
	
// cnwdad1 08/09/2008 - PAR #17822.
	if timeAB &lt;&gt; self.steamingTimeAB then
		foreach durationObj in self.allVesselPathSegmentDurations do
			if durationObj.estimatedTime = timeAB then
				durationObj.setEstimatedTime(self.steamingTimeAB);
			endif;
		endforeach;
	endif;
end;</source>
        <Parameter name="_pxyPathSegment" type="HMS_PathSegment"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="31972f53-c6c1-4c66-92ac-1f639b3f31f9">
        <updating/>
        <source>setProxy(_root : CM_Root; _harbour : HMS_Harbour)updating;
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);
	self.myRoot := _root;
	self.myHarbour := _harbour;
end;</source>
        <Parameter name="_root" type="CM_Root"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="e5bd72fb-462f-4d3f-8fc8-f7dc9a8c5494">
        <source>validateForDelete(_passport: CM_Passport input);
// --------------------------------------------------------------------------------
// Created:		13 October 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(_passport);
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="cf011b08-05d5-48e1-98fd-3c7ce54dae4a">
        <source>validateMe(_passport: CM_Passport input);
//--------------------------------------------------------------
//Created: 04 July 2003 By: cnwgd1
//14/06/2022    navds20     TFS 53760 DuplicateItem not Translatable
//--------------------------------------------------------------
vars
	tmpPathSegment : HMS_PathSegment;
begin
	inheritMethod(_passport);
	
	if self.code = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Code', ETRow_Code, null);
		app.raiseCMException(Input_required_field_code, ETRow_Code, null); // cnwdb2	PAR 35364
	endif;
	if self.description = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Description', ETRow_Description,  null);
		app.raiseCMException(Input_required_field_desc, ETRow_Description,  null);
	endif;

	/* Lorcan Validation on Harbour now gone
	if self.myHarbour = null then
		app.raiseCMException1(REQUIRED_FIELD, 'Harbour', ETRow_MyHarbour,  null);
	endif;
	*/

	if self.myRegionFrom = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Region From', ETRow_MyRegionFrom,  null);
		app.raiseCMException(Input_required_field_regFrom, ETRow_MyRegionFrom,  null); // cnwdb2	PAR 35364


	endif;
	if self.myRegionTo = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Region To', ETRow_MyRegionTo,  null);
		app.raiseCMException(Input_required_field_regTo, ETRow_MyRegionTo,  null); // cnwdb2	PAR 35364
	endif;
	
//	if self.steamingTimeAB = null then
//		app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Steaming_timeAB), ETRow_SteamingTimeAB,  null);
//	endif;
	
//	if self.steamingTimeBA = null then
//		app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Steaming_timeBA), ETRow_SteamingTimeBA,  null);
//	endif;
								
	if _passport.hasErrors then
		return;
	endif;

	tmpPathSegment := self.myRoot.allPathSegments.getAtKey(self.code);
	if tmpPathSegment &lt;&gt; null then
		if self.isTransient and tmpPathSegment &lt;&gt; self.pxyGetRealObject() then
			//app.raiseCMException2(DuplicateItem, 'Path Segment', self.code, ETRow_Code, null); //14.06.2022 navds20 53760
			// Path Segment already exists for %1 : Path_segment_already_exists
			app.raiseCMException1(Path_segment_already_exists, self.code, ETRow_Code, null);  //14.06.2022 navds20 53760
		endif;
	endif;

	foreach tmpPathSegment in myRoot.allPathSegments where tmpPathSegment &lt;&gt; self and tmpPathSegment &lt;&gt; pxyGetRealObject do
		if myRegionFrom = tmpPathSegment.myRegionFrom and myRegionTo = tmpPathSegment.myRegionTo then
			//app.raiseCMException2(DuplicateItem, 'Path Segment ' &amp; tmpPathSegment.code, tmpPathSegment.myRegionFrom.code &amp; '-' &amp; tmpPathSegment.myRegionTo.code, ETRow_Code, null); // 21/06/2022 navds20 53760
			// Path Segment %1 already exists for %2 - %3 : Path_segmentalready_exists
			app.raiseCMException3(Path_segmentalready_exists,  tmpPathSegment.code, tmpPathSegment.myRegionFrom.code , tmpPathSegment.myRegionTo.code, ETRow_Code, null); // 21/06/2022 navds20 53760
			break;
		endif;
	endforeach;
	
	if self.myRegionTo = self.myRegionFrom then
		app.raiseCMException2(HMSRegionToSame, self.myRegionTo.code, self.code, ETRow_MyRegionEnd, null);
	endif;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
