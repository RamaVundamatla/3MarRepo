    <JadeMethod name="setProxyFromObject" id="dab4ba8f-0a2f-4dd8-9483-23865fb35175">
        <updating/>
        <source>setProxyFromObject(_reserveDetail: CM_ReserveDetail) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/06/2024	navdap1		Initial creation TFS 63107 CUX | GET /releaseRequest API to return release request line items
// 23/07/2024	navmd1		TFS 63327 Added lineNumber and piecesRequested
//
vars
	selection : CM_ReserveSelection;

begin
	inheritMethod(_reserveDetail);
	
	selection := _reserveDetail.CM_ReserveSelection;
	
	self.bolId := selection.getBOLNumber();
	self.clean := selection.clean;
	self.heavyDuty := selection.heavyRated;
	self.remarks := selection.remarks;
	self.isoTypeId := selection.getISOTypeCode;
	self.isoGroupId := selection.getISOGroupCode;
	self.lineNumber := selection.lineNumber;
	self.piecesRequested := selection.quantitySelection;
	
epilog

end;</source>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
    </JadeMethod>
</Class>
