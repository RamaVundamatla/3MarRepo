    <JadeMethod name="setSystemMode" id="9ff483f9-b311-4c1f-a181-6d5091243a36">
        <updating/>
        <source>setSystemMode(_value : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     28 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	//epr TFS 42569
	if self.systemMode = _value then
		return;
	endif;
	
	if _value &lt; self.SystemMode_Production or
		_value &gt; self.SystemMode_Dev then
		return;
	endif;
	
	self.systemMode := _value;
	
	self.setConfigFromRefreshParameters();
	
end;</source>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setSystemPermissionDetails" id="f85a05ee-4e08-4261-ac68-62e09d029ea7">
        <updating/>
        <source>setSystemPermissionDetails() updating;
// ---------------------------------------------------------------------------
// Created:     05 April 2004 by cnwrs2
//
// Purpose:     Sets the "extraInfo" field to contain permissions for all the
//				terminals (if they have a separate license).  This field is then
//				used to determine what options should be displayed on the
//				System Items menu.
//
//
//	Date			Who			Reason
//	14 Mar 2024		navnk30		Bug 62361: LINX - Error code 75768 displays when opening Event Stream Definition table in the System administration screen
// ---------------------------------------------------------------------------
vars
	tmpTerm	: CM_Terminal;
	idx,
	maxValue	: Integer;
	tmpCanDo	: Boolean;
	tmpBin		: Binary;
	licPermAgent	: CM_PermissionAgent;
	subsPermAgent	: CM_PermissionAgent;
	obj			: Object;
	subsPerm : CM_PermissionObject;
	subExpDate : Date;
	licenseName : String;
	subsProd : String;
	subsIndex : Integer;
	subExpDates : DateArray;

begin

	self.setPropertyValue('extraInfo', null);

	if (not self.isLicensedForProductCode(ProductCode_JMT)) then
		return;
	endif;

	obj := app.myCheckerObject;
	
	if obj = null then
		return;
	endif;
	
	create subExpDates transient;
	
	create licPermAgent transient;
	licPermAgent.populatePermissionDict(false, false, 0);
	create subsPermAgent transient;		//17 Jun 2020	NDL	TFS 49569
	subsPermAgent.populatePermissionDict(false, false, 4);		//17 Jun 2020	NDL	TFS 49569
//	maxValue := licPermAgent.getMaxConstValue();
	maxValue := licPermAgent.getMaxModuleNumber;	//17 Jun 2020	NDL	TFS 49569
	licenseName := self.licenseName;		//17 Jun 2020	NDL	TFS 49569
	subsProd := "SUBS";		//17 Jun 2020	NDL	TFS 49569
	
	foreach idx in Mod_BaseView + 1 to maxValue do
		tmpCanDo := false;
		subsPerm := null;
		subExpDate := null;
		subsPerm := subsPermAgent.allPermissionsByConstValue[ idx ];
		if subsPerm &lt;&gt; null then		//17 Jun 2020	NDL	TFS 49569
			subsIndex := idx - Mod_BaseView;
			tmpCanDo := obj.sendMsgWithIOParams('isSubsLicensed', licenseName, subsProd, subsIndex, subExpDate ).Boolean;
			subExpDates.atPut( subsIndex, subExpDate );
		else
			if obj.sendMsgWithParams('isLicensed', self.licenseName, 'JMT', idx - Mod_BaseView).Boolean then
				tmpCanDo := true;
			else
				// need to see if canDo at any terminal
				foreach tmpTerm in self.allTerminals where tmpTerm.licenseName &lt;&gt; null do
					if tmpTerm.canDo(idx) then
						tmpCanDo := true;
						break;
					endif;
				endforeach;
			endif;
		endif;
		
		if tmpCanDo then
			self.setForSysMenu(idx - Mod_BaseView, tmpBin);
		endif;
	endforeach;
	
	self.setPropertyValue('extraInfo', tmpBin);
	self.setConfig( "SUBS", subExpDates, true );

	// ### JIRA 33505 03DEC2024 NAVAB1 if (self.canDo(Mod_EventStream) and
	if (self.canDo(Sub_EventStream) and
		CM_PushEventsRoot.firstInstance() = null) then			//13.03.2024 navnk30 #62361
		app.getSingleton(CM_PushEventsRoot);
	endif;

epilog
	delete licPermAgent;
	delete subsPermAgent;
	delete subExpDates;
end;</source>
    </JadeMethod>
    <JadeMethod name="setUseStableObjects" id="97f395a5-ce52-4523-bd36-d26fb10925ec">
        <updating/>
