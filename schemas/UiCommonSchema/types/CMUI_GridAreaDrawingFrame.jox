    <JadeMethod name="mouseDown" id="4a2a9752-7bae-430e-a7a8-a01dcaaaa4d1">
        <updating/>
        <source>mouseDown(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     28 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
vars

begin

	self.startClickTime := app.actualTimeServer.time;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.longLeftClick := false;
	self.longRightClick := false;
	self.didDBLClick := false;

	inheritMethod(frame, button, shift, x, y);

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseUp" id="2fc39eec-f809-48aa-97a1-15c9b79fc968">
        <updating/>
        <source>mouseUp(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     28 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	startTime, endTime : Time;

begin
	// check for a long click
	startTime := self.startClickTime;
	endTime := app.actualTimeServer.time;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	if (not didDBLClick) then
		if endTime &gt;= (startTime + 650) then
			if button = Button.MouseButton_Left then
				self.longLeftClick := true;
			elseif button = Button.MouseButton_Right then
				self.longRightClick := true;
			endif;
		endif;
	endif;

	inheritMethod(frame, button, shift, x, y);

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
