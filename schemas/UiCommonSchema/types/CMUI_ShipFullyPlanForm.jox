    <JadeMethod name="doQuery" id="874f379a-dff4-45c9-8596-565d195b2670">
        <updating/>
        <source>doQuery() updating;
// ---------------------------------------------------------------------------
// Created:		30 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	cmifMonitor		: CMIF_Monitor;
	tmpHeight, idx : Integer;
	tmpOptionsUsed : IntegerArray;
	now : TimeStamp;
begin
	self.allJobs.removeInvalidObjects();  //par 19267
	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	if self.allJobs.isEmpty then
		app.raiseCMException(ERR_JOBS_EMPTY,null,null);
		return;
	endif;	

	cmifMonitor := app.myPassport.myCMIFMonitor;
	if cmifMonitor = null then
		create cmifMonitor transient;
		cmifMonitor.myParent := self;
		app.myPassport.setMyCMIFMonitor(cmifMonitor);
	endif;

	self.modalDialogReturnValue := self.ModalDialogReturn_Null;	
	self.modalDialogShow(null,'Cancel' , null, null, 'Automatic Load Planning',  'Please Wait....');
	self.pbProgressBar.visible := true;

//	delete self.myController;
	
//	create self.myController transient;
	tmpHeight := self.txtHeight.text.Integer;
	
	self.setOptions();
	
	create tmpOptionsUsed transient;
	
	// ### only use the option that are ticked and pass them to the controller in the prefered order.
	foreach idx in 1 to 4 do
		if self.allValues[idx] then
			tmpOptionsUsed.add(self.allOptions[idx]);
		endif;
	endforeach;
	
	self.setYardAreaFlipped();
	self.myController.init(self.myTerminal, self.mode, self.allJobs, self.myCurrentJS, self.myCurrentVoyage, self.chkNoPlanIfStops.value, tmpOptionsUsed, tmpHeight, 
								self.chkRowEnd.value, self.txtRows.text.Integer, self,  self.chkUseWieights.value, self.txtWeight.text.Integer, self.txtPC.text.Integer,
								self.optCrossTermOne.value, self.optCrossTermCol.value, self.chkIgnoreWarning.value,self.chkTwinPlan.value);
	
	self.myController.doQuery(cmifMonitor);

	self.myController.initQuery();
	self.doDisplayStatus(now);
epilog
	delete cmifMonitor;	
	app.myPassport.setMyCMIFMonitor(null);
	self.frmModalDialog.visible := false;
end;</source>
    </JadeMethod>
