    <JadeMethod name="createCMIFMonitor" id="3bb30fed-ab9f-4326-bc1b-69dce670e864">
        <source>createCMIFMonitor(_passport :CM_Passport input):CMIF_Monitor protected;
// ---------------------------------------------------------------------------
// Created:     04 May 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
//
// This method should be moved somewhere else so it can be used in more places
// Either a superclass form or CM_Passport make sense
vars
	cmifMonitor	:CMIF_Monitor;
begin
	if _passport.myCMIFMonitor = null then
		create cmifMonitor transient;
		cmifMonitor.myParent := self;
		_passport.setMyCMIFMonitor(cmifMonitor);
		
		return cmifMonitor;
	endif;
	// there was already one there assume it is in use and don't replace it or return it
	return null;	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CMIF_Monitor"/>
    </JadeMethod>
