    <JadeMethod name="clearEditControls" id="672a6319-7ee7-4ae4-8022-b0c6ac1eeb92">
        <updating/>
        <source>clearEditControls() protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

begin

	delete self.myProxyObject;	// delete any pre-existing proxy.
	
	self.cmbEventType.listIndex := -1;
	self.txtDate.setDate(null);
	self.txtTime.setTime(null);
	self.grpEventDetail.enabled := false;
	self.grpEvents.enabled := true;
	self.btnNewEvent.enabled := true;
	self.btnEditEvent.enabled := false;
	self.btnDelete.enabled := false;
	self.btnSaveBase.enabled := false;
	
	self.setupCmbCharge(true);
	
	self.tblEvents.selectMode := Table.SelectMode_None;
	
		
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
