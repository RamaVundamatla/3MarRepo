    <JadeMethod name="isCancelEstimateRequired" id="442a6d23-a320-4e95-b076-03db98b48744">
        <source>isCancelEstimateRequired(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Aug 2018  cnwma1	ChangeRequest 39698: PEL1 - SAP Enable SAP interfaces

*/

vars
	cr : CM_CashReceipt;
	result : Boolean;
begin
	if self.allCashReceipts.isEmpty then
		return false;
	endif;
	
	foreach cr in self.allCashReceipts do 
		if cr.paymentStatus = CM_CashReceipt.CREDIT_CHECK_APPROVED then
			result := true;
			continue;
		endif;
		result := false;
	endforeach;
	
	return result;
	
epilog

end;</source>
