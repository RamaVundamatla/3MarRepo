    <JadeMethod name="isGlobalConstantNameUnique" id="2d46c56f-2ae5-4b4a-b749-0b93ee0aa0c2">
        <source>isGlobalConstantNameUnique(_globalConstantName : String; _existingGlobalConstant : GlobalConstant output):Boolean;

// check for duplicate global constant name

vars
	globalConstants 	: ConstantNDict;
	tmpSchema	: Schema;

begin

	tmpSchema := rootSchema.getSchema('UiCommonSchema');
	globalConstants := tmpSchema.getConstants();

	_existingGlobalConstant := globalConstants[_globalConstantName].GlobalConstant;
	return (_existingGlobalConstant = null);

end;</source>
        <Parameter name="_globalConstantName" type="String"/>
        <Parameter name="_existingGlobalConstant" type="GlobalConstant" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="linkOldBinaryToToolbarButton" id="f42d27e4-530c-4931-a3bf-566da646d1dc">
        <source>linkOldBinaryToToolbarButton();

vars
	button : CMUI_ToolbarIcon;
	icon : CMUI_IconFile;
	key : Binary;
begin

	foreach button in self.allToolbarIcons do
	
		// ### ENABLED KEY
		key := button.enabledIconOld.abBinaryKey();
		
		icon := self.allIconFilesByBinary[key];
		
		if icon &lt;&gt; null then
			write "ENA " &amp; button.buttonName &amp; " = " &amp; icon.name;
			
			// ### DISABLED KEY
			key := button.disabledIconOld.abBinaryKey();
			icon := self.allIconFilesByBinary[key];
		
			if icon &lt;&gt; null then
				write "DIS " &amp; button.buttonName &amp; " = " &amp; icon.name;
			endif;


		else
		endif;
	
	endforeach;

end;
</source>
    </JadeMethod>
    <JadeMethod name="populateArrayFromString" id="8e2fa7be-81ec-43a3-ae78-bb5b0f68cf1b">
        <source>populateArrayFromString(pString : String; pStringArray : StringArray input) : Boolean;
// ---------------------------------------------------------------------------
// Created:     11 June 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str		: String;
	pos		: Integer;
	
begin

	// add a final delimiter so scanUntil will pickup last item correctly
	str := pString &amp; Delimiter;

	pStringArray.clear;
	pos := 1;
	while pos &lt;= str.length do
		pStringArray.add(str.scanUntil(Delimiter, pos));
		if pos = 0 then
			break;
		endif;
		pos := pos + 1;
	endwhile;

	if pStringArray.size &lt; 2 then
		return false;
	endif;
	
	return true;

end;</source>
        <Parameter name="pString" type="String"/>
        <Parameter name="pStringArray" type="StringArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateNewIconsFromDisk" id="0cc39fa1-3d70-48de-a68b-d1458d1f3698">
        <source>populateNewIconsFromDisk();
constants
	CATERGORY = "CMUI_Icons";
vars


	folder : FileFolder;
	fileNode : FileNode;
	file : File;
	localfiles : FileNodeArray;
	bin : Binary;
	icon : CMUI_IconFile;
	newName : String;
		constantName 	: String;
	globalConstant	: GlobalConstant;
	triedJadloadb	: Boolean;
	commandLine		: String;
	result			: Integer;
	proxy 			: XLAT_TranslationsAndGCProxy; 
	constantStr		: String;

begin

//	self.purgeDiskIconCollection(2021);
	
	create folder;
	folder.mask := "*.png";

	
//	folder.fileName := "C:\NewIcons\MTN2021IconsEnabled";
	folder.fileName := "C:\Users\navab1\Downloads\AdditionalIcons";
	
	localfiles := folder.files();
	
	foreach fileNode in localfiles do
	
		file := fileNode.File;
		file.kind := File.Kind_Binary;
		file.openInput(file.fileName);
		bin := file.readBinary(file.fileLength);
 
		newName := "ICON2021_" &amp; file.name.removeInvalidChars();
		
		if self.allIconFilesByName[newName] = null then
		
			
			beginTransaction;
			create icon;
			icon.setForCreate(self, file.name, newName, bin, 2021, newName.Binary);
			commitTransaction;
			
		else
			write "Update? " &amp; newName;
		endif;	


	endforeach;
	
	
	//folder.fileName := "C:\NewIcons\MTN2021IconsDisabled";
	folder.fileName := "C:\Users\navab1\Downloads\AdditionalIcons-Disabled";

	localfiles := folder.files();
	
	foreach fileNode in localfiles do
	
		file := fileNode.File;
		file.kind := File.Kind_Binary;
		file.openInput(file.fileName);
		bin := file.readBinary(file.fileLength);
 
		newName := "ICON2021_" &amp; file.name.removeInvalidChars() &amp; "_dis";
		
		if self.allIconFilesByName[newName] = null then
		
			
			beginTransaction;
			create icon;
			icon.setForCreate(self, file.name &amp; "_dis", newName, bin, 2021, newName.Binary);
			commitTransaction;
			
		else
			write "Update? " &amp; newName;
		endif;	


	endforeach;	
epilog

//	delete localfiles;
//	delete folder;

end;


</source>
    </JadeMethod>
    <JadeMethod name="populateOldIconsFromDisk" id="cfb9639b-638a-4b60-82c1-0e432d0b90a8">
        <source>populateOldIconsFromDisk();

vars


	folder : FileFolder;
	fileNode : FileNode;
	file : File;
	localfiles : FileNodeArray;
	bin, key : Binary;
	icon : CMUI_IconFile;
	newName : String;
begin


	self.purgeDiskIconCollection(2002);
	
	
	
	
	
	create folder;
//	folder.fileName := "F:\TeamStuff\AndrewBishop\JMT\Jade2020NewSkin\OLD\SomeOldIcons";
	folder.fileName := "F:\Documentation\Internal\Resources\Graphics\JMTIcons\16x16_icons";
	folder.mask := "*.ico";

	localfiles := folder.files();
	
	foreach fileNode in localfiles do
	
		file := fileNode.File;
		file.kind := File.Kind_Binary;
		file.openInput(file.fileName);
		bin := file.readBinary(file.fileLength);
 
		newName := "OLD2002_" &amp; file.name.removeInvalidChars();
		
		if self.allIconFilesByName[newName] = null then
		
		
			key := bin.abBinaryKey();
			
			icon := self.allIconFilesByBinary[key];
			if icon = null then
		
	
			
				beginTransaction;
				create icon;
				icon.setForCreate(self, file.name, newName, bin, 2002, key);
				commitTransaction;
			
			else
				 key := "ODD".Binary &amp; key;
				icon := self.allIconFilesByBinary[key];
				if icon = null then
	
			
					beginTransaction;
					create icon;
					icon.setForCreate(self, file.name, newName, bin, 2002, key);
					commitTransaction;
				else

					write "SAME ICON BINARY! - "  &amp; newName &amp; " as " &amp; file.name;
				endif;
			endif;
			
		else
			write "Update? " &amp; newName;
		endif;	

//		write newName;
	endforeach;
	
	
	
	
epilog


end;


</source>
    </JadeMethod>
    <JadeMethod name="populateToolbarIcons" id="158e849a-df2f-47ca-9b1a-5fcacebee612">
        <updating/>
        <source>populateToolbarIcons() updating;

vars
	root : CMUI_Root;
	toolbarButton : CMUI_ButtonForToolbar;
	idx : Integer;
	iter01 : Iterator;
	oArray : ObjectArray; 
	schemaName, uniqueName : String;
	iconButton : CMUI_ToolbarIcon;
begin

	beginTransaction;
	self.allToolbarIcons.purge;
	
	commitTransaction;


	create oArray transient;
	CMUI_ButtonForToolbar.allInstances(oArray,0,false);
	iter01 := oArray.createIterator;
	
	while iter01.next(toolbarButton) do
	

		schemaName := toolbarButton.form.name[1:toolbarButton.form.name.pos("_",1)] &amp; "Schema";
	
		uniqueName := toolbarButton.form.name &amp; "/" &amp; toolbarButton.name;
	
		write schemaName &amp; "," &amp; toolbarButton.form.name &amp; "," &amp; toolbarButton.name &amp; "," &amp; toolbarButton.caption &amp; "," &amp; toolbarButton.form.name;
		
		if self.allToolbarIcons[schemaName,toolbarButton.form.name,toolbarButton.name] = null then
		
		beginTransaction;
			create iconButton;
			iconButton.schema := schemaName;
			iconButton.formName := toolbarButton.form.name;
			iconButton.buttonName := toolbarButton.name;
			iconButton.myRoot := self;
			iconButton.myToolbarButton := toolbarButton;
			iconButton.caption:= toolbarButton.caption;
			iconButton.iconNameUI := uniqueName;
			iconButton.disabledIconNew := null;
			iconButton.disabledIconOld := toolbarButton.pictureDisabled;
			iconButton.enabledIconNew := null;
			iconButton.enabledIconOld := toolbarButton.picture;
			commitTransaction;
		
		else
		
		endif;

	endwhile;
	
epilog

delete oArray;
end;
</source>
    </JadeMethod>
    <JadeMethod name="populateToolbarIconsForForm" id="6d39fc50-97ed-4acb-839c-b0a2f99be294">
        <updating/>
        <source>populateToolbarIconsForForm(_form : Form) updating;

vars
	root : CMUI_Root;
//	toolbarButton : CMUI_ButtonForToolbar;
	idx : Integer;
	iter01 : Iterator;
	oArray : ObjectArray; 
	obj : Object;
	schemaName, uniqueName : String;
	iconButton : CMUI_ToolbarIcon;
	numControls,
	int:	Integer;
	ctl:	Control;
begin


	beginTransaction;
	self.allToolbarIconsSub.purge;
	
	commitTransaction;

	root := CMUI_Root.firstInstance;
	
	create oArray transient;

	
	numControls := _form.controlCount;
	int := 1;
	while int &lt;= numControls do
		ctl := _form.controls(int);
		
//		write ctl.name;
		if ctl.isKindOf(Picture) then
//			int := int+1;
			oArray.add(ctl);
		endif;
		int := int+1;
	endwhile;

	
	iter01 := oArray.createIterator;
	
	oArray.inspectModal;
	
	while iter01.next(obj) do
	

		schemaName := _form.name[1:_form.name.pos("_",1)] &amp; "Schema";
	
		uniqueName := _form.name &amp; "/" &amp; obj.String;
	
//		write schemaName &amp; "," &amp; toolbarButton.form.name &amp; "," &amp; toolbarButton.name &amp; "," &amp; toolbarButton.caption &amp; "," &amp; toolbarButton.form.name;
		
		if self.allToolbarIconsSub[schemaName,_form.name,uniqueName] = null then
		
			beginTransaction;
			create iconButton;
			iconButton.schema := schemaName;
			iconButton.formName := _form.name;
			iconButton.buttonName := uniqueName;
//			iconButton.myRoot := self;
			iconButton.myToolbarButton := null;
			iconButton.caption:= obj.Picture.name;
			iconButton.iconNameUI := uniqueName;
			iconButton.disabledIconNew := obj.Picture.picture;
			iconButton.disabledIconOld := obj.Picture.picture; // toolbarButton.pictureDisabled;
			iconButton.enabledIconNew := obj.Picture.picture;
			iconButton.enabledIconOld := obj.Picture.picture; //toolbarButton.picture;
			
			root.allToolbarIconsSub.add(iconButton);
			commitTransaction;
		
		else
		
		endif;

	endwhile;
	
epilog

delete oArray;
end;
</source>
        <Parameter name="_form" type="Form"/>
    </JadeMethod>
    <JadeMethod name="purgeDiskIconCollection" id="1b991025-f7ff-4c35-abe1-8246803582b8">
        <source>purgeDiskIconCollection(_year : Integer);
/*
Purpose:			

Date		Who		Reason
06 August 2021	navab1	TFS 50669
*/
vars
	oArray : ObjectArray; 
	icon : CMUI_IconFile;
begin

	create oArray transient;
	CMUI_IconFile.allInstances(oArray,0,false);
	
	foreach icon in oArray as CMUI_IconFile do
	
		if icon.year &lt;&gt; _year then
			continue;
		endif;
		
		beginTransaction;
		delete icon;
	
		commitTransaction;

	endforeach;
	

end;




</source>
        <Parameter name="_year" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateToolbarButtonWithNewIcon" id="df9b866b-3205-472a-9d54-7c08f7148748">
        <source>updateToolbarButtonWithNewIcon();
/*
Purpose:			

Date		Who		Reason
28 September 2021	navab1	TFS 51853
*/

vars
	button : CMUI_ToolbarIcon;
	
begin
	foreach button in self.allToolbarIcons do
		if not global.isValidObject( button.myToolbarButton) then
			continue;
		endif;
		
		if button.enabledIconNew &lt;&gt; null then
			beginTransaction;
			button.myToolbarButton.setPropertyValue("picture",button.enabledIconNew);
			button.myToolbarButton.setPropertyValue("pictureDisabled",button.disabledIconNew);
			button.myToolbarButton.setPropertyValue("pictureDown",button.enabledIconNew);
			
			commitTransaction;
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
