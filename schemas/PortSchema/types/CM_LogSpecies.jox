    <JadeMethod name="getDetailForRemoteQuery" id="1108b545-0f42-48b6-b7c8-4800e7809401">
        <source>getDetailForRemoteQuery(_version : Integer) : String;

// cnwdvb1 10 June 2003 
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars

	iter 	: Iterator;
	grade	: CM_LogGrade;
	detail 	: String;

begin

	if self.notAvailableForEntry then
		return null;
	endif;
	
	iter := self.allLogGrades.createIterator;
	while iter.next(grade) do
		if _version &lt; 3 then
			detail := detail &amp; grade.getDetailForRemoteQuery();
		else
			detail := detail &amp; grade.getDetailForRemoteQueryV3();
		endif;
	endwhile;
	return detail;
epilog
	delete iter;
end;</source>
        <Parameter name="_version" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getProductsForGrdeTypTreatLen" id="2ab5057d-cf62-46d5-8a42-976f0b0cac83">
        <source>getProductsForGrdeTypTreatLen(_operator : CM_Operator; _gradeCode, _typeCode, _treatCode, _lengthCode : String; _productSet : CM_ProductSet input);
// ---------------------------------------------------------------------------
// Created:     30 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	logGrade	: CM_LogGrade;
	product		: CM_Product;
begin

	if _operator = null and
	   _gradeCode = null and
	   _typeCode = null and
	   _treatCode = null and
	   _lengthCode = null then
	   	self.allProducts.copy(_productSet);
	   	return;
	endif;
	
	logGrade := self.allLogGrades[_gradeCode].CM_LogGrade;
	if logGrade &lt;&gt; null then
		logGrade.getProductsForTypeTreatLength(_operator, _typeCode, _treatCode, _lengthCode, _productSet);
	elseif _operator &lt;&gt; null then
		foreach product in self.allProducts do
			if product.myOperator = _operator then
				_productSet.add(product);
			endif;
		endforeach;	
	endif;

end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_gradeCode" type="String"/>
        <Parameter name="_typeCode" type="String"/>
        <Parameter name="_treatCode" type="String"/>
        <Parameter name="_lengthCode" type="String"/>
        <Parameter name="_productSet" type="CM_ProductSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="maxCodeLength" id="47a9a71e-8172-47cf-b2e1-8c341b83bd33">
        <source>maxCodeLength(): Integer;
// ---------------------------------------------------------------------------
// Created:     18 March 2005	cnwhjg1
//
// Purpose:     PAR9839
// ----------   ----------  --------------------------------------------------
vars

begin
// as on CM_Log
	return 6;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="33005b9b-b991-4429-a827-41d442e63444">
        <updating/>
        <source>setProxy(pCode, pDescription:String; _notAvailableForEntry:Boolean;pCodeGroup : CM_CodeGroup)updating;
//--------------------------------------------------------------
//Created: 09 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	self.setSuperClassDetailsForProxy(pCode, pDescription, _notAvailableForEntry,pCodeGroup);

end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pDescription" type="String"/>
        <Parameter name="_notAvailableForEntry" type="Boolean"/>
        <Parameter name="pCodeGroup" type="CM_CodeGroup"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="7344c3e1-3325-4c85-85ca-b83ad778f40d">
        <source>validateForDelete();
//--------------------------------------------------------------
//Created: 09 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if self.allLogGrades.size &gt; 0 then
		app.raiseCMException2(ObjectStillHasEntries, self.code, "Log", null, null);
	endif;

	if (not self.allProducts.isEmpty) then
		app.raiseCMException2(ObjectStillHasEntries, 'Log Species ' &amp; self.code, 
							  self.allProducts.size.String &amp;' '&amp; app.getErrorString(Cargo_subtype_data), null, null);
	endif;

end;</source>
    </JadeMethod>
</Class>
