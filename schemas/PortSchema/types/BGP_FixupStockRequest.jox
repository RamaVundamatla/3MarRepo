<Class name="BGP_FixupStockRequest" id="02a69617-a204-4f41-a09a-8e70835e2818">
    <superclass name="BGP_Request"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Fixup Stock&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <JadeMethod name="action" id="97ff2d21-d3e5-4a24-8c6e-1d0a7c29bbaa">
        <updating/>
        <source>action(): Boolean updating;

// cnwdvb1 20 May 2003 
vars

	errCode	: Integer;
	errTxt	: String;
begin

	on Exception do app.alertExceptionHandler(exception, null, self.getErrorDesc(), errCode, errTxt, true, true);
	on LockException do app.alertLockExceptionHandler(exception);
	
	self.fixupStock();

epilog
	if errCode &lt;&gt; null then
		app.myTrxUA.trxUpdateBGPRequest(self, true, errCode, errTxt, app.myPassport);
	else
		app.createActivityHistory(ActivityHistoryGeneral, self.myTerminal, null, app.getErrorString1(Successfully_Fixed_Up_Stock, self.myTerminal.code), false, false);
	endif;
	inheritMethod();
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="fixupStock" id="560db304-c459-4b27-9c3a-4fa262999a58">
        <updating/>
        <source>fixupStock() protected, updating;

// cnwdvb1 20 May 2003 

vars

	comment		: String;
	
begin

	self.setUser();
	if self.myTerminal = null then
		app.raiseCMException1(BackgroundErrorGeneral, 'Unable to locate terminal', null, null);
	endif;
		
	app.myPassport.setMyTerminal(self.myTerminal);
	app.myPassport.warningsAcknowledged := true;
	
	comment := 'Data Fix.';
	
	app.myTrxUA.trxFixupStockOnHandTerminal(self.myTerminal, comment, null, app.myPassport);
			
	if (not app.myPassport.trxCompletedOK) then
		app.remoteErrorWarningToAlert('Unable to fixup stock movements',null, app.myPassport.allErrors, null, true, true);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="8f277722-2198-452c-982a-8f1c322d66ef">
        <source>getDisplay(): String;

// cnwdvb1 20 May 2003 

vars

begin
	return inheritMethod() &amp; Tab &amp; 'Terminal ' &amp; self.myTerminal.code;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
