<Class name="CM_StateDecimal" id="2c5426f8-c6c9-4014-aafd-78aa360c96dd">
    <superclass name="CM_StateData"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmstate"/>
    <PrimAttribute name="value" id="0ccce50b-9054-4988-8789-d82bdd85f20e">
        <precision>16</precision>
        <scaleFactor>2</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getValue" id="a50e6e6d-4e8b-4ca8-bf79-633af0cfff09">
        <source>getValue(): Any;
// ---------------------------------------------------------------------------
// Created:     23 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

begin
	return self.value;

end;</source>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="setValue" id="709c90c4-d2ca-4cd7-95bf-83314933b5bf">
        <updating/>
        <source>setValue(pValue: Any) updating;
// ---------------------------------------------------------------------------
// Created:     21 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpValue	: Decimal[16,2];
	
begin

	tmpValue := pValue.Decimal;
	if self.value &lt;&gt; tmpValue then
		self.value := tmpValue;
	endif;
	
end;</source>
        <Parameter name="pValue" type="Any"/>
    </JadeMethod>
</Class>
