<Class name="CM_QIntegerMethod" id="0020b73f-321d-434f-87b6-1c3cb2170445">
    <superclass name="CM_QueryMethod"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="0513b08a-50fd-4088-a8fb-539f9836604a">
        <updating/>
        <source>create() updating;
/*
----------   ----------  --------------------------------------------------
Created:	06 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	oper	: CM_QueryOperator;
	
begin
	if self.isTransient then 
		return;
	endif;
	
	create oper as CM_QIntegerEquals persistent;
	self.allAllowedOperators.add(oper);

	create oper as CM_QIntegerGreaterThan persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QIntegerLessThan persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QIntegerLessThanEquals persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QIntegerGreaterEquals persistent;
	self.allAllowedOperators.add(oper);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="getKeyLengthForXTABDictionary" id="72b83da2-6be1-4a61-91e6-8aa0ccaf195f">
        <source>getKeyLengthForXTABDictionary(): Integer;
// ---------------------------------------------------------------------------
// Created:     04 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return (Max_Integer * -1).String.length;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
