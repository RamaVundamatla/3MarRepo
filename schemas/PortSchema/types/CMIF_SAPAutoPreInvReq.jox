    </PrimAttribute>
    <JadeMethod name="copyToRealWSObject" id="671b73f0-8a12-40a1-adbf-d4f2bc751e92">
        <source>copyToRealWSObject(_realRequest: SAP12_AutocollPreInvoiceNewRequest_DT input;
				   _createdObjects : ObjectSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	estimation		: CMIF_SAPAutoPreInvEstimation;
	preInvoice		: CMIF_SAPAutoPreInvItem;
	realEstimation	: SAP12_AutocollPreInvoiceNewRequest_DT_T_Estimation_Item;
	realPreInvoice	: SAP12_AutocollPreInvoiceNewRequest_DT_T_PreInvoice_Item;
	
begin
	inheritMethod(_realRequest, _createdObjects);
	
	_realRequest.currency := self.currency;
	_realRequest.customerNo := self.customerNo;
	_realRequest.profitCenter := self.profitCenter;
	
	// manual population of t_Estimation required
	create _realRequest.t_Estimation transient;
	_createdObjects.add(_realRequest.t_Estimation);
	foreach estimation in self.allEstimation do
		create realEstimation transient;
		_createdObjects.add(realEstimation);
		estimation.copyToRealWSObject(realEstimation, _createdObjects);
		_realRequest.t_Estimation.item.add(realEstimation);
	endforeach;
	
	// manual population of t_PreInvoice required
	create _realRequest.t_PreInvoice transient;
	_createdObjects.add(_realRequest.t_PreInvoice);
	foreach preInvoice in self.allPreInvoice do
		create realPreInvoice transient;
		_createdObjects.add(realPreInvoice);
		preInvoice.copyToRealWSObject(realPreInvoice, _createdObjects);
		_realRequest.t_PreInvoice.item.add(realPreInvoice);
	endforeach;

epilog

end;</source>
        <Parameter name="_realRequest" type="SAP12_AutocollPreInvoiceNewRequest_DT" usage="input"/>
        <Parameter name="_createdObjects" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="copyToSAPAutoPreInvReq" id="bd7f3e27-9e2a-4e35-8b95-508288bd59ff">
        <updating/>
        <source>copyToSAPAutoPreInvReq(_invoice : CM_Invoice)updating;
/*

Purpose:			
	37189.004 Send Release Hold and Debit for Auto-Collection Customer
	WSDL 1.2: Auto-Collection - Release Hold/Debit
	PaymentType_AutoCollection
Parameters:			

Return Value:		

Date		Who		Reason
29 Jun 2018 cnwma1	ChangeRequest 39405: PEL1 - SAP Release Hold
06 Oct 2018 cnwma1  ChangeRequest 41132: PEL1 - SAP Integration : Additional Changes
03 Jan 2019 cnwma1	Bug 42441: PEL1 - Missing Estimation ID WSDL 1.2 - Autocollection
23 Jan 2019	cnwma1	ChangeRequest 42942: PEL1 - Container Services - SAP Process
14 Mar 2019 cnwma1	Bug 43549: PEL1 - SAP - Estimation IDs link to Invoice WSDL 1.2
23 Jan 2019	cnwma1	ChangeRequest 42942: PEL1 - Container Services - SAP Process
*/

vars
	estimationItem	: CMIF_SAPAutoPreInvEstimation;
	preInvItem      : CMIF_SAPAutoPreInvItem;
	estimationID    : String;
	invLine			: CM_InvoiceLine;
	strArr          : StringArray;
	estID           : String;
	lineTot,invTot 	: Decimal[23,6];
	taxCode         : String;
	cashRecMatched  : ObjectArray;
	obj             : Object;
begin
	
	self.customerNo 	:= self.sapHelper(_invoice,"customerNo");
	self.profitCenter 	:= self.sapHelper(_invoice,"profitCenter"); //Berth or MovmentBerth [externalRefrence1]
	self.currency       := self.sapHelper(_invoice,"currency");
	
	//03.01.2019 cnwma1 Bug #42441
	create cashRecMatched transient;
	_invoice.findCashReceipts(cashRecMatched);
	if cashRecMatched.size &gt; 0 then
		foreach obj in cashRecMatched do 
			
			/*
				14.03.2019 cnwma1 #43549
				Estimation ID assigned to an Auto-collection Invoice, 
				should only take the Estimation ID which Cash Receipt status is still Approved (not Paid).  
			*/
			if obj.CM_CashReceipt.paymentStatus &lt;&gt; CM_CashReceipt.CREDIT_CHECK_APPROVED then
				continue;
			endif;			
				
			create estimationItem transient;
			estimationItem.estimationID := obj.CM_CashReceipt.externalInvoiceNumber; 		 					
			self.allEstimation.add(estimationItem);
		endforeach;
	else
		create estimationItem transient;
		estimationItem.estimationID := Space; 		 					
		self.allEstimation.add(estimationItem);
	endif;
	//03.01.2019 cnwma1 Bug #42441

	create preInvItem transient;
	preInvItem.preInvoiceID 	:= self.sapHelper(_invoice,"preInvoiceID");  
	preInvItem.amount           := self.sapHelper(_invoice,"getTotalAmtDocCurAR"); //23.01.2019 cnwma1 TFS #42942
	self.allPreInvoice.add(preInvItem);
	
epilog
	delete cashRecMatched;
end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="delete" id="b29edb00-adda-463b-b05d-fb2046681026">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 June 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars

begin
	self.allEstimation.purge();
	self.allPreInvoice.purge();
	
epilog

end;</source>
    </JadeMethod>
