    <JadeMethod name="getUserList" id="4b715aaf-301e-416e-9f76-29d3e82f030c">
        <source>getUserList():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 September 2009	cnwndl1	Initial creation	CCMS 1609 Par 20521

*/

vars

	user : CM_User;
	isFirst : Boolean;
	retValue : String;
	
begin

	isFirst := true;
	foreach user in self.allUsers do
		if isFirst then
			isFirst := false;
			retValue := user.code;
			continue;
		endif;
		retValue := retValue &amp; ", " &amp; user.code;
	endforeach;
	
	return retValue;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
