    <JadeMethod name="translateForm" id="b3b17e06-d855-4658-a878-646db6680812">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 January 2026 10:34:48.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0027152, locale);
	btnClose.translateCaption(Xlat_0027153, locale);
	btnSave.translateCaption(Xlat_0027154, locale);
	lblExtFinID.translateCaption(Xlat_0027155, locale);
	lblExternalNumber.translateCaption(Xlat_0027156, locale);
	lblExternalTaxNumber.translateCaption(Xlat_0027157, locale);
	lblInvoiceID.translateCaption(Xlat_0027158, locale);
	lblInvoiceLines.translateCaption(Xlat_0027159, locale);
	lblTotal.translateCaption(Xlat_0027160, locale);
	mnuColOrganiser.translateCaption(Xlat_0027161, locale);
	mnuInspectObject.translateCaption(Xlat_0027162, locale);
	mnuInvLineContext.translateCaption(Xlat_0027163, locale);
