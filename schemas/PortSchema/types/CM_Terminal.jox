    <JadeMethod name="setForUpdate" id="3b55829b-511f-4b73-b0f1-171d861b068d">
        <updating/>
        <source>setForUpdate(_proxy :CM_Terminal) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 31/10/2008	consw1		SFW1030 - Rework of Yard Allocations
// 28/11/2012	cnwkpd1		PAR #29274 - remove unnecessary locking on Root collection
// 15/04/2013	cnwcs5		CCMS POL 2097 / par 31259
// 07/07/2017	cnwdap1		TFS 4492 SNO VERMAS Changes
// 12/06/2023	navdap1		TFS 56747 EUP Manifest Load - Internal (Zimmer) - Create
// 13/09/2023	jlizm1		TFS 59985 Truck Seals design changes
// 01/08/2025   navsp1      JIRA-35530 Solution Implementation - COPRAR Trailer Support
// ---------------------------------------------------------------------------
vars
	tmpTime				 : Time;
	newCode			     : String;
	prenoteCriteria 	 : CM_TermPrenoteWeightCriteria;
	weighAuthTerminal, 										// TFS 4492
	newWeighAuthTerminal : CM_WeighAuthTerminal;			// TFS 4492
	weighAuth 		     : CM_WeighAuthority;				// TFS 4492
begin
	tmpTime := self.creationTime.localToUTCTime().Time;
	
	if self.permValue &lt;&gt; ((tmpTime.hour * tmpTime.minute) + tmpTime.second + 42) then
		app.raiseCMException(Invalid_action, null, null);
		return;
	endif;

	// PAR #29274 - check to see if code has actually changed
	newCode := _proxy.code.trimBlanks();
	
	if self.code &lt;&gt; newCode then
		// par 31259 - make sure xlations updated with new code
		self.updateXlations_Code (newCode, self.code, self.allXlations);
	
		self.code	:=	newCode;
	endif;
	
	self.name	:=	_proxy.name.trimBlanks();
	
	self.allCargoBOLTypes.clear();
	_proxy.allCargoBOLTypes.copy(self.allCargoBOLTypes);
	
	
	self.defaultCargoBolType	:=	_proxy.defaultCargoBolType;
	self.defaultCargoType		:=	_proxy.defaultCargoType;
	self.defaultBolType			:=	_proxy.defaultBolType;
	self.defaultCargoGroupType	:= _proxy.defaultCargoGroupType;		// TFS 56747
    self.defaultTrailerCargoType:= _proxy.defaultTrailerCargoType;      //JIRA-35530
	
	if not self.isTransient then	//13 Jul 2010	NDL Par 24973
		self.createSystemEquipmentChecks();
	endif;
	
	//+cnwml2 PAR23715 SFW CCMS1131
	self.sealCheckRailReceival	:= _proxy.sealCheckRailReceival;
	self.sealCheckRailRelease	:= _proxy.sealCheckRailRelease;
	self.sealCheckRoadReceival	:= _proxy.sealCheckRoadReceival;
	self.sealCheckRoadRelease	:= _proxy.sealCheckRoadRelease;
	self.sealCheckShipReceival	:= _proxy.sealCheckShipReceival;
	self.sealCheckShipRelease	:= _proxy.sealCheckShipRelease;
	self.sealCheckPack			:= _proxy.sealCheckPack;	//04 Jul 2011	NDL	Par 26476
	self.sealCheckUnpack		:= _proxy.sealCheckUnpack;	//04 Jul 2011	NDL	Par 26476
	self.sealCheckWagonLoad		:= _proxy.sealCheckWagonLoad;	//10 Mar 2015	NDL	Par 35828
	self.sealCheckWagonDischarge	:= _proxy.sealCheckWagonDischarge;	//10 Mar 2015	NDL	Par 35828
	self.sealCheckTruckLoad		:= _proxy.sealCheckTruckLoad;			// TFS59985
	self.sealCheckTruckDischarge	:= _proxy.sealCheckTruckDischarge;	// TFS59985
	self.timeZoneID				:= _proxy.timeZoneID;
	self.timeZoneShortID		:= _proxy.timeZoneShortID;
	
	//epr TFS 1882 17/5/16
	if self.myPrenoteWeightCriteria = null then
		create prenoteCriteria persistent;	
		prenoteCriteria.setMyTerminal(self);
	endif;
	
	self.myPrenoteWeightCriteria.setForUpdate(_proxy.myPrenoteWeightCriteria);	
	
	weighAuthTerminal := _proxy.allWeighAuthTerminals.first;										// TFS 4492
	if weighAuthTerminal &lt;&gt; null then 																// TFS 4492
		// adding a weigh authority 																// TFS 4492
		if self.allWeighAuthTerminals[weighAuthTerminal.myWeighAuthority] = null then				// TFS 4492
			create newWeighAuthTerminal persistent;													// TFS 4492
			newWeighAuthTerminal.setForCreate(true, weighAuthTerminal.myWeighAuthority, self);		// TFS 4492
		else																						// TFS 4492
			// updating a weigh authority															// TFS 4492
			newWeighAuthTerminal := self.allWeighAuthTerminals[weighAuthTerminal.myWeighAuthority];	// TFS 4492
			if newWeighAuthTerminal &lt;&gt; null then													// TFS 4492
				newWeighAuthTerminal.setIsDefaultForTerminal(true);									// TFS 4492
			endif;																					// TFS 4492
		endif;																						// TFS 4492
	endif;																							// TFS 4492
	
end;</source>
        <Parameter name="_proxy" type="CM_Terminal"/>
    </JadeMethod>
