    <JadeMethod name="tranMapLoadCash" id="73d73a7b-8dc8-49ff-99ed-a6645d111dfc">
        <source>tranMapLoadCash();
// load transaction map for cash modue test
vars
	fileContent : String;
	fileName	: String;
	mapName		: String;
	bank		: CM_Bank;
	cargoMap	: CM_TranMap;

begin
	fileName := "CashTest";
	mapName := "CashTest";

	fileContent := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,RORO?,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?' &amp; CrLf &amp;
				'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),All,VOID' &amp; CrLf &amp;
				'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),(Default),Edited,,(Default),(Default) ›,(Default),All,VOID' &amp; CrLf &amp;
				'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),(Default),Edited,,(Default),(Default) ›,(Default),All,Extra Services' &amp; CrLf &amp;
				'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),(Default),Information.,,(Default),(Default) ›,(Default),All,VOID' &amp; CrLf &amp;
				'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),(Default),Information.,,(Default),(Default) ›,(Default),All,Extra Services' &amp; CrLf &amp;
				'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),(Default),Sealed,,(Default),(Default) ›,(Default),All,VOID' &amp; CrLf &amp;
				'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),(Default),Sealed,,(Default),(Default) ›,(Default),All,Extra Services' &amp; CrLf &amp;
				'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),(Default),Washed,,(Default),(Default) ›,(Default),All,VOID' &amp; CrLf &amp;
				'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),(Default),Washed,,(Default),(Default) ›,(Default),All,Extra Services' &amp; CrLf &amp;
				'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),(Default),Storage,,(Default),CCT06 Days Since Receival ›,(Default),All,VOID' &amp; CrLf &amp;
				'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),(Default),Storage,,(Default),CCT06 Days Since Receival ›,(Default),All,UT_LineTypeStore1' &amp; CrLf;
	
	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();
	
	bank := app.myPassport.myTerminal.getDefaultCompanyBank();
	cargoMap := bank.myCurrentTranMapCargo[mapName];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");

	app.myTrxUA.trxUpdateBankTMActive(cargoMap, app.myPassport);

epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="tranMapLoadCashEscStorage" id="15c71a11-8a26-4f24-93ff-ea610648c478">
        <source>tranMapLoadCashEscStorage();
// QRM is Full Escalating
vars
	fileContent : String;
	fileName	: String;
	mapName		: String;
	bank		: CM_Bank;
	cargoMap	: CM_TranMap;

begin
	fileName := "CashEsc1";
	mapName := "UT_CashEsc1";
	fileContent := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,RORO?,Is 45?,Is 30?,Is 53?,Is Child?' &amp; CrLf &amp;
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Storage,(Default),(Default),Storage,,(Default),CCT06 Days Since Receival +,01 to 15,VOID' &amp; CrLf &amp; 
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Storage,(Default),(Default),Storage,,(Default),CCT06 Days Since Receival +,16 to 21,UT_LTStore1' &amp; CrLf &amp; 
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Storage,(Default),(Default),Storage,,(Default),CCT06 Days Since Receival +,22 to 28,UT_LTStore2' &amp; CrLf &amp; 
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Storage,(Default),(Default),Storage,,(Default),CCT06 Days Since Receival +,29 to 35,UT_LTStore3' &amp; CrLf &amp; 
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Storage,(Default),(Default),Storage,,(Default),CCT06 Days Since Receival +,36 to 42,UT_LTStore4' &amp; CrLf &amp; 
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Storage,(Default),(Default),Storage,,(Default),CCT06 Days Since Receival +,43 to 49,UT_LTStore5' &amp; CrLf &amp; 
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Storage,(Default),(Default),Storage,,(Default),CCT06 Days Since Receival +,50 to MAX,UT_LTStore6' &amp; CrLf;

	// DELETE TRAN MAP
	bank := app.myPassport.myTerminal.getDefaultCompanyBank();
	cargoMap := bank.myCurrentTranMapCargo[mapName];
 	if cargoMap &lt;&gt; null then
		app.myTrxDA.trxDeleteInvoiceTranMap(cargoMap, app.myPassport);
	endif;
	
	// CREATE TRAN MAP
	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();
	
	bank := app.myPassport.myTerminal.getDefaultCompanyBank();
	cargoMap := bank.myCurrentTranMapCargo[mapName];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");

	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);

epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="tranMapLoadCashFull" id="fad90fd5-d748-4b01-886a-0fbec6ff9c05">
        <source>tranMapLoadCashFull();
// load transaction map for cash module full, charges receive to operator and move/release/storage to consignee/customs agent
vars
	fileContent : String;
	fileName	: String;
	mapName		: String;
	bank		: CM_Bank;
	cargoMap	: CM_TranMap;

begin
	fileName := "CashAgent";
	mapName := "CashAgent";

	fileContent := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,RORO?,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?' &amp; CrLf &amp;
					'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),All,VOID' &amp; CrLf &amp;
					'Cargo,'&amp;mapName&amp;',CONT ISO Container,(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),All,VOID' &amp; CrLf &amp;
					'Cargo,'&amp;mapName&amp;',CONT ISO Container,(Default),(Default),Import,(Default),(Default),(Default),,(Default),(Default) ›,(Default),All,VOID' &amp; CrLf &amp;
					'Cargo,'&amp;mapName&amp;',CONT ISO Container,(Default),(Default),Import,FCL,(Default),(Default),,(Default),(Default) ›,(Default),All,VOID' &amp; CrLf &amp;
					'Cargo,'&amp;mapName&amp;',CONT ISO Container,(Default),(Default),Import,FCL,(Default),Released - Road,,(Default),(Default) ›,(Default),All,UT_ILT9' &amp; CrLf &amp;
					'Cargo,'&amp;mapName&amp;',CONT ISO Container,(Default),(Default),Import,FCL,(Default),Received,,(Default),(Default) ›,(Default),All,UT_ILT8' &amp; CrLf &amp;
					'Cargo,'&amp;mapName&amp;',CONT ISO Container,(Default),(Default),Import,FCL,(Default),Storage,,(Default),CCT06 Days Since Receival ›,0 to 1,All,VOID' &amp; CrLf &amp;
					'Cargo,'&amp;mapName&amp;',CONT ISO Container,(Default),(Default),Import,FCL,(Default),Storage,,(Default),CCT06 Days Since Receival ›,2 to MAX,All,UT_ILT10' &amp; CrLf &amp;
