    <PrimAttribute name="initiaingUserCode" id="247be34d-c66e-4886-80f3-d6df3f1db155">
        <length>11</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="initiaingUserName" id="542c7ac5-0ea5-43cb-9dd1-90c6a7989660">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="mode" id="f96f80ee-ed83-4268-ab93-59cfcc5c2204">
        <length>41</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <ImplicitInverseRef name="myInvoice" id="0f6cd116-4a8a-47c0-9217-19f876e5cde2">
        <embedded/>
        <type name="CM_Invoice"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="sharedDirectory" id="a997cc51-fd07-4792-9c47-eb4dd5f542f8">
