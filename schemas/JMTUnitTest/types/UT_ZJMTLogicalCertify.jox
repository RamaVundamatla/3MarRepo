epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="userNotification" id="978c62e3-8236-4a32-9b76-4035153c845d">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*

Purpose:			Attempt to handle SMTP connection issues a bit better.
					Used by self.xSendEmail()

Parameters:			

Return Value:		

Date				Who		Reason
28 April 2025		navmd1	Initial creation

*/

vars
	smtp	: CnSmtpConnection;
begin
	
	if eventType = CnSmtpConnection.Completion_Event_Type then
		smtp := theObject.CnSmtpConnection;
		if smtp.result &lt;&gt; null then
			self.logMessageNow(smtp.extendedErrorText);
		endif;
		delete smtp;
	endif;
	
	inheritMethod(eventType, theObject, eventTag, userInfo);
	
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="xCheckFutureQueuedMoves" id="dd8d8196-dbd4-4fa2-8069-e27048abf0e3">
        <source>xCheckFutureQueuedMoves();
// cnwndl1
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 February 2011	cnwndl1	Initial creation

*/

vars

	fm	: CM_FutureMoveQueued;
	str	: String;
	raiseError : Boolean;

begin

	foreach fm in CM_FutureMoveQueued.instances do
		if fm.allRTQueueEntries.size = 0 and fm.myTrackedItem &lt;&gt; null then
		
			if fm.myTrackedItem.myTerminal.code = "MA" then
				continue;
			endif;
		
			/*if fm.myTrackedItem.myTerminal = null or  fm.myTrackedItem.myTerminal.code = "RJD" then
				beginTransaction;
					fm.inspect;
					delete fm;							
				commitTransaction;
				continue;
			endif;*/
			
			if fm.myTrackedItem.myPrimaryActualLocation.isKindOf(CM_MachineController) then
		//		str := str &amp;  fm.myTrackedItem.String &amp; " '" &amp; fm.myTrackedItem.id &amp; "' on machine " &amp; fm.myTrackedItem.myPrimaryActualLocation.CM_MachineController.id &amp; " - " &amp; fm.myTrackedItem.myTerminal.code &amp; CrLf;
				continue;
			endif;
			
		
			if fm.myTrackedItem.myPrimaryActualLocation = null then
				str := str &amp; fm.myTrackedItem.String &amp; " '" &amp; fm.myTrackedItem.id &amp; "' null primary location - " &amp; fm.myTrackedItem.myTerminal.code &amp; CrLf;
				continue;
			endif;
			if fm.myTrackedItem.myPrimaryQueuedLocation = null then
				str := str &amp; fm.myTrackedItem.String &amp; " '" &amp; fm.myTrackedItem.id &amp; "' null queued location - " &amp; fm.myTrackedItem.myTerminal.code &amp; CrLf;
				continue;
			endif;
			
			if fm.myTrackedItem.myTerminal.code = "RJD" then
				continue;
			endif;
			if fm.myTrackedItem.myTerminal.code = "JBL" then
				continue;
			endif;
			
			str := str &amp; fm.myTrackedItem.String &amp; " '" &amp; fm.myTrackedItem.id &amp; "' future queued move with no RT entry - " &amp; fm.myTrackedItem.myTerminal.code &amp; CrLf;
			
		endif;
	endforeach;
	
	
	raiseError := str.trimBlanks &lt;&gt; null;
	self.assertEqualMsg(raiseError, false, str);
	
epilog

end;</source>
    </JadeMethod>
