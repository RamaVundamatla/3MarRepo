    <JadeMethod name="filterObjects" id="2df6cc65-9696-4cd0-b144-45ab3d6f881d">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
// -----------------------------------------------------------------------------
// Created:		13 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  ----------------------------------------------------
// 13/07/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// 29 Oct 2012	NDL			Par 30282 - Add more filter date ranges.
// 17 Feb 2015	cnwkpd1	PAR #35704 - Changes to prevent extended locking
// -----------------------------------------------------------------------------

vars
	desc : String;
	filterBySchedArrivalDate : Boolean;
	invalidTrain : Boolean;
	partialCode : String;
	partialLength : Integer;
	scheduledArrivalFromTS : TimeStamp;
	scheduledArrivalToTS : TimeStamp;
	terminal : CM_Terminal;
	train : CM_Train;
	
	filterByDepartDate : Boolean;
	departFromTS : TimeStamp;
	departToTS : TimeStamp;
	
	filterByArriveDate : Boolean;
	arriveFromTS : TimeStamp;
	arriveToTS : TimeStamp;
	
	filterBySchedDepartDate : Boolean;
	scheduledDepartFromTS : TimeStamp;
	scheduledDepartToTS : TimeStamp;
	
	localTrainSet : CM_TrainSet;
	iter : Iterator;
	startObject : CM_Train;

begin
	if self.getMyTrain &lt;&gt; null then
		_collection.add(self.getMyTrain);
		return;
	endif;

	partialCode := self.trainCode.trimBlanks().toUpper();
	partialLength := partialCode.length();

	////////////////////////////////////////////////////////
	if self.scheduledArrivalDateFrom.isValid() then
		filterBySchedArrivalDate := true;
		scheduledArrivalFromTS.setDate(self.scheduledArrivalDateFrom);
	else
		scheduledArrivalFromTS.setDate("01/01/0001".Date);
	endif;

	if self.scheduledArrivalDateTo.isValid() then
		filterBySchedArrivalDate := true;
		scheduledArrivalToTS.setDate(self.scheduledArrivalDateTo + 1);
	else
		scheduledArrivalToTS.setDate("01/01/9999".Date);
	endif;

	scheduledArrivalFromTS.setTime("00:00".Time);
	scheduledArrivalToTS.setTime("00:00".Time);

	if scheduledArrivalFromTS &gt; scheduledArrivalToTS then
		return;
	endif;
	
	////////////////////////////////////////////////////
	if self.departDateFrom.isValid() then
		filterByDepartDate := true;
		departFromTS.setDate(self.departDateFrom);
	else
		departFromTS.setDate("01/01/0001".Date);
	endif;

	if self.departDateTo.isValid() then
		filterByDepartDate := true;
		departToTS.setDate(self.departDateTo + 1);
	else
		departToTS.setDate("01/01/9999".Date);
	endif;

	departFromTS.setTime("00:00".Time);
	departToTS.setTime("00:00".Time);

	if departFromTS &gt; departToTS then
		return;
	endif;

	
	////////////////////////////////////////////////////
	if self.arrivalDateFrom.isValid() then
		filterByArriveDate := true;
		arriveFromTS.setDate(self.arrivalDateFrom);
	else
		arriveFromTS.setDate("01/01/0001".Date);
	endif;

	if self.arrivalDateTo.isValid() then
		filterByArriveDate := true;
		arriveToTS.setDate(self.arrivalDateTo + 1);
	else
		arriveToTS.setDate("01/01/9999".Date);
	endif;

	arriveFromTS.setTime("00:00".Time);
	arriveToTS.setTime("00:00".Time);

	if arriveFromTS &gt; arriveToTS then
		return;
	endif;
	
	////////////////////////////////////////////////////////
	if self.scheduledDepartDateFrom.isValid() then
		filterBySchedDepartDate := true;
		scheduledDepartFromTS.setDate(self.scheduledDepartDateFrom);
	else
		scheduledDepartFromTS.setDate("01/01/0001".Date);
	endif;

	if self.scheduledDepartDateTo.isValid() then
		filterBySchedDepartDate := true;
		scheduledDepartToTS.setDate(self.scheduledDepartDateTo + 1);
	else
		scheduledDepartToTS.setDate("01/01/9999".Date);
	endif;

	scheduledDepartFromTS.setTime("00:00".Time);
	scheduledDepartToTS.setTime("00:00".Time);

	if scheduledDepartFromTS &gt; scheduledDepartToTS then
		return;
	endif;
	

	on Exception do app.handleDeletedObject(exception, train, invalidTrain);

	foreach terminal in self.allTerminals do
		//  Filter trains on terminal
		foreach train in terminal.allTrainsOnTerminal discreteLock where train.code &gt;= partialCode do
			invalidTrain := false;
			desc := train.description;
			if invalidTrain then
				continue;
			endif;
			if partialCode &lt;&gt; null and train.code[1:partialLength] &lt;&gt; partialCode then
				break;
			endif;
			if filterBySchedArrivalDate then
				if train.scheduledArrivalDT &lt; scheduledArrivalFromTS
				or train.scheduledArrivalDT &gt;= scheduledArrivalToTS then
					continue;
				endif;
			endif;
			if filterBySchedDepartDate then
				if train.scheduledDepartureDT &lt; scheduledDepartFromTS
				or train.scheduledDepartureDT &gt;= scheduledDepartToTS then
					continue;
				endif;
			endif;
			if filterByArriveDate then
				if train.arrivalDT &lt; arriveFromTS
				or train.arrivalDT &gt;= arriveToTS then
					continue;
				endif;
			endif;
			if filterByDepartDate then	// yes this can actually be set while the train is still on site...
				if train.departureDT &lt; departFromTS
				or train.departureDT &gt;= departToTS then
					continue;
				endif;
			endif;
			if not _collection.includes(train) then
				_collection.add(train);
			endif;
		endforeach;
		
		
		if self.includeDeparted then
			// build a local collection to pre-populate 
			create localTrainSet transient;
			
			if filterBySchedArrivalDate then
				iter := terminal.allDepartedTrainsBySchedArrDT.createIterator();
				startObject := terminal.allDepartedTrainsBySchedArrDT.getAtKeyGeq(scheduledArrivalFromTS, null);
				if startObject &lt;&gt; null then
					iter.startAtObject(startObject);
					while iter.next( train ) do
						invalidTrain := false;
						if train.scheduledArrivalDT &gt;= scheduledArrivalToTS then
							break;
						endif;
						if invalidTrain then
							continue;
						endif;
						localTrainSet.addNoDuplicates( train, false );
					endwhile;
				endif;
				
			elseif filterBySchedDepartDate then
				iter := terminal.allDepartedTrainsBySchedDepDT.createIterator();
				startObject := terminal.allDepartedTrainsBySchedDepDT.getAtKeyGeq(scheduledDepartFromTS,null);
				if startObject &lt;&gt; null then
					iter.startAtObject(startObject);
					while iter.next( train ) do
						invalidTrain := false;
						if train.scheduledArrivalDT &gt;= scheduledDepartToTS then
							break;
						endif;
						if invalidTrain then
							continue;
						endif;
						localTrainSet.addNoDuplicates( train, false );
					endwhile;
				endif;
				
			elseif filterByArriveDate then
				iter := terminal.allDepartedTrainsByArrivalDT.createIterator();
				startObject := terminal.allDepartedTrainsByArrivalDT.getAtKeyGeq(arriveFromTS);
				if startObject &lt;&gt; null then
					iter.startAtObject(startObject);
					while iter.next( train ) do
						invalidTrain := false;
						if train.arrivalDT &gt;= arriveToTS then
							break;
						endif;
						if invalidTrain then
							continue;
						endif;
						localTrainSet.addNoDuplicates( train, false );
					endwhile;
				endif;
				
			elseif filterByDepartDate then
				iter := terminal.allTrainsDepartedReversed.createIterator();
				startObject := terminal.allTrainsDepartedReversed.getAtKeyLeq(departFromTS);	//descending order
				if startObject &lt;&gt; null then
					iter.startAtObject(startObject);
					while iter.back( train ) do	// yes, 'back' this one is descending order.
						invalidTrain := false;
						if train.departureDT &gt;= departToTS then
							break;
						endif;
						if invalidTrain then
							continue;
						endif;
						localTrainSet.addNoDuplicates( train, false );
					endwhile;
				endif;
				
			else
				// no date filters selected
				terminal.allTrainsDeparted.copy( localTrainSet );
			endif;
			
			foreach train in localTrainSet do
				invalidTrain := false;
				desc := train.description;
				if invalidTrain then
					continue;
				endif;
				if partialCode &lt;&gt; null and train.code[1:partialLength] &lt;&gt; partialCode then
					break;
				endif;
				if filterBySchedArrivalDate then
					if train.scheduledArrivalDT &lt; scheduledArrivalFromTS
					or train.scheduledArrivalDT &gt;= scheduledArrivalToTS then
						continue;
					endif;
				endif;
				if filterBySchedDepartDate then
					if train.scheduledDepartureDT &lt; scheduledDepartFromTS
					or train.scheduledDepartureDT &gt;= scheduledDepartToTS then
						continue;
					endif;
				endif;
				if filterByArriveDate then
					if train.arrivalDT &lt; arriveFromTS
					or train.arrivalDT &gt;= arriveToTS then
						continue;
					endif;
				endif;
				if filterByDepartDate then
					if train.departureDT &lt; departFromTS
					or train.departureDT &gt;= departToTS then
						continue;
					endif;
				endif;
				if not _collection.includes(train) then
					_collection.add(train);
				endif;
			endforeach;
		endif;
	endforeach;

epilog

	delete localTrainSet;
	delete iter;

end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="69fe04a3-f777-4036-bbba-37a7d94b7981">
        <source>getDisplayStringForAttribute(_attrName: String; _getCalculatedDate: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 July 2010	cnwmd1	Initial creation

*/
// ---------------------------------------------------------------------------
// Created:     19/07/2010 cnwdz2	
//
// Purpose:     PAR24513 extend the current existing getDisplayStringForAttribute method to return an object's oid.	
vars
	oid 	: String;
begin
	return self.getOIDAndDescForAttribute(_attrName, _getCalculatedDate, oid);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyTrain" id="578d8e38-176c-4330-b0f8-00a0e68c566f">
        <source>getMyTrain():CM_Train;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

	train : CM_Train;
	edition : Integer;
	invalidObj : Boolean;

begin

	train := self.myTrain;

	if train = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, train, invalidObj );
	edition := train.edition;
	
	if invalidObj then
		return null;
	endif;
	
	return train;

epilog

end;</source>
        <ReturnType type="CM_Train"/>
    </JadeMethod>
    <JadeMethod name="getOIDAndDescForAttribute" id="3d1105c3-6f92-4315-954b-72f6542914a3">
        <source>getOIDAndDescForAttribute(_attrName: String; _getCalculatedDate: Boolean; _oid : String output): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 July 2010	cnwmd1	Initial creation

*/
// ---------------------------------------------------------------------------
// Created:     19/07/2010 cnwdz2	
//
// Purpose:     PAR24513 extend the current existing getDisplayStringForAttribute method to return an object's oid.	
vars
	runDate	: Date;
	train : CM_Train;
begin
	runDate := app.actualTimeServer().Date;	// 28/4/16 cnwmp6 TFS 488 - Multi timezone support
	
	if _attrName = ETRow_Train then
		train := self.getMyTrain;	//14 Jul 2016	NDL	TFS 2329
		if train &lt;&gt; null then
			_oid := train.getOidAsString(); //21/07/2010 cnwdz2 24513
			return train.getCodeDateString;
		endif;
		return Any_String;
	elseif _attrName = ETRow_TrainCode then
		return self.trainCode;
		
		// Actually called "Scheduled Arrival Date From"
	elseif _attrName = ETRow_ArrivalsDateFrom then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.scheduledArrivalDateFromType, self.scheduledArrivalDateFromFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.scheduledArrivalDateFromType, self.scheduledArrivalDateFromFactor);
		endif;
		
		// Actually called "Scheduled Arrival Date To"
	elseif _attrName = ETRow_ArrivalsDateTo then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.scheduledArrivalDateToType, self.scheduledArrivalDateToFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.scheduledArrivalDateToType, self.scheduledArrivalDateToFactor);
		endif;

	//30 Oct 2012	NDL	Par 30394
	elseif _attrName = ETRow_SchedDepartedDateFrom then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.scheduledDepartDateFromType, self.scheduledDepartDateFromFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.scheduledDepartDateFromType, self.scheduledDepartDateFromFactor);
		endif;
		
	elseif _attrName = ETRow_SchedDepartedDateTo then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.scheduledDepartDateToType, self.scheduledDepartDateToFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.scheduledDepartDateToType, self.scheduledDepartDateToFactor);
		endif;
	
	//29 Oct 2012	NDL	Par 30394
	elseif _attrName = ETRow_ActDepartedDateFrom then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.departDateFromType, self.departDateFromFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.departDateFromType, self.departDateFromFactor);
		endif;
		
	elseif _attrName = ETRow_ActDepartedDateTo then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.departDateToType, self.departDateToFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.departDateToType, self.departDateToFactor);
		endif;
		
	//30 Oct 2012	NDL	Par 30394
	elseif _attrName = ETRow_ActArrivedDateFrom then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.arrivalDateFromType, self.arrivalDateFromFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.arrivalDateFromType, self.arrivalDateFromFactor);
		endif;
		
	elseif _attrName = ETRow_ActArrivedDateTo then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.arrivalDateToType, self.arrivalDateToFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.arrivalDateToType, self.arrivalDateToFactor);
		endif;
	
	elseif _attrName = ETRow_IncludeDeparted then //+ cnwmd1 Par 23826
		return self.includeDeparted.cnEcGetTableCheckBoxValue;
		
	endif;
	
	return inheritMethod(_attrName, _getCalculatedDate, _oid);

	
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setDatesForTemplateRun" id="02f138d9-ce06-480d-8ace-4f693e8fe0af">
        <updating/>
        <source>setDatesForTemplateRun(_runDate: Date) updating;
// -----------------------------------------------------------------------------
// Created:		17 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 17/07/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
