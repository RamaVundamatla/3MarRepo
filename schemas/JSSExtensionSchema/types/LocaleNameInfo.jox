<Class name="LocaleNameInfo">
    <JadeMethod name="jssCopyInfo" id="87046905-022d-4750-8969-1163e8b774b6">
        <updating/>
        <source>jssCopyInfo(pTheLocaleNameInfo : LocaleNameInfo) updating;
// -----------------------------------------------------------------------------
// Created:		24 December 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.abbreviatedCountryName	:=	pTheLocaleNameInfo.abbreviatedCountryName;
	self.abbreviatedLangName	:=	pTheLocaleNameInfo.abbreviatedLangName;
	self.countryCode			:=	pTheLocaleNameInfo.countryCode;
	self.englishCountryName		:=	pTheLocaleNameInfo.englishCountryName;
	self.englishLangName		:=	pTheLocaleNameInfo.englishLangName;
	self.languageId				:=	pTheLocaleNameInfo.languageId;
	self.localeId				:=	pTheLocaleNameInfo.localeId;
	self.localizedCountryName	:=	pTheLocaleNameInfo.localizedCountryName;
	self.localizedLangName		:=	pTheLocaleNameInfo.localizedLangName;
	self.nativeCountryName		:=	pTheLocaleNameInfo.nativeCountryName;
	self.nativeLangName			:=	pTheLocaleNameInfo.nativeLangName;
end;</source>
        <Parameter name="pTheLocaleNameInfo" type="LocaleNameInfo"/>
    </JadeMethod>
</Class>
