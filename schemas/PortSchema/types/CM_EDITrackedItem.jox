    <JadeMethod name="subTerminalCodeVerify" id="a665fc3d-4755-4510-9c88-beb6919d06fc">
        <source>subTerminalCodeVerify(_terminalObj:CM_Terminal):String;
// --------------------------------------------------------------------------------
// Created:		01 May 2009 by cnwdad1
//
// Purpose:		Method which is called by the EDI load to validate the Sub-Terminal code.
//
// Parameters:	_terminalObj - A reference to the Terminal the EDI is being loaded for.
//
// Returns:		An error message if the Sub-Terminal code is not valid.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
// --------------------------------------------------------------------------------
vars
	value	: Integer;
	message	: String;
	
begin
	if app.isSubTerminalsOn(self.getMyTerminal()) then
		message	:=	null;
		
		if self.subTerminalCode = null then
			value	:=	self.VALID;
		else
			if _terminalObj.allSubTerminals[self.subTerminalCode] = null then
				value	:=	WARNING;
				message	:=	"Unknown Sub-Terminal code '" &amp; self.subTerminalCode &amp; "'";
			else
				value	:=	self.VALID;
			endif;
		endif;
	else
		value	:=	self.VALID;
	endif;
	
	return value.String &amp; message;
end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <ReturnType type="String"/>
    </JadeMethod>
