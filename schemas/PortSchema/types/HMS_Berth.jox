    <JadeMethod name="causeHMSEvent" id="cd7a2a5f-2341-4e28-be46-290ae9a289b1">
        <source>causeHMSEvent(_eventMode: Integer);

vars

begin

	if _eventMode = self.EventMode_Delete then
		self.causeEvent(RefreshView, false, self);
	elseif _eventMode = self.EventMode_Update then
		self.causeEvent(RefreshView, false, self);	
	elseif _eventMode = self.EventMode_Create then
		if self.myWharf &lt;&gt; null then
			self.myWharf.causeEvent(RefreshView, false, self.myWharf);	
		endif;
	else
		inheritMethod(_eventMode);
	endif;
end;</source>
        <Parameter name="_eventMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="checkWharfOverhang" id="fb709ea0-439b-43f7-962e-431408bb29ed">
        <source>checkWharfOverhang(	_bowMark,
					_sternMark : Decimal;
					_raiseError : Boolean) : Boolean;
//--------------------------------------------------
// Created:	24 November 2004 By: cnwgd1
//--------------------------------------------------
// 19 Dec 2018 	jlger1 tfs 42627 - raise exceptions causing problems
vars
	theWharf : HMS_Wharf;
	wharfMin,
	wharfMax : Integer;	
begin

	theWharf := self.myWharf;
	if theWharf = null then
		return true;
	endif;
	
	wharfMin := 0-(theWharf.overhangZeroMetreEnd);
	wharfMax := (theWharf.length)+(theWharf.overhangMaxMetreEnd);

	if _bowMark &lt; wharfMin then
		if _raiseError then
			app.raiseCMException4(HMSWharfOverhang, 'Bow Mark', _bowMark.String, wharfMin.String, theWharf.code, null, null);
		endif;
		return false;
	elseif _sternMark &lt; wharfMin then
		if _raiseError then
			app.raiseCMException4(HMSWharfOverhang, 'Stern Mark', _sternMark.String, wharfMin.String, theWharf.code, null, null);	
		endif;
		return false;
	elseif _bowMark &gt; wharfMax then
		if _raiseError then
			app.raiseCMException4(HMSWharfOverhang, 'Bow Mark', _bowMark.String, wharfMax.String, theWharf.code, null, null);		
		endif;
		return false;
	elseif _sternMark &gt; wharfMax then
		if _raiseError then
			app.raiseCMException4(HMSWharfOverhang, 'Stern Mark', _sternMark.String, wharfMax.String, theWharf.code, null, null);			
		endif;
		return false;
	else
		return true;
	endif;

end;</source>
        <Parameter name="_bowMark" type="Decimal"/>
        <Parameter name="_sternMark" type="Decimal"/>
        <Parameter name="_raiseError" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createAutoCharge" id="7c0a6956-2c52-4cbd-8bde-d7acc99490e9">
        <source>createAutoCharge(_movement : HMS_VoyageMovement input) : HMS_ResourceUsed;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		On the wharf we may have 2 resources, each represents the berthage. If we have 1 then we charge it. 
//				If we have a 2nd we only charge it if the berthage time was greater than the 
//				hours set on the wharf in 'timeTill2ndResource'
//				We mayt have 2 resources to represent berthage because a port may want a different rate 
//				for the first 24 hours and then to have charges every 6 hours
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
30 Mar 2008	cnwkpd1	PAR #16367 - Change to use reworked HMS_VoyageMovement::getVoyageMovementPrevious
30 Jul 2013	cnwdap1	PAR #31364 - Second block processing should only ever deal with time over and above the first block
								 time - otherwise for voyages that shift more than once, we end up calculating the 24 hour
								 period then incorrectly assigning a further 6 hour period.
								 Also avoid calculating an extra 6-hour block for voyages that last an exact number of 24-hour blocks
06 Nov 2015	cnwdap1	PAR #37067 - Use berth "part of contract" setting instead of laways looking for out of contract
10 Dec 2015	cnwdap1	PAR #37295 - Check for Calculation type on resource for setting hour blocks
*/

vars
	timeTill2ndResource : Real;
	theCalcType : CM_CalculationType;
	theVoy : CM_Voyage;
	aRes : HMS_Resource;
	pxyResUsed, aResUsed : HMS_ResourceUsed;
	diffMin, minutes4Block, firstBlockMinutes : Integer;
	poc : Boolean;
	thePrevMove : HMS_VoyageMovement;			// PAR #16367
	prevWharf : HMS_Wharf;
	hmsVoyData : HMS_VoyageData;
	invoiceHMSNoShiftCharge, chargeOK : Boolean;
	hmsBerthBlock1, hmsBerthBlock2 : Decimal[8,2];
	berthPOC : Boolean;									// PAR #37067
begin
	hmsVoyData := _movement.myHMSVoyageData;
	theVoy := hmsVoyData.myVoyage;
	berthPOC := theVoy.isBerthageOnContract();			// PAR #37067
	invoiceHMSNoShiftCharge :=  app.myPassport.myTerminal.getConfig(InvoiceHMSNoShiftCharge).Boolean;

	//	NOTE: The departure movement's wharf is always the logical wharf, which cannot have resources attached.
	//	So we use the wharf of the previous movement to get the correct resource.
	if invoiceHMSNoShiftCharge then // always get the ARRIVAL
		thePrevMove := hmsVoyData.getMovementFirstChargeable(_movement.moveType); 
	else
		thePrevMove := _movement.getVoyageMovementPrevious(); 		// PAR #16367
	endif;
	if thePrevMove &lt;&gt; null then
		prevWharf := thePrevMove.getMyBerth.myWharf;
		aRes := prevWharf.getResourceForHarbourMovement(_movement.moveType,HMS_Wharf.First_Resource);
	else
		prevWharf := self.myWharf;
		aRes := prevWharf.getResourceForHarbourMovement(_movement.moveType,HMS_Wharf.First_Resource);
	endif;
	
	// NOTHING to charge
	if aRes = null then
		return null;
	endif;

	hmsBerthBlock1 := 24; // PAR 35469
	//theCalcType := aRes.getMappedInvoiceCalcType(theVoy,false);	// PAR 35469	// PAR #37067
	theCalcType := aRes.getMappedInvoiceCalcType(theVoy, berthPOC); // PAR 35469	// PAR #37067
	if theCalcType &lt;&gt; null then // PAR 35469
		hmsBerthBlock1 := theCalcType.hoursBlock; // PAR 35469
		// PAR #37295 If the resource has a "Calculation Type for Quantity", then use this to get hours			// PAR #37295
		if aRes.myCalculationTypeQuantity &lt;&gt; null and aRes.myCalculationTypeQuantity.hoursBlock &lt;&gt; null then	// PAR #37295
			hmsBerthBlock1 := aRes.myCalculationTypeQuantity.hoursBlock;										// PAR #37295
		endif;																									// PAR #37295
	endif;
	
	// if the resource is for not a 'chop it up into hourly blocks' type of calculation i.e. non a berthage resource then charge as normal
	if _movement.moveType = HMSMovementTypeArrival then
		theCalcType := aRes.getMappedInvoiceCalcType(theVoy,false);
		chargeOK := ((theCalcType &lt;&gt; null 
						and theCalcType.calculationType &lt;&gt; INV_CALC_TYPE_TIMEBLCK_HRS_ONE 
						and theCalcType.calculationType &lt;&gt; INV_CALC_TYPE_TIMEBLCK_HRS_UNT) 
					or (theCalcType = null));
		if chargeOK then
			// ## charge first non berthage resource. On arrival this might be PORT ACCESS
			self.createAutoChargeNONBlock(_movement.myHarbour,_movement,aRes);

			// ## check if there is a second non berthage resource to charge on the arrival
			aRes := prevWharf.getResourceForHarbourMovement(_movement.moveType,HMS_Wharf.Second_Resource);
			if aRes &lt;&gt; null then
				theCalcType := aRes.getMappedInvoiceCalcType(theVoy,false);
				chargeOK := ((theCalcType &lt;&gt; null 
								and theCalcType.calculationType &lt;&gt; INV_CALC_TYPE_TIMEBLCK_HRS_ONE 
								and theCalcType.calculationType &lt;&gt; INV_CALC_TYPE_TIMEBLCK_HRS_UNT) 
					or (theCalcType = null));
				if chargeOK then
					self.createAutoChargeNONBlock(_movement.myHarbour,_movement,aRes);
				endif;
			endif;
		endif;		
	endif;

	// ### Only for Shift and Departure
	if _movement.moveType = HMSMovementTypeArrival then
		return null;
	endif;


	// ### FIRST BLOCK OF CHARGING
// PAR 35469	self.createAutoChargeBlock(_movement,aRes,HMSBerthBlock1,false,poc, diffMin, firstBlockMinutes); // PAR 12448 added diffMin
	self.createAutoChargeBlock(_movement,aRes,hmsBerthBlock1,false,poc, diffMin, firstBlockMinutes, false, hmsBerthBlock1); // PAR 35469
	
	// ### SECOND BLOCK OF CHARGING
	if diffMin &gt; 0 then // PAR 12448
		// PAR 35469 minutes4Block := ((HMSBerthBlock1 * MillisecondsPerHour) / MillisecondsPerMinute).Integer; // basically 24 hours as minutes = 1440
		minutes4Block := ((hmsBerthBlock1 * MillisecondsPerHour) / MillisecondsPerMinute).Integer; // basically 24 hours as minutes = 1440
		// PAR #31364 Only do second block of charging if we have more than (minutes4Block) minutes to look at
		// diffMin is the number of minutes left from charging the first 24 hour block, so if this is greater than
		// (number of minutes in a day) then we need to carry on calculating. If diffMin is less than (number of minutes in a day)
		// then we've finished calculating
		//if firstBlockMinutes &lt; minutes4Block then // first block is less than 24 hours										// PAR #31364
		//	diffMin := diffMin - firstBlockMinutes; // PAR 12319 - only take away the minutes for the first block of berthage.	// PAR #31364
		//else // first block is greater than 24 hours																			// PAR #31364
			diffMin := diffMin - minutes4Block; // PAR 12319 - take away 24 hours
		//endif;																												// PAR #31364

		timeTill2ndResource := (prevWharf.timeTill2ndResource * MillisecondsPerHour) / MillisecondsPerMinute; // PAR 10972 AKB2005DEC
		// ### charge for 2nd berthage resource
		//if diffMin &gt;=  timeTill2ndResource then // PAR 10972 AKB2005DEC						// PAR #31364
		if diffMin &gt;= timeTill2ndResource and diffMin &gt; 0 then // PAR 10972 AKB2005DEC			// PAR #31364
			aRes := prevWharf.getResourceForHarbourMovement(_movement.moveType,HMS_Wharf.Second_Resource);
			
			// TFS 39721 NOTHING to charge
			if aRes &lt;&gt; null then
				hmsBerthBlock2 := 6; // PAR 35469
				//theCalcType := aRes.getMappedInvoiceCalcType(theVoy,false); 	// PAR 35469	// PAR #37067
				theCalcType := aRes.getMappedInvoiceCalcType(theVoy, berthPOC); // PAR 35469	// PAR #37067
				if theCalcType &lt;&gt; null then // PAR 35469
					hmsBerthBlock2 := theCalcType.hoursBlock; // PAR 35469
					// PAR #37295 If the resource has a "Calculation Type for Quantity", then use this to get hours			// PAR #37295
					if aRes.myCalculationTypeQuantity &lt;&gt; null and aRes.myCalculationTypeQuantity.hoursBlock &lt;&gt; null then	// PAR #37295
						hmsBerthBlock1 := aRes.myCalculationTypeQuantity.hoursBlock;										// PAR #37295
					endif;																									// PAR #37295
				endif;
	
				// PAR 35469self.createAutoChargeBlock(_movement,aRes,HMSBerthBlock2,true,poc, diffMin, firstBlockMinutes);
				self.createAutoChargeBlock(_movement,aRes,hmsBerthBlock2,true,poc, diffMin, firstBlockMinutes, true,hmsBerthBlock1);// PAR 35469
			endif;
		endif;
	endif;

	return aResUsed;
epilog
	delete pxyResUsed;

end;</source>
        <Parameter name="_movement" type="HMS_VoyageMovement" usage="input"/>
        <ReturnType type="HMS_ResourceUsed"/>
    </JadeMethod>
    <JadeMethod name="createAutoChargeBlock" id="49cee3f1-f15f-44e5-99e1-364c31da4871">
        <source>createAutoChargeBlock(_movement : HMS_VoyageMovement input; _aRes : HMS_Resource; _hourBlock : Decimal; 
								_createNew  : Boolean; _poc : Boolean io; _diff : Integer io; _firstBlockMinutes : Integer io; _useFreeHours : Boolean; _firstHourBlock : Decimal) : HMS_ResourceUsed;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		On the wharf we may have 2 resources, each represents the berthage. If we have 1 then we charge it. 
//				If we have a 2nd we only charge it if the berthage time was greater than the 
//				hours set on the wharf in 'timeTill2ndResource'
//				We mayt have 2 resources to represent berthage because a port may want a different rate 
//				for the first 24 hours and then to have charges every 6 hours
//
// ---------------------------------------------------------------------------
// 15/11/2016 cnwrh7	TFS	2909		Resource Type required Error
vars
	numMinutes, numHourBlocks : Real;
	res1CalcType : CM_CalculationType;
	fromTS, toTS : TimeStamp;
	pxyResUsed, aResUsed : HMS_ResourceUsed;
	 nonChargeMinutes, diffMin, firstBlockMinutes : Integer;
	poc : Boolean;
	thePrevMove, arrivalMove : HMS_VoyageMovement;
	prevWharf : HMS_Wharf;
begin
	// ### Only for Shift and Departure
	if _movement.moveType = HMSMovementTypeArrival then
		return null;
	endif;
	if _aRes = null then
		return null;
	endif;

	// ### charge for berthage
	if _createNew then
		// ### PAR 10693 check if it has already been charged!!!
		aResUsed := _movement.getMatchingUsedResUsed(_aRes, self,_poc); // Has it already been charged? // PAR 10825 added _POC passed in param
		if aResUsed = null then
			create aResUsed;
			poc := _poc;
			_movement.allResourceUsed.add(aResUsed);
		else
			_poc := aResUsed.partOfContract; // ### PAR 11016
			return null;
		endif;
	else
		// ### try to find an existing 'contract' resource used
		aResUsed := _movement.getMatchingEmptyResUsed(_aRes); // Is it part of the contract
		if aResUsed = null then
			aResUsed := _movement.getMatchingUsedResUsed(_aRes, self,true); // Has it already been charged?
			if aResUsed = null then
				aResUsed := _movement.getMatchingUsedResUsed(_aRes, self,false); // Has it already been charged?
				if aResUsed = null then
					// assume is non contract
					create aResUsed;
					poc := false;
					_movement.allResourceUsed.add(aResUsed);
				else
					_poc := aResUsed.partOfContract; // ### PAR 11016
					return null;
				endif;
			else
				_poc := aResUsed.partOfContract; // ### PAR 11016
				return null;
			endif;
		else
			poc := aResUsed.partOfContract;
		endif;
	endif;
	// ### use the transaction map to get the calculation type, so that we can chop up the hours into number of blocks
	// ### MORE horrid bodging code for NELSON's twisty turny VTMIS invoicing: If the calctype is INV_CALC_TYPE_TIMEBLCK_HRS_ONE then
	//			only charge for berthage from the arrival to departure and ignore shifts.
	if  _movement.moveType = HMSMovementTypeDeparture
	and app.myPassport.myTerminal.getConfig(InvoiceHMSNoShiftCharge).Boolean then
// PAR 35469		numHourBlocks := _movement.myHMSVoyageData.getNumberOfBlocksVisit(_hourBlock, diffMin, firstBlockMinutes, _hourBlock=HMSBerthBlock2);
		numHourBlocks := _movement.myHMSVoyageData.getNumberOfBlocksVisit(_hourBlock, diffMin, firstBlockMinutes, _useFreeHours, _firstHourBlock, _aRes); // PAR 35469
		_firstBlockMinutes := firstBlockMinutes;
		_diff := diffMin; // this is the actual chargeable time.All the no charge berthage has been taken out, we pass this back to see if we need to charge for the 2nd set of blocks
		arrivalMove := _movement.myHMSVoyageData.getMovementForMoveType(HMSMovementTypeArrival);

		toTS := self.getToTimeStamps(_movement); 
		fromTS := toTS.addMinutes(diffMin * -1);
	else
		fromTS := self.getFromTimeStamp(_movement);
		toTS := self.getToTimeStamps(_movement); 

		diffMin := (fromTS.cnEcDiff(toTS) / MillisecondsPerMinute).Integer; // PAR 10972 AKB2005DEC
		_diff := diffMin;
		
		
		
		
		res1CalcType := _aRes.myCalculationTypeQuantity; // TFS 39721
		if res1CalcType &lt;&gt; null then // TFS 39721
			numHourBlocks := res1CalcType.getNumHourBlocks(diffMin,true,self.myWharf); // TFS 39721
			if numHourBlocks &lt; 1 then // TFS 39721
				numHourBlocks := 1; // TFS 39721
			endif; // TFS 39721
			
		else // TFS 39721
			numHourBlocks := _movement.myHMSVoyageData.getNumberOfBlocksMovement(diffMin,_hourBlock, self.myWharf, not _useFreeHours);	// 36605 extra param
		endif;
	endif;
	
	if numHourBlocks &gt; 0 then		// 33605
		pxyResUsed := aResUsed.pxyGetProxyObject;
		if pxyResUsed = null then
			pxyResUsed := app.createUpdateProxy(aResUsed).HMS_ResourceUsed;
		endif;

		pxyResUsed.setProxy(self.getHarbour, _aRes.myResourceType,_aRes,null,fromTS,toTS,numHourBlocks,poc,null,null);
		pxyResUsed.setHMSObject(self);
	
		aResUsed.setForCreate(pxyResUsed, app.myPassport);
	else
		if aResUsed &lt;&gt; null and aResUsed.myResourceType = null and aResUsed.myResource = null then				//+TFS2909 Checked if aResUsed is crated at Line 53 but not got updated at Line 93 then we need to clear it
			_movement.allResourceUsed.removeIfPresent(aResUsed);
			delete aResUsed;	
		endif;
		aResUsed := null;
	endif;
	_poc := poc;
	return aResUsed;
epilog
	delete pxyResUsed;


end;</source>
        <Parameter name="_movement" type="HMS_VoyageMovement" usage="input"/>
        <Parameter name="_aRes" type="HMS_Resource"/>
        <Parameter name="_hourBlock" type="Decimal"/>
        <Parameter name="_createNew" type="Boolean"/>
        <Parameter name="_poc" type="Boolean" usage="io"/>
        <Parameter name="_diff" type="Integer" usage="io"/>
        <Parameter name="_firstBlockMinutes" type="Integer" usage="io"/>
        <Parameter name="_useFreeHours" type="Boolean"/>
        <Parameter name="_firstHourBlock" type="Decimal"/>
        <ReturnType type="HMS_ResourceUsed"/>
    </JadeMethod>
    <JadeMethod name="createAutoChargeNONBlock" id="7fd8731a-4e80-4561-ab8c-cd1357af87b6">
        <source>createAutoChargeNONBlock(_harbour : HMS_Harbour; _movement : HMS_VoyageMovement input; _aRes : HMS_Resource input) : HMS_ResourceUsed;
// ---------------------------------------------------------------------------
// Created:		September 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	
	pxyResUsed, aResUsed : HMS_ResourceUsed;
	poc : Boolean;
	toTS : TimeStamp;
	qty : Real;
begin
	if _aRes = null then
		return null;
	endif;
	aResUsed := _movement.getMatchingINContractResUsed(_aRes); // Is it part of the contract
	if aResUsed = null then
		aResUsed := _movement.getMatchingUsedResUsed(_aRes, self,true); // Has it already been charged?
		if aResUsed = null then
			aResUsed := _movement.getMatchingUsedResUsed(_aRes, self,false); // Has it already been charged?
			if aResUsed = null then
				create aResUsed;
				_movement.allResourceUsed.add(aResUsed);
			else
				return null;
			endif;
		else
			return null;
		endif;
	else
		poc := aResUsed.partOfContract;
	endif;
	toTS := aResUsed.toDateTime;
	if not toTS.isValid() then
		toTS := _movement.occursOnDTNEW;
	endif;

	qty := aResUsed.unitsUsed;
	if qty &lt;= 0 then
		qty := 1;
	endif;

	create pxyResUsed transient;
	pxyResUsed.setProxy(_harbour, _aRes.myResourceType,_aRes,null,_movement.occursOnDTNEW,toTS,qty,poc,null,null);
	pxyResUsed.setHMSObject(self);
	
	aResUsed.setForCreate(pxyResUsed, app.myPassport);
	return aResUsed;		// cnwjre1 14/11/2012 from unit test - this was in the epilog, stopped the transient delete

epilog
	delete pxyResUsed;

end;</source>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_movement" type="HMS_VoyageMovement" usage="input"/>
        <Parameter name="_aRes" type="HMS_Resource" usage="input"/>
        <ReturnType type="HMS_ResourceUsed"/>
    </JadeMethod>
