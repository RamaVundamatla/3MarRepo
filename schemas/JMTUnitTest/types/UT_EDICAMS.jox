	  &lt;height&gt;10&lt;/height&gt;
&lt;transportMode&gt;Road&lt;/transportMode&gt;
	&lt;/CargoOnSite&gt;
	&lt;CargoOnSite&gt;
	  &lt;site&gt;1&lt;/site&gt;
	  &lt;bol&gt;BOL01&lt;/bol&gt;
	  &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
	  &lt;dischargePort&gt;DEBRE&lt;/dischargePort&gt;
	  &lt;id&gt;'&amp;VoyageName&amp;'/BOL01/002&lt;/id&gt;
	  &lt;imexStatus&gt;Import&lt;/imexStatus&gt;
      &lt;locationId&gt;'&amp;BlockStackName&amp;'&lt;/locationId&gt;
	  &lt;messageMode&gt;A&lt;/messageMode&gt;
	  &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
      &lt;weight&gt;2090.0000&lt;/weight&gt;
      &lt;width&gt;200&lt;/width&gt;
      &lt;height&gt;20&lt;/height&gt;
	  &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
&lt;transportMode&gt;Road&lt;/transportMode&gt;
	&lt;/CargoOnSite&gt;
	&lt;CargoOnSite&gt;
	  &lt;quantity&gt;50&lt;/quantity&gt;
	  &lt;site&gt;1&lt;/site&gt;
	  &lt;totalQuantity&gt;1&lt;/totalQuantity&gt;
	  &lt;bol&gt;BOL01&lt;/bol&gt;
	  &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
	  &lt;commodity&gt;&lt;/commodity&gt;
	  &lt;companyCode&gt;DFBU&lt;/companyCode&gt;
	  &lt;dischargePort&gt;DEBRE&lt;/dischargePort&gt;
	  &lt;id&gt;'&amp;VoyageName&amp;'/BOL01/003&lt;/id&gt;
      &lt;locationId&gt;'&amp;BlockStackName&amp;'&lt;/locationId&gt;
	  &lt;imexStatus&gt;Import&lt;/imexStatus&gt;
	  &lt;messageMode&gt;A&lt;/messageMode&gt;
	  &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
	  &lt;remarks&gt;(AM # 36-12) CL 9,UN 3077,PKG III,ENVIRONMENTALLY HAZARDOUS SUBSTANCE, (50 Steel Coils)&lt;/remarks&gt;
      &lt;weight&gt;3090.0000&lt;/weight&gt;
      &lt;width&gt;300&lt;/width&gt;
      &lt;height&gt;30&lt;/height&gt;
	  &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
&lt;transportMode&gt;Road&lt;/transportMode&gt;
	&lt;/CargoOnSite&gt;
	&lt;CargoOnSite&gt;
	  &lt;quantity&gt;16&lt;/quantity&gt;
	  &lt;site&gt;1&lt;/site&gt;
	  &lt;totalQuantity&gt;1&lt;/totalQuantity&gt;
	  &lt;bol&gt;BOL01&lt;/bol&gt;
	  &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
	  &lt;commodity&gt;&lt;/commodity&gt;
	  &lt;companyCode&gt;DFBU&lt;/companyCode&gt;
	  &lt;dischargePort&gt;DEBRE&lt;/dischargePort&gt;
	  &lt;id&gt;'&amp;VoyageName&amp;'/BOL01/004&lt;/id&gt;
      &lt;locationId&gt;'&amp;BlockStackName&amp;'&lt;/locationId&gt;
	  &lt;imexStatus&gt;Import&lt;/imexStatus&gt;
	  &lt;messageMode&gt;A&lt;/messageMode&gt;
	  &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
	  &lt;remarks&gt;TRIACETIN (16 IBC)&lt;/remarks&gt;
      &lt;weight&gt;4090.0000&lt;/weight&gt;
      &lt;width&gt;400&lt;/width&gt;
      &lt;height&gt;40&lt;/height&gt;
	  &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
&lt;transportMode&gt;Road&lt;/transportMode&gt;
	&lt;/CargoOnSite&gt;
    &lt;/AllCargoOnSite&gt;
 &lt;/JMTInternalCargoOnSite&gt;
';
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);
//return;
	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passport.allErrors.isEmpty(), passport.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passport.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
	self.assertIsOneOf(	ediFileObj.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	ediDataObj	:=	ediFileObj.ediData;
	self.opts.purge();
	self.opts.addAssoc("SetRemarks", false);
	self.ediDBLoad(ediFileObj);
	self.assertIsOneOf(	ediFileObj.fileStatus,
						"Load Failed",
						CM_EDIFile.EDI_STATUS_DBLOADED,
						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 4, "incorrect number of EDI trackedItems");
	
	// Create the Receives
    
	// create terminal area
//    self.deleteTerminalArea(BlockStackName);
//	bs := self.addBlockStack (BlockStackName, 1000, null);
//	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');
    
//	train := self.getTrain(TrainCode, null);
//	wagon := self.getWagon(WagonCode, train);
//	railLine.switchPositions(wagon, 01);	
//	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Switch Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
//	app.myTrxUA.trxUpdateWagonConfirmTrain(true, train, true, app.myPassport);  //in
//	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Confirm IN Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
    create cargoItems transient;
//	train.getAllTrackedItems(true, cargoItems);    
   // Discharge 4 of the items 
	deleteVehicle("UTTRUCK");
//	self.opts.addAssoc("AutoComplete", true);
	gate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
//	self.gateInPrenote("UTTRUCK", "", "UTDRIVER", VoyageName&amp;'/BOL01/001', gate);
//	assertTrue(getTrackedItem(VoyageName&amp;'/BOL01/001').isOnSite);
//	self.gateInPrenote("UTTRUCK", "", "UTDRIVER", VoyageName&amp;'/BOL01/002', gate);
//	assertTrue(getTrackedItem(VoyageName&amp;'/BOL01/002').isOnSite);
//	self.gateInPrenote("UTTRUCK", "", "UTDRIVER", VoyageName&amp;'/BOL01/003', gate);
//	assertTrue(getTrackedItem(VoyageName&amp;'/BOL01/003').isOnSite);
//	self.gateInPrenote("UTTRUCK", "", "UTDRIVER", VoyageName&amp;'/BOL01/004', gate);
//	assertTrue(getTrackedItem(VoyageName&amp;'/BOL01/004').isOnSite);
	cargo1 := self.getTrackedItem(VoyageName&amp;'/BOL01/001');
	vvr := self.gateOutGC("UTTRUCK", "", "UTDRIVER", cargo1, gate, BlockStackName);
	self.workVehicle(vvr);
	self.roadExit(vvr);
	cargo2 := self.getTrackedItem(VoyageName&amp;'/BOL01/002');
	vvr := self.gateOutGC("UTTRUCK", "", "UTDRIVER", cargo2, gate, BlockStackName);
	self.workVehicle(vvr);
	self.roadExit(vvr);
	cargo3 := self.getTrackedItem(VoyageName&amp;'/BOL01/003');
	vvr := self.gateOutGC("UTTRUCK", "", "UTDRIVER", cargo3, gate, BlockStackName);
	self.workVehicle(vvr);
	self.roadExit(vvr);
	cargo4 := self.getTrackedItem(VoyageName&amp;'/BOL01/004');
	vvr := self.gateOutGC("UTTRUCK", "", "UTDRIVER", cargo4, gate, BlockStackName);
	self.workVehicle(vvr);
	self.roadExit(vvr);
//	vvr :=  self.gateInPrenote(TruckId, "", DriverId, ti7, dualGate);
/*    foreach cargoItem in cargoItems do
        count := count + 1;
        self.move(cargoItem, bs);
        if count = 4 then
            break;
        endif;
    endforeach;*/

//	beginTransaction;
//   et := app.createEvent(EVT_VoyageDeparture, app.actualTimeServer, self.getTerminal(), app.myPassport.userCode, false, false,0).CMEVT_VoyageEvent;
//    et.CMEVT_VoyageEvent.setMyVoyage(voyage);
//    commitTransaction;

	
	// DELETE THEN RE-CREATE THE CAM PROTOCOL
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	
	create camTrainEventTypes transient;
//	camTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_VoyageDeparture]);
//	camTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_TrainDepart]);
//	camTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_TruckDeparture]);
//	camTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_WagonConfirmed]);
//	camTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_WagonDeparted]);
	create operatorDict transient;
	create freightForwarders transient;
	create registeredCargoTypes transient;
	registeredCargoTypes.add(cargoTypeObj.id);
    create registeredTransactions transient;
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveRail).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveRoad).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveShip).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReleaseRail).asStringJMT);
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReleaseRoad).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReleaseShip).asStringJMT);
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightForwarders, 16, ShipperCode);
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);

	camProtocolDesc := app.myRoot.allCamProtocolDescs["Alabama Steel Warehouse"];
	camProtocol	:= self.createCamProtocol(CamProtocol, camGroup, "NZCHC", operator.code, camProtocolDesc, false, false, false, registeredTransactions, registeredCargoTypes, camTrainEventTypes, camEditTriggerFields,null);	
	
	beginTransaction;
	camProtocolDesc.setTransmissionNumber(10);
//	camProtocol.setPropertyValue(CM_CamProtocol::noCrLfInMessage.name, true);
	camProtocol.setPropertyValue(CM_CamProtocol::specialFileName.name, true);
	camProtocol.setPropertyValue(CM_CamProtocol::isSingleTransPerFile.name, true);
	commitTransaction;
 	
	// run cams
	endDateTime := startDateTime.addMinutes(1);
	
	app.setIsBackGroundApp (true);
	
	runDateTime := app.actualTimeServer;
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
//	self.runCamsNow(startDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

	self.zOutput_AST_WareXMLTransITO(expectedOutput);
	self.zCheckOutputXML(camProtocol, camTaskHistory, expectedOutput, "warehouse_activity");
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete operatorDict;
	delete freightForwarders;
    delete registeredTransactions;
	delete registeredCargoTypes;
	delete strs;
	delete cargoItems;
	delete camTrainEventTypes;
	app.setIsBackGroundApp (false);
	self.updateEDITIRemarks(ediFileObj);
	delete camEditTriggerFields;
end;
</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;test1&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tBoiseXMLReceipts" id="7402a1ad-5943-45fb-ac47-fee192e86a63">
        <source>tBoiseXMLReceipts();
/*

Date		Who		Reason
20 Jun 2016	cnwer1	Initial creation TFS
13 Dec 2021	navdap1	Aligned with NMAST (8.6.2 final) as part of DMAST/WMAST code comparison
					(also changed the oliTag and oliEndTag scripts to match NMAST)
23 Jan 2025	navah1	Task 33741: MTN - 22.0.24.12 - Unit Tests Review - [1]
14 Apr 2025	navdap1	MTN-14781 CPL| Increase BOL Field Length
*/
constants 
	CamGroup  = "UTBOISE";
	CamProtocol = "UTBOISE_RECEPTS";
	OperatorCode = "BOIS";
	CargoTypeCode = "UT_WIDGET";
	VehicleID1 : String = 'BOISEV1';
	DriverID1 : String = 'BOISED1';
	VehicleID2 : String = 'BOISEV2';
	DriverID2 : String = 'BOISED2';
	VehicleID3 : String = 'BOISEV3';
	DriverID3 : String = 'BOISED3';
	VehicleID4 : String = 'BOISEV4';
	DriverID4 : String = 'BOISED4';
	Cargo1  = "CANNON20061601";
	Cargo2  = "CANNON20061602";
	Cargo3  = "CANNON20061603";
	Cargo4 = "CANNON20061604";
	AltID 	= "123456-1";
	Client = "BOISE";
	RecipientCode 	= "UT_RECIPIENT";
	SenderCode 		= "UT_SENDER";
	SenderCodeDepot = "UT_SENDERDEPOT";
	ShipperCode 	= "UT_SHIPPER";
	FacilityCode 	= "UT_FACILITY";
vars
	runDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camProtocolDesc :CM_CamProtocolDesc;
	operatorDict : CM_OperatorByCodeDict;
	freightForwarders : CM_ConsigneeConsignorSet;
	operator : CM_Operator;
	cargoTypeObj : CM_CargoType;
	gateOut	: CM_GateArea;
	cargo1,
	cargo2,
	cargo3: CM_TrackedItem;
	cargo4 : CM_TrackedItem;
	bs : CM_BlockStack;
	registeredCargoTypes : IntegerArray;
	camEventTypes : CM_EventTypeByNameDict;
	vv1,
	vv2,
 	vv3,
	vvr4: CM_VehicleVisitRecord;
	startDateTime : TimeStamp;
	transactions :StringArray;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	camTaskHistory : CM_CamTaskHistory;
	expected : String;
	endDateTime : TimeStamp;
	vehicle : CM_Vehicle;
begin
	startDateTime := app.actualTimeServer;
	operator := app.myRoot.allOperators[OperatorCode];
	cargoTypeObj := app.myRoot.getCargoTypeFromAbbrev(CargoTypeCode);
	gateOut := self.getPGate(self.getProfileSetting(UT_Profile.P_DGATE_POUT).asString);
	assertNotNull(gateOut);
	
	self.deleteVehicle(VehicleID1);
	self.deleteVehicle(VehicleID2);
	self.deleteVehicle(VehicleID3);						// 23.01.2025 navah1 #33741
	vehicle := self.getVehicle(VehicleID4);
	if vehicle &lt;&gt; null and vehicle.allRoadJobs.size &gt; 0 then
		beginTransaction;
		vehicle.allRoadJobs.purge();
		commitTransaction;
	endif;
	cargo1 := self.getTrackedItem(Cargo1).CM_Cargo;
	self.deleteTrackedItem(cargo1, false);
	cargo2 := self.getTrackedItem(Cargo2).CM_Cargo;
	self.deleteTrackedItem(cargo2, false);
	cargo3 := self.getTrackedItem(Cargo3).CM_Cargo;
	self.deleteTrackedItem(cargo3, false);
	cargo4 :=self.getTrackedItem(Cargo4).CM_Cargo;
	
	vv1:=self.gateInGC(VehicleID1,null,DriverID1,Cargo1,CargoTypeCode,OperatorCode,null,self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString),null);
	self.assertNotNull(vv1);
	cargo1 := self.getTrackedItem(Cargo1).CM_Cargo;
	self.assertNotNull(cargo1);
	
	beginTransaction;
	cargo1.setPropertyValue("alternativeId",AltID );
    cargo1.setPropertyValue("clientRef", Client ); //TFS 2188 Change Previously it was always 1
	commitTransaction;
	
	vv2:=self.gateInGC(VehicleID2,null,DriverID2,Cargo2,CargoTypeCode,OperatorCode,null,self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString),null);
	self.assertNotNull(vv2);
	cargo2 := self.getTrackedItem(Cargo2).CM_Cargo;
	self.assertNotNull(cargo2);
	beginTransaction;
	cargo2.setPropertyValue("alternativeId",AltID );
    cargo2.setPropertyValue("clientRef", Client ); //TFS 2188 Change Previously it was always 1
	commitTransaction;
	
	vv3:=self.gateInGC(VehicleID3,null,DriverID3,Cargo3,CargoTypeCode,OperatorCode,null,self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString),null);
	self.assertNotNull(vv3);
	cargo3 := self.getTrackedItem(Cargo3).CM_Cargo;
	self.assertNotNull(cargo3);
	
	bs:=self.addBlockStack("UTBOISE",null,null);
	self.assertNotNull(bs);
	self.move(cargo1, bs);
	self.move(cargo2, bs);
	self.move(cargo3, bs);
	self.roadExit(vv1);
	self.roadExit(vv2);
	self.roadExit(vv3);
	
	cargo4:=self.addCargoAtLocation(Cargo4,CargoTypeCode,operator,bs.myLocationsController);
	self.assertNotNull(cargo4);
	beginTransaction;
		cargo4.setPropertyValue("deliveryRelease",Client);
	 cargo4.setPropertyValue("remarks", AltID ); //TFS 2188 Change Previously it was always 1
	commitTransaction;
	vvr4:=self.gateOutGC(VehicleID4,null,DriverID4,cargo4,self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString),null);
	self.move(cargo4, vvr4.getVehicle.locationsController);
	self.roadExit(vvr4);
	// create cam group and protocols
	camGroup := self.getCamGroup(CamGroup);
	if camGroup &lt;&gt; null then
		foreach camProtocol in camGroup.protocols do
			self.deleteCamProtocol(camProtocol.code);
		endforeach;
	endif;
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightForwarders, 16, ShipperCode);
	self.assertNotNull(camGroup);
	self.deleteCamProtocol(CamProtocol);
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	
	create registeredCargoTypes transient;
	registeredCargoTypes.add(cargoTypeObj.id);
	camProtocolDesc := app.myRoot.allCamProtocolDescs[CM_CamUserDefRepEventDesc.UserDefinedEventDescName];
	create camEventTypes transient;
	create transactions transient;
	create camEditTriggerFields transient;
	camEventTypes.add (app.myRoot.allEventTypesByType[EVT_TruckDeparture]);
	camProtocol	:= self.createCamProtocol(CamProtocol, camGroup, null, operator.code, camProtocolDesc, false, true, false, transactions, registeredCargoTypes, camEventTypes, camEditTriggerFields,"BOISE Receipts XML");	
	self.assertNotNull(camProtocol);
	
	beginTransaction;
	//camProtocol.setPropertyValue(CM_CamProtocol::jrwReportName.name,"BOISE Receipts XML");
	camProtocol.setPropertyValue(CM_CamProtocol::fileSuffix.name,"xml");
	camProtocol.setPropertyValue(CM_CamProtocol::transferFileFormat.name,"TXT");
	commitTransaction;
	
	// RUNS CAMS
	runDateTime := app.actualTimeServer;
	endDateTime := runDateTime;
//	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	self.runCamsNow(startDateTime, camProtocol);
	
	self.assertEqual(camProtocol.taskHistoryByProtocolSeq.size,3);
	
	camTaskHistory:=camProtocol.taskHistoryByProtocolSeq[camProtocol,1];
	self.assertNotNull(camTaskHistory);
	self.assertEqual(camTaskHistory.messageCount,1);
	expected:='&lt;?xml version="1.0" encoding="UTF-8"?&gt;
	&lt;oswhr&gt;
	  &lt;header&gt;
		&lt;oplocId&gt;3J&lt;/oplocId&gt;
		&lt;creationDate&gt;21 June 2016&lt;/creationDate&gt;
		&lt;creationTime&gt;13:59:07&lt;/creationTime&gt;
	  &lt;/header&gt;
  &lt;load carrier="DOUG" loadKey="BOISE" vehicle="BOISEV1"&gt;
      &lt;item&gt;CANNON20061601&lt;/item&gt;
  &lt;/load&gt;
	  &lt;footer&gt;
		&lt;sourceFileName&gt;3J&lt;/sourceFileName&gt;
	  &lt;/footer&gt;
	&lt;/oswhr&gt;';


	self.zCheckOutputXML(camProtocol, camTaskHistory, expected, "oswhr");
	
	
	camTaskHistory:=camProtocol.taskHistoryByProtocolSeq[camProtocol,2];
	self.assertNotNull(camTaskHistory);
	self.assertEqual(camTaskHistory.messageCount,1);
	expected:='&lt;?xml version="1.0" encoding="UTF-8"?&gt;
	&lt;oswhr&gt;
	  &lt;header&gt;
		&lt;oplocId&gt;3J&lt;/oplocId&gt;
		&lt;creationDate&gt;21 June 2016&lt;/creationDate&gt;
		&lt;creationTime&gt;13:54:08&lt;/creationTime&gt;
	  &lt;/header&gt;
  &lt;load carrier="DOUG" loadKey="BOISE" vehicle="BOISEV2"&gt;
      &lt;item&gt;CANNON20061602&lt;/item&gt;
  &lt;/load&gt;
	  &lt;footer&gt;
		&lt;sourceFileName&gt;3J&lt;/sourceFileName&gt;
	  &lt;/footer&gt;
	&lt;/oswhr&gt;';

	self.zCheckOutputXML(camProtocol, camTaskHistory, expected, "oswhr");
	
	
	camTaskHistory:=camProtocol.taskHistoryByProtocolSeq[camProtocol,3];
	self.assertNotNull(camTaskHistory);
	self.assertEqual(camTaskHistory.messageCount,0);
	
	beginTransaction;
		camProtocol.setPropertyValue(CM_CamProtocol::jrwReportName.name,"BOISE Orders XML");
		self.deleteCamProtocolFiles(camProtocol);
		camProtocol.taskHistoryByProtocolSeq.purge;
	commitTransaction;
	
	// RUNS CAMS
	
	self.runCamsNow(startDateTime, camProtocol);
	self.assertEqual(camProtocol.taskHistoryByProtocolSeq.size,2);
	camTaskHistory:=camProtocol.taskHistoryByProtocolSeq[camProtocol,1];
	self.assertNotNull(camTaskHistory);
	self.assertEqual(camTaskHistory.messageCount,1);
	
	expected:='&lt;?xml version="1.0"?&gt;
	&lt;oswho&gt;
	  &lt;header&gt;
		&lt;oplocId&gt;3J&lt;/oplocId&gt;
		&lt;creationDate&gt;03 November 2016&lt;/creationDate&gt;
		&lt;creationTime&gt;11:10:31&lt;/creationTime&gt;
	  &lt;/header&gt;
	  &lt;load carrier="DOUG" loadKey="UT43137" vehicle="BOISEV4"&gt;
		&lt;oli lineNumber="1" orderKey="123456" itemCount="1"&gt;
		  &lt;item&gt;CANNON20061604&lt;/item&gt;
		&lt;/oli&gt;
	  &lt;/load&gt;
	  &lt;footer&gt;
		&lt;sourceFileName&gt;3J&lt;/sourceFileName&gt;
	  &lt;/footer&gt;
	&lt;/oswho&gt;';
	
	self.zCheckOutputXML(camProtocol, camTaskHistory, expected, "oswho");
	
epilog
	delete operatorDict;
	delete freightForwarders;
	delete registeredCargoTypes;
	delete camEventTypes;
	delete transactions;
	delete camEditTriggerFields;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCAMSExtractCSVFile" id="d5a61331-57e2-4413-a28f-70d815a5d5b0">
        <source>tCAMSExtractCSVFile();
/*

Purpose:			Testlink test 01-373 / To test CAM protocol file extract (csv) without ant error

Date		Who		Reason
09 November 2016	cnwmk3	Initial creation

*/
constants
	CAMGROUP				= "GRP373";
	OPERATOR				= "UTOP";
	CamProtocol				= "CAM373";
	Cargo_Type				= "CONT";
vars
	camProtocolDesc			: CM_CamProtocolDesc;
	camGroup				: CM_CamGroup;
	opColl					: CM_OperatorByCodeDict;
	ffColl					: CM_ConsigneeConsignorSet;
	camProtocol				: CM_CamProtocol;
	registeredTransactions	: StringArray;
	registeredCargoTypes	: IntegerArray;
	camEditTriggerFields	: CM_CamEditTriggerFieldDict;
	emailCopyAddresses		: CM_EmailEntityByTypeNameDict;
	packOperators			: CM_OperatorByCodeDict;
	packExportConsignees	: CM_ConsignByCodeDict;
	allPackAreas			: CM_TAByIdDict;
	allCoarriExportPorts	: CM_PortByCodeDict;
	scheduleTimes			: TimeArray;
	emailEntity				: CM_EmailEntity;
	startDateTime			: TimeStamp;
	cargoTypeObj			: CM_CargoType;
	time					: Time;
	runDateTime				: TimeStamp;
	field					: CM_CamEditTriggerField;
	camTaskHistory			: CM_CamTaskHistory;
	ti						: CM_TrackedItem;
	controller				: CMIF_TIUpdateController;
	expectedOutput			: String;
begin
	self.deleteContainer("TEST373");

	create ffColl transient;
	create opColl transient;
	CM_Operator.instances.copy (opColl);
	
	// Create new CAM Protocol as similar as above but choose different CAM Group and Protocol Description. 
	camProtocolDesc := app.myRoot.allCamProtocolDescs.last;
	self.deleteCamGroup(CAMGROUP);
	camGroup := self.addCamGroup (CAMGROUP, CAMGROUP, OPERATOR, null, null, null, false, false, false, opColl, ffColl, 10, 'MSL');
	self.assertNoTrxErrorsOrWarnings ();
	self.assertNotNullMsg (camGroup, 'Cam group not created');
	
	create registeredCargoTypes transient;
	cargoTypeObj := app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	registeredCargoTypes.add(cargoTypeObj.id);
	
	// Create one more new CAM Protocol with Protocol Description: NYK Codeco,Transactions Tab - Add Pack Complete, Packed, Unpack Complete, Unpacked; Depot/Terminal Tab - Check the 4 Pack / Unpack options
	create registeredTransactions transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create allPackAreas transient;
	create allCoarriExportPorts transient;
	create scheduleTimes transient;
	create camEditTriggerFields transient;
	registeredTransactions.add(TRANS_TYPE_EDIT.asStringJMT);
	
	field := CM_CamUserDefRepDesc.firstInstance.allCamEditTriggerFields['Integer', 'imexStatus'];
	self.assertNotNull(field);
	camEditTriggerFields.add(field);
	
	camProtocolDesc := app.myRoot.allCamProtocolDescs["Maersk Codeco"];
	emailEntity 	:= app.myRoot.allEmailEntities[1, "Mr. Testing"];
	self.ignoreTrxWarnings(true);
	camProtocol := self.addCamProtocol(CamProtocol, CamProtocol, allCoarriExportPorts, camGroup, "NZCHC", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "csv", "UTOP", packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, false, false, false, false, false, false, false, false, false, false, false, false, 
									   false, false, false, false, false, false, false, false, false, false, false, false, 
									   0, 0, 0, 0, '', '', '', camEditTriggerFields, null, null, false, 0, self.getTerminal, true, true, false, false, false, false, false, true, true, 
									   allPackAreas, null, null, registeredCargoTypes);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(camProtocol);
	self.assertEqual(camProtocol.code, CamProtocol);
	
	// RUNS CAMS
	startDateTime := app.actualTimeServer;
	startDateTime.setTime(time - 10000);
	self.runCamsAdhoc(startDateTime, app.actualTimeServer, runDateTime, camProtocol);
	// verify the file in Protocol Task History.
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	expectedOutput := "UNB+UNOA:2+NZCHC+UTOP+161109:1512+0'
UNZ+0+0'";
	self.zCheckOutput(camProtocol, camTaskHistory, expectedOutput);
	
	ti := self.addContainerOpts("TEST373", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	self.assertNotNull(ti);
	
	controller := app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.getMyUserCode(), null);
	self.opts.purge();
	self.opts.addAssoc("IMEXStatus", TI_IMEX_STATUS_IMPORT);
	self.opts.addAssoc(UTTI_AvailabilityGrade, 2);
	self.updateTI(ti);
	self.assertEqual(ti.getImExStatus(), TI_IMEX_STATUS_IMPORT);
	
	// RUNS CAMS
	startDateTime := app.actualTimeServer;
	startDateTime.setTime(time - 30000);
	self.runCamsAdhoc(startDateTime, app.actualTimeServer, runDateTime, camProtocol);
	// verify the file in Protocol Task History.
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	expectedOutput := "UNB+UNOA:2+NZCHC+UTOP+161109:1459+0'
UNH+1+CODECO:D:95B:UN:SMDG16'
BGM+999+1+9'
NAD+CF+MSL:160:20'
NAD+SLS+NZCHC:172:20'
EQD+CN+TEST373+2200:102:5++3+5'
RFF+ER:SUR'
DTM+7:201611091459:203'
LOC+165+NZPOE:160:20'
MEA+AAE+G+KGM:4000'
FTX+AAA+++AV'
CNT+16:1'
UNT+12+1'
UNZ+1+0'";
	self.zCheckOutput(camProtocol, camTaskHistory, expectedOutput);
epilog
	self.ignoreTrxWarnings(false);
	delete ffColl;
	delete opColl;
	delete registeredCargoTypes;
	delete registeredTransactions;
	delete camEditTriggerFields;
	delete emailCopyAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete allPackAreas;
	delete allCoarriExportPorts;
	delete scheduleTimes;
	delete controller;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCAMSProtocols" id="90989e50-40ba-4c59-aba1-8990a051763f">
        <source>tCAMSProtocols();
/*

Purpose:			Testlink test 01-598

Date		Who		Reason
08 November 2016	cnwmk3	Initial creation
26 April 2023		navmd1	TFS 57678 Include check for Ad Hoc runs not clearly previous data in task history

*/
constants
	CamProtocol1		= "TEST5981";
	CamProtocol2		= "TEST5982";
	CamProtocol3		= "TEST5983";
	CAMGROUP1			= "ALL";
	CAMGROUP2			= "CAM08";
	OPERATOR 			= 'UTOP';
	Cargo_Type			= "CONT";
vars
	opColl					: CM_OperatorByCodeDict;
	ffColl					: CM_ConsigneeConsignorSet;
	camGroup				: CM_CamGroup;
	camProtocol				: CM_CamProtocol;
	registeredCargoTypes	: IntegerArray;
	registeredTransactions	: StringArray;
	cargoTypeObj			: CM_CargoType;
	camProtocolDesc			: CM_CamProtocolDesc;
	camEditTriggerFields	: CM_CamEditTriggerFieldDict;
	startDateTime			: TimeStamp;
	runDateTime				: TimeStamp;
	date					: Date;
	camTaskHistory			: CM_CamTaskHistory;
	emailEntity				: CM_EmailEntity;
	emailCopyAddresses 		: CM_EmailEntityByTypeNameDict;
	packOperators			: CM_OperatorByCodeDict;
	packExportConsignees	: CM_ConsignByCodeDict;
	scheduleTimes			: TimeArray;
	allPackAreas			: CM_TAByIdDict;
	allCoarriExportPorts	: CM_PortByCodeDict;
	wh						: CM_IrregularBlockArea;
	container1				: CM_TrackedItem;
	cargo1, cargo2			: CM_Container;
	packTIs					: CM_TIArray;
	time					: Time;
	expectedFileName		: String;
begin
	create ffColl transient;
	create opColl transient;
	CM_Operator.instances.copy (opColl);
	
	self.deleteCamGroup(CAMGROUP1);
	camGroup := self.addCamGroup (CAMGROUP1, CAMGROUP1, OPERATOR, null, null, null, false, false, false, opColl, ffColl, 10, 'UTOP');
	self.assertNoTrxErrorsOrWarnings ();
	self.assertNotNullMsg (camGroup, 'Cam group not created');
	
	create registeredCargoTypes transient;
	cargoTypeObj := app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	registeredCargoTypes.add(cargoTypeObj.id);

	create registeredTransactions transient;
	create camEditTriggerFields transient;
	camProtocolDesc := app.myRoot.allCamProtocolDescs.first;
	registeredTransactions.add(TRANS_TYPE_REL_SHIP.asStringJMT);
	registeredTransactions.add(TRANS_TYPE_REC_SHIP.asStringJMT);
	camProtocol	:= self.createCamProtocol(CamProtocol1, camGroup, "NZCHC", OPERATOR, camProtocolDesc, false, false, true, registeredTransactions, registeredCargoTypes, null, camEditTriggerFields,null);
	
	// RUNS CAMS
	startDateTime := app.actualTimeServer;
	startDateTime.setDate(date - 1);
	self.runCamsAdhoc(startDateTime, app.actualTimeServer, runDateTime, camProtocol);
	// A new file is added under Protocol Task History[0] Tab. Protocol Task History[0] Tab is changed to Protocol Task History[1] 
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	// Delete the CAMS protocol
	self.deleteCamProtocol(CamProtocol1);
	camProtocol := self.getCamProtocol(CamProtocol1);
	self.assertIsDeleted(camProtocol);
	
	// Create new CAM Protocol as similar as above but choose different CAM Group and Protocol Description. 
	camProtocolDesc := app.myRoot.allCamProtocolDescs.last;
	self.deleteCamGroup(CAMGROUP2);
	camGroup := self.addCamGroup (CAMGROUP2, CAMGROUP2, OPERATOR, null, null, null, false, false, false, opColl, ffColl, 10, 'MSL');
	self.assertNoTrxErrorsOrWarnings ();
	self.assertNotNullMsg (camGroup, 'Cam group not created');
	camProtocol	:= self.createCamProtocol(CamProtocol2, camGroup, "NZCHC", OPERATOR, camProtocolDesc, false, false, true, registeredTransactions, registeredCargoTypes, null, camEditTriggerFields,null);
	delete registeredTransactions;
	
	// Create one more new CAM Protocol with Protocol Description: NYK Codeco,Transactions Tab - Add Pack Complete, Packed, Unpack Complete, Unpacked; Depot/Terminal Tab - Check the 4 Pack / Unpack options
	create registeredTransactions transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create allPackAreas transient;
	create allCoarriExportPorts transient;
	create scheduleTimes transient;
	registeredTransactions.add(TRANS_TYPE_PackComplete.asStringJMT);
	registeredTransactions.add(TRANS_TYPE_PACK.asStringJMT);
	registeredTransactions.add(TRANS_TYPE_UnpackComplete.asStringJMT);
	registeredTransactions.add(TRANS_TYPE_UNPACK.asStringJMT);
	camProtocolDesc := app.myRoot.allCamProtocolDescs["NYK Codeco"];
	emailEntity 	:= app.myRoot.allEmailEntities[1, "Mr. Testing"];
	self.ignoreTrxWarnings(true);
	camProtocol := self.addCamProtocol(CamProtocol3, CamProtocol3, allCoarriExportPorts, camGroup, "NZCHC", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", "UTOP", packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, false, false, false, false, false, false, false, false, false, false, false, false, 
									   false, false, false, false, false, false, false, false, false, false, false, false, 
									   0, 0, 0, 0, '', '', '', camEditTriggerFields, null, null, false, 0, self.getTerminal, true, true, false, true, true, true, true, true, true, 
									   allPackAreas, null, null, registeredCargoTypes);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(camProtocol);
	self.assertEqual(camProtocol.code, CamProtocol3);
	
	// Pack and/or unpack a Container in the Pack/Unpack screen.
	self.deleteContainer("TEST598");
	container1 := self.addContainerOpts("TEST598", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	

	self.deleteContainer("CHILD598001");
	self.deleteContainer("CHILD598002");
	wh := self.getTerminal.allTerminalAreas[self.getProfileSetting(UT_Profile.P_WAREHOUSE).asString].CM_IrregularBlockArea;
	cargo1 := self.addContainerAtLocation("CHILD598001", null, "2200", "GENL", 1, wh.allLocationsControllers.first);
	cargo2 := self.addContainerAtLocation("CHILD598002", null, "2200", "GENL", 1, wh.allLocationsControllers.first);

	//first pack in 2  child containers
	create packTIs transient;
	packTIs.add(cargo1);
	packTIs.add(cargo2);
	packContainer(container1.CM_Container, packTIs);
	assertEqualMsg(container1.numChildren, 2, "Container children incorrect");
	
	// RUNS CAMS
	startDateTime := app.actualTimeServer;
	startDateTime.setTime(time - 100000);
	self.runCamsAdhoc(startDateTime, app.actualTimeServer, runDateTime, camProtocol);
	// verify the file in Protocol Task History.
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	self.assertEqualMsg(camTaskHistory.messageCount, 2, "Expected exactly 2 messages on the CAMS Task History");
	expectedFileName := camTaskHistory.fileName[1:6] &amp; camTaskHistory.fileName[camTaskHistory.fileName.reversePos("_"):end];
	self.assertEqualMsg(expectedFileName, app.clock.String[1:6] &amp; "_adhoc0.txt", "File name not close enough to 'now'. Has it been updated?");
	
	// RUN CAMS
	startDateTime := app.actualTimeServer;
	self.runCamsAdhoc(startDateTime, app.actualTimeServer, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
//	self.assertEqualMsg(camTaskHistory.messageCount, 0, "Expected NO messages on the CAMS Task History");
//	self.assertNullMsg(camTaskHistory.fileName, "File name not cleared when no messages generated");
	
	// On the Special Protocol Setting sheet set "Delay in Minutes" and Save.
	self.opts.purge();
	self.opts.addAssoc("DelayMins", 2);
	self.ignoreTrxWarnings(true);
	self.updateCamProtocol(camProtocol);
	self.assertEqual(camProtocol.delayMinutes, 2);
	
	// On the Special Protocol sheet unset "Delay in Minutes"  and Save. Should now be 0.
	self.opts.purge();
	self.opts.addAssoc("DelayMins", 0);
	self.ignoreTrxWarnings(true);
	self.updateCamProtocol(camProtocol);
	self.assertEqual(camProtocol.delayMinutes, 0);
epilog
	self.ignoreTrxWarnings(false);
	delete ffColl;
	delete opColl;
	delete registeredCargoTypes;
	delete registeredTransactions;
	delete camEditTriggerFields;
	delete emailCopyAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete allPackAreas;
	delete allCoarriExportPorts;
	delete scheduleTimes;
	delete packTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCAMSTimestamp" id="d9625dc8-9960-4eeb-a561-119ab0e9002c">
        <source>tCAMSTimestamp();
// cnwrs1
/*
Purpose;	Check transactions are not being created with a null CAMS timestamp

Date		Who		Reason
18 Dec 2012	cnwcs5	Initial creation - par 30855
*/
constants
	DAYS = 2;
vars
	terminal	:CM_Terminal;
	agent		:CM_CamControllerAgent;
	date		:Date;
	coll		:CM_TITransactionByDateTypeDict;
	trx			:CM_TITransaction;
	msg			:String;
	ti			:CM_TrackedItem;
	count		:Integer;
begin
return;
	create agent transient;
	
	terminal 	:= self.getTerminal;
	coll		:= terminal.allTITransactions;
	
	agent.setMyTerminal (terminal);
		
	date := agent.getEarliestCAMSRunDate; 
	
	self.assertNotNullMsg (date, 'CAMS earliest timestamp');
	
	foreach trx in coll reversed do
		if trx.dateTime.date &lt; date then
			continue;
		endif;
		
		ti := trx.myTrackedItem;
				
		msg := 'CAMS timestamp for - ' &amp; trx.getTypeString &amp; ' ' &amp; trx.createdTime.asStringJMT &amp; ' (' &amp; trx.String &amp; ')';
		
		self.assertNotNullMsg (trx.camsTimeStamp, msg);
		
		count := count + 1;
	endforeach;
	


epilog
	delete agent;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCamCODECODamageRepair" id="43402158-7138-48f8-aae7-7433489be61a">
        <source>tCamCODECODamageRepair();
// cnwrs1
// ccms 1826 par 27945
// this is to test MSC Codeco Damage and Repair and to check that consecutive damage or repair does produce 2 messages
//30 Jan 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
//17/06/2016    cnwma1  TFS# 2159:CPL - Wrong Header for CODECO D.95B

constants
	VoyageName = 'VYPAR27945';				// all upper case!
	BoatName = 'VSPAR27945';
	ContainerName = 'PARC1230001';
	TestOperator = 'MSC';
	CamGroup = "P27945";
	CamProtocol = "PAR27945";
vars
	runDateTime : TimeStamp;
	lRegisteredCargoTypes : IntegerArray;
	tempStr	: String;
	idx : Integer;
	container : CM_Container;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	passport : CM_Passport;
//	bs : CM_BlockStack;
	terminal : CM_Terminal;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	emailEntity : CM_EmailEntity;
	camProtocolDesc : CM_CamProtocolDesc;
	registeredTransactions : StringArray;
	scheduleTimes : TimeArray;
	freightForwarders : CM_ConsigneeConsignorSet;
	allCoarriExportPorts : CM_PortByCodeDict;
	emailCopyAddresses : CM_EmailEntityByTypeNameDict;
	packOperators : CM_OperatorByCodeDict;
	packExportConsignees : CM_ConsignByCodeDict;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	camTrainEventTypes : CM_EventTypeByNameDict;
	allPackAreas : CM_TAByIdDict;
	objArray : CM_ObjectArray;	//transaction are added to this array and this array is purged at the end to ensure the transactions dont affect other unit tests
	transObj : CM_TITransaction;
//	setDateTime : TimeStamp;
	damCode : String;
	strArray : StringArray;
	str : String;
	theLines : HugeStringArray;
begin
	create theLines transient;

    // SET UP
    
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	create objArray transient;
	operator := self.getOperator(TestOperator);
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; TestOperator.display);
	
	// delete required voyages and vessels
	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName);
	vessel := self.getVessel(BoatName);
	self.assertIsDeleted(vessel);
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName);
	container := self.getTrackedItem(ContainerName).CM_Container;
	self.assertIsDeleted(container);
	
//	self.deleteTerminalArea(BlockStackName);
//	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
//	self.assertIsDeleted(bs);

	// Now create the required voyages and vessels
	vessel := self.addVesselCellular(BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatName.display &amp; ' failed');
	operator := self.getOperator("MSK");
	
	voyage := self.addVoyageNonPlannedNonWorked(VoyageName,
													BoatName,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage ' &amp; VoyageName &amp; ' failed');

	// Add the container to the voyage
	container := self.addContainerForExport(ContainerName,
										operator,
										"2200",					// ISOType is not needed
										"MT",					// commodity is not needed
										TI_IMEX_STATUS_STORAGE,	// import not export
										null,					// booking id
										voyage.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerName.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container, tempStr);
	self.assertNotNull(voyage.myShipBlockStack);
	self.move(container, voyage.myShipBlockStack);

//	setDateTime := setDateTime.addMinutes(-4);
	operator := self.getOperator(TestOperator);
//	container.setMyOperator(operator);
	self.opts.purge;
	self.opts.addAssoc(CM_TrackedItem::operatorCode.name, TestOperator);
	self.updateTI(container);
	self.assertEqual(container.myOperator, operator);

	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, "REP", "UT", "NZCHC", "FAC", false, false, false, operatorDict, freightForwarders, 16, "SHIP");
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_Damage).asStringJMT);
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_Repair).asStringJMT);
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_Wash).asStringJMT);
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_PreTrip).asStringJMT);
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_NeedsWash).asStringJMT);
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_NeedsPreTrip).asStringJMT);
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_DairyBoard).asStringJMT);	//cnwrs1 par 28644 10 nov 2011
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_NeedsDairyBoard).asStringJMT);	//cnwrs1 par 28644 10 nov 2011
	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	camProtocolDesc := app.myRoot.allCamProtocolDescs["MSC Codeco"];
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	camProtocol := self.addCamProtocol(CamProtocol, CamProtocol, allCoarriExportPorts, camGroup, "NZCHC", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, false, false, false, true, false, false, false, false, false, false, false, false, 
									   false, false, false, false, false, false, false, false, false, false, false, false, 
									   0, 0, 0, 0, '', '', '', camEditTriggerFields, camTrainEventTypes, null, false, 0, self.getTerminal, true, true, false, false, false, false, false, false, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	tempStr	:= 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(camProtocol, tempStr);
	self.assertNotNull(camProtocol);
 
 
    // TEST 1 2x Damage and 2xRepair produces ONE Damage Entry and ONE Repair Entry in CODECO
	transObj := self.createTransaction(container, global.getTiTxnTypeForClass(CM_Damage), null);
	objArray.add(transObj);

	transObj := self.createTransaction(container, global.getTiTxnTypeForClass(CM_Damage), null);
	objArray.add(transObj);

	transObj := self.createTransaction(container, global.getTiTxnTypeForClass(CM_Repair), null);
	objArray.add(transObj);

	transObj := self.createTransaction(container, global.getTiTxnTypeForClass(CM_Repair), null);
	objArray.add(transObj);

    
	endDateTime := startDateTime.addMinutes(1);
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

	idx := 0;
	create strArray transient;
	strArray.add("UNB+UNOA:2+");
	//strArray.add("UNH+1+CODECO:D:95B:UN:ITG12'");     //17/06/2016 cnwma1  TFS#2159
	strArray.add("UNH+1+CODECO:D:95B:UN:SMDG16'");	 //17/06/2016 cnwma1  TFS#2159;	
	strArray.add("BGM+999+1+9'");
	strArray.add("TDT+20+VYPAR27945+1+++++:146::VSPAR27945'");
	strArray.add("LOC+9+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+MS+NZCHC:160:87'");
	if app.isRunningInDMAST() then
		strArray.add("EQD+CN+PARC1230001+2200:102:5+++4'");
	elseif app.isRunningInWMAST() then
		strArray.add("EQD+CN+PARC1230001+AP01:102:5+++4'");
	endif;
	strArray.add("DTM+7:");
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("FTX+DAR++8'");
	if app.isRunningInDMAST() then
		strArray.add("EQD+CN+PARC1230001+2200:102:5+++4'");
	elseif app.isRunningInWMAST() then
		strArray.add("EQD+CN+PARC1230001+AP01:102:5+++4'");
	endif;
	strArray.add("DTM+7:");
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("FTX+DAR++7'");
	strArray.add("CNT+16:2'");
	strArray.add("UNT+18+1'");
	strArray.add("UNZ+1+0'");
	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		idx := idx + 1;
		str := strArray[idx];
		self.assertEqual(tempStr[1:str.length], str);
	endforeach;

	// cleanout transactions from previous test
	beginTransaction;
	camTaskHistory.erase(NORMAL_ERASE);
	objArray.purge;
	commitTransaction;
    
    //TEST2 Test a Wash and a PreTrip produce ONE Repair Entry
	// add some transactions and try again
	transObj := self.createTransaction(container, global.getTiTxnTypeForClass(CM_Wash), null);
	objArray.add(transObj);

	transObj := self.createTransaction(container, global.getTiTxnTypeForClass(CM_PreTrip), null);
	objArray.add(transObj);

	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

	idx := 0;
	strArray.clear();
	strArray.add("UNB+UNOA:2+");
	//strArray.add("UNH+1+CODECO:D:95B:UN:ITG12'");     //17/06/2016 cnwma1  TFS#2159
	strArray.add("UNH+1+CODECO:D:95B:UN:SMDG16'");	 //17/06/2016 cnwma1  TFS#2159
	strArray.add("BGM+999+1+9'");
	strArray.add("TDT+20+VYPAR27945+1+++++:146::VSPAR27945'");
	strArray.add("LOC+9+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+MS+NZCHC:160:87'");
	if app.isRunningInDMAST() then
		strArray.add("EQD+CN+PARC1230001+2200:102:5+++4'");
	elseif app.isRunningInWMAST() then
		strArray.add("EQD+CN+PARC1230001+AP01:102:5+++4'");
	endif;
	strArray.add("DTM+7:");
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("FTX+DAR++7'");
	strArray.add("CNT+16:1'");
	strArray.add("UNT+13+1'");
	strArray.add("UNZ+1+0'");
	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		idx := idx + 1;
		str := strArray[idx];
		self.assertEqual(tempStr[1:str.length], str);
	endforeach;

	// cleanout transactions from previous test
	beginTransaction;
	camTaskHistory.erase(NORMAL_ERASE);
	objArray.purge;
	commitTransaction;
    
    
    // TEST3  Damage, ReleaseRoad and PreTrip produce ONE Damage and ONE Repair entry
	//process.sleep(1000);
	transObj := self.createTransaction(container, global.getTiTxnTypeForClass(CM_Damage), null);
	objArray.add(transObj);

	transObj := self.createTransaction(container, global.getTiTxnTypeForClass(CM_ReleaseRoad), null);
	objArray.add(transObj);

	transObj := self.createTransaction(container, global.getTiTxnTypeForClass(CM_PreTrip), null);
	objArray.add(transObj);

	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

	idx := 0;
	strArray.clear();
	strArray.add("UNB+UNOA:2+");
	//strArray.add("UNH+1+CODECO:D:95B:UN:ITG12'");     //17/06/2016 cnwma1  TFS#2159
	strArray.add("UNH+1+CODECO:D:95B:UN:SMDG16'");	 //17/06/2016 cnwma1  TFS#2159
	strArray.add("BGM+999+1+9'");
	strArray.add("TDT+20+VYPAR27945+1+++++:146::VSPAR27945'");
	strArray.add("LOC+9+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+MS+NZCHC:160:87'");
	if app.isRunningInDMAST() then
		strArray.add("EQD+CN+PARC1230001+2200:102:5+++4'");
	elseif app.isRunningInWMAST() then
		strArray.add("EQD+CN+PARC1230001+AP01:102:5+++4'");
	endif;
	strArray.add("DTM+7:");
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("FTX+DAR++8'");
	if app.isRunningInDMAST() then
		strArray.add("EQD+CN+PARC1230001+2200:102:5+++4'");
	elseif app.isRunningInWMAST() then
		strArray.add("EQD+CN+PARC1230001+AP01:102:5+++4'");
	endif;
	strArray.add("DTM+7:");
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("FTX+DAR++7'");
	strArray.add("CNT+16:2'");
	strArray.add("UNT+18+1'");
	strArray.add("UNZ+1+0'");
	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		idx := idx + 1;
		str := strArray[idx];
		self.assertEqual(tempStr[1:str.length], str);
	endforeach;

	// cleanout transactions from previous test
	beginTransaction;
	camTaskHistory.erase(NORMAL_ERASE);
	objArray.purge;
	commitTransaction;
    
    // TEST 4 2xDamage and Wash produce ONE Repair and ONE Damage Entry
	transObj := self.createTransaction(container, global.getTiTxnTypeForClass(CM_Damage), null);
	objArray.add(transObj);

	transObj := self.createTransaction(container, global.getTiTxnTypeForClass(CM_Damage), null);
	objArray.add(transObj);

	transObj := self.createTransaction(container, global.getTiTxnTypeForClass(CM_Wash), null);
	objArray.add(transObj);

	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

	idx := 0;
	strArray.clear();
	strArray.add("UNB+UNOA:2+");
	//strArray.add("UNH+1+CODECO:D:95B:UN:ITG12'");     //17/06/2016 cnwma1  TFS#2159
	strArray.add("UNH+1+CODECO:D:95B:UN:SMDG16'");	 //17/06/2016 cnwma1  TFS#2159
	strArray.add("BGM+999+1+9'");
	strArray.add("TDT+20+VYPAR27945+1+++++:146::VSPAR27945'");
	strArray.add("LOC+9+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+MS+NZCHC:160:87'");
	if app.isRunningInDMAST() then
		strArray.add("EQD+CN+PARC1230001+2200:102:5+++4'");
	elseif app.isRunningInWMAST() then
		strArray.add("EQD+CN+PARC1230001+AP01:102:5+++4'");
	endif;
	strArray.add("DTM+7:");
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("FTX+DAR++8'");
	if app.isRunningInDMAST() then
		strArray.add("EQD+CN+PARC1230001+2200:102:5+++4'");
	elseif app.isRunningInWMAST() then
		strArray.add("EQD+CN+PARC1230001+AP01:102:5+++4'");
	endif;
	strArray.add("DTM+7:");
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("FTX+DAR++7'");
	strArray.add("CNT+16:2'");
	strArray.add("UNT+18+1'");
	strArray.add("UNZ+1+0'");
	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		idx := idx + 1;
		str := strArray[idx];
		self.assertEqual(tempStr[1:str.length], str);
	endforeach;

		// cleanout transactions from previous test
	beginTransaction;
	camTaskHistory.erase(NORMAL_ERASE);
	objArray.purge;
	commitTransaction;
    
	// TEST 5 2xDamage (separated by a RopadReceipt) and Wash produce ONE Repair and ONE Damage Entry
	transObj := self.createTransaction(container, global.getTiTxnTypeForClass(CM_Damage), null);
	objArray.add(transObj);

	transObj := self.createTransaction(container, global.getTiTxnTypeForClass(CM_ReceiveRoad), null);
	objArray.add(transObj);

	transObj := self.createTransaction(container, global.getTiTxnTypeForClass(CM_Damage), null);
	objArray.add(transObj);

	transObj := self.createTransaction(container, global.getTiTxnTypeForClass(CM_Wash), null);
	objArray.add(transObj);

	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime,camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

	idx := 0;
	strArray.clear();
	strArray.add("UNB+UNOA:2+");
	//strArray.add("UNH+1+CODECO:D:95B:UN:ITG12'");     //17/06/2016 cnwma1  TFS#2159
	strArray.add("UNH+1+CODECO:D:95B:UN:SMDG16'");	 //17/06/2016 cnwma1  TFS#2159
	strArray.add("BGM+999+1+9'");
	strArray.add("TDT+20+VYPAR27945+1+++++:146::VSPAR27945'");
