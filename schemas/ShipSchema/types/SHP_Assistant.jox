    <JadeMethod name="showROROPrintForm" id="c2d4b57e-75fd-4519-8d7f-4c87261c5ef4">
        <source>showROROPrintForm(	_printObject :CM_Object;
					_modeView : Integer;
					_modeViewSub : Integer) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 May 2011	cnwer1	Initial creation CCMS 1031

*/

vars

	form 		: SHP_ROROPrint;

begin
	
	if not _printObject.isKindOf(CM_Deck) and not _printObject.isKindOf(CM_ROROVesselStructure) and not _printObject.isKindOf(CM_ROROVoyageStructure) then
		return IDCANCEL;
	endif;

	form := app.loadForm(SHP_ROROPrint, SHP_Assistant, false, false, false, self.myTerminal, null).SHP_ROROPrint;	
	
	if form = null then
		return IDCANCEL;
	endif;
	
	form.initDetails(_printObject, _modeView, _modeViewSub);

	return form.showModal;

epilog

end;</source>
        <Parameter name="_printObject" type="CM_Object"/>
        <Parameter name="_modeView" type="Integer"/>
        <Parameter name="_modeViewSub" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
