	Written by	:	cnwgrp1		04 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
		sa : StringArray;

begin
	if myWorkbookDefinition &lt;&gt; null then
		myControllingAppsDA.invokeMethod(myControllingAppsContext,myControllingAppsWiz2Method, associatedObjectType, associatedObjectName, myAssociatedObject, myWorkbookDefinition.myApplicationExtractOptions);
	else
		myControllingAppsDA.invokeMethod(myControllingAppsContext,myControllingAppsWiz2Method, associatedObjectType, associatedObjectName, myAssociatedObject, null);
	endif;
	
	
epilog

end;</source>
    </JadeMethod>
