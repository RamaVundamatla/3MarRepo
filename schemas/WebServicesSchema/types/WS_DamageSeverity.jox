<Class name="WS_DamageSeverity" id="a7e10233-4aaa-4544-870a-272bb364262a">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Represents the severity of the damage, A value of one (1) corresponds to minor damage while five (5) corresponds to the most-severe damage.</text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="code" id="c71fbcaf-ed35-4f66-94fa-cdc505f38a8e">
        <length>21</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="description" id="e812dd4f-f6d4-49ff-a80c-38e46158b2b6">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="severity" id="069890c5-de64-48c8-bf59-486b3613b0e8">
        <embedded/>
        <type name="Integer"/>
        <text>Severity value ex.1,2,3,4,5</text>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="cf577aba-b5a4-4620-857c-12947ec240a0">
        <updating/>
        <source>setProxyFromObject(_object: CM_DamageSeverity) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 July 2015	cnwmc5	Initial creation
22 Mar 2023		navlw1  tfs 53812

*/

vars

begin
	inheritMethod(_object);
	
	self.severity := _object.level;
	self.code :=  _object.code;
	self.description := _object.description;

epilog

end;</source>
        <Parameter name="_object" type="CM_DamageSeverity"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromValue" id="7a422a02-f826-4c2e-8085-6b437cf4cdd7">
