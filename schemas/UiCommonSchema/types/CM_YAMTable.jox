    <JadeMethod name="initialise" id="94d9e561-7926-41c6-aceb-6d2f834adbe7">
        <updating/>
        <source>initialise( _manuallyMaintained : Boolean; fra : Frame; p1, p2, p3 : Picture input) updating;
//15 August 2008	cnwdw1	
//
vars
	allocationObj	: CM_YardAllocation;
	block: CM_YABlock;
	rowObj			: JadeTableRow;
	rowPointer		: Integer;
	rowStr		: String;
	colDescr,
	colDescrWidth,
	colTAs,
	colTAsWidth,
	backColour		: Integer;
	tmpHeight		: Integer;
	rowString: String;
	index: Integer;
	yaRow, yaBlockRow: Integer;
	
begin
	self.isManuallyMaintained := _manuallyMaintained;

	if self.mySearchParameters = null then
		create self.mySearchParameters transient;
	endif;
	
	self.pic1 := p1;
	self.pic2 := p2;
	self.pic3 := p3;
	self.framePics := fra;
	
	self.mySearchParameters.resetValues();

	self.refreshMe();
	
	self.registerNotes();
epilog
end;</source>
