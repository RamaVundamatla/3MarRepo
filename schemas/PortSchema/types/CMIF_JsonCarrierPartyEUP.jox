<Class name="CMIF_JsonCarrierPartyEUP" id="93f7e881-2cc2-4b12-a17a-72879e082cee">
    <superclass name="CMIF_JsonTransform"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Created as subtags for the JSON for EUP TFS - 55859</text>
    <DbClassMap file="cams"/>
    <PrimAttribute name="code" id="0a934e6a-8aa8-4dc8-bbbb-e7b5f97fd2ab">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="name" id="a449596e-5a2f-4c15-bcf4-527e876975b3">
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="setFromTI" id="0d747fe6-3b63-45dc-9045-0a1f1346a012">
        <updating/>
        <source>setFromTI(theTI : CM_TrackedItem input; voyage : CM_Voyage input; _translationOperator : CM_Operator; _transportMode: String; _isForLoadConfirmation: Boolean) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 22 June 2023
TFS#		: 58506
Function	:

*** Changes ***
Date			Name		TFS#		Description
11/09/2023		jlika1		60337		EUP | FR EDI - EUP CAMS protocols: Translations based on Receiver
6/10/2023		navra1		60396		EUP | FR 54085 - Load Confirmation - Field Mapping
06/05/2024		navhn30		63171		Bug 63171: EUP* | FR - 53853 - GoodsReceipt - Carrier Party Code Missing for Import Cargo from Ship
****************************************************/

vars
	transportationMode 	: String;	
	foundMatch			: Boolean;
	
begin	
	transportationMode := _transportMode;
	
	if transportationMode = TI_TRANSMODE_ROAD_STR or transportationMode = TI_TRANSMODE_RAIL_STR then
		if _isForLoadConfirmation then			//navra1 - TFS 60396 - 6th Oct 2023
			//jlier1 TFS 60112 20/9/23
			self.code :=theTI.releaseCarrier; // this is also the theTI.releaseCarrier
			self.name := theTI.getReleaseCarrierDesc();				
		else
			self.code := theTI.carrier; // this is also the theTI.carrier
			self.name := theTI.getCarrierDescription();		
		endif;
		
		if _translationOperator &lt;&gt; null then
			self.code := _translationOperator.getXlationForeignCode(self.code, XLATION_TYPE_CARRIER_BYOP, foundMatch);
		endif;
	elseif transportationMode = TI_TRANSMODE_SHIP_STR then
		if theTI.myVoyage &lt;&gt; null and theTI.myVoyage.myShippingLine &lt;&gt; null then
			self.code := theTI.myVoyage.myShippingLine.code;			//06.05.24		navhn30		TFS #63171
			self.name := theTI.myVoyage.myShippingLine.description;
		endif;
		
		if _translationOperator &lt;&gt; null then
			self.code := _translationOperator.getXlationForeignCode(self.code, XLATION_TYPE_SHIPPINGLINE_BYOP, foundMatch);
		endif;
	endif;	
end;</source>
        <Parameter name="theTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_translationOperator" type="CM_Operator"/>
        <Parameter name="_transportMode" type="String"/>
        <Parameter name="_isForLoadConfirmation" type="Boolean"/>
    </JadeMethod>
</Class>
