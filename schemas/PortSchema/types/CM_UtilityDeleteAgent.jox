    <JadeMethod name="utlDeleteInterfaceDefinition" id="6cac9e70-fc54-43ee-bb75-ac52f709d0ce">
        <source>utlDeleteInterfaceDefinition(_definitionObj:CM_InterfaceDefinition input; _passportObj:CM_Passport input);
// --------------------------------------------------------------------------------
// Created:		05 September 2008 by cnwdad1
//
// Purpose:		Deletes the specified Interface Definition object.
//
// Parameters:	_definitionObj - A reference to the Interface Definition to delete.
//				_passportObj - A reference to the current user's Passport object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	// note that validation agent locks object
	app.myValDA.valDeleteInterfaceDefinition(_definitionObj, _passportObj);
	
	if not self.checkValidationWithPassport(_passportObj) then
		return;
	endif;

	if _passportObj.noErrors() then
		// only requierd if class is audited
		self.myDeleteAuditAgent.audDeleteGeneric(_definitionObj);
	endif;

	if _passportObj.noErrors() then
		// This should be :
		//_obj.erase(NORMAL_ERASE);
		// but is as below so test exceptions can be generated.
		_definitionObj.erase(NORMAL_ERASE);
	endif;
end;</source>
        <Parameter name="_definitionObj" type="CM_InterfaceDefinition" usage="input"/>
        <Parameter name="_passportObj" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteInterfaceHistory" id="4a157b6c-498d-4511-8b4f-ceb3659240d0">
        <source>utlDeleteInterfaceHistory(
	_obj		: CM_InterfaceHistory io;
	_passport	: CM_Passport input );
	
/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
15 May 2009			cnwrl1	Initial creation as part of PAR 19668 - CCMS 1814 - Interface History

*/
	
vars
	
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions( true );
	
	// note that validation agent locks object
	app.myValDA.valInterfaceHistory( _obj );
	
	if not self.checkValidationWithPassport( _passport ) then
		return;
	endif;
	
	if _passport.noErrors then
		// only required if class is audited
		self.myDeleteAuditAgent.audDeleteGeneric( _obj );
	endif;
	
	if _passport.noErrors then
		_obj.erase( NORMAL_ERASE );
	endif;
	
epilog
	
end;
</source>
        <Parameter name="_obj" type="CM_InterfaceHistory" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteInterfaceMssgeHistory" id="270d2fdc-e6a8-4e55-b1a8-d7b528092e51">
        <source>utlDeleteInterfaceMssgeHistory(_messageDefinition : CM_InterfaceDefinition; _ts : TimeStamp; _agent : CM_DBPurgeAgent input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 January 2010	cnwmd1	Initial creation

*/

vars

begin
	self.exclusiveLock(_messageDefinition);
	_messageDefinition.purgeInterfaceMessageHistory(_ts, _agent);
epilog

end;</source>
        <Parameter name="_messageDefinition" type="CM_InterfaceDefinition"/>
        <Parameter name="_ts" type="TimeStamp"/>
        <Parameter name="_agent" type="CM_DBPurgeAgent" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteInvContract" id="9bcba2ae-1566-4316-a647-cbd0a4418c6f">
        <source>utlDeleteInvContract(_obj : CM_InvoiceContract io; _passport : CM_Passport input);
/*
Purpose:			

Date		Who		Reason
01DEC2022	NAVAB1	TFS CR 55623 TASK 55671
*/
vars
	theTerminal : CM_Terminal;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	// note that validation agent locks object
	app.myValDA.valDeleteInvContract(_obj);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	if _passport.noErrors then
		// only requierd if class is audited
		self.myDeleteAuditAgent.audDeleteGeneric(_obj);
		_obj.handleChildDeleteAudits(self.myDeleteAuditAgent);
	endif;

	if _passport.noErrors then
		theTerminal := _obj.getMyTerminal();
		app.myEventManager.createSingleObjInfoNoteEvt(_obj.myBusinessUnit,theTerminal.getTerminalEvent(Event_InvContractDelete),_obj); // ### TFS CR 55645 TASK 55662 13DEC2022 NAVAB1

		_obj.setForDelete();
		
	endif;

end;</source>
        <Parameter name="_obj" type="CM_InvoiceContract" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteInvContractAccumulate" id="e6a99364-8c85-4daa-9b37-74a668b8023c">
        <source>utlDeleteInvContractAccumulate(_invContAccumulate : CM_InvoiceContractAccumulate io; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/06/2023	navkc1	CR 55653 Task 58729: EUP - Contract Vol Based Initialise Accumulations

*/

vars
	invContDtlVolBased : CM_InvoiceContractDtlsVolBased;
begin
	self.initialiseActivity();

	app.setContinueCMExceptions(true);
	
	app.myValDA.valInvContractAccumulate(_invContAccumulate);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;

	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(_invContAccumulate);
		invContDtlVolBased := _invContAccumulate.myContractByVolume;
		_invContAccumulate.erase(NORMAL_ERASE);
		invContDtlVolBased.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_InvContractAccumDelete),true,_invContAccumulate);
	endif;
epilog

end;</source>
        <Parameter name="_invContAccumulate" type="CM_InvoiceContractAccumulate" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteInvContractDtl" id="5c865491-5f02-43fc-835b-0aef203b8c6c">
