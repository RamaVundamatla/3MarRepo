    <JadeMethod name="isFull" id="7bd82150-a40c-467e-9624-c19b18bc7a73">
        <source>isFull(): Boolean;
// -------------------------------------------
// Created 15 June 2005 by cnwdvb1
// -------------------------------------------
vars

	commodity : CM_Commodity;
	mtCommodity : CM_Commodity;
	contentsStatus : CM_ContentsStatus;

begin

	//11 May 2012	NDL	Par 29555
	// if either of these are set to a non empty status then return full
	commodity := self.myCommodity;
	if commodity &lt;&gt; null then
		mtCommodity := app.myRoot.allCommodities[self.myTerminal.getDefaultEmptyCommodity()];
		if commodity &lt;&gt; mtCommodity then
			return true;
		endif;
	endif;
	
	contentsStatus := self.myContentsStatus;
	if contentsStatus &lt;&gt; null then
		if contentsStatus.code &lt;&gt; TI_CONTENTS_STATUS_EMPTY then
			return true;
		endif;
	endif;
	
	//if we got this far
	if commodity &lt;&gt; null and commodity = mtCommodity then
		//commodity is set to empty
		return false;
	endif;
	
	if contentsStatus &lt;&gt; null and contentsStatus.code = TI_CONTENTS_STATUS_EMPTY then
		//contentsStatus is set to emopty
		return false;
	endif;
	
	//nothing, defaults to full.
	return true;


end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
