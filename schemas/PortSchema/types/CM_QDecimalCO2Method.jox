    <JadeMethod name="translateToDisplayValue" id="12b344a0-7123-475b-940b-cc8258575978">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 April 2020	jlgndl1	Initial creation	TFS 47958

*/

vars

begin
	
	if _value.Decimal &lt;&gt; NULL_CARBON_DIOXIDE then
		return _value.String;
	endif;
	
	return null;

epilog

end;</source>
