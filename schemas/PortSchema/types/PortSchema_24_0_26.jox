        <source>specificPostStandard(pControllerObj: CnEcReleaseController) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
28 November 2023		navmd1	Initial creation
13 Mar 2024				navhn30	ChangeRequest 55213: GPHA - "Weight can be certified" config option can be deselected for ISO-Containers
04 Jul 2024				jlizm1	TFS 64736 HS Code edi allow invalid codes
09 Sep 2024				navhn30 Bug 61636: NSW | Tech Debt - POB QShips Port Authority Config
19 Jun 2025 			jlizm1	MTN 34778 Add terminal as key for operator cargo group collection
11 Dec 2025				navah1	MTN-36365: NSW | OnePort API Last Run Date - Populate terminal-specific Last Successful Date/Time on upgrade
*/

vars

begin
	inheritMethod(pControllerObj);
	self.convertWeightCanBeCertified(pControllerObj);		//13.03.24		navhn30		TFS #55213
	self.setEDIHSCodeValidConfig(pControllerObj);			// TFS 64736
	self.fixCargoLocationsOnWagons(pControllerObj);         //jlier1 TFS 65100 10/7/24
