        <updating/>
        <source>createInvoiceLineMapEvent(_invoiceLine : String; _quantityRangeMapObj : CM_QuantityRangeMap; _mapType : Integer; 
											_isInContract : Boolean; _groupingType : String; _vesselCategory: HMS_VesselCategory; 
