<Class name="CM_WOToDo_Truck" id="1115af7f-cea9-46a0-b622-134aed96a54d">
    <superclass name="CM_WOTransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <JadeMethod name="getRegNumber" id="1bb0cd0a-02bb-4b80-ab31-72e4c70451a3">
        <source>getRegNumber(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Jun 2024 navhl20 Bug 64718: EUP | 53812 - VAS Work Order - WO Transactions Report issues
*/

vars
	wod : CM_WodToDoVehicleVisit;
begin
	if self.myWorkOrderDetail = null then
		return null;
	endif;
	
	wod := self.myWorkOrderDetail.CM_WodToDoVehicleVisit;

	if wod.allVehicleVisits.isEmpty() then
		return null;
	endif;
	
	return wod.allVehicleVisits.listStringNoDuplicate(Comma,CM_VehicleVisitRecord::regNumber.name);
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
