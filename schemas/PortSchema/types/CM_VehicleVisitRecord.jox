    <JadeMethod name="idForLocationActivity" id="f2d8be06-e32e-4cb2-96ad-fc0eb07fe316">
        <source>idForLocationActivity():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2021	navndl1	Initial creation	TFS 50906

*/

vars

	str : String;

begin

	str := self.visitNumber;
	
	if self.regNumber &lt;&gt; null then
		str := str &amp; " / " &amp; self.regNumber;
	endif;
	
	if timeIn.isValid then
		str := str &amp; " / " &amp; self.timeIn.asStringJMT;
	endif;

	return  str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initializeForActivity" id="89f21197-677c-4430-893c-cea4f40bddd4">
        <updating/>
        <source>initializeForActivity(_ewsOpsView: CM_EWSActivityOpsview; _opsViewTable : CMIF_OpsViewTables) updating;
/*
Purpose:			

Date		Who		Reason
04 May 2022	navab1	TFS 53569
*/

vars
	visitDetails : CMIF_ArgoVisitDetails;
	carrierVisit : CMIF_ArgoCarrierVisit;
	roadTruckCmif : CMIF_RoadTruckVisitDetails;
	visitStats : CMIF_RoadTruckVisitStats;
	
	carr : CM_Carrier;
	operator : CM_Operator;
begin

	if _opsViewTable.isKindOf(CMIF_ArgoVisitDetails) then
		visitDetails := _opsViewTable.CMIF_ArgoVisitDetails;
		
		visitDetails.tableName := visitDetails.Argo_visit_details;
		visitDetails.gkey := visitDetails.generateFullGKey(self, "");
		visitDetails.eta := self.timeIn.asEpochFormat();
		if self.timeOut.isValid() then //  only send if has departed
			visitDetails.etd := self.timeOut.asEpochFormat(); 
		else
			visitDetails.etd := null; 
		endif;
		
		visitDetails.service := 0; // not used on road jobs, just voyage and rail
		
	elseif _opsViewTable.isKindOf(CMIF_ArgoCarrierVisit) then
		carrierVisit :=  _opsViewTable.CMIF_ArgoCarrierVisit;

		carrierVisit.tableName := carrierVisit.Argo_carrier_visit;
		carrierVisit.gkey := carrierVisit.generateFullGKey(self, "");
		carrierVisit.cvcvd_gkey := carrierVisit.generateFullGKey(self, "");
		
		carrierVisit.ata := self.timeIn.asEpochFormat();
		if self.timeOut.isValid() then //  only send if has departed
			carrierVisit.atd := self.timeOut.asEpochFormat(); 
		else
			carrierVisit.atd := null; 
		endif;
		
		carrierVisit.carrier_mode  := carrierVisit.Carrier_mode_Truck;
		carrierVisit.cpx_gkey := carrierVisit.generateCpxGKey();
		carrierVisit.fcy_gkey := carrierVisit.generateFullGKey(self.myTerminal, "");
		carrierVisit.id  := self.jobNumber;
		
		carr := self.getCarrier();
		if carr &lt;&gt; null then
			carrierVisit.operator_gkey := carrierVisit.generateFullGKey(carr,""); 
		endif;
		
		carrierVisit.phase := carrierVisit.n4TruckVisitStatus(self);

		create visitDetails transient;
		visitDetails.termOid := carrierVisit.termOid;
		visitDetails.oid := carrierVisit.oid;
		
		self.initializeForActivity(_ewsOpsView, visitDetails); 
		carrierVisit.argoVisitDetails := visitDetails;
	elseif _opsViewTable.isKindOf(CMIF_RoadTruckVisitDetails) then
		roadTruckCmif :=  _opsViewTable.CMIF_RoadTruckVisitDetails;

		roadTruckCmif.tableName := roadTruckCmif.Road_truck_visit_details;
		roadTruckCmif.gkey := roadTruckCmif.generateFullGKey(self, "");
		
		
		roadTruckCmif.entered_yard := self.timeIn.asEpochFormat();
		roadTruckCmif.exited_yard := self.timeOut.asEpochFormat();
		roadTruckCmif.truck_license_nbr := self.regNumber;
		roadTruckCmif.status	:= roadTruckCmif.n4TruckVisitStatus(self);
		roadTruckCmif.tvdtls_gkey := roadTruckCmif.generateFullGKey(self, "");

		carr := self.getCarrier();
		if carr &lt;&gt; null then
			roadTruckCmif.trkco_gkey :=   roadTruckCmif.generateFullGKey(carr,""); 
		endif;
		roadTruckCmif.trkco_gkey :=   roadTruckCmif.generateFullGKey(self, "");	
		
	elseif _opsViewTable.isKindOf(CMIF_RoadTruckVisitStats) then
		visitStats :=  _opsViewTable.CMIF_RoadTruckVisitStats;

		visitStats.tableName := visitStats.Road_truck_visit_stats;
		visitStats.gkey := visitStats.generateFullGKey(self, "");
		
		visitStats.started := self.timeIn.asEpochFormat();
		visitStats.completed := self.timeOut.asEpochFormat();
		visitStats.turn_time := self.dwellTimeMinutes * 60000;
		visitStats.tv_gkey := visitStats.generateFullGKey(self, ""); // VVR
		visitStats.tv_status	:= visitStats.n4TruckVisitStatus(self);
		carr := self.getCarrier();
		if carr &lt;&gt; null then
			visitStats.trkc_gkey :=   visitStats.generateFullGKey(carr,"");
		endif;
		visitStats.trkc_gkey :=   visitStats.generateFullGKey(self, "");	
		
		operator := self.getOperatorForRelease();
		visitStats.line_dlv_gkey :=   visitStats.generateFullGKey(operator, "");
		operator := self.getOperatorForReceive();
		visitStats.line_rcv_gkey :=   visitStats.generateFullGKey(operator, "");
		visitStats.had_trouble :=  false; // MTN does not have concept of trouble.

		visitStats.is_canceled :=   self.status = CM_VehicleVisitRecord.Status_Cancelled; 

		visitStats.dlv_chs_count :=  self.getNumTIByType(false,false,true); 
		visitStats.dlv_full_count :=  self.getNumTIByType(false,true,false);
		visitStats.dlv_mty_count :=  self.getNumTIByType(false,false,false);
		visitStats.rcv_chs_count :=  self.getNumTIByType(true,false,true);
		visitStats.rcv_full_count :=  self.getNumTIByType(true,true,false);
		visitStats.rcv_mty_count :=  self.getNumTIByType(true,false,false);
		visitStats.tran_count :=  self.allReceivedTrackedItems.size + self.allReleasedTrackedItems.size;
	endif;
	
epilog

end;</source>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <Parameter name="_opsViewTable" type="CMIF_OpsViewTables"/>
    </JadeMethod>
    <JadeMethod name="isAfterSecGateBeforeTerminal" id="3e31c625-3340-4e80-85ef-602ba0b0f357">
        <source>isAfterSecGateBeforeTerminal():Boolean;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04/11/2015	cnwndl1	Initial creation	Par 36886
17/05/2016	cnwdap1	TFS STWR #1970 Prevent new VVR being created if we have a viable one
						(i.e. VVR has been created, is not cancelled, is not complete)
*/

vars

begin

	if not self.myTerminal.getConfig(SiteHasSecurityGate).Boolean then
		// not using the security gate
		return false;
	endif;
	
	if self.vehicle = null then
		// huh
		return false;
	endif;
	
	// TFS #1970 If a user enters a Registration number and clicks one of the Receive/Release		// TFS #1970
	// buttons, this creates a vehicle visit record with Pre-Check and Arrival A-Gate details		// TFS #1970
	// and places the truck in a gate lane controller - os it is on site and has an arrival time.	// TFS #1970
	// We can't use these to determine whether an existing viable VVR exists						// TFS #1970
	//if self.vehicle.isOnsite then																	// TFS #1970
	//	// is already in there																		// TFS #1970
	//	return false;																				// TFS #1970
	//endif;																						// TFS #1970
	//																								// TFS #1970
	//if self.getArrivalAtGateInTime &lt;&gt; null then													// TFS #1970
	//	//has been in or at the gate																// TFS #1970
	//	return false;																				// TFS #1970
	//endif;																						// TFS #1970
	
	if self.isCancelled then
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isBulkGateVVR" id="ffc87cb9-a868-4397-8dde-9fa1c0217453">
        <source>isBulkGateVVR():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Nov 2016	cnwndl1	Initial creation	TFS 2867 / 2779
24 Apr 2025 navma1  MTN-34621 MTN - 1081 dead lock on CM_EIRNumberDict
*/

vars

	detail	: CM_VehicleVisitRecordDetail;
	
begin

	foreach detail in self.allVehicleVisitRecordDetails discreteLock do //22.04.2025 navma1 #MTN-34621
		if detail.isBulkGateVVRD then
			return true;
		endif;
	endforeach;
	
	return false;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isCancelled" id="fcec7a1f-3e3c-4908-a75c-4b0098df0bfa">
        <source>isCancelled() : Boolean;

/*

Purpose:		Return the cancelled reason	

Parameters:			

Return Value:		


Date		Who		Reason
