    <text>


MTN = BOL item and Booking item
N4 = aux_crg_bl_item


Attribute gkey  (Integer64)
Attribute nbr   (String 30)
Attribute client_id   (String 25)
Attribute bl_gkey  (Integer64)
Attribute product_type_gkey  (Integer64)
Attribute commodity_gkey  (Integer64)
Attribute quantity (Real)
Attribute is_bulk (Boolean)
Attribute bulk_unit   (String 255)
Attribute package_type_gkey  (Integer64)
Attribute package_weight_kg  (Real)
Attribute package_length_cm  (Real)
Attribute package_width_cm  (Real)
Attribute package_height_cm  (Real)
Attribute piece_quantity  (Real)
Attribute piece_package_type_gkey  (Integer64)
