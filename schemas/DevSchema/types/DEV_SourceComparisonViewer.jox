    <JadeMethod name="loadData" id="658ec878-2653-46da-941c-0a02dd0cccf0">
        <updating/>
        <source>loadData(_report : DEV_SourceCompareReport; _userCode : String) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 December 2021	navpw1	Initial creation TFS: 52202

*/
vars
	searchString	: String;
begin
	searchString := _userCode;
	
	self.endNotificationForSubscriber(self);

	self.btnExportReport.enabled := true;
	self.myReport := _report;
	/*
	* Differing Methods
	*/
	self.loadDifferingMethods(_report, searchString);
	
	// If the search is not for a usercode, then clear it
	if not _userCode.startsWith__("nav") and not _userCode.startsWith__("jlg") and not _userCode.startsWith__("jli") and 
		not _userCode.startsWith__("cnw") and _userCode &lt;&gt; "JadeLoader" and _userCode &lt;&gt; "&lt;unknown&gt;" then
		searchString := null;
	endif;
	
	/*
	* Missing/Differing Class Data
	* Attributes
	* References
	* Constants
	*/
	self.loadMissingClasses(_report, searchString);
	
	/*
	* Missing Methods
	*/
	self.loadMissingMethods(_report, searchString);
	
	
	/*
	* Global Constants
	*/
	self.loadGlobalConstants(_report, searchString);
	
end;</source>
        <access>protected</access>
        <Parameter name="_report" type="DEV_SourceCompareReport"/>
        <Parameter name="_userCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="loadDifferingMethods" id="fb0ecc76-5940-4060-a73c-372555e3776a">
        <source>loadDifferingMethods(_report : DEV_SourceCompareReport; _searchString : String) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 December 2021	navpw1	Initial creation TFS: 52202
30 Jul 2025			navah1	Story 34749: MTN - Source Compare - Add counts to List Boxes and Heading Labels
*/ 
vars
	schema 			: DEV_Schema;
	class 			: DEV_Class;
	devMethod 		: DEV_Method;
	addedSchema,
	addedClass 		: Boolean;
	currentMethod	: Method;
	systemSchema	: Schema;
	systemClass		: Class;
	systemMethod	: Method;
	showResolved	: Boolean;
	jadeRegexReplacePat : JadeRegexPattern;
	classCount,							//30.07.2025 navah1 #34749
	methodCount,						//30.07.2025 navah1 #34749
	classIndex,							//30.07.2025 navah1 #34749
	schemaIndex		: Integer;      	//30.07.2025 navah1 #34749
begin
	showResolved := self.chkShowResolved.value;

	// ### JIRA 36455 23OCT2026 NAVAB1
	if not self.qlbDifferentMethods.visible then
		_report.setTableDataDiffMethods(_searchString,self.tblDiffMethods);
		return;
	endif;
	
	
	create jadeRegexReplacePat transient;
	jadeRegexReplacePat.compile("[\r\n\t\s]");
	jadeRegexReplacePat.setIgnoreCase(true);
	jadeRegexReplacePat.setExplicitCapture(true);
	
	/*
	* Differing Methods
	*/
	foreach schema in _report.allSchemas do
		systemSchema := rootSchema.getSchema(schema.name);
		addedSchema := false;
		classCount := 0; //30.07.2025 navah1 #34749
		
		foreach class in schema.allClasses where class.reason = DEV_SourceCompareReportAgent.Object_Link do
			systemClass := systemSchema.getClass(class.name);
			addedClass := false;
			methodCount := 0; //30.07.2025 navah1 #34749
			foreach devMethod in class.allMethods where devMethod.reason = DEV_SourceCompareReportAgent.Object_Different do
				
				// If someone else has already looked at this method, then don't display it
				if devMethod.resolvedBy &lt;&gt; null and not showResolved then
					continue;
				endif;
				
				systemMethod := systemClass.getMethod(devMethod.name);
				if _searchString &lt;&gt; null then
					// Filter by Usercode (assumes users start with 'nav')
					if _searchString.startsWith__("nav") or _searchString.startsWith__("jlg") or 
							_searchString.startsWith__("jli") or _searchString.startsWith__("cnw") or 
							_searchString = "JadeLoader" or _searchString = "&lt;unknown&gt;"then
						if devMethod.modifiedBy &lt;&gt; _searchString and (systemMethod &lt;&gt; null and systemMethod.getModifiedByJMT &lt;&gt; _searchString) then 
							continue;
						endif;
					else
						// Filter by method text
						if devMethod.desc.pos(_searchString, 1) = 0 then
							continue;
						endif;
					endif;
				endif;
				
				if not addedSchema then
					self.qlbDifferentMethods.addItem(schema.name);
					self.qlbDifferentMethods.itemObject[self.qlbDifferentMethods.newIndex] := schema;
					self.qlbDifferentMethods.itemLevel[self.qlbDifferentMethods.newIndex] := 1;
					self.qlbDifferentMethods.itemExpanded[self.qlbDifferentMethods.newIndex] := false;
					if schema.resolvedBy &lt;&gt; null then
						self.qlbDifferentMethods.itemForeColor[self.qlbDifferentMethods.newIndex] := Gray;
					else
						self.qlbDifferentMethods.itemForeColor[self.qlbDifferentMethods.newIndex] := Window.Color_WindowText;
					endif;
					addedSchema := true;
					schemaIndex := self.qlbDifferentMethods.newIndex; //30.07.2025 navah1 #34749
					self.beginNotification(schema, Object_Update_Event, Response_Continuous, null);
				endif;
				
				if not addedClass then
					self.qlbDifferentMethods.addItem(class.name);
					self.qlbDifferentMethods.itemObject[self.qlbDifferentMethods.newIndex] := class;
					self.qlbDifferentMethods.itemLevel[self.qlbDifferentMethods.newIndex] := 2;
					self.qlbDifferentMethods.itemExpanded[self.qlbDifferentMethods.newIndex] := false;
					if class.resolvedBy &lt;&gt; null then
						self.qlbDifferentMethods.itemForeColor[self.qlbDifferentMethods.newIndex] := Gray;
					else
						self.qlbDifferentMethods.itemForeColor[self.qlbDifferentMethods.newIndex] := Window.Color_WindowText;
					endif;
					addedClass := true;
					classIndex := self.qlbDifferentMethods.newIndex; //30.07.2025 navah1 #34749
					self.beginNotification(class, Object_Update_Event, Response_Continuous, null);
				endif;
				
				self.qlbDifferentMethods.addItem(devMethod.name);
				self.qlbDifferentMethods.itemObject[self.qlbDifferentMethods.newIndex] := devMethod;
				self.qlbDifferentMethods.itemLevel[self.qlbDifferentMethods.newIndex] := 3;
				self.qlbDifferentMethods.itemExpanded[self.qlbDifferentMethods.newIndex] := false;
				
				if systemMethod &lt;&gt; null and jadeRegexReplacePat.replaceAll(systemMethod.getSource(), "") = jadeRegexReplacePat.replaceAll(devMethod.desc, "") then
					self.qlbDifferentMethods.itemBackColor[self.qlbDifferentMethods.newIndex] := PalePink;
				endif;
				
				if devMethod.resolvedBy &lt;&gt; null then
					self.qlbDifferentMethods.itemForeColor[self.qlbDifferentMethods.newIndex] := Gray;
				else
					self.qlbDifferentMethods.itemForeColor[self.qlbDifferentMethods.newIndex] := Window.Color_WindowText;
				endif;
				
				methodCount += 1; //30.07.2025 navah1 #34749
				self.beginNotification(devMethod, Object_Update_Event, Response_Continuous, null);  
			endforeach;
			
			if methodCount &gt; 0 then //30.07.2025 navah1 #34749
				self.qlbDifferentMethods.itemText[classIndex] :=  app.getErrorString2(LabelWithValue, class.name, methodCount.String);
				classCount += methodCount; 
			endif; 
		endforeach;
		
		if classCount &gt; 0 then //30.07.2025 navah1 #34749
			self.qlbDifferentMethods.itemText[schemaIndex] := app.getErrorString2(LabelWithValue, schema.name, classCount.String);
		endif;
	endforeach;
	
epilog
	delete jadeRegexReplacePat;
	
end;</source>
        <access>protected</access>
        <Parameter name="_report" type="DEV_SourceCompareReport"/>
        <Parameter name="_searchString" type="String"/>
    </JadeMethod>
    <JadeMethod name="loadGlobalConstants" id="e153aef9-7ac1-44b4-9f01-e51a5749a1e0">
        <source>loadGlobalConstants(_report : DEV_SourceCompareReport; _userCode : String) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 December 2021	navpw1	Initial creation TFS: 52202
30 Jul 2025			navah1	Story 34749: MTN - Source Compare - Add counts to List Boxes and Heading Labels
*/

vars
	schema 					: DEV_Schema;
	globalConstantCategory 	: DEV_GlobalConstantCategory;
	globalConstant 			: DEV_GlobalConstant;
	addedSchema,
	addedCategory 			: Boolean;
	systemSchema			: Schema;
	systemGlobalConstCategory	: ConstantCategory;
	systemGlobalConstant	: Constant;
	showResolved			: Boolean;
	jadeRegexReplacePat		: JadeRegexPattern;
	categoryCount,							//30.07.2025 navah1 #34749
	constantCount,							//30.07.2025 navah1 #34749
	categoryIndex,							//30.07.2025 navah1 #34749
	schemaIndex 			: Integer;		//30.07.2025 navah1 #34749
	
begin
	showResolved := self.chkShowResolved.value;
	
	create jadeRegexReplacePat transient;
	jadeRegexReplacePat.compile("[\r\n\t\s]");
	jadeRegexReplacePat.setIgnoreCase(true);
	jadeRegexReplacePat.setExplicitCapture(true);
	
	foreach schema in _report.allSchemas do
		systemSchema := rootSchema.getSchema(schema.name);
		addedSchema := false;
		categoryCount := 0;	//30.07.2025 navah1 #34749
		foreach globalConstantCategory in schema.allGlobalConstantCategories do
			addedCategory := false;
			systemGlobalConstCategory := systemSchema.getConstantCategory(globalConstantCategory.name);
			constantCount := 0; //30.07.2025 navah1 #34749
			// If someone else has already looked at this global constant category, then don't display it
			if globalConstantCategory.resolvedBy &lt;&gt; null and not showResolved then
				continue;
			endif;
			
			if globalConstantCategory.reason &lt;&gt; DEV_SourceCompareReportAgent.Object_Link then
				if _userCode &lt;&gt; null and 
					//(systemGlobalConstCategory &lt;&gt; null and
					//systemGlobalConstCategory.getModifiedByJMT.toUpper &lt;&gt; _userCode.toUpper()) or
					(globalConstantCategory.modifiedBy.toUpper &lt;&gt; _userCode.toUpper())
				then 
					continue;
				endif;
				
				if not addedSchema then
					self.qlbGlobalConstants.addItem(schema.name);
					self.qlbGlobalConstants.itemObject[self.qlbGlobalConstants.newIndex] := schema;
					self.qlbGlobalConstants.itemLevel[self.qlbGlobalConstants.newIndex] := 1;
					self.qlbGlobalConstants.itemExpanded[self.qlbGlobalConstants.newIndex] := false;
					if schema.resolvedBy &lt;&gt; null then
						self.qlbGlobalConstants.itemForeColor[self.qlbGlobalConstants.newIndex] := Gray;
					else
						self.qlbGlobalConstants.itemForeColor[self.qlbGlobalConstants.newIndex] := Window.Color_WindowText;
					endif;
					addedSchema := true;
					schemaIndex := self.qlbGlobalConstants.newIndex; //30.07.2025 navah1 #34749
				endif;
				
				if globalConstantCategory.reason = DEV_SourceCompareReportAgent.Object_Missing then
					self.qlbGlobalConstants.addItem(globalConstantCategory.name &amp; " - Missing");
					
				elseif globalConstantCategory.reason = DEV_SourceCompareReportAgent.Object_Different then
					self.qlbGlobalConstants.addItem(globalConstantCategory.name &amp; " - Different");
				endif;
				
				self.qlbGlobalConstants.itemObject[self.qlbGlobalConstants.newIndex] := globalConstantCategory;
				self.qlbGlobalConstants.itemLevel[self.qlbGlobalConstants.newIndex] := 2;
				self.qlbGlobalConstants.itemExpanded[self.qlbGlobalConstants.newIndex] := false;
				if globalConstantCategory.resolvedBy &lt;&gt; null then
					self.qlbGlobalConstants.itemForeColor[self.qlbGlobalConstants.newIndex] := Gray;
				else
					self.qlbGlobalConstants.itemForeColor[self.qlbGlobalConstants.newIndex] := Window.Color_WindowText;
				endif;
				addedCategory := true;
				categoryIndex := self.qlbGlobalConstants.newIndex; //30.07.2025 navah1 #34749
			endif;
			
			foreach globalConstant in globalConstantCategory.allConstants do
				systemGlobalConstant := systemSchema.getConstant(globalConstant.name);
				if _userCode &lt;&gt; null and 
					//(systemGlobalConstant &lt;&gt; null and
					//systemGlobalConstant.getModifiedByJMT.toUpper &lt;&gt; _userCode.toUpper()) or
					(globalConstant.modifiedBy.toUpper &lt;&gt; _userCode.toUpper())
				then 
					continue;
				endif;
				
				// If someone else has already looked at this global constant category, then don't display it
				if globalConstant.resolvedBy &lt;&gt; null and not showResolved then
					continue;
				endif;
				
				if not addedSchema then
					self.qlbGlobalConstants.addItem(schema.name);
					self.qlbGlobalConstants.itemObject[self.qlbGlobalConstants.newIndex] := schema;
					self.qlbGlobalConstants.itemLevel[self.qlbGlobalConstants.newIndex] := 1;
					self.qlbGlobalConstants.itemExpanded[self.qlbGlobalConstants.newIndex] := false;
					if schema.resolvedBy &lt;&gt; null then
						self.qlbGlobalConstants.itemForeColor[self.qlbGlobalConstants.newIndex] := Gray;
					else
						self.qlbGlobalConstants.itemForeColor[self.qlbGlobalConstants.newIndex] := Window.Color_WindowText;
					endif;
					addedSchema := true;
					schemaIndex := self.qlbGlobalConstants.newIndex; //30.07.2025 navah1 #34749
				endif;
				
				if not addedCategory then
					self.qlbGlobalConstants.addItem(globalConstantCategory.name);
					self.qlbGlobalConstants.itemObject[self.qlbGlobalConstants.newIndex] := globalConstantCategory;
					self.qlbGlobalConstants.itemLevel[self.qlbGlobalConstants.newIndex] := 2;
					self.qlbGlobalConstants.itemExpanded[self.qlbGlobalConstants.newIndex] := false;
					if globalConstantCategory.resolvedBy &lt;&gt; null then
						self.qlbGlobalConstants.itemForeColor[self.qlbGlobalConstants.newIndex] := Gray;
					else
						self.qlbGlobalConstants.itemForeColor[self.qlbGlobalConstants.newIndex] := Window.Color_WindowText;
					endif;
					addedCategory := true;
					categoryIndex := self.qlbGlobalConstants.newIndex; //30.07.2025 navah1 #34749
				endif;
				
				if globalConstant.reason = DEV_SourceCompareReportAgent.Object_Missing then
					self.qlbGlobalConstants.addItem(globalConstant.name &amp; " - Missing");
				else
					self.qlbGlobalConstants.addItem(globalConstant.name &amp; " - Different");
					
					if process.isPW and jadeRegexReplacePat.replaceAll(systemGlobalConstant.text, "") = jadeRegexReplacePat.replaceAll(globalConstant.documentationTextData, "") then
						self.qlbGlobalConstants.itemBackColor[self.qlbGlobalConstants.newIndex] := PalePink;
					endif;
				endif;
				
				self.qlbGlobalConstants.itemObject[self.qlbGlobalConstants.newIndex] := globalConstant;
				self.qlbGlobalConstants.itemLevel[self.qlbGlobalConstants.newIndex] := 3;
				self.qlbGlobalConstants.itemExpanded[self.qlbGlobalConstants.newIndex] := false;
				if globalConstant.resolvedBy &lt;&gt; null then
					self.qlbGlobalConstants.itemForeColor[self.qlbGlobalConstants.newIndex] := Gray;
				else
					self.qlbGlobalConstants.itemForeColor[self.qlbGlobalConstants.newIndex] := Window.Color_WindowText;
				endif;
				constantCount += 1; //30.07.2025 navah1 #34749
			endforeach;
			
			if constantCount &gt; 0 then //30.07.2025 navah1 #34749
				self.qlbGlobalConstants.itemText[categoryIndex] := app.getErrorString2(LabelWithValue, globalConstantCategory.name, constantCount.String);
				categoryCount += constantCount;
			endif;
		endforeach;
		
		if categoryCount &gt; 0 then //30.07.2025 navah1 #34749
			self.qlbGlobalConstants.itemText[schemaIndex] := app.getErrorString2(LabelWithValue, schema.name, categoryCount.String);
		endif;
	endforeach;
	
epilog
	delete jadeRegexReplacePat;
	
end;</source>
        <access>protected</access>
        <Parameter name="_report" type="DEV_SourceCompareReport"/>
        <Parameter name="_userCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="loadJadeMethod" id="72e714a1-714f-434c-9023-653b13902305">
        <source>loadJadeMethod() protected;
/*

Purpose:			Laods a specific jade method to replace Loaded version in case of fixup in Loaded environment without doing full comparison again

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
09 September 2022	navpw1	Initial creation

*/

vars
	fileGet : CMDFileOpen;
	impFile : File;
	sourceCompareAgent : DEV_SourceCompareAgent;
	
begin
	create sourceCompareAgent transient;
	create impFile transient;
	impFile.kind := File.Kind_Unknown_Text;
	
	if impFile = null then
		app.raiseUnexpectedProgramError(class.name, method.name, " file is null - create file before calling ");
	endif;
	
	create fileGet transient;
	fileGet.filter 		:= 'Jade Method (.mth)|*.mth';
	//fileGet.filter 		:= 'Jade Method (.mth)|*.mth|Jade Class (.cls)|*.cls|Jade Schema (.scm)|*.scm';
	fileGet.filterIndex	:= 1;
	fileGet.fileName 	:= '';
	fileGet.initDir 	:= "C:\";
	
	if fileGet.open = 0 then
		impFile.fileName := fileGet.fileName;
	endif;
	
	if impFile.fileName = null then
		return;
	endif;
	
	//Use Source Compare Agent to load mth file into the source comparison report
	sourceCompareAgent.doLoadJadeMethod(impFile, impFile.name.replace(".scm", ""));
	
epilog
	delete impFile;
	delete sourceCompareAgent;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadMissingClasses" id="cfa5a342-f84f-4e13-aee4-63bddf882e8e">
        <source>loadMissingClasses(_report : DEV_SourceCompareReport; _userCode : String) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 December 2021	navpw1	Initial creation TFS: 52202
30 Jul 2025			navah1	Story 34749: MTN - Source Compare - Add counts to List Boxes and Heading Labels
*/

vars
	schema 			: DEV_Schema;
	class 			: DEV_Class;
	attribute 		: DEV_Attribute;
	constant 		: DEV_ClassConstant;
	reference 		: DEV_Reference;
	addedSchema,
	addedClass,
	addedAttributes,
	addedConstants,
	addedReferences : Boolean;
	systemSchema	: Schema;
	systemClass		: Class;
	systemReference : Reference;
	classCount,						//30.07.2025 navah1 #34749 - Start
	attributeCount,					 
	referenceCount,					 
	constantCount,					  
	total,							 
	classIndex,						 
	schemaIndex,					 
	attributeIndex,					 
	referenceIndex,					 
	constantIndex	: Integer;		//30.07.2025 navah1 #34749 - End
begin
	foreach schema in _report.allSchemas do
		addedSchema := false;
		systemSchema := rootSchema.getSchema(schema.name);
		classCount := 0; //30.07.2025 navah1 #34749
		foreach class in schema.allClasses do
			addedClass := false;
			addedAttributes := false;
			addedConstants := false;
			addedReferences := false;
			systemClass := systemSchema.getClass(class.name);
			attributeCount := 0; //30.07.2025 navah1 #34749
			referenceCount := 0; //30.07.2025 navah1 #34749
			constantCount := 0;  //30.07.2025 navah1 #34749
			
			if not self.chkShowResolved.value and class.resolvedBy &lt;&gt; null then
				continue;
			endif;
			
			if class.reason &lt;&gt; DEV_SourceCompareReportAgent.Object_Link then
				if _userCode &lt;&gt; null and class.modifiedBy &lt;&gt; _userCode then 
					continue;
				endif;
				
				if not addedSchema then
					self.qlbClassData.addItem(schema.name);
					self.qlbClassData.itemObject[self.qlbClassData.newIndex] := schema;
					self.qlbClassData.itemLevel[self.qlbClassData.newIndex] := 1;
					self.qlbClassData.itemExpanded[self.qlbClassData.newIndex] := false;
					addedSchema := true;
					schemaIndex := self.qlbClassData.newIndex; //30.07.2025 navah1 #34749
				endif;
				
				if class.reason = DEV_SourceCompareReportAgent.Object_Missing then
					self.qlbClassData.addItem(class.name &amp; " - Missing");
				elseif class.reason = DEV_SourceCompareReportAgent.Object_Different then
					self.qlbClassData.addItem(class.name &amp; " - Different");
				endif;
				
				if class.resolvedBy &lt;&gt; null then
					self.qlbClassData.itemForeColor[self.qlbClassData.newIndex] := Gray;
				else
					self.qlbClassData.itemForeColor[self.qlbClassData.newIndex] := Window.Color_WindowText;
				endif;
				
				self.qlbClassData.itemObject[self.qlbClassData.newIndex] := class;
				self.qlbClassData.itemLevel[self.qlbClassData.newIndex] := 2;
				self.qlbClassData.itemExpanded[self.qlbClassData.newIndex] := false;
				addedClass := true;
				classIndex := self.qlbClassData.newIndex; //30.07.2025 navah1 #34749
			endif;
			
			foreach attribute in class.allAttributes do
				if not self.chkShowResolved.value and attribute.resolvedBy &lt;&gt; null then
					continue;
				endif;
				
				if _userCode &lt;&gt; null and attribute.modifiedBy &lt;&gt; _userCode then 
					continue;
				endif;
				
				if not addedSchema then
					self.qlbClassData.addItem(schema.name);
					self.qlbClassData.itemObject[self.qlbClassData.newIndex] := schema;
					self.qlbClassData.itemLevel[self.qlbClassData.newIndex] := 1;
					self.qlbClassData.itemExpanded[self.qlbClassData.newIndex] := false;
					addedSchema := true;
					schemaIndex := self.qlbClassData.newIndex; //30.07.2025 navah1 #34749
				endif;
				
				if not addedClass then
					self.qlbClassData.addItem(class.name);
					self.qlbClassData.itemObject[self.qlbClassData.newIndex] := class;
					self.qlbClassData.itemLevel[self.qlbClassData.newIndex] := 2;
					self.qlbClassData.itemExpanded[self.qlbClassData.newIndex] := false;
					addedClass := true; 
					classIndex := self.qlbClassData.newIndex; //30.07.2025 navah1 #34749
				endif;
				
				if not addedAttributes then
					self.qlbClassData.addItem("--Attributes--");
					self.qlbClassData.itemObject[self.qlbClassData.newIndex] := null;
					self.qlbClassData.itemLevel[self.qlbClassData.newIndex] := 3;
					self.qlbClassData.itemExpanded[self.qlbClassData.newIndex] := false;
					addedAttributes := true;
					attributeIndex := self.qlbClassData.newIndex; //30.07.2025 navah1 #34749
				endif;
				
				if attribute.reason = DEV_SourceCompareReportAgent.Object_Missing then
					self.qlbClassData.addItem(attribute.name &amp; " - Missing");
				else
					self.qlbClassData.addItem(attribute.name &amp; " - Different");
				endif;
				
				if attribute.resolvedBy &lt;&gt; null then
					self.qlbClassData.itemForeColor[self.qlbClassData.newIndex] := Gray;
				else
					self.qlbClassData.itemForeColor[self.qlbClassData.newIndex] := Window.Color_WindowText;
				endif;
				
				self.qlbClassData.itemObject[self.qlbClassData.newIndex] := attribute;
				self.qlbClassData.itemLevel[self.qlbClassData.newIndex] := 4;
				self.qlbClassData.itemExpanded[self.qlbClassData.newIndex] := false;
				attributeCount += 1; //30.07.2025 navah1 #34749
			endforeach;
			
			foreach constant in class.allConstants do
				if not self.chkShowResolved.value and constant.resolvedBy &lt;&gt; null then
					continue;
				endif;
				
				if _userCode &lt;&gt; null and constant.modifiedBy &lt;&gt; _userCode then 
					continue;
				endif;
				
				if not addedSchema then
					self.qlbClassData.addItem(schema.name);
					self.qlbClassData.itemObject[self.qlbClassData.newIndex] := schema;
					self.qlbClassData.itemLevel[self.qlbClassData.newIndex] := 1;
					self.qlbClassData.itemExpanded[self.qlbClassData.newIndex] := false;
					addedSchema := true;
					schemaIndex := self.qlbClassData.newIndex; //30.07.2025 navah1 #34749
				endif;
				
				if not addedClass then
					self.qlbClassData.addItem(class.name);
					self.qlbClassData.itemObject[self.qlbClassData.newIndex] := class;
					self.qlbClassData.itemLevel[self.qlbClassData.newIndex] := 2;
					self.qlbClassData.itemExpanded[self.qlbClassData.newIndex] := false;
					addedClass := true;
					classIndex := self.qlbClassData.newIndex; //30.07.2025 navah1 #34749
				endif;
				
				if not addedConstants then
					self.qlbClassData.addItem("--Constants--");
					self.qlbClassData.itemObject[self.qlbClassData.newIndex] := null;
					self.qlbClassData.itemLevel[self.qlbClassData.newIndex] := 3;
					self.qlbClassData.itemExpanded[self.qlbClassData.newIndex] := false;
					addedConstants := true;
					constantIndex := self.qlbClassData.newIndex; //30.07.2025 navah1 #34749
				endif;
				
				if constant.reason = DEV_SourceCompareReportAgent.Object_Missing then
					self.qlbClassData.addItem(constant.name &amp; " - Missing");
				else
					self.qlbClassData.addItem(constant.name &amp; " - Different");
				endif;
				
				if constant.resolvedBy &lt;&gt; null then
					self.qlbClassData.itemForeColor[self.qlbClassData.newIndex] := Gray;
				else
					self.qlbClassData.itemForeColor[self.qlbClassData.newIndex] := Window.Color_WindowText;
				endif;
				
				self.qlbClassData.itemObject[self.qlbClassData.newIndex] := constant;
				self.qlbClassData.itemLevel[self.qlbClassData.newIndex] := 4;
				self.qlbClassData.itemExpanded[self.qlbClassData.newIndex] := false;
				constantCount += 1; //30.07.2025 navah1 #34749
			endforeach;
			
			foreach reference in class.allReferences do
				if not self.chkShowResolved.value and reference.resolvedBy &lt;&gt; null then
					continue;
				endif;
				
				systemReference := systemClass.getProperty(reference.name).Reference;
				
				if (_userCode = null or _userCode &lt;&gt; null and reference.modifiedBy &lt;&gt; _userCode) and (systemReference = null or (systemReference &lt;&gt; null and systemReference.getModifiedByJMT &lt;&gt; _userCode)) then 
					continue;
				endif;
				
				if not addedSchema then
					self.qlbClassData.addItem(schema.name);
					self.qlbClassData.itemObject[self.qlbClassData.newIndex] := schema;
					self.qlbClassData.itemLevel[self.qlbClassData.newIndex] := 1;
					self.qlbClassData.itemExpanded[self.qlbClassData.newIndex] := false;
					addedSchema := true;
					schemaIndex := self.qlbClassData.newIndex; //30.07.2025 navah1 #34749
				endif;
				
				if not addedClass then
					self.qlbClassData.addItem(class.name);
					self.qlbClassData.itemObject[self.qlbClassData.newIndex] := class;
					self.qlbClassData.itemLevel[self.qlbClassData.newIndex] := 2;
					self.qlbClassData.itemExpanded[self.qlbClassData.newIndex] := false;
					addedClass := true;
					classIndex := self.qlbClassData.newIndex; //30.07.2025 navah1 #34749
				endif;
				
				if not addedReferences then
					self.qlbClassData.addItem("--References--");
					self.qlbClassData.itemObject[self.qlbClassData.newIndex] := null;
					self.qlbClassData.itemLevel[self.qlbClassData.newIndex] := 3;
					self.qlbClassData.itemExpanded[self.qlbClassData.newIndex] := false;
					addedReferences := true;
					referenceIndex := self.qlbClassData.newIndex; //30.07.2025 navah1 #34749
				endif;
				
				if reference.reason = DEV_SourceCompareReportAgent.Object_Missing then
					self.qlbClassData.addItem(reference.name &amp; " - Missing");
				else
					self.qlbClassData.addItem(reference.name &amp; " - Different");
				endif;
				
				if reference.resolvedBy &lt;&gt; null then
					self.qlbClassData.itemForeColor[self.qlbClassData.newIndex] := Gray;
				else
					self.qlbClassData.itemForeColor[self.qlbClassData.newIndex] := Window.Color_WindowText;
				endif;
				
				self.qlbClassData.itemObject[self.qlbClassData.newIndex] := reference;
				self.qlbClassData.itemLevel[self.qlbClassData.newIndex] := 4;
				self.qlbClassData.itemExpanded[self.qlbClassData.newIndex] := false;
				referenceCount += 1; //30.07.2025 navah1 #34749
			endforeach;
			
			if attributeCount &gt; 0 then //30.07.2025 navah1 #34749
				self.qlbClassData.itemText[attributeIndex] := app.getErrorString2(LabelWithValue, "--Attributes--", attributeCount.String);
			endif;
			
			if constantCount &gt; 0 then //30.07.2025 navah1 #34749
				self.qlbClassData.itemText[constantIndex] := app.getErrorString2(LabelWithValue, "--Constants--", constantCount.String); 
			endif;
			
			if referenceCount &gt; 0 then //30.07.2025 navah1 #34749
				self.qlbClassData.itemText[referenceIndex] := app.getErrorString2(LabelWithValue, "--References--", referenceCount.String);
			endif;
			
			total := referenceCount + constantCount + attributeCount; //30.07.2025 navah1 #34749
			if total &gt; 0 then //30.07.2025 navah1 #34749
				self.qlbClassData.itemText[classIndex] := app.getErrorString2(LabelWithValue, class.name, total.String);
				classCount += total;
			endif;
		endforeach; 
		
		if classCount &gt; 0 then //30.07.2025 navah1 #34749
			self.qlbClassData.itemText[schemaIndex] := app.getErrorString2(LabelWithValue, schema.name, classCount.String);
		endif;
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_report" type="DEV_SourceCompareReport"/>
        <Parameter name="_userCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="loadMissingMethods" id="c4ee7318-0553-4a53-9aea-67f05bda34f6">
        <source>loadMissingMethods(_report : DEV_SourceCompareReport; _userCode : String) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 December 2021	navpw1	Initial creation TFS: 52202
30 Jul 2025			navah1	Story 34749: MTN - Source Compare - Add counts to List Boxes and Heading Labels
*/

vars
	schema 			: DEV_Schema;
	class 			: DEV_Class;
	devMethod 		: DEV_Method;
	addedSchema,
	addedClass 		: Boolean;
	showResolved	: Boolean;
	classCount,					//30.07.2025 navah1 #34749
	methodCount,    			//30.07.2025 navah1 #34749
	classIndex,					//30.07.2025 navah1 #34749
	schemaIndex		: Integer;  //30.07.2025 navah1 #34749
begin
	showResolved := self.chkShowResolved.value;
	
	foreach schema in _report.allSchemas do
		addedSchema := false;
		classCount := 0; //30.07.2025 navah1 #34749
		foreach class in schema.allClasses where class.reason = DEV_SourceCompareReportAgent.Object_Link do
			addedClass := false;
			methodCount := 0; //30.07.2025 navah1 #34749
			foreach devMethod in class.allMethods where devMethod.reason = DEV_SourceCompareReportAgent.Object_Missing do
				if (_userCode &lt;&gt; null and devMethod.modifiedBy &lt;&gt; _userCode) or (devMethod.resolvedBy &lt;&gt; null and not showResolved) then 
					continue;
				endif;
				
				if not addedSchema then
					self.qlbMissingMethods.addItem(schema.name);
					self.qlbMissingMethods.itemObject[self.qlbMissingMethods.newIndex] := schema;
					self.qlbMissingMethods.itemLevel[self.qlbMissingMethods.newIndex] := 1;
					self.qlbMissingMethods.itemExpanded[self.qlbMissingMethods.newIndex] := false;
					if schema.resolvedBy &lt;&gt; null then
						self.qlbMissingMethods.itemForeColor[self.qlbMissingMethods.newIndex] := Gray;
					else
						self.qlbMissingMethods.itemForeColor[self.qlbMissingMethods.newIndex] := Window.Color_WindowText;
					endif;
					addedSchema := true;
					schemaIndex := self.qlbMissingMethods.newIndex; //30.07.2025 navah1 #34749
				endif;
				
				if not addedClass then
					self.qlbMissingMethods.addItem(class.name);
					self.qlbMissingMethods.itemObject[self.qlbMissingMethods.newIndex] := class;
					self.qlbMissingMethods.itemLevel[self.qlbMissingMethods.newIndex] := 2;
					self.qlbMissingMethods.itemExpanded[self.qlbMissingMethods.newIndex] := false;
					if class.resolvedBy &lt;&gt; null then
						self.qlbMissingMethods.itemForeColor[self.qlbMissingMethods.newIndex] := Gray;
					else
						self.qlbMissingMethods.itemForeColor[self.qlbMissingMethods.newIndex] := Window.Color_WindowText;
					endif;
					addedClass := true;
					classIndex := self.qlbMissingMethods.newIndex; //30.07.2025 navah1 #34749
				endif;
				
				self.qlbMissingMethods.addItem(devMethod.name);
				self.qlbMissingMethods.itemObject[self.qlbMissingMethods.newIndex] := devMethod;
				self.qlbMissingMethods.itemLevel[self.qlbMissingMethods.newIndex] := 3;
				self.qlbMissingMethods.itemExpanded[self.qlbMissingMethods.newIndex] := false;
				if devMethod.resolvedBy &lt;&gt; null then
					self.qlbMissingMethods.itemForeColor[self.qlbMissingMethods.newIndex] := Gray;
				else
					self.qlbMissingMethods.itemForeColor[self.qlbMissingMethods.newIndex] := Window.Color_WindowText;
				endif;
				methodCount += 1; //30.07.2025 navah1 #34749
			endforeach;
			 
			if methodCount &gt; 0 then //30.07.2025 navah1 #34749
				self.qlbMissingMethods.itemText[classIndex] := app.getErrorString2(LabelWithValue, class.name, methodCount.String);
				classCount += methodCount; 
			endif; 
		endforeach;
		
		if classCount &gt; 0 then //30.07.2025 navah1 #34749
			self.qlbMissingMethods.itemText[schemaIndex] := app.getErrorString2(LabelWithValue, schema.name, classCount.String);
		endif;
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_report" type="DEV_SourceCompareReport"/>
        <Parameter name="_userCode" type="String"/>
