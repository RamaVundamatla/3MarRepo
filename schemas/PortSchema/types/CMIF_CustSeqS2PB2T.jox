<CollClass name="CMIF_CustSeqS2PB2T" id="fb2ff5cd-6d58-4d46-8351-d25af7a332e8">
    <duplicatesAllowed/>
    <memberType name="CMIF_CustomSequenceObject"/>
    <superclass name="CMIF_CustomSeqObjectDict"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
