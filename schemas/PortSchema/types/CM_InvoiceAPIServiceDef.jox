    <JadeMethod name="setForUpdate" id="082cf7ae-ea32-4341-97d6-de52dff4db85">
        <updating/>
        <source>setForUpdate(_extWebService: CM_InvoiceAPIServiceDef) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 November 2023	navra1	Initial creation for Invoice API for TFS 54090 - EUP | Interface - MTN Invoicing Oracle &lt;&lt;54090&gt;&gt;(CR 61355/Task 61370)

*/

vars

begin	
	self.invoiceLinesPerBatch 	:= _extWebService.invoiceLinesPerBatch.Integer;
	self.authKey				:= _extWebService.authKey;
	self.clientKey 				:= _extWebService.clientKey;
	self.clientSecret 			:= _extWebService.clientSecret;	
	self.scope 					:= _extWebService.scope;
	self.subscriptionKeyName 	:= _extWebService.subscriptionKeyName;
	self.subscriptionKeyValue 	:= _extWebService.subscriptionKeyValue;
	self.tenantId 				:= _extWebService.tenantId;	
	
	inheritMethod(_extWebService);

epilog

end;</source>
        <Parameter name="_extWebService" type="CM_InvoiceAPIServiceDef"/>
    </JadeMethod>
    <JadeMethod name="setInvoiceLinesPerBatch" id="96d3a7e3-7d92-44dd-a1f6-0117becb0285">
        <updating/>
        <source>setInvoiceLinesPerBatch(_invoiceLinesPerBatch : Integer) updating;
