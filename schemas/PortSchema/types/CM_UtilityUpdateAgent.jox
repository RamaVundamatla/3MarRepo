    <JadeMethod name="utlUpdateProcessHarbour" id="fce51d28-ddf8-4ee2-826e-460683cd5a18">
        <source>utlUpdateProcessHarbour(	_proxy : CM_ProcessHarbour; 
							_passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2018	jlgndl1	Initial creation	TFS 38560

*/

vars
	
	real : CM_ProcessHarbour;
	expectedEdition	: Integer;
	
begin

	self.initialiseActivity();

	_proxy.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxy.pxyGetRealObjectAndEdition(real, expectedEdition);
	
