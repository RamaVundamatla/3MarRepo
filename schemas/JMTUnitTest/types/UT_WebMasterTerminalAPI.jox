"imo" : "",
"name" : "Laura Old Vessel",
"callSign" : "", 
"operatorId" : "LAUR",
"loa" : 1 
}
}]';
NoLoa= '[{
"id": "'&amp;Voyage2&amp;'",
"arrivalDT" : "2023-04-05T16:02:25.832611",
"departureDT" : "2023-04-10T16:02:25.832611",
"externalCode": "",
"estimatedArrivalDT" : "2023-04-06T16:02:25.832611",
"estimatedDepartureDT" : "2023-04-10T16:02:25.832611",
"inwardsCode" : "",
"operatorId" : "",
"portRotation" : [{
    "id" : "BNE",
    "tranship" : false
}],
"remarks" : "", 
"shippingLineId" : "ABC",
"tradeId" : "",
"vessel" :{
"id" : "Laura OLD Vessel",
"imo" : "",
"name" : "Laura Old Vessel",
"callSign" : "", 
"operatorId" : "LAUR"
}
}]';
NoPortRotId= '[{
"id": "'&amp;Voyage2&amp;'",
"arrivalDT" : "2023-04-05T16:02:25.832611",
"departureDT" : "2023-04-10T16:02:25.832611",
"externalCode": "",
"estimatedArrivalDT" : "2023-04-06T16:02:25.832611",
"estimatedDepartureDT" : "2023-04-10T16:02:25.832611",
"inwardsCode" : "",
"operatorId" : "",
"portRotation" : [{
    "id" : "",
    "tranship" : false
}],
"remarks" : "", 
"shippingLineId" : "ABC",
"tradeId" : "",
"vessel" :{
"id" : "Laura OLD Vessel",
"imo" : "",
"name" : "Laura Old Vessel",
"callSign" : "",
"loa" : 1,
"operatorId" : "LAUR"
}
}]';
NoPortRotWithTradeId= '[{
"id": "'&amp;Voyage1&amp;'",
"arrivalDT" : "2023-04-05T16:02:25.832611",
"departureDT" : "2023-04-10T16:02:25.832611",
"externalCode": "",
"estimatedArrivalDT" : "2023-04-06T16:02:25.832611",
"estimatedDepartureDT" : "2023-04-10T16:02:25.832611",
"inwardsCode" : "",
"operatorId" : "",
"remarks" : "", 
"shippingLineId" : "ABC",
"tradeId" : "Maersk",
"vessel" :{
"id" : "Laura OLD Vessel",
"imo" : "",
"name" : "Laura Old Vessel",
"callSign" : "",
"loa" : 1,
"operatorId" : "LAUR"
}
}]';
PortRotWithTradeId= '[{
"id": "'&amp;Voyage1&amp;'",
"arrivalDT" : "2023-04-05T16:02:25.832611",
"departureDT" : "2023-04-10T16:02:25.832611",
"externalCode": "",
"estimatedArrivalDT" : "2023-04-06T16:02:25.832611",
"estimatedDepartureDT" : "2023-04-10T16:02:25.832611",
"inwardsCode" : "",
"operatorId" : "",
"portRotation" : [{
    "id" : "AUBNE",
    "tranship" : false
}],
"remarks" : "", 
"shippingLineId" : "ABC",
"tradeId" : "Maersk",
"vessel" :{
"id" : "Laura OLD Vessel",
"imo" : "",
"name" : "Laura Old Vessel",
"callSign" : "",
"loa" : 1,
"operatorId" : "LAUR"
}
}]';
MinimumRequiredFields = '[
    {
        "id": "UTPostVoyHMS",
        "arrivalDT": "2024-02-14T14:30:00+13:00",
        "departureDT": "2024-02-18T09:00:00+13:00",
		"shippingLineId": "MSC",
        "vessel": {
            "id": "HMSHOLDS",
			"loa": 100,
			"operatorId": "MSC",
			"name": "HMS Holds"
        }
    }
]';
vars
	root 				: CM_Root;
	terminalCode,
 	loginJson,
	incomingJsonString	: String;
	expectFailure 		: Boolean;
	terminal 			: CM_Terminal;
	voyage 				: CM_Voyage;
	vessel 				: CM_Vessel;
	portRotation		: CM_PortRotation;
	expectedTimeStamp	: TimeStamp;
begin
	root := self.getRoot();
	
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	self.assertNotNullMsg(terminalCode, "Terminal Code not set in Unit Test Profile");
	
	terminal := app.myPassport.myTerminal;
	self.assertNotNullMsg(terminal.code, "Terminal Code not set in Unit Test Profile");
	
	deleteVoyage(Voyage1);
	deleteVessel("Laura OLD Vessel");
	deleteVessel("Anusha Test Vessel");
	self.opts.purge();
	
	loginJson := '{
   "userId": "' &amp; UT_WebFramework.USERCODE &amp; '",
   "password": "' &amp; UT_WebFramework.PASSWORD &amp; '",
    "applicationId" : "internalAPI",
    "scope" : {
        "complexId" : "Master Terminal",
		"facilityId": "' &amp; terminalCode &amp; '",
        "operatorId" : "Navis",
        "yardId" : "MTN"
    }}';
	
// ########################
	self.logMessage("1. Test One create voyage OK request OK with one port of rotation and no tranship ports");
	self.logMessage("1. and a GC and RORO structure");
// ########################
	incomingJsonString := VoyageJsonString;
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostVoyage.name, loginJson, incomingJsonString, expectFailure);
	
	// check that voyage exists on the terminal
	voyage := terminal.lookupVoyage(Voyage1,null,true);
	self.assertNotNullMsg(voyage, "voyage not created");
	self.assertFalse(voyage.structureIncludesLOLO);		//08.08.2024	navhn30	  TFS #65480
	self.assertTrue(voyage.structureIncludesRORO);
	self.assertTrue(voyage.structureIncludesHolds);
	// Check timestamps
	expectedTimeStamp.setDateTime(2023, 04, 06, 02, 02, 25, 0);
	self.assertEqualMsg(voyage.arrivedDT, expectedTimeStamp, "Arrival DateTime not set correctly");
	expectedTimeStamp.setDateTime(2023, 04, 11, 01, 02, 25, 0);
	self.assertEqualMsg(voyage.departedDT, expectedTimeStamp, "Departure DateTime not set correctly");
	expectedTimeStamp.setDateTime(2023, 03, 07, 01, 02, 25, 0);
	self.assertEqualMsg(voyage.estimatedArrivalDT, expectedTimeStamp, "Estimated Arrival DateTime not set correctly");
	expectedTimeStamp.setDateTime(2023, 03, 11, 00, 02, 25, 0);
	self.assertEqualMsg(voyage.estimatedDepartureDT, expectedTimeStamp, "Estimated Departure DateTime not set correctly");
	
	vessel := voyage.myVessel;
	self.assertNotNullMsg(vessel, "Vessel not created");
	// check port of rotation should only be one
	self.assertEqualMsg(voyage.allPortRotations.size = 1, true, "there should be 1 port rotation");
	// check all ports should be 1
	self.assertEqualMsg(voyage.allPorts.size = 1, true, "there should be 1 port");
	portRotation := voyage.allPortRotations.first();
	self.assertNotNullMsg(portRotation, "No Port rotations created");
	// should be no tranship ports
	self.assertEqualMsg(portRotation.allTranshipPorts.size = 0, true, "there should be 0 tranship ports");
	// voyage status checking
	self.assertEqualMsg(voyage.status, 6, "status not matched");
	
	// TFS 65286 check voyage and vessel structures
	self.assertNotNullMsg(voyage.myGeneralCargoVoyage, "GC Voyage structure not created for test 1 - voyage " &amp; voyage.code);
	self.assertNotNullMsg(voyage.myROROStructure, "RORO Voyage structure not created for test 1 - voyage " &amp; voyage.code);
	self.assertNotNullMsg(vessel.myGeneralCargoVesselStructure, "GC Vessel structure not created for test 1 - vessel " &amp; vessel.code);
	self.assertNotNullMsg(vessel.myROROVesselStructure, "RORO Vessel structure not created for test 1 - vessel " &amp; vessel.code);
	
// ########################
	self.logMessage("2. Test two create a voyage with one port rotation and two tranship ports");
	self.logMessage("2. and a LOLO voyage structure");
// ########################
	deleteVoyage(Voyage1);
	deleteVessel("Laura OLD Vessel");
	
	incomingJsonString := VoyageTranshipJson;
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostVoyage.name, loginJson, incomingJsonString, expectFailure);
	voyage := terminal.lookupVoyage(Voyage1,null,true);
	self.assertNotNullMsg(voyage, "voyage not created");
	vessel := voyage.myVessel;
	self.assertNotNullMsg(vessel, "Vessel not created");
	// check port of rotation should only be one
	self.assertEqualMsg(voyage.allPortRotations.size = 2, true, "there should be 2 port rotation");
	// check all ports should be 1
	self.assertEqualMsg(voyage.allPorts.size = 2, true, "there should be 2 port");
	portRotation := voyage.allPortRotations.first();
	self.assertNotNullMsg(portRotation, "No Port rotations created");
	// should be no tranship ports
	self.assertEqualMsg(portRotation.allTranshipPorts.size = 2, true, "there should be 0 tranship ports");
	
	// TFS 65286 check for LOLO structure
	self.assertNotNullMsg(voyage.myCellularVoyageStructure, "Test 2: Voyage " &amp; voyage.code &amp; " has no LOLO structure");
	self.assertNotNullMsg(vessel.myCellularVesselStructure, "Test 2: Vessel " &amp; vessel.code &amp; " has no LOLO structure");
	
// ########################
	self.logMessage("??? post voyage with vessel having harbour details");
// ########################
	self.deleteVoyage(Voyage1);
	incomingJsonString := VoyageTranshipJson1;
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostVoyage.name, loginJson, incomingJsonString, expectFailure);
	voyage := terminal.lookupVoyage(Voyage1,null,true);
	self.assertNotNullMsg(voyage, "voyage not created");
	vessel := voyage.myVessel;
	self.assertNotNullMsg(vessel, "Vessel not created");
	// check port of rotation should only be one
	self.assertEqualMsg(voyage.allPortRotations.size = 2, true, "there should be 2 port rotation");
	// check all ports should be 1
	self.assertEqualMsg(voyage.allPorts.size = 2, true, "there should be 2 port");
	portRotation := voyage.allPortRotations.first();
	self.assertNotNullMsg(portRotation, "No Port rotations created");
	// should be no tranship ports
	self.assertEqualMsg(portRotation.allTranshipPorts.size = 2, true, "there should be 0 tranship ports");
	
// ########################	
	self.logMessage("3. Test Three no Voyage Code");
// ########################
	incomingJsonString := VoyageNoIdJsonString;
	expectFailure := true;
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :75007. An input is required for the Voyage Id field.");
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostVoyage.name, loginJson, incomingJsonString, expectFailure);
	
// ########################
	self.logMessage("4. Test Four Voyage Code exists");
// ########################
	incomingJsonString := VoyageExistsJsonString;
	expectFailure := true;
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :" &amp; Voyage_already_exists.String &amp; ". " &amp; app.getErrorString1(Voyage_already_exists, Voyage1));
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostVoyage.name, loginJson, incomingJsonString, expectFailure);
	
// ########################
	self.logMessage("5. Test Five No Vessel ID");
// ########################
	incomingJsonString := NoVesselIdJsonString;
	expectFailure := true;
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :75007. An input is required for the Vessel Id field.");
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostVoyage.name, loginJson, incomingJsonString, expectFailure);
	
// ########################	
	self.logMessage("6. Test Six No Vessel LOA");
// ########################
	self.deleteVoyage(Voyage2);
	deleteVessel("Laura OLD Vessel");
	incomingJsonString := NoLoa;
	expectFailure := true;
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :75007. An input is required for the Vessel LOA field.");
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostVoyage.name, loginJson, incomingJsonString, expectFailure);
	
// ########################
	self.logMessage("7. Test Seven No Port Rotation Id");
// ########################
	deleteVoyage(Voyage2);
	deleteVessel("Laura OLD Vessel");
	incomingJsonString := NoPortRotId;
	expectFailure := true;
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :75007. An input is required for the Port Rotation Id field.");
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostVoyage.name, loginJson, incomingJsonString, expectFailure);
	
// ########################
	self.logMessage("8. Test Eight No Port Rotation with Trade Id");
// ########################
	deleteVoyage(Voyage1);
	deleteVessel("Laura OLD Vessel");
	
	incomingJsonString := NoPortRotWithTradeId;					//12.02.2024 naviv1 #62354
	expectFailure := false;
	self.opts.purge();
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostVoyage.name, loginJson, incomingJsonString, expectFailure);
	voyage := terminal.lookupVoyage(Voyage1,null,true);
	self.assertNotNullMsg(voyage, "voyage not created");
	vessel := voyage.myVessel;
	self.assertNotNullMsg(vessel, "Vessel not created");
	self.assertNotNullMsg(voyage.myTrade, "trade not created");
	self.assertEqualMsg(voyage.allPortRotations.size = voyage.myTrade.allPortRotations.size, true,"No of voyage port rotation should be equal to no of trade port rotation");
	portRotation := voyage.allPortRotations.first();
	self.assertNotNullMsg(portRotation, "No Port rotations created");
	
// ########################
	self.logMessage("9. Test Nine Port Rotation with Trade Id");
// ########################
	deleteVoyage(Voyage1);
	deleteVessel("Laura OLD Vessel");
	
	incomingJsonString := PortRotWithTradeId;		//12.02.2024 naviv1 #62354
	expectFailure := false;
	self.opts.purge();
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostVoyage.name, loginJson, incomingJsonString, expectFailure);
	voyage := terminal.lookupVoyage(Voyage1,null,true);
	self.assertNotNullMsg(voyage, "voyage not created");
	vessel := voyage.myVessel;
	self.assertNotNullMsg(vessel, "Vessel not created");
	self.assertNotNullMsg(voyage.myTrade, "trade not created");
	// check port of rotation should only be one
	self.assertEqualMsg(voyage.allPortRotations.size = 1, true, "there should be 1 port rotation");
	// check all ports should be 1
	self.assertEqualMsg(voyage.allPorts.size = 1, true, "there should be 1 port");
	portRotation := voyage.allPortRotations.first();
	self.assertNotNullMsg(portRotation, "No Port rotations created");
	
// ########################
	self.logMessage("10. Test Ten No Voyage Operator, defaults to Vessel Operator");
// ########################
	self.deleteVoyage(Voyage2);
	self.deleteVessel("Laura OLD Vessel");
	incomingJsonString := NoVoyageOperator;
	expectFailure := false;
	self.opts.purge();
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostVoyage.name, loginJson, incomingJsonString, expectFailure);
	voyage := terminal.lookupVoyage(Voyage2,null,true);
	self.assertNotNullMsg(voyage, "voyage not created");
	vessel := voyage.myVessel;
	self.assertNotNullMsg(vessel, "Vessel not created");
	self.assertEqualMsg(voyage.myOperator, vessel.myOperator, "operators different between Voyage and Vessel");
	
// ########################
	self.logMessage("???");
// ########################
	self.deleteVoyage("UTPostVoyHMS".toUpper);
	
	incomingJsonString := MinimumRequiredFields;
	expectFailure := false;
	self.opts.purge();
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostVoyage.name, loginJson, incomingJsonString, expectFailure);
	voyage := terminal.lookupVoyage("UTPostVoyHMS", null, null);
	self.assertNotNullMsg(voyage, "Voyage not created");
	
	
epilog

end;</source>
