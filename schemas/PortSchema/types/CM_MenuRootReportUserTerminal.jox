    <JadeMethod name="getHeading" id="5d4d651b-603f-436c-bef2-c9b61f7943fb">
        <source>getHeading(): String;
// ---------------------------------------------------------------------------
// Created:     22 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
      //par 18483
	/*return 'Report Menu for:' &amp; self.myUserTerminal.getMyTerminal.name &amp; '-' &amp;
								self.myUserTerminal.myUser.code;*/


		return app.getErrorString(ReportMenufor) &amp; self.myUserTerminal.getMyTerminal.name &amp; '-' &amp;
								self.myUserTerminal.myUser.code;						
								
								
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="46cf4b14-3215-4ba0-9d31-d0896b41e569">
        <source>getMyTerminal(): CM_Terminal;
// ---------------------------------------------------------------------------
// Created:     22 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.myUserTerminal &lt;&gt; null then
		return app.myRoot.getTerminalForScenario(self.myUserTerminal.getMyTerminal);
		//return self.myUserTerminal.myTerminal;
	endif;
	
	return inheritMethod();
	
end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="removeFoldersWithNoChildren" id="5a7954a5-a7dd-4f90-be0b-a8ad62aa6d67">
        <source>removeFoldersWithNoChildren();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 November 2015	cnwndl1	Initial creation	Par 36846

*/

vars

	delSet : CM_MenuEntitySet;
	menuEntity : CM_MenuEntity;
	userDefinedDefault : CM_MenuUserHdr;

begin

	create delSet transient;
	self.getItemsWithNoChildren(delSet);
	
	foreach menuEntity in delSet do
		if menuEntity.isUserDefinedReportsHeader() then
			userDefinedDefault := menuEntity.CM_MenuUserHdr;
			break;
		endif;
	endforeach;
	
	if userDefinedDefault &lt;&gt; null then
		delSet.remove(userDefinedDefault);
	endif;
	
	if (not delSet.isEmpty) then
		delSet.purge;
	endif;

epilog
	delete delSet;
end;</source>
    </JadeMethod>
</Class>
