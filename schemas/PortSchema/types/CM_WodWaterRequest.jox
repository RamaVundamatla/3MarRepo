    <JadeMethod name="getExtraInfo" id="74b3c226-90c4-4285-ac59-27cc73e07498">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
/*

Purpose:		TFS 39718	

Parameters:			

Return Value:		

Date		Who		Reason
11 July 2018	jlgab1	Initial creation

*/

vars
	block : CM_DataContainerBlock;
	transtype : CM_VoyageJobTransferType;
	tmpTS : TimeStamp;
begin
	inheritMethod(_dataContainer);
	
	if self.myHMSResource &lt;&gt; null then 
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Water_resource), DC_Label, 1, null);
		block.addNewItem(self.myHMSResource.description , DC_Data, 1, null);
	endif;
	if self.fromDateTime.isValid() then 
		tmpTS := self.systemToLocalTime(self.fromDateTime); // PEL UAT WP testing 30SEP18
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_From), DC_Label, 1, null);
		block.addNewItem(tmpTS.asStringJMT() , DC_Data, 1, null);
	endif;
	if self.toDateTime.isValid() then 
		tmpTS := self.systemToLocalTime(self.toDateTime); // PEL UAT WP testing 30SEP18
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_To), DC_Label, 1, null);
		block.addNewItem(tmpTS.asStringJMT() , DC_Data, 1, null);
	endif;
	if self.unitsUsed &gt; 0 then 
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Units_used), DC_Label, 1, null);
		block.addNewItem(self.unitsUsed.String , DC_Data, 1, null);
	endif;
	if self.transferType &gt; 0 then
		transtype := app.myRoot.allVoyageJobTransferTypes[self.transferType];
		if transtype&lt;&gt; null then
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(Transfer_type), DC_Label, 1, null);
			block.addNewItem(transtype.description, DC_Data, 1, null);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
