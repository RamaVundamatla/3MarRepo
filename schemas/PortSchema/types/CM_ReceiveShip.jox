    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="25534a33-2b05-4c00-b667-fea81baa8c8a">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_TITransactionController; _passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		29 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Date			Changed By		Reason
// 31/05/2019	jlgzm1			TFS 42840 MSL - Direct Delivery Between LOLO RORO Voyages and Rail
// 25/07/2024	jlizm1			TFS 65353 Onboard cargo does not get received transaction
// ---------------------------------------------------------------------------
vars
	wle : CM_WorkListEntry;
	js : CM_VoyageJobSheet;
	request : CM_VoyageRequest;
	voyage : CM_Voyage;
	voy : CM_Voyage;
	iter : Iterator;
	ti : CM_TrackedItem;
	secondSpaceIdx, firstSpaceIdx : Integer;
	position : String;
	lc : CM_LocationsController;
	foundHeight : Integer;
	drVoyageWle : CM_WorkListEntry;
	parent : CM_TrackedItem;
begin
	inheritMethod(_tiTransCntrl, _passport);

	self.transferType := _tiTransCntrl.transferType;
	
	// ### KPI Stuff
	wle := _tiTransCntrl.getWLE();
	self.setJSFromWLE(wle);
	
	if wle = null then
		ti := _tiTransCntrl.myTrackedItem;
		if ti.isOnTrailer then
			parent := ti.getCurrentTrailer;
			self.locationShip := parent.priorLocation;
			self.locationYard := parent.locationId;
		else
			self.locationShip := _tiTransCntrl.myTrackedItem.priorLocation;
			self.locationYard := _tiTransCntrl.myTrackedItem.locationId;
		endif;
		
		if self.voyage &lt;&gt; null then // PAR 36019
			self.voyage.myTerminal.findLocationFromString(self.locationShip,true,lc,foundHeight); // PAR 36019
		endif;
		
		if lc &lt;&gt; null then // PAR 36019
			position := lc.getLocationOrdinal(); // PAR 36019
		elseif self.voyage &lt;&gt; null then
			position := self.voyage.code; // PAR 36019
		endif;
		
		self.craneID := position;

	endif;
	
	// tfs42840
	if _tiTransCntrl.isKindOf(CMIF_MoveTransactionController) then
		self.isDirectReleaseMove := _tiTransCntrl.CMIF_MoveTransactionController.isDirectReleaseMove;
		//11 Mar 2020	NDL	TFS 48774
		if self.myJobSheet &lt;&gt; null then
			voy := self.myJobSheet.myVoyage;
		endif;
		if voy &lt;&gt; null then
			self.myVoyageRelivant := voy;
		endif;
		//12 Mar 2020	NDL	TFS 48774
		if wle &lt;&gt; null then
			drVoyageWle := wle.getDRLinkedWLE();
			if drVoyageWle &lt;&gt; null and drVoyageWle.isKindOf( CM_VoyageWLE ) and drVoyageWle.isReceipt then
				locationYard := wle.locationTarget;
			endif;
		endif;
		
	endif;

epilog
	delete iter;
end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setJSFromJob" id="b6e6e950-95f6-40a4-ace1-77782a4d5386">
        <updating/>
        <source>setJSFromJob(_job : CM_VoyageJob) updating;
// ---------------------------------------------------------------------------
// Created:		19 April 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	js : CM_VoyageJobSheet;
	bay1, bay2, theBay : CM_Bay;
begin
	
	if self.myJob &lt;&gt; null then
		return;
	endif;
	
	if _job &lt;&gt; null then
		self.myJob := _job;
		if self.myJob &lt;&gt; null then
			if _job.myShift &lt;&gt; null then // TFS 3215
				self.shiftCode := _job.myShift.code; // TFS 3215
				self.shiftStart := _job.myShift.startDateTime; // TFS 3215
				self.shiftEnd := _job.myShift.endDateTime; // TFS 3215
			endif;
			
			_job.getBays(bay1, bay2);
			self.myBay := null;
			self.myBay := bay1.CM_BayVoyage;
			
			js := self.myJob.myJobSheet.CM_VoyageJobSheet;
			if js &lt;&gt; null then
				self.myJobSheet := js;
				self.craneID := js.crane;
				
			endif;
			self.transferType := _job.getTransferType;	//12 Mar 2018	NDL	TFS 37444
		endif;
	endif;

end;</source>
        <Parameter name="_job" type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="setJSFromWLE" id="e729d540-8f8f-43e4-b146-1c3ec7f27401">
        <updating/>
        <source>setJSFromWLE(_wle : CM_WorkListEntry) updating;
// ---------------------------------------------------------------------------
// Created:		19 April 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 07/12/2010	cnwcs5	par 23714/ccms 1132 - record machine history for crane
// 16 Jan 2023 	navhl20 ChangeRequest 62066: EUP | Ship Operations in DD - FR - 01
vars
	js : CM_VoyageJobSheet;
	slotReq : CM_SlotRequest;
	starboard : Boolean;
	localWle : CM_WorkListEntry;
	voyageWle : CM_VoyageWLE;
	otherDDWle : CM_WorkListEntry;
	drVoyageWle : CM_WorkListEntry;
	job			: CM_Job;
	voyJobArr	: CM_JobArray;
	voyJob		: CM_VoyageWorkPointJob;
begin

	localWle := _wle;
	
	//07 Feb 2012	NDL	Par 31102
	if localWle &lt;&gt; null then
		if localWle.isKindOf(CM_VoyageWLE) then
			voyageWle := localWle.CM_VoyageWLE;
			
			//11 Mar 2020	NDL	TFS 48774
			if voyageWle &lt;&gt; null then
				drVoyageWle := voyageWle.getDRLinkedWLE();
				if drVoyageWle &lt;&gt; null and drVoyageWle.isKindOf( CM_VoyageWLE ) and drVoyageWle.isReceipt then
					voyageWle := drVoyageWle.CM_VoyageWLE;
				endif;
			endif;
			
		elseif localWle.myTrackedItem &lt;&gt; null and localWle.myTrackedItem.directDelivery then
			//cnwmc5 - 30 September 2013 - PAR 32494
			otherDDWle := localWle.myTrackedItem.getDirectDeliveryWLE(localWle);
			
			if otherDDWle &lt;&gt; null and otherDDWle.isKindOf(CM_VoyageWLE) then
				voyageWle := otherDDWle.CM_VoyageWLE;
			endif;
			
		endif;
	endif;
	
	if voyageWle &lt;&gt; null then
		if self.myMachineMoveHistory &lt;&gt; null then	//29 June 2012	NDL	Par 29915
			// I've already got one, don't try to give me another...
			return;
		endif;
		
		self.locationShip := voyageWle.locationSource;
		self.locationYard := voyageWle.locationTarget;
		
		if  voyageWle.myRequest.isKindOf(CM_SlotRequest) then
			slotReq := voyageWle.myRequest.CM_SlotRequest;
		elseif voyageWle.myRequest.isKindOf(CM_RORORequest) then
			self.myDeck:=voyageWle.myRequest.CM_RORORequest.getDeck();
		endif;
		
		if slotReq &lt;&gt; null then
			self.myBay := slotReq.myBay;
			starboard := true;
			if self.myBay.isKindOf(CM_BayVoyage) then
				starboard := not self.myBay.CM_BayVoyage.myCellularVoyageStructure.myVoyage.starboardBerthed;
			endif;
			self.isTwinLift := slotReq.isTwinLift(starboard);
		endif;
		
		
		self.myJob := voyageWle.job.CM_VoyageJob;
		if self.myJob &lt;&gt; null then
			if self.myJob.myShift &lt;&gt; null then // TFS 2315
				self.shiftCode := self.myJob.myShift.code; // TFS 2315
				self.shiftStart := self.myJob.myShift.startDateTime; // TFS 2315
				self.shiftEnd := self.myJob.myShift.endDateTime; // TFS 2315
			endif;
			js := self.myJob.myJobSheet.CM_VoyageJobSheet;
			if js &lt;&gt; null then
				self.myJobSheet := js;
				self.craneID := js.crane;
				self.createKPIController();
				self.addReceiveToHistory(voyageWle);	// 07/12/2010 cnwcs5 par 23714/ccms 1132
			endif;
			self.transferType := self.myJob.getTransferType;	//12 Mar 2018	NDL	TFS 37444
		endif;
		
		
	
	endif;
	
	if localWle.isKindOf(CM_WOWLE) then							//16.01.2023 navhl20 #62066
		job := localWle.job;
		voyJobArr := job.getAllVoyJobs();
		foreach voyJob in voyJobArr as CM_VoyageWorkPointJob do
			//if voyJob.plannedLocations &lt;&gt; null then
			if voyJob.plannedLocation &lt;&gt; null then //26/08/2024	navkc1 CR 63588 Task 63589
				self.myJob := voyJob;
			endif;
		endforeach;
		if self.myJob &lt;&gt; null then
			if self.myJob.myJobSheetForWorkPoint &lt;&gt; null and self.myJob.myJobSheetForWorkPoint.myShift &lt;&gt; null then
				self.shiftCode := self.myJob.myJobSheetForWorkPoint.myShift.code;
				self.shiftStart := self.myJob.myJobSheetForWorkPoint.myShift.startDateTime;
				self.shiftEnd := self.myJob.myJobSheetForWorkPoint.myShift.endDateTime;
			endif;
			js := self.myJob.myJobSheet.CM_VoyageJobSheet;
			if js &lt;&gt; null then
				self.myJobSheet := js;
				self.craneID := js.crane;
				self.createKPIController();
			endif;
			self.transferType := self.myJob.getTransferType;
		endif;
	endif;
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="0e6e4c57-39ee-45a8-b8c4-0b4afcfd0b12">
        <updating/>
        <source>setMyTrackedItem(pTI: CM_TrackedItem; _tiTransCntrl: CMIF_TITransactionController ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2011	cnwndl1	Initial creation	Par 27438
08 Jul 2011 cnwjre1	Par 27782 set myVoyageRelivant to get this transaction in the import voyage transaction collection, not the export one
12 Jun 2019	jlgdap1	TFS 44554 AAT Stevedore Data Access - set the stevedore from the import voyage for tranships
02 Oct 2020 cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
*/

vars
	previousLocation : CM_LocationsController;
	tmpVoid 		 : Integer;
	tmpTI 			 : CM_TrackedItem;
begin

	inheritMethod(pTI, _tiTransCntrl);
	
	if self.imExStatus = TI_IMEX_STATUS_TRANSHIP then
		// I am a tranship
		
		app.myPassport.myTerminal.findLocationFromString(pTI.priorLocation, false, previousLocation, tmpVoid);
		
		if previousLocation &lt;&gt; null and previousLocation.isKindOf(CM_VoyageController) and previousLocation.CM_VoyageController.myVoyage &lt;&gt; pTI.myVoyageTranshipImport then //cnwrd1 par 31384	
			//we are a tranship on our export voyage coming back into the yard.
				self.voyage 		:= pTI.myVoyage;	
				self.voyageCode		:= pTI.myVoyage.code;
				self.myVoyageRelivant := pTI.myVoyage;	
		else		
			if pTI.myVoyageTranshipImport &lt;&gt; null then
				// the proxy may have already had its 'voyage' and 'voyageCode' attributes
				// set to the export voyage, so unconditionally set the value on the receive to the
				// import version....
				self.voyage 		:= pTI.myVoyageTranshipImport;	
				self.voyageCode		:= pTI.myVoyageTranshipImport.code;
				self.myVoyageRelivant := pTI.myVoyageTranshipImport;	// 27782, set in inheritMethod to pTI.myVoyage, which can be the export voyage
				self.stevedoreCode	:= pTI.getStevedoreForTranshipImport();				// TFS 44554
			endif;
		endif;
		tmpTI:= pTI; 					// TFS 45590
		tmpTI.matchTBAOnReceiveShip(); // TFS 45590
	else
		self.stevedoreCode := pTI.getStevedoreCodeRecieve();  //02.10.2020 cnwma1 TFS #50112
	endif;
	
end;</source>
        <Parameter name="pTI" type="CM_TrackedItem"/>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
    </JadeMethod>
    <JadeMethod name="setTiReceivedTransportMode" id="3bcff4a6-447b-49f8-87b1-5ea6e0218cc7">
        <source>setTiReceivedTransportMode(_ti: CM_TrackedItem input);
// ---------------------------------------------------------------------------
// Created:     24 May 2004 by cnwrs1
//
// Purpose:     PAR8243     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	_ti.setReceiptTransportMode(TI_TRANSMODE_SHIP);
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
