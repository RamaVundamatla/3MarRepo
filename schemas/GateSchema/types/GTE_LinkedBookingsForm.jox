    <JadeMethod name="setMyProxyBookingItem" id="21535fdc-e862-4ebd-a220-9bda3a7f20de">
        <updating/>
        <source>setMyProxyBookingItem(_value : CM_BookingRefItem)updating;
//11 November 2009	cnwml2
