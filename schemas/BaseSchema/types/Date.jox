    <JadeMethod name="cnEcWeekOfMonth" id="9d8fff40-e749-4125-a5c3-6e22a415cf95">
        <source>cnEcWeekOfMonth():Integer;
// --------------------------------------------------------------------------------
// Created:		31 March 2004 by cnwdad1
//
// Purpose:		Returns the week number of the receiver's month.
//
// Parameters:	None
//
// Returns:		The week number.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return ((self.day - 1) div 7) + 1;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
</PrimType>
