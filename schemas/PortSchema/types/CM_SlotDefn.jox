    <JadeMethod name="setOutboard" id="fa40f081-788a-478d-bea0-330b3d678ecb">
        <updating/>
        <source>setOutboard() updating;
// ---------------------------------------------------------------------------
// Created:     02 June 2001 by cnwgd1
//
// Purpose:     Called from hatchlid update to set outboard slots
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 04 Feb 2003	DWQ	Moved to superclass, and fixed so it will work.
// ---------------------------------------------------------------------------

//GD 2/05/01 - Method to determine whether a slot is in an outboard stack.
//The bay must have underdeck and ondeck cells, and hatch lids.
//An outboard stack is one that does not rest on a hatch lid at all, 
//otherwise it is considered an inboard stack and "isOutboard" remains false.

vars
		bay : CM_Bay;
		hatchLidsStart, hatchLidsEnd : Integer;
begin
		exclusiveLock(self);
		self.isOutboard := false;	//Default to false in case of change.
		bay := self.myBay;
		if bay = null then
			return;	
		endif;
		if self.ordinalDeck &lt;&gt; DeckOnDeck then  //check for ondeck
			return;
		endif;
		if bay.allHatchLids.isEmpty then  //check for hatch lids
			return;
		endif;
		if bay.allSlotsUnderDeck.isEmpty then  //check for underdeck
			return;
		endif;
		hatchLidsStart := bay.allHatchLids.first.ordinalODStartCell; 
		hatchLidsEnd := bay.allHatchLids.last.ordinalODEndCell;
		if self.ordinalCell &lt; hatchLidsStart or self.ordinalCell &gt; hatchLidsEnd then
			self.isOutboard := true;
		endif;
end;</source>
    </JadeMethod>
