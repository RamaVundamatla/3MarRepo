    <JadeMethod name="applyStops" id="93f1a4ad-634f-479c-8621-70eebf7e8b40">
        <updating/>
        <source>applyStops(_allTIs : CM_TISet input; _stopsToApply : CM_StopsTableSet) updating;
/*) updating;
/*
Purpose - 	incoming proxy TIs, add proxy stops to apply.
Who - NAVAB1
Date - 25AUG2023
ADO - CR 60052 TASK 60053 
*/


vars
	stop : CM_StopsTable;
	docType, cdtti : CM_CustomDocumentType;
	cdd : CM_CustomDocumentDetail;
	ti, proxyTI : CM_TrackedItem;
	pxyStop : CM_Stops;
	cdti : CM_CustomDocument;
begin

	docType:= self.myCustomDocumentType;
	
	if docType = null then
		return;
	endif;
	
	foreach proxyTI in _allTIs discreteLock do
		foreach stop in _stopsToApply discreteLock do
			if stop.requiresInfo then
				// reset any requires information fields that have been previously set
				// eg for Delivery Release number - this field must be null prior to the stop being added.
				proxyTI.setRequiresInformation( stop.requiresInfoType, null );
			endif;
			
			pxyStop	:= proxyTI.getStop( stop.id );
			
			if pxyStop = null then 
				create pxyStop transient;
				
				pxyStop.id	:= stop.id;
				// checks that the cargo type is OK - should not fail because we checked when we loaded the form
				if not pxyStop.setMyTrackedItem( proxyTI ) then
					// we will never get here as the method raises an exception
					delete pxyStop; 
					return;
				endif;
			else
				pxyStop.pxySetUpdateStop();
			endif;
			// expiry date should be null for a new stop
			pxyStop.setClearanceExpiryDate( null );
			
			
			// stop override reason should be null if adding a stop, it might have been set previously.
			pxyStop.setPxyStopOverrideReason( null );
			
			//12/02/2023	navkc1 Bug 62402 - Re-applying stop, find relavent cust doc, then set it to the stop reference
			ti := proxyTI.pxyGetRealObject();
			
			if ti &lt;&gt; null then
				foreach cdd in ti.allCustomDocDetails discreteLock do
					cdti := cdd.getCustomDocumentHeader();
					if cdti.isCancelled() then
						continue;
					endif;
					
					if cdti.isInward() then
						cdtti := cdti.myCustomDocumentType;
						foreach stop in cdtti.allStopsToApply discreteLock do
							if docType.allStopsToClear.includes(stop) then
								pxyStop.setProxyCustDocApplied(cdd);
							endif;
						endforeach;
					endif;
				endforeach;
			endif;
		endforeach;
	endforeach;
epilog

end;</source>
        <Parameter name="_allTIs" type="CM_TISet" usage="input"/>
        <Parameter name="_stopsToApply" type="CM_StopsTableSet"/>
    </JadeMethod>
