<Class name="CM_QCOUTypeProperty" id="791fc805-96d1-44f2-a1b8-e30f430f578a">
    <superclass name="CM_QIntegerLookupProperty"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <JadeMethod name="create" id="208f748d-534e-4d23-84ab-1665b74b61b7">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     22 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	oper : CM_QueryOperator;

begin
	if self.isTransient then 
		return;
	endif;
		
	create oper as CM_QIntegerLookupEqual persistent;
	self.allAllowedOperators.add(oper);

	create oper as CM_QIntegerLookupNotEqual persistent;
	self.allAllowedOperators.add(oper);

	create oper as CM_QIntegerIsOneOf persistent;
	self.allAllowedOperators.add(oper);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="getKeyLengthForXTABDictionary" id="cf26caf2-fb3d-48d6-ba32-d5d3e0f4d2db">
        <source>getKeyLengthForXTABDictionary(): Integer;
// ---------------------------------------------------------------------------
// Created:     04 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	length	:Integer;
begin
	// just incase the global constant values change !!!
	length := COU_SHORT_NAME.length;
	length := length.max (COU_LONG_NAME.length);
	length := length.max (COU_MARINE_NAME.length);
	length := length.max (COU_LAND_NAME.length);

	return length;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
