	inheritMethod();
	self.modalResult := IDCANCEL;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="cb7e7a64-6ec1-445a-b5dd-63c69f61b6ae">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0010149, locale);
	btnClear.translateCaption(Xlat_0010150, locale);
	btnClose.translateCaption(Xlat_0010151, locale);
	btnDoSearch.translateCaption(Xlat_0010152, locale);
	optStatusActive.translateCaption(Xlat_0010153, locale);
	optStatusAll.translateCaption(Xlat_0010154, locale);
	optStatusDisable.translateCaption(Xlat_0010155, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="updateSearchParameters" id="21fe8756-aed5-44c3-9353-f6baa5177f41">
        <updating/>
        <source>updateSearchParameters() updating;

/*

Purpose:		Get and resolve search criteria from input frame

Parameters:			

Return Value:	Search parameters object populated with values from form.
				allSearchCriteria - collection refreshed with transients for search criteria as entered.
				allSearchCriteriaResolved - collection refreshed with transients of search criteria with patterns resolved.

Date				Who		Reason
05 September 2008	consw1	Initial creation
21 August 2020		jlgdap1	TFS 49951 PRP Satellite View Criteria Search not returning results for field Mark
28 August 2020		jlgdap1	TFS 49953 MTN Satellite View Criteria Search doesn't work for some criteria
*/

vars
	cmifCriteria 	: CMIF_YACriteriaPriority;
	criteriaCtrl	: CMUI_YACriteriaCntl;
	criteriaType 	: CM_YACriteriaType;
	i				: Integer;
	iArray			: IntegerArray;
	itemCode 		: String;
	objSet			: ObjectSet;
	priorityValue	: Real;
	proxyCriteria	: CM_YACriteria;

begin
	self.mySearchParameters.resetValues();
	
	while true do
		i := i + 1;
		criteriaCtrl := self.frmCriteria.getControl(i);
		if criteriaCtrl = null then
			break;
		endif;
		criteriaType := criteriaCtrl.getCriteriaType();
		
		
		
		
		if criteriaType &lt;&gt; null and criteriaCtrl.hasValue() then

			itemCode := criteriaType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
			//  Create proxy as entered for display/reset purposes
			create proxyCriteria transient;
			proxyCriteria.setProxy(criteriaType, criteriaCtrl.getValue(), itemCode);
			cmifCriteria := proxyCriteria.getTransient();
			self.mySearchParameters.allSearchCriteria.add(cmifCriteria);
			//  Create proxy with resolution for actual search
			create proxyCriteria transient;
			if criteriaType.isBooleanType()
			or criteriaType.isKindOf(CM_YATypeMark)							// TFS 49951
			or criteriaType.isKindOf(CM_YATypeCargoGroup)				// TFS 49953
			or criteriaType.isKindOf(CM_YATypeCargoHeight)				// TFS 49953
			or criteriaType.isKindOf(CM_YATypeCargoLength)				// TFS 49953
			or criteriaType.isKindOf(CM_YATypeCargoWidth)				// TFS 49953
			or criteriaType.isKindOf(CM_YATypeFreightTons)				// TFS 49953
			or criteriaType.isKindOf(CM_YATypeID)						// TFS 49953
			or criteriaType.isKindOf(CM_YATypeServiceOrder)				// TFS 49953
			or criteriaType.isKindOf(CM_YATypeVehicleDoors)				// TFS 49953
			or criteriaType.isKindOf(CM_YATypeVehicleYear)				// TFS 49953
			or criteriaType.isKindOf(CM_YATypeTotalWeight)				// TFS 49953
			or criteriaType.isKindOf(CM_YATypeContainerLength) then
				proxyCriteria.setProxy(criteriaType, criteriaCtrl.getValue(), itemCode);
			elseif criteriaType.isTransportModeType() then
				create iArray transient;
				criteriaType.resolveTransportModePattern(criteriaCtrl.getValue().String, iArray);
				proxyCriteria.setProxy(criteriaType, iArray, itemCode);
				delete iArray;
			else
				create objSet transient;
				criteriaType.resolvePattern(criteriaCtrl.getValue().String, objSet, true);
				proxyCriteria.setProxy(criteriaType, objSet, itemCode);
				delete objSet;
			endif;
			proxyCriteria.calculatePriority();
			cmifCriteria := proxyCriteria.getTransient();
			self.mySearchParameters.allSearchCriteriaResolved.add(cmifCriteria);
			//  Total priority value for all search criteria
			priorityValue := priorityValue + proxyCriteria.priorityValue;
		endif;
	endwhile;

	self.mySearchParameters.searchPriorityValueReal := priorityValue;

	self.mySearchParameters.includeActive 	:= optStatusAll.value or optStatusActive.value;
	self.mySearchParameters.includeDisabled	:= optStatusAll.value or optStatusDisable.value;

	self.mySearchParameters.includeActiveDisplay 	:= optStatusActive.caption[1:CMIF_YACriteriaSearch::includeActiveDisplay.length-1].removeInvalidChars();
	self.mySearchParameters.includeDisabledDisplay	:= optStatusDisable.caption[1:CMIF_YACriteriaSearch::includeDisabledDisplay.length-1].removeInvalidChars();
	

epilog
	delete iArray;
	delete objSet;
end;</source>
    </JadeMethod>
</GUIClass>
