    <JadeMethod name="getMappingHeaders" id="d728a831-a50d-430e-830f-a2e9d0dd7306">
        <updating/>
        <source>getMappingHeaders() updating, protected;
// April 2010, cnwjre1, par 23659, invoice transaction map extract enhancements for Tranship IMEX status
//  get the questions for the current cargo and transaction types
vars
	maxOrderEle, allXMLMethods,allXMLCargoTypes,allXMLQuestions	: JadeXMLElementArray;
	xmlCargoType,xmlQuestion,xmlMethod	: JadeXMLElement;

	order, maxOrder : Integer;
	strLabel, strMethod, strClass : String;
begin

	self.applicableMethodNames.clear;
	
	create allXMLMethods transient;
	create allXMLCargoTypes transient;
	create allXMLQuestions transient;
	create maxOrderEle transient;
	
	self.xmlDocument.getElementsByTagName(InvoiceMappingTag_ALL, allXMLMethods);	

	foreach xmlMethod in allXMLMethods do

		xmlMethod.getElementsByTagName("MAXORDER", maxOrderEle);	
		foreach xmlCargoType in maxOrderEle do
			maxOrder := xmlCargoType.textData.Integer;
			self.applicableMethodNames[maxOrder] := "";
		endforeach;

		 xmlMethod.getElementsByTagName(InvoiceMappingTag_CARGOTYPE, allXMLCargoTypes);
		foreach xmlCargoType in allXMLCargoTypes do
			strClass := xmlCargoType.getAttributeByName(InvoiceMappingAttr_CLASS).value;
			
			if strClass = CM_TrackedItem.name 
			or strClass = self.myMapTIService.className then
			
				xmlCargoType.getElementsByTagName(InvoiceMappingTag_QUESTION,allXMLQuestions);
				foreach xmlQuestion in allXMLQuestions do
					
					strLabel := xmlQuestion.getTagValueOfName(InvoiceMappingTag_LABEL);
					
					// only show isRORO for ship release and receive
					if strLabel = InvoiceMappingLabelIsRORO then
						if self.myMapServiceBroker.isKindOf(CM_TransServiceBroker) then
							if not (self.myMapServiceBroker.CM_TransServiceBroker.className = CM_ReceiveShip.name
								or self.myMapServiceBroker.CM_TransServiceBroker.className = CM_ReleaseShip.name
								or self.myMapServiceBroker.CM_TransServiceBroker.className = CM_WorkOrderExtraTI.name) then // TFS 42221
								continue;
							endif;
						else
							continue;
						endif;
					endif;
					strMethod := xmlQuestion.getTagValueOfName(InvoiceMappingTag_METHOD);
					order :=  xmlQuestion.getTagValueOfName(InvoiceMappingTag_ORDER).Integer;
					self.applicableMethodNames[order] := strMethod;
		
				endforeach;
			endif;
		endforeach;
	endforeach;

epilog
	delete allXMLMethods;
	delete allXMLCargoTypes;
	delete allXMLQuestions;
	delete maxOrderEle;

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getMethodIndex" id="453fca23-3ff6-4a6f-ab72-2eb35ef49a24">
        <updating/>
        <source>getMethodIndex(_methodName : String; _proxyQuantityRangeMap : CM_QuantityRangeMap) : Integer updating, protected;
// 
vars
	str : String;
	count : Integer;
begin
	foreach str in _proxyQuantityRangeMap.allRegisteredMethods do
		count := count + 1;
		if str = _methodName then
			return count;
		endif;
	endforeach;
	
	return 0;

end;

</source>
        <access>protected</access>
        <Parameter name="_methodName" type="String"/>
        <Parameter name="_proxyQuantityRangeMap" type="CM_QuantityRangeMap"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMethodKey" id="90e950c6-6c4d-4ea5-a77c-dd689492d96f">
        <updating/>
        <source>getMethodKey(_proxyQuantityRangeMap : CM_QuantityRangeMap input) : Integer updating, protected;
// update the registered methods and return the integer key for the methods used.
vars
	i	: Integer;
	key	: Integer;
	methodIdx	: Integer;
	size	: Integer;
	methodFlag,
	methodName	: String;
begin
	size := self.currentMethods.size;
	foreach methodFlag in self.currentMethods do
		i := i + 1;
		if methodFlag &lt;&gt; null then
			methodName := self.fullMethodNames[i];
			if not _proxyQuantityRangeMap.allRegisteredMethods.includes(methodName) then
				_proxyQuantityRangeMap.allRegisteredMethods.add(methodName);
			endif;
		endif;
	endforeach;

	i := 0;
	foreach methodFlag in self.currentMethods do
		i := i + 1;
		if methodFlag &lt;&gt; null then
			methodName := self.fullMethodNames[i];
			methodIdx := self.getMethodIndex(methodName, _proxyQuantityRangeMap);
			if methodIdx &lt;&gt; 0 then	// safety check
				key := key.bitOr(2^(methodIdx-1));
			endif;
		endif;
	endforeach;

	return key;
end;</source>
        <access>protected</access>
        <Parameter name="_proxyQuantityRangeMap" type="CM_QuantityRangeMap" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMoveDetails" id="df2d3393-1d40-472d-b0ba-afcb82748e70">
        <updating/>
        <source>getMoveDetails(_moveType : String; _move : Boolean; _moveFrom : String output; _moveTo : String output;
				_resourceTypeObj : CM_ResourceType output) updating, protected;

vars
	pos		: Integer;
	id		: String;
	moveFrom	: String;
	moveTo		: String;
	resourceTypeObj : CM_ResourceType;
begin
	if _move then
		// should be from -&gt; to
		if _moveType &lt;&gt; "" then
			pos := _moveType.pos(' -&gt; ', 1);
			if pos &gt; 1 and
			   pos + 4 &lt; _moveType.length then
				moveFrom := _moveType[1:pos-1];
				moveTo := _moveType[pos+4:end];
			endif;
		endif;
		if moveFrom = "" or moveTo = "" then
			self.validationError("Invalid MoveType", _moveType);
		endif;
	else
	// is either null or "Resource Mappings:&lt;resource type code&gt;"
		if _moveType.length &gt; 18 and
		   _moveType[1:18] = "Resource Mappings:" then
			id := _moveType[19:end];
			resourceTypeObj := myRoot.allTaskResourceTypes[id];
			if resourceTypeObj = null then
				self.validationError("Invalid resource type", id);
			else
				_resourceTypeObj := resourceTypeObj;
			endif;
		endif;
	endif;

	_moveFrom := moveFrom;
	_moveTo	  := moveTo;
end;
</source>
        <access>protected</access>
        <Parameter name="_moveType" type="String"/>
        <Parameter name="_move" type="Boolean"/>
        <Parameter name="_moveFrom" type="String" usage="output"/>
        <Parameter name="_moveTo" type="String" usage="output"/>
        <Parameter name="_resourceTypeObj" type="CM_ResourceType" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getProductDetails" id="a47f5f47-7275-4387-b1f5-4d4aacc0f9f4">
        <updating/>
        <source>getProductDetails(_cargoSubtype : String; _productGroupObj : CM_ProductGroup ; _cargoTypeObj : CM_CargoType; _default : Boolean output; _productObj : CM_Product output) updating, protected;
// revised from 33095 testing, get cargo  subtypes from either product group or cargo type
vars
	found		: Boolean;
	productObj : CM_Product;
begin
	productObj := null;
	if _cargoSubtype = CM_FinancialObject.Extract_Default then
		_default := true;
	elseif _productGroupObj &lt;&gt; null then		// null test from 33095 testing
		foreach productObj in _productGroupObj.allProducts do
			if productObj.code =_cargoSubtype then
				found := true;
				break;
			endif;
		endforeach;
		if not found then
			productObj := null;
			self.validationError("Invalid cargo subtype", _cargoSubtype);
		endif;
	elseif _cargoTypeObj &lt;&gt; null then		// added cargo type from 33095 testing
		foreach productObj in _cargoTypeObj.allProducts do
			if productObj.code =_cargoSubtype then
				found := true;
				break;
			endif;
		endforeach;
		if not found then
			productObj := null;
			self.validationError("Invalid cargo subtype", _cargoSubtype);
		endif;
	endif;
	
	_productObj := productObj;

end;</source>
        <access>protected</access>
        <Parameter name="_cargoSubtype" type="String"/>
        <Parameter name="_productGroupObj" type="CM_ProductGroup"/>
        <Parameter name="_cargoTypeObj" type="CM_CargoType"/>
        <Parameter name="_default" type="Boolean" usage="output"/>
        <Parameter name="_productObj" type="CM_Product" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getProductGroupDetails" id="02c364a1-682b-41a7-a3ed-5cb860f00b56">
        <updating/>
        <source>getProductGroupDetails(_cargoSubtypeGroup : String; _cargoTypeObj : CM_CargoType; _default : Boolean output; _productGroupObj : CM_ProductGroup output) updating, protected;

vars
	pos		: Integer;
	foundDelim	: String;
	id		: String;
	productGroupObj : CM_ProductGroup;
begin
	productGroupObj := null;
	if _cargoSubtypeGroup = CM_FinancialObject.Extract_Default then
		_default := true;
	else
		pos := 1;
		id := _cargoSubtypeGroup.getDelimitedToken(pos, '|', foundDelim);		// 33095 just the code portion, with '|' delimiter
		if foundDelim &lt;&gt; '|' then
			pos := 1;
			id := _cargoSubtypeGroup.getDelimitedToken(pos, ' ', foundDelim);		// existing extact files with space delimiter
		endif;
		productGroupObj := _cargoTypeObj.allProductGroups[id];
		if productGroupObj = null then
			self.validationError("Invalid cargo subgroup type", id);
		endif;
	endif;
	
	_productGroupObj := productGroupObj;

end;</source>
        <access>protected</access>
        <Parameter name="_cargoSubtypeGroup" type="String"/>
        <Parameter name="_cargoTypeObj" type="CM_CargoType"/>
        <Parameter name="_default" type="Boolean" usage="output"/>
        <Parameter name="_productGroupObj" type="CM_ProductGroup" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getQuantityAttribute" id="7dce0afb-de81-457c-9bfe-e9a5d07629c5">
        <updating/>
        <source>getQuantityAttribute(_quantityType : String; _outputFormat : CM_OutputFormat_SS; _field : CM_XTABField output) updating, protected;

vars
	found		: Boolean;
	field		: CM_XTABField;
begin
	field := null;
	foreach field in _outputFormat.allFields do
		if field.heading = _quantityType then
			found := true;
			break;
		endif;
	endforeach;
	if not found then
		field := null;
		self.validationError("Invalid snapshot quantity attribute", _quantityType);
	endif;
	
	_field := field;

end;</source>
        <access>protected</access>
        <Parameter name="_quantityType" type="String"/>
        <Parameter name="_outputFormat" type="CM_OutputFormat_SS"/>
        <Parameter name="_field" type="CM_XTABField" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getQuantityRangeDetails" id="71c2ba60-223f-4f7e-bee0-037b105f0df1">
        <updating/>
        <source>getQuantityRangeDetails(_quantityRange : String; _default : Boolean output; _qtyFrom : Real output; _qtyTo : Real output) updating, protected;

vars
	qtyFrom	: Real;
	qtyTo	: Real;
	pos		: Integer;
	rangeFrom	: String;
	rangeTo	: String;
begin
	if _quantityRange = CM_FinancialObject.Extract_Default then
		_default := true;
	else
		pos := _quantityRange.pos(' to ', 1);
		if pos &gt; 1 and
		   pos + 4 &lt;= _quantityRange.length then
			rangeFrom := _quantityRange[1:pos-1];
			qtyFrom := rangeFrom.Real;
			rangeTo := _quantityRange[pos+4:end];
			if rangeTo = "MAX" then
				qtyTo := CM_QuantityRangeMap.MAX_RANGE;
			else
				qtyTo := rangeTo.Real;
			endif;
		endif;
	//	if (qtyFrom &lt;= 0 and qtyTo &lt;= 0) or
		if (qtyFrom &lt; 0 and qtyTo &lt; 0) or	//04 Jan 2018	NDL	TFS 42599
		   (qtyFrom &gt; qtyTo) then
			self.validationError("Invalid Quantity Range", _quantityRange);
		endif;
	endif;
	
	_qtyTo   := qtyTo;
	_qtyFrom := qtyFrom;

end;
</source>
        <access>protected</access>
        <Parameter name="_quantityRange" type="String"/>
        <Parameter name="_default" type="Boolean" usage="output"/>
        <Parameter name="_qtyFrom" type="Real" usage="output"/>
        <Parameter name="_qtyTo" type="Real" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getQuantityTypeDetails" id="3b832084-cf72-4585-927b-61337fa4ee8d">
        <updating/>
        <source>getQuantityTypeDetails(_quantityType : String; _default : Boolean output; _calculationType : CM_CalculationType output;
						_mappingType : Integer output; _chargeZero : Boolean output) protected, updating;

vars
	foundDelim	: String;
	id		: String;
	x,y,
	test	: String;
	pos	: Integer;
begin
	if _quantityType = null then
		return;
	endif;

	pos := _quantityType.length;
	if pos &lt; 3 then
		return;
	endif;
	test := _quantityType[pos:1];
	if test = "…" then  //  was 133.Character then
		_chargeZero := true;
		pos := pos - 2;
		test := _quantityType[pos:1];
	endif;
	
	if test = "›" then		//  was 155.Character then
		_mappingType := CM_QuantityMap.MapType_Single;
	elseif test = "»" then	// was 187.Character then
		_mappingType := CM_QuantityMap.MapType_Escalate;
	else	// 134.Character
		_mappingType := CM_QuantityMap.MapType_EscalateFull;
	endif;
	pos := pos - 2;
	test := _quantityType[1:pos];	
		
	if test = CM_FinancialObject.Extract_Default then
		_default := true;
	else
		pos := 1;
		// 1279 user-defined calc type
		
		if _quantityType[1:1] = "*" then
			id := _quantityType.getDelimitedToken(pos, '*', foundDelim);		// just the code portion
		elseif _quantityType[1:1] = "|" then // TFS 41096
			id := _quantityType.getDelimitedToken(pos, '|', foundDelim);		// TFS 41096 just the code portion
		else
			id := _quantityType.getDelimitedToken(pos, ' ', foundDelim);		// just the code portion
		endif;
		_calculationType := self.findCalculationType(id);
		if _calculationType = null then
			self.validationError("Invalid quantity calculation type", id);	// from 33095 testing, was reporting _quantityType
		endif;
	endif;
end;
</source>
        <access>protected</access>
        <Parameter name="_quantityType" type="String"/>
        <Parameter name="_default" type="Boolean" usage="output"/>
        <Parameter name="_calculationType" type="CM_CalculationType" usage="output"/>
        <Parameter name="_mappingType" type="Integer" usage="output"/>
        <Parameter name="_chargeZero" type="Boolean" usage="output"/>
    </JadeMethod>
