	theAP : CM_CargoTypeAttribPlan;
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valAttributePlan(_proxyAP);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	theMoveMap := _proxyAP.myMoveMap;
	
	create _newAttributePlan as _proxyAP.class persistent;
	_newAttributePlan.setForCreate(_proxyAP);

end;</source>
