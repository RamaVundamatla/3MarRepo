    <JadeMethod name="getIsSheetVisible" id="b39da837-719e-4abb-8c45-4ea3f356f7e1">
        <source>getIsSheetVisible(_sheet : Sheet) :Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31/01/2018	jlger1	Initial creation 36402
21/03/2018	jlgdap1	TFS 37445 PEl1 Voyage Status Security
23/09/2022 	navds20 ChangeRequest 54253: EUP - VAS Work Orders
*/

vars
	tmpRole			: CM_SecurityRole;
begin
	tmpRole:=self.myParentRole;
	if self.myParentRole = null then
		tmpRole:=self.myCurrentObject.CM_SecurityRole;
	endif;
	
	if _sheet = self.shtStopsMaint then
		if self.viewMode = ViewSystem then
			return false;
		else
			return (not tmpRole.allStopsMaint.isEmpty);
		endif;
		
	elseif _sheet = self.shtStopsCancel then
		if self.viewMode = ViewSystem then
			return false;
		else
			return (not tmpRole.allStopsCancel.isEmpty);
		endif;
	elseif _sheet = self.shtStopsView then
		if self.viewMode = ViewSystem then
			return false;
		else
			return (not tmpRole.allStopsView.isEmpty);
		endif;
	elseif _sheet = self.shtReports then
		if self.viewMode = ViewSystem then
			return false;
		else
			return (not tmpRole.allQryReports.isEmpty);
		endif;
	elseif _sheet = self.shtToDoTasks then
		if self.viewMode = ViewSystem then
			return false;
		else
			return (not tmpRole.allToDoTasksAddRemove.isEmpty) or (not tmpRole.allToDoTasksComplete.isEmpty);
		endif;
	elseif _sheet = self.shtTransactions then
		if self.viewMode = ViewSystem then
			return false;
		else
			return (not tmpRole.allTransactionTypesForEvents.isEmpty);
		endif;
		
	elseif _sheet = self.shtStatus then								// TFS 37445
		if self.viewMode = ViewSystem then							// TFS 37445
			return false;											// TFS 37445
		else														// TFS 37445
			return (not tmpRole.allVoyageStatusesMaint.isEmpty);	// TFS 37445
		endif;														// TFS 37445
		
	elseif _sheet = self.shtInvoiceStatus then						// TFS 39618
		if self.viewMode = ViewSystem then							// TFS 39618
			return false;											// TFS 39618
		else														// TFS 39618
			return true; //(not tmpRole.allVoyageStatusesMaint.isEmpty);	// TFS 39618
		endif;														// TFS 39618
		
	elseif _sheet = self.shtworkOrderStatus then					//23/09/2022 navds20 TFS 54253
		if self.viewMode = ViewSystem then							//23/09/2022 navds20 TFS 54253
			return false;											//23/09/2022 navds20 TFS 54253
		else														//23/09/2022 navds20 TFS 54253
			return true; 											//23/09/2022 navds20 TFS 54253
		endif;			

	elseif _sheet = self.shtVolDiscReasons then						// 29/4/19 MAP TFS41707
		if self.viewMode = ViewSystem then							// 29/4/19 MAP TFS41707
			return false;											// 29/4/19 MAP TFS41707
		else														// 29/4/19 MAP TFS41707
			return true;											// 29/4/19 MAP TFS41707
		endif;														// 29/4/19 MAP TFS41707

	//09 Mar 2020	NDL	TFS 48784
	elseif _sheet = self.shtEventTypes then
		if self.viewMode = ViewSystem then
			return false;
		else
			return true;
		endif;
	endif;
	
	return self.myPermissionAgent.allTerminalCategories.includes(_sheet.caption);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_sheet" type="Sheet"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getSptMainTop" id="1d804b36-e48f-4f1a-af3c-e73b61098fbc">
