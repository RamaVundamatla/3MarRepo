end;


</source>
    </JadeMethod>
    <JadeMethod name="createListOfTimeStamps" id="73ef5583-2388-4dbe-8815-732f377f8c21">
        <updating/>
        <source>createListOfTimeStamps(startAtRow : Integer;
					   totalrows : Integer;
					   timeStampList : TimeStampArray io) updating;
/*

Purpose: Creates a list of TimeStamps.
         This method was created to have a temporary record of the timestamp attribute for each CM_DamageInstance object 
		 stored on every row of the table. The list will help us determine the timestamp to be assigned 
		 on the DamageInstance proxy. This was needed because the object reference on the table gets 
		 deleted when the 'setProxyFromTable' method is called.

Parameters:	

Return Value: None

Date		Name	TFS#	Description
============================================================================
13 May 2019	jlgdi1	44730	Initial creation
============================================================================
*/

vars
	row : Integer;
	damageInstance : CM_DamageInstance;
	
begin
	foreach row in startAtRow to totalrows do
		self.accessRow(row);
		
		damageInstance := self.accessRow(row).itemObject.CM_DamageInstance;
		if (app.isValidObject(damageInstance)) and (damageInstance &lt;&gt; null) then
			timeStampList.add(damageInstance.timeStamp);
		else
			timeStampList.add(null);
		endif;
	endforeach;
end;</source>
        <Parameter name="startAtRow" type="Integer"/>
        <Parameter name="totalrows" type="Integer"/>
        <Parameter name="timeStampList" type="TimeStampArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getLostFocusDescr" id="378f78ba-741c-4cd6-b3c4-ea3225e72b39">
        <source>getLostFocusDescr() : String;
/*
----------   ----------  --------------------------------------------------
Created:	02 November 2006 By cnwth2

Purpose:	

/****Changes

Date		Name	TFS#			Description
============================================================================

============================================================================*/

vars
	aRow		: Integer;
	numRows		: Integer;
	rowDescr	: String;
	str			: String;
begin
	numRows := rows;
	foreach aRow in self.fixedRows + 1 to numRows do
		rowDescr := getRowDescr(aRow);
		if rowDescr &lt;&gt; null then
			str := str &amp; rowDescr &amp; ', ';
		endif;
	endforeach;
	
	if str &lt;&gt; null and str[str.length -1:end] = ', ' then
		str := str[1: str.length -2];
	endif;
	
	return str;
end;


</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRowDescr" id="9cde07c3-d828-4378-af96-7d882a744966">
        <source>getRowDescr(_row : Integer) : String;
/*
----------   ----------  --------------------------------------------------
Created:	02 November 2006 By cnwth2

Purpose:	

/****Changes

Date		Name	TFS#	Description
============================================================================
30/11/2018	jlgka1	41225	Add repaired attribute.
============================================================================*/

vars
	locStr		: String;
	damageStr	: String;
	severityStr	: String;
	quantityStr : String;
	repairedStr	: String;
begin
	locStr := self.getCellText(_row, 1) ;
	damageStr := self.getCellText(_row, 2) ;
	severityStr := self.getCellText(_row, 3) ;
	quantityStr := self.getCellText(_row,4).trimBlanks;	// 15 Oct 2013	NDL	Par 32803
	repairedStr := self.getCellText(_row, 5) ; // jlgka1 TFS 41225
	
	if locStr &lt;&gt; null and damageStr &lt;&gt; null and severityStr &lt;&gt; null then
		if quantityStr &lt;&gt; null then
			return locStr &amp; ' has ' &amp; damageStr &amp; '(' &amp; severityStr &amp; ')(x' &amp; quantityStr &amp; ')' &amp; repairedStr;	// 15 Oct 2013	NDL	Par 32803
		else
			return locStr &amp; ' has ' &amp; damageStr &amp; '(' &amp; severityStr &amp; ')' &amp; repairedStr;
		endif;
	endif;
	
	return null;
end;


</source>
        <Parameter name="_row" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTimeStampFromList" id="e01093e4-363f-48b8-9336-143dd076f726">
        <source>getTimeStampFromList(timeStampList : TimeStampArray input; targetIndex : Integer) : TimeStamp;
/*

Purpose: Returns the corresponding TimeStamp from the list at the specified position.
		 If the corresponding TimeStamp is not valid (timeStamp = 00:00:00) or 
		 in a scenario that it could not find it from the list, returns the actual server time instead.

Parameters:	List of TimeStamps; Target position (index)

Return Value: TimeStamp

Date		Name	TFS#	Description
============================================================================
13 May 2019	jlgdi1	44730	Initial creation
============================================================================
*/

vars
	damageTimeStamp : TimeStamp;
	
begin
	if (targetIndex &gt; 0) and (targetIndex &lt;= timeStampList.size) then
		damageTimeStamp := timeStampList[targetIndex];
	else
		damageTimeStamp := app.actualTimeServer();
	endif;
	
	// old CM_DamageInstance does not have TimeStamp value (timeStamp = 00:00:00), 
	// updating it with the server time give them identity.
	if not damageTimeStamp.isValid() then 
		damageTimeStamp := app.actualTimeServer();
	endif;
	
	return damageTimeStamp;
end;</source>
        <Parameter name="timeStampList" type="TimeStampArray" usage="input"/>
        <Parameter name="targetIndex" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="handleWarnings" id="86b2c574-06f8-4414-9d30-478e1073f467">
        <source>handleWarnings(_exObj : Exception; _passport : CM_Passport input) : Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
13 November 2024		jlizm1	Initial creation MTN 33161 Damage check details being lost when incomplete

*/
vars

begin
	if _passport = null then
		return Ex_Pass_Back;
	endif;

	if _exObj.isKindOf(CM_Exception) and _exObj.CM_Exception.isWarning then
		_passport.addWarningFull(_exObj.errorCode, _exObj.extendedErrorText, _exObj.CM_Exception.userString, _exObj.CM_Exception.myUserObject, _exObj.CM_Exception.mySubject);
		return Ex_Continue;
	endif;
	
	return Ex_Pass_Back;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="init" id="e0db4d92-b810-489e-8f88-5ce6e6a65612">
        <updating/>
        <source>init() updating;
/*
----------   ----------  --------------------------------------------------
Created:	25 October 2006 By cnwth2

Purpose:	

/****Changes

Date		Name	TFS#		Description
============================================================================
05/10/2013	NDL		Par 32803	Increase column number from 3 to 4.
30/11/2018	jlgka1	41225		Increase column number from 4 to 5.
============================================================================*/
vars
	row			: Integer;
begin
	
	self.initCmbSeverity(); //moved here does not rely on the type of object
	self.initCmbRepaired(); // jlgka1 TFS 41225
	
	self.rows := 0;
	self.columns := 5;	// jlgka1 TFS 41225
	self.fixedColumns := 0;
	
	//self.addItem(app.getErrorString(Pos) &amp; Tab &amp; app.getErrorString(Damage) &amp; Tab &amp; app.getErrorString(Severity));
	self.addItem(	app.getErrorString(Pos) &amp; Tab
					&amp; app.getErrorString(Damage) &amp; Tab
					&amp; app.getErrorString(Severity) &amp; Tab
					&amp; app.getErrorString(Qty) &amp; Tab // 15 Oct 2013	NDL	Par 32803
					&amp; app.getErrorString(Repair));  // jlgka1 TFS 41225

	self.fixedRows := 1;
	//epr 25/5/10 make column widths dynamic depending on font size
	self.fitColumnWidth(1,10);
	self.fitColumnWidth(3,10);
	
    self.addDamageRow(null);//shiny new row ready for entry
	
	
end;





</source>
    </JadeMethod>
    <JadeMethod name="initCmbRepaired" id="0e13194c-4426-4a69-9dba-f149c5949b6a">
        <source>initCmbRepaired() protected;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 30 November 2018
TFS#		: 41225
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	repaired : Boolean;
begin
	
	self.myCmbRepaired.clear();
	self.myCmbRepaired.style := ComboBox.Style_DropDownComboList;
	self.myCmbRepaired.addItem(null);
	self.myCmbRepaired.addItem("true");
	self.myCmbRepaired.addItem("false");
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initCmbSeverity" id="f865de94-7065-47cb-9d9d-fe20a069041d">
        <source>initCmbSeverity() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 November 2009	cnwer1	Initial creation

*/

vars
	severity : Integer;
begin
	
	self.myCmbSeverity.clear();
	self.myCmbSeverity.style := ComboBox.Style_DropDownComboList;
	self.myCmbSeverity.addItem(null);
	foreach severity in 1 to DamageSeverity_MAX do
		self.myCmbSeverity.itemData[self.myCmbSeverity.addItem(severity.String)] := severity;
	endforeach;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initCombos" id="516db142-284d-4b78-bdc2-656739a204d6">
        <updating/>
        <source>initCombos(_damageInterface : IF_DamageDetails ) updating;
/*
----------   ----------  --------------------------------------------------
Created:	21 September 2006 By cnwth2

Purpose:	

Changed On  Changed By  Reason
----------  ----------  --------------------------------------------------
25/05/2015	cnwdap1		PAR #36311 Resizing Damges table - when maximised, the Position column was still too small
04/06/2024	jlika1	TFS 64052 CUX | UAT Damage Description field in Voyage Ops Live Checks
*/
vars
	damageDef			: CM_DamageDefinitionCode;
	damageCodeDict		: CM_DamageDefinitionByCodeDict;
	damagePosDict		: CM_DamagePositionByCodeDict;
	cmb					: ComboBox;
	textWidth			: Integer;
	damagePosition      : CM_DamagePosition;
	posColumn			: JadeTableColumn;
begin

	cmb := self.myCmbPosition;
	cmb.clear();
	cmb.style := ComboBox.Style_DropDownComboList;
	cmb.addItem(null);
	
	create damagePosDict transient;
	_damageInterface.getDamagePositions(damagePosDict);
	
	posColumn:=self.accessColumn(1);
	foreach damagePosition in damagePosDict do 
		cmb.itemObject[cmb.addItem(damagePosition.code)] := damagePosition;
		textWidth := textWidth.max( self.getTextExtent(damagePosition.code) + posColumn.marginLeft + posColumn.marginRight);
	endforeach;
	
	textWidth:=textWidth + posColumn.marginLeft + posColumn.marginRight + 10; 
	if self.form.windowState = Form.WindowState_Maximized then	// PAR #36311
		textWidth := (textWidth * 2).Integer;					// PAR #36311
	endif;														// PAR #36311
	
	if posColumn.width &lt; textWidth then
		posColumn.width :=textWidth;
	endif;

	cmb := self.myCmbCode;
	cmb.clear();
	cmb.style := ComboBox.Style_DropDownComboList;
	cmb.addItem(null);
	cmb.listWidth := 200;
	
	create damageCodeDict transient;
	_damageInterface.getDamageCodes(damageCodeDict);
	
	foreach damageDef in damageCodeDict do		
		cmb.itemObject[cmb.addItem(damageDef.code &amp; Tab &amp; damageDef.description)] := damageDef;
	endforeach;

	
epilog
	delete damageCodeDict;
	delete damagePosDict;
end;


</source>
        <Parameter name="_damageInterface" type="IF_DamageDetails"/>
    </JadeMethod>
    <JadeMethod name="prefillForPennTerminals" id="a4ab11d4-8aac-4f53-84fa-1a2dc4b888f7">
        <updating/>
        <source>prefillForPennTerminals()updating;
/*

Purpose:			

Parameters:			

Return Value:		

/****Changes

Date		Name	TFS#		Description
============================================================================
09/04/2014	cnwndl1	Par 33934   Initial creation - Dirty back patchable change for Penn
30/11/2018	jlgka1	41225		Add repaired attribute.
============================================================================*/

vars
	aRow : Integer;
begin

	aRow := self.row;
	if aRow &lt;= self.fixedRows or aRow &gt; self.rows then
		aRow := self.rows;
	endif;
	
	if self.accessCell(aRow,1).text.trimBlanks = null then
		if self.myCmbPosition.listCount &gt; 1 then
			self.myCmbPosition.listIndex := 2;
			self.setCellText(aRow,1,self.myCmbPosition.itemText[2]);
		endif;
	endif;
	if self.accessCell(aRow,3).text.trimBlanks = null then
		if self.myCmbCode.listCount &gt; 1 then
			self.myCmbSeverity.listIndex := 2;
			self.setCellText(aRow,3,self.myCmbSeverity.itemText[2]);
		endif;
	endif;
	if self.accessCell(aRow,4).text.trimBlanks = null then
		self.setCellText(aRow,4,"1");
	endif;
	
	if self.accessCell(aRow,5).text.trimBlanks = null then
		self.setCellText(aRow,5,self.myCmbRepaired.itemText[2]);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="queryRowColChg" id="a9759a47-0c99-48e3-b861-1fc49395c860">
