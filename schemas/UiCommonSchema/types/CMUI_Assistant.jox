    <JadeMethod name="showDamageEntryForm" id="9138d2c9-16a2-4943-8a83-e5f2c1a8becf">
        <source>showDamageEntryForm(_parentForm: CM_BaseForm; _mode : Integer; _term : CM_Terminal; _pxy, _real : CM_Object; _damage : CM_DamageInstanceByDmgePos; _masterMenuAction : CMUI_MenuAction; _isParentUpdate : Boolean);
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
// 29/10/13	 cnwer1		par 31845
// 30/09/22	 navkc1		ChangeRequest #54463: MTN - Subscription License, New Feature Support Phase 1
// ---------------------------------------------------------------------------
vars
	advForm 		: CMUI_DamageCodesAdvanceForm;
	form			: CMUI_DamageCodesForm;
	showAdvance		: Boolean;
begin
	/*	30/09/2022	navkc1	#54663
	form := app.loadForm(CMUI_DamageCodesAdvanceForm, CMUI_Assistant, false, false, true , _term, _masterMenuAction).CMUI_DamageCodesAdvanceForm;
	form.mode := _mode;
	form.setMyMasterItems( _pxy, _real);
	form.setParentForm(_parentForm);
	if _damage &lt;&gt; null then
		_damage.copy(form.allProxyDamageInstances);
	endif;
	
	form.showModal();
	*/
	
	if app.getMyUser().canDo(_term, PmAdmDamageCodeAdvancedView) then
		showAdvance := true;
		if app.isSpecial() then
			if app.msgBox("Do you want to use the Advanced Damage?", "", MsgBox_Yes_No) = MsgBox_Return_No then
				showAdvance := false;
			endif;
		endif;
	endif;
	
	if showAdvance then
		advForm := app.loadForm(CMUI_DamageCodesAdvanceForm, CMUI_Assistant, false, false, true , _term, _masterMenuAction).CMUI_DamageCodesAdvanceForm;
		advForm.mode := _mode;
		advForm.setMyMasterItems( _pxy, _real);
		advForm.isParentFormUpdate := _isParentUpdate;
		advForm.setParentForm(_parentForm);
		if _damage &lt;&gt; null then
			_damage.copy(advForm.allProxyDamageInstances);
		endif;
		
		advForm.showModal();
	else
		form := app.loadForm(CMUI_DamageCodesForm, CMUI_Assistant, false, false, true , _term, _masterMenuAction).CMUI_DamageCodesForm;
		form.mode := _mode;
		form.setMyMasterItems( _pxy, _real);
		form.isParentFormUpdate := _isParentUpdate;
		form.setParentForm(_parentForm);
		if _damage &lt;&gt; null then
			_damage.copy(form.allProxyDamageInstances);
		endif;
		
		form.showModal();
	endif;
end;</source>
        <Parameter name="_parentForm" type="CM_BaseForm"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_pxy" type="CM_Object"/>
        <Parameter name="_real" type="CM_Object"/>
        <Parameter name="_damage" type="CM_DamageInstanceByDmgePos"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_isParentUpdate" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showDamageForm" id="c8b65a7b-2b5d-4c42-91d6-2e836a854acf">
        <source>showDamageForm( _parentForm: CM_BaseForm; _mode : Integer; _term : CM_Terminal; _pxy, _real : CM_Object; _damage : CM_DamageInstanceByDmgePos; _masterMenuAction : CMUI_MenuAction; _isParentUpdate : Boolean);
/*
Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
20 December 2022	navmk20	Bug 55809: MTN - Damage on wagons should not show advanced damage option

*/

vars
	form	: CMUI_DamageCodesForm;
begin
	form := app.loadForm(CMUI_DamageCodesForm, CMUI_Assistant, false, false, true , _term, _masterMenuAction).CMUI_DamageCodesForm;
	form.mode := _mode;
	form.setMyMasterItems( _pxy, _real);
	form.isParentFormUpdate := _isParentUpdate;
	form.setParentForm(_parentForm);
	if _damage &lt;&gt; null then
		_damage.copy(form.allProxyDamageInstances);
	endif;
	form.showModal();
end;</source>
        <Parameter name="_parentForm" type="CM_BaseForm"/>
        <Parameter name="_mode" type="Integer"/>
