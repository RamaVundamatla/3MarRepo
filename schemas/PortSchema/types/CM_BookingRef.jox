    <JadeMethod name="myProduct" id="308d1492-2fa9-4d81-9c86-930b2c8117a6">
        <methodInvocation>mapping</methodInvocation>
        <source>myProduct(_set : Boolean; _value : CM_Product io) mapping;
// ---------------------------------------------------------------------------
// Created:     04 March 2010 by cnwcs5
// Purpose:     par 22762
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	if not _set or						// not setting
		self.isTransient or				// don't need to bother for transients
		_value = null or				// product is null
		self.myProduct = _value then	// not changing product
		return;
	endif;
	
	if _value &lt;&gt; null then
		_value.updateForNonInversedReference;
	endif;
epilog

end;</source>
        <Parameter name="_set" type="Boolean"/>
        <Parameter name="_value" type="CM_Product" usage="io"/>
    </JadeMethod>
    <JadeMethod name="numOnsiteTIs" id="ea5d6669-f445-41a8-9d2e-42b63e7e9a78">
        <source>numOnsiteTIs() : Integer;
/*

Purpose:			despite the name this is really the number of cargo items that have been received 
					for this booking regardles of whether they are still onsite.

Parameters:			null

Return Value:		number of received items

Date		Who		Reason
12 Jun 2013	cnwcs5	par 31670 - fix counting for break bulk
03 Apr 2019	jlgzm1	tfs43864 Booking Screen performance

*/
vars
	ti 			: CM_TrackedItem;
	total		: Integer;
	booking		: CM_BookingRef;
	iter		: Iterator;
begin
	//make sure we are the real object
	if self.isTransient then
		booking := app.myProxyManager.getRealObject(self).CM_BookingRef;
		if booking &lt;&gt; null then
			return booking.numOnsiteTIs;
		endif;
	endif;

	//tfs43864 start
	iter := self.allTIsByState.createIterator();
	
	//get all items with state &lt; prenote
	self.allTIsByState.startKeyGeq(TI_STATE_UNDEFINED, "", 0, iter);
	while iter.next(ti) do
		//get state key
		if iter.getCurrentKey(1).Integer &gt;= TI_STATE_NOTIFIED then
			break;
		endif;
		total := total + 1;
	endwhile;
	
	//get all items with state &gt; prenote and state &lt; merged
	self.allTIsByState.startKeyGeq(TI_STATE_OFFSITE, "", 0, iter);
	while iter.next(ti) do
		//get state key
		if iter.getCurrentKey(1).Integer &gt;= TI_STATE_MERGED then
			break;
		endif;
		total := total + 1;
	endwhile;
	//tfs43864 end

	return total;

epilog
	delete iter;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="numTIs" id="d5ee9563-5a62-45e3-922f-d1db361ee5bf">
        <methodInvocation>mapping</methodInvocation>
        <source>numTIs(set: Boolean; _value: Integer io) mapping;
/*

Purpose:			Get number of tracked items

Parameters:			null

Return Value:		number of tracked items

Date		Who		Reason
19 Dec 2006 cnwth2	Initial creation
12 Jun 2013	cnwcs5	par 31670 - fix for break bulk quantity
03 Apr 2019	jlgzm1	tfs43864 Booking screen performance

*/
vars
	ti 		:CM_TrackedItem;
	iter 	: Iterator;
	
begin
	if set then
		//cannot manually set
		app.raiseSetVirtualError(class.name,method.name);
	else
		//tfs43864 start
		iter := self.allTIsByState.createIterator();
		//TI_STATE_MERGED is the last state in the collection, get everything less than that
		self.allTIsByState.startKeyLss(TI_STATE_MERGED, "", 0, iter);

		beginLoad;
			while iter.back(ti) do
				_value := _value + 1;
			endwhile;
		endLoad;
		//tfs43864 end
	endif;
	
epilog
	delete iter;
end;


</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
