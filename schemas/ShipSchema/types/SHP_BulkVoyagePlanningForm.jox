//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 02/09/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars

begin
	if btn.value and not self.workingMode = self.WorkMode_Volume then
		self.switchWorkingMode(self.WorkMode_Volume);
	elseif not btn.value and self.workingMode = self.WorkMode_Volume then
		self.switchWorkingMode(self.WorkMode_Weight);
	endif;
	self.displayModeOperations(false);
	self.voyageDrawGridAreasForMode();
	self.btnViewByWeight.value := not btn.value;
epilog

end;</source>
