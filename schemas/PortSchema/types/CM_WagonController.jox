    <JadeMethod name="isReallyAvailable" id="47b4443f-9458-40e5-84b5-b6aea3de7e68">
        <source>isReallyAvailable( _intendedTi: CM_TrackedItem; _otherLc : CM_LocationsController input; _atPosInStack : Integer; _intendedIsoType : CM_ISOType; _intendedIsoTypeGroup : CM_ISOTypeGroup): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 February 2010	cnwndl1	Initial creation	Par 22343	// moved down to sub classes.

*/

vars

	tiArray : CM_TIArray;
	workArray : CM_TIArray; 
	ti : CM_TrackedItem;
	
begin

	// if the twistlock is marked as damaged.  ( damaged twistlock is signified by the 'isAvailable' attribute)
	// being set when the wagon is not confirmed we are not avaialable.
	if not self.myWagon.confirmed then
		if not self.isAvailable then
			return false;
		endif;
	endif;

	// get a collection of every ti that is actually in this position or is planned or queued to this position
	// if the wagon is confirmed (in) (i.e already arrived in the yard ) then don't include ti's that are coming off
	// the wagon, because we wil be planning the outward journey..
	create tiArray transient;
	foreach ti in self.allTrackedItems do
		if self.myWagon.confirmed then
			if not self.myWagon.isTIOutward(ti) then
				continue;
			endif;
		endif;
		tiArray.add(ti);
	endforeach;
	
	create workArray transient; 
	self.getAllQueuedTrackedItems(workArray, true);
	foreach ti in workArray where not tiArray.includes(ti) do
		tiArray.add(ti);
	endforeach;
	
	self.getAllPlannedTrackedItems(workArray, true, false);
	foreach ti in workArray where not tiArray.includes(ti) do
		tiArray.add(ti);
	endforeach;
	
	// if the collection includes the one being passed in remove it from the collection,
	// cos clearly we are considering moving it. 
	if _intendedTi &lt;&gt; null then 
		if tiArray.includes(_intendedTi) then
			tiArray.remove(_intendedTi);
		endif;
	endif;
	
	//if _intendedIsoType &lt;&gt; null then
	if _intendedIsoType &lt;&gt; null or _intendedIsoTypeGroup &lt;&gt; null then	// 11 May 2010 NDL	Par 24064
		if self.allRailWLELoad.size &gt;= _atPosInStack then
			if self.allRailWLELoad[_atPosInStack] &lt;&gt; null then
				// already earmarked a release request for this position in stack
				return false;
			endif; 
		endif;
	endif;
	
	//13 Oct 2014	NDL	Par 35040
	if _atPosInStack &gt; 0 then
		//If we know the stack position, make sure we have cargo under it, it can't float in space.
		if ( tiArray.size + self.allRailWLELoad.size + 1 ) &lt;&gt; _atPosInStack then
			return false;
		endif;
	endif;
	
	if _otherLc &lt;&gt; null and _otherLc.isWellcarCont then
		if _otherLc.CM_WellcarWagonController.myWellcarWellVisit &lt;&gt; self.CM_WellcarWagonController.myWellcarWellVisit then
			return false;
		endif;
	endif;

	// if there are no ti(s) in this position at this point on the code, its available.
	if tiArray.size = 0 and self.allRailWLELoad.size = 0 then
		return true;
	endif;
	
	// so there is already at least one there, is there room in the stack??
	if ( tiArray.size + self.allRailWLELoad.size ) &gt;= _atPosInStack then
		// this controller is already full at this position.
		return false;
	endif;
	
	// multi stacking... check that we have the same length cargo.
	if _atPosInStack &gt; 1 then
		ti := tiArray.first;	// any on the stack will do, might as well be the bottom one.
		if ti = null then
			ti := self.allRailWLELoad.first.myTrackedItem;
		endif;
		
		if _intendedTi &lt;&gt; null then	//12 Dec 2014	NDL	Par 35345
			if not self.canPlanOverstow( _intendedTi, _otherLc ) then
				return false;
			endif;
		else
			if ti &lt;&gt; null and not ti.isOverStowableOnWagon(self.myWagon,_intendedTi, _intendedIsoType, _intendedIsoTypeGroup) then//10 May 2010	NDL Par 24064
				return false;
			elseif  _intendedIsoType &lt;&gt; null then
				if not self.canPlanOverstow( _intendedIsoType, _otherLc ) then
					return false;
				endif;
			elseif  _intendedIsoTypeGroup &lt;&gt; null then
				if not self.canPlanOverstow( _intendedIsoTypeGroup, _otherLc ) then
					return false;
				endif;
			endif;
		endif;
	
	endif;
	
	return true;
	
epilog

	delete tiArray;
	delete workArray;
	
end;</source>
        <Parameter name="_intendedTi" type="CM_TrackedItem"/>
        <Parameter name="_otherLc" type="CM_LocationsController" usage="input"/>
        <Parameter name="_atPosInStack" type="Integer"/>
        <Parameter name="_intendedIsoType" type="CM_ISOType"/>
        <Parameter name="_intendedIsoTypeGroup" type="CM_ISOTypeGroup"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
