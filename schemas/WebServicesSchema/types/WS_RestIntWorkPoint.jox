<Class name="WS_RestIntWorkPoint" id="14da2f1f-b47a-4c0d-a888-ce2e93ac9e4b">
    <superclass name="WS_RestInternalProxyObject"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="restwebservice"/>
    <PrimAttribute name="code" id="95a6ad7b-aab4-4e8d-9ca1-2d39a97d2ecd">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="description" id="48e8ae8d-665b-4afe-92b4-a733e9ac7f8f">
        <type name="String"/>
    </PrimAttribute>
    <ImplicitInverseRef name="workPointType" id="e919a97f-aaf7-4a6d-be4e-7beeb6399d2f">
        <embedded/>
        <type name="WS_RestIntWorkPointType"/>
    </ImplicitInverseRef>
    <JadeMethod name="setProxyFromObject" id="0e4e18b6-20fd-4cd5-91ef-e612ccecf248">
        <updating/>
        <source>setProxyFromObject(_object: Object) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 June 2023		navma1	Initial creation

*/

vars
	workPointType : CM_WorkPointType;
begin
	inheritMethod(_object);
	self.code 		 := _object.CM_WorkPoint.code;
	self.description := _object.CM_WorkPoint.description;
	
	workPointType := _object.CM_WorkPoint.myWorkPointType;
	if workPointType &lt;&gt; null then
		self.workPointType.setProxyFromObject(workPointType);
	endif;
epilog

end;</source>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
</Class>
