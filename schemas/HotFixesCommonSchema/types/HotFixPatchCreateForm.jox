    <JadeMethod name="removeNullsFromTokens" id="7ca468ce-b505-4572-81e2-d59d2aac6ee2">
        <source>removeNullsFromTokens(_tokens : StringArray io);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 January 2014	cnwmc5	Initial creation	PAR 32864

*/

vars
	token			: String;
	
	actualTokens 	: StringArray;
begin
	create actualTokens transient;
	
	foreach token in _tokens do
		if token &lt;&gt; null then
			actualTokens.add(token);
		endif;
	endforeach;
	
	_tokens.clear();
	actualTokens.copy(_tokens);
	
epilog
	delete actualTokens;
end;</source>
        <Parameter name="_tokens" type="StringArray" usage="io"/>
    </JadeMethod>
