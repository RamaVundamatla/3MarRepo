    <JadeMethod name="getWalkPathTIDetails" id="111bb404-8fd4-455f-b7b9-bb718497ac49">
        <source>getWalkPathTIDetails();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2020	jlgmh5	Initial creation

*/

vars

	yardActivity				: CM_YardActivity;
	
	terminalCode				: String;
	type						: String;
	tiCode						: String;

begin

	foreach yardActivity in CM_ReeferAlarmActivity.instances discreteLock do
	
		type := CM_YardActivity@getStringFromType(yardActivity.type);
		terminalCode := yardActivity.myTerminal.code;
		tiCode := yardActivity.myTrackedItem.id;
		
		write yardActivity.String &amp; Tab &amp; type &amp; Tab &amp; terminalCode &amp; Tab &amp; tiCode;
	
	endforeach;
	
	
	foreach yardActivity in CM_ReeferConnectActivity.instances discreteLock do
	
		type := CM_YardActivity@getStringFromType(yardActivity.type);
		terminalCode := yardActivity.myTerminal.code;
		tiCode := yardActivity.myTrackedItem.id;
		
		write yardActivity.String &amp; Tab &amp; type &amp; Tab &amp; terminalCode &amp; Tab &amp; tiCode;
	
	endforeach;
	
	
	foreach yardActivity in CM_ReeferDisconnectActivity.instances discreteLock do
	
		type := CM_YardActivity@getStringFromType(yardActivity.type);
		terminalCode := yardActivity.myTerminal.code;
		tiCode := yardActivity.myTrackedItem.id;
		
		write yardActivity.String &amp; Tab &amp; type &amp; Tab &amp; terminalCode &amp; Tab &amp; tiCode;
	
	endforeach;
	
	
	foreach yardActivity in CM_ReeferMonitorActivity.instances discreteLock do
	
		type := CM_YardActivity@getStringFromType(yardActivity.type);
		terminalCode := yardActivity.myTerminal.code;
		tiCode := yardActivity.myTrackedItem.id;
		
		write yardActivity.String &amp; Tab &amp; type &amp; Tab &amp; terminalCode &amp; Tab &amp; tiCode;
	
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhTest1" id="aa87074c-96e2-416f-824c-2f3f2b0a14da">
        <source>mdhTest1();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 December 2021	navmh5	Initial creation

*/

vars

begin


	app.initialize();
	
	write "delayTIme: " &amp; app.delayTime.String &amp; Tab &amp; "isOpsViewTest: " &amp; app.isOpsviewTest.String &amp; Tab &amp; "shiftLength: " &amp; app.shiftLength.String;

end;
</source>
    </JadeMethod>
    <JadeMethod name="mdhTestDataLoad2" id="c131fd2c-beb6-4c74-8236-02a3ec54b6f2">
        <updating/>
        <source>mdhTestDataLoad2() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05/10/2017	jlgmh5	Initial creation

*/

vars

	loadOrderFile				: File;
	fileToLoad					: File;
	fileFolder					: FileFolder;
	fileNode					: FileNode;
	tempFileNode				: FileNode;
	fileFolder2					: FileFolder;
	
	xmlDocParser				: JadeXMLDocumentParser;
	xmlDoc						: JadeXMLDocument;
	rootElement					: JadeXMLElement;

	dataToLoad					: UT_DataSetupDestroy;
	
	filesToCopyArray			: FileNodeArray;

	methodStr					: String;
	startTS						: TimeStamp;
	endTS						: TimeStamp;
	
	line						: String;
	fileName					: String;
	methodName					: String;
	tempFileName				: String;
	pos							: Integer;
	result						: String;
	tempFileFolderName			: String;
	
begin
	
	startTS := app.actualTimeAppServer();
	
	app.initialize();
	
	create dataToLoad transient;
	dataToLoad.setActiveProfileMDHONLY();
	
	
	create loadOrderFile transient;
	loadOrderFile.fileName := OrderToLoadFile;
	
	create filesToCopyArray transient;
	
	while not loadOrderFile.endOfFile do
	
		//methodStr := dataToLoad.MethodString;
	
		line := loadOrderFile.readLine();
		if line = null then
			continue;
		endif;
		
		fileName := line &amp; "*.xml";
		
		// need to change the name for EDI file loads
		tempFileFolderName := DataLoadedCopyFrom &amp; "\";
		if line.toUpper().cnContains("Vessels".toUpper()) then
			tempFileFolderName := DataLoadedCopyFromVessels &amp; "\";
			methodName := "process" &amp; line;
			methodStr := dataToLoad.MethodString;
			methodStr.cnReplaceString("&lt;^%For^%&gt;", methodName);
		elseif line.toUpper().cnContains("EDIFiles".toUpper()) then
			methodName := 'processEDIFiles';
			tempFileFolderName := DataLoadedCopyFromEDIFiles &amp; "\";
			methodStr := dataToLoad.MethodString;
			methodStr.cnReplaceString("&lt;^%For^%&gt;", methodName);
		elseif line.toUpper().cnContains('SystemConfigs'.toUpper()) or line.toUpper().cnContains('TerminalConfig'.toUpper()) then
			methodName := 'processConfigs';
		elseif line.toUpper().cnContains('SecurityRole'.toUpper()) then
			methodName := 'processSecurityRoles';
		else
			methodName := "process" &amp; line;
		endif;
		//methodStr.cnReplaceString("&lt;^%For^%&gt;", methodName);
		write 'fileName : ' &amp; fileName &amp; Tab &amp; "methodName: " &amp; methodName;
		app.writeLog('fileName : ' &amp; fileName &amp; Tab &amp; "methodName: " &amp; methodName, LogINFO);
		write 'tempFileFolderName: ' &amp; tempFileFolderName;
	
		delete fileFolder;
		create fileFolder transient;
		fileFolder.fileName := tempFileFolderName;
		fileFolder.usePresentationFileSystem := true;
		fileFolder.mask := fileName;
		
		tempFileNode := null;
		tempFileName := null;
		filesToCopyArray.clear();
		
		foreach fileNode in fileFolder.files do
		
			methodStr := dataToLoad.MethodString;
			methodStr.cnReplaceString("&lt;^%For^%&gt;", methodName);
		
			delete xmlDocParser;
			create xmlDocParser transient;
			delete xmlDoc;
			create xmlDoc transient;
			xmlDocParser.parseDocumentFile(xmlDoc, fileNode.fileName);
			rootElement := xmlDoc.rootElement;
			
			dataToLoad.sendMsgWithIOParams(methodName, rootElement, methodStr);
			tempFileNode := fileNode;
			tempFileName := DataLoadedCopyTo &amp; "\" &amp; tempFileNode.cnGetSimpleFileName();
			filesToCopyArray.add(fileNode);
		
			
			
			// set whether updating method or not
			if methodName = "processLoadColorCodeJobToOps" then
				methodStr.cnReplaceString('&lt;^%updating^%&gt;', 'updating');
			else
				methodStr.cnReplaceString('&lt;^%updating^%&gt;', '');
			endif;
				
			
			if methodStr.pos("&lt;^%vars^%&gt;", 1) &gt; 0 or methodStr.pos("&lt;^%code^%&gt;", 1) &gt; 0 or 
					methodStr.pos("&lt;^%epilog^%&gt;", 1) &gt; 0 then
				app.writeLog(methodName &amp; ' not processed, no details found.', LogINFO);
				write methodName &amp; ' not processed, no details found.';
				continue;
			endif;
			
			write methodStr &amp; CrLf &amp; CrLf;
			
			//execute the transient method
			result := dataToLoad.executeMethod(methodStr);
			
			
		
		endforeach;
		
		// catch those methods that fall through like vessels, edi files
		if methodName = 'processEDIFiles' then
			dataToLoad.sendMsgWithIOParams(methodName, methodStr);
			delete fileFolder2;
			create fileFolder2 transient;
			fileFolder2.fileName := DataLoadedCopyFromEDIFiles &amp; "\";
			fileFolder2.usePresentationFileSystem := true;
			fileFolder2.mask := "*.xml";
			if not fileFolder2.files.isEmpty() then
				fileFolder2.files.copy(filesToCopyArray);
			endif;
			
			// set whether updating method or not
			if methodName = "processLoadColorCodeJobToOps" then
				methodStr.cnReplaceString('&lt;^%updating^%&gt;', 'updating');
			else
				methodStr.cnReplaceString('&lt;^%updating^%&gt;', '');
			endif;
				
			
			if methodStr.pos("&lt;^%vars^%&gt;", 1) &gt; 0 or methodStr.pos("&lt;^%code^%&gt;", 1) &gt; 0 or 
					methodStr.pos("&lt;^%epilog^%&gt;", 1) &gt; 0 then
				app.writeLog(methodName &amp; ' not processed, no details found.', LogINFO);
				write methodName &amp; ' not processed, no details found.';
				continue;
			endif;
			
			write methodStr &amp; CrLf &amp; CrLf;
			
			//execute the transient method
			result := dataToLoad.executeMethod(methodStr);
		elseif methodName = "processVessels" then
			dataToLoad.sendMsgWithIOParams(methodName &amp; 'FromFile', methodStr);
			delete fileFolder2;
			create fileFolder2 transient;
			fileFolder2.fileName := DataLoadedCopyFromVessels &amp; "\";
			fileFolder2.usePresentationFileSystem := true;
			fileFolder2.mask := "*.xml";
			if not fileFolder2.files.isEmpty() then
				fileFolder2.files.copy(filesToCopyArray);
			endif;
			
			// set whether updating method or not
			if methodName = "processLoadColorCodeJobToOps" then
				methodStr.cnReplaceString('&lt;^%updating^%&gt;', 'updating');
			else
				methodStr.cnReplaceString('&lt;^%updating^%&gt;', '');
			endif;
				
			
			if methodStr.pos("&lt;^%vars^%&gt;", 1) &gt; 0 or methodStr.pos("&lt;^%code^%&gt;", 1) &gt; 0 or 
					methodStr.pos("&lt;^%epilog^%&gt;", 1) &gt; 0 then
				app.writeLog(methodName &amp; ' not processed, no details found.', LogINFO);
				write methodName &amp; ' not processed, no details found.';
				continue;
			endif;
			
			write methodStr &amp; CrLf &amp; CrLf;
			
			//execute the transient method
			result := dataToLoad.executeMethod(methodStr);
		endif;
		
		if (result = null and not filesToCopyArray.isEmpty) then
			foreach tempFileNode in filesToCopyArray do
				if tempFileNode.fileName.cnContains(DataLoadedCopyFromEDIFiles) then
					tempFileName := DataLoadedCopyToEDIFiles &amp; "\" &amp; tempFileNode.cnGetSimpleFileName();
				elseif tempFileNode.fileName.cnContains(DataLoadedCopyFromVessels) then
					tempFileName := DataLoadedCopyToVessels &amp; "\" &amp; tempFileNode.cnGetSimpleFileName();
				else
					tempFileName := DataLoadedCopyTo &amp; "\" &amp; tempFileNode.cnGetSimpleFileName();
				endif;
				self.copyFileEx(tempFileNode.fileName, true, tempFileName, true);
				if (not tempFileNode.fileName.toUpper().cnContains("_EVERYRUN".toUpper())) then
					tempFileNode.purge();
				endif;
			endforeach;
		endif;
	
	endwhile;
	
epilog

	endTS := app.actualTimeAppServer;
	write startTS.String &amp; Tab &amp; endTS.String &amp; Tab &amp; (endTS - startTS).String;

	delete loadOrderFile;
	delete fileToLoad;
	delete dataToLoad;
	delete fileFolder;
	delete fileFolder2;
	
	delete xmlDoc;
	delete xmlDocParser;

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhTestTransientMethod" id="93e53e57-713e-40f3-9db0-24829c32a8d9">
        <source>mdhTestTransientMethod();

vars
	
	dsl						: UT_DSL;

begin
	
	app.initialize();
	
	create dsl transient;
	dsl.setActiveProfileMDHONLY();
	dsl.transientMethodToRun();
	
epilog

	delete dsl;

end;</source>
    </JadeMethod>
    <JadeMethod name="processQShipsMessage" id="c77b9811-dd0e-4393-b232-4e229c4345ea">
        <source>processQShipsMessage();
/*

Purpose:			

