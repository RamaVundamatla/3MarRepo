    </JadeMethod>
    <JadeMethod name="getDefaultMarks" id="77bc5db4-7288-4fde-a166-7731c1c4916f">
        <source>getDefaultMarks(_loa : Decimal; _sideTo : Integer output; _bowMark, _sternMark : Decimal output);
//------------------------------------------------
// Created: 05 May 2006 By: cnwgd1
//------------------------------------------------
vars
	shipStart,
	shipEnd : Decimal[12,2];
	waterOnLeftOfWharf : Boolean;
	berth : HMS_Berth;
begin
	berth:=self.getMyBerth;
	if berth = null then
		return;
	endif;
	
	_sideTo := self.orientation;
	waterOnLeftOfWharf := berth.myWharf.waterOnLeft;
	
	if self.defaultBowMark &lt; self.defaultSternMark then
		shipStart := self.defaultBowMark;
		shipEnd := self.defaultSternMark;
	else
		shipStart := self.defaultSternMark;
		shipEnd := self.defaultBowMark;
	endif;
	
	if (shipEnd - shipStart) &lt; _loa then
		//Marks incorrect for length of vessel, centre on berth instead
        berth.getMarksForCentringOnBerth(_loa, _sideTo, _bowMark, _sternMark);
	else // Mark ok, 
		// set marks for orientation
	    if waterOnLeftOfWharf and _sideTo = OrientPortSideTo then
	    	// CASE A: Water on left of wharf, ship is PortSideTo, bowMark=min, sternMark=max
	    	_bowMark := shipStart;
	    	_sternMark := shipEnd;
	    elseif waterOnLeftOfWharf and _sideTo = OrientStarboardSideTo then
	    	// CASE B: Water on left of wharf, ship is StarboardSideTo, bowMark=max, sternMark=min
	    	_bowMark := shipEnd;
	    	_sternMark := shipStart;
	    elseif (not waterOnLeftOfWharf) and _sideTo = OrientPortSideTo then
	    	// CASE C: Water on right of wharf, ship is PortSideTo, bowMark=max, sternMark=min
	    	_bowMark := shipEnd;
	    	_sternMark := shipStart;
	    elseif (not waterOnLeftOfWharf) and _sideTo = OrientStarboardSideTo then
	    	 // CASE D: Water on right of wharf, ship is StarboardSideTo, bowMark=min, sternMark=max
	    	_bowMark := shipStart;
	    	_sternMark := shipEnd;
	    endif;
	endif;
end;</source>
        <Parameter name="_loa" type="Decimal"/>
        <Parameter name="_sideTo" type="Integer" usage="output"/>
        <Parameter name="_bowMark" type="Decimal" usage="output"/>
        <Parameter name="_sternMark" type="Decimal" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getDisplayString" id="a26fcdad-77fb-4a87-8f31-526e09b3db5f">
        <source>getDisplayString(): String;
//--------------------------------------------------
// Created:	26 March 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	return self.berthName;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="ef71f0d3-3f2d-4553-9b5d-63cb35ede243">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------
// Created:	15 March 2004 By: cnwgd1
//--------------------------------------------------
vars
	harbour : HMS_Harbour;
begin

	if _attrName = ETRow_MyHarbour then
		harbour := self.getMyHarbour();
		if harbour &lt;&gt; null then
			return harbour.code;
		endif;
		return null;
	elseif _attrName = ETRow_MyBerth then
		if self.getMyBerth &lt;&gt; null then
			return self.getMyBerth.code;
		endif;
		return self.berthName;
	elseif _attrName = ETRow_Orientation then
		if self.orientation = OrientPortSideTo then
			return 'Port';
		elseif self.orientation = OrientStarboardSideTo then
			return 'Starboard';			
		endif;
		return self.berthName;		
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
