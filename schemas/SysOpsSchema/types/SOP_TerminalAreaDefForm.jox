    <JadeMethod name="updateAllCMIFGridLCsAssocIC" id="81273b0b-5cfc-4bd1-b77b-02d6c67efe1e">
        <source>updateAllCMIFGridLCsAssocIC(_taSet : CM_TerminalAreaSet) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 February 2010	cnwer1	Initial creation

*/

vars
	icArea : CM_InterchangeArea;
	cmifGridLCsAssoc : CMIF_GridLCsAssocICArea;
	obj				: Object;
	allCMIFGridLCsToDelete : ObjectSet;
	ta				: CM_TerminalArea;
begin

	create allCMIFGridLCsToDelete transient;
	self.allCMIFGridLCsAssocICArea.copy(allCMIFGridLCsToDelete);
	
	foreach ta in _taSet do
		icArea:=null;
		if not ta.isKindOf(CM_InterchangeArea) then
			continue;
		endif;
		
		foreach obj in self.allCMIFGridLCsAssocICArea do
			if obj.CMIF_GridLCsAssocICArea.myInterchangeArea = ta then
				icArea:=obj.CMIF_GridLCsAssocICArea.myInterchangeArea;
				allCMIFGridLCsToDelete.remove(obj);
				break;
			endif;
		endforeach;
		
		if icArea =  null then
			self.createCMIFGridLCsAssocIC(ta.CM_InterchangeArea);
		endif;
	endforeach;
	
	foreach obj in allCMIFGridLCsToDelete do
		self.allCMIFGridLCsAssocICArea.remove(obj);
	endforeach;
	
	
	
epilog
	allCMIFGridLCsToDelete.purge;
	delete allCMIFGridLCsToDelete;
end;</source>
        <access>protected</access>
        <Parameter name="_taSet" type="CM_TerminalAreaSet"/>
    </JadeMethod>
    <JadeMethod name="updateDirectionCells" id="ec4952b9-e27e-4e65-9d9d-14b792c43651">
        <source>updateDirectionCells() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2009	cnwjk3	Initial creation

*/

vars
	col,
	rows, int	: Integer;
	row			: JadeTableRow;
	leftLabel,
	rightLabel	: String;
	roroLC		: CM_RoRoController;
begin
	// Get the value of the left and right lane labels
	leftLabel := self.tblMain.getValueByName(ETRow_LeftLabel).String;
	rightLabel := self.tblMain.getValueByName(ETRow_RightLabel).String;

	rows := self.tblGateLanes.rows;
	
	foreach int in self.tblGateLanes.fixedRows to rows do
		row := self.tblGateLanes.accessRow(int);
		roroLC := row.itemObject.CM_RoRoController;
		if roroLC &lt;&gt; null then
			 // Numbering direction
			 self.tblGateLanes.getEntRowColumnByRowName(ETRow_NumberingDirection, col);
			 self.tblGateLanes.accessCell(int, col).text := roroLC.numberingDirectionToString();
			 
			 // Park direction
			 self.tblGateLanes.getEntRowColumnByRowName(ETRow_ParkDirection, col);
			 self.tblGateLanes.accessCell(int, col).text := roroLC.parkingDirectionToString();

			 // Access direction
			 self.tblGateLanes.getEntRowColumnByRowName(ETRow_AccessDirection, col);
			 self.tblGateLanes.accessCell(int, col).text := roroLC.accessDirectionToString();
		endif;
	endforeach;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateColumnsAndDividers" id="afe1d21c-7892-4643-85ae-4e15df0cb31d">
        <source>validateColumnsAndDividers(_columns, _dividers : String; _colArray, _divArray : StringArray input; _error : Integer output; _divider : String output) : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
// 14/07/2020	jlgdap1		TFS 49769 ASPA 1090 Bug from Functional Review of 47975
//
vars
	str, col, divd : String;
	columnArray, dividerArray : StringArray;
	numeric, alpha : Boolean;
	idx : Integer;

begin
	// Rules are: 
	// Column labels can only be 2 characters in length. 
	// If column labels are numeric, they are zero-filled to 2 characters
	// Cannot mix alpha and numeric column labels
	// Dividers must be in the column list
	create columnArray transient;
	create dividerArray transient;
	_columns.getTokensForDelimiter(Comma, columnArray);
	_dividers.getTokensForDelimiter(Comma, dividerArray);
	
	// pad/trim the column numbers if necessary
	foreach idx in 1 to columnArray.size do
		str := columnArray[idx];
		str := str.trimBlanks.toUpper;
		if str.length &gt; 2 then
			_error := Column_labels_2_chars;
			return false;
		endif;
		if str.cnIsNumeric then
			if str.length &lt; 2 then
				str := '0' &amp; str;
			endif;
		endif;
		columnArray.atPut(idx, str);
	endforeach;
	
	idx := null;
	// now check for alpha / number mix
	foreach str in columnArray do
		if str = null then
			continue;
		endif;
		if str.isInteger then
			numeric := true;
		elseif str.isAlpha then
			alpha := true;
		else
			_error := Column_labels_alpha_number;
			return false;
		endif;
		
		if numeric and alpha then
			_error := Column_labels_cant_mix;
			return false;
		endif;
		
		_colArray.add(str);
	endforeach;
	
	// now check each divider entry is in the _colArray
	foreach str in dividerArray do
		str := str.trimBlanks.toUpper;
		// is it numeric? - pad it
		if str.cnIsNumeric and str.length &lt; 2 then
			str := '0' &amp; str;
		endif;
		if not _colArray.includes(str) then
			_error := Divider_not_in_column_labels;
			_divider := str;
			return false;
		endif;
		
		_divArray.add(str);
	endforeach;
	
	// TFS 49769 check the first divider isn't the first column - just remove it if it is
	if _divArray.size &gt; 1 and _colArray.size &gt; 1 and _divArray[1] = _colArray[1] then
		_divArray.removeAt(1);
	endif;
	
	return true;
	
epilog
	delete columnArray;
	delete dividerArray;
end;</source>
        <Parameter name="_columns" type="String"/>
        <Parameter name="_dividers" type="String"/>
        <Parameter name="_colArray" type="StringArray" usage="input"/>
        <Parameter name="_divArray" type="StringArray" usage="input"/>
        <Parameter name="_error" type="Integer" usage="output"/>
        <Parameter name="_divider" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateGridInterchangeAreas" id="d7e0c671-a21e-4145-b221-a519b7161141">
        <source>validateGridInterchangeAreas(): Boolean;


/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 February 2010	cnwer1	Initial creation

*/

vars
	obj : Object;
	iter: Iterator;
	allGridControllers : CM_GridControllersByRowColumn;
	cmifGridLCsAssocICArea : CMIF_GridLCsAssocICArea;
	hadDuplicates : Boolean;
begin

	if self.allCMIFGridLCsAssocICArea.size &lt; 2 then
		return true;
	endif;
	
	
	create allGridControllers transient;
	
	on Exception do allGridControllers.noDuplicatesExceptionhandler(exception,hadDuplicates);
	
	foreach obj in self.allCMIFGridLCsAssocICArea do
		cmifGridLCsAssocICArea:=obj.CMIF_GridLCsAssocICArea;
		
		cmifGridLCsAssocICArea.allGridControllers.copy(allGridControllers);
		if hadDuplicates then
			return false;
		endif;
	
	endforeach;
	
	
	return true;
epilog
	delete allGridControllers;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateRTGAreaLaneGrouping" id="02cbc912-fffb-43ec-8e95-01378a8d1b28">
        <source>validateRTGAreaLaneGrouping() : Boolean protected;
// 30458 Oct 2012 check for either previous or next lane area set (where present) if RTG lane grouping is also set.
//  If not, the RTG lane grouping is not saved.  Code done here rather than in the RTG area object validate as the code to set the proxies up doesn't do the lane if neither the prev or next are also set.
vars
	laneIndex	: Integer;
	result		: Boolean;
	rtgLane		: CM_RTGLane;
begin
	result := true;
	rtgLane	:= self.cmbLaneGroup.listObject.CM_RTGLane;
	if rtgLane &lt;&gt; null then
		if self.cmbNextArea.listIndex = -1 then
			laneIndex := self.cmbPrevArea.listIndex + 1;
		else
			laneIndex := self.cmbNextArea.listIndex.Integer;
		endif;
		if laneIndex &lt;= 0 and
		   (self.cmbPrevArea.listCount &gt; 0 or self.cmbNextArea.listCount &gt; 0) then
			app.msgBox(app.getErrorString(Must_select_prev_or_next_lane), self.caption, 0); 
			result := false;
		endif;
	endif;

	return result;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateRoRoLaneIds" id="746cdb48-6414-452a-90ab-43b83ff4df78">
        <source>validateRoRoLaneIds() : Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 November 2009	cnwjk3	ccms 1018

*/

vars
	col,
	int 	: Integer;
	id 		: String;
	array	: StringArray;
begin
	create array transient;
	
	self.tblGateLanes.getEntRowColumnByRowName(ETRow_Id, col);
	foreach int in self.tblGateLanes.fixedRows + 1 to self.tblGateLanes.rows do
		id := self.tblGateLanes.accessCell(int, col).text.trimBlanks();
		if array.includes(id) then
			app.msgBox(app.getErrorString(RoRo_LaneIdsMustBeUnique), self.caption, MsgBox_OK_Only);
			return false;
		elseif id.length = 0 then  //cnwjo3 par 23873
			app.msgBox(app.getErrorString(RoRo_LaneIdsMustNotBeEmpty), self.caption, MsgBox_OK_Only);
			return false;
		endif;
		array.add(id);
	endforeach;	
	return true;
epilog
	delete array;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateState" id="c714054c-9271-4732-8acd-24f5d03afbde">
        <source>validateState() : Integer protected;

vars

//	gridPoint	: CMUI_GridPoint;

begin

	if self.mode = Mode_Update then
		if self.myCurrentObject.CM_TerminalArea.isInUse() then
			return Return_Tracked_Items;
		else
			return Return_Continue;
		endif;
	elseif self.mode = Mode_Add then 
		return Return_Continue;	
	endif;
	return Return_Wrong_Mode;
end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateStateOfController" id="ce929ed4-91e7-47e9-96c8-2677330a3f35">
        <source>validateStateOfController(_gridPoint : SOP_GridPoint) : Integer protected;
// -------------------------------------------
// Created 03 October 2003 by cnwdvb1
// -------------------------------------------
vars

begin

	// Not implemented yet.
	return Return_Continue;	
	if self.mode = Mode_Update then
		if _gridPoint.myLocationsController.hasTIs or
			_gridPoint.myLocationsController.hasRestrictions(NULL_RESTRICTION) then
			return Return_Tracked_Items;
		endif;
	endif;
	return Return_Continue;	

end;</source>
