    <JadeMethod name="setFromTransaction" id="8e8fae12-a2f4-4940-9c9c-c2221bc46ba2">
        <updating/>
        <source>setFromTransaction(_shipTran: CM_TITransaction) updating;
/*
Date		Who		Reason
10 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars

begin
	if _shipTran &lt;&gt; null and (not _shipTran.isChild) then 	
		inheritMethod (_shipTran);
		
		self.setTotalTimeAndRate(); 							
	endif;
epilog

end;</source>
        <Parameter name="_shipTran" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="setKPI" id="a98d2077-3ef8-464d-9ac9-ca0c8f7647ac">
        <updating/>
        <source>setKPI(_workPoint : CM_WorkPoint; _js : CM_VoyageJobSheet; _deckVoyage : CM_DeckVoyage) updating;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
10 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	voyage			: CM_Voyage;
	strWorkPoint	:String;
	ts				:TimeStamp;
begin
	voyage	:= _js.myVoyage;
	
	if _workPoint &lt;&gt; null then
		strWorkPoint := _workPoint.code;
		
	elseif _js.myWorkPoint &lt;&gt; null then
		strWorkPoint := _js.myWorkPoint.code;
	endif;
	
	self.code 	:= voyage.code &amp; "/" &amp; strWorkPoint &amp; "/" &amp; _deckVoyage.code;
	
	ts			:= voyage.shipExchangeDate;
	
	if not ts.isValid() then
		ts := voyage.arrivedDT;
	endif;
	
	if not ts.isValid() then
		ts := app.actualTimeServer;
	endif;
	
	self.dateTime		:= ts;
	self.userCode 		:= app.myPassport.userCode;
	self.myWorkPoint	:= _workPoint;
	self.myVoyage 		:= voyage;
	self.myTerminal 	:= voyage.myTerminal;
	self.myVessel 		:= voyage.getMyVessel();
	self.myDeckVoyage 	:= _deckVoyage;
	self.myDeckVessel 	:= _deckVoyage.getDeckVessel;
end;</source>
        <Parameter name="_workPoint" type="CM_WorkPoint"/>
        <Parameter name="_js" type="CM_VoyageJobSheet"/>
        <Parameter name="_deckVoyage" type="CM_DeckVoyage"/>
    </JadeMethod>
    <JadeMethod name="setTotalTimeAndRate" id="96ef7383-7f3b-4d8b-b09e-9782dc945f05">
        <updating/>
        <source>setTotalTimeAndRate()updating;
/*
Date		Who		Reason
23 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	length 		: Real;
begin
	length := self.calculateTotalTime( self.myWorkPoint.getID );
	
	self.totalTime := length;
	
	if length &lt;&gt; 0 then
		self.totalRate := self.movesTI / length;
	else
		self.totalRate := 0;
	endif;
epilog

end;</source>
    </JadeMethod>
</Class>
