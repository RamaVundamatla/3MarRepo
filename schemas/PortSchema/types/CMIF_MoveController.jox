// ---------------------------------------------------------------------------
// Created:     16 January 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	return (self.isShiftMove and self.shiftDirection = self.ShiftLeft);
epilog

end;</source>
