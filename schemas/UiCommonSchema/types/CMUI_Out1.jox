    <JadeMethod name="allFinished" id="f5e35e55-ea52-41df-9395-c69ce29f2f3d">
        <source>allFinished() : Boolean;
// ---------------------------------------------------------------------------
// Created:		09 February 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	idx, ennd : Integer;
begin
	ennd := 13; //self.allItemsLocked.size;

	foreach idx in 1 to ennd do
		if not self.allItemsLocked[idx] then
			return false;
		endif;
	endforeach;
	self.chkReset.value := false;
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
