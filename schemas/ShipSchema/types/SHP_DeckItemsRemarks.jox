    <JadeMethod name="addTableItem" id="05c4278d-a0bb-4fcf-b01d-09b5b2cea7e4">
        <source>addTableItem(_item : CM_Object) protected;
/*
Date		    Who			Reason
25 April 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars	
	str : String;
begin	
	str := _item.getAttributeStringForDefArray(self.tblRemarks.allTblDataEntRows);	
	self.tblRemarks.addItemObject(_item, str);	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_item" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="addTableItemsForDeck" id="0302fb78-ed7d-48da-a52d-b71fab98eed4">
        <source>addTableItemsForDeck(_deck : CM_Deck);
/*
Date		    Who			Reason
29 April 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars
	deckItem : CM_DeckItem;
	subDeck : CM_Deck;
	deckLayerLayout : CM_DeckLayerLayout;
	deckItemLayout	: CM_DeckItemLayout;
	subDeckIter : Iterator;
begin
	if _deck.remarks &lt;&gt; null then
		self.addTableItem(_deck);
	endif;
	if _deck.myDeckLayout &lt;&gt; null then
		if _deck.myDeckLayout.remarks &lt;&gt; null then
			self.addTableItem(_deck.myDeckLayout);
		endif;
		foreach deckLayerLayout in _deck.myDeckLayout.allDeckLayerLayouts discreteLock do			//cnwas3 par 27498
			if deckLayerLayout.remarks &lt;&gt; null then
				self.addTableItem(deckLayerLayout);
			endif;
			foreach deckItemLayout in deckLayerLayout.allDeckItemLayouts where deckItemLayout.remarks &lt;&gt; null do
				self.addTableItem(deckItemLayout);
			endforeach;
		endforeach;
	endif;
	
	foreach deckItem in _deck.allDeckItems discreteLock do
		if deckItem.remarks &lt;&gt; null then
			self.addTableItem(deckItem);
		endif;
		if deckItem.myLayout &lt;&gt; null and deckItem.myLayout.remarks &lt;&gt; null then
			self.addTableItem(deckItem.myLayout);
		endif;
	endforeach;		
	
	subDeckIter:=_deck.getSubDeckCollection.createIterator;
	while subDeckIter.next(subDeck) do
			self.addTableItemsForDeck(subDeck);
	endwhile;
	
epilog
	delete subDeckIter;
end;</source>
        <Parameter name="_deck" type="CM_Deck"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="aa22e390-1785-49fa-83cb-ffb0bfae27c7">
