    <JadeMethod name="getOIDAndDescForAttribute" id="a0b39f4e-4e6b-4d6a-b184-b0603ad3ddbf">
        <source>getOIDAndDescForAttribute(_attrName: String; _getCalculatedDate: Boolean; _oid : String output): String;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		22 April 2010
//
// Implemented version: JMT 7.8.2
// Date  		User  		Change
// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface
//----------------------------------------------------------------------

// ---------------------------------------------------------------------------
// Created:     19/07/2010 cnwdz2	
//
// Purpose:     PAR24513 extend the current existing getDisplayStringForAttribute method to return an object's oid.	
//
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 13/02/2018	jlgdap1		TFS 37030 SSL Demurrage Report
// 21/02/2018	jlgmd1		TFS 37093 SNO - No report output
// 13/10/2020	jlgdap1		TFS 50043 ADP Unable to select the status as Pending
vars
	str : String;
	company : CM_Bank;
	proc, invoiceProc : CM_InvoiceProcess;			// TFS 50043
	shipLine : CM_ShippingLine;
begin
	if _attrName = ETRow_InvoiceType then
		if self.getMyInvoiceType &lt;&gt; null then
			_oid := self.getMyInvoiceType.getOidAsString(); //20/07/2010 cnwdz2 24513
			return self.getMyInvoiceType.description &amp; " (" &amp; self.getMyInvoiceType.company.terminal.code &amp; ")";
		endif;
		
	elseif _attrName = ETRow_Company then
		if self.allCompaniesByCode.isNotEmpty then //At this point we only report on one company/bus unit 22/04/2010 cnwsh3
			company := self.allCompaniesByCode.first; //20/07/2010 cnwdz2 24513
			_oid := company.getOidAsString();
			return company.getNameWithTerminalString();
		endif;
		
	elseif _attrName = ETRow_Debtor then
		if self.getMyDebtor &lt;&gt; null then
			_oid := self.getMyDebtor.getOidAsString(); //20/07/2010 cnwdz2 24513
			return self.getMyDebtor.name;
		endif;
		
	elseif _attrName = ETRow_InvoiceStatus then	
		if self.invoiceStatus = -1 then
			return Any_String;
		else
			// TFS 50043 Assume that all companies are using teh same Invoice Process
			foreach proc in app.myRoot.allInvoiceProcesses discreteLock do
				if not proc.allBusinessUnits.isEmpty then
					invoiceProc := proc;
					break;
				endif;
			endforeach;
			//return app.getInvoiceStatusString(null, self.invoiceStatus); // TFS 39618
			return app.getInvoiceStatusString(invoiceProc, self.invoiceStatus); // TFS 39618
			// TFS 50043 end
		endif;
		
	elseif _attrName = ETRow_InvoiceNumber then
		if self.invoiceNumber = null then
			return null;
		else
			return self.invoiceNumber.String;
		endif;
		
	elseif _attrName = ETRow_BillOfLading then
		return self.billOfLading;
	elseif _attrName = ETRow_CargoId then
		return self.cargoId;
	elseif _attrName = ETRow_SiteState then
		//_oid := siteState.String;						//-TFS 37093
		//return app.siteEnumToString(siteState);		//-TFS 37093
		return self.getSiteOIDAndString(_oid);			//+TFS 37093
	elseif _attrName = ETRow_Voyage then
		if self.getMyVoyage &lt;&gt; null then
			_oid := self.getMyVoyage.getOidAsString(); 
			return self.getMyVoyage.code;
		endif;
		
	elseif _attrName = ETRow_Agent then								// TFS 37030
		if self.getMyCustomsAgent &lt;&gt; null then						// TFS 37030
			_oid := self.getMyCustomsAgent.getOidAsString();		// TFS 37030
			return self.getMyCustomsAgent.name;						// TFS 37030
		endif;														// TFS 37030
		
	 // ### TFS BUG 56660 23FEB2023 NAVAB1
	elseif _attrName = ETRow_ShippingLine then
		shipLine := self.getMyShippingLine();
		if shipLine &lt;&gt; null then
			_oid:=shipLine.getOidAsString;
			return shipLine.code;
		endif;
		return Any_String;
	endif;
	
	return inheritMethod(_attrName, _getCalculatedDate, _oid);

epilog
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSiteOIDAndString" id="1d945dcc-c4e0-4ece-b9ea-7822438be61d">
        <source>getSiteOIDAndString(_oid : String output) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
21 February 2018	jlgmd1	Initial creation - TFS #37093 SNO - No report output

*/

vars
	siteString			: String;
	site				: Integer;
begin
	foreach site in self.allQrySites do
		_oid := _oid &amp; site.String &amp; ', ';
		siteString := siteString &amp; app.siteEnumToString(site) &amp; ', ';
	endforeach;
	
	if siteString &lt;&gt; null then
		_oid := _oid[1:_oid.length-2];
		siteString := siteString[1:siteString.length-2];
	endif;
	
	return siteString[1:50];
epilog

end;</source>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="5e37006f-bc16-48c6-92d1-25933fd7f0e5">
        <updating/>
        <source>includesObject(_invoice : CM_Invoice; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		13 April 2010
// Implemented version: JMT 7.8.2
// Date  		User  		Change
// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface
// 23 Jan    2020	jlgma1	Bug 48352: ADP - FW: Get_invoice_date
//----------------------------------------------------------------------
vars
	invTypeDesc : CM_InvoiceDesc;
	debtor      : CM_Debtor;
	qryShipLine, invShipLine : CM_ShippingLine;
begin
	self.numSearched := self.numSearched + 1;
	invTypeDesc      := self.getMyInvoiceType;
	debtor           := self.getMyDebtor;
	qryShipLine := self.getMyShippingLine();
	invShipLine := _invoice.getMyShippingLine();
	
	
	if (self.invoiceStatus = CM_Invoice.INVOICE_ALL_STATUS or _invoice.status = self.invoiceStatus)
	and (invTypeDesc = null    or _invoice.invoiceType = invTypeDesc)
	and (debtor = null         or _invoice.debtor = debtor)
	and (qryShipLine = null or invShipLine = qryShipLine) // ### TFS BUG 56660 23FEB2023 NAVAB1
	and (self.startDate = null or _invoice.createdTime.date &gt;= self.startDate)		     // 37009 missing criteria
	and (self.endDate = null   or _invoice.createdTime.date &lt;= self.endDate) then		 // 37009 
		
		self.numFound := self.numFound + 1;
		return true;
	endif;
	
	return false;

epilog
end;</source>
        <access>protected</access>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initialize" id="45175338-459b-428b-a71a-a1cc253510c6">
        <updating/>
        <source>initialize() updating;

vars

begin
	inheritMethod();
	self.invoiceStatus := CM_Invoice.INVOICE_ALL_STATUS;	// from 28128 testing Oct 2011
end;
</source>
    </JadeMethod>
    <JadeMethod name="populateSummaries" id="f5b0c8f8-5e44-4843-9499-a91b4974902d">
        <source>populateSummaries(_invoice : CM_Invoice; _jrwTrans : CM_JRWTransient) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Nov 2016	cnwrh7	TFS	2893
20 Feb 2018	jlgmd1	TFS 36954 SNO - Error in SCT2 Rate Table  (Swap $CM_RateEntry.decimalPlaces for terminal config)
09 Mar 2020 cnwma1 ChangeRequest 48524: CPL - Credit Invoice Details for Print
*/

vars
	count1,
	count2,
	dpl				: Integer;
	totalQuantity   : Real;
	multiTax,
	isZeroRatedTax,
	isStorage		: Boolean;
	equipType,
	itemId			: String;
	totalAmount		: Decimal[10,2];
	invTotalNoTax,
	taxAmt 			:   Decimal[12,2];
	detailTaxTotal,
	detailTotal		: Decimal[12, 2];
	taxTotal		: Real;
	codes 			: StringArray; 
	rates  			: RealArray; 
	amounts 		: RealArray;
	summDict		: CM_GLSummaryByGLCodeRateDict;
	glSumm			: CM_GLSummary;
	invLine			: CM_InvoiceLine;
	dilt			: CM_DebtorInvLineType;
	ti				: CM_TrackedItem;
	repSumm			: CM_ReportInvoiceSummary;
	repTotal		: CM_ReportInvoiceTotal;
	repItem			: CM_ReportInvoiceItem;
begin
	dpl := _invoice.myTerminal.getConfig(FinancialRateDPlaces).Integer; // TFS 36954 MPD 20 Feb 2018

	create summDict transient;
	_invoice.getGLSummary(summDict);
	
	count1 := 1;
	
	foreach glSumm in summDict do
		
		create repSumm;
		repSumm.myInvoice 		:= _invoice;
		repSumm.myJRWInvoice 	:= _jrwTrans.CM_JRWInvoice;
		
		dilt := glSumm.myInvoiceLine.invoiceLineDesc.getDebtorInvLineType(_invoice.debtor);
		if dilt &lt;&gt; null then
			repSumm.itemIdentifier := dilt.otherCode;
		endif;
		repSumm.itemId 			   := count1;
		repSumm.itemDescription    := glSumm.glCode;
		repSumm.groupById 	       := glSumm.glCode &amp; glSumm.rate.String;
		repSumm.rate 			   := glSumm.rate;
		repSumm.netAmount 	 	   := glSumm.amount;                                     //09/03/2020 cnwma1 TFS #48524
		repSumm.quantity 		   := glSumm.quantity;									//09/03/2020 cnwma1 TFS #48524
		repSumm.cargoIds           := glSumm.getCargoIds();                             //09/03/2020 cnwma1 TFS #45899
		repSumm.printOrder         := glSumm.printOrder;                                //09/03/2020 cnwma1 TFS #45899
		repSumm.printTrackedItems  := glSumm.printTrackedItems;                         //09/03/2020 cnwma1 TFS #45899
		repSumm.taxAmount 		   := glSumm.taxAmount;							        //09/03/2020 cnwma1 TFS #48524
		detailTaxTotal 			   := detailTaxTotal + repSumm.taxAmount;				 //the total gst charged amout
		detailTotal 			   := detailTotal    + repSumm.netAmount;
		totalQuantity 			   := totalQuantity  + repSumm.quantity;
		repSumm.totalAmount 	   := glSumm.amount  + glSumm.taxAmount;
		repSumm.unitPrice 		   := glSumm.rate.asStringJMTWithPrecision(dpl, false); // TFS 36954 MPD 20 Feb 2018
		count1 					   := count1 + 1;
		
		count2 := 1;
		foreach invLine in glSumm.allInvoiceLines do
			if invLine.myTransactionTI &lt;&gt; null and invLine.myTransactionTI.isKindOf(CM_Storage) then
				isStorage := true;
			else
				isStorage := false;
			endif;
			equipType := "UN";
			ti := invLine.getTrackedItem();
			if ti &lt;&gt; null and
			   ti.isContainer() then
				equipType := "CH";
			endif;
			
			itemId := invLine.getTIID();
			create repItem;
			repItem.myInvoiceLine 		    := invLine;
			repItem.myReportInvoiceSummary  := repSumm;
			repItem.itemId 					:= count2;
			count2 							:= count2 + 1;
			repItem.quantity				:= invLine.quantity;    			//09/03/2020 cnwma1 TFS #48524
			repItem.equipmentIdentifier 	:= itemId;
			repItem.equipmentType 			:= equipType;
			repItem.endIdentifier 			:= '140';
			repItem.endDate 				:= invLine.chargeTime.date.userFormat($ODBC_Date);
			
		endforeach;
		
	endforeach;
	
	create repTotal;
	repTotal.myInvoice		 := _invoice;
	repTotal.myJRWInvoice 	 := _jrwTrans.CM_JRWInvoice;
	create codes transient;
	create rates transient;
	create amounts transient;
	multiTax 	   := _invoice.myTerminal.getConfig(InvoiceMultiTaxRates).Boolean;
	invTotalNoTax  := _invoice.getTotalAmount();
	isZeroRatedTax := _invoice.isZeroRatedTax;
	if isZeroRatedTax then
		taxAmt := 0;
	else
		taxTotal := detailTaxTotal;																									//+TFS2893	we have total gst charged amout by above and it is precisely added up from each gst amount
	endif;
	taxAmt 				 := taxTotal;                //09/03/2020 cnwma1 TFS #48524
	totalAmount 		 := invTotalNoTax + taxAmt;
	repTotal.quantity    := totalQuantity;
	repTotal.netAmount   := invTotalNoTax;
	repTotal.taxAmount   := taxAmt;
	repTotal.totalAmount := totalAmount;

epilog
	if summDict &lt;&gt; null then
		summDict.purge();
		delete summDict;
	endif;
	delete codes;
	delete rates;
	delete amounts;
end;</source>
        <access>protected</access>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_jrwTrans" type="CM_JRWTransient"/>
    </JadeMethod>
    <JadeMethod name="setFromTemplate" id="351fe3e6-cf47-49ef-8141-8018458f7179">
        <updating/>
        <source>setFromTemplate(_obj: CMQF_FilterReports; _runDate: Date; _allEventData: CM_EventDataByTypeDict) updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		22 April 2010
//
// Implemented version: JMT 7.8.2
// Date  		User  		Change
//----------------------------------------------------------------------
vars
	eventData	: CM_EventDataInvoice;
	eventVoyageData : CM_EventDataVoyage;
begin
	inheritMethod(_obj, _runDate, _allEventData);
	// CPL CCMS 2120 MSC invoicing xml extract via report writer report Nov 2011
	eventData := _allEventData[EventDataInvoicing].CM_EventDataInvoice;
	if eventData &lt;&gt; null and eventData.myInvoice &lt;&gt; null then
		self.invoiceNumber := eventData.myInvoice.sequenceNum;
		// the report template should be set up with invoice only - the test one also had company with default of T01 default company - 
		//  clear this and use the invoice company instead
		self.allCompaniesByCode.clear();
		self.allCompaniesByCode.add(eventData.myCompany);
	endif;

	// This code sets the voyage for event driven schedules.
	// Have to do this for each appropriate class because they have different myVoyage references.
	//epr par 34813 11/9/14
	eventVoyageData := _allEventData[EventDataVoyage].CM_EventDataVoyage;
	if eventVoyageData &lt;&gt; null and eventVoyageData.myVoyage &lt;&gt; null then
		self.setMyVoyage( eventVoyageData.myVoyage );
	endif;	
epilog
end;

</source>
        <Parameter name="_obj" type="CMQF_FilterReports"/>
        <Parameter name="_runDate" type="Date"/>
        <Parameter name="_allEventData" type="CM_EventDataByTypeDict"/>
    </JadeMethod>
