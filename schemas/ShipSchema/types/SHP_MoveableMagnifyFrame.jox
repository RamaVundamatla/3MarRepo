    <JadeMethod name="adjustFrameXYs" id="3770f099-6a00-4e08-90bf-02912449b967">
        <source>adjustFrameXYs(realX1, realY1: Integer io; tmpFrame : SHP_BayDrawingFrame);
// ---------------------------------------------------------------------------
// Created:		08 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	frmX1, frmX2, frmY1, frmY2 : Integer;
	objX1, objX2, objY1, objY2 : Integer;
begin

		if tmpFrame = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'the bay drawing frame is null');
			return;
		endif;

		frmX1 := tmpFrame.left.Integer;
		frmX2 := tmpFrame.clientWidth + tmpFrame.left.Integer;
		frmY1 := tmpFrame.top.Integer;
		frmY2 := tmpFrame.clientHeight + tmpFrame.top.Integer;
		
		objX1 := realX1 - frmX1 + 5;
		objY1 := realY1 - frmY1 + 5;

		realX1 := objX1;
		realY1 := objY1;
end;</source>
        <Parameter name="realX1" type="Integer" usage="io"/>
        <Parameter name="realY1" type="Integer" usage="io"/>
        <Parameter name="tmpFrame" type="SHP_BayDrawingFrame"/>
    </JadeMethod>
    <JadeMethod name="create" id="e9ca2e21-6725-495c-b7e1-cdc48b8021b0">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>create() updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:     06 January 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.bevelInnerWidth := 0;
	self.bevelOuterWidth := 0;
	self.borderStyle := Frame.BorderStyle_None;
	self.boundaryBrush := 0;
	self.boundaryWidth := 0;
	self.caption := null;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="drawSlot" id="331451e8-fab1-43b8-876d-d4cef43be8fc">
        <updating/>
        <source>drawSlot() updating;
// ---------------------------------------------------------------------------
// Created:     10 December 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theTI : CM_TrackedItem;
	tmpZoom : Real;
begin
	if self.mySlotController = null then

		return;
	endif;
	
	theTI := self.mySlotController.allTrackedItems.first;
	if theTI = null then
		return;
	endif;
	
	tmpZoom := self.myDrawingController.scaleFactor;
	
	self.myDrawingController.setFromSlotDefn(self.mySlotController.mySlotDefnVoyage, 25,25,200,200);
	self.myDrawingController.setScale(20, true, true);
	self.myDrawingController.setFontSizeForAttributeMag();
	/*
	self.myDrawingController.setPropertyValue("myTrackedItem", theTI);
	self.myDrawDrawingFrame.setPropertyValue("myBay",self.mySlotController.myBayVoyage);
	self.myDrawingController.setPropertyValue("myLocationsController", self.mySlotController);
	*/
	self.myDrawingController.drawCurrentObject(self.myDrawDrawingFrame);
	
epilog
	self.myDrawingController.setScale(tmpZoom, true, true);
	self.myDrawingController.setFontSizeForAttributeMag();
end;</source>
    </JadeMethod>
    <JadeMethod name="mouseMove" id="8d597bef-b432-44d2-af8a-ccccff8a3222">
        <controlMethod name="CMUI_MoveableFrame::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>mouseMove(frame: CMUI_MoveableFrame input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:     08 December 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	shipFrame : SHP_BayDrawingFrame;
	realX, realY, shipFrameX, shipFrameY, offsetX, offsetY: Integer ;
	theObj : Object;
begin

	inheritMethod(frame, button, shift, x, y);
	
	self.myDrawDrawingFrame.visible := true;
	self.myDrawDrawingFrame.transparent := true;
	self.transparent := true;
	

	
	
	
	
	
	self.myDrawDrawingFrame.clearGraphics();
	self.myDrawingController.setScale(3, true, true);
	self.myDrawingController.setFontSizeForAttributeMag();
	
	realX := (self.left.Integer); // + (self.width / 2)).Integer;
	realY := (self.top.Integer); // + (self.clientHeight() / 2)).Integer;
	
	shipFrame := self.myDrawingController.getBayFrameFromXY(realX, realY);
	if shipFrame = null then
		self.mySlotController := null;
		return;
	endif;
	
	offsetX := 20;
	offsetY := 20;
	
	
	shipFrameX := realX + offsetX;
	shipFrameY := realY + offsetY;
//	self.myDrawDrawingFrame.drawFillColor := Red;
//	self.myDrawDrawingFrame.drawFilledRectangle(offsetX,offsetY,offsetX + 6, offsetY + 6,Red);
	
	self.adjustFrameXYs(shipFrameX, shipFrameY,shipFrame);
	theObj		:=	shipFrame.getObjectForPosition(shipFrameX, shipFrameY- 60);
	
	if not theObj.isKindOf(CM_SlotController) then
//	self.drawTextAt("realX: " &amp; realX.String &amp; " realY: " &amp; realY.String, 10,10,Black);
//	self.drawTextAt("shipFrameX: " &amp; shipFrameX.String &amp; " shipFrameY: " &amp; shipFrameY.String, 10,25,Black);
//	self.drawTextAt("parent: " &amp; self.parent.String, 10,75,Black);

//		self.myDrawDrawingFrame.drawFillColor := Black;
//		self.myDrawDrawingFrame.drawFilledRectangle(25,83,200,258,Black);
		return;
	endif;
	
	self.mySlotController := theObj.CM_SlotController;
	
	self.drawSlot();
	/*
	self.drawTextAt("realX: " &amp; realX.String &amp; " realY: " &amp; realY.String, 10,10,Black);
	self.drawTextAt("shipFrameX: " &amp; shipFrameX.String &amp; " shipFrameY: " &amp; shipFrameY.String, 10,25,Black);
	self.drawTextAt("SC: " &amp; self.mySlotController.getFullId(), 10,50,Black);
	self.drawTextAt("parent: " &amp; self.parent.String, 10,75,Black);
	*/

epilog

end;</source>
        <Parameter name="frame" type="CMUI_MoveableFrame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setFrame" id="03e85cda-5559-40de-bace-a9a743cb3fc3">
        <updating/>
        <source>setFrame(_frame : SHP_BayDrawingFrame) updating;
// ---------------------------------------------------------------------------
// Created:     10 December 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.myDrawDrawingFrame := _frame;

	
	
	self.myDrawDrawingFrame.clearGraphics();	
	self.myDrawDrawingFrame.top := 0;
	self.myDrawDrawingFrame.left := 0;
	self.myDrawDrawingFrame.width := self.width;
	self.myDrawDrawingFrame.height := self.height;
	self.myDrawDrawingFrame.zOrder(0);
	self.myDrawDrawingFrame.backColor := White;
	self.myDrawDrawingFrame.autoRedraw := true;
	self.myDrawDrawingFrame.visible := true;
epilog

end;</source>
        <Parameter name="_frame" type="SHP_BayDrawingFrame"/>
    </JadeMethod>
    <JadeMethod name="setFrameOverlay" id="69b2653c-a15b-4245-901f-ad83d47a495c">
        <updating/>
        <source>setFrameOverlay(_frame : CMUI_MoveableOverlayFrame input) updating;
// ---------------------------------------------------------------------------
// Created:     10 December 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
//	self.myOverlayFrame := _frame;

	
	_frame.myMoveableFrame := self;
	_frame.clearGraphics();	
	_frame.top := 0;
	_frame.left := 0;
	_frame.width := self.width;
	_frame.height := self.height;
	_frame.zOrder(1);
	_frame.transparent := true;
	_frame.autoRedraw := true;
	_frame.visible := true;
epilog

end;</source>
        <Parameter name="_frame" type="CMUI_MoveableOverlayFrame" usage="input"/>
    </JadeMethod>
