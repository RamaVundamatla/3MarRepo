    <JadeMethod name="getAllChildrenTotWeight" id="b5fb7847-c780-4a55-88ca-28308ca00810">
        <source>getAllChildrenTotWeight(): Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//15/10/2025	navkc1 JIRA 36057 CUX | Total Weight Specification for Trailers - DB Changes / Form /Jade

*/

vars
	gteEntity	: CMGTE_Entity;
	totWeight 	: Decimal[14,4];
begin
	
	foreach gteEntity in self.allChildren do
		totWeight += gteEntity.getWeightTotal();
	endforeach;
	
	return totWeight;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
