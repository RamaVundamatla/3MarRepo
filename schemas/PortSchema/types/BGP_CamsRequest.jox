    <JadeMethod name="action" id="c9985566-d353-44af-8ef9-1440f420bc0d">
        <updating/>
        <source>action(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		16 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
vars

	errCode	: Integer;
	errTxt	: String;
begin

	on Exception do app.alertExceptionHandler(exception, null, self.getErrorDesc(), errCode, errTxt, true, true);

	self.setUser();
	self.runCams();

epilog
	if errCode &lt;&gt; null then
		app.myTrxUA.trxUpdateBGPRequest(self, true, errCode, errTxt, app.myPassport);
	endif;
	inheritMethod();
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="17f633d4-2958-401a-94c1-0c29ac65006a">
        <source>getDisplay(): String;

// cnwdvb1 16 May 2003 
// 28 Sep 2016	cnwrs1	TFS 2756 PAR38267 allow Cams to run per terminal
vars
	dt : TimeStamp;
	str : String;
begin
	if global.isValidObject(self.myProcessingController) then
		str := '   -- Processing --';
		dt := self.processingStartTime;
	else
		dt := self.createdDateTime;
	endif;
	str := self.class.text.cnEcGetTagValueOfName('display') &amp; Tab &amp; dt.bgpDisplay() &amp; str &amp;
	Tab &amp; self.getDisplayErrors();
	str := str &amp; Tab &amp; 'Cams Request';
	if self.myTerminal &lt;&gt; null then
		str := str &amp; ' ('&amp;self.myTerminal.code&amp;')';
	endif;
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getErrorDesc" id="b2fec12e-3e8f-4e2d-8370-f5ed5a06820c">
        <source>getErrorDesc(): String;

/*

Purpose:		Return the error string for the cam Protocol

Date			Who		Reason
27 March 2013	cnwmh5	par 31047 Initial creation
*/
//25 June 2013	cnwrs1	Par31047 - Cams Exception Handler
vars
	msg : String;
begin
	msg := app.myPassport.getMyBGPAgent.getErrorDesc();
	return msg;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInstances" id="d2677b68-afae-437f-b067-b27fd00173c9">
        <source>getInstances(_task: CM_AutoTask): Integer;
//
// 03 Oct 2016	cnwrs1	TFS 2756 PAR38267 allow Cams to run per terminal
//
vars
	count : Integer;
	request : BGP_CamsRequest;
	obj : Object;
	invalid : Boolean;	//02 Jul 2020 NDL	TFS 49711
begin

	on Exception do app.handleDeletedObject( exception, request, invalid );	//02 Jul NDL	TFS 49711 
	
	foreach obj in self.class.instances do
		invalid:= false;		//02 Jul 2020 NDL	TFS 49711
		request := obj.BGP_CamsRequest;
		if request.isProcessed and
		   self.myProcessingController = null then
			continue;
		endif;
		if invalid then	//02 Jul 2020 NDL	TFS 49711 	
			continue;
		endif;
		if request.myTerminal = _task.myTerminal then
			count := count + 1;
		endif;
	endforeach;
	return count;
end;

</source>
        <Parameter name="_task" type="CM_AutoTask"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
