    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <ImplicitInverseRef name="myHarbour" id="20bcf8ca-4507-4b09-9f39-03701e85afc7">
        <embedded/>
        <type name="HMS_Harbour"/>
    </ImplicitInverseRef>
    <JadeMethod name="displayEntry" id="aa03f807-37fc-4dbe-9bd9-47d469b2c659">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>displayEntry(combobox: ComboBox input; _resource : HMS_Resource; lstIndex: Integer): String updating, clientExecution;
//--------------------------------------------------
// Created:	26 November 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	
	if _resource = null then
		return null;
	endif;

	if _resource.isNotAvailableForEntry then // CCMS 1350
		if self.myObject &lt;&gt; _resource then
			return null;
		else
			self.hasDirtyObject := true;
		endif;
	endif;

	return _resource.description &amp; ' ('&amp; _resource.code &amp; ')';	
	
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="_resource" type="HMS_Resource"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCollectionJMT" id="c13004be-4f9c-45c8-9100-571a944d5d6c">
        <source>getCollectionJMT(): Collection protected;
//--------------------------------------------------
// Created:	26 November 2004 By: cnwgd1
//--------------------------------------------------
vars

begin

	
	if self.myHarbour &lt;&gt; null then 
		return self.myHarbour.allResources;
	endif;
	
	return null;

end;</source>
        <access>protected</access>
        <ReturnType type="Collection"/>
    </JadeMethod>
    <JadeMethod name="resetCollectionForHarbour" id="ce0f1863-870c-4e4a-8bba-5e411bd2f4e3">
        <updating/>
        <source>resetCollectionForHarbour(_harbour : HMS_Harbour)updating;
// ---------------------------------------------------------------------------
// Created:     27 May 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	coll		: Collection;
	idx			: Integer;
	saveText	: String;
begin

	if _harbour = null then	
		coll := null;
	elseif _harbour = self.myHarbour then 
		return; // collection should be correct so return/
	else
		coll := _harbour.allResources;
	endif;

// rest of code same as in init method. 

	if coll = null then
		return;
	endif;

	// save the current text and as calling listCollection, clears the current text
	saveText := self.text;

	self.listCollection(coll, true, 0);

	self.selLength := 1000;			
	idx := self.findString(1, saveText);

	if idx &gt; 0 then
		self.listIndex := idx;
		self.text := saveText;
	endif;

	self.amInitialised := true;
end;</source>
        <Parameter name="_harbour" type="HMS_Harbour"/>
    </JadeMethod>
    <JadeMethod name="setObject" id="969c42d9-18c8-4218-8c60-e26965111cff">
        <updating/>
        <source>setObject(_value: HMS_Resource) updating;
// ---------------------------------------------------------------------------
// Created:     28 September 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin

	if _value &lt;&gt; null then 
		if _value.HMS_Resource.myHarbour &lt;&gt; self.myHarbour then 
			// reset collection 
			self.myHarbour := _value.HMS_Resource.myHarbour;
			self.amInitialised := false; //cause reset
		endif;
	endif;

	inheritMethod(_value);

end;</source>
        <Parameter name="_value" type="HMS_Resource"/>
    </JadeMethod>
    <JadeMethod name="setObjectAndResourceType" id="19cc7704-b2de-488f-a7aa-3e2528e945b3">
        <updating/>
        <source>setObjectAndResourceType(_resource : HMS_Resource; _harbour : HMS_Harbour)updating;
// ---------------------------------------------------------------------------
// Created:     27 May 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	coll		: Collection;
	idx			: Integer;
	saveText	: String;
begin

	if self.myHarbour &lt;&gt; _harbour then 
		self.myHarbour := _harbour;
		self.amInitialised := false;
	endif;
	
	self.setObject(_resource);
	
end;</source>
        <Parameter name="_resource" type="HMS_Resource"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
    </JadeMethod>
