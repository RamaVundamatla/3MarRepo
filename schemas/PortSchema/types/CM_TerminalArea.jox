    <JadeMethod name="getDisplayStringForAttribute" id="f93796f5-bead-4a81-9cea-23e3ffc1530c">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     15 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// NOTE: overridden for gridarea to not call getNumTIS
vars

begin

	if _attrName = ETRow_EffectiveFIFODateStr then
		return self.getFIFOEffectiveDate.shortFormatJMT();
		
	elseif _attrName = ETRow_HasMap then // ### TFS CR 58499 TASK 61458 03JAN2024 NAVAB1
		return self.hasMap.getYes();
	elseif _attrName = ETRow_FileName then // ### TFS CR 58499 TASK 61458 03JAN2024 NAVAB1
		return self.getMapFileName();
	elseif _attrName = ETRow_NumItemsStr then
		//return "Unknown"; //rs oct 2005 par 10886
		if self.myLocationStatistics = null then
			return "Unknown";
		else
			//epr quick way to find used total that doesn't have to iter through all lcs and tis
			return self.myLocationStatistics.used.asStringJMT;
		endif;	
		//return self.getNumTIs(REAL_MODE).asStringJMT; //rs oct 2005 par 10886
	elseif _attrName = ETRow_NumTIs then
		return "Unknown"; //rs oct 2005 par 10886
		//return self.getNumTIs(REAL_MODE).asStringJMT; //rs oct 2005 par 10886
		
	elseif _attrName = ETRow_Restrictions then
		return self.getTAEnqRestrictionLocString();
		
	elseif _attrName = ETRow_HideShow then
		return null;
		
	elseif _attrName = ETRow_AutoRestrictionsEnabled then
		return self.autoRestrictionsEnabled.asStringJMT;
		
	elseif _attrName = ETRow_HideFromOverView then
		return self.hideFromOverView.asStringJMT;
		
	elseif _attrName = ETRow_StockControlled then
		return self.isStockControlled.asStringJMT;
		
	elseif _attrName = ETRow_ActAsReleasePoint then
		return self.actAsReleasePoint.asStringJMT;
		
	elseif _attrName =ETRow_Colour then
		if self.myLayoutGraphic = null then
			return null;
		endif;
		return myLayoutGraphic.drawLineColour.asStringJMT;
		
	elseif _attrName = ETRow_AutoPlanEnabled then
		return self.autoPlanEnabled.asStringJMT;
		
	elseif _attrName  = ETRow_LocationLength then
		return self.locationLength.asStringJMT;
		
	elseif _attrName  =	ETRow_LocationWidth then
		return self.locationWidth.asStringJMT;
		
	elseif _attrName = ETRow_InterchangeArea then
		if self.allAssociatedInterchangeAreas.size &gt; 0 then
			return self.allAssociatedInterchangeAreas.first.id;
		else
			return null;
		endif;
	elseif _attrName = ETRow_LabourRestrictions then	// par 30475 Nov 2012
		return self.getLabourRestrictionsAsString;		
		
	elseif _attrName = ETRow_YardAllocations then
		return self.getYardAllocationsAsString;			// par 30475 Nov 2012
	
	//cnwmc5 - 7 Oct 2015 - PAR 37019
	elseif _attrName = ETRow_DwellDaysRangeCount then
		return self.getDwellDaysRangeCount;
		
	else
		return inheritMethod(_attrName, _short);
	endif;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDwellDaysRangeCount" id="16a8fde2-2495-44e8-b992-93bc9078d905">
        <source>getDwellDaysRangeCount() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 October 2015	cnwmc5	Initial creation

*/

vars
	lc		: CM_LocationsController;
	ti		: CM_TrackedItem;
	iter1,
	iter2	: Iterator;
	
	obj	: Object;
	dwellCounts : IntegerArray;
	dwellRanges	: CM_DwellDayRangeByLowerDict;
	dwellRange : CM_DwellDayRange;
	
	value : Integer;
	index : Integer;
	result : String;
	
	localColl : CM_TISet;	//20 Jun 2017	NDL	TFS 4853
	
begin

	create dwellRanges transient;
	create dwellCounts transient;
	
	foreach dwellRange in app.myRoot.allDwellDayRanges do
		dwellRanges.add(dwellRange);
		dwellCounts.add(0);
	endforeach;
	
	create localColl transient;	//20 Jun 2017	NDL	TFS 4853
	
	iter1	:= self.allLocationsControllers.createIterator;
	while iter1.next( lc ) do : lc_loop
		//iter2 := lc.allTrackedItems.createIterator;
		//20 Jun 2017	NDL	TFS 4853
		localColl.clear();
		lc.allTrackedItems.copy( localColl );
		iter2 := localColl.createIterator;
		
		while iter2.next( ti ) do : ti_loop
			dwellRange := ti.getMyDwellDayRange();
			if dwellRange &lt;&gt; null then
				index := dwellRanges.indexOf(dwellRange);
				if index &gt; 0 then
					dwellCounts[index] := dwellCounts[index] + 1;
				endif;
			endif;
		endwhile ti_loop;
		delete iter2;
	endwhile lc_loop;
	
	foreach dwellRange in dwellRanges do
		index := dwellRanges.indexOf(dwellRange);		
		value := dwellCounts[index];
		if value &gt; 0 then
			result := result &amp; dwellRange.getDisplayValue().replaceString(' ', '') &amp; ": " &amp; value.String &amp; ", ";
		endif;
	endforeach;
	
	if result.length &gt; 0 then
		result := result[1 : result.length - 2];
	endif;
	
	return result;
	
epilog

	delete iter1;
	delete iter2;
	delete dwellRanges;
	delete dwellCounts;
	delete localColl;	//20 Jun 2017	NDL	TFS 4853
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnforceMaxCapacity" id="fb02fc65-3479-43e2-b9de-ea021a195693">
