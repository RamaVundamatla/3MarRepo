    <PrimAttribute name="colour" id="9999992d-c239-4752-bfe7-ca6723286340">
        <length>21</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myDutyDocRoot" id="a44e216e-123a-44ba-ba2e-f52974bdbc9b">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
