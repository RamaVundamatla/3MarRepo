//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//CNWTH2 - no more app.enumToString etc - just do a lookup
// ---------------------------------------------------------------------------

vars
	imx : CM_IMEXStatus;
	
begin
	imx := app.myRoot.allImexStatuses[self.imExStatus];
	if imx &lt;&gt; null then
		if _long then
			return imx.description;
		else
			return imx.abbreviation;
		endif;
	else
		return "Unknown";
	endif;
	
end;</source>
        <Parameter name="_long" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
