<Class name="CM_ReeferDaily" id="27baaa9d-94f4-4829-ab87-909057a81473">
    <superclass name="CM_ReeferMonitor"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="getChargeQuantity" id="cd966398-994e-425e-a90c-b5c975b4fdd4">
        <source>getChargeQuantity(): Real;
//----------------------------------------------------------------
//	Created:	22 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	
	if self.lastDisconnectDT.isValid and 
	self.firstConnectDT.isValid then
	//	return (self.dateTime.Date  - self.firstConnectDT.date) + 1;
		return (self.lastDisconnectDT.date - self.firstConnectDT.date) + 1;
	endif;
	
	return 0;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="51a5c72d-1c8a-41f4-8c57-84d02459e998">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498

*/

vars
	lDetail : String;
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			return "On power for " &amp; self.getChargeQuantity.Integer.String &amp; " days";
			
		endif;
							
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="c4ffa6c4-e26a-4ad3-9b7c-c1ff1a912495">
        <source>getEnquiryRow(): String;
//----------------------------------------------------------------
//	Created:	22 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
begin

//	return inheritMethod() &amp; "On power from " &amp; self.firstConnectDT.shortCurrentLocaleFormat 
//									&amp; " to " &amp; self.lastDisconnectDT.shortCurrentLocaleFormat;
	return inheritMethod() &amp; "On power for " &amp; self.getChargeQuantity.Integer.String &amp; " days";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isVoyageVisitRelevant" id="5df7971e-f2d5-4fff-b3df-52ef8eff036e">
        <source>isVoyageVisitRelevant(): Boolean;

vars

begin
	return true;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="112daa4e-3f4f-4e63-aafd-6ad76d08084f">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_TITransactionController; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		



Date		Who		Reason
22 December 2016	cnwma1	Initial creation 3015*:PAR38320 GUQ - Days since receival not inclusive for pro-forma charges
// 20 Nov 2017	jlgrh7 TFS 7198	GUQ - Days connected calculation type
8/10/2018 	JLGNS1	Bug 40690: GUQ - Reef Days connected not working on jmt851#200
*/

vars
	reeferLastDisconnectedDT : TimeStamp;
begin
	inheritMethod(_tiTransCntrl, _passport);
	if app.isCashOnlyEnabled and app.isInProformaMode then  
		reeferLastDisconnectedDT :=self.myTrackedItem.getLastDisconnectDT ();
		if self.myTrackedItem.isConnected or reeferLastDisconnectedDT = null or  reeferLastDisconnectedDT &gt; _tiTransCntrl.dateTime then
			self.lastDisconnectDT := _tiTransCntrl.dateTime;
		else
			self.lastDisconnectDT := reeferLastDisconnectedDT ;
		endif;
	endif;	
			
epilog

end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
