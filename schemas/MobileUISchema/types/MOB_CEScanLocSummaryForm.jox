    <JadeMethod name="loadTable" id="579c8cd4-23e8-4f93-bfc1-8dab7e9d0f64">
        <updating/>
        <source>loadTable(tbl: CM_MobTable io) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 May 2009	#cnwdz2	ccms1801
//23/06/2009 cnwdz2 19969

*/

vars
	quantity,
	rowPointer 	: Integer;
	productDesc : String;
	locationsController : CM_LocationsController;
	sohLocationObj : CM_SOHLocation;
	locDisplayName : String;
begin
	
	locationsController := self.myMobileDataAgent.findLocationByID(self.locID);
    if locationsController = null then
        app.setContinueCMExceptions(false);
        app.raiseCMException1(Location_NotFound, self.locID, null, null);
    endif;
	
	//09/06/2009 cnwdz2 par19867
	if self.allLocations.includes(locationsController) then
		return;
	endif;
	

	//09/06/2009 cnwdz2 par19867
	self.allLocations.add(locationsController);
	
    foreach sohLocationObj in locationsController.allProductLocations do
		if sohLocationObj.numTIs = 0 then
			continue;
		endif;
		
		//23/06/2009 cnwdz2	19969
		productDesc := sohLocationObj.myProduct.code &amp; ' - ' &amp; sohLocationObj.myProduct.description;
		quantity := sohLocationObj.numTIs;
		
		self.loadCount := self.loadCount + quantity;
		locDisplayName := locationsController.terminalAreaId &amp; ' ' &amp; locationsController.getNiceName;
		
		rowPointer := tbl.addItem(locDisplayName &amp; Tab &amp; productDesc &amp; Tab &amp; quantity.String);
		tbl.accessRow(rowPointer).itemObject := sohLocationObj;	
	endforeach;
end;</source>
        <Parameter name="tbl" type="CM_MobTable" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="8ff205c1-a63a-427f-a81e-38b9f047abe5">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 May 2009	#cnwdz2	ccms1801

*/

vars
	ioc : CMIF_InOutCommon;
	locPointer : Real;
	ti    : CM_TrackedItem;
begin
	inheritMethod();
	locPointer := self.lbl_CargoID.top;
	
	self.lbl_Truck.caption := app.getErrorString(Location_Summary);
	self.lbl_TruckNo.caption := '';
	self.btn_TruckDone.visible := false;
	self.loadCount := 0;
	self.allLocations.clear(); //09/06/2009 cnwdz2 par19867
	
	self.frm_Header.height := self.frm_Header.height + self.btn_Clear.top;
	self.frm_CargoTbl.top := self.frm_CargoTbl.top + self.btn_Clear.top;		
	self.frm_Footer.top := self.frm_Footer.top + self.btn_Clear.top;
	self.frm_Footer.height :=  self.frm_Footer.height - self.btn_Clear.top;
	
	self.lbl_LocationID.top  := self.btn_CargoIdOK.top + (self.btn_CargoIdOK.height - self.lbl_LocationID.height)/2;	
	self.lbl_LocationID.left := self.lbl_CargoID.left;
	self.lbl_LocationID.visible := true;
	
	self.txt_LocationID.top  := self.lbl_LocationID.top;
	self.txt_LocationID.left := self.txt_CargoID.left;
	self.txt_LocationID.visible := true;
	
	self.lbl_CargoID.top := locPointer;
	self.txt_CargoID.top := locPointer;
	
	self.txt_OrderCount.text := self.getLoadCountAsString;
	self.txt_OrderCount.top := self.btn_Clear.top + (self.btn_Clear.height - self.txt_OrderCount.height)/2;	
		
	self.lbl_OrderCount.caption := app.getErrorString(Total) &amp; ":";		
	self.lbl_OrderCount.autoSize := true;
	self.lbl_OrderCount.left := self.txt_OrderCount.left - 5 - self.lbl_OrderCount.width;
	self.lbl_OrderCount.top := self.txt_OrderCount.top + (self.txt_OrderCount.height - self.lbl_OrderCount.height)/2;
	
	self.btn_SetDown.visible := false;
	self.btn_ChangeLoc.visible := false;
	self.btn_Back.left := self.btn_Menu.left + self.btn_Menu.width + 1;
	self.btn_Back.visible := true;	
	
	ti := myMainObject.CM_TrackedItem;
	if ti &lt;&gt; null then
		self.locID := ti.locationId;
		self.loadTable(tbl_Items);
		self.txt_OrderCount.text := self.getLoadCountAsString;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupItemTable" id="d910a5b2-c3b9-4152-9350-dc394e50099a">
        <source>setupItemTable(tbl: CM_MobTable input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 May 2009	#cnwdz2	ccms1801

*/

vars
	col : JadeTableColumn;
begin
	tbl.selectMode := tbl.SelectMode_CurrentRow; 
	
	tbl.columns := 3;
	tbl.rows := 0;
	tbl.addItem(app.getErrorString(Location) &amp; Tab &amp; app.getErrorString(Product) &amp; Tab &amp; app.getErrorString(Quantity));
	tbl.fixedRows := 1;
	tbl.defaultRowHeight := 30;
	tbl.accessRow(1);
	tbl.accessedRow.height := 30;
	tbl.gridLines := true;
	tbl.gridColor := Black;
	tbl.setUseHighlightColours(false);
	tbl.alignment := Table.Alignment_Center_Middle;
	tbl.fixed3D := false;
	tbl.setFixedColours();
	tbl.height := tbl.height - 34;
end;</source>
        <Parameter name="tbl" type="CM_MobTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="56698767-f32e-4b1d-9be4-7384ee46d1b7">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018473, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="validateCargoID" id="e8e07947-6e31-490b-94a8-33844bc337d2">
        <source>validateCargoID(_id: String): Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 May 2009	#cnwdz2	ccms1801

*/

vars
	ti: CM_TrackedItem;
begin
	if _id = null then
		return false;
	endif;
	
	ti := self.myMobileDataAgent.findOnsiteCargoByID(_id);
	if ti &lt;&gt; null and ti.isChild then
		app.msgBox(app.getErrorString(ERR_NON_CHILD_OP), '', MsgBox_OK_Only);
		return false;
	endif;
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
