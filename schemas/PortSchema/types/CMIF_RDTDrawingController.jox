    <JadeMethod name="setTargetLocationHeightFromTI" id="c92afb81-3ebc-427b-a127-2087208ea5c8">
        <updating/>
        <source>setTargetLocationHeightFromTI(_ti : CM_TrackedItem) protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 June 2010	cnwjk3	Initial creation

*/

vars
	lc : CM_GridController;
begin
	if _ti = null then
		self.targetLocationHeight := 0;
		return;
	endif;
	
	//epr par 31174 8/3/12
	if self.myTargetLocation &lt;&gt; null and self.myTargetLocation.isKindOf(CM_GridController) then
		if _ti.myPrimaryActualLocation = self.myTargetLocation then //get height based on actual location of the ti
			self.targetLocationHeight := _ti.myPrimaryActualLocation.CM_GridController.getActualStackPositionOfTI(_ti);
		else
			// going to the target location get height based on number of containers there + 1
			self.targetLocationHeight := self.myTargetLocation.allTrackedItems.size + 1;	
		endif;
	else
		self.targetLocationHeight := 0;
	endif;
	
	/*	
	if _ti.myPrimaryActualLocation = null or not _ti.myPrimaryActualLocation.isKindOf(CM_GridController) then
		self.targetLocationHeight := 0;
	else
		self.targetLocationHeight := _ti.myPrimaryActualLocation.CM_GridController.getActualStackPositionOfTI(_ti);
	endif;*/
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
