    <JadeMethod name="setFieldAlignmentOnTable" id="970a3858-9570-489a-b34d-2d038c61a44e">
        <source>setFieldAlignmentOnTable(_table : CM_DataTable io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 January 2023	navhl20	ChangeRequest 55443:[54991] EUP - Receive Cargo Work Order - Enhancements

*/

vars
	entRowArray : StringArray;
	entRow : String;
	align : Integer;
	entRowColumn : Integer;
begin
	create entRowArray transient;
	entRowArray.add(ETRow_QuantityTxt);
	entRowArray.add(ETRow_NumOnsiteTIs);
	entRowArray.add(ETRow_Released);
	entRowArray.add(ETRow_MaxToRelease);
	entRowArray.add(ETRow_MyWeight);
	entRowArray.add(ETRow_TempC);
	entRowArray.add(ETRow_TempF);
	entRowArray.add(ETRow_CarbonDioxide);
	entRowArray.add(ETRow_Oxygen);
	entRowArray.add(ETRow_Ventilation);
	entRowArray.add(ETRow_Humidity);
	entRowArray.add(ETRow_Grade);
	entRowArray.add(ETRow_VolumeTotal);	
	entRowArray.add(ETRow_MyLength);
	entRowArray.add(ETRow_MyWidth);
	entRowArray.add(ETRow_MyHeight);
	entRowArray.add(ETRow_MyQuantity);
	entRowArray.add(ETRow_MyVolume);
	entRowArray.add(ETRow_MyDensity);
	entRowArray.add(ETRow_Overunder);
	entRowArray.add(ETRow_TotalWeight);
	entRowArray.add(ETRow_NumberPrenoted);
	entRowArray.add(ETRow_ReservedCount);
	
	align := Table.Alignment_Right;
	foreach entRow in entRowArray do
		if _table.getEntRowColumnByRowName(entRow, entRowColumn) &lt;&gt; null then
			_table.accessColumn(entRowColumn).alignment := align;
		endif;
	endforeach;
epilog
	delete entRowArray;
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setMeterMarks" id="e0e8cbb1-d588-449f-b57f-0a6de7724bfd">
        <updating/>
        <source>setMeterMarks(_textBox : TextBox) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
25 April 2022	navgm20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	berth, berthForMarks : HMS_Berth;
	loa : Decimal [6,2];
	bridgeToBow, bowMark, sternMark, bridgeMark : Decimal [12,2];
	sideTo : Integer;

begin
	berth := self.cmbToBerth.listObject.HMS_Berth;
	if berth = null then
		return;
	endif;

	if self.myMovement &lt;&gt; null then	
		loa 		:= self.myMovement.myHMSVoyageData.dim_LengthOverall;
		bridgeToBow := self.myMovement.myHMSVoyageData.dist_BridgeToBow;
	endif;
	
	sideTo := OrientStarboardSideTo;
		
	if _textBox = null then
		berth.getBowSternBridgeMarksFromLOA(loa, bridgeToBow, sideTo, bowMark, sternMark, bridgeMark, null, berthForMarks,true);
	elseif _textBox = self.txtBowMarkTo then
		bowMark := _textBox.text.asDecimalJMT();
		berth.getBowSternBridgeMarksFromLOA(loa, bridgeToBow, sideTo, bowMark, sternMark, bridgeMark, app.getErrorString(HMS_BowMark), berthForMarks,true);
	elseif _textBox = self.txtSternMarkTo then
		sternMark := _textBox.text.asDecimalJMT();
		berth.getBowSternBridgeMarksFromLOA(loa, bridgeToBow, sideTo, bowMark, sternMark, bridgeMark, app.getErrorString(HMS_SternMark), berthForMarks,true);	
	else
		return;
	endif;

	self.txtBowMarkTo.text	 := bowMark.asStringJMT();
	self.txtSternMarkTo.text := sternMark.asStringJMT();
	
	if berthForMarks &lt;&gt; null and berthForMarks &lt;&gt; berth then
		self.cmbToBerth.listIndex := self.cmbToBerth.findObject(berthForMarks);
	endif;
epilog

end;</source>
        <Parameter name="_textBox" type="TextBox"/>
    </JadeMethod>
    <JadeMethod name="setParentAspect" id="fda27215-855a-4115-b46b-d9739b200f3a">
        <source>setParentAspect(_both : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Oct 2023 navhl20 Bug 60373: MTN - Expected to see a validation message to save the changes before closing the work order form.
13 Oct 2023 navhl20 Bug 60868: EUP- Work Order New Form has  issues on Remarks Textbox and High Priority Checkbox
*/

vars

begin
	if self.workOrderType = WorkOrderMode_Cargo then
		if _both then
			self.tblSelectedCargo.parentAspect 	:= 3;
			self.tblSelectedCargo.height		:= self.shtSelectedTis.height - 98;
		else
			self.tblSelectedCargo.parentAspect 	:= 1;
			self.tblSelectedCargo.height		:= 150;
		endif;
		self.btnCreateCargo.top := self.tblSelectedCargo.top + self.tblSelectedCargo.height + 5;
	elseif self.workOrderType = WorkOrderMode_ToDo then
		self.mulToDoTasks.height := 270;
		self.mulToDoTasks.parentAspect := 1;														//13.10.2023 navhl20 #60868
	endif;
epilog

end;</source>
        <Parameter name="_both" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setPermitTotalDays" id="a1e295a3-8671-4c1b-b09e-263b92d53391">
        <source>setPermitTotalDays(_alwaysUpdate : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
25 April 2022	navhl20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	realObject : CM_WodPermitRequest;
	rowIndex : Integer;
	wodCargoRequest : CM_VoyageHoldJob;
	holdId : String;
	index : Integer;
	longestDays : Decimal[6,2];
	totDays : Decimal[6,2];
	daysToComplete : Decimal[6,2];
	holdValueArray : DecimalArray;
	holdIdArray : StringArray;
	incrementForCargo : Decimal[5,2];
	roundedTotal : Decimal[6,2];
begin
	if not self.myPxyTask.isKindOf(CM_WodPermitRequest) then
		return;
	endif;
	
	realObject:=self.myPxyTask.pxyGetRealObject.CM_WodPermitRequest;
	if not _alwaysUpdate and realObject &lt;&gt; null and realObject.myParent.CM_WorkOrderVoyage.lengthOfTime &lt;&gt; null  then
		return;
	endif;
	
	create holdValueArray transient;
	create holdIdArray transient;

	foreach rowIndex in 1 to self.tblOOWConfirm.rows do
		if rowIndex &lt;= self.tblOOWConfirm.fixedRows then
			continue;
		endif;
		wodCargoRequest := self.tblOOWConfirm.accessRow( rowIndex ).itemObject.CM_VoyageHoldJob;
		if wodCargoRequest = null then
			//Hold summary line, round up then reset the sub total
			roundedTotal := self.myTerminal.applyRoundingToValue( holdValueArray[ index ] );
			holdValueArray[ index ] := roundedTotal;
			self.tblOOWConfirm.setCellText( rowIndex, HoldTotalCol, roundedTotal.asStringJMT );
			continue;
		endif;
		holdId := wodCargoRequest.getHoldId();
			
		if holdIdArray.includes( holdId ) then
			index := holdIdArray.indexOf( holdId );
		else
			holdValueArray.add(0.00);
			holdIdArray.add(holdId);
			index := holdIdArray.size;
		endif;
		
		daysToComplete := self.tblOOWConfirm.accessCell( rowIndex, DaysToCompleteCol ).text.asDecimalJMT;
		
		holdValueArray[ index ] := holdValueArray[ index ] + daysToComplete;
		
	endforeach;
	
	if not holdValueArray.isEmpty then
		foreach index in 1 to holdValueArray.size do
			daysToComplete := holdValueArray[ index ];
			if daysToComplete &gt; 0 then	
				if longestDays &lt; daysToComplete then
					longestDays :=daysToComplete;// self.myTerminal.applyRoundingToValue(daysToComplete); 
				endif;
				totDays := totDays + daysToComplete;
			endif;
		endforeach;

		longestDays := longestDays + incrementForCargo; 
	endif;

	self.txtPermitTotalDays.text := longestDays.asStringJMT;
epilog
	delete holdValueArray;
	delete holdIdArray;
end;</source>
        <Parameter name="_alwaysUpdate" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxyWorkOrder" id="952349ed-2305-4ba4-b172-b672292e219e">
        <updating/>
        <source>setProxyWorkOrder(_pxyWorkOrder : CM_WorkOrder input) : Boolean protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Apr 2022	navcs2	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
19 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
08 Feb 2023 navma1  ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
15 Feb 2023 navma1  ChangeRequest 56561: FR 53944 | EUP - Simplified Voyage Work Order
06 Apr 2023 navhl20 Bug 57458: EUP - Work Order Remarks
*/

vars
	enteredByUser 	: CM_User;
	org 			: CM_Organisation;
	sendEmail 		: Boolean;
	totalReq		: Integer;
	taskStatus 		: Integer;
	reqByDTLocal	: TimeStamp;
	reqByDTSystem	: TimeStamp;
	enteredDTSystem	: TimeStamp;
	approvalExpiry	: TimeStamp;
	approvedBy 		: String;
	refStr 			: String;
	remarksStr 		: String;
begin
	
	if self.myWorkOrder &lt;&gt; null then 							//12.01.2023 navma1 #56141 Task#56147
		_pxyWorkOrder.setID(self.myWorkOrder.id);
		approvedBy    	:= self.myWorkOrder.approvedBy;			//12.01.2023 navma1 #56141 Task#56147
		enteredByUser 	:= self.myWorkOrder.myEnteredByUser;	//12.01.2023 navma1 #56141 Task#56147
		enteredDTSystem := self.myWorkOrder.enteredByDT;		//12.01.2023 navma1 #56141 Task#56147
	else
		_pxyWorkOrder.setID( self.txtWorkOrderId.text); 
		enteredByUser := app.myPassport.myUser;
	endif;
	
	totalReq := self.txtTotalRequired.text.Integer;
	
	sendEmail := self.chkSendEmail.value;
	
	if self.txtJobRequiredByDT.text.asDateJMT().isValid then
		reqByDTLocal.setDate(self.txtJobRequiredByDT.text.asDateJMT());
		reqByDTLocal.setTime(self.txtJobRequiredByTM.text.asTimeJMT());
		reqByDTSystem := self.localToSystemTime(reqByDTLocal);
	
	else
		reqByDTSystem := null;
	endif;
	
	//approvalExpiry.setDate(self.txtAprovalExpDT.text.asDateJMT());					//06.4.2023 navhl20	#57458
	//approvalExpiry.setTime(self.txtJobApprvalExpTM.text.asTimeJMT());					//06.4.2023 navhl20	#57458
	
	taskStatus  := app.workOrderStatusStringToEnum( self.cmbWorkOrderStatus.text );		//15.02.2023 navma1 #56561
	refStr 		:= self.txtReference.text;
	remarksStr  := self.txtRemarks.text;

	_pxyWorkOrder.setProxy(self.myEmailController.allToAddresses,
		refStr,
		sendEmail,
		enteredDTSystem,
		enteredByUser,
		approvedBy,
		org,
		self.myTerminal,
		remarksStr,
		reqByDTSystem,
		null,
		taskStatus
		);	
		
	//_pxyWorkOrder.setApprovalExpiry(approvalExpiry);									//06.4.2023 navhl20	#57458

	if self.workOrderType = WorkOrderMode_Cargo then										
		//_pxyWorkOrder.CM_WorkOrderTI.setTotalRequired(totalReq);									//24.01.2023 navma1 #56141 Task#56147	//08.02.2023 navma1 #56457 Task#56458
	elseif self.workOrderType = WorkOrderMode_Voyage then									
		_pxyWorkOrder.CM_WorkOrderVoyage.setMyVoyage(self.cmbVoyageDetails.listObject.CM_Voyage);
	endif;																						
	return true;
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_pxyWorkOrder" type="CM_WorkOrder" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxyWorkOrderTasks" id="24561b18-390f-4f97-80b7-4f2e1df333dd">
        <source>setProxyWorkOrderTasks(_pxyWorkOrder : CM_WorkOrder input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Apr 2022	navcs2	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
24 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
*/

vars
	reqByDT, 
	startDT  : TimeStamp;
	taskType : Integer;
begin
	if self.workOrderMode &lt;&gt; self.MODE_ADD then
		app.raiseUnexpectedProgramError(self.class.name, method.name, "Should only be creating a WorkOrderDtl on work order creation");
	endif;
	
	reqByDT.setDate(self.txtJobRequiredByDT.text.asDateJMT());
	reqByDT.setTime(self.txtJobRequiredByTM.text.asTimeJMT());
	reqByDT := self.localToSystemTime(reqByDT);
	startDT := self.localToSystemTime(startDT);
	if self.lstTasks.listIndex &gt; 0 then
		if self.lstTasks.listObject &lt;&gt; null then
			taskType := WO_TASK_TODO;
		endif;
		_pxyWorkOrder.createProxyWorkOrderTasks(taskType,reqByDT, startDT,  self.lstTasks.listObject.CM_ToDoTaskDesc);		//24.01.2023 navma1 #56141 Task#56147
		
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_pxyWorkOrder" type="CM_WorkOrder" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setReleaseRequest" id="bd7474e2-28e1-48db-a5c6-797a953dec6f">
        <updating/>
        <source>setReleaseRequest(_theObject : Object input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Dec 2024	navbs1	Initial creation Bug MTN-33524: MTN - Notifications in the work order details screen update the release request assigned as a new work order is created
17 Feb 2025	navhl20 CR MTN-14693: EUP | Work Order improvement - automatic WO Tasks for Release Cargo Work Order Line items &lt;&lt;54014&gt;&gt;
21 Feb 2025	navhl20 Defect MTN-34153: Object Not Found exception when trying to delete the reserve detail.
21 Feb 2025	navhl20 Defect MTN-34162: Issue when Release Cargo Task is manually added and linked to the same release request
24 Feb 2025	navhl20 Defect MTN-34188: Reserve Detail field is not visible if we create release request with one reserve detail
25 Feb 2025	navhl20 Defect Sub-task MTN-34214: 1086 exception when creating a packing release request from the work order enquiry form
03 Mar 2025	navhl20 Defect MTN-34220: The Child Reserve Detail field is not updated when editing the Release Request while creating a Pack Work Order.
24 Sep 2025 navhl20 Defect MTN-36128: Error 4 exception on the cargo work order new screen when deleting the reserve detail from the release request
*/

vars
	release 		: CM_BulkRelease;
	detail,
	resDtl			: CM_ReserveDetail;
	wodDtl			: CM_WorkOrderDtl;
	dtl				: CM_WodRelease;
	invalid			: Boolean;
	edition 		: Integer;
	wod				: CM_WorkOrder;
	dtlsToBeDeleted : CM_WorkOrderDtlSet;
begin		
	on Exception do app.handleDeletedObject( exception, resDtl, invalid );						//21.02.2025 navhl20 #34153
	if _theObject = null then 
		return;
	endif;
	release := _theObject.CM_BulkRelease;														//17.02.2025 navhl20 #14693
	if self.cmbReleaseRequest.listObject = null then 
		self.cmbReleaseRequest.addItemObject(release.code,release);	
		self.cmbReleaseRequest.listObject := release;
		self.cmbReleaseRequest_click(self.cmbReleaseRequest);									//21.02.2025 navhl20 #34188	
		if release.allReserveDetails.size &gt; 1 then												//17.02.2025 navhl20 #14693
			self.cmbReserveDetail.setIndexFromObject(release.allReserveDetails.first);
			self.doSaveCargoProxy();
		endif;
	endif;		
	
	if self.hasVasSubscription then																//17.02.2025 navhl20 #14693
		wod := self.myPxyWorkOrder;																//21.02.2025 navhl20 #34153
		if wod.isWorkOrderForRelease then														//25.02.2025 navhl20 #34214
			create dtlsToBeDeleted transient;													//21.02.2025 navhl20 #34153
			foreach wodDtl in wod.allWoDtls do													//21.02.2025 navhl20 #34153
				dtl := wodDtl.CM_WodRelease;
				resDtl := dtl.myReserveDetail;
				if resDtl &lt;&gt; null then															//21.02.2025 navhl20 #34162
					invalid := false;
					edition := resDtl.edition;
					
					if invalid then
						dtlsToBeDeleted.tryAdd(wodDtl);
						if self.cmbReserveDetail.listObject = resDtl then						//24.09.2025 navhl20 #36128
							self.cmbReserveDetail.listObject := null;
						endif;
					endif;
				endif;
			endforeach;
			
			if dtlsToBeDeleted.isNotEmpty then													//21.02.2025 navhl20 #34153
				foreach wodDtl in dtlsToBeDeleted do
					self.doBtnTaskDelete(wodDtl);
				endforeach;
			endif;
			
			if release.allReserveDetails.size &gt; 1 then
				self.buildCmbReserveDetails(release);											//21.02.2025 navhl20 #34153
				foreach detail in release.allReserveDetails where detail.isReserveSelection do :toploop
					foreach dtl in wod.allWoDtls as CM_WodRelease do
						resDtl := dtl.myReserveDetail;
						if resDtl &lt;&gt; null and detail.getDescription = resDtl.getDescription then
							continue toploop;
						endif;
					endforeach;
					if self.cmbReserveDetail.listObject = null then								//21.02.2025 navhl20 #34162
						self.cmbReserveDetail.listObject := detail;
						continue;
					endif;
					self.doBtnTaskAdd(true);
					self.buildCmbReserveDetails(release);
					self.cmbReleaseRequest.listObject := release;
					self.cmbReleaseRequest_click(self.cmbReleaseRequest);
					self.cmbReserveDetail.setIndexFromObject(detail);
					self.cmbReserveDetail_click(self.cmbReserveDetail);
					self.doSaveCargoProxy();
				endforeach;
			endif;
		else																					//03.03.2025 navhl20 #34220
			self.cmbReleaseRequest_click(self.cmbReleaseRequest);
		endif;
	endif;
end;</source>
        <Parameter name="_theObject" type="Object" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="7e7438b6-a37d-497d-bffa-248e1add7a8b">
        <updating/>
        <source>setTableDataFromOrganiser(table: CM_DataTable input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Apr 2022	navcs2	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
25 Jan 2022 navhl20 ChangeRequest 55443:[54991] EUP - Receive Cargo Work Order - Enhancements
04 Jul 2023	navma1	Bug 58952: MTN - Unable to add the tracked item when using the Export Booking for Release Cargo Work Order
*/

vars

begin
	self.doRefresh();
	self.saveXMLStrForTblColumns(table);
	
	if self.cmbBooking.listObject &lt;&gt; null then
		self.loadItemTable(self.cmbBooking.listObject);		//25.1.2023 navhl20 #55443[54991]
	elseif self.cmbBol.listObject &lt;&gt; null then
		self.loadItemTable(self.cmbBol.listObject);	
	elseif self.cmbReleaseRequest.listObject &lt;&gt; null then
		self.loadItemTable(self.cmbReleaseRequest.listObject);
	endif;
	
	self.loadTabCargoTis();
	self.buildTblChildItems();

epilog

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTodoDetails" id="ae9db418-2a75-40d1-89a3-ab71366186c4">
        <source>setTodoDetails(_show : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Oct 2023	navhl20	Bug 60868: EUP- Work Order New Form has  issues on Remarks Textbox and High Priority Checkbox
01 Aug 2024 navhl20	ChangeRequest 65468: EUP -  VAS Mobile App - Enable Remarks for ToDo Tasks on Cargo Work Orders
26 Aug 2024 navhl20	Bug 65538: Retrospective date/time is not recorded on the cargo for the VAS work orders
*/

vars

begin
	if _show then
		self.grpTodoDetails.parent 			:= self.shtToDoTasks;
		self.grpTodoDetails.visible			:= true;
		self.mulToDoTasks.height 			:= 270;
		self.mulToDoTasks.parentAspect 		:= 1;
		self.grpTodoDetails.enabled			:= true;				//26.08.2024 navhl20 #65538
		if not self.myPxyTask.isKindOf(CM_WodToDo) then				//01.08.2024 navhl20 #65468
			self.grpTodoDetails.enabled		:= false;
		endif;
	else
		self.grpTodoDetails.visible			:= false;
		self.mulToDoTasks.height 			:= self.shtToDoTasks.height - 30;
		self.mulToDoTasks.parentAspect 		:= 3;
	endif;
epilog

end;</source>
        <Parameter name="_show" type="Boolean"/>
    </JadeMethod>
