    <JadeMethod name="create" id="f6aa04d3-1c95-45df-b7c6-d185b643b332">
        <updating/>
        <source>create() updating;

vars
	p : Property;
	t : Type;
	
begin
	// cache our property names and their type when we're created so that
	// jtdAsString and jtdSetFromString don't have to keep accessing the
	// persistent meta-data from the database (and placing locks/unlocks)
	
	foreach p in self.class.rootType.jtdGetProperties do
		t := p.type.rootType;

		// jtdAllPropertyNames is an array, so we'll hold the property
		// names in the same order that we read them		

		if t = Integer then
			self.jtdAllPropertyNames.add('I' &amp; p.name);
		elseif t = Real then
			self.jtdAllPropertyNames.add('R' &amp; p.name);
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="jtdAddSummary" id="fcefa750-efa9-494b-a90d-ab5671a8017e">
        <updating/>
        <source>jtdAddSummary(jts : JtdTransactionSummary; addSecs : Boolean) updating;

begin
	if jts = null then
		return;
	endif;

	self.jtdTotalDeadlocks := self.jtdTotalDeadlocks + jts.jtdTotalDeadlocks;
	self.jtdTotalLocks := self.jtdTotalLocks + jts.jtdTotalLocks;
	self.jtdTotalErrs := self.jtdTotalErrs + jts.jtdTotalErrs;
	self.jtdTotalTransactions := self.jtdTotalTransactions + jts.jtdTotalTransactions;
	self.jtdTotalUnhandledExceptions := self.jtdTotalUnhandledExceptions + jts.jtdTotalUnhandledExceptions;

	if addSecs then
		self.jtdTotalGenSecs := self.jtdTotalGenSecs + jts.jtdTotalGenSecs;
		self.jtdTotalTrxSecs := self.jtdTotalTrxSecs + jts.jtdTotalTrxSecs;
	endif;
end;</source>
        <Parameter name="jts" type="JtdTransactionSummary"/>
        <Parameter name="addSecs" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jtdAsString" id="2489a56b-dd8c-4dc3-b42c-1a18abe76757">
        <source>jtdAsString() : String;

vars
	s, propName, typ : String;
	
begin
	s := null;
	
	foreach propName in self.jtdAllPropertyNames do
		typ := propName[1];
		propName := propName[2 : end];
		
		if typ = 'I' then
			s := s &amp; self.getPropertyValue(propName).Integer.String &amp; ';';
		elseif typ = 'R' then
			s := s &amp; self.getPropertyValue(propName).Real.String &amp; ';';
		endif;
	endforeach;
	
	return s;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jtdGetGPS" id="bb6362c6-9fb2-464f-b209-a16533a13142">
        <source>jtdGetGPS() : Real;

vars
	totalSecs : Real;
	totalTrx : Integer;
	
begin
	totalSecs := self.jtdTotalGenSecs;
	totalTrx := self.jtdTotalTransactions;
	
	if totalTrx &lt; 1 then
		return 0;
	endif;
	
	if totalSecs &lt;= 0 then
		return totalTrx;
	endif;
	
	return totalTrx / totalSecs;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="jtdGetTPS" id="1833590f-d2ec-43a1-b48d-0bc3e438d820">
        <source>jtdGetTPS() : Real;

vars
	totalSecs : Real;
	totalTrx : Integer;
	
begin
	totalSecs := self.jtdTotalTrxSecs;
	totalTrx := self.jtdTotalTransactions;
	
	if totalTrx &lt; 1 then
		return 0;
	endif;
	
	if totalSecs &lt;= 0 then
		return totalTrx;
	endif;
	
	return totalTrx / totalSecs;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="jtdGetTotalSecs" id="3ed1d55d-f03b-49f5-a628-f0e3d5eaa785">
        <source>jtdGetTotalSecs() : Real;

begin
	return self.jtdTotalGenSecs + self.jtdTotalTrxSecs;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
