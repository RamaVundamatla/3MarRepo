<Class name="CMQF_BookingRef">
    <JadeMethod name="setFromAgent" id="6b079602-45d7-4473-af07-94605b848c00">
        <updating/>
        <source>setFromAgent(_agent: CMUI_ReportAgent input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	26 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
10 Jul 2013	cnwkpd1		PAR #31971 - Booking Ref reports get exceptions when run through the RIA
						Changed parameter type

*/
vars
	consign			: CM_ConsigneeConsignor;
begin
	inheritMethod(_agent);

	if _agent.isRowIncluded(ETRow_BookingReference) then
		self.bookingRef := _agent.getValueByNameIfVisible(ETRow_BookingReference).String; //18/08/2010 SFW CCMS1063 PAR25404 - cnwsh3 Add booking number filter to Booking Ref Reporting
	endif;
	
	if _agent.isRowIncluded(ETRow_BookingStatus) then
		self.status := _agent.getSelectedBookingRefStatus(); //18/08/2010 SFW CCMS1063 PAR25404 - cnwsh3 Add status filter to Booking Ref Reporting
	endif;
	
	if _agent.isRowIncluded(ETRow_OperatorCode) then
		self.myOperator := _agent.getSelectedOperator();
	endif;

	if _agent.isRowIncluded(ETRow_Voyage) then
		self.setMyVoyage( _agent.getSelectedCellularVoyage() );
	endif;
	
	if _agent.isRowIncluded(ETRow_CargoType) then
		self.setMyCargoType( _agent.getSelectedCargoType() );
	endif;
	
	if _agent.isRowIncluded(ETRow_Consignee) then
		consign := _agent.getSelectedConsignee();
		if consign &lt;&gt; null then
			self.consignee := consign.code;
		endif;
	endif;

	if _agent.isRowIncluded(ETRow_Consignor) then
		consign := _agent.getSelectedConsignor();
		if consign &lt;&gt; null then
			self.consignor := consign.code;
		endif;
	endif;

	if _agent.isRowIncluded(ETRow_ArrivalsDateFrom) then
		if _agent.state = _agent.STATE_TEMPLATE_SAVE or
		   _agent.state = _agent.STATE_TEMPLATE_EDIT then
			self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_ArrivalsDateFrom), 
								self.voyageArrivalDateFromTplType, self.voyageArrivalDateFromTplFactor, ETRow_ArrivalsDateFrom);
		else
			self.voyageArrivalDateFrom := _agent.getValueByNameIfVisible(ETRow_ArrivalsDateFrom).Date;
		endif;
	endif;
	
	if _agent.isRowIncluded(ETRow_ArrivalsDateTo) then
		if _agent.state = _agent.STATE_TEMPLATE_SAVE or
		   _agent.state = _agent.STATE_TEMPLATE_EDIT then
			self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_ArrivalsDateTo), 
								self.voyageArrivalDateToTplType, self.voyageArrivalDateToTplFactor, ETRow_ArrivalsDateTo);
		else
			self.voyageArrivalDateTo := _agent.getValueByNameIfVisible(ETRow_ArrivalsDateTo).Date;
		endif;
	endif;

end;</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
