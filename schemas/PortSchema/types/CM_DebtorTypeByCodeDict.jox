<CollClass name="CM_DebtorTypeByCodeDict" id="d2493d18-857b-4d2f-a949-54e366145a6b">
    <loadFactor>66</loadFactor>
    <memberType name="CM_DebtorType"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="invoice"/>
    <MemberKey>
        <property name="CM_DebtorType::code"/>
    </MemberKey>
    <JadeMethod name="findDebtorTypeByDescription" id="4391c47f-85cf-4d37-a39b-7dacaed3ecfb">
        <source>findDebtorTypeByDescription( _desc : String ):CM_DebtorType;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	iter : Iterator;
	drType : CM_DebtorType;

begin

	if self.isEmpty then
		return null;
	endif;
	
	iter := self.createIterator();
	while iter.next( drType ) do
		if drType.description = _desc then
			return drType;
		endif;
	endwhile;
	
	return null;

epilog

	delete iter;

end;</source>
        <Parameter name="_desc" type="String"/>
        <ReturnType type="CM_DebtorType"/>
    </JadeMethod>
</CollClass>
