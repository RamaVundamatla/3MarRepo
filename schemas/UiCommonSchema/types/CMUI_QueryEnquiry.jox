    <JadeMethod name="doQuery" id="f1c521f9-673e-4965-a479-5a236d00e723">
        <updating/>
        <source>doQuery() updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 27/04/2010	cnwcs5		ccms 1118 - par 23580 - enhanced EDI form
// 07/03/2011	cnwcs5		ccms cpl 2027 - fix bug where searcher gets shown when not being used
// 16/10/2012	cnwcs5		par 30483 - refresh macro info after query
// ---------------------------------------------------------------------------


vars
	table	:CM_DataTable;
begin
	table := self.tblData;
	
	if self.usesQueryFrame then						// cnwcs5 07/03/2011 ccms cpl 2027
		self.frmQuery.visible := (table.rows &lt;= table.fixedRows);
	
		if not frmQuery.visible then				// cnwcs5 27/04/2010 par 23580
			self.searcherShowHideControls (true);	// cnwcs5 27/04/2010 par 23580
		endif;										// cnwcs5 27/04/2010 par 23580
	endif;											// cnwcs5 07/03/2011 ccms cpl 2027
	
	if self.useTableInfo then						// par 30483 Oct 2012
		self.doTblDataRowColChange (table);			// par 30483 Oct 2012
	endif;											// par 30483 Oct 2012
	
	self.showNumberOfItems (table);
end;</source>
