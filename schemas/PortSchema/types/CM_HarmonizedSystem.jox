    <JadeMethod name="validateForDelete" id="58587236-c4e3-403e-ac14-60e7b1fceb60">
        <source>validateForDelete();
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
25 November 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars

begin
	if self.allCustomDocuments.size() &gt; 0 then	
		app.raiseCMWarning2(Codes_used_custo_docum_sure_wa, self.description, self.allCustomDocuments.size().String, null, null, self);		
	endif;
epilog

end;</source>
