    <JadeMethod name="populateControlWithSearchValue" id="37dd4d1d-444a-4958-8833-f9ab0953ec07">
        <source>populateControlWithSearchValue(_controlArray: ObjectArray input);
// ---------------------------------------------------------------------------
// Created:     11 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	txtTo,
	txtFrom			: TextBox;
begin
	if _controlArray = null or _controlArray.size &lt; 2 then
		return;
	endif;
	
	txtFrom := _controlArray[1].TextBox;
	txtTo := _controlArray[2].TextBox;
	
	if txtFrom = null then
		return;
	endif;
	
	txtFrom.text := self.fromDate.String;

	if txtTo = null then
		return;
	endif;
	
	txtTo.text := self.toDate.String;		

end;</source>
        <Parameter name="_controlArray" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFromDate" id="ac2adb15-e71c-4adb-b8cc-96db9fe6b3b1">
        <updating/>
        <source>setFromDate(_date : Date input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Nov 2019	jlger1	Initial creation TFS 47132

*/

vars

begin
	self.fromDate:=_date;
epilog

end;</source>
        <Parameter name="_date" type="Date" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setSearchValue" id="84b6a8c2-83ab-4626-afc1-567aecffb78c">
        <updating/>
        <source>setSearchValue(_dateArray : DateArray) updating;
// ---------------------------------------------------------------------------
// Created:     03 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	
	if _dateArray &lt;&gt; null and _dateArray.size &gt; 1 then

		self.fromDate 	:= _dateArray[1];
		self.toDate		:= _dateArray[2];
		
		// ccms 1593. Queries for Drivers screen. Drivers put dates as strings. So, need check here
		if not ( self.fromDate.isValid() and self.toDate.isValid() ) then
			app.raiseCMException1( ERR_INVALID_TIMESTAMP, null, null, self );
		endif;

	endif;

end;</source>
        <Parameter name="_dateArray" type="DateArray"/>
    </JadeMethod>
