    <JadeMethod name="setupForm" id="0bb68cd7-350c-4f11-bfc8-1cfc1d7ecd94">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 November 2012	cnwrd1	Initial creation

*/

vars
	entTableDef : EntTableDef;
begin
	inheritMethod();
	
	entTableDef := app.myController.getEntTableDef(ETDef_CargoSearchForm);
	self.tblResults.setTblDataEntRowsFromDef(entTableDef);
	self.tblResults.setMyDataClass(CM_TrackedItem);
	self.tblResults.fixedColumns := 0;
	self.tblResults.fixedRows := 1;
	self.tblResults.selectMode := CM_DataTable.SelectMode_FixedRow;
	self.tblResults.selectionType := CM_DataTable.SelectionType_Row;
	self.tblResults.multiSelect := CM_BaseTable.MultiSelect_Simple;	
	self.setColorsForTable(self.tblResults);
	self.tblResults.clearAllData();

	//+cnwml2 PAR21663
	entTableDef := app.myController.getEntTableDef(ETDef_CargoSearchForm);
	self.tblSelectedItems.setTblDataEntRowsFromDef(entTableDef);
	self.tblSelectedItems.setMyDataClass(CM_TrackedItem);
	self.tblSelectedItems.fixedColumns := 0;
	self.tblSelectedItems.fixedRows := 1;
	self.tblSelectedItems.selectMode := CM_DataTable.SelectMode_FixedRow;
	self.tblSelectedItems.selectionType := CM_DataTable.SelectionType_Row;
	self.tblSelectedItems.multiSelect := CM_BaseTable.MultiSelect_Simple;	
	self.setColorsForTable(self.tblSelectedItems);
	self.tblSelectedItems.clearAllData();
	
	self.modalResult := IDCANCEL;		
	self.isSelectorCapable := true;
//	self.lblInfo.caption := app.getErrorString1(Selected_cargo_count,self.allSelectedCargo.size.asStringJMT());

epilog

end;</source>
    </JadeMethod>
