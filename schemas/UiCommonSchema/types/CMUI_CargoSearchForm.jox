        <updating/>
        <source>cmbCommodities_displayEntry(combobox: ComboBox input; _commodity: CM_Commodity; lstIndex: Integer):String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
12 January 2023	navcs2	ChangeRequest 56149: EUP - VAS Cargo Search Screen (Task 56150)

*/

vars

begin
	if _commodity.isNotAvailableForEntry then
		return null;
	endif;
	
	return _commodity.code &amp; " " &amp; _commodity.description;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="_commodity" type="CM_Commodity"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
