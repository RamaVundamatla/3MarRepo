    <JadeMethod name="showVoyageCreateNewCargo" id="3bc2d7ea-ebb2-4707-88e6-0e0640e85869">
        <source>showVoyageCreateNewCargo(_voyage : CM_Voyage; _menuAction : CMUI_MenuAction ; isForEdit : Boolean; _editObject : CM_BOLIn; _isNWNPScreen: Boolean) : Boolean;
//--------------------------------------------------------------
//Created: 07 February 2006 By: cnwgd1
//--------------------------------------------------------------
vars
	theForm : CMUI_BOLEntryGCVoyage;
begin
	
	if _voyage = null then
		return false;
	endif;
	
	theForm := app.loadForm(CMUI_BOLEntryGCVoyage, CMUI_Assistant, false, false, true, self.myTerminal, _menuAction).CMUI_BOLEntryGCVoyage;

	if theForm = null then
		return false;
	endif;
	
	theForm.myCurrentVoyage := _voyage;
	theForm.useShipBlockStack := _isNWNPScreen;
	
	if isForEdit then 
		theForm.mode := theForm.Mode_Edit;
		theForm.myCurrentBOL := _editObject;
	else
		theForm.mode := theForm.Mode_Add;
	endif;
	
	
	//theForm.showModal();
	theForm.show();
	
	//return theForm.modalResult = IDOK;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_menuAction" type="CMUI_MenuAction"/>
        <Parameter name="isForEdit" type="Boolean"/>
        <Parameter name="_editObject" type="CM_BOLIn"/>
        <Parameter name="_isNWNPScreen" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showVoyageDefForm" id="c5ad392c-f4d2-40dc-bf40-573a15e98bc7">
        <source>showVoyageDefForm(_voyage : CM_Voyage; _masterMenuAction : CMUI_MenuAction; _doNewEdit, _copyAsNewVoyage : Boolean);
//--------------------------------------------------
// Created:	18 July 2005 By: cnwgd1
//--------------------------------------------------
vars
	formCls					: Class;
	assistCls				: Class;
	voyageDefForm			: CM_BaseForm;
	menuAction				: CMUI_MenuAction;
	subSys					: CMUI_SubSystem;
	term					: CM_Terminal;
	tmpDoCopy				: Boolean;
	tmpDoNewEdit			: Boolean;
	glbVoyageObj			: CM_VoyageGlobal;
	legOneFirstWaypoint		: HMS_HarbourRegion;
	legOneSecondWaypoint	: HMS_HarbourRegion;
	berthObj				: HMS_Berth;
	
begin
	// also re-implemented in ShipSchema
	
	subSys	:=	app.myController.allSubSystems['ShipSchema'];
	
	if subSys &lt;&gt; null then
		//epr 11/3/14 removing voyage commodity planning as part of bulk CCMS 1366
		subSys.getFormDetails('SHP_VoyageDefinitionForm', formCls, assistCls);	
	endif;
	
	if formCls = null then
		return;
	endif;

	if _voyage &lt;&gt; null then
		term	:=	_voyage.myTerminal;
	else
		term	:=	self.myTerminal;
	endif;
	
	voyageDefForm	:=	app.loadForm(formCls, assistCls, false, false, true, term, _masterMenuAction).CM_BaseForm;
	
	if voyageDefForm = null then
		return;
	endif;

	// CCMS 1009, do not go into add or update if copying as new voyage
	tmpDoCopy		:=	_copyAsNewVoyage and _voyage &lt;&gt; null;
	tmpDoNewEdit	:=	_doNewEdit and (not tmpDoCopy);

	// CCMS 1009, set form up for copy as new voyage
	if tmpDoCopy then
		//epr 11/3/14 removing voyage commodity planning as part of bulk CCMS 1366
		voyageDefForm.setPropertyValue('initCopyAsNewVoyage', true);
		
	endif;
	
	if _voyage &lt;&gt; null
	or tmpDoNewEdit
	then
		//epr 11/3/14 removing voyage commodity planning as part of bulk CCMS 1366
		voyageDefForm.showWithObjectMode(_voyage, tmpDoNewEdit);
		
	else
		voyageDefForm.show();
	endif;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_doNewEdit" type="Boolean"/>
        <Parameter name="_copyAsNewVoyage" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showVoyageDefFormVoyageFilter" id="781f3f49-df33-4500-a2fc-cd10b719fa73">
        <source>showVoyageDefFormVoyageFilter(_voyage : CM_Voyage; _masterMenuAction : CMUI_MenuAction; _doNewEdit, _copyAsNewVoyage : Boolean; _coll : Collection);
/*

Purpose:			


Return Value:		


Date		Who		Reason
12 November 2007	cnwer1	Initial creation - PAR#14984

*/
vars

	formCls,
	assistCls	: Class;
	voyageDefForm : CM_BaseForm;
	menuAction : CMUI_MenuAction;
	subSys : CMUI_SubSystem;
	term : CM_Terminal;
	tmpDoCopy,
	tmpDoNewEdit : Boolean;	
begin
	// also re-implemented in ShipSchema
		
	subSys := app.myController.allSubSystems['ShipSchema'];
	
	if subSys &lt;&gt; null then
		//subSys.getFormDetails('SHP_VoyageDefinitionForm', formCls, assistCls);
		//epr 11/3/14 removing voyage commodity planning as part of bulk CCMS 1366	
		subSys.getFormDetails('SHP_VoyageDefinitionForm', formCls, assistCls);
	endif;
	
	if formCls = null then
		return;
	endif;

	if _voyage &lt;&gt; null then
		term := _voyage.myTerminal;	
	else
		term := self.myTerminal;
	endif;
	
	voyageDefForm := app.loadForm(formCls, assistCls, false, false, true, term, _masterMenuAction).CM_BaseForm;
	if voyageDefForm = null then
		return;
	endif;	

	// CCMS 1009, do not go into add or update if copying as new voyage
	tmpDoCopy := _copyAsNewVoyage and _voyage &lt;&gt; null;
	tmpDoNewEdit := _doNewEdit and (not tmpDoCopy);

	// CCMS 1009, set form up for copy as new voyage
	if tmpDoCopy then
		voyageDefForm.setPropertyValue('initCopyAsNewVoyage', true);
	endif;
		
	if _voyage &lt;&gt; null 
	or tmpDoNewEdit then
		//epr 11/3/14 removing voyage commodity planning as part of bulk CCMS 1366
		voyageDefForm.sendMsgWithParams('showWithObjectAndVoyageColl',_voyage, tmpDoNewEdit,_coll);
		
	else
		voyageDefForm.show();
	endif;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_doNewEdit" type="Boolean"/>
        <Parameter name="_copyAsNewVoyage" type="Boolean"/>
        <Parameter name="_coll" type="Collection"/>
    </JadeMethod>
    <JadeMethod name="showVoyageDelayForm" id="5dc54627-77d7-4673-bd24-9bdda3178703">
        <source>showVoyageDelayForm(_hmsVoyageData : HMS_VoyageData; _delay : HMS_VoyageDelay; _menuAction : CMUI_MenuAction) : Boolean;
//--------------------------------------------------------------
//Created: June 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	delayForm : CMUI_VoyageDelayForm;
begin
	
	if _hmsVoyageData = null then
		return false;
	endif;
	
	delayForm := app.loadForm(CMUI_VoyageDelayForm, CMUI_Assistant, false, false, true, self.myTerminal, _menuAction).CMUI_VoyageDelayForm;

	if delayForm = null then
		return false;
	endif;
	
	delayForm.myHMSVoyageData := _hmsVoyageData;
	delayForm.myVoyageDelay := _delay;
	delayForm.showModal();
	
	return delayForm.modalResult = IDOK;

end;</source>
        <Parameter name="_hmsVoyageData" type="HMS_VoyageData"/>
        <Parameter name="_delay" type="HMS_VoyageDelay"/>
        <Parameter name="_menuAction" type="CMUI_MenuAction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showVoyageJobRenumberForm" id="0de8ca32-fe0e-4262-a31c-4de9ab4c6bd2">
        <source>showVoyageJobRenumberForm(	_terminal : CM_Terminal; 
							_masterMenuAction : CMUI_MenuAction;
							_callerForm : CM_BaseForm;
							_type : Integer);
/*

Date		Who		Reason
12 April 2017	cnwer1	Initial creation TFS 830

*/

vars
	lForm : CMUI_GetData;
begin

	lForm:= app.loadForm(CMUI_GetData, CMUI_Assistant, false, false, true, _terminal, _masterMenuAction).CMUI_GetData;
	
	if lForm = null then
		return;
	endif;
	
	lForm.centreWindow;
	lForm.width := 320;
	lForm.height := 200;	
	lForm.setLblTextHeight( 40);
	lForm.lblTextCaption := app.getErrorString(Please_Enter_Number);  //30631
	lForm.txtData.text := null;
	lForm.txtData.maxLength := 30;
	lForm.txtData.dataType := TextBox.DataType_AlphaNumeric;
	lForm.myCaller := _callerForm;
	lForm.formCaption := app.getErrorString(Job_Renumber); // 30631
  	lForm.type := _type;
	lForm.maxButton := false;
	lForm.minButton := false;
	lForm.handleMenusForModalDisplay();
	lForm.show;

epilog
	

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_callerForm" type="CM_BaseForm"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showVoyageManualMatchTBA" id="8ef73d3b-dbc6-448a-a714-e25e99bf81b8">
        <source>showVoyageManualMatchTBA(_tba : CM_TrackedItem; _masterMenuAction : CMUI_MenuAction);
/*
Purpose:	TFS 45590		
Date				Who			Reason
NOVEMBER 2019		JLGAB1 initial creation
*/

vars
	formCls					: Class;
	assistCls				: Class;
	voyageMatchForm			: CM_BaseForm;
	menuAction				: CMUI_MenuAction;
	subSys					: CMUI_SubSystem;
	term					: CM_Terminal;
	tmpDoCopy				: Boolean;
	tmpDoNewEdit			: Boolean;
	glbVoyageObj			: CM_VoyageGlobal;
	legOneFirstWaypoint		: HMS_HarbourRegion;
	legOneSecondWaypoint	: HMS_HarbourRegion;
	berthObj				: HMS_Berth;
	
begin
	subSys	:=	app.myController.allSubSystems['ShipSchema'];
	
	if subSys &lt;&gt; null then
		subSys.getFormDetails('SHP_TBAManualMatch', formCls, assistCls);	
	endif;
	
	if formCls = null then
		return;
	endif;

	if _tba &lt;&gt; null then
		term	:=	_tba.myTerminal;
	else
		term	:=	self.myTerminal;
	endif;
	
	voyageMatchForm	:=	app.loadForm(formCls, assistCls, false, false, true, term, _masterMenuAction).CM_BaseForm;
	
	if voyageMatchForm = null then
		return;
	endif;

	voyageMatchForm.setPropertyValue("myTBAItem",_tba);
	voyageMatchForm.show();
end;</source>
        <Parameter name="_tba" type="CM_TrackedItem"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
    <JadeMethod name="showVoyageMovementsForm" id="c0aceef8-d320-4096-8dc1-27a029987bde">
        <source>showVoyageMovementsForm(_movement : HMS_VoyageMovement; _resUsed : HMS_ResourceUsed; _doEdit : Boolean; _terminal : CM_Terminal; _harbour : HMS_Harbour);
//--------------------------------------------------------------
//Created: June 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	formCls,
	assistCls	: Class;
	movementFrm : CM_BaseForm;
	subSys : CMUI_SubSystem;
	term : CM_Terminal;
	
begin
	subSys := app.myController.allSubSystems['HmsSchema'];
	
	if subSys &lt;&gt; null then
		subSys.getFormDetails('HMS_VoyageMovementForm', formCls, assistCls);
	endif;

	term := _terminal;
	
	if term = null then
		if _harbour &lt;&gt; null then
			term := _harbour.allTerminalsByCode.first;
		endif;
		
		if term = null then
			term := app.getMyTerminalDO_NOT_USE();
		endif;
	endif;

	movementFrm := app.loadForm(formCls, assistCls, false, false, false, term, null).CM_BaseForm;

	if movementFrm = null then
		return;
	endif;

	movementFrm.setPropertyValue("myInitResourceUsed", _resUsed); // CCMS 1350
	movementFrm.showWithObjectMode(_movement, _doEdit);
end;</source>
        <Parameter name="_movement" type="HMS_VoyageMovement"/>
        <Parameter name="_resUsed" type="HMS_ResourceUsed"/>
        <Parameter name="_doEdit" type="Boolean"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
    </JadeMethod>
    <JadeMethod name="showVoyagePlanningForm" id="4916906f-e0ec-478f-b22a-b8282f8a5646">
        <source>showVoyagePlanningForm(_voyage : CM_Voyage; _bay : CM_Bay input; _displayMode : Integer;_menuAction : CMUI_MenuAction );
// ---------------------------------------------------------------------------
// Created:		November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	plnForm : Form;
	menuAction : CMUI_MenuAction;	enqForm : Form;
	aClass : Class;
	jrw : Schema;
	rowStr	: String;
	obj : Object;
	gRow : CM_GridRow;
	rows : CM_ObjectArray;
begin
	jrw := rootSchema.getSchema("ShipSchema");
	aClass := jrw.getClass("SHP_VoyageAreaForm2");
	if _voyage = null then
		return;
	endif;
	plnForm := app.getForm(aClass.name);
	if plnForm = null then
		plnForm := app.loadForm(aClass, CMUI_Assistant, false, false, true, self.myTerminal, _menuAction);
		if plnForm = null then
			return;
		endif;
	endif;

	if _bay &lt;&gt; null then		
		plnForm.setPropertyValue("myStartUpBay",_bay);
	endif;

	plnForm.setPropertyValue("myCurrentVoyage",_voyage);
	plnForm.setPropertyValue("displayModeHistory",_displayMode); 
	plnForm.show();

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_bay" type="CM_Bay" usage="input"/>
        <Parameter name="_displayMode" type="Integer"/>
        <Parameter name="_menuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
    <JadeMethod name="showVoyageResourceUsedForm" id="fbadd857-337e-4de2-81a1-71e31b22481b">
        <source>showVoyageResourceUsedForm(_object : Object; _masterMenuAction : CMUI_MenuAction; _isModal : Boolean);
// ---------------------------------------------------------------------------
// Created:		August 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 06/04/2017	cnwdap1		TFS 4010 PKT Voyage Resources Used giving 1011 error
vars
	resForm : Form;
	menuAction : CMUI_MenuAction;
	inv : CM_Invoice;
	assistClass,aClass : Class;
	jrw : Schema;
	jrwGlobal : Class;
	jrwGlobalObject : Object;
	path,
	fileName	: String;
	pos		: Integer;
	
	
begin
	jrw := rootSchema.getSchema("HmsSchema");
	assistClass := jrw.getClass("HMS_Assistant");
	
	if _isModal then
		aClass := jrw.getClass("HMS_VoyageResourceUsedNonMDI");
	else
		aClass := jrw.getClass("HMS_VoyageResourceUsedForm");
	endif;
	
	if not _object.isKindOf(CM_Voyage)  and _object &lt;&gt; null and not _object.isKindOf(CMIF_HMS_WorkingVoyage)then
		return;
	endif;

	if _isModal then
		resForm := app.loadForm(aClass, assistClass, false, false, true, self.myTerminal, _masterMenuAction);
	else
		resForm := app.loadForm(aClass, CMUI_Assistant, false, false, true, self.myTerminal, _masterMenuAction);
	endif;
	if resForm = null then
		return;
	endif;

	if _object.isKindOf(CMIF_HMS_WorkingVoyage) then
		resForm.setPropertyValue("myCurrentVoyage", _object.CMIF_HMS_WorkingVoyage.myHMSVoyageData.myVoyage);
	else
		resForm.setPropertyValue("myCurrentVoyage", _object);
	endif;
	//resForm.setPropertyValue("isModal", _isModal);							// TFS 4010
	resForm.setPropertyValue(CM_BaseForm::isBaseFormModal.name, _isModal);		// TFS 4010
	resForm.show(); 

end;</source>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_isModal" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showVoyageStatistcsForm" id="d25ff844-857c-4286-948a-bc30f8591ebf">
        <source>showVoyageStatistcsForm(_harbour : HMS_Harbour; _masterMenuAction : CMUI_MenuAction; _terminal : CM_Terminal);
//--------------------------------------------------
// Created:	18 July 2005 By: cnwgd1
//--------------------------------------------------
vars
	formCls,
	assistCls	: Class;
	voyageStatisticsForm : CM_BaseForm;
	menuAction : CMUI_MenuAction;
	subSys : CMUI_SubSystem;
begin

	subSys := app.myController.allSubSystems['HmsSchema'];
	
	if subSys &lt;&gt; null then
		subSys.getFormDetails('HMS_VoyageStatisticsForm', formCls, assistCls);
	endif;
	
	if formCls = null then
		return;
	endif;

	voyageStatisticsForm := app.loadForm(formCls, assistCls, false, false, true, _terminal, _masterMenuAction).CM_BaseForm;
	if voyageStatisticsForm = null then
		return;
	endif;	
	
	voyageStatisticsForm.showWithObjectMode(_harbour, null);

end;</source>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="showVoyageStatusEmailOptions" id="e835ad84-cd02-408b-ab05-67955f1c6008">
        <source>showVoyageStatusEmailOptions(_emailDefault: CM_VoyStatusDefaultEmail; _sending: Boolean) : Integer;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 09/03/2018	jlgdap1		Initial creation TFS 37427 PEL1 Voyage Status Enhancements
//
vars
	form			: CMUI_VoyStatusEmailForm;
	canView			: Boolean;
	canMaintain		: Boolean;
	limitedUpdate	: Boolean;

begin
	canView := app.myPassport.myUser.canDo(self.myTerminal, PmAdmVSEmailDefaultView);
	canMaintain := app.myPassport.myUser.canDo(self.myTerminal, PmAdmVSEmailDefaultMaint);
	
	if not (canView or canMaintain) then
		//just return OK - send default email
		app.msgBox("You do not have the permissions required for viewing or modifying the email defaults.","E-mail Options",null);
		return IDOK;
	endif;

	if _emailDefault = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'email defaults is null from form');
		return IDCANCEL;
	endif;
	
	if not _emailDefault.enabled then
		app.msgBox("Voyage Status emails have not been enabled.", "E-mail Options", MsgBox_OK_Only);
		return IDCANCEL;
	endif;
	
	if canMaintain then
		limitedUpdate := false;
	else
		limitedUpdate := true;
	endif;
	
	create form;
	form.setAssistantAndTerminalRefs(self, self.myTerminal);
	form.setCaption(form.caption &amp; ' Options - ' &amp; _emailDefault.name);
	form.setupForVoyageStatus(_emailDefault, limitedUpdate, _sending);
	form.centreWindow;
	form.showModal();
	
	return form.modalResult;

epilog

end;</source>
        <Parameter name="_emailDefault" type="CM_VoyStatusDefaultEmail"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showWagonClass" id="a213ba11-2ca5-410c-ad10-a7e8e33a865b">
        <source>showWagonClass( _wagonClass : CM_WagonClass; _callingForm : CM_BaseForm; _viewOnly : Boolean ):CM_WagonClass;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 August 2009	cnwndl1	Initial creation

*/

vars

	wagonClassForm : CM_BaseForm;
	subSys : CMUI_SubSystem;
	formCls	: Class;
	assistCls : Class;
	wagonClass : CM_WagonClass;
	
begin

	subSys := app.myController.allSubSystems['SysOpsSchema'];
	
	if subSys &lt;&gt; null then
		subSys.getFormDetails('SOP_WagonPositionRuleFormModal', formCls, assistCls);
	endif;
	
	if formCls = null then
		return null;
	endif;

	wagonClassForm := app.loadForm(formCls, assistCls, false, false, false, null, null).CM_BaseForm;
	if wagonClassForm = null then
		return null;
	endif;
	
	wagonClassForm.showWithObjectMode(_wagonClass, _viewOnly);
	wagonClassForm.showModal();
	
	wagonClass := wagonClassForm.getPropertyValue("myRealWagonClass").CM_WagonClass;		// cheap and dirty but no option... NDL Par 22342

	return wagonClass;
	
epilog

end;</source>
        <Parameter name="_wagonClass" type="CM_WagonClass"/>
        <Parameter name="_callingForm" type="CM_BaseForm"/>
        <Parameter name="_viewOnly" type="Boolean"/>
        <ReturnType type="CM_WagonClass"/>
    </JadeMethod>
    <JadeMethod name="showWagonMasterCargoRestrict" id="adfb45e7-6675-48e2-8d23-938a1e257f88">
        <source>showWagonMasterCargoRestrict( _wagon : CM_Wagon; _wagonMaster : CM_WagonMaster; _term : CM_Terminal; _parentForm : CM_BaseForm );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 February 2014	cnwndl1	Initial creation	Par 33439 / CCMS 2311

*/

vars

	form : CMUI_ObjectCriteriaListForm;
	wagonMaster : CM_WagonMaster;

begin

	if _wagonMaster = null then
		if _wagon &lt;&gt; null then
			wagonMaster := _wagon.myWagonMaster;
		endif;
	else
		wagonMaster := _wagonMaster;
	endif;
	
	if wagonMaster &lt;&gt; null then
		
		create form transient;
		form.setBaseData(	null,	//_parentForm : CM_BaseForm;
							wagonMaster,	//_contextObject : CM_Object;
							CM_ObjectMatchCriteria.WagonRestrictionInt //_context : Integer
							);
		if _parentForm &lt;&gt; null then
	//		form.setParentForm( _parentForm );
		endif;
		form.showModal();

		
	endif;

epilog

end;</source>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="_wagonMaster" type="CM_WagonMaster"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_parentForm" type="CM_BaseForm"/>
    </JadeMethod>
    <JadeMethod name="showWeighForm" id="15fb8f4b-7f32-4fe2-91ac-eb9b1d964d40">
        <source>showWeighForm( _parentForm : CM_BaseForm; _obj : CM_Object; _id : String; _extraObject : CM_Object );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars

	form : CM_BaseForm;
	objArray : ObjectArray;
	msg : String;

begin

	form := app.loadForm(CMUI_WeightsForm, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_WeightsForm;
	if form = null then
		// will have raised an error.
		return;
	endif;
			
	if _parentForm &lt;&gt; null then
		create objArray transient;
		if not _parentForm.getWeighFormObjects( _obj, objArray ) then
			return;
		endif;
		
		//08 Jul 2019	NDL	TFS 44965
		if _extraObject &lt;&gt; null then
			if not _extraObject.isWeighBridgeWeighable( objArray, msg ) then
				app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
				return;
			endif;
		endif;
		
	else
		msg := app.getErrorString(No_Associated_form) &amp; CrLf &amp; method.qualifiedName;
		app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
	
	endif;
	
	form.setParentForm( _parentForm );	//22 Jul 2016	NDL	TFS 2331
	form.CMUI_WeightsForm.setBaseData( objArray, _id );
//	form.setParentForm( _parentForm );
	form.showModal;
	
epilog

	delete objArray;

end;</source>
        <Parameter name="_parentForm" type="CM_BaseForm"/>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_extraObject" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="showWorkOrderForm" id="428a0d9d-bc19-4742-b69e-b9ab6365ea77">
        <source>showWorkOrderForm( _workOrder: CM_WorkOrder; _masterMenuAction: CMUI_MenuAction;_terminal :CM_Terminal);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 January 2010	cnwrd1	Initial creation

*/

vars

	subSys : CMUI_SubSystem;
	formCls,
	assistCls: Class;
	workOrderForm : CM_BaseForm;
begin
	subSys := app.myController.allSubSystems['YardSchema'];
	
	if subSys &lt;&gt; null then
		subSys.getFormDetails('YRD_TaskJobMaintForm', formCls, assistCls);
	endif;
	if formCls = null then
		return;
	endif;
	if _workOrder = null then
		app.msgBox(app.getErrorString1(NothingSelected,"WorkOrder"),"WorkOrder" ,MsgBox_OK_Only);
		return;
	endif;
	workOrderForm := app.loadForm(formCls, 
							assistCls, 
							false, 
							false,
							false, 
							_terminal,
							_masterMenuAction).CM_BaseForm;	

	if workOrderForm = null then
		return;
	endif;
	workOrderForm.setFormObject(_workOrder);
	workOrderForm.show;
	

	
epilog

end;</source>
        <Parameter name="_workOrder" type="CM_WorkOrder"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="showWorkPointHrsForm" id="c795667d-81e2-46b3-badf-48d489379822">
        <source>showWorkPointHrsForm( _voyage : CM_Voyage; _opHrs : CM_WorkPointOperatingHours; _crane : CM_Crane; _workPoint : CM_WorkPoint );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars

	form : CM_TableViewForm;
	class : Class;

begin

	class := rootSchema.getSchema("ShipSchema").getClass("SHP_CraneOperatingHoursForm");

	form := app.loadForm(class, CMUI_Assistant, false, false, false, self.myTerminal, null).CM_TableViewForm;
	
	if form &lt;&gt; null then
		if _crane &lt;&gt; null then
			form.setSecondaryObject( _crane );
		elseif _workPoint &lt;&gt; null then
			form.setSecondaryObject( _workPoint );
		endif;
		if _opHrs &lt;&gt; null then
			form.showWithObject(_opHrs, false, false);
		elseif _voyage &lt;&gt; null then
			form.showWithObject(_voyage, false, false);
		else
			form.show();
		endif;
	endif;


epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_opHrs" type="CM_WorkPointOperatingHours"/>
        <Parameter name="_crane" type="CM_Crane"/>
        <Parameter name="_workPoint" type="CM_WorkPoint"/>
    </JadeMethod>
    <JadeMethod name="showXTABDisplayForm" id="ff452701-6fe6-41d8-a7dc-cec9a5e4759f">
        <source>showXTABDisplayForm(
	_proxyFormat		: CM_OutputFormat_XTAB;
	_realFormat			: CM_OutputFormat_XTAB;
	_expectedEdition	: Integer;
	_collection			: ObjectSet;
	_isVoyageCCMode : Boolean);

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
19 January 2009		cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)

*/
	
vars
	form	: CMUI_XTABDisplayForm;
	
begin
	form	:= app.loadForm(	CMUI_XTABDisplayForm,
								CMUI_Assistant,
								false,							// Maximized
								false,							// Show
								false,							// Modal
								self.myTerminal,
								null ).CMUI_XTABDisplayForm;
	
	// set the format and collection for the form
	form.initialise( _proxyFormat, _realFormat, _expectedEdition , _collection );
	form.isVoyageCCMode := _isVoyageCCMode; // PAR 21746
	form.show;
	
epilog
	
end;
</source>
        <Parameter name="_proxyFormat" type="CM_OutputFormat_XTAB"/>
        <Parameter name="_realFormat" type="CM_OutputFormat_XTAB"/>
        <Parameter name="_expectedEdition" type="Integer"/>
        <Parameter name="_collection" type="ObjectSet"/>
        <Parameter name="_isVoyageCCMode" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showXTABSummaryDefinitionForm" id="9a3686cd-2c72-42f1-b120-a63f6e759d66">
        <source>showXTABSummaryDefinitionForm( _coll : Collection; _showExpanded, _isSnapshot,  _isVoyageCCMode: Boolean; _showWarning : Boolean );

/*

Purpose:		CCMS SFW 1047 - Totals Only Lists
				Displays the XTAB definition form ready for user to select a summary
Parameters:		_coll is the collection of objects to be used in the summary display.
				_showExpanded of false means that the hideDetails is run else showDetails is run.
				
Return Value:	

Date				Who		Reason
16 January 2009		cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)
							Copy of Christina's (concms1) doSummariseResults on CM_BaseForm.
14/12/2009			cnwcs5	ccms 1023 - snapshot summaries
*/
	
vars
	form	: CMUI_XTABDefinitionForm;
	cls		: Class;	// cnwcs5 14/12/2009
	
begin
	if _showWarning and _coll.isEmpty then
		if app.msgBox(	app.getErrorString( SummaryDefn_PassedAnEmptyColl ),
						app.getErrorString( Warning ),
						MsgBox_OK_Cancel + MsgBox_Default_First ) = MsgBox_Return_Cancel then
			return;
		endif;

	endif;
	
	if _isSnapshot then						// cnwcs5 14/12/2009
		cls := CMUI_XTABDefinitionForm_SS;	// cnwcs5 14/12/2009
	else									// cnwcs5 14/12/2009
		cls := CMUI_XTABDefinitionForm;		// cnwcs5 14/12/2009
	endif;									// cnwcs5 14/12/2009
	
	form	:= app.loadForm(	cls,		// cnwcs5 14/12/2009
								CMUI_Assistant,
								false,							// Maximized
								false,							// Show
								false,							// Modal
								self.myTerminal,
								null ).CMUI_XTABDefinitionForm;
	
	if form = null then
		// must of had a security issue.
		return;
	endif;
	
	// set the collection and how to initially display the form
	form.initialise( _coll, _showExpanded );
	form.isVoyageCCMode := _isVoyageCCMode; // PAR 21746
	form.show;
	
epilog
	
end;
</source>
        <Parameter name="_coll" type="Collection"/>
        <Parameter name="_showExpanded" type="Boolean"/>
        <Parameter name="_isSnapshot" type="Boolean"/>
        <Parameter name="_isVoyageCCMode" type="Boolean"/>
        <Parameter name="_showWarning" type="Boolean"/>
    </JadeMethod>
