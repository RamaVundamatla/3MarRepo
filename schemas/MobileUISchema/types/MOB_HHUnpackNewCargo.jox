<GUIClass name="MOB_HHUnpackNewCargo" id="f22317a8-585f-4768-a85a-67a93cebde2e">
    <superclass name="MOB_HHTruckCargo"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <JadeMethod name="createNewTrackedItem" id="321f43e2-7ad8-4a55-95f0-98ef0dd5d287">
        <updating/>
        <source>createNewTrackedItem():Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07/07/2011	cnwndl1	Initial creation
26/06/2012	cnwdap1	PAR #29735 New parameter for CM_TrackedItem::setBookingRefAndItem method
*/

vars
	
	term : CM_Terminal;
	cargoType : CM_CargoType;
	id : String;
	row : Integer;
	fieldName : String;
	pxyTI : CM_TrackedItem;
	operator : CM_Operator;
	commodity : CM_Commodity;
	commodityCode : String;
	imex : CM_IMEXStatus;
	voyage : CM_Voyage;
	weightTotal : Decimal [14,4];
	destination : CM_Port;
	discharge : CM_Port;
	subT : CM_SubTerminal;
	isoType : CM_ISOType;
	freightForwarderCode : String;
	bookingNumber : String;
	bookingRef : CM_BookingRef;
	bookingRefItem : CM_BookingRefItem;
	consignorCode : String;
	length : Decimal [14,4];
	width : Decimal [14,4];
	height : Decimal [14,4];
	quantity : Integer;
	subCargo : CM_Product;
	volume : Decimal [14,4];
	carriageTempC : Real;
	packTempC : Real;
	packTempF : Real;
	ti : CM_TrackedItem;
	mess : String;
	pxyContainer : CM_TrackedItem;
	str : String;
	
	//30 Aug 2013	NDL	Par 32368
	volumeRow : String;
	weightRow : String;
	lengthRow : String;
	widthRow : String;
	heightRow : String;
	product : CM_Product;
	colour : String;
	mark : String;
	totalQuantity : Integer;
	
begin

	term := self.myTerminal;
	
	cargoType := self.cmbType.listObject.CM_CargoType;
	if cargoType = null then
		row := tblCargo.getRow(ETRow_CargoType);
		fieldName := tblCargo.getCellText(row,1);
	//	self.msgBox( app.getErrorString1( REQUIRED_FIELD, fieldName ) , app.getErrorString(Error), MsgBox_OK_Only, true );
		self.msgBox( app.getErrorString1( Input_required_field_Required, fieldName ) , app.getErrorString(Error), MsgBox_OK_Only, true ); // cnwdb2	PAR 35364

		self.setErrorPostionFor( ETRow_CargoType );
		return false;
	endif;

	id := getStringValueFromTable( ETRow_CargoId ).toUpper.trimBlanks;
	if id = null then
		row := tblCargo.getRow(ETRow_CargoId);
		fieldName := tblCargo.getCellText(row,1);
	//	self.msgBox( app.getErrorString1( REQUIRED_FIELD, fieldName ) , app.getErrorString(Error), MsgBox_OK_Only, true );
		self.msgBox( app.getErrorString1( Input_required_field_Required, fieldName ) , app.getErrorString(Error), MsgBox_OK_Only, true ); // cnwdb2	PAR 35364

		self.setErrorPostionFor(ETRow_CargoId );
		return false;
	elseif id.length &gt; 20 then
		//27 Nov 2015	NDL	Par 37124
		self.msgBox( app.getErrorString2( Field_Value_Too_Long, fieldName, "20" ) , app.getErrorString(Error), MsgBox_OK_Only, true ); // cnwdb2	PAR 35364
		self.setErrorPostionFor(ETRow_CargoId );
		return false;
	endif;
	
	pxyTI := term.createTI(cargoType, true);
	pxyTI.zSetPxyId(id);
	pxyTI.zSetPxyTerminal(term);
	pxyTI.setCargoType(cargoType.id);
	
	operator := cmbOperator.listObject.CM_Operator;
	if operator = null then
		if self.myMobileGenericAgent.myUnpackTi &lt;&gt; null then
			operator := self.myMobileGenericAgent.myUnpackTi.myOperator;
		endif;
	endif;
	
	if operator &lt;&gt; null then
		pxyTI.setMyOperator(operator);
	else
		row := tblCargo.getRow(ETRow_VoyageOperator);
		fieldName := tblCargo.getCellText(row,1);
	//	self.msgBox( app.getErrorString1( REQUIRED_FIELD, fieldName ) , app.getErrorString(Error), MsgBox_OK_Only, true );
		self.msgBox( app.getErrorString1( Input_required_field_Required, fieldName ) , app.getErrorString(Error), MsgBox_OK_Only, true ); // cnwdb2	PAR 35364

		self.setErrorPostionFor(ETRow_Operator);
		return false;
	endif;
	
	commodity := cmbCommodity.listObject.CM_Commodity;
	if cargoType.defaultCommodityCode &lt;&gt; null then
		commodityCode := cargoType.defaultCommodityCode;
	else
		commodityCode := "MT"; // used in subterminal code further down too.
	endif;
	if commodity &lt;&gt; null then
		commodityCode := commodity.code;
		pxyTI.setCommodity(commodity.code);
	endif;
	
	imex := self.cmbImexStatus.listObject.CM_IMEXStatus;
	if imex = null then
		if self.myMobileGenericAgent.myUnpackTi &lt;&gt; null then
			imex := self.myMobileGenericAgent.myUnpackTi.getImExStatusObject;
		endif;
	endif;
	if imex &lt;&gt; null then
		pxyTI.setImExStatus( imex.code );
	else
		row := tblCargo.getRow(ETRow_ImexStatus);
		fieldName := tblCargo.getCellText(row,1);
	//	self.msgBox( app.getErrorString1( REQUIRED_FIELD, fieldName ) , app.getErrorString(Error), MsgBox_OK_Only, true );
		self.msgBox( app.getErrorString1( Input_required_field_Required, fieldName ) , app.getErrorString(Error), MsgBox_OK_Only, true ); 

		self.setErrorPostionFor(ETRow_ImexStatus);
		return false;
	endif;
	
	voyage := cmbVoyage.listObject.CM_Voyage;
	if voyage &lt;&gt; null then
		pxyTI.setMyVoyage(voyage, app.myPassport);
	endif;
	
	pxyTI.changeState(TI_STATE_NORMAL, app.myPassport);
	
//	
	
	//weightTotal := getStringValueFromTable( ETRow_TotalWeight ).Decimal;
	//weightRow := Prefix_Weight &amp; ETRow_TotalWeight &amp; '_' &amp; self.getDefaultMeasurementForType(product, Type_Weight).shortName;
//	weightRow := Prefix_Weight &amp; ETRow_TotalWeight &amp; '_' &amp; cargoType.getMeasurementTypeFor(Type_Weight,true).shortName;
//	weightTotal := self.getStringValueFromTable( weightRow ).Decimal;
	weightTotal := self.getConvertedWeight;
	if weightTotal &gt; 0 then
		pxyTI.setTotalWeight(weightTotal, null, app.myPassport);
	endif;
	
	//pxyTI.zSetPxyCompany(term.getConfig(DefCompany).CM_Bank);
	pxyTI.zSetPxyCompany(term.getDefaultCompanyBank);//17 Apr 2012 NDL	Par 29393
		
	destination := cmbDestination.listObject.CM_Port;
	if destination &lt;&gt; null then
		pxyTI.zSetPxyDestinationPort(destination.code);
	endif;
	
	discharge := cmbDischarge.listObject.CM_Port;
	if discharge &lt;&gt; null then
		pxyTI.zSetPxyDischargePort(discharge.code);
	endif;
		
	if app.isSubTerminalsOn(self.myTerminal) then
		subT := term.getDefaultSubTerminal(CM_SubTerminal.Type_TrackedItem,
																0,	
																TI_IMEX_STATUS_IMPORT,
																commodityCode,
																true); 
		pxyTI.setSubTerminal(subT,null);
	endif;
	
	isoType := cmbISOType.listObject.CM_ISOType;
	if isoType &lt;&gt; null and pxyTI.isContainer then
		pxyTI.zSetPxyISOType( isoType.code );
	endif;
	
	freightForwarderCode := getStringValueFromTable( ETRow_FreightForwarder );
	if freightForwarderCode &lt;&gt; null then
		pxyTI.zSetPxyFreightFowarderCode(freightForwarderCode);
	endif;

	if self.cmbBRItem.listObject &lt;&gt; null then
		bookingRefItem := self.cmbBRItem.listObject.CM_BookingRefItem;
		bookingRef := bookingRefItem.myBookingReference;				
		consignorCode := bookingRef.consignorCode;
		//pxyTI.setBookingRefAndItem(bookingRef, bookingRefItem, app.myPassport);		// PAR #29735
		pxyTI.setBookingRefAndItem(bookingRef, bookingRefItem, false, app.myPassport);	// PAR #29735
		pxyTI.zSetPxyConsignor(consignorCode);
	else
		bookingNumber := getStringValueFromTable( ETRow_BookingReference );
		pxyTI.zSetPxyBookingReference(bookingNumber);
	endif;
	
	product := self.getProductForMeasurementType();
	
	//length := getStringValueFromTable( ETRow_Length ).Decimal;
	lengthRow := Prefix_Linear &amp; ETRow_Length &amp; '_' &amp; self.getDefaultMeasurementForType(product, Type_Length).shortName;
	length := self.getStringValueFromTable( lengthRow ).Decimal;
	if length &gt; 0 then
		pxyTI.zSetPxyLength( length );
	endif;
	
	//width := getStringValueFromTable( ETRow_Width ).Decimal;
	widthRow := Prefix_Linear &amp; ETRow_Width &amp; '_' &amp; self.getDefaultMeasurementForType(product, Type_Width).shortName;
	width := self.getStringValueFromTable( widthRow ).Decimal;
	if width &gt; 0 then
		pxyTI.zSetPxyWidth( width );
	endif;
	
	//height := getStringValueFromTable( ETRow_Height ).Decimal;
	heightRow := Prefix_Linear &amp; ETRow_Height &amp; '_' &amp; self.getDefaultMeasurementForType(product, Type_Height).shortName;
	height := self.getStringValueFromTable( heightRow ).Decimal;
	if height &gt; 0 then
		pxyTI.zSetPxyHeight( height );
	endif;
	
//	volume := getStringValueFromTable( ETRow_Volume ).Decimal;
//	volumeRow := Prefix_Volume &amp; ETRow_TotalVolume &amp; '_' &amp; self.getDefaultMeasurementForType(product, Type_Volume).shortName;
	volumeRow := Prefix_Weight &amp; ETRow_TotalVolume &amp; '_' &amp; cargoType.getMeasurementTypeFor(Type_Volume,true).shortName;
	volume := self.getStringValueFromTable( volumeRow ).Decimal;
	if volume &gt; 0 then
		pxyTI.zSetPxyTotalVolume(volume);
	endif;
	
	quantity := getStringValueFromTable( ETRow_Quantity ).Integer;
	if quantity &gt; 0 then
		pxyTI.zSetPxyQuantity( quantity );
	endif;
	
	subCargo := cmbSubCargo.listObject.CM_Product;
	if subCargo &lt;&gt; null then
		pxyTI.zSetPxyProductCode(subCargo.code);
		pxyTI.setMyProduct(subCargo);
	endif;
	
	if ( pxyTI.isContainer &lt;&gt; null and isoType.isReefer ) or ( subCargo &lt;&gt; null and subCargo.isReefer ) or ( cargoType &lt;&gt; null and cargoType.mySystemProductType &lt;&gt; null and cargoType.mySystemProductType.isReefer ) then	// PAR #22938
		
		str :=  getStringValueFromTable( ETRow_CarriageTempC );
		if str.trimBlanks = null then
			pxyTI.setTemperature(NULL_TEMPERATURE);
		else
			carriageTempC := str.Real;
			pxyTI.setTemperature(carriageTempC);
		endif;
		
		str :=  getStringValueFromTable( ETRow_PackTempC );
		if str.trimBlanks = null then
			pxyTI.setPackTempC(NULL_TEMPERATURE.String);
		else
			packTempC := str.Real;
			pxyTI.setPackTempC(packTempC.String);
		endif;
		
		str :=  getStringValueFromTable( ETRow_PackTempF );
		if str.trimBlanks = null then
			pxyTI.setPackTempF(NULL_TEMPERATURE.String);
		else
			packTempF := getStringValueFromTable( ETRow_PackTempF ).Real;
			pxyTI.setPackTempF(packTempF.String);
		endif;
	endif;
	
	//02 Sep 2013	NDL	Par 32368
	str :=  getStringValueFromTable( ETRow_Colour ).toUpper.trimBlanks;
	if str &lt;&gt; null then
		if pxyTI.isKindOf(CM_BreakBulkGeneric) then												
			pxyTI.CM_BreakBulkGeneric.setColour(str);
		elseif pxyTI.isKindOf(CM_Car) then	//23 Sep 2013	NDL	Par 32215												
			pxyTI.CM_Car.setColour(str);
		endif;
	endif;
	str :=  getStringValueFromTable( ETRow_Mark ).trimBlanks;
	if str &lt;&gt; null then
		pxyTI.setMark(str);
	endif;
	if pxyTI.isKindOf(CM_BreakBulkGeneric) then
		totalQuantity := getStringValueFromTable( ETRow_NumItems ).Integer;
		if totalQuantity &gt; 0 then
			pxyTI.setTotalQuantity(totalQuantity);
		endif;
		
		//06 Sep 2013	NDL	Par 32413
		str :=  getStringValueFromTable( ETRow_DimType ).trimBlanks;
		if str &lt;&gt; null then
			pxyTI.CM_BreakBulkGeneric.setPxyDimType( str );
		endif;
	
	endif;
	
	//23 Sep 2013	NDL	Par 32215
	if pxyTI.isKindOf(CM_Car) then
		str :=  getStringValueFromTable( ETRow_Make ).toUpper.trimBlanks;
		if str &lt;&gt; null then
			pxyTI.CM_Car.setMake(str);																							
		endif;
		str :=  getStringValueFromTable( ETRow_Model ).toUpper.trimBlanks;
		if str &lt;&gt; null then
			pxyTI.CM_Car.setModel(str);																							
		endif;
		str :=  getStringValueFromTable( ETRow_VehicleType ).toUpper.trimBlanks;
		if str &lt;&gt; null then
			pxyTI.CM_Car.setVehicleType(str);																							
		endif;
		str :=  getStringValueFromTable( ETRow_Year ).toUpper.trimBlanks;
		if str &lt;&gt; null and str.isInteger then
			pxyTI.CM_Car.setYear(str.Integer);																							
		endif;
	endif;
	
	//24 Sep 2013	NDL	Par 32556
	if pxyTI.isKindOf(CM_TILC) then
		pxyTI.CM_TILC.setMyType( self.cmbTrailerType.listObject.CM_TILCType );
	endif;
		
	app.myPassport.clearErrorsWarnings();
	app.myPassport.setWarningsIgnored(true);	
	
	while true do
		
		app.myTrxCA.trxCreateChildTrackedItem(	self.myMobileGenericAgent.myUnpackTi,	//_container : CM_TrackedItem input;	
												pxyTI,	//_pxyChildTI : CM_TrackedItem input;
												self.myTrackedItem,	//_realChildTI : CM_TrackedItem output;
												app.myPassport	//_passport : CM_Passport input
												);
		if app.myPassport.trxCompletedOK then
			break;
		else
			mess := app.myPassport.getAllErrorsWarningsAsString;
			if self.showErrorMessage(mess, app.myPassport.hasErrors()) then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
	endwhile;
	
	return true;
		
epilog


end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDataFromObject" id="3a763913-269b-42ff-b828-e9ce1fc193c5">
        <source>getDataFromObject(entTableRow: EntTableRowEntity; errMsg: String output): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 July 2011	cnwndl1	Initial creation	Par 26476

*/


vars
	dataValue : String;
	
begin

	if self.myMobileGenericAgent.myUnpackTi &lt;&gt; null then
		
		if entTableRow.name = ETRow_VoyageCode
		or entTableRow.name = ETRow_VoyageOperator
		or entTableRow.name = ETRow_Commodity
		then
			return self.getDataFromParent(	self.myMobileGenericAgent.myUnpackTi,	//parent : CM_TrackedItem;
											entTableRow,	//entTableRow: EntTableRow;
											errMsg	//errMsg: String output
											);
		endif;
		
		if entTableRow.name = ETRow_Location then
			if self.myMobileGenericAgent.myUnpackDefaultLocation &lt;&gt; null then
				return self.myMobileGenericAgent.myUnpackDefaultLocation.getFullId;
			endif;
			
		else
			
			dataValue := inheritMethod(entTableRow, errMsg);
		endif;
		
		return dataValue;
		
	endif;

	return inheritMethod(entTableRow, errMsg);

epilog

end;</source>
        <Parameter name="entTableRow" type="EntTableRowEntity"/>
        <Parameter name="errMsg" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDataFromParent" id="7a01158a-4ac2-4765-8494-f664d2b6aa60">
        <source>getDataFromParent(parent : CM_TrackedItem; entTableRow: EntTableRowEntity; errMsg: String output): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 September 2011	cnwndl1	Initial creation

*/

vars

begin
	
	if entTableRow.name = ETRow_VoyageCode then
		if parent.myVoyage &lt;&gt; null then
			return parent.myVoyage.code;
		endif;
	
	elseif entTableRow.name = ETRow_VoyageOperator then
		if parent.myOperator &lt;&gt; null then
			return parent.myOperator.code;
		endif;
		
	elseif entTableRow.name = ETRow_Commodity then
		return parent.commodity;
		
	elseif entTableRow.name = ETRow_BookingReference then
		return parent.bookingReference;
		
	elseif entTableRow.name = ETRow_BookingReferenceItem then
		if parent.myBookingRefItem &lt;&gt; null then
			return parent.myBookingRefItem.getDisplayString;
		endif;
		
	elseif entTableRow.name = ETRow_ImexStatus then
		return parent.getImExStatusString;
		
	elseif entTableRow.name = ETRow_DischargePort then
		return parent.dischargePort;
		
	elseif entTableRow.name = ETRow_DestinationPort then
		return parent.destinationPort;
		
	elseif entTableRow.name = ETRow_FreightForwarder then
		return parent.freightForwarderCode;
		
	endif;
		
	return null;

epilog

end;</source>
        <Parameter name="parent" type="CM_TrackedItem"/>
        <Parameter name="entTableRow" type="EntTableRowEntity"/>
        <Parameter name="errMsg" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="resetEntTableIfRequired" id="ed34f96c-641b-4f66-bed6-2d12fab9387a">
        <updating/>
        <source>resetEntTableIfRequired(combobox: ComboBox input) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 September 2011	cnwndl1	Initial creation	
29 September 2016   cnwma1 TFSf #2764:UE 1090 in app MobileUISchema::HandHeldWithDevApp of CIGPJMT
*/

vars

	obj : Object;
	entTableRow : EntTableRowTransient;
	
	//28 Mar 2014	NDL	Par 33759
	lengthRow : String;
	widthRow : String;
	heightRow : String;
	volumeRow : String;
	weightRow : String;

	id : String;
	length : Decimal [16,4];
	width : Decimal [16,4];
	height : Decimal [16,4];
	volume : Decimal [16,4]; 
	weight : Decimal [16,4]; 
	quantity : Integer;
	totalQuantity : Integer;
	colour : String;
	mark : String;
	make : String;
	model : String;
	vehicleType : String;
	year : Integer;
	product : CM_Product;
	measureTbl : CMUI_MeasurementTable;
	measureType : CM_MeasurementType;
	cargoType : CM_CargoType;
	
begin

	product := self.getProductForMeasurementType();
	cargoType := self.getCargoTypeForMeasurementType();

	lengthRow := Prefix_Linear &amp; ETRow_Length &amp; '_' &amp; self.getDefaultMeasurementForType(product, Type_Length).shortName;
	widthRow := Prefix_Linear &amp; ETRow_Width &amp; '_' &amp; self.getDefaultMeasurementForType(product, Type_Width).shortName;
	heightRow := Prefix_Linear &amp; ETRow_Height &amp; '_' &amp; self.getDefaultMeasurementForType(product, Type_Height).shortName;
//	volumeRow := Prefix_Volume &amp; ETRow_TotalVolume &amp; '_' &amp; self.getDefaultMeasurementForType(product, Type_Volume).shortName;
//	weightRow := Prefix_Weight &amp; ETRow_TotalWeight &amp; '_' &amp; self.getDefaultMeasurementForType(product, Type_Weight).shortName;
	if cargoType = null then
		volumeRow := Prefix_Volume &amp; ETRow_TotalVolume &amp; '_' &amp; self.getDefaultMeasurementForType(product, Type_Volume).shortName;
		weightRow := Prefix_Weight &amp; ETRow_TotalWeight &amp; '_' &amp; self.getDefaultMeasurementForType(product, Type_Weight).shortName;
	else
		volumeRow := Prefix_Volume &amp; ETRow_TotalVolume &amp; '_' &amp; cargoType.getMeasurementTypeFor(Type_Volume,true).shortName;
		weightRow := Prefix_Weight &amp; ETRow_TotalWeight &amp; '_' &amp; cargoType.getMeasurementTypeFor(Type_Weight,true).shortName;
	endif;

		// get the user entered values
	id := getStringValueFromTable( ETRow_CargoId ).toUpper.String;
	length := self.getStringValueFromTable( lengthRow ).Decimal;
	width := self.getStringValueFromTable( widthRow ).Decimal;
	height := self.getStringValueFromTable( heightRow ).Decimal;
	volume := self.getStringValueFromTable( volumeRow ).Decimal; 
	weight := self.getStringValueFromTable( weightRow ).Decimal; 
	quantity := getStringValueFromTable( ETRow_Quantity ).Integer;
	totalQuantity := getStringValueFromTable( ETRow_NumItems ).Integer;
	colour :=  getStringValueFromTable( ETRow_Colour ).String;
	mark :=  getStringValueFromTable( ETRow_Mark ).String;
	make :=  getStringValueFromTable( ETRow_Make ).String;
	model :=  getStringValueFromTable( ETRow_Model ).String;
	vehicleType :=  getStringValueFromTable( ETRow_VehicleType ).String;
	year :=  getStringValueFromTable( ETRow_Year ).Integer;
	
	inheritMethod(combobox);
	
	foreach obj in tblCargo.allEntRowTransients do
		entTableRow := obj.EntTableRowTransient;
		if entTableRow.name = ETRow_VoyageCode
		or entTableRow.name = ETRow_VoyageOperator
	//	or entTableRow.name = ETRow_Commodity	//28 Mar 2014	NDL	Par 33748
		or entTableRow.name = ETRow_BookingReference
		or entTableRow.name = ETRow_BookingReferenceItem
		or entTableRow.name = ETRow_ImexStatus
		or entTableRow.name = ETRow_DischargePort
		or entTableRow.name = ETRow_DestinationPort
		or entTableRow.name = ETRow_FreightForwarder
		or entTableRow.name = ETRow_Location
		then
			tblCargo.hideRowByName( entTableRow.name, false );
		endif;
	endforeach;	
	
	self.cmbVoyage.visible:=false;
	// try to put back any user entered values
	product := self.getProductForMeasurementType();
	cargoType := self.getCargoTypeForMeasurementType();

	lengthRow := Prefix_Linear &amp; ETRow_Length &amp; '_' &amp; self.getDefaultMeasurementForType(product, Type_Length).shortName;
	widthRow := Prefix_Linear &amp; ETRow_Width &amp; '_' &amp; self.getDefaultMeasurementForType(product, Type_Width).shortName;
	heightRow := Prefix_Linear &amp; ETRow_Height &amp; '_' &amp; self.getDefaultMeasurementForType(product, Type_Height).shortName;
	//volumeRow := Prefix_Volume &amp; ETRow_TotalVolume &amp; '_' &amp; self.getDefaultMeasurementForType(product, Type_Volume).shortName;
	//weightRow := Prefix_Weight &amp; ETRow_TotalWeight &amp; '_' &amp; self.getDefaultMeasurementForType(product, Type_Weight).shortName;
	if cargoType = null then
		volumeRow := Prefix_Volume &amp; ETRow_TotalVolume &amp; '_' &amp; self.getDefaultMeasurementForType(product, Type_Volume).shortName;
		weightRow := Prefix_Weight &amp; ETRow_TotalWeight &amp; '_' &amp; self.getDefaultMeasurementForType(product, Type_Weight).shortName;
	else
		volumeRow := Prefix_Volume &amp; ETRow_TotalVolume &amp; '_' &amp; cargoType.getMeasurementTypeFor(Type_Volume,true).shortName;
		weightRow := Prefix_Weight &amp; ETRow_TotalWeight &amp; '_' &amp; cargoType.getMeasurementTypeFor(Type_Weight,true).shortName;
	endif;
	
	
	self.tblCargo.setValueByName(ETRow_CargoId, id );
	self.tblCargo.setValueByName(ETRow_Quantity, quantity );
	self.tblCargo.setValueByName(ETRow_NumItems, totalQuantity );
	self.tblCargo.setValueByName(ETRow_Colour, colour );
	self.tblCargo.setValueByName(ETRow_Mark, mark );
	self.tblCargo.setValueByName(ETRow_Make, make );
	self.tblCargo.setValueByName(ETRow_Model, model );
	self.tblCargo.setValueByName(ETRow_VehicleType, vehicleType );
	self.tblCargo.setValueByName(ETRow_Year, year );
	
	measureTbl := self.allMeasurementControls[lengthRow].CMUI_MeasurementTable;

	if measureTbl &lt;&gt; null then
		measureType := self.getDefaultMeasurementForType(product, Type_Length);
		measureTbl.setValues( app.convertMeasurementForDisplay(measureType.shortName, length) &amp; Space &amp; measureType.shortName);
		measureTbl.lostFocus( measureTbl );
	endif;
	measureTbl := self.allMeasurementControls[widthRow].CMUI_MeasurementTable;
	if measureTbl &lt;&gt; null then
		measureType := self.getDefaultMeasurementForType(product, Type_Width);
		measureTbl.setValues( app.convertMeasurementForDisplay(measureType.shortName, width) &amp; Space &amp; measureType.shortName);
		measureTbl.lostFocus( measureTbl );
	endif;
	measureTbl := self.allMeasurementControls[heightRow].CMUI_MeasurementTable;
	if measureTbl &lt;&gt; null then
		measureType := self.getDefaultMeasurementForType(product, Type_Height);
		measureTbl.setValues( app.convertMeasurementForDisplay(measureType.shortName, height) &amp; Space &amp; measureType.shortName);
		measureTbl.lostFocus( measureTbl );
	endif;
	measureTbl := self.allMeasurementControls[volumeRow].CMUI_MeasurementTable;
	if measureTbl &lt;&gt; null  then
		if cargoType &lt;&gt; null then 													//29/09/16 cnwma1 TFS #2674
			measureType := cargoType.getMeasurementTypeFor(Type_Volume,true);		
		else
			measureType := app.getDefaultMeasurementForType( Type_Volume );        //29/09/16 cnwma1 TFS #2674
		endif;
		measureTbl.setValues( app.convertMeasurementForDisplay(measureType.shortName, volume) &amp; Space &amp; measureType.shortName);
		measureTbl.lostFocus( measureTbl );
	endif;
		
		
	
	measureTbl := self.allMeasurementControls[weightRow].CMUI_MeasurementTable;
	if measureTbl &lt;&gt; null  then
		if cargoType &lt;&gt; null then 													//29/09/16 cnwma1 TFS #2674
			measureType := cargoType.getMeasurementTypeFor(Type_Weight,true);	
		else
			measureType := app.getDefaultMeasurementForType( Type_Weight );        //29/09/16 cnwma1 TFS #2674
		endif;
		measureTbl.setValues( app.convertMeasurementForDisplay(measureType.shortName, weight) &amp; Space &amp; measureType.shortName);
		measureTbl.lostFocus( measureTbl );
		
	endif;

	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="saveChanges" id="f13639f1-6785-424f-b90a-4355e1ec033d">
        <updating/>
        <source>saveChanges(_fromChecks: Boolean): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

	tmpFoundLC: CM_LocationsController;
	errMess : String;

begin
	
	if not self.MOB_HHUnpackNewCargo.createNewTrackedItem() then
		return false;
	endif;
	
	self.myMobileGenericAgent.setPackContainerDetails(	self.myMobileGenericAgent.myPackStockBookingRef,	//_stockBookingRef : CM_BookingRef;
															self.myMobileGenericAgent.myPackStockBookingItem,	//_stockBookingRefItem : CM_BookingRefItem;
															self.myMobileGenericAgent.myPackExportBookingRef,	//_exportBookingRef : CM_BookingRef;
															self.myMobileGenericAgent.myPackExportBookingItem,	//_exportBookingRefItem : CM_BookingRefItem;
															self.myTrackedItem	//_trackedItem : CM_TrackedItem
															);

	return true;

epilog

end;</source>
        <Parameter name="_fromChecks" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
