    <JadeMethod name="getNextAvailableLocation" id="2831e00b-d692-4c8e-81c1-86f093e220a7">
        <source>getNextAvailableLocation(_mode : Integer): CM_GridController;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 June 2010	cnwmd1	Initial creation
02 Feb 2015 cnwab1	added _mode
*/

vars
	targetLocn : CM_GridController;
	found : Boolean;
	direction : CM_YADeckingRule;
	maxStack : Integer;
begin
	direction := self.myGridArea.myYADeckingOptions.allDeckingRulesIn.first;
	maxStack := self.myGridArea.heightOfStack;
	
	if direction.rowRule = DeckingRule_Increasing then
		foreach targetLocn in self.allControllersByRow discreteLock do
			if not targetLocn.isAvailable(-1,null) then
				continue;
			endif;
			
			if _mode = REAL_MODE then
				if targetLocn.allTrackedItems.size &lt; maxStack then
					found := true;
					break;
				endif;
			elseif _mode = QUEUE_MODE then  // PAR 35397
				if targetLocn.allQueuedFutureMoves.size &lt; maxStack then
					found := true;
					break;
				endif;
			elseif _mode = PLANNING_MODE then // PAR 35397
				if targetLocn.allPlannedFutureMoves.size &lt; maxStack then
					found := true;
					break;
				endif;
			endif;
		endforeach;
	else
		foreach targetLocn in self.allControllersByRow reversed, discreteLock do
			if not targetLocn.isAvailable(-1,null) then
				continue;
			endif;
			if _mode = REAL_MODE then
				if targetLocn.allTrackedItems.size &lt; maxStack then
					found := true;
					break;
				endif;
			elseif _mode = QUEUE_MODE then // PAR 35397
				if targetLocn.allQueuedFutureMoves.size &lt; maxStack then
					found := true;
					break;
				endif;
			elseif _mode = PLANNING_MODE then // PAR 35397
				if targetLocn.allPlannedFutureMoves.size &lt; maxStack then
					found := true;
					break;
				endif;
			endif;
		endforeach;
	
	endif;
	if found then 
		return targetLocn;
	endif;
epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="CM_GridController"/>
    </JadeMethod>
    <JadeMethod name="getNextColumn" id="56258a3d-b674-4ba5-9bcc-7a3948d4a2c8">
        <source>getNextColumn(): CM_GridColumn;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 September 2009	cnwer1	Initial creation

*/

vars
	iter : Iterator;
	nextColumn : CM_GridColumn;
begin

	iter:=self.myGridArea.allGridColumns.createIterator;
	iter.startAtObject(self);
	iter.next(nextColumn);
	iter.next(nextColumn);
	
	return nextColumn;
epilog
	delete iter;

end;</source>
        <ReturnType type="CM_GridColumn"/>
    </JadeMethod>
    <JadeMethod name="getNiceName" id="08348a59-7010-4e8d-ba48-1990a3fde0db">
        <source>getNiceName(): String;
// ---------------------------------------------------------------------------
// Created:		21 February 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	realMe : SelfType;
begin
	realMe := self;
	
	if realMe.pxyIsProxy() then
		realMe := self.pxyGetRealObject();
	endif;

	return "Col " &amp; realMe.myGridArea.allGridColumnsByLabel.indexOf(realMe).padLeadingWith("0",2) &amp; " (" &amp;  realMe.label.String &amp; ")";

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNumTIsQueuedIn" id="aee935ca-20d3-40a5-981d-69fbe282f27f">
        <source>getNumTIsQueuedIn(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 August 2009	cnwer1	Initial creation

*/

vars
	lc : CM_LocationsController;
	count : Integer;
begin

	count:=0;
	
	foreach lc in self.allControllersByRow do
		count:=count + lc.getNumTIsQueuedIn;
	endforeach;
	
	return count;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNumTIsQueuedInOut" id="011c303b-e050-4528-9354-74cc4d98de32">
        <source>getNumTIsQueuedInOut(	_queuedIn,	
						_queuedOut: Integer output);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 September 2009	cnwer1	Initial creation

*/

vars
	lc : CM_LocationsController;
begin

	_queuedIn:=0;
	_queuedOut:=0;
	foreach lc in self.allControllersByRow do
		_queuedIn:=_queuedIn + lc.getNumTIsQueuedIn;
		_queuedOut:=_queuedOut + lc.getNumTIsQueuedOut;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_queuedIn" type="Integer" usage="output"/>
        <Parameter name="_queuedOut" type="Integer" usage="output"/>
    </JadeMethod>
