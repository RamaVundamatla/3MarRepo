    <JadeMethod name="doFormatMessage" id="f2b1caa0-e47d-4e8c-b14b-396beaed482e">
        <source>doFormatMessage();

/*

Purpose:			

Parameters:			None

Return Value:		None


Date		Who		Reason
07 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	request		: String;
	requestType	: String;

begin
	requestType := self.cmbRequestType.text;

	if requestType = ITS_MESSAGETYPE_LOGON then
		request := self.xmlLogon();
	elseif requestType = ITS_MESSAGETYPE_LOGOFF then
		request := self.xmlLogoff();	
	elseif requestType = ITS_MESSAGETYPE_CHANGEPASSWORD then
		request	:= self.xmlChangePassword();	
	elseif requestType = ITS_MESSAGETYPE_GETNEXTJOB then
		request := self.xmlGetNextJob();
	elseif requestType = ITS_MESSAGETYPE_ACCEPTJOB then
		request := self.xmlAcceptJob();
	elseif requestType = ITS_MESSAGETYPE_VALIDATEMOVE then
		request := self.xmlValidateMove();
	elseif requestType = ITS_MESSAGETYPE_PICKUP then
		request := self.xmlPickup();
	elseif requestType = ITS_MESSAGETYPE_SETDOWN then
		request := self.xmlSetdown();
	elseif requestType = ITS_MESSAGETYPE_REJECT then
		request := self.xmlReject();
	elseif requestType = ITS_MESSAGETYPE_WEIGHTUPDATE then
		request := self.xmlWeightUpdate();
	endif;
	
	self.txtRequest.text := request;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doProcessTimeouts" id="b2a6d28b-3291-47d6-af53-da15b542b15d">
        <updating/>
        <source>doProcessTimeouts() updating;

/*

Purpose:			

Parameters:			None

Return Value:		None


Date		Who		Reason
16 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	nextTimeout : TimeStamp;
	str			: String;
	today		: Date;
	
begin
	self.myInterfaceAgent.processTimeouts(nextTimeout);
	
	if nextTimeout &lt;&gt; null and
	   nextTimeout.date = today then
		str := nextTimeout.time.String;
	endif;
	
	self.lblTimeout.caption := str;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doReceiveAcknowledge" id="ffa7bfb3-14aa-44d0-8f70-0ec64d094fa1">
        <source>doReceiveAcknowledge(_messageType : String);

/*

Purpose:			Create acknowledgement request for selected response.

Parameters:			

Return Value:		None


Date		Who		Reason
07 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	response		: CM_ITSInterfaceResponse;
	responseString	: String;
	row 			: Integer;

begin
	if self.tblWaitingAck.row &lt;= self.tblWaitingAck.fixedRows then
		return;
	endif;
	
	row 		:= self.tblWaitingAck.row;
	response	:= self.tblWaitingAck.accessRow(row).itemObject.CM_ITSInterfaceResponse;
	
	responseString := self.xmlAcknowledge(_messageType, response);
	
	self.myInterfaceAgent.processRequestString(responseString);
	
	self.incrementMessageNo();
	self.tblMachines.refreshEntries(null);

epilog

end;</source>
        <Parameter name="_messageType" type="String"/>
    </JadeMethod>
    <JadeMethod name="doReceiveMessage" id="e533709b-6d52-4b60-b5a9-de127b83fe4a">
        <updating/>
        <source>doReceiveMessage() updating;

/*

Purpose:			

Parameters:			None

Return Value:		None


Date		Who		Reason
07 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin
	self.myInterfaceAgent.processRequestString(self.txtRequest.text);
	
	self.incrementMessageNo();
	self.tblMachines.refreshEntries(null);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSendNextResponse" id="0a9933e1-7f25-4def-8b6e-75906a48b9cf">
        <source>doSendNextResponse() : Boolean;

/*

Purpose:			Send Next Response.
					Doesn't really sent response!  Just moves response out of the To Send queue.

Parameters:			None

Return Value:		None


Date		Who		Reason
07 December 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	response		: CM_ITSInterfaceResponse;
	
begin
	response := self.myInterfaceAgent.getNextResponseToBeSent();
	
	if response = null then
		return false;
	endif;
	
	self.myInterfaceAgent.completeSentResponse(response, app.actualTimeServer);
	
	return true;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="formLoad" id="941d4c95-a87a-4825-9515-8df16089ab44">
        <updating/>
        <source>formLoad() updating;

/*

Purpose:			

Parameters:			None

Return Value:		None


Date		Who		Reason
07 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	terminal	: CM_Terminal;

begin
	self.myInterfaceDefinition := CM_ITSInterfaceDefinition.firstInstance;

	create self.myInterfaceAgent transient;
	self.myInterfaceAgent.setMyInterfaceDefinition(self.myInterfaceDefinition);

	create self.myQMController transient;
	self.myQMController.setMyInterfaceDefinition(self.myInterfaceDefinition);
	self.myQMController.start();
	
	create self.myWorkerController transient;
	self.myWorkerController.setMyInterfaceDefinition(self.myInterfaceDefinition);
	self.myWorkerController.start();
	
	self.tblToSend.displayCollection(self.myInterfaceDefinition.allResponsesToSend, true, 0, null);
	self.tblWaitingAck.displayCollection(self.myInterfaceDefinition.allResponsesWaitingAck, true, 0, null);
	self.tblMachines.displayCollection(self.myInterfaceDefinition.allMachinesLoggedOn, true, 0, null);
	self.tblMessages.displayCollection(self.myInterfaceDefinition.allMessages, true, Table.DisplayCollection_Reversed, null);

	self.cmbRequestType.addItem(ITS_MESSAGETYPE_LOGON);
	self.cmbRequestType.addItem(ITS_MESSAGETYPE_LOGOFF);
	self.cmbRequestType.addItem(ITS_MESSAGETYPE_CHANGEPASSWORD);
	self.cmbRequestType.addItem(ITS_MESSAGETYPE_GETNEXTJOB);
	self.cmbRequestType.addItem(ITS_MESSAGETYPE_ACCEPTJOB);
	self.cmbRequestType.addItem(ITS_MESSAGETYPE_VALIDATEMOVE);
	self.cmbRequestType.addItem(ITS_MESSAGETYPE_PICKUP);
	self.cmbRequestType.addItem(ITS_MESSAGETYPE_SETDOWN);
	self.cmbRequestType.addItem(ITS_MESSAGETYPE_REJECT);
	self.cmbRequestType.addItem(ITS_MESSAGETYPE_WEIGHTUPDATE);

	self.txtMessageNo.setTextFromInteger(10001);

	self.beginClassNotification(CM_ITSInterfaceResponseIdDict, false, Any_System_Event, Response_Continuous, null);
	
	// Register for ITS Send Response notifications
	terminal := self.myInterfaceDefinition.myTerminal;
	self.beginNotification(terminal, terminal.getTerminalEvent(Event_ITS_SendResponse), Response_Continuous, 0);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="formUnload" id="93014aa1-fe06-4462-91c9-aae135bb8315">
        <updating/>
        <source>formUnload() updating;

/*

Purpose:			

Parameters:			None

Return Value:		None


Date		Who		Reason
07 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin
	delete self.myInterfaceAgent;
	delete self.myQMController;
	delete self.myWorkerController;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="incrementMessageNo" id="11cb6207-b022-4330-9fcf-2c2baf66c82b">
        <source>incrementMessageNo();

/*

Purpose:			

Parameters:			None

Return Value:		None


Date		Who		Reason
08 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

