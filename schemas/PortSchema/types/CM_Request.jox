    <JadeMethod name="getAllTrackedItems" id="6a9da836-df40-4c45-863b-42d088bf2bdc">
        <source>getAllTrackedItems(_theTIs : CM_TIArray input) ;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	aTI : CM_TrackedItem;
	aWLE : CM_WorkListEntry;
	ls : Boolean;
begin
	if _theTIs = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_theTIs', null, null);
		return;
	endif;
	app.cmsBeginLoad(ls);
	_theTIs.clear;
	foreach aWLE in self.allWorkListEntries do
		aTI := aWLE.myTrackedItem;
		if aTI &lt;&gt; null then
			_theTIs.add(aTI);
		endif;
	endforeach;
epilog
	app.cmsEndLoad(ls);
end;</source>
        <Parameter name="_theTIs" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllUnworkedTIs" id="301b36ef-0606-420b-b2b8-58475df029c9">
        <source>getAllUnworkedTIs(_theTIs : CM_TIArray input) ;
//----------------------------------------------------------------
//	Created:	24 March 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	aTI		: CM_TrackedItem;
	aWLE	: CM_WorkListEntry;
	tmpReq	: CM_Request; 
begin
	if _theTIs = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_theTIs', null, null);
		return;
	endif;

	_theTIs.clear;

	foreach aWLE in self.allWorkListEntries do
		aTI := aWLE.myTrackedItem;
		if aTI &lt;&gt; null 
		and aWLE.status &lt;&gt; WLE_COMPLETED 
		and (not _theTIs.includes(aTI)) then
			_theTIs.add(aTI);
		endif;
	endforeach;

end;</source>
        <Parameter name="_theTIs" type="CM_TIArray" usage="input"/>
    </JadeMethod>
