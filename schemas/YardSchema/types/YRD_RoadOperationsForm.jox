    <JadeMethod name="mLstMoveVehicle_click" id="30726a4a-b07f-4010-9464-8bbdb805a454">
        <source>mLstMoveVehicle_click(menuItem : MenuItem input);
/*

Purpose:			


Return Value:		


Date		Who		Reason
12 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815

begin
	if self.myCurrentVehicle = null or menuItem.userObject = null then
		return;
	endif;
	
	//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxMoveVehicle(self.myCurrentVehicle, menuItem.userObject.CM_YardController, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Move Vehicle in Yard', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;

epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mProceed_click" id="fd36e7e1-298e-45aa-b895-1e79b123e48d">
        <updating/>
        <source>mProceed_click(menuItem : MenuItem input) updating;
/*
Purpose:			
Return Value:		

Date			Who		Reason
15 August 2006	cnwer1	Initial creation - PAR#xxxx
17 August 2009	cnwcs5	ccms 1061 - road ops form changes
05/05/2010		cnwmh5	PAR23634 - Change to allow for multi select processing
*/
vars
	newLocation	:CM_YardController;
	table		: CM_GroupingTable;
	obj			: Object;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815	
	
begin
	
	table 	:= myCurrentTable.CM_GroupingTable;
			
	if table.allSelectedObjects.isEmpty then
		return;
	endif;
			
	foreach obj in table.allSelectedObjects do
		//self.tblStageChange(obj.CM_Object,table);
		if not self.setMyCurrentAttributes(obj.CM_Object) then
			continue;
		endif;
		
		if menuItem.userObject &lt;&gt; null and
			menuItem.userObject.isKindOf(CM_YardController) then
			// this will probably be a gate lane
			newLocation := menuItem.userObject.CM_YardController;	
		elseif menuItem.userObject = null then
			// assume moving into yard
			newLocation := self.myCurrentVehicle.getInTransitToYardLocation;
		endif;
		
		if newLocation = null then
			continue;
		endif;		
		
		// is we get to here we have a vehicle and a location to move it to
		//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxUA.trxMoveVehicle(	self.myCurrentVehicle, newLocation, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog(self.mnuProceed.caption, app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
			
		endwhile;
		
		// if &lt;&gt; null then we're not moving to the yard so can only do one at a time
		if menuItem.userObject &lt;&gt; null then
			break;
		endif;
		
	endforeach;

	
epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
