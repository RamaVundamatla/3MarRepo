    <JadeMethod name="setForCreate" id="2b8d66b5-344b-4f4a-b46f-01666eb98480">
        <updating/>
        <source>setForCreate(_pxyWoDDtl: CM_WorkOrderDtl io; _realWorkOrder: CM_WorkOrder) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 03/04/2019	jlgdap1		Initial creation TFS 43694 PEL1 Charging for Vessels that use a Ramp
//
vars

begin
	self.originalHasRamp := _pxyWoDDtl.CM_WodExtension.hasRamp;
	self.hasRamp := _pxyWoDDtl.CM_WodExtension.hasRamp;
	
	inheritMethod(_pxyWoDDtl, _realWorkOrder);

epilog

end;</source>
        <Parameter name="_pxyWoDDtl" type="CM_WorkOrderDtl" usage="io"/>
        <Parameter name="_realWorkOrder" type="CM_WorkOrder"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="14a4f07f-ba0b-49f8-aaa2-45cc8a6bc787">
        <updating/>
        <source>setForUpdate(_pxyWoDDtl: CM_WodExtension) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
// 03/04/2019	jlgdap1		TFS 43694 PEL1 Charging for Vessels that use a Ramp
//
vars
	permitRequest : CM_WodPermitRequest;
	voyage : CM_Voyage;
	
	wodMarineServiceDtl : CM_WodMarineServiceDetail;
	pxyWodMarineServiceDtl : CM_WodMarineServiceDetail;
	purgeSet : CM_WodMarineServiceDetailSet;
	movement : HMS_VoyageMovement;					// TFS 43694
	
begin
	inheritMethod(_pxyWoDDtl);
	
	self.occursOnDT := _pxyWoDDtl.occursOnDT;
	self.hasRamp := _pxyWoDDtl.hasRamp;											// TFS 43694
	voyage := self.getMyVoyageObject;											// TFS 43694
	if voyage &lt;&gt; null then														// TFS 43694
		movement := voyage.myHMSVoyageData.allVoyageMovements.last;				// TFS 43694
		if movement &lt;&gt; null and movement.myMarineServiceTimings &lt;&gt; null then	// TFS 43694
				/* Ian says 'don't tick any box automatically and leave it up to the user to confirm on the movement 
									when the vessel moves away from the berth if the ramp was actually used there.'
			movement.myMarineServiceTimings.setHasRamp(self.hasRamp);			// TFS 43694
			*/
		endif;																	// TFS 43694
	endif;																		// TFS 43694
	
	//epr 12/10/18 TFS 41310
	if self.myRelatedPermitRequest = null then
		voyage :=self.getMyVoyageObject;
		if voyage &lt;&gt; null then
			//find the ETMAL permit
			permitRequest:=voyage.allWorkOrders.getWODPermitForDetailType(self.detailType,WO_STATUS_COMPLETE).CM_WodPermitRequest;
			if permitRequest &lt;&gt; null then
	
				self.myRelatedPermitRequest:=permitRequest;
			endif;
		endif;
	endif;
	
	create purgeSet transient;
	foreach wodMarineServiceDtl in self.allMarineServiceDetails do
		if _pxyWoDDtl.allMarineServiceDetails.findWodMarineServiceDet( wodMarineServiceDtl.myHMSResource ) = null then
			purgeSet.add( wodMarineServiceDtl );
		endif;
	endforeach;
	if not purgeSet.isEmpty then
		foreach wodMarineServiceDtl in purgeSet do
			self.allMarineServiceDetails.remove( wodMarineServiceDtl );
		endforeach;
		purgeSet.purge();
	endif;
	
	//update or add the rest
	foreach pxyWodMarineServiceDtl in _pxyWoDDtl.allMarineServiceDetails do
		wodMarineServiceDtl := pxyWodMarineServiceDtl.pxyGetRealObject();
		if wodMarineServiceDtl = null then
			// must be an addiional one
			create wodMarineServiceDtl persistent;
			self.allMarineServiceDetails.add( wodMarineServiceDtl );
		endif;
		wodMarineServiceDtl.setForUpdate( pxyWodMarineServiceDtl );
	endforeach;
	
epilog

	delete purgeSet;

end;</source>
        <Parameter name="_pxyWoDDtl" type="CM_WodExtension"/>
    </JadeMethod>
    <JadeMethod name="setMarineDetsFromResourceUsed" id="2a881081-40ba-424d-906c-82b8d14d7c4e">
        <updating/>
        <source>setMarineDetsFromResourceUsed(_resourceUsedSet: HMS_ResourceUsedSet) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2019	jlgndl1	Initial creation	TFS 43374

*/

vars

	wodMarineServiceDtl : CM_WodMarineServiceDetail;
	resourceUsed : HMS_ResourceUsed;
	purgeSet : CM_WodMarineServiceDetailSet;
	

begin
	
	create purgeSet transient;
	foreach wodMarineServiceDtl in self.allMarineServiceDetails do
		if _resourceUsedSet.findResourceUsedFor( wodMarineServiceDtl.myHMSResource ) = null then
			purgeSet.add( wodMarineServiceDtl );
		endif;
	endforeach;
	if not purgeSet.isEmpty then
		foreach wodMarineServiceDtl in purgeSet do
			self.allMarineServiceDetails.remove( wodMarineServiceDtl );
		endforeach;
		purgeSet.purge();
	endif;
	
	if _resourceUsedSet= null or _resourceUsedSet.isEmpty then
		return;
	endif;
	
	foreach resourceUsed in _resourceUsedSet do
		wodMarineServiceDtl := self.allMarineServiceDetails.findWodMarineServiceDet( resourceUsed.myResource );
		if wodMarineServiceDtl = null then
			if self.isTransient then
				create wodMarineServiceDtl transient;
			else
				create wodMarineServiceDtl persistent;
			endif;
			self.allMarineServiceDetails.add( wodMarineServiceDtl );
		endif;
		wodMarineServiceDtl.setProxyFromResourceUsed( resourceUsed );		
	endforeach;

epilog

	delete purgeSet;

end;</source>
        <Parameter name="_resourceUsedSet" type="HMS_ResourceUsedSet"/>
    </JadeMethod>
    <JadeMethod name="setProxyWodExtension" id="7c863ab7-0978-4fa7-8f15-9a94751b683c">
        <updating/>
        <source>setProxyWodExtension(_occursOn : TimeStamp; _hasRamp : Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
// 03/04/2019	jlgdap1		TFS 43694 PEL1 Charging for Vessels that use a Ramp
//
vars

begin
	self.occursOnDT := _occursOn;
	self.hasRamp := _hasRamp;					// TFS 43694
epilog

end;</source>
        <Parameter name="_occursOn" type="TimeStamp"/>
        <Parameter name="_hasRamp" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setRequiredByDT" id="d0bfbd13-dbb7-4459-bb8d-3e07a8b0795f">
        <updating/>
        <source>setRequiredByDT(_dateTime: TimeStamp) updating;

/*

Purpose:		TFS 41084 SAT29SEP18 PEL1 ON CALL	

Parameters:			

Return Value:		


Date		Who		Reason
29 September 2018	jlgab1	Initial creation

*/

vars
begin
	inheritMethod(_dateTime);

	self.occursOnDT := _dateTime;
epilog

end;</source>
        <Parameter name="_dateTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="d6391652-c4fb-4eb7-bb52-e3cdf05bd1e2">
        <source>validateForCreate();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
//
vars
voyage : CM_Voyage;
	otherExtension : CM_WodExtension;
begin
	inheritMethod();
	
	voyage:=self.getMyVoyageObject;
	if voyage &lt;&gt; null then
		//not quite right check if there are any that are not approved, complete
		//cancelled ,complete finance pending, archived etc are ok
		otherExtension:=voyage.findWorkOrderDtlNotApproved(WO_TASK_EXTENSION).CM_WodExtension;
	
	
	endif;
	
	self.validateForUpdate();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="40c7ae2a-a8e2-435e-bd68-a8e00d81ccd2">
        <source>validateForUpdate();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
//
vars
	voyage : CM_Voyage;
	pxyDeparture, departure : HMS_VoyageMovement;

begin
	inheritMethod();
	
	if not self.occursOnDT.isValid then
		app.raiseCMException1(ERR_INVALID_TIMESTAMP, app.getErrorString(Occurs_datetime), null, null);
		
/*	//24 Aug 2018	NDL	TFS 40219 - Don't update here
	else
		
		voyage := self.getMyVoyageObject;
		departure := voyage.myHMSVoyageData.allVoyageMovements.last;
		pxyDeparture := app.createUpdateProxy(departure).HMS_VoyageMovement;
		pxyDeparture.setOccursOnDT(self.occursOnDT);
		pxyDeparture.validateForUpdate(app.myPassport); */
		
	endif;	

epilog
//	delete pxyDeparture;
end;</source>
    </JadeMethod>
