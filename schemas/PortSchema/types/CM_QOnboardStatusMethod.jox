        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="setComboValues" id="88365538-4b70-4ce8-9ca5-ee76f356b675">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
26 February 2024		jlizm1	Initial creation TFS 62531 CUX add IsOnboard to Selector Query

*/

vars

begin
	_combo.clear();
	
	_combo.addItem(false.getYesNo());
	_combo.addItem(app.getErrorString(Mafi));
	_combo.addItem(app.getErrorString(Trailer));

	if CM_QIntegerLookupEqual.hasInstance(_queryOperator) then
		_combo.text := self.translateToDisplayValue(_queryOperator.CM_QIntegerLookupEqual.searchValue);

	elseif CM_QIntegerLookupNotEqual.hasInstance(_queryOperator) then
		_combo.text := self.translateToDisplayValue(_queryOperator.CM_QIntegerLookupNotEqual.searchValue);

	endif;
	
epilog

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="ad0888c1-6259-46dd-8d0f-a004adf4746b">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QIntegerIsOneOf; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
26 February 2024		jlizm1	Initial creation TFS 62531 CUX add IsOnboard to Selector Query

*/

vars
	intArray	: IntegerArray;
	idx,int		: Integer;
	cmString	: CM_String;
	
begin
	_tbl.purgeTableObjects();
	_tbl.clear;
	_tbl.rows := _tbl.fixedRows;
	
	create intArray transient;
	
	intArray.add(TI_Onboard_MAFI);
	intArray.add(TI_Onboard_Trailer);
	
	foreach int in intArray do
		create cmString transient;
		cmString.string := self.translateToDisplayValue( int );
		
		if _operator &lt;&gt; null and _operator.allSelectionValues.includes(int) then
			idx := _tbl.addItem(1.String &amp; Tab &amp; cmString.string);
		else
			idx := _tbl.addItem(0.String &amp; Tab &amp; cmString.string);	
		endif;
		
		_tbl.accessRow(idx).itemObject := cmString;
		_tbl.row := idx;
		_tbl.change(_tbl);	
	endforeach;

epilog
	delete intArray;
	
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QIntegerIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="fc8336ab-424b-433f-b9c5-a93e60dd30a3">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
26 February 2024		jlizm1	Initial creation TFS 62531 CUX add IsOnboard to Selector Query

*/

vars
	str		: String;
	numRows : Integer;
	idx		: Integer;
	ia		: IntegerArray;

begin
	create ia transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			str := _tbl.accessCell(idx, 2).text;
			ia.add(self.translateToSearchValue(str).Integer);
		endif;
	endforeach;
	
	_op.setSearchValue(ia);
	
epilog
	delete ia;
	
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="50e77d60-e167-4e7b-bb79-460759b98143">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
26 February 2024		jlizm1	Initial creation TFS 62531 CUX add IsOnboard to Selector Query

*/

vars

begin
	if _value.Integer = 0 then
		return false.getYesNo();
		
	elseif _value.Integer = TI_Onboard_MAFI then
		return app.getErrorString(Mafi);
		
	elseif _value.Integer = TI_Onboard_Trailer then
		return app.getErrorString(Trailer);
		
	endif;
	
	return null;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="33cc62dd-b8f6-40e6-8818-2dcab0e024d4">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
26 February 2024		jlizm1	Initial creation TFS 62531 CUX add IsOnboard to Selector Query

*/

vars

begin
	if _value.String = app.getErrorString(Mafi) then
		return TI_Onboard_MAFI;
		
	elseif _value.String = app.getErrorString(Trailer)then
		return TI_Onboard_Trailer;
		
	endif;
	
	return null;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
