    <JadeMethod name="setTagAttribute" id="43f76e4c-5ff9-4946-9999-8ff3d87909e6">
        <updating/>
        <source>setTagAttribute(pAttrib : String) updating;

begin
	if pAttrib.length &lt;= 200 then
		self.tagAttribute := pAttrib;
	else
		self.tagAttribute := pAttrib[1:200];
	endif;
end;</source>
        <Parameter name="pAttrib" type="String"/>
    </JadeMethod>
</Class>
