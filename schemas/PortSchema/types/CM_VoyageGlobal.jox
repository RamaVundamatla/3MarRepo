    <JadeMethod name="getArrivalDraft" id="38921016-c267-412d-9810-a386cb81bac3">
        <source>getArrivalDraft() : Decimal;
/*
----------   ----------  --------------------------------------------------
Created:	30 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	hmsMovement		: HMS_Movement;
begin
	hmsMovement := self.allHMSMovements.first;
	if hmsMovement = null then
		return null;
	endif;
	
	return hmsMovement.vesselDraft;

end;


</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="f6b4a2a1-8b5e-4955-a7e5-f5e5830e3f7b">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     May 2007 by cnwvu1
//
// Purpose:     
/* Changes

Date		Name	TFS#		Description
============================================================================
22/09/2011	cnwcs5	CCMS RIO 2041 / par 28220 start/stop times
23/07/2019	jlgka1 	TFS 45620	JMT - Refactor remove remaining  Voyage Commodity  Planning
============================================================================*/
vars
	txt				: String;
	tmpStr			: String;
	movement		: HMS_Movement;
	berth			: HMS_Berth;
	//voyCommodity	: CM_GlblVoyageCommodityPlanning; // jlgka1 TFS 45620
	i				: Integer;
	days, hours, minutes: Integer;
	loadedFile		: CM_FileData;
	cargoDetails	: String;
	
begin
	txt[10000] 	:= '*'; 
	txt 		:= null;
	txt 		:= inheritMethod();

	// ------------------------------------------
	//  Global Voyage Maintenance - Voyage times
	// ------------------------------------------
	i := 0;
	
	foreach movement in self.allHMSMovements do
		i := i + 1;
		// getting berths from the movement
		berth			:= movement.getMyBerth();
	
		//arrivalTimeAtFromRegion
		tmpStr := movement.arrivalTimeAtFromRegion.String;
		txt := txt &amp;'Move'&amp;i.String&amp;' ' &amp; berth.code &amp; ': arrivalTimeAtFromRegion' &amp;  AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		//arrivalTimeAtFromRegionLocked
		//jlgka1 TFS 45620 --&gt;
		/*tmpStr := movement.arrivalTimeAtFromRegionLocked.String;
		txt := txt &amp;'Move'&amp;i.String&amp;' ' &amp; berth.code &amp; ': arrivalTimeAtFromRegionLocked' &amp;  AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;*/
		//jlgka1 TFS 45620 &lt;--
		//moveStatusNEW
		tmpStr := movement.moveStatusNEW.String;
		txt := txt &amp;'Move'&amp;i.String&amp;' ' &amp; berth.code &amp; ': moveStatusNEW' &amp;  AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		//moveType
		tmpStr := movement.moveType;
		txt := txt &amp;'Move'&amp;i.String&amp;' ' &amp; berth.code &amp; ': moveType' &amp;  AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		//myBerth
		tmpStr := berth.code;
		txt := txt &amp;'Move'&amp;i.String&amp;' ' &amp; berth.code &amp; ': myBerth' &amp;  AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
				
		//jlgka1 TFS 45620 --&gt;
		//isBerthLocked
		/*tmpStr := movement.isBerthLocked.String;
		txt := txt &amp;'Move'&amp;i.String&amp;' ' &amp; berth.code &amp; ': isBerthLocked' &amp;  AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;*/
		//jlgka1 TFS 45620 &lt;--
		
		//myTidalClass	-	IT IS ALWAYS NULL
	//	tmpStr := movement.myTidalClass.code;
	//	txt := txt &amp;'Move '&amp;i.String&amp;' ' &amp; berth.code &amp; ': myTidalClass' &amp;  AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		//occursOnDTNEW
		tmpStr := movement.occursOnDTNEW.String;
		txt := txt &amp;'Move'&amp;i.String&amp;' ' &amp; berth.code &amp; ': occursOnDTNEW' &amp;  AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		//remarks
		tmpStr := movement.remarks.String;
		txt := txt &amp;'Move'&amp;i.String&amp;' ' &amp; berth.code &amp; ': remarks' &amp;  AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		//steamingTime
		movement.steamingTime.spltAsDaysHoursMinutes(days, hours, minutes);
		tmpStr := days.String &amp;':'&amp; hours.String &amp;':'&amp; minutes.String;
		txt := txt &amp;'Move'&amp;i.String&amp;' ' &amp; berth.code &amp; ': steamingTime' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		//steamingTimeLocked
		
		//waitingTime
		movement.waitingTime.spltAsDaysHoursMinutes(days, hours, minutes);
		tmpStr := days.String &amp;':'&amp; hours.String &amp;':'&amp; minutes.String;
		txt := txt &amp;'Move'&amp;i.String&amp;' ' &amp; berth.code &amp; ': waitingTime' &amp;  AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		//jlgka1 TFS 45620 --&gt;
		//waitingTimeLocked
		/*tmpStr := movement.departureTimeLocked.String;
		txt := txt &amp;'Move'&amp;i.String&amp;' ' &amp; berth.code &amp; ': departureTimeLocked' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;		
		
		tmpStr := movement.steamingTimeLocked.String;
		txt := txt &amp;'Move'&amp;i.String&amp;' ' &amp; berth.code &amp; ': steamingTimeLocked' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;		
		
		//Minimum Residence Time
		tmpStr := movement.minWaitingTime.asStringJMT();
		txt := txt &amp;'Move'&amp;i.String&amp;' ' &amp; berth.code &amp; ': Minimum Residence Time' &amp;  AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;*/
		//jlgka1 TFS 45620 &lt;--
		
		//vesselDraft
		tmpStr := movement.vesselDraft.String;
		txt := txt &amp;'Move'&amp;i.String&amp;' ' &amp; berth.code &amp; ': vesselDraft' &amp;  AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
			
		tmpStr := movement.getCargoOperationsTimesString;
		
		txt := txt &amp; 'Move' &amp; i.String &amp; ' ' &amp; berth.code &amp; ': Cargo Operations Times' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
				
		//harbour (movement.berth.myHarbourRegion.code)
		if berth &lt;&gt; null and berth.myHarbourRegion &lt;&gt; null then
			tmpStr := berth.myHarbourRegion.code;
			txt := txt &amp;'Move'&amp;i.String&amp;' ' &amp; berth.code &amp; ': harbourRegion' &amp;  AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		endif;
		//jlgka1 TFS 45620 --&gt;
		/*tmpStr := app.cargoOperationEnumToString(movement.cargoOperation, true);
		txt := txt&amp;'Move' &amp; i.String &amp; ' ' &amp; berth.code &amp; ': Cargo Operation' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;*/
		//jlgka1 TFS 45620 &lt;--
	endforeach;

	// -------------------------------------------
	//  Global Voyage Maintenance - Cargo details
	// -------------------------------------------
	i := 0;
	//jlgka1 TFS 45620 --&gt;
	/*
	foreach voyCommodity in self.allVoyCommodPlanningObjs do
//		cargoDetails	:=	voyCommodity.getCargoDtlsAsString(voyCommodity.myVoyage);
		
		i := i + 1;
		//actualDischargedVolume
		tmpStr := voyCommodity.actualDischargedVolume.String;  
		txt := txt &amp; "Cargo" &amp; i.String &amp; ' ' &amp; ': actualDischargedVolume' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		//actualDischargedWeight
		tmpStr := voyCommodity.actualDischargedWeight.asStringWeightJMT();  
		txt := txt &amp; "Cargo" &amp; i.String &amp; ' ' &amp; ': actualDischargedWeight' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		//actualLoadedVolume
		tmpStr := voyCommodity.actualLoadedVolume.String;  
		txt := txt &amp; "Cargo" &amp; i.String &amp; ' ' &amp; ': actualLoadedVolume' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		//actualLoadedWeight
		tmpStr := voyCommodity.actualLoadedWeight.asStringWeightJMT();  
		txt := txt &amp; "Cargo" &amp; i.String &amp; ' ' &amp; ': actualLoadedWeight' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		//cargoStatus
		tmpStr := voyCommodity.cargoStatus;
		txt := txt &amp; "Cargo" &amp; i.String &amp; ' ' &amp; ': cargoStatus' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		//dischargeVoyageArrival
		tmpStr := voyCommodity.dischargeVoyageArrival.String;
		txt := txt &amp; "Cargo" &amp; i.String &amp; ' ' &amp; ': dischargeVoyageArrival' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		//dryMetricTonnes 
		tmpStr := voyCommodity.dryMetricTonnes.String;  
		txt := txt &amp; "Cargo" &amp; i.String &amp; ' ' &amp; ': dryMetricTonnes' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		//loadVoyageArrival
		tmpStr := voyCommodity.loadVoyageArrival.String;  
		txt := txt &amp; "Cargo" &amp; i.String &amp; ' ' &amp; ': loadVoyageArrival' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		//myCargoType
		if voyCommodity.myCargoType &lt;&gt; null then
			tmpStr := voyCommodity.myCargoType.id.String;
			txt := txt &amp; "Cargo" &amp; i.String &amp; ' ' &amp; ': cargoType' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		endif;
		//myProductType
		if voyCommodity.myCargoType &lt;&gt; null then
			tmpStr := voyCommodity.myCargoType.productType.String;
			txt := txt &amp; "Cargo" &amp; i.String &amp; ' ' &amp; ': productType' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		endif;
		//myDischargeLocation
		if (voyCommodity.myDischargeLocation &lt;&gt; null) and (voyCommodity.myDischargeLocation.myTerminalArea &lt;&gt; null) then
			tmpStr := voyCommodity.myDischargeLocation.myTerminalArea.id;
			txt := txt &amp; "Cargo" &amp; i.String &amp; ' ' &amp; ': myDischargeLocation' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		endif;
		//myDischargedCargo
		if voyCommodity.myDischargedCargo &lt;&gt; null then
			tmpStr := voyCommodity.myDischargedCargo.id;
			txt := txt &amp; "Cargo" &amp; i.String &amp; ' ' &amp; ': myDischargedCargo' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		endif;
		//myLoadLocation 
		if voyCommodity.myLoadLocation &lt;&gt; null then
			tmpStr := voyCommodity.myLoadLocation.terminalAreaId.String;
			txt := txt &amp; "Cargo" &amp; i.String &amp; ' ' &amp; ': load location' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		endif;
		//myLoadedCargo
		if voyCommodity.myLoadedCargo &lt;&gt; null then
			tmpStr := voyCommodity.myLoadedCargo.id;
			txt := txt &amp; "Cargo" &amp; i.String &amp; ' ' &amp; ': myLoadedCargo' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		endif;
		//myLocation
		if (voyCommodity.myLocation &lt;&gt; null) and (voyCommodity.myLocation.myTerminalArea &lt;&gt; null) then
			tmpStr := voyCommodity.myLocation.myTerminalArea.id;
			txt := txt &amp; "Cargo" &amp; i.String &amp; ' ' &amp; ': myLocation' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		endif;
		//myPlannedDischargeCargo
		if voyCommodity.myPlannedDischargeCargo &lt;&gt; null then
			tmpStr := voyCommodity.myPlannedDischargeCargo.id;
			txt := txt &amp; "Cargo" &amp; i.String &amp; ' ' &amp; ': myPlannedDischargeCargo' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		endif;
		//myPlannedLoadCargo
		if voyCommodity.myPlannedLoadCargo &lt;&gt; null then
			tmpStr := voyCommodity.myPlannedLoadCargo.id;
			txt := txt &amp; "Cargo" &amp; i.String &amp; ' ' &amp; ': myPlannedLoadCargo' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		endif;
		//myProduct
		if voyCommodity.myProduct &lt;&gt; null then
			tmpStr := voyCommodity.myProduct.code;
			txt := txt &amp; "Cargo" &amp; i.String &amp; ' ' &amp; ': myProduct' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		endif;
		//myTerminal - loaded at
		if voyCommodity.myTerminal &lt;&gt; null then
			tmpStr := voyCommodity.myTerminal.code;
			txt := txt &amp; "Cargo" &amp; i.String &amp; ' ' &amp; ': loaded At' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		endif;
		//myVoyage
		if voyCommodity.myVoyage &lt;&gt; null then
			tmpStr := voyCommodity.myVoyage.code;
			txt := txt &amp; "Cargo" &amp; i.String &amp; ' ' &amp; ': myVoyage' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		endif;
		//myVoyageDischarging
		if voyCommodity.myVoyageDischarging &lt;&gt; null then
			tmpStr := voyCommodity.myVoyageDischarging.code;
			txt := txt &amp; "Cargo" &amp; i.String &amp; ' ' &amp; ': myVoyageDischarging' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		endif;
		//myVoyageGlobal
		if voyCommodity.myVoyageGlobal &lt;&gt; null then
			tmpStr := voyCommodity.myVoyageGlobal.code;
			txt := txt &amp; "Cargo" &amp; i.String &amp; ' ' &amp; ': myVoyageGlobal' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		endif;
		//myVoyageLoading
		if voyCommodity.myVoyageLoading &lt;&gt; null then
			tmpStr := voyCommodity.myVoyageLoading.code;
			txt := txt &amp; "Cargo" &amp; i.String &amp; ' ' &amp; ': myVoyageLoading' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		endif;
		//notes
		tmpStr := voyCommodity.notes.String;  
		txt := txt &amp; "Cargo" &amp; i.String &amp; ' ' &amp; ': notes' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		//plannedLoadedVolume
		tmpStr := voyCommodity.plannedLoadedVolume.String;  
		txt := txt &amp; "Cargo" &amp; i.String &amp; ' ' &amp; ': plannedLoadedVolume' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		//plannedLoadedWeight
		tmpStr := voyCommodity.plannedLoadedWeight.asStringWeightJMT();  
		txt := txt &amp; "Cargo" &amp; i.String &amp; ' ' &amp; ': plannedLoadedWeight' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		//state
		tmpStr := voyCommodity.state.String;  
		txt := txt &amp; "Cargo" &amp; i.String &amp; ' ' &amp; ': state' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endforeach;*/
	//jlgka1 TFS 45620 &lt;--
	// -------------------------------------------
	//  Global Voyage Maintenance - loaded files
	// -------------------------------------------
	foreach loadedFile in self.allFiles do
		//fileName
		tmpStr := loadedFile.fileName;  
		txt := txt &amp; 'Loaded file: ' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endforeach;
	
	return txt;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getColour" id="6d046af9-94e6-41e9-a847-f9daf69f2892">
        <source>getColour():Integer;
// --------------------------------------------------------------------------------
// Created:		18 September 2006 by cnwdad1:2
//
// Purpose:		Returns the receiver's colour.
//
// Parameters:	None
//
// Returns:		The receiver's colour, or 0.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	voyageObj	: CM_Voyage;
	
begin
	voyageObj	:=	self.getDefaultVoyage();
	
	if voyageObj &lt;&gt; null then
		return voyageObj.colour;
	endif;
	
	return 0;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDefaultVoyage" id="3375fbcb-91c3-4173-8b81-d861b182216f">
        <source>getDefaultVoyage():CM_Voyage;
// --------------------------------------------------------------------------------
// Created:		18 September 2006 by cnwdad1
//
// Purpose:		Returns a reference to the receiver's default Voyage.
//
// Parameters:	None
//
// Returns:		A reference to the Voyage object, or null.
//
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	voyageObj		: CM_Voyage;
	invalid 		: Boolean;
	ed				: Integer;
	
begin
	voyageObj	:=	self.allVoyages.last();
	
	if voyageObj &lt;&gt; null then		// and global.isValidObject(voyageObj) then
		on Exception do app.handleDeletedObject(exception, voyageObj, invalid);
		// Dereference voyage to check it is valid
		ed := voyageObj.edition();
		if not invalid then
			return voyageObj;
		endif;
	endif;
	
	return null;
end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="getDefaultVoyageData" id="d0211d77-934f-494c-b36f-6c1749a45e6a">
        <source>getDefaultVoyageData():HMS_VoyageData;
// --------------------------------------------------------------------------------
// Created:		18 September 2006 by cnwdad1
//
// Purpose:		Returns a reference to the receiver's default HMS Voyage Data object.
//
// Parameters:	None
//
// Returns:		A reference to the HMS Voyage Data object, or null.
//
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	voyageObj		: CM_Voyage;
	voyageDataObj	: HMS_VoyageData;
	
begin
	voyageObj := self.getDefaultVoyage();
	if voyageObj &lt;&gt; null then
		return voyageObj.myHMSVoyageData;
	endif;
	
//	voyageObj	:=	self.allVoyages.last();
	
//	if voyageObj &lt;&gt; null and global.isValidObject(voyageObj) then
//		if voyageObj.myHMSVoyageData &lt;&gt; null
//		and global.isValidObject(voyageObj.myHMSVoyageData)
//		then
//			return voyageObj.myHMSVoyageData;
//		endif;
//	endif;
	
	return null;
end;</source>
        <ReturnType type="HMS_VoyageData"/>
    </JadeMethod>
    <JadeMethod name="getEtaFromLaycans" id="a0156a6b-d278-4cca-b196-b206be40b2d3">
        <source>getEtaFromLaycans() : TimeStamp;
//-----------------------------------------------------------------------
//	Created:	14 September 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars

	depTime,
	eta			: TimeStamp;
	halfDiffSeconds	: Integer;
begin

	halfDiffSeconds := (self.laycanDateFrom.cnEcDiff(self.laycanDateTo) / 2000).Integer;

	eta := self.laycanDateFrom.cnEcAddSeconds (halfDiffSeconds);
	
	return eta;

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfoLogVoyOps" id="e77e8c2b-e411-4177-9f61-8f62f4fad205">
        <source>getExtraInfoLogVoyOps(_array : HugeStringArray input; _terminalForTerminology : CM_Terminal);
//--------------------------------------------------------------
//Created: 07 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	voyage : CM_Voyage;
	
begin
	_array.add("Global Voyage Code" &amp; Tab &amp; self.code);
	// 33174 CCMS 1124 add IMO
	_array.add("IMO" &amp; Tab &amp; self.vesselCode);
	_array.add("Vessel" &amp; Tab &amp; self.vesselName);
	
	foreach	voyage in self.allVoyages do
		voyage.getExtraInfoLogVoyOps(_array, _terminalForTerminology);
	endforeach;
end;</source>
        <Parameter name="_array" type="HugeStringArray" usage="input"/>
        <Parameter name="_terminalForTerminology" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getFirstHarbourRegion" id="9bdce925-32b8-43e5-859f-bb81cb8f9ff3">
        <source>getFirstHarbourRegion() : HMS_HarbourRegion;
// ---------------------------------------------------------------------------
// Created:     26 October 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpMove	: HMS_Movement;
begin
	tmpMove := self.allHMSMovements.first;
	if tmpMove = null then
		return null;
	endif;
	
	return tmpMove.getHarbourRegion();

end;</source>
        <ReturnType type="HMS_HarbourRegion"/>
    </JadeMethod>
    <JadeMethod name="getId" id="6dd2e2f4-70b3-4594-ada7-6b58d1a19eab">
        <source>getId(): String;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.vesselName &lt;&gt; null then
		return self.code.trimBlanks &amp; " - " &amp; self.vesselName.trimBlanks;
	else
		return self.code.trimBlanks;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLastArrivalShiftWaypoint" id="c06fd3ce-8d95-4f16-8753-1d73634429a8">
        <source>getLastArrivalShiftWaypoint() : HMS_HarbourRegion;
// ---------------------------------------------------------------------------
// Created:     26 October 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpMove	: HMS_Movement;
begin
	tmpMove := self.allHMSMovements.last;
	if tmpMove = null then
		return null;
	endif;
	
	tmpMove := tmpMove.getMovementPreviousGlobal();
	if tmpMove = null then
		return null;
	endif;
	
	return tmpMove.getHarbourRegion();

end;</source>
        <ReturnType type="HMS_HarbourRegion"/>
    </JadeMethod>
    <JadeMethod name="getLastDepartureHarbourRegion" id="f0a52b62-973d-4ac6-98b3-b97b1044cae0">
        <source>getLastDepartureHarbourRegion() : HMS_HarbourRegion;
// ---------------------------------------------------------------------------
// Created:     26 October 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpMove	: HMS_Movement;
begin
	tmpMove := self.allHMSMovements.last;
	if tmpMove = null then
		return null;
	endif;
	
	return tmpMove.getHarbourRegion();

end;</source>
        <ReturnType type="HMS_HarbourRegion"/>
    </JadeMethod>
    <JadeMethod name="getLastDepartureTime" id="a25cfd0f-6df3-487f-af0d-47acc9829875">
        <source>getLastDepartureTime() : TimeStamp;

/*

Purpose:			Get the time of departure of the last voyage in the receiver


Return Value:		Departure TimeStamp


Date		Who		Reason
30 Mar 2008	cnwkpd1	PAR #16362 - Correct selection of global voyages to close

*/

vars
	lastVoyage		: CM_Voyage;
	
begin
	lastVoyage := self.allVoyages.last;
	if lastVoyage &lt;&gt; null then
		return lastVoyage.departedDT;
	endif;
	
	return null;

end;
</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getLastMovementArivsAtBLocalTZ" id="95257a4c-e130-4685-b1ed-0aeb12708b96">
        <source>getLastMovementArivsAtBLocalTZ() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 June 2016	cnwns1	Initial creation
// 07 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/
vars
	tmpMovement	: HMS_Movement;
	
begin
	tmpMovement := self.allHMSMovements.last;
	if tmpMovement &lt;&gt; null then
		return self.systemToLocalTime(tmpMovement.arrivalTimeAtToRegion);
	endif;
	return null;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getLastMovementArrivesAtB" id="f305f57e-47fa-45ca-8630-e113edd590c3">
        <source>getLastMovementArrivesAtB() : TimeStamp;
//-----------------------------------------------------------------------
//	Created:	05 December 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	tmpMovement	: HMS_Movement;
	
begin
	tmpMovement := self.allHMSMovements.last;
	if tmpMovement &lt;&gt; null then
		return tmpMovement.arrivalTimeAtToRegion;
	endif;
	return null;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getLastMovementDepartsA" id="e8d08bad-64d9-4a59-a43a-2f403a7a50d4">
        <source>getLastMovementDepartsA() : TimeStamp;
//-----------------------------------------------------------------------
//	Created:	12 February 2007 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
/*

Date		Who		Reason
30 Mar 2008	cnwkpd1	PAR #16362 - correction to use departure time
			cnwrs2	

*/

vars
	tmpMovement	: HMS_Movement;
	
begin
	tmpMovement := self.allHMSMovements.last;
	if tmpMovement &lt;&gt; null then
		// return tmpMovement.arrivalTimeAtFromRegion.addMinutes (tmpMovement.waitingTime);		// PAR #16362
		return tmpMovement.departureTimeFromFromRegion;
	endif;

	return null;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getLastMovementDepartsALocalTZ" id="a79af09f-b64d-41f6-9bea-275fb0b18f90">
