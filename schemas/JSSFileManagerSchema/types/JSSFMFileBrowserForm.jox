        <source>load() updating;
// --------------------------------------------------------------------------------
// Created:		30 July 2002 by cnwdad1
//
// Purpose:		Passes this event on to the Form Interface class for processing.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	
	if self.aMyFormInterface &lt;&gt; null then
		self.aMyFormInterface.sendMsg(method.name);
	endif;
end;</source>
    </JadeMethod>
