    <JadeMethod name="create" id="988dff32-18ea-44ab-a0f3-d4cf84bc59ac">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		04 May 2010 by cnwjo3
//
// Purpose:		par 23349.  Set what operators are available in Item Seletor screen
//
// Parameters:	
//
// Returns:		Nothing
//
vars
	oper : CM_QueryOperator;
begin
	if self.isTransient then 
		return;
	endif;

	create oper as CM_QStringContains persistent;
	self.allAllowedOperators.add(oper);	
end;</source>
    </JadeMethod>
    <JadeMethod name="getControlTypeForOperator" id="3bb202fa-dbbc-4041-bb96-99958cb663f5">
        <source>getControlTypeForOperator(_op: CM_QueryOperator): Integer;
// --------------------------------------------------------------------------------
// Created:		04 May 2010 by cnwjo3
//
// Purpose:		par 23349.  What type of control used in Arguments area on Item Selector.  Currently only using Combo Box but later might use
//				multi select check box listbox thing
//
// Parameters:	
//
// Returns:		Nothing
//
vars

begin
	if _op.isKindOf(CM_QStringIsOneOf) then
		return QueryControl_MultiSelect;
	else
		return QueryControl_ComboBox;
	endif;
	
end;</source>
        <Parameter name="_op" type="CM_QueryOperator"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
