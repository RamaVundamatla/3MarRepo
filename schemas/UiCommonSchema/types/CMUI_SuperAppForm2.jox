    <JadeMethod name="doResize" id="7b81547b-68ac-4eac-84d7-69b9bf450b66">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:     28 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if app.toolbarHidden then
		self.moveMdiClient(0, 0, self.clientWidth, self.clientHeight - self.staMain.height);
	else
		self.frmToolbar.repositionAfterResize();
		self.moveMdiClient(0, self.frmToolbar.height, self.clientWidth, self.clientHeight - self.frmToolbar.height - self.staMain.height);
	endif;

	self.repositionLblUserName();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveAsSystemDefault" id="07a6d12a-ecb4-4c25-a63e-a1bca4bb9711">
        <source>doSaveAsSystemDefault() protected;
// ---------------------------------------------------------------------------
// Created:     22 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	agent			: CM_MenuAgent;
	user			: CM_User;
	toolbarRoot		: CM_MenuRootForRoot;		
	menuEntity		: CM_MenuEntity;
begin
	app.mousePointer := MousePointer_HourGlass;
	
	user := app.getMyUser;
	
	create agent transient;
	create toolbarRoot transient;
	
	foreach menuEntity in user.myMenuUserToolbarRoot.allMenuUserToolbarItems do
		toolbarRoot.allChildren.add(menuEntity);
	endforeach;
	
	agent.trxSaveToolbarMenuAsSysDefault(toolbarRoot);
	
epilog
	delete agent;	
	delete toolbarRoot;
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSaveToJMTDefault" id="c355839c-704f-47d3-ac4d-461fb350be6e">
        <source>doSaveToJMTDefault() protected;
// ---------------------------------------------------------------------------
// Created:     22 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	agent			: CM_MenuAgent;
	user			: CM_User;
	toolbarRoot		: CM_MenuRootForRoot;		
	menuEntity		: CM_MenuEntity;
begin
	app.mousePointer := MousePointer_HourGlass;
	
	user := app.getMyUser;
	
	create agent transient;
	create toolbarRoot transient;
	
	foreach menuEntity in user.myMenuUserToolbarRoot.allMenuUserToolbarItems do
		toolbarRoot.allChildren.add(menuEntity);
	endforeach;
	
	agent.trxSaveToolbarMenuAsJMTDefault(toolbarRoot);
	
epilog
	delete agent;	
	delete toolbarRoot;
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doShowAlertAlarm" id="9bee20ae-e311-422f-8001-6bbdc34d9a8e">
        <source>doShowAlertAlarm();
/*

Purpose:			


Return Value:		


Date		Who		Reason
30 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if app.myPassport.myUser &lt;&gt; null then
		if app.myPassport.myUser.needsAlertAlarm then
			app.showAlertAlarm(null);
		endif;
	endif;

epilog

end;</source>
