    <JadeMethod name="btnAddDest_click" id="8482e8ca-4415-43ad-9e3f-65f9c79a1190">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAddDest_click(btn: Button input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2010	conkc1	Initial creation
*/
vars
	
begin
	vUpdated := true;
	showDestinationTerminalForm(Mode_Add);

epilog

end;</source>
