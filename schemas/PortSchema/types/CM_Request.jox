    <JadeMethod name="getDensityFromCargoType" id="32a2ac0b-cccf-4270-9997-217a36c82524">
        <source>getDensityFromCargoType() : Decimal;
/*

Date		Who		Reason
18 June 2014	cnwer1	Initial creation PAR 34406

*/

vars
	ct			: CM_CargoType;
	product	 	: CM_Product;
	density 		: Decimal[14,4];
begin
	ct:= self.getCargoType;
	product:= self.getCargoSubType;
	if product &lt;&gt; null then
		return product.getDefaultValueStringForType(Type_Density).Decimal;
	
	else
		if ct &lt;&gt; null then
			if ct.mySystemProductType &lt;&gt; null then
				return ct.mySystemProductType.getDefaultValueStringForType(Type_Density).Decimal;
			endif;
			
			return ct.defaultDensity;
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
