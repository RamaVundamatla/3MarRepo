    <JadeMethod name="getLoadClassSubclasses" id="79b84e50-621d-41c7-9910-b6795d215d4d">
        <updating/>
        <source>getLoadClassSubclasses(pClass:String) updating, protected;

vars
	class: Class;
	subclass: Class;
	classColl: ClassColl;
	className: String;
	theSchema: Schema;
	changeClass: JSSCTChangeTrackingClass;
begin
	self.monitor(self.class.name&amp;'::'&amp;method.name&amp;' ', MONITOR_DEBUG);

	className := pClass;
	if self.isStartedApplication then
		theSchema := self.myNotificationObject.mySharedTransientInstance.applicationSchema;
	else
		theSchema := currentSchema;
	endif;
	class := theSchema.getClass(className);
	if class = null then
		self.monitor("Class " &amp; className &amp; " not found in currentSchema " &amp; theSchema.name, MONITOR_ONLY);
	else
		changeClass := self.myChangeTrackingRoot.allChangeClasses[className, false];
		if changeClass = null then

			//	create an entry for this class in the collection
			self.createChangeDictForClass(className, false, false);
		endif;
		//	do the same for any/all subclass of this class
		if class.hasSubclasses() then
			create classColl transient;
			class.getSubclasses(classColl);
			foreach subclass in classColl do
				self.getLoadClassSubclasses(subclass.name);
			endforeach;
		endif;
	endif;
epilog
	delete classColl;
end;</source>
        <access>protected</access>
        <Parameter name="pClass" type="String"/>
    </JadeMethod>
