    <JadeMethod name="addToBuffer" id="6706d3e3-2f44-4912-b476-aed8ee99bb1a">
        <updating/>
        <source>addToBuffer(_buffer : String) updating, protected;

vars

begin

	if _buffer.length &gt; 0 then
		self.buffer := self.buffer &amp; _buffer;
	endif;

end;</source>
