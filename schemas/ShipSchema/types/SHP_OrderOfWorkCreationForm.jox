	chkShipTLHeight.translateBubbleHelp(Xlat_0006626, locale);
	chkShipTLHeight.translateCaption(Xlat_0006627, locale);
	chkShipTLWeight.translateBubbleHelp(Xlat_0006628, locale);
	chkShipTLWeight.translateCaption(Xlat_0006629, locale);
	chkSplit.translateCaption(Xlat_0006630, locale);
	clrBay.translateBubbleHelp(Xlat_0014477, locale);
