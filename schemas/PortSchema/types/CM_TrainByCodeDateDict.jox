<CollClass name="CM_TrainByCodeDateDict" id="33695562-4f61-4b0e-8be7-11c0fd48791e">
    <loadFactor>66</loadFactor>
    <memberType name="CM_Train"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <MemberKey>
        <property name="CM_Train::code"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_Train::scheduledArrivalDT"/>
    </MemberKey>
    <JadeMethod name="getByCode" id="61d283fd-7a93-4900-9113-bcf967c5dd06">
        <source>getByCode(_trainCode : String) : CM_Train;
/*

Purpose:			Finds train by code that has not departed

Parameters:			_trainCode	String	Train code to look for

Return Value:		CM_Train	The train that was found

Date		Who		Reason
21 June 2022	navpw1	Initial creation TFS: 53764

*/

vars
	tmpTrain	: CM_Train;
	iter		: Iterator;
	
begin
	if _trainCode &lt;&gt; null then
		iter := self.createIterator();
		self.startKeyGeq(_trainCode, null, iter);
		while iter.next(tmpTrain) do
			if tmpTrain.code &lt;&gt; _trainCode then
				return null;
			endif;
			
			if tmpTrain.hasDeparted or tmpTrain.isDeparted then
				continue;
			endif;
			
			return tmpTrain;
			
		endwhile;
	endif;
epilog
	delete iter;
end;</source>
        <Parameter name="_trainCode" type="String"/>
        <ReturnType type="CM_Train"/>
    </JadeMethod>
</CollClass>
