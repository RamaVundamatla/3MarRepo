    <JadeMethod name="create" id="1d88c3d2-7af5-45a7-beb7-7477be90abb3">
        <updating/>
        <source>create() updating;
//----------------------------------------------------------------
//	Created:	03 March 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.name := "PON Coarri";
	self.type := EDIFileTypeCams_PONCoarri;

end;</source>
    </JadeMethod>
    <JadeMethod name="getEDIBundle" id="40ea5703-32fe-44f7-9bb3-513aabe6d491">
        <source>getEDIBundle(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2025	navkc1	JIRA Story MTN-33491: MTN | License - EDI Bundles Methods

*/

vars

begin
	
	return CM_EDIFileType.EDI_Bundle_CUSTOM;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSenderCode_UNB" id="48ae98d3-c079-4d21-9835-c03a7677299e">
        <source>getSenderCode_UNB(_protocol :CM_CamProtocol):String protected;
/*	
Return Value:	sender code to use in UNB segment

Date		Who		Reason
16 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
vars
	code		:String;
	terminal	:CM_Terminal;
begin
	code 		:= _protocol.camGroup.senderCode.trimBlanks;
	terminal	:= _protocol.terminal;
	
	if code = null then
		code := terminal.getConfig(PortDestCode).String.trimBlanks;
	endif;
	
	// no translation
	
	return code;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessageHeader" id="1809260a-ffdc-4028-9ab0-3b53747592ac">
        <updating/>
        <source>makeMessageHeader(_camFile : CM_CamFile input; _camTaskHistory : CM_CamTaskHistory input; 
					_unhSeqNumber : Integer io; _type : String; _fileType : String;
					_coll :HugeStringArray input) : String updating;
// 10/02/2011	cnwcs5	CCMS JMT 1977/PAR 26531 - changed _camFile/_camTaskHistory parameter usage from io to input
// 16/05/2011	cnwcs5 	CCMS SCT 2058/par 27460 - replace literals with characters defined on protocol
// 20/12/2012	cnwcs5	CCMS SFW 1294 /par 30855
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
vars
	protocol	:CM_CamProtocol;	// par 27460 cnwcs5
	strLine : String;
begin
	_unhSeqNumber 	:= _unhSeqNumber + 1;
	protocol		:= _camTaskHistory.camProtocol;	// par 27460 cnwcs5

	// UNH Segment
	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeUNHSegment (protocol, _unhSeqNumber, _fileType, "D", "95B", "UN", "ITG14", null, _camTaskHistory.runDateTime), _coll); 	//cnwmc5 - 15 Oct 2014 - CCMS 2380
	// BGM segment
	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeBGMSegment (protocol, _type, _unhSeqNumber, 9, null), _coll);

	_camFile.incrementMessageCount();
	return strLine;
end;</source>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_unhSeqNumber" type="Integer" usage="io"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_fileType" type="String"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessageRFF_ABT" id="d7f900b6-90b9-4146-8694-a7155c9c2aa3">
        <source>makeMessageRFF_ABT(_protocol :CM_CamProtocol; _group :HugeStringArray input; _activity :Integer; _ti :CM_TrackedItem):String protected;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
22 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
vars
	msg	:String;
begin
	if _ti.customExportEntryNumber.trimRight &lt;&gt; null then
		msg := self.makeRFFSegment (_protocol, _group, "ABT", _ti.getCustExpEntryNoMinusSlash);
	endif;
	
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_LOC" id="3c489e34-bbb7-4775-8f1e-88ad04b6452e">
        <updating/>
        <source>outputHeader_LOC(_camTaskHistory :CM_CamTaskHistory input; _protocol :CM_CamProtocol; _activity :Integer;_count :Integer io; _coll :HugeStringArray input) : String updating, protected;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
22 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
vars
	terminal	:CM_Terminal;
	code, fCode	:String;
	strLine : String;
begin
	terminal	:= _protocol.terminal;
	
	code 		:= terminal.getConfig(PortDestCode).String;
	fCode 		:= self.getXlatedForeignCode(_protocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, terminal).trimRight;

	if _activity = COARRI_SHIPLOAD then
		strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeLOCSegment (_protocol, null, '9',  fCode, '139', '6', null, null, null), _coll);
		_count := _count + 1;
	else
		strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeLOCSegment (_protocol, null, '11',  fCode, '139', '6', null, null, null), _coll);
		_count := _count + 1;
	endif;

	//PON requested additional LOC segement here	
	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeLOCSegment (_protocol, null, '165', fCode, "139", "6", _protocol.camGroup.facilityCode, "TER", "ZZZ"), _coll);
	_count := _count + 1;
	return strLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_count" type="Integer" usage="io"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_NAD" id="514d2d2c-f834-4e15-9c23-ac9e302bd49a">
        <updating/>
        <source>outputHeader_NAD(_protocol :CM_CamProtocol; _camTaskHistory :CM_CamTaskHistory input; _camMessage :CM_CamMessage input; _coll :HugeStringArray input) : String updating, protected;
/*
Date		Who		Reason
20/12/2012	cnwcs5	CCMS SFW 1294 /par 30855
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
vars
	strLine : String;
begin
	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeNADSegment (_protocol, null, "CA", _protocol.camGroup.shippersCode.trimBlanks, '172', '20'), _coll);
	
	_camMessage.segmentCount := _camMessage.segmentCount + 1;
	
	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeNADSegment (_protocol, null, "MS",  _protocol.camGroup.senderCode.trimBlanks, '160', '87'), _coll);
	
	_camMessage.segmentCount := _camMessage.segmentCount + 1;
	return strLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_UNB" id="5615b6d2-f54d-4284-82f7-76c4e74196b9">
        <updating/>
        <source>outputHeader_UNB(_protocol :CM_CamProtocol; _camTaskHistory :CM_CamTaskHistory input; _seqNumber :Integer; _coll :HugeStringArray input) : String updating, protected;
/*
Date		Who		Reason
20/12/2012	cnwcs5	CCMS SFW 1294 /par 30855
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
vars
	
begin
	return self.outputFileMessage (_camTaskHistory, 
									self.makeUNBSegment (_protocol, "UNOA", 2, self.getSenderCode_UNB (_protocol), null, 
									_protocol.camGroup.recipient.trimBlanks, null, _seqNumber, null, false, _camTaskHistory.runDateTime),
									_coll);	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
