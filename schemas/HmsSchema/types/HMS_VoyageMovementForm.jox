    <JadeMethod name="cmbCopyVoyage_click" id="396a9ed8-0872-4545-a0c1-9b92843d41d5">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCopyVoyage_click(combobox: ComboBox input) updating;
// 31075
vars	
	indx		: Integer;
	saveIndex	: Integer;
	voyage	: CM_Voyage;
	movement	: HMS_VoyageMovement;
begin
	self.cmbCopyMvmt.clear();
	voyage := combobox.listObject.CM_Voyage;
	if voyage = null or voyage.myHMSVoyageData = null then
		return;
	endif;
	foreach movement in voyage.myHMSVoyageData.allVoyageMovements do
		indx := self.cmbCopyMvmt.addItem(movement.moveType &amp; '  ' &amp; movement.occursOnDTNEW.shortCurrentLocaleFormat() &amp; '  [' &amp; movement.allResourceUsed.size.String &amp; ']');
		self.cmbCopyMvmt.itemObject[indx] := movement;
		if movement.moveType = self.myCurrentMovement.moveType then
			saveIndex := indx;
		endif;
	endforeach;
	if indx &gt; 0 then
		if saveIndex &lt;&gt; 0 then
			self.cmbCopyMvmt.listIndex := saveIndex;
		else
			self.cmbCopyMvmt.listIndex := 1;
		endif;
	endif;
end;
</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbHMSVoyage_click" id="10927a3a-2b17-45c2-a62a-c3d90f4b9c14">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbHMSVoyage_click(combobox: ComboBox input) updating;
//--------------------------------------------------
// Created:	27 October 2005 By: cnwgd1
//--------------------------------------------------
vars
	voyageData : HMS_VoyageData;
begin
	voyageData := combobox.listObject.HMS_VoyageData;
	if voyageData &lt;&gt; null then
	//	if voyageData.isArchived() then
	//		self.cmbMovements.listCollection(voyageData.allVoyagetMovementsArchived, true, 0);
	//	else
	//		self.cmbMovements.listCollection(voyageData.allVoyageMovements, true, 0);
	//	endif;
		self.populateCmbMovements( voyageData.myVoyage );	//19 Nov 2018	NDL	TFS 42043
	else
		self.cmbMovements.clear();
	endif;
	
	if self.cmbMovements.listCount &gt; 0 then 
		self.cmbMovements.listIndex := 1;	
		self.setMyCurrentMovement(self.cmbMovements.listObject.HMS_VoyageMovement);		
	else
		self.setMyCurrentMovement(null);			
	endif;
	
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbHMSVoyage_displayEntry" id="2ca19c4f-38a3-456f-91aa-85957ff3caba">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbHMSVoyage_displayEntry(combobox: ComboBox input; obj: HMS_VoyageData; lstIndex: Integer):String updating;
//--------------------------------------------------
// Created:	27 October 2005 By: cnwgd1
//--------------------------------------------------
vars

begin

	//21 Aug 2019	NDL	TFS 46201
	if obj.myVoyage.archived then
		return null;	//don't show archived
	elseif obj.allVoyageMovements.isEmpty then
		return null;	// don't show those without movements.
	endif;

	// TFS 40747  for Andrew only show voyages for my terminal
 	executeWhen JMTDevelopmentEnvironment; 
	if process.isJLGAB1 then
		if obj.getMyTerminal &lt;&gt; self.myTerminal then
			return "";
		else
			return self.myAssistant.displayEntryHMSVoyageData(obj);
		endif;
	endif;
	
	endExecuteWhen;

	return self.myAssistant.displayEntryHMSVoyageData(obj);
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="HMS_VoyageData"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
