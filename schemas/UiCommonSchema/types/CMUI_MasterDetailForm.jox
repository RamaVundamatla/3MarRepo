    <JadeMethod name="setTblDataDetailCellText" id="e1cdb396-8563-4d2d-b9a4-50692bd07f57">
        <updating/>
        <source>setTblDataDetailCellText(table : Table input) updating;
// ---------------------------------------------------------------------------
// Created:     26 July 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	cntrl : Control;
begin
	
	if (not table.userInputEnabled)
	or table.row &lt;= table.fixedRows then
		return;
	endif;

		
	if table.accessCell(table.row, table.column).enabled then
		cntrl := table.accessedCell.cellControl;
		if TextBox.hasInstance(cntrl) then
			table.accessedCell.text := cntrl.TextBox.text;
		elseif ComboBox.hasInstance(cntrl) then
			table.accessedCell.text := cntrl.ComboBox.text;
		endif;
	endif;
		
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="8c40e8a1-1af1-4c15-ae52-51032c34099d">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     30 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;
	
	inheritMethod();

	self.initForm();
	
	if self.showTblDetailCount then
		self.splMain.setDistanceFromBottom(self.staMain.height);
	else
		self.splMain.setDistanceFromBottom(0);
	endif;

	self.armNotifications();
	self.setForPermission();
	self.zInitControls();
	self.zSetControlsForView();
	self.resetSearch();
	
	self.setNavigatorHeading(self.caption);
	self.tblSearch.setFocus;
	self.tblSearch.moveFirst();
	self.btnSearch.default := true;
	
	self.tblSearch.top := CMUI_Toolbar.HeightWithoutCaptions; // ### TFS 50421 17SEP2021 NAVAB1
end;</source>
    </JadeMethod>
