<Class name="CM_CamINTRACDesc" id="223bab5b-bd8c-48cd-82b5-680d5df97048">
    <superclass name="CM_CamEDIFACTDesc"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>This is an implementation of Intracon.
The Intracon Implementation has some strange alterations from normal cam protocols.
The non vessel movements are not grouped by voyage so the voyage code in camVoyage is set to all Z's.
This ensures that all ship(terminal) movements are listed out prior to road/rail(depot) movements.
Since PoCams lists containers by id not date/time order like other cam protocols an additional dictionary
was added to camMessage. This is referenced in camVoyage as "massages" and is manually maintained.
This ordering is done to enable windiff to easily compare the two systems during parallel run.
This dictionary should be removed when PoCams is removed.</text>
    <DbClassMap file="cams"/>
    <JadeMethod name="availableTransactions" id="0d4ae3a1-fd91-45fe-9e22-5b7cf485846b">
        <source>availableTransactions(_classColl: ClassColl input);
// 10/02/2011	cnwcs5	CCMS JMT 1977/PAR 26531 - changed parameter usage from io to input
vars

begin
	_classColl.add(CM_PackComplete);
	_classColl.add(CM_ReceiveRail);
	_classColl.add(CM_ReceiveRoad);
	_classColl.add(CM_ReleaseRail);
	_classColl.add(CM_ReleaseRoad);
	_classColl.add(CM_ReceiveShip);
	_classColl.add(CM_ReleaseShip);
	_classColl.add(CM_DairyBoard);
	_classColl.add(CM_Damage);
	_classColl.add(CM_HideLined);
	_classColl.add(CM_PreTrip);
	_classColl.add(CM_Repair);
	_classColl.add(CM_Wash);
end;
</source>
        <Parameter name="_classColl" type="ClassColl" usage="input"/>
    </JadeMethod>
    <JadeMethod name="checkEditTransaction" id="570ce841-d5b9-4a35-8b87-28023ff53250">
        <updating/>
        <source>checkEditTransaction(_transaction : CM_TITransaction; _camProtocol : CM_CamProtocol; _camAgent : CM_CamControllerAgent input; _camFile : CM_CamFile io)updating;

//18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
//06 Mar 2015	cnwrs1	Par35784 - increased exclusion reason logging to include non excluded

vars
	trans,saveTrans:CM_TITransaction;
	field,oldValue,newValue:String;
	i:Integer;
	tmpTerminal	: CM_Terminal;

begin
	if not _transaction.isCamsEditType() then
		return;
	endif;

	//we have an edit transaction see if it is intesteresting
	foreach i in 1 to _transaction.CM_Edit.fieldsValues.size do
		_transaction.CM_Edit.getFieldValues(i,field,oldValue,newValue);
		//see if it includes a voyage change
		if field = CM_TrackedItem::myVoyage.name then
			tmpTerminal := _transaction.myTerminal;
			// if the old value is null voyage and the new value is not then find the last gate/rail in and process it
			if oldValue = tmpTerminal.getDefaultVoyageCode then
				if newValue &lt;&gt; null and newValue &lt;&gt; oldValue then
					foreach trans in _transaction.myTrackedItem.allTransactions do
						if self.isTransactionToBeProcessed(_camProtocol, trans, _camAgent) then //par 21254 cnwrs1 oct 2009
							saveTrans := trans;
						endif;
		                if trans = _transaction then  //dont want to pickup later receive/release transactions
		                	break;
		                endif;
					endforeach;
					if saveTrans &lt;&gt; null then
						//FD for pars 4298 :The Edit may be done very recently,so the saveTrans might already be
						//processed in builFile before this
						if (saveTrans.dateTime &lt;= _camAgent.startDateTime) or (saveTrans.dateTime &gt;= _camAgent.endDateTime) then
							if _camAgent.logIncludedTransactions then
								_camAgent.logReasonForInclusion(saveTrans, "Transaction is edit to be processed");
							endif;
							self.processTransaction(saveTrans, _camProtocol, _camAgent, _camFile);
						endif;
					endif;
				endif;
			endif;
		endif;
		
		//CCMS 1169 19/9/2003 special for edit
		if field = "Operator"  and _camProtocol.gateInForNullOperatorChange   then
			// if the old value is null voyage and the new value is not then find the last gate/rail in and process it
			if oldValue.trimBlanks = "PON" then
				if newValue.trimBlanks = "PONR" or newValue.trimBlanks ="POND" then
					self.processTransaction(_transaction, _camProtocol, _camAgent, _camFile);
				endif;
			endif;
		endif; 
	endforeach;
end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="io"/>
    </JadeMethod>
    <JadeMethod name="create" id="c76b6aa6-fb61-4933-9226-8778e81dd257">
        <updating/>
        <source>create() updating;
//----------------------------------------------------------------
//	Created:	03 March 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.name := "NZEDI Intracon";
	self.type := EDIFileTypeCams_NZEDIIntracon;

end;</source>
    </JadeMethod>
    <JadeMethod name="getContentsStatusString" id="9da42d74-6ead-4735-992d-1f3485bc3655">
        <source>getContentsStatusString(contentsStatus: Integer): String;

vars
	contentsString:String;
begin
	if contentsStatus = TI_CONTENTS_STATUS_EMPTY then
		contentsString := "E";
	elseif contentsStatus =TI_CONTENTS_STATUS_FCL then
		contentsString := "F";
	elseif contentsStatus = TI_CONTENTS_STATUS_LCL then
		contentsString := "L";
	else
		contentsString := "";
	endif;
	return contentsString;
end;</source>
        <Parameter name="contentsStatus" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
