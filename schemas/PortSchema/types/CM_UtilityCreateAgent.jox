    <JadeMethod name="utlCreateTempReading" id="8d0af338-124f-491d-8faf-456baae4215b">
        <updating/>
        <source>utlCreateTempReading(_tempParams: CMIF_TempReading input; _passport: CM_Passport input): CM_TempReading updating;
// ---------------------------------------------------------------------------
// Created:		09 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
vars
	newTempReading				: CM_TempReading;
	//realTrackedItem,aProxyTI	: CM_Container;		// CCMS 1007
	realTrackedItem,aProxyTI	: CM_TrackedItem;	// CCMS 1007
	expectedEdition				: Integer;
begin

	self.initialiseActivity();
	
	aProxyTI := _tempParams.myTrackedItem;

	aProxyTI.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	aProxyTI.pxyGetRealObjectAndEdition(realTrackedItem, expectedEdition);
	
	if realTrackedItem = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_TrackedItem.name, null, null);
		return null;
	endif;

	app.myValCA.valTempReading(_tempParams);

	if not self.checkValidationWithPassport(_passport) then
		return null;
	endif;
	app.setContinueCMExceptions(false);

	exclusiveLock(realTrackedItem);

//	if auto connected then then edition will be different
//	if _passport.noErrors and realTrackedItem.edition &lt;&gt; expectedEdition then
//		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'realTrackedItem', null, null);
//		return null;
//	endif;
	
	if _passport.noErrors then
		_tempParams.myTrackedItem := realTrackedItem;
		
		//cnwmc5 - 20 Oct 2015 - PAR 37057
		if realTrackedItem &lt;&gt; null and realTrackedItem.getExternalMonitoring() then
			_tempParams.noCharge := true; // TFS 3844 NO CHARGE; this is part of the functionality of monitoring for certain operators
		endif;
		
		create newTempReading persistent;
		newTempReading.setForCreate(_tempParams);
	
	endif;
	
	if _passport.noErrors then
		//note for monitor
		if _tempParams.isRefConReading then
			_tempParams.myTerminal.causeEvent(_tempParams.myTerminal.getTerminalEvent(EVENT_TEMP_CREATE_REFCON), false, newTempReading);
		endif;
		//plus normal note
		_tempParams.myTrackedItem.causeEvent(_tempParams.myTerminal.getTerminalEvent(EVENT_TEMP_CREATE), false, newTempReading);
	endif;
	
	return newTempReading; 
	
end;</source>
        <Parameter name="_tempParams" type="CMIF_TempReading" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_TempReading"/>
    </JadeMethod>
