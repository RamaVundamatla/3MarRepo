    <JadeMethod name="btnSave_click" id="0ecef563-6a13-4935-be23-fd3fb78d17a4">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSave_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2018	jlgndl1	Initial creation	TFS 39215

*/

vars

begin

	if self.doSave then
		self.modalResult := IDOK;
		self.unloadForm();
	endif;

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="checkNotReadySurcharge" id="b8cf2dc0-a1ce-43f5-bb6d-1e175ea38679">
        <updating/>
        <source>checkNotReadySurcharge( _warnOnly : Boolean ):Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 22/06/2018	jlgdap1		Initial creation TFS 39355 PEL1 Pilot Surcharges
//
vars
	requestedDT : TimeStamp;
	actualDT : TimeStamp;
	
	currentValue : Boolean;		//06 Dec 2018	NDL	TFS 42403
	retValue : Boolean;		//06 Dec 2018	NDL	TFS 42403


begin

	currentValue := self.chkNotReady.value;	//06 Dec 2018	NDL	TFS 42403

	// if requested date is valid, and actual date is valid, and requested &lt;&gt; actual,
	// then check the "Not Ready" check box
	requestedDT.setDate(self.txtPilotReqDate.getDate);
	requestedDT.setTime(self.txtPilotReqTime.getTime);
	if requestedDT.isValid then
		actualDT.setDate(self.txtPilotActDate.getDate);
		actualDT.setTime(self.txtPilotActTime.getTime);
		if actualDT.isValid and actualDT &lt;&gt; requestedDT then
			self.chkNotReady.value := true;
			if app.getMyUser.canDo(self.myTerminal, PmShpMarineVoyageNotReady) then
				self.chkNotReady.enabled := true;
				self.btnRecalc.enabled := true;
			endif;
		endif;
	endif;
	
	retValue := self.chkNotReady.value &lt;&gt; currentValue;	//06 Dec 2018	NDL	TFS 42403
	
	//06 Dec 2018	NDL	TFS 42403
	
	if _warnOnly then
		self.chkNotReady.value := currentValue;
	else
		self.btnRecalc.foreColor := Black;
	endif;
	
	return retValue;	//06 Dec 2018	NDL	TFS 42403
	
epilog

end;</source>
        <Parameter name="_warnOnly" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkTooSoonSurcharge" id="d98d17b7-f5ce-495b-9720-e84d822b98ac">
        <updating/>
        <source>checkTooSoonSurcharge( _warnOnly : Boolean ):Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 22/06/2018	jlgdap1		Initial creation TFS 39355 PEL1 Pilot Surcharge
//
vars
//	requestDT, actualDT : TimeStamp;
	timeRequestMade : TimeStamp;
	timeRequestMadeFor : TimeStamp;
	timeDiff : TimeStampInterval;
	hours : Real;
	voyage : CM_Voyage;	//29 Oct 2018	NDL	TFS 41638
	imsr : CM_WodMarineServicesInitial;	//29 Oct 2018	NDL	TFS 41638
	
	currentValue : Boolean;		//06 Dec 2018	NDL	TFS 42403
	retValue : Boolean;		//06 Dec 2018	NDL	TFS 42403

begin

	currentValue := self.chkTooSoon.value;	//06 Dec 2018	NDL	TFS 42403

	// if requested date/time is valid, and Movement actual date/time is valid,
	// for arrival movements, if requested and actual are &lt; 6 hours apart
	// for shift and departure, if requested and actual are &lt; 3 hours apart
	// tick the Too Soon check box, and enable it if user has correct permission
	self.chkTooSoon.value := false;

	timeRequestMadeFor.setDate(self.txtPilotReqDate.getDate);
	timeRequestMadeFor.setTime(self.txtPilotReqTime.getTime);
	if self.myMarineServicesTimings &lt;&gt; null and self.myMarineServicesTimings.myMovement &lt;&gt; null then
	//	actualDT := self.myMarineServicesTimings.myMovement.occursOnDTNEW;
		//30 Oct 2018	NDL	TFS 41638 - use imsr entered date against  marine service pilot requested
		voyage := self.myMarineServicesTimings.myMovement.getMyVoyage;
		if voyage &lt;&gt; null then
			imsr := voyage.getWorkOrderForIMSR();
			if imsr &lt;&gt; null and imsr.getMyParent &lt;&gt; null and imsr.getMyParent.enteredByDT.date.isValid then
				timeRequestMade.setDate(imsr.getMyParent.enteredByDT.date);
				timeRequestMade.setTime(imsr.getMyParent.enteredByDT.time);
			endif;
		endif;
		
	endif;
	if timeRequestMade.isValid and timeRequestMadeFor.isValid then
		timeDiff := timeRequestMadeFor - timeRequestMade;
		hours := timeDiff.asHours();
		if hours &lt; 6 and self.myMarineServicesTimings.myMovement.moveType = HMSMovementTypeArrival then
			self.chkTooSoon.value := true;
			if app.getMyUser.canDo(self.myTerminal, PmShpMarineTooSoon) then
				self.chkTooSoon.enabled := true;
				self.btnRecalc.enabled := true;
			endif;
		elseif hours &lt; 3 and self.myMarineServicesTimings.myMovement.moveType.isOneOf(HMSMovementTypeShift, HMSMovementTypeDeparture) then
			self.chkTooSoon.value := true;
			if app.getMyUser.canDo(self.myTerminal, PmShpMarineTooSoon) then
				self.chkTooSoon.enabled := true;
				self.btnRecalc.enabled := true;
			endif;
		endif;
	endif;
	
	retValue := self.chkTooSoon.value &lt;&gt; currentValue;	//06 Dec 2018	NDL	TFS 42403
	
	//06 Dec 2018	NDL	TFS 42403
	if _warnOnly then
		self.chkTooSoon.value := currentValue;
	else
		self.btnRecalc.foreColor := Black;
	endif;
	
	return retValue;	//06 Dec 2018	NDL	TFS 42403
	
epilog

end;</source>
        <Parameter name="_warnOnly" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="cd99dfe5-b2b2-4847-931b-274da67da965">
