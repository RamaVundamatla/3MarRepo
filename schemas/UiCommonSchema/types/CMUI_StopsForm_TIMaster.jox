    <JadeMethod name="setupForm" id="838ef555-d57a-4814-9e7a-5a22aea8fdbd">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     17 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	master	:CM_TIMaster;
begin
	master := self.myTIMaster;
	
	// make sure we have the selecetd TI in our coll
	self.allTIMasters.addNoDuplicates (master, false);

	inheritMethod();

	self.loadStops (master);
	self.setCaption (master.id);
	
	self.beginNotification (master, Object_Update_Event, Response_Continuous, null);
	self.beginNotification (master, Object_Delete_Event, Response_Continuous, null);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="fa311158-cef6-4da1-901b-264119d56937">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0016221, locale);
end;</source>
    </JadeMethod>
</GUIClass>
