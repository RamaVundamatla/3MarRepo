    <JadeMethod name="doBaseFormSave" id="fdc3fb3c-3ddc-4fa6-85e1-2ee22b3f8981">
        <updating/>
        <source>doBaseFormSave() updating, protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
14 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

	rtnValue : Boolean;
begin
	rtnValue:=self.doSave();
	
epilog
	if rtnValue then
		self.unloadForm;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSave" id="2b58753d-134e-48d7-89b8-0aa22ec84fde">
        <source>doSave():Boolean;
// ---------------------------------------------------------------------------
// Created:     02 September 2008 by concms1:1
//
// Purpose:     User definable forms - CCMS 1011
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	proxy, config	: CM_FormConfigForm;
	rtnValue		: Boolean;
	result			: Integer;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	create proxy transient;
		
	if cmbForm.listIndex &gt; 0 then		
		proxy.setFormName (cmbForm.itemText[cmbForm.listIndex]);
	endif;
	
	if cmbTerminal.listIndex &gt; 0 then
		proxy.setMyTerminal (cmbTerminal.itemObject[cmbTerminal.listIndex].CM_Terminal);
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxCA.trxCreateFormConfiguration(proxy, config, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			return true;
		else
			theResult := app.showErrorWarningDialog('Form Configuration', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;
	
epilog
	delete proxy;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadForms" id="46fa9ac5-8e06-443b-bf1e-ada65151ccd6">
        <source>loadForms()protected;
// ---------------------------------------------------------------------------
// Created:     02 September 2008 by concms1:1
//
// Purpose:     User definable forms - CCMS 1011
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	index	:Integer;
begin
	index := cmbForm.addItem ('Flexi Gate In/Out');
	
	cmbForm.itemText[index] := 'GTE_InOutExpressForm';
	cmbForm.listIndex 		:= index;
	cmbForm.enabled			:= false;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadTerminals" id="470d1667-272c-4f41-a371-7d9c964b2084">
        <source>loadTerminals()protected;
// ---------------------------------------------------------------------------
// Created:     02 September 2008 by concms1:1
