    <JadeMethod name="initialiseRoot" id="1fd2e2e7-87c1-4adc-a9a4-28b02165dcc0">
        <updating/>
        <source>initialiseRoot() updating;
// -----------------------------------------------------------------------------
// Created:		11 February 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
// 01/05/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// 30/01/2015	cnwdap1		PAR #35610 Create Null Carrier
// 18 Sep 2018	jlgrs1		TFS 40627 STWR Make EDI MultiThreaded
// 29 Aug 2019	jlgdi1		45802 Added a method call to createJMTSupportUser
// 21 Sep 2020  cnwma1		ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data
// 29 Sep 2021  navma1 		ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
// 19 Jul 2022	navkc1		Bug 54130: CUX - 1090 Error in Job Operations with Ship Release
// -----------------------------------------------------------------------------
vars
	tableAgent : EntTableAgent;
	entRoot	: EntTableDataRoot;
	ok		: Boolean;
	errStr	: String;
begin
	self.createNullOperator();
	self.createNullCarrier();		// PAR #35610
	self.initCargoBOLTypes();
//	self.initProductTypes();
	self.initMutexes();				//15 Sep 2021	NDL	TSF 51143 - renamed
	self.initCodeGroupTypes();
	self.initTerminalAreaTypes();
	self.createMachineTypes();
	self.createSuperuser();
	self.createJMTSupportUser();
	self.createNavOpsViewUser();	//21.09.2020 cnwma1 TFS #49758
	self.createStatii();
	self.createMeasurementTypes();	// PAR #31155
	self.createWeightRanges();
	self.createInvoiceCalcTypes();
	self.createDebtorTypes();
	self.createNullVessel();		//07 Jun 2018	NDL	TFS 38914
	self.revealAllFinancialTypes();	// PAR 36631
	self.createRoadProcesses();		// ### JIRA: MTN-37041 22Jan2026 NAVPW1
	
	create tableAgent transient;
	// createEntTableDataRoot();
	ok := tableAgent.utlCreateDataRoot(CM_EntTableDataRoot,
								  'Gate', '',
								  PortSchemaName,
								  'EntTableGroups',
								  'EntTableDefs',
								  'EntTableRows',
								  errStr,
								  entRoot);
	
	self.loadNavObjectDefs(false);
	self.createDefaultNavObjectGroups(false);
	self.createTranslationCategories();
	self.createWorkOrderDetailTypes();				//29.09.2021 navma1 #51925
	self.createVoyageJobTransferTypes();			//19.07.2022 navkc1	#54130
epilog
	delete tableAgent;
end;</source>
    </JadeMethod>
    <JadeMethod name="initializeForActivity" id="e327c769-6ce3-4f85-9e89-230ef1079037">
        <updating/>
        <source>initializeForActivity(_ewsOpsView: CM_EWSActivityOpsview; _opsViewTable : CMIF_OpsViewTables) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2022	navsp1	Initial creation TFS#53369

*/

vars
	n4Complex		: CMIF_ArgoComplex;
begin

	if _opsViewTable.isKindOf(CMIF_ArgoComplex) then 					//navsp1 03MAY2022 TFS#53369
		n4Complex						:=_opsViewTable.CMIF_ArgoComplex;
		n4Complex.tableName				:= n4Complex.Argo_complex;          
		n4Complex.gkey					:= n4Complex.generateCpxGKey();		//navsp1 03MAY2022 TFS#53369
		n4Complex.id		    		:= self.companyCode;			//navsp1 03MAY2022 TFS#53369
		n4Complex.name		    		:= self.licenseName[1:30];	//navsp1 03MAY2022 TFS#53369
		n4Complex.opr_gkey				:= n4Complex.generateCpxGKey();		//navsp1 03MAY2022 TFS#53369
		n4Complex.time_zone		   		:= app.systemTimeZoneID; // ### TFS 51853 27AUG2021 NAVAB1		//navsp1 03MAY2022 TFS#53369
		n4Complex.life_cycle_state 		:= n4Complex.Life_Cycle_State_ACT;  // ### TFS 52413 29NOV2021 NAVAB1 MANOJ SAYS	//navsp1 03MAY2022 TFS#53369
	endif;
epilog

end;</source>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <Parameter name="_opsViewTable" type="CMIF_OpsViewTables"/>
    </JadeMethod>
    <JadeMethod name="isAnEmptyCommodity" id="6ccb5628-17fc-419d-94e5-79aebf5d8814">
        <source>isAnEmptyCommodity(_commodity : String; _nullIsEmpty : Boolean) : Boolean;

vars
	tmpCommodity	: CM_Commodity;
begin
	if _commodity = null then
		return _nullIsEmpty;
	endif;
	tmpCommodity := self.allCommodities[_commodity];
	if tmpCommodity = null then
		return _nullIsEmpty;
	endif;
	
	return tmpCommodity.isEmpty;

end;
</source>
        <Parameter name="_commodity" type="String"/>
        <Parameter name="_nullIsEmpty" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isAsynchronousMethodEnabled" id="0e847ce9-98bc-4f02-9a61-88f6fd5e6621">
        <source>isAsynchronousMethodEnabled(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Apr 2024 navma1 ChangeRequest 63823: EUP | Performance Async Workers workorder operations

*/

vars

begin
	

	if app.myRoot.isClientEuroPorts()  or 
	   app.myRoot.isClientJadeMaster() or 
	   app.myRoot.isClientJMTTesting() then
		
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isCandidateCalendarDate" id="46b8b69e-3c6e-49e8-b056-7e5544119231">
        <source>isCandidateCalendarDate(_dayNamesArray : StringArray;
						_calendar : CM_Calendar;
						_templateCalendarDate : CM_CalendarDate;
						_proposedDate : Date ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 November 2010	cnwndl1	Initial creation	CCMS 1185 / Par 25530
	// This method is here so that it is easier for Hook code call to make use of it as a default if required...
	
	The dayNames array contains Monday thru Sunday in order, in positions 1 - 7. (I.e. the same as Jades 'dayOfWeek' value)
	The date is passed in along with the template Calendar date.
	The description of the template determines what sort of date we are looking for.

*/

vars

//	type : String;

begin

	return _calendar.isCandidateCalendarDate(_dayNamesArray, _templateCalendarDate, _proposedDate );

/*	type := _templateCalendarDate.description;
	
	
	if _templateCalendarDate.dataSource = 0 then
		// Its a yearly type - we don't check anything on these
		return true;
		
	
		
	elseif _templateCalendarDate.dataSource = 1 then
		// Its a 'day of the week' type
		return _dayNamesArray[ _proposedDate.dayOfWeek ] = type;
		
	
		
	elseif _templateCalendarDate.dataSource = 2 then
		// Its a monthly type
		if type = app.getErrorString(First_day_of_month) then	// First Day of Month
			if _proposedDate.day &lt;&gt; 1 then
				return false;
			endif;
		elseif type = app.getErrorString(Last_day_of_month) then	// Last Day of Month
			if ( ( _proposedDate + 1 ).Date.day ) &lt;&gt; 1 then
				return false;
			endif;
		elseif type = app.getErrorString(First_business_dom) then	// First Business Day of Month
			if _proposedDate &lt;&gt; _proposedDate.getFirstBusinessDayOfMonth then
				return false;
			endif;
		elseif type = app.getErrorString(Last_business_dom) then	// Last Business Day of Month
			if _proposedDate &lt;&gt; _proposedDate.getLastBusinessDayOfMonth then
				return false;
			endif;
		elseif type = app.getErrorString(First_monday_month) then	// First Monday of Month
			if _proposedDate.dayOfWeek &lt;&gt; 1 then
				return false;
			endif;
			if _proposedDate.day &gt; 7 then
				return false;
			endif;
		elseif type = app.getErrorString(Last_monday_month) then	// Last Monday of Month
			if _proposedDate.dayOfWeek &lt;&gt; 1 then
				return false;
			endif;
			if ( _proposedDate + 7 ).Date.month = _proposedDate.month then
				return false;
			endif;
		elseif type = app.getErrorString(First_tuesday_month) then	// First Tuesday of Month
			if _proposedDate.dayOfWeek &lt;&gt; 2 then
				return false;
			endif;
			if _proposedDate.day &gt; 7 then
				return false;
			endif;
		elseif type = app.getErrorString(Last_tuesday_month) then	// Last Tuesday of Month
			if _proposedDate.dayOfWeek &lt;&gt; 2 then
				return false;
			endif;
			if ( _proposedDate + 7 ).Date.month = _proposedDate.month then
				return false;
			endif;
		elseif type = app.getErrorString(First_wednesday_month) then	// First Wednesday of Month
			if _proposedDate.dayOfWeek &lt;&gt; 3 then
				return false;
			endif;
			if _proposedDate.day &gt; 7 then
				return false;
			endif;
		elseif type = app.getErrorString(Last_wednesday_month) then	// Last Wednesday of Month
			if _proposedDate.dayOfWeek &lt;&gt; 3 then
				return false;
			endif;
			if ( _proposedDate + 7 ).Date.month = _proposedDate.month then
				return false;
			endif;
		elseif type = app.getErrorString(First_thursday_month) then	// First Thursday of Month
			if _proposedDate.dayOfWeek &lt;&gt; 4 then
				return false;
			endif;
			if _proposedDate.day &gt; 7 then
				return false;
			endif;
		elseif type = app.getErrorString(Last_thursday_month) then	// Last Thursday of Month
			if _proposedDate.dayOfWeek &lt;&gt; 4 then
				return false;
			endif;
			if ( _proposedDate + 7 ).Date.month = _proposedDate.month then
				return false;
			endif;
		elseif type = app.getErrorString(First_friday_month) then	// First Friday of Month
			if _proposedDate.dayOfWeek &lt;&gt; 5 then
				return false;
			endif;
			if _proposedDate.day &gt; 7 then
				return false;
			endif;
		elseif type = app.getErrorString(Last_friday_month) then	// Last Friday of Month
			if _proposedDate.dayOfWeek &lt;&gt; 5 then
				return false;
			endif;
			if ( _proposedDate + 7 ).Date.month = _proposedDate.month then
				return false;
			endif;
		elseif type = app.getErrorString(First_saturday_month) then	// First Saturday of Month
			if _proposedDate.dayOfWeek &lt;&gt; 6 then
				return false;
			endif;
			if _proposedDate.day &gt; 7 then
				return false;
			endif;
		elseif type = app.getErrorString(Last_saturday_month) then	// Last Saturday of Month
			if _proposedDate.dayOfWeek &lt;&gt; 6 then
				return false;
			endif;
			if ( _proposedDate + 7 ).Date.month = _proposedDate.month then
				return false;
			endif;
		elseif type = app.getErrorString(First_sunday_month) then	// First Sunday of Month
			if _proposedDate.dayOfWeek &lt;&gt; 7 then
				return false;
			endif;
			if _proposedDate.day &gt; 7 then
				return false;
			endif;
		elseif type = app.getErrorString(Last_sunday_month) then	// Last Sunday of Month
			if _proposedDate.dayOfWeek &lt;&gt; 7 then
				return false;
			endif;
			if ( _proposedDate + 7 ).Date.month = _proposedDate.month then
				return false;
			endif;
		endif;
		
		return true;
	
	endif;
	
	return false; */

epilog

end;</source>
        <Parameter name="_dayNamesArray" type="StringArray"/>
        <Parameter name="_calendar" type="CM_Calendar"/>
        <Parameter name="_templateCalendarDate" type="CM_CalendarDate"/>
        <Parameter name="_proposedDate" type="Date"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
