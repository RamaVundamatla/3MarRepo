    <JadeMethod name="setISOType" id="f272fa53-42fa-40c4-9908-aefa3d3c6086">
        <updating/>
        <source>setISOType(_isoCode: String; _operator: CM_Operator) updating;
//----------------------------------------------------------------
//	Created:	20 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
vars
	isotype		: String;
	foundMatch	: Boolean;
begin

	isotype := _isoCode[1:4];
	
	//now use xlation CCMS 1157
	if _operator &lt;&gt; null then
		self.isoType := _operator.getXlationSystemCode(isotype, XLATION_TYPE_ISOTYPE_BYOP, foundMatch)[1:4];
	else
		self.isoType := isotype.trimBlanks[1:4];
	endif;
epilog

end;</source>
        <Parameter name="_isoCode" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="setImCodes" id="b0315125-c715-40d1-ad8b-65ebcf3e0b02">
        <updating/>
        <source>setImCodes(_codes : String) updating;
// ---------------------------------------------------------------------------
// Created:		08 April 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
//02 Feb 2012	cnwrs1	Par 29076 Fix up Hazard Processing in EDI
vars
	tmpIMCodes : StringArray;
begin
	create tmpIMCodes transient;
	self.addImCodes(_codes, tmpIMCodes);			// MES1008 allow imCodes in toehr classes. Was typecasting to _ediTI.CM_EDIPrenoteTI.imCodes.add(_processedValue);
	self.imCodes.clear();
	tmpIMCodes.copy(self.imCodes);
epilog    
	delete tmpIMCodes;
end;</source>
        <Parameter name="_codes" type="String"/>
    </JadeMethod>
    <JadeMethod name="setLocationId" id="5af1b5e7-41a8-4b70-908b-9d37491ca54b">
        <updating/>
        <source>setLocationId(_value: String) updating;
//----------------------------------------------------------------
//	Created:	24 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.locationId := _value.padLeadingZeros(7);

epilog

end;</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setMeasurementTypeValue" id="6b661c58-34b9-4919-afbd-7ebe09bf1173">
        <updating/>
        <source>setMeasurementTypeValue(_columnName: String; _value: String) : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 September 2014	cnwmc5	Initial creation	PAR 34533

*/

vars
	rowName,
	measureType		: String;
	
begin

	if not inheritMethod(_columnName, _value) then
		return false;
	endif;
	
	_columnName.getRowNameMeasureType(rowName, measureType);
	
	if rowName = ETRow_TotalWeight then
		self.weight := app.convertMeasurementForStorage(measureType, _value.asDecimalJMT());
		return true;
	endif;
	
	if self.class.getPropertyInHTree(rowName) &lt;&gt; null then
		self.setPropertyValue(rowName, app.convertMeasurementForStorage(measureType, _value.asDecimalJMT()));
	endif;
	
	return true;
	
epilog

end;</source>
        <Parameter name="_columnName" type="String"/>
        <Parameter name="_value" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setOptDischargePorts" id="175f8acb-d7d9-4f9e-9902-dd8ed99b3fef">
        <source>setOptDischargePorts(_codes: String);
// ---------------------------------------------------------------------------
//02 Feb 2012	cnwrs1	Par 29076 Fix up Hazard Processing in EDI
// 12/08/2014	cnwmh5	Change so StringArray returned by getTokens gets
//						deleted correctly
/// 22 Feb 2016	cnwrs1	TFS 3401 fixup EDI Operations update of EDI TIs
// ---------------------------------------------------------------------------
	
vars
	tokensArray				: StringArray;
begin
	self.dischargePorts.clear;
	
	if _codes &lt;&gt; "" then
		//_codes.getTokens.copy(self.dischargePorts);
		tokensArray := _codes.getTokens();
		tokensArray.copy(self.dischargePorts);
	endif;
	
epilog
	delete tokensArray;
end;</source>
        <Parameter name="_codes" type="String"/>
    </JadeMethod>
