    <JadeMethod name="pxyCreateUpdateProxy" id="203c4666-5604-41fe-8a3a-ef24f55462b8">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------------
//
// Created by: cnwsh3 
//
// Date: 22 July 2003
//
//----------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxy 	:	HMS_VesselCategory;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	proxy.myRoot := self.myRoot;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="a2efd1ad-b4df-4961-84d1-8978c778dbdb">
        <updating/>
        <source>setForUpdate(_pxyVesselCat: HMS_VesselCategory; _passport: CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod(_pxyVesselCat, _passport);
	
	self.code 			:= _pxyVesselCat.code.toUpper.trimBlanks;
	self.description	:= _pxyVesselCat.description;
	self.myRoot			:= _pxyVesselCat.myRoot;
end;</source>
        <Parameter name="_pxyVesselCat" type="HMS_VesselCategory"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="5374716f-a8f0-4c11-8562-4b6bfea47357">
        <updating/>
        <source>setProxy(_root	:	CM_Root) updating;
//--------------------------------------------------------
//
// Created by: cnwsh3 
//
// Date: 22 July 2003
//
//----------------------------------------------------------

vars

begin
	self.raiseExceptionIfNotTransient(method);
	self.myRoot := _root;

epilog

end;</source>
        <Parameter name="_root" type="CM_Root"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="b6305925-6f42-4fc8-9b0f-c5303a790650">
        <source>validateMe(_passport: CM_Passport input);
//--------------------------------------------------------
//
// Created by: cnwsh3 
//
// Date: 22 July 2003
//14/06/2022    navds20     TFS 53760 DuplicateItem not Translatable
//----------------------------------------------------------

vars
	tmpVesselCat	:	HMS_VesselCategory;
	
begin
	inheritMethod(_passport);
	
	if self.code = null then
	//	app.raiseCMException1( REQUIRED_FIELD, 'Code', ETRow_Code, null );
		app.raiseCMException( Input_required_field_code, ETRow_Code, null ); // cnwdb2	PAR 35364


	endif;
	
	if self.description = null then
	//	app.raiseCMException1( REQUIRED_FIELD, 'Description', ETRow_Description, null );
		app.raiseCMException( Input_required_field_Desc, ETRow_Description, null ); // cnwdb2	PAR 35364


	endif;
	
	if self.myRoot = null then
//		app.raiseCMException1( REQUIRED_FIELD , 'Harbour Root', null, null );
		app.raiseCMException( Input_required_field_harbRoot, null, null ); // cnwdb2	PAR 35364
	endif;
	
	
	if _passport.hasErrors then
		return;
	endif;
	
	
	tmpVesselCat := self.myRoot.allVesselCategories.getAtKey(self.code);
	if tmpVesselCat &lt;&gt; null then
		if self.isTransient and tmpVesselCat &lt;&gt; self.pxyGetRealObject() then
			//app.raiseCMException2(DuplicateItem, 'Vessel Category', self.code, ETRow_Code, null); //14.06.2022 navds20 53760
			// Vessel Category already exists for %1 : Vessel_categor_already_exists
			app.raiseCMException1(Vessel_categor_already_exists, self.code, ETRow_Code, null);  //14.06.2022 navds20 53760
		endif;
	endif;

epilog


end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
