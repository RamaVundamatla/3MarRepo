		elseif index = 12 then
			report.frmBay12.visible := true;	
			self.populateFrmBay( 	report.frmBay12,	//_bayFrame : CMUI_Frame;
								report.lblBayId12,	//_bayIdLbl : CMUI_Label input;
								report.lblColId12,	//_colIdLbl : CMUI_Label input;
								report.lblTierId12,	//_tierIdLbl : CMUI_Label input;
								report.picCell12,	//_cellPic : CMUI_Picture input;
								report.frmHatch12,	//_hatchFrm : CMUI_Frame input;
								cmifBay	//_cmifBay : CMIF_ScanPlanReportBay
								);
		endif;		
		*/
		if perPageLegendsUsed &lt;&gt; null then
			//accumulate the legends we need for this bay (may be multiples per page)
			cmifBay.getLegendsUsed( perPageLegendsUsed );
		endif;
		
		rem := index mod self.baysPerPage;
		if rem = 0 then
			// we have set up as many frames as we were requested per page
			// print what we got
			if perPageLegendsUsed &lt;&gt; null then
				self.addLegendSubHeading( perPageLegendsUsed, perPageLegendsUsed.includesColours, perPageLegendsUsed.includesAttributes );
				self.populateFrmLegend( report, perPageLegendsUsed );
			endif;
			self.populateFrmFooter( report, dt );
			app.printer.print( report.frmMain );
			app.printer.newPage();
			index := 0; // set our counter back.
			
			if self.printCargoList then
				//print the associated cargo list for these bays if we were told to.
				self.doPrintCargoList( report, dt );
			endif;
			
			//Clear everything ready to start again
			self.allClonedControls.purge();
			report.frmBay1.visible := false;
			report.frmBay2.visible := false;
			report.frmBay3.visible := false;
			report.frmBay4.visible := false;
			report.frmBay5.visible := false;
			report.frmBay6.visible := false;
			report.frmBay7.visible := false;
			report.frmBay8.visible := false;
			report.frmBay9.visible := false;
			report.frmBay10.visible := false;
			report.frmBay11.visible := false;
			report.frmBay12.visible := false;
		endif;
		
	endforeach;
	
	if index &gt; 0 then
		//must be a part populated page
		if perPageLegendsUsed &lt;&gt; null then
			self.addLegendSubHeading( perPageLegendsUsed, perPageLegendsUsed.includesColours, perPageLegendsUsed.includesAttributes );
			self.populateFrmLegend( report, perPageLegendsUsed );
		endif;
		self.populateFrmFooter( report, dt );
		app.printer.print( report.frmMain );
		app.printer.newPage();
		
		if self.printCargoList then
			self.doPrintCargoList( report, dt );
		endif;
			
	endif;
	
	retValue := true;

epilog

	app.printer.close();
	delete report;
	delete perPageLegendsUsed;
	
	return retValue;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPrintCargoList" id="2a350970-2337-4126-925c-b44dc8ed518c">
        <source>doPrintCargoList( _report : CMUI_ScanPlanReport input; _dt : TimeStamp )protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 September 2020	jlgndl1	Initial creation	TFS 49963

*/

vars
	
	legendVisValue : Boolean;
	table : CM_DataTable;
	ti : CM_TrackedItem;
	newPage : Boolean;
	lastCell : JadeTableCell;
	lastCellLinePos : Integer;
	lastRow : JadeTableRow;
	nextCellLinePos : Integer;

begin

	legendVisValue := _report.frmLegend.visible;

	if self.allCurrentCargoToList.isEmpty or not printCargoList then
		return;
	endif;
	
	_report.frmLegend.visible := false;	// hide the legend frame
	
	_report.frmPrintCargoList.visible := true; // show the Cargo List frame
	
	_report.frmPrintCargoList.borderStyle := Frame.BorderStyle_None;
	_report.lblPrintCargoList.borderStyle := Frame.BorderStyle_None;
	
	table := _report.tblPrintCargo;
	
	newPage := true;	// we need to start a new page
	
	foreach ti in self.allCurrentCargoToList do
	
		if newPage then
			//set up the base data in teh table
			self.addCargoListTableLine( table, null );
			newPage := false;			
		endif;
		
		// Add the cargo to teh table
		self.addCargoListTableLine( table, ti );
		
		//check how far down teh page we are
		lastCell := table.accessCell( table.rows, 1);
		lastRow := table.accessRow( table.rows );
		lastCellLinePos := lastCell.positionTop;
		nextCellLinePos := lastCellLinePos + ( lastRow.height * 2 );
		
		if nextCellLinePos &gt; table.height then
			// if we can't fit any more, print what we have and request a new page.
			self.populateFrmFooter( _report, _dt );
			app.printer.print( _report.frmMain );
			app.printer.newPage();
			newPage := true;
		endif;
		
	endforeach;
	
	if not newPage then
		//Some more to print yet, because we didn't fill the last page we were working on.
		self.populateFrmFooter( _report, _dt );
		app.printer.print( _report.frmMain );
		app.printer.newPage();
	endif;
	
epilog

	if legendVisValue then
		//make the legend frame visible again if need be.
		_report.frmLegend.visible := legendVisValue;
	endif;
	
	//hide the Crago print frame again
	_report.frmPrintCargoList.visible := false;

	
end;</source>
        <access>protected</access>
        <Parameter name="_report" type="CMUI_ScanPlanReport" usage="input"/>
        <Parameter name="_dt" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="findCreateColourLegend" id="9e5dd651-07a0-4f18-940a-48c6b156a28d">
        <updating/>
        <source>findCreateColourLegend( _object : CM_Object; _attrIndex : Integer; _report : CMUI_ScanPlanReport ):CMIF_ScanPlanLegend updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 September 2020	jlgndl1	Initial creation	TFS 49963

*/

vars

	iter : Iterator;
	legend : CMIF_ScanPlanLegend;
	colourObject : CM_Object;
	workStr : String;
	cmifSlot : CMIF_ScanPlanReportSlot;
	cmifLegend : CMIF_ScanPlanLegend;

begin

	//Legends for std attributes
	if _attrIndex &gt; 0 then
	
		iter := self.allScanPlanLegends.createIterator;
		while iter.next( legend ) do
			if legend.attributeIndex = _attrIndex then
				return legend;
			endif;
		endwhile;
		
		create cmifLegend transient;
		cmifLegend.setAttributeDetails( _attrIndex, self );
		
		if _report &lt;&gt; null then
			create cmifSlot transient;
			cmifSlot.setFromLegend( cmifLegend );
			if self.baysPerPage &lt;= BaysPerPageThree then
				cmifLegend.picture := _report.getLegendPicFromCMIF( cmifSlot, cmifLegend, true );
			else
				cmifLegend.picture := _report.getLegendPicFromCMIF( cmifSlot, cmifLegend, false );
			endif;
			delete cmifSlot;
		endif;
	
		return cmifLegend;
		
	endif;

	
	//legends for objects
	if _object = null or self.slotColour = ColourNone then
		return null;
	endif;
	
	if _object.isKindOf( CM_Container ) then
		//27 Oct 2020 - TFS 50226
		//Additional rule. ROB that are DLR should be coloured, not grey. The DLR slot should have text and indicators.
		//Additional rule. ROB that are SOB should be coloured, not grey. The SOB slot should have text and indicators.
	//	if _object.CM_Container.isROB then
		if _object.CM_Container.isROB and ( not _object.CM_Container.isSOB and not _object.CM_Container.isRehandle ) then
			if self.myROBGrey = null then
				create self.myROBGrey transient;
				self.myROBGrey.setAttributeDetails( self.ROMAttribute, self );
			endif;
			return self.myROBGrey;
			
		elseif self.slotColour = ColourCommodity then
			colourObject := _object.CM_Container.myCommodityGroup;
		elseif self.slotColour = ColourDischargePort then
			colourObject := _object.CM_Container.getDischargePortObject();
		elseif self.slotColour = ColourIsoGroup then
			if self.myTerminal.getConfig(ShipShowISOType).Boolean then
				colourObject := _object.CM_Container.getISOTypeObject();
			else
				colourObject := _object.CM_Container.getISOTypeGroupObject();
			endif;
		elseif self.slotColour = ColourLoadPort then
			colourObject := _object.CM_Container.getLoadPortObject();
		elseif self.slotColour = ColourOperator then
			colourObject := _object.CM_Container.myOperator;
		endif;
		
	elseif _object.isKindOf( CM_SlotRequest ) then
		if self.slotColour = ColourCommodity then
			colourObject := _object.CM_SlotRequest.getAttrCommodityGroup;
		elseif self.slotColour = ColourDischargePort then
			workStr := _object.CM_SlotRequest.dischargePort.trimBlanks;
			if workStr &lt;&gt; null then
				colourObject := app.myRoot.allPorts[workStr];
			endif;
		elseif self.slotColour = ColourIsoGroup then
			if self.myTerminal.getConfig(ShipShowISOType).Boolean then
				colourObject := _object.CM_SlotRequest.getAttrISOType;
			else
				colourObject := _object.CM_SlotRequest.getAttrIsoGroup;
			endif;
		elseif self.slotColour = ColourLoadPort then
			if _object.CM_SlotRequest.isLoad then
				workStr := self.myTerminal.getConfig(PortDestCode).String;
			elseif _object.CM_SlotRequest.mySlotController.allTrackedItems.isEmpty then
				workStr := _object.CM_SlotRequest.mySlotController.allTrackedItems.first.loadPort;
			endif;
			if workStr &lt;&gt; null then
				colourObject := app.myRoot.allPorts[workStr];
			endif;
		elseif self.slotColour = ColourOperator then
			colourObject := _object.CM_SlotRequest.getAttrOperator;
		endif;
		
	else
		return null;
		
	endif;
	
	if colourObject = null then
		return null;
	endif;

	iter := self.allScanPlanLegends.createIterator;
	while iter.next( legend ) do
		if legend.myObject = colourObject then
			return legend;
		endif;
	endwhile;
	
	//Not found, add it.
	create legend transient;
	legend.setDetails( colourObject, self );
	
	return legend;

epilog

	delete iter;
	delete cmifSlot;

end;</source>
        <Parameter name="_object" type="CM_Object"/>
        <Parameter name="_attrIndex" type="Integer"/>
        <Parameter name="_report" type="CMUI_ScanPlanReport"/>
        <ReturnType type="CMIF_ScanPlanLegend"/>
    </JadeMethod>
    <JadeMethod name="populateCMIFPictures" id="4c6a1e28-e910-4cbe-b701-56c6f6f52f3b">
        <updating/>
        <source>populateCMIFPictures( _report : CMUI_ScanPlanReport input )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 September 2020	jlgndl1	Initial creation	TFS 49963

*/

vars

	cmifBay : CMIF_ScanPlanReportBay;
	cmifSlot : CMIF_ScanPlanReportSlot;
	attrIndex : Integer;
	addSubHeading : Boolean;

begin

	//creates the frame that represents each slot as a picture.
	foreach cmifBay in self.allScanPlanReportBays do
		foreach cmifSlot in cmifBay.allScanPlanReportSlots do
			if self.baysPerPage &lt;= BaysPerPageThree then
				cmifSlot.picture := _report.getBigCellPictureFromCMIF( cmifSlot );
			else
				cmifSlot.picture := _report.getMediumCellPictureFromCMIF( cmifSlot );
			endif;
		endforeach;
	endforeach;
	
	//Now create legends for the attributes we used
	
	//find the ones we used.
	self.allScanPlanReportBays.getPrintAttributesUsed( self.allPrintAttributesUsed );
	
	foreach attrIndex in 1 to 14 do
		if not self.allPrintAttributesUsed[attrIndex] then
			continue;
		endif;
		//For each one we used add a legend line with a matching graphic.
		self.findCreateColourLegend( null, attrIndex, _report );
		addSubHeading := true;
	endforeach;
	
	if addSubHeading then
		self.addLegendSubHeading( null, false, true );
	endif;

epilog


end;</source>
        <Parameter name="_report" type="CMUI_ScanPlanReport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="populateFrmBay" id="9f992ffd-9520-4071-be9f-ec6ac2370d8a">
        <source>populateFrmBay( _bayFrame : CMUI_Frame input;
				_bayIdLbl : CMUI_Label input;
				_colIdLbl : CMUI_Label input;
				_tierIdLbl : CMUI_Label input;
				_cellPic : CMUI_Picture input;
				_hatchFrm : CMUI_Frame input;
				_cmifBay : CMIF_ScanPlanReportBay
				) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 September 2020	jlgndl1	Initial creation	TFS 49963

*/

constants

	GridLineColour : Integer = Black; //LightGray;	22 Mar 2021 NDL TFS 50901 - Andrews changed his mind again.
	GridLineWidth : Integer = 1;
	
vars
	
	onDeckTiers : Integer;
	onDeckColumns : Integer; 
	showHatches : Boolean;
	underDeckTiers : Integer; 
	underDeckColumns : Integer; 
	rowsRequired : Integer;
	colsRequired : Integer;
	cellMaxWidth : Integer;
	cellMaxHeight : Integer;
	cellWidth : Integer;
	cellHeight : Integer;
	offsetLeft : Integer;
	
	slot : CMIF_ScanPlanReportSlot;
	index : Integer;
	topOfCellPos : Real;
	leftOfCellPos : Real;
	iter : Iterator;
	clonedPic : CMUI_Picture;
	picIndex : Integer;
	clonedLabel : CMUI_Label;
	labelIndex : Integer;
	tierTopOfCellPos : Real;
	tiersDown : Integer;
	fontSize : Real;
	
	hatchLid : CM_HatchLid;
	hatchIndex : Integer;
	clonedFrame : CMUI_Frame;
	hatchHeight : Real;
	hatchTop : Real;
	hatchWidth : Real;
	hatchLeft : Real;
	numHatchCells : Real;
	gridLineLeft : Real;
	gridLineRight : Real;
	gridLineTop : Real;
	gridLineBottom : Real;
	
	hatchLidOffSet : Integer;

begin
	
	//Work out the numbers to determine the maximum cell size.

	_cmifBay.getTierCount( onDeckTiers, underDeckTiers );
	_cmifBay.getColumnCount( onDeckColumns, underDeckColumns );
	
	showHatches := not _cmifBay.myBay.allHatchLids.isEmpty; // need to work out whether to draw hatches
	
	rowsRequired := underDeckTiers + onDeckTiers + 1; //Total number of tiers plus one for the bay label
	
	if onDeckTiers &gt; 0 then
		rowsRequired := rowsRequired + 1; // plus one for the on deck column labels
	endif;
	if underDeckTiers &gt; 0 then
		rowsRequired := rowsRequired + 1; // plus one for the under deck column labels
		if showHatches then
			rowsRequired := rowsRequired + 1; // plus one for the hatch drawing
		endif;
	endif;
	
	colsRequired := onDeckColumns.max( underDeckColumns ) + 1; // widest point plus room for the tier label.

	cellMaxWidth := ((_bayFrame.width / colsRequired).Integer - GridLineWidth ).Integer;  // Minus one for the grid line
	cellMaxHeight := ((_bayFrame.height / rowsRequired).Integer - GridLineWidth ).Integer;	 // Minus one for the grid line
	
	if self.baysPerPage &gt; 3 then
		//use square cells
		cellHeight := cellMaxWidth.min( cellMaxHeight );
		cellWidth := cellHeight;
	else
		//use rectangular cells in the ratio of 1.6w/1.0h
		if (cellMaxHeight * 1.6) &lt;= cellMaxWidth then
			cellHeight := cellMaxHeight;
			cellWidth := (cellMaxHeight * 1.6).Integer;
		else
			cellHeight := (cellMaxWidth / 1.6).Integer;
			cellWidth := cellMaxWidth;
		endif;
	endif;
	
	offsetLeft := ( ( _bayFrame.width - ( cellWidth * ( onDeckColumns + 1 ) ) - 4 ) / 2 ).Integer; //The left over width split in two to place in the centre
	
	fontSize := _colIdLbl.fontSize;
	
	//Setup the base sizes	
	_colIdLbl.height := cellHeight;
	_colIdLbl.width := cellWidth;
	_colIdLbl.fontSize := fontSize;
	while _colIdLbl.getTextHeight( "XX" ) &gt; cellHeight do
		fontSize := fontSize - .5;
		_colIdLbl.fontSize := fontSize;
	endwhile;
	while _colIdLbl.getTextExtent( "XX" ) &gt; cellWidth do
		fontSize := fontSize - .5;
		_colIdLbl.fontSize := fontSize;
	endwhile;
	
	_tierIdLbl.height := cellHeight;
	_tierIdLbl.width := cellWidth;
	_tierIdLbl.fontSize := fontSize;
	
	_cellPic.height := cellHeight;
	_cellPic.width := cellWidth;
	_cellPic.fontSize := fontSize;
	
	_bayIdLbl.top := 0;
	_bayIdLbl.left := 0;
	_bayIdLbl.height := cellHeight;
	_bayIdLbl.width := _bayFrame.width;
	_bayIdLbl.fontSize := fontSize;
	_bayIdLbl.caption := "Bay " &amp; _cmifBay.bayId;
	
	_bayFrame.drawWidth := GridLineWidth.Integer;
	_bayFrame.clearGraphics();
	_bayFrame.autoRedraw := true;
	
	//Do the On Deck Cell Id Labels
	topOfCellPos := cellHeight;	
	iter := _cmifBay.allScanPlanReportSlots.createIterator;
	while iter.next(slot) do
		if slot.ordinalDeck = 2 then	// on deck
			labelIndex := slot.ordinalCell;
			clonedLabel := _colIdLbl.getControl( labelIndex );
			if clonedLabel = null then
				leftOfCellPos := ( slot.ordinalCell * cellWidth ) + offsetLeft + ( slot.ordinalCell * GridLineWidth );  //cellwidths + offset + gridline width of 1 per cell
				
				clonedLabel := _colIdLbl.loadControl( labelIndex ).CMUI_Label;
				self.allClonedControls.add( clonedLabel );
				clonedLabel.parent := _bayFrame;
				clonedLabel.move(leftOfCellPos, topOfCellPos, _colIdLbl.width, _colIdLbl.height );
				clonedLabel.visible := true;
				clonedLabel.fontSize := fontSize;
				clonedLabel.caption := slot.mySlotController.cellId;
				
			endif;
		endif;
	endwhile;
	delete iter;
	
	//Do the On Deck Tier Id Labels
	iter := _cmifBay.allScanPlanReportSlots.createIterator;
	while iter.next(slot) do
		if slot.ordinalDeck = 2 then	// on deck
			labelIndex := slot.ordinalTier;
			clonedLabel := _tierIdLbl.getControl( labelIndex );
			if clonedLabel = null then
				tiersDown := (onDeckTiers - labelIndex + 1);
				tierTopOfCellPos := topOfCellPos + ( tiersDown * cellHeight ) + ( tiersDown * GridLineWidth );  //cellheights + gridline width of 1 per cell
				
				clonedLabel := _tierIdLbl.loadControl( labelIndex ).CMUI_Label;
				self.allClonedControls.add( clonedLabel );
				clonedLabel.parent := _bayFrame;
				clonedLabel.move(offsetLeft, tierTopOfCellPos, _tierIdLbl.width, _tierIdLbl.height );
				clonedLabel.visible := true;
				clonedLabel.fontSize := fontSize;
				clonedLabel.caption := slot.mySlotController.tierId;

			endif;
		endif;
	endwhile;
	delete iter;
		
	
	picIndex := 0;
	if onDeckTiers &gt; 0 then	//22 Dec 2020	NDL	TFS 50538
		topOfCellPos := topOfCellPos + cellHeight;
	endif;
	//Do the On Deck Cells	
	foreach index in onDeckTiers to 1 step -1 do
		iter := _cmifBay.allScanPlanReportSlots.createIterator;
		while iter.next(slot) do
			if slot.ordinalDeck = 2 then	// on deck
				if slot.ordinalTier = index then	
					picIndex := picIndex + 1;
					leftOfCellPos := ( slot.ordinalCell * cellWidth ) + offsetLeft + ( slot.ordinalCell * GridLineWidth );  //cellwidths + offset + gridline width of 1 per cell
					tiersDown := (onDeckTiers - index + 1);
					tierTopOfCellPos := topOfCellPos + ( tiersDown + GridLineWidth );  //cellheights + gridline width of 1 per cell
					
					clonedPic := _cellPic.loadControl( picIndex ).CMUI_Picture;
					self.allClonedControls.add( clonedPic );
					clonedPic.parent := _bayFrame;
					clonedPic.move(leftOfCellPos, tierTopOfCellPos, _cellPic.width, _cellPic.height );
					clonedPic.visible := true;
					clonedPic.setPicture(1,slot.picture.convertPicture(Window.PictureType_Jpeg));
					clonedPic.pictureIndex := 1;
					
					 //Gridline left of cell
					gridLineLeft := leftOfCellPos - GridLineWidth;
					gridLineRight := gridLineLeft;
					gridLineTop := tierTopOfCellPos;
					gridLineBottom := tierTopOfCellPos + cellHeight + GridLineWidth;
					_bayFrame.drawLine( gridLineLeft,  gridLineTop, gridLineRight, gridLineBottom, GridLineColour); 
					
					 //Gridline right of cell
					gridLineLeft := leftOfCellPos + cellWidth;
					gridLineRight := gridLineLeft;
					_bayFrame.drawLine( gridLineLeft,  gridLineTop, gridLineRight, gridLineBottom, GridLineColour); 
					
					 //Gridline over cell
					gridLineLeft := leftOfCellPos - GridLineWidth;
					gridLineRight := leftOfCellPos + cellWidth + GridLineWidth;
					gridLineTop := tierTopOfCellPos - GridLineWidth;
					gridLineBottom := gridLineTop;
					_bayFrame.drawLine( gridLineLeft,  gridLineTop, gridLineRight, gridLineBottom, GridLineColour); 
					
					 //Gridline under cell
					gridLineLeft := leftOfCellPos - GridLineWidth;
					gridLineRight := leftOfCellPos + cellWidth + GridLineWidth;
					gridLineTop := tierTopOfCellPos + cellHeight;
					gridLineBottom := gridLineTop;
					_bayFrame.drawLine( gridLineLeft,  gridLineTop, gridLineRight, gridLineBottom, GridLineColour); 
					
					if self.printCargoList and slot.myContainerForList &lt;&gt; null then
						self.allCurrentCargoToList.add( slot.myContainerForList );
					endif;
		
				endif;
			endif;
		endwhile;
		delete iter;
		topOfCellPos := topOfCellPos + cellHeight;
	endforeach;
	
	topOfCellPos := topOfCellPos + ( onDeckTiers * GridLineWidth); //allows for the gridlines.
	
	//Do the Hatch lid/s
	offsetLeft := ( ( _bayFrame.width - ( cellWidth * ( underDeckColumns + 1 ) )) / 2 ).Integer;	//to the start of the tier labels
	offsetLeft := offsetLeft + cellWidth; // the start of the under deck cells
	
	if showHatches then
		hatchIndex := 0;
		hatchHeight := ( cellHeight / 4 ).Integer;
		hatchTop :=  topOfCellPos + ( hatchHeight * 2 ).Integer;
		
		if underDeckColumns &lt; onDeckColumns then
			//It seems some lack of understanding in the past means that the UD values are sometimes actually 
			// just duplicates of the on deck values, so can be wrong relative to the under deck positions.
			// So if they are different total widths we need to further offset
			hatchLidOffSet := ( ( ( underDeckColumns - onDeckColumns ) / 2 ) * cellWidth ).Integer;
		endif;
		
		iter := _cmifBay.myBay.allHatchLids.createIterator;
		while iter.next(hatchLid) do
			hatchIndex := hatchIndex + 1;
			hatchLeft := offsetLeft + ( cellWidth * ( hatchLid.ordinalUDStartCell - 1 ) ); 
			if hatchLid.ordinalUDStartCell = hatchLid.ordinalODStartCell and hatchLid.ordinalUDEndCell = hatchLid.ordinalODEndCell then
				//use the value calculated above.
				hatchLeft := hatchLeft + hatchLidOffSet;
			endif;
			numHatchCells := ( ( hatchLid.ordinalUDEndCell - hatchLid.ordinalUDStartCell ) + 1 );
			hatchWidth := (numHatchCells * cellWidth ) + (( numHatchCells - 1 ) * GridLineWidth );
			
			clonedFrame := _hatchFrm.loadControl( hatchIndex ).CMUI_Frame;
			self.allClonedControls.add( clonedFrame );
			clonedFrame.parent := _bayFrame;
			clonedFrame.move(hatchLeft, hatchTop, hatchWidth, hatchHeight );
			clonedFrame.visible := true;
			
		endwhile;
		delete iter;
		topOfCellPos := topOfCellPos + cellHeight; 
	endif;
	
	//Do the Under Deck Cell Id Labels
	offsetLeft := ( ( _bayFrame.width - ( cellWidth * ( underDeckColumns + 1 ) )) / 2 ).Integer;
	iter := _cmifBay.allScanPlanReportSlots.createIterator;
	while iter.next(slot) do
		if slot.ordinalDeck = 1 then	// under deck
			labelIndex := slot.ordinalCell + onDeckColumns; // to increment out of our previous control index range
			clonedLabel := _colIdLbl.getControl( labelIndex );
			if clonedLabel = null then
				leftOfCellPos := ( slot.ordinalCell * cellWidth ) + offsetLeft + ( slot.ordinalCell * GridLineWidth );  //cellwidths + offset + gridline width of 1 per cell
				
				clonedLabel := _colIdLbl.loadControl( labelIndex ).CMUI_Label;
				self.allClonedControls.add( clonedLabel );
				clonedLabel.parent := _bayFrame;
				clonedLabel.move(leftOfCellPos, topOfCellPos, _colIdLbl.width, _colIdLbl.height );
				clonedLabel.visible := true;
				clonedLabel.fontSize := fontSize;
				clonedLabel.caption := slot.mySlotController.cellId;
				
			endif;
		endif;
	endwhile;
	delete iter;
	
	//Do the Under Deck Tier Id Labels
	iter := _cmifBay.allScanPlanReportSlots.createIterator;
	while iter.next(slot) do
		if slot.ordinalDeck = 1 then	// under deck
			labelIndex := slot.ordinalTier  + onDeckTiers;
			clonedLabel := _tierIdLbl.getControl( labelIndex );
			if clonedLabel = null then
				tiersDown := (underDeckTiers - slot.ordinalTier + 1);
				tierTopOfCellPos := topOfCellPos + ( tiersDown * ( cellHeight + GridLineWidth ) );	 //cellheights + gridline width of 1 per cell
				
				clonedLabel := _tierIdLbl.loadControl( labelIndex ).CMUI_Label;
				self.allClonedControls.add( clonedLabel );
				clonedLabel.parent := _bayFrame;
				clonedLabel.move(offsetLeft, tierTopOfCellPos, _tierIdLbl.width, _tierIdLbl.height );
				clonedLabel.visible := true;
				clonedLabel.fontSize := fontSize;
				clonedLabel.caption := slot.mySlotController.tierId;
				
			endif;
		endif;
	endwhile;
	delete iter;
	
	
	//Do the under deck cells
	topOfCellPos := topOfCellPos + cellHeight;
	foreach index in underDeckTiers to 1 step -1 do
		iter := _cmifBay.allScanPlanReportSlots.createIterator;
		while iter.next(slot) do
			if slot.ordinalDeck = 1 then	// under deck
				if slot.ordinalTier = index then	
					picIndex := picIndex + 1;
					leftOfCellPos := ( slot.ordinalCell * cellWidth ) + offsetLeft + ( slot.ordinalCell * GridLineWidth );  //cellwidths + offset + gridline width of 1 per cell
					tiersDown := (underDeckTiers - index + 1);
					tierTopOfCellPos := topOfCellPos + ( tiersDown * GridLineWidth );  //cellheights + gridline width of 1 per cell
				
					clonedPic := _cellPic.loadControl( picIndex ).CMUI_Picture;
					self.allClonedControls.add( clonedPic );
					clonedPic.parent := _bayFrame;
					clonedPic.move(leftOfCellPos, tierTopOfCellPos, _cellPic.width, _cellPic.height );
					clonedPic.visible := true;
					clonedPic.setPicture(1,slot.picture.convertPicture(Window.PictureType_Jpeg));
					clonedPic.pictureIndex := 1;
					
					 //Gridline left of cell
					gridLineLeft := leftOfCellPos - GridLineWidth;
					gridLineRight := gridLineLeft;
					gridLineTop := tierTopOfCellPos;
					gridLineBottom := tierTopOfCellPos + cellHeight + GridLineWidth;
					_bayFrame.drawLine( gridLineLeft,  gridLineTop, gridLineRight, gridLineBottom, GridLineColour);
					
					 //Gridline right of cell
					gridLineLeft := leftOfCellPos + cellWidth;
					gridLineRight := gridLineLeft;
					_bayFrame.drawLine( gridLineLeft,  gridLineTop, gridLineRight, gridLineBottom, GridLineColour);
					
					 //Gridline over cell
					gridLineLeft := leftOfCellPos - GridLineWidth;
					gridLineRight := leftOfCellPos + cellWidth + GridLineWidth;
					gridLineTop := tierTopOfCellPos - GridLineWidth;
					gridLineBottom := gridLineTop;
					_bayFrame.drawLine( gridLineLeft,  gridLineTop, gridLineRight, gridLineBottom, GridLineColour); 
					
					 //Gridline under cell
					gridLineTop := tierTopOfCellPos + cellHeight;
					gridLineBottom := gridLineTop;
					_bayFrame.drawLine( gridLineLeft,  gridLineTop, gridLineRight, gridLineBottom, GridLineColour); 
					
					if self.printCargoList and slot.myContainerForList &lt;&gt; null then
						self.allCurrentCargoToList.add( slot.myContainerForList );
					endif;
		
				endif;
			endif;
		endwhile;
		delete iter;
		topOfCellPos := topOfCellPos + cellHeight;
	endforeach;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_bayFrame" type="CMUI_Frame" usage="input"/>
        <Parameter name="_bayIdLbl" type="CMUI_Label" usage="input"/>
        <Parameter name="_colIdLbl" type="CMUI_Label" usage="input"/>
        <Parameter name="_tierIdLbl" type="CMUI_Label" usage="input"/>
        <Parameter name="_cellPic" type="CMUI_Picture" usage="input"/>
        <Parameter name="_hatchFrm" type="CMUI_Frame" usage="input"/>
        <Parameter name="_cmifBay" type="CMIF_ScanPlanReportBay"/>
    </JadeMethod>
    <JadeMethod name="populateFrmFooter" id="3a8c7b38-baa6-4c0b-badb-dc5036f44bfd">
        <source>populateFrmFooter( _report : Form; now : TimeStamp ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 September 2020	jlgndl1	Initial creation	TFS 49963

*/

vars

	report : CMUI_ScanPlanReport;

begin

	report := _report.CMUI_ScanPlanReport;
	
	report.lblPage.caption := app.getErrorString(Page) &amp; " " &amp; app.printer.pageNumber.String;
	report.lblDate.caption := now.date.format("dd MMM yyy") &amp; now.time.format(", hh:mm");

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_report" type="Form"/>
        <Parameter name="now" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="populateFrmHeader" id="a3093375-e45a-4391-bb75-22fa1f0bc9ab">
        <source>populateFrmHeader( _report : Form ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 September 2020	jlgndl1	Initial creation	TFS 49963

*/

vars

	report : CMUI_ScanPlanReport;
	voyageBaysWorkString : String;
	bay : CM_BayVoyage;
	contentString : String;

begin

	report := _report.CMUI_ScanPlanReport;
	
	// hide the borders that we display in the painter for ease of maintenance
	report.frmMain.borderStyle := 0;
	report.frmHeader.borderStyle := 0;
	report.frmFooter.borderStyle := 0;
	report.frmLegend.borderStyle := 0;
	
	report.frmBay1.borderStyle := 0;
	report.frmBay2.borderStyle := 0;
	report.frmBay3.borderStyle := 0;
	report.frmBay4.borderStyle := 0;
	report.frmBay5.borderStyle := 0;
	report.frmBay6.borderStyle := 0;
	report.frmBay7.borderStyle := 0;
	report.frmBay8.borderStyle := 0;
	report.frmBay9.borderStyle := 0;
	report.frmBay10.borderStyle := 0;
	report.frmBay11.borderStyle := 0;
	report.frmBay12.borderStyle := 0;
	
	if self.myVoyage = null then
		return;
	endif;
	
	report.picMTNLogo.setPicture( 1, app.getPicLogoProduct().convertPicture(Window.PictureType_Jpeg) );
	report.picMTNLogo.pictureIndex := 1;
	report.picCustLogo.setPicture( 1, app.getPicLogoPort().convertPicture(Window.PictureType_Jpeg) );
	report.picCustLogo.pictureIndex := 1;
	
	voyageBaysWorkString := self.myVoyage.code &amp; " - " &amp; self.myVoyage.vesselName &amp; "   " &amp; app.getErrorString(CM_Bays) &amp; " ";
	
	foreach bay in self.allSelectedBays do
		voyageBaysWorkString := voyageBaysWorkString &amp; bay.id &amp; " ";
	endforeach;
	
	report.lblVoyageBays.caption := voyageBaysWorkString;
	
	
	
	if self.slotContent = ContentActual then
		contentString := app.getErrorString(ActualComma);
	elseif self.slotContent = ContentDischarge then
		contentString := app.getErrorString(SHP_Discharge) &amp; ",";
	elseif self.slotContent = ContentDischargeAndLoad then
		contentString := app.getErrorString(Worked_load_discharge) &amp; ",";
	elseif self.slotContent = ContentLoad then
		contentString := app.getErrorString(SHP_Load) &amp; ",";
	elseif self.slotContent = ContentProposed then
		contentString := app.getErrorString(ProposedComma);
	endif;
	
	if self.slotColour = ColourDischargePort then
		contentString := contentString &amp; app.getErrorString(Spacebyspace) &amp; app.getErrorString(Mode_Discharge_Port) &amp; ", ";
	elseif self.slotColour = ColourIsoGroup then
		if self.myTerminal.getConfig(ShipShowISOType).Boolean then
			contentString := contentString &amp; app.getErrorString(Spacebyspace) &amp; app.getErrorString(CM_ISO_Type) &amp; ", ";
		else
			contentString := contentString &amp; app.getErrorString(Spacebyspace) &amp; app.getErrorString(ISO_Group) &amp; ", ";
		endif;
	elseif self.slotColour = ColourLoadPort then
		contentString := contentString &amp; app.getErrorString(Spacebyspace) &amp; app.getErrorString(Mode_Load_Port) &amp; ", ";
	elseif self.slotColour = ColourOperator then
		contentString := contentString &amp; app.getErrorString(Spacebyspace) &amp; app.getErrorString(Operator_GC) &amp; ", ";
	elseif self.slotColour = ColourCommodity then
		contentString := contentString &amp; app.getErrorString(Spacebyspace) &amp; app.getErrorString(CommodityGroup) &amp; ", ";
	elseif slotColour = ColourNone then
		// no colour added
	endif;
	
	contentString := contentString &amp; self.myVoyage.myTerminal.code &amp; " - " &amp; self.myVoyage.myTerminal.name;
	
	report.lblTypeColTerm.caption := contentString;


epilog

end;</source>
        <access>protected</access>
        <Parameter name="_report" type="Form"/>
    </JadeMethod>
    <JadeMethod name="populateFrmLegend" id="06c91a7d-4978-4873-a094-4e3946f2f31a">
        <source>populateFrmLegend( _report : Form; _perPageLegends : CMIF_ScanPlanLegendDict ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 September 2020	jlgndl1	Initial creation	TFS 49963

*/

constants

	GridLineWidth : Integer = 1;
	
vars

	report : CMUI_ScanPlanReport;
	legend : CMIF_ScanPlanLegend;
	controlIndex : Integer;
	topIndex : Real;
	offSet : Real;
	max : Real;
	clonedLegLine : CMUI_Frame;
	clonedColour : CMUI_Label;
	clonedDesc : CMUI_Label;
	clonedPicture : CMUI_Picture;
	legTitle : String;
	currentFrmLegend : CMUI_Frame;
	frmLegendIndex : Integer;
	dict : CMIF_ScanPlanLegendDict;
	
	gridLineLeft : Real;
	gridLineRight : Real;
	gridLineTop : Real;
	gridLineBottom : Real;

begin

	report := _report.CMUI_ScanPlanReport;
	
	if not self.allScanPlanLegends.isEmpty then
		report.frmLegend.visible := true;
	else
		return;
	endif;
	
	currentFrmLegend := report.frmLegend;
	topIndex := report.frmLegendLine.top;
	offSet := report.frmLegendLine.height + 1;
	controlIndex := 1;
	frmLegendIndex := 0;
	max := report.frmLegend.height;
	
//	if _perPageLegends &lt;&gt; null and not _perPageLegends.isEmpty then
	if _perPageLegends &lt;&gt; null then
		dict := _perPageLegends;
	else
		dict := self.allScanPlanLegends;
	endif;

	foreach legend in dict do
		
		clonedLegLine := report.frmLegendLine.loadControl( controlIndex ).CMUI_Frame;
		clonedLegLine.parent := currentFrmLegend;
		clonedLegLine.move(report.frmLegendLine.left, topIndex, report.frmLegendLine.width, report.frmLegendLine.height );
		clonedLegLine.visible := true;
		clonedLegLine.autoRedraw := true;
		self.allClonedControls.add( clonedLegLine );
		
		if legend.attributeIndex &gt; 0 and legend.picture &lt;&gt; null then
			clonedPicture := report.picLegend.loadControl( controlIndex ).CMUI_Picture;
			clonedPicture.parent := clonedLegLine;
			if self.baysPerPage &gt; self.BaysPerPageThree then
				clonedPicture.move(report.lblLegendCol.left, 0, clonedLegLine.height, clonedLegLine.height );
			else 
				clonedPicture.move(report.lblLegendCol.left, 0, clonedLegLine.height * 1.6, clonedLegLine.height );
			endif;
			clonedPicture.visible := true;
			clonedPicture.stretch := 4; //Picture Proportional to cell.
			clonedPicture.setPicture(1,legend.picture.convertPicture(Window.PictureType_Jpeg));
			clonedPicture.pictureIndex := 1;
			self.allClonedControls.add( clonedPicture );
			
			
			 //Gridline left of pic
			clonedPicture.autoRedraw := true;
			gridLineLeft := 1;
			gridLineRight := 1;
			gridLineTop := 0;
			gridLineBottom := clonedPicture.height;
			clonedPicture.drawLine( gridLineLeft,  gridLineTop, gridLineRight, gridLineBottom, Black); 
			
			 //Gridline right of pic
			gridLineLeft := clonedPicture.width - GridLineWidth;
			gridLineRight := gridLineLeft;
			clonedPicture.drawLine( gridLineLeft,  gridLineTop, gridLineRight, gridLineBottom, Black); 
			
			 //Gridline over pic
			gridLineLeft := 0;
			gridLineRight := clonedPicture.width - GridLineWidth;
			gridLineTop := 0;
			gridLineBottom := gridLineTop;
			clonedPicture.drawLine( gridLineLeft,  gridLineTop, gridLineRight, gridLineBottom, Black); 
			
			 //Gridline under pic
			gridLineTop := clonedPicture.height - GridLineWidth;
			gridLineBottom := gridLineTop;
			clonedPicture.drawLine( gridLineLeft,  gridLineTop, gridLineRight, gridLineBottom, Black); 
			
		else
			clonedColour := report.lblLegendCol.loadControl( controlIndex ).CMUI_Label;
			clonedColour.parent := clonedLegLine;
			if legend.attributeIndex &gt; 0 and self.baysPerPage &lt;= self.BaysPerPageThree then
				clonedColour.move(report.lblLegendCol.left, report.lblLegendCol.top, report.lblLegendCol.height * 1.6, report.lblLegendCol.height ); // let this one scale, its a coloured attribute
			else
				clonedColour.move(report.lblLegendCol.left, report.lblLegendCol.top, report.lblLegendCol.height, report.lblLegendCol.height ); // make it square
			endif;
			clonedColour.backColor := legend.colour;
			self.allClonedControls.add( clonedColour );
		endif;
		
		clonedDesc := report.lblLegendDesc.loadControl( controlIndex ).CMUI_Label;
		clonedDesc.parent := clonedLegLine;
		clonedDesc.move(report.lblLegendDesc.left, report.lblLegendDesc.top, report.lblLegendDesc.width, report.lblLegendDesc.height );
		if legend.header &gt; 0 then
			clonedDesc.fontBold := true;
		endif;
		legTitle := legend.title;
		while clonedDesc.getTextExtent( legTitle ) &gt; clonedDesc.width do
			legTitle := legTitle[1: (legTitle.length - 4)] &amp; "...";
		endwhile;
		clonedDesc.caption := legTitle;
		self.allClonedControls.add( clonedDesc );
	
		controlIndex:= controlIndex + 1;
		topIndex := topIndex + offSet;
		if topIndex + offSet &gt; max then
			//They have more legends than will fit down the page
			if self.legend = self.LegendOne then
				//We are only doing it once on the first page, so add another column reset
				//the pointers to the top of this one and carry on
				frmLegendIndex := frmLegendIndex + 1;
				currentFrmLegend := report.frmLegend.loadControl( frmLegendIndex ).CMUI_Frame;
				currentFrmLegend.parent := report.frmMain;
				currentFrmLegend.move( ((report.frmLegend.width + report.lblLegendCol.width )* frmLegendIndex ), report.frmLegend.top, report.frmLegend.width, report.frmLegend.height );
				currentFrmLegend.borderStyle := 0;
				currentFrmLegend.visible := true;
				self.allClonedControls.add( currentFrmLegend );
				topIndex := report.frmLegendLine.top;
			else
				// printing on every page so too bad.
				break;
			endif;
		endif;
		
	endforeach;	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_report" type="Form"/>
        <Parameter name="_perPageLegends" type="CMIF_ScanPlanLegendDict"/>
    </JadeMethod>
    <JadeMethod name="setAgentData" id="c546f044-b93b-412f-b7b1-5ac21f81435e">
        <updating/>
        <source>setAgentData(	_voyage : CM_Voyage; 
				_selectedBays : CM_BayVoyageByIdDict;
				_paperSize : Integer;
				_baysPerPage : Integer;
				_legend : Integer;
				_colour : Integer;
				_content : Integer;
				_rob : Integer;
				_printCargoList : Boolean;
				_printProfSumm : Boolean;
				_preview : Boolean
				) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 September 2020	jlgndl1	Initial creation	TFS 49963

*/

vars

begin

	self.myVoyage := _voyage;
	if self.myVoyage &lt;&gt; null then
		self.myTerminal := self.myVoyage.myTerminal;
	endif;
	self.allSelectedBays.clear();
	_selectedBays.copy( self.allSelectedBays );
	
	self.baysPerPage := _baysPerPage;
	self.legend := _legend;
	self.paperSize:= _paperSize;
	self.preview := _preview;
	self.printCargoList := _printCargoList;
	self.printProfileSummary := _printProfSumm;
	self.remainOnBoard := _rob;
	self.slotColour := _colour;
	self.slotContent := _content;
	
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_selectedBays" type="CM_BayVoyageByIdDict"/>
        <Parameter name="_paperSize" type="Integer"/>
        <Parameter name="_baysPerPage" type="Integer"/>
        <Parameter name="_legend" type="Integer"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_content" type="Integer"/>
        <Parameter name="_rob" type="Integer"/>
        <Parameter name="_printCargoList" type="Boolean"/>
        <Parameter name="_printProfSumm" type="Boolean"/>
        <Parameter name="_preview" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFrameFromIndex" id="0b8c2b43-9bcf-4e40-90fa-5a1175769018">
        <source>setFrameFromIndex(	index : Integer;
					report : CMUI_ScanPlanReport input;
					cmifBay : CMIF_ScanPlanReportBay
					);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 January 2021	jlgndl1	Initial creation	TFS 50541 - Change to print the frames top to bottom then across the page instead of left to right and then down the page

*/

vars

begin

	if self.baysPerPage = self.BaysPerPage2x3 then
	
		if index = 1 then
			report.frmBay1.visible := true;
			self.populateFrmBay( 	report.frmBay1,	//_bayFrame : CMUI_Frame;
								report.lblBayId1,	//_bayIdLbl : CMUI_Label input;
								report.lblColId1,	//_colIdLbl : CMUI_Label input;
								report.lblTierId1,	//_tierIdLbl : CMUI_Label input;
								report.picCell1,	//_cellPic : CMUI_Picture input;
								report.frmHatch1,	//_hatchFrm : CMUI_Frame input;
								cmifBay	//_cmifBay : CMIF_ScanPlanReportBay
								);
		elseif index = 3 then
			report.frmBay2.visible := true;	
			self.populateFrmBay( 	report.frmBay2,	//_bayFrame : CMUI_Frame;
								report.lblBayId2,	//_bayIdLbl : CMUI_Label input;
								report.lblColId2,	//_colIdLbl : CMUI_Label input;
								report.lblTierId2,	//_tierIdLbl : CMUI_Label input;
								report.picCell2,	//_cellPic : CMUI_Picture input;
								report.frmHatch2,	//_hatchFrm : CMUI_Frame input;
								cmifBay	//_cmifBay : CMIF_ScanPlanReportBay
								);
		elseif index = 5 then
			report.frmBay3.visible := true;	
			self.populateFrmBay( 	report.frmBay3,	//_bayFrame : CMUI_Frame;
								report.lblBayId3,	//_bayIdLbl : CMUI_Label input;
								report.lblColId3,	//_colIdLbl : CMUI_Label input;
								report.lblTierId3,	//_tierIdLbl : CMUI_Label input;
								report.picCell3,	//_cellPic : CMUI_Picture input;
								report.frmHatch3,	//_hatchFrm : CMUI_Frame input;
								cmifBay	//_cmifBay : CMIF_ScanPlanReportBay
								);
		elseif index = 2 then
			report.frmBay4.visible := true;	
			self.populateFrmBay( 	report.frmBay4,	//_bayFrame : CMUI_Frame;
								report.lblBayId4,	//_bayIdLbl : CMUI_Label input;
								report.lblColId4,	//_colIdLbl : CMUI_Label input;
								report.lblTierId4,	//_tierIdLbl : CMUI_Label input;
								report.picCell4,	//_cellPic : CMUI_Picture input;
								report.frmHatch4,	//_hatchFrm : CMUI_Frame input;
								cmifBay	//_cmifBay : CMIF_ScanPlanReportBay
								);
		elseif index = 4 then
			report.frmBay5.visible := true;	
			self.populateFrmBay( 	report.frmBay5,	//_bayFrame : CMUI_Frame;
								report.lblBayId5,	//_bayIdLbl : CMUI_Label input;
								report.lblColId5,	//_colIdLbl : CMUI_Label input;
								report.lblTierId5,	//_tierIdLbl : CMUI_Label input;
								report.picCell5,	//_cellPic : CMUI_Picture input;
								report.frmHatch5,	//_hatchFrm : CMUI_Frame input;
								cmifBay	//_cmifBay : CMIF_ScanPlanReportBay
								);
		elseif index = 6 then
			report.frmBay6.visible := true;	
			self.populateFrmBay( 	report.frmBay6,	//_bayFrame : CMUI_Frame;
								report.lblBayId6,	//_bayIdLbl : CMUI_Label input;
								report.lblColId6,	//_colIdLbl : CMUI_Label input;
								report.lblTierId6,	//_tierIdLbl : CMUI_Label input;
								report.picCell6,	//_cellPic : CMUI_Picture input;
								report.frmHatch6,	//_hatchFrm : CMUI_Frame input;
								cmifBay	//_cmifBay : CMIF_ScanPlanReportBay
								);
		
		endif;
		
	elseif self.baysPerPage = self.BaysPerPage3x4 then
	
		if index = 1 then
			report.frmBay1.visible := true;
			self.populateFrmBay( 	report.frmBay1,	//_bayFrame : CMUI_Frame;
								report.lblBayId1,	//_bayIdLbl : CMUI_Label input;
								report.lblColId1,	//_colIdLbl : CMUI_Label input;
								report.lblTierId1,	//_tierIdLbl : CMUI_Label input;
								report.picCell1,	//_cellPic : CMUI_Picture input;
								report.frmHatch1,	//_hatchFrm : CMUI_Frame input;
								cmifBay	//_cmifBay : CMIF_ScanPlanReportBay
								);
		elseif index = 4 then
			report.frmBay2.visible := true;	
			self.populateFrmBay( 	report.frmBay2,	//_bayFrame : CMUI_Frame;
								report.lblBayId2,	//_bayIdLbl : CMUI_Label input;
								report.lblColId2,	//_colIdLbl : CMUI_Label input;
								report.lblTierId2,	//_tierIdLbl : CMUI_Label input;
								report.picCell2,	//_cellPic : CMUI_Picture input;
								report.frmHatch2,	//_hatchFrm : CMUI_Frame input;
								cmifBay	//_cmifBay : CMIF_ScanPlanReportBay
								);
		elseif index = 7 then
			report.frmBay3.visible := true;	
			self.populateFrmBay( 	report.frmBay3,	//_bayFrame : CMUI_Frame;
								report.lblBayId3,	//_bayIdLbl : CMUI_Label input;
								report.lblColId3,	//_colIdLbl : CMUI_Label input;
								report.lblTierId3,	//_tierIdLbl : CMUI_Label input;
								report.picCell3,	//_cellPic : CMUI_Picture input;
								report.frmHatch3,	//_hatchFrm : CMUI_Frame input;
								cmifBay	//_cmifBay : CMIF_ScanPlanReportBay
								);
		elseif index = 10 then
			report.frmBay4.visible := true;	
