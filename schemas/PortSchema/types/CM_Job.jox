    <JadeMethod name="getMyWorkOrderDtl" id="27827a06-36bc-470a-83f4-1762f98ae76d">
        <source>getMyWorkOrderDtl(): CM_WorkOrderDtl;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Jul 2023	navhl20	ChangeRequest 58333: EUP | Delivery Dispatch Screen - Split Jobs
18 Apr 2024 navhl20 ChangeRequest 63511: FR | 53891 - Mobile App changes for Delivery Dispatch - Remedial
17 May 2024 navhl20 Bug 64191: EUP - Lock and Freeze issue
28 Aug 2024 navbk1  Bug 65855: EUP - Total Count on the Cargo Scanning app is showing the wrong value when we gate in the truck with trailer
*/

vars
	wle 	: CM_WorkListEntry;
	woWle	: CM_WOWLE;
begin
	if self.myWODtl &lt;&gt; null then
		return self.myWODtl;
	elseif self.myWorkOrderDtlToDo &lt;&gt; null then
		return self.myWorkOrderDtlToDo;
	else 
		// START 28.08.2024 navbk1 #65855
		foreach wle in self.workListEntries discreteLock do
			woWle := wle.myWorkOrderWLE;
			
			if woWle &lt;&gt; null and woWle.job &lt;&gt; null and woWle.job.myWODtl &lt;&gt; null then
				return woWle.job.myWODtl;
			endif;
		endforeach;
		// END 28.08.2024 navbk1 #65855
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_WorkOrderDtl"/>
    </JadeMethod>
    <JadeMethod name="getNewStatus" id="3923c449-f99a-41b7-b5f1-89b6366d8083">
        <source>getNewStatus() : Integer;
// refactored out of updateStatus for 31890 to check also in job printing
vars
	newStatus	:	Integer;
begin

	if self.isInUseByDevices() then
		newStatus := JOB_PART_COMPLETE;

	elseif self.workListEntries.isEmpty then
		newStatus := JOB_COMPLETE;

	elseif self.areWLEsAllDone then
		newStatus := JOB_COMPLETE;

	elseif self.areWLEsAllStatus(WLE_UNACTIONED) then
		newStatus := JOB_UNACTIONED;
		
	elseif self.allEntries.isEmpty then
		newStatus := JOB_PART_COMPLETE;
		
	else // Must be partially underway...
		newStatus := JOB_PART_COMPLETE;
		
	endif;

	return newStatus;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
