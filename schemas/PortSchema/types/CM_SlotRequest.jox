    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="b3b76f35-8481-46e9-9495-aa112d167a84">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
//----------------------------------------------------------------
//	Created:	05 February 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	propName	: String;
	
begin

	propName := _property.name;

	if propName = 'reefer' then
		return false;
	endif;
	
	return inheritMethod(_rootClass, _property);
end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="splitAllWLEs" id="61ccc60b-63c4-4a4e-8c04-b0e326037e48">
        <updating/>
        <source>splitAllWLEs(_newJob: CM_VoyageJob) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 March 2017	cnwmp6	Initial creation
*/
vars
	
begin

	inheritMethod(_newJob);	
	
	self.splitWLEs(_newJob);
	

epilog

end;</source>
        <Parameter name="_newJob" type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="splitCompletedWLEs" id="e97043f9-52f2-4041-b759-6c0f07eb52c4">
        <updating/>
        <source>splitCompletedWLEs(_toJob: CM_VoyageJob) updating;
// --------------------------------------------------------------------------------
// Created:		16 September 2010 by cnwjo3
//
// Purpose:		par 23366
//
vars
	wle : CM_WorkListEntry;
begin
	foreach wle in self.allWorkListEntries do
		//just checking again that its complete
		if wle.status &lt;&gt; WLE_COMPLETED then
			return;
		endif;
	endforeach;

	inheritMethod(_toJob);	

	self.splitWLEs(_toJob);
	
end;</source>
        <Parameter name="_toJob" type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="splitUnactionedWLEs" id="5a0bed0d-22df-402b-8292-63aed7353129">
        <updating/>
        <source>splitUnactionedWLEs(_newJob: CM_VoyageJob) updating;
//--------------------------------------------------------------
//Created: 24 April 2003 By: cnwgd1
//--------------------------------------------------------------
// 01/04/2010	cnwcs5	par 23383 - pass context info (_request) to updateTICollections 
//									via new parameter (_extra)
vars
	
begin

	// check to see if all are unactioned first as can only split unactioned requests
	if not self.doISplit() then
		return;
	endif;
		
	inheritMethod(_newJob);	
	
	self.splitWLEs(_newJob);
	
epilog
end;</source>
        <Parameter name="_newJob" type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="splitUnqueuedWLEs" id="77fc3d46-b64c-404f-8a37-e9b62475d44a">
        <updating/>
        <source>splitUnqueuedWLEs(_newJob: CM_VoyageJob) updating;
// --------------------------------------------------------------------------------
// Created:		20 April 2010 by cnwjo3
//
// Purpose:		par 23520.  This method basically ignores (doesn't add) certain
//				requests/WLE if they have been queued or completed
//				so when the new voyage job is created it only has unplanned
//				requests.
//
vars
	
	wle 		: CM_WorkListEntry;
begin

	//CNWRD1 assuming requedst : WLE 1:1 ratio here for voyage jobs.
	//check to see if all WLE are incomplete and unplanned as can only want to
	//split unplanned requests
	foreach wle in self.allWorkListEntries do
		//if the WLE has been planned or queued we don't want to split it.
		if wle.myFutureMove &lt;&gt; null then
			if  wle.myFutureMove.isKindOf(CM_FutureMoveQueued) then  //cnwrd1 we are only shifting unqued work. 
				return;
			endif;
		endif;
	endforeach;

	inheritMethod(_newJob);	
	
	self.splitWLEs(_newJob);
	

epilog

end;</source>
        <Parameter name="_newJob" type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="stowageId" id="bd5b6603-07ff-4992-9ee4-3bc708da1eaa">
        <methodInvocation>mapping</methodInvocation>
        <source>stowageId(_set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:     13 Dec 2001 by cnwrs1
//
// Purpose:     rewrite from C++
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	if _set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	if self.mySlotController &lt;&gt; null then
		_value :=  self.mySlotController.getStowageId(null);
	else
		_value := null;
	endif;
end;</source>
        <Parameter name="_set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="testCommodityGroup" id="75188cf3-63f9-4911-a1cb-6630301826ce">
        <source>testCommodityGroup(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 December 2008	cnwer1	Initial creation

*/

vars
	commodityGroup : CM_CommodityGroup; //cnwas3 PAR 24273
begin
	commodityGroup := self.getAttrCommodityGroup();		//cnwas3 PAR 24273
	if commodityGroup = null then				//cnwas3 PAR 24273
		return false;
	endif;
	
	if not commodityGroup.isSpecialStow then			//cnwas3 PAR 24273
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
