<CollClass name="CMUI_ControlsByNameDict" id="115e9633-c940-4c58-bb60-3c5a34088a8a">
    <duplicatesAllowed/>
    <memberType name="Control"/>
    <superclass name="ExtKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>
Duplicates are allowed because sometimes used in situations where
there are cloned controls which will have the same name.</text>
    <DbClassMap file="cmui"/>
    <ExternalKey name="name">
        <length>31</length>
        <type name="String"/>
    </ExternalKey>
    <JadeMethod name="add" id="bb046032-cd61-4b39-a877-8b487f9c01a1">
        <lockReceiver/>
        <updating/>
        <source>add(value: MemberType) updating, lockReceiver;
// ---------------------------------------------------------------------------
// Created:     16 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if value &lt;&gt; null then
		self.putAtKey(value.name, value);
	endif;

end;</source>
        <Parameter name="value" type="MemberType"/>
    </JadeMethod>
    <JadeMethod name="deleteMeasurementTablesFor" id="a31a57a2-f757-4dff-82dd-a3c8bffe9010">
        <lockReceiver/>
        <updating/>
        <source>deleteMeasurementTablesFor( _tbl : CM_EntryTable ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 March 2014	cnwndl1	Initial creation	Par 33356

*/
vars

	iter : Iterator;
	control : Control;
	controlsToDelete : ObjectArray;
	obj : Object;

begin

	create controlsToDelete transient;
	//find them
	iter := self.createIterator;
	while iter.next( control ) do
		if not control.isKindOf(CMUI_MeasurementTable) then
			continue;
		endif;
		if control.CMUI_MeasurementTable.heading &lt;&gt; _tbl.name then
			continue;
		endif;
		controlsToDelete.add(control);
	endwhile;
	
	//remove them
	foreach obj in controlsToDelete do
		control := obj.Control;
		self.removeKeyEntry( control.name, control );
	endforeach;

epilog
	//purge them
	if controlsToDelete &lt;&gt; null and not controlsToDelete.isEmpty then
		controlsToDelete.purge;
	endif;
	delete controlsToDelete;
	delete iter;

end;
</source>
        <Parameter name="_tbl" type="CM_EntryTable"/>
    </JadeMethod>
    <JadeMethod name="getNextControlId" id="a36ba77f-8ff3-468d-b4c6-b0e9197c45d7">
        <source>getNextControlId():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 March 2014	cnwndl1	Initial creation	Par 33356

*/
vars

	idNumber : Integer;
	iter : Iterator;
	control : Control;

begin

	idNumber := 13000;
	iter := self.createIterator;
	while iter.next( control ) do
		if control.index &gt;= idNumber then
			idNumber := control.index + 1;
		endif;
	endwhile;

epilog
	delete iter;
	return idNumber;
	

end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
</CollClass>
