    <JadeMethod name="getTIsForModeOperVoy" id="69f7d9da-5b7f-4345-9489-d08825cbb97d">
        <source>getTIsForModeOperVoy(_dict : Collection input; _mode : Integer;
					 _operator : CM_Operator; _voyage : CM_Voyage);
//--------------------------------------------------------------
//Created: 24 February 2003 By: cnwgd1
//--------------------------------------------------------------
//Operator and Voyage are optional, _dict and _mode are required;
vars
	lc	: CM_LocationsController;
	ti	: CM_TrackedItem;
	lcSet : CM_LCSet;
	iter	: Iterator;
begin

	lcSet := self.allLocationsControllers;
	if lcSet &lt;&gt; null then
		endLoad;
		iter := lcSet.createIterator;
		while iter.next(lc) do
			beginLoad;
			lc.getTIsForModeOperVoy(_dict, _mode, _operator, _voyage);
			endLoad;
		endwhile;
	endif;

epilog
	endLoad;
	delete iter;
end;</source>
        <Parameter name="_dict" type="Collection" usage="input"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="getTextHeader" id="1084751d-940e-455a-a952-3054bca303a4">
        <source>getTextHeader() : String;
//--------------------------------------------------
// Created:	22 September 2003 By: cnwgd1
//--------------------------------------------------

// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30/10/2008	consw1		SFW1030 - Remove unused auto plan flags

vars
	fifoDate 	: Date;	
	tmpStr : String;
begin
	//ccms1573	cnwvu1 14/August/2007
	if not self.allRestrictionsLabour.isEmpty() then
		tmpStr := tmpStr &amp; '[' &amp; app.getErrorString(LabourOnBlockRestriction) &amp; '];  ';	//after hotfix - to create message constant here
	endif;

