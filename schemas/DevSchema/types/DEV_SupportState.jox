    <PrimAttribute name="startTS" id="a967068f-09fc-42a0-8734-254874ae8c01">
        <embedded/>
        <type name="TimeStamp"/>
    </PrimAttribute>
    <PrimAttribute name="type" id="7d922a9c-09da-4015-9c39-62be8889ec45">
