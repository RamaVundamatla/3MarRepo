    <JadeMethod name="setUnpackChangeIDValue" id="7d354f47-35a5-4542-9f72-fa389807d998">
        <updating/>
        <source>setUnpackChangeIDValue() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
04 March 2016	cnwndl1	Initial creation
31 March 2021	navmd1	TFS 51047 Reduce log clutter a little by changing levels to Debug

*/

vars

	iniFileName : String;
	strUnpackChangeID : String;

begin

	iniFileName := app.getIniFileName();
	app.writeLog("Inifilename: '" &amp; iniFileName &amp; "'", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	
	if iniFileName &lt;&gt; null then
		strUnpackChangeID := app.getProfileString(iniFileName, HandHeldAppIniFileSection, MOB_UnpackChangeID, null);
		app.writeLog("strUnpackChangeID: '" &amp; strUnpackChangeID &amp; "'", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		if strUnpackChangeID &lt;&gt; null then
			self.unpackChangeID := ( strUnpackChangeID.toUpper.trimBlanks = "TRUE" );
			return;
		endif;
	endif;
	
	self.unpackChangeID := false;

epilog

end;</source>
    </JadeMethod>
