    <JadeMethod name="setForCreate" id="937852f8-320d-4312-8394-b1915374d7d1">
        <updating/>
        <source>setForCreate(_pxyAutoTask: CM_AutoTask) updating;
// ---------------------------------------------------------------------------
// Created:		16 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(_pxyAutoTask);
	self.requestClassName := BGP_CamsRequest.name;


end;</source>
