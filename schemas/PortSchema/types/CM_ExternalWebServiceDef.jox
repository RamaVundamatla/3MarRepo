    <JadeMethod name="getTerminalLastSuccDTAsString" id="702e5bbb-8598-4e4e-8e78-f6e3f7295d8c">
        <source>getTerminalLastSuccDTAsString(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 December 2025	navsp1	Initial creation MTN-36362

*/

vars
    lastDt : CM_EWSTerminalLastSuccessDT;
    str, item : String;
begin
    foreach lastDt in self.allTerminalLastSuccessDT do
        if lastDt.lastSuccessDt &lt;&gt; null then                //MTN-37026
            item := lastDt.myTerminal.code &amp; Space &amp; lastDt.lastSuccessDt.String;
            if str &lt;&gt; null then
                str := str &amp; "; ";
            endif;       
            str := str &amp; item;
		endif;
	endforeach;
	
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWebServiceType" id="13b1e9b8-14fe-4444-a100-589a634746f7">
        <source>getWebServiceType() : CM_ExternalWebServiceType;
// ### JIRA 33959 14FEB2025 NAVAB1
vars

	ewsType : CM_ExternalWebServiceType;

begin

	foreach ewsType in app.myRoot.allExternalWebServiceTypes do
		if self.class = ewsType.classToCreate() then
			return ewsType;
		endif;
	endforeach;

	return null;
epilog

end;</source>
