    <JadeMethod name="doNotableAdd" id="be048f27-9c55-460b-b6cc-94dabe2d8579">
        <source>doNotableAdd(_anObject : Object);
/*
Purpose - 	
Who - NAVAB1
Date - 08JUL2024
ADO -  CR 64617 TASK 64638
*/

vars
	invalid : Boolean;
	ed : Integer;
begin
	if _anObject = null then
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception,_anObject,invalid);
	ed := _anObject.edition;
	if invalid then
		return;
	endif;
	
	self.allNotableObjects.add(_anObject);
	beginNotification(_anObject, self.myTerminal.getTerminalEvent(Event_CustDocHeaderUpdate), Response_Continuous, null);
	beginNotification(_anObject, EventFileAdd, Response_Continuous, null);
	beginNotification(_anObject, EventFileDelete, Response_Continuous, null);

epilog

end;</source>
        <Parameter name="_anObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doNotableClear" id="160049a9-51d7-4c4d-a6f0-9554a10aa34e">
        <source>doNotableClear(_custDoc : CM_EDIIssue);
/*
Purpose:			

Date		Who		Reason
08AUG2023	NAVAB1	 CR 56094 TASK 59618
*/

vars
begin

	endNotification(_custDoc, self.myTerminal.getTerminalEvent(Event_EDIIssueUpdate));

	epilog

end;</source>
        <Parameter name="_custDoc" type="CM_EDIIssue"/>
    </JadeMethod>
    <JadeMethod name="doPermissions" id="a64e62f0-ec0a-4d8a-b71f-851685671df2">
        <source>doPermissions();
/*
Purpose - 	
Who - NAVAB1
Date - 08JUL2024
ADO -  CR 64617 TASK 64638
*/

vars

begin
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnNew.enabled := false;
		self.btnRemove.enabled := false;
		self.btnSave.enabled := false;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="97a0d615-94ad-4b18-bc63-727d73320f79">
        <updating/>
        <source>doSave() updating;
/*
Purpose:	

Date			Who		Reason
09 July 2024	navab1	CR 64617 TASK 64638
04 Dec	2024	navlw1	Jira-14844: MTN - Refinement of EDI Issue Save
*/

vars
	pxyIssue, realIssue : CM_EDIIssue;
	theReturn : Integer;
begin
	self.emailChanged := false;
	self.ediChanged :=  false; // navlw1 #Jira-14844
	
	if not self.updateMode then
		create pxyIssue transient;
		pxyIssue.setProxy(self.myTerminal, self.txtCode.text.trimBlanks(), self.txtDesc.text.trimBlanks(), self.chkIncludeLoad.value, self.chkIncludeVerify.value, self.myProxyEmailTemplate);
		self.setProxyMappings(pxyIssue);
		
		while true do
			app.myTrxCA.trxCreateEDIIssue(pxyIssue, realIssue, app.myPassport);

			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				global.beep;
				self.myCurrentEDIIssue := realIssue;
				break;
			else
				theReturn := app.showErrorWarningDialog("EDI Issues", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
				return;
			endif;
			break;
		endwhile;
	else
		if self.myProxyEmailTemplate = null then
			self.myProxyEmailTemplate := app.createUpdateProxy( self.myCurrentEDIIssue.myEmailTemplate).CM_EmailTemplate;
		endif;
		pxyIssue := app.createUpdateProxy(self.myCurrentEDIIssue).CM_EDIIssue;
		pxyIssue.setProxy(self.myTerminal, self.txtCode.text.trimBlanks(), self.txtDesc.text.trimBlanks(), self.chkIncludeLoad.value, self.chkIncludeVerify.value, self.myProxyEmailTemplate);
		self.setProxyMappings(pxyIssue);
		
		while true do
			app.myTrxUA.trxUpdateEDIIssue(pxyIssue, app.myPassport);

			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				global.beep;
				break;
			else
				theReturn := app.showErrorWarningDialog("EDI Issues", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
				return;
			endif;
			break;
		endwhile;

	endif;
epilog
	delete self.myProxyEmailTemplate ;
	delete pxyIssue;
end;</source>
    </JadeMethod>
    <JadeMethod name="doShowEmailForm" id="4678158d-4ac4-4f61-bc07-f92229798dc2">
        <updating/>
        <source>doShowEmailForm() updating;
/*
Purpose:	

Date			Who		Reason
10 July 2024	navab1	CR 64617 TASK 64638
26 Aug 2024		navnk30	Bug 65636: NSW - EDI Issues Configuration UI issues
*/

vars
	form : CMUI_EDIIssueMaint;
	issue : CM_EDIIssue;
	emailAdding : Boolean;
	modalResult : Integer;
begin
	form := self;
	issue := form.myCurrentEDIIssue.CM_EDIIssue;
	
	if issue = null then
		app.msgBox(app.getErrorString(NO_Items_selected), app.getErrorString(Problem), MsgBox_OK_Only);
		return;
	
	endif;
	
	self.emailChanged := false;					//26.08.2024 navnk30 #65636
	
	if self.myProxyEmailTemplate &lt;&gt; null and	//26.08.2024 navnk30 #65636
		self.myProxyEmailTemplate.pxyGetRealObject() = issue.myEmailTemplate then
		self.emailChanged := true;
	elseif issue.myEmailTemplate = null then
		emailAdding := true;
		self.myProxyEmailTemplate := issue.createPxyEmailTemplate();
	else
	
		delete self.myProxyEmailTemplate;
		self.myProxyEmailTemplate := app.createUpdateProxy( issue.myEmailTemplate).CM_EmailTemplate;
	endif;
	
	//self.emailChanged := false;				//26.08.2024 navnk30 #65636

	modalResult := form.myAssistant.showEDIEmailOptions(self.myProxyEmailTemplate, false);
	
	if modalResult = IDOK then
		self.emailChanged := true;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doTblDataContMenu" id="9f490583-e755-4386-bc1f-858d750c17b3">
        <updating/>
        <source>doTblDataContMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating, protected;
/*
Purpose:			

Date		Who		Reason
08AUG2023	NAVAB1	 CR 56094 TASK 59618
*/

vars
	canEdit		: Boolean;
	x1,
	y1			: Real;
begin
	x1 := x;
	y1 := y;
	if (not mouse) then
	    x1 := 1;
	    y1 := 1;
	endif;
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);
	self.mnuColumnOrganiser.visible := true;
	self.mnuColumnOrganiser.userObject := self.tblData;
	self.mnuInspectObject.visible := app.isAllowedToInspect(); 
	self.popupMenu(self.mnuContextMenu, x1.Integer, y1.Integer);
	return false;

end;</source>
        <access>protected</access>
