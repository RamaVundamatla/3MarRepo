    <JadeMethod name="utlUpdateTransRailToRoad" id="77724952-0fb1-4f26-b7c8-857a0f144bbe">
        <source>utlUpdateTransRailToRoad(_pxyworkOrder: CM_WorkOrder;_oldTransport,_transport : String; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 January 2023	navhl20	ChangeRequest 54979:[54981] EUP - Transport Mode change - PortSchema Changes

*/

vars
	realWO 		: CM_WorkOrder;
	expectedEdition 		: Integer;
begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_pxyworkOrder, 'Work Order proxy');
	
	_pxyworkOrder.pxyGetRealObjectAndEdition(realWO, expectedEdition);
	self.raiseExceptionIfNull(realWO, 'Work Order');
	
	if not _passport.noErrors then
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realWO, true);
	endif;
	
	if realWO.allWoDtls.isNotEmpty() then 
		if realWO.allWoDtls.first.isKindOf(CM_WodReceive) then
			if realWO.allWoDtls.first.CM_WodReceive.myBookingRef &lt;&gt; null then 
			    if realWO.allWoDtls.first.CM_WodReceive.myBookingRef.allTIs.isEmpty() and 
				   realWO.allWoDtls.first.CM_WodReceive.allJobs.isEmpty() then
						realWO.allWoDtls.first.CM_WodReceive.setTransportMode(app.transportModeStringToENum(_transport));
				endif;
			endif;
		else 
			if realWO.allWoDtls.first.CM_WodRelease.myReleaseRequest &lt;&gt; null then 
				if realWO.allWoDtls.first.CM_WodRelease.myReleaseRequest.allTrackedItemsReleased.isEmpty() and 
				   realWO.allWoDtls.first.CM_WodRelease.allJobs.isEmpty() then
						realWO.allWoDtls.first.CM_WodRelease.setTransportMode(app.transportModeStringToENum(_transport));
				endif;
			endif;
		endif;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realWO, false);
	endif;
epilog

end;</source>
        <Parameter name="_pxyworkOrder" type="CM_WorkOrder"/>
        <Parameter name="_oldTransport" type="String"/>
        <Parameter name="_transport" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
