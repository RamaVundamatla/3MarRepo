<Class name="CM_YARTVConfigCriteria" id="4ed26ca4-d8a6-40db-91a0-f467be447914">
    <superclass name="CM_YACriteria"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="yardAllocations"/>
    <ExplicitInverseRef name="myRTVConfig" id="2c58e722-8899-46f9-ab4a-5ce9c09b82e7">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <embedded/>
        <type name="CM_RTVehicleConfig"/>
        <access>readonly</access>
        <Inverse name="CM_RTVehicleConfig::allCriteria"/>
    </ExplicitInverseRef>
    <JadeMethod name="pxyCreateUpdateProxy" id="9d40f95d-605e-45b7-be5e-bd9d907cb7b1">
        <source>pxyCreateUpdateProxy(): SelfType;
/* ---------------------------------------------------------------------------
Created:	15 September 2010	by cnwvu1

Purpose:	MES CCMS 1080
   
Change Date		Who		Reason
20/04/2011		cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
						trying to create the proxy
------------------------------------------------------------------------------*/

vars
	proxyObj		: SelfType;
	completedOK		: Boolean;
	
begin

	proxyObj				:= inheritMethod();
	proxyObj.myRTVConfig	:= self.myRTVConfig;

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyObj;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyObj;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="8100d943-eca7-4e3f-b827-720ab1fba780">
        <updating/>
        <source>setForCreate(pProxyObj: SelfType) updating;
/* ---------------------------------------------------------------------------
Created:	15 September 2010	by cnwvu1

Purpose:	MES CCMS 1080
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	self.setForUpdate(pProxyObj);
	
	self.myRTVConfig	:= pProxyObj.myRTVConfig;
	

end;</source>
        <Parameter name="pProxyObj" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setMyRTVConfig" id="67361b95-a367-4f0c-96bb-05d5ee4adcee">
        <updating/>
        <source>setMyRTVConfig(_rtVehicleConfig: CM_RTVehicleConfig) updating;
/* ---------------------------------------------------------------------------
Created:	15 September 2010	by cnwvu1

Purpose:	MES CCMS 1080
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	self.myRTVConfig := _rtVehicleConfig;

end;</source>
        <Parameter name="_rtVehicleConfig" type="CM_RTVehicleConfig"/>
    </JadeMethod>
</Class>
