    <JadeMethod name="setupIcons" id="100124bd-25a1-44cd-a703-74aeba35a640">
        <updating/>
        <source>setupIcons( _iconUpString, _iconDownString, _iconLocationString : String) updating;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 23 July 2004
//
//	Used to setup new properties in VTMIS from data in old HMS
//	Setting up properties from globals so globals must be loaded 
//	first
//********************************************************************

vars
	
begin
	self.iconUpString := _iconUpString;
	self.iconDownString := _iconDownString;
	self.iconLocationString := _iconLocationString;	
	
end;</source>
