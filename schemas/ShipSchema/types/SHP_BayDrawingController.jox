    <JadeMethod name="init" id="4f5faff4-19ba-4245-b1f4-747cfef6e0dd">
        <updating/>
        <source>init(_voyage : CM_Voyage; _holds : CM_HoldByOrdinalDict;_terminal : CM_Terminal) updating;
// ---------------------------------------------------------------------------
// Created:     05 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpHold	: CM_Hold;
begin

	self.myTerminal := _terminal;
	self.myVoyage	:= _voyage;
	
	self.shipShowISOType := self.myTerminal.getConfig(ShipShowISOType).Boolean;
	//epr TFS 7006 27/9/17
	self.showOnlyDoorDirections := self.myTerminal.getConfig(ShowOnlyDoorDirections).Boolean;
	
	self.allHolds.clear;
	self.allBays.clear;
	
	_holds.copy(self.allHolds);
	
	foreach tmpHold in _holds do
		tmpHold.allBays.copy(self.allBays);
	endforeach;
	
	self.noteVoyageAreaUpdate	:= self.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA);
	self.noteVoyageAreaRefresh	:= self.myTerminal.getTerminalEvent(EVENT_REFRESH_VOYAGE_AREA);
	
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_holds" type="CM_HoldByOrdinalDict"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="initConfigs" id="04fb3a08-2208-4f98-8238-7b8797dc595b">
        <updating/>
        <source>initConfigs(_terminal : CM_Terminal) updating;
/*

Date		Who		Reason
02 February 2017	cnwer1	Initial creation TFS 3284

*/

vars

begin
	if _terminal = null then
		return;
	endif;
	
	//epr TFS 3284 performance storing config settings
	if self.amPrinting and self.printOutputStyle &lt;&gt; self.PrintOutput_Large then
		self.showWeights:=false;
		self.showHeights:=false;
	else
		self.showWeights :=_terminal.getConfig(ShowWeightsLOLOPlanning).Boolean;
		self.showHeights := _terminal.getConfig(ShowHeightsLOLOPlanning).Boolean;
	
	endif;
	
	
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="isLoadPlanning" id="fe4b585f-56c8-43d9-8284-7f38e4de2159">
        <source>isLoadPlanning() : Boolean;
// ---------------------------------------------------------------------------
// Created:		03 June 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
 return self.displayMode = ShpDisplayMode_ColCodeLoad
	and self.workingMode = SHP_VoyageAreaForm2.WorkMode_Plan;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSlotRequest40" id="d0359587-b9ac-47ac-a513-c30f8020138a">
        <source>isSlotRequest40(_slotRequest : CM_SlotRequest) : Boolean;
/*

Date		Who		Reason
02 February 2017	cnwer1	Initial creation TFS 3284

*/

vars
	voyageAllocCCAttributes : CMIF_VoyageAllocCCAttributes;
begin
	if _slotRequest = null then
		return false;
	endif;
	
	if  _slotRequest.useVoyageAllocations then
		voyageAllocCCAttributes:= self.getVoyageAllocCCAttributes(_slotRequest);
		if voyageAllocCCAttributes &lt;&gt; null then
			return voyageAllocCCAttributes.is40;
		endif;
	else
		return _slotRequest.is40();
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_slotRequest" type="CM_SlotRequest"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="notableObjectArmNotes" id="250e5b2b-88b3-4824-bd0c-a62669cedaef">
        <source>notableObjectArmNotes(_obj: Object);
// ---------------------------------------------------------------------------
// Created:     05 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_obj);
	
	if CM_Voyage.hasInstance(_obj) then
		self.beginNotification(_obj, self.noteVoyageAreaRefresh, Response_Continuous, null);
		self.beginNotification(_obj, self.noteVoyageAreaUpdate, Response_Continuous, null);
		self.beginNotification(_obj, self.myTerminal.getTerminalEvent(VoyageJob_Create_Event), Response_Continuous, null); // PAR 21817
	endif;

end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
