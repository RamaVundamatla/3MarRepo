    <JadeMethod name="isSOBMixed" id="3b2d27be-1c44-4529-95a1-2753906bafa7">
        <source>isSOBMixed() : Boolean;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

	aReq : CM_Request;
	sob, dis : Integer;
begin
	foreach aReq in self.allRequests do
		if aReq.isSOB() then
			sob := sob + 1;
		elseif aReq.getAttrIsDischarge() then
			dis := dis + 1;
		endif;
	endforeach;

	return ((sob &gt; 0) and (dis &gt; 0));

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSOBOnly" id="a7fc222c-cca1-4523-afc9-858dd94e769f">
        <source>isSOBOnly() : Boolean;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

	aReq : CM_Request;
	lo, sob, dis : Integer;
begin

	foreach aReq in self.allRequests do
		if aReq.isSOB() then
			sob := sob + 1;
		elseif aReq.getAttrIsDischarge() then
			dis := dis + 1;
		else
			lo := lo + 1;
		endif;
	endforeach;

	return ((sob &gt; 0) and (dis = 0) and (lo = 0));

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTISimilarToJob" id="c7e2c0dd-a093-451d-bb18-9933d9726b5c">
        <source>isTISimilarToJob(_ti : CM_TrackedItem) : Boolean;
// ---------------------------------------------------------------------------
// Created:		March 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aReq : CM_Request;
begin
	
	foreach aReq in self.allRequests discreteLock do
	
		if aReq.getDischargePort = _ti.dischargePort 
		and aReq.getAttrIs40() = _ti.isForty() then
			return true;
		endif;
	endforeach;
	
	return false;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidForLoadPlanning" id="9e453d4c-4dfc-472b-aab5-bb2f17a9557c">
        <source>isValidForLoadPlanning() : Boolean;
/*

Date		Who		Reason
27 March 2017	cnwer1	Initial creation TFS 830

*/

vars

begin
	if self.isHatchLidJob then
		return false;
	endif;
	
	if self.isDischarge then
		return false;
	endif;
	
	if self.isJobComplete then
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isVoyageAllocLoad" id="e3a1ec7a-17c7-4914-9d35-27d3799d7a01">
        <source>isVoyageAllocLoad(): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 November 2012	cnwrd1	Initial creation

*/

vars
	aRequest : CM_Request;
begin
	
	aRequest := self.allRequests.first;
	
	if not self.allowOutOfOrderLoading then
		return false;
	endif;
	
	if aRequest.getFirstAllocation = null then
		return false;
	endif;
	

	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
