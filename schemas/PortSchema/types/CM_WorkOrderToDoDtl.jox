    <JadeMethod name="getNumberRemainingToAction" id="d3b1f4ab-37b7-40de-bd7d-3389101940c2">
        <source>getNumberRemainingToAction(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Mar 2023	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs

*/

vars

begin
	if self.status = WO_STATUS_COMPLETE then
		return self.getTotalRequested - self.getTotalComplete;
	else
		return self.getTotalRequested - self.getTotalActioned;
	endif;
	

epilog

end;</source>
