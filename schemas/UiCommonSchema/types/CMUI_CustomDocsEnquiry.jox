	btnLoadExtRef.translateCaption(Xlat_0026447, locale);
	btnRemove.translateCaption(Xlat_0026285, locale);
	btnUpdate.translateCaption(Xlat_0026286, locale);
	chkShowParameters.translateCaption(Xlat_0026439, locale);
	grpParams.translateCaption(Xlat_0026440, locale);
	lblAgent.translateCaption(Xlat_0026287, locale);
	lblCargoGroup.translateCaption(Xlat_0026742, locale);
	lblCargoId.translateCaption(Xlat_0026743, locale);
	lblCode.translateCaption(Xlat_0026288, locale);
	lblDesc.translateCaption(Xlat_0026289, locale);
	lblDocType.translateCaption(Xlat_0026290, locale);
	lblEnd.translateCaption(Xlat_0026291, locale);
	lblExtRef.translateCaption(Xlat_0026292, locale);
	lblHSCode.translateCaption(Xlat_0026293, locale);
	lblLicense.translateCaption(Xlat_0026294, locale);
	lblNumber.translateCaption(Xlat_0026295, locale);
	lblStart.translateCaption(Xlat_0026296, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0026297, locale);
