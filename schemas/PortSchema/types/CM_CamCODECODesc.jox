    <JadeMethod name="outputHeader_RFF_ACW" id="7f9f298b-34b3-4a70-a96b-0d039a8592e5">
        <updating/>
        <source>outputHeader_RFF_ACW(_protocol :CM_CamProtocol; _camTaskHistory :CM_CamTaskHistory input; _camMessage :CM_CamMessage input; _coll :HugeStringArray input; _transactions : CM_TITransactionSet) : String updating, protected;
/*
Purpose: Insert RFF+ACW segment for CODECO CANCEL transaction

Parameters:			

Return Value:		

Date		Who		TFS		Reason
04 Nov 2019	jlgdi1	46578	Initial creation
09 Jan 2020	jlgdap1	TFS 48016 SNO Deletion CODECO - new signature and other changes
19 Aug 2022	jlger1	TFS 54478 - changed to StringArray with Jade increasing length of strings in - to fix 1035
*/
vars
	refID : String ;
	strLine : String;
	obj : Object;								// TFS 48016
	messageArray : StringArray;				// TFS 48016
	tiTrx : CM_TITransaction;					// TFS 48016
	message, tiId : String;						// TFS 48016
	
begin
	// TFS 48016 start
	//camVoyage := _camMessage.camVoyage;
	
	//if not camVoyage.voyageOid.isNullVoyage() then 
	//	refID := camVoyage.getSanitisedVoyageCode();
	//else
	//	refID := camVoyage.voyage;
	//endif;
	foreach obj in _camMessage.allCAMSInfoDetails do
		messageArray := obj.StringArray;
		foreach message in messageArray do
			if message[1:7] = 'EQD+CN+' then
				tiId := message[8:11];
				foreach tiTrx in _transactions where tiTrx.myTrackedItem &lt;&gt; null and tiTrx.myTrackedItem.id = tiId do
					refID := self.getRoadReceiveTrxSeqNum(tiTrx.myTrackedItem);
					break;
				endforeach;
				break;
			endif;
		endforeach;
	endforeach;
	// TFS 48016 end
	
	if refID &lt;&gt; null then 
		strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeRFFSegment(_protocol, null, "ACW",  refID), _coll);
		_camMessage.segmentCount := _camMessage.segmentCount + 1;
	endif;
	
	return strLine;
end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <Parameter name="_transactions" type="CM_TITransactionSet"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_UNA" id="6b5ff6cb-b845-4283-8020-52627ae46217">
        <updating/>
        <source>outputHeader_UNA(_protocol :CM_CamProtocol; _camTaskHistory: CM_CamTaskHistory input) : String updating, protected;
/*
Date		Who		Reason
20/12/2012	cnwcs5	CCMS SFW 1294 /par 30855
*/
vars
	result	:String;
begin
	if _protocol.requiresUNASegment then
		result := self.outputFileMessage(_camTaskHistory, self.makeUNASegment (_protocol), null);
	endif;

	return result;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_UNB" id="cd2f600b-dbf6-4cde-985d-cf32c53937d2">
        <updating/>
        <source>outputHeader_UNB(_protocol :CM_CamProtocol; _camTaskHistory: CM_CamTaskHistory input; _seqNumber : Integer; _coll :HugeStringArray input; _contextObj : CM_Object) : String updating, protected;
/*
Date		Who		Reason
20/12/2012	cnwcs5	CCMS SFW 1294 /par 30855
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
vars

	code, msg	:String;
	ts : TimeStamp;	//30 Apr 2018	NDL	TFS 37406
	
begin	

	//30 Apr 2018	NDL	TFS 37406
	ts := _camTaskHistory.runDateTime;
	if _protocol.singleContainerPerUNB and _contextObj &lt;&gt; null then
		_protocol.incrementTSForContext( _contextObj, ts );
	endif;
	
	code 	:= self.getSenderCode_UNB (_protocol);
	msg 	:= self.makeUNBSegment (_protocol, "UNOA", 2, code, null, _protocol.camGroup.recipient.trimBlanks, null, _seqNumber, null, false, ts);
	
	return self.outputFileMessage(_camTaskHistory, msg, _coll);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <Parameter name="_contextObj" type="CM_Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_UNH_BGM" id="74a2f01b-defc-4d77-b21a-da3c864fd4b9">
        <updating/>
        <source>outputHeader_UNH_BGM(_camMessage :CM_CamMessage input; _camTaskHistory :CM_CamTaskHistory input; _camFile :CM_CamFile input; 
						_unhSeqNumber :Integer io; _coll :HugeStringArray input) : String updating, protected;
/* Changes

Date		Name	TFS#		Description
============================================================================
20/12/2012	cnwcs5	CCMS SFW 1294 /par 30855
29 Jan 2015	cnwrs1	Par 35544 	Change CamMessage to use HugeStringArray
25 Feb 2015	cnwrs1	Par 35544 	Refactor Cams file storage to string
12 Jul 2017	jlgrs1	TFS 4465 	SNO standard Codedo/Coarri
26 Jun 2019	jlgka1	TFS 44737 	PNL Hapag CODECO on Weighing.
============================================================================*/
vars
	strLine 			: String;
	codecoVGMBGMMsgCode : String;
begin
	if _camMessage.activity = CODECO_GATEIN then
		strLine := strLine &amp; self.makeMessageHeader(_camFile, _camTaskHistory, _unhSeqNumber, "34", "CODECO", _coll);
		_camMessage.segmentCount := _camMessage.segmentCount + 2;
	elseif _camMessage.activity = CODECO_GATEOUT then
		strLine := strLine &amp; self.makeMessageHeader(_camFile, _camTaskHistory, _unhSeqNumber, "36", "CODECO", _coll);
		_camMessage.segmentCount := _camMessage.segmentCount + 2;
	elseif _camMessage.activity = CODECO_DAMAGED or _camMessage.activity = CODECO_REPAIRED then	//cnwrs1 CCMS 1826 29 July 2010
		strLine := strLine &amp; self.makeMessageHeader(_camFile, _camTaskHistory, _unhSeqNumber, "999", "CODECO", _coll);
		_camMessage.segmentCount := _camMessage.segmentCount + 2;
	elseif _camMessage.activity = CODECO_PACK then
		strLine := strLine &amp; self.makeMessageHeader(_camFile, _camTaskHistory, _unhSeqNumber, "999", "CODECO", _coll);
		_camMessage.segmentCount := _camMessage.segmentCount + 2;
	elseif _camMessage.activity = CODECO_UNPACK then
		strLine := strLine &amp; self.makeMessageHeader(_camFile, _camTaskHistory, _unhSeqNumber, "999", "CODECO", _coll);
		_camMessage.segmentCount := _camMessage.segmentCount + 2;
	elseif _camMessage.activity = CODECO_VGM then //epr par 37551 18/2/16 TFS 1429	
		//jlgka1 TFS 44737 --&gt;
		if _camTaskHistory.camProtocol &lt;&gt; null then
			codecoVGMBGMMsgCode := _camTaskHistory.camProtocol.getCodecoVGMBGMMessageCode();
		endif;
		if codecoVGMBGMMsgCode &lt;&gt; null then
			strLine := strLine &amp; self.makeMessageHeader(_camFile, _camTaskHistory, _unhSeqNumber, codecoVGMBGMMsgCode, "CODECO", _coll);	
			_camMessage.segmentCount := _camMessage.segmentCount + 2;	
		else //jlgka1 TFS 44737 &lt;--
			strLine := strLine &amp; self.makeMessageHeader(_camFile, _camTaskHistory, _unhSeqNumber, "VGM", "CODECO", _coll);	
			_camMessage.segmentCount := _camMessage.segmentCount + 2;			
		endif;
	endif;
	return strLine;
end;</source>
        <access>protected</access>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_unhSeqNumber" type="Integer" usage="io"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processOperatorChange" id="7508488f-e7e7-4df1-8daa-8f4239c48978">
        <updating/>
        <source>processOperatorChange(_editTrans : CM_Edit; _camProtocol : CM_CamProtocol; _camAgent : CM_CamControllerAgent input; _camFile : CM_CamFile input) protected, updating;
//
//04 Mar 2013	cnwrs1	Par 31344 operator changes are sometimes being missed
//17 Jnu 2014	cnwdap1	PAR #4422 Remove beginLock / endLock
//23 Feb 2014	cmwrs1	Par 35738 Replace removed beginLock/Endloack with beginLoad /endload
//06 Mar 2015	cnwrs1	Par35784 - increased exclusion reason logging to include non excluded
//
vars
	trans : CM_TITransaction;
	saveTrans : CM_TITransaction;
	receivalTrans : CM_TITransaction;
	loadState : Boolean;
begin
	foreach trans in _editTrans.myTrackedItem.allTransactions do
		if trans.dateTime &gt;= _editTrans.dateTime then
			break;
		endif;
		if self.isTransactionToBeProcessed(_camProtocol, trans, _camAgent) then //par 21254 cnwrs1 oct 2009
			if trans.isCamsCodecoRecRelType() then
				if saveTrans &lt;&gt; null and
				   _camAgent.logExcludedTransactions then
					// we already had one but we won't be using it 
					_camAgent.logReasonForExclusion (saveTrans, '"Include gate in/out for those with operator change" is set. Looking for most recent Receival/Release for EDIT ( ) - this transaction is not most recent CAMS receival/release'); // par 29601/2
				endif;
				
				saveTrans := trans;
			else
				if _camAgent.logExcludedTransactions then
					_camAgent.logReasonForExclusion (trans, '"Include gate in/out for those with operator change" is set. Looking for most recent Receival/Release for EDIT ( ) - this transaction is not a CAMS receival/release'); // par 29601/2
				endif;
			endif;
		else
			if _camAgent.logExcludedTransactions then
				_camAgent.logReasonForExclusion (trans, '"Include gate in/out for those with operator change" is set. Looking for most recent Receival/Release for EDIT ( ) - this transaction does not match selected transactions for CAM protocol'); // par 29601/2
			endif;
		endif;
	endforeach;
	if saveTrans &lt;&gt; null then
		//FD for pars 4298 :The Edit may be done very recently,so the saveTrans might already be
		//processed in builFile before this
		if (saveTrans.dateTime &lt;= _camAgent.startDateTime) or (saveTrans.dateTime &gt;= _camAgent.endDateTime) then
			//beginLock; //par 22391 cnwrs1 24 Feb 2010	// PAR #34422
			app.cmsBeginLoad(loadState);
			receivalTrans := saveTrans.pxyCreateUpdateProxy();
			app.cmsEndLoad(loadState);
			//endLock;									// PAR #34422
			receivalTrans.setFromNoInfoEdit(saveTrans.myTrackedItem, _editTrans);
			if _camAgent.logIncludedTransactions then
				_camAgent.logReasonForInclusion(receivalTrans, "Transaction is operator change to be processed");
			endif;
			self.processTransaction(receivalTrans, _camProtocol, _camAgent, _camFile);	
			delete receivalTrans;
		else
			if _camAgent.logExcludedTransactions then
				_camAgent.logReasonForExclusion (saveTrans, '"Include gate in/out for those with operator change" is set. Looking for most recent Receival/Release for EDIT ( ) - this transaction already falls within CAMS start/end dates'); // par 29601/2 
			endif;
		endif;
	endif;
end;

</source>
        <access>protected</access>
        <Parameter name="_editTrans" type="CM_Edit"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processTransaction" id="29836108-1520-4003-976f-5541ae2eb298">
        <updating/>
        <source>processTransaction(_transaction : CM_TITransaction; _camProtocol : CM_CamProtocol; _camAgent : CM_CamControllerAgent input; _camFile : CM_CamFile input) updating;
// 12/05/2010	cnwcs5	par 23967 - change _camFile paremeter to be input not io so as to correctly reflect its usage
//12 Jul 2012	cnwrs1	CCMS 1269 CAMS reduce number of Trxs
//18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
// 17 Dec 2012	cnwcs5	CCMS SFW 1294 / par 30855
// 04 Feb 2013	cnwcs5	CCMS SFW 1294 /par 30855
//30 may 2014	cnwrs1	Par 34265 change voyage on unpack full
//20 dec 2016	cnwrs1	TFS 3158 Cams Exclusion report does not include the rehandles and sobs
//02 May 2022	jlika1	TFS 53181	GPHA - Voyage Code Translation for Multiple Terminals and Co-Loaders
vars
	camMessage 			: CM_CamMessage;
	messageTypeArray 	: IntegerArray;
	messageType 		: Integer;
	xlVoyageId 			: String;
	contentsStatus 		: String;
	arrayPos3, 
	arrayPos4, 
	arrayPos5 			: Integer;
	theTI 				: CM_TrackedItem;
	vesselName 			: String;
	xlVoyageIdSaved 	: String;
	vesselNameSaved 	: String;
	voyage				: CM_Voyage;
begin
	_camAgent.writeDebugLog(class.name&amp;'::'&amp;method.name&amp;" process "&amp;_transaction.getCamsDisplayDetails);

	theTI := _transaction.myTrackedItem;
	
	create messageTypeArray transient;

	//get the translated voyage Code
	voyage := theTI.myVoyage;
	if _camProtocol.getIsCustomsProtocol() and voyage.customsManifest &lt;&gt; null then
		xlVoyageId := voyage.customsManifest;
	else
		xlVoyageId := self.getVoyageCode(_transaction, _camProtocol, vesselName);
	endif;
	
	xlVoyageIdSaved := xlVoyageId;
	vesselNameSaved := vesselName;
	
	self.getMessageType(_transaction, messageTypeArray, _camProtocol,_camAgent);
	
	if messageTypeArray.size &gt; 0 then
		foreach messageType in messageTypeArray do
			if messageType = CODECO_GATEOUT and 
			   (_transaction.type = TRANS_TYPE_UnpackComplete or
			    _transaction.type = TRANS_TYPE_UNPACK) then
				xlVoyageId := self.getTransactionVoyageCode(_transaction, _camProtocol, vesselName);
			elseif messageType = CODECO_GATEIN and 
			   (_transaction.type = TRANS_TYPE_UnpackComplete or
			    _transaction.type = TRANS_TYPE_UNPACK) then
				xlVoyageId := null;
				vesselName := null;
			else 
				xlVoyageId := xlVoyageIdSaved;
				vesselName := vesselNameSaved;
			endif;
			// One of the Swire Shipping changes is to always have separate messages for each container.
			if _camProtocol.isCodecoSwire then
				camMessage := self.getCamMessage(_camFile, xlVoyageId, vesselName, messageType, true);
			else
				camMessage := self.getCamMessage(_camFile, xlVoyageId, vesselName, messageType, _camProtocol.singleContainerPerBGM);
			endif;
			
			if camMessage &lt;&gt; null then
				contentsStatus := self.contentsStatusToString(_transaction.contentsStatus, camMessage.activity, _transaction.type);
				
				arrayPos3 := camMessage.group3.size;
				arrayPos4 := camMessage.group4.size;
				arrayPos5 := camMessage.group5.size;
				
				camMessage.camVoyage.voyageOid 	:= _transaction.myTrackedItem.myVoyage;
				camMessage.dateTime 			:= self.transDateTime(_transaction, camMessage.activity, _camProtocol);
				
				self.makeMessages(null, _transaction, _camProtocol, camMessage, xlVoyageId, _camProtocol.terminal, null);
				
				camMessage.setupCAMSInfoDetails(_camProtocol, arrayPos3, arrayPos4, arrayPos5, _transaction);	//12 Jul 2012	cnwrs1	CCMS 1269 CAMS reduce number of Trxs
			else
				if _camAgent.logExcludedTransactions then
					_camAgent.logReasonForExclusion(_transaction, "CAM Message is null " &amp; _transaction.String &amp; ".");
				endif;
			endif;
		endforeach;
	endif;
epilog
	if messageTypeArray &lt;&gt; null then
		delete messageTypeArray;
	endif;
end;
</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
    </JadeMethod>
