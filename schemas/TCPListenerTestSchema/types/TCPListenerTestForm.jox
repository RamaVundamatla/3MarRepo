    <JadeMethod name="messageExceptionHandler" id="2620fa38-05f8-4602-869d-0186559063ba">
        <source>messageExceptionHandler(exc : Exception) : Integer;

/*

Purpose:			


Return Value:		


Date		Who		Reason
08 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars
	returnVal		: Integer;
	
begin
	returnVal := Ex_Pass_Back;

	logMessage("Exception " &amp; exc.errorCode.String &amp; " " &amp; 
							  exc.text &amp; " " &amp; 
							  exc.errorItem.String &amp; " " &amp; exc.extendedErrorText);

	if exc.isKindOf(ConnectionException) then
		exc.ConnectionException.connection.close;
		returnVal := Ex_Continue;
	else
		returnVal := Ex_Resume_Next;
	endif;
	
	
epilog
	return returnVal;
	
end;</source>
        <Parameter name="exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
