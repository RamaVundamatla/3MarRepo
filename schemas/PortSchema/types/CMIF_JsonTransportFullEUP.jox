    <JadeMethod name="createGoodFromTI" id="453828a6-309e-4663-9f7b-3c8683f59dab">
        <source>createGoodFromTI(_ti : CM_TrackedItem; _translationOperator : CM_Operator; _isForLoadConfirmation : Boolean; _transaction: CM_TITransaction; _isForEvent: Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Jun 2023	jlier1	Initial creation
30 Jun 2023	jlika1	TFS 58506 57077 - Goods Receipt JADE work
24 Jul 2023	jlika1	TFS 55938 EUP | Load Confirmation Protocol
07 Aug 2023	jlika1	TFS 59632 EUP | Goods Receipt and Load Confirmation: Good/Id
04 Sep 2023 navcs2	Bug 60159: EUP | FR 54536 - Damage and Repair CAMS - Transform Change (ID)
08 Sep 2023	navra1	TFS 60394 - EUP | FR 53824 - Transport Manifest - Number attributes
25 Sep 2023	navra1	TFS 60600 - EUP | FR 53853 - GoodsReceipt Goods/Good/ADMTEffective value should be the same as GrossWeightEffective
02 Oct 2023 navra1	TFS 60662 - EUP | FR - 53853 GoodsReceipt - Output Missing Item Detail/Errors
04 Oct 2023 navra1  TFS 60620 - EUP | FR 53853 GoodsReceipt - Width on Goods Level Not Filled Correctly
06 Oct 2023	navra1	TFS	60396 - EUP | FR 54085 - Load Confirmation - Field Mapping
25 Oct 2023	navdap1	TFS 60390 EUP | FR 53824 - Goods/Good/ID and Item grouping
29 Nov 2023 navhn30 TFS 60687: EUP | FR - 53853 - GoodsReceipt Missing Data Fields
11 Nov 2024	navnk30	JIRA 19826: EUP | FR 53853 GoodsReceipt - Good/QuantityExpected, Good/GrossWeightExpected and Good/NettWeightExpected Incorrect Values (NTO-884)
09 Jan 2025 naviv1	JIRA 33682 : EUP | FR GoodsReceipt Effective Amounts are incorrect for Shortlanded Cargo
10/01/2025	navcs2	MTN-33780  EUP FR | TareWeightExpected is included in the Message but is not in the BRD (NTO-1100)
11 Mar 2025 naviv1  JIRA: MTN-34287 : EUP FR | Expected and Effective amounts are incorrect for cargo received via ship
21 Apr 2025 navhn30	MTN-34603	EUP FR | 53853 Good Receipt effective Quantity and Weight not correct after Ship Discrepancy
*/

vars
	good 				: CMIF_JsonGoodEUP;
	item 				: CMIF_JsonItemEUP;
	foundGood 			: Boolean;	
	id					: String;			// 04 Sep 2023 navcs2	Bug 60159
	createdNewGood		: Boolean;			//navra1 - TFS 60620 - 5th Oct 2023
	count				: Integer;				// TFS 60390
	result				: JadeRegexResult;		// TFS 60390
begin
	if _ti = null then
		return;
	endif;
	
	if _ti.itemised then	//navra1 - TFS 60662 - 2rd Oct 2023
		//navra1 - TFS 60662 - 2rd Oct 2023 - start
		if _ti.myCargoGroup = null then
			//get its cargo group
			foreach good in self.goods do
				if good.keyMarks = self.CARGOGROUP_UNKNOWN then
					foundGood:=true;
					break;
				endif;
			endforeach;
			if not foundGood then
				create good transient;
				good.keyMarks := self.CARGOGROUP_UNKNOWN;
				good.setFromTI( _ti,_translationOperator, _isForLoadConfirmation, _transaction,_isForEvent);	//21.04.25	navhn30 MTN-34603		//navra1 - TFS 60396 - 6th Oct 2023
				self.goods.add(good);
				// TFS 60390 Look for a Goods ID on the end of the manifest number
				count := JadeRegex@split(_ti.manifestNumber, "(\|)", true, result);
				if count = 3 then
					id := result.at(3).value;
				else
					id := self.goods.size.String;	// 04 Sep 2023 navcs2	Bug 60159
				endif;
				// TFS 60390 end of this bit
				good.setID(id);
				createdNewGood := true;			//navra1 - TFS 60620 - 5th Oct 2023
			endif;
			
			create item transient;
			item.setFromTI(_ti);
			//navra1 - TFS 60662 - 2rd Oct 2023 - end
			
			//navra1 - TFS 60620 - 5th Oct 2023 - start - you have UOM values in the item only after the previous line(avoid calling convertMeasurementForDisplay call again)
			if createdNewGood then				
				good.width := app.convertMeasurementForDisplay(item.lengthUOM, _ti.width).asDecimalJMT;
				good.length := app.convertMeasurementForDisplay(item.lengthUOM, _ti.length).asDecimalJMT;
				good.thickness := app.convertMeasurementForDisplay(item.lengthUOM, _ti.height).asDecimalJMT;
				good.diameter :=  app.convertMeasurementForDisplay(item.lengthUOM, _ti.getDiameter()).asDecimalJMT;				
				good.piecesPerPack := _ti.quantity;
				good.grammage := _ti.getGrammage();			//navra1 - TFS 60586 - 18th Oct 2023 - Changed requirement
			endif;
			//navra1 - TFS 60620 - 5th Oct 2023 - end
		else
			//get its cargo group
			foreach good in self.goods do
				if good.keyMarks = _ti.myCargoGroup.id then
					foundGood:=true;
					break;
				endif;
			endforeach;
			if not foundGood then
				create good transient;
				good.keyMarks := _ti.myCargoGroup.id;		//navra1 - TFS 60662 - 2rd Oct 2023
				good.setFromTI( _ti.myCargoGroup,_translationOperator, _isForLoadConfirmation,_transaction,_isForEvent);	//21.04.25	navhn30 MTN-34603			//navra1 - TFS 60396 - 6th Oct 2023
				good.setExpectedAttributes(_ti.myCargoGroup,_ti.myVoyage, _isForLoadConfirmation);								//11.11.2024 navnk30 JIRA 19826  10/01/2025	navcs2	MTN-33780
				good.setEffectiveAttributes(_ti.myCargoGroup,_ti.myVoyage); //JIRA-34287	
				self.goods.add(good);
				// TFS 60390 Look for a Goods ID on the end of the manifest number
				count := JadeRegex@split(_ti.manifestNumber, "(\|)", true, result);
				if count = 3 then
					id := result.at(3).value;
				else
					id := self.goods.size.String;	// 04 Sep 2023 navcs2	Bug 60159
				endif;
				// TFS 60390 end of this bit
				good.setID(id);
				createdNewGood := true;			//navra1 - TFS 60620 - 5th Oct 2023
			endif;
			
			create item transient;
			item.setFromTI(_ti);
			
			//navra1 - TFS 60620 - 5th Oct 2023 - start - you have UOM values in the item only after the previous line(avoid calling convertMeasurementForDisplay call again)
			if createdNewGood then				
				good.width := app.convertMeasurementForDisplay(item.lengthUOM, _ti.width).asDecimalJMT;
				good.length := app.convertMeasurementForDisplay(item.lengthUOM, _ti.length).asDecimalJMT;
				good.thickness := app.convertMeasurementForDisplay(item.lengthUOM, _ti.height).asDecimalJMT;
				good.diameter :=  app.convertMeasurementForDisplay(item.lengthUOM, _ti.getDiameter()).asDecimalJMT;				
				good.piecesPerPack := _ti.quantity;
				good.grammage := _ti.getGrammage();			//navra1 - TFS 60586 - 18th Oct 2023 - Changed requirement
				
				//10.Apr.24 navsp1 TFS 63309
				//Since the good.setFromTI() passing the cargo group object as the parameter and the collection allReserveDetailsReleased is empty for the cargo group, -
				//set the delivery party information from the TI that has the transaction.
				if _isForLoadConfirmation and _ti.allReserveDetailsReleased &lt;&gt; null and _ti.allReserveDetailsReleased.size &gt; 0 then
					good.setFromReserveDetail(_ti.allReserveDetailsReleased.first);
				endif;
				
			endif;
			//navra1 - TFS 60620 - 5th Oct 2023 - end
		endif;
		
		if good.items = null then
			create good.items transient;
		endif;
		
		good.items.add(item);
		
		//requirement if there is &gt; 1 item in the goods and the values are different then blank the fields i.e diameter,width,length,thickness, grammage   (except quantity, weight, volume)		
		//quanity, weight volume fields should be summarized (i.e totalled)
		
		//navra1 - TFS 60620 - 5th Oct 2023 - start
		//navra1 - TFS 60586 - 18th Oct 2023 - Changed requirement - start
		if good.grammage &lt;&gt; item.grammage then
			good.grammage := null;
		endif;
		//navra1 - TFS 60586 - 18th Oct 2023 - Changed requirement - end
		
		if good.diameter &lt;&gt; item.diameter then
			good.diameter := null;
		endif;
		
		if good.width &lt;&gt; item.width then
			good.width := null;
		endif;
		
		if good.length &lt;&gt; item.length then
			good.length  := null;
		endif;
		
		if good.thickness &lt;&gt; item.thickness then
			good.thickness  := null;
		endif;
		
		if good.piecesPerPack &lt;&gt; item.piecesPerPack then
			good.piecesPerPack  := null;
		endif;
		
		if good.reference &lt;&gt; item.reference then				// 29.11.23 	navhn30 	TFS #60687		&gt;&gt;&gt;&gt;
			good.reference  := null;
		endif;
		
		if good.millOrderNumber &lt;&gt; item.millOrderNumber then
			good.millOrderNumber  := null;
		endif;
		
		if good.millOrderLineNumber &lt;&gt; item.millOrderLineNumber then
			good.millOrderLineNumber  := null;
		endif;
		
		if good.description &lt;&gt; item.description then
			good.description  := null;
		endif;

		if good.grade &lt;&gt; item.grade then
			good.grade  := null;
		endif;
		
		if good.remarks &lt;&gt; item.remarks then
			good.remarks  := null;
		endif;
		
		if good.colour &lt;&gt; item.colour then
			good.colour  := null;
		endif;
		
		if good.quality &lt;&gt; item.quality then
			good.quality  := null;
		endif;
		
		if good.goodsBarcode &lt;&gt; item.goodsBarCode then
			good.goodsBarcode  := null;
		endif;
		
		if good.productCondition &lt;&gt; item.productCondition then
			good.productCondition  := null;
		endif;
		
		if good.sortingMethod &lt;&gt; item.sortingMethod then
			good.sortingMethod  := null;
		endif;
		
		if good.certificate &lt;&gt; item.certificate then
			good.certificate  := null;
		endif;
		
		if good.containerNumber &lt;&gt; item.containerNumberText then
			good.thickness  := null;
		endif;
		
		if good.loadingPort &lt;&gt; item.loadPort then
			good.loadingPort  := null;
		endif;
		
		if good.finalDestinationPort &lt;&gt; item.dischargePort then
			good.finalDestinationPort  := null;
		endif;
		
		if good.destinationPort &lt;&gt; item.destinationPort then
			good.destinationPort  := null;
		endif;
		
		if good.customerReference &lt;&gt; item.customerReference then
			good.customerReference  := null;
		endif;
		
		if good.stowageMode &lt;&gt; item.stowMode then
			good.stowageMode  := null;
		endif;
		
		if good.countryOfOrigin &lt;&gt; item.countryOfOrigin then
			good.countryOfOrigin  := null;
		endif;
		
		if good.dangerousGoods &lt;&gt; item.dangerousGoods then
			good.dangerousGoods  := null;
		endif;
		
		if good.iMOClass &lt;&gt; item.iMOClass then
			good.iMOClass  := null;
		endif;
		
		if good.flashpoint &lt;&gt; item.flashpoint then
			good.flashpoint  := null;
		endif;
		
		if good.packingGroup &lt;&gt; item.packingGroup then
			good.packingGroup  := null;
		endif;
		
		if good.uNCode &lt;&gt; item.uNCode then
			good.uNCode  := null;
		endif;
		
		if good.limitedQuantity &lt;&gt; item.limitedQuantity then
			good.limitedQuantity  := null;
		endif;												// 29.11.23 	navhn30 	TFS #60687		&lt;&lt;&lt;&lt;
		
	else
	
		create good transient;
		good.setFromTI(_ti,_translationOperator, _isForLoadConfirmation,_transaction,_isForEvent);		//21.04.25	navhn30 MTN-34603		//navra1 - TFS 60396 - 6th Oct 2023
		self.goods.add(good);
		id := self.goods.size.String;	// 04 Sep 2023 navcs2	Bug 60159
		good.setID(id);
	endif;
epilog
	delete result;		// TFS 60390
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_translationOperator" type="CM_Operator"/>
        <Parameter name="_isForLoadConfirmation" type="Boolean"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_isForEvent" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createTransportObjects" id="8fc7b27a-2b0b-44a7-b5af-1ca9f3e71274">
        <updating/>
        <source>createTransportObjects(transportMode : String; 
					   voyage : CM_Voyage input; 
					   theTI : CM_TrackedItem input; 
					   translationOperator : CM_Operator input; 					   
					   transaction : CM_TITransaction;
					   vehicleVisit : CM_VehicleVisitRecord;
					   wagon : CM_Wagon;
					   isForLoadConfirmation : Boolean;
					   isForEvent :  Boolean) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 24 July 2023
TFS#		: 55938
Function	:

*** Changes ***
Date			Name		TFS#		Description
6/10/2023		navra1		60396		EUP | FR 54085 - Load Confirmation - Field Mapping
21 Apr 2025 	navhn30		MTN-34603	EUP FR | 53853 Good Receipt effective Quantity and Weight not correct after Ship Discrepancy

****************************************************/

vars
	vesselInfo 	: CMIF_JsonVesselInfoEUP;
	truckInfo 	: CMIF_JsonTruckInfoEUP;
	trainInfo 	: CMIF_JsonTrainInfoEUP;
	unpackedTI 	: CM_TrackedItem;
	container 	: CMIF_JsonContainerEUP;
	goods 		: CMIF_JsonGoodEUP;
begin
    if transportMode = TI_TRANSMODE_SHIP_STR then
		create vesselInfo transient;
		vesselInfo.setVesselInfo(voyage, theTI, translationOperator);
		self.vesselInfo := vesselInfo;
	endif;
	
	if transportMode = TI_TRANSMODE_ROAD_STR then			
		create truckInfo transient;
		truckInfo.setFromTI(theTI, transaction,translationOperator, vehicleVisit, isForLoadConfirmation);			//navra1 - TFS 60396 - 6th Oct 2023
		self.truckInfo := truckInfo;
	endif;
	
	if transportMode = TI_TRANSMODE_RAIL_STR then			
		create trainInfo transient;
		trainInfo.setFromTI(theTI, wagon, isForLoadConfirmation);			//navra1 - TFS 60396 - 6th Oct 2023
		self.trainInfo := trainInfo;
	endif;
	
	unpackedTI := theTI.getMyUnpackedFromContainer();
	if unpackedTI &lt;&gt; null then
		create container transient;
		container.setFromTI(unpackedTI,translationOperator, isForLoadConfirmation);			//navra1 - TFS 60396 - 6th Oct 2023
		self.containers.add(container);
	endif;	

	self.createGoodFromTI(theTI, translationOperator, isForLoadConfirmation,transaction.CM_TITransaction,isForEvent);		// 21.04.25	navhn30	MTN-34603 	//navra1 - TFS 60396 - 6th Oct 2023
end;
</source>
        <Parameter name="transportMode" type="String"/>
        <Parameter name="voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="theTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="translationOperator" type="CM_Operator" usage="input"/>
        <Parameter name="transaction" type="CM_TITransaction"/>
        <Parameter name="vehicleVisit" type="CM_VehicleVisitRecord"/>
        <Parameter name="wagon" type="CM_Wagon"/>
        <Parameter name="isForLoadConfirmation" type="Boolean"/>
        <Parameter name="isForEvent" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="delete" id="6628f352-e876-4b38-a617-aaf99a5795b6">
        <updating/>
        <source>delete() updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 30 June 2023
TFS#		: 58506
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
begin
	self.containers.purge;	
	self.goods.purge;
	
	if self.trainInfo &lt;&gt; null then
		delete self.trainInfo;
	endif;
	
	if self.truckInfo &lt;&gt; null then
		delete self.truckInfo;
	endif;
	
	if self.vesselInfo &lt;&gt; null then
		delete self.vesselInfo;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setFromTI" id="0152db5c-d7fc-4c94-87b2-96d74520394a">
        <updating/>
        <source>setFromTI(theTI : CM_TrackedItem input; voyage : CM_Voyage input;_translationOperator : CM_Operator; _transportMode: String; _isForLoadConfirmation: Boolean; _startDate, _endDate : TimeStamp) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 22 June 2023
TFS#		: 58506
Function	:

*** Changes ***
Date			Name		TFS#		Description
30/08/2023		jlika1		60139		MTN - Load Confirmation - TransportationMode and TransportType are displaying as Road and Truck in the CAMS message for the Ship Release Request
11/09/2023		jlika1		60337		EUP | FR EDI - EUP CAMS protocols: Translations based on Receiver
6/10/2023		navra1		60396		EUP | FR 54085 - Load Confirmation - Field Mapping
02/02/2024		naviv1		61693		EUP | FR 53853 GoodsReceipt Future Voyage Departure Date
04/06/2024		navlw1		63178		EUP* | FR - 53853 GoodsReceipt Missing Fields  
25/06/2024		navmd1		61725		Fix Timestamps not being reported in UTC (as the mapper expects UTC/Zulu time)
22/10/2024		navmd1		MTN-27222	Fix start/endDateTime coming through invalid when the voyage was the null voyage
13/11/2024		navcs2		MTN-33410 EUP | FR 53853 - NTO-1054 - Shortlanded is not sent in the GoodsReceipt Message
****************************************************/

vars
	carrier 		: CMIF_JsonCarrierPartyEUP;
	vehicleVisit 	: CM_VehicleVisitRecord;
	train 			: CM_Train;
begin
	self.transportationMode := _transportMode;
	self.dischargingPlace := theTI.getMyTerminal().code;
	self.loadingPlace := theTI.loadPort;
	
	if self.transportationMode = TI_TRANSMODE_ROAD_STR then
		self.transportType := "Truck";
		vehicleVisit := theTI.getVehicleVisit();
		if vehicleVisit  &lt;&gt; null then
			self.dateTimeOfArrival := vehicleVisit.timeIn.localToUTCTime;
			self.dateTimeOfDeparture := vehicleVisit.timeOut.localToUTCTime;
		endif;
	elseif self.transportationMode = TI_TRANSMODE_RAIL_STR then
		self.transportType := "Wagon";
		train := theTI.getMyTrainReceive();
		if train &lt;&gt; null then
			self.dateTimeOfArrival := train.arrivalDT.localToUTCTime;
			self.dateTimeOfDeparture := train.departureDT.localToUTCTime;
		endif;
	elseif self.transportationMode = TI_TRANSMODE_SHIP_STR and voyage.isBarge then
		self.transportType := "Barge";
		self.dateTimeOfArrival := voyage.arrivedDT.localToUTCTime;
		if theTI.getVoyageDepartureDate &lt; app.actualTimeServer.Date then 	//02.02.2024 naviv1 #61693
			self.dateTimeOfDeparture := voyage.departedDT.localToUTCTime;
		endif;
	elseif self.transportationMode = TI_TRANSMODE_SHIP_STR then
		self.transportType := "Vessel";
		self.dateTimeOfArrival := voyage.arrivedDT.localToUTCTime;
		if theTI.getVoyageDepartureDate &lt; app.actualTimeServer.Date then 	//02.02.2024 naviv1 #61693
			self.dateTimeOfDeparture := voyage.departedDT.localToUTCTime;
		endif;
	endif;
	
	// navlw1 #63178
	if _startDate.isValid then										//13/11/2024		navcs2		MTN-33410
		self.startDateTime := _startDate.localToUTCTime;
	endif;															//13/11/2024		navcs2		MTN-33410
	
	if _endDate.isValid then										//13/11/2024		navcs2		MTN-33410
		self.endDateTime := _endDate.localToUTCTime;
	endif;															//13/11/2024		navcs2		MTN-33410
	
	if not self.startDateTime.isValid and voyage.arrivedDT.isValid then
		self.startDateTime := voyage.arrivedDT.localToUTCTime;
	endif;
	if not self.endDateTime.isValid and voyage.departedDT.isValid then
		self.endDateTime := voyage.departedDT.localToUTCTime;
	endif;
	
	create carrier transient;
	carrier.setFromTI(theTI, voyage, _translationOperator, _transportMode, _isForLoadConfirmation);			//navra1 - TFS 60396 - 6th Oct 2023
	self.carrierParty := carrier;		
	
end;</source>
        <Parameter name="theTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_translationOperator" type="CM_Operator"/>
        <Parameter name="_transportMode" type="String"/>
        <Parameter name="_isForLoadConfirmation" type="Boolean"/>
        <Parameter name="_startDate" type="TimeStamp"/>
        <Parameter name="_endDate" type="TimeStamp"/>
    </JadeMethod>
</Class>
