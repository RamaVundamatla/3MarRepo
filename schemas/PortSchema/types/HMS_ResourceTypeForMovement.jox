	return app.getErrorString(MovementResource);
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLDefinitionString" id="b9b2d668-3ac2-400e-b1ae-5cbe783691a1">
        <source>getXMLDefinitionString() : String;
//--------------------------------------------------
// Created:	07 October 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpResType : HMS_ResourceType;
	xml : String;
begin
	
	xml := "&lt;RTM&gt;&lt;mt&gt;" &amp; self.movementType &amp;
		   "&lt;/mt&gt;&lt;nt&gt;" &amp;  self.numTugsForMovement.Integer.String &amp;
		   "&lt;/nt&gt;&lt;RT&gt;";

	foreach tmpResType in self.allResourceTypes do
		xml := xml &amp; "&lt;rtc&gt;" &amp; tmpResType.code &amp; "&lt;/rtc&gt;";
	endforeach;
	
	xml := xml &amp; "&lt;/RT&gt;&lt;/RTM&gt;";
	
	return xml;			 	
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="importFromXMLDocReference" id="95186f86-a8dc-4a4f-ab95-8b411ec68ecc">
        <updating/>
        <source>importFromXMLDocReference(_property: Property; _xmlElement: JadeXMLElement input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 April 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars
	childElement , resourceTypeElement: JadeXMLElement;
	allChildElements : JadeXMLElementArray;
	resourceType : HMS_ResourceType;
begin
	if _property = HMS_ResourceTypeForMovement::myHarbour then
		// ExportAsChild;
		childElement:=_xmlElement.getElementByTagName(HMS_Harbour::code.name);	
		if childElement &lt;&gt; null then
			self.myHarbour:=app.myRoot.allHarbours[childElement.textData];
		endif;
	elseif _property = HMS_ResourceTypeForMovement::allResourceTypes then
		// ExportAsParent;	
		create allChildElements transient;
		_xmlElement.getAllElementsByTagName(HMS_ResourceType.name,allChildElements);
		foreach childElement in allChildElements do
			resourceTypeElement:=childElement.getElementByTagName(HMS_ResourceType::code.name);	
			if resourceTypeElement &lt;&gt; null then
				resourceType:=app.myRoot.allResourceTypes[resourceTypeElement.textData];
				if resourceType &lt;&gt; null then
					self.allResourceTypes.add(resourceType);
				endif;
			endif;
		endforeach;	
	endif;

epilog
	delete allChildElements;
end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_xmlElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="5e538cab-7a55-4253-ae31-9fc6373ec97c">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     16 February 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
vars
	prxy 			: HMS_ResourceTypeForMovement;
	completedOK		: Boolean;
begin
	prxy := inheritMethod();	
	prxy.myHarbour			:= self.myHarbour;
	self.allResourceTypes.copy(prxy.allResourceTypes);
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return prxy;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete prxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="f8a46101-d9f8-4226-bf57-aeb4a39330cc">
        <updating/>
        <source>setForUpdate(_pxyMovementResource: HMS_ResourceTypeForMovement; _passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     15 February 2005	cnwhjg1
//
// Purpose:     
//
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 11/02/2021	jlgdap1		TFS 50720 PNL How to remove contract movement resources
// 
vars
	movement : HMS_VoyageMovement;		// TFS 50720

begin
	inheritMethod(_pxyMovementResource, _passport);
	
	self.movementType 		:= _pxyMovementResource.movementType;
	self.numTugsForMovement := _pxyMovementResource.numTugsForMovement;
	self.myHarbour 			:= _pxyMovementResource.myHarbour;
	
	// TFS 50720 Adjust the num tugs on the associated movement if required
	if self.myHMSVoyageData &lt;&gt; null then
		movement := self.myHMSVoyageData.getMovementForMoveType(self.movementType);
		if movement &lt;&gt; null then
			movement.setNumContractTugs(self.numTugsForMovement);
		endif;
	endif;
	// TFS 50720 end

	self.allResourceTypes.clear();
	_pxyMovementResource.allResourceTypes.copy(self.allResourceTypes);
end;</source>
        <Parameter name="_pxyMovementResource" type="HMS_ResourceTypeForMovement"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="5d216ae1-715f-4c7a-9650-952649395ff6">
        <updating/>
        <source>setProxy(_movementType : String; _numTugsForMovement : Integer; _myHarbour : HMS_Harbour; _allResourceTypes : Collection) updating;
//-----------------------------------------
// Created: 8 April 2005 By: cnwgd1
//-----------------------------------------
vars

begin
	
	
	self.raiseExceptionIfNotTransient(method);
	
	self.movementType 		:= _movementType;
	self.numTugsForMovement := _numTugsForMovement;
	self.myHarbour 			:= _myHarbour;

	self.allResourceTypes.clear();
	if _allResourceTypes &lt;&gt; null then
		_allResourceTypes.copy(self.allResourceTypes);
	endif;
	
end;</source>
        <Parameter name="_movementType" type="String"/>
        <Parameter name="_numTugsForMovement" type="Integer"/>
        <Parameter name="_myHarbour" type="HMS_Harbour"/>
        <Parameter name="_allResourceTypes" type="Collection"/>
    </JadeMethod>
    <JadeMethod name="setProxyVDHFromXML" id="0e60eb1b-0f3c-46a1-808b-ea9434904dbd">
        <updating/>
        <source>setProxyVDHFromXML(_theXML, _moveType : String; _harbour : HMS_Harbour) updating;
//--------------------------------------------------
// Created:	07 October 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpStr,
	tmpCode : String;
	pos : Integer;
	tmpRoot : CM_Root;
	tmpResType : HMS_ResourceType;
begin

	if _harbour = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null harbour');
		return;
	endif;
	
	self.movementType := _moveType;
	self.myHarbour := _harbour;

	if _theXML = null then
		return;
	endif;
		
	self.numTugsForMovement	:= _theXML.cnEcGetTagValueOfName("nt").Integer;

	tmpStr := _theXML.cnEcGetTagValueOfName("RT"); 
	if tmpStr = null then
		return;
	endif;
	
	tmpRoot	:= app.myRoot;

	// create default movement resources
	pos := 1;
	while (pos &gt; 0) do
		tmpCode := tmpStr.cnEcGetNextTagValueOfName("rtc", pos); 
		if tmpCode = null then
			break;
		endif;

		tmpResType := tmpRoot.allResourceTypes[tmpCode];
		
		if self.allResourceTypes.includes(tmpResType) then
			// one already exists for this type
			continue;
		endif;
		
		self.allResourceTypes.add(tmpResType);
		
	endwhile;				
					
end;</source>
        <Parameter name="_theXML" type="String"/>
        <Parameter name="_moveType" type="String"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="d20a013d-f603-4546-a2ca-583d18e9783a">
        <source>validateMe(_passport: CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     15 February 2005	cnwhjg1
//
// Purpose:     
//14/06/2022    navds20     TFS 53760 DuplicateItem not Translatable
// ----------   ----------  --------------------------------------------------
vars
	tmpMoveResource,
	exsistingRM,
	realMovementResource	: HMS_ResourceTypeForMovement;
begin
	inheritMethod(_passport);
	
	if self.myHarbour = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Harbour', ETRow_MyHarbourResource, null);
		app.raiseCMException(Input_required_field_harbour, ETRow_MyHarbourResource, null); // cnwdb2	PAR 35364
	endif;	

	if self.movementType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Movement Type', ETRow_MoveType, null);
		app.raiseCMException(Input_required_field_moveType, ETRow_MoveType, null); // cnwdb2	PAR 35364
	endif;		

	//---------------------------------------------------------------------------
	// Check for duplicates
	//---------------------------------------------------------------------------
	if self.isTransient then		
		realMovementResource := self.pxyGetRealObject();
	endif;
	foreach tmpMoveResource in self.myVesselDataHarbour.allMovementResourcesByMovement do
		if tmpMoveResource = self then
			continue;
		endif;
		if tmpMoveResource = realMovementResource then
			continue;
		endif;		
		if tmpMoveResource.isTransient then
			exsistingRM := tmpMoveResource.pxyGetRealObject();
		endif;
		if exsistingRM &lt;&gt; null then
			if exsistingRM = realMovementResource then
				continue;
			endif;
		endif;
		
		if tmpMoveResource.movementType = self.movementType then
			//app.raiseCMException2(DuplicateItem, 'Movement Type', self.movementType, ETRow_MoveType, null); //14.06.2022 navds20 53760
			// Movement Type already exists for %1 : Movemen_type_already_exists
			app.raiseCMException1(Movemen_type_already_exists, self.movementType, ETRow_MoveType, null); //14.06.2022 navds20 53760
			return;		
		endif;
	endforeach;	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
