    <JadeMethod name="setProxyFromObject" id="28301b63-b29c-48da-bd93-5d87c8cd695d">
        <updating/>
        <source>setProxyFromObject(_reserveDetail : CM_ReserveDetail) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/06/2024	navdap1		Initial creation TFS 63107 CUX | GET /releaseRequest API to return release request line items
//
vars
	weightLoaded, weightPacked, weightReleased, weightStaged : Decimal [16,4];

begin
	weightLoaded := _reserveDetail.getWeightLoaded();
	if weightLoaded &lt;&gt; null then
		self.loaded := weightLoaded;
	else
		self.loaded := _reserveDetail.getTotalLoaded;
	endif;
	
	weightPacked := _reserveDetail.getWeightPacked();
	if weightPacked &lt;&gt; null then
		self.packed := weightPacked;
	else
		self.packed := _reserveDetail.getTotalPacked;
	endif;
	
	weightReleased := _reserveDetail.getWeightReleased();
	if weightReleased &lt;&gt; null then
		self.released := weightReleased;
	else
		self.released := _reserveDetail.getTotalReleased;
	endif;
	
	self.remaining := _reserveDetail.getTotalOutstandingForWeb();
	
	weightStaged := _reserveDetail.getWeightStaged();
	if weightStaged &lt;&gt; null then
		self.staged := weightStaged;
	else
		_reserveDetail.getTotalStagedOrSelected(self.staged, weightStaged);
	endif;
epilog

end;</source>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
    </JadeMethod>
</Class>
