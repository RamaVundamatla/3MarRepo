    <JadeMethod name="getFirstBGPExtWebController" id="d22ee6fe-a428-4245-b707-af170ed87ae2">
        <source>getFirstBGPExtWebController( _wsDef : CM_ExternalWebServiceDef ):BGP_ExternalWSController;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 August 2020	jlgndl1	Initial creation	TFS 49869

*/

vars

	iter : Iterator;
	bgpCont : BGP_ExternalWSController;

begin

	iter := BGP_ExternalWSController.instances.createIterator;
	while iter.next( bgpCont ) do
		if bgpCont.myExternalWSDef &lt;&gt; _wsDef then
			continue;
		endif;
		if bgpCont.myTerminal &lt;&gt; self then
			continue;
		endif;
		return bgpCont;
	endwhile;
	
	return null;

epilog

	delete iter;

end;</source>
        <Parameter name="_wsDef" type="CM_ExternalWebServiceDef"/>
        <ReturnType type="BGP_ExternalWSController"/>
    </JadeMethod>
    <JadeMethod name="getFirstNonSystemCargoType" id="db35b229-7a88-4028-a193-b420ee922f42">
        <source>getFirstNonSystemCargoType() : CM_CargoBOLType;
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/
vars
	iter					: Iterator;
	cargoBOLType			: CM_CargoBOLType;
	compName : String;
begin

	compName := app.computerNameAppServer();
		
	iter := self.allCargoBOLTypes.createIterator;

	if app.isDevelopmentSystem then 
		while iter.next(cargoBOLType) do
			if cargoBOLType.abbreviation = "CANNONBALL" then
				return cargoBOLType;
			endif;
		endwhile;
	endif;

	iter.reset();
	while iter.next(cargoBOLType) do
		if cargoBOLType.isSystemCargoBOLType then
			continue;
			
		endif;
		if not cargoBOLType.isKindOf(CM_CargoType) then
			continue;
		endif;
		return cargoBOLType;
	endwhile;
	
	return null;
epilog
	delete iter;
end;</source>
        <ReturnType type="CM_CargoBOLType"/>
    </JadeMethod>
