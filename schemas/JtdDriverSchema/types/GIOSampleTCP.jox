    <JadeMethod name="tp020_GIOF_tblExtra_click" id="47808024-1d60-4ef3-8112-300d60ae4e03">
        <updating/>
        <source>tp020_GIOF_tblExtra_click():Integer updating;

vars
	tblExtra:Table;
	cmbCommodity:ComboBox;
begin
	tblExtra:=myGTE_InOutForm_2.getPropertyValue('tblExtra').Table.getControl(1);
	tblExtra.row:=28;
	tblExtra.column:=2;
	tblExtra.clearAllSelected;
	tblExtra.accessCell(28,2).selected:=true;
	tblExtra.rowColumnChg(tblExtra);
	tblExtra:=myGTE_InOutForm_2.getPropertyValue('tblExtra').Table.getControl(1);
	tblExtra.mouseDown(tblExtra, 1, 0, 192, 153);
	app.doWindowEvents(shortPause);
	cmbCommodity:=myGTE_InOutForm_2.getPropertyValue('cmbCommodity').ComboBox.getControl(1);
	cmbCommodity.lostFocus(cmbCommodity);
	tblExtra:=myGTE_InOutForm_2.getPropertyValue('tblExtra').Table.getControl(1);
	tblExtra.mouseUp(tblExtra, 1, 0, 192, 153);
	app.doWindowEvents(shortPause);
	tblExtra:=myGTE_InOutForm_2.getPropertyValue('tblExtra').Table.getControl(1);
	app.doWindowEvents(shortPause);
	tblExtra.row:=28;
	tblExtra.column:=2;
	tblExtra.click(tblExtra);  // 16:06:14
	return 0;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
