    <JadeMethod name="canUserRemove" id="a9196ee9-33cd-4611-9252-f23046f22b74">
        <source>canUserRemove(_passport : CM_Passport input) : Boolean;
// ---------------------------------------------------------------------------
// Created:     07 March 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	canUpdate	: Boolean;

begin

	canUpdate := false;
	
	if self.toDoTaskDesc = null then		// not global.isValidObject(self.toDoTaskDesc) then - inversed, so can't be invalid
		//Can't reference the task type so can't tell if they have rights
		canUpdate := true;
	else
		if _passport.myUser.canAddRemoveTodoTask(_passport.myTerminal, self.toDoTaskDesc) then
			canUpdate := true;
		endif;
	endif;
		
	if not canUpdate then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ErrToDoTaskRemove, self.toDoTaskDescDesc, null, null);
		return false;		
	endif;

epilog
	return canUpdate;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canUserSetComplete" id="ecde165f-920f-4a4d-bae3-61003ca63d7d">
        <source>canUserSetComplete(_passport : CM_Passport input) : Boolean;
// ---------------------------------------------------------------------------
// Created:     07 March 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	canUpdate	: Boolean;

begin

	canUpdate := false;
	
	if app.isUnitTestGarbageCollect then
		return true;
	endif;
	
	if self.toDoTaskDesc = null then		// not global.isValidObject(self.toDoTaskDesc) then
		//Can't reference the task type so can't tell if they have rights
		canUpdate := true;
	else
		if _passport.myUser.canCompleteTodoTask(self.myTerminal, self.toDoTaskDesc) then
			canUpdate := true;
		endif;
	endif;
		
	if not canUpdate then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_COMPLETE_TASK, self.toDoTaskDescDesc, null, null);
		return false;		
	endif;

epilog
	return canUpdate;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
