    <JadeMethod name="controlNamePrefix" id="fe273aa5-8e69-4274-a06a-6bec2fb74d87">
        <source>controlNamePrefix(): String;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
