    <JadeMethod name="comboBoxSite" id="c1197099-f85c-4977-b59c-b77c184ca3ec">
        <source>comboBoxSite(_cmb : ComboBox input; _site : Integer);
// ---------------------------------------------------------------------------
// Created:     29 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	listIdx					: Integer;
begin
	_cmb.clear();
	_cmb.sorted := false;
	_cmb.itemData[_cmb.addItem(app.siteEnumToString(TI_SITE_ONSITE))] := TI_SITE_ONSITE;
	_cmb.itemData[_cmb.addItem(app.siteEnumToString(TI_SITE_ONSHIP))] := TI_SITE_ONSHIP;
	_cmb.itemData[_cmb.addItem(app.siteEnumToString(TI_SITE_TBA))] := TI_SITE_TBA;
	_cmb.itemData[_cmb.addItem(app.siteEnumToString(TI_SITE_OFFSITE))] := TI_SITE_OFFSITE;
	_cmb.itemData[_cmb.addItem(app.siteEnumToString(TI_SITE_UNDEFINED))] := TI_SITE_UNDEFINED;
	_cmb.itemData[_cmb.addItem(app.siteEnumToString(TI_SITE_PLACEHOLDER))] := TI_SITE_PLACEHOLDER;	//13 Mar 2020	NDL	TFS 47004
	if app.isCargoGroupEnabled then
		_cmb.itemData[_cmb.addItem(app.siteEnumToString(TI_SITE_CARGOGROUP))] := TI_SITE_CARGOGROUP;
	endif;

	if listIdx &gt; 0 then
		_cmb.listIndex := listIdx;
	endif;
	
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_site" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="comboBoxSnapshotDefinition" id="1149ce65-cb3f-45f5-978f-bdc85f4678b3">
        <source>comboBoxSnapshotDefinition( _cmb : ComboBox input; _snapshotDef : CM_OutputFormat_SS);
// ---------------------------------------------------------------------------
// Created:		21 Feb 2013	cnwjre1
// ---------------------------------------------------------------------------

vars
	snapshot	: CM_OutputFormat_SS;
	idx		: Integer;
begin

	_cmb.clear;
	
	idx := _cmb.addItem("");
	_cmb.itemObject[idx] := null;
	
	foreach snapshot in app.myRoot.allOutputFormats_SS do
		idx := _cmb.addItem( snapshot.name );
		_cmb.itemObject[idx] := snapshot;
	endforeach;
	if _snapshotDef &lt;&gt; null then
		_cmb.listIndex := _cmb.findObject(_snapshotDef);
	endif;
	

end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_snapshotDef" type="CM_OutputFormat_SS"/>
    </JadeMethod>
    <JadeMethod name="comboBoxSortingMethods" id="430377a0-c1a4-469a-9c6f-79ae23db151a">
        <source>comboBoxSortingMethods(_cmb : ComboBox input; _sortingMethod : CM_SortingMethod);
/*

Purpose:			Populates the combo box with all the sorting methods in the system

Parameters:			_cmb	ComboBox					The combo box to populate
					_sortingMethod	CM_SortingMethod	The sorting method to set the combo box to once populated

Return Value:		NONE

Date			Who		Reason
12 June 2023	navpw1	Initial creation TFS: 57812 (58439)

*/

vars
	sortingMethodsDict	: CM_SortingMethodByCodeDict;
	sortingMethod		: CM_SortingMethod;
	form				: Form;
	
begin
	_cmb.clear();
	sortingMethodsDict := app.myRoot.allSortingMethods;
	
	form := _cmb.form;
	
	foreach sortingMethod in sortingMethodsDict do
		_cmb.itemObject[_cmb.addItem(sortingMethod.code &amp; " - " &amp; sortingMethod.description)] := sortingMethod;
	endforeach;
	
	sortingMethod := null; //Reset from above
	
	if _sortingMethod &lt;&gt; null then
		sortingMethod := sortingMethodsDict[_sortingMethod.code];
	endif;
	
	if sortingMethod &lt;&gt; null then
		_cmb.listObject := sortingMethod;
	endif;
	
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_sortingMethod" type="CM_SortingMethod"/>
    </JadeMethod>
    <JadeMethod name="comboBoxSourceArea" id="17899ebd-ea81-4f87-9905-425e2af50a7b">
        <source>comboBoxSourceArea(_cmb: CMUI_ComboBox input; _terminalArea : CM_TerminalArea);
// -----------------------------------------------------------------------------
// Created:		13 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	_cmb : ComboBox to populate
//				__terminalArea : the currently selected terminal area
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 08 Sep 2022	jlika1		TFS 54699 - CUX - MAFI Handling Enhancements - MAFI Heap Terminal Area
// -----------------------------------------------------------------------------

vars
	aTerminalArea : CM_TerminalArea;
	idx : Integer;
	theFilter : CMQF_TerminalAreas;
	theQryReport : CM_QryReport;
	
begin
	_cmb.clear;
	
	theQryReport := app.myRoot.myReportMenuRoot.getReportByConstantValue(CM_RepTerminalArea);
	
	create theFilter transient;
	theFilter.allTerminals.add(self.myTerminal);
	theFilter.terminalAreaTypes.add(TA_TYPE_DEPOT_LCL);
	theFilter.terminalAreaTypes.add(TA_TYPE_BLOCK_STACK);
	theFilter.terminalAreaTypes.add(TA_TYPE_SUBBLOCK_STACK);	
	theFilter.terminalAreaTypes.add(TA_TYPE_WASH_AREA);			
	theFilter.terminalAreaTypes.add(TA_TYPE_PTI);				
	theFilter.terminalAreaTypes.add(TA_TYPE_REPAIR);				
	theFilter.terminalAreaTypes.add(TA_TYPE_RECTRANS);				
	theFilter.terminalAreaTypes.add(TA_TYPE_RELTRANS);				
	theFilter.terminalAreaTypes.add(TA_TYPE_RAIL_TRANS);				
//	theFilter.terminalAreaTypes.add(TA_TYPE_ROAD_TRANS);	cnwcs5 11/09/2009 - removing VTA
	theFilter.terminalAreaTypes.add(TA_TYPE_DAIRY);				
	theFilter.terminalAreaTypes.add(TA_TYPE_RAIL_TRANS);	 //cnwrd1 6.8.2010 par 25315
	theFilter.terminalAreaTypes.add(TA_TYPE_MAFI);
	
	theQryReport.doFilter(theFilter, app.myPassport);
	
	idx := _cmb.addItem('');
	_cmb.itemObject[idx] := null;
	
	foreach aTerminalArea in theFilter.allQryTerminalAreas do
		if aTerminalArea.type = TA_TYPE_CRANE_TRANS
		or  aTerminalArea.type = TA_TYPE_DELETE then
			continue;
		endif;
		idx := _cmb.addItem(aTerminalArea.id &amp; " " &amp; aTerminalArea.getMenuDetails(false,REAL_MODE));
		_cmb.itemObject[idx] := aTerminalArea;
	endforeach;

	if _terminalArea &lt;&gt; null then
		_cmb.cnEcSetObjectIndex(_terminalArea);
	endif;
	
epilog
	delete theFilter;
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="comboBoxSourceArea2" id="16563c84-e5cc-47a3-938c-2bc06e641d6e">
        <source>comboBoxSourceArea2(_cmb: ComboBox input; _terminalArea : CM_TerminalArea; _includeNull : Boolean; _includeCount : Boolean);
/* -----------------------------------------------------------------------------
// Created:		17 March 2010 by cnwjre1, CCMS 1101 MT release handling
//
// Purpose:		Populate combo box of source terminal areas for cargo source selection,
//				including block stacks and gridded areas.  Called from CMUI_SelectISOSource,
//					CMUI_ReleaseCargoForm etc
//
// Parameters:	_cmb : ComboBox to populate
//				_terminalArea : the currently selected terminal area
//				_includeNull  : include a null entry to allow resetting the option
//				_includeCount : include the TI count (is slower, so optional)
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
/	15 Jul 2013  cnwer1 		PAR 31985 removed trailer areas
//	08 Sep 2022	jlika1			TFS 54699 - CUX - MAFI Handling Enhancements - MAFI Heap Terminal Area
// -----------------------------------------------------------------------------
*/
vars
	aTerminalArea : CM_TerminalArea;
	numTIs,
	idx : Integer;
	str				: String;
	theFilter : CMQF_TerminalAreas;
	theQryReport : CM_QryReport;
	
begin
	_cmb.clear;
	
	theQryReport := app.myRoot.myReportMenuRoot.getReportByConstantValue(CM_RepTerminalArea);
	
	create theFilter transient;
	theFilter.allTerminals.add(self.myTerminal);
	theFilter.terminalAreaTypes.add(TA_TYPE_DEPOT_LCL);
	theFilter.terminalAreaTypes.add(TA_TYPE_BLOCK_STACK);
	theFilter.terminalAreaTypes.add(TA_TYPE_IRREGULAR_BLOCK_AREA); //epr par 36101 29/4/15
	theFilter.terminalAreaTypes.add(TA_TYPE_BULK); //epr par 35702 24/2/15
	theFilter.terminalAreaTypes.add(TA_TYPE_SUBBLOCK_STACK);	
	theFilter.terminalAreaTypes.add(TA_TYPE_WASH_AREA);			
	theFilter.terminalAreaTypes.add(TA_TYPE_PTI);				
	theFilter.terminalAreaTypes.add(TA_TYPE_REPAIR);				
	theFilter.terminalAreaTypes.add(TA_TYPE_DAIRY);	
	
	theFilter.terminalAreaTypes.add(TA_TYPE_STRADDLE_STACK);	
	theFilter.terminalAreaTypes.add(TA_TYPE_FORK_LIFT_STACK);	
	theFilter.terminalAreaTypes.add(TA_TYPE_RTG);	
	theFilter.terminalAreaTypes.add(TA_TYPE_RMG);
	theFilter.terminalAreaTypes.add(TA_TYPE_RORO_LANE_AREA);	//29 May 2012	NDL	Par 29642
	theFilter.terminalAreaTypes.add(TA_TYPE_MAFI);
	
	theQryReport.doFilter(theFilter, app.myPassport);
	
	if _includeNull then
		idx := _cmb.addItem('');
		_cmb.itemObject[idx] := null;
	endif;
	
	foreach aTerminalArea in theFilter.allQryTerminalAreas do
		if aTerminalArea.type = TA_TYPE_CRANE_TRANS
		or  aTerminalArea.type = TA_TYPE_DELETE then
			continue;
		endif;
		str := aTerminalArea.id.trimBlanks &amp; Tab &amp;
			   aTerminalArea.typeString.trimBlanks;
		if _includeCount then
			numTIs := aTerminalArea.getNumTIs(REAL_MODE); //rs oct 2005 par 10886
			str := str &amp; Tab &amp; numTIs.String;
		endif;
		idx := _cmb.addItem(str);
		_cmb.itemObject[idx] := aTerminalArea;
	endforeach;

	if _terminalArea &lt;&gt; null then
		_cmb.cnEcSetObjectIndex(_terminalArea);
	endif;
	
epilog
	delete theFilter;
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_includeNull" type="Boolean"/>
        <Parameter name="_includeCount" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="comboBoxSpecialStow" id="626f2f53-034f-48d8-893c-956e9d187510">
        <source>comboBoxSpecialStow(_cmb : CMUI_ComboBox input; _specialStow : CM_SpecialStow);
