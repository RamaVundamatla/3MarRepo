    </JadeMethod>
    <JadeMethod name="updateActivityHistory" id="4d985684-1798-4cc8-b605-9f8b08309e62">
        <source>updateActivityHistory(_agent : CM_KiwiRailCheckInWSAgent ;_response : CMIF_KRFCheckInResponse);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Mar 2019	jlgsl4	TFS 40360 - NXL - KiwiRail EDI message

*/

vars
	responseStatus : String;
	pxyActivityHistory : CM_ActivityHistoryExtInterface;
begin
	if _agent = null then
		return;
	endif;
	if _agent.myLastActivityHistory &lt;&gt; null then
		beginLoad;
			pxyActivityHistory :=_agent.myLastActivityHistory.pxyCreateUpdateProxy().CM_ActivityHistoryExtInterface;
		endLoad;
		if _response = null then
			responseStatus := "Null response";
		else
			responseStatus := _response.status;
		endif;
		pxyActivityHistory.setDescription("KiwiRail CheckIn webservice " &amp; responseStatus);
		pxyActivityHistory.setSuccess(responseStatus = "SUCCESS");
		app.myTrxUA.trxUpdateActivityHistory(pxyActivityHistory, app.myPassport);
		if app.myPassport.hasErrors then
			app.writeLog(method.qualifiedName &amp; 
				"	**KiwiRail**Update Activity History - ERRORS :	"  &amp; app.myPassport.getErrorsAndWarningsAsString ,LogINFO);
		endif;
	endif;
epilog
	delete pxyActivityHistory;
end;</source>
        <Parameter name="_agent" type="CM_KiwiRailCheckInWSAgent"/>
        <Parameter name="_response" type="CMIF_KRFCheckInResponse"/>
    </JadeMethod>
</Class>
