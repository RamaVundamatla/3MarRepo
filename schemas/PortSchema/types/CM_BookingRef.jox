    <JadeMethod name="getReleasedCount" id="718906f6-a129-4f5d-9fea-328085b0538b">
        <source>getReleasedCount():Integer;
/*
Date		Who		Reason
27 November 2009	cnwndl1	Initial creation	CCMS 1028

*/
vars
	release	: CM_BulkRelease;
	count 	: Integer;
begin
	foreach release in self.allReleaseRequests do
		count := count + release.allTrackedItemsReleased.size;
	endforeach;
	
	return count;
epilog

end;</source>
