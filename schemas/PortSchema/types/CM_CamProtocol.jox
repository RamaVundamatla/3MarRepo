vars

begin

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="2c1d64b2-fd48-4346-936d-14ae4aafa71f">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     11 September 2002 by cnwdf1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.validateMe();
end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="00a86660-224e-4e18-8511-45f40a8ff389">
        <source>validateMe();
// ---------------------------------------------------------------------------
// Created:     11 September 2002 by cnwdf1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 02/04/2009	cnwrl1		CCMS 1819 - EDI messaging needs the ability to send CAMS for operators that slot share
// 08/03/2010	cnwrl1		PAR 22836 - File Prefix must now be unique within all Protocols.
// 08/03/2010	cnwrl1		PAR 22835 - Make sure the resulting generated CAMS Task History file name will not get too long.
// 08/03/2010	cnwrl1		PAR 22821 - Make sure a JRW Design Name is selected when appropriate
// 25/05/2010	cnwdad1		PAR 21547 - Additional validation to prevent conflicting options being set.
// 18/05/2011	cnwcs5		CCMS SCT 2058 / par 27460 - user defined special characters
// 01/07/2013	cnwcs5		par 31819 - do not allow "send files with no message" for user defined JRW files
// 11 Jun 2014	cnwrs1	Par 34159 - include Chassis in Codeco
//18 Dec 2014	cnwrs1	Par 35419 - add additional data
// ---------------------------------------------------------------------------
vars
	today		: Date;
	tempStr		: String;							// cnwrl1 08/03/2010 PAR 22835
	fileLength	: Integer;							// cnwrl1 08/03/2010 PAR 22835
	maxLength	: Integer;							// cnwrl1 08/03/2010 PAR 22835
	characters	: String;							// par 27460 cnwcs5
	trxColl		: StringArray;
	cargoTypeColl : IntegerArray;
begin
	trxColl 	:= self.registeredTransactions;			// cnwcs5 July 2013 - small optimization
	cargoTypeColl := self.allRegisteredCargoTypes;
	if self.code = null then
		app.raiseCMException(Input_required_field_code, null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.camGroup = null then
		app.raiseCMException(Input_required_field_camGroup, null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.protocolDesc = null then
		app.raiseCMException(Input_required_field_protDesc, null, null); // cnwdb2	PAR 35364
	else
		if (not app.myRoot.canDoEDIFileType(self.protocolDesc.type)) then
			app.raiseCMException1(NotLicensedToPerformAction, 'Use CAM Protocol Description ' &amp; self.protocolDesc.name, null, null);
			return;	
		endif;
	endif;

	if self.isEmailEnabled and self.myEmailEntity = null then
		app.raiseCMException(Input_required_field_emlAddres, null, null); // cnwdb2	PAR 35364

	endif;
	
	if self.lastRunDateTime = null or (not self.lastRunDateTime.isValid) then
		//this date at least must be valid
		app.raiseCMException1(ERR_INVALID_TIMESTAMP, 'last run', 'lastRunDate/Time', null);
	endif;
	
	if self.firstRunDateTime &gt; self.lastRunDateTime then
		app.raiseCMWarning(Last_date_time_older_than_firs, 'next due date', null, self);
	endif;
	
	if self.firstRunDateTime = null or not self.firstRunDateTime.isValid() then
		//this date at least must be valid
		app.raiseCMException1(ERR_INVALID_TIMESTAMP, 'first run', 'firstRunDate/Time', null);
		
	elseif self.firstRunDateTime.date.year &lt; (today.year - 2) and not self.lastRunDTIsValid() then
		app.raiseCMWarning(Cams_will_start_proce_data_thi, 'next due date', null, self);
	endif;
	
	if not self.emailFileImbedded and not self.specialFileName and self.fileSuffix = null then
		app.raiseCMException(Input_required_field_fleType, null, null); // cnwdb2	PAR 35364
	endif;
	
	// cnwrl1 02/04/2009 CCMS 1819 - start of coding
	// The user must select at least one of "Use Voyage Operator" and "Use Container operator" options.
	if not self.useTiOperator and not self.useVoyageOperator then
		app.raiseCMException1(Must_Select_At_Least, app.getErrorString(Use_Voyage_Container_Operator), null, null);
	endif;
	
	// File Prefix must now be unique within all Protocols.
	self.checkForDuplicateFilePrefix;		// cnwrl1 08/03/2010 PAR 22836
	
	// cnwrl1 08/03/2010 PAR 22835 - start of coding
	// Make sure the resulting generated CAMS Task History file name will not get too long.
	// There is an assumption here that fileName and transferFileName have the same length!
	maxLength	:= CM_CamTaskHistory::fileName.getLengthForString;

	// make sure allow for the file period as well as the rest.
	fileLength	:= self.filePrefix.length + self.fileSuffix.length + self.transferFileSeqLength + 1;
	
	if fileLength &gt; maxLength then
		tempStr	:= "File Prefix length + File Type length + Transfer File Sequence Length + 1";
		app.raiseCMException3(Generated_CamsTaskHistory, tempStr, fileLength.display, maxLength.display, null, null);
	endif;
	
	if self.isUserDefinedReport or self.isUserDefinedEventReport then	// PAR 21905 CCMS MES 1008 - PHB
		
		// cnwrl1 08/03/2010 PAR 22821 - start of coding
		if self.jrwReportName = null then
			app.raiseCMException1(Input_required_field_Required, app.getString(JRW_Design_Name), null, null); // cnwdb2	PAR 35364
		endif;
		
		//ccms 1011
		if self.isFileTransferEnabled then
			if self.destinationFilePath = null then
				app.raiseCMException(Input_required_field_destFile, null, null); // cnwdb2	PAR 35364
			endif;
			
			if self.destinationFilePath.toUpper = app.cnConvertPathNameToFwdSlashes(self.terminal.getConfig_FileDirectory(CamsFileDirectory).String.toUpper) then
				app.raiseCMException1(Desti_file_path_canno_same_def, self.destinationFilePath, null, null);
			endif;
						
			if self.fileSuffix = null then
				app.raiseCMException(Input_required_field_fileTypes, null, null); // cnwdb2	PAR 35364
			endif;
			
		endif;

		if self.isUserDefinedEventReport then	// PAR 21905 CCMS MES 1008 - PHB
			if self.allTrainEventTypes.isEmpty() then
				app.raiseCMException(Input_required_field_slctEvnts, null, null); // cnwdb2	PAR 35364
			endif;					
		else
			if self.myQFCamTransactionTemplate =  null then		// actually, default query filter tranaction template should be setup before. PAR 20994 Oct 2009
				app.raiseCMException(Input_required_field_trnsFltr, null, null); // cnwdb2	PAR 35364	// this message for future development
			endif;
			
		endif;
		
		if self.sendMtFiles then
			// cannot set this option - GUI should take care of it
			app.raiseUnexpectedProgramError (self.class.name, method.name, "Send Files With No Message cannot be set for user defined JRW protocols");
		endif;
	endif;
	
	//epr TFS 2395 these are only valid for user defined reports 20/7/16
	if trxColl.includes(global.getTiTxnTypeForClass(CM_Edit).asStringJMT()) and 
		self.allEditTriggerFields.isEmpty() and 
		not self.anyEditTriggerField then
		app.raiseCMException(Edite_selec_trans_requi_selec_, null, null);
	endif;
	
	
	// par 27460 validate special characters that have been entered
	if self.isCoarri or self.isCodeco then
		if self.decimalCharacter &lt;&gt; Period and self.decimalCharacter &lt;&gt; Comma then
			// decimal character can only be "." or ","
			app.raiseCMException (XLAT_Invalid_DecimalCharacter, null, null);
		endif;
		
		if self.SpecialCharacters.pos (self.elementSeparator, 1) = 0 then
			// element seperator not valid
			app.raiseCMException2 (XLAT_Valid_Values, app.getErrorString(XLAT_Element_Seperator), 
									CM_CamProtocol.SpecialCharacters, null, null);
		endif;
		
		if self.SpecialCharacters.pos (self.escapeCharacter, 1) = 0 then
			// element seperator not valid
			app.raiseCMException2 (XLAT_Valid_Values, app.getErrorString(XLAT_Escape_Character), 
									CM_CamProtocol.SpecialCharacters, null, null);			
		endif;
		
		if self.SpecialCharacters.pos (self.segmentTerminator, 1) = 0 then
			// element seperator not valid
			app.raiseCMException2 (XLAT_Valid_Values, app.getErrorString(XLAT_Segment_Terminator), 
									CM_CamProtocol.SpecialCharacters, null, null);						
		endif;

		if self.SpecialCharacters.pos (self.subElementSeparator, 1) = 0 then
			// element seperator not valid
			app.raiseCMException2 (XLAT_Valid_Values, app.getErrorString(XLAT_SubElement_Seperator), 
									CM_CamProtocol.SpecialCharacters, null, null);			
		endif;
		// now work out if any special character is used more than once
		characters := self.decimalCharacter;
		
		if characters.pos (self.elementSeparator, 1) &lt;&gt; 0 then
			// elementSperator already used
			app.raiseCMException2 (XLAT_Value_Used, app.getErrorString (XLAT_Element_Seperator),
									self.elementSeparator, null, null);
		endif;
		
		characters := characters &amp; self.elementSeparator;
		
		if characters.pos (self.escapeCharacter, 1) &lt;&gt; 0 then
			app.raiseCMException2 (XLAT_Value_Used, app.getErrorString (XLAT_Escape_Character),
									self.escapeCharacter, null, null);
			// escape character already used
		endif;
		
		characters := characters &amp; self.escapeCharacter;
		
		if characters.pos (self.segmentTerminator, 1) &lt;&gt; 0 then
			// segment terminator already used
			app.raiseCMException2 (XLAT_Value_Used, app.getErrorString (XLAT_Segment_Terminator),
									self.segmentTerminator, null, null);
		endif;
		
		characters := characters &amp; self.segmentTerminator;
		
		if characters.pos (self.subElementSeparator, 1) &lt;&gt; 0 then
			// sub element terminator already used
			app.raiseCMException2 (XLAT_Value_Used, app.getErrorString (XLAT_SubElement_Seperator),
									self.subElementSeparator, null, null);
		endif;
	endif;
	
// cnwdad1 31/08/2009 - CCMS 1875.
	if self.useSubTerminals then	

		if	trxColl.includes(global.getTiTxnTypeForClass(CM_SubTermReceiveDepotIntern).asStringJMT) or		
			trxColl.includes(global.getTiTxnTypeForClass(CM_SubTermReceiveDepotRail).asStringJMT) or			
			trxColl.includes(global.getTiTxnTypeForClass(CM_SubTermReceiveDepotRoad).asStringJMT) or			
			trxColl.includes(global.getTiTxnTypeForClass(CM_SubTermReceiveDepotShip).asStringJMT) or			
			trxColl.includes(global.getTiTxnTypeForClass(CM_SubTermReceiveMarineIntern).asStringJMT) or		
			trxColl.includes(global.getTiTxnTypeForClass(CM_SubTermReceiveMarineRail).asStringJMT) or		
			trxColl.includes(global.getTiTxnTypeForClass(CM_SubTermReceiveMarineRoad).asStringJMT) or		
			trxColl.includes(global.getTiTxnTypeForClass(CM_SubTermReceiveMarineShip).asStringJMT) or		
			trxColl.includes(global.getTiTxnTypeForClass(CM_SubTermReceiveWHouseIntern).asStringJMT) or		
			trxColl.includes(global.getTiTxnTypeForClass(CM_SubTermReceiveWHouseRail).asStringJMT) or		
			trxColl.includes(global.getTiTxnTypeForClass(CM_SubTermReceiveWHouseRoad).asStringJMT) or		
			trxColl.includes(global.getTiTxnTypeForClass(CM_SubTermReceiveWHouseShip).asStringJMT) or		
			trxColl.includes(global.getTiTxnTypeForClass(CM_SubTermReleaseDepotIntern).asStringJMT) or		
			trxColl.includes(global.getTiTxnTypeForClass(CM_SubTermReleaseDepotRail).asStringJMT) or			
			trxColl.includes(global.getTiTxnTypeForClass(CM_SubTermReleaseDepotRoad).asStringJMT) or			
			trxColl.includes(global.getTiTxnTypeForClass(CM_SubTermReleaseDepotShip).asStringJMT) or			
			trxColl.includes(global.getTiTxnTypeForClass(CM_SubTermReleaseMarineIntern).asStringJMT) or		
			trxColl.includes(global.getTiTxnTypeForClass(CM_SubTermReleaseMarineRail).asStringJMT) or		
			trxColl.includes(global.getTiTxnTypeForClass(CM_SubTermReleaseMarineRoad).asStringJMT) or		
			trxColl.includes(global.getTiTxnTypeForClass(CM_SubTermReleaseMarineShip).asStringJMT) or		
			trxColl.includes(global.getTiTxnTypeForClass(CM_SubTermReleaseWHouseIntern).asStringJMT) or		
			trxColl.includes(global.getTiTxnTypeForClass(CM_SubTermReleaseWHouseRail).asStringJMT) or		
			trxColl.includes(global.getTiTxnTypeForClass(CM_SubTermReleaseWHouseRoad).asStringJMT) or		
			trxColl.includes(global.getTiTxnTypeForClass(CM_SubTermReleaseWHouseShip).asStringJMT) or		
			trxColl.includes(global.getTiTxnTypeForClass(CM_SubTerminalReceiveDepot).asStringJMT) or			
			trxColl.includes(global.getTiTxnTypeForClass(CM_SubTerminalReceiveMarine).asStringJMT) or		
			trxColl.includes(global.getTiTxnTypeForClass(CM_SubTerminalReceiveWHouse).asStringJMT) or		
			trxColl.includes(global.getTiTxnTypeForClass(CM_SubTerminalReleaseDepot).asStringJMT) or			
			trxColl.includes(global.getTiTxnTypeForClass(CM_SubTerminalReleaseMarine).asStringJMT) or		
			trxColl.includes(global.getTiTxnTypeForClass(CM_SubTerminalReleaseWHouse).asStringJMT) then
		else
			app.raiseCMWarning(CAMS_SubTerm_Options_Warn, null, null, null);
		endif;
		
	endif;
	
	if trxColl.isEmpty() and
	   self.allTrainEventTypes.isEmpty() and
	   not self.isUserDefinedEventReport then		// PAR 21905 CCMS MES 1008 - PHB - will be empty if	isUserDefinedEventReport
		app.raiseCMWarning(Selecte_transat_list_empty, 'Selected Transactions', null, self);
	endif;
	
	if (trxColl.includes(global.getTiTxnTypeForClass(CM_Pack).asStringJMT) and 
	    trxColl.includes(global.getTiTxnTypeForClass(CM_PackComplete).asStringJMT))
	or (trxColl.includes(global.getTiTxnTypeForClass(CM_Unpack).asStringJMT) and
	    trxColl.includes(global.getTiTxnTypeForClass(CM_UnpackComplete).asStringJMT)) then
// cnwdad1 25/05/2010 - PAR #21547 - The "list is empty" message didn't seem to make any sense here.
		app.raiseCMWarning(CAMS_Pack_or_Unpack_Multi_Msgs, null, null, self);
	endif;
	
// cnwdad1 25/05/2010 - PAR #21547.
	if self.allPackAreas.cnEcIsNotEmpty() and 
		(not trxColl.includes(global.getTiTxnTypeForClass(CM_Move).asStringJMT())) and 
		(not trxColl.includes(global.getTiTxnTypeForClass(CM_Pickup).asStringJMT())) and 
		(not trxColl.includes(global.getTiTxnTypeForClass(CM_SetDown).asStringJMT())) and 
		(not trxColl.includes(global.getTiTxnTypeForClass(CM_Pack).asStringJMT())) and 
		(not trxColl.includes(global.getTiTxnTypeForClass(CM_PackComplete).asStringJMT())) and 
		(not trxColl.includes(global.getTiTxnTypeForClass(CM_Unpack).asStringJMT())) and 
		(not trxColl.includes(global.getTiTxnTypeForClass(CM_UnpackComplete).asStringJMT())) then
		app.raiseCMWarning(CAMS_No_Msgs_If_No_Move_Trans, null, null, null);
	endif;
	
// cnwdad1 25/05/2010 - PAR #21547.
	if self.packGateInFull or self.packGateOutMT or self.unpackGateInMT or self.unpackGateOutFull then
		if (not trxColl.includes(global.getTiTxnTypeForClass(CM_Pack).asStringJMT())) and 
			(not trxColl.includes(global.getTiTxnTypeForClass(CM_PackComplete).asStringJMT())) and 
			(not trxColl.includes(global.getTiTxnTypeForClass(CM_Unpack).asStringJMT())) and 
			(not trxColl.includes(global.getTiTxnTypeForClass(CM_UnpackComplete).asStringJMT())) then
			app.raiseCMWarning(CAMS_No_PackUnpack_Trans, null, null, null);
		endif;
	endif;
	
	if cargoTypeColl.isEmpty() and self.requiresCargoType then //21.11.2014 cnwgb1 PAR 35255 CCMS ABS 2405 
		app.raiseCMWarning(Selecte_cargo_types_empty, 'Selected Cargo Types', null, self);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateMoveTransCrits" id="56dab7e9-ff65-4d88-85bd-a930cf1b2df5">
        <source>validateMoveTransCrits(_newTrnsCrit : CM_CamsMoveTATypeCritieria): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2024	navcs2	ChangeRequest 60397: EUP | FR 54085 - Load Confirmation / Goods Receipt - Multiple Move transaction criteria, Event Only Trigger

*/

vars
	trnsCrit	: CM_CamsMoveTATypeCritieria;
begin	
	foreach trnsCrit in self.allMoveTrxCriteria do
		if _newTrnsCrit.toTAType = trnsCrit.notToTAType or trnsCrit.toTAType = _newTrnsCrit.notToTAType then
			return false;
		endif;
	endforeach;
	
	return true;
epilog

end;</source>
        <Parameter name="_newTrnsCrit" type="CM_CamsMoveTATypeCritieria"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="xHandlerFile" id="174e214a-20dc-43b7-85a2-2fede68ccb70">
        <source>xHandlerFile(_exceptionObj:FileException; _isFailed:Boolean io; _errorInfo:String io):Integer protected;
// --------------------------------------------------------------------------------
// Created:		27 August 2010 by cnwdad1
//
// Purpose:		This File Exception handler is implemeneted specifically to deal with
//				situations where, when creating a CAMS file directory, the location
//				is not available, such as where the location is on a network drive.
//
// Parameters:	_exceptionObj - A reference to the File Exception object.
//				_isFailed - A boolean flag that is returned to indicate there was an error.
//				_errorInfo - The details of the file error.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	details		: String;
	errorMsg	: String;
	causedBy	: String;
	nodeObj		: FileNode;
	
begin
	_isFailed	:=	true;
	errorMsg	:=	process.getErrorText(_exceptionObj.errorCode);
	causedBy	:=	_exceptionObj.errorItem;
	nodeObj		:=	_exceptionObj.fileNode;
	
	details	:=	"'" &amp; nodeObj.fileName &amp; "' caused error " &amp; _exceptionObj.errorCode.String &amp; " (" &amp; errorMsg &amp; ")";
	
	if causedBy = null then
		details	:=	details &amp; ", the cause could not be identified.";
	else
		details	:=	details &amp; ", which was caused by '" &amp; causedBy &amp; "'.";
	endif;
	
	_errorInfo	:=	details;
	
	return Ex_Resume_Next;
end;</source>
        <access>protected</access>
        <Parameter name="_exceptionObj" type="FileException"/>
        <Parameter name="_isFailed" type="Boolean" usage="io"/>
        <Parameter name="_errorInfo" type="String" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
