    <JadeMethod name="showSelectorForm" id="a1a7eefe-90bd-4b70-92bc-4410d7b79283">
        <updating/>
        <source>showSelectorForm() updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

	theSelector				: CMUI_Selector;
	cargoType				: CM_CargoType;
	
begin
	
	theSelector := app.getSelectorForm(self, self.myMasterMenuAction);
	if theSelector = null then
		return;
	endif;
	
	self.setSelector(theSelector);//this will set the default mode
	theSelector.show;

end;</source>
