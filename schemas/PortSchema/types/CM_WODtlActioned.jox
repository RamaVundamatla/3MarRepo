    <JadeMethod name="setMyWODtl" id="5b279080-9892-4a13-a837-03ee13171dc2">
        <updating/>
        <source>setMyWODtl( _woTIDtl : CM_WorkOrderTIDtl) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 June 2010	cnwrd1	Initial creation

*/

vars

begin
	self.myWorkOrderDtl := _woTIDtl;
epilog

end;</source>
        <Parameter name="_woTIDtl" type="CM_WorkOrderTIDtl"/>
    </JadeMethod>
    <JadeMethod name="setValues" id="45bd6428-c079-494b-9eeb-960f2843a0a2">
        <updating/>
        <source>setValues( _numItems : Integer; _schedule : CM_WorkOrderSchedule ; _requestBT : CM_WorkOrderRequestByType; _numFromRBT : Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 June 2010	cnwrd1	Initial creation

*/

vars

begin

	self.numberItems := _numItems;
	self.myWorkOrderSchedule := _schedule;
	self.myWORequestBT := _requestBT;
	self.numberFromRequest := _numFromRBT;
	
epilog

end;</source>
        <Parameter name="_numItems" type="Integer"/>
        <Parameter name="_schedule" type="CM_WorkOrderSchedule"/>
        <Parameter name="_requestBT" type="CM_WorkOrderRequestByType"/>
        <Parameter name="_numFromRBT" type="Integer"/>
    </JadeMethod>
</Class>
