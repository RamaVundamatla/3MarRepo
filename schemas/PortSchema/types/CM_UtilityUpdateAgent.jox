	endif;
	
	if realWO.allWoDtls.isNotEmpty() then
		if realWO.allWoDtls.first.CM_WodRelease.myReleaseRequest &lt;&gt; null and 
		   realWO.allWoDtls.first.CM_WodRelease.myReleaseRequest.allTrackedItemsReleased.isEmpty() and 
		   realWO.allWoDtls.first.CM_WodRelease.allJobs.isEmpty() then
				realWO.allWoDtls.first.CM_WodRelease.setTransportMode(app.transportModeStringToENum(_transport));
		endif;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realWO, false);
	endif;
epilog

end;</source>
        <Parameter name="_pxyworkOrder" type="CM_WorkOrder"/>
        <Parameter name="_oldTransport" type="String"/>
        <Parameter name="_transport" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTransactionCharge" id="d25a2dca-70b5-4444-81ad-10385ffdcc2d">
        <updating/>
        <source>utlUpdateTransactionCharge(_transactions : CM_TransactionSet; _set : Boolean; _passport : CM_Passport input) updating;
// Feb 2012 CCMS 1262 Transaction Enquiry set/reset the noCharge attribute on cargo, event and HMS transactions
vars
	txn		: CM_Transaction;
begin

	self.initialiseActivity();
	//no validation required 
	app.setContinueCMExceptions(false);

	foreach txn in _transactions do
		if txn.isKindOf(CM_TITransaction) then
			txn.CM_TITransaction.setNoCharge(not _set);
		elseif txn.isKindOf(CM_EventTransaction) then
			txn.CM_EventTransaction.setNoCharge(not _set);
		elseif txn.isKindOf(HMS_VTMISTransaction)  then
			txn.HMS_VTMISTransaction.setNoCharge(not _set);
		elseif txn.isKindOf(CM_WOTransaction)  then // TFS 42161
			txn.CM_WOTransaction.setNoCharge(not _set); // TFS 42161
		endif;
	endforeach;
	
end;</source>
        <Parameter name="_transactions" type="CM_TransactionSet"/>
        <Parameter name="_set" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTransactionMapCSV" id="06c3c540-7d62-4049-9d49-a14b3955a4bf">
        <source>utlUpdateTransactionMapCSV(_allFileRows:ObjectArray; _passportObj:CM_Passport input);
// --------------------------------------------------------------------------------
// Created:		April 2010 by cnwjre1
//
// Purpose:		Updates multiple invoice transaction map that have been read from a CSV file
//				(in the same format as the Rate Table extract).
//
// Parameters:	_allFileRows - An object array of file rows (each one being a HugeStringArray).
//				_passportObj - A reference to the current user's Passport object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	object				: Object;
	allRowFields		: HugeStringArray;
	bankObj				: CM_Bank;
	rootDebtorObj		: CM_DebtorNode;
	debtorObj			: CM_DebtorNode;
	serviceObj			: CM_Service;
	debtorRateObj		: CM_DebtorRate;
	rateEntryObj		: CM_RateEntry;
	proxyEntryObj		: CM_RateEntry;
	currentRateObj		: CM_RateEntry;
	effectiveTS			: TimeStamp;
	costPerUnitLabels	: StringArray;
	cpuPointer			: Integer;
	userObj				: CM_User;
	userCode			: String;
	createCount			: Integer;
	updateCount			: Integer;
	
	// The following are the file field values.
	
	rowType				: String;
	debtorName			: String;
	debtorCode			: String;
	override			: String;
	serviceName			: String;
	effectiveDate		: Date;
	effectiveTime		: Time;
	cpuName				: String;
	tempName			: String;
	costPerUnit			: Real;
	glCode				: String;
	rowNum				: String;
	adjustToBase		: Real;
	percentOfBase		: Real;
	adjustToBaseDecimal	: Decimal [12,6];
	percentOfBaseDecimal: Decimal [8,4];
	parentRateEntryObj	: CM_RateEntry;
	rootDebtorGroup : CM_RootDebtorGroup;
	
begin
	
	// 17/10/2012 cnwmh5 #30459 - no longer used
	/*
	
	self.initialiseActivity();
	
	createCount		:=	0;
	updateCount		:=	0;
	userObj			:=	app.getMyUser();
	userCode		:=	userObj.code;
	bankObj			:=	app.theCurrentBank;
	rootDebtorObj	:=	bankObj.rootDebtorGroup;
	create costPerUnitLabels transient;
	
	foreach object in _allFileRows do
		allRowFields	:=	object.HugeStringArray;
		
		// Get the field values.
		
		rowType			:=	allRowFields[1];
		debtorName		:=	allRowFields[2];
		debtorCode		:=	allRowFields[3];
		override		:=	allRowFields[4];
		serviceName		:=	allRowFields[5];
		effectiveDate	:=	allRowFields[6].Date;
		effectiveTime	:=	allRowFields[7].Time;
		effectiveTime.setTime(effectiveTime.hour, effectiveTime.minute, effectiveTime.second, 999);
		cpuName			:=	allRowFields[8]; // this is allowed to be null, multi line rates (there are 2 HMS invoice rates that allow 2 or more rates, a populated cpuName = multiline rate)
		costPerUnit		:=	allRowFields[9].Real;		// *** Leave as a cast - no English users will be importing their own formatted data ***
		glCode			:=	allRowFields[10];
		rowNum			:=	allRowFields[11];
		
		//18 Sep 2012	NDL	Par 30375
		if allRowFields.size &gt;= 13 then
			adjustToBase	:=	allRowFields[12].Real;
			percentOfBase	:=	allRowFields[13].Real;
			adjustToBaseDecimal	:= adjustToBase.Decimal;
			percentOfBaseDecimal := percentOfBase.Decimal;
		endif;
		
		effectiveTS.setDate(effectiveDate);
		effectiveTS.setTime(effectiveTime);
		
		// Now process the data.
		
		if costPerUnit &gt; 999999.999999 then
			app.raiseCMException1(	Cost_Per_Unit_Too_Large,
									rowNum,
									null,
									null);
		endif;
		
		// Get the Debtor and Service.
		
		debtorObj	:=	rootDebtorObj.allChildDebtorNodes[debtorName];
		
		if debtorObj = null then
			debtorObj	:=	app.myRoot.myRootCompany.debtorNodes[debtorName];
		endif;
		
		if debtorObj = null then
			app.raiseCMException2(	Debtor_Not_Found,
									debtorName,
									rowNum,
									null,
									null);
			return;
		endif;
		
		if rootDebtorGroup = null then
			rootDebtorGroup := debtorObj.bank.getRootDebtorGroup;
		endif;
		
		serviceObj		:=	bankObj.services[serviceName];
		
		if serviceObj = null then
			app.raiseCMException2(	Service_Not_Found,
									serviceName,
									rowNum,
									null,
									null);
			return;
		endif;
		
		// Now check whether the rate has to be changed.  If not, do nothing.
		
		currentRateObj	:=	null;
		currentRateObj	:=	debtorObj.getServiceTimeRate(serviceObj, effectiveTS);
//if currentRateObj &lt;&gt; null then
//currentRateObj.inspectModal();
//endif;
		
// If the default is not found, then the defaule rate is deemed to be zero,
// so we should create a new rate.
//		if currentRateObj = null then
//			app.raiseCMException3(	Default_Rate_Not_Found,
//									serviceName,
//									effectiveTS.asStringJMT(),
//									rowNum,
//									null,
//									null);
//			return;
//		endif;
		
		costPerUnitLabels.clear();
		cpuPointer	:=	0;
		
		if currentRateObj &lt;&gt; null then
			if cpuName = null then
				if currentRateObj.getRawCostPerUnit = costPerUnit then
					continue;
				endif;
			else
				// This is one line of a multi-line Rate Table, so find out which line to update
				// based upon the line's Cost Per Unit label.
				currentRateObj.getCostPerUnitLabels(costPerUnitLabels);
				
				if costPerUnitLabels.size() = 1 and currentRateObj.allCostPerUnits.isEmpty() then
					if currentRateObj.getRawCostPerUnit = costPerUnit then
						continue;
					endif;
				else
					cpuPointer	:=	costPerUnitLabels.indexOf(cpuName);
					
					if cpuPointer = 0 then
						app.raiseCMException4(	Cost_Per_Unit_Label_Not_Found,
												cpuName,
												debtorName,
												serviceName,
												rowNum,
												null,
												null);
						return;
						
					elseif currentRateObj.allCostPerUnits.size() &lt; cpuPointer then
						app.raiseCMException4(	Cost_Per_Unit_Not_Found,
												cpuName,
												debtorName,
												serviceName,
												rowNum,
												null,
												null);
						return;
					endif;
					
					if currentRateObj.allCostPerUnits[cpuPointer] = costPerUnit then
						continue;
					endif;
				endif;
			endif;
		else
			app.writeStatement("Current Rate Entry for " &amp; debtorName &amp; "/" &amp; serviceName &amp; " of '" &amp; costPerUnit.numberFormat() &amp; ".");
		endif;
		
		// Now change the rate by updating an existing one, or create a new one.
		
		debtorRateObj	:=	serviceObj.debtorNodeRates[debtorObj];
		
		//18 Sep 2012	NDL	Par 30375
		if ( adjustToBaseDecimal &lt;&gt; 0 or percentOfBaseDecimal &lt;&gt; 0 ) and debtorObj &lt;&gt; rootDebtorGroup then
			parentRateEntryObj := rootDebtorGroup.getServiceTimeRate( serviceObj, effectiveTS );
		else
			parentRateEntryObj := null;
		endif;
		
		if debtorRateObj = null then
			create debtorRateObj transient;
			debtorRateObj.setProxy(serviceObj, debtorObj);
		else
			// PAR 18650 rateEntryObj	:=	debtorRateObj.rateEntries[effectiveTS]; 
			rateEntryObj := currentRateObj; // PAR 18650 
		endif;
		
		if rateEntryObj = null then
			create proxyEntryObj transient;
			
			proxyEntryObj.setProxyFromCSV(cpuPointer, costPerUnit, debtorRateObj, userCode, effectiveTS, null, adjustToBaseDecimal, percentOfBaseDecimal,  parentRateEntryObj);
			
			costPerUnitLabels.clear();
			proxyEntryObj.getCostPerUnitLabels(costPerUnitLabels);
			
			// PAR 22074 WAS if costPerUnitLabels.size() &gt; 0 then
			// PAR 22074 NOW from here 
			if costPerUnitLabels.size() = 1 then // PAR 22074 // ordinary single line rate
				cpuPointer := 1;
				proxyEntryObj.allCostPerUnits[1]	:=	costPerUnit;// PAR 22074 // ordinary single line rate
			
			elseif costPerUnitLabels.size() &gt; 1 then
			// PAR 22074 NOW to here 
				cpuPointer	:=	0;
				
				foreach tempName in costPerUnitLabels do
					cpuPointer	:=	cpuPointer + 1;
					
					if tempName = cpuName then
						proxyEntryObj.allCostPerUnits[cpuPointer]	:=	costPerUnit;
					else
						proxyEntryObj.allCostPerUnits[cpuPointer]	:=	0;
					endif;
				endforeach;
			endif;
			
			app.myUtilityCA.utlCreateRateEntry(proxyEntryObj, rateEntryObj, _passportObj);
			createCount	:=	createCount + 1;
			app.writeStatement("Created Rate Entry for " &amp; debtorName &amp; "/" &amp; serviceName &amp; " of '" &amp; costPerUnit.numberFormat() &amp; ".");
		else
			if costPerUnit &lt;&gt; rateEntryObj.getRawCostPerUnit then
				proxyEntryObj	:=	app.createUpdateProxy(rateEntryObj).CM_RateEntry;
				proxyEntryObj.setProxyFromCSV(cpuPointer, costPerUnit, debtorRateObj, userCode, effectiveTS, null, adjustToBaseDecimal, percentOfBaseDecimal,  parentRateEntryObj);
				self.utlUpdateRateEntry(proxyEntryObj, _passportObj);
				updateCount	:=	updateCount + 1;
				app.writeStatement("Updated Rate Entry for " &amp; debtorName &amp; "/" &amp; serviceName &amp; " of '" &amp; costPerUnit.numberFormat() &amp; ".");
			endif;
		endif;
		
		delete proxyEntryObj;		// We always need to delete this (does nothing if hasn't been created).
		
		if debtorRateObj.isTransient() then
			delete debtorRateObj;	// If we created this, then we need to delete it now.
		endif;
		
		rateEntryObj	:=	null;	// Need to reset this otherwise the next loop may try to update it.
	endforeach;
epilog
	delete proxyEntryObj;
	delete costPerUnitLabels;
	
	app.writeStatement("Created " &amp; createCount.cnEcNumberFormat() &amp; " Rate Tables.");
	app.writeStatement("Updated " &amp; updateCount.cnEcNumberFormat() &amp; " Rate Tables.");
	*/
end;</source>
        <Parameter name="_allFileRows" type="ObjectArray"/>
        <Parameter name="_passportObj" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTruckSeal" id="30834dce-a66c-4e55-85f3-d8b840d79431">
        <updating/>
        <source>utlUpdateTruckSeal(_pxySeal : CM_TruckSeal input; _realSeal : CM_TruckSeal io; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
06 April 2023		jlizm1	Initial creation TFS 57098 EUP Seal numbers on trucks
20 Feb 2024 navhl20 ChangeRequest 62525: EUP | Retrospective Operations - [54177.060] - Cargo &amp; Truck Checks
*/

vars
	newTruckSeal 	: CM_TruckSeal;
	vvr 			: CM_VehicleVisitRecord;
	
begin
	
	self.initialiseActivity();

	self.raiseExceptionIfNull(_pxySeal, 'Truck Seal');
	
	app.myValUA.valTruckSeal( _pxySeal );
	
	if _realSeal &lt;&gt; null then
		vvr := _realSeal.myVehicleVisit;
		
		exclusiveLock(_realSeal);
		
		if _passport.noErrors then
			vvr.createVisitRecordDetail(VisitRecord_SealDelete, _realSeal, _pxySeal);				//20.02.2024 navhl20 #62525
		endif;
		
		_realSeal.setForUpdate(_pxySeal);
		
		if _passport.noErrors then
			if _realSeal.getSealValueAsString.trimBlanks = null and _realSeal.previousSeal.trimBlanks = null then
				//Seal has been removed, and replaced with nothing, really delete it.
				delete _realSeal;
			else
				// seal has been replaced with this one
				vvr.createVisitRecordDetail(VisitRecord_SealAdd, _realSeal, null);
			endif;
		endif;
	
	else
		vvr := _pxySeal.myVehicleVisit;
		
		create newTruckSeal persistent;
		newTruckSeal.setForCreate(_pxySeal);
		newTruckSeal.setMyVehicleVisit(_pxySeal.myVehicleVisit);
		
		_realSeal := newTruckSeal;
		
		if _passport.noErrors and vvr &lt;&gt; null then
			vvr.createVisitRecordDetail(VisitRecord_SealAdd, newTruckSeal, null);
		endif;
	
	endif;
	
epilog

end;</source>
        <Parameter name="_pxySeal" type="CM_TruckSeal" usage="input"/>
        <Parameter name="_realSeal" type="CM_TruckSeal" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTug" id="93bd295f-b299-4f12-822f-83da0b0b0b41">
        <updating/>
        <source>utlUpdateTug( _pxyTug	:	HMS_Tug;
			  _passport	:	CM_Passport input ) updating;
//--------------------------------------------------------
//
// Created by: cnwsh3 
//
// Date: 14 July 2003
//
//----------------------------------------------------------

vars
	realTug			:	HMS_Tug;
	expectedEdition	:	Integer;
	
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	_pxyTug.raiseExceptionIfNotProxy(method);
	_pxyTug.validateMe( _passport );
	
	if not self.checkValidationWithPassport( _passport ) then
		return;
	endif;
	
	app.setContinueCMExceptions( false );
	_pxyTug.pxyGetRealObjectAndEdition( realTug, expectedEdition );
	app.setContinueCMExceptions( true );
	
	if realTug = null then
		app.raiseCMException1( ObjectUpdatedByAnotherUserSave, 
							   'Tug' ,
							   null,
							   null );
		return;
	endif;
	
	exclusiveLock(realTug);
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric( realTug, true );
	endif;
	
	if _passport.noErrors then
		realTug.setForUpdate( _pxyTug, _passport );
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric( realTug, false);
	endif;

epilog


end;</source>
        <Parameter name="_pxyTug" type="HMS_Tug"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateUNDGCode" id="59ff37b3-492a-4167-a2ef-3d12ad32d3d1">
        <source>utlUpdateUNDGCode(_proxyUNDGCode: CM_UNDangerousGoods; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 April 2004 by cnwjc2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	realUNDGCode		: CM_UNDangerousGoods;
	expectedEdition		: Integer;
	
begin

	self.initialiseActivity();

	_proxyUNDGCode.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxyUNDGCode.pxyGetRealObjectAndEdition(realUNDGCode, expectedEdition);
	
	if realUNDGCode = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_UNDangerousGoods.name, null, null);
		return;
	endif;

	app.myValUA.valUNDGCode(realUNDGCode, _proxyUNDGCode);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realUNDGCode);

	if _passport.noErrors and realUNDGCode.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'UNDGCode', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realUNDGCode, true);
	endif;
	
	if _passport.noErrors then
		realUNDGCode.setForUpdate(_proxyUNDGCode);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realUNDGCode, false);
	endif;

epilog
	
	
end;</source>
        <Parameter name="_proxyUNDGCode" type="CM_UNDangerousGoods"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateUnassignRelease" id="954568e2-1f3b-4c96-ba79-49b06b8ea7f7">
        <updating/>
        <source>utlUpdateUnassignRelease(_tiSet : CM_TISet;
						_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     21 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
12 Oct 2016	cnwkpd1	TFS 2815 - JADE 7.1.08 causeEvent changes
	
*/

vars
	tmpBR : CM_BulkRelease;
	ti			: CM_TrackedItem;
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);

	app.setContinueCMExceptions(false);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	foreach ti in _tiSet do
		foreach tmpBR in ti.allBulkReleasesAssigned do
//			tmpBR.causeEvent(Object_Update_Event,false,null); // CCMS 1282
			self.updateObjectEdition(tmpBR);
			tmpBR.removeTIAssigned(ti);
			// moved transaction create to above method (PAR 23115)
			//tmpBR.createAssignedTransaction(ti, true);
		endforeach;
	endforeach;
	
end;</source>
        <Parameter name="_tiSet" type="CM_TISet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateUnassignTBA" id="88d9ce78-6dd5-4408-87e5-4b24512098ea">
        <updating/>
        <source>utlUpdateUnassignTBA(_tbaTI : CM_TrackedItem input;	_passport : CM_Passport input	) updating;
/*
Purpose:			PAR 33695
Date				Who			Reason
MARCH 2014	CNWAB1		Initial creation
*/

vars
	cancelSave 		: Boolean;
	realMeasurement	: CM_MeasurementType;
	expectedEdition	: Integer;
	eventStr 		: String;
	codeChanged		: Boolean;
	terminal 		: CM_Terminal;
	
begin
	self.initialiseActivity();
	
	exclusiveLock(_tbaTI);

	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_tbaTI, true);
	endif;
	
	if _passport.noErrors then
		_tbaTI.breakTBAMatch();
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_tbaTI, false);
	endif;
epilog

end;</source>
        <Parameter name="_tbaTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateUnlinkCrdFromInv" id="9291974f-49cf-4fba-9128-b82757fe9139">
        <source>utlUpdateUnlinkCrdFromInv(_allInvoicesToUnlink : CM_InvoiceSet; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 February 2023	navkc1	Initial creation TFS CR 55305 TASK 55536

*/

vars
	invoice,
	creditNote			: CM_Invoice;
	allCreditsLinked	: CM_InvoiceSet;
	itemAudit			: CM_UpdateTransactionAuditAgent;
	allTransientToDel	: ObjectArray;
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	foreach invoice in _allInvoicesToUnlink do
		app.myValUA.valUpdateUnlinkCrdFromInv(invoice);
	endforeach;
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	create allCreditsLinked transient;
	create itemAudit transient;
	create allTransientToDel transient; //16/10/2024	navkc1	JIRA Bug MTN-12541
	
	foreach invoice in _allInvoicesToUnlink do		
		allCreditsLinked.clear(); //16/10/2024	navkc1	JIRA Bug MTN-12541
		invoice.allCreditCredits.copy(allCreditsLinked);//16/10/2024	navkc1	JIRA Bug MTN-12541
		
		self.myUpdateAuditAgent.audUpdateGeneric(invoice, true);		
		
		//16/10/2024	navkc1	JIRA Bug MTN-12541
		// Because invoice.allCreditCredits is automatic collection, we need to go remove the link from the other end. Hence this loop
		foreach creditNote in allCreditsLinked do
			create itemAudit transient;
			allTransientToDel.add(itemAudit); 
			// Audit credit note before
			itemAudit.audUpdateGeneric(creditNote, true);			
			// We only want to unlink this invoice.
			creditNote.allCreditInvoices.tryRemove(invoice);
			// Audit credit note after
			itemAudit.audUpdateGeneric(creditNote, false);
		endforeach;
		
		self.myUpdateAuditAgent.audUpdateGeneric(invoice, false);
		
		if _passport.noErrors() then
			invoice.causeEvent(_passport.myTerminal.getTerminalEvent(Event_InvoiceUpdate), false, invoice);
		endif;
	endforeach;
	
	foreach creditNote in allCreditsLinked do
		creditNote.causeEvent(_passport.myTerminal.getTerminalEvent(Event_InvoiceUpdate), false, creditNote);
	endforeach;
	
epilog
	delete allCreditsLinked;
	delete itemAudit;
	if allTransientToDel &lt;&gt; null then //16/10/2024	navkc1	JIRA Bug MTN-12541
		allTransientToDel.purge();
	endif;
end;</source>
        <Parameter name="_allInvoicesToUnlink" type="CM_InvoiceSet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateUnpackCargo" id="6d9e59ed-a167-464c-bca4-97187b737bdc">
        <updating/>
        <source>utlUpdateUnpackCargo(	_childCargo 				 : CM_TrackedItem io;
						_targetLocation 			 : CM_LocationsController input;
						_unpackQuantity 			 : Integer;
						_unpackWeight 				 : Decimal;
						_retroDate					 : TimeStamp;
						_passport 					 : CM_Passport input) updating;
/*

Date		Who		Reason
26 Jun 2014	cnwer1	Initial creation PAR
09 Jan 2024	navma1  Bug 60947: EUP - Cargo Scanning - Work order is not completed on unpacking all the child cargo items from scanning App
14 Mar 2024 navhl20 ChangeRequest 62861: EUP | Retrospective Operations - [54177.090] - UnPack
01 Jul 2024 navhl20	ChangeRequest 64969: EUP | 53856 - New Scanning App - Unpack mode issue
09 Jul 2025	jlizm1	MTN 35183 Storage transaction not created during unpack
*/

vars
	parent 			: CM_TrackedItem;
	moveController 	: CMIF_MoveController;
	job				: CM_Job;
	wle				: CM_WorkListEntry;
	wod				: CM_WodUnpack;
	tiUpdateCntrlr	: CMIF_TIUpdateController;	
	pxyChildTI		: CM_TrackedItem;
	
begin
	self.initialiseActivity();

	app.setContinueCMExceptions(false);
	
	self.raiseExceptionIfNull(_childCargo,"Cargo to unpack");
	self.raiseExceptionIfNull(_targetLocation,app.getErrorString(CM_Target_Location));
	
	if _passport.hasErrors then
		return;
	endif;
	if not _childCargo.isChild then
		//raise exception can't unpack not child cargo
		return;
	endif;

	if _unpackQuantity &lt;&gt; null and _unpackQuantity &gt; _childCargo.totalQuantity then
		app.raiseCMException3(Quantity_greater_than_cargo,"Unpack",_unpackQuantity.asStringJMT, _childCargo.totalQuantity.asStringJMT,null,null);
		//raise exception	
		return;
	endif;
	
	if _unpackWeight &lt;&gt; null and _unpackWeight &gt; _childCargo.totalWeight then
		app.raiseCMException3(Weigh_greater_than_cargo,"Unpack",_unpackWeight.asStringJMT,_childCargo.totalWeight.asStringJMT,null,null);
		return;
	endif;
	
	
	parent:=_childCargo.myParent;
	
	//31 Aug 2015	NDL	Par 36666
	if parent &lt;&gt; null and not parent.isOnSite then
		app.raiseCMException1(Not_unpack_offsite, parent.id,null,null);
		return;
	endif;
	
	app.setContinueCMExceptions(true);
	
	//see if the storage configuration has any triggers for unpacked child
	tiUpdateCntrlr := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);
	
	pxyChildTI := _childCargo.pxyGetProxyObject();
	if pxyChildTI = null then
		pxyChildTI := _childCargo.pxyCreateUpdateProxy();
	endif;
	
	pxyChildTI.pxySetMyParent(null);
	_childCargo.setForUpdateStorage(pxyChildTI,tiUpdateCntrlr , app.myPassport); 
	delete tiUpdateCntrlr; 	
	
	//move the child cargo to target location
	create moveController transient;
	moveController.setMyToPrimaryLocation(_targetLocation );
	moveController.setMyTrackedItem(_childCargo);
	moveController.setMoveMode(REAL_MODE);
	moveController.setQuantity(_unpackQuantity);
	moveController.setWeight(_unpackWeight);
	moveController.retrospectiveDT := _retroDate;					//14.03.2024 navhl20 #62861
	moveController.isForcedMove :=true;
	moveController.myUnpackFromTI:=parent;
	self.utlUpdateMoveTrackedItem(moveController, _passport);
	
	if parent &lt;&gt; null and parent.allChildren.isNotEmpty() and _passport.isVASEnabled then		//01.07.2024 navhl20 #64969
		wle := parent.getIncompleteWLE(CM_WOUnpackWLE);
		if wle &lt;&gt; null then
			job := wle.job;
		endif;
		if job &lt;&gt; null then
			wod := job.getWorkOrderDtl().CM_WodUnpack;
			job.updateStatus();
			if job.status = JOB_PART_COMPLETE then
				app.myEventManager.createSingleObjInfoNoteEvt(job, parent.myTerminal.getTerminalEvent(Object_Update_Event), job);	
			endif;
			if wod &lt;&gt; null then
				wod.updateStatus();
			endif;
		endif;
	endif;
	
epilog
	delete  moveController;
	delete pxyChildTI;
	delete tiUpdateCntrlr;
	
end;</source>
        <Parameter name="_childCargo" type="CM_TrackedItem" usage="io"/>
        <Parameter name="_targetLocation" type="CM_LocationsController" usage="input"/>
        <Parameter name="_unpackQuantity" type="Integer"/>
        <Parameter name="_unpackWeight" type="Decimal"/>
        <Parameter name="_retroDate" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateUser" id="4493497a-4b1e-4583-a012-7f984c98ce00">
        <source>utlUpdateUser(pProxyUser : CM_User; password : String; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     30 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	realUser		: CM_User;
	expectedEdition	: Integer;
	
begin

	self.initialiseActivity();

	pProxyUser.raiseExceptionIfNotProxy(method);
	pProxyUser.pxyGetRealObjectAndEdition(realUser, expectedEdition);
	
	if realUser = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_User.name, null, null);
		return;
	endif;

	app.myValUA.valUser(pProxyUser, realUser, _passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realUser);

	if _passport.noErrors and realUser.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'user', null, null);
		return;
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realUser, true);
	endif;

	// Update the password first as this also can update the user status.  The
	// change here will be overridden below if required (rjs Jul01)
	if _passport.noErrors and password &lt;&gt; null then
		app.myUtilityUA.utlUpdatePassword(realUser, realUser.edition, password, _passport);
	endif;

	if _passport.noErrors then
		realUser.setForUpdate(pProxyUser);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realUser, false);
	endif;

end;</source>
        <Parameter name="pProxyUser" type="CM_User"/>
        <Parameter name="password" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateUserNotifyDetails" id="de31a370-0e82-4a34-aa24-a9bd3837ff8c">
        <updating/>
        <source>utlUpdateUserNotifyDetails(_platform, _token : String; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 June 2013	cnwmc5	Initial creation

*/

vars

begin
	self.initialiseActivity();

	if _passport.myUser = null then
		app.setContinueCMExceptions(false);
	//	app.raiseCMException1(REQUIRED_FIELD, "user", null, null);
		app.raiseCMException(Input_required_field_Usr, null, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	// Lock will be released at commit/abort transaction	
	exclusiveLock(_passport.myUser);
	
	if _passport.noErrors then
		_passport.myUser.setNotificationDetails(_platform, _token);
	endif;	
end;</source>
        <Parameter name="_platform" type="String"/>
        <Parameter name="_token" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateUserPwDefEmail" id="a71e6597-e1d6-4889-b5d6-01bbca9cc5f6">
        <updating/>
        <source>utlUpdateUserPwDefEmail( _proxy : CM_UserPasswordDefaultEmail; _real : CM_UserPasswordDefaultEmail io; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2018	jlgndl1	Initial creation	TFS 38768

*/

vars

	real : CM_UserPasswordDefaultEmail;
	expectedEdition : Integer;

begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	if _real &lt;&gt; null then
		_proxy.raiseExceptionIfNotProxy(method);
		_proxy.pxyGetRealObjectAndEdition( real, expectedEdition );
	endif;
	
	app.myValUA.valUserPwDefEmail( _proxy );
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;

	app.setContinueCMExceptions(false);
	
	if real = null then
		create real;
		_real := real;
		
	else
		exclusiveLock( real );

		if _passport.noErrors and real.edition &lt;&gt; expectedEdition then
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'User Password Email', null, null);
			return;
		endif;
		
		if _passport.noErrors then
			self.myUpdateAuditAgent.audUpdateGeneric(real, true);
		endif;
		
	endif;
		
	if _passport.noErrors then
		real.setForUpdate(_proxy);
	endif;

	if _passport.noErrors then
		app.myRoot.setConfig( UserEmailTemplate, real, true );
		self.myUpdateAuditAgent.audUpdateGeneric(real, false);
	endif;

epilog

end;</source>
        <Parameter name="_proxy" type="CM_UserPasswordDefaultEmail"/>
        <Parameter name="_real" type="CM_UserPasswordDefaultEmail" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateUserSSOUniqueId" id="fc38d582-9489-4987-8171-b37572a999a5">
        <updating/>
        <source>utlUpdateUserSSOUniqueId( _proxyUser : CM_User io; _uniqueId : String; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 July 2022 navam1 ChangeRequest 52824: EUP - Azure Active Directory Single Sign On - MTN
*/

vars
	cancelSave		:Boolean;
	realUser		:CM_User;
	expectedEdition	:Integer;
begin
	self.initialiseActivity();
	
	_proxyUser.raiseExceptionIfNotProxy(method);
	
	app.setContinueCMExceptions(true);
	
	_proxyUser.setSSOUniqueId(_uniqueId);
	
	_proxyUser.pxyGetRealObjectAndEdition(realUser, expectedEdition);
	
	if realUser = null then
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_User.name, null, null);
		return;
	endif;	
	
	app.myValUA.valUser(_proxyUser, realUser, _passport);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;
	
	app.setContinueCMExceptions(false);
		
	exclusiveLock(realUser);
	
	if _passport.noErrors and realUser.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'User', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realUser, true);
	endif;
	
	//set uniqueId
	if _passport.noErrors then
		//_proxyUser.setSSOUniqueId(_uniqueId);
		realUser.setForUpdate(_proxyUser);
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realUser, false);
	endif;
	
epilog

end;</source>
        <Parameter name="_proxyUser" type="CM_User" usage="io"/>
        <Parameter name="_uniqueId" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateUserStateData" id="3ef77647-13b1-490b-a826-43e23de884d9">
        <source>utlUpdateUserStateData(pUser : CM_User; pSubSystem : Integer; pKey : String; pValue : Any);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
