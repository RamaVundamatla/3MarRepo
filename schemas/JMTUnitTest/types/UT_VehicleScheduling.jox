	//Attach VBS Slots to VVR
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tBaseSetup" id="d4d8d77d-002c-4e6b-aacf-81ce4d310dcc">
        <updating/>
        <source>tBaseSetup() updating;
/*

Purpose:			Sets up some vehicle Booking Time Slots for use in UT_vehicleScheduling

Parameters:			NONE

Return Value:		NONE

Date			Who			Reason
11 April 2013	cnwndl1		Initial creation	Par 31393
12 May 2016		cnwns1		TFS 488 - Multi Timezone Support
21 Jun 2022 	navsrk20	ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types
*/

constants
	CarrierId	: String = "UTVSS";
	CarrierDesc	: String = "VSS Unit Test Carrier";
	VehicleId	: String = "UTVSS";
	DriverID	: String = "UTVS";
	
vars
	term					: CM_Terminal;
	vvsTerm					: CM_VehicleBookingTerminal;
	now, ts					: TimeStamp;
	date1, date2			: Date;
	calendar				: CM_Calendar;
	truck					: CM_Vehicle;
	driver					: CM_DriverDetails;
	carrier					: CM_Carrier;
	pinEmailAddresses		: CM_EmailEntityByTypeNameDict;
	allCarriers				: CM_CarrierByCodeDict;
	allVehicleMachines		: CM_VehicleSet;
	vssTimeSlot,
	startObject				: CM_VehicleBookingTimeSlot;
	iter					: Iterator;
	count, mins, hrs,
	origHrs, expectedHrs	: Integer;
	lateTimeSlot,
	earlyTimeSlot			: CM_VehicleBookingTimeSlot;
	vvr1,vvr2				: CM_VehicleVisitRecord;
	ti						: CM_TrackedItem;
	tsi,workTsi				: TimeStampInterval;
	vbtst, vbtst1, vbtst2	: CM_VehicleBookingTimeSlotType;

begin
	self.assertTrueMsg(app.myVehicleBookingRoot &lt;&gt; null, "1. No Vehicle Booking Root object");
	
	beginTransaction;
	app.setPropertyValue("isVehicleBookingEnabled",true);
	commitTransaction;

	term := self.getTerminal;
	vvsTerm := term.myVehicleBookingTerminal;
	
	if vvsTerm &lt;&gt; null then
		self.deleteVVSTerminal(vvsTerm);
	endif;
	self.assertTrueMsg(term.myVehicleBookingTerminal = null, "2. CM_VehicleBookingTerminal for terminal not deleted");
	
	//add CM_VehicleBookingTerm
	beginTransaction;
	vvsTerm := term.createVehicleBookingTerm();
	commitTransaction;
	self.assertTrueMsg(term.myVehicleBookingTerminal &lt;&gt; null, "3. CM_VehicleVisitScheduleTerm for terminal not created");
	
	//set config value
	self.setTerminalConfig(VsUseVehicleScheduling,true);	// need to add this to config to cmif...
	self.setTerminalConfig(VsTruckDriverMand,true);
	self.setTerminalConfig(VsOntimeGracePeriod,5);
	self.setTerminalConfig(VsPurgeSlotsOlderThan,20);
	self.setTerminalConfig(VsGenerateDaysInAdvance,5);
	self.setTerminalConfig(VsBookMinAdvanceHrs,5);
	self.setTerminalConfig(VsBookMinAdvancePu,3);
	self.setTerminalConfig(VsBookingRule,10);
	
	//test config values
	self.assertTrueMsg(term.getConfig(VsUseVehicleScheduling).Boolean, "4. 'Use Vehicle Booking' terminal config not set");
	self.assertTrueMsg(term.getConfig(VsTruckDriverMand).Boolean, "5. 'Mandatory Truck and Driver' terminal config not set");
	term.getVSTimeslotGraceTimeInterval( mins );
	self.assertTrueMsg(mins = 5 , "6. 'Vehicle Booking On Time Grace period' terminal config not set");
	self.assertTrueMsg(term.getConfig(VsPurgeSlotsOlderThan).Integer = 20 , "6a. 'Vehicle Booking Purge Older than' terminal config not set");
	term.getVSBookInAdvanceDelivTimeInt( hrs);
	self.assertTrueMsg(hrs = 5 , "6b. 'Vehicle Booking Book in Advance delivery' terminal config not set");
	term.getVSBookInAdvancePuTimeInt( hrs);
	self.assertTrueMsg(hrs = 3 , "6c. 'Vehicle Booking Book in Advance pickup' terminal config not set");
	self.assertTrueMsg(term.getConfig(VsBookingRule).Integer = 10 , "6d. 'Vehicle Booking Rule' terminal config not set");
	
	self.setTerminalConfig(VsBookMinAdvanceHrs,0);
	self.setTerminalConfig(VsBookMinAdvancePu,0);
	self.setTerminalConfig(VsBookingRule,0);
	
	//21 Oct 2014	NDL	Par 35008
	self.deleteVbsTimeslotType("UTTEST");
	vbtst := self.addVbsTimeslotType( "UTTEST", "UT Test Description" );
	self.assertTrueMsg(vbtst &lt;&gt; null , "6d. 'CM_VehicleBookingTimeSlotType' not created");
	
	//vbtst1 := app.myRoot.allVehicleBookingTSTypes.getAtKey("MAIN");	//21.06.2022 navsrk20 TFS 53697
	vbtst1 := term.allTerminalVBSSlotTypes.getAtKey("MAIN");			//21.06.2022 navsrk20 TFS 53697
	if vbtst1 = null then
		vbtst1 := self.addVbsTimeslotType( "MAIN", "Main Gate" );
	endif;
	//vbtst2 := app.myRoot.allVehicleBookingTSTypes.getAtKey("SIDE");	//21.06.2022 navsrk20 TFS 53697
	vbtst2 := term.allTerminalVBSSlotTypes.getAtKey("SIDE");			//21.06.2022 navsrk20 TFS 53697
	if vbtst2 = null then
		vbtst2 := self.addVbsTimeslotType( "SIDE", "Side Gate" );
	endif;
	
	//check for error messages  from generate of booking slots
	now := app.actualTimeServer;// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	date1 := (now.Date + 1);
	date2 := (date1 + 2);
	
	//Add a calendar for special date, set up date2
	calendar := self.addSpecialCalendar( date2 );
	
	//Add Day and TimeSlot templates
	//Add values for Default templates
	self.zAddVbsTemplates( 	app.getErrorString(Default),	//name : String;
							999,	//priority : Integer;
							null,	//calendar : CM_Calendar;
							vvsTerm,	//vvsTerm : CM_VehicleVisitScheduleTerm;
							vbtst1	//vbtst : CM_VehicleBookingTimeSlotType
							);
					
	//Add values for 'Special dates calendar'
	self.zAddVbsTemplates( 	"Special dates",	//name : String;
							5,	//priority : Integer;
							calendar,	//calendar : CM_Calendar;
							vvsTerm,	//vvsTerm : CM_VehicleVisitScheduleTerm;
							vbtst2	//vbtst : CM_VehicleBookingTimeSlotType
							);
	
	//create Empty Booking slots
	app.myPassport.clearErrorsWarnings();
	vvsTerm.generateSlotsFromTemplate(date1,date2);
	self.assertTrueMsg(vvsTerm.allBookingsByTS.size &gt; 224 , "7. Not enough empty slots generated");
	
	//set up carrier/driver/truck
	self.deleteCarrier(CarrierId);
	create pinEmailAddresses transient;
	carrier := self.addCarrier(CarrierId, CarrierDesc, pinEmailAddresses, false, false, true, null);
	self.assertTrueMsg(carrier &lt;&gt; null , "8. Carrier " &amp; CarrierId &amp; " not created");
	
	self.deleteVehicle(VehicleId);
	truck := self.addVehicle(VehicleId, carrier, term);
	self.assertTrueMsg(truck &lt;&gt; null , "9. Truck " &amp; VehicleId &amp; " not created");
	
	self.deleteDriverDetails(DriverID);
	create allCarriers transient;
	allCarriers.add(carrier);
	create allVehicleMachines transient;
	allVehicleMachines.add(truck);
	driver := self.createDriverDetails(DriverID, allCarriers, allVehicleMachines);
	self.assertTrueMsg(driver &lt;&gt; null , "10. Driver " &amp; DriverID &amp; " not created");
	
	ts.setDate(date1);
	ts.setTime("08:30".Time);
	
	//book slots for carrier/driver/truck
	self.setTerminalConfig(VsTruckDriverMand,false);
	
	//book slots for carrier/driver/truck
	vssTimeSlot := vvsTerm.allUnBookedBookingsByTS.getAtKeyGeq(ts,null);
	self.assertTrueMsg(vssTimeSlot &lt;&gt; null , "11. Available time slot not found after " &amp; ts.asStringJMT);
	self.zBookVbsSlot(	vssTimeSlot,	//_vssSlot : CM_VehicleVisitScheduleSlot	input;
					carrier,	//_carrier : CM_Carrier;
					null,	//_driver : CM_DriverDetails;
					null	//_vehicle : CM_Vehicle
					);
	self.assertTrueMsg(app.myPassport.hasErrors = false , "12. " &amp; app.myPassport.getAllErrorsWarningsAsString);
	self.assertTrueMsg(vssTimeSlot.myCarrier = carrier , "13. carrier not set");
	self.assertTrueMsg(vssTimeSlot.myDriver = null , "14. driver set");
	self.assertTrueMsg(vssTimeSlot.myVehicle = null , "15. vehicle set");
				
	vssTimeSlot := vvsTerm.allUnBookedBookingsByTS.getAtKeyGeq(ts,null);
	self.assertTrueMsg(vssTimeSlot &lt;&gt; null , "16. Available time slot not found after " &amp; ts.asStringJMT);
	self.zBookVbsSlot(	vssTimeSlot,	//_vssSlot : CM_VehicleVisitScheduleSlot	input;
					carrier,	//_carrier : CM_Carrier;
					driver,	//_driver : CM_DriverDetails;
					null	//_vehicle : CM_Vehicle
					);
	self.assertTrueMsg(app.myPassport.hasErrors = false , "17. " &amp; app.myPassport.getAllErrorsWarningsAsString);
	self.assertTrueMsg(vssTimeSlot.myCarrier = carrier , "18. carrier not set");
	self.assertTrueMsg(vssTimeSlot.myDriver = driver , "19. driver not set");
	self.assertTrueMsg(vssTimeSlot.myVehicle = null , "20. vehicle set");
	
	vssTimeSlot := vvsTerm.allUnBookedBookingsByTS.getAtKeyGeq(ts,null);
	self.assertTrueMsg(vssTimeSlot &lt;&gt; null , "21. Available time slot not found after " &amp; ts.asStringJMT);
	self.zBookVbsSlot(	vssTimeSlot,	//_vssSlot : CM_VehicleVisitScheduleSlot	input;
					carrier,	//_carrier : CM_Carrier;
					driver,	//_driver : CM_DriverDetails;
					truck	//_vehicle : CM_Vehicle
					);
	self.assertTrueMsg(app.myPassport.hasErrors = false , "22. " &amp; app.myPassport.getAllErrorsWarningsAsString);
	self.assertTrueMsg(vssTimeSlot.myCarrier = carrier , "23. carrier not set");
	self.assertTrueMsg(vssTimeSlot.myDriver = driver , "24. driver not set");
	self.assertTrueMsg(vssTimeSlot.myVehicle = truck , "25. vehicle not set");
	
	//21 Oct 2014	NDL	Par 35008
	vssTimeSlot := vvsTerm.allUnBookedBookingsByTS.getAtKeyGeq(ts,null);
	self.assertTrueMsg(vssTimeSlot &lt;&gt; null , "26. Available time slot not found after " &amp; ts.asStringJMT);
	self.zBookVbsSlot(	vssTimeSlot,	//_vssSlot : CM_VehicleVisitScheduleSlot	input;
						carrier,	//_carrier : CM_Carrier;
						driver,	//_driver : CM_DriverDetails;
						truck	//_vehicle : CM_Vehicle
						);
	self.addPreNoteAndRelease( vssTimeSlot );
	
	
	vssTimeSlot := vvsTerm.allUnBookedBookingsByTS.getAtKeyGeq(ts,null);
	self.assertTrueMsg(vssTimeSlot &lt;&gt; null , "27. Available time slot not found after " &amp; ts.asStringJMT);
	self.zBookVbsSlot(	vssTimeSlot,	//_vssSlot : CM_VehicleVisitScheduleSlot	input;
						carrier,	//_carrier : CM_Carrier;
						driver,	//_driver : CM_DriverDetails;
						truck	//_vehicle : CM_Vehicle
						);

	//need to add a booking and a cargo item to pickup
	self.addBookingAndCargo( vssTimeSlot );									
	
	//block book some slots for form demos
	if now.time.hour &gt; 2 then
		now.setTime( now.time.cnEcAddMinutes(-30) );
	endif;
	startObject := vvsTerm.allUnBookedBookingsByTS.getAtKeyGeq(now,null);
	iter := vvsTerm.allUnBookedBookingsByTS.createIterator;
	iter.startAtObject( startObject );
	while iter.next(vssTimeSlot) do
		count := count + 1;
		self.zBookVbsSlot(	vssTimeSlot,	//_vssSlot : CM_VehicleVisitScheduleSlot	input;
					carrier,	//_carrier : CM_Carrier;
					driver,	//_driver : CM_DriverDetails;
					truck	//_vehicle : CM_Vehicle
					);
		if count = 1 then
			lateTimeSlot := vssTimeSlot;
		elseif count &gt;= 10 then
			earlyTimeSlot := vssTimeSlot;
			break;
		endif;
	endwhile;
	
	//gate in the truck and associate the vvr with a 'lateTimeSlot' booking.
	vvr1 := zGateIn( truck, carrier.code, driver, "UTVS5555001" );
	self.zAssociateVbsSlot( lateTimeSlot, vvr1 );
	self.workVehicle(vvr1);
	
	//Gate the truck out.
	app.myTrxDA.trxVehicleRoadExit(truck, app.myPassport);
	
	//gate in the truck and associate the vvr with a 'earlyTimeSlot' booking.
	vvr2 := zGateIn( truck, carrier.code, driver, "UTVS5555002" );
	self.zAssociateVbsSlot( earlyTimeSlot, vvr2 );
	self.workVehicle(vvr2);
	
	//Gate the truck out.
	app.myTrxDA.trxVehicleRoadExit(truck, app.myPassport);
	
	//Vehicle Booking rule 0 in play - I.e. the default rules
	self.setTerminalConfig(VsBookMinAdvanceHrs,2);
	self.setTerminalConfig(VsBookMinAdvancePu,4);
	self.setTerminalConfig(VsBookingRule,0);
	tsi := vvsTerm.getBookInAdvanceDelivTimeInt(origHrs);
	self.assertTrueMsg(origHrs = 2 , "28. delivery hours value incorrect");
	self.assertTrueMsg(tsi.asMinutes &gt;= 119 and tsi.asMinutes &lt;= 121 , "28A. delivery hours TimeStampIntevral value incorrect");
	
	tsi := vvsTerm.getBookInAdvancePuTimeInt(origHrs);
	self.assertTrueMsg(origHrs = 4 , "29. pick up hours value incorrect");
	self.assertTrueMsg(tsi.asMinutes &gt;= 239 and tsi.asMinutes &lt;= 241 , "29A. pick up hours TimeStampIntevral value incorrect");
	//end of rule 0 testing.
	
	//Vehicle Booking rule 1 in play - I.e the Recife rule.
	self.setTerminalConfig(VsBookingRule, 1);
	now := app.actualTimeServer;// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	tsi := vvsTerm.getBookInAdvanceDelivTimeInt(origHrs);
	if now.time &lt; "16:00".Time and now.time &gt; "08:00".Time then
		self.assertTrueMsg(origHrs = 2 , "30. delivery hours value incorrect");
		self.assertTrueMsg(tsi.asMinutes &gt;= 119 and tsi.asMinutes &lt;= 121 , "31. delivery hours TimeStampIntevral value incorrect");
	else
		if now.time &lt; "08:00".Time then
			expectedHrs := ( 8 - now.time.hour );
		elseif now.time &gt; "16:00".Time then
			expectedHrs := ( 24 - now.time.hour ) + 8;
		endif;
		self.assertTrueMsg(origHrs &gt;=  ( expectedHrs - 1 ) and origHrs &lt;=  ( expectedHrs + 1), "32. delivery hours value incorrect");
		self.assertTrueMsg(tsi.asMinutes &gt;= ((expectedHrs -1) * 60) and tsi.asMinutes &lt;= ((expectedHrs + 1) * 60)  , "33. delivery hours TimeStampIntevral value incorrect ["
																						&amp; tsi.asMinutes.String &amp; " &lt;&gt; " &amp; (expectedHrs * 60).String &amp; "]");
	endif;

	tsi := vvsTerm.getBookInAdvancePuTimeInt(origHrs);
	self.assertTrueMsg(origHrs = 4 , "34. pick up hours value incorrect");
	self.assertTrueMsg(tsi.asMinutes &gt;= 239 and tsi.asMinutes &lt;= 241 , "35. pick up hours TimeStampIntevral value incorrect");
	//end of rule 1 testing.
	
epilog
	abortTransaction;
	delete pinEmailAddresses;
	delete allVehicleMachines;
	delete allCarriers;
	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckStandardProcAssocVvr" id="76ac1764-5f4b-4d62-bec8-a3293d2de440">
        <updating/>
        <source>tCheckStandardProcAssocVvr() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2023	navpw1	Initial creation TFS: 54049 (55844)

*/

constants
	UT_Carrier			: String = "UT" &amp; self.TFS55844;
	UT_VbsSlotTypeCode	: String = "UT" &amp; self.TFS55844;
	UT_VbsSlotId		: String = "UT" &amp; self.TFS55844;
	UT_BookingReference	: String = "UTB" &amp; self.TFS55844;
	UT_IsoType			: String = "2200";
	UT_DischargePort	: String = "NZAKL";
	UT_Commodity		: String = "GENL";
	UT_TrackedItemId	: String = "UTTI" &amp; self.TFS55844;
	UT_Remarks			: String = "Testing " &amp; self.TFS55844;
	UT_CargoTypeCode	: String = "CONT";
	
vars
	terminal			: CM_Terminal;
	vehicleBookingTerminal : CM_VehicleBookingTerminal;
	terminalUTHelper	: UT_HelperAdmTerm;
	
	booking				: CM_BookingRef;
	operator			: CM_Operator;
	carrier				: CM_Carrier;
	ti					: CM_TrackedItem;
	vbsTimeSlotType		: CM_VehicleBookingTimeSlotType;
	pxyVbsTimeSlot,
	vbsTimeSlot			: CM_VehicleBookingTimeSlot;
	ids					: StringArray;
	startTime,
	endTime				: TimeStamp;
	date				: Date;
	vehicleName,
	driverName			: String;
	vvr					: CM_VehicleVisitRecord;
	driver				: CM_DriverDetails;
	vehicle				: CM_Vehicle;
	myRoot				: CM_Root;
	
begin
	terminal := self.getTerminal();
	self.assertNotNullMsg(terminal, "terminal");
	
	myRoot := app.myRoot;
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	vehicleBookingTerminal := self.getMyTerminal.myVehicleBookingTerminal;
	self.assertNotNullMsg(vehicleBookingTerminal, "vehicleBookingTerminal");
	
	vehicleName := self.getTruckName();
	self.assertNotNullMsg(vehicleName, "vehicleName");
	
	driverName := self.getDriverName();
	self.assertNotNullMsg(driverName, "driverName");
	
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_VehicleScheduling::tCheckStandardProcAssocVvr;
	
	terminalUTHelper.xSetupVbsProcess(myRoot.allVBSProcesses[CM_VBSProcess.VBS_STANDARD_CODE], terminal);
	
	//Delete Carrier
	terminalUTHelper.xDeleteCarrier(UT_Carrier);
	
	//Create Carrier
	carrier := terminalUTHelper.xCreateCarrier(UT_Carrier, UT_Carrier, null, false, true, true, null);
	self.assertNotNullMsg(carrier, "carrier");
	
	//Delete Vbs Time Slot
	terminalUTHelper.xDeleteVbsTimeSlot(UT_VbsSlotId, vehicleBookingTerminal);
	
	//Delete Vbs Time Slot Type
	terminalUTHelper.xDeleteVbsTimeSlotType(UT_VbsSlotTypeCode, terminal);
	
	//Create Vbs Time Slot Type
	vbsTimeSlotType := terminalUTHelper.xCreateVbsTimeSlotType(UT_VbsSlotTypeCode, UT_VbsSlotTypeCode, terminal);
	self.assertNotNullMsg(vbsTimeSlotType, "vbsTimeSlotType");
	
	/*
	** Vbs Time Slot Includes Delivering
	*/
	//Delete Vehicle
	self.deleteVehicle(vehicleName);
	
	//Delete Booking
	self.deleteBooking(UT_BookingReference);
	
	//Create Booking
	booking := self.addBookingForContainer(UT_BookingReference, operator, self.voyage, UT_DischargePort, UT_IsoType, UT_Commodity);
	self.assertNotNullMsg(booking, "booking");
	
	//Delete Prenotified cargo/containers
	self.deleteContainer(UT_TrackedItemId);
	
	//Create Prenotified cargo/containers
	ti := self.addPrenotedContainer(booking.allBookingRefItems.first, UT_TrackedItemId);
	self.assertNotNullMsg(ti, "ti");
	
	//Create Id's String Array
	create ids transient;
	ids.add(UT_TrackedItemId);
	
	//Create Vehicle Visit Record
	self.opts.addAssoc("YardInterchangeArea", self.yic.id);
	vvr := terminalUTHelper.xCreateVehicleVisitRecord(vehicleName, driverName, driverName, null, terminal, self.dualGate.name);
	self.assertNotNullMsg(vvr, "vvr");
	
	//Get Driver
	driver := terminal.allDriversByCode[driverName];
	self.assertNotNullMsg(driver, "driver");
	
	//Get Vehicle
	vehicle :=  terminal.vehicles.getAtKeyGeq(vehicleName, null);
	self.assertNotNullMsg(vehicle, "vehicle");
	
	//Create Vbs Time Slot
	startTime.setTime(startTime.addHours(1).Time);
	startTime.setDate(date);
	
	endTime.setTime(startTime.addMinutes(vbsTimeSlotType.duration).Time);
	endTime.setDate(date);
	
	create pxyVbsTimeSlot transient;
	vbsTimeSlot := terminalUTHelper.xCreateVbsTimeSlot(pxyVbsTimeSlot, startTime, endTime, vehicleBookingTerminal, carrier, null, driver, vehicle, UT_Remarks, true,
														false, ids, null, vbsTimeSlotType, UT_VbsSlotId, null, null, null, null, null, null, null, null);
	self.assertNotNullMsg(vbsTimeSlot, "Create: vbsTimeSlot");
	
	//Attach VBS Slot to VVR
	vbsTimeSlot := terminalUTHelper.xUpdateVbsTimeSlot(vbsTimeSlot, startTime, endTime, vehicleBookingTerminal, carrier, null, driver, vehicle, UT_Remarks, true,
														false, ids, vvr, vbsTimeSlotType, UT_VbsSlotId, null, null, null, null, null, null, null, null);
	self.assertNotNullMsg(vbsTimeSlot, "Update: vbsTimeSlot");
	
	//Gate in Container against Vbs Time Slot
	vvr := terminalUTHelper.xCreateGateEntity(vvr, UT_CargoTypeCode, UT_TrackedItemId, UT_IsoType, operator.code, UT_Commodity);
	
	//Asserting
	self.assertEqual(vvr.vehicle.allRoadJobs.size, 1);
	self.assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.size, 1);
	self.assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.first.status, JOB_UNACTIONED);
	self.assertTrue(vvr.vehicle.allRoadJobs.first.workListEntries.first.myRequest.isKindOf(CM_TIRequest));
	self.assertTrue(vvr.vehicle.allRoadJobs.first.workListEntries.first.myRequest.CM_TIRequest.trackedItem &lt;&gt; null);
	
	self.opts.addAssoc("YardInterchangeArea", self.yic.id);
	self.moveVehicleToLane(vvr.vehicle, self.pin, 1);
	self.assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(self.pin, 1));
	
	terminalUTHelper.xMoveVehicleToYard(vvr.vehicle);
	
	self.workVehicle(vvr);
	self.assertNotNull(ti.getPrimaryLocation(REAL_MODE));
	self.assertTrue(ti.getPrimaryLocation(REAL_MODE).isKindOf(CM_YardController));
	self.assertTrue(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation);
	
	self.roadExit(vvr);
	self.assertNull(vvr.myRoadJob);
	self.assertEqual(vvr.status, CM_VehicleVisitRecord.Status_Complete);
	self.assertNull(vvr.vehicle.myPrimaryActualLocation);
	
	self.assertTrueMsg(vvr.myVehicleBookingTimeslot &lt;&gt; null, "vvr.myVehicleBookingTimeslot Expected: 'Not null' | Actual: 'null'");
	self.assertTrueMsg(vvr.myVehicleBookingTimeslot = vbsTimeSlot, "vvr.myVehicleBookingTimeslot Expected: 'to equal' | Actual: 'not equal'");
	self.assertTrueMsg(vvr.myVehicleBookingTimeslot.id = UT_VbsSlotId, "vvr.myVehicleBookingTimeslot.id Expected: '" &amp; UT_VbsSlotId &amp; "' | Actual: '" &amp; vvr.myVehicleBookingTimeslot.id &amp; "'");
	
	self.assertTrueMsg(vvr.myVehicleBookingTimeslot.allBookedTrackedItems.size = 1, "vvr.myVehicleBookingTimeslot.allBookedTrackedItems size Expected: '" &amp; 1.String &amp; "' | Actual: '" &amp; vvr.myVehicleBookingTimeslot.allBookedTrackedItems.size.String &amp; "'");
	self.assertTrueMsg(vvr.myVehicleBookingTimeslot.allBookedTrackedItems.first.id = UT_TrackedItemId, "vvr.myVehicleBookingTimeslot.id Expected: '" &amp; UT_TrackedItemId &amp; "' | Actual: '" &amp; vvr.myVehicleBookingTimeslot.allBookedTrackedItems.first.id &amp; "'");
	
	self.assertTrueMsg(vbsTimeSlot.myVehicleVisitRecord &lt;&gt; null, "vbsTimeSlot.myVehicleVisitRecord Expected: 'Not null' | Actual: 'null'");
	self.assertTrueMsg(vbsTimeSlot.myVehicleVisitRecord = vvr, "vbsTimeSlot.myVehicleVisitRecord Expected: 'to equal' | Actual: 'not equal'");
	
epilog
	delete terminalUTHelper;
	delete ids;
	delete pxyVbsTimeSlot;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckVVRLinkedWithVBS" id="1e067dc3-bd99-4181-8613-041d94c64526">
        <updating/>
        <source>tCheckVVRLinkedWithVBS()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Nov 2024 navhl20 MTN-33483 :TPT | Vehicle Truck Booking Auto Associate with Release Request
*/

constants
	UT_Carrier			: String = "UT" &amp; "33483";
	UT_VbsSlotTypeCode	: String = "UT" &amp; "33483";
	UT_VbsSlotId		: String = "UT" &amp; "33483";
	UT_Release			: String = "UTB" &amp; "33483";
	UT_IsoType			: String = "2200";
	UT_DischargePort	: String = "NZAKL";
	UT_Commodity		: String = "GENL";
	UT_TrackedItemId	: String = "UTTI" &amp; "33483";
	UT_Remarks			: String = "Testing " &amp; "33483";
	UT_CargoTypeCode	: String = "CONT";
	UT_Vessel			: String = "UTVES33483";
	UT_Voyage			: String = "UTVOY33483";
vars
	terminal			: CM_Terminal;
	vehicleBookingTerm : CM_VehicleBookingTerminal;
	terminalUTHelper	: UT_HelperAdmTerm;
	release				: CM_BulkRelease;
	operator			: CM_Operator;
	carrier				: CM_Carrier;
	vbsTimeSlotType		: CM_VehicleBookingTimeSlotType;
	pxyVbsTimeSlot,
	vbsTimeSlot			: CM_VehicleBookingTimeSlot;
	startTime,
	endTime				: TimeStamp;
	date				: Date;
	vehicleName,
	driverName			: String;
	vvr					: CM_VehicleVisitRecord;
	driver				: CM_DriverDetails;
	vehicle				: CM_Vehicle;
	cargoType			: CM_CargoType;
	product				: CM_Product;
	taSource			: CM_TerminalArea;
	voyage				: CM_Voyage;
	vessel				: CM_Vessel;
	gate				: CM_Gate;
	myRoot				: CM_Root;
	brSet				: CM_BulkReleaseSet;
begin
	terminal := self.getTerminal();
	self.assertNotNullMsg(terminal, "terminal");
	
	myRoot := app.myRoot;
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	vehicleBookingTerm := self.getMyTerminal.myVehicleBookingTerminal;
	self.assertNotNullMsg(vehicleBookingTerm, "vehicleBookingTerminal");
	
	vehicleName := self.getTruckName();
	self.assertNotNullMsg(vehicleName, "vehicleName");
	
	driverName := self.getDriverName();
	self.assertNotNullMsg(driverName, "driverName");
	
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_VehicleScheduling::tCheckVVRLinkedWithVBS;
	terminalUTHelper.xSetupVbsProcess(myRoot.allVBSProcesses[CM_VBSProcess.VBS_STANDARD_CODE], terminal);
	
	//Delete Carrier
	terminalUTHelper.xDeleteCarrier(UT_Carrier);
	
	//Create Carrier
	carrier := terminalUTHelper.xCreateCarrier(UT_Carrier, UT_Carrier, null, false, true, true, null);
	self.assertNotNullMsg(carrier, "carrier");
	
	//Delete Vbs Time Slot
	terminalUTHelper.xDeleteVbsTimeSlot(UT_VbsSlotId, vehicleBookingTerm);
	
	//Delete Vbs Time Slot Type
	terminalUTHelper.xDeleteVbsTimeSlotType(UT_VbsSlotTypeCode, terminal);
	
	//Create Vbs Time Slot Type
	terminalUTHelper.opts.purge();
	terminalUTHelper.opts.addAssoc('AutoAssociateRR', true);
	vbsTimeSlotType := terminalUTHelper.xCreateVbsTimeSlotType(UT_VbsSlotTypeCode, UT_VbsSlotTypeCode, terminal);
	self.assertNotNullMsg(vbsTimeSlotType, "vbsTimeSlotType");
	
	/*
	** Vbs Time Slot Includes Delivering
	*/
	//Delete Vehicle
	self.deleteVehicle(vehicleName);
	
	//Delete Booking
	self.deleteReleaseRequest(UT_Release);
	
	cargoType := terminal.allCargoBOLTypes.getCargoTypeByAbbreviation("STEEL COIL").CM_CargoType;
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product := cargoType.getProductFromCode("TIEWIRE10G");
	self.assertNotNullMsg(product, "product");
	self.deleteVoyage(UT_Voyage);
	
	// vessel and voyage
	vessel := self.addVesselWithHolds(UT_Vessel, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(UT_Voyage, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNull(voyage);
	
	//Create release request
	self.opts.purge();
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("CanBeHiLoCube", true);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc("TerminalArea",taSource );
	self.opts.addAssoc("Product", product);
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc('Number', 2500);
	release := self.addReleaseByTypeRequestOpts(UT_Release, BR_TYPE_ROAD, cargoType.id);
	self.assertNotNull(release);
	create brSet transient;
	brSet.add(release);
	
	gate := self.getTerminal.getConfig(GateDefaultEntry).CM_Gate;
	self.assertNotNullMsg(gate, "Gate");
	
	//Create Vehicle Visit Record
	self.opts.addAssoc("YardInterchangeArea", self.yic.id);
	vvr := terminalUTHelper.xCreateVehicleVisitRecord(vehicleName, driverName, driverName, null, terminal, gate.name);
	self.assertNotNullMsg(vvr, "vvr");
	
	//Get Driver
	driver := terminal.allDriversByCode[driverName];
	self.assertNotNullMsg(driver, "driver");
	
	//Get Vehicle
	vehicle :=  terminal.vehicles.getAtKeyGeq(vehicleName, null);
	self.assertNotNullMsg(vehicle, "vehicle");
	
	//Create Vbs Time Slot
	startTime.setTime(startTime.addHours(1).Time);
	startTime.setDate(date);
	
	endTime.setTime(startTime.addMinutes(vbsTimeSlotType.duration).Time);
	endTime.setDate(date);
	
	create pxyVbsTimeSlot transient;
	vbsTimeSlot := terminalUTHelper.xCreateVbsTimeSlot(pxyVbsTimeSlot, startTime, endTime, vehicleBookingTerm, carrier, null, driver, vehicle, UT_Remarks, true,
														false, null, null, vbsTimeSlotType, UT_VbsSlotId, null, brSet, null, null, null, null, null, null);
	self.assertNotNullMsg(vbsTimeSlot, "Create: vbsTimeSlot");
	
	//Attach VBS Slot to VVR
	if release.getVBTimeSlot() &lt;&gt; null then
		vbsTimeSlot := terminalUTHelper.xUpdateVbsTimeSlot(vbsTimeSlot, startTime, endTime, vehicleBookingTerm, carrier, null, driver, vehicle, UT_Remarks, true,
														false, null, vvr, vbsTimeSlotType, UT_VbsSlotId, null, brSet, null, null, null, null, null, null);
	endif;
	self.assertNotNullMsg(vbsTimeSlot, "Update: vbsTimeSlot");
	self.assertNotNull(vvr.myVehicleBookingTimeslot);
	self.assertEqualMsg(vbsTimeSlot,vvr.myVehicleBookingTimeslot,"VVr should associated with VBS");
epilog
	delete terminalUTHelper;
	delete pxyVbsTimeSlot;
	delete brSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCreateVbsAdv53899" id="acbefb90-f9f1-414c-ad0a-b9a895b5ea0e">
        <source>tCreateVbsAdv53899();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
07 September 2022	navcs2	53899 EUP - SD - VBS MTN - [3] - Maintaining VBS Slot
24 May 2023 		navhl20 Defect 58041: MTN - Unable to copy the slots with the status "Booked - Current"
05 September 2023	navpw1	TFS: None - Added better validation/asserting to unit test
08 Aug 2024 navcs2	ChangeRequest 63928: EUP | Trailer Type in a VBS Slot
*/

constants
	
	REF : String = UT_DSL.TFS53899;
	CARRIERCODE : String = REF &amp; "CAR";
	SUBCARRIERCODE : String = REF &amp; "SUB";
	DRIVERID    : String = REF &amp; "DRIVER";
	VEHICLEID   : String = REF &amp; "VEHICLE";
	ID			: String = "IDUT" &amp; REF;
	
vars
	realVbsTimeSlot,
	proxyVbsTimeSlot		: CM_VehicleBookingTimeSlot;
	vbsSlotType				: CM_VehicleBookingTimeSlotType;
	id,						
	externalReference		: String;
	date					: Date;
	startTime,
	endTime					: TimeStamp;
	vbsTimeSlotItem			: CM_VehicleBookingTimeSlotItem;
	vbsTimeSlotITemsArray	: CM_ObjectArray;
	trackedItem				: CM_TrackedItem;
	tiStringArray			: StringArray;
	vehicleBookingTerminal	: CM_VehicleBookingTerminal;
	carrier					: CM_Carrier;
	subCarrier				: CM_Carrier;
	driver					: CM_DriverDetails;
	vehicle					: CM_Vehicle;
	preGateInCheck,
	postGateCheck,
	kioskCheck				: Boolean;
	allCarriers 			: CM_CarrierByCodeDict;	
	allVehicleMachines 		: CM_VehicleSet; 
	email					: CM_EmailEntityByTypeNameDict;
begin

	self.deleteVbsTimeSlotAdv(ID);
	self.deleteVbsTimeslotType(REF);
	
	vehicleBookingTerminal := self.getMyTerminal.myVehicleBookingTerminal;
	vbsSlotType 		   := self.addVbsTimeslotType(REF, "Slot Type Create" &amp; REF); 
	
	create proxyVbsTimeSlot transient;
	
	// create vehicle booking time slot item
	self.createVbsTimeSlotItem(proxyVbsTimeSlot, "UTC01");
	
	// get tracked item
	trackedItem := proxyVbsTimeSlot.allVehicleBookingItems.first.myTrackedItem;
	assertNotNullMsg(trackedItem, "Tracked Item");
	
	create tiStringArray transient;
	tiStringArray.add(trackedItem.id);
	
	// create carrier and subcarrier
	create email transient;
	self.deleteCarrier(CARRIERCODE);
	self.deleteCarrier(SUBCARRIERCODE);

	carrier := self.addCarrier(CARRIERCODE, CARRIERCODE, email, false, true, true, null);
	subCarrier := self.addCarrier(SUBCARRIERCODE, SUBCARRIERCODE, email, false, true, true, null);

	// create vehicle
	self.deleteVehicle(VEHICLEID);
	vehicle := self.addVehicle( VEHICLEID, carrier, self.getTerminal());
	self.assertNotNull(vehicle);
	
	// create driver details
	self.deleteDriverDetails(DRIVERID);
	create allCarriers transient;
	allCarriers.add(carrier);
	create allVehicleMachines transient;
	allVehicleMachines.add(vehicle);
	driver := self.createDriverDetails(DRIVERID, allCarriers, allVehicleMachines);
	
	startTime.setTime(vbsSlotType.startTime);
	startTime.setDate(date.cnEcAddDays(1));
	
	endTime.setTime(vbsSlotType.startTime.addMinutes(vbsSlotType.duration));
	endTime.setDate(date.cnEcAddDays(1));
	
	proxyVbsTimeSlot.setProxy(startTime, endTime, vehicleBookingTerminal, carrier, subCarrier, driver, vehicle, null, true, false, tiStringArray, null, vbsSlotType, ID, null, null, null, vbsSlotType.preGateInCheck, vbsSlotType.preGateOutCheck, vbsSlotType.kioskCheck, null, null);		// 08 Aug 2024 navcs2	ChangeRequest 63928
	
	app.myTrxCA.trxCreateVehicleBookingAdv(proxyVbsTimeSlot, realVbsTimeSlot,false, app.myPassport);			//24.5.2023 navhl20 #58041
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertNotNullMsg(realVbsTimeSlot, "realVbsTimeSlot: Expected 'not null' | Actual: 'null'");
	
epilog
	delete tiStringArray;
	delete allCarriers;
	delete email;
	delete allVehicleMachines;
	delete proxyVbsTimeSlot;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRoadGateVbsItemMaxWeight" id="a295f330-8d40-4b89-a2cb-696fbe5bff59">
        <source>tRoadGateVbsItemMaxWeight();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 July 2024	navpw1	Initial creation TFS: 61525 (61527)

*/

constants
	REF							: String = "61525-1";
	CARRIERCODE					: String = REF &amp; "CAR";
	SUBCARRIERCODE				: String = REF &amp; "SUB";
	DRIVERID					: String = REF &amp; "DRIVER";
	VEHICLEID 					: String = REF &amp; "VEHICLE";
	UT_TimeSlotTypeId			: String = REF;
	UT_ReleaseRequestByWeight	: String = "Rel" &amp; REF;
	UT_ReleaseRequestByQuantity	: String = "Rel" &amp; REF &amp; "1";
	UT_CargoTypeAbbr			: String = "STEEL COIL";
	UT_ProductCode				: String = "ROLLS";
	UT_TimeSlotId1				: String = "IDUT" &amp; REF &amp; "1";
	UT_TimeSlotId2				: String = "IDUT" &amp; REF &amp; "2";
	UT_TimeSlotId3				: String = "IDUT" &amp; REF &amp; "3";
	UT_TimeSlotId4				: String = "IDUT" &amp; REF &amp; "4";
	UT_SourceTypeRelease		: Integer = 2;
	
vars
	realVbsTimeSlotByWeight,
	realVbsTimeSlotByQuantity,
	vbsTimeSlot,
	pxyVbsTimeSlot			: CM_VehicleBookingTimeSlot;
	vbsSlotType				: CM_VehicleBookingTimeSlotType;
	date					: Date;
	startTime,
	endTime					: TimeStamp;
	vehicleBookingTerminal	: CM_VehicleBookingTerminal;
	carrier					: CM_Carrier;
	subCarrier				: CM_Carrier;
	driver					: CM_DriverDetails;
	vehicle					: CM_Vehicle;
	allCarriers 			: CM_CarrierByCodeDict;	
	allVehicleMachines 		: CM_VehicleSet; 
	email					: CM_EmailEntityByTypeNameDict;
	terminalUTHelper		: UT_HelperAdmTerm;
	releaseRequestByWeight,
	releaseRequestByQuantity		: CM_BulkRelease;
	pxyReserveSelectionByWeight,
	pxyReserveSelectionByQuantity	: CM_ReserveSelection;
	cargoType				: CM_CargoType;
	product					: CM_Product;
	terminal				: CM_Terminal;
	vvr						: CM_VehicleVisitRecord;
	utOperator				: CM_Operator;
	pxyVbsTimeSlotItem			: CM_VehicleBookingTimeSlotItem;
	roadJob : CM_RoadJob;
	gateEntity		: CMGTE_Entity;
	gateEntityRelease		: CMGTE_Release;
	
begin
	//Get Terminal
	terminal := self.getTerminal();
	self.assertNotNullMsg(terminal, "terminal");
	
	beginTransaction;
	terminal.setPropertyValue(CM_Terminal::myVBSProcess.name, app.myRoot.allVBSProcesses[CM_VBSProcess.VBS_SLVALIDATION_CODE]);
	commitTransaction;
	
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_VehicleScheduling::tRoadGateVbsItemMaxWeight;
	
	//Delete Vbs Time Slot
	vbsTimeSlot := self.getVbsTimeSlot(UT_TimeSlotId1);
	if vbsTimeSlot &lt;&gt; null and vbsTimeSlot.myVehicleVisitRecord &lt;&gt; null then
		self.deleteVVR(vbsTimeSlot.myVehicleVisitRecord);
	endif;
	self.deleteVbsTimeSlotAdv(UT_TimeSlotId1);
	
	vbsTimeSlot := self.getVbsTimeSlot(UT_TimeSlotId2);
	if vbsTimeSlot &lt;&gt; null and vbsTimeSlot.myVehicleVisitRecord &lt;&gt; null then
		self.deleteVVR(vbsTimeSlot.myVehicleVisitRecord);
	endif;
	self.deleteVbsTimeSlotAdv(UT_TimeSlotId2);
	
	//Get Vehicle Booking Terminal
	vehicleBookingTerminal := terminal.myVehicleBookingTerminal;
	self.assertNotNullMsg(vehicleBookingTerminal, "vehicleBookingTerminal");
	
	//Get Cargo Type
	cargoType := self.getCargoTypeByAbbrv(UT_CargoTypeAbbr);
	self.assertNotNullMsg(cargoType, "cargoType");
	
	//Get Product
	product := cargoType.allProducts.getAtKeyGeq(null, UT_ProductCode);
	self.assertNotNullMsg(product, "product");
	
	//Get Operator
	utOperator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(utOperator, "operator");
	
	//Delete VBS SlotType
	self.deleteVbsTimeslotType(UT_TimeSlotTypeId);
	
	//Create VBS Slot Type
	vbsSlotType := self.addVbsTimeslotType(UT_TimeSlotTypeId, "Slot Type Create" &amp; UT_TimeSlotTypeId); 
	self.assertNotNullMsg(vbsSlotType, "vbsSlotType");
	
	//Delete Carrier
	self.deleteCarrier(CARRIERCODE);
	
	//Delete Sub Carrier
	self.deleteCarrier(SUBCARRIERCODE);
	
	//Create Carrier
	carrier := self.addCarrier(CARRIERCODE, CARRIERCODE, email, false, true, true, null);
	self.assertNotNullMsg(carrier, "carrier");
	
	//Create Sub Carrier
	subCarrier := self.addCarrier(SUBCARRIERCODE, SUBCARRIERCODE, email, false, true, true, null);
	self.assertNotNullMsg(subCarrier, "subCarrier");
	
	//Delete Release Request By Weight
	self.deleteReleaseRequest(UT_ReleaseRequestByWeight);
	
	//Create Release Request By Weight
	terminalUTHelper.opts.purge;
	terminalUTHelper.opts.addAssoc(UT_OPTS_WeightRequested, 1000);
	pxyReserveSelectionByWeight := terminalUTHelper.xCreateReserveSelection(cargoType, product, null, null, null, null);
	releaseRequestByWeight := terminalUTHelper.xCreateReleaseRequest(UT_ReleaseRequestByWeight, BR_TYPE_ROAD, true, terminal, pxyReserveSelectionByWeight);	// Create a release request/bulk release. Release by Type
	self.assertNotNullMsg(releaseRequestByWeight, "releaseRequestByWeight");
	
	//Delete Release Request By Quantity
	self.deleteReleaseRequest(UT_ReleaseRequestByQuantity);
	
	//Create Release Request By Quantity
	terminalUTHelper.opts.purge;
	pxyReserveSelectionByQuantity := terminalUTHelper.xCreateReserveSelection(cargoType, product, null, 100, null, null);
	releaseRequestByQuantity := terminalUTHelper.xCreateReleaseRequest(UT_ReleaseRequestByQuantity, BR_TYPE_ROAD, true, terminal, pxyReserveSelectionByQuantity);	// Create a release request/bulk release. Release by Type
	self.assertNotNullMsg(releaseRequestByQuantity, "releaseRequestByQuantity");
	
	create email transient;
	
	//Delete Vehicle
	self.deleteVehicle(VEHICLEID);
	
	//Create Vehicle
	vehicle := self.addVehicle( VEHICLEID, carrier, terminal);
	self.assertNotNullMsg(vehicle, "vehicle");
	
	//Delete Driver Details
	self.deleteDriverDetails(DRIVERID);
	
	create allCarriers transient;
	allCarriers.add(carrier);
	create allVehicleMachines transient;
	allVehicleMachines.add(vehicle);
	
	//Create driver details
	driver := self.createDriverDetails(DRIVERID, allCarriers, allVehicleMachines);
	self.assertNotNullMsg(driver, "driver");
	
	startTime.setTime(vbsSlotType.startTime);
	startTime.setDate(date.cnEcAddDays(1));
	
	endTime.setTime(vbsSlotType.startTime.addMinutes(vbsSlotType.duration));
	endTime.setDate(date.cnEcAddDays(1));
	
	//Delete VBS Slot &amp; Item using Release Request By Weight
	terminalUTHelper.xDeleteVbsTimeSlot(UT_TimeSlotId1, vehicleBookingTerminal);
	
	//Create VBS Slot &amp; Item using Release Request By Weight
	create pxyVbsTimeSlotItem transient;
	
	pxyVbsTimeSlotItem.setProxy(DIRECTION_DELIVERY,
							null,
							null,
							releaseRequestByWeight,
							releaseRequestByWeight.allReserveDetails.first,
							null,
							null,
							null,
							0,
							UT_SourceTypeRelease,
							1000,
							0,
							500);	// ### TFS 61525 (61527) 11Jul2024 NAVPW1
	
	create pxyVbsTimeSlot transient;
	pxyVbsTimeSlot.allVehicleBookingItems.add(pxyVbsTimeSlotItem);
	
	realVbsTimeSlotByWeight := terminalUTHelper.xCreateVbsTimeSlot(pxyVbsTimeSlot, startTime, endTime, vehicleBookingTerminal, carrier, null, driver, vehicle, self.createdByUnitTest(null), true,
														false, null, null, vbsSlotType, UT_TimeSlotId1, null, null, null, vbsSlotType.preGateInCheck, vbsSlotType.preGateOutCheck, vbsSlotType.kioskCheck, null, null);
	self.assertNotNullMsg(realVbsTimeSlotByWeight, "Create: realVbsTimeSlotByWeight");
	
	delete pxyVbsTimeSlot;
	
	//Delete VBS Slot &amp; Item using Release Request By Quantity
	terminalUTHelper.xDeleteVbsTimeSlot(UT_TimeSlotId2, vehicleBookingTerminal);
	
	//Create VBS Slot &amp; Item using Release Request By Quantity
	create pxyVbsTimeSlotItem transient;
	
	pxyVbsTimeSlotItem.setProxy(DIRECTION_DELIVERY,
							null,
							null,
							releaseRequestByQuantity,
							releaseRequestByQuantity.allReserveDetails.first,
							null,
							null,
							null,
							0,
							UT_SourceTypeRelease,
							0,
							0,
							500);	// ### TFS 61525 (61527) 11Jul2024 NAVPW1
	
	create pxyVbsTimeSlot transient;
	pxyVbsTimeSlot.allVehicleBookingItems.add(pxyVbsTimeSlotItem);
	
	realVbsTimeSlotByQuantity := terminalUTHelper.xCreateVbsTimeSlot(pxyVbsTimeSlot, startTime, endTime, vehicleBookingTerminal, carrier, null, driver, vehicle, self.createdByUnitTest(null), true,
														false, null, null, vbsSlotType, UT_TimeSlotId2, null, null, null, vbsSlotType.preGateInCheck, vbsSlotType.preGateOutCheck, vbsSlotType.kioskCheck, null, null);
	self.assertNotNullMsg(realVbsTimeSlotByQuantity, "Create: realVbsTimeSlotByQuantity");
	
	/*
	** Test 1: Road Gate One VBS Slot, Release By Type by Weight
	*/
	//Setup
	
	//Run
	
	//Create VVR
	terminalUTHelper.opts.purge;
	terminalUTHelper.opts.addAssoc(UT_OPTS_Carrier, carrier.code);
	terminalUTHelper.opts.addAssoc(UT_OPTS_SubCarrier, subCarrier);
	
	vvr := terminalUTHelper.xCreateVehicleVisitRecord(vehicle.regNumber, driver.code, driver.name, null, terminal, self.dualGate.name);
	
	//Attach VBS Slot to VVR
	realVbsTimeSlotByWeight := terminalUTHelper.xUpdateVbsTimeSlot(realVbsTimeSlotByWeight, startTime, endTime, vehicleBookingTerminal, carrier, null, driver, vehicle, self.createdByUnitTest(null), true,
														false, null, vvr, vbsSlotType, UT_TimeSlotId1, null, null, null, vbsSlotType.preGateInCheck, vbsSlotType.preGateOutCheck, vbsSlotType.kioskCheck, null, null);
	self.assertNotNullMsg(realVbsTimeSlotByWeight, "Update: realVbsTimeSlotByWeight");
	
	//Gate in Container against Vbs Time Slot
	terminalUTHelper.opts.purge;
	terminalUTHelper.opts.addAssoc(UTTI_CargoSubType, product);
	terminalUTHelper.opts.addAssoc("_direction", Release);
	terminalUTHelper.opts.addAssoc(UT_OPTS_ReleaseRequest, releaseRequestByWeight);
	terminalUTHelper.opts.addAssoc(UT_OPTS_ReserveDetail, releaseRequestByWeight.allReserveDetails.first);
	terminalUTHelper.opts.addAssoc(UT_OPTS_ReleaseById, false);
	terminalUTHelper.opts.addAssoc(UT_OPTS_Vbsti, realVbsTimeSlotByWeight.allVehicleBookingItems.first);
	terminalUTHelper.opts.addAssoc(UT_OPTS_ReleaseWeight, 500.00.Decimal);
	terminalUTHelper.opts.addAssoc(UT_OPTS_ReleaseQuantity, 0);
	terminalUTHelper.opts.addAssoc(UT_OPTS_IsAnyId, true);
	terminalUTHelper.opts.addAssoc(UT_OPTS_IsAnyAmount, true);
	
	vvr := terminalUTHelper.xCreateGateEntityRelTemp(vvr, UT_CargoTypeAbbr, null, null, utOperator.code, null);
	//vvr := terminalUTHelper.xCreateGateEntityOutRelease(vvr, null, null, 50, truckReleaseRequest);
	
	//Assert
	self.assertEqualMsg(vvr.vehicle.allRoadJobs.size, 1, "Too many road jobs");
	
	foreach roadJob in vvr.vehicle.allRoadJobs as CM_RoadJob do
		self.assertEqualMsg(roadJob.workListEntries.size, 1, "Expected 1 Work list entry");
		self.assertEqualMsg(roadJob.workListEntries.first.status, JOB_UNACTIONED, "Expected Job to be unactioned");
		self.assertTrueMsg(roadJob.workListEntries.first.myRequest.isKindOf(CM_DeliveryRequest), "Expecting a Delivery Request request");
	endforeach;
	
	//Assert Gate Entity
	self.assertEqualMsg(vvr.allGateEntities.size, 1, "Too many gate entities");
	gateEntity := vvr.allGateEntities.first;
	self.assertNotNullMsg(gateEntity, "gateEntity");
	self.assertTrueMsg(gateEntity.isKindOf(CMGTE_Release), "Expected: type to be 'CMGTE_Release' | Actual: '" &amp; gateEntity.class.name &amp; "'");
	self.assertTrueMsg(gateEntity.isRelease, "Expected gate entity to be a release gate entity");
	
	gateEntityRelease := gateEntity.CMGTE_Release;
	
	self.assertNotNullMsg(gateEntityRelease.myBulkRelease, "gateEntityRelease.myBulkRelease");
	self.assertTrueMsg(gateEntityRelease.myBulkRelease = releaseRequestByWeight, "Gate Entity assigned release request does not match the release request expected. Expected: '" &amp; UT_ReleaseRequestByWeight &amp; "' | Acutal: '" &amp; gateEntityRelease.myBulkRelease.code &amp; "'");
	self.assertNotNullMsg(gateEntityRelease.myReserveDetail, "gateEntityRelease.myReserveDetail");
	self.assertTrueMsg(gateEntityRelease.myReserveDetail = releaseRequestByWeight.allReserveDetails.first, "Gate Entity reserve detail is not the same as the one on the release request");
	self.assertTrueMsg(gateEntityRelease.releaseWeight = 500, "Expected releaseWeight to be '500' | Actual: '" &amp; gateEntityRelease.releaseWeight.asStringJMT() &amp; "'");
	self.assertTrueMsg(gateEntityRelease.releaseQuantity = 0, "Expected releaseQuantity to be '0' | Actual: '" &amp; gateEntityRelease.releaseQuantity.asStringJMT() &amp; "'");
	self.assertTrueMsg(gateEntityRelease.getIsAnyId, "Expected isAnyId to be 'true' | Actual: '" &amp; gateEntityRelease.getIsAnyId.asStringJMT() &amp; "'");
	self.assertTrueMsg(gateEntityRelease.getIsAnyAmount, "Expected isAnyAmount to be 'true' | Actual: '" &amp; gateEntityRelease.getIsAnyAmount.asStringJMT() &amp; "'");
	
	self.assertNotNullMsg(gateEntityRelease.myVbsti, "gateEntityRelease.myVbsti");
	self.assertTrueMsg(gateEntityRelease.myVbsti.myBulkRelease = releaseRequestByWeight, "Vbs Slot Item assigned release request does not match the release request expected. Expected: '" &amp; UT_ReleaseRequestByWeight &amp; "' | Acutal: '" &amp; gateEntityRelease.myVbsti.myBulkRelease.code &amp; "'");
	self.assertTrueMsg(gateEntityRelease.myVbsti.myReserveDetails = releaseRequestByWeight.allReserveDetails.first, "Vbs Slot Item assigned reserve detail is not the same as the one on the release request");
	
	self.assertNotNullMsg(gateEntityRelease.myVbsti.myVehicleBookingSlot, "gateEntityRelease.myVbsti.myVehicleBookingSlot");
	self.assertTrueMsg(gateEntityRelease.myVbsti.myVehicleBookingSlot.id = UT_TimeSlotId1, "Vehicle Booking Timeslot Assigned to Gate Entity. Expected: '" &amp; UT_TimeSlotId1 &amp; "' | Actual: '" &amp; gateEntityRelease.myVbsti.myVehicleBookingSlot.id &amp; "'");
	
	/*
	** Test 2: One VBS Slot, Release By Type by Quantity
	*/	
	//Setup
	
	//Run
	
	//Assert
	
	/*
	** Test 3: One VBS Slot, Muleiple Release By Type by Weight items
	*/
	//Setup
	
	//Run
	
	//Assert
	
	/*
	** Test 4: One VBS Slot, Multiple Release By Type by Quantity items
	*/	
	//Setup
	
	//Run
	
	//Assert
	
epilog
	beginTransaction;
	terminal.setPropertyValue(CM_Terminal::myVBSProcess.name, app.myRoot.allVBSProcesses[CM_VBSProcess.VBS_STANDARD_CODE]);
	commitTransaction;
	
	delete allCarriers;
	delete email;
	delete allVehicleMachines;
	delete pxyVbsTimeSlot;
	delete terminalUTHelper;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tVbsSlotItemMaxWeight" id="ac9b295e-31a4-4ab0-9705-11317a6ebbe4">
        <updating/>
        <source>tVbsSlotItemMaxWeight() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
15 July 2024	navpw1	Initial creation TFS: 61525 (61527)
08 Aug 2024 	navcs2	ChangeRequest 63928: EUP | Trailer Type in a VBS Slot

*/

constants
	REF					: String = "61525";
	CARRIERCODE			: String = REF &amp; "CAR";
	SUBCARRIERCODE		: String = REF &amp; "SUB";
	DRIVERID			: String = REF &amp; "DRIVER";
	VEHICLEID 			: String = REF &amp; "VEHICLE";
	UT_TimeSlotTypeId	: String = REF;
	UT_ReleaseRequestByWeight	: String = "Rel" &amp; REF;
	UT_ReleaseRequestByQuantity	: String = "Rel" &amp; REF &amp; "1";
	UT_CargoTypeAbbr	: String = "STEEL COIL";
	UT_ProductCode		: String = "ROLLS";
	UT_Remarks			: String = "Testing " &amp; REF;
	
	UT_TimeSlotId1		: String = "IDUT" &amp; REF &amp; "1";
	UT_TimeSlotId2		: String = "IDUT" &amp; REF &amp; "2";
	UT_TimeSlotId3		: String = "IDUT" &amp; REF &amp; "3";
	UT_TimeSlotId4		: String = "IDUT" &amp; REF &amp; "4";
	UT_SourceTypeRelease	: Integer = 2;
	
vars
	realVbsTimeSlot1,
	pxyVbsTimeSlot			: CM_VehicleBookingTimeSlot;
	vbsSlotType				: CM_VehicleBookingTimeSlotType;
	date					: Date;
	startTime,
	endTime					: TimeStamp;
	vehicleBookingTerminal	: CM_VehicleBookingTerminal;
	carrier					: CM_Carrier;
	subCarrier				: CM_Carrier;
	driver					: CM_DriverDetails;
	vehicle					: CM_Vehicle;
	allCarriers 			: CM_CarrierByCodeDict;	
	allVehicleMachines 		: CM_VehicleSet; 
	email					: CM_EmailEntityByTypeNameDict;
	terminalUTHelper		: UT_HelperAdmTerm;
	releaseRequestByWeight,
	releaseRequestByQuantity		: CM_BulkRelease;
	pxyReserveSelectionByWeight,
	pxyReserveSelectionByQuantity	: CM_ReserveSelection;
	cargoType				: CM_CargoType;
	product					: CM_Product;
	terminal				: CM_Terminal;
	vvr						: CM_VehicleVisitRecord;
	utOperator				: CM_Operator;
	pxyVbsTimeSlotItem			: CM_VehicleBookingTimeSlotItem;
	
begin
	//Get Terminal
	terminal := self.getTerminal();
	self.assertNotNullMsg(terminal, "terminal");
	
	beginTransaction;
	terminal.setPropertyValue(CM_Terminal::myVBSProcess.name, app.myRoot.allVBSProcesses[CM_VBSProcess.VBS_SLVALIDATION_CODE]);
	commitTransaction;
	
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_WorkOrders::iRelTransChangeRoadToShip2;
	
	//Delete Vbs Time Slot
	self.deleteVbsTimeSlotAdv(UT_TimeSlotId1);
	
	//Get Vehicle Booking Terminal
	vehicleBookingTerminal := terminal.myVehicleBookingTerminal;
	self.assertNotNullMsg(vehicleBookingTerminal, "vehicleBookingTerminal");
	
	//Get Cargo Type
	cargoType := self.getCargoTypeByAbbrv(UT_CargoTypeAbbr);
	self.assertNotNullMsg(cargoType, "cargoType");
	
	//Get Product
	product := cargoType.allProducts.getAtKeyGeq(null, UT_ProductCode);
	self.assertNotNullMsg(product, "product");
	
	//Get Operator
	utOperator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(utOperator, "operator");
	
	//Delete VBS SlotType
	self.deleteVbsTimeslotType(UT_TimeSlotTypeId);
	
	//Create VBS Slot Type
	vbsSlotType := self.addVbsTimeslotType(UT_TimeSlotTypeId, "Slot Type Create" &amp; UT_TimeSlotTypeId); 
	self.assertNotNullMsg(vbsSlotType, "vbsSlotType");
	
	//Delete Carrier
	self.deleteCarrier(CARRIERCODE);
	
	//Delete Sub Carrier
	self.deleteCarrier(SUBCARRIERCODE);
	
	//Create Carrier
	carrier := self.addCarrier(CARRIERCODE, CARRIERCODE, email, false, true, true, null);
	self.assertNotNullMsg(carrier, "carrier");
	
	//Create Sub Carrier
	subCarrier := self.addCarrier(SUBCARRIERCODE, SUBCARRIERCODE, email, false, true, true, null);
	self.assertNotNullMsg(subCarrier, "subCarrier");
	
	//Delete Release Request By Weight
	self.deleteReleaseRequest(UT_ReleaseRequestByWeight);
	
	//Create Release Request By Weight
	terminalUTHelper.opts.purge;
	terminalUTHelper.opts.addAssoc(UT_OPTS_WeightRequested, 1000);
	pxyReserveSelectionByWeight := terminalUTHelper.xCreateReserveSelection(cargoType, product, null, null, null, null);
	releaseRequestByWeight := terminalUTHelper.xCreateReleaseRequest(UT_ReleaseRequestByWeight, BR_TYPE_ROAD, true, terminal, pxyReserveSelectionByWeight);	// Create a release request/bulk release. Release by Type
	self.assertNotNullMsg(releaseRequestByWeight, "releaseRequestByWeight");
	
	//Delete Release Request By Quantity
	self.deleteReleaseRequest(UT_ReleaseRequestByQuantity);
	
	//Create Release Request By Quantity
	terminalUTHelper.opts.purge;
	pxyReserveSelectionByQuantity := terminalUTHelper.xCreateReserveSelection(cargoType, product, null, 100, null, null);
	releaseRequestByQuantity := terminalUTHelper.xCreateReleaseRequest(UT_ReleaseRequestByQuantity, BR_TYPE_ROAD, true, terminal, pxyReserveSelectionByQuantity);	// Create a release request/bulk release. Release by Type
	self.assertNotNullMsg(releaseRequestByQuantity, "releaseRequestByQuantity");
	
	
	create email transient;
	
	//Delete Vehicle
	self.deleteVehicle(VEHICLEID);
	
	//Create Vehicle
	vehicle := self.addVehicle( VEHICLEID, carrier, terminal);
	self.assertNotNullMsg(vehicle, "vehicle");
	
	//Delete Driver Details
	self.deleteDriverDetails(DRIVERID);
	
	create allCarriers transient;
	allCarriers.add(carrier);
	create allVehicleMachines transient;
	allVehicleMachines.add(vehicle);
	
	//Create driver details
	driver := self.createDriverDetails(DRIVERID, allCarriers, allVehicleMachines);
	self.assertNotNullMsg(driver, "driver");
	
	startTime.setTime(vbsSlotType.startTime);
	startTime.setDate(date.cnEcAddDays(1));
	
	endTime.setTime(vbsSlotType.startTime.addMinutes(vbsSlotType.duration));
	endTime.setDate(date.cnEcAddDays(1));
	
	
	/*
	** Test 1: VBS Slot Item Validation, Release By Type by Weight
	** Purpose: To test the exceptions that should be raised from the vehicle booking timeslot.
	*/
	//Setup
	
	//Create VBS Time Slot Item	
	create pxyVbsTimeSlotItem transient;
	
	pxyVbsTimeSlotItem.setProxy(DIRECTION_DELIVERY,
							null,
							null,
							releaseRequestByWeight,
							releaseRequestByWeight.allReserveDetails.first,
							null,
							null,
							null,
							0,
							UT_SourceTypeRelease,
							0,
							0,
							null);	// ### TFS 61525 (61527) 11Jul2024 NAVPW1
	
	//Create VBS Time Slot
	create pxyVbsTimeSlot transient;
	pxyVbsTimeSlot.allVehicleBookingItems.add(pxyVbsTimeSlotItem);
	
	pxyVbsTimeSlot.setProxy(startTime, endTime, vehicleBookingTerminal, carrier, null, driver, vehicle, UT_Remarks, true,
														false, null, null, vbsSlotType, UT_TimeSlotId1, null, null, null, vbsSlotType.preGateInCheck, vbsSlotType.preGateOutCheck, vbsSlotType.kioskCheck, null, null);	// 08 Aug 2024 navcs2	ChangeRequest 63928
	
	self.expectedTrxErrors.add(Vbs_max_weight_required);
	app.myTrxCA.trxCreateVehicleBookingAdv(pxyVbsTimeSlot, realVbsTimeSlot1,false, app.myPassport);
	
	//Trx should fail and raise an exception
	self.assertIncludesExceptions();
	
	delete pxyVbsTimeSlot;
	
	
	/*
	** Test 2: VBS Slot Item Validation, Release By Type by Quantity
	** Purpose: To test the exceptions that should be raised from the vehicle booking timeslot.
	**Vbs_max_weight_quanti_required
	**Vbs_max_weight_quan_both_enter
	*/
	//Setup
	self.expectedTrxErrors.clear();
	
	//Create VBS Time Slot Item	
	create pxyVbsTimeSlotItem transient;
	
	pxyVbsTimeSlotItem.setProxy(DIRECTION_DELIVERY,
							null,
							null,
							releaseRequestByQuantity,
							releaseRequestByQuantity.allReserveDetails.first,
							null,
							null,
							null,
							0,
							UT_SourceTypeRelease,
							0,
							0,
							null);	// ### TFS 61525 (61527) 11Jul2024 NAVPW1
	
	//Create VBS Time Slot
	create pxyVbsTimeSlot transient;
	pxyVbsTimeSlot.allVehicleBookingItems.add(pxyVbsTimeSlotItem);
	
	pxyVbsTimeSlot.setProxy(startTime, endTime, vehicleBookingTerminal, carrier, null, driver, vehicle, UT_Remarks, true,
														false, null, null, vbsSlotType, UT_TimeSlotId2, null, null, null, vbsSlotType.preGateInCheck, vbsSlotType.preGateOutCheck, vbsSlotType.kioskCheck, null, null);		// 08 Aug 2024 navcs2	ChangeRequest 63928
	
	self.expectedTrxErrors.add(Vbs_max_weight_quanti_required);
	app.myTrxCA.trxCreateVehicleBookingAdv(pxyVbsTimeSlot, realVbsTimeSlot1,false, app.myPassport);
	
	//Trx should fail and raise an exception
	self.assertIncludesExceptions();
	
	return;
	
	delete pxyVbsTimeSlot;
	
	/*
	** Test 3: VBS Slot Item Validation, Release By Type by Quantity
	** Purpose: To test the exceptions that should be raised from the vehicle booking timeslot.
	**Vbs_max_weight_quan_both_enter
	*/
	//Setup
	self.expectedTrxErrors.clear();
	
	//Create VBS Time Slot Item	
	create pxyVbsTimeSlotItem transient;
	
	pxyVbsTimeSlotItem.setProxy(DIRECTION_DELIVERY,
							null,
							null,
							releaseRequestByQuantity,
							releaseRequestByQuantity.allReserveDetails.first,
							null,
							null,
							100,
							0,
							UT_SourceTypeRelease,
							0,
							0,
							1000.00);	// ### TFS 61525 (61527) 11Jul2024 NAVPW1
	
	//Create VBS Time Slot
	create pxyVbsTimeSlot transient;
	pxyVbsTimeSlot.allVehicleBookingItems.add(pxyVbsTimeSlotItem);
	
	pxyVbsTimeSlot.setProxy(startTime, endTime, vehicleBookingTerminal, carrier, null, driver, vehicle, UT_Remarks, true,
														false, null, null, vbsSlotType, UT_TimeSlotId3, null, null, null, vbsSlotType.preGateInCheck, vbsSlotType.preGateOutCheck, vbsSlotType.kioskCheck, null, null); // 08 Aug 2024 navcs2	ChangeRequest 63928
	
	self.expectedTrxErrors.add(Vbs_max_weight_quan_both_enter);
	app.myTrxCA.trxCreateVehicleBookingAdv(pxyVbsTimeSlot, realVbsTimeSlot1,false, app.myPassport);
	
	//Trx should fail and raise an exception
	self.assertIncludesExceptions();
	
	return;
	
	delete pxyVbsTimeSlot;
	
	/*
	** Test 4: Road Gate One VBS Slot, Release By Type by Weight
	*/
	//Setup
	
	//Create VVR
	terminalUTHelper.opts.purge;
	terminalUTHelper.opts.addAssoc(UT_OPTS_Carrier, carrier);
	terminalUTHelper.opts.addAssoc(UT_OPTS_SubCarrier, subCarrier);
	
	vvr := terminalUTHelper.xCreateVehicleVisitRecord(vehicle.regNumber, driver.code, driver.name, null, terminal, self.dualGate.name);
	
	//Create VBS Time Slot
	create pxyVbsTimeSlot transient;
	
	realVbsTimeSlot1 := terminalUTHelper.xCreateVbsTimeSlot(pxyVbsTimeSlot, startTime, endTime, vehicleBookingTerminal, carrier, null, driver, vehicle, UT_Remarks, true,
														false, null, null, vbsSlotType, UT_TimeSlotId1, null, null, null, vbsSlotType.preGateInCheck, vbsSlotType.preGateOutCheck, vbsSlotType.kioskCheck, null, null);
	self.assertNotNullMsg(realVbsTimeSlot1, "Create: realVbsTimeSlot1");
	
	//Attach VBS Slot to VVR
	realVbsTimeSlot1 := terminalUTHelper.xUpdateVbsTimeSlot(realVbsTimeSlot1, startTime, endTime, vehicleBookingTerminal, carrier, null, driver, vehicle, UT_Remarks, true,
														false, null, vvr, vbsSlotType, UT_TimeSlotId1, null, null, null, vbsSlotType.preGateInCheck, vbsSlotType.preGateOutCheck, vbsSlotType.kioskCheck, null, null);	
	self.assertNotNullMsg(realVbsTimeSlot1, "Update: realVbsTimeSlot1");
	
	//Gate in Container against Vbs Time Slot
	terminalUTHelper.opts.purge;
	terminalUTHelper.opts.addAssoc(UTTI_CargoSubType, product);
	terminalUTHelper.opts.addAssoc("_direction", Release);
	terminalUTHelper.opts.addAssoc(UT_OPTS_ReleaseRequest, releaseRequestByWeight);
	terminalUTHelper.opts.addAssoc(UT_OPTS_ReserveDetail, releaseRequestByWeight.allReserveDetails.first);
	terminalUTHelper.opts.addAssoc(UT_OPTS_ReleaseById, false);
	
	vvr := terminalUTHelper.xCreateGateEntity(vvr, UT_CargoTypeAbbr, null, null, utOperator.code, null);
	
	
	//Run
	
	
	
	
	//Assert
	
	
	/*
	** Test 2: One VBS Slot, Release By Type by Quantity
	*/	
	//Setup
	
	//Run
	
	//Assert
	
	/*
	** Test 3: One VBS Slot, Muleiple Release By Type by Weight items
	*/
	//Setup
	
	//Run
	
	//Assert
	
	/*
	** Test 4: One VBS Slot, Multiple Release By Type by Quantity items
	*/	
	//Setup
	
	//Run
	
	//Assert
	
epilog
	beginTransaction;
	terminal.setPropertyValue(CM_Terminal::myVBSProcess.name, app.myRoot.allVBSProcesses[CM_VBSProcess.VBS_STANDARD_CODE]);
	commitTransaction;
	
	delete allCarriers;
	delete email;
	delete allVehicleMachines;
	delete pxyVbsTimeSlot;
	delete terminalUTHelper;
	
end;</source>
    </JadeMethod>
