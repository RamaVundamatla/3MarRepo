    <JadeMethod name="translateForm" id="ed45b818-424e-490b-831c-885e1f639a8d">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017593, locale);
	btnBackground.translateBubbleHelp(Xlat_0002314, locale);
	btnBackground.translateCaption(Xlat_0002316, locale);
	btnNextT.translateBubbleHelp(Xlat_0002315, locale);
	btnNextT.translateCaption(Xlat_0002317, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0006302, locale);
	mnuTblSelDataContext.translateCaption(Xlat_0006303, locale);
	mnuTblSelDataDeselect.translateCaption(Xlat_0006304, locale);
	mnuTblSelDataSelect.translateCaption(Xlat_0006305, locale);
	optDocket.translateCaption(Xlat_0002318, locale);
	optLocation.translateCaption(Xlat_0002319, locale);
	optLogId.translateCaption(Xlat_0002320, locale);
	optSpecs.translateCaption(Xlat_0002321, locale);
end;</source>
    </JadeMethod>
