    <JadeMethod name="loadNewDrawingAttribute" id="0a74a9d9-06ee-49df-a2fe-b6b912f2a2d4">
        <source>loadNewDrawingAttribute();
vars
	aJS : JadeScript;
	aDT : CM_DrawingAttribute;
	idx : Integer;
	theStringArray,theNameArray : StringArray;
	theIntegerArray,theColArray : IntegerArray;
	theRoot : CM_Root;
begin
	theRoot := CM_Root.firstInstance;
	
	create theStringArray transient;
	create theIntegerArray transient;
	create theNameArray transient;
	create theColArray transient;

	theStringArray.add(PicTACrane); theIntegerArray.add(169); theColArray.add(16711680); theNameArray.add('Arial');	
	
	foreach idx in 1 to theStringArray.size do
		if theRoot.allDrawingAttributes[theStringArray[idx].trimBlanks] = null then
			beginTransaction;
			create aDT;
			aDT.myRoot := theRoot;
			aDT.fontName := theNameArray[idx];
			aDT.fontCharacter := theIntegerArray[idx];
			aDT.code := theStringArray[idx].trimBlanks;
			aDT.colour := theColArray[idx];
			commitTransaction;
		endif;
	endforeach;	
	global.beep;
epilog
delete theIntegerArray;
delete theStringArray;
delete theColArray;
delete theNameArray;


end;</source>
    </JadeMethod>
    <JadeMethod name="loadSpecificTranslation2" id="b807e6c8-4828-48ec-8eb0-32cab9219a28">
        <source>loadSpecificTranslation2();
	//----------------------------------------------------------------------
	//
	//  Created by cnwsh3
	//
	//	Date 04 May 2007
	//
	//Adds a specific error message to a system.
	//
	// Usage: 	1. Ensure the new error message has been loaded in the patch definition
	//			2. Add the global constant as a string
	//
	// Designed to add the error message as per global constant and include it in all
	// the locales that exist on the system.
	//----------------------------------------------------------------------
	// Created on 15 January 2026.
vars
	transAgent : CM_TranslationAgent;
	sa : StringArray;
begin
	app.initialize;
	create transAgent transient;
	create sa transient;


	app.writeLog("sa.size: " &amp; sa.size.String, LogINFO);
	transAgent.trxLoadSpecificTranslations(sa);
	app.finalize;
epilog
	delete transAgent;
	delete sa;
end;</source>
