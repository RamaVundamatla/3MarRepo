    <JadeMethod name="buildFile" id="91d94d0d-1730-431d-8e46-653a249c1821">
        <updating/>
        <source>buildFile(_camProtocol: CM_CamProtocol input; _camAgent : CM_CamControllerAgent input; _seqNumber :Integer; _unhSeqNumber : Integer io; _terminal : CM_Terminal) updating;

// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26 june 2008 concms1		par 17268 - CAMs messages by freight forwarder
// 21 May 2012	cnwrs1		Par 26914 - make cam task transient and remove camprotocol::camTask cleanup
// 30/05/2012	cnwcs5		par 29601 - log reason for transactions being excluded
// 01 June 2012	cnwrs1		Par 26914 - make cams restart after lock error
// 26/06/0212	cnwcs5		par 29601 - log excluded transactions
// 18 Jul 2012	cnwrs1		CCMS 1269 CAMS remove CM_CamTask
// 26/07/2012	cnwcs5		par 29601/3 - minor changes after test run
// 30 Jul 2012	cnwrs1		CCMS 1269 CAMS remove CM_CamTask
// 11/12/2012	cnwcs5		CCMS SFW 1294 / par 30855 - use CAMS timestamp instead of transaction timestamp
// 25 Mar 2013	cnwrs1		CCMS SFW 1294 Testing - not failing after exception in cam task history
// 25 Jun 2013	cnwrs1		Par 31047 - add Enviroment Terminal and Protocol to Cams Alerts
// 19 Nov 2014	cnwrs1	 	CCMS 2405 - Alabama Steel Cams
// 06 Mar 2015	cnwrs1		Par35784 - increased exclusion reason logging to include non excluded
// 31 Mar 2015	cnwrs1		Par 36680 - make single transaction per file work for UN/EDIFACT
// 25 May 2016	cnwrs1		get SingleTransPerFile setting working with Adhoc
// 09 Jan 2020	jlgdap1		TFS 48016 SNO Deletion CODECO - retain unh sequence nbr on road receive transaction
// 13/02/2020	jlgka1		48550 Add booking number in the externalReferenceId
// 12/03/2020	jlgdap1		TFS 48785 SNO COARRI Issue - new parameter for CM_CamProtocolDesc includeTransaction
// 01/04/2020	jlgdap1		TFS 48911 SNO Deletion CODECO - correct sequence number saving
// 15/05/2020	jlgdap1		TFS 49371 SNO BGM Sequence correctinos to cater for ad-hoc vs scheduled 
//							and messages for a mixture of voyages
// 20/10/2020   cnwma1		Bug 50149: GPHA - CAMS file names not unique when "Single Transaction per File" in enabled
// 22 Apr 2024	jlirs1	TFS 63766 Cams issues with Jade deferred update
//02 Jan 2024	navnk30		MTN-33424: SNO - Transaction filter set to 'EMPTY CONTAINERS' does NOT work in STANDARD CODECO SMDG162 Cam Protocol
// ---------------------------------------------------------------------------
vars
	camFile 				: CM_CamFile;
	camGroup				: CM_CamGroup;
	transaction 			: CM_TITransaction;
	camTaskHistory 			: CM_CamTaskHistory;
	startTS, endTS			: TimeStamp;
	qfFilteredTITrxItems	: CM_TITransactionByDateTypeDict;
//	coll					: CM_TITransactionByDateTypeDict;
	coll					: CM_TITransactionByDtOrdTiDict;	//13 Aug 2020	NDL	TFS 49876
	typeColl				: IntegerArray;
	iter 					: Iterator;
	logExcludedTransaction	: Boolean;		// par 29601
	str						: String;
	type					: Integer;
	seqNo					: Integer;
	isFirstTime				: Boolean;
	processTransSingleMode : Boolean;
	camMessage				: CM_CamMessage;			//30 Apr 2018	NDL	TFS 37406
	txSet 					: CM_TITransactionSet;		// TFS 48016
	useDailyFileName        : Boolean;
	camTrxTemplate			: CMQF_CamTransactionTemplate;
	qfCam					: CMQF_CamTransactionQuery;
begin
	seqNo			:= _seqNumber;
	isFirstTime 	:= 	true;

	if _camProtocol&lt;&gt; null and _camProtocol.camGroup &lt;&gt; null  then  //20.10.2020 cnwma1 #50149
		if _camProtocol.camGroup.useDailyFileName then
			useDailyFileName := true;
		endif;		
	endif;
	
	processTransSingleMode := false;
    if self.isEventType() then //cnwgb1 PAR 34561, 34883 CCMS 2346 Suzano confirmations
        self.buildEventFile(_camProtocol, _camAgent, _seqNumber, _unhSeqNumber, _terminal);
		if not _camProtocol.protocolDesc.isAlsoTransactionType then
			return;
		endif;
    endif;
    
	create camFile transient;
	camFile.myCamControllerAgent := _camAgent;	// 22 Apr 2024	jlirs1	TFS 63766 Cams issues with Jade deferred update
	create coll transient;
	
	camGroup				:= _camProtocol.camGroup;				// par 29601 Jane 2012
	startTS					:= _camAgent.startDateTime;				// par 29601 June 2012
	endTS					:= _camAgent.endDateTime;				// par 29601 June 2012
	logExcludedTransaction	:= _camAgent.logExcludedTransactions;	// par 29601 June 2012
	
	iter 	:= _terminal.allTITransactionsByCamsTS.createIterator();

	create typeColl transient;
	create txSet transient;								// TFS 48016
	
	self.getTransactionTypesToProcess (_camProtocol, typeColl);
	
	// build up colection with all transactions os required type/dates in a collection
	foreach type in typeColl do
		// str in the transaction type (integer)
		iter.reset;
		
		_terminal.allTITransactionsByCamsTS.startKeyGeq(type, startTS, iter);
		
		while iter.next (transaction) do
			if transaction.type &lt;&gt; type or
				transaction.camsTimeStamp &gt; endTS then 
				break;
			endif;
			
			coll.add (transaction);
		endwhile;
	endforeach;
	
	delete iter;
	
	iter := coll.createIterator;
	
	camTrxTemplate := _camProtocol.myQFCamTransactionTemplate;		//02.01.2024 navnk30 JIRA 33424 START
	create qfFilteredTITrxItems transient;
	if camTrxTemplate &lt;&gt; null then
		qfCam := camTrxTemplate.cloneSelfAs(CMQF_CamTransactionQuery, true).CMQF_CamTransactionQuery;
		qfCam.cloneReferences(camTrxTemplate, true);
		qfCam.setQueryFromCams(_terminal, _camProtocol, _camAgent);
		qfCam.filterObjects(qfFilteredTITrxItems, app.myPassport);
	endif;															//02.01.2024 navnk30 JIRA 33424 END
	
	// remove load state to prevent contention (refer also PAR-15593)
	//externalRefId := _unhSeqNumber;												// TFS 48911		// TFS 49371
	while iter.next(transaction) do	
		if camTrxTemplate &lt;&gt; null and not qfFilteredTITrxItems.includes(transaction) then	//02.01.2024 navnk30 JIRA 33424
			continue;
		endif;
		
		// makes sense to exclude transaction of the incorrect type 1st
		if self.includeTransaction (transaction, transaction.camsTimeStamp, startTS, endTS, 
									_camProtocol, camGroup, _camAgent, logExcludedTransaction, null) then	// par 29601 June 2012	// TFS 48785
			if _camAgent.isProcessAsSingleTransPerFile(_camProtocol) then
				if self.isTransactionToBeProcessed(_camProtocol, transaction, _camAgent) then 
					processTransSingleMode := true;
					if _camAgent.logIncludedTransactions then
						_camAgent.logReasonForInclusion(transaction, "Transaction is correct time period and in Transaction Type list");
					endif;
					if not isFirstTime then
						self.createNextCamTaskHistory(_camAgent, _camProtocol, seqNo);	
					endif;
					isFirstTime := false;
					self.processTransaction(transaction, _camProtocol, _camAgent, camFile);				
					self.buildFileExtra (transaction, _camProtocol, _camAgent, camFile);
					camMessage := camFile.getFirstCamMessage();	//30 Apr 2018	NDL	TFS 37406
					txSet.add(transaction);																																					// TFS 48016
					//app.myTrxUA.trxSetupCamTaskHistory(_camProtocol, _camAgent, camFile, _camAgent.runDateTime, camTaskHistory, _unhSeqNumber, seqNo, _terminal, null, camMessage);		// TFS 48016
					app.myTrxUA.trxSetupCamTaskHistory(_camProtocol, _camAgent, camFile, _camAgent.runDateTime, camTaskHistory, _unhSeqNumber, seqNo, _terminal, null, camMessage, txSet);	// TFS 48016
					txSet.clear;																																							// TFS 48016
					self.retainRecDataOnTiTrx(transaction, _camProtocol.unhSequenceNum-1, transaction.myTrackedItem.bookingReference);																								// TFS 48106
					camFile.clear();
					if _camAgent.isAdhoc then
						_camAgent.incrementDailySeqNumber();
					else
						seqNo := seqNo + 1;
						_camAgent.setProcessSeqNumber(seqNo);
						if useDailyFileName then                       //20.10.2020 cnwma1 #50149
							_camAgent.incrementDailySeqNumber();
						endif;
					endif;
				endif;
			else
				// reasons for excluding have been logged in self.includeTransaction
				if self.isTransactionToBeProcessed(_camProtocol, transaction, _camAgent) then 												
					if _camAgent.logIncludedTransactions then
						_camAgent.logReasonForInclusion(transaction, "Transaction is correct time period and in Transaction Type list");
					endif;
					self.processTransaction(transaction, _camProtocol, _camAgent, camFile);				
					//externalRefId := externalRefId + 1;												// TFS 48016	// TFS 49371
					txSet.add(transaction);																// TFS 48016
					//self.retainRecDataOnTiTrx(transaction, externalRefId, transaction.myTrackedItem.bookingReference);	// TFS 48106	// TFS 49371
				endif;
				// some protocols do extra processing so this is implemented in the buildFileExtra method 
				self.buildFileExtra(transaction, _camProtocol, _camAgent, camFile);
			endif;
		endif;
	endwhile;
	
	// this next bt creates the CAMS file and updates the CAM protocol history
	if processTransSingleMode then
		self.createNextCamTaskHistory(_camAgent, _camProtocol, seqNo);	
	endif;
	//app.myTrxUA.trxSetupCamTaskHistory(_camProtocol, _camAgent, camFile, _camAgent.runDateTime, camTaskHistory, _unhSeqNumber, seqNo, _terminal, null, null);			// TFS 48016
	app.myTrxUA.trxSetupCamTaskHistory(_camProtocol, _camAgent, camFile, _camAgent.runDateTime, camTaskHistory, _unhSeqNumber, seqNo, _terminal, null, null, txSet);	// TFS 48016
	if (not app.myPassport.trxCompletedOK) then
		_camAgent.writeCrashLogAlertAndEmail(app.myPassport);
	endif;
epilog
	delete camFile;
	delete iter;
	delete coll;
	delete typeColl;
	delete txSet;				// TFS 48016
	delete qfCam;
	delete qfFilteredTITrxItems;
end;
</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol" usage="input"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_unhSeqNumber" type="Integer" usage="io"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="contentsStatusToString" id="6714305a-cc1c-48a8-83fc-c35880b6234a">
        <source>contentsStatusToString(_contentsStatus: Integer; _activity: Integer; _type: Integer): String;

vars
	contentsString:String;
begin
	if _contentsStatus = TI_CONTENTS_STATUS_EMPTY then
		contentsString := "4";
	elseif _contentsStatus =TI_CONTENTS_STATUS_FCL then
		contentsString := "5";
	elseif _contentsStatus = TI_CONTENTS_STATUS_LCL then
		contentsString := "5";
	else
		contentsString := "6";
	endif;
	return contentsString;
end;</source>
        <Parameter name="_contentsStatus" type="Integer"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAVGradeCodeAndDesc" id="3966977e-3edb-4bb0-b7a5-510932121b09">
        <source>getAVGradeCodeAndDesc(_ti : CM_TrackedItem; _avForeignCode : String output) : String protected;
/*

Purpose:	Centralise container Grade lookup for Coarri/Codeco	

Parameters:			

Return Value:		

Date		Who		Reason
22 Mar 2019	jlgsl4	TFS 41786 - SNO - Consistent FTX+DAR and DAM for Coarri/Codeco
20 May 2019 cnwma1	Bug 44797: SNO - Testing reference 7813
29 Mar 2021 cnwma1  Bug 51027: GPHA - Inconsistent FTX+DAR segment between COARRI and CODECO
*/

vars
	foundMatch   : Boolean;
	grade        : CM_MTGrade;
	avDesc 		 : String;
begin
	grade := app.myRoot.allAvailabilityGrades[_ti.getAvailabilityGrade];
	if grade &lt;&gt; null then
		avDesc       := grade.description;
		_avForeignCode := _ti.myOperator.getXlationForeignCode(grade.code.String, XLATION_TYPE_MTGRADE_BYOP, foundMatch);
	endif;
	
	if _avForeignCode = null then // 29.03.2021 cnwma1 #51027
		_avForeignCode := '0';
	endif;
	
	return avDesc;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_avForeignCode" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCamISOPortDesc" id="c13ca760-d887-4aa0-a69e-c4ea3113f08e">
        <source>getCamISOPortDesc(_protocol :CM_CamProtocol ):String;
/*
Return Value:	ISO port (used in some NAD segements)

Date		Who		Reason
17 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
vars
	code	:String;
begin
	code := _protocol.camISOPortDesc;
	
	if code = null then
		code := _protocol.terminal.getConfig(CamsISOPortDesc).String;
	endif;
	
	return code.trimBlanks;
epilog

end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCamMessageById" id="a2b81f49-c162-4045-887a-bcdc4a7c86ae">
        <source>getCamMessageById(_camFile : CM_CamFile input; _voyageCode, _vesselName : String; _messageType : Integer; _tiId : String) : CM_CamMessage;
// 12/05/2010	cnwcs5	par 23967 - change _camFile paremeter to be input not io so as to correctly reflect its usage
vars
	camVoyage : CM_CamVoyage;
	camMessage : CM_CamMessage;

begin
	camVoyage := _camFile.camVoyages[_voyageCode, _vesselName]; //par18987 cnwrs1 Mar 2009
	if camVoyage = null then
		create camVoyage transient;
		camVoyage.voyage := _voyageCode;
		camVoyage.vesselName := _vesselName; //par18987 cnwrs1 Mar 2009
		camVoyage.camFile := _camFile;

	endif;
	camMessage := camVoyage.camMessagesByTiId[_messageType, _tiId];
	if camMessage = null then
		create camMessage transient;
		camMessage.activity := _messageType;
		camMessage.tiId := _tiId;
		camMessage.camVoyage := camVoyage;
		camVoyage.camMessagesByTiId.add(camMessage);
		_camFile.camMessageByActivityVoyage.add(camMessage);

	endif;

	return camMessage;

end;</source>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_vesselName" type="String"/>
        <Parameter name="_messageType" type="Integer"/>
        <Parameter name="_tiId" type="String"/>
        <ReturnType type="CM_CamMessage"/>
    </JadeMethod>
