    <JadeMethod name="trxUpdateConnect" id="4cfbf380-3bc4-4cf8-a8c4-662a8c6f22d7">
        <updating/>
        <source>trxUpdateConnect(params : CMIF_ConnectParams io; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 18/09/2017	jlgmd1		TFS 6813 - QNS - Jade application slow
//
// ---------------------------------------------------------------------------
vars
	pxyTI	: CM_TrackedItem;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
		
	if params = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "Connection Parameters", null, null);
	endif;
	if params.allTrackedItems.size = 0 then
		app.raiseCMException2(MethodWithNullParam, method.name, "Connection Parameters: allTrackedItems", null, null);
	endif;	

	app.setContinueCMExceptions(false);
	
	_passport.useTITransactionDeferUpdate := true;		// TFS 6813
	_passport.useTIDictDeferUpdate := true;				// TFS 6813
		
	beginTransaction;
	
	foreach pxyTI in params.allTrackedItems do
		app.myUtilityUA.utlUpdateConnect(params, pxyTI, _passport);
 		if _passport.hasErrors() then
			return;
		endif;
	endforeach;
	
	if _passport.noErrors then				// TFS 6813
		_passport.doDeferredUpdates();		// TFS 6813
	endif;									// TFS 6813
	
epilog	
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="params" type="CMIF_ConnectParams" usage="io"/>
