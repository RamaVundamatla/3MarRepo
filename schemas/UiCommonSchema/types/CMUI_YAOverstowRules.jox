    <JadeMethod name="setupForm" id="c25f52b2-e357-4b81-9612-95211cb36503">
        <updating/>
        <source>setupForm() updating;
// -------------------------------------------
// Created 21 September 2005 by cnwdvb1
// -------------------------------------------
vars

	cmifAttribute		: CMIF_YAOverstowAttributeType;
//	overstowAttribute	: CM_YAOverstowAttribute;
	
begin
	self.centreOverParent(100);
	inheritMethod();
	self.setNavigatorHeading(self.caption);
	self.useTblThumb := true;
	self.zHideSearcher();
	self.btnShowSearchTV.visible := false;

	self.initMainTable();
	
	// Set up the imex status list box.
	self.lstImex.displayCollection(app.myRoot.allImexStatuses, false, 0, null);
	
	// Set up the attributes list box with cmif versions of available attribute types.
	self.buildCMIFOverstowAttribute(TI_Test_Carrier);
	self.buildCMIFOverstowAttribute(TI_Test_CommodityGroup);
	self.buildCMIFOverstowAttribute(TI_Test_Consignee);
	self.buildCMIFOverstowAttribute(TI_Test_DischargePort);
	self.buildCMIFOverstowAttribute(TI_Test_ImExStatus);
	self.buildCMIFOverstowAttribute(TI_Test_Operator);
	self.buildCMIFOverstowAttribute(TI_Test_Voyage);
	self.buildCMIFOverstowAttribute(TI_Test_Weight);

	self.lstAttributes.displayCollection(self.allAttributeTypes, false, 0, null);
	
	// Set up the later voyage combo.
	self.cmbVoyageLater.addItemWithData('Never',CM_YAOverstowRule.NeverOverstowLaterVoyage);
	self.cmbVoyageLater.addItemWithData('Last Resort', CM_YAOverstowRule.LastResortOverstowLaterVoyage);
	
	self.frmEdit.parent := self.frmDetailsTop;
	self.frmEdit.zOrder(0);
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="9af90042-3c2f-4c84-8436-918daf0b7aeb">
        <updating/>
        <source>showThumbnailData(obj: Object) updating;
// -------------------------------------------
// Created 21 September 2005 by cnwdvb1
// -------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars

	rule		: CM_YAOverstowRule;
	headings,
	data		: HugeStringArray;
	dataSize	: Integer;
	str			: String;
	i			: Integer;

begin
	rule := obj.CM_YAOverstowRule;

	self.setNavigatorHeading('Overstow Rule  (' &amp; rule.code &amp; ')');

	create headings transient;
	create data transient;
		
	rule.showThumbnailData(headings, data, self.myTerminal);

	self.tblThumb.rows := 0;

	dataSize := data.size;
	foreach str in headings do
		i := i + 1;
		if i &gt; dataSize then
			break;
		endif;
		tblThumb.addItem(str &amp; Tab &amp; data[i]);
	endforeach;
	tblThumb.cnAdjustColumnWidths();
	return;
epilog	
	delete headings;
	delete data;
end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="108fdcc9-f8a4-467d-9a26-ae162206eb00">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008251, locale);
	chkVoyageJobs.translateCaption(Xlat_0001146, locale);
	lblAttributes.translateCaption(Xlat_0001147, locale);
	lblCode.translateCaption(Xlat_0001149, locale);
	lblDescription.translateCaption(Xlat_0001145, locale);
	lblFree.translateCaption(Xlat_0001150, locale);
	lblImexStatus.translateCaption(Xlat_0001148, locale);
	lblLaterVoyages.translateCaption(Xlat_0001151, locale);
end;</source>
    </JadeMethod>
</GUIClass>
