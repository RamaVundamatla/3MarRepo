    <JadeMethod name="trxDeleteDBPurgeArchivedLns" id="44e44113-6634-44bc-ba74-9342a1a48301">
        <updating/>
        <source>trxDeleteDBPurgeArchivedLns(_terminal : CM_Terminal; _ts : TimeStamp; _agent : CM_DBPurgeAgent input; _passport : CM_Passport input) updating;
// -------------------------------------------
// Created 26 August 2004 by cnwdvb1
// -------------------------------------------
// SPECIAL TRX FOR GARBAGE COLLECTION.
vars

	locationsSet		: CM_LCSet;
	ta					: CM_TerminalArea;
	location			: CM_LocationsController;
	setAll,
	setErrors			: CM_ObjectSetActual;
	iter,
	iter2				: Iterator;
	theSize,
	count,
	count2,
	completed,
	numOfLockExceptions	: Integer;
	hadLock				: Boolean;
	errTxt				: String;

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	// SPECIAL TRX FOR GARBAGE COLLECTION.
	// EXCEPTION HANDLER ARMED OUTSIDE OF TRX
	on LockException do _agent.xLockHandler(exception, hadLock, numOfLockExceptions, errTxt, true);
	
	create locationsSet transient;
	create setAll transient;
	create setErrors transient;
	
	iter := _terminal.allTerminalAreasByTypeId.createIterator();	
	while iter.next(ta) do
		iter2 := ta.allLCsArchived.createIterator();
		while iter2.next(location) do
			if location.statusDateTime &lt;= _ts then
				locationsSet.add(location);
			endif;
		endwhile;
		delete iter2;
	endwhile;
		

	if _agent.abort() then
		return;
	endif;

	theSize := locationsSet.size;
	foreach location in locationsSet do
		count := count + 1;
		setAll.add(location);
		app.writeLog('Erasing location (' &amp; location.getNiceName() &amp; ')', LogINFO);
		if count = _agent.Commit_Block_Size_Small then
			if not _agent.doEraseBlockOfObjects(setAll, setErrors) then
				return;
			endif;
			completed := completed + setAll.size;
			setAll.clear();
			count2 := count2 + count;
			count := 0;
			if _agent.abort() then
				return;
			endif;
			// Keep track of progress every commit.
			if count2 mod (_agent.Activity_Progress_Count_Medium/10) = 0 then
				_agent.createActivityHistory(app.getErrorString2(Progress, app.getErrorString(Purged)&amp;' '&amp;count2.String, theSize.String &amp; ' ' &amp; app.getErrorString(Available)), false, false);
			endif;
		endif;
	endforeach;	
	
	if not setAll.isEmpty() then
		if not _agent.doEraseBlockOfObjects(setAll, setErrors) then
			return;
		endif;
		completed := completed + setAll.size;
	endif;
	
	_agent.setStats(app.getErrorString(Purged)&amp;' '&amp;completed.String &amp; ' ' &amp; app.getErrorString(Archived_Locations) &amp; ' ' &amp; setErrors.size.String &amp; ' ' &amp; app.getErrorString(Errors));
	
	if not process.isInTransactionState then
		// To get past finalise;
		beginTransaction;
	endif;

epilog
	delete locationsSet;
	delete setAll;
	delete setErrors;
	delete iter;
	delete iter2;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_ts" type="TimeStamp"/>
        <Parameter name="_agent" type="CM_DBPurgeAgent" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxDeleteDBPurgeArchivedVoyage" id="d5249e47-1304-4c83-99ae-c2e07b0aa2e6">
        <updating/>
        <source>trxDeleteDBPurgeArchivedVoyage(_voyage : CM_Voyage input; _agent : CM_DBPurgeAgent input; _passport : CM_Passport input) updating;
// -------------------------------------------
// Created 24 August 2004 by cnwdvb1
// -------------------------------------------
// SPECIAL TRX FOR GARBAGE COLLECTION.
//9/11/17 jlgns1 TFS 6960 QNS - Disk space issues and house keeping inside JMT
vars

	iter,
	iter2,
	iter3		: Iterator;
	ti			: CM_TrackedItem;
	count		: Integer;
	voyageRef	: CM_Voyage;
	bolOut		: CM_BOLOut;
	setAll,
	setErrors	: CM_ObjectSetActual;
	count1,
	count2,
	theSize,
	completed	: Integer;

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on LockException do app.alertLockExceptionHandler(exception);
	// SPECIAL TRX FOR GARBAGE COLLECTION.
	// EXCEPTION HANDLER ARMED OUTSIDE OF TRX

	// Get internal reference so it can be passed to delete util.
	voyageRef := _voyage;
	
	self.lock(_voyage, Exclusive_Lock, Session_Duration, LockTimeout_Server_Defined);
	
	// Do archived voyage validation for delete.
	app.myValDA.valArchivedVoyage(voyageRef);
	
	if _agent.abort() then	
		return;
	endif;

	create setAll transient;
	create setErrors transient;
	
	// Start the transaction
	beginTransaction;
	// Run through all tis on the voyage and process in transaction blocks.
	iter := voyageRef.allOnshipTIsByCargoTypeId.createIterator();
// update on CM_Voyage object that have started purging	
	while iter.next(ti) do
		count := count + 1;
		ti.breakTerminalRefForPurge();
		if count = _agent.Commit_Block_Size_Medium then
			if _agent.abort() then
				return;
			endif;
			app.cmsCommitTransaction(_passport);
			
			beginTransaction;
			count := 0;
		endif;
	endwhile;
	
	app.cmsCommitTransaction(_passport);
	
	if _agent.abort() then	
		return;
	endif;
	
	beginTransaction;
	
	iter2 := voyageRef.allBOLOutByTypeStatusNumDT.createIterator();
	while iter2.next(bolOut) do
		bolOut.breakTerminalRefForPurge();	
	endwhile;
	
	app.cmsCommitTransaction(_passport);
	
	if _agent.abort() then
		return;
	endif;
	
	theSize := voyageRef.allOnshipTIsByCargoTypeId.size();
	iter3 := voyageRef.allOnshipTIsByCargoTypeId.createIterator();
	while iter3.next(ti) do
		if ti.isChild then
			continue;
		endif;
		count1 := count1 + 1;
		setAll.add(ti);
		if count1 = _agent.Commit_Block_Size_Medium then
			if not _agent.doEraseBlockOfObjects(setAll, setErrors) then
				return;
			endif;
			completed := completed + setAll.size;
			setAll.clear();
			count2 := count2 + count1;
			count1 := 0;
			if _agent.abort() then
				return;
			endif;
			if count2 mod _agent.Activity_Progress_Count_Medium = 0 then
				_agent.createActivityHistory(app.getErrorString2(Progress, app.getErrorString(Purged)&amp;' '&amp;count2.String, theSize.String &amp; ' ' &amp; app.getErrorString(Available)), false, true);
			endif;
		endif;
	endwhile;	
	
	if not setAll.isEmpty() then
		if not _agent.doEraseBlockOfObjects(setAll, setErrors) then
			return;
		endif;
		completed := completed + setAll.size;
	endif;
	
	_agent.setStats(app.getErrorString(Purged)&amp;' '&amp;completed.String &amp; ' ' &amp; app.getErrorString(TrackedItems) &amp; ' ' &amp; setErrors.size.String &amp; ' ' &amp; app.getErrorString(Errors));

	
	beginTransaction;
	
	// Do the remainder of the work.
	voyageRef.causeEvent(voyageRef.myTerminal.getTerminalEvent(Voyage_Delete_Event), false, _voyage);
	voyageRef.erase(NORMAL_ERASE);
	app.cmsCommitTransaction(_passport);
	beginTransaction;
	
epilog		

	
	delete iter;
	delete iter2;
	delete setAll;
	delete setErrors;
	delete iter3;
	self.finaliseActivityWithPassport(_passport);
	self.unlock(_voyage);
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_agent" type="CM_DBPurgeAgent" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxDeleteDBPurgeCargoGroups" id="1cdb3c56-8779-49af-b9c2-19ac0d13b9ba">
        <updating/>
        <source>trxDeleteDBPurgeCargoGroups(_terminal : CM_Terminal; _ts : TimeStamp; _agent : CM_DBPurgeAgent input;  _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 June 2015	cnwndl1	Initial creation	Par 36338

*/

// SPECIAL TRX FOR GARBAGE COLLECTION.
vars
	tiSet : CM_TISet;
	setAll : CM_ObjectSetActual;
	setErrors : CM_ObjectSetActual;
	iter : Iterator;
	ti : CM_TrackedItem;
	currentTi : CM_Object;
	cargoType,
	count,
	count2,
	completed,
	theSize : Integer;
	id : String;
	releasedDate,
	deletedDate	 : TimeStamp;
	trns : CM_TITransaction;
	numOfLockExceptions : Integer;
	hadLock : Boolean;
	errTxt : String;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	create setAll transient;
	create setErrors transient;
	create tiSet transient;
	
	// Arm our base exception handlers
	on LockException do _agent.xLockHandler(exception, hadLock, numOfLockExceptions, errTxt,true);

	
	iter := _terminal.allCargoGroupsByIdCargoType.createIterator();
	while iter.next(ti) do
		if ti.releasedDT = null or not ti.releasedDT.date.isValid then
			continue;
		endif;
		if ti.releasedDT &lt;= _ts then
			tiSet.add(ti);
		endif;
	endwhile;
	
	if _agent.abort() then
		return;
	endif;
	
	count := 0;
	
	theSize := tiSet.size;
	foreach ti in tiSet do
		count := count + 1;
		setAll.add(ti);
		if count = _agent.Commit_Block_Size_Medium then
			if not _agent.doEraseBlockOfObjects(setAll, setErrors) then
				return;
			endif;
			completed := completed + setAll.size;
			setAll.clear();
			count2 := count2 + count;
			count := 0;
			if _agent.abort() then
				return;
			endif;

			if count2 mod _agent.Activity_Progress_Count_Large = 0 then
				_agent.createActivityHistory(app.getErrorString2(Progress, app.getErrorString(Purged)&amp;' '&amp;count2.String, theSize.String &amp; ' ' &amp; app.getErrorString(Available)), false, false);
			endif;
		endif;
	endforeach;
	
	if not setAll.isEmpty() then
		if not _agent.doEraseBlockOfObjects(setAll, setErrors) then
			return;
		endif;
		completed := completed + setAll.size;
	endif;
	
	_agent.setStats(app.getErrorString(Purged)&amp;' '&amp;completed.String &amp; ' ' &amp; app.getErrorString(TrackedItems) &amp; ' ' &amp; setErrors.size.String &amp; ' ' &amp; app.getErrorString(Errors));
	
	if not process.isInTransactionState then
		// To get past finalise;
		beginTransaction;
	endif;

epilog		
	delete tiSet;
	delete setAll;
	delete setErrors;
	delete iter;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_ts" type="TimeStamp"/>
        <Parameter name="_agent" type="CM_DBPurgeAgent" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxDeleteDBPurgeEmptyBOLIns" id="04419ec3-5444-4193-bad1-afbd5742ed69">
        <updating/>
        <source>trxDeleteDBPurgeEmptyBOLIns(_terminal : CM_Terminal; _ts : TimeStamp; _agent : CM_DBPurgeAgent input; _passport : CM_Passport input) updating;
// -------------------------------------------
// Created 26 August 2004 by cnwdvb1
// -------------------------------------------
// 14/07/2025	naviv1	35226	MTN - Usage of Iterator.getCurrentKeys  
// SPECIAL TRX FOR GARBAGE COLLECTION.
vars

	bolSet				: CM_BOLSet;
	iter,
	iter2				: Iterator;
	bolIn				: CM_BOLIn;
	type				: Integer;
	receivalTs			: TimeStamp;
	count,
//	count2,
	completed,
	theSize				: Integer;
	setAll,
	setErrors			: CM_ObjectSetActual;
	numOfLockExceptions	: Integer;
	hadLock				: Boolean;
	errTxt				: String;

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	// Arm our base exception handlers
	// SPECIAL TRX FOR GARBAGE COLLECTION.
	// EXCEPTION HANDLER ARMED OUTSIDE OF TRX
	on LockException do _agent.xLockHandler(exception, hadLock, numOfLockExceptions, errTxt, true);
	
	create setAll transient;
	create setErrors transient;
	create bolSet transient;

	iter := _terminal.allBOLsReceivedByDTType.createIterator();
	while iter.next(bolIn) do
		iter.getCurrentKeys(type,receivalTs); //MTN-35226
		if receivalTs &lt;= _ts then
			bolSet.add(bolIn);
		endif;
	endwhile;
	
	if _agent.abort() then
		return;
	endif;

	theSize := bolSet.size;
	iter2 := bolSet.createIterator();

	while iter2.next(bolIn) do
		count := count + 1;
		if (bolIn.allTrackedItems.isEmpty) and
		   (bolIn.myYardJob = null)		// #25445 07/02/2011 - Unreconciled dockets have road jobs, so, leaving them not deleted.
		then
			setAll.add(bolIn);
			if count mod _agent.Commit_Block_Size_Medium = 0 then
				if not _agent.doEraseBlockOfObjects(setAll, setErrors) then
					return;
				endif;
				completed := completed + setAll.size;
				setAll.clear();
				if _agent.abort() then
					return;
				endif;
				if count mod _agent.Activity_Progress_Count_Large = 0 then
					_agent.createActivityHistory(app.getErrorString2(Progress, app.getErrorString(Processed)&amp;' '&amp;count.String, theSize.String &amp; ' ' &amp; app.getErrorString(Available)), false, true);
				endif;
			endif;
		endif;
	endwhile;	
	
	if not setAll.isEmpty() then
		if not _agent.doEraseBlockOfObjects(setAll, setErrors) then
			return;
		endif;
		completed := completed + setAll.size;
	endif;
	
	_agent.setStats(app.getErrorString(Purged)&amp;' '&amp;completed.String &amp; ' ' &amp; app.getErrorString(Empty) &amp;  ' ' &amp; app.getErrorString(Receival_Dockets) &amp; ' ' &amp; setErrors.size.String &amp; ' ' &amp; app.getErrorString(Errors));
	
	if not process.isInTransactionState then
		// To get past finalise;
		beginTransaction;
	endif;

epilog
	delete bolSet;
	delete iter;
	delete iter2;
	delete setAll;
	delete setErrors;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_ts" type="TimeStamp"/>
        <Parameter name="_agent" type="CM_DBPurgeAgent" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
