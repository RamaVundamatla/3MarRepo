<Class name="WS_Report" id="af6f2e4c-9758-4bf0-8d81-095b5d847a1c">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Used to return all reports under specific  report header [Report Header str: Required] ex. Container Reports.
 </text>
    <DbClassMap file="webservice"/>
    <Constant name="Prefix_JMTReport_Definition" id="fdd31cfd-fef8-4b1d-a4eb-3266ff93b52e">
        <source>"rptDef_"</source>
        <type name="String"/>
    </Constant>
    <Constant name="Prefix_JMTReport_Output_Option" id="4b6293b5-a798-48a0-accd-b725cf756aff">
        <source>"rptOpt_"</source>
        <type name="String"/>
    </Constant>
    <PrimAttribute name="description" id="d27b6917-a6dd-4e1d-b03d-cfbfc474f616">
        <type name="String"/>
        <access>readonly</access>
        <text>Report Description. ex. Cargo Basic</text>
    </PrimAttribute>
    <PrimAttribute name="id" id="c465890b-c234-4f67-912d-2c0e10926df7">
        <type name="String"/>
        <access>readonly</access>
        <text>Report ID</text>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="1b72985d-b85e-4696-8306-8430b04b838f">
        <updating/>
        <source>setProxyFromObject(_object: CM_QryReport ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 September 2008	cnwkao1	Initial creation

*/

vars

begin
	inheritMethod(_object);
	//self.id			 := Prefix_JMTReport_Definition &amp; _object.reportName;//&amp; _object.jrwReportName.first();
	self.id			 := _object.reportName;
	self.description := _object.reportName;
	
epilog

end;</source>
        <Parameter name="_object" type="CM_QryReport"/>
    </JadeMethod>
</Class>
