    <JadeMethod name="setForCreate" id="b3b0f5ac-9d13-42ba-99d6-8b3ec6188cef">
        <updating/>
        <source>setForCreate(_proxyBGPMutex : BGP_Mutex input) updating;
//
// 03 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage 2
//
vars

begin
	self.setForUpdate(_proxyBGPMutex);
epilog

end;</source>
        <Parameter name="_proxyBGPMutex" type="BGP_Mutex" usage="input"/>
