    <JadeMethod name="getDescription" id="bbc74ca0-4ddb-4fbf-bd4e-57fcd13c324d">
        <source>getDescription(): String;
// ---------------------------------------------------------------------------
// Created:		07 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars

begin
	if self.myResource = null then 		// not global.isValidObject(self.myResource) then
		return null;
	endif;
	return self.myResource.description;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceLineDesc" id="9e2248db-6d77-43c9-9b08-9a3294752c39">
        <source>getInvoiceLineDesc(_aSBController : CMIF_ServiceBroker input);
// 10 Oct 2022 navma1	Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
// 23 Oct 2024 navlw1	JIRA-33107: Invoice Logging Use Levels
vars
	tmpDebtor   : CM_Debtor;
	aDM 		: CM_DebtorMap;
	hmsTrans 	: HMS_VTMISTransaction;
	canLogExtra	: Boolean;
begin
	canLogExtra	:=	app.canLogExtraDetail();				//10.10.2022 navma1 #52967
	hmsTrans    := _aSBController.myVTMISTransaction;
	
	if hmsTrans &lt;&gt; null then
		tmpDebtor := hmsTrans.myDebtor;
		if tmpDebtor &lt;&gt; null then
			if canLogExtra then							       //10.10.2022 navma1 #52967
				app.invLog("Debtor " &amp; tmpDebtor.name, LogINFO.String);
			endif;
			
			aDM := self.allDebtorMapsByDebtor[tmpDebtor.name];		
			if aDM &lt;&gt; null then
				if canLogExtra then							   //10.10.2022 navma1 #52967
					app.invLog("Debtor map found for " &amp; tmpDebtor.name, LogINFO.String);
				endif;
				aDM.getInvoiceLineDesc(_aSBController);
				return;
			endif;
		endif;
	endif;
	
	if canLogExtra then							 			  //10.10.2022 navma1 #52967
		app.invLog("Debtor map for DEFAULT", LogINFO.String);
	endif;
	self.myChildQuantityMap.getInvoiceLineDesc(_aSBController);
	
end;</source>
        <Parameter name="_aSBController" type="CMIF_ServiceBroker" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceLineDescVTMIS" id="a775ab2c-41dd-405c-94af-3de54e91ea4c">
        <source>getInvoiceLineDescVTMIS(_debtor : CM_DebtorNode; _poc : Boolean): CM_InvoiceLineDesc;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		find the invoice line description. If a debtor has been passed in the check if that debtor has a special mappinig, 
//				stored on the CM_DebtorMap,  if not used the default stored on the service broker.
//
// ---------------------------------------------------------------------------
vars
	lineDescription:   CM_InvoiceLineDesc;
	aDM : CM_DebtorMap;
begin

	if _debtor &lt;&gt; null then
		aDM := self.allDebtorMapsByDebtor[_debtor.name];		
		if aDM &lt;&gt; null then
			lineDescription := aDM.myChildQuantityMap.getInvoiceLineDescVTMIS(_poc);
		endif;
	endif;

	if lineDescription = null then // DEFAULT
		lineDescription := self.myChildQuantityMap.getInvoiceLineDescVTMIS(_poc); // PAR 35469
	endif;
	
	return lineDescription;
end;</source>
        <Parameter name="_debtor" type="CM_DebtorNode"/>
        <Parameter name="_poc" type="Boolean"/>
        <ReturnType type="CM_InvoiceLineDesc"/>
    </JadeMethod>
