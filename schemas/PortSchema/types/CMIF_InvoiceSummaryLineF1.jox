    <JadeMethod name="getTypeStringImex" id="28fa03c3-9954-4b5e-8dba-2bde33edd148">
        <source>getTypeStringImex( _ti : CM_TrackedItem; _tiTrx : CM_TITransaction ):String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 August 2017	jlgndl1	Initial creation	TFS 5799

*/

vars

	imex : Integer;
	imexObj : CM_IMEXStatus;
	
	recVoyageStr : String;
	releaseVoyage : CM_Voyage;
	relVoyageStr : String;
	invVoyageStr : String;

begin
	
	if _tiTrx &lt;&gt; null then
		imex := _tiTrx.imExStatus;
	else
		imex := _ti.getImExStatus;
	endif;
	
	if imex = TI_IMEX_STATUS_TRANSHIP then
		recVoyageStr := _ti.receiveVoyageCode;
		releaseVoyage := _ti.releaseVoyage;
		if releaseVoyage = null then
			releaseVoyage := _ti.myExportVoyage;
		endif;
		if releaseVoyage &lt;&gt; null then
			relVoyageStr := releaseVoyage.code;
		endif;
		invVoyageStr := self.myInvoice.voyageCode;
		if recVoyageStr = invVoyageStr then
			//the invoice line is relative to the import voyage 
			return "T/SHIP IN";
		elseif relVoyageStr = invVoyageStr then
			//the invoice line is relative to the export voyage 
			return "T/SHIP OUT";
		endif;
		
	endif;
	
	imexObj := app.myRoot.allImexStatuses[imex];
	if imexObj &lt;&gt; null then
		return imexObj.description;
	else
		return "Unknown";
	endif;

epilog

end;</source>
        <access>protected</access>
