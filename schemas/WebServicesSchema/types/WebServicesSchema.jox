epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="finalize" id="668699fb-b959-45bd-9d86-77dac07723c4">
        <updating/>
        <source>finalize() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 Jan 2009	cnwkpd1	PAR #17554 - Development of new RIA Web Service application
02 Oct 2017	jlgkpd1	TFS 7163 - Add Web Services for JSON serialisation

*/

vars

begin
	// Prevent closedown errors if the last Web Service call was a logon
	if self.myPassport &lt;&gt; null then
		self.myPassport.myEventLogin := null;
	endif;
	
	delete self.myPushEventsAgent;
	
	inheritMethod();

	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getEnvName" id="2cf5e930-703a-472e-93fe-61b4db9e2c23">
        <source>getEnvName() : String;
/*

Purpose:			Work out the environment name, can't use CardSchema here, as its not quite correct for non 'standard' setups
Parameters:			

Return Value:		

Date			Who		Reason
13 April 2021	navmd1	Initial creation TFS 51086 JADE 2020 Fixes

*/

vars
	dbPath,
	env_id		: String;
	pos			: Integer;
begin
	// Need to cater for:
	//	D:\navDmast\server\c_system
	//	D:\navDmast\c_system
	//	D:\Some\Other\Folder\Structure\navDmast\server\c_system
	//	D:\Some\Other\Folder\Structure\navDmast\c_system
	//
	// so... basically just strip off the end and hope that the last "folder" in the path is us!
	
	dbPath := app.cnStandardizePathName(app.dbPath);	// Turn slashes into forward slashes
	dbPath := dbPath.replace(CN_SLASH &amp; "c_system", "");
	dbPath := dbPath.replace(CN_SLASH &amp; "server", "");
	
	pos := dbPath.reversePos("/");
	if pos &gt; 0 then
		pos := pos + 1;
		env_id := dbPath[pos:end];
	endif;
	
	return env_id;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getJMTPermissionsForFormName" id="6a000f23-684e-4010-99cf-a0ebab396207">
        <source>getJMTPermissionsForFormName(_formName : String;
							 _viewPermission,
							 _addPermission,
							 _updatePermission,
							 _deletePermission : Integer output);

/*

Purpose:			Get the JMT permission constant values for the passed in Web Service 
					form name

Parameters:			Form name as known to the JMT Web Service

Return Value:		Integer values for the appropriate JMT permissions
					Null value means everyone has access
					Negative value means access is not available via the Web Service
					

Date		Who		Reason
23 Jan 2009	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

constants
	NotAvailableViaWebService	= -1;
	
vars

begin
	if _formName = WS_FormDefinition.Cargo_Notification then
		_viewPermission 	:= PmEventReqNotifyMaint;
		_addPermission 		:= PmEventReqNotifyMaint;
		_updatePermission	:= PmEventReqNotifyMaint;
		_deletePermission	:= PmEventReqNotifyMaint;

	elseif _formName = WS_FormDefinition.Cargo_Notification_Search then
		_viewPermission 	:= PmEventReqNotifyMaint;
		_addPermission 		:= PmEventReqNotifyMaint;
		_updatePermission	:= PmEventReqNotifyMaint;
		_deletePermission	:= PmEventReqNotifyMaint;
	
	elseif _formName = WS_FormDefinition.BookingRefItem_Select_Form then
		_viewPermission 	:= null;
		_addPermission 		:= null;
		_updatePermission	:= null;
		_deletePermission	:= null;
	
	elseif _formName = WS_FormDefinition.PreNotes then
		_viewPermission 	:= PmGtePreNoteView;
		_addPermission 		:= PmGtePreNoteMaint;
		_updatePermission	:= PmGtePreNoteMaint;
		_deletePermission	:= PmGtePreNoteMaint;
	
	elseif _formName = WS_FormDefinition.PreNotes_Search then	
		_viewPermission 	:= PmGtePreNoteView;
		_addPermission 		:= PmGtePreNoteMaint;
		_updatePermission	:= PmGtePreNoteMaint;
		_deletePermission	:= PmGtePreNoteMaint;
	
	elseif _formName = WS_FormDefinition.Cargo_Update_Request then
		_viewPermission 	:= PmEventReqStopsMaint;
		_addPermission 		:= PmEventReqStopsMaint;
		_updatePermission	:= PmEventReqStopsMaint;
		_deletePermission	:= PmEventReqStopsMaint;
	
	elseif _formName = WS_FormDefinition.Cargo_Update_Search then
		_viewPermission 	:= PmEventReqStopsMaint;
		_addPermission 		:= PmEventReqStopsMaint;
		_updatePermission	:= PmEventReqStopsMaint;
		_deletePermission	:= PmEventReqStopsMaint;
	
	elseif _formName = WS_FormDefinition.Cargo_Rel_Import then
		_viewPermission 	:= PmGteFullReleaseView;
		_addPermission 		:= NotAvailableViaWebService;
		_updatePermission	:= NotAvailableViaWebService;
		_deletePermission	:= NotAvailableViaWebService;
	
	elseif _formName = WS_FormDefinition.Cargo_Rel_Import_Search then
		_viewPermission 	:= PmGteFullReleaseView;
		_addPermission 		:= NotAvailableViaWebService;
		_updatePermission	:= NotAvailableViaWebService;
		_deletePermission	:= NotAvailableViaWebService;
	
	elseif _formName = WS_FormDefinition.Cargo_Enq_Form then
		_viewPermission 	:= PmAdmCargoEnquiryView;
		_addPermission 		:= NotAvailableViaWebService;
		_updatePermission	:= NotAvailableViaWebService;
		_deletePermission	:= NotAvailableViaWebService;
	
	elseif _formName = WS_FormDefinition.Cargo_Enq_Search_Form then
		_viewPermission 	:= PmAdmCargoEnquiryView;
		_addPermission 		:= NotAvailableViaWebService;
		_updatePermission	:= NotAvailableViaWebService;
		_deletePermission	:= NotAvailableViaWebService;
	
	elseif _formName = WS_FormDefinition.Release_Request then
		_viewPermission 	:= PmGteMTReleaseView;
		_addPermission 		:= PmGteEmptyReleaseMaintAll;		//cnwmc5 - 10 Nov 2014 - CCMS 2429
		_updatePermission	:= PmGteEmptyReleaseMaintAll;		//cnwmc5 - 10 Nov 2014 - CCMS 2429
		_deletePermission	:= PmGteEmptyReleaseMaintAll;		//cnwmc5 - 10 Nov 2014 - CCMS 2429
	
	elseif _formName = WS_FormDefinition.Release_Request_Search then
		_viewPermission 	:= PmGteMTReleaseView;
		_addPermission 		:= PmGteEmptyReleaseMaintAll;
		_updatePermission	:= PmGteEmptyReleaseMaintAll;
		_deletePermission	:= PmGteEmptyReleaseMaintAll;
	
	elseif _formName = WS_FormDefinition.Report_Selection then
		_viewPermission 	:= PmReportRunnerView;
		_addPermission 		:= NotAvailableViaWebService;
		_updatePermission	:= NotAvailableViaWebService;
		_deletePermission	:= NotAvailableViaWebService;
	
	elseif _formName = WS_FormDefinition.Add_Attachments then
		_viewPermission 	:= null;
		_addPermission 		:= null;
		_updatePermission	:= null;
		_deletePermission	:= null;

	elseif _formName = WS_FormDefinition.Preferences_Form then
		_viewPermission 	:= null;
		_addPermission 		:= null;
		_updatePermission	:= null;
		_deletePermission	:= null;	
	
	elseif _formName = WS_FormDefinition.Cargo_QuickView_Form then
		_viewPermission 	:= PmCargoQuickViewView;
		_addPermission 		:= NotAvailableViaWebService;
		_updatePermission	:= NotAvailableViaWebService;
		_deletePermission	:= NotAvailableViaWebService;
		
	elseif _formName = WS_FormDefinition.Cargo_QuickView_Search_Form then
		_viewPermission 	:= PmCargoQuickViewView;
		_addPermission 		:= NotAvailableViaWebService;
		_updatePermission	:= NotAvailableViaWebService;
		_deletePermission	:= NotAvailableViaWebService;
	
	elseif _formName = WS_FormDefinition.VehicleBooking then	//08 may 2013	NDL	Par 31393
		_viewPermission 	:= PmGteVehSchWeb;
		_addPermission 		:= PmGteVehSchWeb;
		_updatePermission	:= PmGteVehSchWeb;
		_deletePermission	:= PmGteVehSchWeb;
		
	elseif _formName = WS_FormDefinition.VehicleBookingEnquiry then	//cnwmc5 - 29 Oct 2014 - PAR 35008
		_viewPermission 	:= PmGteVehSchWeb;
		_addPermission 		:= NotAvailableViaWebService;
		_updatePermission	:= NotAvailableViaWebService;
		_deletePermission	:= NotAvailableViaWebService;
	else
		// This is a report
		_viewPermission 	:= null;
		_addPermission 		:= null;
		_updatePermission	:= null;
		_deletePermission	:= null;

	endif;


epilog

end;</source>
        <Parameter name="_formName" type="String"/>
        <Parameter name="_viewPermission" type="Integer" usage="output"/>
        <Parameter name="_addPermission" type="Integer" usage="output"/>
        <Parameter name="_updatePermission" type="Integer" usage="output"/>
        <Parameter name="_deletePermission" type="Integer" usage="output"/>
    </JadeMethod>
