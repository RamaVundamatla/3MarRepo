<Class name="CM_CamTOLDepotReturn" id="97d5f09d-9fc9-48b9-b71f-2aca025f1e1d">
    <superclass name="CM_CamTasmanOrientDesc"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cams"/>
    <JadeMethod name="create" id="01d92fc1-e655-4d8b-a651-98784ac99577">
        <updating/>
        <source>create() updating;
//----------------------------------------------------------------
//	Created:	03 March 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.name := "";
	self.type := 0;

end;</source>
    </JadeMethod>
    <JadeMethod name="processTransaction" id="8b0f8257-a2ac-4325-b46a-9b8ae87490f8">
        <updating/>
        <source>processTransaction(_transaction : CM_TITransaction; _camProtocol : CM_CamProtocol; _camAgent : CM_CamControllerAgent input; _camFile : CM_CamFile input) updating;
// 12/05/2010	cnwcs5	par 23967 - change _camFile paremeter to be input not io so as to correctly reflect its usage
//18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
// 17 Dec 2012	cnwcs5	CCMS SFW 1294 / par 30855
// 04 Feb 2013	cnwcs5	CCMS SFW 1294 /par 30855
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//20 dec 2016	cnwrs1	TFS 3158 Cams Exclusion report does not include the rehandles and sobs
vars
	camMessage 			: CM_CamMessage;
	message				: String;
	msgLength, status	: Integer;
	theTI 				: CM_TrackedItem;
	vesselName 			: String; //par18987 cnwrs1 Mar 2007
begin
	_camAgent.writeDebugLog(class.name&amp;'::'&amp;method.name&amp;" process "&amp;_transaction.getCamsDisplayDetails);
	
	theTI 	:= _transaction.myTrackedItem;
	status 	:= self.setStatus(_transaction);
	
	if status = RCVD or status = SNTR or status = RCVA or status = RCDB then
		camMessage := self.getCamMessage(_camFile, "", vesselName, 0, _camProtocol.singleContainerPerBGM); //ccms1747 cnwrs1 aug 2008 
	else
		//do nothing
		if _camAgent.logExcludedTransactions then
			_camAgent.logReasonForExclusion(_transaction, "Transaction has invalid status of "&amp;status.String&amp;".");
		endif;
		return;
	endif;

	camMessage.camVoyage.voyageOid := _transaction.myTrackedItem.myVoyage;
	
	message := "";
	message := message&amp;_camProtocol.camGroup.senderCode.trimBlanks;
	message := message&amp;",";
	message := message&amp;_transaction.myTrackedItem.id.trimBlanks;
	message := message&amp;",";
	message := message&amp;_transaction.myTrackedItem.getISOType().trimBlanks;
	message := message&amp;",";
	message := message&amp;_transaction.dateTime.date.day.String.padLeadingZeros(2)&amp;"-"&amp;_transaction.dateTime.date.monthName[1:3]&amp;"-"&amp;_transaction.dateTime.date.year.String[3:2];
	message := message&amp;",";
	message := message&amp;_transaction.dateTime.time.shortFormatEDI();
	message := message&amp;",";
	message := message&amp;self.statusString(status);
	msgLength := message.length;

//	if msgLength &lt; 62 then
		camMessage.group3.add(message);
//		camMessage.group4.add("");
//		camMessage.group5.add("");
/*	else
		camMessage.group3.add(message[1:61]);
		
		msgLength := msgLength - 61;
		
		if msgLength &lt; 62 then
			camMessage.group4.add(message[61:msgLength]);
			camMessage.group5.add("");
		else
			camMessage.group4.add(message[61:61]);
			msgLength := msgLength - 61;
			if msgLength &lt; 62 then
				camMessage.group5.add(message[122:msgLength]);
			else
				camMessage.group5.add(message[122:61]);
			endif;
		endif;
	endif;*/
	
	camMessage.eqdCount := camMessage.eqdCount + 1;
	
	// save of messages so we can create a CMS Info transaction at the same time we arite out
	// the file and update the CAMS task history.
	camMessage.setupCAMSInfoDetailsStr (_camProtocol, message, _transaction); 	// par 30855 Dec 2012

end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
    </JadeMethod>
    <JadeMethod name="specialFileName" id="dc73753b-de6c-4ac4-a17b-24073e6f22cd">
        <source>specialFileName(_camGroup:CM_CamGroup;_startDateTime:TimeStamp; _runDateTime : TimeStamp):String;

vars
	today:TimeStamp;
begin
	return "DRT"&amp;_camGroup.senderCode&amp;_startDateTime.date.shortYearEDI()&amp;_startDateTime.time.format("hh")&amp;".csv";
end;</source>
        <Parameter name="_camGroup" type="CM_CamGroup"/>
        <Parameter name="_startDateTime" type="TimeStamp"/>
        <Parameter name="_runDateTime" type="TimeStamp"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
