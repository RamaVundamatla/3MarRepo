    </JadeMethod>
    <JadeMethod name="addToSummaryLine" id="7aee990a-b113-4e63-a012-548dca874e83">
        <updating/>
        <source>addToSummaryLine( _kpiTerminalArea : CM_KPITerminalArea; _isSubTotal : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 October 2013	cnwndl1	Initial creation	Par 32079
//26 Feb 2015  cnwma1 PAR # 33352 Space Utilisation functionality for Block Stacks
*/

vars

	idx : Integer;
	
	
begin
	
	if _kpiTerminalArea &lt;&gt; null then
		self.totalTIs := self.totalTIs + _kpiTerminalArea.totalTIs;
		self.totalTEUs := self.totalTEUs + _kpiTerminalArea.totalTEUs;
		self.totalLocnEmpty := self.totalLocnEmpty + _kpiTerminalArea.totalLocnEmpty;
		self.totalLocnOccupied := self.totalLocnOccupied + _kpiTerminalArea.totalLocnOccupied;	
		self.totalLocnFull := self.totalLocnFull + _kpiTerminalArea.totalLocnFull;
		if _isSubTotal then
			self.maxTIs := self.maxTIs + _kpiTerminalArea.maxTIs;
		endif;
		
		//22 Jun 2016	NDL	TFS 1752
		if _isSubTotal then
			self.capacityLength := self.capacityLength + _kpiTerminalArea.capacityLength;
			self.capacityVolume := self.capacityVolume + _kpiTerminalArea.capacityVolume;
			self.capacityWeight := self.capacityWeight + _kpiTerminalArea.capacityWeight;
		endif;
		self.totalLength := self.totalLength + _kpiTerminalArea.totalLength;
		self.totalQuantity := self.totalQuantity + _kpiTerminalArea.totalQuantity;
		self.totalVolume := self.totalVolume + _kpiTerminalArea.totalVolume;
		self.totalWeight := self.totalWeight + _kpiTerminalArea.totalWeight;
		
		if not _kpiTerminalArea.getTA.CM_TerminalArea.isBlockStack then 			//26/02/2015  cnwma1 PAR #33352
			foreach idx in 1 to _kpiTerminalArea.availStackHeights.size do
				if self.availStackHeights.size &lt; idx then
					self.availStackHeights[idx] := 0;
					self.maxStackHeight := idx;
				endif;
					self.availStackHeights[idx] := self.availStackHeights[idx] + _kpiTerminalArea.availStackHeights[idx];
			endforeach;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_kpiTerminalArea" type="CM_KPITerminalArea"/>
        <Parameter name="_isSubTotal" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="clearSummaryData" id="9f1ba699-aed7-4feb-b686-a301ce621fa8">
        <updating/>
        <source>clearSummaryData( _area : String ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 October 2013	cnwndl1	Initial creation	Par 32079

*/

vars

begin
	
	self.code := _area; //08/09/2025	navkc1 JIRA 35622  - For RoRo
	self.setTerminalAreaCode( _area );
	
	self.totalTIs := 0;
	self.totalTEUs := 0;
	self.totalLocnEmpty := 0;
	self.totalLocnOccupied := 0;
	self.totalLocnFull := 0;
	self.totalTEUs := 0;
	self.maxTIs := 0;
	self.availStackHeights.clear;
	
	//22 Jun 2016	NDL	TFS 1752
	self.capacityLength := 0;
	self.capacityVolume := 0;
	self.capacityWeight := 0;
	self.totalLength := 0;
	self.totalQuantity := 0;
	self.totalVolume := 0;
	self.totalWeight := 0;
		
epilog

end;</source>
        <Parameter name="_area" type="String"/>
    </JadeMethod>
    <JadeMethod name="delete" id="708e5929-5107-4f88-975a-9db4ae2d45dc">
        <updating/>
        <source>delete() updating;
// ---------------------------------------------------------------------------
// Created:		13 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.allKIPLocations.purge;
end;</source>
    </JadeMethod>
    <JadeMethod name="exportCSV" id="83fcc60a-d4b1-4082-b1c0-66bb7d58bdc9">
        <source>exportCSV() : String;
// ---------------------------------------------------------------------------
// Created:		13 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	line : String;
	tmpKPI : CM_KPILocation;
begin
	foreach tmpKPI in self.allKIPLocations discreteLock do
		line := line &amp; tmpKPI.exportCSV();
	endforeach;
	
	line := line &amp; 	inheritMethod()  &amp; "," &amp;
				self.terminalAreaCode &amp; "," &amp;
				self.maxStackHeight.String &amp; ",,," &amp;
				
				self.totalTIs.String &amp; "," &amp;
				self.totalTEUs.asStringJMTWithPrecision(1,false) &amp; "," &amp;
				self.totalLocnEmpty.String &amp; "," &amp;
				self.totalLocnFull.String &amp; "," &amp;
				self.totalLocnOccupied.String &amp; "," &amp; 
				
				self.pcCapacity.String &amp; "," &amp; 
				self.pcFull.String &amp; "," &amp; 
				self.pcMT.String &amp; "," &amp; 
				self.pcOccupied.String &amp; "," &amp; 
				
				self.getParamString(false) &amp; CrLf;
	return line;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCapacityUsedPercent" id="edd55b98-10a1-4123-8e2e-e7740d3db8a7">
        <source>getCapacityUsedPercent():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 June 2016	cnwndl1	Initial creation	TFS 1752

*/

vars

	value : Integer;
	str : String;
	ta : CM_TerminalArea;
	count : Integer;

begin

	if self.capacityLength &gt; 0 then
		count := count + 1;
	endif;
	if self.capacityVolume &gt; 0 then
		count := count + 1;
	endif;
	if self.capacityWeight &gt; 0 then
		count := count + 1;
	endif;
	if self.maxTIs &gt; 0 then
		count := count + 1;
	endif;
	
	if count &lt;&gt; 1 then
		//can't calculate poercentages when have apples AND oranges... 
		return null;
	endif;

	if self.maxTIs &lt;&gt; 0 then
		if self.myTerminal &lt;&gt; null then
			ta := self.getTA.CM_TerminalArea;
		endif;
		if ta &lt;&gt; null and ( ta.isBlockStack or ta.isIrregularBlockArea ) then
			value :=  ((self.totalQuantity / self.maxTIs) * 100).truncated;
		else
			value :=  ((self.totalTEUs / self.maxTIs) * 100).truncated;
		endif;
		if value &gt; 0 then
			if str &lt;&gt; null then
				return null;	// may not have multiples.... it makes no sense
			endif;
			str := value.String;
		endif;
	endif;
	if self.capacityLength &lt;&gt; 0 then
		value :=  ((self.totalLength / self.capacityLength) * 100).truncated;
		if value &gt; 0 then
			if str &lt;&gt; null then
				return null;	// may not have multiples.... it makes no sense
			endif;
			str := value.String;
		endif;
	endif;
	if self.capacityVolume &lt;&gt; 0 then
		value :=  ((self.totalVolume / self.capacityVolume) * 100).truncated;
		if value &gt; 0 then
			if str &lt;&gt; null then
				return null;	// may not have multiples.... it makes no sense
			endif;
			str := value.String;
		endif;
	endif;
	if self.capacityWeight &lt;&gt; 0 then
		value :=  ((self.totalWeight / self.capacityWeight) * 100).truncated;
		if value &gt; 0 then
			if str &lt;&gt; null then
				return null;	// may not have multiples.... it makes no sense
			endif;
			str := value.String;
		endif;
	endif;
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayLine" id="9e62ab42-bb18-4e27-a8bb-f295fc2db1ed">
        <source>getDisplayLine() : String;
// ---------------------------------------------------------------------------
// Created:		13 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	area,
	totalTi,
	totalTeu,
	emptyLocn,
	emptyPc,
	occuLocn,
	occuPc,
	fullLocn,
	fullPc,
	maxTeu,
	totTeu,
	capPc,
	availStr : String;
	idx : Integer;
begin
	
	foreach idx in 1 to self.maxStackHeight do
		if idx &lt;=  self.availStackHeights.size then
			availStr := availStr &amp; Tab &amp; self.availStackHeights[idx].String;
		endif;
	endforeach;
	
	//05/09/2025	navkc1 JIRA 35622
	/*return self.terminalAreaCode &amp; Tab &amp;
			self.totalTIs.String &amp; Tab &amp; 
			self.totalTEUs.asStringJMTWithPrecision(1,false) &amp; Tab &amp; 
			self.totalLocnEmpty.String &amp; Tab &amp;
			self.pcMT.String &amp; Tab &amp; 
			self.totalLocnOccupied.String &amp; Tab &amp;
			self.pcOccupied.String &amp; Tab &amp; 
			self.totalLocnFull.String &amp; Tab &amp;
			self.pcFull.String &amp; Tab &amp; 
			self.totalTEUs.String &amp; Tab &amp;
			self.maxTIs.String &amp; Tab &amp;
			self.pcCapacity.String &amp; 
			availStr;
	*/
	
	//05/09/2025	navkc1 JIRA 35622
	totalTi := self.totalTIs.String;
	totalTeu := self.totalTEUs.asStringJMTWithPrecision(1, false);
	emptyLocn := self.totalLocnEmpty.String;
	emptyPc := self.pcMT.String;
	occuLocn := self.totalLocnOccupied.String;
	occuPc := self.pcOccupied.String;
	fullLocn := self.totalLocnFull.String;
	fullPc := self.pcFull.String;
	totTeu := self.totalTEUs.String;
	maxTeu := self.maxTIs.String;
	capPc := self.pcCapacity.String;
	
	//05/09/2025	navkc1 JIRA 35622
	if self.isRoRoLane() then
		area := self.code;															// Area
		totalTeu := self.totalLength.asStringJMT();									// Total Length
		
		emptyLocn := (self.capacityLength - self.totalLength).asStringJMT();		// Empty Length
		emptyPc := self.pcMTForRORO().asStringJMT();								// Empty %
		
		occuLocn := self.totalLength.asStringJMT();									// Occupied Length
		occuPc := self.pcCapacityForRORO().asStringJMT();							// Occupied %
		
		fullLocn := self.totalLength.asStringJMT();									// Full Length
		fullPc := self.pcFullForRORO().asStringJMT();								// Full %
		
		totTeu := self.totalLength.asStringJMT();									// Capacity Used Length
		maxTeu := self.capacityLength.asStringJMT();								// Capacity Total Length
		capPc := self.pcCapacityForRORO().asStringJMT();							// Capacity %
	else
		area := self.terminalAreaCode;
	endif;
	
	//05/09/2025	navkc1 JIRA 35622
	return 	area &amp; Tab &amp; 
			totalTi &amp; Tab &amp;	
			totalTeu &amp; Tab &amp; 
			emptyLocn &amp; Tab &amp;
			emptyPc &amp; Tab &amp;
			occuLocn &amp; Tab &amp;
			occuPc &amp; Tab &amp;
			fullLocn &amp; Tab &amp;
			fullPc &amp; Tab &amp;
			totTeu &amp; Tab &amp;
			maxTeu &amp; Tab &amp;
			capPc &amp; 
			availStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayLine2" id="94c385e1-357f-4847-aba6-aa74ee11d871">
        <source>getDisplayLine2() : String;
// ---------------------------------------------------------------------------
// Created:		13 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin

	return Tab &amp; Tab &amp; Tab &amp; self.totalTIs.String &amp; Tab &amp; 
			self.totalTEUs.asStringJMTWithPrecision(1,false) &amp; Tab &amp; 
			self.totalLocnEmpty.String &amp; " (" &amp; self.pcMT.String &amp; "%)" &amp; Tab &amp; 
			self.totalLocnOccupied.String &amp; " (" &amp; self.pcOccupied.String &amp; "%)" &amp; Tab &amp; 
			self.totalLocnFull.String &amp; " (" &amp; self.pcFull.String &amp; "%)" &amp; Tab &amp; 
			self.totalTEUs.String &amp; " of " &amp; self.maxTIs.String &amp; " (" &amp; self.pcCapacity.String &amp; "%)";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayLineSummaryRORO" id="7af0dcf3-ac03-4aa4-9015-dd183b7ece7a">
        <source>getDisplayLineSummaryRORO() : String;
/*

Purpose:			This is used for displaying the Summary line when there's only RORO lane in the query
					Doing something similar to getDisplayLine but this always gets the value for RORO
					
					Having a separate method because when we are displaying the Summary Line, the CM_KPITerminalArea doesn't have terminalAreaCode set, and there's
					no way we can tell whether it's RORO lane (i.e using self.isRoRoLane()). Hence we create this that always display value for RORO lane, and call it from the UI/Agent

Parameters:			

Return Value:		

Date		Who		Reason
08/09/2025	navkc1 JIRA 35622 MSL | Terminal Utilization RoRo - Jade

*/

vars
	area,
	totalTi,
	totalTeu,
	emptyLocn,
	emptyPc,
	occuLocn,
	occuPc,
	fullLocn,
	fullPc,
	maxTeu,
	totTeu,
	capPc,
	availStr 	: String;
	idx 		: Integer;
begin
	
	foreach idx in 1 to self.maxStackHeight do
		if idx &lt;=  self.availStackHeights.size then
			availStr := availStr &amp; Tab &amp; self.availStackHeights[idx].String;
		endif;
	endforeach;

	totalTi := self.totalTIs.String;	
	area := self.code;															// Area
	totalTeu := self.totalLength.asStringJMT();									// Total Length
	
	emptyLocn := (self.capacityLength - self.totalLength).asStringJMT();		// Empty Length
	emptyPc := self.pcMTForRORO().asStringJMT();								// Empty %
	
	occuLocn := self.totalLength.asStringJMT();									// Occupied Length
	occuPc := self.pcCapacityForRORO().asStringJMT();							// Occupied %
	
	fullLocn := self.totalLength.asStringJMT();									// Full Length
	fullPc := self.pcFullForRORO().asStringJMT();								// Full %
	
	totTeu := self.totalLength.asStringJMT();									// Capacity Used Length
	maxTeu := self.capacityLength.asStringJMT();								// Capacity Total Length
	capPc := self.pcCapacityForRORO().asStringJMT();							// Capacity %;
	
	
	//05/09/2025	navkc1 JIRA 35622
	return 	area &amp; Tab &amp; 
			totalTi &amp; Tab &amp;	
			totalTeu &amp; Tab &amp; 
			emptyLocn &amp; Tab &amp;
			emptyPc &amp; Tab &amp;
			occuLocn &amp; Tab &amp;
			occuPc &amp; Tab &amp;
			fullLocn &amp; Tab &amp;
			fullPc &amp; Tab &amp;
			totTeu &amp; Tab &amp;
			maxTeu &amp; Tab &amp;
			capPc &amp; 
			availStr;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="a438a349-cbb0-4d75-9367-b3998bf4797d">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 June 2016	cnwndl1	Initial creation	TFS 1752

*/

vars

	stackHeightAvail : Integer;
	measureType : String;	
	etrowStr : String;

begin
	
	if _attrName = ETRow_Area  then
		return self.terminalAreaCode;
		
	elseif _attrName = ETRow_TotalItems  then
		return self.totalTIs.asStringJMTWithOptionalCommas(false,true);
		
	elseif _attrName = ETRow_TotalQuantity  then
		return self.totalQuantity.asStringJMTWithOptionalCommas(false,true);
	
	elseif _attrName = ETRow_TotalTEU  then
		if self.totalTEUs = 0 then
			return null;
		endif;
		return self.totalTEUs.asStringJMTWithPrecision(1,false);
		
	elseif _attrName = ETRow_CapacityQuantity  then
		return self.maxTIs.asStringJMTWithOptionalCommas(false,true);
	
	elseif _attrName = ETRow_CapacityPercent  then
		return getCapacityUsedPercent;
		
	elseif _attrName = ETRow_EmptyPads  then
		return self.totalLocnEmpty.asStringJMTWithOptionalCommas(false,true);
	
	elseif _attrName = ETRow_EmptyPadsPC  then
		if self.pcMT = 0 then
			return null;
		endif;
		return self.pcMT.String;
		
	elseif _attrName = ETRow_OccupiedPads  then
		return self.totalLocnOccupied.asStringJMTWithOptionalCommas(false,true);	

	elseif _attrName = ETRow_OccupiedPadsPC  then
		if self.pcOccupied = 0 then
			return null;
		endif;
		return self.pcOccupied.String;
		
	elseif _attrName = ETRow_FullPads  then
		return self.totalLocnFull.asStringJMTWithOptionalCommas(false,true);
		
	elseif _attrName = ETRow_FullPadsPC  then
		if self.pcFull = 0 then
			return null;
		endif;
		return self.pcFull.String;
		
	elseif _attrName = ETRow_AvailHeight1  then
		if self.availStackHeights.size &gt;= 1 then
			stackHeightAvail := self.availStackHeights[1];
		endif;
		return stackHeightAvail.asStringJMTWithOptionalCommas(false,true);
		
	elseif _attrName = ETRow_AvailHeight2  then
		if self.availStackHeights.size &gt;= 2 then
			stackHeightAvail := self.availStackHeights[2];
		endif;
		return stackHeightAvail.asStringJMTWithOptionalCommas(false,true);
		
	elseif _attrName = ETRow_AvailHeight3  then
		if self.availStackHeights.size &gt;= 3 then
			stackHeightAvail := self.availStackHeights[3];
		endif;
		return stackHeightAvail.asStringJMTWithOptionalCommas(false,true);
		
	elseif _attrName = ETRow_AvailHeight4  then
		if self.availStackHeights.size &gt;= 4 then
			stackHeightAvail := self.availStackHeights[4];
		endif;
		return stackHeightAvail.asStringJMTWithOptionalCommas(false,true);
		
	elseif _attrName = ETRow_AvailHeight5  then
		if self.availStackHeights.size &gt;= 5 then
			stackHeightAvail := self.availStackHeights[5];
		endif;
		return stackHeightAvail.asStringJMTWithOptionalCommas(false,true);
		
	elseif _attrName = ETRow_AvailHeight6  then
		if self.availStackHeights.size &gt;= 6 then
			stackHeightAvail := self.availStackHeights[6];
		endif;
		return stackHeightAvail.asStringJMTWithOptionalCommas(false,true);
		
	elseif _attrName = ETRow_AvailHeight7  then
		if self.availStackHeights.size &gt;= 7 then
			stackHeightAvail := self.availStackHeights[7];
		endif;
		return stackHeightAvail.asStringJMTWithOptionalCommas(false,true);
		
	elseif _attrName = ETRow_AvailHeight8  then
		if self.availStackHeights.size &gt;= 8 then
			stackHeightAvail := self.availStackHeights[8];
		endif;
		return stackHeightAvail.asStringJMTWithOptionalCommas(false,true);
	
	elseif  _attrName.isMeasurementType then
		_attrName.getRowNameMeasureType(etrowStr, measureType);	
		return self.getMeasurementStringForAttrib(etrowStr, measureType, _short);
	else
		return inheritMethod(_attrName, _short);
		
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementStringForAttrib" id="ce5f5420-01f2-4f2b-af3b-44fd3e11b699">
        <source>getMeasurementStringForAttrib(_attrName: String; _measureType: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 June 2016	cnwndl1	Initial creation	TFS 1752

*/

vars

begin
	
	
	if _attrName = ETRow_TotalWeight  then
		if self.totalWeight = 0 then
			return null;
		endif;
		return app.convertMeasurementForDisplay(_measureType, self.totalWeight); 
		
	elseif _attrName = ETRow_TotalVolume  then
		if self.totalVolume = 0 then
			return null;
		endif;
		return app.convertMeasurementForDisplay(_measureType, self.totalVolume);
		
	elseif _attrName = ETRow_TotalLength  then
		if self.totalLength = 0 then
			return null;
		endif;
		return app.convertMeasurementForDisplay(_measureType, self.totalLength * 100);	// length for ROR lane is stored in metres, but usually store in cm
	
	elseif _attrName = ETRow_CapacityWeight  then
		if self.capacityWeight = 0 then
			return null;
		endif;
		return app.convertMeasurementForDisplay(_measureType, self.capacityWeight);
		
	elseif _attrName = ETRow_CapacityVolume  then
		if self.capacityVolume = 0 then
			return null;
		endif;
		return app.convertMeasurementForDisplay(_measureType, self.capacityVolume);
		
	elseif _attrName = ETRow_CapacityLength  then
		if self.capacityLength = 0 then
			return null;
		endif;
		return app.convertMeasurementForDisplay(_measureType, self.capacityLength * 100); // length for ROR lane is stored in metres, but usually store in cm
		
	else	
		return inheritMethod(_attrName, _measureType, _short);
		
	endif;
	
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_measureType" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getParamString" id="5edf9294-fad4-44e6-b369-be7fb1151183">
        <source>getParamString(_short : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:		13 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	line : String;
begin
	if not self.allQryCargoTypes.isEmpty then
		if line &lt;&gt; null then
			line := line &amp; ";";
		endif;
		if _short then
			line := self.allQryCargoTypes.getDisplayCodes(_short);
		else
			line := "CargoType:" &amp; self.allQryCargoTypes.getDisplayCodes(_short);
		endif;
	endif;
	if not self.allQryContents.isEmpty then
		if line &lt;&gt; null then
			line := line &amp; ";";
		endif;
		if _short then
			line := line &amp; self.allQryContents.getDisplayCodes(_short);
		else
			line := line &amp; "ContentsStatus:" &amp; self.allQryContents.getDisplayCodes(_short);
		endif;
	endif;
	if not self.allQryIMEX.isEmpty then
		if line &lt;&gt; null then
			line := line &amp; ";";
		endif;
		if _short then
			line := line &amp; self.allQryIMEX.getDisplayCodes(_short);
		else
			line := line &amp; "ImExStatus:" &amp; self.allQryIMEX.getDisplayCodes(_short);
		endif;
	endif;
	if not self.allQryISOGroups.isEmpty then
		if line &lt;&gt; null then
			line := line &amp; ";";
		endif;
		if _short then
			line := line &amp; self.allQryISOGroups.getDisplayCodes(_short);
		else
			line := line &amp; "ISOGroups:" &amp; self.allQryISOGroups.getDisplayCodes(_short);
		endif;
	endif;
	if not self.allQryOperator.isEmpty then
		if line &lt;&gt; null then
			line := line &amp; ";";
		endif;
		if _short then
			line := line &amp; self.allQryOperator.getDisplayCodes(_short);
		else
			line := line &amp; "Operators:" &amp; self.allQryOperator.getDisplayCodes(_short);
		endif;
	endif;
	if not self.allQryPorts.isEmpty then
		if line &lt;&gt; null then
			line := line &amp; ";";
		endif;
		if _short then
			line := line &amp; "Ports:" &amp; self.allQryPorts.getDisplayCodes(_short);
		else
			line := line &amp; self.allQryPorts.getDisplayCodes(_short);
		endif;
	endif;
	if not self.allQryVoyages.isEmpty then
		if line &lt;&gt; null then
			line := line &amp; ";";
		endif;
		if _short then
			line := line &amp; self.allQryVoyages.getDisplayCodes(_short);
		else
			line := line &amp; "Voyages:" &amp; self.allQryVoyages.getDisplayCodes(_short);
		endif;
	endif;
	
	if line = null then
		line := "PARAMS:ALL";
	else
		if not _short then
		line := "PARAMS:" &amp; line;
		endif;
	endif;
	return line;
end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStackHeight" id="317d3039-3651-4d65-9528-9bb4e0697ed2">
        <source>getStackHeight() : Integer;
// ---------------------------------------------------------------------------
// Created:		13 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpTA : CM_TerminalAreaMaster;
begin
	tmpTA := self.getTA();
	if tmpTA = null then
		return 1;
	else
		return tmpTA.getHeightOfStack();
	endif;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTA" id="bbcf84d7-773e-46ba-ab4e-5ac8fd25969c">
        <source>getTA() : CM_TerminalAreaMaster;
// ---------------------------------------------------------------------------
// Created:		13 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpCode : String;
begin

	tmpCode := self.code;
	
	if self.isRoRoLane() then //05/09/2025	navkc1 JIRA 35622
		tmpCode := self.terminalAreaCode;
	endif;
	
	//return self.myTerminal.allTerminalAreaMastersById[self.code];
	return self.myTerminal.allTerminalAreaMastersById[tmpCode]; //05/09/2025	navkc1 JIRA 35622
end;</source>
        <ReturnType type="CM_TerminalAreaMaster"/>
    </JadeMethod>
    <JadeMethod name="hasCONT" id="9151dab4-4052-4cb5-a6d2-ef1272185f02">
        <source>hasCONT() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05/09/2025	navkc1 JIRA 35622 MSL | Terminal Utilization RoRo - Jade

*/

vars
	locn : CM_KPILocation;
begin
	
	foreach locn in self.allKIPLocations discreteLock do
		if locn.isCONT() then
			return true;
		endif;
	endforeach;
	
	return false;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initTA" id="0f654aac-23bd-4e92-b0cc-3fbda9677977">
        <updating/>
        <source>initTA(_max : Integer; _code : String) updating;
// ---------------------------------------------------------------------------
// Created:		13 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//26 Feb 2015  cnwma1 PAR # 33352 Space Utilisation functionality for Block Stacks
// ---------------------------------------------------------------------------
vars
begin
	//self.terminalAreaCode := _code;
	self.setTerminalAreaCode( _code );
	//self.maxStackHeight := _max;    //26/02/2015  cnwma1 PAR #33352
	
//20 Jul 2021	NDL	TFS 51518
	//	if not self.getTA.CM_TerminalArea.isBlockStack then  //26/02/2015  cnwma1 PAR #33352
		self.maxStackHeight :=_max;
		self.availStackHeights[_max]  := 0;
/*	else
		self.maxStackHeight :=0;
	endif; */
	

	
end;</source>
        <Parameter name="_max" type="Integer"/>
        <Parameter name="_code" type="String"/>
    </JadeMethod>
    <JadeMethod name="isKPITerminalArea" id="7fa53cdb-0315-4b02-9e2d-d16a11976b07">
        <source>isKPITerminalArea(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05/09/2025	navkc1 JIRA 35622 MSL | Terminal Utilization RoRo - Jade

*/

vars

begin
	return true;

epilog

