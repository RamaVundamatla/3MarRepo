    <JadeMethod name="validateForCreate" id="c9974d16-74b7-4bbb-8865-6cf54930c297">
        <source>validateForCreate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 January 2024	navra1	Initial creation

*/

vars

begin
	inheritMethod();
	
	if self.allEndpoints.first = null then
		if self.invoiceLinesPerBatch &lt; 3000 or self.invoiceLinesPerBatch &gt; 5000 then
			app.raiseCMException(Range_invalid_invoiceLines, "InvoiceLinesPerBatch", null);
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
