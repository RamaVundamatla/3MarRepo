    <JadeMethod name="getFileStatusForAuto" id="9f479383-9dc3-4744-95eb-cce385643075">
        <updating/>
        <source>getFileStatusForAuto( _isBGPAuto : Boolean; _ediControllerAgent	: CM_EDIControllerAgent ) updating;

// cnwdvb1 29 January 2003 

vars
	supportEmail,
	sendersEmail	: String;
	
begin
	if self.fileStatus = CM_EDIFile.EDI_STATUS_LOADED then 
		if _isBGPAuto then
			app.writeLog('Load successful for ' &amp; self.fileName, LogINFO);
		endif;
//		if self.ediData.singleDataFile then // cnwrs1 Par 24207 ccms 1117 11 May 2010
		
//		endif;
	else  //load unsuccessful
		if _isBGPAuto then
			supportEmail	:= app.myRoot.getConfig(AutoSupportEmailAddress).String;
			sendersEmail	:= app.myRoot.getConfig(AutoSendersEmailAddress).String;
			if self.fileStatus = CM_EDIFile.EDI_STATUS_LOADED_ERRORS then
				app.writeLog('Load failed for ' &amp; self.fileName, LogINFO);
//				app.remoteErrorWarningToAlert('Auto load failure ' &amp; self.fileName &amp; ' failed with status ' &amp; self.displayStatus,	// cnwrl1 31/03/2010 PAR 23432 - what it was
//				 null, null, null, false, true);		// cnwrl1 31/03/2010 PAR 23432 - what it was
				app.remoteErrorWarningToAlert(	'Auto load failure ' &amp; self.fileName &amp; ' failed with status ' &amp;
												_ediControllerAgent.displayStatus( self.fileStatus ),
												null,
												null,
												null,
												false,
												true );
//				app.myTrxCA.trxCreateEmailSendRequest('EDI',supportEmail, sendersEmail, null, null,  'Auto load failure',
//				 self.fileName &amp; " failed with status " &amp; self.displayStatus, null, null, null, null, EmailSource_EDI, self, app.myPassport);
				app.myTrxCA.trxCreateEmailSendRequest(	'EDI',
														supportEmail,
														sendersEmail,
														null,
														null,
														'Auto load failure',
														self.fileName &amp; " failed with status " &amp;
														_ediControllerAgent.displayStatus( self.fileStatus ),
														null,
														null,
														null,
														null,
														EmailSource_EDI,
														self,
														app.myPassport );
			elseif self.fileStatus = CM_EDIFile.EDI_STATUS_LOADING then 
				app.writeLog('Load in progress for ' &amp; self.fileName, LogINFO);
			else
//				app.writeLog("Load finished with unexpected status for " &amp; self.fileName &amp;  " of " &amp; self.displayStatus, LogAlways);	// cnwrl1 31/03/2010 PAR 23432 - what it was
				app.writeLog(	"Load finished with unexpected status for " &amp; self.fileName &amp;
								" of " &amp; _ediControllerAgent.displayStatus( self.fileStatus ),
								LogINFO );
//				app.remoteErrorWarningToAlert("Load finished with unexpected status for " &amp; self.fileName &amp;  " of " &amp; self.displayStatus,	// cnwrl1 31/03/2010 PAR 23432 - what it was
//				 null, null, null, false, true);				// cnwrl1 31/03/2010 PAR 23432 - what it was
				app.remoteErrorWarningToAlert(	"Load finished with unexpected status for " &amp; self.fileName &amp;
												" of " &amp; _ediControllerAgent.displayStatus( self.fileStatus ),
												null,
												null,
												null,
												false,
												true );
//				app.myTrxCA.trxCreateEmailSendRequest('EDI',supportEmail, sendersEmail, null, null, 'Auto load failure',	// cnwrl1 31/03/2010 PAR 23432 - what it was
//					 "Load finished with unexpected status for " &amp; self.fileName &amp;  " of " &amp; self.displayStatus, null, null, null, null, EmailSource_EDI, self, app.myPassport);	// cnwrl1 31/03/2010 PAR 23432 - what it was
				app.myTrxCA.trxCreateEmailSendRequest(	'EDI',
														supportEmail,
														sendersEmail,
														null,
														null,
														'Auto load failure',
														"Load finished with unexpected status for " &amp; self.fileName &amp;
														" of " &amp; _ediControllerAgent.displayStatus( self.fileStatus ),
														null,
														null,
														null,
														null,
														EmailSource_EDI,
														self,
														app.myPassport );
			endif;
		endif;
	endif;
	
end;
</source>
        <Parameter name="_isBGPAuto" type="Boolean"/>
        <Parameter name="_ediControllerAgent" type="CM_EDIControllerAgent"/>
    </JadeMethod>
    <JadeMethod name="getItemFields" id="8b8f11fe-2307-47a6-8068-9555bd2e827c">
        <source>getItemFields(_fields: CM_FieldByTypeSysNameDict input; _fieldClass: Class);
//----------------------------------------------------------------
//	Created:	07 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	props		: PropertyNDict;
	prop		: Property;
	field		: CM_EDIItemField;
begin
//	create props transient;
	_fields.clear;
	
	props := self.class.getProperties();

	foreach prop in props do
		if self.canUserSet(prop.name) then
			create field as _fieldClass transient;
			field.set(prop.name, false, prop.type.name, self.class.name);
			_fields.add(field);
		endif;
	endforeach;

end;</source>
        <Parameter name="_fields" type="CM_FieldByTypeSysNameDict" usage="input"/>
        <Parameter name="_fieldClass" type="Class"/>
    </JadeMethod>
