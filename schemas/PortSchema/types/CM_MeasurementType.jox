        <source>setIsDefaultToFalse() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 February 2013	cnwdap1	Initial creation
*/
vars

begin
	self.isDefault := false;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxy" id="dcc22abd-4776-408c-96e0-274c51a30c3f">
        <updating/>
        <source>setProxy(	_conversionRate 	 : Decimal;
			_format 			 : Decimal;
			_isAvailableForEntry : Boolean;
			_isDefault 			 : Boolean;
			_isDisplay 			 : Boolean;
			_isSystemType		 : Boolean;
			_shortName			 : String;
			_measurementType 	 : String;
			_name 				 : String;
			_formatPrecision     : Integer) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12/02/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
14/11/2022	navma1	ChangeRequest 55381: MTN - Store format's decimal precision on Measurement Type
*/
vars

begin
	self.raiseExceptionIfNotTransient(method);
	
	self.conversionRate			:= _conversionRate;
	self.format					:= _format;
	self.isAvailableForEntry	:= _isAvailableForEntry;
	self.isDefault				:= _isDefault;
	self.isDisplay				:= _isDisplay;
	self.isSystemType			:= _isSystemType;
	self.shortName				:= _shortName;
	self.measurementType		:= _measurementType;
	self.name					:= _name;
	self.formatPrecision        := _formatPrecision;			//14.11.2022 navma1 #55381
epilog

end;</source>
        <Parameter name="_conversionRate" type="Decimal"/>
        <Parameter name="_format" type="Decimal"/>
        <Parameter name="_isAvailableForEntry" type="Boolean"/>
        <Parameter name="_isDefault" type="Boolean"/>
        <Parameter name="_isDisplay" type="Boolean"/>
        <Parameter name="_isSystemType" type="Boolean"/>
        <Parameter name="_shortName" type="String"/>
        <Parameter name="_measurementType" type="String"/>
        <Parameter name="_name" type="String"/>
        <Parameter name="_formatPrecision" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateQueryDefinitions" id="3f4e5593-06af-4c8d-b642-0c62b93808e3">
        <source>updateQueryDefinitions(_create, _update, _delete : Boolean; _oldCode : String);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 21/08/2014	cnwdap1		Initial creation PAR #33253 Update query definitions
//							1. If I'm new, or I've changed to display and available, create definitions
//							2. If my code has changed, find and update all query defintions for me
//								And update all CM_XTABField or CM+XTABGrouping objects that use me
//							3. If I've changed to not available or not displayed, delete definitions
//
vars
	obj 		: Object;
	qDef 		: CM_QueryDefinition;
	allQDefs 	: ObjectArray;
	prop 		: CM_QueryProperty;
	pos 		: Integer;
	measure 	: CM_MeasurementType;
	newProperty : CM_QueryProperty;
	niceName 	: String;
	propName 	: String;
	allDeletes 	: ObjectArray;
	group 		: CM_XTABGrouping;
	field 		: CM_XTABField;
	userQuery : CM_MenuUserQuery;	//18 Nov 2014	NDL	Par 35215
	strArray : StringArray;	//18 Nov 2014	NDL	Par 35215
	attrName : String;	//18 Nov 2014	NDL	Par 35215
	checkForStr : String;	//18 Nov 2014	NDL	Par 35215
	checkLength : Integer;	//18 Nov 2014	NDL	Par 35215
	newAttrName : String;	//18 Nov 2014	NDL	Par 35215
	queryDef : CM_QueryDefinition;	//18 Nov 2014	NDL	Par 35215
	propDict : CM_QueryPropertyDict;	//18 Nov 2014	NDL	Par 35215
	queryProp : CM_QueryProperty;	//18 Nov 2014	NDL	Par 35215

begin
	create allDeletes transient;
	create allQDefs transient;
	CM_QueryDefinition.allInstances(allQDefs, null, true);
	
	foreach obj in allQDefs do
		qDef := obj.CM_QueryDefinition;
		pos := null;
		foreach prop in qDef.allQueryProperties discreteLock do
			// if we're creating query definitions, we need to figure out if this query definition maps to a 
			// measurement type of the same type as me
			if _create then
				pos := prop.propertyName.pos(CN_UNDERSCORE, 1);
				if pos &lt;&gt; null then
					measure := app.myRoot.allMeasurementTypesByShortName[prop.propertyName[1:pos-1]];
					if measure &lt;&gt; null and measure &lt;&gt; self and measure.measurementType = self.measurementType then
						propName := self.shortName &amp; CN_UNDERSCORE &amp; prop.propertyName[pos+1:end];
						if qDef.allQueryProperties[propName] = null then
							// create a property for me
							create newProperty as prop.class persistent;
							niceName := prop.niceName[1:(prop.niceName.pos(Left_Round_Bracket,1)-1)];
							niceName := niceName &amp; Left_Round_Bracket &amp; self.shortName &amp; Right_Round_Bracket;
							newProperty.set(niceName, propName, prop.propertyClassName);
							newProperty.setPerformanceRating( prop.performanceRating );		
							qDef.allQueryProperties.add(newProperty);
						endif;
					endif;
				endif;
				
			// if we're updating to a new code, check for a property with the old code's name
			elseif _update then
				if prop.propertyName[1:_oldCode.length] = _oldCode then
					pos := prop.propertyName.pos(CN_UNDERSCORE, 1);
					propName := self.shortName &amp; prop.propertyName[pos:end];
					niceName := prop.niceName[1:prop.niceName.pos(Left_Round_Bracket,1)-1];
					niceName := niceName &amp; Left_Round_Bracket &amp; self.shortName &amp; Right_Round_Bracket;
					prop.set(niceName, propName, prop.propertyClassName);
					prop.setPerformanceRating( prop.performanceRating );
				endif;
				
			// if we're deleting, store the property for purging later
			elseif _delete then
				if prop.propertyName[1:self.shortName.length] = self.shortName then
					allDeletes.add(prop);
				endif;
			endif;
		endforeach;
	endforeach;
	
	foreach obj in allDeletes do
		prop := obj.CM_QueryProperty;
		prop.myQueryDef.allQueryProperties.remove(prop);
	endforeach;
	allDeletes.purge;
	
	// for updates only, check all existing saved Summary fields and groups
	if _update then
		foreach group in CM_XTABGrouping.instances discreteLock do
			if group.propertyName[1:_oldCode.length] = _oldCode then
				propName := self.shortName &amp; group.propertyName[_oldCode.length+1:end];
				group.setPropertyValue(CM_XTABGrouping::propertyName.name, propName);
			endif;
		endforeach;
		foreach field in CM_XTABField.instances discreteLock do
			if field.propertyName[1:_oldCode.length] = _oldCode then
				propName := self.shortName &amp; field.propertyName[_oldCode.length+1:end];
				field.setPropertyValue(CM_XTABField::propertyName.name, propName);
			endif;
		endforeach;
		
		//18 Nov 2014	NDL	Par 35215 - Updating, do the selected columns in selector queries too
		checkForStr := _oldCode &amp; CN_UNDERSCORE;  // old code is the previous short name
		checkLength := checkForStr.length;
		foreach userQuery in CM_MenuUserQuery.instances discreteLock do
			strArray := userQuery.allVisibleColumns;
			foreach attrName in strArray do
				if attrName[1:checkLength] = checkForStr and attrName.length &gt; checkLength then
					newAttrName := self.shortName &amp; CN_UNDERSCORE &amp; attrName[ checkLength + 1 : end];
					queryDef := userQuery.getQueryDefinition();
					queryProp := null;
					if queryDef &lt;&gt; null then
						propDict := queryDef.allQueryProperties;
						queryProp := propDict[newAttrName];
					endif;
					if queryProp &lt;&gt; null then
						userQuery.replaceVisibleColumnName( attrName, newAttrName );
					endif;
				endif;
			endforeach;
		endforeach;
		
	endif;
	
epilog
	delete allQDefs;
	delete allDeletes;
end;</source>
        <Parameter name="_create" type="Boolean"/>
        <Parameter name="_update" type="Boolean"/>
        <Parameter name="_delete" type="Boolean"/>
        <Parameter name="_oldCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="bec2b608-e735-4ac6-a78f-c9cdccddbbdb">
        <source>validateForCreate();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12/02/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
11/07/2013	cnwdap1	PAR #31975 Move name and short name validation to validateForUpdate
*/
vars

begin
	self.validateForUpdate;
	// PAR #31975 Moved to validateForUpdate so changes to name and shortname are also checked
	/*if app.myRoot.allMeasurementTypesByShortName[self.shortName] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.shortName, null, null);
	endif;
	foreach measure in app.myRoot.allMeasurementTypesByShortName do
		if measure.name = self.name and measure &lt;&gt; self then
			app.raiseCMException1(VB_DUPLICATED_ITEM, self.name, null, null);
		endif;
	endforeach;*/
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="19374926-2a0f-468f-bc32-7b56e928958f">
        <source>validateForDelete();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13/02/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
10/06/2013	cnwdap1	PAR #31721 Additional checking before allowing delete
22/008/2014	cnwdap1	PAR #33235 Check for summaries using this measurement type
*/
vars
	cargoType		: CM_CargoType;			// PAR #31721
	cargoSubType	: CM_Product;			// PAR #31721
	inUse			: Boolean;				// PAR #31721
	cargoCode		: String;				// PAR #31721
	group			: CM_XTABGrouping;		// PAR #33235
	field			: CM_XTABField;			// PAR #33235
	checkForStr : String;	//18 Nov 2014	NDL	35215
	userQuery : CM_MenuUserQuery;	//18 Nov 2014	NDL	35215
	strArray : StringArray;	//18 Nov 2014	NDL	35215
	attrName : String;	//18 Nov 2014	NDL	35215
	invalid : Boolean;
	edition : Integer;
begin
	if self.isSystemType then
		app.raiseCMException1(CannotDeleteSysMeasureType, self.name, null, null);
	endif;
	
	if self.isDefault then
		app.raiseCMException3(CannotDeleteDefaultMeasureType, self.name, self.measurementType, self.name, null, null);
	endif;
	
	if not self.allCalculationTypes.isEmpty() then
		app.raiseCMException2(Canno_delet_measu_type_becau_u, self.name, self.allCalculationTypes.getCalcTypeList(), null, null);
	endif;
	
	// PAR #31721 start
	if not self.allWeightRanges.isEmpty then
		app.raiseCMException2(ObjectStillHasEntries, self.shortName, "Weight Ranges", null, null);
	endif;
	
	if not self.allEDIFieldMappings.isEmpty then
		app.raiseCMException2(ObjectStillHasEntries, self.shortName, "EDI Field Mappings", null, null);
	endif;
	
	on Exception do app.handleDeletedObject( exception, cargoSubType, invalid );
	
	foreach cargoType in app.myRoot.allCargoTypesById do
		if cargoType.mySystemProductType &lt;&gt; null then
			cargoSubType := cargoType.mySystemProductType;
			if cargoSubType = null then // 30 Apr 2021	NDL	Found in Unit test.
				continue;
			endif;
			edition := cargoSubType.edition;
			if invalid then
				invalid := false;
				continue;
			endif;
			if cargoSubType.myDensityDec &lt;&gt; null and cargoSubType.myDensityDec.myMeasurementType = self then		// ### TFS 52193 22Nov2021 NAVPW1
				inUse := true;
			elseif cargoSubType.getMyHeight &lt;&gt; null and cargoSubType.getMyHeight.myMeasurementType = self then
				inUse := true;
			elseif cargoSubType.getMyLength &lt;&gt; null and cargoSubType.getMyLength.myMeasurementType = self then
				inUse := true;
			elseif cargoSubType.getMyVolume &lt;&gt; null and cargoSubType.getMyVolume.myMeasurementType = self then
				inUse := true;
			elseif cargoSubType.getMyWeight &lt;&gt; null and cargoSubType.getMyWeight.myMeasurementType = self then
				inUse := true;
			elseif cargoSubType.getMyWidth &lt;&gt; null and cargoSubType.getMyWidth.myMeasurementType = self then
				inUse := true;
			endif;
			if inUse then
				cargoCode := cargoType.description;
				break;
			endif;
		else
			foreach cargoSubType in cargoType.allProducts do
				if cargoSubType.myDensityDec.myMeasurementType = self then		// ### TFS 52193 22Nov2021 NAVPW1
					inUse := true;
				elseif cargoSubType.getMyHeight.myMeasurementType = self then
					inUse := true;
				elseif cargoSubType.getMyLength.myMeasurementType = self then
					inUse := true;
				elseif cargoSubType.getMyVolume.myMeasurementType = self then
					inUse := true;
				elseif cargoSubType.getMyWeight.myMeasurementType = self then
					inUse := true;
				elseif cargoSubType.getMyWidth.myMeasurementType = self then
					inUse := true;
				endif;
				if inUse then
					cargoCode := cargoSubType.description;
					break;
				endif;
			endforeach;
		endif;
		
		if inUse then
			break;
		endif;
	endforeach;		
	if inUse then
		app.raiseCMException2(ObjectStillHasEntries, self.name, "Cargo Sub Type attribute (" &amp; cargoCode &amp; ")", null, null);
	endif;
	// PAR #31721 end
	
	// PAR #33235
	foreach group in CM_XTABGrouping.instances discreteLock do 
		if group.propertyName[1:self.shortName.length] = self.shortName then
			app.raiseCMException2(ObjectStillHasEntries, self.name, "Summary (" &amp; group.myOutputFormat.name &amp; ")", null, null);
			break;
		endif;
	endforeach;
	foreach field in CM_XTABField.instances discreteLock do 
		if field.propertyName[1:self.shortName.length] = self.shortName then
			app.raiseCMException2(ObjectStillHasEntries, self.name, "Summary (" &amp; field.myOutputFormat.name &amp; ")", null, null);
			break;
		endif;
	endforeach;
	// PAR #33235 end
	
	//18 Nov 2014	NDL	35215
	checkForStr := self.shortName &amp; "_";
	foreach userQuery in CM_MenuUserQuery.instances discreteLock do
		strArray := userQuery.allVisibleColumns;
		foreach attrName in strArray do
			if attrName.pos(checkForStr,1) = 1 then
				app.raiseCMException2(ObjectStillHasEntries, self.name, "Selector Query (" &amp; userQuery.heading &amp; ")", null, null);
				break;
			endif;
		endforeach;
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="4419af9e-5b2c-4bc1-a024-eb8a9e258769">
        <source>validateForUpdate();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12/02/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurement
11/07/2013	cnwdap1	PAR #31975 Validate shortName and name are unique regardless of case
25/08/2014	cnwdap1	PAR #33235 Measurement type changing to not available or not displayed can't have summaries
*/
vars
	measure			: CM_MeasurementType;
	realMeasure		: CM_MeasurementType;
	edition			: Integer;
	defaultFound	: Boolean;
	group			: CM_XTABGrouping;		// PAR #33235
	field			: CM_XTABField;			// PAR #33235
	realType		: CM_MeasurementType;	// PAR #33235

begin
	if self.name = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Measurement Name', null, null);
		app.raiseCMException(Input_required_field_measreNam, null, null); // cnwdb2	PAR 35364


	endif;
		
	if self.shortName = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Short Name', null, null);
		app.raiseCMException(Input_required_field_shrtName, null, null); // cnwdb2	PAR 35364


	endif;
		
	if self.measurementType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Measurement Type', null, null);
		app.raiseCMException(Input_required_field_measType, null, null);

	endif;
		
	if self.format = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Format', null, null);
		app.raiseCMException(Input_required_field_format, null, null); // cnwdb2	PAR 35364

	endif;
		
	if self.conversionRate = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Conversion Rate', null, null);
		app.raiseCMException(Input_required_field_convRate, null, null); // cnwdb2	PAR 35364


	endif;
	
	// PAR #31975 check that short names and names are unique						// PAR #31975
	if self.isTransient then														// PAR #31975
		realMeasure := self.pxyGetRealObject();										// PAR #31975
	else																			// PAR #31975
		realMeasure := self;														// PAR #31975
	endif;																			// PAR #31975
	foreach measure in app.myRoot.allMeasurementTypesByShortName do					// PAR #31975
		if measure.shortName.toUpper = self.shortName.toUpper 						// PAR #31975
		and measure &lt;&gt; realMeasure then												// PAR #31975
			app.raiseCMException1(VB_DUPLICATED_ITEM, self.shortName, null, null);	// PAR #31975
			return;																	// PAR #31975
		endif;																		// PAR #31975
		if (measure.name = self.name or measure.name.toUpper = self.name.toUpper)	// PAR #31975
		and measure &lt;&gt; realMeasure then 											// PAR #31975
			app.raiseCMException1(VB_DUPLICATED_ITEM, self.name, null, null);		// PAR #31975
			return;																	// PAR #31975
		endif;																		// PAR #31975
	endforeach;																		// PAR #31975
	
	// Are we changing from "default" to "non-default" and do we have a default type?
	if self.isTransient and not self.isDefault then
		self.pxyGetRealObjectAndEdition(realMeasure, edition);
		if realMeasure &lt;&gt; null and realMeasure.isDefault then
			foreach measure in app.myRoot.allMeasurementTypesByShortName where measure.measurementType = self.measurementType do
				if measure.isDefault and measure &lt;&gt; realMeasure then
					defaultFound := true;
					break;
				endif;
			endforeach;
			
			if not defaultFound then
				app.raiseCMException2(Measurement_Unit_No_Default, self.name, self.measurementType, null, null);
			endif;
		endif;
	endif;
		
	// PAR #33235
	if not self.isAvailableForEntry or not self.isDisplay then
		realType := self.pxyGetRealObject();
		if realType &lt;&gt; null and (realType.isDisplay &lt;&gt; self.isDisplay or realType.isAvailableForEntry &lt;&gt; self.isAvailableForEntry) then
			foreach group in CM_XTABGrouping.instances discreteLock do 
				if group.propertyName[1:self.shortName.length] = self.shortName then
					app.raiseCMException2(MeasureTypeInSummaries, self.shortName, " Summary " &amp; group.myOutputFormat.name, null, null);
					break;
				endif;
			endforeach;
			foreach field in CM_XTABField.instances discreteLock do 
				if field.propertyName[1:self.shortName.length] = self.shortName then
					app.raiseCMException2(MeasureTypeInSummaries, self.shortName, " Summary " &amp; field.myOutputFormat.name, null, null);
					break;
				endif;
			endforeach;
		endif;
	endif;
	// PAR #33235 end
epilog

end;</source>
    </JadeMethod>
</Class>
