    <JadeMethod name="x31460CreateReleaseRequest" id="a3afa5f6-a0f9-4935-9325-62c1a77c0cc6">
        <source>x31460CreateReleaseRequest(_releaseRequestId : String; _voyage : CM_Voyage; _releaseRequest : CM_BulkRelease io);

/*

Purpose:		Create Release Requests

Date			Who		Reason
24/04/2013		cnwmh5	Initial creation

*/

vars

begin

	self.deleteReleaseRequest(_releaseRequestId);
	_releaseRequest := addReleaseByTypeRequestOpts(_releaseRequestId, BR_TYPE_SHIP, TI_CargoType_Container);
	self.assertNotNull(_releaseRequest);
	self.assertTrue(_releaseRequest.requests.first.isKindOf(CM_DeliveryRequest));
	self.assertEqual(_releaseRequest.requests.first.CM_DeliveryRequest.voyageCode, _voyage.code);
	
epilog

end;</source>
