    </PrimAttribute>
    <JadeMethod name="setHeading" id="687b2e65-ee48-429f-95f8-73b7099e422c">
        <updating/>
        <source>setHeading(_str: String) updating;
// ---------------------------------------------------------------------------
// Created:     17 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.headingPrefix &lt;&gt; null then
		inheritMethod(self.headingPrefix &amp; ' (' &amp; _str &amp; ')');
	else
		inheritMethod(_str);
	endif;

end;</source>
        <Parameter name="_str" type="String"/>
    </JadeMethod>
