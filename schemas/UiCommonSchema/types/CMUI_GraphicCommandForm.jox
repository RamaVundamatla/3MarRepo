    <JadeMethod name="getCommandType" id="513cad79-5f95-413c-baa2-f6e74a9d387a">
        <source>getCommandType(_label : String) : Integer;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if _label = CM_GraphicCommand.LABEL_DRAW then
		return CM_GraphicCommand.TYPE_DRAW;
	elseif _label = CM_GraphicCommand.LABEL_ELIPSE then
		return CM_GraphicCommand.TYPE_ELIPSE;
	elseif _label = CM_GraphicCommand.LABEL_FILL then
		return CM_GraphicCommand.TYPE_FILL;
	elseif _label = CM_GraphicCommand.LABEL_RECTANGLE then
		return CM_GraphicCommand.TYPE_RECTANGLE;
	elseif _label = CM_GraphicCommand.LABEL_LINE then
		return CM_GraphicCommand.TYPE_LINE;
	elseif _label = CM_GraphicCommand.LABEL_STOP then
		return CM_GraphicCommand.TYPE_STOP;
	elseif _label = CM_GraphicCommand.LABEL_TEXT_POS then
		return CM_GraphicCommand.TYPE_TEXT_POS;
	elseif _label = CM_GraphicCommand.LABEL_STOP_FILL then
		return CM_GraphicCommand.TYPE_STOP_FILL;
	elseif _label = CM_GraphicCommand.LABEL_STRETCHXY then
		return CM_GraphicCommand.TYPE_STRETCHXY;
	elseif _label = CM_GraphicCommand.LABEL_FIRST_POINT then
		return CM_GraphicCommand.TYPE_FIRST_POINT;
	elseif _label = CM_GraphicCommand.LABEL_LAST_POINT then
		return CM_GraphicCommand.TYPE_LAST_POINT;
	elseif _label = CM_GraphicCommand.LABEL_CLEARHEIGHT then
		return CM_GraphicCommand.TYPE_CLEARHEIGHT;
	elseif _label = CM_GraphicCommand.LABEL_CLEARWIDTH then
		return CM_GraphicCommand.TYPE_CLEARWIDTH;
	elseif _label = CM_GraphicCommand.LABEL_ARC then
		return CM_GraphicCommand.TYPE_ARC;
	endif;
	return -1;

end;</source>
        <Parameter name="_label" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initTableDimensions" id="0cb27d3a-fe8d-41dd-a5db-dd0414b827ef">
        <source>initTableDimensions();
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theTable : CM_EntryTable;
begin
	theTable := self.tblDim;
	theTable.rows := 0;
	theTable.columns:= 0;
	theTable.columns:= 13;
	theTable.addItem("" &amp; Tab &amp; "Type" &amp; Tab &amp; "L Colour"&amp; Tab &amp; "F Colour" &amp; Tab &amp; "X1" &amp; Tab &amp; "Y1" &amp; Tab &amp; "X2" &amp; Tab &amp; "Y2" &amp; Tab &amp; "StartX" &amp; Tab &amp; "EndX" &amp; Tab &amp; "StartY" &amp; Tab &amp; "EndY" &amp;Tab &amp; "Note");
	theTable.fixedRows := 1;
	theTable.fixedColumns := 1;
	theTable.userInputEnabled := true;

	theTable.accessColumn(COLUMN_NUM).inputType := Table.InputType_None;
	theTable.accessColumn(COLUMN_TYPE).inputType := Table.InputType_None;
	theTable.accessColumn(COLUMN_COLOUR).inputType := Table.InputType_None;
	theTable.accessColumn(COLUMN_FILL).inputType := Table.InputType_None;
	theTable.accessColumn(COLUMN_X1).inputType := Table.InputType_TextNumeric;
	theTable.accessColumn(COLUMN_Y1).inputType := Table.InputType_TextNumeric;
	theTable.accessColumn(COLUMN_X2).inputType := Table.InputType_TextNumeric;
	theTable.accessColumn(COLUMN_Y2).inputType := Table.InputType_TextNumeric;
	//epr 8/8/08 ccms 1045
	theTable.accessColumn(COLUMN_STARTX).inputType := Table.InputType_TextNumeric;
	theTable.accessColumn(COLUMN_ENDX).inputType := Table.InputType_TextNumeric;
	theTable.accessColumn(COLUMN_STARTY).inputType := Table.InputType_TextNumeric;
	theTable.accessColumn(COLUMN_ENDY).inputType := Table.InputType_TextNumeric;
	theTable.accessColumn(COLUMN_LABEL).inputType := Table.InputType_TextBox;

	self.doResizeTable();


end;</source>
    </JadeMethod>
