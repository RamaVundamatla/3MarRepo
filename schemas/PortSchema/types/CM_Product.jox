    <JadeMethod name="getDefaultMeasurementForType" id="a0e30738-d1b2-4458-af51-ea38fa729e79">
        <source>getDefaultMeasurementForType(_type : String) : CM_MeasurementType;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19/03/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
27 Nov 2013	NDL	Par 33069 / cnwmc5 33075
*/
vars

	measureType : CM_MeasurementType;

begin 
	if _type = Type_Density then
		measureType := self.myDensityDec.myMeasurementType;		// ### TFS 52193 22Nov2021 NAVPW1
	elseif _type = Type_Volume then
		measureType := self.myVolume.myMeasurementType;
	elseif _type = Type_Weight then
		measureType := self.myWeight.myMeasurementType;
	elseif _type = Type_Height then
		measureType := self.myHeight.myMeasurementType;
	elseif _type = Type_Length then
		measureType := self.myLength.myMeasurementType;
	elseif _type = Type_Width then
		measureType := self.myWidth.myMeasurementType;
	elseif _type = Type_Density then
		measureType := self.myDensityDec.myMeasurementType;		// ### TFS 52193 22Nov2021 NAVPW1
	endif;
	if measureType = null then
		measureType := inheritMethod(_type);
	endif;
	
	return measureType;
	
epilog

end;</source>
        <Parameter name="_type" type="String"/>
        <ReturnType type="CM_MeasurementType"/>
    </JadeMethod>
    <JadeMethod name="getDefaultValueStringForType" id="9c1abc9a-8b2e-44d7-a3f0-208a47a78ea4">
        <source>getDefaultValueStringForType(_type : String)  : String;
/*

Date		Who		Reason
12 November 2013	cnwer1	Initial creation PAR 32951

*/

vars

begin
	if _type = Type_Density then
		return self.myDensityDec.getDefaultValueString(null);	// ### TFS 52193 22Nov2021 NAVPW1
	elseif _type = Type_Volume then
		return self.myVolume.getDefaultValueString(null);
	elseif _type = Type_Weight then
		return self.myWeight.getDefaultValueString(null);
	elseif _type = Type_Height then
		return self.myHeight.getDefaultValueString(null);
	elseif _type = Type_Length then
		return self.myLength.getDefaultValueString(null);
	elseif _type = Type_Width then
		return self.myWidth.getDefaultValueString(null);
	elseif _type = ETRow_MyWidthString then
		return self.myWidthString.getDefaultValueString(null);
	elseif _type =	ETRow_MyHeightString then
		return self.myHeightString.getDefaultValueString(null);
	elseif _type =	ETRow_MyLengthString then
		return self.myLengthString.getDefaultValueString(null);
	elseif  _type = ETRow_MyType then
		return self.myType.getDefaultValueString(null);
	elseif _type = ETRow_MyQuantity then
		return self.myQuantity.getDefaultValueString(null);
	endif;
epilog

end;</source>
