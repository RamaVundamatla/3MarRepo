    <JadeMethod name="setAddEditDelBtnState" id="0ca7e793-d790-4728-ba6e-0d09e0d185d2">
        <updating/>
        <source>setAddEditDelBtnState() updating;

vars

begin

 	// This method sets the Add, Edit and Delete button states according to 
 	// selectedShip&lt;&gt;null and and a selected row in the tblBerthPref
 	if self.myCurrentVessel = null
 	or self.mode = self.Mode_View then
 		// Ship not yet saved in DB - Set Add, Edit, Delete to disabled
 		btnAddPrefBerth.enabled:=false;
 		btnDelPrefBerth.enabled:=false;
 	else
 		// Ship is saved in DB
 		tblPrefBerth.column:=1;
		if self.mode = self.Mode_Add
		or self.mode = self.Mode_Update then 		
			if tblPrefBerth.row &gt; 1 then
	 			btnAddPrefBerth.enabled:=true;
	 			btnDelPrefBerth.enabled:=true;	
	 		else
	 			btnAddPrefBerth.enabled:=true;
	 			btnDelPrefBerth.enabled:=false;
	 		endif;
	 	endif;
 	endif;
end;</source>
    </JadeMethod>
