    <JadeMethod name="addToolbarControls" id="97c14c12-f9fc-467e-b5dc-0da7db183893">
        <updating/>
        <source>addToolbarControls() updating, protected;
//--------------------------------------------------
// Created:	22 January 2004 By: cnwgd1
//--------------------------------------------------
/*

Date		Who		Reason
31 Mar 2008	cnwkpd1	PAR #16388 - New Movements can not be created via this form for VCP mode,
					They must be maintained via the Global Voyage Definition
//03 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
*/

vars
	toolbar		: CMUI_Toolbar;
begin
	inheritMethod();
	
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnNew, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnEdit, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
//	toolbar.addFrame(self.frmToolbarMoves, CMUI_Toolbar.Control_Alignment_Left);		
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	toolbar.positionToolbarControls();
	toolbar.visible := true;

end;</source>
        <access>protected</access>
    </JadeMethod>
