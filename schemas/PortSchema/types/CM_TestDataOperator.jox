<Class name="CM_TestDataOperator" id="a189177d-c756-4789-b562-698a2f8d2ca2">
    <superclass name="CM_TestDataEntity"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="testData"/>
    <ExplicitInverseRef name="allTestProducts" id="14068616-61b4-47bf-bcd7-6661fbdaa41b">
        <kind>parent</kind>
        <type name="CM_TestDataEntityArray"/>
        <access>readonly</access>
        <Inverse name="CM_TestDataProductCode::myTestDataOperator"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myTestDataRoot" id="60b6d92e-5c80-4103-9ad3-4181f6532dfc">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_TestDataRoot"/>
        <access>readonly</access>
        <Inverse name="CM_TestDataRoot::allTestOperators"/>
    </ExplicitInverseRef>
    <PrimAttribute name="operatorCode" id="7806ca99-9d64-49b6-86b1-90ac1ddbb185">
        <length>11</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="createProductsForOperator" id="872a1150-2dfb-46ac-8089-fadd5b9da1b6">
        <source>createProductsForOperator();
// ---------------------------------------------------------------------------
// Created:     17 January 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpOperator	: CM_Operator;
	tmpPassport	: CM_Passport;
	tmpLogSpecs	: CM_CodeGroupLogSpecs;
	
begin

	tmpOperator := app.myRoot.allOperators[operatorCode];
	if tmpOperator = null then
		app.writeStatement( 'Operator null for (' &amp; operatorCode &amp; ')');
		return;
	endif;
	
	tmpLogSpecs := tmpOperator.allCodeGroups[CodeGroup_LogSpecs].CM_CodeGroupLogSpecs;
	if tmpLogSpecs = null then
		app.writeStatement( 'LogSpecs code group null for (' &amp; operatorCode &amp; ')');
		return;
	endif;

	create tmpPassport transient;
	
	tmpLogSpecs.createProductsForOperator(tmpOperator, tmpPassport);

epilog
	delete tmpPassport;

end;</source>
    </JadeMethod>
    <JadeMethod name="getMyOperator" id="47e2754c-824d-439a-8835-78d3b7bbfb41">
        <source>getMyOperator() : CM_Operator;
// ---------------------------------------------------------------------------
// Created:     17 January 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	return app.myRoot.allOperators[self.operatorCode];
end;</source>
        <ReturnType type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="getNextTestProduct" id="48cb724e-cd7c-4a23-8500-7404c346f4ff">
        <updating/>
        <source>getNextTestProduct() : CM_TestDataProductCode updating;

vars
	tmpProd	: CM_TestDataProductCode;
	
begin

	beginTransaction;
	exclusiveLock(self.allTestProducts);
	tmpProd := self.allTestProducts.first.CM_TestDataProductCode;
	self.allTestProducts.removeAt(1);
	self.allTestProducts.add(tmpProd);
	commitTransaction;
	
	return tmpProd;

end;</source>
        <ReturnType type="CM_TestDataProductCode"/>
    </JadeMethod>
    <JadeMethod name="init" id="c2912879-08d8-4564-90ae-88ad7b611564">
        <updating/>
        <source>init(_operator : CM_Operator; _root : CM_TestDataRoot input) updating;

vars
	testProdCode	: CM_TestDataProductCode;
	tmpProduct		: CM_Product;
	
begin

	self.operatorCode := _operator.code;
	self.createProductsForOperator();

	foreach tmpProduct in _operator.allProducts do
		create testProdCode persistent;
		testProdCode.setForCreate(_operator, tmpProduct);
		self.allTestProducts.add(testProdCode);
		// add this as it is array
		_root.allTestProducts.add(testProdCode);
	endforeach;
	
	self.myTestDataRoot := _root;

end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_root" type="CM_TestDataRoot" usage="input"/>
    </JadeMethod>
</Class>
