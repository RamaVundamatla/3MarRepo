    <JadeMethod name="ndl030" id="1cdd01d6-6969-438e-9ba2-c7ace95d7f2d">
        <source>ndl030();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 September 2014	cnwndl1	Initial creation  - Hubble Export
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	formatObj : CnEcXmlFormat;
	formatDataArrayObj : ObjectArray;
	instanceObj : Object;
	oidTableRootObj : CnEcOidTable;
	hubbleObj : CnEcHubble;
	
	errorFileName : String;
	inputFileName : String;
	noidFileName : String;
	logFileName : String;
	outputFileName : String;
	formatName : String;

begin

	app.cnEcInitializeBaseSchema();
	app.cnEcSetXmlSchema("PortSchema");
	app.cnEcSetBaseRoot(false);

	inputFileName := null;
//	errorFileName := "C:\XMLUtility\UserError.txt";
//	noidFileName := "C:\XMLUtility\UserNoid.txt";
	outputFileName := "C:\XMLUtility\UserMain.txt";
//	logFileName :="C:\XMLUtility\UserLog.txt";

	formatName := "UserCompare";
	formatObj := app.myBaseRoot.getXmlFormat("PortSchema", formatName);
	
	write formatObj;
	create formatDataArrayObj transient;
	CM_User.instances.copy( formatDataArrayObj );
	write formatDataArrayObj.size().String &amp; " objects being extracted.";
	
	create oidTableRootObj transient;
	create hubbleObj transient;
	
	hubbleObj.initializeMe(	errorFileName,
							inputFileName,
							noidFileName,
							logFileName,
							outputFileName,
							formatName,
							oidTableRootObj,
							formatDataArrayObj);
	
	write "Hubble exporting...." &amp; " - " &amp; app.actualTimeServer().Time.String;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	
    if formatDataArrayObj.size() &lt; 1000 then
    	hubbleObj.export(0,false);
 	else
 		hubbleObj.export((formatDataArrayObj.size() div 10),false);
 	endif;   	   	
    
    write "Hubble exporting complete, deleting transients...." &amp; " - " &amp; app.actualTimeServer().Time.String;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	       

epilog

	delete formatDataArrayObj;
	delete oidTableRootObj;
	delete hubbleObj;

end;</source>
    </JadeMethod>
    <JadeMethod name="ndlCountForms" id="0a7325cd-7994-4bd7-8160-43bdc49ea222">
        <source>ndlCountForms();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 July 2016	cnwndl1	Initial creation

*/

vars

	schema : Schema;
	classColl : ClassColl;
	class : Class;
	iterClass : Iterator;
	count : Integer;
	schemaCount : Integer;
	
	
	schemaArray : ObjectArray;
	obj : Object;
	
begin

	create schemaArray transient;

	schema := currentSchema;
	while schema.name &lt;&gt; "PortSchema" do
		schema := schema.superschema;
	endwhile;
	
	schemaArray.add(schema);
	ndlCountFormsGetSubschemas( schema, schemaArray	);
	
	
	
	foreach obj in schemaArray do
		schema := obj.Schema;
		schemaCount:= 0;
		classColl := schema.getAllClasses(false);

	
		iterClass := classColl.createIterator;
		while iterClass.next( class ) do
			if not class.inheritsFrom( CM_BaseForm ) then
				continue;
			endif;	
			if class.schema &lt;&gt; schema then
				continue;
			endif;
			count := count + 1;
			schemaCount := schemaCount + 1;
				
		endwhile;
		
		delete classColl;
		write schema.name &amp; " - " &amp; schemaCount.String &amp; " forms";
	
	endforeach;
	
	write "Total = " &amp; count.String;
	
epilog

	delete classColl;
	delete iterClass;	
	delete schemaArray;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="ndlCountFormsGetSubschemas" id="82c4368a-910a-462c-9f40-613e9785d575">
        <source>ndlCountFormsGetSubschemas( _schema : Schema; _schemaArray : ObjectArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 July 2016	cnwndl1	Initial creation

*/

vars

	subs : SchemaNDict;
	schema : Schema;

begin

	_schemaArray.add( _schema );

	create subs transient;
	_schema.getSubschemas( subs );
	
	foreach schema in subs do
		self.ndlCountFormsGetSubschemas( schema, _schemaArray );
	endforeach;

epilog

	delete subs;

end;</source>
        <Parameter name="_schema" type="Schema"/>
        <Parameter name="_schemaArray" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="ndlCountRealDBClasses" id="79e568f1-c573-4265-b5a9-33453362b31b">
        <source>ndlCountRealDBClasses();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 November 2020	jlgndl1	Initial creation

*/

vars

	schema : Schema;
	classColl : ClassColl;
	class : Class;
	iterClass : Iterator;
	count : Integer;
	schemaCount : Integer;
	
	
	schemaArray : ObjectArray;
	obj : Object;
	
begin

	create schemaArray transient;

	schema := currentSchema;
	while schema.name &lt;&gt; "PortSchema" do
		schema := schema.superschema;
	endwhile;
	
	schemaArray.add(schema);
//	ndlCountFormsGetSubschemas( schema, schemaArray	);
	
	
	
	foreach obj in schemaArray do
		schema := obj.Schema;
		schemaCount:= 0;
		classColl := schema.getAllClasses(false);

	
		iterClass := classColl.createIterator;
		while iterClass.next( class ) do
		//	if not class.inheritsFrom( CM_Object ) then
			if not class.inheritsFrom( CM_FinancialObject ) then
				continue;
			endif;	
			if class.schema &lt;&gt; schema then
				continue;
			endif;
			count := count + 1;
			schemaCount := schemaCount + 1;
				
		endwhile;
		
		delete classColl;
		write schema.name &amp; " - " &amp; schemaCount.String &amp; " CM_Object classes";
	
	endforeach;
	
	write "Total = " &amp; count.String;
	
epilog

	delete classColl;
	delete iterClass;	
	delete schemaArray;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="ndlDeletEmptyVoyages" id="ee315062-bce5-48ba-a47c-228252b4221f">
        <source>ndlDeletEmptyVoyages();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 October 2019	jlgndl1	Initial creation

*/

vars

	term : CM_Terminal;
	voyage : CM_Voyage;
	createdBefore : Date;
	voyagesToDelete : CM_ObjectArrayActual;
	skipVoyages : CM_VoyageSet;
	voyAllocsToDelete  : CM_YardAllocationSet;
	cmObj : CM_Object;

begin

	create voyagesToDelete transient;
	create voyAllocsToDelete transient;

	term := CM_Root.firstInstance.allTerminals.getAtKey("T4");
	app.myPassport.setMyTerminal( term );
	createdBefore := "01 Jan 2019".Date;
	
	create skipVoyages transient;	// add the corruptted ones into here for further investigation later.
//	skipVoyages.add( "4480.212".asOid.CM_Voyage );
//	skipVoyages.add( "4480.463".asOid.CM_Voyage );
	
	foreach voyage in term.allVoyagesByCode do
		if voyage.archived then
			continue;
		endif;
		if skipVoyages.includes( voyage ) then
			continue;
		endif;
		if voyage.creationTime.Date &gt;= createdBefore then
			continue;
		endif;
		if not voyage.allOnshipTIsByCargoTypeId.isEmpty then
			continue;
		endif;
		if not voyage.allOffloadedTIsByCargoTypeId.isEmpty then
			continue;
		endif;
		if not voyage.allOnsiteTIsByCargoTypeId.isEmpty then
			continue;
		endif;
		if not voyage.allNotifiedTIsByCargoTypeId.isEmpty then
			continue;
		endif;
		if not voyage.allOffsiteTIsByCargoTypeId.isEmpty then
			continue;
		endif;
		
		if not voyagesToDelete.includes(voyage) then
			voyagesToDelete.add( voyage );
			if not voyage.allVoyageAllocations.isEmpty then
				voyage.allVoyageAllocations.copy(voyAllocsToDelete);
			endif;
		endif;
		
	endforeach;
	
//	voyagesToDelete.inspectModal();
//	voyAllocsToDelete.inspectModal();
	
	if not voyAllocsToDelete.isEmpty then
			while true do
			app.myTrxDA.trxDeleteVoyageAllocations(voyAllocsToDelete, app.myPassport);
			if app.myPassport.trxCompletedOK then
				break;
			elseif app.myPassport.hasErrors then
				write app.myPassport.getErrorsAndWarningsAsString;
				break;
			else
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endwhile;
	endif;
	
	if not voyagesToDelete.isEmpty then
		foreach cmObj in voyagesToDelete do
			while true do
				app.myTrxDA.trxDeleteCMObject(cmObj, app.myPassport);
				if app.myPassport.trxCompletedOK then
					break;
				elseif app.myPassport.hasErrors then
					write app.myPassport.getErrorsAndWarningsAsString;
					break;
				else
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endwhile;
		endforeach;
	endif;


epilog

	delete voyagesToDelete;
	delete skipVoyages;
	delete voyAllocsToDelete;

end;</source>
    </JadeMethod>
    <JadeMethod name="ndlDeleteOldBookings" id="7f174ed6-970e-4fea-8512-b3a8cdac4baa">
        <source>ndlDeleteOldBookings();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 October 2019	jlgndl1	Initial creation

*/

vars

	term : CM_Terminal;
	bulk : CM_BulkRelease;
	createdBefore : Date;
	
	bulkRelsToDelete : CM_BulkReleaseSet;

begin

	term := CM_Root.firstInstance.allTerminals.getAtKey("T4");
	app.myPassport.setMyTerminal( term );
	createdBefore := "01 Jan 2018".Date;
	
	create bulkRelsToDelete transient;
	
	foreach bulk in term.allBulkReleasesByCodeDate discreteLock do
		if bulk.isInterTerminalBulkRelease then
			continue;
		endif;
		if bulk.creationTime.Date &gt;= createdBefore then
			continue;
		endif;
		bulkRelsToDelete.add( bulk );
	endforeach;
	
	bulkRelsToDelete.inspectModal();
	
	foreach bulk in bulkRelsToDelete do
		while true do
			app.myTrxDA.trxDeleteBulkRelease( bulk, app.myPassport );
			if app.myPassport.trxCompletedOK then
				break;
			elseif app.myPassport.hasErrors then
				write app.myPassport.getErrorsAndWarningsAsString;
				break;
			else
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endwhile;
	endforeach; 
	
	//If you get "Code :87384. Release Request 570404844 already has items released and cant be deleted while active." or a bulk rel;ease doesn't delete
	//Go to Release Requests form and find it, then change its status to Complete, and then delete it.

epilog

	delete bulkRelsToDelete;

end;</source>
    </JadeMethod>
    <JadeMethod name="ndlDeleteOldPreNotes" id="2b5075ab-ead6-4024-b5eb-146a4ec8ef3a">
        <source>ndlDeleteOldPreNotes();
/*

