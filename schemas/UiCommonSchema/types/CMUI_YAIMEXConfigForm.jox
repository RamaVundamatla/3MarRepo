    <JadeMethod name="doControlEvent" id="3bd1160b-a9af-43bb-84ec-94b10ee8823e">
        <updating/>
        <source>doControlEvent(_control: Control) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 January 2009	cnwjk3	SFW1030

*/

vars
	objSelectedArray : ObjectArray;
begin
	inheritMethod(_control);
	if _control = self.mltFields.myAddSelectedBtn or
	   _control = self.mltFields.myAddAllBtn or		
	   _control = self.mltFields.myRemoveSelectedBtn or
	   _control = self.mltFields.myRemoveAllBtn then
		   
		create objSelectedArray transient;
		
		// Store the currently selected items
		self.mltGroup.getSelected(objSelectedArray);
		
		// Remove all items from Group available list and Group Slected list
		self.mltGroup.clearSelected();
		self.mltGroup.myAvailableListBox.clear();
		
		// Copy all from Fileds selected list to Group available list
		self.populateGroupAvailable();
		
		// Re-select the items
		self.mltGroup.setSelected(objSelectedArray);
		self.populateColourSourceCombo(); //cnwrd1 ccms 2115 par 28185 12.9.2011
	endif;	
epilog
	delete objSelectedArray;
end;</source>
        <Parameter name="_control" type="Control"/>
    </JadeMethod>
    <JadeMethod name="doOK" id="f603840d-b770-4f12-8b68-8854cfcc7ba0">
        <updating/>
        <source>doOK() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
29 August 2008	consw1	Initial creation

*/

vars

begin
	if self.saveData() then
		inheritMethod();
		return;
	endif;

	app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Update);
	
epilog

end;</source>
    </JadeMethod>
