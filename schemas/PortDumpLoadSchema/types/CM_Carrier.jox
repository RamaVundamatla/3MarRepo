<Class name="CM_Carrier">
    <JadeMethod name="importPLXMLReference" id="7b8df79c-a71c-44df-8a9f-e365767953f0">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = CM_Carrier::myRoot.name then
		return app.myRoot;
	else
		return null;
	endif;
end;</source>
