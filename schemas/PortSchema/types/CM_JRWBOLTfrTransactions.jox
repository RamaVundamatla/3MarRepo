epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="masterBillOperator" id="63b8ce71-a8d8-44a0-b5e1-370e309a5169">
        <source>masterBillOperator():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2016	cnwndl1	Initial creation	TFS	1904

*/

vars

begin

	if self.myStartingBOLIn &lt;&gt; null and self.myStartingBOLIn.myOperator &lt;&gt; null  then
		return self.myStartingBOLIn.myOperator.code;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="masterBillVoyage" id="e3e75449-6382-4873-80f9-8a9bad121634">
        <source>masterBillVoyage():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2016	cnwndl1	Initial creation	TFS	1904

*/

vars

begin

	if self.myVoyage &lt;&gt; null then
		return self.myVoyage.code;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setMyPopulatingBOL" id="99ea182a-60bc-4265-8c22-6302ba5f115c">
        <updating/>
        <source>setMyPopulatingBOL( _bol : CM_BOLIn ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2016	cnwndl1	Initial creation	TFS 1904

*/

vars

	testing : Boolean;

	ti : CM_TrackedItem;
	workTrxs1 : CM_BOLTfrTransByTiDict;
	workTrxs2 : CM_BOLTfrTransByTiDict;
	str : String;
	lastBolTrx : CM_BOLTransferTransaction;
	bolTrx : CM_BOLTransferTransaction;
	bolTfrTransTi : CM_JRWBOLTfrTransTi;	
	dataLine : CM_JRWBOLTfrTransTi;

begin

	self.myStartingBOLIn := _bol;
	if self.myStartingBOLIn = null then
		return;
	endif;

	self.myVoyage := self.myStartingBOLIn.getMyVoyage;
	if self.myVoyage = null then
		return;
	endif;
	
	// gather up the Bol Transfer transactions up and down the tree, and the related ti's
	self.myStartingBOLIn.getBolTfrTransAndTis( self.allTrx, self.allTIs );
	
	create workTrxs1 transient;
	create workTrxs2 transient;
	
	self.allTrx.copy(workTrxs1);
	
	foreach ti in self.allTIs do
		//get the collection of trx relating to this ti.
		workTrxs1.getTfrTrnsForTi( workTrxs2, ti, true );
		//get the string representation of the Transfer History for this TI thru the selected BOLs
		str := workTrxs2.getBolTfrHistForTi( ti, lastBolTrx );
		bolTfrTransTi := self.addBOLTfrTransTi( str, ti, lastBolTrx );
		foreach bolTrx in workTrxs2 do
			str := bolTrx.getSourceBolString;
			if str = "None" then
				str := bolTrx.getTargetBolString;
			endif;
			bolTfrTransTi.masterBolNumber := str;
			break;
		endforeach;
	endforeach;
	
	testing := false;
	//testing := (app.name = "EntTableMaintApp"); // to make true if run from a dev script;
	if testing then
		write "Master Bill " &amp; self.masterBillNumber &amp; ", Operator " &amp; self.masterBillOperator &amp; ", Operator " &amp; app.actualTimeServer.Date.String;
		write "Voyage " &amp; self.masterBillVoyage &amp; ", Discharge port " &amp; self.masterBillDischarge;
		write "--------------------------------------------------";
		write "HouseBills, Voyage, CargoId, Operator, Commodity, Weight, Quantity";
		foreach dataLine in self.allTfrsByCargoId do
			write dataLine.houseBOLHistoryStr &amp; ", " &amp; dataLine.voyageCode &amp; ", " &amp; dataLine.cargoId &amp; ", " &amp; dataLine.operatorCode &amp; ", " &amp; dataLine.commodity &amp; ", " &amp; dataLine.weight.String &amp; ", " &amp; dataLine.quantity.String;
		endforeach;
	endif;

epilog

	delete workTrxs1;
	delete workTrxs2;

end;</source>
        <Parameter name="_bol" type="CM_BOLIn"/>
    </JadeMethod>
</Class>
