    <JadeMethod name="readFromINISettings" id="2a188022-f739-4808-8ed0-defa01c5b6d4">
        <updating/>
        <source>readFromINISettings() protected, updating;
/*

Purpose:			Read through the environment INI file and set any Web Service specific settings

Parameters:			

Return Value:		

Date			Who		Reason
04 May 2020		jlgmd1	Initial creation TFS #49214 STWR - Further enhancements to handle deadlocks when Packing a Container

*/

constants
	LowEDIPriDef : String = "false";
vars
	iniValue : String;
begin
	// EDI Processing Low Priority [values: true|false, default: false]
	iniValue := app.getProfileStringMyIni(JMTWebService_Section, JMTWebService_LowPriorityEDI, LowEDIPriDef);
	self.lowPriorityEDI := iniValue.Boolean;
	app.writeLog("Low Priority EDI Processing: " &amp; iniValue.Boolean.String, LogINFO);
	
epilog

end;</source>
