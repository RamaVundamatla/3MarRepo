// 08/12/2022	navdap1		Initial creation TFS 55159 MTN Export CMAS to JSON API Endpoint
//
vars

begin
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="c7ff5328-47d6-4222-8d51-f316ca544dd0">
        <source>pxyCreateUpdateProxy(): SelfType;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 13/01/2023	navdap1		Initial creation TFS 55159 MTN Export CAMS to JSON API Endpoint
//
vars
	pxyCamsAct : CM_EWSActivityCams;

begin
	pxyCamsAct := inheritMethod();
	
	pxyCamsAct.myCamProtocol := self.myCamProtocol;
	pxyCamsAct.myCamTaskHistory:=self.myCamTaskHistory;  //jlier1 TFS  58637 20/6/23
	
	return pxyCamsAct;

epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="8c3f6a80-baa0-4e9f-baac-4df4c564c42e">
        <updating/>
        <source>setForCreate(_proxy: SelfType) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 12/01/2023	navdap1		Initial creation TFS 55159 MTN Export CAMS to JSON API Endpoint
//
vars

begin
	inheritMethod(_proxy);
	self.setForUpdate(_proxy);
epilog

end;</source>
        <Parameter name="_proxy" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="983bacac-cf6c-4354-b6e2-fb3fb120c768">
        <updating/>
        <source>setForUpdate(_proxy: SelfType) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 12/01/2023	navdap1		Initial creation TFS 55159 MTN Export CAMS to JSON API Endpoint
//
vars

begin
	inheritMethod(_proxy);
	
	self.msgIndex:=_proxy.msgIndex;  //jlier1 TFS  58637 20/6/23
	self.myCamProtocol := _proxy.myCamProtocol;
	self.myCamTaskHistory := _proxy.myCamTaskHistory;
epilog

end;</source>
        <Parameter name="_proxy" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setMyCamTaskHistory" id="5aa89909-7eee-4097-b820-1af3d8a15cd9">
        <updating/>
        <source>setMyCamTaskHistory(_camHistory : CM_CamTaskHistory; _msgIndex : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2023	jlier1	Initial creation  TFS 58637 

*/

vars

begin
	self.myCamTaskHistory:=_camHistory;
	self.msgIndex:=_msgIndex;
epilog

end;</source>
        <Parameter name="_camHistory" type="CM_CamTaskHistory"/>
        <Parameter name="_msgIndex" type="Integer"/>
    </JadeMethod>
</Class>
