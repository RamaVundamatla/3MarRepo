/*

Purpose:			Creates a new Invoice Note from Proxy object passed in and gives a new invoice note out

Parameters:			_pxyInvoiceNote	CM_InvoiceNote	Proxy invoice note to create real object from (Input meaning it gets passed in as a constant)
					_newInvoiceNote	CM_InvoiceNote	Real Invoice Note created (Output meaning it is passed outwards)
					_passport		CM_Passport		Passport to use for our Trx that holds errors and other useful data

Return Value:		None

Date		Who		Reason
03 February 2022	navpw1	Initial creation TFS: 52752

*/

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;

	// Perform the operation
	app.myUtilityCA.utlCreateInvoiceNote(_pxyInvoiceNote, _newInvoiceNote, _realInvoice, _passport);
	
epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
