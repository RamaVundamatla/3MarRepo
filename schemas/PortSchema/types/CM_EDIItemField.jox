    <DbClassMap file="edi"/>
    <ImplicitInverseRef name="allFieldAdditionals" id="1936da7b-151c-40fc-96a1-7216eda5de48">
        <memberTypeInverse/>
        <type name="CM_ObjectArray"/>
        <access>readonly</access>
        <text>
All additional file fields that combine to make up the system field value.

One system field can be set by many file fields.

Concat. all 'value' fields in order.</text>
    </ImplicitInverseRef>
    <ExplicitInverseRef name="myFileFormatEDI" id="67640af4-ffc1-4949-8d28-072031d16a2b">
        <kind>child</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_FileFormatEDI"/>
        <access>readonly</access>
        <Inverse name="CM_FileFormatEDI::allFileFieldsByName"/>
        <Inverse name="CM_FileFormatEDI::allFileFieldsBySysName"/>
    </ExplicitInverseRef>
    <JadeMethod name="addFieldAdditional" id="c18105a8-e4e2-4048-a39d-e5e66a32fd7f">
        <source>addFieldAdditional(_itemField: SelfType);
//----------------------------------------------------------------
//	Created:	10 December 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if _itemField &lt;&gt; null then	
		self.allFieldAdditionals.add(_itemField);
	endif;
	
end;</source>
        <Parameter name="_itemField" type="SelfType"/>
    </JadeMethod>
