<Class name="CM_EDIDataToDoTask" id="893c9bba-29ae-45f1-8bbd-d5f906c03fd8">
    <superclass name="CM_EDIData"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <JadeMethod name="constructCMIFDictDefinition" id="d057c522-6b08-4a16-b268-d6f03ffec0c1">
        <source>constructCMIFDictDefinition( _cmifList : DynaDictionary input);
// ---------------------------------------------------------------------------
// Created:	21 February 2010 By Graeme Black cnwgb1 PAR 22022 MSL CCMS 1069
// Purpose:	Construct the definition of the Dynadict that will hold the 
//			parameters for the trx.
// ---------------------------------------------------------------------------
vars
begin
	_cmifList.setMembership(CMIF_EDIToDoTask);
	_cmifList.addMemberKey("id", false, false);
	_cmifList.addMemberKey("cargoType", false, false);
	_cmifList.endKeys(false);
end;</source>
        <Parameter name="_cmifList" type="DynaDictionary" usage="input"/>
    </JadeMethod>
    <JadeMethod name="constructCMIFs" id="7c11017e-6ebc-4bde-80a7-24c6fa003d15">
        <source>constructCMIFs(_cmifList : DynaDictionary  input) ;
// ---------------------------------------------------------------------------
// Created:	21 February 2010 By Graeme Black cnwgb1 PAR 22022 MSL CCMS 1069
// Status: 	
// Purpose:	Create a parameter list for passing to the transaction layer
// ---------------------------------------------------------------------------
vars
	cmifToDoTask : CMIF_EDIToDoTask; // A member of the list we are creating
	ediTrackedItem : CM_EDITrackedItem; // Generic EDI record
	ediToDoTaskTI : CM_EDIToDoTaskTI; // EDI ToDoTask record
	
begin
	//Start with an empty list
	_cmifList.purge();
	
	foreach ediTrackedItem in self.allEDITrackedItems do 
		ediToDoTaskTI := ediTrackedItem.CM_EDIToDoTaskTI;
		if ediToDoTaskTI &lt;&gt; null then
			cmifToDoTask := _cmifList.getAtKey( ediToDoTaskTI.id, ediToDoTaskTI.cargoType ).CMIF_EDIToDoTask;
			if cmifToDoTask = null then 
				// First time we have encountered this cargo in this file, need to create an entry in the cmif list
				create cmifToDoTask transient;
				cmifToDoTask.setKey( ediToDoTaskTI.id, ediToDoTaskTI.cargoType );
				_cmifList.add( cmifToDoTask );
			endif;
			
			//Add the Task to the appropriate list to be actioned later.
			if ediToDoTaskTI.messageMode = "A" then 
				cmifToDoTask.allTasksToAdd.add( ediToDoTaskTI.taskCode );
			elseif ediToDoTaskTI.messageMode = "U" and ediToDoTaskTI.isComplete then 
				cmifToDoTask.allTasksToComplete.add( ediToDoTaskTI.taskCode );
			elseif ediToDoTaskTI.messageMode = "D"then
				cmifToDoTask.allTasksToRemove.add( ediToDoTaskTI.taskCode );
			endif;
			
		endif;
	endforeach;
	
epilog
end;</source>
        <Parameter name="_cmifList" type="DynaDictionary" usage="input"/>
    </JadeMethod>
