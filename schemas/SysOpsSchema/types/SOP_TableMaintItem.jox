    <JadeMethod name="setConvertedDisplayValue" id="fd27984b-854e-4100-b492-865467d5558f">
        <source>setConvertedDisplayValue( _table : CM_EntryTable input; _rowName : String; _rawValue : Decimal; _measureType : CM_MeasurementType ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 March 2014	cnwndl1	Initial creation	Par 33268 - Populates the table string value in the measurement table values directly from the raw database value
28 Nov   2014   cnwma1						Par 35281 - Terminal Admin Machines
*/

vars

	rawValue : Decimal [16,4];
	convertedValue : String;
	prefix : String;
	measure : CM_MeasurementType;
begin

	rawValue := _rawValue;

	convertedValue := app.convertMeasurementForDisplay(_measureType.shortName, rawValue) &amp; Space &amp; _measureType.shortName;
	if not app.myRoot.getConfig(MeasuresSeparateLines).Boolean then
		self.myForm.getMultiValueConvertedString( rawValue, _measureType, convertedValue );
	endif;
	
	prefix := app.getMeasurementPrefixFromType( _measureType.measurementType );

	_table.setValueByName(_rowName, convertedValue);
	_table.setValueByName( prefix &amp; _rowName &amp; "_" &amp; _measureType.shortName, convertedValue );
	
	if app.myRoot.getConfig(MeasuresSeparateLines).Boolean then		//cnwmc5 - 24 Nov 2015 - PAR 36960 - only needed if this is true..
		foreach measure in app.myRoot.allMeasurementTypesByShortName where measure &lt;&gt; _measureType do
			if not measure.isDisplay then
				continue;
			endif;
			convertedValue := app.convertMeasurementForDisplay(measure.shortName, rawValue) &amp; Space &amp; measure.shortName;
			prefix := app.getMeasurementPrefixFromType( _measureType.measurementType );
		
			//_table.setValueByName(_rowName, convertedValue);		//cnwmc5 - 24 Nov 2015 - PAR 36960
			_table.setValueByName( prefix &amp; _rowName &amp; "_" &amp; measure.shortName, convertedValue );
		endforeach;
	endif;															//cnwmc5 - 24 Nov 2015 - PAR 36960
	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_EntryTable" usage="input"/>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_rawValue" type="Decimal"/>
        <Parameter name="_measureType" type="CM_MeasurementType"/>
    </JadeMethod>
