    <JadeMethod name="getDisplayDetails" id="31c37c94-b551-40b5-b3d4-ee2fdc2c11ac">
        <source>getDisplayDetails(_short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     Aug 2004	cnwrs1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin

	if _short then
		return self.timeIn.String;
	else
		return self.timeIn.String&amp;'  '&amp;self.timeOut.String;
	endif;

end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="25be38f5-cda7-45e1-bb4e-d3a2d3ce0e95">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//------------------------------------------------
// Created: 10 April 2006 By: cnwgd1
//------------------------------------------------
// 21/12/2009	cnwmh5	PAR 21864 - Add code for getting the cancelled reason
// 04/12/2012	cnwcs5	par 30413 - 4 x new fields	
// 17/12/2013	cnwdap1	PAR #32849 CCMS PEN 2321 new Security Gate fields
// 03/07/2014	cnwdap1	PAR #34500 Added Security Gate Departure attribute
// 14/04/2016	cnwmp6	TFS 488 - Multi Timezone Support
// 26/05/2022 	navhl20 TFS 53430  EUP - Sub Carrier registration in MTN
// 29/06/2022	navdap1	TFS 53362 EUP Master Data Interface Customers Between TOS and ERP
// 28/07/2022 	navvt20	Bug 54199: EUP - Tables with Operator/Stevedore not adhering to the configuration
// 07/03/2023	navdap1	TFS 57001 FR | 53667 - EUP - Inspection App checks - New Fields in Column Organiser
// 15/03/2023   navmp20 Bug 57024: FR | 53667 - EUP - Inspection App checks - Trailer ID - Vehicle visit
// 24/05/2023	navpw1	TFS: 54049 (55843) - Added vbs id and external reference
// 27/09/2023	navkc1	CR 60428 Task 60701: UI - Customs Status on Transport UI
//11 Jan 2024   navbs1  ChangeRequest 61971: FR | 55168 - Seal Numbers on Trucks (remedial) - Add columns to Road Exit and Vehicle Enquiry
// 28/05/2024	jlika1	TFS 64307 MTN - Barrier IN Time display format
// 03/07/2024	jlizm1	TFS 65024 Duplicate drivers can't be destinguished in vehicle visit enquiry
// 27 Mar 2025	navnk30	JIRA 34424: TPT | VBS - Change the information from "Arrived on schedule" to be more clear with the timestamp like "Arrived on schedule at 23:23 on 20th March 2025"
// 06 Aug 2025	naviv1	MTN-35545: FR 35007.020 Display Release Request ID in Vehicle Visit Enquiry
// 11 Aug 2025	navhl20 Story MTN-35650: TPT | Uploading of Photos into MTN Production | 2 | Thin Client Changes
//------------------------------------------------
vars
	str			: String;
	weight		: Decimal[23,4];
	subCarrier  : CM_Carrier;
	numPhotos	: Integer;
begin
	if _attrName = ETRow_WorkNumber then
		return self.verificationNumber;
		
	elseif _attrName = ETRow_TransactionNum then // PAR 17703
		return self.visitNumber;
		
	elseif _attrName = ETRow_Clerk then
		return self.verifiedByUserCode;
		
	elseif _attrName = ETRow_DwellTime then
		// refer PAR-16390.  Once dwellTime has been changed to an integer (for num mins) then
		// this can be changed back as attribute will then return correct details.
		return self.getDwellTime.asStringJMT;
		
	elseif _attrName = ETRow_PreGateToGateOutTime then
		return self.getPreGateToOutGateTime.asStringJMT;
		
	elseif _attrName = ETRow_GateInToGateOutTime then
		return self.getGateInToGateOutTime.asStringJMT;
		
	elseif _attrName = ETRow_Trucker or  _attrName = ETRow_ReceivedBy	then
		return self.driversName;
		
	elseif _attrName = ETRow_Gate then
		return self.departureGate;
		
	elseif _attrName = ETRow_TimeOut or _attrName = ETRow_PickupDate	then
		return self.systemToLocalTime(self.timeOut).asStringJMT();
		
	elseif _attrName = ETRow_TimeIn	then
		return self.systemToLocalTime(self.timeIn).asStringJMT();
		
	elseif _attrName = ETRow_Loader	then
		return self.loadingCompanyCode;
		
	elseif _attrName = ETRow_TransportId or _attrName = ETRow_Vehicle then
		if self.vehicle = null then
			return self.regNumber;
		endif;
		
		return self.vehicle.regNumber;
		
	elseif _attrName = ETRow_Exception then
		return self.remarks;
		
	elseif _attrName = ETRow_ArrivalInwardGateLane then
		// if there is not VVRD instance the following code will return null
		return self.systemToLocalTime(self.getArrivalAtGateInTime).asStringJMT;	// Par 19715
		
	elseif _attrName = ETRow_ArrivalPregate then
		// if there is no VVRD instance the following code will return null
		return self.systemToLocalTime(self.getFirstPreGateTime).asStringJMT;	// Par 19715
		
	elseif _attrName = ETRow_ArrivalOutwardGateLane then
		// if there is not VVRD instance the following code will return null
		return self.systemToLocalTime(self.getArrivalAtGateOutTime).asStringJMT;	// Par 19715
		
	elseif _attrName = ETRow_DriversName then				//cnwas3 PAR 20888	begin	
		if self.myDriverDetails &lt;&gt; null then
			return self.myDriverDetails.name.asStringJMT;		
		else
			return self.driversName.asStringJMT;
		endif;												//cnwas3 PAR 20888   end
	
	elseif _attrName = ETRow_DriverCode then
		if self.myDriverDetails &lt;&gt; null then
			return self.myDriverDetails.code.asStringJMT;		
		else
			return self.driverCode.asStringJMT;
		endif;
		
	elseif _attrName = ETRow_ExtraInfo_Cancel then
		// 21/12/2009 cnwmh5 #21864
		if self.status = CM_VehicleVisitRecord.Status_Cancelled then
			return self.getCancelledReason();
		endif;
		
	elseif _attrName = ETRow_CargoPlaced then
		return self.systemToLocalTime(self.getFirstCargoPlacedTime).asStringJMT;
	
	elseif _attrName = ETRow_CargoRemoved then
		return self.systemToLocalTime(self.getFirstCargoRemovedTime).asStringJMT;
		
	elseif _attrName = ETRow_BatNumber or _attrName = ETRow_RfidTag then
		return self.getRFIDTag;
		
	elseif _attrName = ETRow_VvsBooking then
		if myTerminal.isVehicleBookingEnabled then
			if self.myVehicleBookingTimeslot &lt;&gt; null then	//23 Oct 2014	NDL	Par 35008
				//str := self.myVehicleBookingTimeslot.getStatusString;			//27.03.2025 navnk30 JIRA 34424
				str := self.myVehicleBookingTimeslot.getStatusStringWithTS();	//27.03.2025 navnk30 JIRA 34424
				if self.myVehicleBookingTimeslot.id &lt;&gt; null then
					str := self.myVehicleBookingTimeslot.id &amp; " - " &amp; str;
				endif;
				return str;
			else
				return app.getErrorString(No);
			endif;
		endif;
		return null;
	elseif _attrName = ETRow_ReleaseNumber then   //12Aug-2025 naviv1 #MTN-35545
		return self.getReleaseNumber(); 
	elseif _attrName = ETRow_ArrivalAtYIC then //15 May 2013	NDL	Par 31464
		return self.systemToLocalTime(self.getArrivalAtYardIC).asStringJMT;
		
	elseif _attrName = ETRow_ReadyToLeave then //15 May 2013	NDL	Par 31464
		return self.systemToLocalTime(self.getReadyToLeaveTime).asStringJMT;
		
	elseif _attrName = ETRow_ArriveAtAGate then //15 May 2013	NDL	Par 31464
		return self.systemToLocalTime(self.getArrivalAtAGateTime).asStringJMT;
		
	elseif _attrName = ETRow_ArrivePGateOut then //15 May 2013	NDL	Par 31464
		return self.systemToLocalTime(self.getArrivalAtPGateOutTime).asStringJMT;
		
	elseif _attrName = ETRow_Operators then //29 Oct 2013	NDL	Par 32587
		// return self.getOperatorCodesString; 	// 29.07.2022 navvt20 TFS 54199
		
		// START 29.07.2022 navvt20 TFS 54199
		if app.myRoot.getConfig(ComboByNameOperator).Boolean  then    
           return self.getOperatorDescString;                                                   																							
        else
			return self.getOperatorCodesString;
		endif;
		// END 29.07.2022 navvt20 TFS 54199
		
	elseif _attrName = ETRow_Status then					// PAR #32849
		return self.getStatusForSecurityGateForm;			// PAR #32849
															// PAR #32849
	elseif _attrName = ETRow_VisitNumber then				// PAR #32849
		return self.visitNumber;							// PAR #32849
															// PAR #32849
	elseif _attrName = ETRow_ArrivalAtSecurityGate then		// PAR #32849
		return self.systemToLocalTime(self.getSecurityGateArrivalTS).asStringJMT;	// PAR #32849
		
	elseif _attrName = ETRow_DepartSecurityGate then		// PAR #34500
		return self.systemToLocalTime(self.getSecurityGateDepartTS).asStringJMT;	// PAR #34500
		
	//15/12/2016 cnwns1 TFS 2867:PKT - Bulk Process - WeighBridge Integration
	elseif _attrName = ETRow_FirstTrackedItem then 
		return self.getFirstTrackedItemId();
	elseif _attrName = ETRow_FirstTrackedItemType then 
		return self.getFirstTrackedItemType();	
	elseif _attrName = ETRow_BulkVisitType then	
		return	self.getBulkVisitType();
	//15/12/2016 cnwns1 TFS 2867	
	elseif _attrName = ETRow_InwardScaleWeight then	
		return self.getInwardScaleWeight();	
	elseif _attrName = ETRow_CargoWeightIn then
		//epr TFS 45705 23/7/19
		weight :=self.getTotalWeightReceived;
		if weight &gt; 0 then
			return app.getWeightForDefaultDisplay(weight);
		else
			return null;
		endif;
	elseif _attrName = ETRow_CargoWeightOut then
		//epr TFS 45705 23/7/19
		weight :=self.getTotalWeightReleased;
		if weight &gt; 0 then
			return app.getWeightForDefaultDisplay(weight);
		else
			return null;
		endif;
	elseif _attrName = ETRow_Stevedore then	//13 Oct 2020	NDL	TFS 49189
		if self.myStevedore &lt;&gt; null then
			if app.myRoot.getConfig(ComboByNameStevedore).Boolean then		// TFS 53362
				return self.myStevedore.description;						// TFS 53362
			endif;															// TFS 53362
			return self.myStevedore.code;
		else
			return null;
		endif;
	elseif _attrName = ETRow_Booking then	//13 Oct 2020	NDL	TFS 49189
		return self.getFirstBookingNum();
	elseif ( _attrName = ETRow_CargoSubType or  _attrName = ETRow_FirstTrackedItemSubType ) then	//14 Oct 2020	NDL	TFS 49189
		return self.getFirstTrackedItemSubType;
	elseif _attrName = ETRow_BOL then			//14 Oct 2020	NDL	TFS 49189
		return self.getFirstBolNumber();
	elseif _attrName = ETRow_TrailerType then	//28 Oct 2020	NDL	TFS 50113
		return self.getTrailerTypeCode( null );
	elseif _attrName = ETRow_Commodity then 	//TFS 53176, AjitM, navam1
		return self.getFirstTrackedItemCommodity;
	elseif _attrName = ETRow_SubCarrierCodeDesc then
		subCarrier := self.getMySubCarrier();
		if subCarrier &lt;&gt; null then
			return subCarrier.code &amp; " - " &amp;subCarrier.description;
		endif;
		return null;
	elseif _attrName = ETRow_GateInCheckStatus then
		return self.gateInCheckStatus;
	elseif _attrName = ETRow_GateInCheckTS then				
		if self.gateInCheckTS &lt;&gt; null and self.gateInCheckTS.isValid then
			return self.systemToLocalTime(self.gateInCheckTS).asStringJMT;
		endif;
		return null;
	elseif _attrName = ETRow_GateOutCheckStatus then		// TFS 57001
		return self.gateOutCheckStatus;
	elseif _attrName = ETRow_GateOutCheckTS then				
		if self.gateOutCheckTS &lt;&gt; null and self.gateOutCheckTS.isValid then
			return self.systemToLocalTime(self.gateOutCheckTS).asStringJMT;
		endif;
		return null;
	elseif _attrName = ETRow_TrailerIn then
		//return self.myInCMGTE_Chassis.id;
		if self.myInCMGTE_Chassis &lt;&gt; null then
			return self.myInCMGTE_Chassis.id;
		endif;
		return null;
	elseif _attrName = ETRow_TrailerOut then
		//return self.myOutCMGTE_Chassis.id;
		if self.myOutCMGTE_Chassis &lt;&gt; null then
			//Start 15.03.2023 navmp20 TFS 57024
			if self.myOutCMGTE_Chassis.id &lt;&gt; null then
				return self.myOutCMGTE_Chassis.id;
			endif;
			if self.myOutCMGTE_Chassis.isKindOf(CMGTE_Release) and self.myOutCMGTE_Chassis.CMGTE_Release.myTrackedItem &lt;&gt; null then
				return self.myOutCMGTE_Chassis.CMGTE_Release.myTrackedItem.id;
			endif;
			if self.myOutCMGTE_Chassis.isKindOf(CMGTE_Release) and self.myOutCMGTE_Chassis.CMGTE_Release.myTrackedItem = null and self.myOutCMGTE_Chassis.CMGTE_Release.getID &lt;&gt; null then
				return self.myOutCMGTE_Chassis.CMGTE_Release.getID;
			endif;
			//End 15.03.2023 navmp20 TFS 57024
		endif;
		return null;
	//End - 12Dec2022 navsp1 TFS 55580
	// ### TFS 54049 (55843) 24May2023 NAVPW1
	elseif _attrName = ETRow_ExternalRef then
		if self.allVehicleBookingSlots.isEmpty then
			return null;
		endif;
		
		return  self.allVehicleBookingSlots.listString(Comma,CM_VehicleBookingTimeSlot::externalReference.name);
	elseif _attrName = ETRow_VbsId then
		if self.allVehicleBookingSlots.isEmpty then 
			return null;
		endif;
		
		return  self.allVehicleBookingSlots.listString(Comma,CM_VehicleBookingTimeSlot::id.name);
	// ### TFS 54049 (55843) 24May2023 NAVPW1
	elseif _attrName = ETRow_BarrierInCode then  //jlier1 TFS  57936 18/5/23
		return self.getBarrierInCode();
	elseif _attrName = ETRow_BarrierOutCode then  //jlier1 TFS  57936 18/5/23
		return self.getBarrierOutCode();
	elseif _attrName = ETRow_BarrierInTime then  //jlier1 TFS  57936 18/5/23
		return self.getBarrierInTime();
	elseif _attrName = ETRow_BarrierOutTime then  //jlier1 TFS  57936 18/5/23
		return self.getBarrierOutTime();
	elseif _attrName = ETRow_BarrierValidityIn then  //jlier1 TFS  57936 18/5/23
		return self.getBarrierValidityIn();
	elseif _attrName = ETRow_BarrierValidityOut then  //jlier1 TFS  57936 18/5/23
		return self.getBarrierValidityOut();
	//10 Sep 2021	NDL	TFS 51809
	elseif _attrName = ETRow_VvrdBoomInward
		or _attrName = ETRow_VvrdBoomOutward
		or _attrName = ETRow_VvrdBulkIn
		or _attrName = ETRow_VvrdBulkOut
		or _attrName = ETRow_VvrdCargoPlaced
		or _attrName = ETRow_VvrdCargoRemoved
		or _attrName = ETRow_VvrdCreation
		or _attrName = ETRow_VvrdDeAssignRFID
		or _attrName = ETRow_VvrdDeleted
		or _attrName = ETRow_VvrdDiscrepancy
		or _attrName = ETRow_VvrdGrossWeightIn
		or _attrName = ETRow_VvrdGrossWeightOut
		or _attrName = ETRow_VvrdSwapRelease
		or _attrName = ETRow_VvrdTrouble
		or _attrName = ETRow_VvrdTurnAround
		or _attrName = ETRow_VvrdWayBillPrint
		or _attrName = ETRow_VvrdWeighBridge
		or _attrName = ETRow_VvrdWeighBridgeIn
		or _attrName = ETRow_VvrdWeighBridgeOut
		or _attrName = ETRow_VvrdYardLocation
	then
		return self.getVvrDetailsStringForAttrib( _attrName ); 
	elseif _attrName = ETRow_CustomStatus then
		return self.getCustomStatus(); //27/09/2023	navkc1	CR 60428 Task 60701
	elseif _attrName = ETRow_TruckSeals then
		return self.getSealNumbersOnly(); 		//11.01.2024 navbs1 #61971
	elseif _attrName = ETRow_Photos then		//11.08.2025 navhl20 #35650
		numPhotos := self.numAttachments(CM_Attachment.Type_Photo);
		return numPhotos.asStringJMT;
	else	
		return inheritMethod(_attrName, _short);
		
	endif;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDwellTime" id="a888aa06-b1bf-4090-a34a-98a49f15a1e7">
        <source>getDwellTime() : Integer;
//-----------------------------------------------------------------------
//	Created:	17 May 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	---------------------------------------------
// 20/12/2013	cnwdap1		PAR #32849 Security Gate
vars
	aT	: Time;
	isPos : Integer;
	numDays	: Integer;
	numMins	: Integer;
	detail : CM_VehicleVisitRecordDetail;										// PAR #32849
	ad : CM_VehicleVisitRecordDetail;
begin
	if timeOut = null then		//Job not complete yet
		//aT := app.actualTimeServer.differenceAsTime(timeIn, isPos, numDays);
		numMins := timeIn.getDifferenceInMinutes(app.actualTimeServer);
	else
		//aT := timeOut.differenceAsTime(timeIn, isPos, numDays);
		ad := self.getSecurityGateArrivedDetail; //04 Aug 2015	NDL	found testing 01-921 Cant exit thru sec gate if haven't entered thru it....
		if ad &lt;&gt; null and self.myTerminal.getConfig(SiteHasSecurityGate).Boolean then			// PAR #32849
			detail := self.getSecurityGateExitDetail;							// PAR #32849
			if detail &lt;&gt; null then												// PAR #32849
				numMins := timeIn.getDifferenceInMinutes(detail.timeStart);		// PAR #32849
			else																// PAR #32849
				numMins := timeIn.getDifferenceInMinutes(app.actualTimeServer);	// PAR #32849
			endif;																// PAR #32849
		else																	// PAR #32849
			numMins := timeIn.getDifferenceInMinutes(timeOut);
		endif;																	// PAR #32849
	endif;
	
	return (numMins + 1);
	//return (numDays * 24 * 60) + (aT.hour * 60) + aT.minute + 1;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getElapsedMinsCurrentStage" id="5f117c57-4998-4ce2-97de-0d5712abc47e">
        <source>getElapsedMinsCurrentStage() : Integer;
/*

Purpose:			


Return Value:		


Date		Who		Reason
17 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	currentVisistDwellStage : CM_VehicleVisitRecordDetail;
begin

	currentVisistDwellStage:=self.getCurrentVisitDetailStage;
	if currentVisistDwellStage = null then
		return null;
	else
		return currentVisistDwellStage.getElapsedTimeStage;
	endif;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getElapsedTime" id="1be8889e-7c29-4f4a-9b0d-8db35549ed22">
        <source>getElapsedTime() : Integer;
/*
Purpose:			
Return Value:	Time between first pre-gate and last out-gate VVRDs	


Date			Who		Reason
24 August 2006	cnwer1	Initial creation - PAR#xxxx
19 May 2009		concms1	Par 19715 - changes to VVRD updating
12/10/2009		cnwcs5	Removed code related to VTA 
*/
vars
	tmpElapsedMins		: Integer;
	endTime,
	startTime 			: TimeStamp;
	taMaster 			: CM_TerminalAreaMaster;
	preGateDwellRecord,
	gateOutDwellRecord	: CM_VehicleVisitRecordDetail;
begin
	endTime 			:= null; //epr par 16579 30/4/08 need to initialize this to null
	preGateDwellRecord 	:= self.getFirstPreGateVVRD;	// Par 19715
	gateOutDwellRecord 	:= self.getLastGateOutVVRD;	// Par 19715
	
	if preGateDwellRecord &lt;&gt; null then
		startTime := preGateDwellRecord.timeStart;
	else
		startTime:=timeIn;
	endif;
	// we used to do a different check for dual gate VTA becasue a single stage VTA did not
	// alway have all the vehicle visit records. Now all GATES should have same VVRDs created
	// regardless of whether they are single or two stage
	if gateOutDwellRecord &lt;&gt; null  then
		endTime := gateOutDwellRecord.getEndTime;	// par 19715
	else
		endTime:= self.timeOut;
	endif;
	
	if endTime = null then		//Job not complete yet
		//aT := app.actualTimeServer.differenceAsTime(startTime, isPos, numDays);
		tmpElapsedMins := app.actualTimeServer.getDifferenceInMinutes(startTime);
	else
		//aT := endTime.differenceAsTime(startTime, isPos, numDays);
		tmpElapsedMins := endTime.getDifferenceInMinutes(startTime);
	endif;
	
	return tmpElapsedMins;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
