    <JadeMethod name="getAllClassesForSearch" id="76c13581-9858-46de-99fe-1db92b343b39">
        <source>getAllClassesForSearch( strArray : StringArray io );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 February 2011	cnwndl1	Initial creation

*/

vars
	iter : Iterator;
	///classMethod : UM_ClassMethod;
	classString : String;
	lastClassString : String;
	classMethod			: UM_UnitTestClassMethod;					// 10/09/2013 cnwmh5
begin

	strArray.clear();
	
	///iter := self.allClassMethods.createIterator;
	iter := self.allClassMethodsUsedBy.createIterator;				// 10/09/2013 cnwmh5
	while iter.next( classMethod ) do
	
		///classString := classMethod.classString;
		classString := classMethod.className;							// 10/09/2013 cnwmh5
		if classString = lastClassString then
			continue;
		endif;
		
		strArray.add( classString );
		lastClassString := classString;
		
	endwhile;

epilog

	delete iter;
	
end;</source>
        <Parameter name="strArray" type="StringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAllMethodsForClassSearch" id="a5f94c78-3f75-4393-b542-3207f32f6ec2">
        <source>getAllMethodsForClassSearch( strArray : StringArray io; _classString : String );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 February 2011	cnwndl1	Initial creation

*/

vars
	iter : Iterator;
	///firstObject : UM_ClassMethod;
	///classMethod : UM_ClassMethod;
	classString : String;
	lastClassString : String;
	firstObject		: UM_UnitTestClassMethod;						// 10/09/2013 cnwmh5
	classMethod		: UM_UnitTestClassMethod;
	
begin

	strArray.clear();
	
	///iter := self.allClassMethods.createIterator;
	///firstObject := self.allClassMethods.getAtKeyGeq(_classString,null);
	iter := self.allClassMethodsUsedBy.createIterator;									// 10/09/2013 cnwmh5
	firstObject := self.allClassMethodsUsedBy.getAtKeyGeq(_classString, null);
	if firstObject = null or firstObject.className &lt;&gt; _classString then
		return;
	endif;
	
	iter.startAtObject( firstObject );
	while iter.next( classMethod ) do
	
		///classString := classMethod.classString;
		classString := classMethod.className;													// 10/09/2013 cnwmh5
		if classString &lt;&gt; _classString then
			break;
		endif;
		
		///strArray.add( classMethod.methodString );
		strArray.add( classMethod.methodName );												// 10/09/2013 cnwmh5
		
	endwhile;

epilog

	delete iter;
	
end;</source>
        <Parameter name="strArray" type="StringArray" usage="io"/>
        <Parameter name="_classString" type="String"/>
    </JadeMethod>
    <JadeMethod name="getFirstAdminUserEmailAddress" id="2334a380-a74a-4477-b774-69a0b518abee">
        <source>getFirstAdminUserEmailAddress() : UM_UserEmailAddress;

/*

Purpose:		Get the 1st admin user from User Email Address collection

Date			Who		Reason
09/10/2013	    cnwmh5	Initial creation

*/

vars

    user                : UM_UserEmailAddress;
    
begin

    foreach user in self.allUserEmailAddresses do
        if user.isAdmin then
			break;
		endif;
    endforeach;
    
    return user;
	
epilog

end;</source>
        <ReturnType type="UM_UserEmailAddress"/>
    </JadeMethod>
</Class>
