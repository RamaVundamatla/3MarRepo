        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateVbsSlotCriteria" id="77139d6b-4431-4b7e-8a0f-40b2185bf240">
        <source>validateVbsSlotCriteria(_allVehicleBookingSlots : CM_VehicleBookingTimeSlotById; _terminal : CM_Terminal; _vvr : CM_VehicleVisitRecord; _gateEntities : CM_ObjectSet input);
/*

Purpose:			Validates whether the vbs slot is valid and can be added to the vehicle visit record

Parameters:			_allVehicleBookingSlots	CM_VehicleBookingTimeSlotById	The vbs time slots to validate
					_terminal				CM_Terminal						The terminal to use for validation
					_vvr					CM_VehicleVisitRecord			The VVR to use to validate the vbs slot against
					_gateEntities			CM_ObjectSet					The gate entities to check against the VVR

Return Value:		NONE

Date		Who		Reason
19 May 2023	navpw1	Initial creation TFS: 54049 (55840)
26 May 2023	navpw1	TFS: 57756 (57896) - Modified logic and moved common code to CM_VBSProcess::checkTimeSlotOutsideGracePeriod
14 June 2023 navpw1	TFS: 58590 - Fixed the else statement for outside timeslot action
09 Feb 2024 navhl20 ChangeRequest 62084:[62379] EUP | Retrospective Operations - [54177.010] - Road Entry
05 Feb 2025	navhl20 Bug MTN-19856: MTN - VBS Slot validation is not using the retrospective date/time entered in the gate.
*/

vars
	isOutsideGracePeriod	: Boolean;
	outsideTimeSlotAction	: Integer;
	slotIdsOutsideTime		: StringArray;
	vbts					: CM_VehicleBookingTimeSlot;
	
begin
	create slotIdsOutsideTime transient;
	
	//isOutsideGracePeriod := self.checkTimeSlotOutsideGrcePeriod(_allVehicleBookingSlots, _terminal, outsideTimeSlotAction, slotIdsOutsideTime , _vvr);		//09.02.2023 navhl20 #62084[62379]
	//isOutsideGracePeriod := self.checkTimeSlotOutsideGrcePeriod(_allVehicleBookingSlots, _terminal, outsideTimeSlotAction, slotIdsOutsideTime , _vvr);		//09.02.2023 navhl20 #62084[62379]	//05.02.2025 navhl20 #19856
	isOutsideGracePeriod := self.checkTimeSlotOutsideGrcePeriod(_allVehicleBookingSlots, _terminal, outsideTimeSlotAction, slotIdsOutsideTime , _vvr, null);	//05.02.2025 navhl20 #19856
	
	if isOutsideGracePeriod then
		if outsideTimeSlotAction = CM_VehicleBookingTimeSlotType.VBS_ENTRY_WARN then 
			if not app.myPassport.allWarnings.includesErrorCode(WARN_Vbs_slot_outside_grace) then
				app.raiseCMWarning1(WARN_Vbs_slot_outside_grace, slotIdsOutsideTime.asCSV(false), null, null, null);
			endif;
		elseif outsideTimeSlotAction = CM_VehicleBookingTimeSlotType.VBS_ENTRY_ERROR then
			if not app.myPassport.allErrors.includesErrorCode(Veh_booking_slot_outside_grace) then
				app.raiseCMException1(Veh_booking_slot_outside_grace, slotIdsOutsideTime.asCSV(false), null, null);
			endif;
		endif;
	endif;
	
	foreach vbts in _allVehicleBookingSlots do
		if vbts.validateVbsSlotCriteria(CM_VehicleBookingTimeSlot.CHECK_MODE_VVR, _vvr, _gateEntities) then
			continue;
		endif;
		break;
	endforeach;
	
epilog
	delete slotIdsOutsideTime;
	
end;</source>
        <Parameter name="_allVehicleBookingSlots" type="CM_VehicleBookingTimeSlotById"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
        <Parameter name="_gateEntities" type="CM_ObjectSet" usage="input"/>
    </JadeMethod>
</Class>
