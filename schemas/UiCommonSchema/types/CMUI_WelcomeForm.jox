    <JadeMethod name="actionHyperlink" id="88461f6b-9de3-4219-9b08-5bdf88f3ef56">
        <source>actionHyperlink(_link :String)protected;
// ---------------------------------------------------------------------------
// Created:     10 September 2008 by concms1
// Purpose:     PAR 17903/CCMS 1741 - Welcome screen interim solution
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	10 Oct 2016	cnwkpd1		TFS JMT 2805 - JADE 7.1.08 upgrade
// ---------------------------------------------------------------------------
vars
	result: Integer;
begin
	if _link = null then
		return;
	endif;
	
	result := call _shellExecute(null, 'open', _link, null, null, 1);

	if result &lt; 32 then
		app.msgBox('Unable to open browser (' &amp; result.String &amp; ')', 'Error', MsgBox_OK_Only + MsgBox_Stop_Icon);
	endif; 
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_link" type="String"/>
    </JadeMethod>
    <JadeMethod name="actionNavigatorItem" id="57129f67-e29e-4d8b-ab10-f586cc832ed2">
        <source>actionNavigatorItem(_item :CM_MenuDtlNav):CM_MenuAction protected;
// ---------------------------------------------------------------------------
// Created:     10 September 2008 by concms1
// Purpose:     PAR 17903/CCMS 1741 - Welcome screen interim solution
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	menuAction	:CMUI_MenuAction;
	userItem	:CM_MenuUserDtl;
	ut			:CM_UserTerminal;
begin
	create menuAction transient;
	
	if _item.isSystemDtl then
		userItem := _item.getMenuUserDtlSystem (app.getMyUser).CM_MenuUserDtl;
	else
		ut := self.getUserTerminal;
		
		if ut = null then
			app.raiseCMException( ERR_dontHaveAccessToThisItem, null, self );
			return null;
		endif;
		
		userItem 	:= _item.getMenuUserDtl (ut).CM_MenuUserDtl;
	endif;
	
	menuAction.setFromMenuDtl(userItem, _item);

	menuAction.actionFromMenuDtl(true, null);
	
	return menuAction;
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_item" type="CM_MenuDtlNav"/>
        <ReturnType type="CM_MenuAction"/>
    </JadeMethod>
    <JadeMethod name="actionReportItem" id="b2578603-2f9f-4cf8-ac5d-19b8ee205a28">
        <source>actionReportItem(_report :CM_QryReport)protected;
// ---------------------------------------------------------------------------
// Created:     11 September 2008 by concms1
// Purpose:     PAR 17903/CCMS 1741 - Welcome screen interim solution
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	reportRunnerMenu	:CM_MenuDtlNav;
	menuAction			:CM_MenuAction;
	form				:CMUI_ReportRunner;
begin
	reportRunnerMenu := app.myRoot.getNavigatorItem (PmReportRunnerView);
	
	menuAction	:= self.actionNavigatorItem (reportRunnerMenu);
	
	form := menuAction.CMUI_MenuAction.myForm.CMUI_ReportRunner;
	
	self.selectReport (_report, form);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_report" type="CM_QryReport"/>
    </JadeMethod>
    <JadeMethod name="chkDoNotShow_click" id="9217b89f-b176-4a29-8fd3-5459125209d2">
        <controlMethod name="CMUI_CheckBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkDoNotShow_click(checkbox: CheckBox input) updating;
/* ---------------------------------------------------------------------------
Created:	25 September 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	self.doChkDoNotShow();

end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doChkDoNotShow" id="cb28112a-db1a-4e92-9906-bde2c8938dc1">
        <source>doChkDoNotShow();
/* ---------------------------------------------------------------------------
Created:	25 September 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	// need to create transaction for update user settings - Show Welcome Screen
	// it is only the way to remember this, because if the Welcome screen is closed,
	// the checkbox value is lost.
	app.myTrxUA.trxUpdateUserWelcomeScreen( app.getMyUser(), not self.chkDoNotShow.value, app.myPassport);

end;</source>
    </JadeMethod>
    <JadeMethod name="getPictureForReports" id="0de02f56-d99a-4818-9df1-03690a933b86">
        <source>getPictureForReports():Binary protected;
// ---------------------------------------------------------------------------
// Created:     11 September 2008 by concms1
// Purpose:     PAR 17903/CCMS 1741 - Welcome screen interim solution
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	item 	:CM_MenuDtlNav;
begin 	
	item := app.myRoot.getNavigatorItem (PmReportRunnerView);
	
	if item &lt;&gt; null then
		return item.pictureButton;
	endif;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="getTerminal" id="75a23f9b-0953-4c42-89c8-10408024a8fa">
        <source>getTerminal():CM_Terminal protected;
// ---------------------------------------------------------------------------
// Created:     11 September 2008 by concms1
// Purpose:     PAR 17903/CCMS 1741 - Welcome screen interim solution
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ut	:CM_UserTerminal;
begin
	ut := self.getUserTerminal;
	
	if ut &lt;&gt; null then
		return ut.myTerminal;
	endif;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getUserTerminal" id="5b207576-079a-4130-a58b-4f8387673116">
        <source>getUserTerminal():CM_UserTerminal protected;
// ---------------------------------------------------------------------------
// Created:     11 September 2008 by concms1
// Purpose:     PAR 17903/CCMS 1741 - Welcome screen interim solution
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return app.getMyUser.allUserTerminals.first;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="CM_UserTerminal"/>
    </JadeMethod>
