    <JadeMethod name="isSection" id="e4974235-6533-4f04-b44c-c5cb0f661faa">
        <source>isSection(_line : String; _canRemove : Boolean) : Boolean protected;
/*

Purpose:			Checks the line to see if what we are dealing with is a section	

Parameters:			_line: 			String		Line to check
					_canRemove: 	Boolean		Whether we can remove the section from the array

Return Value:		Boolean: Stating whether this is a section or not.

Date		Who		Reason
27 October 2021	navpw1	Initial creation TFS: 52202

*/

vars

begin
	if (sections.includes(_line)) then
		if (_canRemove) then
			sections.remove(_line);
		endif;
		return true;
	else
		return false;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_line" type="String"/>
        <Parameter name="_canRemove" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadClassMapDefSection" id="df3475eb-8cd7-4ada-893a-380c6a44ecad">
        <source>loadClassMapDefSection(_sectionName		: String; 
						_line			: String io; 
						_lineNumber 	: Integer io; 
						_inputFile 		: File io) protected;
/*

Purpose:			Load the Class -&gt; Map file section in a coherient (alphabetical) order.
					Expects lines to look like:
						"&lt;Class Name&gt;" in "&lt;Map Name&gt;";

Parameters:			_sectionName:		String				Name of the section
					_line:				String				Line we are processing
					_lineNumber:		Integer				Line number to keep a record in case we need to know
					_inputFile:			File				The file we are reading

Return Value:		

Date				Who		Reason
14 November 2021	navmd1	Initial creation TFS: 52202

*/
constants
	Start2ndSection		: String	= '	classMapDefinitions';
	ClassMapRefRegex	: String	= '\s*(\w+) in "(\w+)";';
	MaxFailures			: Integer	= 5;
	
vars
	section				: DEV_SchemaClassMapSection;
	classMapRef			: DEV_ClassMapReference;
	matches				: JadeRegexMatch;
	contentArray		: DEV_StringArray;
	
	inClassMapSection	: Boolean;
	content				: String;
	className,
	mapName				: String;
	failures			: Integer;
begin
	self.trxCreateSchemaClassMapRefSctn(_sectionName, section);
	
	create contentArray transient;
	
	while true do
		//Process File
		_line := _inputFile.readLine();
		_lineNumber := _lineNumber + 1;
		
		// EOF
		if(_line = null and _inputFile.endOfFile()) then
			break;
		endif;
		
		// Hit a new section ? bail
		if self.isSection(_line, false) then
			//section.setContent(contentArray, JadeRegex@replaceFirst(content, "", self.ReplaceOneEndCrLf, true));
			section.setContent(contentArray, content);
			break;
		endif;
		
		// First part of the section - lists all the map files. This seems to be in order, so just add it as content to this section as is.
		if not inClassMapSection then
			if _line = Start2ndSection then
				inClassMapSection := true;
			endif;
			
			// The first part of this section, is just listing out the map files, so this is probably overkill ;)
			if (content.length + CrLf.length + _line.length) &gt; 15000 or inClassMapSection then
				//if _line = null then
					//content &amp;= CrLf;
				//endif;
				contentArray.add(content);
				content := null;
			else
				content &amp;= CrLf &amp; _line;
				//content &amp;= _line &amp; CrLf;
			endif;
			
			continue;	// next line
		endif;
		
		// Second part of this section doesn't appear to be in a coherent order, so lets mangle it!
		delete matches;
		JadeRegex@match(_line, ClassMapRefRegex, true, true, matches);
		
		if matches = null or matches.numCaptures &lt; 2 then
			// Finished with the bits we care about in the second section, back to pretending we aren't the second section
			inClassMapSection := false;
			content := _line;
			continue;
		endif;
		
		// New ref
		self.trxCreateClassMappRef( matches.at(1).value, matches.at(2).value, section, classMapRef);
		
		// ... rinse and repeat ...
		
	endwhile;

epilog
	delete matches;
	delete contentArray;
end;</source>
        <access>protected</access>
        <Parameter name="_sectionName" type="String"/>
        <Parameter name="_line" type="String" usage="io"/>
        <Parameter name="_lineNumber" type="Integer" usage="io"/>
        <Parameter name="_inputFile" type="File" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadConstantsSection" id="a8f26274-0556-476f-80f2-8584b3d1b523">
        <source>loadConstantsSection(_sectionName		: String; 
					_line				: String io; 
					_lineNumber			: Integer io; 
					_inputFile 			: File io) protected;
/*

Purpose:			Loads the constants section (Needs extending for (alphabetical) order)
					Expects constant category lines to look like:
						categoryDefinition &lt;Constant Category Name&gt;	categoryDefinition PermissionTypeConstatns
					Expects constant lines to look like:
					&lt;Tab&gt;&lt;Tab&gt;&lt;Constant Name (31 whitespace padding)&gt;:&lt;Constant Type&gt; = &lt;Constant Value&gt;;

Parameters:			_sectionName:		String				Name of the section
					_line:				String				Line we are processing
					_lineNumber:		Integer				Line number to keep a record in case we need to know
					_inputFile:			File				The file we are reading

Return Value:		

Date		Who		Reason
27 October 2021	navpw1	Initial creation TFS: 52202

*/

constants
	ConstantCategoryRegex 	= "\tcategoryDefinition\s(?'category'[A-Za-z0-9_.,;]*)"; //&lt;Tab&gt;categoryDefinition &lt;Category&gt;
	ConstantRegex			= "\s*(?'constantName'[A-Za-z0-9_]*):[\s]*(?'constantType'[Binary|Boolean|Byte|Character|Date|Decimal|Integer|Integer64|Point|Real|String|StringUtf8|Time|Timestamp|TimestampInterval|TimestampOffset]*)[\s]*=[\s]*(?'constantData'.*)"; //&lt;Tab&gt;&lt;Constant&gt;:&lt;ConstantValue&gt;
	ModifiedTimeStampRegex 	= "\t\tsetModifiedTimeStamp\s(?'modifiedTimestamp'[A-Za-z0-9&lt;&gt;" &amp; '"' &amp; "\s.:;]*)"; //Look into removing
	CategoryDefinition		= "categoryDefinition";
	SemiColon 				= ";";
	DocumentationText		= "documentationText";
	
vars
	matches							: JadeRegexMatch;
	constantCategory,
	constant,
	constantType,
	constantValue,
	documentationTextStr			: String;
	devConstantsSection 			: DEV_SchemaConstantsSection;
	devConstantCategory,
	devConstantCategoryTransient	: DEV_GlobalConstantCategory;
	devConstant 					: DEV_GlobalConstant;
	processingCategory,
	processingConstant,
	keepReadingLine 				: Boolean;
	
	modifiedTimeStamp 				: LSModifiedTimeStamp;
begin
	processingCategory := false; //Are we processing a constant Category
	processingConstant := false; //Are we processing a constant
	
	self.trxCreateSchemaConstantsSection(_sectionName, devConstantsSection);

	create modifiedTimeStamp transient;
	
	while true do

		_line := _inputFile.readLine();
		_lineNumber := _lineNumber + 1;
		
		delete matches; //Transients are created everytime JadeRegex@match is called
		
		if(_line = null and _inputFile.endOfFile()) then
			break;
		endif;
		
		if (JadeRegex@match(_line, ConstantCategoryRegex, true, true, matches) and JadeRegex@contains(_line, CategoryDefinition, false)) then //Dealing with Category
			
			processingConstant := false;
			processingCategory := true;
			//Regex check Category Line
			constantCategory := matches.getCaptureByName("category").value;
			
			self.trxCreateGConstantCategory(devConstantCategory, constantCategory, documentationTextStr, devConstantsSection);
			
		elseif (JadeRegex@match(_line, ConstantRegex, true, true, matches)) then
			
			processingCategory := false;
			processingConstant := true;
			//Regex check Constant
			constant := matches.getCaptureByName("constantName").value.trimWhiteSpace();
			constantType := matches.getCaptureByName("constantType").value.trimWhiteSpace();
			constantValue := matches.getCaptureByName("constantData").value;
			
			if (not JadeRegex@contains(constantValue, SemiColon, false)) then
				while(not JadeRegex@contains(constantValue, SemiColon, false)) do
					_line := _inputFile.readLine();
					_lineNumber := _lineNumber + 1;
					constantValue := constantValue &amp; CrLf &amp; _line;
				endwhile;
			endif;
			
			constantValue := JadeRegex@replaceAll(constantValue, "", ";{1}$", true);
			
			self.trxCreateGConstant(devConstant, constant, constantType, constantValue, documentationTextStr, devConstantCategory);
			
		elseif self.checkModifiedTimestamp(_line, modifiedTimeStamp) then
			//Read Modified DateTime
			//Can remove once timestamp is working correctly (Look into export)
			if (processingCategory) then
				self.trxUpdateGConstantCategory(devConstantCategory, devConstantCategory.documentationTextData);
				devConstantCategory.setLastModifiedTimeStamp(modifiedTimeStamp);
			else
				self.trxUpdateGConstant(devConstant, devConstant.documentationTextData);
				devConstant.setLastModifiedTimeStamp(modifiedTimeStamp);
			endif;
			
		elseif (JadeRegex@contains(_line, DocumentationText, true)) then //Check whether its a documentationText
			documentationTextStr := null;
			documentationTextStr := self.getDocumentationText(_line, _lineNumber, _inputFile);
			
			if (processingCategory) then
				self.trxUpdateGConstantCategory(devConstantCategory, documentationTextStr);
			else
				self.trxUpdateGConstant(devConstant, documentationTextStr);
			endif;
			
			documentationTextStr := null;
		elseif (self.isSection(_line, false)) then
			break;
		endif;
	
	endwhile;

epilog
	delete matches;
	delete modifiedTimeStamp;
	
end;</source>
        <access>protected</access>
        <Parameter name="_sectionName" type="String"/>
        <Parameter name="_line" type="String" usage="io"/>
        <Parameter name="_lineNumber" type="Integer" usage="io"/>
        <Parameter name="_inputFile" type="File" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadGenericSection" id="8b310e0e-cb89-46be-a88e-75a0c77a5b0a">
        <source>loadGenericSection(_sectionName 	: String; 
					_line			: String io;
					_lineNumber 	: Integer io; 
					_inputFile 		: File io) protected;
/*

Purpose:			Loads a generic secion (A section we do not need to currently interpret)

Parameters:			_sectionName:		String				Name of the section
					_line:				String				Line we are processing
					_lineNumber:		Integer				Line number to keep a record in case we need to know
					_inputFile:			File				The file we are reading

Return Value:		

Date		Who		Reason
27 October 2021	navpw1	Initial creation TFS: 52202

*/

vars
	content 				: String;
	contentArray 			: DEV_StringArray;
	devSchemaGenericSection : DEV_SchemaGenericSection;
	
begin
	content := null;
	contentArray := null;
	create contentArray transient;
	while true do

		_line := _inputFile.readLine();
		_lineNumber := _lineNumber + 1;
		
		if(_line = null and _inputFile.endOfFile()) then
			if(content.length &gt; 0) then
				contentArray.add(content);
				content := null;
			endif;
			self.trxCreateSchemaGenericSection(_sectionName, content, contentArray, devSchemaGenericSection);
			break;
		endif;
		
		if(self.isSection(_line, false)) then
			//write content;
			if(content.length &gt; 0) then
				contentArray.add(content);
				content := null;
			endif;
			self.trxCreateSchemaGenericSection(_sectionName, content, contentArray, devSchemaGenericSection);
			break;
		else
			if (content = null) then
				content := _line;
			elseif((content &amp; CrLf &amp; _line).length() &gt;= 15000) then
				if (_line = null) then
					content &amp;= CrLf &amp; _line;
				endif;
				
				contentArray.add(content);
				content := null;
				content := _line;
			else
				content &amp;= CrLf &amp; _line;
			endif;
		endif;

	endwhile;

epilog
	delete contentArray;

end;</source>
        <access>protected</access>
        <Parameter name="_sectionName" type="String"/>
        <Parameter name="_line" type="String" usage="io"/>
        <Parameter name="_lineNumber" type="Integer" usage="io"/>
        <Parameter name="_inputFile" type="File" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadIFDefsSection" id="aecb5363-427f-4ccf-a235-519ad5f30c7a">
        <source>loadIFDefsSection(_sectionName 		: String; 
					_line			: String io;
					_lineNumber 	: Integer io; 
					_inputFile 		: File io) protected;
/*

Purpose:			Loads a generic secion (A section we do not need to currently interpret)

Parameters:			_sectionName:		String				Name of the section
					_line:				String				Line we are processing
					_lineNumber:		Integer				Line number to keep a record in case we need to know
					_inputFile:			File				The file we are reading

Return Value:		

Date		Who		Reason
3 December 2021	navpw1	Initial creation TFS: 52202

*/

constants
	InterfaceNameRegex = "^\s*(?'interfaceName'.[^\s\(\)]*)\s*number\s*=\s.*";
	
vars
	content 				: String;
	contentArray 			: DEV_StringArray;
	devSchemaGenericSection : DEV_SchemaGenericSection;
	devClassesSection		: DEV_SchemaClassesSection;
	devClass				: DEV_Class;
	matches					: JadeRegexMatch;
	
begin
	if self.mySchemaFile.mySchema.allSections.getAtKey("typeDefinitions") = null then
		self.trxCreateSchemaClassesSection("typeDefinitions", devClassesSection);
	else
		devClassesSection := self.mySchemaFile.mySchema.allSections.getAtKey("typeDefinitions").DEV_SchemaClassesSection;
	endif;

	content := null;
	contentArray := null;
	create contentArray transient;
	while true do

		_line := _inputFile.readLine();
		_lineNumber := _lineNumber + 1;
		
		if JadeRegex@match(_line, InterfaceNameRegex, true, true, matches) then
			//Create a interface class to exclude from typeDefinition output as these outputted in a difference section
			self.trxCreateClass(matches.getCaptureByName("interfaceName").value, "", true, devClass, devClassesSection);
			delete matches;
		endif;
		
		if(_line = null and _inputFile.endOfFile()) then
			if(content.length &gt; 0) then
				contentArray.add(content);
				content := null;
			endif;
			self.trxCreateSchemaGenericSection(_sectionName, content, contentArray, devSchemaGenericSection);
			break;
		endif;
		
		if(self.isSection(_line, false)) then
			//write content;
			if(content.length &gt; 0) then
				contentArray.add(content);
				content := null;
			endif;
			self.trxCreateSchemaGenericSection(_sectionName, content, contentArray, devSchemaGenericSection);
			break;
		else
			if (content = null) then
				content := _line;
			elseif((content &amp; CrLf &amp; _line).length() &gt;= 15000) then
				if (_line = null) then
					content &amp;= CrLf &amp; _line;
				endif;
				
				contentArray.add(content);
				content := null;
				content := _line;
			else
				content &amp;= CrLf &amp; _line;
			endif;
		endif;

	endwhile;

epilog
	delete contentArray;

end;</source>
        <access>protected</access>
        <Parameter name="_sectionName" type="String"/>
        <Parameter name="_line" type="String" usage="io"/>
        <Parameter name="_lineNumber" type="Integer" usage="io"/>
        <Parameter name="_inputFile" type="File" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadSchemaFile" id="b2cd5c7f-ef6e-42b6-be4f-2cfd90a8e08c">
        <updating/>
        <source>loadSchemaFile(_fileAndDirectory, _schemaFileName : String) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 October 2021	navpw1	Initial creation TFS: 52202

*/

constants
	JadeVersionRegex = "jadeVersionNumber\s(?'jadeVersion'[0-9." &amp; '"' &amp; "]*);";
	JadeCommandRegex = "JADE COMMAND FILE NAME";
	
vars
	line			: String;
	inputFile,
	outputFile		: File;
	lineNumber 		: Integer;
	matches			: JadeRegexMatch;
	
begin
	if self.mySchemaFile &lt;&gt; null then
		delete self.mySchemaFile;
	endif;
	self.trxCreateSchemaFile(_schemaFileName);
	
	//Create Transients
    create inputFile transient;
    create outputFile transient;
    
	inputFile.maxRecordSize := self.MaxRecordSize;
    inputFile.usePresentationFileSystem := false;
    inputFile.mode := inputFile.Mode_Input;
    inputFile.unicodeBOM := true;
    inputFile.kind := inputFile.Kind_Unicode; //Most extracted files are from Jade 2022
    inputFile.openInput(_fileAndDirectory);
	
	// Re save the file as ANSI until Wmast is on 2022
    outputFile.usePresentationFileSystem := false;
    outputFile.mode := File.Mode_Output;
    outputFile.kind := File.Kind_ANSI;
    outputFile.fileName := inputFile.fileName &amp; "_ansi";
    outputFile.writeString(inputFile.readString(inputFile.fileLength));
    outputFile.close();
    
	inputFile.close();
    inputFile.fileName := outputFile.fileName;
    inputFile.unicodeBOM := false;
    inputFile.kind := File.Kind_ANSI;
    inputFile.open();
	
	lineNumber := 0; //Initialise Line Number
	
	line := inputFile.readLine(); //Read the next line
	lineNumber += 1; //Grab next line number
	
	if (JadeRegex@match(line, JadeVersionRegex, true, true, matches)) then //Read Jade Version from file
		self.trxUpdateSchemaFile(matches.getCaptureByName("jadeVersion").value, self.mySchemaFile.commandFileData); //Update our file with the jade version number
	endif;
	
	line := inputFile.readLine(); //Read the next line
	lineNumber += 1; //Grab next line number
	
	if (JadeRegex@contains(line, JadeCommandRegex, true)) then //Jade command file name is optional in schema files
		self.trxUpdateSchemaFile(self.mySchemaFile.jadeVersion, line); //Update our file with the Jade command file name
	endif;
	
	while true do
		delete matches; //Transients are created everytime JadeRegex@match is called
		
		//Process File
		if(self.isSection(line, true)) then //Is this line a section header
			self.loadSection(line, lineNumber, inputFile); //Load/Interpret the section header
		else
			line := inputFile.readLine(); //Read the next line
			
			//EOF check
			if(line = null and inputFile.endOfFile()) then
				break;
			endif;

			lineNumber += 1;
			
		endif;
	endwhile;
	
epilog
	delete inputFile;
	delete outputFile;
	delete matches;
	
end;</source>
        <access>protected</access>
        <Parameter name="_fileAndDirectory" type="String"/>
        <Parameter name="_schemaFileName" type="String"/>
    </JadeMethod>
    <JadeMethod name="loadSchemaSection" id="669da911-eefb-4426-b3ae-b5232e43ad66">
        <source>loadSchemaSection(_sectionName 		: String; 
					_line			: String io; 
					_lineNumber 	: Integer io; 
					_inputFile 		: File io) protected;
/*

Purpose:			Loads the schema section

Parameters:			_sectionName:		String			Name of the section
					_line:				String			Line we are processing
					_lineNumber:		Integer			Line number to keep a record in case we need to know
					_inputFile:			File			The file we are reading

Return Value:		

Date		Who		Reason
27 October 2021	navpw1	Initial creation TFS: 52202

*/

constants
	FirstSchemaLine 	= "(?'schema'[A-Za-z0-9]*)\ssubschemaOf\s(?'subSchema'[A-Za-z]*)\s(?'otherData'[A-za-z0-9\s,=;]*)";
	ModifiedTimeStamp 	= "\t\tsetModifiedTimeStamp\s(?'modifiedTimestamp'[A-Za-z0-9&lt;&gt;" &amp; '"' &amp; "\s.:;]*)";
	DocumentationText 	= "documentationText";
	GraveAccent 		= "`";
	
vars
 	matches					: JadeRegexMatch;
	schema,
	subschema,
	otherData,
	documentationTextStr	: String;
	modifiedTimeStamp		: LSModifiedTimeStamp;
	devSchema 				: DEV_Schema;
	
begin		
	//Loop for this section
	create modifiedTimeStamp transient;
	
	while true do
		
		delete matches; //Transients are created everytime JadeRegex@match is called
		
		//Process File
		_line := _inputFile.readLine();
		_lineNumber := _lineNumber + 1;
	
		if(_line = null and _inputFile.endOfFile()) then
			break;
		endif;
	
		//Perform Regex for data
		if(JadeRegex@match(_line, FirstSchemaLine, true, true, matches)) then //Do we match the first schema file line
			//Grab our named matches from the collection
			schema := matches.getCaptureByName("schema").value;
			subschema := matches.getCaptureByName("subSchema").value;
			otherData := matches.getCaptureByName("otherData").value;
			self.trxCreateSchema(schema, subschema, otherData, devSchema);
			
		elseif self.checkModifiedTimestamp(_line, modifiedTimeStamp) then
			//Set our variable with above check to be used when we are in a new section
			devSchema.setLastModifiedTimeStamp(modifiedTimeStamp);
			
		elseif (JadeRegex@contains(_line, DocumentationText, true)) then //Check if we're dealing with documentation text
			documentationTextStr := self.getDocumentationText(_line, _lineNumber, _inputFile);
			devSchema.setDocumentationText(documentationTextStr);
			
		elseif(self.isSection(_line, false)) then
			//If we are dealing with a new section then create our schema and break our loop
			break;
		endif;
		
	endwhile;

epilog
	delete matches;
	delete modifiedTimeStamp;
end;</source>
        <access>protected</access>
        <Parameter name="_sectionName" type="String"/>
        <Parameter name="_line" type="String" usage="io"/>
        <Parameter name="_lineNumber" type="Integer" usage="io"/>
        <Parameter name="_inputFile" type="File" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadSection" id="3a655ba7-19b0-426f-b88b-f7057bbb59c0">
        <source>loadSection(_line			: String io; 
			_lineNumber		: Integer io; 
			_inputFile 		: File io) protected;
/*

Purpose:			Load a section based on name

Parameters:			_line:				String				Line we are processing
					_lineNumber:		Integer				Line number to keep a record in case we need to know
					_inputFile:			File				The file we are reading

Return Value:		

Date		Who		Reason
27 October 2021	navpw1	Initial creation TFS: 52202

*/

vars
	section : String;
	
begin
	section := _line;
	
	// 1. Schema Info
	if (section = "schemaDefinition") then
		self.loadSchemaSection(section, _line, _lineNumber, _inputFile);
	
	// 2. Packages (Imported)
	elseif (section = "importedPackageDefinitions") then
		self.loadGenericSection(section, _line, _lineNumber, _inputFile);
	
	// 3. Constants
	elseif (section = "constantDefinitions") then
		self.loadConstantsSection(section, _line, _lineNumber, _inputFile);
	
	// 4. Locales
	elseif (section = "localeDefinitions") then
		self.loadGenericSection(section, _line, _lineNumber, _inputFile);
		//self.loadLocaleSection(section, _line, _lineNumber, _inputFile, _devSchema);					// TODO: This doesn't work - I *assume* we're trying to re-order them... but who knows ;)
																										// Do we actually need to bother ? Is the order not deterministic ?
	
	// 5. (JADE) Translatable Strings
	elseif (section = "translatableStringDefinitions") then
		self.loadGenericSection(section, _line, _lineNumber, _inputFile);								// ----|
																										//     |
	// 6. Locale (Schema) Formats (ie, Schema -&gt; Formats)												//     |
	elseif (section = "localeFormatDefinitions") then													//     |
		self.loadGenericSection(section, _line, _lineNumber, _inputFile);								// ----|
																										//     |
	// 7. External Libraries																			//     |
	elseif (section = "libraryDefinitions") then														//     |
		self.loadGenericSection(section, _line, _lineNumber, _inputFile);								// ----|
																										//     |
	// 8. External Functions																			//     |
		// 'externalFunctionDefinitions'																// ----|
																										//     |
	// 9. Class Header Info																				//     |
		// 'typeHeaders'																				// ----|---- If all of these are 'generic' why bother putting them in their own sections ??
																										//     |
	// 10. Interfaces																					//     |
		// 'interfaceDefs'																				// ----|
																										//     |
	// 11. Collections																					//     |
	elseif (section = "membershipDefinitions") then														//     |
		self.loadGenericSection(section, _line, _lineNumber, _inputFile);								// ----|
																										//     |
	// 12. Class Method Header/Attribute/Constants														//     |
	elseif (section = "typeDefinitions") then															//     |
		self.loadTypeDefinitionsSection("typeDefinitions", _line, _lineNumber, _inputFile);				// ----|
																										//     |
	// 13. Inverses																						//     |
	elseif (section = "inverseDefinitions") then														//     |
		self.loadGenericSection(section, _line, _lineNumber, _inputFile);								// ----|
	
	// 14. Map Files
	elseif (section = "databaseDefinitions") then
		self.loadClassMapDefSection(section, _line, _lineNumber, _inputFile);
	
	// 15. Schema Views
	elseif (section = "schemaViewDefinitions") then
		self.loadGenericSection(section, _line, _lineNumber, _inputFile);
	
	// 16. Web Service Consumers
		// '_exposedListDefinitions'
	
	// 17. Packages (Exported)
	elseif (section = "exportedPackageDefinitions") then
		self.loadGenericSection(section, _line, _lineNumber, _inputFile);
	
	// 18. External Functions
	elseif (section = "externalFunctionSources") then
		self.loadGenericSection(section, _line, _lineNumber, _inputFile);
	
	// 19. Methods
	elseif (section = "typeSources") then
		self.loadTypeSourcesSection("typeDefinitions", _line, _lineNumber, _inputFile);
	
	// 20. Member Key Definitions
	elseif section = "memberKeyDefinitions" then
		self.loadGenericSection(section, _line, _lineNumber, _inputFile);

	// 21. External Key Definitions
	elseif section = "externalKeyDefinitions" then
		self.loadGenericSection(section, _line, _lineNumber, _inputFile);
	
	// 22. interface Definitions
	elseif section = "interfaceDefs" then
		self.loadIFDefsSection(section, _line, _lineNumber, _inputFile);
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_line" type="String" usage="io"/>
        <Parameter name="_lineNumber" type="Integer" usage="io"/>
        <Parameter name="_inputFile" type="File" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadTypeDefinitionsSection" id="8aa7f471-a223-4c93-aec8-0d78f09bb990">
        <source>loadTypeDefinitionsSection(_sectionName 	: String; 
							_line			: String io; 
							_lineNumber 	: Integer io; 
							_inputFile 		: File io) protected;
/*

Purpose:			Load the type definition section (Does not currently work/Needs refactoring)

Parameters:			_sectionName:		String				Name of the section
					_line:				String				Line we are processing
					_lineNumber:		Integer				Line number to keep a record in case we need to know
					_inputFile:			File				The file we are reading

Return Value:		

Date		Who		Reason
05 November 2021	navpw1	Initial creation TFS: 52202

*/

constants
	CompleteDefinitionRegex = "^[\s\t]*(?'className'[a-zA-z0-9:]*)[\s\t]*completeDefinition$";
	ClassNameRegex 			= "^\s*(?'className'[A-Za-z0-9_:]*)\s*\(";
	
	SubSectionRegex 		= "\s*(constantDefinitions|attributeDefinitions|referenceDefinitions|jadeMethodDefinitions|eventMethodMappings|externalMethodDefinitions|webServicesClassProperties|webServicesMethodDefinitions|implementInterfaces){1}";
	
	ConstantRegex 			= "^[\s]*(?'constantName'[A-Za-z0-9_]*):[\s]*(?'constantType'[Binary|Boolean|Byte|Character|Date|Decimal|Integer|Integer64|Point|Real|String|StringUtf8|Time|Timestamp|TimestampInterval|TimestampOffset]*)[\s]*=[\s]*(?'constantValue'.*)[\s]{1}(?'miscData'number.*);$";
	ConstantNoNumberRegex 	= "^[\s]*(?'constantName'[A-Za-z0-9_]*):[\s]*(?'constantType'[Binary|Boolean|Byte|Character|Date|Decimal|Integer|Integer64|Point|Real|String|StringUtf8|Time|Timestamp|TimestampInterval|TimestampOffset]*)[\s]*=[\s]*(?'constantValue'.*);$";
	
	StartConstantRegex		= "[\s]*(?'constantName'[A-Za-z0-9_]*):[\s]*(?'constantType'[Binary|Boolean|Byte|Character|Date|Decimal|Integer|Integer64|Point|Real|String|StringUtf8|Time|Timestamp|TimestampInterval|TimestampOffset]*)[\s]*=[\s]*(?'constantData'.*)";
	AttributeRegex 			= "^[\s]*(?'attributeName'[a-zA-Z0-9_-]*):[\s]*(?'type'[a-zA-Z0-9_]*)\[?(?'length'[0-9]*),?(?'precision'[0-9])*\]?(?'miscData'.*);$";
	
	ReferenceRegex 			= "^[\s]*(?'referenceName'[A-Za-z0-9_]*):[\s]*(?'referenceType'[A-Za-z0-9_-]*)(?'miscData'.*);$";
	
	JadeMethodRegex 		= "^.*number[\s]*=[\s\t]*[0-9]*;$";
	JadeMethodWholeRegex 	= "^[\s]*(?'name'[A-Za-z0-9_-]*)[^\)]+?\)[^;]*;[\r\n]*";
	
	ExternalMethodRegex		= "^[\s]*(?'name'[A-Za-z0-9_-]*)\(.*$";
	EventMethodMappingRegex = "^[\s]*(?'name'[A-Za-z0-9_-]*)[\s\t]*=[\s\t]*(?'value'.*);$";
	EndOfClass 				= "^[\s]?\)$";
	
	ReplaceOneEndCrLf 		= "\r\n{1}$";
	LeadingTabs 			= "^[\t]*";
	TrailingWhitespace 		= "[ ]*$";
	
vars
	devClassesSection 			: DEV_SchemaClassesSection;
	
	matches						: JadeRegexMatch;
	
	devClass 					: DEV_Class;
	devAttribute				: DEV_Attribute;
	devConstant 				: DEV_Constant;
	devReference 				: DEV_Reference;
	devMethodSource 			: DEV_Method;
	devExternalMethod			: DEV_ExternalMethod;
	devEventMethodMapping		: DEV_EventMethodMapping;
	previousLine 				: String;
	
	constantValue,
	constantData,
	miscData,
	documentationTextStr,
	webServicesClassPropertiesStr,
	webServicesMethodDefinitionsStr,
	implementInterfacesStr,
	jadeMethodDesc 				: String;
	
	processingClass				: Boolean;
	
	//Temp/New
	currentSubSection 			: String;
	pos 						: Integer;
	delimiter 					: String;
	modifiedTimeStamp 			: LSModifiedTimeStamp;
	doNotReadLine 				: Boolean;
	length						: Integer;
	
begin
	if self.mySchemaFile.mySchema.allSections.getAtKey("typeDefinitions") = null then
		self.trxCreateSchemaClassesSection("typeDefinitions", devClassesSection);
	else
		devClassesSection := self.mySchemaFile.mySchema.allSections.getAtKey("typeDefinitions").DEV_SchemaClassesSection;
	endif;
	
	create modifiedTimeStamp transient;
	
	while true do
		//Process File
		if doNotReadLine then
			doNotReadLine := false;
		else
			_line := _inputFile.readLine();
			_lineNumber := _lineNumber + 1;
		endif;
		
		delete matches;
		
		if(_line = null and _inputFile.endOfFile()) then
			break;
		elseif _line = null or _line = " " then
			continue;
		endif;
	
		if (not processingClass and (JadeRegex@match(_line, CompleteDefinitionRegex, true, true, matches) or JadeRegex@match(_line, ClassNameRegex, true, true, matches))) 
			and not _line = "	("
		then
			//Processing a Type/Class
			
			//Class/Type name
			processingClass := true;
			self.trxCreateClass(matches.getCaptureByName("className").value, "", false, devClass, devClassesSection);
			currentSubSection := null;
			previousLine := _line;
				
		elseif JadeRegex@isMatch(_line, SubSectionRegex, true) then
			//we have matched a subsection
			currentSubSection := _line; //Trim Whitespace and Tabs
		
			previousLine := _line;
		
		//Sanitise the currentSubSection and remove start tabs and spaces
		elseif JadeRegex@contains(currentSubSection, "constantDefinitions", true) and not JadeRegex@isMatch(_line, EndOfClass, true) then
			//We are adding a new constant
			if JadeRegex@match(_line, ConstantRegex, true, true, matches) then
				constantValue := matches.getCaptureByName("constantValue").value;
				constantValue := JadeRegex@replaceAll(constantValue, "", TrailingWhitespace, true);
				
				miscData := matches.getCaptureByName("miscData").value;
				
				devConstant := self.trxCreateConstant(matches.getCaptureByName("constantName").value, matches.getCaptureByName("constantType").value, constantValue, miscData, delimiter, devClass);
				delimiter := null;
				miscData := null;
				
			elseif JadeRegex@match(_line, StartConstantRegex, true, true, matches) then
				constantData := matches.getCaptureByName("constantData").value &amp; CrLf;
				
				while true do
					_line := _inputFile.readLine();
					_lineNumber := _lineNumber + 1;
					
					if JadeRegex@contains(_line, "documentationText", true) 
						or JadeRegex@contains(_line, "setModifiedTimeStamp", true) 
						or JadeRegex@contains(_line, SubSectionRegex, true)
						or JadeRegex@isMatch(_line, EndOfClass, true) 
					then
						doNotReadLine := true;	//Do not read next line
						
						pos := 1;	//Reset position to 1
						pos := constantData.reversePos("number"); //See if we can locate number
						
						constantData := JadeRegex@replaceAll(constantData, "", "\r\n$", true); //Remove last line break &amp; carridge return
						
						if pos &lt;&gt; 0 then
							constantValue := constantData[1:pos-2];
							miscData := constantData[pos:constantData.length-pos];
						else
							constantValue := constantData[1:constantData.length-1];
						endif;
						
						devConstant := self.trxCreateConstant(matches.getCaptureByName("constantName").value, matches.getCaptureByName("constantType").value, constantValue, miscData, delimiter, devClass);
						constantData := null;
						miscData := null;
						break;
					else
						constantData &amp;= _line;
					endif;
					
					constantData &amp;= CrLf;
				endwhile;
				
			elseif self.checkModifiedTimestamp(_line, modifiedTimeStamp) then
				devConstant.setLastModifiedTimeStamp(modifiedTimeStamp);
				
			elseif JadeRegex@contains(_line, "documentationText", true) then
				//documentationText Loop to get text data
				documentationTextStr := null;
				documentationTextStr := self.getDocumentationText(_line, _lineNumber, _inputFile);
				self.trxUpdateConstant(devConstant, documentationTextStr);
				documentationTextStr := null;
				
			endif;
			
			previousLine := _line;
			
		elseif JadeRegex@contains(currentSubSection, "attributeDefinitions", true) and not JadeRegex@isMatch(_line, EndOfClass, true) then
			
			if JadeRegex@match(_line, AttributeRegex, true, true, matches) then
				//We are adding a new constant
				length := matches.getCaptureByName("length").value.Integer;
				if length = 0 then
					length := -1;	//Maximum Length Strings are -1
				endif;
				devAttribute := self.trxCreateAttribute(matches.getCaptureByName("attributeName").value, 
														matches.getCaptureByName("type").value, 
														matches.getCaptureByName("miscData").value.trimBlankCharacters(), 
														"", 
														length,
														matches.getCaptureByName("precision").value.Integer,
														devClass);
														
			elseif self.checkModifiedTimestamp(_line, modifiedTimeStamp) then
				devAttribute.setLastModifiedTimeStamp(modifiedTimeStamp);
				
			elseif JadeRegex@contains(_line, "documentationText", true) then
				//documentationText Loop to get text data
				documentationTextStr := null;
				documentationTextStr := self.getDocumentationText(_line, _lineNumber, _inputFile);
				self.trxUpdateAttribute(devAttribute, documentationTextStr);
				documentationTextStr := null;
			endif;
			previousLine := _line;
			
		elseif JadeRegex@contains(currentSubSection, "referenceDefinitions", true) and not JadeRegex@isMatch(_line, EndOfClass, true) then
			if JadeRegex@match(_line, ReferenceRegex, true, true, matches) then
				devReference 	:= self.trxCreateReference(matches.getCaptureByName("referenceName").value, 
															matches.getCaptureByName("referenceType").value.trimBlankCharacters(), 
															matches.getCaptureByName("miscData").value, "", devClass);
															
			elseif self.checkModifiedTimestamp(_line, modifiedTimeStamp) then
				devReference.setLastModifiedTimeStamp(modifiedTimeStamp);
				
			elseif JadeRegex@contains(_line, "documentationText", true) then
				//documentationText Loop to get text data
				documentationTextStr := null;
				documentationTextStr := self.getDocumentationText(_line, _lineNumber, _inputFile);
				self.trxUpdateReference(devReference, documentationTextStr);
				documentationTextStr := null;
				
			endif;
			
			previousLine := _line;
			
		elseif JadeRegex@contains(currentSubSection, "jadeMethodDefinitions", true) and not JadeRegex@isMatch(_line, EndOfClass, true) then
			
			if JadeRegex@match(jadeMethodDesc, JadeMethodWholeRegex, true, true, matches) then
				jadeMethodDesc := JadeRegex@replaceAll(matches.value, "", LeadingTabs, true);
				devMethodSource := self.trxCreateMethodSource(matches.getCaptureByName("name").value, JadeRegex@replaceAll(jadeMethodDesc, "", "\r\n$", true), "", devClass);
				jadeMethodDesc := "";

			elseif not JadeRegex@isMatch(_line, SetModifiedTimeStampRegex, true) and not JadeRegex@isMatch(_line, "^\s*documentationText", true) then
				jadeMethodDesc := jadeMethodDesc &amp; _line &amp; CrLf;
				
			endif;
			
			if self.checkModifiedTimestamp(_line, modifiedTimeStamp) then
				devMethodSource.setLastModifiedTimeStamp(modifiedTimeStamp);
				
			elseif JadeRegex@isMatch(_line, "^\s*documentationText", true) then
				//documentationText Loop to get text data
				documentationTextStr := null;
				documentationTextStr := self.getDocumentationText(_line, _lineNumber, _inputFile);
				self.trxUpdateMethodSource(devMethodSource, documentationTextStr);
				documentationTextStr := null;
				
			endif;
			
			previousLine := _line;
		
		elseif JadeRegex@contains(currentSubSection, "externalMethodDefinitions", true) and not JadeRegex@isMatch(_line, EndOfClass, true) then
			
			//Match whole method regex spanning multiple lines
			if JadeRegex@match(jadeMethodDesc, JadeMethodWholeRegex, true, true, matches) then
				jadeMethodDesc := JadeRegex@replaceAll(matches.value, "", LeadingTabs, true);
				devExternalMethod := self.trxCreateExternalMethod(matches.getCaptureByName("name").value, JadeRegex@replaceAll(jadeMethodDesc, "", "\r\n$", true), devClass);
				jadeMethodDesc := "";

			elseif not JadeRegex@isMatch(_line, SetModifiedTimeStampRegex, true) and not JadeRegex@contains(_line, "documentationText", true) then
				jadeMethodDesc := jadeMethodDesc &amp; _line &amp; CrLf;
				
			endif;
			
			if self.checkModifiedTimestamp(_line, modifiedTimeStamp) then
				devExternalMethod.setLastModifiedTimeStamp(modifiedTimeStamp);
				
			endif;
			
			previousLine := _line;
			
		elseif JadeRegex@contains(currentSubSection, "eventMethodMappings", true) and not JadeRegex@isMatch(_line, EndOfClass, true) then
			if JadeRegex@match(_line, EventMethodMappingRegex, true, true, matches) then
				devEventMethodMapping := self.trxCreateEventMethodMapping(matches.getCaptureByName("name").value, matches.getCaptureByName("value").value, devClass);
			endif;
			
			previousLine := _line;
			
		elseif JadeRegex@contains(currentSubSection, "webServicesClassProperties", true) and not JadeRegex@isMatch(_line, EndOfClass, true) then
			webServicesClassPropertiesStr := null;
			webServicesClassPropertiesStr := previousLine &amp; CrLf;
			if (JadeRegex@contains(_line, "\(", false)) then
				webServicesClassPropertiesStr := webServicesClassPropertiesStr &amp; _line &amp; CrLf;
				while true do
					_line := _inputFile.readLine();
					_lineNumber := _lineNumber + 1;
					
					webServicesClassPropertiesStr := webServicesClassPropertiesStr &amp; _line &amp; CrLf;
					if(JadeRegex@contains(_line, "\)", false)) then
						break;
					endif;
				endwhile;
			endif;
			webServicesClassPropertiesStr := JadeRegex@replaceAll(webServicesClassPropertiesStr, "", ReplaceOneEndCrLf, true); //Remove one ending line break
			self.trxUpdateClass(devClass, devClass.documentationTextData, webServicesClassPropertiesStr, devClass.webServicesMethodDefinitionsText, devClass.implementInterfacesText, devClass.isInterface);
			
			webServicesClassPropertiesStr := null;
			previousLine := _line;
			
		elseif JadeRegex@contains(currentSubSection, "webServicesMethodDefinitions", true) and not JadeRegex@isMatch(_line, EndOfClass, true) then
			/*while true do
				webServicesMethodDefinitionsStr := webServicesMethodDefinitionsStr &amp; _line &amp; CrLf;
				_line := _inputFile.readLine();
				_lineNumber := _lineNumber + 1;
				
				if JadeRegex@contains(_line, "constantDefinitions|attributeDefinitions|referenceDefinitions|jadeMethodDefinitions|eventMethodMappings|externalMethodDefinitions|implementInterfaces", true) or JadeRegex@isMatch(_line, EndOfClass, true) then
					break;
				endif;
				previousLine := _line;
			endwhile;
			webServicesMethodDefinitionsStr := JadeRegex@replaceAll(webServicesMethodDefinitionsStr, "", ReplaceOneEndCrLf, true);
			self.trxUpdateClass(devClass, devClass.documentationTextData, devClass.webServicesClassPropertiesText, webServicesMethodDefinitionsStr, devClass.implementInterfacesText, devClass.isInterface);
			
			webServicesMethodDefinitionsStr := null;
			previousLine := _line;
			doNotReadLine := true;*/
			
			//We do not care about the webServicesMethodProperties at the moment so the loop just skips it
			//Will be implemented in the future version
			//Updated to read the section properly as jade methods and add them to the class
			if JadeRegex@contains(_line, "webServicesMethodProperties", true) then
			
				while true do
					_line := _inputFile.readLine();
					_lineNumber := _lineNumber + 1;
					
					if JadeRegex@contains(_line, "constantDefinitions|attributeDefinitions|referenceDefinitions|jadeMethodDefinitions|eventMethodMappings|externalMethodDefinitions|implementInterfaces|\)", true) or JadeRegex@isMatch(_line, EndOfClass, true) then
						break;
					endif;
					previousLine := _line;
				endwhile;
			
			elseif JadeRegex@match(jadeMethodDesc, JadeMethodWholeRegex, true, true, matches) then
				jadeMethodDesc := JadeRegex@replaceAll(matches.value, "", LeadingTabs, true);
				devMethodSource := self.trxCreateMethodSource(matches.getCaptureByName("name").value, JadeRegex@replaceAll(jadeMethodDesc, "", "\r\n$", true), "", devClass);
				jadeMethodDesc := "";
				
			elseif not JadeRegex@isMatch(_line, SetModifiedTimeStampRegex, true) and not JadeRegex@isMatch(_line, "^\s*documentationText", true) then
				jadeMethodDesc := jadeMethodDesc &amp; _line &amp; CrLf;
				
			endif;
			
			if self.checkModifiedTimestamp(_line, modifiedTimeStamp) then
				devMethodSource.setLastModifiedTimeStamp(modifiedTimeStamp);
				
			elseif JadeRegex@isMatch(_line, "^\s*documentationText", true) then
				//documentationText Loop to get text data
				documentationTextStr := null;
				documentationTextStr := self.getDocumentationText(_line, _lineNumber, _inputFile);
				self.trxUpdateMethodSource(devMethodSource, documentationTextStr);
				documentationTextStr := null;
				
			endif;
			
			previousLine := _line;
			
		elseif JadeRegex@contains(currentSubSection, "implementInterfaces", true) and not JadeRegex@isMatch(_line, EndOfClass, true) then
			while true do
				implementInterfacesStr := implementInterfacesStr &amp; _line &amp; CrLf;
				_line := _inputFile.readLine();
				_lineNumber := _lineNumber + 1;
				
				if JadeRegex@contains(_line, "constantDefinitions|attributeDefinitions|referenceDefinitions|jadeMethodDefinitions|eventMethodMappings|externalMethodDefinitions|webServicesMethodDefinitions", true) or JadeRegex@isMatch(_line, EndOfClass, true) then
					break;
				endif;
				previousLine := _line;
			endwhile;
			implementInterfacesStr := JadeRegex@replaceAll(implementInterfacesStr, "", ReplaceOneEndCrLf, true);
			
			self.trxUpdateClass(devClass, devClass.documentationTextData, devClass.webServicesClassPropertiesText, devClass.webServicesMethodDefinitionsText, implementInterfacesStr, devClass.isInterface);
			
			implementInterfacesStr := null;
			previousLine := _line;
			doNotReadLine := true;
			
		elseif self.checkModifiedTimestamp(_line, modifiedTimeStamp) then
			if processingClass then
				//Add Timestamp to class
				devClass.setLastModifiedTimeStamp(modifiedTimeStamp);
			endif;
			
		elseif JadeRegex@contains(_line, "documentationText", true) then
			if processingClass then
				//documentationText Loop to get text data
				documentationTextStr := null;
				documentationTextStr := self.getDocumentationText(_line, _lineNumber, _inputFile);
				
				self.trxUpdateClass(devClass, documentationTextStr, devClass.webServicesClassPropertiesText, devClass.webServicesMethodDefinitionsText, devClass.implementInterfacesText, devClass.isInterface);
			endif;
			
		elseif JadeRegex@isMatch(_line, EndOfClass, true) then //End Of Class
			//delete devClass;
			devClass := null;
			currentSubSection := "";
			processingClass := false;
			
		elseif (self.isSection(_line, false)) then
			break;
			
		else
			previousLine := _line;
			
		endif;
	
	endwhile;

epilog
	delete matches;
	delete modifiedTimeStamp;
	
end;</source>
        <access>protected</access>
        <Parameter name="_sectionName" type="String"/>
        <Parameter name="_line" type="String" usage="io"/>
        <Parameter name="_lineNumber" type="Integer" usage="io"/>
        <Parameter name="_inputFile" type="File" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadTypeSourcesSection" id="e596232f-b19a-4941-8c9b-1f902f442d26">
        <source>loadTypeSourcesSection(_sectionName 	: String; 
						_line			: String io; 
						_lineNumber 	: Integer io; 
						_inputFile 		: File io) protected;
/*

Purpose:			Loads the type sources section (All the Methods)
					Maybe change to how a compiler works using scanUntil functionality

Parameters:			_sectionName:		String				Name of the section
					_line:				String				Line we are processing
					_lineNumber:		Integer				Line number to keep a record in case we need to know
					_inputFile:			File				The file we are reading

Return Value:		

Date		Who		Reason
27 October 2021	navpw1	Initial creation TFS: 52202

*/

constants
	MethodStartRegex 		= "^{$";
	MethodEndRegex 			= "^}$";
	ClassRegex 				= "^\t(?'className'[A-Za-z0-9_]*)\s*\(";
	CompleteCommentRegex 	= "^.*\/\*.*\*\/.*$";	// '/*' ... '*/'
	StartComment 			= "\/\*";	// '/*'
	EndComment 				= "\*\/";	// '*/'
	CommentStartRegex 		= "^[\s\t]*\/\*.[^\*\/]*$"; // '/*' until EOL or '*/'
	CommentEndRegex 		= "^.*\*\/.*$";	// '*/'
	SignatureEnd 			= "^.*end[\s]*;.*$";
	ReplaceOneEndCrLf 		= "\r\n{1}$";
	MethodSource 			= "webServicesMethodSources|externalMethodSources|jadeMethodSources";
	AbstractMethodRegex		= "^.*abstract.*;$";
	BeginRegex				= "^begin[\s]*$";
	
vars
	processingClass,
	processingMethod,
	processingComment,
	processingMethodData,
	foundBeginInstruction,
	abstractMethod				: Boolean;
	devClassesSection 			: DEV_SchemaClassesSection;

	devClass,
	existingClass 				: DEV_Class;
	devMethod 					: DEV_Method;
	
	className,
	methodName,
	methodDesc,
	methodSourceType,
	previousLine				: String;
	
	currentMethodCount,
	currentMethodDataCount 		: Integer;
	
begin
	 //Get Classes Section and check if class exists?
	if self.mySchemaFile.mySchema.allSections.getAtKey("typeDefinitions") = null then
		self.trxCreateSchemaClassesSection("typeDefinitions", devClassesSection);
	else
		devClassesSection := self.mySchemaFile.mySchema.allSections.getAtKey("typeDefinitions").DEV_SchemaClassesSection;
	endif;
	
	processingMethod := false;
	processingComment := false;
	processingMethodData := false;
	foundBeginInstruction := false;
	abstractMethod := false;
	currentMethodCount := 0;
	
	while true do
		//Process File
		_line := _inputFile.readLine();
		_lineNumber := _lineNumber + 1;
	
		if(_line = null and _inputFile.endOfFile()) then
			break;
		endif;
		
		if (not processingMethod and JadeRegex@isMatch(_line, ClassRegex, true)) then //Dealing with Class
			processClass(_line, ClassRegex, false, devClass, devClassesSection);
			methodSourceType := null;
			
		elseif (not processingMethod and JadeRegex@contains(_line, MethodSource, true)) then
			methodSourceType := _line.removeTabCrLfs().trimWhiteSpace();
		
		elseif (not processingComment and JadeRegex@isMatch(_line, BeginRegex, false)) then
		
			if (processingMethodData) then
				currentMethodDataCount := currentMethodDataCount + 1;
				methodDesc := methodDesc &amp; _line &amp; CrLf;
			else
				foundBeginInstruction := true;
				processingMethodData := true;
				methodDesc := methodDesc &amp; _line &amp; CrLf;
				currentMethodDataCount := 1;
			endif;

		elseif (not processingComment and JadeRegex@isMatch(_line, SignatureEnd, true)) then
		
			if (currentMethodDataCount = 1) then
				processingMethodData := false;
				methodDesc := methodDesc &amp; _line &amp; CrLf;
			else
				currentMethodDataCount := (currentMethodDataCount - 1).max(1);	// don't go below 1
				methodDesc := methodDesc &amp; _line &amp; CrLf;
			endif;
			
		elseif (not processingComment and not processingMethodData and JadeRegex@isMatch(_line, MethodStartRegex, true)) then //methodStartRegex.isMatch(_line)) then
			
			if (processingMethod) then
				currentMethodCount := currentMethodCount + 1;
				methodDesc := methodDesc &amp; _line &amp; CrLf;
			else
				processingMethod := true;
				methodName := previousLine;
				currentMethodCount := 1;
				
			endif;
		
		elseif (JadeRegex@contains(_line, StartComment, true) and (JadeRegex@isMatch(_line, CommentStartRegex, true) or _line = "/*")) then //Do not process commented code inside method as method endings
			processingComment := true;
			methodDesc := methodDesc &amp; _line &amp; CrLf;
		
		elseif (JadeRegex@contains(_line, EndComment, true) and JadeRegex@isMatch(_line, CommentEndRegex, true)) then 
			processingComment := false;
			methodDesc := methodDesc &amp; _line &amp; CrLf;
		
		elseif (JadeRegex@isMatch(_line, CompleteCommentRegex, true)) then
			methodDesc := methodDesc &amp; _line &amp; CrLf;
			previousLine := _line; //Used for MethodName as it appears before the { in the file
				
		elseif (not processingComment and not processingMethodData and JadeRegex@isMatch(_line, MethodEndRegex, true)) then //end of method so read data
			
			if 	currentMethodCount = 1 or
				(methodSourceType = "jadeMethodSources" and (foundBeginInstruction or abstractMethod))
			then
				processingMethod := false;
				foundBeginInstruction := false;
				abstractMethod := false;
				methodDesc := JadeRegex@replaceAll(methodDesc, "", ReplaceOneEndCrLf, true); //Remove the CrLf before the '}' character as this is added as extra
				self.trxCreateMethod(methodName, methodDesc, methodSourceType, devClass);
				methodName :=  null;
				methodDesc := null;
			else
				currentMethodCount := (currentMethodCount - 1).max(1);	// don't go below 1
				methodDesc := methodDesc &amp; _line &amp; CrLf;
			endif;
		
		elseif (processingMethod) then
			methodDesc := methodDesc &amp; _line &amp; CrLf;
			previousLine := _line; //Used for MethodName as it appears before the { in the file
			if methodSourceType = "jadeMethodSources" and JadeRegex@isMatch(_line, AbstractMethodRegex, false) then
				abstractMethod := true;
			endif;
		
		elseif (self.isSection(_line, false)) then
			break;
			
		else
			previousLine := _line; //Used for MethodName as it appears before the { in the file
			
		endif;
	
	endwhile;

	if process.isMPD and methodName &lt;&gt; null then
		process.debug;
		system.interruptUser(node, process);
	endif;
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_sectionName" type="String"/>
        <Parameter name="_line" type="String" usage="io"/>
        <Parameter name="_lineNumber" type="Integer" usage="io"/>
        <Parameter name="_inputFile" type="File" usage="io"/>
    </JadeMethod>
    <JadeMethod name="logMessage" id="0e926958-8037-4d06-b7d8-79b9495c55d4">
        <source>logMessage(_msg : String; _logLevel : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 December 2017	jlgkpd1	Initial creation

*/

vars
	errorString		: String;
	
begin
	if _logLevel &lt;= app.logLevel then
		write errorString &amp; _msg;
		app.writeLog(errorString &amp; _msg, _logLevel);
	endif;
	
end;</source>
        <Parameter name="_msg" type="String"/>
        <Parameter name="_logLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="processClass" id="8ccefaa2-6a81-4b00-8eb5-bb86c0b7a79d">
        <source>processClass(_line 				: String io; 
			_classRegex 		: String; 
			_isInterface		: Boolean;
			_devClass 			: DEV_Class io; 
			_devClassesSection 	: DEV_SchemaClassesSection io) protected;
/*

Purpose:			Processes a class (Obsolete? Look at integrating this back in)

Parameters:			_line:					String							The line we are processing
					_classRegex:			String							The class regex we need to use to break it down
					_devClass:				DEV_Class						The class we are reading
					_devClassesSection:		DEV_SchemaClassesSection		The section that holds all the types/classes

Return Value:		

Date		Who		Reason
27 October 2021	navpw1	Initial creation TFS: 52202

*/

vars
	classRegexMatches	: JadeRegexMatch;
	className			: String;
	devClass			: DEV_Class;
	
begin
	//Regex check Category Line
	JadeRegex@match(_line, _classRegex, true, true, classRegexMatches);
	className := classRegexMatches.getCaptureByName("className").value;
	
	self.trxCreateClass(className, "", _isInterface, _devClass, _devClassesSection);
epilog
	delete classRegexMatches;
	
end;</source>
        <access>protected</access>
        <Parameter name="_line" type="String" usage="io"/>
        <Parameter name="_classRegex" type="String"/>
        <Parameter name="_isInterface" type="Boolean"/>
        <Parameter name="_devClass" type="DEV_Class" usage="io"/>
        <Parameter name="_devClassesSection" type="DEV_SchemaClassesSection" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setIsRunningComparison" id="bf4efb0a-5d13-4149-8bb6-666bb3fae7ef">
        <source>setIsRunningComparison(_value : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 February 2024	navpw1	Initial creation

*/

vars
	sourceCompareRoot : DEV_SourceCompareRoot;
begin
	sourceCompareRoot := DEV_SourceCompareRoot.firstInstance;
	if sourceCompareRoot = null then
		return;
	endif;
	
	sourceCompareRoot.setIsRunningComparison(_value);
	
end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setReportAvailable" id="19a5254f-a239-4422-b403-f42ad47add4e">
        <source>setReportAvailable();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 March 2022	navpw1	Initial creation TFS: 52791

*/

vars

begin
	self.reportAgent.setReportAvailable();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="trxCreateAttribute" id="876f970f-bf45-43eb-b351-3b2bb04a8c3c">
        <source>trxCreateAttribute(_attributeName, 
					_attributeType, 
					_miscData,
					_documentationtextData	: String;
					_length,
					_precision				: Integer;
					_devClass				: DEV_Class io) : DEV_Attribute protected;
/*

Purpose:			Creates a DEV_Attribute

Parameters:			_attributeName:				String			The attributes name
					_attributeType:				String			The attributes type
					_miscData:					String			The data we are not interested in but needs to be written out
					_documentationtextData:		String			The class's documentation text
					_devClass:					DEV_Class		The class the attribute belongs to

Return Value:		The created DEV_Attribute

Date		Who		Reason
09 November 2021	navpw1	Initial creation TFS:52202

*/

vars
	devAttribute: DEV_Attribute;
	
begin
	devAttribute := create DEV_Attribute(_attributeName, _attributeType, _miscData, _documentationtextData, _length, _precision, 0, _devClass) transient;
	return devAttribute;
	
end;</source>
        <access>protected</access>
        <Parameter name="_attributeName" type="String"/>
        <Parameter name="_attributeType" type="String"/>
        <Parameter name="_miscData" type="String"/>
        <Parameter name="_documentationtextData" type="String"/>
        <Parameter name="_length" type="Integer"/>
        <Parameter name="_precision" type="Integer"/>
        <Parameter name="_devClass" type="DEV_Class" usage="io"/>
        <ReturnType type="DEV_Attribute"/>
    </JadeMethod>
    <JadeMethod name="trxCreateClass" id="f019d2ee-f02e-44a0-b6e3-3322d1140e32">
        <source>trxCreateClass(_className,
				_documentationTextData	: String;
				_isInterface			: Boolean;
				_devClass 				: DEV_Class io; 
				_devClassesSection		: DEV_SchemaClassesSection io) protected;
/*

Purpose:			Creates a DEV_Class

Parameters:			_className:					String						The name of the class
					_documentationTextData:		String						The documentation text on the class
					_devClass:					DEV_Class					The class we are creating
					_devClassesSection:			DEV_SchemaClassesSection	The section that holds all the types/classes

Return Value:		

Date		Who		Reason
27 October 2021	navpw1	Initial creation TFS: 52202

*/

vars
	devClass : DEV_Class;
	
begin
	foreach devClass in _devClassesSection.allClasses do
		if devClass.name = _className then
			devClass.update(devClass.documentationTextData, devClass.webServicesClassPropertiesText, devClass.webServicesMethodDefinitionsText, devClass.implementInterfacesText, devClass.isInterface);
			_devClass := devClass;
			return;
		endif;
	endforeach;

	_devClass := create DEV_Class(_className, _documentationTextData, _isInterface, 0, null, _devClassesSection) transient;

end;</source>
        <access>protected</access>
        <Parameter name="_className" type="String"/>
        <Parameter name="_documentationTextData" type="String"/>
        <Parameter name="_isInterface" type="Boolean"/>
        <Parameter name="_devClass" type="DEV_Class" usage="io"/>
        <Parameter name="_devClassesSection" type="DEV_SchemaClassesSection" usage="io"/>
    </JadeMethod>
    <JadeMethod name="trxCreateClassMappRef" id="27852e9f-d26c-47da-8c15-31b46d8620a7">
        <source>trxCreateClassMappRef(	_className,
						_mapFileName 	: String;
						_section 		: DEV_SchemaClassMapSection;
						_classMapRef 	: DEV_ClassMapReference io) protected;
/*

Purpose:			Creates a DEV_ClassMapReference (Look into putting this into a type/classes section later on)

Parameters:			_className:		String						The name of the class
					_mapFileName:	String						The name of the map file
					_section:		DEV_SchemaClassMapSection	The section containing Class &amp; Maps
					_classMapRef:	DEV_ClassMapReference		The class map reference we are creating

Return Value:		

Date		Who		Reason
28 October 2021	navmd1	Initial creation TFS: 52202

*/

begin
	_classMapRef := create DEV_ClassMapReference(_className, _mapFileName, _section) transient;
	
end;</source>
        <access>protected</access>
        <Parameter name="_className" type="String"/>
        <Parameter name="_mapFileName" type="String"/>
        <Parameter name="_section" type="DEV_SchemaClassMapSection"/>
        <Parameter name="_classMapRef" type="DEV_ClassMapReference" usage="io"/>
    </JadeMethod>
    <JadeMethod name="trxCreateConstant" id="c639c593-d7e3-4ffc-8bc3-734570eef58c">
        <source>trxCreateConstant(_constantName,
					_constantType,
					_constantValue, 
					_miscData,
					_delimiter		: String; 
					_devClass 		: DEV_Class io) : DEV_Constant protected;
/*

Purpose:			Creates a DEV_Constant

Parameters:			_constantName:		String		The name of the constant
					_constantType:		String		The type of the constant
					_constantValue:		String		The value of the constant
					_miscData:			String		The data we are not interested in but needs to be written out
					_delimiter			String		The delimiter used for a string type either ' or "
					_devClass:			DEV_Class	The class the constant belongs to

Return Value:		The created DEV_Constant

Date		Who		Reason
09 November 2021	navpw1	Initial creation TFS: 52202

*/
vars
	devConstant : DEV_Constant;
	
begin
	devConstant := create DEV_ClassConstant(_constantName, _constantType, _constantValue, "", _miscData, _delimiter, 0, _devClass) transient;
	return devConstant;
	
end;</source>
        <access>protected</access>
        <Parameter name="_constantName" type="String"/>
        <Parameter name="_constantType" type="String"/>
        <Parameter name="_constantValue" type="String"/>
        <Parameter name="_miscData" type="String"/>
        <Parameter name="_delimiter" type="String"/>
        <Parameter name="_devClass" type="DEV_Class" usage="io"/>
        <ReturnType type="DEV_Constant"/>
    </JadeMethod>
    <JadeMethod name="trxCreateEventMethodMapping" id="14f2500c-793f-4f20-9147-af4c28cc3251">
        <source>trxCreateEventMethodMapping(_name,
							_value		: String;
							_devClass	: DEV_Class io) : DEV_EventMethodMapping protected;
/*

Purpose:			Creates an DEV_EventMethodMapping

Parameters:			_name:		String		The name of the event method mapping
					_value:		String		The value of the event method mapping
					_devClass:	DEV_Class	The class the event method mapping belongs to	

Return Value:		Returns the created DEV_EventMethodMapping

Date		Who		Reason
10 November 2021	navpw1	Initial creation TFS: 52202

*/
vars
	devEventMethodMapping : DEV_EventMethodMapping;
	
begin
	devEventMethodMapping := create DEV_EventMethodMapping(_name, _value, _devClass) transient;
	return devEventMethodMapping;
	
end;</source>
        <access>protected</access>
        <Parameter name="_name" type="String"/>
        <Parameter name="_value" type="String"/>
        <Parameter name="_devClass" type="DEV_Class" usage="io"/>
        <ReturnType type="DEV_EventMethodMapping"/>
    </JadeMethod>
    <JadeMethod name="trxCreateExternalMethod" id="9979f6bb-565a-4354-889a-879720e77c35">
        <source>trxCreateExternalMethod(_name,
						_description		: String; 
						_devClass 			: DEV_Class io) : DEV_ExternalMethod protected;
/*

Purpose:			Creates an DEV_ExternalMethod

Parameters:			_name:					String			The name of the external method
					_description:			String			The description of the external method
					_devClass:				DEV_Class		The class the external method belongs to

Return Value:		Returns the created DEV_ExternalMethod

Date		Who		Reason
10 November 2021	navpw1	Initial creation TFS: 52202

*/
vars
	devExternalMethod : DEV_ExternalMethod;
	
begin
	devExternalMethod := create DEV_ExternalMethod(_name, _description, _devClass) transient;
	return devExternalMethod;
	
end;</source>
        <access>protected</access>
        <Parameter name="_name" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_devClass" type="DEV_Class" usage="io"/>
        <ReturnType type="DEV_ExternalMethod"/>
    </JadeMethod>
    <JadeMethod name="trxCreateGConstant" id="d8eb15d7-7a38-45be-aa72-61cbcd11b29c">
        <source>trxCreateGConstant(_devConstant 			: DEV_GlobalConstant io; 
					_constantName,
					_constantType,
					_constantValue,
					_documentationTextStr	: String; 
					_devConstantCategory	: DEV_GlobalConstantCategory io) protected;
/*

Purpose:			Creates a DEV_GlobalConstant

Parameters:			_devConstant:			DEV_GlobalConstant				The global constant to create
					_constantName:			String							The global constant name
					_constantType:			String							The global constant type
					_constantValue:			String							The global constant value
					_documentationTextStr:	String					`		The documentation text on the global constant
					_devConstantCategory:	DEV_GlobalConstantCategory		The global constant category the global constant belongs to

Return Value:		

Date		Who		Reason
27 October 2021	navpw1	Initial creation TFS: 52202

*/

begin
	_devConstant := create DEV_GlobalConstant(_constantName, _constantType, _constantValue, _documentationTextStr, 0, _devConstantCategory) transient;
	
end;</source>
        <access>protected</access>
