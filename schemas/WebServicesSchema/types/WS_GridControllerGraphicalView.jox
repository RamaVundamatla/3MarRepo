    <JadeMethod name="setProxyFromObject" id="90c4b869-d0e9-406e-a72c-78d24f5ebc7c">
        <updating/>
        <source>setProxyFromObject(_object: CM_GridController) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Sep 2017	jlghl1	Initial creation
09 Sep 2021 jlier1	TFS 50988
*/

vars

begin
	inheritMethod(_object);
	
	self.column := _object.column;
	self.row := _object.row;
	self.columnLabel := _object.myGridColumn.label;
	self.columnLabel40:=_object.get40ftColumnLabel; // epr TFS 50988 9/9/21
	self.rowLabel := _object.myGridRow.label;

epilog

end;</source>
        <Parameter name="_object" type="CM_GridController"/>
