    <JadeMethod name="updateTI" id="d991a280-bedf-4d55-b3c6-0d1e9aa81480">
        <updating/>
        <source>updateTI(_passport : CM_Passport input) updating;
/*
 ------------------------------------------------------------------------
Created:			19 August 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	inheritMethod(_passport);			//cnwmc5 - 17 April 2015 - PAR 35925
	
	if self.myTrackedItem = null then
		return;
	endif;
	self.myTrackedItem.setMovedDT(TI_PickedUp);
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
