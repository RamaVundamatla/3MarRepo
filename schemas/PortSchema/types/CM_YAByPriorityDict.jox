    <MemberKey>
        <property name="CM_YardAllocation::priorityValue"/>
        <descending/>
    </MemberKey>
    <JadeMethod name="hasActiveAllocations" id="7c1a33fb-f670-49e9-af47-0aeacf573642">
        <source>hasActiveAllocations() : Boolean;

// Created by cnwdvb1 on 23 June 2006

vars

	allocation : CM_YardAllocation;

begin

	foreach allocation in self discreteLock do
		// CCMS 1013
		//if not allocation.isDisabled then
		if not allocation.isDisabled and allocation.includeInYardDisplays() then
			return true;
		endif;
	endforeach;

	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="removeObject" id="325ad223-876b-4d43-9d2b-78204e23989b">
        <lockReceiver/>
        <updating/>
        <source>removeObject(_obj: MemberType): Boolean updating, lockReceiver;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2017	jlgns1	Initial creation
14 July 2017 	jlgns1 	TFS 4566:CPL - Users encountered 1309 error at same time in Master Terminal
*/

vars
	iter	: Iterator;
	tmpObj	: MemberType;
	keyNum	: Real;
begin
	iter := self.createIterator();
	
	
	while iter.next(tmpObj) do
		if tmpObj = _obj then
			self.getIteratorKeys(keyNum, iter);
			self.removeKeyEntry(keyNum, tmpObj);
			return true;
		endif;
	endwhile;

	return false;

epilog
	delete iter;
end;</source>
        <Parameter name="_obj" type="MemberType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
