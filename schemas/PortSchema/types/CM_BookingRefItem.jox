    <JadeMethod name="setForCreate_CMIF" id="118de8c7-c048-4063-9cf5-cc6ca4e03d32">
        <updating/>
        <source>setForCreate_CMIF(pProxyBookingRefItem : CMIF_BookingRefItem; pBookingRef : CM_BookingRef) updating;
/*
	Created on 11 January 2008
	
	by Debby Hutchison
	
	Purpose: Copied from CM_BookingRef for CCMS 1618
	
	28/9/09 JMH  MES1008 Added extra fields
	04/3/14	DMP	 PAR #33193 CCMS DPH 2285 Aded purchase order and service order fields
	15/12/2014  cnwdb2	PAR 35364
	08 Dec 2022 jlika1 TFS 55586 - HS Code User Defined EDI
*/
vars
	docActions : CM_BookingItemActions;
begin
	self.raiseExceptionIfTransient(method);
//	self.setHazards(pProxyBookingRefItem.allTIHazards);		//CCMS 1203		//Par 18318
//	self.bolType			:= pProxyBookingRefItem.bolType; // adm 160310 Par 22937 remove bolType
	self.cargoType			:= pProxyBookingRefItem.cargoType;
	if self.cargoType = 0 then //par 14104 cnwrs1 May 2007 booking refs with a cargotype dont work to well
		if pBookingRef.isStockBookingRef = true then
			if pProxyBookingRefItem.myProduct &lt;&gt; null then  // aer CCMS 1618 if cargo type is not specified in the file, 
				self.cargoType := pProxyBookingRefItem.myProduct.myCargoType.id;	
			else // if is a stock BR and has a product , then get the cargo type from the product.
			//	app.raiseCMException1(REQUIRED_FIELD, 'Cargo Type',null, null);
				app.raiseCMException(Input_required_field_cargoType,null, null); // cnwdb2	PAR 35364
			endif;
		elseif app.getMyTerminalDO_NOT_USE.allCargoBOLTypes.includes(app.myRoot.allCargoTypesById[TI_CargoType_Container]) then
			self.cargoType := TI_CargoType_Container;
		else
			self.cargoType := app.getMyTerminalDO_NOT_USE.allCargoBOLTypes.first.id;
		endif;
	endif;
	self.clean				:= pProxyBookingRefItem.clean;
	self.setCommodityWithDefaults( pProxyBookingRefItem.commodity, pProxyBookingRefItem.ediCommodityDescription); // cnwgb1 33710 30.12.2014
	self.ediCommodityDescription := pProxyBookingRefItem.ediCommodityDescription;	//cnwrs1 CCMS 1882 03 June 2010
	self.cubicMetres		:= pProxyBookingRefItem.cubicMetres;
	self.description		:= pProxyBookingRefItem.description;
	self.inspected			:= pProxyBookingRefItem.inspected;
	self.isoType			:= pProxyBookingRefItem.isoType;
	
	self.quantity			:= pProxyBookingRefItem.quantity;
	self.remarks			:= pProxyBookingRefItem.remarks;
	self.weight				:= pProxyBookingRefItem.weight;
	
	self.height				:= pProxyBookingRefItem.height;
	self.length				:= pProxyBookingRefItem.length;
	self.width				:= pProxyBookingRefItem.width;
	self.heightString		:= pProxyBookingRefItem.heightString;
	self.lengthString		:= pProxyBookingRefItem.lengthString;
	self.widthString		:= pProxyBookingRefItem.widthString;
	self.typeString			:= pProxyBookingRefItem.typeString;
	self.density			:= pProxyBookingRefItem.density;
	self.volume				:= pProxyBookingRefItem.volume;
	self.productQuantity	:= pProxyBookingRefItem.productQuantity;
	// set the references with inverses that will add to the appropriate collections
	self.myProduct			:= pProxyBookingRefItem.myProduct;
	self.rawEDIData 		:= pProxyBookingRefItem.rawEDIData;
	self.creationTS			:= self.createdTime;
	self.shippingMarks 		:= pProxyBookingRefItem.shippingMarks;// Nelson 1637, Anca 09/05/08 
	self.myBookingReference	:= pBookingRef;
	
	self.generatorType 		:= pProxyBookingRefItem.generatorType; //cnwrd1 par 18220 24.2.09
	self.trailerType 		:= pProxyBookingRefItem.trailerType;
	// MES1008 JMH 28/9/09
	self.markNumber 		:= pProxyBookingRefItem.markNumber;
	self.isoTypeGroup 		:= pProxyBookingRefItem.isoTypeGroup;
	self.productWeight		:= pProxyBookingRefItem.productWeight;		
	self.productVolume		:= pProxyBookingRefItem.productVolume;		
	
	self.setHazards(pProxyBookingRefItem.allTIHazards);		//CCMS 1203		//Par 18318
	
	// cnwrl1 16/04/2010 PAR 23624 - start of coding
	self.allLinkedExportBookings.clear();
	pProxyBookingRefItem.allLinkedExportBookingsRefs.copy( self.allLinkedExportBookings );
	// cnwrl1 16/04/2010 PAR 23624 - end of coding
	self.sequence := pProxyBookingRefItem.sequence; //cnwrs1 CCMS 1882 25 May 2010
	
	self.purchaseOrder		:= pProxyBookingRefItem.purchaseOrder;			// PAR #331193
	self.serviceOrder		:= pProxyBookingRefItem.serviceOrder;			// PAR #331193

	//10 Oct 2016	NDL	TFS 2650 / 2001
	if not pProxyBookingRefItem.allStopTablesToAdd.isEmpty
	or not pProxyBookingRefItem.allTaskDescsToAdd.isEmpty
	then
		if self.myBookingRefItemActions = null then
			create docActions;
			docActions.setMyBookingRefItem(self);
		endif;
		self.myBookingRefItemActions.setStopTablesToAdd( pProxyBookingRefItem.allStopTablesToAdd );
		self.myBookingRefItemActions.setTaskDescsToAdd( pProxyBookingRefItem.allTaskDescsToAdd, pProxyBookingRefItem.allTaskRemarkToAdd );	//05 Oct 2016	NDL	TFS 2001 / 2792
	endif;
	
	self.mySpecialStow := pProxyBookingRefItem.mySpecialStow;	//08 Jun 2017	NDL	TFS 4454
	self.hsCode := pProxyBookingRefItem.hsCode; // jlika1 TFS 55586
	
	self.matchMode := pProxyBookingRefItem.matchMode;				//navra1 - CR 63764/Task 64227 - 22nd May 2024
	
end;
</source>
        <Parameter name="pProxyBookingRefItem" type="CMIF_BookingRefItem"/>
        <Parameter name="pBookingRef" type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="49e34ce4-e2f2-4df7-b0a5-07167080700c">
        <updating/>
        <source>setForUpdate(_proxyBookingRefItem : CM_BookingRefItem; _bookingRef : CM_BookingRef) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
18 Nov 2008		cnwer1	Initial creation
05 Feb 2014		cnwdap1	PAR #33193 CCMS DPH 2285 Added Purchase Order and Service Order fields
08 Dec 2022 	jlika1 TFS 55586 - HS Code User Defined EDI
*/

vars
	isoType : CM_ISOType;
	docActions : CM_BookingItemActions;
begin
	self.raiseExceptionIfTransient(method);
//	self.bolType			:= _proxyBookingRefItem.bolType; // adm 160310 Par 22937 remove bolType
	self.cargoType			:= _proxyBookingRefItem.cargoType;
	if self.cargoType = 0 then //par 14104 cnwrs1 May 2007 booking refs with a cargotype dont work to well
		if app.getMyTerminalDO_NOT_USE.allCargoBOLTypes.includes(app.myRoot.allCargoTypesById[TI_CargoType_Container]) then
			self.cargoType := TI_CargoType_Container;
		else
			self.cargoType := app.getMyTerminalDO_NOT_USE.allCargoBOLTypes.first.id;
		endif;
	endif;
	self.clean				:= _proxyBookingRefItem.clean;
	self.commodity 			:= _proxyBookingRefItem.commodity;
	self.description		:= _proxyBookingRefItem.description;
	self.inspected			:= _proxyBookingRefItem.inspected;
	self.isoType			:= _proxyBookingRefItem.isoType;
	self.isoTypeGroup		:= _proxyBookingRefItem.isoTypeGroup;				//+cnwml2 PAR21083
	
	//cnwmc5 - 21 March 2014 - PAR 33045
	if self.isoTypeGroup = null and self.isoType &lt;&gt; null then
		isoType := app.myRoot.allISOTypes[self.isoType];
		if isoType &lt;&gt; null and isoType.myISOTypeGroup &lt;&gt; null then
			self.isoTypeGroup := isoType.myISOTypeGroup.code;
		endif;
	endif;
	
	self.cubicMetres		:= _proxyBookingRefItem.cubicMetres;
	self.quantity			:= _proxyBookingRefItem.quantity;
	self.remarks			:= _proxyBookingRefItem.remarks;
	self.weight				:= _proxyBookingRefItem.weight;
	
	self.height				:= _proxyBookingRefItem.height;
	self.length				:= _proxyBookingRefItem.length;
	self.width				:= _proxyBookingRefItem.width;
	self.heightString		:= _proxyBookingRefItem.heightString;
	self.lengthString		:= _proxyBookingRefItem.lengthString;
	self.widthString		:= _proxyBookingRefItem.widthString;
	self.typeString			:= _proxyBookingRefItem.typeString;
	self.density			:= _proxyBookingRefItem.density;
	self.volume				:= _proxyBookingRefItem.volume;
	self.productVolume 		:= _proxyBookingRefItem.productVolume;							//+cnwml2 PAR20173 SFW CCMS 1091
	self.productWeight		:= _proxyBookingRefItem.productWeight;							//+cnwml2 PAR20173 SFW CCMS 1091
	self.productQuantity	:= _proxyBookingRefItem.productQuantity;
	self.shippingMarks := _proxyBookingRefItem.shippingMarks;// Nelson 1637, Anca 09/05/08 
	if not self.isCommodityChanged then  	// don't change once set
		self.isCommodityChanged := _proxyBookingRefItem.isCommodityChanged;
	endif;
	if not self.isDataChanged then			// don't change once set
		self.isDataChanged := _proxyBookingRefItem.isDataChanged;
	endif;
	
	// set the references with inverses that will add to the appropriate collections
	self.myProduct			:= _proxyBookingRefItem.myProduct;
	self.rawEDIData := _proxyBookingRefItem.rawEDIData;
	self.myBookingReference := _bookingRef;
	
	self.setHazards(_proxyBookingRefItem.allTIHazards);			//CCMS 1203		//Par 18318
	
	self.allSpecialLifts.clear;																//+cnwml2 PAR20173 SFW CCMS 1091
	_proxyBookingRefItem.allSpecialLifts.copy(self.allSpecialLifts);						//+cnwml2 PAR20173 SFW CCMS 1091
	
	self.generatorType 	:= _proxyBookingRefItem.generatorType; //cnwrd1 par 18222 24.2.09
	self.trailerType := _proxyBookingRefItem.trailerType;
	
	self.mySpecialStow 		:= _proxyBookingRefItem.mySpecialStow;							//+cnwml2 PAR20173 SFW CCMS 1091
	self.markNumber			:= _proxyBookingRefItem.markNumber;								//+cnwml2 PAR20173 SFW CCMS 1091
	self.colour				:= _proxyBookingRefItem.colour;									//+cnwml2 PAR20173 SFW CCMS 1091
	self.id					:= _proxyBookingRefItem.id;										//+cnwml2 PAR20173 SFW CCMS 1091
	self.sequence := _proxyBookingRefItem.sequence; //ccms 1882 cnwrs1 Dec 2009
	self.allLinkedExportBookings.clear();	//+cnwml2 MSL CCMS 1012
	if self.isStockBooking then            // PAR 26622
		_proxyBookingRefItem.allLinkedExportBookings.copy(self.allLinkedExportBookings);		//+cnwml2 MSL CCMS 1012
	endif;
	
	self.purchaseOrder		:= _proxyBookingRefItem.purchaseOrder;							// PAR #33193
	self.serviceOrder		:= _proxyBookingRefItem.serviceOrder;	// PAR #33193
	
	//14 Sep 2016	NDL	TFS 2644 / 2001
	if _proxyBookingRefItem.myBookingRefItemActions &lt;&gt; null then
		if self.myBookingRefItemActions = null then
			create docActions;
			docActions.setMyBookingRefItem(self);
		endif;
		self.myBookingRefItemActions.setForUpdate( _proxyBookingRefItem.myBookingRefItemActions );
	endif;
	
	self.hsCode	:= _proxyBookingRefItem.hsCode;
	
	self.matchMode := _proxyBookingRefItem.matchMode;		//navra1 - CR 63764/Task 64227 - 22nd May 2024
	
epilog

end;</source>
        <Parameter name="_proxyBookingRefItem" type="CM_BookingRefItem"/>
        <Parameter name="_bookingRef" type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate_CMIF" id="085a5bc4-253c-4fa3-97ca-bf363be9fbd5">
        <updating/>
        <source>setForUpdate_CMIF(_cmifBRItem : CMIF_BookingRefItem; pBookingRef : CM_BookingRef) updating;
/*
	Created on 17 January 2008
	
	by Debby Hutchison
	
	Purpose:
	
   Changed On	By			Reason
   ----------	--------	---------------------------------------------------------------------
   05/03/2014	cnwdap1		PAR #33193 CCMS DPH 2285 Added Purchase Order and Service Order fields
   08/12/2022 	jlika1 		TFS 55586 - HS Code User Defined EDI
*/

vars

	docActions : CM_BookingItemActions;
begin
	self.raiseExceptionIfTransient(method);
//	self.setHazards(_cmifBRItem.allTIHazards);			//CCMS 1203		//Par 18318
//	self.bolType			:= _cmifBRItem.bolType; // adm 160310 Par 22937 remove bolType
	self.cargoType			:= _cmifBRItem.cargoType;
	if self.cargoType = 0 then //par 14104 cnwrs1 May 2007 booking refs with a cargotype dont work to well
		if app.getMyTerminalDO_NOT_USE.allCargoBOLTypes.includes(app.myRoot.allCargoTypesById[TI_CargoType_Container]) then
			self.cargoType := TI_CargoType_Container;
		else
			self.cargoType := app.getMyTerminalDO_NOT_USE.allCargoBOLTypes.first.id;
		endif;
	endif;
	self.clean				:= _cmifBRItem.clean;
	self.commodity 			:= _cmifBRItem.commodity;
	self.ediCommodityDescription := _cmifBRItem.ediCommodityDescription;	//cnwrs1 CCMS 1882 03 June 2010
	self.description		:= _cmifBRItem.description;
	self.inspected			:= _cmifBRItem.inspected;
	self.isoType			:= _cmifBRItem.isoType;
	
	self.cubicMetres		:= _cmifBRItem.cubicMetres;
	self.quantity			:= _cmifBRItem.quantity;
	self.remarks			:= _cmifBRItem.remarks;
	self.weight				:= _cmifBRItem.weight;
	
	self.height				:= _cmifBRItem.height;
	self.length				:= _cmifBRItem.length;
	self.width				:= _cmifBRItem.width;
	self.heightString		:= _cmifBRItem.heightString;
	self.lengthString		:= _cmifBRItem.lengthString;
	self.widthString		:= _cmifBRItem.widthString;
	self.typeString			:= _cmifBRItem.typeString;
	self.density			:= _cmifBRItem.density;
	self.volume				:= _cmifBRItem.volume;
	self.productQuantity	:= _cmifBRItem.productQuantity;
	self.shippingMarks := _cmifBRItem.shippingMarks;// Nelson 1637, Anca 09/05/08 
	if not self.isCommodityChanged then  	// don't change once set
		self.isCommodityChanged := _cmifBRItem.blnCommodityChanged;
	endif;
	if not self.isDataChanged then			// don't change once set
		self.isDataChanged := _cmifBRItem.blnChangedByUser;
	endif;
	// set the references with inverses that will add to the appropriate collections
	self.myProduct			:= _cmifBRItem.myProduct;
	self.rawEDIData := _cmifBRItem.rawEDIData;
	myBookingReference := pBookingRef;
	
	self.setHazards(_cmifBRItem.allTIHazards);			//CCMS 1203		//Par 18318
	
	self.generatorType 	:= _cmifBRItem.generatorType; //cnwrd1 par 18222 24.2.09
	self.trailerType := _cmifBRItem.trailerType;
	
	// MES1008 JMH 28/9/09
	self.density 					:= _cmifBRItem.density;
	self.markNumber 				:= _cmifBRItem.markNumber;
	self.isoTypeGroup 				:= _cmifBRItem.isoTypeGroup;
	self.productVolume 				:= _cmifBRItem.productVolume;
	self.productWeight 				:= _cmifBRItem.productWeight;
	
	// cnwrl1 16/04/2010 PAR 23624 - start of coding
	self.allLinkedExportBookings.clear();
	if self.isStockBooking then            // PAR 26622
		_cmifBRItem.allLinkedExportBookingsRefs.copy( self.allLinkedExportBookings );
	endif;
	// cnwrl1 16/04/2010 PAR 23624 - end of coding
	self.sequence := _cmifBRItem.sequence; //cnwrs1 CCMS 1882 25 May 2010
	
	self.purchaseOrder				:= _cmifBRItem.purchaseOrder;				// PAR #33193
	self.serviceOrder				:= _cmifBRItem.serviceOrder;				// PAR #33193
	
	//19 Sep 2016	NDL	TFS 2650 / 2001
	if not _cmifBRItem.allStopTablesToAdd.isEmpty
	or not _cmifBRItem.allTaskDescsToAdd.isEmpty
	then
		if self.myBookingRefItemActions = null then
			create docActions;
			docActions.setMyBookingRefItem(self);
		endif;
		self.myBookingRefItemActions.setStopTablesToAdd( _cmifBRItem.allStopTablesToAdd );
		self.myBookingRefItemActions.setTaskDescsToAdd( _cmifBRItem.allTaskDescsToAdd, _cmifBRItem.allTaskRemarkToAdd );	//05 Oct 2016	NDL	TFS 2001 / 2792
	endif;
	
	self.mySpecialStow := _cmifBRItem.mySpecialStow;	//08 Jun 2017	NDL	TFS 4454
	self.hsCode := _cmifBRItem.hsCode; //jlika1 TFS 55586
	
	self.matchMode := _cmifBRItem.matchMode;			//navra1 - CR 63764/Task 64227 - 22nd May 2024
	
end;
</source>
        <Parameter name="_cmifBRItem" type="CMIF_BookingRefItem"/>
        <Parameter name="pBookingRef" type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="setHSCode" id="5b148d36-1d25-4b76-8651-c0a4382af484">
        <updating/>
        <source>setHSCode(_hsCode: String) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 12 December 2022
TFS#		: 55590
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	self.hsCode := _hsCode;
end;</source>
