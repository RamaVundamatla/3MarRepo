    <JadeMethod name="translateToDisplayValue" id="42b5a0de-ec59-4c93-9845-3345eb09f47e">
        <source>translateToDisplayValue(_value: Any): String;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
========================================================
10 February 2010		cnwcs5	CCMS 1925/PAR 22295 Release Summaries (Initial creation)
*/

vars

begin
	if _value &lt;&gt; null then
		return _value.CM_OperatorGroup.code;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="4af83089-1586-421c-a171-b291002cebb3">
        <source>translateToSearchValue(_value: Any): Any;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
========================================================
10 February 2010		cnwcs5	CCMS 1925/PAR 22295 Release Summaries (Initial creation)
*/

vars
	returnVal		: CM_OperatorGroup;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			
			return _value;
		endif;

		if _value.isKindOf(CM_OperatorGroup) then
			returnVal := _value.CM_OperatorGroup;
		endif;
	endif;
	
	return returnVal;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
