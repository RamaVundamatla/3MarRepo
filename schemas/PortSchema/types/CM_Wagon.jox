epilog

end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="autoAllocationMatch" id="534491b7-337e-4dca-be4f-f3f2931a5de2">
        <source>autoAllocationMatch(_ti : CM_TrackedItem; _noMatchReason : String output; _yaAgent : CM_YAAutoplanAgent input; _cmifAutoPlan : CMIF_YAAutoPlan) : Boolean;
/*
----------   ----------  --------------------------------------------------
Created:	20 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
11 June 2013	NDL rework for Auto planning Par 31692
*/
vars
	alloc				: CM_RailAllocation;
	criteria			: CM_YACriteria;
	destPort			: CM_Port;
	releaseReq			: CM_BulkRelease;
begin
	alloc := self.getRailAllocation;

	if alloc = null then
		_noMatchReason := app.getErrorString(No_Associated_allocation);
		return false; // PAR 19710 AKB changed to make more like Yard. If not Allocation do not use for auto planning.
	endif;
	
	if ( not self.confirmed) then
		_noMatchReason := app.getErrorString( Wagon_not_confirmed );
		return false;
	endif;
	
	if ( self.confirmedOutwards) then
		_noMatchReason := app.getErrorString( Wagon_confirmed_out );
		return false;
	endif;
	
	foreach criteria in alloc.allCriteria do
		if criteria.myYACriteriaType.type = YACriteriaType_ImexStatus then // PAR 22051 ignore imex as this is used as a default on rail allocs and is always IMPORT
			continue;
		endif;
		
		if not criteria.isCMIFAutoPlanDataMatch(_cmifAutoPlan) then
			_noMatchReason := app.getErrorString3(Item_does_match_with_criter, _ti.id, criteria.getDescription, null); //+ cnwmd1, CCMS 1067, Par 19710
			return false;
		endif;
	
	endforeach;
	
	if _yaAgent &lt;&gt; null then
		_yaAgent.addLogEntry(AP_Log_YA_Match,app.getErrorString1(Item_matched_criteria, self.id), false);
	endif;
	
	return true;
	
epilog

	if _yaAgent &lt;&gt; null and _noMatchReason &lt;&gt; null then
		_yaAgent.addLogEntry(AP_Log_YA_No_Match, app.getErrorString2(WagonAutoPlanError, self.id, _noMatchReason), false);
	endif;
	
end;


</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_noMatchReason" type="String" usage="output"/>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canHandleISOContainer" id="641a249f-5ab9-4fe7-84fc-e64149ddf64c">
        <source>canHandleISOContainer():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Mar 2024	navma1	Bug 62975: EUP - 1308 Error During EUP performance test

*/

vars
	wagonClass : CM_WagonClass;
begin
	
	wagonClass := self.myWagonClass;
	
	if wagonClass = null then
		return false;
	endif;
	
	if wagonClass.isFlatcar or wagonClass.isWellcar then
		return true;
	endif;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
