    <JadeMethod name="translateForm" id="e080bf8e-9297-45b2-96da-7ca426c6fdd1">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017457, locale);
	btnCreateData.translateBubbleHelp(Xlat_0016177, locale);
	btnCreateData.translateCaption(Xlat_0016178, locale);
	btnDailyCancel.translateCaption(Xlat_0018827, locale);
	btnDailyCreate.translateCaption(Xlat_0018828, locale);
	btnDefault.translateBubbleHelp(Xlat_0013507, locale);
	btnDefault.translateCaption(Xlat_0013508, locale);
	btnDeleteDef.translateBubbleHelp(Xlat_0013509, locale);
	btnDeleteDef.translateCaption(Xlat_0013510, locale);
	btnEditDef.translateBubbleHelp(Xlat_0013511, locale);
	btnEditDef.translateCaption(Xlat_0013512, locale);
	btnNewCancel.translateCaption(Xlat_0016179, locale);
	btnNewCreate.translateCaption(Xlat_0016180, locale);
	btnNewData.translateBubbleHelp(Xlat_0018829, locale);
	btnNewData.translateCaption(Xlat_0018830, locale);
	btnNewDef.translateBubbleHelp(Xlat_0013513, locale);
	btnNewDef.translateCaption(Xlat_0013514, locale);
	lblDailyFrom.translateCaption(Xlat_0018831, locale);
	lblDailyTo.translateCaption(Xlat_0018832, locale);
	lblForTerm.translateCaption(Xlat_0013515, locale);
	lblSelector.translateCaption(Xlat_0016181, locale);
	lblShowResults.translateCaption(Xlat_0013516, locale);
	lblSnapDate.translateCaption(Xlat_0016182, locale);
	lblSnapTime.translateCaption(Xlat_0016183, locale);
	lblTo.translateCaption(Xlat_0013517, locale);
	mnuCharge.translateCaption(Xlat_0016184, locale);
	mnuCloneItem.translateCaption(Xlat_0013518, locale);
	mnuDelSnapShot.translateCaption(Xlat_0013519, locale);
	mnuInvoiceLines.translateCaption(Xlat_0016185, locale);
	mnuLocalContext.translateCaption(Xlat_0013520, locale);
	mnuResync.translateCaption(Xlat_0016186, locale);
	mnuShowBar2.translateCaption(Xlat_0013521, locale);
	mnuShowBar2Caption.translateCaption(Xlat_0013522, locale);
	mnuShowSnapShot.translateCaption(Xlat_0013523, locale);
	mnuSummarise2.translateCaption(Xlat_0013524, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotify" id="324d9a20-592c-41f3-9a05-98a94f36d11a">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 December 2009	cnwndl1	Initial creation	CCMS 1023

*/

vars

begin

	// if this event is not one of the required events just return.
	if eventType = EVENT_SummaryTable_Update or eventType = EVENT_SummaryTable_Delete then
		self.handleNotification(eventType, theObject, eventTag);
	endif;
	
	
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
