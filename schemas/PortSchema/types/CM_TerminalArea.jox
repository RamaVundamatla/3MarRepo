vars

begin
	//return 	_theTI.id &amp; ". Area " &amp; self.id &amp; " has no access front or back."; //- cnwmd1, Par 20524
	return 	app.getErrorString2(Area_access_front_back,_theTI.id, self.id);

end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <ReturnType type="String"/>
    </JadeMethod>
