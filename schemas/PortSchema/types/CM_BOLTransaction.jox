    <JadeMethod name="getQuantityForCalcType" id="42789d61-333f-421a-96b2-150d891aa44d">
        <source>getQuantityForCalcType( _calcType : CM_CalculationType ):Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

	value : Real;
	bol : CM_BOL;

begin

	if _calcType &lt;&gt; null then
		
		if _calcType.calculationType = INV_CALC_TYPE_BOL_VALUEOF1 then
			value := 1;
			
		else
			bol := self.myBOL;
			if bol &lt;&gt; null then
				if _calcType.calculationType = INV_CALC_TYPE_BOL_NUMITEMS then
						value := bol.getBOLQuantityForInvoice();
						
				elseif _calcType.calculationType = INV_CALC_TYPE_BOL_VOLUME then
					value := bol.getBOLVolumeForInvoice();
					
				elseif _calcType.calculationType = INV_CALC_TYPE_BOL_WEIGHT then
					value := bol.getBOLWeightForInvoice();
					
				endif;
				
			endif;
		
		endif;
		
	endif;
	
	return value;

epilog

end;</source>
        <Parameter name="_calcType" type="CM_CalculationType"/>
        <ReturnType type="Real"/>
    </JadeMethod>
