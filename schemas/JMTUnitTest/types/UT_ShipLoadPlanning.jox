    <JadeMethod name="checkSlotRequest" id="f8562acb-6916-4e5f-9ff7-f1f21ea1b77c">
        <source>checkSlotRequest(_slotRequest : CM_SlotRequest; _expectedStaddleStack : CM_StraddleStack; _expectedRow, _expectedCol,_expectedHeight : Integer);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 December 2008	cnwer1	Initial creation

*/

vars
	futureMovePlanned : CM_FutureMovePlanned;
	gridControler : CM_GridController;
	trackedItem 	: CM_TrackedItem;
begin
	futureMovePlanned:=_slotRequest.getVoyageLoadController.allPlannedFutureMoves.first.CM_FutureMovePlanned;
	assertTrueMsg(futureMovePlanned&lt;&gt;null,_slotRequest.id &amp; " has null future planned move");
	
	
	gridControler:=_expectedStaddleStack.allGridControllersByRowColumn[_expectedRow,_expectedCol];
	assertTrueMsg(gridControler &lt;&gt; null,_slotRequest.id &amp; " has no grid controller in position row = " &amp;_expectedRow.String &amp; " column " &amp;  _expectedCol.String &amp; " height " &amp; _expectedHeight.String);
	trackedItem:=futureMovePlanned.myTrackedItem;
	self.assertTIPlannedToLocation(trackedItem,_slotRequest,gridControler,_expectedHeight);

epilog

end;</source>
        <Parameter name="_slotRequest" type="CM_SlotRequest"/>
        <Parameter name="_expectedStaddleStack" type="CM_StraddleStack"/>
        <Parameter name="_expectedRow" type="Integer"/>
        <Parameter name="_expectedCol" type="Integer"/>
        <Parameter name="_expectedHeight" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="createContainers" id="832b72a4-4804-4605-890f-14a710a6fe3f">
        <updating/>
        <source>createContainers(_objectArray : ObjectArray) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 December 2008	cnwer1	Initial creation

*/

vars
	obj : Object;
	assoc : CM_AssociationDict;
	id,
	commodityCode,
	operatorName,
	isoCode: String;
	ti : CM_TrackedItem;
	gridArea : CM_GridArea;
	row,
	col : Integer;
begin

	foreach  obj in _objectArray do
		assoc := obj.CM_AssociationDict;
		assoc := assoc;
		id := assoc.str("ID");
		commodityCode := assoc.str("Commodity");
		operatorName := assoc.str(UTTI_Operator);
		isoCode := assoc.str("ISO");
		
		ti := self.addContainerOpts(id, isoCode,commodityCode , self.getOperator(operatorName));
		self.assertTrue(ti &lt;&gt; null);
		if assoc.includesKey("LOC_TA") then
			
				
			gridArea := assoc["LOC_TA".toUpper()].asObject.CM_GridArea;
			row := assoc.int("LOC_ROW");
			col := assoc.int("LOC_COL");
			// Move in a ti
			move(ti, gridArea.allGridControllersByRowColumn[		row, col]);
			assertLocationHasTI(gridArea.allGridControllersByRowColumn[		row, col], ti);
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_objectArray" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="createStraddleAreas" id="572491bd-7d66-4d50-a813-0669ad8dda6d">
        <source>createStraddleAreas();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 December 2008	cnwer1	Initial creation

*/

vars

	straddleStack : CM_StraddleStack;
	gridCol : CM_GridColumn;
	gridController : CM_GridController;
begin
	self.deleteStraddleAreas();
	
	straddleStack := addStraddleStack("UTSTRDA", 5, 5,3);	
	assertNotNullMsg(straddleStack, "straddleStack");
	
	//self.updateGridColumnCanTwinLift(straddleStack,1,true,false);
	//self.updateGridColumnCanTwinLift(straddleStack,2,false,true);
	
	
	straddleStack := addStraddleStack("UTSTRDB", 5, 5,3);
	assertNotNullMsg(straddleStack, "straddleStack");
	
	straddleStack := addStraddleStack("UTSTRDC", 5, 5,3);
	assertNotNullMsg(straddleStack, "straddleStack");

epilog

end;</source>
