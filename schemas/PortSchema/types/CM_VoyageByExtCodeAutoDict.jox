<CollClass name="CM_VoyageByExtCodeAutoDict" id="a5fe5d8e-5064-4280-8c68-13336056294b">
    <loadFactor>66</loadFactor>
    <memberType name="CM_Voyage"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="voyages"/>
    <MemberKey>
        <property name="CM_Voyage::voyageCodeExternalAuto"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_Voyage::vesselCode"/>
    </MemberKey>
    <JadeMethod name="getAllVoyages" id="7c9639ce-4c4e-4e14-8b63-9d169a7d87ec">
        <lockReceiver/>
        <source>getAllVoyages(_voyageCode : String; _voyageSet : CM_VoyageSet input) lockReceiver;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
16 September 2025	navlw1	JIRA-35882: Support External Voyage Code

*/

vars
	iter 		: Iterator;
	startVoy,
	voyage		: CM_Voyage;
begin
	iter := self.createIterator;
	startVoy := self.getAtKeyGeq(_voyageCode, null);

	if startVoy = null or startVoy.voyageCodeExternalAuto &lt;&gt; _voyageCode then
		return;
	endif;
	
	// forward loop
	iter.startAtObject(startVoy);
	while iter.next(voyage) do
		if voyage.voyageCodeExternalAuto &lt;&gt; _voyageCode then
			break;
		endif;
		_voyageSet.addNoDuplicates(voyage, false);
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_voyageSet" type="CM_VoyageSet" usage="input"/>
    </JadeMethod>
</CollClass>
