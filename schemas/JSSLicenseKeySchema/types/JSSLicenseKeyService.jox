    <JadeMethod name="create" id="4fd22659-15e2-4788-a6c2-80af242c333b">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		17 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theRoot		: JSSLKRoot;
	
begin
	theRoot	:=	JSSLKRoot.firstInstance();
	
	if theRoot = null then
		self.getTA().trxCreateRoot(theRoot);
	endif;
	
	self.myRoot					:=	theRoot;
	self.isDoTransactionState	:=	true;
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="3b1ad2af-132c-4eaf-bf8a-c68a1b875168">
        <updating/>
        <source>delete() updating;
// --------------------------------------------------------------------------------
// Created:		17 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myEditForm &lt;&gt; null then
		self.myEditForm.unloadForm();
	endif;
	
	if self.myMaintenanceForm &lt;&gt; null then
		self.myMaintenanceForm.unloadForm();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="deleteLicenseKey" id="3c6cc950-ac6f-4725-839a-162ca9381831">
        <source>deleteLicenseKey(pCustomerName:String; pProductCode:String):Boolean;
// --------------------------------------------------------------------------------
// Created:		14 January 2003 by cnwdad2
//
// Purpose:		Removes a previously registered license key
//
// Parameters:	pCustomerName - The name of the customer who's license to delete.
//				pProductCode - The unique code of the licensed product.
//
// Returns:		True if the license key was deleted, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theTA		: JSSLKTransactionAgent;
	
begin
	create theTA transient;
	theTA.setDoTransactionState(self.isDoTransactionState);
	theTA.trxDeleteCustomerLicense(self.getManager(), self.myRoot, pCustomerName, pProductCode);
	return true;
epilog
	delete theTA;
end;</source>
        <Parameter name="pCustomerName" type="String"/>
        <Parameter name="pProductCode" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="editLicenseKey" id="d2f61c80-245c-42a1-a441-8968e0b11800">
        <source>editLicenseKey(pCustomerName:String; pProductCode:String):String;
// --------------------------------------------------------------------------------
// Created:		17 January 2003 by cnwdad1
//
// Purpose:		Shows a form on which to enter a (new) license registration key.
//
// Parameters:	pCustomerName - The name of the customer.
//				pProductCode - The unique code of the licensed product.
//
// Returns:		The Product Code if the license key was accepted, otherwise null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theEditForm	: JSSLKEditLicenseForm;
	theLicense	: JSSLKCustomerLicense;
	
begin
	create theEditForm;
	
	if pCustomerName &lt;&gt; null and pProductCode &lt;&gt; null then
		theLicense	:=	self.myRoot.allCustomerLicenses[pCustomerName, pProductCode];
	endif;
	
	if theLicense = null then
		theEditForm.setCustomerLicense(null);
	else
		theEditForm.setCustomerLicense(theLicense);
	endif;
	
	theEditForm.setReferences(self.getManager, self, self.myRoot);
	
	if theEditForm.showModal() = 7 then
		theLicense	:=	theEditForm.aMyLicense;
		return theLicense.productCode;
	else
		return null;
	endif;
end;</source>
        <Parameter name="pCustomerName" type="String"/>
        <Parameter name="pProductCode" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="enterEWSLicenseKey" id="bcf68018-f243-4021-801b-4e8b1eda03c8">
        <source>enterEWSLicenseKey( pCustomerName:String; pLicenseKey:String ):String;
// ### JIRA 33541 12DEC2024 NAVAB1
vars

	theCustomerLicense	: JSSLKCustomerLicense;
	theTA				: JSSLKTransactionAgent;
	theKey				: JSSLKey;
	productCode			: String;
	rawDatesData		: String;
	
begin
	create theKey transient;
	theKey.setServiceManager(self.getManager());
	
	if theKey.decomposeEWS(pCustomerName, pLicenseKey) then
		productCode	:=	theKey.data4.String;
		rawDatesData := theKey.data5.String;
	else
		return null;
	endif;
	
	theCustomerLicense	:=	self.myRoot.allCustomerLicenses[pCustomerName, productCode];
	
	create theTA transient;

	theTA.setDoTransactionState(self.isDoTransactionState);
	
	if theCustomerLicense = null then
		theTA.trxCreateCustomerLicense(	self.getManager(),
										pCustomerName,
										productCode,
										pLicenseKey,
										self.myRoot,
										theCustomerLicense);
	else
		theTA.trxUpdateCustomerLicense(	theCustomerLicense,
										theCustomerLicense.edition,
										self.getManager(),
										pCustomerName,
										productCode,
										pLicenseKey,
										self.myRoot);
	endif;
	
	return productCode;
epilog
	delete theKey;
	delete theTA;
end;</source>
        <Parameter name="pCustomerName" type="String"/>
        <Parameter name="pLicenseKey" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="enterLicenseKey" id="1dc7d79b-8ad1-40ac-ab6e-85fde9dcde3d">
        <source>enterLicenseKey(pCustomerName:String; pLicenseKey:String):String;
// --------------------------------------------------------------------------------
// Created:		14 January 2003 by cnwdad2
//
// Purpose:		Accepts a (new) license key, causing the registration bit mask to
//				be rebuilt.  If the key is not valid (i.e. checksum fails) or if
//				any other errors are detected, an exception will be raised (of type
//				JSSException) - refer to the isJSSException method for determining
//				whether an exception was raised by a JSS peer schema.
//
// Parameters:	pCustomerName - The name of the customer to whom the product is
//					registered.
//				pLicenceKey - A string containing the customer's product key.
//
// Returns:		The Product Code if the license key was accepted, otherwise null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theCustomerLicense	: JSSLKCustomerLicense;
	theTA				: JSSLKTransactionAgent;
	theKey				: JSSLKey;
	productCode			: String;
	
begin
	create theKey transient;
	theKey.setServiceManager(self.getManager());
	
	if theKey.decompose(pCustomerName, pLicenseKey) then
		productCode	:=	theKey.data4.String;
	else
		return null;
	endif;
	
	theCustomerLicense	:=	self.myRoot.allCustomerLicenses[pCustomerName, productCode];
	
	create theTA transient;
	theTA.setDoTransactionState(self.isDoTransactionState);
	
	if theCustomerLicense = null then
		theTA.trxCreateCustomerLicense(	self.getManager(),
										pCustomerName,
										productCode,
										pLicenseKey,
										self.myRoot,
										theCustomerLicense);
	else
		theTA.trxUpdateCustomerLicense(	theCustomerLicense,
										theCustomerLicense.edition,
										self.getManager(),
										pCustomerName,
										productCode,
										pLicenseKey,
										self.myRoot);
	endif;
	
	return productCode;
epilog
	delete theKey;
	delete theTA;
end;</source>
        <Parameter name="pCustomerName" type="String"/>
        <Parameter name="pLicenseKey" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="enterSubsLicenseKey" id="ecee1ae6-d085-40b4-8cf1-cd74d2fd4a54">
        <source>enterSubsLicenseKey( pCustomerName:String; pLicenseKey:String ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2020	jlgndl1	Initial creation	TFS 49569

*/

vars

	theCustomerLicense	: JSSLKCustomerLicense;
	theTA				: JSSLKTransactionAgent;
	theKey				: JSSLKey;
	productCode			: String;
	rawDatesData		: String;
	
begin
	create theKey transient;
	theKey.setServiceManager(self.getManager());
	
	if theKey.decomposeSubs(pCustomerName, pLicenseKey) then
		productCode	:=	theKey.data4.String;
		rawDatesData := theKey.data5.String;
	else
		return null;
	endif;
	
	theCustomerLicense	:=	self.myRoot.allCustomerLicenses[pCustomerName, productCode];
	
	create theTA transient;

	theTA.setDoTransactionState(self.isDoTransactionState);
	
	if theCustomerLicense = null then
		theTA.trxCreateCustomerLicense(	self.getManager(),
										pCustomerName,
										productCode,
										pLicenseKey,
										self.myRoot,
										theCustomerLicense);
	else
		theTA.trxUpdateCustomerLicense(	theCustomerLicense,
										theCustomerLicense.edition,
										self.getManager(),
										pCustomerName,
										productCode,
										pLicenseKey,
										self.myRoot);
	endif;
	
	return productCode;
epilog
	delete theKey;
	delete theTA;
end;</source>
        <Parameter name="pCustomerName" type="String"/>
        <Parameter name="pLicenseKey" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExpiryDate" id="3d97ae7e-49e0-4267-a6ea-e0ec5e5dbf2a">
        <source>getExpiryDate(pCustomerName:String; pProductCode:String):Date;
// --------------------------------------------------------------------------------
// Created:		30 April 2007 by cnwdad1
//
// Purpose:		Returns the date on which the license expires.
//
// Parameters:	pCustomerName - The name of the customer.
//				pProductCode - The unique code of the licensed product.
//
// Returns:		The expiry date of the license, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theCustomerLicense	: JSSLKCustomerLicense;
	
begin
	theCustomerLicense	:=	self.myRoot.allCustomerLicenses[pCustomerName, pProductCode];
	
	if theCustomerLicense = null then
		self.raiseJSSException2(JSS_EX_00079, pCustomerName, pProductCode);
		return null;
	else
		return theCustomerLicense.expiryDate;
	endif;
end;</source>
        <Parameter name="pCustomerName" type="String"/>
        <Parameter name="pProductCode" type="String"/>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getVersion" id="5bd929d6-d3c6-4ac2-b207-d508953a7c8f">
        <source>getVersion(): String;
// --------------------------------------------------------------------------------
// Created:		14 January 2003 by cnwdad1
//
// Purpose:		Returns the version number of the peer schema.
//
// Parameters:	None
//
// Returns:		The peer schema version number, i.e. "1.0", as a string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.JSS_VERSION;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVersionFull" id="7f2dcda3-0e0a-4944-b984-e37ad20b06c5">
        <source>getVersionFull(): String;
// --------------------------------------------------------------------------------
// Created:		14 January 2003 by cnwdad1
//
// Purpose:		Returns the full version number of the peer schema.
//
// Parameters:	None
//
// Returns:		The peer schema's full version number, i.e. "1.0.000", as a string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (self.JSS_VERSION &amp; "." &amp; self.JSS_PATCH_LEVEL);
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isJSSException" id="04085bf7-cd26-4ffa-94d2-ec9378b26632">
        <source>isJSSException(pTheException: Exception): Boolean;
// --------------------------------------------------------------------------------
// Created:		14 January 2003 by cnwdad1
//
// Purpose:		This method is for application schemas exception handling.  In most
//				cases, peer schemas will raise exceptions of type JSSException to
//				report any detected errors.  For the application schema to easily
//				determine whether their exception is a peer schema one or not, they
//				can simply call this method, and then treat the error according to
//				the application's needs.
//
// Parameters:	pTheException - The exception object.
//
// Returns:		True if the exception is a JSS exception, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return JSSException.hasInstance(pTheException);
end;</source>
        <Parameter name="pTheException" type="Exception"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isLicenseRegistered" id="a24f452a-5173-4536-8725-717edd7dfc0f">
        <source>isLicenseRegistered(pCustomerName:String; pProductCode:String):Boolean;
// --------------------------------------------------------------------------------
// Created:		10 April 2003 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether a license has been
//				registered for the requested Customer/Product name.
//
// Parameters:	pCustomerName - The name of the customer.
//				pProductCode - The unique code of the licensed product.
//
// Returns:		True if the Customer/Product is registered and is current, otherwise
//				false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theCustomerLicense	: JSSLKCustomerLicense;
	
begin
	theCustomerLicense	:=	self.myRoot.allCustomerLicenses[pCustomerName, pProductCode];
	
	if theCustomerLicense = null then
		return false;
	else
		if theCustomerLicense.expiryDate &lt;= app.actualTimeServer.date() then
			self.raiseJSSException3(JSS_EX_00017, pCustomerName, pProductCode, theCustomerLicense.expiryDate.display());
			return false;
		else
			return true;
		endif;
	endif;
end;</source>
        <Parameter name="pCustomerName" type="String"/>
        <Parameter name="pProductCode" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isLicensed" id="9c7ceef5-b67a-4199-834f-caf23d41bb36">
        <source>isLicensed(pCustomerName:String; pProductCode:String; pComponentId:Integer):Boolean;
// --------------------------------------------------------------------------------
// Created:		14 January 2003 by cnwdad2
//
// Purpose:		Returns a boolean flag to indicate whether the specified product
//				component is registered for use.
//
// Parameters:	pCustomerName - The name of the customer.
//				pProductCode - The unique code of the licensed product.
//				pComponentId - The identifer of the product component.
//
// Returns:		True if the component is registered and is current, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 30/04/2007	cnwdad1		Added check for expiry date.
// --------------------------------------------------------------------------------
vars
	theCustomerLicense	: JSSLKCustomerLicense;
	
begin
	theCustomerLicense	:=	self.myRoot.allCustomerLicenses[pCustomerName, pProductCode];
	
	if theCustomerLicense = null then
		self.raiseJSSException2(JSS_EX_00079, pCustomerName, pProductCode);
		return false;
	else
		if theCustomerLicense.expiryDate &lt;= app.actualTimeServer.date() then
			self.raiseJSSException3(JSS_EX_00017, pCustomerName, pProductCode, theCustomerLicense.expiryDate.display());
			return false;
		else
			return theCustomerLicense.isBit(pComponentId);
		endif;
	endif;
end;</source>
        <Parameter name="pCustomerName" type="String"/>
        <Parameter name="pProductCode" type="String"/>
        <Parameter name="pComponentId" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isLicensedEWS" id="50151d10-0811-4a49-b188-206d3cc13106">
        <updating/>
        <source>isLicensedEWS(pCustomerName:String io; pProductCode:String io; pComponentId:Integer io; pExpDate : Date io) : Boolean updating;
// --------------------------------------------------------------------------------
// Created:		// ### JIRA 33545 16DEC2024 NAVAB1
//
// Purpose:		Returns a boolean flag to indicate whether the specified product
//				component is registered for use.
//
// Parameters:	pCustomerName - The name of the customer.
//				pProductCode - The unique code of the licensed product.
//				pComponentId - The identifer of the product component.
//
// Returns:		True if the component is registered and is current, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// --------------------------------------------------------------------------------
vars
	theCustomerLicense	: JSSLKCustomerLicense;
	lclDate : Date;
	size : Integer;
	candothis : Boolean;
begin

	theCustomerLicense	:=	self.myRoot.allCustomerLicenses[pCustomerName, pProductCode];
	
	if theCustomerLicense = null then
		self.raiseJSSException2(JSS_EX_00079, pCustomerName, pProductCode);
		return null;
	else
		if theCustomerLicense.expiryDate &lt;= app.actualTimeServer.date() then
			self.raiseJSSException3(JSS_EX_00017, pCustomerName, pProductCode, theCustomerLicense.expiryDate.display());
			return null;
		else
			size := theCustomerLicense.allExpiries.size;
			if pComponentId &lt;= size then
				lclDate := theCustomerLicense.allExpiries[pComponentId];
				if lclDate.isValid and lclDate &lt;= app.actualTimeServer.date() then
// ### JIRA 33957 12FEB2025 NAVAB1				self.raiseJSSException3(JSS_EX_00017, pCustomerName, pProductCode, theCustomerLicense.expiryDate.display());
					pExpDate := lclDate;// ### JIRA 33957 12FEB2025 NAVAB1
					return false;// ### JIRA 33957 12FEB2025 NAVAB1
			
				else
					candothis := theCustomerLicense.isBit(pComponentId);
					pExpDate := lclDate;
					
					return candothis;

				endif;
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="pCustomerName" type="String" usage="io"/>
        <Parameter name="pProductCode" type="String" usage="io"/>
        <Parameter name="pComponentId" type="Integer" usage="io"/>
        <Parameter name="pExpDate" type="Date" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSubsLicensed" id="bf9bdde3-d712-4b95-a813-24bc14ade6ae">
        <source>isSubsLicensed(pCustomerName:String io; pProductCode:String io; pComponentId:Integer io; pExpDate:Date io):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2020	jlgndl1	Initial creation	TFS 49569

*/

vars
	theCustomerLicense	: JSSLKCustomerLicense;
	
begin
	theCustomerLicense	:=	self.myRoot.allCustomerLicenses[pCustomerName, pProductCode];
	
	if theCustomerLicense = null then
		// 28/07/2020 jlgmd1 Don't raise an exception here, otherwise things break when we validate the standard JMT license (at least via the DevSchema::doInitializeApp/Batch apps)
		// as we haevn't got round to creating this one yet. (if at all)
		//self.raiseJSSException2(JSS_EX_00079, pCustomerName, pProductCode);
		return false;
	else
	
		//05 Aug 2020	NDL - Loading new license before permissions loaded.
		if pComponentId &gt; theCustomerLicense.allExpiries.size then
			return false;
		endif;
	
		pExpDate := theCustomerLicense.allExpiries[pComponentId];
		if theCustomerLicense.expiryDate &lt;= app.actualTimeServer.date() then
			self.raiseJSSException3(JSS_EX_00017, pCustomerName, pProductCode, theCustomerLicense.expiryDate.display());
			return false;
		elseif pExpDate.isValid and pExpDate &lt; app.actualTimeServer.date() then
			return false;
		else
			return theCustomerLicense.isBit(pComponentId);
		endif;
	endif;
end;</source>
        <Parameter name="pCustomerName" type="String" usage="io"/>
        <Parameter name="pProductCode" type="String" usage="io"/>
        <Parameter name="pComponentId" type="Integer" usage="io"/>
        <Parameter name="pExpDate" type="Date" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="listLicenses" id="f8c642ba-9aab-4bb4-af77-7c30a04efd90">
        <source>listLicenses();
/*
Purpose:	

Date		Who		Reason
06 January 2025	navab1	JIRA 33503
*/

vars
	theCustomerLicense	: JSSLKCustomerLicense;

begin
	foreach theCustomerLicense in self.myRoot.allCustomerLicenses discreteLock do
		write theCustomerLicense.productCode &amp; " " &amp; theCustomerLicense.customerName;
	
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setEditForm" id="fd41e5a5-be43-4cf1-b30a-5b499717f4c2">
        <updating/>
        <source>setEditForm(pTheEditForm:JSSLKEditLicenseForm) updating;
// --------------------------------------------------------------------------------
// Created:		17 January 2003 by cnwdad1
//
// Purpose:		Sets the current License Key edit form.  This form will be unloaded
//				if this interface is destroyed.
//
// Parameters:	pTheEditForm - A reference to the edit form.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
