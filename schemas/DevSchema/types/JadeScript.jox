    </JadeMethod>
    <JadeMethod name="dataDumpMatchJMTToSQL" id="dfe692db-bc9f-4703-909e-613151566e47">
        <source>dataDumpMatchJMTToSQL(_class : Class);
// ---------------------------------------------------------------------------
// Created:     cnwrs1 Mar 20006
// ---------------------------------------------------------------------------
constants
	DDxDefDescription = "Joe's Test SQL Native";
vars
	agent : CM_ExternalDatabaseAgent;
	objArray : ObjectArray;
	obj : Object;
	def : CM_DataDumpExtractDef;
	transExtractDef: CM_DataDumpTransExtractDef;
	created, updated : Boolean;
	sqlStatement: String;
	binObj : Binary[6];
	loadMode: Boolean;
	newObject : Boolean;
	extObj : ExternalObject;
	logPathName : String;
	file: File;
	count1, count2, count3 : Integer;
	now: TimeStamp;
begin
	app.initialize;
	app.setPropertyValue(PortSchema::name.name, "DataDumpMatchApp");
	create objArray transient;
	_class.allInstances(objArray, 0, true);
	if objArray.size = 0 then
		return;
	endif;
	create file transient;
	logPathName := app.getProfileStringAppServer(app.getIniFileNameAppServer(), 'JadeLog', 'LogDirectory', null);
	if logPathName = null then
		logPathName := app.getProfileStringAppServer(app.getIniFileNameAppServer(), 'CardLog', 'LogPath', null);
	endif;
	if logPathName = null then
		logPathName := "c:\temp";
	endif;
	file.fileName := logPathName.trimBlanks&amp;"\"&amp;_class.name&amp;'_'&amp;now.date.formatAsYYYYMMDD()&amp;now.time.format("hhmm")&amp;"_match.sql";
	if file.isAvailable then
		file.purge();
	endif;
	file.mode := File.Mode_Output;
	file.open();
		
	on Exception do self.dataDumpXDBExHandler(exception, agent);
	create agent transient;

	// Initialise the agent with the transExtractDef for this extractDef
	def := app.myRoot.allDataDumpExtractDefs[DDxDefDescription];
	if def = null then
		app.writeLog("Definition not found", 0);
		return;
	endif;
	create transExtractDef transient;
	transExtractDef.setForCreate(def, false);

	agent.initialise(EDB_PortDss, transExtractDef, null, false);
	app.writeLog("Data Dump Match started for "&amp;_class.name, 0);	
	foreach obj in objArray do
		count1 := count1 + 1;
		if (count2 + count3) &gt; 0 and 
		   (count2 + count3) mod 500 = 0 then
			app.writeLog("Data Dump Match contuning for "&amp;_class.name&amp;" after "&amp;count1.String, 0);	
		endif;
		if (count2 + count3) mod 500 = 0 then
			file.writeLine('GO');
		endif;
		extObj := agent.getExternalObj(obj);
		if extObj &lt;&gt; null then
			if obj.edition &lt;&gt; extObj.getPropertyValue(EDB_Bank::edb_Edition.name).Integer then
				count2 := count2 + 1;
				newObject := false;
				if not agent.setExternalAttributes(obj, extObj) then
					app.raiseCMException(DataDumpFeatureErrorsFound, null, null);
					continue;
				else
					file.writeLine(agent.createSQLStatement(extObj, newObject));
				endif;
			endif;
		else
			count3 := count3 + 1;
			binObj := global.dataDumpFormatBin(obj);
			extObj := agent.createObject();
			newObject := true;
			if not agent.setExternalAttributes(obj, extObj) then
				app.raiseCMException(DataDumpFeatureErrorsFound, null, null);
				continue;
			else
				file.writeLine(agent.createSQLStatement(extObj, newObject));
			endif;
		endif;
	endforeach;
	app.writeLog("Data Dump SQL Match finished for "&amp;_class.name&amp;' total='&amp;count1.String&amp;' adds='&amp;count3.String&amp;' updates='&amp;count2.String, 0);	
epilog
	if agent &lt;&gt; null then
		agent.finalise;
	endif;
	delete agent;
	delete transExtractDef;
	if file &lt;&gt; null then
		file.close;
		delete file;
	endif;
end;</source>
        <Parameter name="_class" type="Class"/>
    </JadeMethod>
    <JadeMethod name="dataDumpMissingFeatures" id="dddb847a-1843-4441-b853-e4e59817f67d">
        <source>dataDumpMissingFeatures();
//
//25 Jun 2014	cnwrs1	Par 34470 New SQL native classes are missing edition 
//
constants
	DDxDefDescription = "RS SQL";
vars
	ddeClass: CM_DataDumpExtractClass;
	ddClass : CM_DataDumpClass;
	ddExtractDef: CM_DataDumpExtractDef; 
	foundClass : Boolean;
	foundFeature : Boolean;
	finished: Boolean;
	feature : CM_DataDumpFeature;
	featureE : CM_DataDumpFeature;
begin
	app.initialize;
	finished := false;
	if not self.tryLock(app.myRoot.allDataDumpClasses, Reserve_Lock, Session_Duration, LockTimeout_Immediate) then
		app.writeLog("Could not get Data Dump Extract lock. Data Extract must already be running retry later.",0);
		return;
	endif;	
	ddExtractDef := app.myRoot.allDataDumpExtractDefs[DDxDefDescription];
	if ddExtractDef = null then
		app.writeLog("Could not find the Data Dump Extract details.",0);
		return;
	endif;
	foreach ddClass in app.myRoot.allDataDumpClasses do
		foundClass := false;
		foreach ddeClass in ddExtractDef.allDataDumpExtractClasses do
			if ddeClass.myDataDumpClass.myClass = ddClass.myClass then
				foundClass := true;
				break;
			endif;
		endforeach;
		if not foundClass then
			if ddExtractDef.extractFormat = 1 and not ddClass.isAvailableForDSS then
			else
				write ddClass.myClass.name&amp;" not used";
			endif;
		else
			foreach feature in ddClass.allDataDumpFeatures do
				foundFeature := false;
				foreach featureE in ddeClass.allDataDumpFeatures do
					if feature = featureE then
						foundFeature := true;
						break;
					endif;
				endforeach;
				if not foundFeature and 
				   feature.featureName &lt;&gt; "oidBin" and
				   ddeClass.allDataDumpFeatures.size &lt; 126 then
					if ddExtractDef.extractFormat = 1 and not ddClass.isAvailableForDSS and not feature.isDSS then
					else
						write ddClass.myClass.name&amp;" feature "&amp;feature.featureName&amp;" not used "&amp;ddeClass.allDataDumpFeatures.size.String;
					endif;
				endif;
			endforeach;
		endif;
	endforeach;
end;
</source>
    </JadeMethod>
    <JadeMethod name="dataDumpPar27010" id="14b8a900-e19b-4fab-bda3-b0b5e901ea90">
        <source>dataDumpPar27010();

vars
	objArray : ObjectArray;
	tiArray : ObjectArray;
	obj : Object;
	count : Integer;
	abort : Boolean;
	dataDumpRec : CM_DataDumpPar27010;
	str : String;
	cls : Class;
	transaction : CM_TITransaction;
	startDT : TimeStamp;
	iter : Iterator;
	terminal : CM_Terminal;
	ti : CM_TrackedItem;
	firstTime : Boolean;
begin
	app.initialize;
	terminal := CM_Terminal.firstInstance;
	startDT := PortSchema_7_9_1.firstInstance.myHistoryMaster.processStartTime;
	create objArray transient;
	dataDumpRec := CM_DataDumpPar27010.firstInstance;
	if dataDumpRec = null then
		beginTransaction;
		create dataDumpRec;
		dataDumpRec.classes.add(CM_Carrier); 
		dataDumpRec.classes.add(CM_Charge); 
		dataDumpRec.classes.add(CM_Commodity); 
		dataDumpRec.classes.add(CM_ConsigneeConsignor); 
		dataDumpRec.classes.add(CM_Debtor); 
		dataDumpRec.classes.add(CM_DebtorGroup); 
		dataDumpRec.classes.add(CM_ISOType); 
		dataDumpRec.classes.add(CM_Invoice); 
		dataDumpRec.classes.add(CM_InvoiceDesc); 
		dataDumpRec.classes.add(CM_InvoiceLineDesc); 
		dataDumpRec.classes.add(CM_Operator); 
		dataDumpRec.classes.add(CM_Port); 
		dataDumpRec.classes.add(CM_Service); 
		dataDumpRec.classes.add(CM_ServiceGroup); 
		dataDumpRec.classes.add(CM_SnapShot); 
		dataDumpRec.classes.add(CM_SubTerminal); 
		dataDumpRec.classes.add(CM_ToDoTaskDesc); 
		dataDumpRec.classes.add(CM_Trade); 
		dataDumpRec.classes.add(CM_User); 
		dataDumpRec.classes.add(CM_Vessel); 
		dataDumpRec.classes.add(CM_Voyage); 
		dataDumpRec.classes.add(HMS_Berth); 
		dataDumpRec.classes.add(HMS_BerthPreference); 
		dataDumpRec.classes.add(HMS_HarbourRegion); 
		dataDumpRec.classes.add(HMS_ResourceForObject); 
		dataDumpRec.classes.add(HMS_VoyageData); 
		dataDumpRec.classes.add(HMS_VoyageMovement); 
		dataDumpRec.classes.add(HMS_Wharf); 
//		CM_TITransaction
//		CM_TempReading
//		CM_TrackedItem
		commitTransaction;
	endif;

	firstTime := true;
	foreach cls in dataDumpRec.classes do
		if firstTime and
		   dataDumpRec.currentClass &lt;&gt; null then
			if cls &lt;&gt; dataDumpRec.currentClass then
				continue;
			endif;
			firstTime := false;
			beginTransaction;
		endif;
		objArray.clear;
		count := 0;
		cls.allInstances(objArray,0,true);
		dataDumpRec.currentClass := cls;
		foreach obj in objArray do
			count := count + 1;
			if count &lt; dataDumpRec.position then
				continue;
			endif;
			obj.updateObjectEdition (obj);	// par 30292
			if count mod 10000 = 0 then
				dataDumpRec.position := count;
				commitTransaction;
				beginTransaction;
			endif;
		endforeach;
		commitTransaction;
		beginTransaction;
		dataDumpRec.position := 0;
	endforeach;
	commitTransaction;

	iter := terminal.allTITransactions.createIterator();
	if dataDumpRec.trDT &lt;&gt; null then
		startDT := dataDumpRec.trDT;
	endif;
	terminal.allTITransactions.startKeyGeq(startDT, 0, iter);
	count := 0;
	beginTransaction;
	while iter.next(transaction) do
		count := count + 1;
		transaction.updateObjectEdition (transaction);	// par 30292
		if count mod 10000 = 0 then
			dataDumpRec.trDT := transaction.dateTime;
			commitTransaction;
			beginTransaction;
		endif;
	endwhile;
	dataDumpRec.trDT.setDate((01/01/3010).Date);
	commitTransaction;
	
	count := 0;
	beginTransaction;
	foreach ti in dataDumpRec.tiArray do
		count := count + 1;
		ti.updateObjectEdition (ti);	// par 30292
		if count mod 10000 = 0 then
			commitTransaction;
			beginTransaction;
		endif;
	endforeach;
	dataDumpRec.tiArray.clear;
	commitTransaction;
epilog
	delete objArray;
	delete iter;
end;
</source>
    </JadeMethod>
    <JadeMethod name="dataDumpRemoveOidFeatures" id="84637219-660a-4f40-88f7-376321274a04">
        <source>dataDumpRemoveOidFeatures();
vars
	dataDumpExtractClass, proxyDataDumpExtractClass: CM_DataDumpExtractClass;
	feature: CM_DataDumpFeature;
	iterator: Iterator;	
	objArray: CM_DataDumpFeatureArray;
	object: Object;
begin
	app.initialize;
	create objArray transient;
	foreach dataDumpExtractClass in CM_DataDumpExtractClass.instances do
		iterator := dataDumpExtractClass.allDataDumpFeatures.createIterator();
		objArray.clear;
		while iterator.next(feature) do
			if feature.featureName = "oidHex" then
				app.writeLog("remove oidHex from "&amp;dataDumpExtractClass.className,0);
			elseif feature.featureName = "oidStr" then
				app.writeLog("remove oidStr from "&amp;dataDumpExtractClass.className,0);
			elseif feature.featureName = "myTerminal" and
			       (dataDumpExtractClass.className = "CM_TempReading" or
			        dataDumpExtractClass.className = "CM_TITransaction" or
			        dataDumpExtractClass.className = "CM_TrackedItem" or
			        dataDumpExtractClass.className = "CM_Voyage") then
				app.writeLog("remove myTerminal from "&amp;dataDumpExtractClass.className,0);
			else
				objArray.add(feature);
			endif;
		endwhile;
		if objArray.size &lt;&gt; dataDumpExtractClass.allDataDumpFeatures.size then
			beginTransaction;
			dataDumpExtractClass.allDataDumpFeatures.updateSameAsArray(objArray);
			commitTransaction;			
		endif;
	endforeach;
	delete objArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="dataDumpResetTs" id="c00b80df-d1d8-4dbd-98d2-406dc5547ae6">
        <source>dataDumpResetTs();
// ---------------------------------------------------------------------------
// Created:     29 May 2003 by cnwsb1
//
// Purpose:		Resets data dump class extract timestamp.
// ---------------------------------------------------------------------------
constants
	DDxDefDescription = "Joe's Test SQL Native";
vars
	ts : TimeStamp;
	def : CM_DataDumpExtractDef;
	defEdition : Integer;

begin
	app.initialize;
	
	ts.setDate("07.FEB.2004".Date);
	ts.setTime("12:00:00".Time);

	def := app.myRoot.allDataDumpExtractDefs[DDxDefDescription];
	defEdition := app.getLatestObjEdition(def);

	app.myTrxUA.trxUpdateDataDumpExtrDefTs(def, defEdition, ts, app.myPassport);

	if app.myPassport.hasErrors then
		app.writeStatement(app.myPassport.getErrorsAsString);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="dataDumpRunDSS" id="daac537c-17ce-4fe3-9497-e60129d093a2">
        <source>dataDumpRunDSS();

// ---------------------------------------------------------------------------
// Created:     03 June 2003 by cnwsb1
//
// Purpose:		Extracts all changes and deletes for the real sub-classes
//				of the given extract definition.  Uses the timestamp stored
//				on the extract definition classes to determine which objects
//				to dump (via the change tracker peer schema).
// ---------------------------------------------------------------------------
constants
	DDxDefDescription = "mjcsql";
vars
	agent : CM_DataDumpExtractionAgent;

begin
	app.initialize;
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	create agent transient;
	agent.initialise("", false, false);
	agent.doExtractDefinitonChanges(DDxDefDescription, false);
	agent.finalise;
	
epilog
	delete agent;
end;
</source>
    </JadeMethod>
    <JadeMethod name="dataDumpStartChangeTracker" id="46f3fc19-e8b2-4762-9ce6-632d8953d7af">
        <source>dataDumpStartChangeTracker();
//cnwrs1 mar 2006 script for testing changetracker
vars

