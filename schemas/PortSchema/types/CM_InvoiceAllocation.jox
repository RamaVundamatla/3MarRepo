    <JadeMethod name="getDisplayDescriptionString" id="7d84671e-39c9-4820-a6ac-53d2f522c37f">
        <source>getDisplayDescriptionString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2019	jlgndl1	Initial creation	TFS 43153

*/

vars

	yac : CM_YACriteria;
	descriptionStr : String;
	
begin

	foreach yac in self.allCriteria do
		if descriptionStr &lt;&gt; null then
			descriptionStr := descriptionStr &amp; ", ";
		endif;
		descriptionStr := descriptionStr &amp; yac.getRawDescription;
	endforeach;
	
	if descriptionStr = null then
		descriptionStr := "(" &amp; app.getErrorString(Default) &amp; ")";
	endif;
	
	return descriptionStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayForInUseValidation" id="7fdcbe4c-0494-42ed-9ed8-b4da62a515a3">
        <source>getDisplayForInUseValidation(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 November 2012	cnwndl1	Initial creation	Par 30767

*/

vars

	tempStr : String;

begin

	//23 Jul 2021	NDL	TFS 49952 - should not be used
//	if self.myTerminal &lt;&gt; null then
//		tempStr :=	app.getString( Terminal ) &amp; Space &amp; self.myTerminal.code &amp; ' / ';
//	endif;
	
	if self.myServiceBroker &lt;&gt; null then
		tempStr :=	app.getErrorString( Snapshot_definition ) &amp; Space &amp; self.myServiceBroker.getDescription &amp; ' / ';
	endif;

	
	tempStr :=	tempStr &amp; self.code &amp; " [" &amp; app.getErrorString(Snap_shot_allocation) &amp; "]";
	

epilog

	return tempStr;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceLineTypesString" id="a3155397-5a7d-40b8-bbbe-915b7227bc40">
        <source>getInvoiceLineTypesString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2019	jlgndl1	Initial creation	TFS 43153

*/

vars

	codeStr : String;
	qrm : CM_QuantityRangeMap;
	mapping : CM_TranMapInvoiceLineMapping;
	ild : CM_InvoiceLineDesc;
	ildSet : CM_InvoiceLineDescSet;

begin

	create ildSet transient;
	
	if self.myQuantityMap &lt;&gt; null then
		foreach qrm in self.myQuantityMap.allQuantityRanges do
			foreach mapping in qrm.allTMInvoiceLineMappings do
				ild := mapping.myTMInvoiceLineDesc;
				if ild &lt;&gt; null and not ildSet.includes( ild) then
					ildSet.add(ild);
					if codeStr &lt;&gt; null then
						codeStr := codeStr &amp; ", ";
					endif;
					codeStr := codeStr &amp; ild.narration;
				endif;
			endforeach;
		endforeach;
	endif;

epilog

	delete ildSet;
	return codeStr;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
