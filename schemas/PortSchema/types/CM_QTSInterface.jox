	mapper(cashRec,"PosRef")             &amp; Comma &amp;     //21 - Payment Interface Flexfield Segment 9
	mapper(cashRec,"CreatedBy")          &amp; Comma &amp;     //22 - Payment Interface Flexfield Segment 10
	mapper(cashRec,"MopCode")            &amp; Comma &amp;     //23 - Payment Interface Flexfield Segment 11
	mapper(cashRec,"MopDesc")            &amp; Comma &amp;     //24 - Payment Interface Flexfield Segment 12
	Space                  &amp; Comma &amp;                   //25 - Payment Interface Flexfield Segment 13
	Space                  &amp; Comma &amp;                   //26 - Payment Interface Flexfield Segment 14
	Space                  &amp; Comma &amp;                   //27 - Payment Interface Flexfield Segment 15
	Space                  &amp; Comma &amp;                   //28 - Payment Interface Flexfield Context
	Space                  ;		                   //29 - END
	
	_file.writeLine(str);
epilog

end;</source>
