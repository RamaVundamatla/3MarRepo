    <JadeMethod name="cmbDriverCode_displayEntry" id="1853a3cb-b9cb-41cd-9876-dbb7acaa8ebc">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbDriverCode_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
13 June 2024		jlizm1	Initial creation TFS 63908 Allow duplicate driver names

*/

vars
	driver : CM_DriverDetails;
	
begin
	driver := obj.CM_DriverDetails;
	
	if driver = null then
		return null;
	endif;
	
	if driver.myTerminal &lt;&gt; self.myTerminal then
		return null;
	endif;
	
	return driver.code;
	
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
