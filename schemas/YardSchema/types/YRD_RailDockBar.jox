    <JadeMethod name="setCreate" id="8e289371-48f1-4106-81d8-0dc11236604b">
        <updating/>
        <source>setCreate( _drawingFrame : CMUI_ScrollableDrawingFrame; _dragSelectFrame : CMUI_GridAreaDrawingFrame ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 Jun 2009	consw1	Initial creation

*/

vars

begin
	self.mySDF := _drawingFrame;
	self.myDragSelectFrame := _dragSelectFrame;
	
	self.myDragSelectFrame.parent := self.mySDF;
	self.mySDF.parent := self;

	self.mySDF.ignoreSkin := true;
	self.mySDF.myDrawingFrame.ignoreSkin := true;
	self.mySDF.myHLabels.ignoreSkin := true;
	self.mySDF.myVLabels.ignoreSkin := true;
	self.mySDF.myTopLeftFillerFrame.ignoreSkin := true;

epilog

end;</source>
        <Parameter name="_drawingFrame" type="CMUI_ScrollableDrawingFrame"/>
        <Parameter name="_dragSelectFrame" type="CMUI_GridAreaDrawingFrame"/>
    </JadeMethod>
    <JadeMethod name="setRailArea" id="cb6b2290-20f3-4e5b-a3e1-caa5d6bde4b2">
        <updating/>
        <source>setRailArea(_railArea : CM_Rail) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 Jun 2009	consw1	Initial creation

*/

vars

begin
	self.myRailArea := _railArea;
epilog

end;</source>
        <Parameter name="_railArea" type="CM_Rail"/>
    </JadeMethod>
    <JadeMethod name="setVisible" id="d8dfff55-30cd-49c6-850b-c5b1e42d9f6f">
        <updating/>
        <source>setVisible(_value : Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 Jun 2009	consw1	Initial creation

*/

vars

begin
	self.visible := _value;
	self.mySDF.visible := _value;

	self.myDragSelectFrame.visible := false;
	
epilog

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
