*/

vars

begin
	if _obj.CM_ConsigneeConsignor.isNotAvailableForEntry then			// PAR #37606
		return null;													// PAR #37606
	endif;																// PAR #37606
	
	return _obj.CM_ConsigneeConsignor.getYADisplay;
epilog

end;</source>
