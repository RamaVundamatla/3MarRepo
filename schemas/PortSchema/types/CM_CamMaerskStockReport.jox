    <JadeMethod name="buildFile" id="790ef0fb-8f64-4ddc-b5d9-1ebeedf9b460">
        <updating/>
        <source>buildFile(_camProtocol: CM_CamProtocol input; _camAgent : CM_CamControllerAgent input; _seqNumber : Integer; _unhSeqNumber : Integer io; _terminal : CM_Terminal) updating;
// Builds a file to be sent
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 21 May 2012	cnwrs1		Par 26914 - make cam task transient and remove camprotocol::camTask cleanup
// 27/06/2012	cnwcs5		par 29601 - change usage of _camTask
// 18 Jul 2012	cnwrs1		CCMS 1269 CAMS remove CM_CamTask
// 30 Jul 2012	cnwrs1		CCMS 1269 CAMS remove CM_CamTask
// 25 Mar 2013	cnwrs1		CCMS SFW 1294 Testing - not failing after exception in cam task history
// 25 Jun 2013	cnwrs1		Par 31047 - add Enviroment Terminal and Protocol to Cams Alerts
// 09 Jan 2020	jlgdap1		TFS 48016 SNO Deletio CODECO - change of signature for app.myTrxUA.trxSetupCamTaskHistory
vars
    camFile 			: CM_CamFile;
    camTaskHistory 		: CM_CamTaskHistory;
begin
	if _camProtocol = null then
		app.writeLog("Error: Cam protocol was expected but does not exist.  Message not created." ,LogINFO);
		return;
	endif;
	//-----------------------------
	// create a new camFile
    //-----------------------------
	camFile := self.createCamFile();
	
    if camFile = null then
		app.writeLog("Error: Cam file was expected but does not exist.  Message not created." ,LogINFO);
		return;
	endif;
	
    //-----------------------------
	// Get the camTask and dates
	//-----------------------------
	if _camAgent = null then
		app.writeLog("Error: Cam task was expected but does not exist.  Message not created." ,LogINFO);
		return;
	endif;
	
    //-----------------------------
	// process containers in yard
    //-----------------------------
	self.getContainersOnSite(camFile, _camProtocol);
    
    //-----------------------------
	// process MT containers released during the day/time period
    //-----------------------------
	self.getMTContainersReleased(camFile, _camProtocol, _camAgent);   
    
    //-----------------------------
	// process file
	//-----------------------------	
	//app.myTrxUA.trxSetupCamTaskHistory(_camProtocol, _camAgent, camFile, _camAgent.runDateTime, camTaskHistory, _unhSeqNumber, _seqNumber, _terminal, null, null);		// TFS 48016
	app.myTrxUA.trxSetupCamTaskHistory(_camProtocol, _camAgent, camFile, _camAgent.runDateTime, camTaskHistory, _unhSeqNumber, _seqNumber, _terminal, null, null, null);	// TFS 48016
	if (not app.myPassport.trxCompletedOK) then
		_camAgent.writeCrashLogAlertAndEmail(app.myPassport);
	endif;
epilog
    delete camFile;
end;</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol" usage="input"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_unhSeqNumber" type="Integer" usage="io"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="create" id="c63ee343-d059-4fc5-9ab1-7c0a94143da1">
        <updating/>
        <source>create() updating;
//----------------------------------------------------------------
//	Created:	03 March 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.name := "Maersk Stock Report";
	self.type := EDIFileTypeCams_MSKStockReport;

end;</source>
    </JadeMethod>
    <JadeMethod name="createCamFile" id="0c399d79-c693-4f6e-8684-98909008937d">
        <source>createCamFile(): CM_CamFile protected;

vars
	camFile 	: CM_CamFile;
	camVoyage	: CM_CamVoyage;
begin
	create camFile transient;
	create camVoyage transient;
	camVoyage.voyage := STOCK_REPORT_VOYAGE;
	camVoyage.camFile := camFile;
	
	return camFile;
end;</source>
        <access>protected</access>
        <ReturnType type="CM_CamFile"/>
    </JadeMethod>
    <JadeMethod name="getContainersOnSite" id="c6d4124f-a643-4917-b9fe-7b798b8adc35">
        <updating/>
        <source>getContainersOnSite(_camFile: CM_CamFile io; _camProtocol: CM_CamProtocol)updating, protected;

/*

Date		Who		Reason
22 Dec 2010	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars
	ti 		: CM_TrackedItem;
	iter	: Iterator;
	tiDict	: CM_TIByCargoTypeIdDict;
	operator: CM_Operator;
	terminal: CM_Terminal;
	opTerm	: CM_OperatorTerminal;
begin
	//-----------------------------
	// get messages for ti's
	//-----------------------------
	terminal :=  _camProtocol.terminal;
	operator := app.myRoot.allOperators[_camProtocol.operatorXlationCode.trimBlanks];
	
	if operator = null then
		tiDict := terminal.allOnsiteTIsByCargoTypeId;
	else
		opTerm	:= operator.allOperatorTerminals[terminal];
		if opTerm = null then
			tiDict := terminal.allOnsiteTIsByCargoTypeId;
		else
			tiDict := opTerm.allOnsiteTIsByCargoTypeId;
		endif;
	endif;
	
	iter := tiDict.createIterator;
	tiDict.startKeyGeq(TI_CargoType_Container, "", iter);
		
	while iter.next(ti) do
		if ti.cargoType &lt;&gt; TI_CargoType_Container then
			break;
		endif;
		if ti.operatorCode.trimBlanks =	_camProtocol.operatorXlationCode.trimBlanks then
			self.processTI(ti, _camProtocol, _camFile);	
		endif;
	endwhile;
    
epilog
	delete iter;			// PAR #26678
	
end;</source>
        <access>protected</access>
        <Parameter name="_camFile" type="CM_CamFile" usage="io"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
    </JadeMethod>
