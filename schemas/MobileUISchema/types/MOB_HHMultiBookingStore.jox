    <JadeMethod name="btnDocActions_click" id="6f56c1f8-b275-4607-967e-4ecaed3fe940">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDocActions_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 March 2017	cnwndl1	Initial creation	TFS 3299

*/

vars

	obj : Object;
	docAction : CM_DocumentActions;
	
	reserveDetail : CM_ReserveDetail;
	resDetailSet : CM_ReserveDetailSet;
	bookingItem : CM_BookingRefItem;
	bookingItemSet : CM_BookingRefItemSet;

begin

	create resDetailSet transient;
	create bookingItemSet transient;

	foreach obj in self.docActsToDisplay do
		docAction := obj.CM_DocumentActions;
		if docAction.isBookingItemAction then
			bookingItem := docAction.CM_BookingItemActions.myBookingItem;
			bookingItemSet.add( bookingItem );
		elseif docAction.isReserveDetailAction then
			reserveDetail := docAction.CM_ReserveDetailActions.myReserveDetail;
			resDetailSet.add( reserveDetail );
		endif;
	endforeach;

	self.myMobileGenericAgent.setAllReserveDetails( resDetailSet );
	self.myMobileGenericAgent.setAllBookingRefItems( bookingItemSet );
	self.gotoForm( MOB_HHDocumentActions, false );

epilog

	delete resDetailSet;
	delete bookingItemSet;

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
