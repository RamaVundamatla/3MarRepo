    <JadeMethod name="executePostMoveForToLocation" id="d6d9f981-f3db-4e7b-9fb9-8258cc2014fc">
        <updating/>
        <source>executePostMoveForToLocation(_moveController: CMIF_MoveController; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 07 January 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	voyStartDT	: TimeStamp;
	voyStatus	: Integer;
	needUpdate	: Boolean;
begin
	inheritMethod(_moveController, _passport);
	if _moveController.isUndoMove then
		return;
	endif;
	sharedLock(self.myVoyage);

	voyStartDT := self.myVoyage.loadStartDT;
	
	if (not voyStartDT.isValid) then
		needUpdate := true;
		voyStartDT := _moveController.effectiveTimeStamp;
	endif;
	
	voyStatus := self.myVoyage.status;
	if voyStatus = Voyage_Status_Pending then
		needUpdate := true;
		voyStatus := Voyage_Status_Loading;
	endif;

	if needUpdate then
		self.myVoyage.setLoadStartDTStatus(voyStartDT, voyStatus);
	endif;

end;</source>
        <Parameter name="_moveController" type="CMIF_MoveController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllOperators" id="7706a41b-0023-4f47-8fc3-08b999531247">
        <source>getAllOperators(_allOperators : CM_OperatorSet input);

vars

	iter	: Iterator;
	soh		: CM_SOHLocation;

begin

	iter := self.allProductLocations.createIterator;
	while iter.next(soh) do
		if soh.allTrackedItems.size &gt; 0 
		and soh.myOperator &lt;&gt; null
		and (not _allOperators.includes(soh.myOperator)) then
			_allOperators.add(soh.myOperator);
		endif;
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_allOperators" type="CM_OperatorSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="94f116a7-e625-40d0-9974-17e31e944e48">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------------------
//Created: 18 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	if _attrName = ETRow_Place then
		return app.vesselPlaceEnumToStr(self.place);
	elseif _attrName = ETRow_Pieces then
		return self.numTIs.String;
	elseif _attrName = ETRow_Lot then
		return self.myLogLot.lotNo;				
	endif;
	
	return inheritMethod(_attrName, _short);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFullId" id="621a308a-9c13-466c-a8b7-107bda0dc5d0">
        <source>getFullId(): String;
//--------------------------------------------------------------
//Created: 04 December 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	voyCode,
	lotNo,
	placel	: String;
begin
	if self.myVoyage &lt;&gt; null then
		voyCode := self.myVoyage.code;
	endif;
	if self.myLogLot &lt;&gt; null then
		lotNo := self.myLogLot.lotNo;
	endif;
	
	placel := app.vesselPlaceEnumToStr(self.place); 
	
	return voyCode &amp; '/' &amp; lotNo &amp; '/' &amp; self.hatch.String &amp; '/' &amp; placel;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getID" id="29cea325-8d15-426b-a313-07ce5fc9adab">
        <source>getID(): String;

vars
	lot : String;
begin
	if self.myLogLot &lt;&gt; null then
		lot := self.myLogLot.lotNo;
	endif;
	return lot &amp; '/' &amp; hatch.String &amp; '/' &amp; app.vesselPlaceEnumToStr(self.place);
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getName" id="de737e5b-3f63-43a0-83d4-ba1ef545f237">
        <source>getName(): String;
// ---------------------------------------------------------------------------
// Created:     18 September 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpLotNo	: String;

begin

	if self.myLogLot &lt;&gt; null then
		tmpLotNo	:= self.myLogLot.lotNo;
	else
		tmpLotNo	:= 'Unknown';
	endif;
	
	return inheritMethod() &amp; ' (' &amp; self.getID &amp; ')';

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
