    <JadeMethod name="canSplitTotalQuantity" id="493d13bf-fbaa-4472-8760-74be4b49e136">
        <source>canSplitTotalQuantity():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2013	cnwndl1	Initial creation

*/

vars

	cm_cargoType : CM_CargoType;

begin

	if self.cargoType &lt;&gt; 0 then
		cm_cargoType := app.myRoot.allCargoTypesById[self.cargoType];
	endif;
	
	if cm_cargoType &lt;&gt; null then
		if not cm_cargoType.allowDuplicates then
			return false;
		endif;
	endif;
	
	if self.totalQuantity &gt; 1 then
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cargoTypeAllowsDuplicates" id="2ca8f318-8c93-41f3-afef-3aa03c38627b">
        <source>cargoTypeAllowsDuplicates(): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 June 2013	cnwrd1	Initial creation

*/

vars

	ct : CM_CargoType;
begin
	ct :=  app.myRoot.allCargoTypesById[self.cargoType];
	
	if ct = null then
		return false;
	endif;
	
	return ct.allowDuplicates;

epilog

end;</source>
        <ReturnType type="Boolean"/>
