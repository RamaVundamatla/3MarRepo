<CollClass name="Array">
    <JadeMethod name="cnEcDoSort" id="f6580505-45b0-4ac3-bff1-20a1d9c7be66">
        <lockReceiver/>
        <updating/>
        <source>cnEcDoSort(pSorterObj:CnEcSorter) updating, protected, abstract;
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Purpose:		Using the CnEcSorter class, this method will sort the members of
//				the receiver array, purge the existing members, and then reload
//				the receiver with the sorted members.
// --------------------------------------------------------------------------------
// Parameters:	pSorterObj - A reference to the transient CnEcSorter object.
//
// Returns:		Nothing
// --------------------------------------------------------------------------------</source>
        <abstract/>
        <access>protected</access>
        <Parameter name="pSorterObj" type="CnEcSorter"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsPrimitiveArray" id="4051113e-34d5-472c-9bd3-03aa308da820">
        <source>cnEcIsPrimitiveArray():Boolean;
// --------------------------------------------------------------------------------
// Created:		03 February 2006 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is an array
//				of primitive values.
//
// Parameters:	None
//
// Returns:		True if the receiver is an array of primitive values, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcMoveElement" id="15095b24-f38b-4cf3-b27b-02bad6af99ba">
        <lockReceiver/>
        <updating/>
        <source>cnEcMoveElement(pElement:Any; pIsMoveUp:Boolean) lockReceiver, updating;
// --------------------------------------------------------------------------------
// Created:		14 March 2005 by cnwdad1
//
// Purpose:		Moves the specified array member up or down one (1) position in the
//				receiver.
//
// Parameters:	pElement - A reference to the array element to move.
//				pIsMoveUp - True if the member object is to be moved up one element,
//					otherwise the member will be moved down one element.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	elementIndex	: Integer;
	
begin
	if pElement = null then
		self.cnEcRaiseMoveError("The array element to move is null.");
	endif;
	
	if self.size() = 1 then
		return;
	endif;
	
	elementIndex	:=	self.indexOf(pElement);
	
	if elementIndex = 0 then
		self.cnEcRaiseMoveError("The array element to move (" &amp; pElement.String &amp; ") is not a member of the array.");
	else
		if pIsMoveUp then
			if elementIndex = 1 then
				return;
			endif;
			
			elementIndex	:=	elementIndex - 1;
		else
			if elementIndex = self.size() then
				return;
			endif;
			
			elementIndex	:=	elementIndex + 1;
		endif;
		
		self.remove(pElement);
		self.insert(elementIndex, pElement);
	endif;
end;</source>
        <Parameter name="pElement" type="Any"/>
        <Parameter name="pIsMoveUp" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcRaiseMoveError" id="dd0c6476-dbec-496f-9d36-73bf7474f959">
        <source>cnEcRaiseMoveError(pErrorMessage:String) protected;
// --------------------------------------------------------------------------------
// Created:		14 March 2005 by cnwdad1
//
// Purpose:		Raises an exception with the specified error message.
//
// Parameters:	pErrorMessage - An error message to raise the exception with.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 09/06/2008	cnwdad1		Changed to purge the call stack array before deleting it.
// --------------------------------------------------------------------------------
// adm 200509 Par 19207  change abstract exception class
vars
	callStackArray	: ProcessStackArray;
	methodCallObj	: MethodCallDesc;
	methodObj		: Method;
	classObj		: Class;
	errorMessage	: String;
	
begin
	create callStackArray transient;
	self.cnEcGetPreviousMethods(callStackArray);
	methodCallObj	:=	callStackArray[3];
	methodObj		:=	methodCallObj.method;
	classObj		:=	methodCallObj.getReceiver().class;
	errorMessage	:=	pErrorMessage &amp; CrLf &amp; "(" &amp; classObj.name &amp; "::" &amp; methodObj.name &amp; ")";
	
	CnEcBaseSchemaException.raise_(CNEC_X_13999, pErrorMessage);
epilog
	callStackArray.purge();
	delete callStackArray;
end;</source>
        <access>protected</access>
        <Parameter name="pErrorMessage" type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcRandomSelect" id="e46c2cd6-e3dd-4043-9867-eecbef9fbd47">
        <lockReceiver/>
        <updating/>
        <source>cnEcRandomSelect(pMaxSelect:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		22 March 2003 by cnwdad1
//
// Purpose:		Randomly selects a maximum number of candidate elements from receiver,
//				and discards the remaining elements.
//
// Parameters:	pMaxSelect - The maximum number of candidates to randomly select.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	entryName		: String;
	arraySize		: Integer;
	loopCount		: Integer;
	arrayPointer	: Integer;
	allCandidates	: Array;
	
begin
	if self.isEmpty() then
		return;
	endif;
	
	arraySize	:=	self.size();
	
	if pMaxSelect = arraySize then
		return;
	elseif pMaxSelect &gt; arraySize then
		CnEcBaseSchemaException.raise_(CNEC_X_72000, "The maximum number of selections (" &amp; pMaxSelect.String &amp; ") cannot exceed the number of candidates (" &amp; arraySize.String &amp; ").");
		return;
	endif;
	
	if pMaxSelect &gt; (arraySize div 2) then
		// The number of elements to select is more than half of the candidates,
		// so it'll be more efficient to randomly select elements to discard.
		
		loopCount	:=	arraySize - pMaxSelect;
		
		while loopCount &gt; 0 do
			arrayPointer	:=	app.random(self.size());
			
			if arrayPointer &gt; 0 then
				self.removeAt(arrayPointer);
				loopCount	:=	loopCount - 1;
			endif;
		endwhile;
	else
		// The number of elements to select is less than half of the candidates,
		// so it'll be more efficient to randomly select elements to keep.
		
		create allCandidates as self.class() transient;
		loopCount	:=	pMaxSelect;
		
		while loopCount &gt; 0 do
			arrayPointer	:=	app.random(self.size());
			
			if arrayPointer &gt; 0 then
				allCandidates.add(self[arrayPointer]);
				self.removeAt(arrayPointer);
				loopCount	:=	loopCount - 1;
			endif;
		endwhile;
		
		self.clear();
		allCandidates.copy(self);
	endif;
epilog
	delete allCandidates;
end;</source>
        <Parameter name="pMaxSelect" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcScramble" id="0c6139a3-1d05-4699-9af3-50c480dc67c1">
        <lockReceiver/>
        <updating/>
        <source>cnEcScramble() updating;
// --------------------------------------------------------------------------------
// Created:		23 March 2003 by cnwdad2
//
// Purpose:		Randomly scrambles the order of the receiver's elements.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allElements		: Array;
	loopCount		: Integer;
	arrayPointer	: Integer;
	
begin
	if self.isEmpty() then
		return;
	endif;
	
	create allElements as self.class() transient;
	loopCount	:=	self.size();
	
	while loopCount &gt; 0 do
		arrayPointer	:=	app.random(self.size());
		
		if arrayPointer &gt; 0 then
			allElements.add(self[arrayPointer]);
			self.removeAt(arrayPointer);
			loopCount	:=	loopCount - 1;
		endif;
	endwhile;
	
	allElements.copy(self);
epilog
	delete allElements;
end;</source>
    </JadeMethod>
    <JadeMethod name="cnEcSort" id="b6f97ef0-2c61-4d0f-a351-7a4f10547b29">
        <lockReceiver/>
        <updating/>
        <source>cnEcSort(pIsDescending:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Purpose:		Using the CnEcSorter class, this method will sort the members of
//				the receiver array, purge the existing members, and then reload
//				the receiver with the sorted members.
//
// Parameters:	pIsDescending - If True, the array will be sorted in descending
//					order, otherwise ascending order will be assumed.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	sorterObj	: CnEcSorter;
	
begin
	create sorterObj transient;
	sorterObj.setSortType(self.cnEcGetMemberType.name, pIsDescending);
	self.cnEcDoSort(sorterObj);
epilog
	delete sorterObj;
end;</source>
        <Parameter name="pIsDescending" type="Boolean"/>
    </JadeMethod>
</CollClass>
