    <JadeMethod name="assignValueSpecial" id="4a579add-8399-43e8-950c-f404f624a86f">
        <updating/>
        <source>assignValueSpecial(_propName: String; _processedValue: String; _xlationOperator: CM_Operator): Boolean updating;
//
//11 August 2017	jlgrs1	TFS 5457 Make JMTInternal XML work
//
vars

begin
	if _propName = ETRow_CargoIds or _propName = CM_EDICargoGroupAssign::allCargoIds.name then
		self.setCargoIdsFromString(_processedValue);
		return true;
	else
		return inheritMethod(_propName, _processedValue, _xlationOperator);
	endif;
epilog

end;</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_processedValue" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createProxy" id="eacdc808-729a-40e7-9a9a-b78f35306c47">
        <source>createProxy() : CM_MultiMoveGroup;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 September 2015	cnwndl1	Initial creation	Par 36906

*/

vars

	pxyMultiMoveGroup : CM_MultiMoveGroup;
	cargoTypeObj : CM_CargoType;

begin
	
	if self.cargoType &gt; 0 then
		cargoTypeObj := app.myRoot.getCargoTypeForID( self.cargoType );
	elseif self.cargoTypeDescr &lt;&gt; null then
		if self.cargoTypeDescr.isInteger then
			cargoTypeObj := app.myRoot.getCargoTypeForID( self.cargoTypeDescr.Integer );
		else
			cargoTypeObj := app.myRoot.getCargoTypeFromAbbrevOrDescr( self.cargoTypeDescr );
		endif;
	endif;
	
	create pxyMultiMoveGroup transient;
	pxyMultiMoveGroup.setProxy(	self.allCargoIds,	//_allCargoIds : StringArray input;
								cargoTypeObj,	//_myCargoType : CM_CargoType;
								self.targetLocation,	//_targetLocation : String;
								self.getMyTerminal	//_terminal : CM_Terminal
								);
	
	
	return pxyMultiMoveGroup;
	
epilog

end;</source>
        <ReturnType type="CM_MultiMoveGroup"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="f9e31bd5-c633-428c-8325-27bfae80b188">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 September 2015	cnwndl1	Initial creation	Par 36906

*/

vars

	cType : CM_CargoType;
	str : String;
	retStr : String;

begin

	if _attrName = ETRow_CargoIds then
		foreach str in self.allCargoIds do
			if retStr &lt;&gt; null then
				retStr := retStr &amp; ",";
			endif;
			retStr := retStr &amp; str;
		endforeach;
		return retStr;
		
	elseif _attrName = ETRow_CargoType then
		cType := app.myRoot.allCargoTypesById[self.cargoType];
		if cType = null then
			if self.cargoTypeDescr.isInteger then
				cType := app.myRoot.allCargoTypesById[self.cargoTypeDescr.Integer];
			else
				cType := app.myRoot.getCargoTypeFromAbbrevOrDescr( self.cargoTypeDescr );
			endif;
		endif;
		if cType &lt;&gt; null then
			return cType.abbreviation;
		else
			return null;
		endif;
		
	elseif _attrName = ETRow_CargoTypeDescr then
		if self.cargoType &lt;&gt; null then
			cType := app.myRoot.allCargoTypesById[self.cargoType];
			if cType &lt;&gt; null then
				return cType.description;
			endif;
		elseif self.cargoTypeDescr &lt;&gt; null then
			if self.cargoTypeDescr.isInteger then
				cType := app.myRoot.allCargoTypesById[self.cargoTypeDescr.Integer];
			else
				cType := app.myRoot.getCargoTypeFromAbbrevOrDescr( self.cargoTypeDescr );
			endif;
			if cType &lt;&gt; null then
				return cType.description;
			endif;
			return self.cargoTypeDescr;
		endif;
		return null;
		
	elseif _attrName = ETRow_LocationId then
		return self.targetLocation;
		
	elseif _attrName = ETRow_Action then
		return self.messageMode;
		
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyTIDisplayDefName" id="d38550bd-1254-4ada-a200-14f65c7aba95">
