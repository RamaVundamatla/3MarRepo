        <source>txtRequiredDate_doTabOrder(_startTab: Integer):Integer protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 September 2009	cnwrd1	Initial creation

*/

vars
tabOrder	: Integer;
begin

	tabOrder				:= _startTab;
	tabOrder 				:= tabOrder + 1;
	self.cmbShifts.tabIndex 	:= tabOrder;	
	tabOrder 				:= tabOrder + 1;
	self.dtRequired.tabIndex 	:= tabOrder;


	return tabOrder;
	
epilog

end;</source>
