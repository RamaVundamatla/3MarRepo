    <JadeMethod name="createCharge" id="1006fbb2-4bfc-4a09-b7b7-3ead06a71bdb">
        <updating/>
        <source>createCharge(_passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
////06 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
// ---------------------------------------------------------------------------
//Date			Who		Reason
//23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
//31 Jan 2025	navlw1 	JIRA-33865: MTN | Logging only displays that financials aren't enabled in logging level is TRACE
vars
	co	: CM_Bank;
	term: CM_Terminal;
	theDebtor : CM_DebtorNode;
	aMess : String;
	woDtl : CM_WorkOrderDtl;
begin
	if not global.isValidObject(self.myResourceUsed) then
		app.raiseUnexpectedProgramError(class. name, method.name, 'null resource used');
		return;
	endif;

	if self.myResourceUsed.myResource = null then
		app.raiseUnexpectedProgramError(class. name, method.name, 'null resource');
		return;
	endif;	
	
	term := self.myTerminal;
	if term = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'null self.myTerminal');
		return;
	endif;

	// Start navlw1 #JIRA-33865 31/01/2025
	if self.noCharge then
		app.invLog("Transaction is not chargeable",LogINFO.String); // navlw1 #JIRA-33692
		return;
	endif;
	if not term.getConfig(FinancialsEnabled).Boolean then
		app.invLog("Financials Are Not Enabled, No Charging Will Occur",LogTRACE.String); // navlw1 #JIRA-33692  // ### JIRA 35228 11JUL2025 NAVAB1
		return;
	endif;
	if not app.myRoot.canDo(Mod_Invoicing) then
		app.invLog("Invoice Module is not licensed",LogINFO.String); // navlw1 #JIRA-33692
		return;
	endif;
	// End navlw1 #JIRA-33865 31/01/2025
	

	theDebtor := self.myVoyage.myDebtor; // &lt;&lt;&lt; this is virtual
	
	//26 Nov 2018	NDL	TFS 41980
	if self.myResourceUsed &lt;&gt; null then
		if self.myResourceUsed.myDebtor &lt;&gt; null then
			theDebtor := self.myResourceUsed.myDebtor;
		else
			woDtl := self.myResourceUsed.myWorkOrderVoyageDtl;
			if woDtl &lt;&gt; null and woDtl.isWorkOrderMarineServiceDtl then
				if woDtl.CM_WodMarineServiceDetail.myDebtor &lt;&gt; null then
					theDebtor := woDtl.CM_WodMarineServiceDetail.myDebtor;
				endif;
			endif;
		endif;
	endif;
	
	if theDebtor = null then
		aMess := aMess &amp; " Voyage " &amp; self.myVoyage.code &amp; " has no operator or default line debtor, so has no DEBTOR. Cannot use TranMap.";
		return;
	endif;
	
	if theDebtor.isSuspended then //cnwrd1 par 23824 29.07.2010
		aMess := aMess &amp; " Debtor " &amp; theDebtor.name &amp; " is suspended.";
		return;
	endif;
	
	// Feb 2012 CCMS 1262 transaction enquiry add resync, refactor out to getBank
	co := self.getBank();

	if co = null then
		aMess := aMess &amp; " Voyage " &amp; self.myVoyage.code  &amp; "has no business unit. And there is no default company setup in terminal configuration. Cannot use TranMap.";
		return;
	endif;
	
	// lock the business unit for this transaction.
	if not tryLock(co, Share_Lock, Transaction_Duration, 5000) then
		// create an invoicing alert
	endif;

	self.myDebtor := theDebtor.CM_Debtor;
	co.createChargeVoyage(self, aMess);
	
	if aMess = null then
		//OK, this will allow the transaction details to appear in the HMS Audit form
		self.createPropertyChanges(null);
	endif;
	
epilog
	aMess := aMess.trimBlanks;
	if aMess &lt;&gt; null then
		self.raiseAlert("Resource " &amp; self.myResourceUsed.myResource.code &amp; " Invoicing Problem.",aMess,SEVERE_INFO);
		app.invLog("Resource " &amp; self.myResourceUsed.myResource.code &amp; " Invoicing Problem.", LogTRACE.String);
	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="createPropertyChanges" id="aa808f8c-3db1-4394-b143-dd3c35d374f9">
        <updating/>
        <source>createPropertyChanges(_cmifTrans: CMIF_HMS_TransactionController) updating, protected;
//--------------------------------------------------
// Created:	28 February 2005 By: cnwgd1
//--------------------------------------------------
vars
	propertyChange:	HMS_PropertyChange;
begin
	inheritMethod(_cmifTrans);
	create propertyChange;
   	propertyChange.set(self, self.myResourceUsed.description, "Not charged", "Charged");	   	
end;</source>
        <access>protected</access>
        <Parameter name="_cmifTrans" type="CMIF_HMS_TransactionController"/>
    </JadeMethod>
    <JadeMethod name="doCreateCharge" id="e2daba5d-6357-4b2d-a6fc-2a8cc12003ef">
        <updating/>
        <source>doCreateCharge(_passport: CM_Passport): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2021	navndl1	Initial creation	TFS 51443

*/

vars

begin
	
	self.createCharge( _passport );
	
	return not _passport.hasErrorsOrWarnings();

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResyncInvoiceLines" id="d1925707-34e8-42fb-9175-739720b6460d">
        <source>doResyncInvoiceLines(_sbController : CMIF_ServiceBroker input);
// Feb 2012 CCMS 1262 Transaction Enquiry, do voyage transaction resync
//Date			Who		Reason
//23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
//31 Jan 2025	navlw1 	JIRA-33865: MTN | Logging only displays that financials aren't enabled in logging level is TRACE
//25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
vars
	invLine 		 : CM_InvoiceLine;
	invLineTypes	 : CM_InvoiceLineDescArray;
	invLineDesc 	 : CM_InvoiceLineDesc;
	reject 			 : Boolean;
	bu 			     : CM_Bank;
	term 			 : CM_Terminal;
	canLogExtra		 : Boolean;	//28.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//28.02.2025 navah1	#34141
	bu 			:= self.getBank();
	
	create invLineTypes transient;
	
	// Start navlw1 #JIRA-33865 31/01/2025
	term := self.myTerminal;
	if term = null then
		app.raiseUnexpectedProgramError(class.name, method.name, CM_TITransaction::myTerminal.name &amp; " is null.");
		return;
	endif;
	if self.noCharge then
		if canLogExtra then	//28.02.2025 navah1	#34141
			app.invLog("Transaction is not chargeable",LogINFO.String); // navlw1 #JIRA-33692
		endif;
		return;
	endif;
	if not term.getConfig(FinancialsEnabled).Boolean then
		if canLogExtra then	//28.02.2025 navah1	#34141
			app.invLog("Financials Are Not Enabled, No Charging Will Occur",LogTRACE.String); // navlw1 #JIRA-33692  // ### JIRA 35228 11JUL2025 NAVAB1
		endif;
		return;
	endif;
	if not app.myRoot.canDo(Mod_Invoicing) then
		if canLogExtra then	//28.02.2025 navah1	#34141
			app.invLog("Invoice Module is not licensed",LogINFO.String); // navlw1 #JIRA-33692
		endif;
		return;
	endif;
	// End navlw1 #JIRA-33865 31/01/2025
	
	foreach invLine in self.allInvoiceLines discreteLock where invLine.status &lt;&gt; CM_InvoiceLine.STATUS_VOIDED do
		
		reject := true;
		
		// if the business unit has changed then void all the invoice lines
		// i.e. if the CM_Bank has changed we wont get in this bit...
		if bu = null or (_sbController.myBank = bu) then
			invLineTypes.clear;
			_sbController.allInvoiceLineTypes.copy(invLineTypes);
			foreach invLineDesc in invLineTypes discreteLock do
				if invLine.invoiceLineDesc = invLineDesc then
					// take out any invoiceline type that we have already charged correctly for
					_sbController.allInvoiceLineTypes.remove(invLineDesc);
					reject := false;
					invLine.setFromQuantityRangeMap(_sbController.getQRMFromLineType(invLineDesc));
					if canLogExtra then	//28.02.2025 navah1	#34141
						app.invLog(invLine.invoiceLineDesc.narration &amp; " - existing invoice line " &amp; invLine.sequenceNum.String &amp; " of invoice " &amp; invLine.invoice.sequenceNum.String, LogTRACE.String);
					endif;
				endif;
			endforeach;
		endif;
		
		if reject then
			// should not have been charged so void it
			if canLogExtra then	//28.02.2025 navah1	#34141
				app.invLog("Invoice line " &amp; invLine.sequenceNum.String &amp; " of invoice " &amp; invLine.invoice.sequenceNum.String &amp; " voided", LogTRACE.String);
			endif;
			invLine.changeStatus(CM_InvoiceLine.STATUS_VOIDED);
		endif;
	endforeach;

epilog 

	delete invLineTypes;
	
end;</source>
        <Parameter name="_sbController" type="CMIF_ServiceBroker" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getBank" id="d387199f-9241-490d-a1f1-d76f4c24a3e8">
        <source>getBank() : CM_Bank;
// CCMS 1262 get invoice number for transaction enquiry
vars
	co	: CM_Bank;
begin
	co := self.myVoyage.myDischargeCompany;
	if co = null then	
		//co := app.myPassport.myTerminal.getConfig(DefCompany).CM_Bank;
		co := app.myPassport.myTerminal.getDefaultCompanyBank();	//17 Apr 2012	NDL	Par 29393
	endif;
	return co;
end;
</source>
        <ReturnType type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="getBerthFromWOForPaymentType" id="07ec04ba-6901-4c3d-a87c-863dbfd5c9df">
        <source>getBerthFromWOForPaymentType():HMS_Berth;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 October 2018	jlgndl1	Initial creation	TFS 41281

*/

vars

	woDtl : CM_WorkOrderVoyageDtl;

begin

	if self.myResourceUsed &lt;&gt; null then
		woDtl := self.myResourceUsed.myWorkOrderVoyageDtl;
	endif;

	if woDtl &lt;&gt; null then
		return woDtl.getBerthForPaymentType();
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="getCalcTypeForTransaction" id="fa658463-529b-42e0-bbf3-27784176e8de">
        <source>getCalcTypeForTransaction(): CM_CalculationType;
/*
Purpose:			
Date		Who		Reason
30 December 2014	cnwab1	Initial creation
*/

vars
	invLineDesc:  CM_InvoiceLineDesc;
	aSBController : CMIF_ServiceBroker;
	idx : Integer;
	aServ : CM_Service;
	bu : CM_Bank;
	message : String;
begin
	bu := self.getBank();

	create aSBController transient;
	aSBController.myVTMISTransaction := self;
	aSBController.myBank := bu;
	bu.getInvoiceLineDescForVTMIS(aSBController, message);

	foreach invLineDesc in aSBController.allInvoiceLineTypes discreteLock do
		aServ := invLineDesc.services.first;
		if aServ &lt;&gt; null and aServ.myCalculationType &lt;&gt; null then
			return aServ.myCalculationType;
		endif;
	endforeach;
	return null;
	
epilog
	delete aSBController;
end;</source>
        <ReturnType type="CM_CalculationType"/>
    </JadeMethod>
    <JadeMethod name="getDebtorForSelector" id="1785c126-1082-4965-abde-0182f6a6ba2a">
        <source>getDebtorForSelector() : CM_Debtor;
// Feb 2012 CCMS 1262 Transaction Enquiry, HMS transactions in selector
vars
	debtor : CM_Debtor;
begin
	if self.myDebtor &lt;&gt; null then
		return self.myDebtor;
	endif;

	debtor := self.myVoyage.myDebtor.CM_Debtor;
	return debtor;
end;</source>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="2ca51657-0d18-4589-b2c8-5643f23733ba">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------
// Created:	28 February 2005 By: cnwgd1
//--------------------------------------------------
//20/09/2019 	JLGNS1	Bug 46339 JMT - Event transaction does not resync
//27 Jun 2025	navbs1	Story 35185: MTN - Refactor Required to Stop Using getDisplayStringForAttribute() for Known Attributes 
vars
	result	: String;
	invLine	: CM_InvoiceLine;
	invalid : Boolean;
begin
	if _attrName = ETRow_VesselName then
		if global.isValidObject(self.myVoyage) then
			return self.myVoyage.vesselName &amp; ' (' &amp; self.myVoyage.vesselCode &amp; ')';
		else
			return null;
		endif;
	elseif _attrName = ETRow_MyHMSVoyageData then
		if global.isValidObject(self.myVoyage) then
			return self.myVoyage.vesselName &amp; ' (' &amp; self.myVoyage.code &amp; ')';
		else
			return null;
		endif;
	elseif _attrName = ETRow_TypeString then // TFS 43694
		if self.myResourceUsed &lt;&gt; null then
			return self.typeString	 &amp; " - " &amp; self.myResourceUsed.description;// TFS 43694 making the HMS transaction list clearer
		endif;
	elseif _attrName = ETRow_OccursOnDT then
		if global.isValidObject(self.myVoyage) then
			return self.myVoyage.arrivedDT.shortCurrentLocaleFormat() &amp; ' Departing ' &amp; self.myVoyage.departedDT.shortCurrentLocaleFormat();
		else
			return null;
		endif;
	// Feb 2012 CCMS 1262 Transaction Enquiry
	elseif _attrName = ETRow_InvoiceLines then
		foreach invLine in self.allInvoiceLines discreteLock do
			if result = null then
				result := invLine.sequenceNum.String;
			else
				result := result &amp; ", " &amp; invLine.sequenceNum.String;
			endif;
		endforeach;
		return result;
	elseif _attrName = ETRow_Debtor then
		on Exception do app.handleDeletedObject(exception, self.myDebtor, invalid);	//Bug 46339
		if self.myDebtor &lt;&gt; null then
			result := self.myDebtor.name;
		endif;
		return result;
	elseif _attrName = ETRow_ResourcesUsed then
		return self.getResourcesUsedAsString();									//27.06.2025 navbs1 #35185
	elseif _attrName = ETRow_NoCharge then
		return app.getYesBlank(self.noCharge);
	elseif _attrName = ETRow_Charged  then
		return app.getYesNo(self.isCharged);
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceNumber" id="4c608e56-cfaa-4eca-bedd-7b5172175f46">
        <source>getInvoiceNumber() : String;
// CCMS 1262 get invoice number for transaction enquiry
vars
	invoiceLine		: CM_InvoiceLine;
begin
	invoiceLine := self.allInvoiceLines.first();
	if invoiceLine = null then
		return null;
	else
		return invoiceLine.invoice.sequenceNum.String;
	endif;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
