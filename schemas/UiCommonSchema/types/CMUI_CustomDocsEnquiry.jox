    <JadeMethod name="addRowToTable" id="a6916142-f10f-4055-b28d-e7d01aa04b6d">
        <source>addRowToTable(_custdoc : CM_CustomDocument);
/*
Purpose:			

Date		Who		Reason
08AUG2023	NAVAB1	 CR 56094 TASK 59618
05/09/2023	navkc1	CR 60156  Task 60157: UI - Cust Doc Type Colour
08/09/2023	navkc1	Defect 60450: Custom Document Enquiry - Colors are incorrectly updated
*/

vars
	theDataLine : String;
	docTypeColumn: Integer;
	custDocType	: CM_CustomDocumentType;
	row			: Integer;
begin
	theDataLine := _custdoc.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
	row := self.tblData.addItem(theDataLine); //08/09/2023	navkc1	Defect 60450
	self.tblData.accessRow(row).itemObject := _custdoc;
	self.doNotableAdd(_custdoc);
	
	//05/09/2023	navkc1	CR 60156  Task 60157
	docTypeColumn := self.tblData.getColumnByRowName(ETRow_CustDocType);
	custDocType := _custdoc.myCustomDocumentType;
	if docTypeColumn &gt; 0 and custDocType &lt;&gt; null then
		self.tblData.accessCell(row, docTypeColumn).backColor  := custDocType.colour;
		self.tblData.accessedCell.foreColor := custDocType.colour.getInverseColour();
	endif;
epilog

end;</source>
        <Parameter name="_custdoc" type="CM_CustomDocument"/>
    </JadeMethod>
    <JadeMethod name="btnAdd_click" id="72a97cd6-75cb-4722-88a7-71b2e0c80296">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAdd_click(btn: Button input) updating;
/*
Purpose:			

Date		Who		Reason
08AUG2023	NAVAB1	 CR59614 TASK 59619
*/

vars
	form : CMUI_CustomDocsMaint;
	
begin
	form := app.loadForm(CMUI_CustomDocsMaint, CMUI_Assistant, false, false,false, self.myTerminal,null).CMUI_CustomDocsMaint;
	if form &lt;&gt; null then
		form.updateMode	:= false;
		form.btnRemove.enabled := false;
		form.btnAddItems.enabled := false;
		form.btnUpdate.enabled := false;
		form.btnAttachment.enabled := false;
		form.btnApprove.enabled	:= false;
		form.btnAudits.enabled := false;
		form.btnAudit.enabled	:= false;    //11/07/2023 navrv30 #58391
		//form.txtFilterDocDetail.enabled := false; //25/06/2024	navkc1 CR 64823 Task 64824
		form.centreWindow();
		form.showModal;
	endif;
epilog

end;
</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
