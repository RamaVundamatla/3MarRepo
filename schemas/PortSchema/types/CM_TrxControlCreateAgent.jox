    <JadeMethod name="trxCreateInvoiceResourceChrges" id="54056aa2-169b-4a01-819b-a29144a03983">
        <updating/>
        <source>trxCreateInvoiceResourceChrges(_pxyResourcesUsed : HMS_ResourceUsedSet input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	pxyResUsed : HMS_ResourceUsed;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;

	foreach pxyResUsed in _pxyResourcesUsed do
		// Perform the operation
		app.myUtilityCA.utlCreateInvoiceResourceCharge(pxyResUsed,   _passport, false);
		if _passport.hasErrors() then
			return;
		endif;
	endforeach;
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
