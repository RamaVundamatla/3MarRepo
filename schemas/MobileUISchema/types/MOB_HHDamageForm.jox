    <JadeMethod name="displayDamages" id="a5d45983-0ff2-4a05-849a-ac51149ee102">
        <updating/>
        <source>displayDamages() updating;
/*
Date		Who		Reason
28 January 2009	cnwcp2	Initial creation
*/
constants
	BOTTOMOFFSET = 30;
	LEFTOFFSET = 4;
vars
	damage : CM_DamageInstance;
	taskDesc : CM_ToDoTaskDesc;
begin
	tblDamages.rows := 1;
	
	if self.myTrackedItem &lt;&gt; null then
		tblDamages.initCombos(self.myTrackedItem.IF_DamageDetails);
		tblDamages.setTableFromDamageInterface(self.myTrackedItem.IF_DamageDetails);
	endif;
	
	self.setMyCargoCheckItem();																									//cnwas3 24175 begin
	if self.myDamageCargoCheckItem &lt;&gt; null and self.myDamageCargoCheckItem.myToDoTaskDesc &lt;&gt; null then	
		taskDesc := self.myDamageCargoCheckItem.myToDoTaskDesc;
		self.chkToDo.visible := true;		
		self.chkToDo.caption := taskDesc.description;		
		self.chkToDo.move(LEFTOFFSET, self.btnThree.top - BOTTOMOFFSET, self.chkToDo.width, self.chkToDo.height);
	else
		self.chkToDo.visible := false;
		self.chkToDo.value := false;
	endif;																														//cnwas3 24175 end
	
	//21 Aug 2019	TFS 46193 - Unconditionally hide the Repair row in the Hand Held regardless of where it is called from
	self.tblDamages.accessColumn(5).visible := false;
	
	//resize the table again because the chk to do may now be visible;
	self.resizeTable();
	self.setForView();
	
epilog

end;</source>
    </JadeMethod>
