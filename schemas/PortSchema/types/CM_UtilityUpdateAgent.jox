    <JadeMethod name="utlUpdateWagonRailAlloc" id="d0fc8d6f-b0f5-4c52-8e6c-e2d182f9ebf3">
        <source>utlUpdateWagonRailAlloc(_allWagons : CM_WagonByIdDict; 
						_railAllocTemplate : CM_RailAllocation input; 
						_passport : CM_Passport input);
/*
----------   ----------  --------------------------------------------------
Created:	14 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	expectedEdition		: Integer;
	wagon				: CM_Wagon;
begin

	self.initialiseActivity();
	self.raiseExceptionIfNull(_railAllocTemplate, 'Rail Allocation Template');
	self.raiseExceptionIfNull(_allWagons, 'All wagons collection');	
	
	app.setContinueCMExceptions(true);
	app.myValUA.valWagonRailAlloc(_allWagons, _railAllocTemplate, _passport);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	foreach wagon in _allWagons do
		wagon.setRailAllocation(_railAllocTemplate, _passport);
	endforeach;

end;


</source>
        <Parameter name="_allWagons" type="CM_WagonByIdDict"/>
        <Parameter name="_railAllocTemplate" type="CM_RailAllocation" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWagonRakePositionSwap" id="c2bbbf5b-c14f-4df5-9754-710ad66889a3">
        <source>utlUpdateWagonRakePositionSwap(	_wagon1 : CM_Wagon io;
								_wagon1NewRake : CM_RailLine io;
								_wagon1NewRakePos : Integer;
								_wagon2 : CM_Wagon io;
								_wagon2NewRake : CM_RailLine io;
								_wagon2NewRakePos : Integer;
								_passport : CM_Passport input
								);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

	wagMoveController : CMIF_WagonMoveController;

begin

	self.initialiseActivity();
	exclusiveLock(_wagon1NewRake);
	exclusiveLock(_wagon2NewRake);
	exclusiveLock(_wagon1);
	exclusiveLock(_wagon2);

	if (not _passport.noErrors) then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, app.getErrorString(Wagon), null, null);
		return;
	endif;

	//clear the existing positions
	_wagon1NewRake.removeWagon(_wagon2);
	_wagon2NewRake.removeWagon(_wagon1);

	if (not _passport.noErrors) then
		return;
	endif;
	
	//26 Feb 2021	NDL	TFS 50837
	create wagMoveController transient;
	wagMoveController.autoSetEffectiveTimeStamp();
	
	app.myUtilityUA.utlUpdateWagonPosition( wagMoveController, _wagon1NewRake, _wagon1, _wagon1NewRakePos, _passport);
	
	if (not _passport.noErrors) then
		return;
	endif;
	
	app.myUtilityUA.utlUpdateWagonPosition( wagMoveController, _wagon2NewRake, _wagon2, _wagon2NewRakePos, _passport);

epilog

	delete wagMoveController;

end;</source>
        <Parameter name="_wagon1" type="CM_Wagon" usage="io"/>
        <Parameter name="_wagon1NewRake" type="CM_RailLine" usage="io"/>
        <Parameter name="_wagon1NewRakePos" type="Integer"/>
        <Parameter name="_wagon2" type="CM_Wagon" usage="io"/>
        <Parameter name="_wagon2NewRake" type="CM_RailLine" usage="io"/>
        <Parameter name="_wagon2NewRakePos" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWagonRemarks" id="61de3915-90f4-46db-afa8-3604ba1f0442">
        <source>utlUpdateWagonRemarks(_wagon : CM_Wagon input; _remarks : String; _passport : CM_Passport input);
//-----------------------------------------
//Created: January 2003 By: cnwgd1
//-----------------------------------------
vars
begin

	self.initialiseActivity();
	
	if _wagon = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, _wagon.getName, null, null);
		return;
	endif;

	exclusiveLock(_wagon);

	if (not _passport.noErrors) then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'YardJob', null, null);
		return;
