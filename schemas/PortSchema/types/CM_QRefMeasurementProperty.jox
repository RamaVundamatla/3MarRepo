<Class name="CM_QRefMeasurementProperty" id="e8e06fb8-08b7-4d0f-9048-d33042833100">
    <superclass name="CM_QReferenceLookupProperty"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="1c678d96-a46b-414f-aba1-40eb983416c6">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 December 2014	cnwma1	Initial creation

*/


vars
	oper	: CM_QueryOperator;
	
begin
	if self.isTransient then 
		return;
	endif;
	
	// Lookup property expects an object to be passed through for the "equals to" operator,
	// but we want the actual string entered - so we have to get rid of the CM_QReferenceLookup
	// operator and replace it with a CM_QDecimalEquals for this to work
	if self.allAllowedOperators.size = 1 and self.allAllowedOperators.first.isKindOf(CM_QReferenceLookup) then
		self.allAllowedOperators.purge;
	endif;
	
	create oper as CM_QDecimalEquals persistent;
	self.allAllowedOperators.add(oper);
	

	create oper as CM_QDecimalGreaterThan persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QDecimalLessThan persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QDecimalLessThanEquals persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QDecimalGreaterEquals persistent;
	self.allAllowedOperators.add(oper);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="getControlTypeForOperator" id="36382bf7-1b28-4fa3-a1f1-a8a3a4fd2fe2">
