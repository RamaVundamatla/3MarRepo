<Class name="WS_NSDSObject" id="e4f5dc4c-6df5-4092-b509-e35e481a2c24">
    <superclass name="WS_NavisProxyObject"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="gkey" id="1ce18903-afa9-48d4-becc-824f6018d800">
        <embedded/>
        <type name="Integer64"/>
    </PrimAttribute>
    <PrimAttribute name="oid" id="9f7dfa3c-057d-4772-a817-b0eafa344e75">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="sequenceNumber" id="d222f49e-bad2-4fd7-8973-4a2016b44a89">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="tableName" id="500afb3a-233a-4e75-8f4d-d06976409dfb">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="updateTimeStamp" id="6f461473-671f-4e6d-96b2-b1281e03d269">
        <embedded/>
        <type name="Integer64"/>
    </PrimAttribute>
    <JadeMethod name="setFromOpsViewTable" id="42538bcd-919d-4f64-aed8-327fd9018fd3">
        <updating/>
        <source>setFromOpsViewTable(_detail: CMIF_OpsViewTables; _seq : Integer io) updating;
/*
Purpose:			

Date		Who		Reason
09 December 2021	navab1	TFS 51853
*/

vars

begin
	self.oid    			:= _detail.oid;
	self.updateTimeStamp    := app.actualTimeServer().asEpochFormat();
	self.sequenceNumber     := app.actualTimeServer().asEpochFormat().String;

epilog

end;</source>
        <Parameter name="_detail" type="CMIF_OpsViewTables"/>
        <Parameter name="_seq" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setProxyObject" id="4c912004-d750-4603-9190-eec23047be02">
        <updating/>
        <source>setProxyObject(_any: Any) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2020 cnwma1 ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data

*/

vars

begin
	
	if _any = null then
		return;
	endif;
	

	self.sequenceNumber     := "";
	if _any.isKindOf(Object) then
		self.oid    			:= _any.Object.getOidString();
	endif;
	self.updateTimeStamp    := app.actualTimeServer().asEpochFormat();
	self.sequenceNumber     := app.actualTimeServer().asEpochFormat().String;
epilog

end;</source>
        <Parameter name="_any" type="Any"/>
    </JadeMethod>
    <JadeMethod name="setProxyObjectPrefix" id="1aaedecd-265f-4504-a891-00cdec83b424">
        <updating/>
        <source>setProxyObjectPrefix(_any: Any; _prefix : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2020 cnwma1 ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data

*/

vars

begin
	
	if _any = null then
		return;
	endif;
	

	self.sequenceNumber     := "";
	if _any.isKindOf(Object) then
		self.oid    			:= _any.Object.getOidString();
	endif;
	self.updateTimeStamp    := app.actualTimeServer().asEpochFormat();
	self.sequenceNumber     := app.actualTimeServer().asEpochFormat().String;
epilog

end;</source>
        <Parameter name="_any" type="Any"/>
        <Parameter name="_prefix" type="String"/>
    </JadeMethod>
</Class>
