        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnClear_click" id="3d3fc5ed-c179-459c-a790-b6c087568856">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClear_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		26 May 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	txtMonitor.text	:=	null;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnKillNode_click" id="996077ce-4142-4002-9ab1-b1097b460847">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnKillNode_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		29 May 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableObj	: Table;
	nodeObj		: Node;

begin
	app.mousePointer	:=	Busy;
	tableObj			:=	tblNode;

	if tableObj.row &gt; 1 and tableObj.row &lt;= tableObj.rows then
		nodeObj	:=	tableObj.cnEcGetCellObject(tableObj.row, 1).Node;

		if nodeObj &lt;&gt; null then
			system.removeNode(nodeObj);
		endif;
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnKillProcess_click" id="afaae818-9dd2-4fa1-904e-f209bff9d7a0">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnKillProcess_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		27 May 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableObj	: Table;
	processObj	: Process;

begin
	app.mousePointer	:=	Busy;
	tableObj			:=	tblProcess;

	if tableObj.row &gt; 1 and tableObj.row &lt;= tableObj.rows then
		processObj	:=	tableObj.cnEcGetCellObject(tableObj.row, 1).Process;

		if processObj &lt;&gt; null then
			system.forceOffUser(processObj.node, processObj);
		endif;
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnPause_click" id="568c2601-0d48-46da-a362-f54238141eba">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnPause_click(btn: Button input) updating;

// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
begin
	if self.aIsPaused then
		self.aIsPaused		:=	(not self.aIsPaused);
		self.doShowMonitorMessage(app.actualTimeServer().Time.String &amp; " Monitor Active");// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
		btn.caption			:=	"Pause";
		endTimer(self.BLINK_TIMER);
		lblPaused.visible	:=	false;
	else
		self.doShowMonitorMessage(app.actualTimeServer().Time.String &amp; " Monitor Paused");// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
		btn.caption			:=	"Resume";
		lblPaused.visible	:=	true;
		self.aIsPaused		:=	(not self.aIsPaused);
		beginTimer(1000, Timer_Continuous, self.BLINK_TIMER);
	endif;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cnEcKeyDown" id="068a842a-8cda-4290-838c-698d5af6db87">
        <source>cnEcKeyDown(pKeyCode: Integer io; pShift: Integer);
// --------------------------------------------------------------------------------
// Created:		03 April 2008 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	
	inheritMethod(pKeyCode, pShift);
	
	if pKeyCode = CNEC_KEY_F5 then
		self.doLoadApplicationNames();
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="pKeyCode" type="Integer" usage="io"/>
        <Parameter name="pShift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="87eb4672-dcee-4d36-aa31-e79d3345eb0c">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		26 May 2000 by cnwdad1
//
// Purpose:		Standard form load method.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	LOAD_MESSAGE	: String = "Loading BaseSchema Monitor on ";
	WAIT_MESSAGE	: String = "Waiting...";

begin
	on Exception do self.zExceptionHandler(exception) global;

	self.caption	:=	"Real-time Monitor for: "  &amp; self.getEnvironmentName()  &amp; "/" &amp; currentSchema.name;
	self.aIsPaused	:=	false;
	centreWindow();

	beginNotification(system, CNEC_MONITOR, Response_Continuous, 0);
//	beginClassNotification(Node, false, Object_Create_Event, Response_Continuous, 0);
//	beginClassNotification(Node, false, Object_Delete_Event, Response_Continuous, 0);
//	beginClassNotification(Process, false, Object_Create_Event, Response_Continuous, 0);
//	beginClassNotification(Process, false, Object_Delete_Event, Response_Continuous, 0);

	self.setMenuNameSetLogFile();
	self.doSetupTableInclude();
	self.doSetupTableExclude();
	self.doSetupTableNode();
	self.doSetupTableProcess();
	self.doLoadApplicationNames();
	self.doMenuDisplay(null, true);
	self.doResizeControls();

	self.cnEcMonitor(LOAD_MESSAGE &amp; app.computerName() &amp; ". " &amp; WAIT_MESSAGE);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoadApplicationNames" id="351ebbd7-8cd4-4319-add5-90c832273c5f">
        <source>doLoadApplicationNames() protected;
// --------------------------------------------------------------------------------
// Created:		03 May 2000 by cnwdad3
//
// Purpose:		Populate the application (process) names.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 01/10/2003	cnwdad1		Changed to no longer use a foreach to iterate the nodes
//							and processes because this left a timing hole where
//							other nodes/processes could be locked out.
// --------------------------------------------------------------------------------
constants
	PROC_BACKGROUND		: Integer = 0;	// Background process
	PROC_JADEDEV		: Integer = 1;	// JADE development (that is, JADE itself)
	PROC_USERAPP_DEV	: Integer = 2;	// A non-development process (that is, a user application running from a non-production mode database)
	PROC_USERAPP_PROD	: Integer = 3;	// A production process (that is, a user application running from a production mode database)
	PROC_JADEDEBUG		: Integer = 4;	// JADE Debugger

vars
	nodeObj			: Node;
	processObj		: Process;
	comboInclude	: ComboBox;
	comboExclude	: ComboBox;
	nodeTableObj	: Table;
	processTableObj	: Table;
	rowPointer		: Integer;
	nodeArray		: ObjectArray;
	nodeElement		: Object;
	processArray	: ObjectArray;
	processElement	: Object;

begin
	comboInclude	:=	cmbInclude;
	comboExclude	:=	cmbExclude;
	nodeTableObj	:=	tblNode;
	processTableObj	:=	tblProcess;

	comboInclude.clear();
	comboExclude.clear();
	nodeTableObj.rows		:=	1;
	processTableObj.rows	:=	1;

/*
	foreach nodeObj in system.nodes do
		rowPointer	:=	nodeTableObj.addItem(nodeObj.cnEcGetTableDisplay());
		nodeTableObj.cnEcSetCellObject(rowPointer, 1, nodeObj);

		foreach processObj in nodeObj.processes do
			if	(processObj.type.Integer = PROC_USERAPP_DEV		or
				processObj.type.Integer = PROC_USERAPP_PROD)	then

				rowPointer	:=	comboInclude.addItem(processObj.persistentApp.name &amp; " / " &amp; processObj.userCode);
				rowPointer	:=	comboExclude.addItem(processObj.persistentApp.name &amp; " / " &amp; processObj.userCode);
			endif;
		endforeach;
	endforeach;
*/
	// Populate the table of nodes.
	
	create nodeArray transient;
	Node.allInstances(nodeArray, 0, false);
	
	foreach nodeElement in nodeArray do
		nodeObj		:=	nodeElement.Node;
		rowPointer	:=	nodeTableObj.addItem(nodeObj.cnEcGetTableDisplay());
		nodeTableObj.cnEcSetCellObject(rowPointer, 1, nodeObj);
	endforeach;
	
	// Populate the filter include/exclude comboboxes with processes.
	
	create processArray transient;
	Process.allInstances(processArray, 0, false);
	
	foreach processElement in processArray do
		processObj	:=	processElement.Process;
		
		if processObj.type.Integer = PROC_USERAPP_DEV
		or processObj.type.Integer = PROC_USERAPP_PROD
		then
			rowPointer	:=	comboInclude.addItem(processObj.persistentApp.name &amp; " / " &amp; processObj.userCode);
			rowPointer	:=	comboExclude.addItem(processObj.persistentApp.name &amp; " / " &amp; processObj.userCode);
		endif;
	endforeach;
	
	btnKillNode.enabled		:=	false;
	btnKillProcess.enabled	:=	false;
epilog
	delete nodeArray;
	delete processArray;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoadNodeProcesses" id="f0b82195-0c9a-4a91-9781-e2f76e79a9b3">
        <source>doLoadNodeProcesses(pNodeObj:Node) protected;
// --------------------------------------------------------------------------------
// Created:		27 May 2000 by cnwdad1
//
// Purpose:		Populate the processes for a node in the data table.
//
// Parameters:	pNodeObj - The node who's processes to load.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 01/10/2003	cnwdad1		Changed to no longer use a foreach to iterate the processes
//							because this left a timing hole where, other nodes/processes
//							could be locked out.
// --------------------------------------------------------------------------------
vars
	tableObj			: Table;
	processObj			: Process;
	rowDisplay			: String;
	rowIndex			: Integer;
	processArray		: ObjectArray;
	processElementObj	: Object;

begin
	tableObj		:=	tblProcess;
	tableObj.rows	:=	1;
	
//	foreach processObj in pNode.processes do
//		rowIndex	:=	tableObj.addItem(processObj.cnEcGetTableDisplay());
//		tableObj.cnEcSetCellObject(rowIndex, 1, processObj);
//	endforeach;
	
	// Populate the table of processes.
	
	create processArray transient;
	Process.allInstances(processArray, 0, false);
	
	foreach processElementObj in processArray do
		processObj	:=	processElementObj.Process;
		rowIndex	:=	tableObj.addItem(processObj.cnEcGetTableDisplay());
		tableObj.cnEcSetCellObject(rowIndex, 1, processObj);
	endforeach;
	
	btnKillProcess.enabled	:=	false;
epilog
	delete processArray;
end;</source>
        <access>protected</access>
        <Parameter name="pNodeObj" type="Node"/>
    </JadeMethod>
    <JadeMethod name="doMenuDisplay" id="8770b959-f9ee-4b20-84ec-1af6d51c9665">
        <source>doMenuDisplay(pMessage:String; pIsClosed:Boolean) protected;
// --------------------------------------------------------------------------------
// Created:		02 May 2000 by cnwdad2
//
// Purpose:		Display a menu description on the status bar.
//
// Parameters:	pMessage - The message/description to show.
//				pIsClosed - If true, the menu is being closed.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pIsClosed then
		statusLine.caption	:=	self.STATUS_READY;
	else
		statusLine.caption	:=	pMessage;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pMessage" type="String"/>
        <Parameter name="pIsClosed" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMessageLog" id="b200e045-f773-484f-9085-b30ec081edfb">
        <source>doMessageLog(pLogMessage:String) protected;
// --------------------------------------------------------------------------------
// Created:		25 May 2000 by cnwdad1
//
// Purpose:		Write a message to a log file.
//
// Parameters:	pLogMessage - The message to write to the log file.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.mnuSettingsLog.checked and self.aMyLogFile &lt;&gt; null then
		self.aMyLogFile.writeLine(pLogMessage);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pLogMessage" type="String"/>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="1f103f82-20c5-43cb-85d1-d59fde4b7190">
        <source>doResizeControls() protected;
// --------------------------------------------------------------------------------
// Created:		02 May 2000 by cnwdad2
//
// Purpose:		Resizes all of the form's child controls, typically after the form
//				itself has been resized.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	rulerMenu.move(1, 1, self.width, rulerMenu.height);
	self.doResizeTables();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResizeTables" id="518f5a38-b7c1-4221-ac40-0cb29dfb8b39">
        <source>doResizeTables() protected;
// --------------------------------------------------------------------------------
// Created:		27 May 2000 by cnwdad1
//
// Purpose:		Resize the data table control and its columns within.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableObj			: Table;
	columnWidthArray	: IntegerArray;

begin
	tableObj	:=	tblNode;

	tableObj.move(	tableObj.left,
					tableObj.top,
					(fldMonitor.width - (tableObj.left * 2) - 6),
					tableObj.height);	//(shtProcesses.height - ((tableObj.top * 3) + btnKill.height + 3)));

	create columnWidthArray transient;
	columnWidthArray.add(40);
	columnWidthArray.add(20);
	columnWidthArray.add(40);
	tableObj.cnEcSetColumnWidths(columnWidthArray);

	columnWidthArray.clear();
	tableObj	:=	tblProcess;

	tableObj.move(	tableObj.left,
					tableObj.top,
					(fldMonitor.width - (tableObj.left * 2) - 6),
					(fldMonitor.height - tableObj.top - 58));	//(shtProcesses.height - ((tableObj.top * 3) + btnKill.height + 3)));

	columnWidthArray.add(20);
	columnWidthArray.add(20);
	columnWidthArray.add(20);
	columnWidthArray.add(20);
	columnWidthArray.add(20);
	tableObj.cnEcSetColumnWidths(columnWidthArray);
epilog
	delete columnWidthArray;
end;</source>
        <access>protected</access>
    </JadeMethod>
