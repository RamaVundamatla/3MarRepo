    <JadeMethod name="par29012" id="4eeddecf-739b-430d-8bbb-3267c2eecc34">
        <source>par29012();
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries	
//  (re)create query def objects
vars
	root	: CM_Root;
	qdef	: CM_QueryDefinition;
begin
	app.initialize;
	root := app.myRoot;
	beginTransaction;
	foreach qdef in root.allQueryDefinitionObjects do
		if qdef.type = CM_QueryDefinition.Transaction_Query_Type then
			write qdef;
			delete qdef;
		endif;
	endforeach;
	commitTransaction;

	beginTransaction; 
	root.sendMsgWithParams("createQueryDefinitionObject", null, CM_QueryDefinition.Transaction_Query_Type, CM_QueryDefinition.CargoTransaction_Query_Mode);
	root.sendMsgWithParams("createQueryDefinitionObject", null, CM_QueryDefinition.Transaction_Query_Type, CM_QueryDefinition.EventTransaction_Query_Mode);
	root.sendMsgWithParams("createQueryDefinitionObject", null, CM_QueryDefinition.Transaction_Query_Type, CM_QueryDefinition.HMSTransaction_Query_Mode);
	commitTransaction;
end;
</source>
    </JadeMethod>
    <JadeMethod name="par29234" id="2ca0cdbc-bb14-464b-888c-9e463a3be9b6">
        <source>par29234();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 March 2012	cnwrd1	Initial creation

*/

vars
	term : CM_Terminal;
	aVoyage : CM_Voyage;
	aTI : CM_TrackedItem;
	badLoc,
	ignorArchive : Boolean;
	locCont : CM_LocationsController;
	count : Integer;
	theUser : CM_User;
begin

	app.initialize();
	theUser := CM_Root.firstInstance.allUsers["CNWRD1"];
	app.myPassport.setMyUser(theUser);
	
	on Exception do app.handleDeletedObject(exception, locCont, badLoc); 

	foreach term in CM_Terminal.instances do
	
		foreach aVoyage in term.allVoyagesByCode do
		
		foreach aTI in aVoyage.allOnshipTIsByCargoTypeId do
			count := count +1;
			if aTI.isChild then
				locCont := aTI.myPrimaryActualLocation;
				
				if locCont = null then
					continue;
				endif;
				
				ignorArchive := locCont.ignoreArchiving;
				
				if badLoc and locCont &lt;&gt; null then
					//aTI.inspectModal;
					
					write "Terminal : " &amp; term.code &amp; " voyage : " &amp; aVoyage.code &amp; " cargo item : " &amp;  aTI.id &amp; " oid :" &amp; aTI.getOidAsString &amp; " parent : " &amp; aTI.myParent.id &amp; " location :" &amp; aTI.myParent.myPrimaryActualLocation.getFullId;
					
					break;
				endif;
			endif;
			
		endforeach;
		
		endforeach;
	
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="par29698" id="95677cdd-37aa-463a-8318-af4e0e561b81">
        <source>par29698();
/*

Purpose:		Post-CCMS 1264, existing non-posted non-void non-manual invoice lines need their quantity and rate explicitly set.

Parameters:			

Return Value:		


Date		Who		Reason
18 June 2012	cnwjre1	Initial creation

*/

vars
	term	: CM_Terminal;
	bank	: CM_Bank;
	invoice	: CM_Invoice;
	line	: CM_InvoiceLine;
	iter	: Iterator;
	count	: Integer;
begin
	app.initialize;
	
	beginTransaction;
	foreach term in app.myRoot.allTerminals do
		foreach bank in term.companies do
			delete iter;
			iter := bank.invoicesByStatus.createIterator();
			// open and pending, skip posted and void
			bank.invoicesByStatus.startKeyGeq(CM_Invoice.INVOICE_OPEN, iter);
			while iter.next(invoice)  do
				if invoice.status &gt; CM_Invoice.INVOICE_PENDING then
					break;
				endif;
				count := count + 1;
				foreach line in invoice.invoiceLines do
					if not line.manual and
					   line.debtor &lt;&gt; null then
						line.convert();
					endif;
				endforeach;
			endwhile;
			iter.reset();
			// suspense
			bank.invoicesByStatus.startKeyGeq(CM_Invoice.INVOICE_SUSPENSE, iter);
			while iter.next(invoice)  do
				if invoice.status &gt; CM_Invoice.INVOICE_SUSPENSE then
					break;
				endif;
				count := count + 1;
				foreach line in invoice.invoiceLines do
					if not line.manual and
					   line.debtor &lt;&gt; null then
						line.convert();
					endif;
				endforeach;
			endwhile;
		endforeach;
	endforeach;
	commitTransaction;
	write count;
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="par31478" id="343dfe9c-bd8a-44d7-8cf4-f059ea666c8c">
        <source>par31478();

/*

Purpose:		Load debtors from csv file for DPH
				Loaded into test on 7/5/2013 and production on 13/5/2013.

Parameters:			

Return Value:		


Date		Who		Reason
26/04/2013	cnwjre1	Initial creation
09/08/2018	jlgdap1	TFS 40092 New parameter for CM_DebtorNode::setProxy
*/

vars
	count, numCodes, noLines 			: Integer;
	fieldNo								: Integer;
	fieldValue							: String;
	address1, address2, address3, address4, address5, phone	: String;
	debtorName,debtorCode, debtorParent, debtorType, debtorAddress, purchOrder,
	account, terms, carrier, consignor, operator, remarks, fileLine	: String;
	poMandatory, zeroRated, suspended								: Boolean;
	fieldArray, debtorArray											: CnStringArray;
	file								: File;
	myParentDebtor,	newDebtor, pxyDebtorNode 						: CM_DebtorNode;
	thePassport							: CM_Passport;
	debtorNodeController				: CMIF_DebtorNode;
	myTofT								: CM_InvoiceTermsOfTrade;
	myCarrier							: CM_Carrier;
	myOperator							: CM_Operator;
	myConsignor							: CM_ConsigneeConsignor;
	myDebtorType						: CM_DebtorType;
	err									: CM_Error;
	errorStore							: CM_ErrorSet;
	controllerArray						: ObjectArray;
	obj									: Object;
	agent								: CM_TrxControlCreateAgent;
	
begin
// *** REMOVE the return to run this for real
return;
	app.initialize();

	thePassport := app.myPassport;
	
	create controllerArray transient;
	create fieldArray transient;
	create debtorArray transient;
	create errorStore transient;
	
	create file transient;
	file.kind := File.Kind_Unknown_Text;	// 29/2/16 cnwmp6 PAR 36286 unicode version
	file.usePresentationFileSystem := true;
	file.openInput("c:\temp\Customer Listing-5-8.csv");
	
	while not file.endOfFile() do
		fileLine 	:= file.readLine;
		noLines		:= noLines + 1;
		if fileLine = null then
			continue;
		endif;
		
		fieldArray.clear;
		fileLine.csvToStringArray(fieldArray, ",");
		
		if fieldArray.isEmpty then
			continue;
		endif;
		
		debtorName		:= null;
		debtorCode      := null;
		debtorParent	:= null;
		debtorAddress	:= null;
		address1		:= null;
		address2		:= null;
		address3		:= null;
		address4		:= null;
		address5		:= null;
		phone			:= null;
		remarks			:= null;
		account			:= null;
		purchOrder		:= null;
		poMandatory		:= null;
		terms			:= null;
		zeroRated		:= null;
		suspended		:= null;
		carrier			:= null;
		consignor		:= null;
		operator		:= null;
		debtorType		:= null;
		
		fieldNo :=	0;
		
		foreach fieldValue in fieldArray do
			fieldNo	:=	fieldNo + 1;
			
			if fieldNo = 1 then
				account		:=  fieldValue.trimBlanks();
			elseif fieldNo = 2 then
				debtorName	:= fieldValue.trimBlanks()[1:40];
			elseif fieldNo = 3 then
				address1	:= fieldValue.trimBlanks();
			elseif fieldNo = 4 then
				address2	:= fieldValue.trimBlanks();
			elseif fieldNo = 5 then
				address3	:= fieldValue.trimBlanks();
			elseif fieldNo = 6 then
				address4	:= fieldValue.trimBlanks();
			elseif fieldNo = 7 then
				address5	:= fieldValue.trimBlanks();
			elseif fieldNo = 8 then
				phone		:= fieldValue.trimBlanks();
			endif;
		endforeach;
		
		myParentDebtor	:= null;
		myTofT	:= null;
		myCarrier	:= null;
		myOperator	:= null;
		myConsignor	:= null;
		myDebtorType	:= null;
		debtorAddress := address1;
		if address2 &lt;&gt; null then
			debtorAddress := debtorAddress &amp; CrLf &amp; address2;
		endif;
		if address3 &lt;&gt; null then
			debtorAddress := debtorAddress &amp; CrLf &amp; address3;
		endif;
		if address4 &lt;&gt; null or
		   address5 &lt;&gt; null then
			debtorAddress := debtorAddress &amp; CrLf &amp; address4 &amp; "  " &amp; address5;		// state and zip
		endif;
		remarks := phone;		// phone number to remarks, not in address
		
		if not debtorArray.includes(debtorName) then
			create debtorNodeController transient;
			debtorNodeController.setForImport(debtorName, debtorAddress, remarks, account, purchOrder, poMandatory, zeroRated, suspended, myParentDebtor, myTofT, myCarrier, 
												myOperator, myConsignor,  myDebtorType, null,null,null,false,null,null,null);

			create pxyDebtorNode as CM_Debtor transient;
			debtorNodeController.myPxyDebtorNode := pxyDebtorNode;
			//pxyDebtorNode.setProxy(debtorNodeController.name);								// TFS 40092
			pxyDebtorNode.setProxy(debtorNodeController.name, debtorNodeController.code);		// TFS 40092
			controllerArray.add(debtorNodeController);
			debtorArray.add(debtorName);
		else
			create err transient;
			err.set(0, app.getErrorString(INV_Debtor) &amp; ' : ' &amp; app.getErrorString2(Line_duplicate_file, noLines.String, app.getErrorString(INV_Debtor_Register)) &amp; debtorName, false, '', debtorNodeController, null);
			errorStore.add(err);
		endif;		
	endwhile;
	
	
	count:= 0;
	numCodes := controllerArray.size;
	
	// Start the transaction
	beginTransaction;
	
	// Perform the operation
	foreach obj in controllerArray do
		debtorNodeController	:= obj.CMIF_DebtorNode;
		count := count + 1;
		
		app.myUtilityCA.utlCreateDebtorNode(debtorNodeController, newDebtor, thePassport);

		if thePassport.hasErrors then
			foreach err in thePassport.allErrors do 
				err.setErrorText(app.getErrorString(INV_Debtor) &amp; ' : ' &amp; debtorNodeController.name &amp; '  ' &amp; err.text, false);
				errorStore.add(err);
			endforeach;
			foreach err in thePassport.allErrors do 
				err.removeFromPassport;
			endforeach;
		endif;
	endforeach;
	commitTransaction;
	
	create agent transient;
	agent.trxWriteToLogFile(file.fileName, noLines, count, thePassport, errorStore);
	
epilog
	delete debtorArray;
	delete fieldArray;
	if controllerArray &lt;&gt; null then
		controllerArray.purge;
		delete controllerArray;
	endif;
	if file &lt;&gt; null then
		if file.isOpen() then
			file.close;
		endif;
		delete file;
	endif;
	delete errorStore;
	delete agent;
end;
</source>
    </JadeMethod>
    <JadeMethod name="par36424CheckBookings" id="53f3e7cf-37ab-42d1-8063-2e3a9cb91b79">
        <source>par36424CheckBookings();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Sep 2015	cnwkpd1	PAR #36424 - Check CM_BookingRef collections

*/
vars
	t				: CM_Terminal;
	v				: CM_Voyage;
	c				: CM_ConsigneeConsignor;
	b				: CM_BookingRef;
	voyages,
	terminals,
	consignees		: ObjectArray;
	iter, iter2		: Iterator;
	codeKey			: String;
	refKey			: String;
	refVoy          : CM_Voyage;
	badOne			: Boolean;
	  file : File;
begin
     create file transient;
	file.mode := File.Mode_Output;	// 29/2/16 cnwmp6 PAR 36286 unicode version
    file.fileName := "c:\temp\test.txt";

	//////////////////////////////////////////////////////////////CM Voyage 
	
	create voyages transient;
	CM_Voyage.allInstances(voyages, 0, true);
	iter := voyages.createIterator();
	
	file.writeLine("======================CM_Voyage======================================="); 
	while iter.next(v) do
		delete iter2;
		iter2 := v.allBookingRefs.createIterator();
		
		while iter2.next(b) do
			badOne := false;
			v.allBookingRefs.getIteratorKeys(codeKey, refKey, iter2);
			
			if b.bookingReference &lt;&gt; refKey then
				badOne := true;
			endif;
			if b.myOperator &lt;&gt; null and b.myOperator.code &lt;&gt; codeKey then
				badOne := true;
			endif;
			if b.myOperator = null and codeKey &lt;&gt; null then
				badOne := true;
			endif;
			
			if not badOne then
				continue;
			endif;
			//write v.String &amp; Tab &amp; b.String;
			file.writeLine( v.String &amp; Tab &amp; b.String &amp;Tab &amp; "Booking Operator ="&amp; b.myOperator.code);
		endwhile;
	endwhile;
	
	file.writeLine("======================CM_Voyage======================================="); 
	file.writeLine("   ");
	///////////////////////////////////////////////////////////////CM_Terminal
	create terminals transient;
	CM_Terminal.allInstances(terminals, 0, true);
	iter := terminals.createIterator();
	file.writeLine("======================CM_Terminal======================================="); 
	while iter.next(t) do
		delete iter2;
		iter2 := t.allBookingRefsByOperatorRef.createIterator();
		while iter2.next(b) do
			badOne := false;
			t.allBookingRefsByOperatorRef.getIteratorKeys(codeKey, refKey, refVoy,iter2);
			if b.bookingReference &lt;&gt; refKey then
				badOne := true;
			endif;
			if b.myOperator &lt;&gt; null and b.myOperator.code &lt;&gt; codeKey then
				badOne := true;
			endif;
			if b.myOperator = null and codeKey &lt;&gt; null then
				badOne := true;
			endif;
			if not badOne then
				continue;
			endif;
			file.writeLine( t.String &amp; Tab &amp; b.String &amp;Tab &amp; "Booking Operator ="&amp; b.myOperator.code);
		endwhile;
	endwhile;
	file.writeLine("======================CM_Terminal======================================="); 
	file.writeLine("   ");
	///////////////////////////////////////////////////////////////CM_ConsigneeConsignor
	create consignees transient;
	CM_ConsigneeConsignor.allInstances(consignees, 0, true);
	iter := consignees.createIterator();
	file.writeLine("=======================CM_ConsigneeConsignor===================="); 
	while iter.next(c) do
		delete iter2;
		iter2 := c.allBookingRefsByOperatorRef.createIterator();
		while iter2.next(b) do
			badOne := false;
			c.allBookingRefsByOperatorRef.getIteratorKeys(t,codeKey, refKey, refVoy,iter2);
			if b.bookingReference &lt;&gt; refKey then
				badOne := true;
			endif;
	
			/*if b.myTerminal &lt;&gt; t then
				badOne :=true;
			endif;*/
			
			if b.myOperator &lt;&gt; null and b.myOperator.code &lt;&gt; codeKey then
				badOne := true;
			endif;
			if b.myOperator = null and codeKey &lt;&gt; null then
				badOne := true;
			endif;
			
			if not badOne then
				continue;
			endif;
			
			file.writeLine( c.String &amp; Tab &amp; b.String &amp;Tab &amp; "Booking Operator ="&amp; b.myOperator.code);
		endwhile;
	endwhile;
	file.writeLine("=======================CM_ConsigneeConsignor====================");  
	file.writeLine("   ");
	file.writeLine( "Finished");
	file.close();
	
	/*beginTransaction;
	"2190.19191".asOid.CM_ConsigneeConsignor.allBookingRefsByOperatorRef.rebuild;
	commitTransaction;*/
	
epilog
	delete voyages;
	delete terminals;
	delete consignees;
	delete file;
end;</source>
    </JadeMethod>
    <JadeMethod name="par36424FixBookings" id="1b8a776b-cfb1-48f2-9f2f-45f4c34de859">
        <source>par36424FixBookings();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Sep 2015	cnwkpd1	PAR #36424 - Check CM_BookingRef collections
*/

vars
	t				: CM_Terminal;
	v				: CM_Voyage;
	c				: CM_ConsigneeConsignor;
	b				: CM_BookingRef;
	voyages,
	terminals,
	consignees		: ObjectArray;
	iter, iter2		: Iterator;
	codeKey			: String;
	refKey			: String;
	refVoy          : CM_Voyage;
	badOne			: Boolean;

begin
	
	///////////////////////////////////////////////////////////////CM_Terminal
	create terminals transient;
	CM_Terminal.allInstances(terminals, 0, true);
	delete iter;
	iter := terminals.createIterator();
	
	while iter.next(t) do
		delete iter2;
		iter2 := t.allBookingRefsByOperatorRef.createIterator();
		badOne := false;
		while iter2.next(b) do
			
			t.allBookingRefsByOperatorRef.getIteratorKeys(codeKey, refKey, refVoy,iter2);
			if b.bookingReference &lt;&gt; refKey then
				badOne := true;
				break;
			endif;
			if b.myOperator &lt;&gt; null and b.myOperator.code &lt;&gt; codeKey then
				badOne := true;
				break;
			endif;
			if b.myOperator = null and codeKey &lt;&gt; null then
				badOne := true;
				break;
			endif;
		
		endwhile;
			
		if badOne then
			beginTransaction;
			t.allBookingRefsByOperatorRef.rebuild;
			commitTransaction;
		endif;
	endwhile;
	///////////////////////////////////////////////////////////////CM_Voyage
	create voyages transient;
	CM_Voyage.allInstances(voyages, 0, true);
	delete iter;
	iter := voyages.createIterator();
	
	while iter.next(v) do
		delete iter2;
		iter2 := v.allBookingRefs.createIterator();
		
		badOne := false;

		while iter2.next(b) do
			v.allBookingRefs.getIteratorKeys(codeKey, refKey, iter2);
			
			if b.bookingReference &lt;&gt; refKey then
				badOne := true;
				break;
			endif;
			if b.myOperator &lt;&gt; null and b.myOperator.code &lt;&gt; codeKey then
				badOne := true;
				break;
			endif;
			if b.myOperator = null and codeKey &lt;&gt; null then
				badOne := true;
				break;
			endif;
		endwhile;
		
		if badOne then
			beginTransaction;
			v.allBookingRefs.rebuild;
			commitTransaction;
		endif;
	endwhile;
	

	///////////////////////////////////////////////////////////////CM_ConsigneeConsignor
	create consignees transient;
	CM_ConsigneeConsignor.allInstances(consignees, 0, true);
	delete iter;
	iter := consignees.createIterator();

	while iter.next(c) do
		delete iter2;
		iter2 := c.allBookingRefsByOperatorRef.createIterator();
		badOne := false;
		while iter2.next(b) do
			
			c.allBookingRefsByOperatorRef.getIteratorKeys(t,codeKey, refKey, refVoy,iter2);
			if b.bookingReference &lt;&gt; refKey then
				badOne := true;
				break;
			endif;
	
			/*if b.myTerminal &lt;&gt; t then
				badOne :=true;
				break;
			endif;*/
			
			if b.myOperator &lt;&gt; null and b.myOperator.code &lt;&gt; codeKey then
				badOne := true;
				break;
			endif;
			if b.myOperator = null and codeKey &lt;&gt; null then
				badOne := true;
				break;
			endif;
			
		endwhile;
		if badOne then
			beginTransaction;
			c.allBookingRefsByOperatorRef.rebuild;
			commitTransaction;
		endif;
	endwhile;

epilog
	delete voyages;
	delete terminals;
	delete consignees;
end;</source>
    </JadeMethod>
    <JadeMethod name="par36718" id="4f28b5a5-79fc-40fc-b444-ad05b631c280">
        <source>par36718();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 November 2015	cnwndl1	Initial creation

*/

vars

	menuHdr : CM_MenuUserHdr;
	iter : Iterator;
	objArray : ObjectArray;
	parent : CM_MenuEntity;
	obj : Object;

begin

	create objArray transient;

	iter := CM_MenuUserHdr.instances.createIterator;
	while iter.next( menuHdr ) do
		if menuHdr.myParent = null then
			write menuHdr.String &amp; " - null parent";
			continue;
		endif;
		if menuHdr.myParent.isKindOf( CM_MenuRootReportUserTerminal ) then
			continue;
		endif;
		if menuHdr.myParent.isKindOf( CM_MenuRootUserTerminal ) then
			continue;
		endif;
		if menuHdr.myParent.isKindOf( CM_MenuRootForUser ) then
			continue;
		endif;
		if menuHdr.myParent.isKindOf( CM_MenuRootForRoot ) then
			continue;
		endif;
		if menuHdr.myParent.isKindOf( CM_MenuRootReportForRoot ) then
			continue;
		endif;
		if menuHdr.myParent.isKindOf( CM_MenuUserRootForRoot ) then
			continue;
		endif;
		if menuHdr.myParent.isKindOf( CM_MenuUserReportRootForRoot ) then
			continue;
		endif;
		if menuHdr.myParent.isKindOf( CM_MenuRootQuery ) then
			continue;
		endif;
		if menuHdr.myParent.isKindOf( CM_MenuRootUserBackgroundReps ) then
			continue;
		endif;
		if menuHdr.myParent.isKindOf( CM_MenuUserHdr ) then
			if menuHdr.myMenuRoot &lt;&gt; null then
				continue;
			endif;
			parent := menuHdr.myParent;
			if menuHdr = parent then
				continue;
			endif;
			objArray.clear;
			while parent.isKindOf( CM_MenuUserHdr ) do
				if parent.CM_MenuUserHdr.myMenuRoot &lt;&gt; null then
					break;
				endif;
				if objArray.includes(parent) then
					menuHdr.inspectModal();
					write menuHdr.String &amp; " - circular reference (" &amp; menuHdr.heading &amp; ")";
					break;
				endif;
				objArray.add(parent);
				parent := parent.myParent;
			endwhile;
		endif;
		
	endwhile;
	

epilog

	delete iter;
	delete objArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="pelFixServices" id="0a9d36f3-a9af-4563-8819-107c035f9f3f">
