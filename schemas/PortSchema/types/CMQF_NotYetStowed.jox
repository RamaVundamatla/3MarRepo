<Class name="CMQF_NotYetStowed" id="eb38b9c9-3940-43fb-ab05-668203d44ba7">
    <superclass name="CMQF_TrackedItem"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="filterObjects" id="a3231e3a-8a35-4e59-8d77-06c0c58102cb">
        <updating/>
        <source>filterObjects(_collection  : Collection input; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:		28 January 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	ti				: CM_TrackedItem;
	terminal		: CM_Terminal;
	breakOut		: Boolean;
begin

		//search all onsite (normal) and notified colls
	foreach terminal in self.allTerminals do
		//TI_STATE_NORMAL
		foreach ti in terminal.allOnsiteTIsByIdCargoType discreteLock do
			if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//			if self.includesObject(ti, _passport, breakOut) then
				if not _collection.includes(ti) then
					_collection.add(ti);
				endif;
			endif;
			
//			if breakOut then
//				return;
//			endif;
		endforeach;
		
		//search notified ti's
		//TI_STATE_NOTIFIED
		foreach ti in terminal.allNotifiedTIsByIdCargoType discreteLock do
			if self.checkStatusIncludesObject(ti, _passport, breakOut) then
	//		if self.includesObject(ti, _passport, breakOut) then
				if not _collection.includes(ti) then
					_collection.add(ti);
				endif;
			endif;
	//		if breakOut then
	//			return;
	//		endif;
		endforeach;	
	endforeach;
	
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="cb6e0e07-0b00-41cc-b18d-2dcd16a104fe">
        <updating/>
        <source>includesObject(_ti: CM_TrackedItem; _passport : CM_Passport; _breakOut : Boolean output): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:		28 January 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 15/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport for tranships
vars

begin
	if	(not _ti.isKindOf(CM_Log))
	and (not _ti.isChild)			//exclude packed/attached items
	and inheritMethod(_ti, _passport, _breakOut) then	
		if _ti.state = TI_STATE_NOTIFIED then
				
				//if _ti.isExport 														// PAR #25021
				if (_ti.isExport or _ti.isTranshipOutbound) 							// PAR #25021
				and _ti.plannedSite &lt;&gt; TI_SITE_ONSHIP then
					return true;
				endif;
		
		elseif	_ti.state = TI_STATE_NORMAL then
		
				//if (_ti.isExport or _ti.isInTransitOnShip)							// PAR #25021
				if (_ti.isExport or _ti.isTranshipOutbound or _ti.isInTransitOnShip)	// PAR #25021
				and _ti.plannedSite = TI_SITE_UNDEFINED then
					return true;
				endif;
	
		endif; 
	endif;
	
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
